    <JadeMethod name="draftMax" id="e11c433d-a3da-4c45-ab95-9c350d145dcd">
        <methodInvocation>mapping</methodInvocation>
        <source>draftMax(set: Boolean; _value: Decimal io) mapping;
//4.1.1 Draft Enhancements. 
//DraftMax is a virtual read only proprty. It returns the forward or aft draft
//for the movement, whichever is the greater.
vars

begin
	if set = false then
 	  	if draftFwd &gt; draftAft then
  	 		_value := draftFwd;
   		else
   			_value := draftAft;
   		endif;
   	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="erase" id="11cc2d37-d395-4d74-9296-35a449007b8b">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//----------------------------------------------------------------------------------------------------
// Created:	20 Dec 2007 By cnwvu1. Par 15582
// Purpose: 
//		when erasing a movement, we should rebuild relationship: myNextMovement and myPreviousMovement
//----------------------------------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------------------------
// 21/09/2018	jlgdap1		TFS 40543 PEL1 WP Time Change does not display all relevant work orders
vars
	wo : CM_WorkOrder;
	woDtl : CM_WorkOrderDtl;
	
begin

	//20 Mar 2019	NDL	TFS 43894 - moved essence of code to validateForDelete
/*	if self.myHMSVoyageData &lt;&gt; null and self.myHMSVoyageData.myVoyage &lt;&gt; null then // Testing.... TFS 42043
		// TFS 40543 Chdeck whether this movement is attached to one of my voyage's work orders
		foreach wo in self.myHMSVoyageData.myVoyage.allWorkOrders discreteLock do
			foreach woDtl in wo.allWoDtls discreteLock do
				if woDtl.isKindOf(CM_WodShiftMovement) and woDtl.CM_WodShiftMovement.myHMSVoyageMovement = self then
					woDtl.CM_WodShiftMovement.setMyHMSVoyageMovement(null);
				endif;
			endforeach;
		endforeach;
		// TFS 40543 end
	endif; */
	
	inheritMethod(_eraseLevel);
end;
</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findAndLinkCancelledShift" id="9b757757-cc7a-41ba-800f-9aa7f4b99888">
        <updating/>
        <source>findAndLinkCancelledShift() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2018	jlgndl1	Initial creation	TFS 42043

	Cancelled Shift movements are not supposed to create replacements straight away ( unlike cancelling Arrival and Deoparture )
	So when a new shift movment is created, we have to check and see if there is a prevgiously cancelled shift movement that we are 
	replacing.  Cancelled movements are NOT in teh HMS_VoyageData collectiuon of movements, so we have to find them from the voyages
	collection of work orders, where there is a one way reference to an associated Movement.

*/

vars

	voyage : CM_Voyage;

begin

	if self.isTransient then
		return;
	elseif self.moveType &lt;&gt; HMSMovementTypeShift then
		//we are not a shift movement, handles at time of creation of the replacement
		return;
	elseif self.myCancelledMovement &lt;&gt; null then
		//we are already linked to our cancelled movement, do nothing
		return;
	endif;
	
	//If we are a new shift movement, and there is a pre-existing cancelled shift movement
	// that is not linked to a replacement, link it up. 
	
	voyage := self.myHMSVoyageData.myVoyage;
	if voyage &lt;&gt; null then
		self.setMyCancelledMovement(  voyage.findUnlinkedCancelledShift() );
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllPilotLaunches" id="5335df9f-a992-4d72-9846-64346627493b">
        <source>getAllPilotLaunches(_objectSet : CM_ObjectSet io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	movementPilotDetails : HMS_MovementPilotDetails;
begin
	foreach movementPilotDetails in self.allMovementPilotDetails where movementPilotDetails.myPilotLaunch &lt;&gt; null do
		_objectSet.add(movementPilotDetails.myPilotLaunch);
	endforeach;
epilog

end;</source>
        <Parameter name="_objectSet" type="CM_ObjectSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllResourceUsedForClass" id="4c004324-93ed-468e-924c-656770648c94">
        <source>getAllResourceUsedForClass(_class : Class; _allResourceUsed : HMS_ResourceUsedSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2018	jlger1	Initial creation

*/

vars
	hmsResourceUsed : HMS_ResourceUsed;
begin
	if _allResourceUsed = null then
		return;
	endif;
	
	foreach hmsResourceUsed in self.allResourceUsed discreteLock do
		if hmsResourceUsed.myResource = null then
			continue;
		endif;
		if hmsResourceUsed.myResource.isResourceForClass(_class) then
			_allResourceUsed.add(hmsResourceUsed);	
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_allResourceUsed" type="HMS_ResourceUsedSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBridgeMark" id="979d2148-a199-4930-b453-3ab770802dd9">
        <source>getBridgeMark() : String;
//--------------------------------------------------
// Created:	28 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.bowMarkTo &gt; self.sternMarkTo then
		return (self.bowMarkTo - self.myHMSVoyageData.dist_BridgeToBow).asStringJMT();	// 24363 17/06/2010
	else
		return (self.bowMarkTo + self.myHMSVoyageData.dist_BridgeToBow).asStringJMT();	// 24363 17/06/2010
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultResourceForType" id="1490c32f-37c4-4332-8939-dfc1db86cda4">
        <source>getDefaultResourceForType(_resourceType : HMS_ResourceType) : HMS_Resource;
//--------------------------------------------------
// Created:	26 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpResourceUsed : HMS_ResourceUsed;
begin
	if _resourceType = null then
		return null;
	endif;
	foreach tmpResourceUsed in self.allResourceUsed do
		if tmpResourceUsed.myResourceType = _resourceType then
			if tmpResourceUsed.myResource &lt;&gt; null then
				if tmpResourceUsed.myResource.myResourceType = _resourceType then
					return tmpResourceUsed.myResource;
				endif;
			endif;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="_resourceType" type="HMS_ResourceType"/>
        <ReturnType type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="getDefaultResourceUsed" id="66f1a969-6ebc-497e-8ab8-1c9482e529a9">
        <source>getDefaultResourceUsed(_resource : HMS_Resource) : HMS_ResourceUsed;
//--------------------------------------------------
// Created:	26 October 2005 By: cnwab1
//--------------------------------------------------
vars
	tmpResourceUsed : HMS_ResourceUsed;
begin
	if _resource = null then
		return null;
	endif;
	foreach tmpResourceUsed in self.allResourceUsed do
		if tmpResourceUsed.myResource = _resource then
			return tmpResourceUsed;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="_resource" type="HMS_Resource"/>
        <ReturnType type="HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="b1bbba14-fa1c-44bf-91bc-e348629b0169">
        <source>getDisplayString(): String;
//--------------------------------------------------
// Created:	05 April 2004 By: cnwgd1
//--------------------------------------------------
vars
begin
	
	return self.myHMSVoyageData.getDisplayString();

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="cc55f537-837e-48d3-842f-e3dab6cd20c9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	05 April 2004 By: cnwgd1
// 26/07/2011	PAR27908	cnwsh3	To Berth and From Berth were displaying the incorrect values.
// 23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
// 08/02/2022	jlika1	52659	SAL - HMS Movement Current Berth  
//--------------------------------------------------

vars
	tmpMovePrev,
 	tmpMoveNext		: HMS_VoyageMovement;
	tmpTug 			: HMS_Tug;
	tmpStr 			: String;
	offsetTime,
  	orderTime		: Time;
	defaultTideClass: HMS_TidalClass;
	tmpResourceUsed	: HMS_ResourceUsed;	
	seaHarbourRegion: HMS_HarbourRegion;
	seaHRArrivalBerth: HMS_Berth;
	str : String;
	voyage : CM_Voyage;	//05 Nov 2018	NDL	TFS 41687
	
begin

	if _attrName = ETRow_OccursOnDTNEW then
		return self.systemToLocalTime(self.occursOnDTNEW).shortCurrentLocaleFormat();	// 24/5/16	cnwmp6	TFS 488 - Multi timezone support
		
	elseif _attrName = ETRow_CustomerForMovement then
		if self.isAgentDefault then
			return app.getErrorString(Agent);
		else
			return app.getErrorString(Shipping_Line);
		endif;
	elseif _attrName = ETRow_HmsMovementVoyage then
		return self.myHMSVoyageData.myVoyage.code;
	elseif _attrName = ETRow_HmsMovementLOA then
		return self.myHMSVoyageData.dim_LengthOverall.String;
	elseif _attrName = ETRow_HmsMovementClearance then
		if self.isLogicalBerth() then
 		// Logical berth - clearances not applicable
 			return app.getErrorString(NotApplicable);
 		else
 			if self.foreClearanceTo &gt; 99990 or self.foreClearanceTo &lt; -99990 or
	 			self.isLogicalBerth() then
 				return app.getErrorString(Unlimited);
 			else
 				return self.foreClearanceTo.String;
	 		endif;
	 	endif;
	elseif _attrName = ETRow_HmsMovementClearanceA then
			// Set movement bow to
 	 	if self.isLogicalBerth() then
 			// Logical berth - clearances not applicable
 			return app.getErrorString(NotApplicable);
	 	else
 			if self.aftClearanceTo &gt; 99990 or self.aftClearanceTo &lt; -99990 or
 			self.isLogicalBerth() then
 				return app.getErrorString(Unlimited);
 			else
 				return self.aftClearanceTo.String;
	 		endif;
	 	endif;
	elseif _attrName = ETRow_HmsMovementDay then	
		return self.systemToLocalTime(self.occursOnDTNEW).date.format("ddd").String.toUpper;	// 24/5/16	cnwmp6	TFS 488 - Multi timezone support
	elseif _attrName = ETRow_HmsMovementFromPort 
		or _attrName = ETRow_HmsMovementToPort then	
		return self.myHMSVoyageData.getDisplayStringForAttribute(_attrName, _short);
	elseif _attrName = ETRow_HmsMovementFromBerth then
		tmpMovePrev := self.getVoyageMovementPrevious();	//PAR27908 cnwsh3 26/07/2011
		//Find out if I have previous movement and use those details on where the voyage was shifted from.
		if tmpMovePrev &lt;&gt; null then
		   if tmpMovePrev.getMyBerth() &lt;&gt; null then
		   		return tmpMovePrev.getMyBerth().description;
			endif;
	 	elseif self.moveType = HMSMovementTypeArrival then
			seaHarbourRegion := app.myRoot.getSeaHarbourRegion();			
			if seaHarbourRegion &lt;&gt; null then
				seaHRArrivalBerth := seaHarbourRegion.getArrivalBerth();
				if seaHRArrivalBerth &lt;&gt; null then
					return seaHRArrivalBerth.description;
				endif;
			endif;
		endif;
		
		return null;
	elseif _attrName = ETRow_HmsMovementToBerth then
	
		//05 Nov 2018	NDL	TFS 41687
		voyage := self.getVoyage();
		if voyage &lt;&gt; null and voyage.myVoyageProcess &lt;&gt; null and not voyage.myVoyageProcess.isDefaultProcessJMT then
			if self.moveType = HMSMovementTypeArrival and self.myBerth &lt;&gt; null then
				return self.myBerth.description;
			endif;
		endif;
		
		if self.moveType = HMSMovementTypeArrival and self.isLogicalBerth() then
			if self.myHarbour.defaultArrvBerth &lt;&gt; null then
				return self.myHarbour.defaultArrvBerth.description;			
			else
				return null;
			endif;
		else
			tmpMoveNext := self.getVoyageMovementNext();
			if tmpMoveNext = null then
				return null;
			else
				return self.getMyBerth().description;
			endif;
		endif;
		
	elseif _attrName = ETRow_HmsMovementPilot then
		//31 Oct 2018	NDL	TFS 41662
		if not self.pilotExempt then
			str := self.getPilotsString(true);
		endif;
		if str = null then
			str := app.getErrorString(NotRequired);
		endif;
		return str;
	//	if self.myPilot &lt;&gt; null
	//	and not self.pilotExempt then
 	//		return self.myPilot.description;
	// 	else
	// 		return app.getErrorString(NotRequired);
	// 	endif;
	elseif _attrName = ETRow_HmsMovementPilotLaunch then
		if self.getFirstPilotLaunch() &lt;&gt; null //myPilotLaunch &lt;&gt; null // TFS 44438
		and not self.pilotExempt then
			tmpMovePrev := self.getVoyageMovementPrevious();
 			if tmpMovePrev &lt;&gt; null 
 			and self.moveType = HMSMovementTypeShift then
 				if tmpMovePrev.getMyBerth() &lt;&gt; null then
 					if tmpMovePrev.isLogicalBerth()
 					or self.isLogicalBerth() then
 						// Ship is being SHIFTed to or from sea - pilot launch is required
 						return self.getPilotLaunchString(true); //myPilotLaunch.description; // TFS 44438
 					else
	 					// Ship is being SHIFTed within the harbour - pilot launch is NOT required
	 					return app.getErrorString(NotRequired);
 					endif;
 				else 
 					// Destination berth for ship not set - set pilot launch to 'Not Required'
 					return app.getErrorString(NotRequired);
 				endif;
 			else
	 			// Move is not a shift and is not pilot exempt - ie. launch is required
 				return self.getPilotLaunchString(true); //myPilotLaunch.description; // TFS 44438
 			endif;
 		endif;
		return app.getErrorString(NotRequired); 		
	elseif _attrName = ETRow_HmsMovementTugs then
		foreach tmpTug in self.allTugsUsed do
			tmpStr := tmpStr &amp; tmpTug.description &amp; ", ";
	 	endforeach;
 		if tmpStr.length &gt; 0 then
	 		// trim last comma
			return tmpStr[1:((tmpStr.length)-2)];
		return null;
		endif;
	elseif _attrName = ETRow_HmsMovementLinesTime then
		if self.numLineCrewRequired &gt; 0 then
 			if self.relativeOrderTimeLines &lt; 0 then
 				offsetTime.setTime(0,((self.relativeOrderTimeLines) * -1),0,0);
	 			orderTime := (self.systemToLocalTime(self.occursOnDTNEW) - offsetTime).Time;	// 25/5/16	cnwmp6	TFS 488 - Multi timezone support
	 		else
	 			offsetTime.setTime(0,(self.relativeOrderTimeLines),0,0);
	 			orderTime := (self.systemToLocalTime(self.occursOnDTNEW) + offsetTime).Time;	// 25/5/16	cnwmp6	TFS 488 - Multi timezone support
	 		endif;
	 		return orderTime.Time.shortFormatJMT();
 		endif;
 		return null;
	elseif _attrName = ETRow_HmsMovementTugsTime then
		if self.requiresMarineServices() then
	 		if self.relativeOrderTimeTugs &lt; 0 then
	 			offsetTime.setTime(0,((self.relativeOrderTimeTugs)*-1),0,0);
	 			orderTime := (self.systemToLocalTime(self.occursOnDTNEW) - offsetTime).Time;	// 25/5/16	cnwmp6	TFS 488 - Multi timezone support
 			else
 				offsetTime.setTime(0,(self.relativeOrderTimeTugs),0,0);
	 			orderTime := (self.systemToLocalTime(self.occursOnDTNEW) + offsetTime).Time;	// 25/5/16	cnwmp6	TFS 488 - Multi timezone support
	 		endif;
 			if self.locationTug = AlongSide then
 				return "(A)  " &amp; orderTime.Time.shortFormatJMT();
	 		else
	 			return "(O)  " &amp; orderTime.Time.shortFormatJMT();
	 		endif;
	 	endif;
	elseif _attrName = ETRow_HmsMovementPilotLaunchT then
	 	if not self.pilotExempt then
			tmpMovePrev := self.getVoyageMovementPrevious();
 			if tmpMovePrev &lt;&gt; null
 			and self.moveType = HMSMovementTypeShift then
 				if tmpMovePrev.getMyBerth() &lt;&gt; null then
 					if tmpMovePrev.isLogicalBerth() 
 					or self.isLogicalBerth() then
	 					// Ship is being SHIFTed to or from sea - pilot launch is required
	 					if self.relativeOrderTimePlaunch &lt; 0 then
	 						offsetTime.setTime(0,((self.relativeOrderTimePlaunch)*-1),0,0);
	 						orderTime := (self.systemToLocalTime(self.occursOnDTNEW) - offsetTime).Time;	// 25/5/16	cnwmp6	TFS 488 - Multi timezone support
 						else
	 						offsetTime.setTime(0,(self.relativeOrderTimePlaunch),0,0);
	 						orderTime := (self.systemToLocalTime(self.occursOnDTNEW) + offsetTime).Time;	// 25/5/16	cnwmp6	TFS 488 - Multi timezone support
	 					endif;
	 					if self.locationPilotLaunch=AlongSide then
	 						return "(A)  " &amp; orderTime.Time.shortFormatJMT();
	 					else
	 						return "(O)  " &amp; orderTime.Time.shortFormatJMT();
	 					endif;
 					else
 						// Ship is being SHIFTed within the harbour - pilot launch is NOT required
 						return app.getErrorString(NotRequired);
 					endif;
 				endif;
 			else 
 				// Destination berth for ship not set - set pilot launch to 'Not Required'
 				return app.getErrorString(NotRequired);	
 			endif;
 		else
 			// Move self not a shift and is not pilot exempt - ie. launch is required
 			if self.relativeOrderTimePlaunch &lt; 0 then
 				offsetTime.setTime(0,((self.relativeOrderTimePlaunch)*-1),0,0);
 				orderTime := (self.systemToLocalTime(self.occursOnDTNEW) - offsetTime).Time;	// 25/5/16	cnwmp6	TFS 488 - Multi timezone support
 			else
 				offsetTime.setTime(0,(self.relativeOrderTimePlaunch),0,0);
 				orderTime := (self.systemToLocalTime(self.occursOnDTNEW) + offsetTime).Time;	// 25/5/16	cnwmp6	TFS 488 - Multi timezone support
 			endif;
 			if self.locationPilotLaunch=AlongSide then
 				return "(A)  " &amp; orderTime.Time.shortFormatJMT();
 			else
 				return "(O)  " &amp; orderTime.Time.shortFormatJMT();
 			endif;
    	endif;
    	return app.getErrorString(NotRequired);
	elseif _attrName = ETRow_HmsMovementDefTideClass then
		if self.moveType = HMSMovementTypeDeparture then
   			defaultTideClass := self.myHMSVoyageData.myTidalClassDept;
	   	else
   			defaultTideClass := self.myHMSVoyageData.myTidalClass;
	   	endif;
   		if defaultTideClass &lt;&gt; null then
	   		return defaultTideClass.description;
	   	else
	   		return app.getErrorString(NotApplicable);
	   	endif;
	elseif _attrName = ETRow_HmsMovementResources then
		foreach tmpResourceUsed in self.allResourceUsed do
			if tmpResourceUsed.myResource &lt;&gt; null then
	 			tmpStr := tmpStr &amp; tmpResourceUsed.myResource.description &amp; ", ";
	 		endif;
	 	endforeach;
 		if tmpStr &lt;&gt; null then
 			// trim last comma
			return tmpStr[1:((tmpStr.length)-2)];
		endif;
		return null;
	elseif _attrName = ETRow_HmsMovementCustomer then
		if self.isAgentDefault then
 			if self.myShippingAgent &lt;&gt; null then
 				return self.myShippingAgent.description;
	 		endif;
	 	elseif self.myShippingLine &lt;&gt; null then
 			return self.myShippingLine.description;
	 	endif;
	 	return null;
	
	elseif _attrName = ETRow_BowMarkTo
	or _attrName = ETRow_SternMarkTo
	or _attrName = ETRow_BridgeMarkTo then
		
		if self.moveType = HMSMovementTypeDeparture then
			tmpMovePrev := self.getVoyageMovementPrevious();
			if tmpMovePrev &lt;&gt; null then
				return tmpMovePrev.getDisplayStringForAttribute(_attrName, _short);
			endif;
		endif;
		
		if _attrName = ETRow_BridgeMarkTo then
			if self.bowMarkTo &gt; self.sternMarkTo then
				return (self.bowMarkTo - self.myHMSVoyageData.dist_BridgeToBow).String;
			else
				return (self.bowMarkTo + self.myHMSVoyageData.dist_BridgeToBow).String;
			endif;
		else			
			return inheritMethod(_attrName, _short);
		endif;
			 	
	elseif _attrName = ETRow_IsChargeable then
		return self.chargeForMove.getYesNo();
	elseif _attrName = ETRow_LocationPilotLaunch then
		return app.locationPilotTugNumToString(self.locationPilotLaunch);
	elseif _attrName = ETRow_LocationTug then
		return app.locationPilotTugNumToString(self.locationTug);	
	elseif _attrName = ETRow_MoveStatusNEW then
		return app.movementStatusNumToString(self.moveStatusNEW);	
	elseif _attrName = ETRow_MyBerth then
		return self.getMyBerth().code;	
	elseif _attrName = ETRow_MyBerthFrom then
		return self.getMyBerth().code;	
	elseif _attrName = ETRow_MyContact then
		if self.myContact &lt;&gt; null then
			return self.myContact.name;			
		endif;
		return null;
	elseif _attrName = ETRow_MyHMSVoyageData then
		return self.myHMSVoyageData.getDisplayString();		
	elseif _attrName = ETRow_MyLineCompany then
		if self.myLineCompany &lt;&gt; null then
			return self.myLineCompany.code;			
		endif;
		return null;
	elseif _attrName = ETRow_MyPilot then
	//	if self.myPilot &lt;&gt; null then
	//		return self.myPilot.code;			
	//	endif;
	//	return null;
		//31 Oct 2018	NDL	TFS 41662
		return self.getPilotsString(true);
		
	elseif _attrName = ETRow_MyPilotLaunch then
		//if self.myPilotLaunch &lt;&gt; null then // TFS 44438
		//	return self.myPilotLaunch.code;  // TFS 44438
		return self.getPilotLaunchString(true); // TFS 44438
		//endif; // TFS 44438
		//return null; // TFS 44438
	elseif _attrName = ETRow_MyShippingAgent then
		if self.myShippingAgent &lt;&gt; null then
			return self.myShippingAgent.code;			
		endif;
		return null;
	elseif _attrName = ETRow_MyTidalClass then
		if self.myTidalClass &lt;&gt; null then
			return self.myTidalClass.code;			
		endif;
		return null;										
	elseif _attrName = ETRow_OccursOnDate then
		return self.systemToLocalTime(self.occursOnDTNEW).date.shortFormatJMT();	// 25/5/16	cnwmp6	TFS 488 - Multi timezone support
	elseif _attrName = ETRow_OccursOnTime then
		return self.systemToLocalTime(self.occursOnDTNEW).time.currentLocaleFormatJMT();	// 25/5/16	cnwmp6	TFS 488 - Multi timezone support
	elseif _attrName = ETRow_SideTo then
		return app.sideToNumToString(self.sideTo);
	elseif _attrName = ETRow_VesselName then
		return self.myHMSVoyageData.getDisplayStringForAttribute(_attrName, _short);
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="2e18254a-cb64-4c12-95b0-eca52e8004d1">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
//--------------------------------------------------
// Created:	02 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	block : CM_DataContainerBlock;
begin
	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem(self.moveType &amp; ' Resources', DC_Label, 1, null);
	block.addNewItem(self.getResourceUsedString(), DC_Data, 1, null);

	block := _dataContainer.addNewBlock;
	block.addNewItem(self.moveType &amp; ' Remarks', DC_Label, 1, null);
	block.addNewItem(self.remarks, DC_Data, 1, null);

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFirstPilot" id="0624612a-6377-4e27-a8df-fd1375941984">
        <source>getFirstPilot():HMS_Pilot;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2018	jlgndl1	Initial creation	TFS 41662
23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
*/

vars

begin
	if not self.allMovementPilotDetails/*allPilots*/.isEmpty then // TFS 44438
		return self.allMovementPilotDetails.first.myPilot; //allPilots.first; // TFS 44438
	endif;	
	return self.getUnConvertedMyPilotRef();
epilog

end;</source>
        <ReturnType type="HMS_Pilot"/>
    </JadeMethod>
    <JadeMethod name="getFirstPilotLaunch" id="9e5c5589-c49d-400d-8c32-0dfd7211a04d">
        <source>getFirstPilotLaunch() : HMS_PilotLaunch;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars

begin
	if not self.allMovementPilotDetails.isEmpty then
		return self.allMovementPilotDetails.first.myPilotLaunch;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="HMS_PilotLaunch"/>
    </JadeMethod>
    <JadeMethod name="getFirstRegionWithChkPts" id="315c301e-8d3a-4575-b4f5-35fa01db1502">
        <source>getFirstRegionWithChkPts(_totalOffsetTime : Integer io; _enterLeaveStatus : String io;
						 _movePrev : HMS_VoyageMovement) : HMS_HarbourRegion;
//--------------------------------------------------
// Created:	06 April 2004 By: cnwgd1
//--------------------------------------------------
/* This method returns the first region with checkpoints that is 
crossed as a ship moves from one region to another. It also calculates the 
offset time (from basetime) to this region and the 'entering/leaving' the harbour status.
SCRUCTURE:
Check to see if a path exists for this movement
If it does, find first region on path with checkpoints
If it doesn't, check both to and from regions for checkpoints*/
vars
	toBerth:			HMS_Berth;
	fromBerth:			HMS_Berth;
	pathToCheck:		HMS_MovementPath;
	path:				HMS_MovementPath;
	regA:				HMS_HarbourRegion;
	regB:				HMS_HarbourRegion;
	baseTimeAtRegA:		Boolean;
	harbour:			HMS_Harbour;
	directionFwd:		Boolean;
	pathSegment:		HMS_PathSegment;
	regToCheck:			HMS_HarbourRegion;
	offSetTime:			Integer;
begin

	// Set reference to harbour
	harbour := self.myHarbour;

	// Get _enterLeaveStatus and from/to regions
	_enterLeaveStatus := self.getShipEnterLeaveStatus(regA,regB,_movePrev);

	

	// Initialise offset time
	_totalOffsetTime := 0;

	// Determine which end the basetime is relative to:
	if self.moveType = HMSMovementTypeArrival then
		// Arrival movement
		// Determine which end of the path the base time needs to be associated with
   		if harbour.baseTimeArrive = AtSea then
   			baseTimeAtRegA := true;
   		endif;		
	elseif self.moveType = HMSMovementTypeDeparture then
		// Departure movement 
		// Determine which end of the path the base time needs to be associated with
   		if harbour.baseTimeDepart = AtWharf then
   			baseTimeAtRegA := true;
   		endif;
	else
		// Shift movement
		// Determine which end of the path the base time needs to be associated with
   		if harbour.baseTimeDepart = AtBerthDepartingFrom then
   			baseTimeAtRegA := true;
   			if _movePrev &lt;&gt; null then
   				// If the shift is from a logical berth eg Roadstead, then set BT to
   				// the time at the physical berth (ie destination or regB)
   				if _movePrev.isLogicalBerth() then
   					baseTimeAtRegA := false;
   				endif;
   			endif;
   		endif;
	endif;

	// Check to see if a path is defined. If it is, then find the first region with checkpoints 
	// along the path
    foreach path in harbour.allMovementPaths do
    	if path.myRegionFrom = regA and path.myRegionTo = regB then
    		pathToCheck := path;
    		// Set direction along path to fwd=true ie. The ship is travelling
    		// from regA to regB
    		directionFwd := true;
    	elseif path.myRegionFrom = regB and path.myRegionTo = regA then
    		pathToCheck := path;
    		// Set direction along path to fwd=false ie. The ship is travelling
    		// from regB to regA
    		directionFwd := false;
    		// Swap BT ends
    		baseTimeAtRegA := not(baseTimeAtRegA);  //- not sure why this is here - RH 06/08/99

    	endif;
    endforeach;

    

   	if pathToCheck &lt;&gt; null then
   		// Check this path
   		// Step through all regions along path and check their respective checkpoints
   		// at the appropriately offset times

   		if (baseTimeAtRegA and directionFwd) then
   			// Check regions along path in direction = from 'A' to 'B'
   				// Set basetime=movement time
   				//basetime:=self.occursOnDT;
   				// Check checkpoints at reg A at basetime
   				if regA.hasCheckpointsWithTidalModel() then
   					// Checkpoints to check
   					return regA;
   				endif;
   				foreach pathSegment in pathToCheck.allPathSegments do
   					regToCheck := pathSegment.myRegionTo;
   					offSetTime := pathSegment.steamingTimeAB;
   					_totalOffsetTime := _totalOffsetTime+offSetTime;
   					//basetime:=basetime+offSetTime;
   					if regToCheck.hasCheckpointsWithTidalModel() then
   						return regToCheck;
   					endif;
   				endforeach;
   		elseif (baseTimeAtRegA=false and directionFwd=true) then
   			// Check regions along path in direction = from 'B' to 'A'
   				// Set basetime=movement time
   				//basetime:=self.occursOnDT;
   				// Check checkpoints at reg B at basetime
   				if regB.hasCheckpointsWithTidalModel() then
   					// Checkpoints to check
   					return regB;
   				endif;
   				foreach pathSegment in pathToCheck.allPathSegments reversed do
   					regToCheck := pathSegment.myRegionFrom;
   					offSetTime := pathSegment.steamingTimeAB;
   					_totalOffsetTime := _totalOffsetTime-offSetTime;
   					//basetime:=basetime-offSetTime;
   					if regToCheck.hasCheckpointsWithTidalModel() then
   						return regToCheck;
   					endif;
   				endforeach;
   		elseif (baseTimeAtRegA and directionFwd=false) then
   			// Check regions along path in direction = from 'A' to 'B'
   				// Set basetime=movement time
   				//basetime:=self.occursOnDT;
   				// Check checkpoints at reg A at basetime
   				if regA.hasCheckpointsWithTidalModel() then
   					// Checkpoints to check
   					return regA;
   				endif;
   				foreach pathSegment in pathToCheck.allPathSegments do
   					regToCheck := pathSegment.myRegionTo;
   					offSetTime := pathSegment.steamingTimeBA;
   					_totalOffsetTime := _totalOffsetTime-offSetTime;
   					//basetime:=basetime-offSetTime;
   					if regToCheck.hasCheckpointsWithTidalModel() then
   						return regToCheck;
   					endif;
   				endforeach;
   		elseif (baseTimeAtRegA=false and directionFwd=false) then
   			// Check regions along path in direction = from 'B' to 'A'
   				// Set basetime=movement time
   				//basetime:=self.occursOnDT;
   				// Check checkpoints at reg B at basetime
   				if regB.hasCheckpointsWithTidalModel() then
   					// Checkpoints to check
   					return regB;
   				endif;
   				foreach pathSegment in pathToCheck.allPathSegments reversed do
   					regToCheck := pathSegment.myRegionFrom;
   					// 06/08
   					offSetTime:=pathSegment.steamingTimeBA;
   					_totalOffsetTime := _totalOffsetTime+offSetTime;
   					//basetime:=basetime+offSetTime;
   					if regToCheck.hasCheckpointsWithTidalModel() then
   						return regToCheck;
   					endif;
   				endforeach;
   		endif;
   	else
   		// If path is not defined - check region A and B for checkpoints
   		if regA &lt;&gt; null and regA.hasCheckpointsWithTidalModel() then
			return regA;
   		elseif regB &lt;&gt; null and regB.hasCheckpointsWithTidalModel() then
   			return regB;
   		else
			return null;
		endif;
   	endif;

end;</source>
        <Parameter name="_totalOffsetTime" type="Integer" usage="io"/>
        <Parameter name="_enterLeaveStatus" type="String" usage="io"/>
        <Parameter name="_movePrev" type="HMS_VoyageMovement"/>
        <ReturnType type="HMS_HarbourRegion"/>
    </JadeMethod>
    <JadeMethod name="getFirstResourceUsedForClass" id="7df767b6-7271-4a38-986d-d54c608671c3">
        <source>getFirstResourceUsedForClass(_class : Class) : HMS_ResourceUsed;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 June 2018	jlger1	Initial creation 39322

*/

vars
	hmsResourceUsed : HMS_ResourceUsed;
begin
	foreach hmsResourceUsed in self.allResourceUsed discreteLock do
		if hmsResourceUsed.myResource = null then
			continue;
		endif;
		if hmsResourceUsed.myResource.isResourceForClass(_class) then
			if hmsResourceUsed.myVTMISTransaction &lt;&gt; null then
				return hmsResourceUsed;
			endif;	
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="getFirstTug" id="5e0a9a11-11cb-4afd-a175-0c988f3e59cd">
        <source>getFirstTug() : HMS_Tug;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/02/2012	cnwdap1	Initial creation PAR #29042
*/
vars
	
begin
	return self.allTugsUsed.first;
		
epilog

end;</source>
        <ReturnType type="HMS_Tug"/>
    </JadeMethod>
    <JadeMethod name="getForeAftClearances" id="d4484684-f517-4703-91ef-864dcfb640d1">
        <source>getForeAftClearances(_movesToCheck : HMS_VoyageMovementByDateDict;
					 _foreClearance, _aftClearance : Decimal io;
					 _overlapsWharfSection : Boolean io);
//--------------------------------------------------
// Created:	1 April 2005 By: cnwgd1
//--------------------------------------------------
// Also see CMIF_HMS_WorkingMovement::calc_Clearances()
//-------------------------------------------------
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------
// 19/06/2014	cnwdap1		PAR #34175 resubmit
// 03/11/2022	jlika1	TFS 54892  POB - Vessel, Voyage and Movement EDI Messages
vars
	movement,
	tempNextMoveToCheck,
	movePrev,				
   	tempNextMove:			HMS_VoyageMovement;
   	closestStartPosn,
   	closestEndPosn,
   	moveStartPosn,
   	moveEndPosn,
   	currentStartPosn,
   	currentEndPosn,
   	moveBowMark,
   	moveSternMark,
   	distToSectionLimit:		Decimal[12,2];
   	moveOccursDT,
   	voyArrivalDT,
   	voyDepartureDT:			TimeStamp;
   	tmpLockout:				HMS_WharfLockout;
   	changed:				Boolean;
   	tmpHMSVoyageData:		HMS_VoyageData;
   	moveWharf:				HMS_Wharf;
   	section:				HMS_WharfSection;   	
begin

	// This method calculates the clearances for a ship for its entire duration at a particular berth
	// based the following supplied information	bowMark, sternMark, and the wharf that these marks apply to.
	//added for par 15929
//	if _foreClearance = ClearanceNotApplicable or _aftClearance = ClearanceNotApplicable then  // dh 20/3/2008 par 15929 removed
//		return;
//	endif;
	//add end

	if self.getMyBerth() = null then
		app.raiseCMException1(ERR_NO_OBJECT, 'Berth: ' &amp; class.name &amp; ' ' &amp; method.name, null, null);
		return;
	endif;		

	if _movesToCheck = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _movesToCheck Dictionary');
		return;
	endif;
	
	tmpHMSVoyageData := self.myHMSVoyageData;
	moveOccursDT := self.occursOnDTNEW;							
	
	// Initialise the closestStartPosn and closestEndPosn variables
	closestStartPosn := -1*(ClearanceUnbounded);
	closestEndPosn := ClearanceUnbounded;

	tempNextMoveToCheck := self.getVoyageMovementNext();	
	if tempNextMoveToCheck &lt;&gt; null then
		voyDepartureDT := tempNextMoveToCheck.occursOnDTNEW;
	else
		voyDepartureDT := moveOccursDT;
	endif;

	voyArrivalDT := moveOccursDT;
					
	if self.moveType = HMSMovementTypeDeparture then
		movePrev := self.getVoyageMovementPrevious();
		if movePrev &lt;&gt; null then
			if movePrev.getMyBerth() = null then
				app.raiseCMException1(ERR_NO_OBJECT, 'Berth: ' &amp; class.name &amp; ' ' &amp; method.name, null, null);
				return;
			endif;
			moveWharf 		:= movePrev.getMyBerth().myWharf;
			moveBowMark 	:= movePrev.bowMarkTo;
			moveSternMark	:= movePrev.sternMarkTo;	
			movePrev.berthing_StartEndFromOrient(currentStartPosn, currentEndPosn, moveBowMark, moveSternMark);
			voyArrivalDT := movePrev.occursOnDTNEW;							
		endif;
		voyDepartureDT := moveOccursDT;
	endif;
	
	if moveWharf = null then
		// Get the current wharf
		moveWharf		:= self.getMyBerth().myWharf;
		moveBowMark		:= self.bowMarkTo;
		moveSternMark	:= self.sternMarkTo;
		berthing_StartEndFromOrient(currentStartPosn, currentEndPosn, moveBowMark, moveSternMark);
  	endif;
	
	if moveWharf = null then
		// we can ignore the clearances
		return;
	endif;
	
	foreach movement in _movesToCheck where movement.myHMSVoyageData &lt;&gt; tmpHMSVoyageData do
		tempNextMove := movement.getVoyageMovementNext();
		if tempNextMove = null then
			continue;
		endif;					
		if movement.isLogicalBerth then
			// at sea
			continue;
		endif;
		if movement.getMyBerth().myWharf &lt;&gt; moveWharf then
			// not on the same wharf
			continue;
		endif;

		//if movement.occursOnDT&lt;=self.getMovementNext.occursOnDT and movement.getMovementNext.occursOnDT&gt;=self.occursOnDT then //&lt;&lt;--- 6.3.4
		//if movement.occursOnDT &lt;= voyDepartureDT and tempNextMove.occursOnDT &gt;= moveOccursDT then 
		//if movement.occursOnDTNEW &lt;= moveOccursDT and tempNextMove.occursOnDTNEW &gt;= moveOccursDT then 	// PAR #34175 resubmit
		if self.timesOverlap(movement) then																	// PAR #34175 resubmit
			// ie. this movement is in existance (overlaps) at the same time as the movementToCheck occurs
			self.berthing_StartEndFromOrient(moveStartPosn, moveEndPosn, movement.bowMarkTo, movement.sternMarkTo);

			if	moveStartPosn &gt; currentStartPosn then
				// this movement starts further up the wharf than the movementToCheck
				if moveStartPosn &lt; closestEndPosn then
					// This is the closest movement on the far end side
					closestEndPosn := moveStartPosn;
				endif;
			else
				// this movement start further down the wharf than the movementToCheck 
				if moveEndPosn &gt; closestStartPosn then
					// This is the closest movement on the start (0m) side
					closestStartPosn := moveEndPosn;
				endif;	
			endif;
		endif;
	endforeach;	
	
	foreach tmpLockout in moveWharf.allWLockoutsByBothDT 
	where tmpLockout.startOfLockoutDT &lt; voyDepartureDT 
	and tmpLockout.endOfLockoutDT &gt; voyArrivalDT do
		// Check to see if ship is within any part of this lockout
		// and is closer than any other ship
		if tmpLockout.startMarkOnWharf &gt; currentStartPosn then
			// this movement starts further up the wharf than the movementToCheck
			if tmpLockout.startMarkOnWharf &lt; closestEndPosn then
				// This lockout is closest to movement on the far end side
				closestEndPosn := tmpLockout.startMarkOnWharf;
			endif;
		else
			// this lockout start further down the wharf than anything else 
			if tmpLockout.endMarkOnWharf &gt; closestStartPosn then
				// This lockout is closest to movement on the start (0m) side
				closestStartPosn := tmpLockout.endMarkOnWharf;
			endif;	
		endif;	

	endforeach;	


	// Calculate clearances
	if moveBowMark &gt; moveSternMark then
		if closestEndPosn &lt; ClearanceUnbounded then
			_foreClearance := closestEndPosn-currentEndPosn;
		else
			// Fore clearance is unrestricted
			_foreClearance := ClearanceUnbounded; 
		endif;
		if closestStartPosn &gt; (-1*(ClearanceUnbounded)) then
			_aftClearance := currentStartPosn-closestStartPosn;
		else
			// Aft clearance is unrestricted
			_aftClearance := ClearanceUnbounded;
		endif;		
	else
		if closestEndPosn &lt; ClearanceUnbounded then
			_aftClearance := closestEndPosn-currentEndPosn;
		else
			// Fore clearance is unrestricted
			_aftClearance := ClearanceUnbounded; 
		endif;
		if closestStartPosn &gt; (-1*(ClearanceUnbounded)) then
			_foreClearance := currentStartPosn-closestStartPosn;
		else
			// Aft clearance is unrestricted
			_foreClearance := ClearanceUnbounded;
		endif;	
	endif;

	// Modified by Russell 20/07/99
	// -----------------------------------------------------------------------------------
	// Calc clearances to wharf ends if unlimited by other vessels.

	if moveBowMark &gt; moveSternMark then
		if _foreClearance = ClearanceUnbounded then
			// Calc clearance from bow to max metre end of wharf
			_foreClearance := ((moveWharf.length)-moveBowMark);
		endif;
		if _aftClearance = ClearanceUnbounded then
			// Calc clearance from stern to zero metre end of wharf
			_aftClearance := moveSternMark;
		endif;
	else
		if _aftClearance = ClearanceUnbounded then
			// Calc clearance from stern to max metre end of wharf
			_aftClearance := ((moveWharf.length)-moveSternMark);
		endif;
		if _foreClearance = ClearanceUnbounded then
			// Calc clearance from bow to zero metre end of wharf
			_foreClearance := moveBowMark;
		endif;	
	endif;

	// Calc clearances to wharf section ends if less than current clearances
	self.calc_ClearancesWharfSection(_foreClearance, _aftClearance, _overlapsWharfSection, moveWharf,
									 currentStartPosn, currentEndPosn, moveBowMark, moveSternMark);
/*	foreach section in moveWharf.allWharfSections do
		// Check to see if ship is within any part of this section
		if currentEndPosn &gt;= section.startMeterage 
		and currentStartPosn &lt;= section.endMeterage then
			// Ship overlaps some portion of this section.
			// Calc clearances to sections ends
			// Ship is closer to start of wharf than the end of this section
			distToSectionLimit := (section.endMeterage)-currentEndPosn;
			if moveBowMark &gt; moveSternMark then
				if distToSectionLimit &lt; _foreClearance then
					// Bow closer to section end than stern and....
					// Section end is closer than current foreClearance - reduce clearance;
					_foreClearance := distToSectionLimit;
					_overlapsWharfSection := true;
				endif;
			else
				if distToSectionLimit &lt; _aftClearance then
					// Stern closer to section end than bow and....
					// Section end is closer than current aftClearance - reduce clearance;
					_aftClearance := distToSectionLimit;
					_overlapsWharfSection := true;						
				endif;
			endif;
			// Ship is closer to end of wharf than section start
			distToSectionLimit := currentStartPosn-(section.startMeterage);
			if moveBowMark &gt; moveSternMark then
				if distToSectionLimit &lt; _aftClearance then
					// Stern closer to section start than bow and....
					// Section start is closer than current aftClearance - reduce clearance;
					_aftClearance := distToSectionLimit;
					_overlapsWharfSection := true;						
				endif;
			else
				if distToSectionLimit &lt; _foreClearance then
					// Bow closer to section start than stern and....
					// Section start is closer than current foreClearance - reduce clearance;
					_foreClearance := distToSectionLimit;
					_overlapsWharfSection := true;						
				endif;
			endif;
		endif;
	endforeach;*/

end;</source>
        <Parameter name="_movesToCheck" type="HMS_VoyageMovementByDateDict"/>
        <Parameter name="_foreClearance" type="Decimal" usage="io"/>
        <Parameter name="_aftClearance" type="Decimal" usage="io"/>
        <Parameter name="_overlapsWharfSection" type="Boolean" usage="io"/>
    </JadeMethod>
