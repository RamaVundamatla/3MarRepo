    <JadeMethod name="doEnableButtons" id="cb8dd807-ac4c-4187-afc5-10b7fe4d3451">
        <source>doEnableButtons() protected;

vars
	isParameterSelected	: Boolean;

begin
	isParameterSelected	:=	tblParameters.cnEcIsRowSelected(tblParameters.row) and (not aIsParamsReadOnly);

	btnParamMoveUp.enabled			:=	isParameterSelected;
	btnParamMoveDown.enabled		:=	isParameterSelected;
	btnParamNew.enabled				:=	not aIsParamsReadOnly;
	btnParamUpdate.enabled			:=	isParameterSelected;
	btnParamDelete.enabled			:=	isParameterSelected;
	btnDeleteReport.enabled	:=	(self.aMyReport &lt;&gt; null);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="c53a3378-949c-45e2-b248-afb0273fadd1">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		27 July 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	printerNameArray	: StringArray;
	reportColl			: ClassColl;
	marginIndex			: Integer;

begin
	centreWindow();
	inheritMethod();

	cmbCategory.listCollection(app.myBaseRoot.allReportCategories, true, 0);
	create printerNameArray transient;	
	global.cnEcGetAllPrinters(printerNameArray);
	cmbPrinter.listCollection(printerNameArray, false, 0);
	create reportColl transient;
	currentSchema.getClass(CnEcReport.name).allSubclasses(reportColl);
	cmbForm.listCollection(reportColl, false, 0);

	// Populate margins and paper size combo boxes

	foreach marginIndex in MARGIN_MINIMUM to MARGIN_MAXIMUM do
		cmbTop.addItem((marginIndex div 10).String &amp; "." &amp; (marginIndex mod 10).String &amp; " cm");
		cmbBottom.addItem((marginIndex div 10).String &amp; "." &amp; (marginIndex mod 10).String &amp; " cm");
		cmbLeft.addItem((marginIndex div 10).String &amp; "." &amp; (marginIndex mod 10).String &amp; " cm");
		cmbRight.addItem((marginIndex div 10).String &amp; "." &amp; (marginIndex mod 10).String &amp; " cm");
	endforeach;

	self.doSetupPaperSizes(cmbPaperSize);
	self.doSetupTable();

	if self.aIsNewEntry then
		caption	:=	$CNEC_CREATE(caption);
	else
		caption	:=	$CNEC_EDIT(caption);
	endif;

	self.doLoadReportDetails();
	self.doLoadReportParameters();

	if self.aIsParamsReadOnly then
		lblMessage.visible			:=	true;
		tblParameters.readOnly		:=	true;
		btnDeleteReport.enabled		:=	false;
	else
		lblMessage.visible			:=	false;
		tblParameters.readOnly		:=	false;
		btnDeleteReport.enabled		:=	true;
	endif;

	self.doEnableButtons();
epilog
	delete printerNameArray;
	delete reportColl;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="11772316-e1d7-4163-8e14-ced8958226e8">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		27 July 2000 by cnwdad1
//
// Purpose:		Standard form update method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	// Report details.
	
	theReportDefinition	: CnEcReportDefinition;
	reportName			: String;
	theReportCategory	: CnEcReportCategory;
	reportDescription	: String;
	formName			: String;
	printerName			: String;
	copies				: Integer;
	isLocalAllowed		: Boolean;
	paperSize			: Integer;
	orientation			: Integer;
	marginTop			: Integer;
	marginBottom		: Integer;
	marginLeft			: Integer;
	marginRight			: Integer;
	
	// Parameter details.
	
	parameterArray		: CnEcReportParameterArray;
	parameterSequence	: Integer;
	parameterName		: String;
	displayValue		: String;
	parameterType		: String;
	parameterHasList	: Boolean;
	table				: Table;
	rowIndex			: Integer;
	rowCount			: Integer;

begin
	theReportDefinition	:=	self.aMyReport;

	if pIsDelete then
		self.aError	:=	self.aMyTA.trxReportDefinitionDelete(theReportDefinition);
	else
		// Get the report details.
		
		reportName			:=	txtName.text.trimBlanks;
		theReportCategory	:=	cmbCategory.listObject.CnEcReportCategory;
		reportDescription	:=	txtDescription.text.trimBlanks;
		formName			:=	cmbForm.text.trimBlanks;
		printerName			:=	cmbPrinter.text.trimBlanks;
		copies				:=	txtCopies.text.trimBlanks.Integer;
		isLocalAllowed		:=	chkLocal.value;
		marginTop			:=	(cmbTop.text[1 : cmbTop.text.length - 3].Decimal * 10).Integer;
		marginBottom		:=	(cmbBottom.text[1 : cmbBottom.text.length - 3].Decimal * 10).Integer;
		marginLeft			:=	(cmbLeft.text[1 : cmbLeft.text.length - 3].Decimal * 10).Integer;
		marginRight			:=	(cmbRight.text[1 : cmbRight.text.length - 3].Decimal * 10).Integer;
		paperSize			:=	cmbPaperSize.itemData[cmbPaperSize.listIndex];

		if optPortrait.value then
			orientation	:=	Print_Portrait;
		else
			orientation	:=	Print_Landscape;
		endif;

		// Get the parameter details.
		
		create parameterArray transient;
		table		:=	tblParameters;
		rowCount	:=	table.rows;
		
		foreach rowIndex in 2 to rowCount do
			parameterSequence	:=	table.getCellText(rowIndex, 1).Integer;
			parameterName		:=	table.getCellText(rowIndex, 2).trimBlanks;
			displayValue		:=	table.getCellText(rowIndex, 3).trimBlanks;
			parameterType		:=	table.getCellText(rowIndex, 4).trimBlanks;
			parameterHasList	:=	(table.getCellText(rowIndex, 5).trimBlanks = $CNEC_LIT_YES);
			
			parameterArray.addParameter(null,
										parameterName,
										displayValue,
										parameterSequence,
										parameterType,
										parameterHasList);
		endforeach;

		if theReportDefinition = null then
			self.aError	:=	self.aMyTA.trxReportDefinitionCreate(	reportName,
																			theReportCategory,
																			reportDescription,
																			formName,
																			printerName,
																			copies,
																			isLocalAllowed,
																			paperSize,
																			orientation,
																			marginTop,
																			marginBottom,
																			marginLeft,
																			marginRight,
																			parameterArray,
																			self.aMyReport);
		else
			self.aError	:=	self.aMyTA.trxReportDefinitionUpdate(	self.aMyReport,
																			self.aObjectEdition,
																			reportName,
																			theReportCategory,
																			reportDescription,
																			formName,
																			printerName,
																			copies,
																			isLocalAllowed,
																			paperSize,
																			orientation,
																			marginTop,
																			marginBottom,
																			marginLeft,
																			marginRight,
																			parameterArray);
		endif;
	endif;
epilog
	delete parameterArray;
	return self.doShowError();
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadReportDetails" id="aa69d9e4-fcb8-4c2a-b61a-481fdaf96740">
        <updating/>
        <source>doLoadReportDetails() updating, protected;
/*
	Changed on	Changed by				Reason
	==========	======================	=====================================================================
	1/10/1998	Darrell					CR 15 (Report Categories) - added myReportCategory to the Report class.
*/
vars
	theReport		: CnEcReportDefinition;
	paperSizeIndex	: Integer;
	paperSizeCount	: Integer;
	marginTop		: Integer;
	marginBottom	: Integer;
	marginLeft		: Integer;
	marginRight		: Integer;
	orientation		: Integer;
	paperSize		: Integer;

begin
	if self.aIsNewEntry then
		self.aMyReport		:=	null;

		if cmbPrinter.listCount &gt; 0 then
			cmbPrinter.listIndex	:=	1;
		endif;

		txtCopies.text			:=	"1";
		optPortrait.value		:=	true;
		picPortrait.visible		:=	true;
		picLandscape.visible	:=	false;
		chkLocal.value			:=	false;

		paperSizeCount	:=	cmbPaperSize.listCount;

		foreach paperSizeIndex in 1 to paperSizeCount do
			if cmbPaperSize.itemData[paperSizeIndex] = Print_A4 then
				cmbPaperSize.listIndex	:=	paperSizeIndex;
				break;
			endif;
		endforeach;
	else
		theReport	:=	self.aMyReport;

		if theReport = null then
			global.cnEcMessage_UnknownError("The Report reference is missing.");
			self.unloadForm();
		endif;

		txtName.text			:=	theReport.reportName;
		cmbCategory.listIndex	:=	cmbCategory.findObject(theReport.myReportCategory);
		txtDescription.text		:=	theReport.reportDescription;
		cmbForm.listIndex		:=	cmbForm.findStringExact(1, theReport.formName);
		cmbPrinter.listIndex	:=	cmbPrinter.findStringExact(1, theReport.printerName);
		txtCopies.text			:=	theReport.copies.String;
		chkLocal.value			:=	theReport.isLocalAllowed;

		marginTop				:=	theReport.marginTop;
		marginBottom			:=	theReport.marginBottom;
		marginLeft				:=	theReport.marginLeft;
		marginRight				:=	theReport.marginRight;
		orientation				:=	theReport.orientation;
		paperSize				:=	theReport.paperSize;
		cmbTop.listIndex		:=	cmbTop.findString(1, (marginTop div 10).String &amp; "." &amp; (marginTop mod 10).String);
		cmbBottom.listIndex		:=	cmbBottom.findString(1, (marginBottom div 10).String &amp; "." &amp; (marginBottom mod 10).String);
		cmbLeft.listIndex		:=	cmbLeft.findString(1, (marginLeft div 10).String &amp; "." &amp; (marginLeft mod 10).String);
		cmbRight.listIndex		:=	cmbRight.findString(1, (marginRight div 10).String &amp; "." &amp; (marginRight mod 10).String);

		paperSizeCount	:=	cmbPaperSize.listCount;

		foreach paperSizeIndex in 1 to paperSizeCount do
			if cmbPaperSize.itemData[paperSizeIndex] = paperSize then
				cmbPaperSize.listIndex	:=	paperSizeIndex;
				break;
			endif;
		endforeach;

		// Set orientation checkbox value

		if orientation = Print_Portrait then
			optPortrait.value		:=	true;
			picPortrait.visible		:=	true;
			picLandscape.visible	:=	false;
		else
			optLandscape.value		:=	true;
			picLandscape.visible	:=	true;
			picPortrait.visible		:=	false;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadReportParameters" id="59bd244f-29cb-455f-83f5-58b9ca43d4c2">
        <updating/>
        <source>doLoadReportParameters() updating, protected;

vars
	theReport			: CnEcReportDefinition;
	theReportParameter	: CnEcReportParameter;
	parameterIterator	: Iterator;
	rowString			: String;
	rowIndex			: Integer;

begin
	theReport	:=	self.aMyReport;

	if theReport = null then
		return;
	endif;

	tblParameters.rows	:=	1;
	parameterIterator	:=	theReport.allReportParameters.createIterator();

	while parameterIterator.next(theReportParameter) do
		rowString	:=	theReportParameter.sequence.String;
		rowString	:=	rowString &amp; Tab &amp; theReportParameter.parameterName;
		rowString	:=	rowString &amp; Tab &amp; theReportParameter.displayValue;
		rowString	:=	rowString &amp; Tab &amp; theReportParameter.parameterType;
		rowString	:=	rowString &amp; Tab &amp; theReportParameter.hasValueList.cnEcGetYesNo();

		rowIndex	:=	tblParameters.addItem(rowString);
		tblParameters.cnEcSetItemObject(rowIndex, 1, theReportParameter);
	endwhile;

	tblParameters.sortColumn[1]	:=	1;
	tblParameters.sortType[1]	:=	Table.SortType_Numeric;		// cnwdad1 30/09/2000.
	tblParameters.resort;
//	Darrell 24/9/1998 - reset table sortColumn. The move up/down buttons weren't working because
//	when the moved entry was re-added, it was automatically sorted into the wrong place !
	tblParameters.sortColumn[1]	:=	0;
// 24/9/1998  end of change to reset sortColumn.
	self.setParamsReadOnly(self.hasQueuedEntries(txtName.text.trimBlanks));
epilog
	delete parameterIterator;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMoveParameter" id="bf35fc1f-bdc8-4a86-96a1-632e1df4ba75">
        <source>doMoveParameter(pIsUp:Boolean) protected;

vars
	table			: Table;
	paramIndex		: Integer;
	newParamIndex	: Integer;
	sequence		: String;
	paramName		: String;
	displayValue	: String;
	paramType		: String;
	hasListString	: String;
	rowString		: String;

begin
	table		:=	tblParameters;
	paramIndex	:=	table.row;

	if (not table.cnEcIsRowSelected(paramIndex)) then
		app.msgBox($CNEC_SELECT_ITEM_TO_MOVE, $CNEC_ERROR, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;

	if pIsUp then
		if paramIndex = 2 then
			return;
		else
			newParamIndex	:=	paramIndex - 1;
		endif;
	else
		if paramIndex = table.rows then
			return;
		else
			newParamIndex	:=	paramIndex + 1;
		endif;
	endif;

	sequence		:=	table.getCellText(paramIndex, 1);
	paramName		:=	table.getCellText(paramIndex, 2);
	displayValue	:=	table.getCellText(paramIndex, 3);
	paramType		:=	table.getCellText(paramIndex, 4);
	hasListString	:=	table.getCellText(paramIndex, 5);
	rowString		:=	sequence &amp; Tab &amp; paramName &amp; Tab &amp; paramType &amp; Tab &amp; hasListString;

	table.removeItem(paramIndex);
	table.addItemAt(rowString, newParamIndex);
	self.doResequenceParameters();
	self.doEnableButtons();
end;</source>
        <access>protected</access>
        <Parameter name="pIsUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doParameterDelete" id="f2555b53-6fa8-40be-8bbe-580841f13f7e">
        <updating/>
        <source>doParameterDelete() updating, protected;
/*
	Changed On	Changed By	Reason
	----------	----------	---------------------------------------------------------------------------------
	2/11/1998	Darrell		Removed the self.attr_DeletedParameters objectArray.  When a report definition is
							now updated, all existing report parameter objects are purged, and re-created.
*/
vars
	theParameter	: CnEcReportParameter;
	table			: Table;
	paramIndex		: Integer;

begin
	table			:=	tblParameters;
	paramIndex		:=	table.row;

	if table.cnEcIsRowSelected(paramIndex) then
		theParameter	:=	table.cnEcGetCellObject(paramIndex, 1).CnEcReportParameter;

		table.removeItem(paramIndex);
		self.doResequenceParameters();
	else
		app.msgBox($CNEC_SELECT_ITEM_TO_DELETE, $CNEC_ERROR, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doParameterMaintain" id="c09b5b72-3516-4c22-8a2b-ca3dfb3f0feb">
        <source>doParameterMaintain(pIsNew:Boolean) protected;

vars
	paramForm	: CnEcReportParameterSuper;
	sequenceNo	: Integer;
	paramIndex	: Integer;
	table		: Table;
	rowString	: String;

begin
	if cmbForm.listIndex = CNEC_NULL_INDEX then
		app.msgBox("Please select the Report Form for this report.", $CNEC_ERROR, MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	endif;

	table	:=	tblParameters;
	create paramForm as global.cnEcGetReportModuleForm(CnEcReportParameterSuper);

	if pIsNew then
		if table.cnEcIsRowSelected(table.row) then
			sequenceNo	:=	table.getCellText(table.row, 1).Integer;
			paramIndex	:=	table.row;
		else
			sequenceNo	:=	table.rows;
		endif;

		paramForm.setIsNewEntry(true);
		paramForm.setReportFormName(cmbForm.text.trimBlanks);
		paramForm.setDescription(txtDescription.text.trimBlanks);
		paramForm.setSequence(sequenceNo);
		paramForm.showModal();

		if paramForm.aParameterName = null then
			// User must have cancelled.
			return;
		endif;

		rowString	:=	paramForm.aSequence.String;
		rowString	:=	rowString &amp; Tab &amp; paramForm.aParameterName;
		rowString	:=	rowString &amp; Tab &amp; paramForm.aDisplayValue;
		rowString	:=	rowString &amp; Tab &amp; paramForm.aParameterType;
		rowString	:=	rowString &amp; Tab &amp; paramForm.aIsValueList.cnEcGetYesNo();

		if paramIndex &gt; 0 then
			table.addItemAt(rowString, paramIndex);
			self.doResequenceParameters();
		else
			table.addItem(rowString);
		endif;
	else
	 	if btnParamUpdate.enabled = false then
	 		return;
	 	endif;
	 	
		if table.cnEcIsRowSelected(table.row) then
			paramIndex	:=	table.row;
		else
			app.msgBox($CNEC_SELECT_ITEM_TO_UPDATE, $CNEC_ERROR, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			return;
		endif;

		paramForm.setIsNewEntry(false);
		paramForm.setReportFormName(cmbForm.text.trimBlanks);
		paramForm.setDescription(txtDescription.text.trimBlanks);
		paramForm.setSequence(table.getCellText(paramIndex, 1).Integer);
		paramForm.setParameterName(table.getCellText(paramIndex, 2));
		paramForm.setDisplayValue(table.getCellText(paramIndex, 3));
		paramForm.setParameterType(table.getCellText(paramIndex, 4));
		paramForm.setIsValueList(table.getCellText(paramIndex, 5) = $CNEC_LIT_YES);
		paramForm.showModal();

		if paramForm.aParameterName = null then
			// User must have cancelled.
			return;
		endif;

		table.setCellText(paramIndex, 1, paramForm.aSequence.String);
		table.setCellText(paramIndex, 2, paramForm.aParameterName);
		table.setCellText(paramIndex, 3, paramForm.aDisplayValue);
		table.setCellText(paramIndex, 4, paramForm.aParameterType);
		table.setCellText(paramIndex, 5, paramForm.aIsValueList.cnEcGetYesNo());
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pIsNew" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResequenceParameters" id="4fb7dbc7-5125-4b21-b13c-360661c480ac">
        <source>doResequenceParameters() protected;

vars
	table		: Table;
	paramIndex	: Integer;
	rowCount	: Integer;

begin
	table		:=	tblParameters;
	rowCount	:=	table.rows;

	foreach paramIndex in 2 to rowCount do
		table.setCellText(paramIndex, 1, (paramIndex - 1).String);
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
