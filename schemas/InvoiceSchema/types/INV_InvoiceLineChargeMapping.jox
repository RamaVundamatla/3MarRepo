        <source>mnuViewAudits_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 January 2017	cnwma1	Initial creation

*/

vars

begin
	if self.myCurrentMapping &lt;&gt; null then
		app.viewAuditForm(self.myCurrentMapping, self.myAssistant.class, self.myTerminal);
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
