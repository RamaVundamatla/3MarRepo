    <JadeMethod name="createYardRequestJob" id="e4b2471a-01d2-4680-b441-823ba75d4c47">
        <source>createYardRequestJob() :CM_YardInternalJob;
//Used to create a "Depot Request" job, for a specific type of container. This is VERY
//much like a road release, but delivered to somewhere inside the yard instead.
//Called from VB interface, returns the job we created. Request is created later.
vars
	yardJob	:	CM_YardInternalJob;
begin
	create yardJob;
	yardJob.type := Depot_Request;
	yardJob.addToJobSheet();	
	return yardJob;
end;</source>
        <ReturnType type="CM_YardInternalJob"/>
    </JadeMethod>
    <JadeMethod name="delete" id="d7ade636-13b7-4300-9a12-9dcaf935764a">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By cnwrs1
//
// Purpose:		
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 04/07/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
// 24/09/2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
// 28/07/2020	jlgmd1				StarterDB - Prevent dialogs while the batch init app is (re)initialising the system
// ---------------------------------------------------------------------------

vars

begin
	if app.isJMTUnitTest then
		return;
	endif;
		
	if (not self.isTransient) and (not app.isBackGroundApp) then
		if app.msgBox("You are about to DELETE CM_Terminal '" &amp; self.code &amp; "' (" &amp; self.String &amp; ")." &amp; CrLf &amp;
						"Are you sure that you want to do this?",
						"Delete Terminal Confirmation", MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
			abortTransaction;
			return;
		endif;
	endif;
	self.allBatNumbersInUse.purge;
	
	if self.isTransient then					// TFS 4492
		self.allWeighAuthTerminals.purge;		// TFS 4492
	endif;										// TFS 4492
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152
	
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteExpiredNotifyRequests" id="18a094d1-d15a-40b2-9725-98b1e1aa472c">
        <source>deleteExpiredNotifyRequests(_passport : CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		23 September 2009 by cnwdad1
//
// Purpose:		Deletes expired notification requests.
//
// NOTE: This method was originally implemented on CM_Root.
//
// Parameters:	_passport - A reference to the user's passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	bgpEmail : BGP_EmailSendRequest;
	keyAddress,
	fromAddress,
	address,	
	reqMessage : String;
	days : Integer;
	expiryDT : TimeStamp;
	iter : Iterator;
	tmpNotifyRequest : CM_EventRequestNotification;
	bgpEmailDict : BGP_EmailReqByUserAddressDict;
	
begin
	days := app.myRoot.getConfig(EventRequestExpireNotify).Integer;
	expiryDT := app.serverTimestampAtTrxStart.cnEcAddDays(-days);
	fromAddress := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	
	create bgpEmailDict transient;
	iter := self.allEventRequestsNotify.createIterator();
	
	while iter.next(tmpNotifyRequest) do
		if tmpNotifyRequest.status &lt;&gt; EventRequestPending then
			break;
		endif;
		//if tmpNotifyRequest.enteredDT &lt; expiryDT then
		if tmpNotifyRequest.enteredDT &gt; expiryDT then		// 21/07/2008 cnwar2 #16636
			//break;
			continue;				// 19/07/2011 cnwjre1 27813 collection is keyed on statusDate
		endif;
		exclusiveLock(tmpNotifyRequest);
		
		reqMessage := 'Event notification request for cargo item ' &amp; tmpNotifyRequest.cargoId &amp; ' has expired and has been deleted.';
		
		foreach address in tmpNotifyRequest.allEmailAddresses do
			keyAddress := address[1:50];
			if keyAddress = null then //par15256 Nov 2007
				continue;
			endif;
			bgpEmail := bgpEmailDict.getAtKey(keyAddress);
			if bgpEmail = null then
				create bgpEmail;
				bgpEmail.setEmailRequest(	keyAddress,
											EventRequestTypeNotifyStr,
											address,
											fromAddress,
											null,
											null,
											EventRequestTypeNotifyStr,
											reqMessage,
											tmpNotifyRequest.myUser,
											self,
											null,
											null,
											null,
											null,
											EmailSource_System);
				bgpEmailDict.add(bgpEmail);
			else
				bgpEmail.addTextToSendMessage(reqMessage);
			endif;
		endforeach;
		
		delete tmpNotifyRequest;
		
	endwhile;

	app.myUtilityUA.utlUpdateBGPEmailRequests(bgpEmailDict, _passport);
epilog
	delete bgpEmailDict;
	delete iter;	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="deleteExpiredStopRequests" id="d3bca395-e5b0-4a1d-8226-b6df72159898">
        <source>deleteExpiredStopRequests(_passport : CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		23 September 2009 by cnwdad1
//
// Purpose:		Deletes expired stop requests.
//
// NOTE: This method was originally implemented on CM_Root.
//
// Parameters:	_passport - A reference to the user's passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	bgpEmail : BGP_EmailSendRequest;
	keyAddress,
	fromAddress,
	address,	
	reqMessage : String;
	days : Integer;
	expiryDT : TimeStamp;
	iter : Iterator;
	tmpStopRequest : CM_EventRequestStops;
	bgpEmailDict : BGP_EmailReqByUserAddressDict;
	
begin
	days := app.myRoot.getConfig(EventRequestExpireStops).Integer;
	expiryDT := app.serverTimestampAtTrxStart.cnEcAddDays(-days);
	fromAddress := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	
	create bgpEmailDict transient;
	iter := self.allEventRequestsStops.createIterator();
	
	while iter.next(tmpStopRequest) do
		if tmpStopRequest.status &lt;&gt; EventRequestPending then
			break;
		endif;
		//if tmpStopRequest.enteredDT &lt; expiryDT then
		if tmpStopRequest.enteredDT &gt; expiryDT then		// 21/07/2008 cnwar2 #16636
		//	break;
			continue;				// 19/07/2011 cnwjre1 27813 collection is keyed on statusDate
		endif;
		
		if not tmpStopRequest.autoCleanup then // CCMS 1542
			continue;
		endif;
		
		exclusiveLock(tmpStopRequest);
		
		reqMessage := 'Stop request for cargo item ' &amp; tmpStopRequest.cargoId &amp; ' has expired and has been deleted.';
		
		foreach address in tmpStopRequest.allEmailAddresses do
			keyAddress := address[1:50];
			if keyAddress = null then //par15256 Nov 2007
				continue;
			endif;
			if app.isDevelopmentSystem  and keyAddress.toLower.pos("jade" ,1) = 0 then
				continue;
			endif;
			bgpEmail := bgpEmailDict.getAtKey(keyAddress);
			if bgpEmail = null then
				create bgpEmail;
				bgpEmail.setEmailRequest(keyAddress,
										  EventRequestTypeStopsStr,
										  address,
										  fromAddress,
										  null,
										  null,
										  EventRequestTypeStopsStr,
										  reqMessage,
										  tmpStopRequest.myUser,
										  self,
										  null,
										  null,
										  null,
										  null,
										  EmailSource_System);
				bgpEmailDict.add(bgpEmail);
			else
				bgpEmail.addTextToSendMessage(reqMessage);
			endif;
		endforeach;
		
		delete tmpStopRequest;
	endwhile;
	
	app.myUtilityUA.utlUpdateBGPEmailRequests(bgpEmailDict, _passport);
epilog
	delete bgpEmailDict;
	delete iter;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="deleteExtraData" id="88181c3c-1cfd-4418-adbf-c713f1f0e416">
        <source>deleteExtraData(_key : String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2009	cnwar2	Initial creation (CCMS1107/#20627)

*/

vars
	stateObj : CM_StateObject;
	data	 : CM_StateData;
	
begin
	if self.allStateObjects.size &lt; ConfigGrp_ExtraData then
		return;
	endif;
	
	stateObj := self.allStateObjects[ConfigGrp_ExtraData];
	if stateObj &lt;&gt; null then
		data := stateObj.allStateData[_key];
		if data &lt;&gt; null then
			delete data;
		endif;
	endif;

end;</source>
        <Parameter name="_key" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteStateDataObject" id="7976da64-9b25-4625-bda3-e7ef1a48446c">
        <source>deleteStateDataObject(_key : String; _stateClass :Class): Boolean;
// ---------------------------------------------------------------------------
// Created:		01 April 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//	15/10/2009	cnwcs5	par 21044 - allow for null class to be passed in
vars
	stateObject		: CM_StateObject;
	stateData		: CM_StateData;
begin
	
	if _stateClass &lt;&gt; null and	// par 21044
		_stateClass.getSuperclass() &lt;&gt; CM_StateData then
		return false;
	endif;
	
	foreach stateObject in self.allStateObjects do
		foreach stateData in stateObject.allStateData do
			if _stateClass = null or	// par 21044
				stateData.isKindOf(_stateClass) then
				if stateData.key = _key then
					delete stateData;
					return true;
				endif;
			endif;
		endforeach;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_key" type="String"/>
        <Parameter name="_stateClass" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
