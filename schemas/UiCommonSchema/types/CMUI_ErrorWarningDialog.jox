    <JadeMethod name="canAckWarningsSkipErrors" id="c73f362f-553d-41f1-b39d-a166f338c724">
        <methodInvocation>mapping</methodInvocation>
        <source>canAckWarningsSkipErrors(set: Boolean; _value: Boolean io) mapping;
//--------------------------------------------------
// Created:	22 June 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := self.mode.bitAnd(ErrWarnMode_CanAckWarnSkipErr).Boolean;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
