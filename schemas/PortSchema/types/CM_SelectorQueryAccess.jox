    </JadeMethod>
    <JadeMethod name="setForUpdate" id="bb552636-aacd-4341-a32b-f38b8832235d">
        <updating/>
        <source>setForUpdate( _pxyQuerySet : CM_SelectorQueryAccess; _queryColl : CM_MenuUserQueryArray ) updating;
// ---------------------------------------------------------------------------
// Created:     15 April 2008		cnwvu1	
// ---------------------------------------------------------------------------

vars

begin

	self.description:= _pxyQuerySet.description;

	self.allSelectedQueries.clear();
	_queryColl.copy( self.allSelectedQueries );

end;
</source>
        <Parameter name="_pxyQuerySet" type="CM_SelectorQueryAccess"/>
        <Parameter name="_queryColl" type="CM_MenuUserQueryArray"/>
    </JadeMethod>
    <JadeMethod name="validate" id="57382d83-1e6d-4b29-8d48-643fd2fed6ed">
        <source>validate( _queryColl : CM_MenuUserQueryArray );
// ---------------------------------------------------------------------------
// Created:     14 April 2008		cnwvu1	
// ---------------------------------------------------------------------------

vars
	query	: CM_MenuUserQuery;

begin
	
	if self.description = null then
	//	app.raiseCMException1( REQUIRED_FIELD, "Description", null, self );
		app.raiseCMException(Input_required_field_Desc, null, self ); // cnwdb2	PAR 35364
	endif;

	if _queryColl.isEmpty then		// exception - SelectorQueryAccess should have at least one selected query.
			app.raiseCMException(ERR_SelectorQuerySet, null, self);
	endif;

	if _queryColl.size &gt; 36 then		// exception - SelectorQueryAccess should have at least one selected query.
			//app.raiseCMException(ERR_SelectorQuerySetMax, null, self);
			app.raiseCMWarning(ERR_SelectorQuerySetMax, null, self, self);	//04 Oct 2011	NDL	Par 28283
	endif;

	foreach query in _queryColl do	// check for queries' opertors. Must only use operations except for selection and sort off "one is of"
		query.validateForRT();
	endforeach;

end;
</source>
        <Parameter name="_queryColl" type="CM_MenuUserQueryArray"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="4873ba34-8c68-4b9f-b796-f706732e14e7">
        <source>validateDelete(_passport: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     14 April 2008		cnwvu1	
// ---------------------------------------------------------------------------

vars

	whereUsed : String;

begin
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.description, whereUsed, null, self);
	endif;
	
end;
</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
