    <JadeMethod name="createProperties" id="cc7f5936-5a20-4fc0-8232-5c23a00d613c">
        <source>createProperties();
/*  CCMS 1262 CM_EventTransaction properties for selector queries

Changed On	By			Reason
----------	--------	---------------------------------------------------------------------
25/09/2018	jlgka1		TFS 40200 Add User List to use CM_QStrUserProperty.
25/09/2018	jlgka1		TFS 40200 Add Resource Used List to use CM_QStrResourceMethod.
*/
vars
	qProp		: CM_QueryProperty;
begin
	inheritMethod();		// 'Terminal', myTerminal
	
	// HMS_VTMISTransaction properties
	create qProp as CM_QDateProperty persistent;
	qProp.set('Transaction Date', HMS_Transaction::transactionDT.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QRefDebtorMethod persistent;
	qProp.set('Debtor', HMS_VTMISTransaction::getDebtorForSelector.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QStringMethod persistent;
	qProp.set('Invoice Number', HMS_VTMISTransaction::getInvoiceNumber.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);

	create qProp as CM_QBooleanProperty persistent;
	qProp.set('Is No Charge', HMS_VTMISTransaction::noCharge.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QStringProperty persistent;
	qProp.set('User Code', HMS_VTMISTransaction::userCode.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	//jlgka1 TFS 40200 25/09/2018 --&gt;
	create qProp as CM_QStrUserMethod persistent;
	qProp.set('User List', HMS_VTMISTransaction::getUserCode.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	//jlgka1 TFS 40200 25/09/2018 &lt;--
	
	create qProp as CM_QRefVoyageMethod persistent;
	qProp.set('Voyage', HMS_VTMISTransaction::getVoyage.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QStringMethod persistent;
	qProp.set('Resource Used Code', HMS_VTMISTransaction::getResourceCode.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	//jlgka1 TFS 40200 25/09/2018 --&gt;
	create qProp as CM_QStrResourceMethod persistent;
	qProp.set('Resource Used List', HMS_VTMISTransaction::getMyResourceUsedCode.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	//jlgka1 TFS 40200 25/09/2018 &lt;--
	
	create qProp as CM_QDecimalMethod persistent;
	qProp.set('Resource Units', HMS_VTMISTransaction::getResourceUnits.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);

	create qProp as CM_QDateMethod persistent;
	qProp.set('Resource From Date', HMS_VTMISTransaction::getResourceFromDT.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);

	create qProp as CM_QDateMethod persistent;
	qProp.set('Resource To Date', HMS_VTMISTransaction::getResourceToDT.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QStringMethod persistent;														//03/06/2020 cnwma1 Tfs #49400
	qProp.set('Voyage Group Code', HMS_VTMISTransaction::getVoyageGroupCode.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
end;</source>
    </JadeMethod>
    <JadeMethod name="getSelectorVisibleColumns" id="3ee00d72-d62b-42a8-bd0f-377fbc054f05">
        <source>getSelectorVisibleColumns(_sa : StringArray input);
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries - hard-coded list equivalent to CM_CargoBOLType allSelectorVisibleColumns
vars
	qProp	: CM_QueryProperty;
begin
	_sa.clear();

	qProp := self.allQueryProperties[HMS_VTMISTransaction::transactionDT.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[HMS_VTMISTransaction::getDebtorForSelector.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[HMS_VTMISTransaction::getInvoiceNumber.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[HMS_VTMISTransaction::myTerminal.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[HMS_VTMISTransaction::noCharge.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;

end;
</source>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
</Class>
