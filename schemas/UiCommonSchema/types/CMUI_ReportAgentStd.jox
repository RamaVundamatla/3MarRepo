        <source>doLoadVoyageJobs(_cmbJob : CMUI_ComboBox input; _voyage : CM_Voyage) protected;
// ---------------------------------------------------------------------------
// Created:     05 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	voyageCode	: String;
begin
	if _cmbJob = null then
		return;
	endif;
