    <JadeMethod name="releaseAssignCargo" id="021ad84b-a8c3-455d-96c5-ed7375b50b60">
        <source>releaseAssignCargo(_release : CM_BulkRelease; _allTIPins : CM_StringDict; _ti: CM_TrackedItem);
//04 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items

vars
	pxyBulkRelease : CM_BulkRelease;
	cmif_BulkRelease : CMIF_BulkRelease;
begin
	if _release.isTransient() then
		pxyBulkRelease := _release;
	else
		pxyBulkRelease	:=	app.createUpdateProxy(_release).CM_BulkRelease;
	endif;
	pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.add(_ti);
	//pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.setTotalRequested(pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size);
	pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.setTotalRequested(pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false));
	pxyBulkRelease.allTrackedItemsAssigned.add(_ti);	
	app.myTrxUA.trxUpdateBulkRelease(pxyBulkRelease, _allTIPins, app.myPassport); //cnwrd1 par 25594 10.12.2010

	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete pxyBulkRelease;
end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_allTIPins" type="CM_StringDict"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="releaseAssignCargoWithWaybill" id="792d6a21-27ce-4d38-8b66-a9b4bcbf4ff5">
        <updating/>
        <source>releaseAssignCargoWithWaybill(_release : CM_BulkRelease; _ti: CM_TrackedItem)updating;
//04 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
vars
	pxyBulkRelease : CM_BulkRelease;
	cmif_BulkRelease : CMIF_BulkRelease;
begin
	if _release.isTransient() then
		pxyBulkRelease := _release;
	else
		pxyBulkRelease	:=	app.createUpdateProxy(_release).CM_BulkRelease;
	endif;
	pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.add(_ti);
	//pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.setTotalRequested(pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size);
	pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.setTotalRequested(pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false)); //23/06/2023	navkc1	CR 58406 Task 58408
	pxyBulkRelease.allTrackedItemsAssigned.add(_ti);	
	pxyBulkRelease.setAllowCargoOnMultipleRelease(true);
	app.myTrxUA.trxUpdateBulkRelease(pxyBulkRelease,null, app.myPassport); //cnwrd1 par 25594 10.12.2010

	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete pxyBulkRelease;
end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="releaseAssignCargoWithoutWay" id="7b05c8c5-9dd8-483f-b8ca-00cda1f69dc8">
        <updating/>
        <source>releaseAssignCargoWithoutWay(_release : CM_BulkRelease; _ti: CM_TrackedItem)updating;
//04 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items

vars
	pxyBulkRelease : CM_BulkRelease;
	cmif_BulkRelease : CMIF_BulkRelease;
begin
	if _release.isTransient() then
		pxyBulkRelease := _release;
	else
		pxyBulkRelease	:=	app.createUpdateProxy(_release).CM_BulkRelease;
