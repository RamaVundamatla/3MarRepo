    <JadeMethod name="translateForm" id="d93ca511-1839-4389-9c7f-f954c16fb0d3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 03 April 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016003, locale);
	btnAddDelay.translateCaption(Xlat_0016004, locale);
	lblDelayGroup.translateCaption(Xlat_0016005, locale);
	lblDelayType.translateCaption(Xlat_0016006, locale);
	lblEndTime.translateCaption(Xlat_0016007, locale);
	lblMachine.translateCaption(Xlat_0016008, locale);
	lblStartTime.translateCaption(Xlat_0016009, locale);
	lblVoyage.translateCaption(Xlat_0016010, locale);
	mnuAudits.translateCaption(Xlat_0019592, locale);
///	mnuColumnOrganiser.translateCaption(Xlat_0006432, locale);
	mnuColumnOrganiser2.translateCaption(Xlat_0016011, locale);
	mnuContextTbl.translateCaption(Xlat_0016012, locale);
	mnuEndDelay.translateCaption(Xlat_0016013, locale);
///	mnuInspectObj.translateCaption(Xlat_0006435, locale);
	mnuInspectObj2.translateCaption(Xlat_0016014, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateObjectInTable" id="bb545623-f733-44e0-a424-5c4d956b2c05">
        <source>updateObjectInTable(_eventType : Integer; _delay :CM_Delay; _table : CM_DataTable input) : Boolean protected;
/*
----------   ----------  --------------------------------------------------
Created:	16 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	row	: Integer;
begin

	if _eventType = Object_Delete_Event or _eventType = Object_Update_Event then
		_table.findObjectInRow(_delay, row);
	
		if row &lt;= _table.fixedRows then
			return false;
		endif;
	
		_table.removeItem(row); 
		
		self.doNotableRemove (_delay);
		
		if _eventType = Object_Update_Event then 
			self.doQueryAddItem(_delay);
		endif;
		
	elseif _eventType = Object_Create_Event then
		self.doQueryAddItem(_delay);
	endif;
	
	 _table.colourRows(self.colorRow1, self.colorRow2);
	 
	return true;
end;
</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_delay" type="CM_Delay"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
