    <JadeMethod name="getDisplayStringForAttribute" id="36cd0370-78c8-4584-9417-b8805046d68b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2023 navhl20 ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS

*/

vars

begin
	if _attrName = ETRow_VbsId then
		return self.allVBSSlots.listString(Comma,CM_VehicleBookingTimeSlot::id.name);
	elseif _attrName = ETRow_ExternalRef then
		return self.allVBSSlots.listString(Comma,CM_VehicleBookingTimeSlot::externalReference.name);
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
