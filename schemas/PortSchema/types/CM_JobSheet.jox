    <JadeMethod name="setWorkStartedDate" id="fffe1c80-6659-4a55-bd3c-38ba20ff7cfe">
        <updating/>
        <source>setWorkStartedDate(_workStartedDate : TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	
begin
	//epr par 32088 2/8/2013 only override if workstarted is null 
	if not self.workStarted.isValid then
		self.workStarted:=_workStartedDate;
	endif;

end;</source>
