	and self.myTrackedItem.bookingReference &lt;&gt; null then
		if self.myTerminal = null then
			return false;
		endif;
		if self.myTrackedItem.operatorCode &lt;&gt; null then		//Lookup by operator
			br := self.myTerminal.allBookingRefsByOperatorRef[self.myTrackedItem.operatorCode, self.myTrackedItem.bookingReference.trimRight];
		else
			br := self.myTerminal.allBookingRefsByRef[self.myTrackedItem.bookingReference.trimRight];
		endif;
		if _yaData.allObjects.includes(br) then
			return true;
		endif;	
	endif;
	return false;
*/
