    <JadeMethod name="tblDataDblClick" id="4b62a598-f7a7-4c93-9665-bd20a203a8bb">
        <updating/>
        <source>tblDataDblClick(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars
	theRow	: Integer;

begin

	theRow := table.row;
	
	if theRow &lt;= 0 then
		return;
	endif;

	if theRow = 1 then
		return;
	else
		self.handleTblDataDblClick(theRow);
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="994a06ee-60d7-4e95-bbd9-50774c959dd9">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 October 2018 09:43:37.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022918, locale);
	lblCrane.translateCaption(Xlat_0018515, locale);
	lblCraneOpr.translateCaption(Xlat_0023028, locale);
	lblExchangeEnd.translateCaption(Xlat_0018516, locale);
	lblExchangeSt.translateCaption(Xlat_0018517, locale);
	lblLabourEnd.translateCaption(Xlat_0018518, locale);
	lblLabourSt.translateCaption(Xlat_0018519, locale);
	lblRemarks.translateCaption(Xlat_0018520, locale);
end;</source>
    </JadeMethod>
</GUIClass>
