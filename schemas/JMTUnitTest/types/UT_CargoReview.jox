	reservations := jdo.getPropertyValue(ETRow_Reservations).String;
	quantityReserved := jdo.getPropertyValue(ETRow_QuantityReserved).Integer.asStringJMT;		
	self.assertTrueMsg(quantityTotal = "45", "Wrong total quantity.  Expected 45 got " &amp; quantityTotal );
	self.assertTrueMsg(reservations = "REL04(12),REL05(8)", "Wrong Reservation.  Expected REL04(12),REL05(8) got " &amp; reservations);
	self.assertTrueMsg(quantityReserved = "20", "Wrong quantity reserved.  Expected 20 got " &amp; quantityReserved );
	
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup("CG_X");
	self.deleteCargoGroup("CG_Y");
	
	
epilog
	self.resetDefaultTranMap();
	delete pxyBOL;
	delete dateArray;
	delete criteriaHolder;
	delete myEnqController;
