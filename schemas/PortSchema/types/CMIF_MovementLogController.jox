    <JadeMethod name="checkOverlap" id="2a73573f-ad0c-4b03-8a64-37b343cb716a">
        <updating/>
        <source>checkOverlap(_container : CM_Container; _gc : CM_GridController) updating, protected;
/*

Purpose:			Check when a container is moved to/from a slot that may have caused it
					to overlap into or out of a Yard Allocation area

Parameters:			Container being moved, Primary Location Controller

Return Value:		


Date		Who		Reason
05 September 2008	conkc1	Initial creation

*/
vars
	offset : Integer;
	length : Integer;
	used   : Integer;
	nextGC : CM_GridController;
	
begin
	if _container.is20 then
		return;
	endif;
	
	length := _container.getActualLength.Integer;
	
	if _container.is30 then
		offset := _gc.offset30;
	elseif _container.is45 then
		offset := _gc.offset45;
	elseif _container.is40 then
		offset := 0;
	elseif _container.is53 then
		offset := _gc.offset53;
	else
		// error
		return;
	endif;
	
	if offset = -1 or offset &gt; 19 then
		// error
		return;
	endif;
	
	used := 20 - offset;
	
	//
	// Now loop through all Controllers for this container
	//
	
	nextGC := _gc;
	
	while used &lt; length do
		nextGC := nextGC.myNextController;
		if nextGC = null then
			return;
		endif;
		self.checkYABlocks(nextGC);
		used := used + 20;
	endwhile;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_container" type="CM_Container"/>
        <Parameter name="_gc" type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="checkYABlocks" id="d22bb732-a58c-43be-8c4f-e296c6e9f5c5">
        <source>// PAR 19285
//checkYABlocks(_gc : CM_GridController) protected;
checkYABlocks(_gc : CM_YardController) protected;
/*

Purpose:			Checks for YABlock and adds unique ones to myYABlockSet 

Parameters:			Current Controller

Return Value:		


Date		Who		Reason
05 September 2008	conkc1	Initial creation

*/
vars
	ya : CM_YABlock;	
begin
	// This could potentially make following faster - need to test (RJS Jun 2009)
	//foreach ya in _gc.allYABlocks where
	//		ya.myYardAllocationIn &lt;&gt; null and
	//		(not ya.myYardAllocationIn.isYASnapshot)
	//do
	
	foreach ya in _gc.allYABlocks do
		if ya.myYardAllocationIn = null then
			continue;
		endif;
		
		if ya.myYardAllocationIn.isYASnapshot = true then 
			continue;
		endif;
		
		if self.allYABlocksSet.includes(ya) = false then
			self.allYABlocksSet.add(ya);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_gc" type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="create" id="dbe5ba16-d3ed-4c48-967c-d9c7c31117e5">
        <updating/>
        <source>create() updating;

/*

Purpose:			Set up defaults for parameters

Parameters:			

Return Value:		


Date		Who		Reason
22 Jul 2009	cnwkpd1	PAR #20328 - Fix problem with SDS tracking
					Also "soften" up runtime settings to add tuning ability

*/

vars

begin
	self.maximumNumberToProcess := 20;
	self.minimumAgeToProcess := 0;
	self.timerIntervalCatchUp := 1000;
	self.timerIntervalNormal := 1000;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllTAsGridRowsAndYABlocks" id="a5038a8f-b95b-4f8d-84f6-75e1a244c602">
        <updating/>
        <source>getAllTAsGridRowsAndYABlocks(_lc : CM_LocationsController; 
							 _movementLog : CM_MovementLog) updating, protected;

/*

Purpose:			To optimise the number of calculations required, find the unique Terminal Areas,
					Grid Rows and YABlock's

Parameters:			Current LC

Return Value:		None - updates allGridAreasSet, allTerminalAreasSet and allYABlocksSet


Date		Who		Reason
22 Aug 2008	conkc1	Initial creation
27 Mar 2009	cnwkpd1	PAR #19285 - Add in calculation for Block Stacks
07 Sep 2009	cnwkpd1	PAR #20586 - Improve performance by only processing affected rows

*/

vars
	ta      		: CM_TerminalArea;
	container		: CM_Container;
	yc        		: CM_YardController;
	gridCont		: CM_GridController;
	
begin
	// Location statistics are only valid for Stacks, RTG and Block Stacks
	if _lc.isKindOf(CM_StackController) or _lc.isKindOf(CM_BlockController) or _lc.isKindOf(CM_RTGController) then
		
		yc := _lc.CM_YardController;			// PAR 19285
		
		ta := yc.myTerminalArea;

		// Collect unique Terminal Areas
		self.allTerminalAreasSet.addNoDuplicates(ta, false);

		// And YA Blocks
		self.checkYABlocks(yc);

		// PAR #20586 - for Grid controllers, also collect unique Grid Rows
		if yc.isKindOf(CM_GridController) then
		
			gridCont := yc.CM_GridController;
			if gridCont.myGridRow &lt;&gt; null then
				self.allGridRowsSet.addNoDuplicates(gridCont.myGridRow, false);
			endif;
			if gridCont.myGridColumn &lt;&gt; null then
				self.allGridColumnSet.addNoDuplicates(gridCont.myGridColumn, false);
			endif;
			// And also any overlapping YA Blocks for grid controllers
			if _movementLog.myTrackedItem = null then
				return;
			endif;

			if _movementLog.myTrackedItem.isKindOf(CM_Container) then
				container := _movementLog.myTrackedItem.CM_Container;
				self.checkOverlap(container, gridCont);
			endif;
		endif;
	endif;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_movementLog" type="CM_MovementLog"/>
    </JadeMethod>
    <JadeMethod name="getAllTerminalAreasAndYAB_OLD" id="50615894-7bd6-4e91-8953-919b82dde6b2">
        <updating/>
        <source>getAllTerminalAreasAndYAB_OLD(_lc : CM_LocationsController; _movementLog : CM_MovementLog) updating, protected;
/*

Purpose:			To optimise the number of calculations required
					Only keeps unique YABlock's

Parameters:			Current LC

Return Value:		None - updates myTerminalAreaSet and myYABlockSet


Date		Who		Reason
22 August 2008	conkc1	Initial creation

*/
vars
	gc        : CM_GridController;
	ta        : CM_TerminalArea;
	container : CM_Container;
	
begin
	if _lc.isKindOf(CM_StackController) /*or lc.isKindOf(CM_BlockController)*/
	or _lc.isKindOf(CM_RTGController)
	then
		gc := _lc.CM_GridController;
		ta := gc.myTerminalArea;
		
		if self.allTerminalAreasSet.includes(ta) = false then
			self.allTerminalAreasSet.add(ta);
		endif;

		self.checkYABlocks(gc);

		if _movementLog.myTrackedItem = null then
			return;
		endif;
		
		if _movementLog.myTrackedItem.isKindOf(CM_Container) then
			container := _movementLog.myTrackedItem.CM_Container;
			self.checkOverlap(container, gc);
		endif;

	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_movementLog" type="CM_MovementLog"/>
    </JadeMethod>
    <JadeMethod name="handleMovementLogEx" id="9562d755-32e9-411d-b236-443ad0d4b35c">
        <updating/>
        <source>handleMovementLogEx(_ex : Exception; _error4 : Boolean io) : Integer updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2008	conkc1	Initial creation

*/
begin
	//
	// Check if the object has been deleted before we get here
	// if so just ignore it and process the next object
	//
	if _ex.errorCode = 4 then
		_error4 := true;
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="_ex" type="Exception"/>
        <Parameter name="_error4" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initMovementLog" id="5e3e20a0-fb75-4e1c-ad82-93d0a8e0e39e">
        <updating/>
        <source>initMovementLog() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Aug 2008	conkc1	Initial creation
22 Jul 2009	cnwkpd1	PAR #20328 - Fix problem with SDS tracking
					Also "soften" up runtime settings to add tuning ability

*/

vars

begin
	app.writeLog('Location Statistics controller started ' &amp; process.String, LogINFO);
	app.writeLog('Number of unprocessed movement logs is ' &amp; CM_MovementLog.countPersistentInstances.String, LogINFO);
	
	self.setupFromInitializationFile();		// PAR #20328
	
	beginTimer(self.timerIntervalCatchUp, Timer_OneShot, EVENT_LOCATION_STATS_TIMER); 
	
	
epilog

end;</source>
    </JadeMethod>
