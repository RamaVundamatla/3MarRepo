    <JadeMethod name="getMappingLineValue" id="03f0eeab-3d76-42e6-9cf9-66184581ddf7">
        <source>getMappingLineValue():String;
// ---------------------------------------------------------------------------
// Created:     07 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myXTABMapping.order = CM_XTABMapping.ORDER_MAPPING_VALUE then
		return (self.mappedValue);
	else
		return (CM_XTABMapping.MAPPING_PREFIX &amp; self.myXTABMapping.allMappingLines.indexOf(self).padLeadingWith ('0', 6));
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="7d476607-7fbc-4c2e-9b63-abf5ef31e852">
        <updating/>
        <source>setForCreate(_proxy : CM_XTABMappingLine input)updating;
// ---------------------------------------------------------------------------
// Created:     23 November 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.setForUpdate (_proxy);
epilog

end;</source>
        <Parameter name="_proxy" type="CM_XTABMappingLine" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e3ae828e-5ebc-44e6-a40f-54221239e5cd">
        <updating/>
        <source>setForUpdate(_proxy: CM_XTABMappingLine input) updating;
// ---------------------------------------------------------------------------
// Created:     23 November 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	queryOperator : CM_QueryOperator;
begin
	self.mappedValue		:= _proxy.mappedValue;
	
//	self.myQueryOperator	:= _proxy.myQueryOperator;
	//26 Nov 2009	NDL	
	if _proxy.myQueryOperator &lt;&gt; null then
		queryOperator := _proxy.myQueryOperator.cloneSelf( false );
		_proxy.myQueryOperator.cloneReferences(queryOperator);
		self.myQueryOperator := queryOperator;
	endif;
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_XTABMappingLine" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMappedValue" id="1d194674-ece7-46ae-9e1b-4e5088bce16e">
