    <JadeMethod name="getValueForRow" id="5b2bc35e-2e99-4bc6-b1c2-7e5a3827b61f">
        <source>getValueForRow(_rowName: String; _obj: Object output): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason 
04 April 2022	jlier1	Initial creation 53286

*/

vars

begin
	if _rowName = ETRow_BgpExternalFinInterface then
		if self.myExtFinanceIO &lt;&gt; null then
			return self.myExtFinanceIO.getNiceName;
		endif;
		return null;
	elseif _rowName = ETRow_BgpAutoDirectoryPath then
		if self.myExtFinanceIO &lt;&gt; null then
			return self.myExtFinanceIO.exportPath;
		endif;
		return null;
	elseif _rowName = ETRow_BgpBusinessUnit then
		if self.myBusinessUnit &lt;&gt; null then
			return self.myBusinessUnit.code;
		endif;
		return null;
	elseif _rowName = ETRow_BgpEmailGroup then
		if self.myEmailGroup &lt;&gt; null then
			return self.myEmailGroup.name;
		endif;
		return null;
	else
		return inheritMethod(_rowName, _obj);
	endif;	

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="4edbfa1e-85db-4b98-b810-ade5609a4e4a">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2022	jlier1	Initial creation 53286

*/

vars
	pxy : CM_AutoTaskIFS;
begin
	pxy:= inheritMethod();
	
	if pxy = null then
		return null;
	endif;
	
	pxy.myBusinessUnit:=self.myBusinessUnit;
	pxy.myExtFinanceIO:= self.myExtFinanceIO;
	pxy.myEmailGroup:=self.myEmailGroup;
	
	return pxy;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="fd127914-be4d-4ffe-ab6e-4f3adedef894">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskIFS) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2022	jlier1	Initial creation 53286

*/

vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName:=BGP_IFSRequest.name;
	self.myBusinessUnit:=_pxyAutoTask.myBusinessUnit;
	self.myExtFinanceIO:=_pxyAutoTask.myExtFinanceIO;
	self.myEmailGroup:=_pxyAutoTask.myEmailGroup;
	
epilog

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskIFS"/>
