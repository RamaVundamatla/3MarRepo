<PrimType name="Real">
    <JadeMethod name="asFeetInches" id="e7fd9b5d-0226-4abe-9a88-77cd1c0ac3fc">
        <source>asFeetInches() : String;
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theString : String;
	theInteger : Integer;
	theDecimal : Decimal[3,2];
begin
	theInteger := self.Integer;
	theDecimal := self - theInteger;
	
	if theInteger = 0 then
		theString := "";
	elseif theInteger = 1 then
		theString := "1 Foot";
	else
		theString := theInteger.String &amp; " Feet";
	endif;
	
	if theDecimal &gt; 0 then
		if theDecimal &lt;= .1 then
			theString := theString &amp; ", 1 Inch";
		elseif theDecimal &lt;= .2 then
			theString := theString &amp; ", 2 Inches";
		elseif theDecimal &lt;= .2 then
			theString := theString &amp; ", 2 Inches";
		elseif theDecimal &lt;= .25 then
			theString := theString &amp; ", 3 Inches";
		elseif theDecimal &lt;= .30 then
			theString := theString &amp; ", 4 Inches";
		elseif theDecimal &lt;= .4 then
			theString := theString &amp; ", 5 Inches";
		elseif theDecimal &lt;= .5 then
			theString := theString &amp; ", 6 Inches";
		elseif theDecimal &lt;= .6 then
			theString := theString &amp; ", 7 Inches";
		elseif theDecimal &lt;= .7 then
			theString := theString &amp; ", 8 Inches";
		elseif theDecimal &lt;= .75 then
			theString := theString &amp; ", 9 Inches";
		elseif theDecimal &lt;= .8 then
			theString := theString &amp; ", 10 Inches";
		elseif theDecimal &lt;= .99999 then
			theString := theString &amp; ", 11 Inches";
		endif;
	endif;
	return theString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asNullReal" id="9681f244-19d7-4501-a785-ad47ba44e637">
        <source>asNullReal() : String;
/*

Purpose:		For display of positive real values where zero is a valid value to enter.
				NULL_INTEGER (negative value) indicates a value has not been entered.

Parameters:			

Return Value:		


Date				Who		Reason
//par18451 nov 2008 cnwrs1

*/

vars

begin
	if self &gt; NULL_INTEGER then
		return self.String;
	else
		return null;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asStringEDIWithPrecision" id="e8294333-350b-4a7c-8a2c-a47010ae80e4">
        <source>asStringEDIWithPrecision(_decimalPrecision : Integer):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2018	jlgma1	Bug 39347: SNO - Error in BAPLIE when reporting reefer temepratures

*/

constants
	JMTDecimalSeperator = ".";
vars
	decimalSeperator,
	currentStringValue,localeFormat	: String;
	len, pos, sbe, diff 			: Integer;
	isNeg : Boolean;
	me : Decimal[12,2];
begin

	localeFormat 		:=	self.roundedTo(_decimalPrecision).display();
	
	if _decimalPrecision = 0 then
		return localeFormat;
	endif;
	
	pos := localeFormat.pos(JMTDecimalSeperator,1);
	if pos = 0 then
		if _decimalPrecision &gt; 0 then 
			len := localeFormat.length;
			sbe :=len + 1  + _decimalPrecision;
			localeFormat := localeFormat &amp; JMTDecimalSeperator;
			foreach pos in 1 to _decimalPrecision do
				localeFormat := localeFormat &amp; "0";
			endforeach;
		endif;
	else
		len := localeFormat.length;
		sbe := pos + _decimalPrecision;
		diff := sbe - len;
		if diff &gt; 0 then
			foreach pos in 1 to diff do
				localeFormat := localeFormat &amp; "0";
			endforeach;
		
		endif;
	endif;
	
	return localeFormat;


end;</source>
        <Parameter name="_decimalPrecision" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
