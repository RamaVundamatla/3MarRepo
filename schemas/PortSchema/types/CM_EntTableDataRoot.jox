    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="myRoot" id="8f6529de-8433-4b5c-b209-38b0574cb4d5">
        <kind>child</kind>
