    <JadeMethod name="setTaskComplete" id="02cf7c54-1f85-42fa-ad5d-f68f80b24ab0">
        <updating/>
        <source>setTaskComplete(_passport : CM_Passport input; _createTransaction : Boolean; _newTrans : CM_TITransaction output) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
// ---------------------------------------------------------------------------
vars

begin

	if (not self.canUserSetComplete(_passport)) then
		return false;
	endif;
	self.setTaskStatus(STATUS_COMPLETE, _passport);
	
	return true;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_createTransaction" type="Boolean"/>
        <Parameter name="_newTrans" type="CM_TITransaction" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTaskStatus" id="a6189c79-75f8-43aa-b879-42cf71443a73">
        <updating/>
        <source>setTaskStatus(_newStatus : Integer; _passport : CM_Passport input) : Boolean updating, protected;
//Shift this task to the "todoTasks" array of the TI.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/07/2009	consw1		PAR 20335 - SFW1075 To Do Task Scheduling
// 14/06/2022 	navcs2 		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
// ---------------------------------------------------------------------------

vars

begin
	exclusiveLock(self);
	self.dtLastUpdate 	:= app.serverTimestampAtTrxStart;
	self.status			:= _newStatus;
	self.userLastUpdate := _passport.userCode;
	
	if self.status = STATUS_COMPLETE and self.myWOToDoWLE &lt;&gt; null then //14/06/2022 navcs2 TFS 53038 
		self.myWOToDoWLE.setStatus(WLE_COMPLETED);
		if self.myWOToDoWLE.job &lt;&gt; null then
			self.myWOToDoWLE.job.updateStatus();
		endif;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setToDoTaskComplete" id="158a7eb0-8555-4b82-ba37-5f3a21fee3bd">
        <updating/>
        <source>setToDoTaskComplete(_passport : CM_Passport input; _resourceProxies: CM_ResourceTypeUsageSet) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Nov 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTIabortTransaction;
*/


vars
	
begin
	self.setTaskStatus(STATUS_COMPLETE, _passport);
	
	if self.myWODetailToDo &lt;&gt; null then								//12.01.2023 navma1 #56141 Task#56147
		self.myWODetailToDo.setToDoTaskComplete(self);
	endif;	
		
	return true;

epilog
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_resourceProxies" type="CM_ResourceTypeUsageSet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="statusString" id="fdfbd4bb-0220-48e2-b21f-2d7bb313ab2f">
        <methodInvocation>mapping</methodInvocation>
        <source>statusString(set: Boolean; _value: String io) mapping;

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.status = STATUS_TODO then
		_value := "Todo";

	elseif self.status = STATUS_TOBECERT then
		// NOT USED ANYMORE
		_value := "Actioned (To be Certified)";

	elseif self.status = STATUS_COMPLETE then
		_value := "Completed";
	else
		_value := "Unknown";
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="toDoTaskDescTrans" id="168a9910-f262-446a-8ea8-7b574c0892a0">
        <methodInvocation>mapping</methodInvocation>
        <source>toDoTaskDescTrans(set: Boolean; _value: String io) mapping;
//Returns the transaction to create if required.
//We may not find one (quite valid, this is why this is virtual)
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	toDoDesc	:	CM_ToDoTaskDesc;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	//----------------
	//Attempt to use the local reference, if its any good.
	//----------------
	if self.toDoTaskDesc &lt;&gt; null then		// and global.isValidObject(self.toDoTaskDesc) then
		toDoDesc := self.toDoTaskDesc;
	else
		toDoDesc := app.myRoot.allToDoTaskDescriptions[self.toDoTaskDescCode];
	endif;
	
	if toDoDesc = null then
		_value := null;
		return;
	endif;
	
	_value	:=	toDoDesc.getTrxTypeOnCompleteClassName();
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="toDoTaskDescTransType" id="ba9c1249-f35f-464f-90ff-c7c7bccb6a15">
        <methodInvocation>mapping</methodInvocation>
        <source>toDoTaskDescTransType(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     13 March 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	toDoDesc	:	CM_ToDoTaskDesc;
	tmpTransType	: CM_TransactionType;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	//----------------
	//Attempt to use the local reference, if its any good.
	//----------------
	if self.toDoTaskDesc &lt;&gt; null then 	// and global.isValidObject(self.toDoTaskDesc) then - inversed, so cant be invalid
		toDoDesc := toDoTaskDesc;
	else
		toDoDesc := app.myRoot.allToDoTaskDescriptions[self.toDoTaskDescCode];
	endif;
	
	if toDoDesc = null then
		_value := null;
		return;
	endif;
	
	tmpTransType := toDoDesc.getTrxTypeOnCompletion();
	if tmpTransType &lt;&gt; null then
		_value	:=	tmpTransType.trxType;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="toDoTaskDescTrxOnCreate" id="40b6d21d-72e0-4bf9-bae8-21406384c2dc">
        <methodInvocation>mapping</methodInvocation>
        <source>toDoTaskDescTrxOnCreate(set: Boolean; _value: String io) mapping;
//
//cnwrs1 CCMS 1826 29 July 2010
//
vars
	toDoDesc : CM_ToDoTaskDesc;
	trxType : CM_TransactionType;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	//----------------
	//Attempt to use the local reference, if its any good.
	//----------------
	if self.toDoTaskDesc &lt;&gt; null then		// and global.isValidObject(self.toDoTaskDesc) then
		toDoDesc := toDoTaskDesc;
	else
		toDoDesc := app.myRoot.allToDoTaskDescriptions[self.toDoTaskDescCode];
	endif;
	
	if toDoDesc = null then
		_value := null;
		return;
	endif;
	
	trxType := toDoDesc.getTrxTypeOnCreation();
	if trxType &lt;&gt; null then
		_value := trxType.class.name;
	endif;
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
