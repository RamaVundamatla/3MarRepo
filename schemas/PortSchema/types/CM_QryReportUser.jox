// ---------------------------------------------------------------------------
// Created:     03 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_heading, _classNameToCreate, _pictureButton, _pictureButtonDown, _pictureIcon, _schemaName, _windowClassName, _permissionValue, _isSystemDetail);


end;</source>
        <Parameter name="_heading" type="String"/>
