			&lt;expiryDate/&gt;
			&lt;packDate/&gt;
			&lt;receiveDate/&gt;
			&lt;transitOnPowerDate/&gt;
			&lt;cargoWeight/&gt;
			&lt;height/&gt;
			&lt;length/&gt;
			&lt;overHeight/&gt;
			&lt;overLengthBack/&gt;
			&lt;overLengthFront/&gt;
			&lt;overWidthLeft/&gt;
			&lt;overWidthRight/&gt;
			&lt;tareWeight/&gt;
			&lt;timeAllowedOffPower/&gt;
			&lt;vent/&gt;
			&lt;volume/&gt;
			&lt;weight&gt;40000&lt;/weight&gt;
			&lt;width/&gt;
			&lt;availabilityGrade/&gt;
			&lt;carbonDioxide/&gt;
			&lt;coolingType/&gt;
