    <JadeMethod name="comboBoxROROVoyageJobs" id="56d9d0ca-dda5-4451-8667-0940e121c837">
        <source>comboBoxROROVoyageJobs(_cmb : CMUI_ComboBox input; _voyage : CM_Voyage);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 December 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	iter : Iterator;
	job  	: CM_VoyageJob;
begin
	_cmb.clear;
	
	if _voyage = null then
		return;
	endif;
	
	iter:=_voyage.allVoyageJobs.createIterator;
	
	while iter.next(job) do
		if job.isKindOf(CM_VoyageDeckJob) then
			_cmb.addItemObject( job.id,job); 
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="comboBoxROROVoyageStructure" id="9fefe7ad-f63d-45d5-8bc1-c2f08fd7f5ed">
        <source>comboBoxROROVoyageStructure(_cmb : CMUI_ComboBox input;
							_selectedROROVoyageStruct : CM_ROROVoyageStructure;
							_terminal : CM_Terminal );
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	tmpTerm : CM_Terminal;
	roroVoyageStructure : CM_ROROVoyageStructure;
	iter 		: Iterator;
	voyage		: CM_Voyage;
	failedDAC  :CM_DataAccessController;
begin
	_cmb.clear;
	
	tmpTerm := _terminal;

	
	iter:=tmpTerm.allVoyagesByCode.createIterator;
	while iter.next(voyage) do
	
		roroVoyageStructure:=voyage.myROROStructure;
		
		if roroVoyageStructure = null then
			continue;
		endif;
		
		if voyage.isCancelled then  //jlier1 TFS51963 5/10/21
			continue;
		endif;
		
		if not voyage.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		
	
		_cmb.addItemObject( voyage.code.trimBlanks &amp; " " &amp; voyage.vesselName.trimBlanks,roroVoyageStructure); 
		
	endwhile;
	
	
	if _selectedROROVoyageStruct &lt;&gt; null then
		_cmb.listIndex:=_cmb.findObject(_selectedROROVoyageStruct);
	endif;


epilog
	delete iter;

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_selectedROROVoyageStruct" type="CM_ROROVoyageStructure"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
