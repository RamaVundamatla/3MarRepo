    <JadeMethod name="getObjects" id="9f596be7-6f99-481c-8270-967b424adaaf">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores

*/

vars
	stevedore : CM_Stevedore;
begin
	foreach stevedore in app.myRoot.allStevedores do
		objects[stevedore.getYAIdentifier] := stevedore;
	endforeach;
epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
