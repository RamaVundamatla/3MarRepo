    <JadeMethod name="makeMessage_M7" id="10e46abc-f646-49b9-ba66-bd6a57b921d1">
        <source>makeMessage_M7(_protocol :CM_CamProtocol ; _sealNumber, _entityCode : String ): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwrd1	Initial creation

Seal Number (M7)1

Seal Number				M701	&lt;Seal Number&gt;
Seal Number				M702 
Seal Number				M703
Seal Number				M704
Entity Identifier Code	M705	CA/CM/SH 

Notes
1There can be up to 3 records, one for Operator, Customs and Shipper 
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time

constants
	MESSAGE	= "M7";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	//colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
			plus &amp; _sealNumber &amp;
			plus &amp; 
			plus &amp;
			plus &amp;
			plus &amp; _entityCode &amp;
			singleQuote;

		return msg;
epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_sealNumber" type="String"/>
        <Parameter name="_entityCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_N1" id="fffb1972-0f63-4c0d-bfa8-d8be72ba3134">
        <source>makeMessage_N1(_protocol :CM_CamProtocol ; _entityIdentifierCode, _entityName, _identificationCodeQual,_identificationCode : String): String;

/*

Purpose: Name N1 segment			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2014	cnwrd1	Initial creation
08 Jan 2015	cnwrs1	Par 35493 remove trailing segment delimiters

Name (N1)  (&lt;=4)

Entity Identifier Code			N101	MC/CN/SH/FW6
Name							N102	Name of above7
Identification Code Qualifier	N103	94
Identification Code				N104	SFL
Entity Relationship Code		N104	 
Entity Identifier Code			N106
 
Notes
MC= Carrier, CN=Consignor, SH=Shipper, FW=Freight Forwarder
Translated if available
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	MESSAGE	= "N1";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
			plus &amp; _entityIdentifierCode &amp; 
			plus &amp; _entityName &amp; 
			plus &amp; _identificationCodeQual &amp; 
			plus &amp; _identificationCode &amp; 
//			plus &amp; //entity relationship code
//			plus &amp; //entity identifier code
			singleQuote;
			
	return msg;

epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_entityIdentifierCode" type="String"/>
        <Parameter name="_entityName" type="String"/>
        <Parameter name="_identificationCodeQual" type="String"/>
        <Parameter name="_identificationCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_N7" id="48154fb6-e636-4089-9c13-3178e216b4d2">
        <source>makeMessage_N7( _protocol :CM_CamProtocol ;_containerPrefix, _containerNumeric, _grossWeight, _weightQualifier, _tareWeight, _eqipDescCode, _carrierAlphaCode, _containerCheckDigit, _isoType, _equipmentLength: String): String;

/*

Purpose:	N7 Equipment Details		

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwrd1	Initial creation
//11 Jan 2018	jlgrs1	TFS 2299 add VGM Details to X12 322

Equipment Initial			N701	Prefix of Container
Equipment Number			N702	Numeric Cargo ID (length 6)
Weight						N703	Gross Weight
Weight Qualifier			N704	G
Tare Weight					N705	Tare Weight if present, else Weight for ISO Type
Weight Allowance 			N706		 
Dunnage						N707
Volume						N708
Volume Unit Qualifier		N709
Ownership Code				N710
Equipment Description Code	N711	CN
Standard Carrier Alpha Code	N712	SEFU
Temperature Control			N713
Position 					N714
Equipment Length			N715
Tare Qualifier Code			N716
Weight Unit Code			N717	K/L
Equipment Number Check DigitN718	Container ID Check Digit
Type of Service Code		N719	HH 
Height 						N720
Width 						N721
Equipment Type				N722	ISO Type
Standard Carrier Alpha Code	N723	SEFU
Car Type Code				N724
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time

constants
	MESSAGE	= "N7";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	//colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	
	/*
8	Equipment Length	N0	4/5	O	export from system	N7-15 *
9	Tare Qualifier Code	ID	1/1	O	export from system	N7-16 *

13	Height	R	1/8	O	export from system	N7-20 *


*/

	msg := MESSAGE &amp; 
			plus &amp; _containerPrefix &amp;			//01
			plus &amp; _containerNumeric &amp; 			//02
			plus &amp; _grossWeight &amp; 				//03
			plus &amp; _weightQualifier &amp;	//'G' &amp; 						//04
			plus &amp; _tareWeight &amp; 				//05
			plus &amp; //weight allowance			//06
			plus &amp;  //dunnage					//07
			plus &amp;  //volume					//08
			plus &amp;  //volume unit qualifier		//09
			plus &amp;  //ownership code			//10
			plus &amp; _eqipDescCode &amp; 				//11
			plus &amp; _carrierAlphaCode &amp; 			//12
			plus &amp;  //temperature control		//13
			plus &amp;  //position					//14
			plus &amp;  _equipmentLength &amp; 			//15
			plus &amp;  'A' &amp;						//16
			plus &amp; 'K' &amp; //weight unit code		//17
			plus &amp; _containerCheckDigit &amp; 		//18
			plus &amp;  'HH' &amp;  //type of service	//19
			plus &amp; //height						//20
			plus &amp; //width						//21
			plus &amp; _isoType &amp; 					//22
			plus &amp; _carrierAlphaCode &amp; 			//23
			plus &amp;  //car type code				//24
			singleQuote;
			
	return msg;

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_containerPrefix" type="String"/>
        <Parameter name="_containerNumeric" type="String"/>
        <Parameter name="_grossWeight" type="String"/>
        <Parameter name="_weightQualifier" type="String"/>
        <Parameter name="_tareWeight" type="String"/>
        <Parameter name="_eqipDescCode" type="String"/>
        <Parameter name="_carrierAlphaCode" type="String"/>
        <Parameter name="_containerCheckDigit" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_equipmentLength" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_N9" id="7d9607e1-6a37-45fa-95c2-3aa6793ad557">
        <source>makeMessage_N9(_protocol :CM_CamProtocol ; _identCode, _identNumber : String): String;


/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2014	cnwrd1	Initial creation

Reference Identification (N9)

Reference Identification Code		N901	BM/BN
Reference Identification			N902	BOL/Booking Number 
Free-form Description				N903
Date								N904
Time								N905
Time Code							N906
Reference Identifier				N907

*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time

constants
	MESSAGE	= "N9";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
			plus &amp; _identCode &amp; 
			plus &amp; _identNumber &amp;
			plus &amp; //free form desc
			plus &amp; //date
			plus &amp; //time
			plus &amp; //time code
			plus &amp; //reference identifier
			singleQuote;
			
	return msg;

epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_identCode" type="String"/>
        <Parameter name="_identNumber" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_NA" id="d7c667c5-21c2-4386-a8b2-d9ab09db968b">
        <source>makeMessage_NA(_protocol :CM_CamProtocol ; _equipInitial, _equipNumber,_equipDesc : String): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 January 2015	cnwrd1	Initial creation

NA Cross-Reference Equipment							
							
Name	Type	Min/max	REQ	Content			
Equipment Initial	AN	1/4	M	export from system	NA-03		
Equipment Number	AN	1/15	M	export from system	NA-04		
Equipment Description Code	ID	1/1	O	export from system	NA-05	SMLU	NA***NKCR*1253*F~ ­
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time

constants
	MESSAGE	= "NA";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
			plus &amp; 		
			plus &amp; 
			plus &amp; _equipInitial &amp; 
			plus &amp; _equipNumber &amp;
			plus &amp; _equipDesc &amp;
			singleQuote;
			
	return msg;

epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_equipInitial" type="String"/>
        <Parameter name="_equipNumber" type="String"/>
        <Parameter name="_equipDesc" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_Q5" id="75b7e4f4-0888-4522-b58a-71eb0b7d8af8">
        <source>makeMessage_Q5(_protocol :CM_CamProtocol ;_shipStatusCode : String; _tranDate : Date; _tranTime : Time; _timeCode : String) : String;

/*

Purpose:	Status Details Q5 segment		

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwrd1	Initial creation
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time



constants
	MESSAGE	= "Q5";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	//colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
			plus &amp; _shipStatusCode &amp; // Shipment Status Code
			plus &amp; _tranDate.formatAsYYYYMMDD &amp; //Transaction Date YYYYMMDD
			plus &amp; _tranTime.shortFormatEDI &amp; //Transaction Time HHMMSS
			plus &amp; _timeCode &amp; //Time Code
			plus &amp; //Status Reason Code
			plus &amp; //City Name
			plus &amp; //State or Province Code
			plus &amp; //Country Code
			plus &amp; //Equipment Initial
			plus &amp; //Equipment Number
			plus &amp; //Reference Identification Qualifier
			plus &amp; //Reference Identification 
			plus &amp; //Direction Identifier Code
			plus &amp; //Reference Identification Qualifier
			plus &amp; //Reference identification
			plus &amp; //Direction Identifier Code
			plus &amp; //Percent
			plus &amp; //Pick-up or Delivery Code
			singleQuote;

			
	return msg;
	
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_shipStatusCode" type="String"/>
        <Parameter name="_tranDate" type="Date"/>
        <Parameter name="_tranTime" type="Time"/>
        <Parameter name="_timeCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_R4" id="e1d7269d-70dc-4b8c-89f2-879daed49bd6">
        <source>makeMessage_R4(_protocol :CM_CamProtocol ; _portFunctCode , _portLocQual , _portCode, _portName: String): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwrd1	Initial creation

Port or Terminal (R4)

Port or Terminal Function Code	R401	D/L
Location Qualifier				R402	K/D/UN5
Location Identifier				R403	PortCode
Port Name						R404	Port Name
Country Code					R405
Terminal name					R406
Pier Number						R407
State or Province Code			R408
 
Notes
5There must be a port object in Master Terminal associated with the Port. By default Schedule K/D codes and names will be used. If not UN/LOCODES will be used if available.
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time

constants
	MESSAGE	= "R4";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
			plus &amp; _portFunctCode &amp; 
			plus &amp; _portLocQual &amp; 
			plus &amp; _portCode &amp; 
			plus &amp; _portName &amp; 
			plus &amp; //country code 
			plus &amp; //termina name
			plus &amp; //pier number
			plus &amp; //state province
			singleQuote;
			
	return msg;

epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_portFunctCode" type="String"/>
        <Parameter name="_portLocQual" type="String"/>
        <Parameter name="_portCode" type="String"/>
        <Parameter name="_portName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_V1" id="4f7c6313-0fd5-4de4-8583-ba05b2736602">
        <source>makeMessage_V1(_protocol :CM_CamProtocol ; _lloydsNumber , _vesselName, _translatedVoyageCode,_carrierCode : String): String;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2014	cnwrd1	Initial creation for par 34693

Vessel Identification (V1)

Vessel Code						V101	Lloyds Number
Vessel Name						V102	Vessel Name3
Country Code					V103
Flight/Voyage Number			V104	SF Voyage Code4
Standard Carrier Alpha Code		V105
Vessel requirement Code			V106
Vessel Type Code				V107
Vessel Code Qualifier			V108
Transportation method/Type Code	V109	L

Notes
3Vessel is translated if possible
4Voyage code is translated if possible

*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time


constants
	MESSAGE	= "V1";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	//colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
			plus &amp; _lloydsNumber &amp; 
			plus &amp; _vesselName &amp;
			plus &amp; //country code
			plus &amp;  _translatedVoyageCode&amp;
			plus &amp; _carrierCode &amp; //standard carrier alpha code
			plus &amp; //vessel requirement code
			plus &amp; //vessel type code
			plus &amp; 'L' &amp; //vessel code qualifier
			plus  &amp; //transport method
			singleQuote;
	
	return msg;

epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_lloydsNumber" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_translatedVoyageCode" type="String"/>
        <Parameter name="_carrierCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_V4" id="3f31ff5d-eaea-4a5c-bbe6-2fac62548cde">
        <source>makeMessage_V4(_protocol :CM_CamProtocol ; _stowageLoc : String): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2015	cnwrd1	Initial creation
V4 Cargo location reference
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 18 May 2018	jlgmd1	TFS 38657 Truncate location to a maximum of 12 characters
constants
	MESSAGE	= "V4";
vars
	msg	:String;
	stowageLoc :String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	stowageLoc	:= _stowageLoc[1:12];

	msg := MESSAGE &amp; 
			plus &amp; stowageLoc &amp; 
			singleQuote;
	
	return msg;

epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_stowageLoc" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_W09" id="ee9eafbf-77d8-4c9d-8652-1d925ec670bf">
        <source>makeMessage_W09(_protocol :CM_CamProtocol; _equipCode , _lowTemp, _highTemp, _unitType, _message, _ventSetting, _humidity, _quantity : String ): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2014	cnwrd1	Initial creation

W09 - Equipment and Temperature
Equipment Description Code			W0901
Temperature (setting)				W0902
Unit of measurement					W0903
Temperature (reading)				W0904
Unit of measurement					W0905
Free Form Message					W0906
Vent Setting Code					W0907
Percent (humidity)					W0908
Quantity (cu air exchange)			W0909
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	MESSAGE	= "W09";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin

	plus		:= _protocol.elementSeparator;
	//colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
				plus &amp; _equipCode &amp; //Equipment Description Code			W0901
				plus &amp; _lowTemp &amp; //Temperature (setting)				W0902
				plus &amp; _unitType &amp; //Unit of measurement					W0903
				plus &amp; _highTemp &amp; //Temperature (reading)				W0904
				plus &amp; _unitType &amp; //Unit of measurement					W0905
				plus &amp; _message &amp;//Free Form Message					W0906
				plus &amp; _ventSetting &amp; //Vent Setting Code					W0907
				plus &amp; _humidity &amp; //Percent (humidity)					W0908
				plus &amp; _quantity &amp;//Quantity (cu air exchange)			W0909
				singleQuote;
			
			
	return msg;
epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
