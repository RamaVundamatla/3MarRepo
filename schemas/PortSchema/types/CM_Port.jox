    <JadeMethod name="hasSameCountryAs" id="e962193b-489a-404a-ac4e-7011c7fee0ca">
        <source>hasSameCountryAs(_port: CM_Port): Boolean;
//----------------------------------------------------------------
//	Created:	12 January 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _port = null then
		return false;
	endif;
	
	if _port.myCountry = null then
		//don't want to match to nulls
		return false;
	endif;
	
	return (self.myCountry = _port.myCountry);
	
end;</source>
        <Parameter name="_port" type="CM_Port"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
