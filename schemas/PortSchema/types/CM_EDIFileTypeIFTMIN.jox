    <JadeMethod name="findEDIDataType" id="382d0c95-c1e1-4a64-bbd4-6bd9122eef23">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
23 April 2009		cnwrl1	Initial creation as part of PAR 19510 - CCMS 1812

*/
	
vars
	
begin
	_ediDataClass	:= CM_EDIDataPrenote;
	_dataType		:= EDIDataType_Prenote;
	_fileTypeCode	:= self.type;
	
end;
</source>
