    <JadeMethod name="export" id="81f86086-6a65-41c0-aa77-52357531a3dd">
        <updating/>
        <source>export(_invoice: CM_Invoice input) updating;
// take 2 for Oracle financial 11 Apr 2013
// 27 Oct 2016	cnwrs1	TFS allow this directory to be assigned %MiscDir% insrtead of D:\qnsPjmt\server\c_misc
vars
	file 	: File;
	path 	: String;
	fileName	: String;
	fFolder : FileFolder;
	terminal : CM_Terminal;
	message : String;
begin
	// 32853 Jan 2014 don't export default debtor
	if _invoice.debtor.isRDT() then
		return;
	endif;
	terminal := _invoice.myTerminal; 	 // 18/11/2016 cnwma1 TFS #2986
	
	if app.isJMTUnitTest then	
		path := self.exportPath.normaliseDirectory().substituteDirectory();
	else
		path := self.exportPath.normaliseDirectory().substituteDirectory();
		path := path &amp; terminal.code &amp;"\";  // 18/11/2016 cnwma1 TFS #2986
	endif;
	

	create fFolder;
	fFolder.fileName := path;
	// all files and directories are on the app server
	// except from unit test
	if not app.isJMTUnitTest then	
		fFolder.usePresentationFileSystem := false;
	endif;
	if not fFolder.isAvailable() then
		if not process.isInTransactionState then
			
/*	WAS	 TFS 6949
			app.msgBox("The export path of '" &amp; path &amp; "' does not exist. Cannot export invoice " &amp; _invoice.sequenceNum.String &amp; "." &amp; Cr
					&amp; "See Export Path settings in Invoice Configuration","Export Error",
				MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			NOW	*/
				
			message := app.getErrorString2(Expor_path_does_not_exist_cann,path,_invoice.sequenceNum.String);
			app.msgBox(message,app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);

			return;
		else		// from 33862 testing, was no feedback of an invalid export path
		/* WAS TFS 6949
			app.raiseCMException2(ERR_STATUS_CHANGE, _invoice.sequenceNum.String, "The export path of '" &amp; path &amp; "' does not exist. Cannot export invoice. See Export Path settings in Invoice System Defaults.",null, null);		return;
			NOW */
			app.raiseCMException3(Error_statu_chang_invoi_not_al, _invoice.sequenceNum.String, path,_invoice.sequenceNum.String,null, null);		
			return;
			
			
		endif;
	endif;
	
	fileName := path &amp; "ar_invoice_" &amp; _invoice.sequenceNum.padLeadingWith('0', 6) &amp; ".csv";

	create file;
	file.fileName := fileName;
	file.mode := File.Mode_Output;
	file.allowReplace := true;
	// the file must be written to the app server so it can be automatically loaded into Oracle
	// except from unit test
	if not app.isJMTUnitTest then	
		file.usePresentationFileSystem := false;
	endif;

	self.exportToFileCSV(_invoice, file);
	
	// 37141 Feb 2016 export any associated cash receipt
	if _invoice.myCashReceipt &lt;&gt; null then
		self.exportReceipt(_invoice.myCashReceipt);
	endif;

epilog
	delete fFolder;
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close();
		endif;
		delete file;
	endif;
end;

</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportCredit" id="7816631f-c00c-4fb0-afd9-5f7844f8dbbc">
        <source>exportCredit(_credit: CM_CashCredit input);
// Feb 2016 TFS 985 export a cash credit separately
// 27 Oct 2016	cnwrs1	TFS allow this directory to be assigned %MiscDir% insrtead of D:\qnsPjmt\server\c_misc
// 18/11/2016   TFS #2986:PAR38432 QNS - Changes to existing Oracle R12 Interface for Hamad port multi terminal go-live (SQL Loader changes)
vars
	file 	: File;
	path 	: String;
	fileName	: String;
	fFolder : FileFolder;
	debtor	: CM_Debtor;
	terminal : CM_Terminal;
	message : String;
	
begin
	// matching test on invoices, don't export default debtor
	debtor := _credit.getDebtor();
	if debtor = null or
	   debtor.isRDT() then
		return;
	endif;

	terminal := _credit.getDebtorTerminal().myTerminal; 															// 18/11/2016 cnwma1 TFS #2986

	path := self.exportPath.normaliseDirectory().substituteDirectory();
	path := path &amp; terminal.code &amp;"\";  // 18/11/2016 cnwma1 TFS #2986

	create fFolder;
	fFolder.fileName := path;
	// all files and directories are on the app server
	// except from unit test and special for testing
	if not app.isJMTUnitTest and
	   not app.isSpecial() then	
		fFolder.usePresentationFileSystem := false;
	endif;
	if not fFolder.isAvailable then
		if not process.isInTransactionState then
		
		/* WAS TFS 6949
			app.msgBox("The export path of '" &amp; path &amp; "' does not exist. Cannot export credit " &amp; _credit.externalId &amp; "." &amp; Cr
					&amp; "See Export Path settings in Invoice System Defaults.","Export Error",
				MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				NOW */
			message := app.getErrorString2(Expor_path_does_not_exist_cred,path,_credit.externalId.String);
			app.msgBox(message,app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				
			return;
		else
		/* WAS TFS 6949
			app.raiseCMException2(ERR_STATUS_CHANGE, _credit.externalId, "The export path of '" &amp; path &amp; "' does not exist. Cannot export credit. See Export Path settings in Invoice System Defaults.",null, null);		return;
			NOW */
			app.raiseCMException3(Error_statu_chang_invoi_not_cr, _credit.externalId.String, path,_credit.externalId.String,null, null);		
			
			
		endif;
	endif;
	
	fileName := path &amp; "ar_credit_" &amp; _credit.getExportSequence().padLeadingWith('0', 6) &amp; ".csv";

	create file;
	file.fileName := fileName;
	file.mode := File.Mode_Output;
	file.allowReplace := true;
	// the file must be written to the app server so it can be automatically loaded into Oracle
	// except from unit test
	if not app.isJMTUnitTest then	
		file.usePresentationFileSystem := false;
	endif;

	self.exportCreditToFileCSV(_credit, file);

epilog
	delete fFolder;
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close();
		endif;
		delete file;
	endif;

end;
</source>
        <Parameter name="_credit" type="CM_CashCredit" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportCreditToFile" id="b09d529f-709d-47dd-a563-f218322a5c7d">
        <source>exportCreditToFile(_credit: CM_CashCredit input; _fileNameBase: String);
// Feb 2016 TFS 985 export a cash credit separately
// 17 Aprirl 2018	jlgrh7 TFS #37879
vars
	file : File;
	debtor	: CM_Debtor;
begin
	// don't export if default debtor to match invoice processing
	debtor := _credit.getDebtor();
	if debtor = null or
	   debtor.isRDT() then
		return;
	endif;

	create file;
	file.allowReplace := true;
	file.fileName := _fileNameBase; 
	file.mode := File.Mode_Output;
	// the file must be written to the app server so it can be automatically loaded into Oracle
	//  unless testing
	/*if not app.isSpecial() then													//-TFS37879
		file.usePresentationFileSystem := false;
	endif;*/
	file.usePresentationFileSystem :=true;							//+TFS37879
	
	self.exportCreditToFileCSV(_credit, file);
epilog
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close();
		endif;
		delete file;
	endif;

end;
</source>
        <Parameter name="_credit" type="CM_CashCredit" usage="input"/>
        <Parameter name="_fileNameBase" type="String"/>
    </JadeMethod>
    <JadeMethod name="exportCreditToFileCSV" id="b94550d0-5c82-4333-9d18-2d1ac9e19aec">
        <source>exportCreditToFileCSV(_credit: CM_CashCredit input; _file : File input) protected;
// Feb 2016 TFS 985
// 18/11/2016   TFS #2986:PAR38432 QNS - Changes to existing Oracle R12 Interface for Hamad port multi terminal go-live (SQL Loader changes)
vars
//	totalAmount : Decimal[16,2];
	debtor		: CM_Debtor;
	fileEx		: FileException;
	terminal 	: CM_Terminal;
	totalAmount : Decimal[20,2];	//11 May 2018	NDL	TFS 38528
begin
	on FileException do self.fileExceptionHandler(fileEx);

	debtor := _credit.getDebtor();
	if debtor = null then
		return;
	endif;
	totalAmount := _credit.cashValue;

	self.writeCreditHeaderToFile(_file, _credit);
	self.writeCreditLinesToFile(_file, _credit, totalAmount);

	if process.isInTransactionState then 	// true for export called from invoice post
		_credit.exportedCount := _credit.exportedCount + 1;
	else
		app.myTrxUA.trxIncrementCreditExportCount(_credit, app.myPassport);
	endif;
	terminal :=_credit.myDebtorTerminal.myTerminal;			 // 18/11/2016 cnwma1 TFS #2986
	self.runLoader(_file.fileName,terminal);				 // 18/11/2016 cnwma1 TFS #2986
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_credit" type="CM_CashCredit" usage="input"/>
        <Parameter name="_file" type="File" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportReceipt" id="7f4bf42a-f2f0-406e-b655-049f59c91d08">
        <source>exportReceipt(_receipt: CM_CashReceipt input);
// Feb 2016 TFS 985 export a cash receipt separately
// 27 Oct 2016	cnwrs1	TFS allow this directory to be assigned %MiscDir% insrtead of D:\qnsPjmt\server\c_misc
vars
	file 	: File;
	path 	: String;
	fileName	: String;
	fFolder : FileFolder;
	debtor	: CM_Debtor;
	terminal : CM_Terminal;
	message : String;
begin
	// matching test on invoices, don't export default debtor
	debtor := _receipt.getDebtor();
	if debtor = null or
	   debtor.isRDT() then
		return;
	endif;
	
	terminal := _receipt.getBank.getMyTerminal; 															// 16/11/2016 cnwma1 TFS #2985

	path := self.exportPath.normaliseDirectory().substituteDirectory();
	path := path &amp; terminal.code &amp;"\"; 															// 16/11/2016 cnwma1 TFS #2985
	
	create fFolder;
	fFolder.fileName := path;
	// all files and directories are on the app server
	// except from unit test and special for testing
	if not app.isJMTUnitTest and
	   not app.isSpecial() then	
		fFolder.usePresentationFileSystem := false;
	endif;
	if not fFolder.isAvailable then
		if not process.isInTransactionState then
		/* WAS TFS 6949
			app.msgBox("The export path of '" &amp; path &amp; "' does not exist. Cannot export receipt " &amp; _receipt.getExternalInvoiceNumber() &amp; "." &amp; Cr
					&amp; "See Export Path settings in Invoice System Defaults.","Export Error",
				MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				NOW */
			message := app.getErrorString2(Expor_path_does_not_exist_rec,path,_receipt.getExternalInvoiceNumber() );
			app.msgBox(message,app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				
				
			return;
		else
		/* WAS TFS 6949
			app.raiseCMException2(ERR_STATUS_CHANGE, _receipt.getExternalInvoiceNumber(), "The export path of '" &amp; path &amp; "' does not exist. Cannot export receipt. See Export Path settings in Invoice System Defaults.",null, null);		return;
			NOW */
			app.raiseCMException3(Error_statu_chang_invoi_not_re, _receipt.getExternalInvoiceNumber(), path,_receipt.getExternalInvoiceNumber(),null, null);		
			return;
			
			
		endif;
	endif;
	
	fileName := path &amp; "ar_receipt_" &amp; _receipt.getExportSequence().padLeadingWith('0', 6) &amp; ".csv";

	create file;
	file.fileName := fileName;
	file.mode := File.Mode_Output;
	file.allowReplace := true;
	// the file must be written to the app server so it can be automatically loaded into Oracle
	// except from unit test
	if not app.isJMTUnitTest then	
		file.usePresentationFileSystem := false;
	endif;

	self.exportReceiptToFileCSV(_receipt, file);

epilog
	delete fFolder;
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close();
		endif;
		delete file;
	endif;
end;

</source>
        <Parameter name="_receipt" type="CM_CashReceipt" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportReceiptToFile" id="42e68304-8cd5-4408-9d87-9d1887edd0d7">
        <source>exportReceiptToFile(_receipt: CM_CashReceipt input; _fileNameBase: String);
// Feb 2016 TFS 985 export a cash receipt separately
// 17 Aprirl 2018	jlgrh7 TFS #37879
vars
	file : File;
	debtor	: CM_Debtor;
begin
	// don't export if default debtor to match invoice processing
	debtor := _receipt.getDebtor();
	if debtor = null or
	   debtor.isRDT() then
		return;
	endif;

	create file;
	file.allowReplace := true;
	file.fileName := _fileNameBase; 
	file.mode := File.Mode_Output;
	// the file must be written to the app server so it can be automatically loaded into Oracle
	//  unless testing
	/*if not app.isSpecial() then																				//-TFS37879
		file.usePresentationFileSystem := false;
	endif;*/
	file.usePresentationFileSystem := true;														//+TFS37879

	self.exportReceiptToFileCSV(_receipt, file);
epilog
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close();
		endif;
		delete file;
