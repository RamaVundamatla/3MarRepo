<Class name="JSSDate" id="ca3d5271-7a24-477e-b364-f3d572be81b2">
    <superclass name="JSSPrimitiveValue"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
