    <JadeMethod name="uObjectCount" id="669cf1e7-d573-42db-8af0-0db65c46cb7c">
        <source>uObjectCount();

vars
	schemas: SchemaColl;
	schema: Schema;
	classes: ClassSet;
	classColl: ClassColl;
	klass: Class;
	
	jmtClassCount: Integer;
	numberOfObjects: Integer64;
begin
	create schemas transient;
	create classes transient;
	rootSchema.allSubschemas(schemas);
	foreach schema in schemas do
		classColl := schema.allClasses();
		foreach klass in classColl do
			if not classes.includes(klass) and not klass.isSystemObject then
				classes.add(klass);
				if klass.anyInstance then
					numberOfObjects := numberOfObjects + klass.instances.size;
				endif;
				jmtClassCount := jmtClassCount + 1;
			endif;
		endforeach;
		delete classColl;
	endforeach;
	self.logMessage("Number of Schemas: "&amp; schemas.size.String);
	self.logMessage("Number of JMT Classes: "&amp; jmtClassCount.String);
	self.logMessage("Numberof Objects: " &amp; numberOfObjects.String);
epilog
   delete schemas;
   delete classes;
end;</source>
    </JadeMethod>
    <JadeMethod name="uOwnerTests" id="ebee2553-97fe-48d1-aacb-5fb85ff3a786">
        <source>uOwnerTests();
//21 December 2010	cnwdw1	
//
vars
	controller: JMTTestController;
	allTests: MethodSet;
	test: Method;
	result: UT_TestResult;
	owner: String;
begin
	owner := "owner";
	read owner;
	if owner.trimBlanks = null then
		return;
	endif;

	create controller transient;
	create allTests transient;
	
	controller.getAllTests(allTests);
	
	write "Tests owned by " &amp; owner;
	foreach test in allTests do
		create result transient;
		result.construct(test, false, false, null, null, null,null,null, null);
		if result.getOwnerName.toUpper = owner.toUpper then
			write test.qualifiedName;
		endif;	
		delete result;
	endforeach;
epilog
	delete controller;
	delete allTests;
	delete result;
end;</source>
    </JadeMethod>
    <JadeMethod name="uPerformgetCurrentVoyages" id="5f045973-f3b2-4e2d-8d49-16b854c189cf">
        <source>uPerformgetCurrentVoyages();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2021	navndl1	Initial creation	TFS 

*/

vars

	theVoyages : CM_VoyageSet;

	gracePeriod : Integer;
	checkDT  	: TimeStamp;
	aVoyage		: CM_Voyage;
	thePassport : CM_Passport;
	iter		: Iterator;
	failedDAC   : CM_DataAccessController;
	now			: TimeStamp;
	startTS : TimeStamp;
	endTS : TimeStamp;
	interval : TimeStampInterval;
	count : Integer;

begin

	thePassport := app.myPassport;
	create theVoyages transient;
	
	gracePeriod := self.getTerminal.getConfig(VoyDepartedGracePeriod).Integer;
	if gracePeriod = null then
		gracePeriod := 24;
	endif;
	
	checkDT := app.actualTimeServer();
	checkDT := checkDT.changeByXXHours(-gracePeriod);	
	now := app.actualTimeServer;														
	iter := self.getTerminal.allVoyagesByCode.createIterator();
	
	
	
	startTS := app.actualTimeAppServer;
	while iter.next(aVoyage) do
		count := count + 1; 
		if ((not true) and aVoyage.isNullVoyage()) or 
		not aVoyage.canUserAccessSelf(null, failedDAC, thePassport) then	
			continue;
		endif;
		//epr tfs 51963 5/10/21
		if aVoyage.isCancelled or aVoyage.status = Voyage_Status_Closed then 
			continue;
		endif;					

		if not true and aVoyage.isHOLDSorSHIP() then
			continue;
		endif;
		
		if aVoyage.isATARequired then                                                      
			if not aVoyage.arrivedDT.isValid then
				continue;
			endif;
		endif;
		
		if aVoyage.isActiveDisplay(checkDT) then		
			theVoyages.add(aVoyage);
		endif;		
				
	endwhile;	
	endTS := app.actualTimeAppServer;
	interval := endTS - startTS;
	write "Original = " &amp; interval.getMilliseconds.String &amp; ", found " &amp; theVoyages.size.String &amp; ", read " &amp; count.String;
	
	delete iter;
	iter := self.getTerminal.allVoyagesByCode.createIterator();
	theVoyages.clear;
	count := 0;
	
	
	startTS := app.actualTimeAppServer;
	while iter.next(aVoyage) do
		count := count + 1;
		
		if aVoyage.status = Voyage_Status_Cancelled or aVoyage.status = Voyage_Status_Closed then 
			continue;
		endif;					

		if not true and aVoyage.isHOLDSorSHIP() then
			continue;
		endif; 
		
		if aVoyage.isATARequired then                                                      
			if not aVoyage.arrivedDT.isValid then
				continue;
			endif;
		endif; 
		
		if not aVoyage.isActiveDisplay(checkDT) then		
			continue;
		endif; 
		if not aVoyage.canUserAccessSelf(null, failedDAC, thePassport) then	
			continue;
		endif; 
		
		if ((not true) and aVoyage.isNullVoyage()) then
			continue;
		endif;  
		
		theVoyages.add(aVoyage);
				
	endwhile;	
	endTS := app.actualTimeAppServer;
	interval := endTS - startTS;
	write "Test one = " &amp; interval.getMilliseconds.String &amp; ", found " &amp; theVoyages.size.String &amp; ", read " &amp; count.String;
	
epilog

	delete iter;
	delete theVoyages;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="uPostInvoicesForTerminals" id="ea8259d4-c20c-4106-9b93-2a9faf7ce9d5">
        <updating/>
        <source>uPostInvoicesForTerminals() updating;

/*

Purpose:		Post Invoices for terminals based on the selected details from the form

Date			Who		Reason
14/02/2014		cnwmh5	Initial creation

*/

vars

	terminal						: CM_Terminal;
	form							: UT_InvoiceDeleteForm;
	
	startTS							: TimeStamp;
	endTS							: TimeStamp;
	result 							: Boolean;

begin

	create self.terminalArray transient;

	create form transient;
	form.utdsl := self;
	form.showModal;
	
	// cancelled from form
	if form.wasCancelled then
		delete self.terminalArray;
		return;
	endif;	
	
	startTS := null;
	startTS.setDate(form.txtStartDate.text.Date);
	endTS := null;
	endTS.setDate(form.txtEndDate.text.Date);
	endTS.setTime("23:59:59".Time);
		
	self.opts.purge();
	self.opts.addAssoc("TerminalArray", self.terminalArray);
	self.opts.addAssoc("StartDate", startTS.String);
	self.opts.addAssoc("EndDate", endTS.String);
	result := self.postInvoices();
	self.assertEqual(result, true);	
	
epilog

	delete form;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uRebuildCollection" id="ddea5342-8d60-4a50-a38f-f8916fff3d7a">
