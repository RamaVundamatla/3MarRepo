    <JadeMethod name="rel822_par33885" id="ba8ca19d-9179-4885-8ef3-7344c0a46ee8">
        <source>rel822_par33885();

/*

Purpose:			Attach existing CM_CashPayments to their associated CM_CashReceipt
					This method is re-runnable, it will only add the payments if they are not already included.
Parameters:			

Return Value:		


Date		Who		Reason
17 April 2014	cnwjre1	Initial creation

*/

vars
	transAgent : CM_TranslationAgent;
	tmpArray : StringArray;

	paymentList	: CM_CashPaymentDict;
	paymentDict	: CM_CashPaymentDict;
	cashReceipt	: CM_CashReceipt;
	tiPayment	: CM_CashPayment;
	ti			: CM_TrackedItem;
	first		: Boolean;

begin
	app.initialize();
	//create tmpArray transient;
	//create transAgent transient;
	//tmpArray.add('Cash_cargo_not_paid');
	//transAgent.trxLoadSpecificErrors(tmpArray);

	create paymentList transient;
	beginTransaction;
	foreach cashReceipt in CM_CashReceipt.instances do
		first := true;
		paymentList.clear();
		foreach ti in cashReceipt.allTrackedItems do
			foreach tiPayment in ti.allCashPayments do
				if not paymentList.includes(tiPayment) then
					paymentList.add(tiPayment);
				endif;
			endforeach;
		endforeach;

		paymentDict := cashReceipt.getAllCashPayments();
		foreach tiPayment in paymentList do
			if first then
				if paymentDict = null then
					create paymentDict persistent;
				endif;
				first := false;
			endif;
			
			if not paymentDict.includes(tiPayment) then
				paymentDict.add(tiPayment);
			endif;
			tiPayment.setCashReceipt(cashReceipt);
		endforeach;
		if not first then
			cashReceipt.setAllCashPayments(paymentDict);
		endif;
		
	endforeach;
	commitTransaction;
	
	return;
	//write Cash_cargo_not_paid;
epilog
	delete paymentList;
	delete tmpArray;
	delete transAgent;

end;</source>
    </JadeMethod>
