    <JadeMethod name="translateForm" id="e16a93c7-95ff-46a7-997f-1140b00f6de1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015882, locale);
	btnCancel.translateCaption(Xlat_0015883, locale);
	btnClear.translateBubbleHelp(Xlat_0015884, locale);
	btnClear.translateCaption(Xlat_0015885, locale);
	btnGenDate.translateBubbleHelp(Xlat_0015886, locale);
	btnGenDate.translateCaption(Xlat_0015887, locale);
	btnProcess.translateBubbleHelp(Xlat_0015888, locale);
	btnProcess.translateCaption(Xlat_0015889, locale);
	btnProxyApply.translateCaption(Xlat_0015890, locale);
	btnProxyCancel.translateCaption(Xlat_0015891, locale);
	btnRemDate.translateBubbleHelp(Xlat_0015892, locale);
	btnRemDate.translateCaption(Xlat_0015893, locale);
	btnUpdDate.translateBubbleHelp(Xlat_0015894, locale);
	btnUpdDate.translateCaption(Xlat_0015895, locale);
	lblChoose.translateCaption(Xlat_0015896, locale);
	lblDateFrom.translateCaption(Xlat_0015897, locale);
	lblDateTo.translateCaption(Xlat_0015898, locale);
	lblDayType.translateCaption(Xlat_0015899, locale);
	lblProxyDate.translateCaption(Xlat_0015900, locale);
	lblProxyDesc.translateCaption(Xlat_0015901, locale);
	lblProxyEnd.translateCaption(Xlat_0015902, locale);
	lblProxyStart.translateCaption(Xlat_0015903, locale);
	lblSave.translateCaption(Xlat_0015904, locale);
	lblStartTime.translateCaption(Xlat_0015905, locale);
	lblUserPref.translateCaption(Xlat_0015906, locale);
	lblUsing.translateCaption(Xlat_0015907, locale);
	optDay.translateCaption(Xlat_0015908, locale);
	optMonth.translateCaption(Xlat_0015909, locale);
	optYear.translateCaption(Xlat_0015910, locale);
end;</source>
    </JadeMethod>
