    <JadeMethod name="translateForm" id="e4a91723-f3b8-41b5-880f-6824490605ee">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:50:41.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006374, locale);
	btn40BaySlots40.translateBubbleHelp(Xlat_0002579, locale);
	btn40BaySlots40.translateCaption(Xlat_0002593, locale);
	btnBayApplyBay.translateBubbleHelp(Xlat_0002619, locale);
	btnBayApplyBay.translateCaption(Xlat_0002634, locale);
	btnBayCancelbay.translateBubbleHelp(Xlat_0002581, locale);
	btnBayCancelbay.translateCaption(Xlat_0002595, locale);
	btnBayCopy.translateBubbleHelp(Xlat_0002723, locale);
	btnBayCopy.translateCaption(Xlat_0002725, locale);
	btnBayCopyClose.translateCaption(Xlat_0002597, locale);
	btnBayCopySave.translateCaption(Xlat_0002635, locale);
	btnBayEditBay.translateBubbleHelp(Xlat_0002745, locale);
	btnBayEditBay.translateCaption(Xlat_0002752, locale);
	btnBayNewBay.translateBubbleHelp(Xlat_0002662, locale);
	btnBayNewBay.translateCaption(Xlat_0002668, locale);
	btnBayPrintBay.translateBubbleHelp(Xlat_0002621, locale);
	btnBayPrintBay.translateCaption(Xlat_0002637, locale);
	btnBayRemoveBay.translateBubbleHelp(Xlat_0002584, locale);
	btnBayRemoveBay.translateCaption(Xlat_0002599, locale);
	btnBaySeqBay.translateBubbleHelp(Xlat_0002664, locale);
	btnBaySeqBay.translateCaption(Xlat_0002670, locale);
	btnBaySeqBay40.translateBubbleHelp(Xlat_0002622, locale);
	btnBaySeqBay40.translateCaption(Xlat_0002638, locale);
	btnBayTempBay.translateBubbleHelp(Xlat_0002746, locale);
	btnBayTempBay.translateCaption(Xlat_0002755, locale);
	btnColLegendClos.translateCaption(Xlat_0002536, locale);
