	self.btnRemoveDtl.enabled := false;
	self.btnAddShow.enabled:= false;
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyDetailObjects" id="0e0fdf1e-b7b2-4f6c-802b-7d507fb2c885">
        <source>setProxyDetailObjects() : Boolean;
// ---------------------------------------------------------------------------
// Created:     08 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tblDetail 	: CM_DataTable;
	reqdQuantity, row		: Integer;
	classToCreate	: Class;
	goToRow			: String;
	orderLine		: CM_StockOrderLine;
	ti : CM_TrackedItem;
	product : CM_Product;
	tmpDeleteSet	: ObjectSet;
	tmpObj		: Object;
	
begin

	tblDetail	:= self.tblDataDetail;
	
	create tmpDeleteSet transient;
	self.allDetailObjects.copy(tmpDeleteSet);

	foreach row in tblDetail.fixedRows + 1 to tblDetail.rows do 
		orderLine := tblDetail.accessRow(row).itemObject.CM_StockOrderLine;		
		
		if tmpDeleteSet.includes(orderLine) then
			tmpDeleteSet.remove(orderLine);
		endif;

		if orderLine.isKindOf(CM_StockOrderTILine) then
			ti := self.getTblDataDetailTI(row);
		 	orderLine.CM_StockOrderTILine.setProxy(ti);
		 	
		elseif	orderLine.isKindOf(CM_StockOrderProductLine) then 
			product := self.getTblDataDetailProduct(row);
			reqdQuantity := self.getTblDataDetailQuantity(row);

			orderLine.CM_StockOrderProductLine.setProxyForOrderLine(product,reqdQuantity, null, null, null, null, null, null);
		elseif orderLine = null then 
			// is new line added in an edit 
			if (not self.createPrxyOrderLineFrmTableRow(row)) then
				return false;
			endif;
		endif;		
	endforeach;
	
	foreach tmpObj in tmpDeleteSet do
		if self.allDetailObjects.includes(tmpObj) then
			self.allDetailObjects.remove(tmpObj);
		endif;
	endforeach;
	
	tmpDeleteSet.purge();

	return true;

epilog
	delete tmpDeleteSet;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPxyHeaderFromTbl" id="f1318344-d91b-4b09-961a-51b53113898d">
        <source>setPxyHeaderFromTbl(_stkOrd : CM_StockOrderHeaderGeneric input) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     06 May 2004	cnwth2
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	tbl 				: CM_EntryTable;
	tmpProcessOpt,
	tmpTransMode		: Integer;
	userCode,
	orderNo,
	disPort				: String;
	deadline			: TimeStamp;
	tmpVoyage			: CM_Voyage;
	orderDate			: Date;
	
begin
	tbl := self.tblMasterEnt;
	userCode := app.getMyUser().code;
	if self.cmbProcessOpt.listIndex &gt; 0 then
		tmpProcessOpt := self.cmbProcessOpt.itemData[self.cmbProcessOpt.listIndex];	
	else
		app.msgBox('You must select a process option for the stock order','No process specified', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	if tmpProcessOpt = Process_Direct_Loadout then
		if self.cmbTransportMode.listIndex &gt; 0 then
			tmpTransMode := self.cmbTransportMode.itemData[self.cmbTransportMode.listIndex];	
		else
			app.msgBox('You must specify a transport mode for direct loudout','No transport mode specified', MsgBox_Exclamation_Mark_Icon);
			return false;			
		endif;
		
		if tmpTransMode = TI_TRANSMODE_SHIP then
			tmpVoyage := self.cmbVoyage.listObject.CM_Voyage;
			if tmpVoyage = null then
				app.msgBox('You must specify a voyage for a ship loudout', 'No voyage selected', MsgBox_Exclamation_Mark_Icon);
				return false;	
			endif;
			
			if self.cmbDisPort.listObject &lt;&gt; null then
				disPort := self.cmbDisPort.getCode ();
			endif;
		endif;
	endif;
	
//	deadline.setDate(tbl.getValueByName(ETRow_DeadlineDate).Date);


	deadline.setDate(tbl.getValueAsDate(ETRow_DeadlineDate));
	
	deadline.setTime(tbl.getValueByName(ETRow_DeadlineTime).Time);
	
	//19 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	deadline := self.localToSystemTime(deadline);
	orderDate := app.actualTimeServer.Date;

	_stkOrd.setProxy(self.cmbConsignee.myObject.CM_ConsigneeConsignor,
					self.cmbOperator.myObject.CM_Operator,
					self.myTerminal,
					tmpVoyage,
					orderDate,
					deadline,
					tbl.getValueByName(ETRow_OrderNo).String,
					tmpTransMode,
					disPort,
					StockOrderHeaderType_GC,
					tmpProcessOpt,
					true,
					false,
					null,
					userCode);
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_stkOrd" type="CM_StockOrderHeaderGeneric" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSearchValues" id="ac54817a-bd30-4f0a-9a13-3e353aecdbe5">
        <updating/>
        <source>setSearchValues() updating;

vars

begin
	self.filtOrderNo := self.tblSearch.getValueByName(ETRow_FiltOrderNo).String;
	if self.cmbFiltProcess.listIndex &gt; 0 then
		self.filtProcessOption := self.cmbFiltProcess.itemData[self.cmbFiltProcess.listIndex];
	else
		self.filtProcessOption := null;
	endif;
	
	if self.cmbFiltStatus.listIndex &gt; 0 then
		self.filtFulfillStatus := self.cmbFiltStatus.itemData[self.cmbFiltStatus.listIndex];
	else
		self.filtFulfillStatus := null;
	endif;
	
	self.myFiltOperator := self.cmbFiltOp.myObject.CM_Operator;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setTblDataDetailCells" id="9a523065-b8de-4117-b732-79b58fdafc86">
        <updating/>
        <source>setTblDataDetailCells(_theRow : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	backColour : Integer;
	tmpTable : CM_DataTable;
	intCol		: Integer;
begin

	tmpTable := self.tblDataDetail;

	tmpTable.accessCell(_theRow, self.colLineType).backColor := White;
	
	backColour := self.colorRow1;

//	backColour := tmpTable.accessedRow.backColor;

	tmpTable.accessCell(_theRow, self.colCargoType).backColor := White;
	tmpTable.accessCell(_theRow, self.colProduct).backColor := White;	
	tmpTable.accessCell(_theRow, self.colQuantityId).backColor := White;	
									
	//disable cells that do not need input
	intCol := tmpTable.getColumnByRowName(ETRow_NoFulfilled);
	tmpTable.accessCell(_theRow, intCol).enabled := false;
	tmpTable.accessCell(_theRow, intCol).backColor := backColour;				
	tmpTable.accessRow(_theRow).backColor := backColour;				

end;</source>
        <Parameter name="_theRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setViewForLineType" id="baaf1ae3-7577-4f96-8a3e-82712e6214df">
        <source>setViewForLineType(_lineType : Integer) : EntTableView;
// ---------------------------------------------------------------------------
// Created:     05 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	viewName		: String;
	entView			: EntTableView;
	
begin
	if _lineType = StockOrderLine_Product then
		viewName := 'ProductLine';
	elseif _lineType = StockOrderLine_TI then
		viewName := 'TILine';
	else
		viewName := 'defaultLine';
	endif;
	
	entView := self.tblDetailEnt.myEntTableDef.allEntTableViews[viewName];
	self.tblDetailEnt.showHideRowsByView(entView, CM_EntryTable.ShowHideRows, false);
	self.tblDetailEnt.adjustHeight(300);

	return entView;

end;</source>
        <Parameter name="_lineType" type="Integer"/>
        <ReturnType type="EntTableView"/>
    </JadeMethod>
    <JadeMethod name="setViewForStockOrder" id="a416f01a-58b5-4e57-8696-475a8f0c7a28">
        <source>setViewForStockOrder(_processOpt, _transMode : Integer) : EntTableView;
// ---------------------------------------------------------------------------
// Created:     29 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	viewName		: String;
	entView			: EntTableView;
	
begin
	if self.mode = self.Mode_View then //return a thumb view
		if _processOpt = Process_Direct_Loadout then
			if _transMode = TI_TRANSMODE_ROAD then
				viewName := 'roadThumb';
			elseif _transMode = TI_TRANSMODE_RAIL then
				viewName := 'railThumb';
			elseif _transMode = TI_TRANSMODE_SHIP then
				viewName := 'shipThumb';
			else
				viewName := 'defaultThumb';
			endif;
			
		elseif _processOpt = Process_Pack then
			viewName := 'packThumb';
		else
			viewName := 'defaultThumb';
		endif;
	else //return an entry view
		if _processOpt = Process_Direct_Loadout then
			if _transMode = TI_TRANSMODE_ROAD then
				viewName := 'roadEnt';
			elseif _transMode = TI_TRANSMODE_RAIL then
				viewName := 'railEnt';
			elseif _transMode = TI_TRANSMODE_SHIP then
				viewName := 'shipEnt';
			else
				viewName := 'directEnt';
			endif;
			
		elseif _processOpt = Process_Pack then
			viewName := 'packEnt';
		else
			viewName := 'defaultEnt';
		endif;
	endif;
	
	entView := self.tblMasterEnt.myEntTableDef.allEntTableViews[viewName];
	self.tblMasterEnt.showHideRowsByView(entView, CM_EntryTable.ShowHideRows, false);
	self.tblMasterEnt.adjustHeight(300);

	return entView;

end;</source>
        <Parameter name="_processOpt" type="Integer"/>
        <Parameter name="_transMode" type="Integer"/>
        <ReturnType type="EntTableView"/>
    </JadeMethod>
    <JadeMethod name="settblDtlFocusForNewRow" id="349d9306-735e-4bfd-b0b3-4da7a061dbd4">
        <source>settblDtlFocusForNewRow();
// ---------------------------------------------------------------------------
// Created:     16 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tmpCell : JadeTableCell;
begin

	
	tmpCell := self.tblDataDetail.accessCell(self.tblDataDetail.row,self.colQuantityId);
	tmpCell.selected := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupColumnQtyIdForLineType" id="b77f066e-cce9-4d81-8d14-286f646ee2ec">
        <updating/>
        <source>setupColumnQtyIdForLineType(_lineType, _row : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 October 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tbl				: CM_DataTable;
	tmpCmbProd		: CMUI_ComboProduct;
	txtBox			: CMUI_TextBox;
	newCombo  		: CMUI_ComboBox;
	theRow 			: Integer;
	tmpCell 		: JadeTableCell;
	beforeTxt		: String;
	tmpCargoType	: CM_CargoType;
begin

	tbl	:= self.tblDataDetail;

	if _lineType &lt;= 0 or _row &lt;= tbl.fixedRows or
	   _row &gt; tbl.rows then
		return;
	endif;

	theRow  := _row;
	self.newIndex := self.newIndex + 1;

	if _lineType = StockOrderLine_Product then
		// change control in Quantity /ID to Combo
		txtBox	:= self.addControlTxtQuantity(theRow, newIndex).CMUI_TextBox;
		
	elseif _lineType = StockOrderLine_TI then
		// change control in Quuantity /ID to Text
		newCombo := self.addControlCmbTI(theRow, newIndex).CMUI_ComboBox;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_lineType" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c75bc9ae-7ddd-463f-bad7-adfefb6922ac">
        <updating/>
        <source>setupForm() updating;

vars
	tbl			: CM_DataTable;
begin
	inheritMethod();
	tbl := self.tblDataDetail;
	tbl.multiSelect := self.tblDataDetail.MultiSelect_Simple;
	tbl.tabKey := J_key_Tab;
	
	if tbl.columns &gt; 0 then
		tbl.sortColumn[1] := 1;
		if tbl.columns &gt; 1 then	
			tbl.sortColumn[2] := 2;
			if tbl.columns &gt; 2 then	
				tbl.sortColumn[3] := 3;
			endif;
		endif;
	endif;
	
	self.setViewForStockOrder(null, null);
	self.setColIndexsTblDataDetail();
	self.btnRemoveDtl.enabled := false;
	self.btnAddShow.enabled:= false;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupTblDtlRowForCargoType" id="d859814d-85a6-4083-b27f-179f781c8fd4">
        <updating/>
        <source>setupTblDtlRowForCargoType(_row, _lineType : Integer; _cargoType : CM_CargoType) updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 October 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tbl				: CM_DataTable;
	tmpCmbProd		: CMUI_ComboProduct;
	tmpCmb			: CMUI_ComboBox;
	tmpCell 		: JadeTableCell;

begin

	tbl	:= self.tblDataDetail;

	tmpCell := tbl.accessCell(_row, self.colProduct);
	tmpCmbProd := tmpCell.cellControl.CMUI_ComboProduct;
	
	if tmpCmbProd = null or tmpCmbProd.myCargoType = _cargoType then
		return;
	endif;
	
	tmpCmbProd.clear(); // cargo type has changed so what if anything in hear it is bunk.
	tmpCmbProd.setCargoType(_cargoType);
	
	if _lineType = StockOrderLine_TI then // populate ti combo
		tmpCell := tbl.accessCell(_row,self.colQuantityId);
		tmpCmb := tmpCell.cellControl.CMUI_ComboBox;
		tmpCmb.clear(); // cargo type has changes so what if anything in hear it is bunk.
		self.myAssistant.comboBoxTrackedItemToPack(tmpCmb, _cargoType.id, TI_STATE_NORMAL, null ); 				
	else  // if for Item allocation or linetype has not been selected yet. 
			//do nothing 
	endif;	

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_lineType" type="Integer"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setupTblDtlRowForProduct" id="0ed01b21-80c9-4e96-8295-d44e20e985e7">
        <updating/>
        <source>setupTblDtlRowForProduct(_row : Integer; _product : CM_Product) updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 October 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpLineType	: Integer;
	tmpCell 		: JadeTableCell;
	tmpCmb 		: CMUI_ComboBox;

begin

	tmpLineType := self.getTblDataDetailRowLineType(_row);

	if tmpLineType = StockOrderLine_TI then // populate combo
		tmpCell := self.tblDataDetail.accessCell(_row, self.colQuantityId);
		tmpCmb := tmpCell.cellControl.CMUI_ComboBox;
		tmpCmb.clear(); // cargo type has changed so what if anything in hear it is bunk.
//			tmpCmbItem.myCargoType := tmpCargoType;
		self.myAssistant.comboBoxTIsByProduct(tmpCmb, _product, null); 			
		
		// also populate Items combo with all avail items of this cargo
	else
		// else if line type is for Item or not selected do nothing. 
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="12857fdd-24aa-4c7a-a30c-82290bd8d87d">
        <updating/>
        <source>showThumbnailData(_obj: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:     29 April 2004	cnwth2
//
// Purpose:     
//			 
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	stkOrd				: CM_StockOrderHeaderGeneric;
	entView				: EntTableView;
	entRow				: EntTableRow;
	fulfillStatus,
	processOpt,
	transMode			: Integer;
	masterTbl			: CM_EntryTable;
	detailTbl			: CM_DataTable;
	tmpOperator			: CM_Operator;
	tmpConsign			: CM_ConsigneeConsignor;
	tmpVoyage			: CM_Voyage;
	orderLine			: CM_StockOrderLine;
	localDeadlineDT 	: TimeStamp;
begin
	if not CM_StockOrderHeaderGeneric.hasInstance(_obj) then
		return;
	endif;
	if self.mode = self.Mode_New then	// + dh 12/11/2007 par 15304
		return;							// + dh 12/11/2007 par 15304
	endif;								// + dh 12/11/2007 par 15304
		
	masterTbl := self.tblMasterEnt;
	detailTbl := self.tblDataDetail;
	stkOrd := _obj.CM_StockOrderHeaderGeneric;
	processOpt := stkOrd.processOption;
	transMode := stkOrd.transportMode;
	entView := self.setViewForStockOrder(processOpt, transMode);
	
	foreach entRow in entView.allEntTableRows do
		masterTbl.setValueByName(entRow.name, stkOrd.getDisplayStringForAttribute(entRow.name, false));
	endforeach;
	
	//row values have been set, not set the combobox listObjects
	if stkOrd.myOperator &lt;&gt; null then 									 // + dh 12/11/2007 par 15304
		tmpOperator := app.myRoot.allOperators[stkOrd.myOperator.code];	
	endif;																// + dh "					
	// HJG CCMS1235 dealt with in combobox class
	self.cmbOperator.setObject(tmpOperator);
//	if tmpOperator &lt;&gt; null and (not tmpOperator.isNotAvailableForEntry) then
//		self.cmbOperator.listObject := tmpOperator;
//	endif;

	
	tmpConsign := app.myRoot.allConsigneeConsignors[stkOrd.consigneeCode];
	if tmpConsign &lt;&gt; null /* and (not tmpConsign.isNotAvailableForEntry)*/ then	// HJG CCMS1235 dealt with in combobox class
//		self.cmbConsignee.listObject := tmpConsign;
		self.cmbConsignee.setObject(tmpConsign);
	else
		self.cmbConsignee.setObject(null);
	endif;

	tmpConsign := app.myRoot.allConsigneeConsignors[stkOrd.consignorCode];
	if tmpConsign &lt;&gt; null /* and (not tmpConsign.isNotAvailableForEntry)*/ then  // HJG CCMS1235 dealt with in combobox class
//		self.cmbConsignor.listObject := tmpConsign;
		self.cmbConsignor.setObject(tmpConsign);
	else
		self.cmbConsignor.setObject(null);
	endif;


	if 	stkOrd.deadlineDT.isValid then 
		localDeadlineDT := self.systemToLocalTime(stkOrd.deadlineDT);
		self.tblMasterEnt.setValueByName(ETRow_DeadlineDate, localDeadlineDT.date);
		self.tblMasterEnt.setValueByName(ETRow_DeadlineTime, localDeadlineDT.time);
	//	self.tblMasterEnt.setValueByName(ETRow_DeadlineDate, stkOrd.deadlineDT.date);
	//	self.tblMasterEnt.setValueByName(ETRow_DeadlineTime, stkOrd.deadlineDT.time);
//		self.txtDeadDate.setDate(stkOrd.deadlineDT.date);
//		self.txtDeadTime.setTime(stkOrd.deadlineDT.time);
	endif;
	
	self.cmbProcessOpt.text := app.processOptionEnumToString(processOpt);
	
	if processOpt = Process_Direct_Loadout then
		self.cmbTransportMode.text := app.transModeToString(stkOrd.transportMode);
	endif;
	
	if stkOrd.transportMode = TI_TRANSMODE_SHIP then
		tmpVoyage := stkOrd.myVoyage;
		if tmpVoyage &lt;&gt; null then
		// ### PAR 10264. is possible that the voyage has departed and so is not in the combo list.
			if self.cmbVoyage.findObject(tmpVoyage) = -1 then 
				self.cmbVoyage.addItemObject(tmpVoyage.code,tmpVoyage);
			endif;
			self.cmbVoyage.listObject := tmpVoyage;
		endif;		
	endif;

	detailTbl := self.tblDataDetail;
	foreach orderLine in stkOrd.allStockOrderLines do
		self.addObjectToDetailTable(orderLine);
	endforeach;
	
	self.tblDataDetail.colourRows(self.colorRow1, self.colorRow1);
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7bde3d35-7de5-4c60-9811-7e76a272b16a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005814, locale);
	mnuInspectObject.translateCaption(Xlat_0005815, locale);
	mnuTblDataContext.translateCaption(Xlat_0005816, locale);
end;</source>
    </JadeMethod>
