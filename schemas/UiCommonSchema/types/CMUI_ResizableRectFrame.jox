    <JadeMethod name="resizeByPoints" id="6107309a-c52a-4ff7-ab36-8afaa7bc4f99">
        <updating/>
        <source>resizeByPoints(_x1, _y1, _x2, _y2 : Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/02/2009	cnwjk3	Initial creation
17/11/2011	cnwdap1	PAR #28514 Set my 'changed' attribute (because I've just changed by being resized)
*/
vars

begin
	// Hiding before moving stops an ugly shimmer
	self.visible := false;
	self.move(_x1, _y1, _x2-_x1, _y2-_y1);
	self.changed := true;						// PAR #28514
	self.visible := true;
epilog

end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setAdjustedLeft" id="0cb56107-df1e-42d2-9979-23cd5120fbde">
        <updating/>
        <source>setAdjustedLeft(_value : Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 October 2009	cnwer1	Initial creation

*/

vars

	machWorkzone : CMIF_MachineWorkzone;
begin
	
	if 	self.userObject.isKindOf(CMIF_MachineWorkzone) then
		machWorkzone:=self.userObject.CMIF_MachineWorkzone;
		if machWorkzone.rotated90  then
			self.top:=_value;
		else
			self.left:=_value;
		endif;
	else
		self.left:=_value;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Real"/>
    </JadeMethod>
