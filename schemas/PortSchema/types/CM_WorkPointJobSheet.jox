    </JadeMethod>
    <JadeMethod name="validateForDelete" id="ae65c760-7579-4427-b112-54ccfcbe5f55">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2023	navhl20	ChangeRequest 57766:[57767] EUP - Delivery Dispatch – Define Job Sheet
25 Jun 2023 navma1  ChangeRequest 58589[58595]: EUP | LMS Gang API - Endpoint
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	job 	: CM_Job;
	invalid : Boolean;
	
begin
	
	on Exception do app.handleDeletedObject(exception, job, invalid);
	foreach job in self.allJobsByPriorityRequiredDT  discreteLock do			//25.02.2025 navma1 #MTN-34075
		
		invalid := false;
		
		job.edition;
		
		if invalid then
			continue;
		endif;
  		
		if job.status &lt;&gt;JOB_UNACTIONED then 
			app.raiseCMException1(ERR_Delete_WP_JobSheet,self.externalName,null,self);
			break;
		endif;
 	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForJob" id="249cbcdb-7309-4239-a87d-2d7cfa6a9bf3">
        <source>validateForJob(_job : CM_Job);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
12 Feb 2024 navnk30 ChangeRequest 62420: EUP | Retrospective Operations - [54177.020] - Allocate Road Jobs
26 Sep 2024 navhl20	ChangeRequest 14712: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective) - 1
*/

vars

begin
	
	if _job = null then
		return;
	endif;
	
	if not _job.requiredByDT.isValid() then
		app.raiseCMException(Invalid_required_date, null, self);
	endif;
	

epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="9509ef2e-d9bf-4814-879f-e2417436a82a">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2023	navhl20	ChangeRequest 57766:[57767] EUP - Delivery Dispatch – Define Job Sheet
23 May 2023 navhl20	Defect 58115: MTN - 1090 exception when editing the work point job sheet
13 June 2023 navhl20 Defect 58611: MTN - 1090 Exception when defining a job sheet without entering Shift
*/

vars
	jobSheet,
	realMe,
	jobSheetOld		: CM_WorkPointJobSheet;
begin
	if self.myWorkPoint = null then
		app.raiseCMException(Input_required_field_workPoint, ETRow_WorkPoint, self);
	endif;
	
	if self.externalName = null then															//13.6.2023 navhl20 #58611
		app.raiseCMException(Input_requir_extern_name_field, ETRow_Name, self);
	endif;
	
	if self.myShift = null then																	//13.6.2023 navhl20 #58611
		app.raiseCMException(Input_require_shift_field, ETRow_Shift, self);
	endif;
	
	realMe := self.pxyGetRealObject();															//23.5.2023 navhl20 #58115
	
	foreach jobSheet in self.myTerminal.allJobSheetsForWorkPoints do							//23.5.2023 navhl20 #58115
		if jobSheet.externalName = self.externalName then
			jobSheetOld :=  jobSheet;
		endif;
	endforeach;
	if jobSheetOld &lt;&gt; null // might be changing the contract id value							//23.5.2023 navhl20 #58115
	and  jobSheetOld &lt;&gt; realMe then
		if self.externalName &lt;&gt; null then
			foreach jobSheet in self.myTerminal.allJobSheetsForWorkPoints do
				if jobSheet.externalName = self.externalName then
					app.raiseCMException(Exter_name_shoul_uniqu_work_po, null, self);
				endif;
			endforeach;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
