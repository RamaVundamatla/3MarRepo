    <JadeMethod name="tblData_click" id="08c9d471-8990-44de-8ce9-6c5eaa0fcf38">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_click(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2009	cnwndl1	Initial creation

*/

vars

	field : CM_XTABField;
	
begin

	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;

	field := self.tblData.accessRow(self.tblData.row).itemObject.CM_XTABField;
	
	if field = null then
		return;
	endif;
	
	self.btnAttrRem.enabled := true;

epilog

end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b0af7abb-2f20-47de-9571-f0679cb4c88b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017458, locale);
	btnAttrAdd.translateCaption(Xlat_0013492, locale);
	btnAttrRem.translateCaption(Xlat_0013493, locale);
	btnCancel.translateCaption(Xlat_0013494, locale);
	btnSSDefNew.translateCaption(Xlat_0013495, locale);
	btnSSDefRem.translateCaption(Xlat_0013496, locale);
	btnSave.translateCaption(Xlat_0013497, locale);
	btnSelector.translateBubbleHelp(Xlat_0016171, locale);
	btnSelector.translateCaption(Xlat_0016172, locale);
	btnTask.translateBubbleHelp(Xlat_0016173, locale);
	btnTask.translateCaption(Xlat_0016174, locale);
	grpData.translateCaption(Xlat_0013498, locale);
	lblAttribute.translateCaption(Xlat_0013499, locale);
	lblBank.translateCaption(Xlat_0016175, locale);
	lblDescription.translateCaption(Xlat_0013500, locale);
	lblFunction.translateCaption(Xlat_0013501, locale);
	lblLabel.translateCaption(Xlat_0013502, locale);
	lblMode.translateCaption(Xlat_0013503, locale);
	lblName.translateCaption(Xlat_0013504, locale);
	lblSSDef.translateCaption(Xlat_0013505, locale);
	lblSelector.translateCaption(Xlat_0016176, locale);
	lblStatus.translateCaption(Xlat_0013506, locale);
end;</source>
    </JadeMethod>
