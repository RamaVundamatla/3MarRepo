    <JadeMethod name="appendXmlTag" id="b5ace8f7-f2fb-4b33-a0e9-8f1068b13ddd">
        <updating/>
        <source>appendXmlTag(_tagName: String; _value: String) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

vars

