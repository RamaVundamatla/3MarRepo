    <JadeMethod name="checkOnShip" id="89119add-b722-4906-a698-37be8306ebb5">
        <source>checkOnShip() : Boolean;
//--------------------------------------------------------------
//Created: 22 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	voyCntrl : CM_LogVoyageController;
	ls			: Boolean;

begin

	app.cmsBeginLoad(ls);
	foreach voyCntrl in self.allLogVoyageLocations do
		sharedLock(voyCntrl);
		if voyCntrl.hasTIs then
			return true;
		endif;
	endforeach;
	
	return false;

epilog
	app.cmsEndLoad(ls);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erase" id="22d00887-63dd-4d71-8859-53f124407062">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//--------------------------------------------------------------
//Created: 24 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpLot		: CM_LogLot;
	allocation 	: CM_StockOrderAllocation;
begin
	
	if self.allStockAllocations.size &gt; 0 then
		foreach allocation in self.allStockAllocations do
			allocation.erase(NORMAL_ERASE);
		endforeach;
	endif;
	
	if self.myStockOrderSummary &lt;&gt; null then
		if self.myStockOrderSummary.allStockOrderLines.size &lt;= 1 then
			self.myStockOrderSummary.erase(NORMAL_ERASE);
		else
			self.myStockOrderSummary := null;
		endif;
	endif;
	
	if self.myLogLot &lt;&gt; null then
		exclusiveLock(self.myLogLot);		
		tmpLot := self.myLogLot;
		// Null myLogLot first to remove inverse
		self.myLogLot := null;
		if tmpLot.checkCanBeDelete then
			tmpLot.erase(NORMAL_ERASE);
		endif;
	endif;

	if self.myStockOrderHeader.allStockOrderLines.size &lt;= 1 then
		// Header will erase me as well because I'm a child of header
		self.myStockOrderHeader.erase(NORMAL_ERASE);
	else
		inheritMethod(_eraseLevel);
	endif;

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
