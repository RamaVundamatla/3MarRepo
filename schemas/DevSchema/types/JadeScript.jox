    <JadeMethod name="jlgsh3CheckContainerState" id="f8ed9f52-9204-4898-9eac-a09ff69ecd9d">
        <source>jlgsh3CheckContainerState();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2018	jlgsh3	Initial creation

*/

vars
	c : CM_Container;
	int : Integer;
	edi : Integer;
begin
	foreach c in CM_Container.instances do
	
	if c.state &lt;&gt; TI_STATE_UNDEFINED and //0
		c.state &lt;&gt; TI_STATE_NORMAL and //1
		c.state &lt;&gt; TI_STATE_ONSHIP and//5
		c.state &lt;&gt; TI_STATE_TBA and//8
		c.state &lt;&gt; TI_STATE_OFFSITE then //4
			if c.state = 7 then
				edi := edi + 1;
			else
				write c.id &amp; ' is state ' &amp; c.state.String;
				int := int + 1;
			endif;
			
		if int &gt; 100 then
			break;
		endif;
	endif;
	endforeach;
epilog
 write edi.String;
 
 
end;</source>
    </JadeMethod>
