    <JadeMethod name="validateMoveTo" id="a66d4a59-124b-4b19-8533-6fe1a7827103">
        <source>validateMoveTo(control: CMIF_MoveController input);
/*
 ------------------------------------------------------------------------
Created:			29 November 2001 by cnwdwq1
Purpose:			We DONT support planning mode to vehicles
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
12 Sep 2024 	navma1			Bug 66073: SNO - Code :83948. When trying to change Vehicle registration
10/10/2025		navcs2	MTN-36214 Unable to Add Cargo to the Cargo Released section which is received onsite
---------------------------------------------------------------------------
*/
vars
	allowMoreCargoButton : Boolean;
	dummyString 		 : String;
	ti					 : CM_TrackedItem;
	term				 : CM_Terminal;
begin

	if control.isForcedMove then
		return;
	endif;
	
	//cnwrd1 ccms 2257 some validation here for vehicles! par 30819
	ti  		:= control.myTrackedItem;		//12.09.2024 navma1 #66073
	term		:= ti.myTerminal;				//12.09.2024 navma1 #66073
	
	if ti.directDelivery then
	else
		if control.moveMode = REAL_MODE  then	
			//epr par 35349 19/12/14 always do check that there is a road job
			// it was only doing it for onsite which allowed lander to discharge to offsite truck
			//epr par 34107 20/5/14 //28/4/16 tfs 1842 added if not is truck receive reload 
			if not ti.isKindOf(CM_TILC)and not control.isTruckReceiveReLoad() then
				//doing a reversal back onto the truck
				
				if not self.vehicle.hasIncompleteRoadJobs then
					//JLIER1 MTN-34143 11/4/25 
					if not ( term.getConfig( HhTUnloadEdit ).Boolean or term.getConfig( WebShowCompletedTrucks ).Boolean) then	
						app.raiseCMException(Err_Gate_VehicleNoJob, null,null);
					endif;
				endif;
				
				if  ti.isOnSite then
			
					//if not self.vehicle.hasIncompleteRelease then
					if not self.vehicle.hasIncompleteRelease and not term.roadProcessIsASPA and not control.moveContext = CMIF_MoveController.CONTEXT_UPDATED_VEHICLEVISIT then  // 10/10/2025 navcs2	MTN-36214	(Check if the context for the move is returning to side to avoid errors)
						allowMoreCargoButton := term.getConfig(AllowLoadMoreCargo).Boolean;	//04 Dec 2015	NDL	Par 36866
						if allowMoreCargoButton then
							app.raiseCMWarning1(Canno_place_cargo_vehic_incom_, self.vehicle.code, null, null, null);
						else
							app.raiseCMException1(Canno_place_cargo_vehic_incom_, self.vehicle.code, null, null);
						endif;
					endif;
					// TFS 3972 added warning
					ti.hasUnactionedDocumentActions(true,true,dummyString);	//28 Nov 2016	NDL	TFS 2967 - Raise a warning if TI being loaded has outstanding 'Document Actions'
					
					// ### TFS CR 60424 TASK 60549 02OCT2023 NAVAB1
					/*
					12.09.2024 navma1 #66073
					if control.myWorkListEntry &lt;&gt; null	and not control.myWorkListEntry.isReleaseByTypeBulkRelease() then
					// do not do						control.myTrackedItem.validateCustDocTransportMove(control, app.myPassport);
					endif;
					*/
				endif;
			endif;
		endif;
	endif;

	inheritMethod(control);
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
