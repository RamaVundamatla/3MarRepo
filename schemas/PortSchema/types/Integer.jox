    <JadeMethod name="leftBitShift" id="34174f64-8a06-4d40-bb30-b7857ec96606">
        <source>leftBitShift(n : Integer) : Integer;

/*
----------   ----------  --------------------------------------------------
Created:	 24 Feb 2020 By jlgmd1

Purpose:	This method converts an integer into binary then does a left shift of n bits.
			(aka, appending 'zero's to the binary value [a logical shift])
			Returns an integer value representing the shifted binary number.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/

vars
	bin : String;
	count : Integer;
begin
	// exit early
	if n = 0 then
		return self;
	endif;

	// convert to binary
	bin := self.asBinaryNumber();
	
	// append 'n' number of zeros
	foreach count in 1 to n do
		bin := bin &amp; "0";
	endforeach;
	
	return bin.binaryAsInteger();
	
epilog

end;</source>
        <Parameter name="n" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="minusNotAllowed" id="0c6d5113-4abf-4593-af58-ec6a2473826b">
        <source>minusNotAllowed(_zeroOK : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	
	if self &lt; 0 then
		return "0";
	else
		if (_zeroOK and self = 0) or self &gt; 0 then
			return self.String;
		else
			return "0";
		endif;
	endif;
end;</source>
        <Parameter name="_zeroOK" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="minutesTohhhhmm" id="c22f679c-9591-4ae8-b3eb-8bbf3d90683b">
        <source>minutesTohhhhmm():String;
// --------------------------------------------------------------------------------
// Created:		15 September 2006 by cnwdad1
//
// Purpose:		Converts a number of minutes into a string formated as hhhh:mm.
//
// Parameters:	None
//
// Returns:		The formated minutes as a string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	SEPARATOR		: Character = ":";
	
vars
	hours			: Integer;
	minutes			: Integer;
	totalMinutes	: Integer;
	returnString	: String;
	
begin
	totalMinutes	:=	self;
	
	if totalMinutes &lt;= CNEC_MINUTES_IN_HOUR then
		hours	:=	0;
		minutes	:=	self;
	else
		hours	:=	self div CNEC_MINUTES_IN_HOUR;
		minutes	:=	self - (hours * CNEC_MINUTES_IN_HOUR);
	endif;
	
	returnString	:=	hours.padLeadingWith("0", 4) &amp; SEPARATOR &amp; minutes.padLeadingWith("0", 2);
//	returnString	:=	hours.String &amp; SEPARATOR &amp; minutes.String;
	
	return returnString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="newInverseColour" id="b4959d80-ef44-432b-a707-b2bb91d476db">
        <source>newInverseColour() : Integer;
// ---------------------------------------------------------------------------
// Created:		August  2003 By Dave Quennell cnwdwq1
//
// Purpose:		Returns opposite of the RGB back colour passed in. Used for Text on backgrounds.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpRed : Integer;
	tmpGreen : Integer;
	tmpBlue : Integer;
	tmpColour : Integer;
begin
   tmpColour := self.bitAnd(#FFFFFF);  // remove sign bit if any 
 	tmpRed := tmpColour.bitAnd(#FF);
   tmpGreen := (tmpColour.bitAnd(#100FF00) div #100);
   tmpBlue := (tmpColour.bitAnd (#FF0000) div #10000);
  //get opposite colors
   tmpRed := (255 - tmpRed).abs;
   tmpBlue := (255 - tmpBlue).abs;
   tmpGreen := (255 - tmpGreen).abs;
	tmpColour := app.convertRGBToColor(tmpRed, tmpGreen, tmpBlue);
	return tmpColour;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="padPrefixZeros" id="acf619f6-6b8e-451c-8e1e-3db41ae7ead9">
        <source>padPrefixZeros(len : Integer) : String;
/*
Purpose:			

Date		Who		Reason
26JAN2023	NAVAB1	CR 55624 TASK 55700 
*/

vars
   	new:String;

begin

	new := self.String;

	while new.length &lt; len do
		new := '0' &amp; new;
	endwhile;

 	return new; 
 	
end;</source>
        <Parameter name="len" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="padTrailingZeros" id="22b23c3f-8221-4f1c-b962-42ac88592bca">
        <source>padTrailingZeros(len : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     15 December 2000 by cnwrs2
//
// Purpose:     turns an integer into a string with as many trailing zeros as required.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
   	new:String;

begin

	new := self.String;

	while new.length &lt; len do
		new := new &amp; '0';
	endwhile;

 	return new; 
 	
end;</source>
        <Parameter name="len" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="positive" id="f7918cc7-4f74-4f74-9278-ec990c78b51e">
        <source>positive() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	27 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self &lt; 0 then
		return 0 - self;
	else
		return self;
	endif;

end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="rightBitShift" id="f3b3c676-36dc-47e5-81be-37d16f3083c6">
        <source>rightBitShift(n : Integer) : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	09 May 2007 By cnwmo1

Purpose:	This method convert an integer into binary then does a right shift of one bit.
			Returns an integer value representing the shifted binary number.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	length : Integer;
	shift : String;
begin
			shift := self.asBinaryNumber.String;
			length := shift.length-1;
			shift := shift[n:length];
			return shift.binaryAsInteger();	
end;
</source>
        <Parameter name="n" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="spltAsDaysHoursMinutes" id="6a8e48d9-df60-451d-ad39-d8ff6bcb87ad">
        <source>spltAsDaysHoursMinutes(_days, _hours, _minutes : Integer output);
// ---------------------------------------------------------------------------
// Created:     18 October 2006 by cnwrs2
//
// Purpose:     self = minutes
//				returns number of days, hours, mins that make up self
// ---------------------------------------------------------------------------
vars
	hoursleft : Integer;

begin
		// set code here
	_days := self div (24 * 60);
	hoursleft := self mod (24 * 60);
	_hours := hoursleft div 60;
	_minutes := hoursleft mod 60;
end;</source>
        <Parameter name="_days" type="Integer" usage="output"/>
        <Parameter name="_hours" type="Integer" usage="output"/>
        <Parameter name="_minutes" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="stringWithLeadingZeros" id="008d02f6-2805-47d3-aa5b-4ea267a7a327">
