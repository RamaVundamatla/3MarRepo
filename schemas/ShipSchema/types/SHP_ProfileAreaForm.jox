    <JadeMethod name="tblWPOpHrs_contextMenu" id="cb5c7c50-6d36-4be4-8288-4fad4097958b">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWPOpHrs_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	row	: Integer;
	obj : Object;
	
begin

	self.doTurnOffContextMenus();
	
	row := table.row;
	
	if row &gt; table.fixedRows then
		obj := table.accessRow(row).itemObject;
		if obj &lt;&gt; null then
			self.mnuWPOpHrsEdit.userObject := obj;
			self.mnuWPOpHrsEdit.visible := obj.isKindOf(CM_WorkPointOperatingHours);
			if app.isAllowedToInspect() then
				self.mnuInspectObject.userObject := obj;
				self.mnuInspectObject.visible := true;
			endif;
			return self.showContextMenu(mnuGridAreaContext, table, conwin, mouse, x, y);
		endif;
	endif;
	
	return false;
	
end;</source>
