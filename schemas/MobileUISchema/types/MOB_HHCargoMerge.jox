    <JadeMethod name="btnSelect_click" id="315d96e4-c146-490a-bfc3-e1d74e301d44">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSelect_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2014	cnwndl1	Initial creation

*/

vars

	index : Integer;

begin

	
	
	if self.tblProspects.rows &gt; self.tblProspects.fixedRows then
		foreach index in self.tblProspects.fixedRows + 1 to self.tblProspects.rows do
			if self.tblProspects.accessRow(index).selected then
				if self.tblProspects.accessCell(index, 1).text = "1" then
					self.tblProspects.accessCell(index, 1).text := "0";
					self.btnSelect.caption := "+";
				else
					self.tblProspects.accessCell(index, 1).text := "1";
					self.btnSelect.caption := "-";
				endif;
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayProspects" id="f549139e-5430-4529-9b18-42160cede7fa">
        <source>displayProspects();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	allTis : CM_TIArray;
	ti : CM_TrackedItem;
	startObject : Object;
	cargoType : Integer;
	operator : CM_Operator;
	location : CM_LocationsController;
	index : Integer;
	msg : String;
	strArray : StringArray;
	cellData : String;
	numLines : Integer;
	word : String;
	cellDataLine : String;
	jadeTablecell : JadeTableCell;
	cellWidth : Integer;
	desc : String;
	measureType : CM_MeasurementType;

begin

	self.tblProspects.rows := 1;
	self.tblProspects.accessColumn(1).visible := true;
	if self.myTrackedItem = null then
		self.lblSelectCargo.caption := null;
		return;
	endif;
	
	if self.myTrackedItem.isBulkByQuantity then
		desc := self.myTrackedItem.totalQuantity.String;
	elseif self.myTrackedItem.isBulkByWeight then
		measureType := self.myTrackedItem.myCargoType.getMeasurementTypeFor(Type_Weight, true);
		desc := app.convertMeasurementForDisplay(measureType.shortName, self.myTrackedItem.totalWeight) &amp; " " &amp; measureType.shortName;
	elseif self.myTrackedItem.isBulkByVolume then
		measureType := self.myTrackedItem.myCargoType.getMeasurementTypeFor(Type_Volume, true);
		desc := app.convertMeasurementForDisplay(measureType.shortName, self.myTrackedItem.totalVolume) &amp; " " &amp; measureType.shortName;
	endif;
	
	self.lblSelectCargo.caption := app.getErrorString(Select_cargo_merge_into) &amp; " " &amp; self.myTrackedItem.id
					&amp; "(" &amp; desc &amp; ")";
					
	
	create allTis transient;

	if self.myTrackedItem &lt;&gt; null
	and self.myTrackedItem.myCargoType &lt;&gt; null
	and self.myTrackedItem.myCargoType.allowDuplicates
	then

		cargoType := self.myTrackedItem.cargoType;
		operator := self.myTrackedItem.myOperator;
		location := self.myTrackedItem.myPrimaryActualLocation;
		startObject := self.myMobileGenericAgent.myTerminal.allOnsiteTIsByCargoTypeId.getAtKeyGeq( cargoType,null);
		
		if startObject &lt;&gt; null then
			iter := self.myMobileGenericAgent.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
			iter.startAtObject( startObject );
			while iter.next( ti ) do
				if ti.cargoType &lt;&gt; cargoType then
					break;
				endif;
				if ti = self.myTrackedItem then
					continue;
				endif;
				if ti.myOperator &lt;&gt; operator then
					continue;
				endif;
				if ti.myPrimaryActualLocation &lt;&gt; location then
					continue;
				endif;
				if ti.totalQuantity &lt; 1 then
					continue;
				endif;
				if ti.totalWeight &lt; 1 then
					continue;
				endif;
				allTis.add(ti);
			endwhile;
		endif;
	
	endif;
	
	if allTis.isEmpty then
		numLines := 1;
		self.tblProspects.accessColumn(1).visible := false;
		self.tblProspects.addItem( Tab &amp; " " );
		jadeTablecell := self.tblProspects.accessCell(2,2);
		jadeTablecell.wordWrap := true;
		cellWidth := jadeTablecell.getCellWidth() - 2;
		msg := app.getErrorString1(No_Match_break_bulk_for_merge, self.myTrackedItem.id);
		create strArray transient;
		msg.getTokensForDelimiter( " ", strArray );
		foreach index in 1 to strArray.size do
			word := strArray[index];
			if self.getTextExtent(cellDataLine &amp; " " &amp; word) &lt; cellWidth then
				if cellDataLine = null then
					cellDataLine := word;
				else
					cellDataLine := cellDataLine &amp; " " &amp; word;
				endif;
			else
				if cellData = null then
					cellData := cellDataLine;
				else
					cellData := cellData &amp; CrLf &amp; cellDataLine;
				endif;
				numLines := numLines + 1;
				cellDataLine := word;
			endif;
		endforeach;
		if cellDataLine &lt;&gt; null then
			if cellData = null then
				cellData := cellDataLine;
			else
				cellData := cellData &amp; CrLf &amp; cellDataLine;
			endif;
			numLines := numLines + 1;
		endif;
		jadeTablecell.text := cellData;
		//self.tblTargets.setCellText(2,2,cellData);
		self.tblProspects.accessRow(2).height := ( self.tblProspects.accessRow(1).height * numLines );
		
	else
		foreach ti in allTis do
			desc := null;
			if ti.isBulkByQuantity then
			//	desc := self.myTrackedItem.totalQuantity.String;
				desc := ti.totalQuantity.String;	//31 Mar 2016	NDL Par 37729
			elseif ti.isBulkByWeight then
				measureType := ti.myCargoType.getMeasurementTypeFor(Type_Weight, true);
				desc := app.convertMeasurementForDisplay(measureType.shortName, ti.totalWeight) &amp; " " &amp; measureType.shortName;
			elseif ti.isBulkByVolume then
				measureType := ti.myCargoType.getMeasurementTypeFor(Type_Volume, true);
				desc := app.convertMeasurementForDisplay(measureType.shortName, ti.totalVolume) &amp; " " &amp; measureType.shortName;
			endif;
			index := self.tblProspects.addItem( "0" &amp; Tab &amp; ti.id &amp; "(" &amp; desc &amp; ")" );
			self.tblProspects.accessRow(index).itemObject := ti;
		endforeach;
	endif;
	
	self.tblProspects.cnAdjustColumnWidths();
	
	self.txtFindInList.enabled := not allTis.isEmpty;
	self.btnSelect.enabled := false;
	
epilog

	delete iter;
	delete strArray;

end;</source>
    </JadeMethod>
