        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="3bf492fb-0540-407c-bce7-270c3ad200d1">
        <source>getDisplay():String;
/*

Purpose:			

Parameters:			

Return Value:		

------------------------------------------------------------------------
Date		Who		TFS		Reason
------------------------------------------------------------------------
29 Nov 2016	cnwma1			Initial creation
05 Oct 2022 navma1			Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
*/

vars
	invalidTI 	 : Boolean;
	str	,
	detail		 : String;
	cargoSubtype : String;
	ti			 : CM_TrackedItem;
	opCode : String;
	actionDT, anniDT : Date;
begin
	str := inheritMethod();
	//epr TFS 4474 1/6/17
	on Exception do app.handleDeletedObject(exception,self.myTrackedItem,invalidTI);
	
	ti := self.myTrackedItem;									//05.10.2022 navma1 #52967
	if ti.myProduct &lt;&gt; null then
		cargoSubtype := ti.myProduct.description;
	endif;
	
	actionDT:= self.actionTimeStamp.date;
	opCode := ti.getCOOOperatorByDate(actionDT); // ### TFS BUG 64680 17JUNE024 NAVAB with a COO in the future there may be 2 BGPs
	
	// ### TFS BUG 65978 04SEP2024 NAVAB1
	if self.isCOOResync then
		opCode := opCode &amp; " *";
	endif;
	
	detail := "Future Storage Process";
	detail :=  detail								 &amp; Tab &amp; 
			   self.actionTimeStamp.date.asStringJMT &amp; Tab &amp;
			   ti.myTerminal.code 					 &amp; Tab &amp;
			   ti.id 								 &amp; Tab &amp;
			   ti.myCargoType.description 			 &amp; Tab &amp;
			   cargoSubtype 						 &amp; Tab &amp;
			   ti.locationId 						 &amp; Tab &amp;
			   ti.totalQuantity.asStringJMT 		 &amp; Tab &amp;
 // ### TFS 60548 06NOV2023 NAVAB1			    ti.plannedDT.date.asStringJMT 		 &amp; Tab;
			  // ### TFS BUG 64680 17JUNE024 NAVAB1 ti.getFutureStorageAnniversary().asStringJMT &amp; Tab;
			  self.actionTimeStamp.date.addDays(-1).asStringJMT &amp; Tab // ### TFS BUG 64680 17JUNE024 NAVAB1 with a COO in the future there may be 2 BGPs
			  &amp; opCode;
	
	if invalidTI then
		return null;
	endif;
	
	return detail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationString" id="0f867086-e437-43f8-9926-f55d7c6baf51">
