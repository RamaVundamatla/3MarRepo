    <JadeMethod name="validateSED" id="3cf51155-7e5e-4a55-ac9b-526a5323d274">
        <source>validateSED(pControl: CMIF_TIUpdateController) protected;
//--------------------------------------------------------------
//Created: 05 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.sedMean &gt; 0 and
	   self.sedMin = 0 and
	   self.sedMax = 0 then
	   	// This implies that this was a % scaled log.  At first the min/max sed
	   	// was not being set for these logs.  This was being checked when they
	   	// were being regraded.  This is to get around that check.
		return;
	endif;
	
	if self.sedMin = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Log SED Min', ETRow_SedMin, pControl.myUserObject);
		app.raiseCMException(Input_required_field_logSedMin, ETRow_SedMin, pControl.myUserObject); // cnwdb2	PAR 35364
	endif;
	if self.sedMax = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Log SED Max', ETRow_SedMax, pControl.myUserObject);
		app.raiseCMException(Input_required_field_logSedMax, ETRow_SedMax, pControl.myUserObject); // cnwdb2	PAR 35364
	endif;	
	
	//17 Oct. 2008 cnwdz2 Par 16849
	if self.sedMin &lt; 0 then
		app.raiseCMException2(ERR_FIELD_SED_MIN, self.sedMin.String, 'SEDMin', null, pControl.myUserObject);
	endif;
	//17 Oct. 2008 cnwdz2 Par 16849	
	if self.sedMax &lt; 0 then
		app.raiseCMException2(ERR_FIELD_SED_MIN, self.sedMax.String, 'SEDMax', null, pControl.myUserObject);
	endif;
	
	if self.sedMin &gt; self.sedMax then
		app.raiseCMException2(ERR_FIELD_SED_MIN, self.sedMin.String, 'SEDMin', null, pControl.myUserObject);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateSpecies" id="19b544b7-ce28-4aed-8bb7-0eff55c32f83">
        <source>validateSpecies(pControl: CMIF_TIUpdateController) protected;
