    <JadeMethod name="delete" id="0cbbeb67-2b8c-40cf-9933-43bd3faeb3c6">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2024	navkc1	CR 64837
08 Jan 2026 navma1 MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars

begin
	self.allVoyageProcessReports.purge();	//08.01.2026 navma1 #MTN-36897
	delete self.cashReceiptHeader;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setValueFromCMIF" id="ddf2379f-a113-4cc2-a21a-19e39aba9fdb">
        <updating/>
        <source>setValueFromCMIF(_cmif : CMIF_CashInvoiceProformaCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//11/07/2024	navkc1 CR 64837 Task 64851: Jade - New API putProformaForExternal

*/

vars
	cashReceipt : CM_CashReceipt;
	now			: TimeStamp;
	terminal	: CM_Terminal;
	wsReceiptHeader : WS_ProformaHeader;
	wsReceiptDetails : WS_ProformaDetails;
	object	: Object;
	cashPayment : CM_CashPayment;
	cashCredit : CM_CashCredit;
	
begin
	cashReceipt := _cmif.myNewCashReceipt;
	
	if cashReceipt = null then
		return;
	endif;
	
	terminal := _cmif.myTerminal;
	if terminal = null then
		terminal := cashReceipt.myTerminal;
	endif;
	
	//self.amountValue := _cmif.cargoTotalCharges;
	//self.amountValue := cashReceipt.cashValue;
	//self.amountValue := cashReceipt.totalCargoCharges + cashReceipt.taxValue1 + cashReceipt.taxValue2 + cashReceipt.taxValue3; //04/10/2024	navkc1	JIRA 33018 - This value to be Total amount (including invoice line amount) + Tax amount
	//self.amountValue := cashReceipt.totalCargoCharges + cashReceipt.taxValue1 + cashReceipt.taxValue2 + cashReceipt.taxValue3 + cashReceipt.roundingDifference; //27/06/2025 NAVKC1 JIRA 35258 
	self.amountValue   := cashReceipt.cashValue; // 25/07/2025	navkc1	JIRA MTN-35344
	self.bol := cashReceipt.getBOLNumber();
	self.businessUnitId := _cmif.getBusinessUnitId();
	self.cargoID := _cmif.getAllTisID();
	// Cash receipt header
	if terminal &lt;&gt; null then
		//self.currencyCode := terminal.getConfig(CurrencyCodeForAPI).asStringJSON(); 
		self.currencyCode := terminal.getConfig(CurrencyCodeForAPI).asString(); //23/08/2024	navkc1 Bug 65781
	endif;
	self.customsAgentCode := _cmif.myDebtorAgentId;
	self.customsEntryNumber := cashReceipt.getCustomsEntryNumber();
	self.debtorId := cashReceipt.getDebtorAccountCode();
	self.description := cashReceipt.getDescription();
	self.document := _cmif.document;
	//self.effectiveDate := cashReceipt.effectiveDate.asStringJSON();
	self.effectiveDate := cashReceipt.effectiveDate.asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	self.externalUserCode := cashReceipt.externalUserCode;
	self.invoiceType := cashReceipt.getInvoiceTypeDesc();
	self.isPaymentAllowed := _cmif.isPaymentAllowed;
	self.paymentType := app.paymentTypeEnumToString(cashReceipt.getPaymentType());
	self.receiptNumber := cashReceipt.sequenceNum;
	self.remarks := cashReceipt.remarks;
	//self.shipReleaseDate := cashReceipt.shipReleaseDate.asStringJSON();
	self.shipReleaseDate := cashReceipt.shipReleaseDate.asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	//self.taxValue := _cmif.getTotalTaxValue();
	self.taxValue := cashReceipt.taxValue1 + cashReceipt.taxValue2 + cashReceipt.taxValue3;
	self.type := cashReceipt.getTypeString(null);
	self.vesselName := cashReceipt.getVesselName();
	//self.voyageArrival := cashReceipt.getVoyageArrivalDateLocalTZ().asStringJSON();
	self.voyageArrival := cashReceipt.getVoyageArrivalDateLocalTZ().asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	self.voyageCode := cashReceipt.getVoyageCode();
	//self.voyageDeparture := cashReceipt.getVoyageSailingDateLocalTZ().asStringJSON();
	self.voyageDeparture := cashReceipt.getVoyageSailingDateLocalTZ().asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	
	// Receipt Header
	create wsReceiptHeader transient;
	wsReceiptHeader.setValuesFromCMIF2(cashReceipt, _cmif);
	self.cashReceiptHeader := wsReceiptHeader;
	
	// Receipt Details
	foreach object in cashReceipt.allCashPayments do
		if object.isKindOf(CM_CashPayment) then
			cashPayment := object.CM_CashPayment;
		else
			continue;
		endif;
		
		/* //04/10/2024	navkc1	JIRA 33018 - Include invoice line to the response as well
		if not cashPayment.isProformaPayment() then
			continue;
		endif;
		*/
		
		create wsReceiptDetails transient;
		wsReceiptDetails.setValuesFromCMIF(cashPayment, cashCredit);
		wsReceiptHeader.allProformaDetails.add(wsReceiptDetails);
	endforeach;
epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_CashInvoiceProformaCtrl"/>
    </JadeMethod>
</Class>
