    <JadeMethod name="queryTAByDate" id="5b8fa81e-d172-4687-868b-b047fe7e6df7">
        <updating/>
        <source>queryTAByDate() updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	iter	: Iterator;
	ta		: CM_TerminalArea;
	lc		: CM_LocationsController;
	dict	: CM_StockMoveBucketsByDateDups;
	bucket	: CM_StockMoveBucket;
begin

	if self.myFiltTA = null then
		return;
	endif;
	
	create dict transient;
	
	foreach lc in self.myFiltTA.allLocationsControllers do
		if iter &lt;&gt; null then
			delete iter;
		endif;
		
		iter := lc.allStockMovesByDateProduct.createIterator;
		lc.allStockMovesByDateProduct.startKeyGeq(self.filtOpenDate, null, iter);
		while iter.next(bucket) do
			if bucket.date &gt; self.filtCloseDate then
				break;
				// PAR 18081 - as never do anything with this can break
				//continue;//changed by cnwyl1 for par 15591,13716
			endif;
			dict.add(bucket.CM_StockMoveLocation);
		endwhile;
	endforeach;
	
	delete iter;
	
	// PAR15591/18081 - CNWSH3 -Include archive stock moves
	foreach lc in self.myFiltTA.allLCsArchived where
			lc.statusDateTime.date &gt;= self.filtOpenDate do
		if iter &lt;&gt; null then
			delete iter;
		endif;
		
		iter := lc.allStockMovesByDateProduct.createIterator;
		lc.allStockMovesByDateProduct.startKeyGeq(self.filtOpenDate, null, iter);
		while iter.next(bucket) do
			if bucket.date &gt; self.filtCloseDate then
				break;
				// PAR 18081 - as never do anything with this can break
				//continue;//changed by cnwyl1 for par 15591,13716
			endif;
			dict.add(bucket.CM_StockMoveLocation);
		endwhile;
	endforeach;
	
	delete iter;
	iter := dict.createIterator;
	
	self.outputBucketsByLocation(iter);

epilog
	delete iter;
	delete dict;
end;</source>
    </JadeMethod>
    <JadeMethod name="queryTAByProduct" id="a5d2f6e6-a699-4740-ae03-70aeb43f4498">
        <source>queryTAByProduct();
// ---------------------------------------------------------------------------
// Created:     14 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc		: CM_LocationsController;
	dict	: CM_StockMoveBucketsByDateDups;
	bucket	: CM_StockMoveBucket;
	iter	: Iterator;
	filtProdCode	: String;

begin

	if self.myFiltTA = null then
		return;
	endif;

	if self.myFiltProduct &lt;&gt; null then
		filtProdCode := self.myFiltProduct.code;
	endif;

	create dict transient;

	foreach lc in self.myFiltTA.allLocationsControllers do
		if iter &lt;&gt; null then
			delete iter;
		endif;	
		iter := lc.allStockMovesByDateProduct.createIterator;
		
		lc.allStockMovesByDateProduct.startKeyGeq(self.filtOpenDate, self.myFiltProduct, iter);
		while iter.next(bucket) do
			if bucket.date &gt; self.filtCloseDate then
				break;
				// PAR 18081 - as never do anything with this can break
				//continue;//changed by cnwyl1 for par 15591,13716
			endif;
		
			if filtProdCode &lt;&gt; null and filtProdCode &lt;&gt; bucket.product then
				//break;
				continue;//changed by cnwyl1 for par 15591,13716
			endif;
			
			dict.add(bucket.CM_StockMoveLocation);
			
		endwhile;
	endforeach;
	
	//PAR15591/18081 - cnwsh3 include archived stock movements for correct counting.
	foreach lc in self.myFiltTA.allLCsArchived where
			lc.statusDateTime.date &gt;= self.filtOpenDate do
		
		if iter &lt;&gt; null then
			delete iter;
		endif;
		iter := lc.allStockMovesByDateProduct.createIterator;
		lc.allStockMovesByDateProduct.startKeyGeq(self.filtOpenDate, self.myFiltProduct, iter);
		while iter.next(bucket) do
			if bucket.date &gt; self.filtCloseDate then
				break;
				// PAR 18081 - as never do anything with this can break
				//continue;//changed by cnwyl1 for par 15591,13716
			endif;
			if filtProdCode &lt;&gt; null and filtProdCode &lt;&gt; bucket.product then
				//break;
				continue;//changed by cnwyl1 for par 15591,13716
			endif;
			dict.add(bucket.CM_StockMoveLocation);
		endwhile;
	endforeach;
	
	iter := dict.createIterator;
	
	self.outputBucketsByProduct(iter);
	
epilog
	delete iter;
	delete dict;
end;</source>
    </JadeMethod>
    <JadeMethod name="queryTerminalByDate" id="5001d932-cb14-429a-98b3-14a0c506c415">
        <updating/>
        <source>queryTerminalByDate() updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
// ---------------------------------------------------------------------------
vars
	iter	: Iterator;
	ta		: CM_TerminalArea;
	lc		: CM_LocationsController;
	dict	: CM_StockMoveBucketsByDateDups;
	bucket	: CM_StockMoveBucket;
	
begin

	if self.myFiltTerminal = null then
		return;
	endif;
	create dict transient;
	
	foreach ta in self.myFiltTerminal.allTerminalAreas where ta.isStockControlled do
		foreach lc in ta.allLocationsControllers do
	
			delete iter;		// PAR #26678
			iter := lc.allStockMovesByDateProduct.createIterator;
			lc.allStockMovesByDateProduct.startKeyGeq(self.filtOpenDate, null, iter);
			while iter.next(bucket) do : lc_stkmove_loop
				if bucket.date &gt; self.filtCloseDate then
					break lc_stkmove_loop;
					// PAR 18081 - as never do anything with this can break
					//continue;//changed by cnwyl1 for par 15591,13716
				endif;
				dict.add(bucket.CM_StockMoveLocation);
			endwhile;
		endforeach;

		foreach lc in ta.allLCsArchived where
				lc.statusDateTime.date &gt;= self.filtOpenDate do
	
			delete iter;		// PAR #26678
			iter := lc.allStockMovesByDateProduct.createIterator;
			lc.allStockMovesByDateProduct.startKeyGeq(self.filtOpenDate, null, iter);
			while iter.next(bucket) do : archive_stkmove_loop
				if bucket.date &gt; self.filtCloseDate then
					break archive_stkmove_loop;
					// PAR 18081 - as never do anything with this can break
					//continue;//changed by cnwyl1 for par 15591,13716
				endif;
				dict.add(bucket.CM_StockMoveLocation);
			endwhile;
		endforeach;
	
	endforeach;
	
	delete iter;
	iter := dict.createIterator;
	
	self.outputBucketsByLocation(iter);
	
epilog
	delete iter;
	delete dict;
end;</source>
    </JadeMethod>
    <JadeMethod name="queryTerminalByProduct" id="bde14b40-fc2f-4427-bbb7-95567c017873">
        <source>queryTerminalByProduct();
// ---------------------------------------------------------------------------
// Created:     14 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
// ---------------------------------------------------------------------------
vars
	ta		: CM_TerminalArea;
	lc		: CM_LocationsController;
	dict	: CM_StockMoveBucketsByDateDups;
	bucket	: CM_StockMoveBucket;
	iter	: Iterator;
	filtProdCode	: String;
	voy		: CM_Voyage;
begin
	if self.myFiltTerminal = null then
		return;
	endif;
	
	if self.myFiltProduct &lt;&gt; null then
		filtProdCode := self.myFiltProduct.code;
	endif;
	
	create dict transient;
	
	foreach ta in self.myFiltTerminal.allTerminalAreas where ta.isStockControlled do
		foreach lc in ta.allLocationsControllers do
			delete iter;		// PAR #26678
			iter := lc.allStockMovesByDateProduct.createIterator;
			lc.allStockMovesByDateProduct.startKeyGeq(self.filtOpenDate, self.myFiltProduct, iter);
			while iter.next(bucket) do
				if bucket.date &gt; self.filtCloseDate then
					break;
					// PAR 18081 - as never do anything with this can break
					//continue;//changed by cnwyl1 for par 15591,13716
				endif;
				if filtProdCode &lt;&gt; null and filtProdCode &lt;&gt; bucket.product then
					//break;
					continue;//changed by cnwyl1 for par 15591,13716
				endif;
				dict.add(bucket.CM_StockMoveLocation);
			endwhile;
		endforeach;

		foreach lc in ta.allLCsArchived where 
				lc.statusDateTime.date &gt;= self.filtOpenDate do
			delete iter;		// PAR #26678
			iter := lc.allStockMovesByDateProduct.createIterator;
			lc.allStockMovesByDateProduct.startKeyGeq(self.filtOpenDate, self.myFiltProduct, iter);
			while iter.next(bucket) do
				if bucket.date &gt; self.filtCloseDate then
					break;
					// PAR 18081 - as never do anything with this can break
					//continue;//changed by cnwyl1 for par 15591,13716
				endif;
				if filtProdCode &lt;&gt; null and filtProdCode &lt;&gt; bucket.product then
					//break;
					continue;//changed by cnwyl1 for par 15591,13716
				endif;
				dict.add(bucket.CM_StockMoveLocation);
			endwhile;
		endforeach;

	endforeach;
	
	delete iter;
	iter := dict.createIterator;
	
	self.outputBucketsByProduct(iter);
	
epilog
	delete iter;
	delete dict;

end;</source>
    </JadeMethod>
    <JadeMethod name="queryTerminalFixups" id="5673d4d3-9be1-416d-9757-973d8d9ed2df">
        <updating/>
        <source>queryTerminalFixups() updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	fixup	: CM_SOHFixupHdr;
	iter	: Iterator;
	rowIdx	: Integer;
	tmpSheet	: JadeTableSheet;

begin

	if self.myFiltTerminal = null then
		return;
	endif;

	tmpSheet := self.tblData.accessSheet(TblDataSheet_SOHFixups);
	
	tmpSheet.rows := tmpSheet.fixedRows;
	
	iter := self.myFiltTerminal.allSOHFixups.createIterator;
	self.myFiltTerminal.allSOHFixups.startKeyGeq(self.filtOpenDate.TimeStamp, iter);

	while iter.next(fixup) do
		if fixup.dateTime.date &gt; self.filtCloseDate then
			break;
		endif;
		rowIdx := tmpSheet.addItem(fixup.dateTime.String &amp; Tab &amp; 
									   fixup.userCode.String &amp; Tab &amp;
									   fixup.allSOHTransactions.size.String);
		tmpSheet.accessRow(rowIdx).itemObject := fixup;
	endwhile;

	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="queryVoyageByDate" id="1a090c60-6982-4734-8352-86ae530ed198">
        <updating/>
        <source>queryVoyageByDate() updating;
//--------------------------------------------------------------
//Created: September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	iter				: Iterator;
	stockMoveVoyDict	: CM_StockMoveLocnsByDateProduct;
begin
	
	if self.myFiltLC = null and self.myFiltVoyage = null then
		return;
	endif;
	
	if self.myFiltLC &lt;&gt; null then
		stockMoveVoyDict := self.myFiltLC.allStockMovesByDateProduct;
		iter := stockMoveVoyDict.createIterator;
		stockMoveVoyDict.startKeyGeq(self.filtOpenDate, null, iter);
		self.outputBucketsByLocation(iter);		
	else
		self.queryVoyageSOHLocns();
	endif;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
