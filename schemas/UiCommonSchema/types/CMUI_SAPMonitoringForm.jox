    <JadeMethod name="tblData_rowColumnChg" id="79c108d5-82a7-4373-88bd-57113230ac02">
        <updating/>
        <source>tblData_rowColumnChg(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2018	jlgndl1	Initial creation	TFS 42116

*/

vars

	invoice : CM_Invoice;

begin

	self.btnActivity.enabled := false;

	inheritMethod(table);
	
	invoice := self.tblData.accessRow(table.row).itemObject.CM_Invoice;
	if ( invoice &lt;&gt; null and not invoice.allSAPActivity.isEmpty ) /*or process.isNDL*/  then
		self.btnActivity.enabled := true;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
