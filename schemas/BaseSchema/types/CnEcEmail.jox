        <Parameter name="pBccList" type="String"/>
        <Parameter name="pCcList" type="String"/>
        <Parameter name="pContentType" type="String"/>
        <Parameter name="pEncodingType" type="String"/>
        <Parameter name="pMessageBody" type="String"/>
        <Parameter name="pMessageHeader" type="String"/>
        <Parameter name="pMyEmailBaseData" type="CnEcEmailBaseData"/>
