    <JadeMethod name="getStatus" id="74a894ad-23fd-4cc0-b254-b588d0b5a210">
        <source>getStatus(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlger1	Initial creation 38520

*/

vars
		
	status : Integer;
begin
	status:= inheritMethod();
	
	if status &lt;&gt; 0 then
		return status;
	endif;
	

	if self.getTotalActioned() = 0 then
		if self.myParent.hasBeenApproved then
			return WO_STATUS_APPROVED;	
		else
			return WO_STATUS_PENDING;
		endif;
	elseif self.myParent.CM_WorkOrderTI.totalRequired &gt; self.totalComplete then
		return WO_STATUS_PARTCOMPLETE;
	elseif self.myParent.CM_WorkOrderTI.totalRequired = self.totalComplete then
		return WO_STATUS_COMPLETE;
	endif;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStatusString" id="5742843c-517f-4ecb-8279-b38d3d94fdc5">
        <source>getStatusString(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 Nov 2009	cnwrd1	Initial creation
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars
	statusString : String;
begin
	statusString := inheritMethod();
	
	if statusString &lt;&gt; null then
		return statusString;
	endif;
	
	if self.getTotalActioned() = 0 then
		if self.myParent.hasBeenApproved then
			return app.getErrorString(WO_STATUS_APPROVED_DESC);						//15.02.2023 navma1 #56561
		else
			return app.getErrorString(WO_STATUS_PENDING_DESC);						//15.02.2023 navma1 #56561
		endif;
	elseif self.myParent.CM_WorkOrderTI.totalRequired &gt; self.totalComplete then
		return app.getErrorString(WO_STATUS_PARTCOMPLETE_DESC);						//15.02.2023 navma1 #56561
	elseif self.myParent.CM_WorkOrderTI.totalRequired = self.totalComplete then
		return app.getErrorString(WO_STATUS_COMPLETE_DESC);							//15.02.2023 navma1 #56561
	endif;
	
epilog

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIOperator" id="8796115b-b63f-471f-8261-92981ff59541">
