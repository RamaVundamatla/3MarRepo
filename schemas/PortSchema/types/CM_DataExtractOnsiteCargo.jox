        <source>initDataExtractFields_Ship(_fields : CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services
26 May 2011 cnwdz2  PAR #27598 Reviewed.
*/

vars
	fieldName		: String;
	
begin
	fieldName := "planningState";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "planningState", fieldName, STRING, "Planning State", "The planning state of this cargo item", STRING, "Notified, Received, Planned To Load, Loaded, Planned_To_Discharge, Discharged, Delivered, Planned SOB, Shifted On Board, or Unknown");

	fieldName := "readyToShip";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "readyToShip", fieldName, STRING, "Ready To Ship", "If the container has been designated as ready to ship", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "isTranshipItem";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "isTranshipItem", fieldName, BOOLEAN, "Is Tranship Item", "If this item is a tranship", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "dischargeDT";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "dischargeDT", fieldName, TIMESTAMP, "Discharge Date/Time",  "Discharge date and time", TIMESTAMP, TIMESTAMP_POSSIBLEVAL);

	fieldName := "dischargeJobNum";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "dischargeJobNum", fieldName, STRING, "Discharge Job Num", "The ids of jobs that have been created to unload a container from a vessel", STRING, "A string value of any length");

	fieldName := "dischSeqNumber";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "dischSeqNumber", fieldName, STRING, "Disch Seq Number", "Discharge sequence number", STRING, "Max Length 4");

	fieldName := "loadDT";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "loadDT", fieldName, TIMESTAMP, "Load Date/Time", "Load date and time", TIMESTAMP, TIMESTAMP_POSSIBLEVAL);

	fieldName := "loadSeqNumber";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "loadSeqNumber", fieldName, STRING, "Load Seq Number","Load sequence number", STRING, "Max length 4");

	fieldName := "loadJobNum";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "loadJobNum", fieldName, STRING, "Load Job Num", "The ids of jobs that have been created to load a container to a vessel", STRING, "A string value of any length");

	fieldName := "destinationPort";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "destinationPort", fieldName, STRING, "Destination", "Intended port destination port of the container", STRING, "Valid port code");

epilog

end;</source>
