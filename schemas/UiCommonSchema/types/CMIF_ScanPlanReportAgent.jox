		elseif index = 9 then
			report.frmBay9.visible := true;	
			self.populateFrmBay( 	report.frmBay9,	//_bayFrame : CMUI_Frame;
								report.lblBayId9,	//_bayIdLbl : CMUI_Label input;
								report.lblColId9,	//_colIdLbl : CMUI_Label input;
								report.lblTierId9,	//_tierIdLbl : CMUI_Label input;
								report.picCell9,	//_cellPic : CMUI_Picture input;
								report.frmHatch9,	//_hatchFrm : CMUI_Frame input;
