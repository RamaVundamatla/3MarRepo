							_stForImportGenObj:CM_SubTerminal;
							_stForExportGenObj:CM_SubTerminal;
							_stForStorageGenObj:CM_SubTerminal;
							_stForCargoOtherObj:CM_SubTerminal;
							_stForSourceBulkRdObj:CM_SubTerminal;	// cnwdad1 PAR 22205.
							_stForSourceBulkRlObj:CM_SubTerminal;	// cnwdad1 PAR 22205.
							_stForSourceBulkShObj:CM_SubTerminal;	// cnwdad1 PAR 22205.
