    <JadeMethod name="clickToCompBtn" id="ca84c488-c038-4a02-8d45-7590ec3d7596">
        <updating/>
        <source>clickToCompBtn( btn: Button input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2016	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
//	hasActions : Boolean;
//	resDetailSet : CM_ReserveDetailSet;
//	bookingItemSet : CM_BookingRefItemSet;
//	doActions : Boolean;
//	doStore : Boolean;
//	opt1Str : String;
//	opt2Str : String;
//	opt3Str : String;
//	returnValue : Integer;
	lc : CM_LocationsController;

begin

	//03 Mar 2017 - TFS 3299 - Leave Doc Action code commented out, until they change their minds again....

	ti := btn.userObject.CM_TrackedItem;
	if ti = null then
		return;
	endif;
	
/*	create resDetailSet transient;
	create bookingItemSet transient;
	if ti.hasDocumentActions( resDetailSet, bookingItemSet ) then
		hasActions := true;
	endif;
	
	if hasActions then
		opt1Str := app.getErrorString( Move_storage );
		opt2Str := app.getErrorString( Perform_document_actions );
		opt3Str := app.getErrorString(None_above_cancel);
		returnValue := self.optBox(opt1Str, opt2Str, opt3Str, null, 2, app.getErrorString(Select_option) );
		if returnValue = 1 then
			doActions := false;
			doStore := true;
		elseif returnValue = 2 then
			doActions := true;
			doStore := false;
		else
			//bail
			return;
		endif;
	else
		doStore := true;
	endif;
	
	
	if doActions then
		self.myMobileGenericAgent.setAllReserveDetails( resDetailSet );
		self.myMobileGenericAgent.setAllBookingRefItems( bookingItemSet );
		self.myMobileGenericAgent.setMyNextTiToAction( ti );
		
		self.myMobileGenericAgent.setDecimalField1( self.cmbSortBy.listIndex );
		
		self.myMobileGenericAgent.setMyLocationsController( self.cmbSourceLoc.listObject.CM_LocationsController );
		
		self.findLocationToMoveTo( lc );
		app.myMobileCargoFindAgent.setMyYardLoc( lc );
		
		self.gotoForm( MOB_HHDocumentActions, false );
	
	elseif doStore then */
		self.myMobileGenericAgent.setMyNextTiToAction( ti );
		self.myMobileGenericAgent.setDecimalField1( self.cmbSortBy.listIndex );
		self.myMobileGenericAgent.setMyLocationsController( self.cmbSourceLoc.listObject.CM_LocationsController );
		self.myMobileGenericAgent.setStringField1( self.fldStripped.topSheet.caption ); //10 Mar 2017 NDL	TFS 3676
		
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess( ti );
		self.findLocationToMoveTo( lc );
		app.myMobileCargoFindAgent.setMyYardLoc( lc );
		
		self.gotoForm(MOB_HHMoveCargo, false);
	
//	endif;

epilog

//	delete resDetailSet;
//	delete bookingItemSet;

end;</source>
