vars

begin
	if set then
		// set code here
		return;
	else
		// get code here
		if self.myProxyDeckingOptions &lt;&gt; null
		and self.myProxyDeckingOptions.allDeckingRulesOut.size = 1 then
			_value := (self.myProxyDeckingOptions.allDeckingRulesOut.first.deckingRuleType = DeckingRule_Custom);	
		else
			//if size = 0 or &gt; 1 then cannot be
			_value := false;
		endif;
		
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setProxyDeckingOptions" id="93ce33c5-222d-4671-aead-1534a12287bb">
        <updating/>
        <source>setProxyDeckingOptions(_pxyDeckingOptions: CM_YADeckingOptions) updating;
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.myProxyDeckingOptions := _pxyDeckingOptions;
	
end;</source>
        <Parameter name="_pxyDeckingOptions" type="CM_YADeckingOptions"/>
    </JadeMethod>
