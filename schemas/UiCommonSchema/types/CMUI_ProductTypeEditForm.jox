	self.permissionMaint := PmGCProductMaint;

end;</source>
    </JadeMethod>
    <JadeMethod name="disableProdAttributes" id="29133ff5-2040-44b8-a275-a845fa390cf2">
        <source>disableProdAttributes(_toClear : Boolean) protected;
/* ---------------------------------------------------------------------------
Created:	28 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who			Reason
-----------		--------	--------------------------------------------------
15/03/2013		cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
11/06/2013		cnwdap1		PAR #31767 Correct handling of decimals for measurement types
------------------------------------------------------------------------------*/
vars
	validationType		: String;
	measureType			: CM_MeasurementType;			// PAR #31155
	value				: String;						// PAR #31767

begin

	// disable all
	self.cmbCode.enabled		:= false;
	self.txtRange.enabled		:= false;
	self.txtValue.enabled		:= false;
	self.txtMultiplier.enabled	:= false;
	self.txtDisplayValue.enabled:= false;
	
	self.lblCode.enabled		:= false;
	self.lblRange.enabled		:= false;
	self.lblValue.enabled		:= false;
	self.lblMultipplier.enabled	:= false;
	self.lblDisplayValue.enabled:= false;
	
	if _toClear then
		self.txtRange.text := "";
		self.txtValue.text := "";
		self.txtMultiplier.text := "";
		self.txtDisplayValue.text := "";
	endif;
	
	//re-enable
	validationType := self.myCurrentProdAttr.validationType;
	
	if validationType = CM_ProductAttr.ValidationType_Codes then
		self.cmbCode.enabled	:= true;
		self.lblCode.enabled	:= true;	//label active
		
	elseif validationType = CM_ProductAttr.ValidationType_Value then
		
		if self.myCurrentProdAttr.myType = String then
			self.txtValue.maxLength	:= 30;
			self.txtValue.enabled		:= true;
			self.txtValue.dataType		:= 0;	// Alphanumeric
			self.lblValue.enabled		:= true;	//label active

		elseif self.myCurrentProdAttr.myType = Decimal then
			self.txtRange.enabled		:= true;
			self.txtValue.enabled		:= true;
			self.txtValue.dataType		:= 1;	// Numeric
			self.txtValue.maxLength		:= 12;
			// PAR #31155 if we havde a measurement, don't set the decimals here
			if self.cmbMeasureType.listIndex &lt; 1 then						// PAR #31155
				self.txtValue.decimals		:= 3;
			endif;															// PAR #31155
			self.txtMultiplier.enabled	:= true;
			self.txtMultiplier.dataType	:= 1;
			self.txtMultiplier.maxLength:= 10;
			self.txtMultiplier.decimals	:= 3;
			self.lblRange.enabled		:= true;	//label active
			self.lblValue.enabled		:= true;	//label active
			self.lblMultipplier.enabled	:= true;	//label active
		
		elseif self.myCurrentProdAttr.myType = Integer then
			self.txtRange.enabled		:= true;
			self.txtValue.enabled		:= true;
			self.txtValue.dataType		:= 1;	// Numeric
			self.txtValue.maxLength		:= 9;
			self.txtMultiplier.enabled	:= true;
			self.txtMultiplier.dataType	:= 1;
			self.txtMultiplier.maxLength:= 10;
			self.txtMultiplier.decimals	:= 3;
			self.lblRange.enabled		:= true;	//label active
			self.lblValue.enabled		:= true;	//label active
			self.lblMultipplier.enabled	:= true;	//label active
			
		endif;
		
	endif;
	
	// PAR #31155 hide the multiplier field, default decimals to measurement type decimals
	if self.cmbMeasureType.listIndex &gt; 0 then									// PAR #31155
		measureType := self.cmbMeasureType.listObject.CM_MeasurementType;		// PAR #31155
		if self.txtValue.text &lt;&gt; null then										// PAR #31767
			value := measureType.removeDecimalZeros(self.txtValue.text);		// PAR #31767
			self.txtValue.text := null;											// PAR #31767
		endif;																	// PAR #31767
		self.txtValue.decimals 		:= measureType.getDecimalPrecision;			// PAR #31155
		self.txtValue.text			:= value;									// PAR #31767
		self.lblMultipplier.visible := false;									// PAR #31155
		self.txtMultiplier.visible 	:= false;									// PAR #31155
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_toClear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCmbCodeClick" id="4dab9002-c088-4b1e-8d88-15f77e83a19a">
        <updating/>
        <source>doCmbCodeClick() updating, protected;
/* ---------------------------------------------------------------------------
Created:	29 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	cmbText	: String;

begin

	cmbText := self.cmbCode.text;
	//self.tblAttributes.setCellText(tblAttributes.row, tblAttributes.getColumnByRowName(ETRow_ColumnCode), cmbText);
	
	if cmbText = self.EditCodeString then
		self.showEditCodesForm();
	else
		self.myCurrentProdAttr.setMyCode(self.cmbCode.listObject.CM_ProductAttributeCode);
	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbMeasureTypeClick" id="20472b57-5cc3-4326-88de-4217fda6b592">
        <updating/>
        <source>doCmbMeasureTypeClick() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
10/06/2013	cnwdap1	PAR #31767 Null object check
*/
vars
	displayName 	: String;
	oldMeasureType	: CM_MeasurementType;
	measureType		: CM_MeasurementType;
	value			: Decimal [23,10];
	result			: String;

begin
	if self.cmbMeasureType.listIndex &lt; 1 then	
		return;
	endif;
	
	// build display name from system name and measurement type short name
	measureType := self.cmbMeasureType.itemObject[self.cmbMeasureType.listIndex].CM_MeasurementType;
	displayName := self.cmbSystemName.text;
	self.txtDisplayName.text := displayName;
	
	// Change Value and Display Value to reflect the new measurement type
	if self.txtValue.text &lt;&gt; null then
		oldMeasureType := self.myCurrentProdAttr.myMeasurementType;
		if oldMeasureType &lt;&gt; null then										// PAR #31767
			value := app.convertMeasurementForStorage(oldMeasureType.shortName, self.txtValue.text.Decimal);
			if oldMeasureType.isFeetAndInches then																						//cnwmc5 - 28 Nov 2013 - PAR 33074
				value := app.convertMeasurementForStorage(oldMeasureType.shortName, self.txtFeetAndInches.getFeetInches().Decimal);		//cnwmc5 - 28 Nov 2013 - PAR 33074
			endif;																														//cnwmc5 - 28 Nov 2013 - PAR 33074
			result := app.convertMeasurementForDisplay(measureType.shortName, value);
		endif;																// PAR #31767
		self.txtValue.text := null;
		if self.txtValue.dataType = TextBox.DataType_AlphaNumeric then		// PAR #31767
			self.txtValue.dataType := TextBox.DataType_Numeric;				// PAR #31767
		endif;																// PAR #31767
		self.txtValue.decimals := measureType.getDecimalPrecision;
		self.txtValue.text := result;
		if measureType.isFeetAndInches then									//cnwmc5 - 28 Nov 2013 - PAR 33074
			self.txtFeetAndInches.text := result.asFeetInchesForMask();		//cnwmc5 - 28 Nov 2013 - PAR 33074
		endif;																//cnwmc5 - 28 Nov 2013 - PAR 33074
		self.showDisplayValue;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbSystemNameClick" id="fc52ce9b-a205-4a5a-aadb-2b2859679b7e">
        <updating/>
        <source>doCmbSystemNameClick() updating, protected;
/* ---------------------------------------------------------------------------
Created:	28 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who			Reason
-----------		--------	--------------------------------------------------
16/05/2013		cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
11/06/2013		cnwdap1		PAR #31767 Correct interaction between system name and measurement type combos
20/03/2014		cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
------------------------------------------------------------------------------*/
vars
	prodAttr	: CM_ProductAttr;
	entRowName	: String;
	
begin

	if self.cmbSystemName.listIndex = -1 then
		return;
	endif;

	// setting self.myCurrentProdAttr
	entRowName := self.getEntRowNameFromCmbSystemName();
	prodAttr := self.myProductType.getProdAttrFromName(entRowName);

	if self.myCurrentProdAttr = prodAttr then
		return; //nothing chyanged
	endif;
	
	self.saveDataForProdAttribute();
	self.myCurrentProdAttr := prodAttr;
	
	// PAR 31767 moved to below saveDataForProdAttribute as this sets things on the current object based on what's currently on the form
	// PAR #31155 If current product attribute is a measurement type, set measurement combo appropriately						// PAR #31155
	//if entRowName.isOneOf(ETRow_MyWeight, ETRow_MyVolume, ETRow_MyHeight, ETRow_MyLength, ETRow_MyWidth, ETRow_MyDensity) then	// PAR #31155		// PAR #33606
	if entRowName.isOneOf(ETRow_MyWeight, ETRow_MyVolume, ETRow_MyHeight, ETRow_MyLength, ETRow_MyWidth, ETRow_MyDensity, ETRow_MyStowageFactor) then	// PAR #33606
		self.setCmbMeasureType(entRowName);																						// PAR #31155
	else																														// PAR #31155
		self.setCmbMeasureType(null);																							// PAR #31155
	endif;																														// PAR #31155
	
	// PAR #31767 moved to below setCmbMeasureType so we have the correct measurement type (if any) selected to set decimals etc
	self.loadDataForProdAttribute();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbValidationClick" id="22a253ff-0be9-4b0f-8e8b-adb88e2543d0">
        <source>doCmbValidationClick() protected;
/* ---------------------------------------------------------------------------
Created:	29 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.myCurrentProdAttr.validationType = cmbValidation.text then
		return;	// nothing changed
	endif;
	
	self.myCurrentProdAttr.setValidation(cmbValidation.text);
	self.disableProdAttributes(true);
	self.setCmbCode();
	if cmbValidation.text = CM_ProductAttr.ValidationType_Codes then
//		table.setCellText(table.row, table.getColumnByRowName(ETRow_ColumnCode), Any_String);
		self.cmbCode.text := Any_String;
	endif;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="a2161cc5-3f44-49a8-9e47-d04ac9290d93">
