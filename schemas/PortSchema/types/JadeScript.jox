    <JadeMethod name="rel811_par30193" id="01cc9e1f-f7cc-40fc-912c-5a86e0743ad5">
        <updating/>
        <source>rel811_par30193() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/08/2012	cnwdap1	Initial creation PAR #30193 VTMIS module needs access to Operator and Trades maintenance, 
					does not need access to blockstack maintenance and release request
*/
vars
	termRole : CM_SecurityRoleTerminalRoot;
	sysRole : CM_SecurityRoleSystemRoot;
	newPerms : IntegerArray;
	menuAgent : CM_MenuAgent;

begin
	app.initialize;
	
	create newPerms transient;
	newPerms.add(PmAdmOpereditMaint);
	newPerms.add(PmAdmOpereditView);
	newPerms.add(PmAdmPortCodeMaint);
	newPerms.add(PmAdmTradesMaint);
	newPerms.add(PmAdmTradesView);
	newPerms.add(PmViewOtherUsersScreens);
	newPerms.add(PmAdmBlockstackMaint);
	newPerms.add(PmGteMTReleaseViewUnknown);
	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	sysRole := CM_SecurityRoleSystemRoot.firstInstance;
	beginTransaction;
	termRole.setPermissionsFromIntArray(newPerms, false);	//true if terminal permission
	sysRole.setPermissionsFromIntArray(newPerms, true);	//true if system permission
	commitTransaction;

	// ### RESET MENUS
	beginTransaction;
	app.myRoot.resetRootSecurityRoles(null);
	commitTransaction;
	create menuAgent transient;
	menuAgent.resetAllMenuDetails();
	
epilog
	delete newPerms;
	delete menuAgent;
end;</source>
    </JadeMethod>
