<Class name="CMIF_VentReading" id="f47c583e-96f4-4a88-82ad-f71b6a88a147">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <PrimAttribute name="dateTime" id="a98b067c-429e-4f15-8478-77dda87d1dce">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myTerminal" id="07c93608-2b2e-46aa-b6b4-f690d7293878">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTrackedItem" id="9568249b-f768-4547-90e4-219c02c20350">
        <embedded/>
        <type name="CM_TrackedItem"/>
    </ImplicitInverseRef>
    <PrimAttribute name="noCharge" id="ed462a8f-1321-40b7-9694-e71751587256">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="userId" id="cc9ddb94-fb65-4107-a961-202d776a83e3">
        <length>11</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="ventilation" id="7df7adcc-30d0-44cc-890a-2e9867ae42e9">
