    <JadeMethod name="getStructureLayer" id="b98d4886-af3d-43bd-a278-a622ae1e6c63">
        <source>getStructureLayer() : CM_DeckLayerLayout;
/*
Purpose:			
Date				Who			Reason
OCTOBER 2011		CNWAB1		Initial creation
*/


vars
	pxyCC, realCC : CM_DeckLayerLayout;
	found : Boolean;
begin
	foreach realCC in self.allDeckLayerLayouts discreteLock where realCC.type = ROROLayerType_Structure do
		return realCC;
	endforeach;

	create pxyCC transient;
	pxyCC.setProxy("General Areas", "Auto Created EDI", "", self,true,ROROLayerType_Structure);
	
	if process.isInTransactionState then // PAR 28330
		app.myUtilityCA.utlCreateDeckLayerLayout(pxyCC, realCC, true, app.myPassport);
