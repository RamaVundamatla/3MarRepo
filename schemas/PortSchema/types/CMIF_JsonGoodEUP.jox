    <JadeMethod name="aDMTExpected" id="3a9f2597-ad20-482c-ba00-5c320f369083">
        <methodInvocation>mapping</methodInvocation>
        <source>aDMTExpected(set : Boolean; _value : Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Nov 2024	navnk30	JIRA 19826: EUP | FR 53853 GoodsReceipt - Good/QuantityExpected, Good/GrossWeightExpected and Good/NettWeightExpected Incorrect Values (NTO-884)

*/

vars

begin
	if set and self.isSetForCargoGroup then
		_value := self.aDMTExpected;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="delete" id="fe7e76c8-0fcf-494f-923e-b1eec6b17aea">
        <updating/>
        <source>delete() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 30 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description
12/07/2023		navdap1		TFS 58923	EUP - Call Off EDI Data Type / EDI Load
06/10/2023		navmd1		TFS 60588	Improve performance and fix transient leaks
****************************************************/
vars
	
begin
	delete self.buyer;
	
	if self.damages &lt;&gt; null then
		self.damages.purge;
		delete self.damages;
	endif;
	
	delete self.deliveryParty;
	delete self.exportShippingLine;
	delete self.forwardingAgent;
	delete self.goodsOwner;
	delete self.instruction;
	
	if self.items &lt;&gt; null then
		self.items.purge;
		delete self.items;
	endif;
	
	delete self.mill;
	delete self.transport;

end;</source>
    </JadeMethod>
