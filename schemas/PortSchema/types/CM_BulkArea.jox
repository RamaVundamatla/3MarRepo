    <JadeMethod name="isBulkWeightInRange" id="acda2064-17ef-467b-abc0-04c09e5d05ff">
        <source>isBulkWeightInRange(_weight:Integer; _isBelow:Boolean output; _limit:Integer output): Boolean;
// --------------------------------------------------------------------------------
// Created:		05 February 2007 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified weight is
//				within the receiver's minimum/maximum range.
//
// Parameters:	_weight - The weight of the Terminal Area cargo.
//				_isBelow - True if the levels are below the limit, or false if the
//					levels are above the limit (irrelevant if levels are within
//					the limits).
//				_limit - The limit value that has been broken.
//
// Returns:		True if the weight iswithin range, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.minWeight &gt; 0 and _weight &lt; self.minWeight then
		_isBelow	:=	true;
		_limit		:=	self.minWeight;
		
		return false;
		
	elseif self.maxWeight &gt; 0 and _weight &gt; self.maxWeight then
		_isBelow	:=	false;
		_limit		:=	self.maxWeight;
		
		return false;
		
	endif;
	
	return true;
end;</source>
        <Parameter name="_weight" type="Integer"/>
        <Parameter name="_isBelow" type="Boolean" usage="output"/>
        <Parameter name="_limit" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
