    <JadeMethod name="cmbCargoTA_lostFocus" id="a25098a9-775b-4471-b8ad-c6aecd3b52ce">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoTA_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2026	jlier1	Initial creation

*/

vars
priorLocation : CM_LocationsController;
	ta : CM_TerminalArea;
	locationControllerArray : ObjectArray;

begin

	ta := combobox.listObject.CM_TerminalArea;
	priorLocation := self.cmbCargoLoc.listObject.CM_LocationsController;

	self.tblInvLineProps.setValueByControlName(combobox.name,combobox.text);
	
	self.cmbCargoLoc.clear();
	
	if ta &lt;&gt; null then
		create locationControllerArray transient;
		ta.getAllMachineVehicleConts( locationControllerArray );	//18 Dec 2019	NDL	TFS 47954
		ta.getAllLocationsControllers( locationControllerArray );
		self.cmbCargoLoc.listCollection( locationControllerArray, false, 0);
		if priorLocation &lt;&gt; null then
			self.cmbCargoLoc.listIndex := self.cmbCargoLoc.findObject( priorLocation );
		endif;
		if locationControllerArray.size = 1 and self.cmbCargoLoc.listIndex &lt; 1 then
			self.cmbCargoLoc.listIndex := self.cmbCargoLoc.findObject( locationControllerArray.first );
		endif;
	endif;

epilog

	delete locationControllerArray;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
