    <JadeMethod name="shouldAuditProperty" id="1a384cd3-0f38-499a-a627-99be94e5905a">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
// ---------------------------------------------------------------------------
// Created:		14 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//17/6/17 jlgns1 TFS 4552*:C3 - Cannot Match docket to Location

vars

begin
	if //_property.name = CM_Operator::allCodeGroups.name or
	   _property.name = CM_Operator::allDataAccessControllers.name or
	   _property.name = CM_Operator::allLocationRestrictions.name or
	   _property.name = CM_Operator::allOperatorGroups.name or
	   _property.name = CM_Operator::allOperatorShippingLines.name or
	  // _property.name = CM_Operator::allOperatorTerminals.name or
	   _property.name = CM_Operator::allProducts.name or
	   _property.name = CM_Operator::allStkOrdByProcessFulfillStat.name or
	   _property.name = CM_Operator::allStockOrderHeaders.name or
	   _property.name = CM_Operator::allVessels.name or
	   _property.name = CM_Operator::allVoyageOperators.name or
	   _property.name = CM_Operator::allVoyages.name or
	   _property.name = CM_Operator::allVoyagesShippingLine.name or
	   _property.name = CM_Operator::allXlationTables.name then
		return false;
	endif;

	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="3699aa0d-f0a6-4e90-b1ee-3f190b8e396d">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.allOperators[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="1666e69e-e07f-4889-9a9e-78d1f1d4ed0b">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/08/2011	cnwcs5		Tidy up when removing old KPI classes
// 29/03/2012	cnwcs5		par 29318 - cannot delete operator if they are referenced in a sailing package	
//11/04/2019 	JLGNS1		Bug 44243: PEL1 add inverses to prevent deleting consigniees if used in a WODCargoRequest
// ---------------------------------------------------------------------------
vars
	opTerm		: CM_OperatorTerminal;
	theOperator : CM_Operator;
	aTerm 		: CM_Terminal;
	theID 		: String;
	booking		: CM_BookingRef;
	bolOut		: CM_BOLOut;
	voyage 		: CM_Voyage;
	consignee	: CM_ConsigneeConsignor;
	package		: CM_Package;	// par 29318
	iter 		: Iterator;
	ti 			: CM_TrackedItem;
	objArray 	: ObjectArray;
	whereUsed : String;
	term : CM_Terminal;
begin
	
	if app.isJMTUnitTest then
		//do nothing..
	else
		app.raiseCMException1( Delet_funct_not_supported, app.getErrorString(Operator), null, null );
		return;
	endif;

//	foreach aTerm in app.myRoot.allTerminals do
//		theOperator := aTerm.getConfig(DefOperator).CM_Operator;
//		if theOperator = self then
//			app.raiseCMException3(ERR_USED_IN_CONFIG,"Operator", self.code,"Terminal " &amp; aTerm.code,null, null);
//		endif;
//	endforeach;

	foreach opTerm in self.allOperatorTerminals do
		opTerm.validateForDelete();
	endforeach;

	if not self.allOperatorShippingLines.isEmpty then //Par 18310 AER 24/10/2008
		app.raiseCMException(OperatorInUse, null, null);
	endif;
	
	if not self.allProducts.isEmpty then //Par14642
		app.raiseCMException(ERR_DEL_SUPPLIER_PRODUCT, null, null);
	endif;
	
	if (not self.allStockOrderHeaders.isEmpty) then	//par 21807 Jan 2010
		app.raiseCMException2(Operator_has_stock_orders, self.code, app.getErrorString(Operator_cannot_be_deleted), null, null);
	endif;

	if (not self.allVessels.isEmpty) then	//par 21807 Jan 2010
		app.raiseCMException3(Operator_is_vessel_operator, self.code, self.allVessels.size.String, app.getErrorString(Operator_cannot_be_deleted), null, null);
	endif;

	if (not self.allVoyageOperators.isEmpty) then	//par 21807 Jan 2010
		app.raiseCMException3(Operator_has_worked_voyage_inf, self.code, self.allVoyageOperators.size.String, app.getErrorString(Operator_cannot_be_deleted), null, null);
	endif;

	if (not self.allVoyages.isEmpty) then		//par 21807 Jan 2010
		app.raiseCMException3(Operator_is_voyage_operator, self.code, self.allVoyages.size.String, app.getErrorString(Operator_cannot_be_deleted), null, null);
	endif;
	
	if self.allWodCargoRequests.isNotEmpty then																															//Bug 44243
		app.raiseCMException3(Operator_is_voyage_operator, self.code, self.allWodCargoRequests.size.String, app.getErrorString(Operator_cannot_be_deleted),null, null);	//Bug 44243
	endif;																																								//Bug 44243
	
	//12 Aug 2011	NDL	27792 - starts here	
	foreach aTerm in app.myRoot.allTerminals do
		booking := aTerm.allBookingRefsByOperatorRef.getAtKeyGeq(self.code,null,null);
		if booking &lt;&gt; null and booking.myOperator = self then
			app.raiseCMException2(Operator_has_bookings, self.code, aTerm.code, null, null);
			break;	// par 29318
		endif;
		
		bolOut := aTerm.allBOLOutUnmatched.getAtKeyGeq(self.code,null,null);
		if bolOut &lt;&gt; null and bolOut.myOperator = self then
			app.raiseCMException2(Operator_has_bols, self.code, aTerm.code, null, null);
			break;	// par 29318
		endif;
	endforeach;	
	//12 Aug 2011	NDL	27792 - ends here

	// there are references to operator on CM_PackageSailing that are not inversed
	// make sure we don't delete an operator f they are references on a package.
	foreach package in app.myRoot.allPackages do	// par 29318
		if not package.isKindOf (CM_PackageSailing) then
			continue;
		endif;
		
		if package.CM_PackageSailing.myRecipient = self or
			package.CM_PackageSailing.myCargoOperator = self then
			app.raiseCMException1 (Operator_has_sailingpackages, self.code, null, null);
			break;
		endif;
	endforeach;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.code, whereUsed, null, self);
	endif;
	
	//29 Apr 2021	NDL	TSF 50906
	foreach opTerm in self.allOperatorTerminals do
		term := opTerm.myTerminal;
		if term.hasLocationActivityFor( self ) then
			app.raiseCMException2(ObjectStillHasEntries, term.code, app.getErrorString(Location_activity), app.getErrorString(Location_activity), null);
		endif;
	endforeach;
	
epilog

	delete iter;
	delete objArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForStopReceival" id="98885925-7cd7-4461-aa4f-0f8a024d15ad">
        <source>validateForStopReceival(_theController:CMIF_OpCargoRecController);
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

end;</source>
        <Parameter name="_theController" type="CMIF_OpCargoRecController"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="c4a33893-b5a2-48f3-a8c2-8c92e38e8fe8">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
//17/6/17 jlgns1 TFS 4552*:C3 - Cannot Match docket to Location

vars
	pxyCodeGroup	: CM_CodeGroup;		
	tmpProduct 		: CM_Product;
	realOperator 	: CM_Operator;
	whereUsed : String;
begin
	
	pxyCodeGroup :=  self.allCodeGroups[CodeGroup_LogSpecs];
	realOperator := self.pxyGetRealObject();
	
	if pxyCodeGroup &lt;&gt; null and	realOperator.allProducts.size &gt; 0 then
		//If any product is in a stock order we cannot change code groups
		foreach tmpProduct in realOperator.allProducts do
			if tmpProduct.isKindOf(CM_ProductLog) and tmpProduct.CM_ProductLog.myLogSpecies.myCodeGroup &lt;&gt; pxyCodeGroup then
				if tmpProduct.allStockOrderProductLines.size &gt; 0 or tmpProduct.allStockOrderSummaries.size &gt; 0 then
					app.raiseCMException1(UnableToChangeLogsSpecs, self.code, null, null);
					return;
				endif;
			endif;	
		endforeach;
		//Delete all products from the wrong code group
		foreach tmpProduct in realOperator.allProducts do
			if tmpProduct.isKindOf(CM_ProductLog) and tmpProduct.CM_ProductLog.myLogSpecies.myCodeGroup &lt;&gt; pxyCodeGroup then
				delete tmpProduct;	
			endif;	
		endforeach;
	endif;
	 
	self.validateMe();
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isNotAvailableForEntry then
		if self.isUsedinConfig( whereUsed ) then
			app.raiseCMException1(Not_make_not_availa_while, whereUsed, null, self);
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="6b1066c4-5239-4f18-9651-9f53ef5bf803">
        <source>validateMe() protected;
//
//15 May 2013	cnwrs1	par31549 stop removal of unused options
//
vars
	tmpStr : String;
	opTerm	: CM_OperatorTerminal;
	pxyOperator : CM_Operator;

begin
	if self.code = null then
		tmpStr := app.getTerminologyAlternate(null, null, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr &amp; ' Code', null, null);
		app.raiseCMException1(Input_required_field_andCode, tmpStr, null, null); // cnwdb2	PAR 35364


	endif;
	
	if self.description = null then
		tmpStr := app.getTerminologyAlternate(null, null, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
//		app.raiseCMException1(REQUIRED_FIELD, tmpStr &amp; ' Description', null, null);
		app.raiseCMException1(Input_required_field_andDesc, tmpStr , null, null); // cnwdb2	PAR 35364
	endif;
	
	foreach opTerm in self.allOperatorTerminals do
		opTerm.validateForUpdate();
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
