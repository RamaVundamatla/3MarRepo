    <JadeMethod name="doComplete" id="78d77df1-5bf7-4b70-9e68-8838231dc28c">
        <updating/>
        <source>doComplete():Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2010	cnwndl1	Initial creation	CCMS MES 1077

*/

vars

	errMess : String;
	tmpFoundLC : CM_LocationsController;
	wle : CM_WorkListEntry;
	
begin

	if self.myTrackedItem = null then
		errMess := app.getErrorString(No_Cargo_identified);
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return false;
	endif;
	
	if self.myTrackedItem.myVoyage &lt;&gt; self.myMobileGenericAgent.myVoyage then
		errMess := app.getErrorString3(Contai_voyage_your_curren_voya,self.myTrackedItem.id, self.myTrackedItem.myVoyage.code, self.myMobileGenericAgent.myVoyage.code);
		self.myTrackedItem := null;
		self.msgBox(errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		self.txtId.setFocus();
		return false;
	endif;
	
	tmpFoundLC := self.myMobileGenericAgent.myCraneTransferArea.getFirstAvailableLoadLane;
	
	if self.myTrackedItem.myPrimaryActualLocation = tmpFoundLC then
		errMess := app.getErrorString2(Cargo_already_located, self.myTrackedItem.id, tmpFoundLC.getFullId);
		self.msgBox( errMess, app.getErrorString(Warning), MsgBox_OK_Only, true );
		return false;
	endif;	
//process.debugNDL;	
//	wle := self.myTrackedItem.getVoyageWLEUnactioned( false );
	wle := self.myTrackedItem.getVoyageWLEForLCUnactioned( false, tmpFoundLC );	//23 Jun 2016	NDL	TFS 2172
	if not self.myMobileGenericAgent.moveTI( self.myTrackedItem, null, tmpFoundLC, wle, false, 0, 0, null ) then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="c6d8976d-311c-475f-93b4-ab2a80074e03">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	localTop : Real;
	localHeight : Real;
	stdWidth : Real;
	halfWidth : Real;
	width : Real;
	stdHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	halfWidth := ( self.clientWidth/2 ) - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	width := stdWidth - self.getSearchButtonSpace();
	localTop := self.resizedMargin;
	
	if _initialSetup then
		self.txtId.visible := true;
	endif;
	self.txtId.move( self.resizedMargin,
					 localTop,
					 width,
					 stdHeight );
					 
	width := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move( self.txtId.left + self.txtId.width + self.resizedMargin,
						 localTop,
						 width,
						 stdHeight );
						 
	localTop := localTop + self.txtId.height + self.resizedMargin;
	if _initialSetup then
		self.lblCargoType.visible := true;
	endif;
	self.lblCargoType.move( self.resizedMargin,
							 localTop,
							 halfWidth,
							 stdHeight );
	
	if _initialSetup then
		self.lblLoad.visible := true;
	endif;
	self.lblLoad.move( self.lblCargoType.left + self.lblCargoType.width + self.resizedMargin,
						 localTop,
						 halfWidth,
						 stdHeight );
							 
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
