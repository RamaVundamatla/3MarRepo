/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2020	jlgndl1	Initial creation	TFS 50279

*/

vars

	agent : CM_ConfigDisplayAgent;
	persistentMe : CM_Object;

begin

	create agent transient;
	if not self.isTransient then
		return agent.isObjectUsedinConfig( self, _returnStr );
	else
		persistentMe := self.pxyGetRealObject();
		if persistentMe &lt;&gt; null then
			return agent.isObjectUsedinConfig( persistentMe, _returnStr );
		endif;
	endif;

epilog

