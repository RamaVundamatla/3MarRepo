    <JadeMethod name="isComplete" id="a7186da2-a1d1-4593-8a2d-50189d23f1f6">
        <methodInvocation>mapping</methodInvocation>
        <source>isComplete(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     17 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpWLE	: CM_WorkListEntry;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
		
	foreach tmpWLE in self.allWorkListEntries do
		if tmpWLE.status &lt;&gt; WLE_COMPLETED then
			_value := false;
			return; 
		endif;
	endforeach;
	
	_value := true;
	
end;</source>
