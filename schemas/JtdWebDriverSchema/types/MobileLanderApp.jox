    <JadeMethod name="startup2" id="b00fe0db-d7ac-4d17-8bff-3eb6193e50fd">
        <updating/>
        <source>startup2() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2019	jlger1	Initial creation

*/

vars

	o:Object;
	craneCode,
	voyageCode : String;
begin
	inheritMethod();
	self.myWebServiceTestForm.txtWebURL.text:="http://localhost/dmastLocal/bin_public/jadehttp.dll?JMTWebService";
	self.myWebServiceTestForm.txtUser.text :="CNWER1";
	self.myWebServiceTestForm.txtPassword.text:="1";
	self.voyageCode :="JBL500N";
	self.voyageCode :="BET0001";
	self.isDischarge :=app.jtdMyContext.jtdMachineId &lt;&gt; "C8";
	if app.jtdMyContext.jtdMachineId = null then  //just from testing
		app.jtdMyContext.jtdTerminalId:="JBL";
		app.jtdMyContext.jtdMachineId:="J10"; //a crane 
		self.isDischarge:=false;
	endif;
	self.myWebServiceTestForm.txtTerminal.text:=app.jtdMyContext.jtdTerminalId;
	self.myWebServiceTestForm.txtMachine.text:=app.jtdMyContext.jtdMachineId;
	
	// find our queue to work
	foreach o in rootSchema.getSchema("PortSchema").getClass("CM_VoyageCraneQueue").instances do
		if o.getPropertyValue("crane").Object = null then
			continue;
		endif;
		craneCode:=o.getPropertyValue("crane").Object.getPropertyValue("code").String;
		if o.getPropertyValue("myVoyage").Object = null then
			continue;
		endif;
		
		voyageCode:=o.getPropertyValue("myVoyage").Object.getPropertyValue("code").String;
		if voyageCode = self.voyageCode and craneCode = app.jtdMyContext.jtdMachineId then
			self.myRTQueue:=o;
			break;
		endif;
	endforeach;
	
	assert(self.myRTQueue &lt;&gt; null, self);
	
	foreach o in self.myRTQueue.getPropertyValue("allPrimaryMachines").MemberKeyDictionary do
		imvs.add(o.getPropertyValue("code").String);
	endforeach;
	assert(imvs.size &gt; 0, self);
	app.logMessage(method.qualifiedName&amp;" voyageCode="&amp;self.voyageCode&amp;", craneCode="&amp;app.jtdMyContext.jtdMachineId&amp;" machines="&amp;imvs.display.atcgReplace(CrLf, ",")&amp;" myRTQueue="&amp;self.myRTQueue.String);
	
	self.logon();
	
	self.setTerminal();
	
	self.getVoyages();
epilog

end;</source>
    </JadeMethod>
