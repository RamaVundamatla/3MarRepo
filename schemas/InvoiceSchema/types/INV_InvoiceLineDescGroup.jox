    <JadeMethod name="setupAvailableLines" id="1b7666e2-992a-4cae-8a50-1446e0e8322b">
        <source>setupAvailableLines(_theGroup : CM_InvoiceLineDescGroup);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theLines : CM_InvoiceLineDescByNarrDict;
	ldsc : CM_InvoiceLineDesc;
begin
	create theLines transient;
	foreach ldsc in self.myCurrentBank.invoiceLineDescriptors where not ldsc.isNotAvailableForEntry do
		if ldsc.group = null then
			theLines.add(ldsc);
		endif;
	endforeach;
	
	if _theGroup &lt;&gt; null then
		foreach ldsc in _theGroup.lineDescriptions do
			theLines.add(ldsc);
		endforeach;
	endif;
	self.msgLines.setAvailable(theLines,true);
epilog
	delete theLines;
end;</source>
        <Parameter name="_theGroup" type="CM_InvoiceLineDescGroup"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="0a5bea08-1f2e-4e1b-bd8b-409785345770">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.doCmbBankBuild();

	inheritMethod();
	//epr TFS 2903 17/1/17
	self.setMyCurrentBank(self.myTerminal.getDefaultCompanyBank());
//	TFS 2682	self.caption := self.myCurrentBank.code &amp; " Invoice Line Group";
	self.setCaption("Invoice Line Group " &amp; self.myCurrentBank.code);
	
	
	
	self.initMSG();
	self.msgLines.setAvailable(self.myCurrentBank.invoiceLineDescriptors,true);
	beginClassNotification(CM_InvoiceLineDescGroup, false, Object_Create_Event, Response_Continuous, 0); 
	self.doResize();
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="2baca37b-7f57-459d-bce0-02433fec0b03">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theInvoiceLineDesc : CM_InvoiceLineDescGroup;
begin
	self.fldEntDetail.visible := false;
	theInvoiceLineDesc := obj.CM_InvoiceLineDescGroup;
	self.tblThumb.rows := 0;
	self.tblThumb.columns := 2;
	self.showThumbnailForDef(ETDef_InvMaintLineGroupEnt, theInvoiceLineDesc);
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="tblEntDetail_queryRowColChg" id="a5466876-4046-45e1-bf79-0845ee3ab666">
        <controlMethod name="CM_EntryTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEntDetail_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

	value : Real;
	msg : String;

begin

	if self.tblEntDetail.column = 2 then
		if self.tblEntDetail.row = self.tblEntDetail.getRowByName( ETRow_MinimumChargeAmount )
		then
			value := self.tblEntDetail.getCellText( self.tblEntDetail.row, self.tblEntDetail.column ).asRealJMT();
			if value &gt; CM_InvoiceTypeSurchargeExempt.HighValue_15_2 then	//rework 24 Jul 2019	NDL TFS 45509
				msg := app.getErrorString2(ERR_LOWER_GT_UPPER, app.getErrorString(Minimum_charge), CM_InvoiceTypeSurchargeExempt.HighValue_15_2.asStringJMT);
				app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
				return false;
			endif;
		endif;
	endif;

	return true;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d008f9f2-cc74-42c4-9bd6-0a580a127dda">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006204, locale);
	msgLines.translateCaption(Xlat_0002104, locale);
	shtEntDetail.translateCaption(Xlat_0002095, locale);
	shtNarration.translateCaption(Xlat_0002098, locale);
end;</source>
    </JadeMethod>
</GUIClass>
