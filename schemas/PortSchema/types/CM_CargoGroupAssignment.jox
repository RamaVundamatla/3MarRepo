		return false;
	endif;

	return self.allNotifiedCargoGroupByIdDict.getAtKey( _cgId ) &lt;&gt; null;

epilog

end;</source>
        <Parameter name="_cgId" type="String"/>
        <ReturnType type="Boolean"/>
