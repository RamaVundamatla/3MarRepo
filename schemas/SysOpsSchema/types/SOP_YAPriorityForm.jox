    </JadeMethod>
    <JadeMethod name="translateForm" id="52f0a08b-d200-4ae7-8433-88ec8b76e5de">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007235, locale);
	btnCancel.translateCaption(Xlat_0009745, locale);
	btnMoveDown.translateCaption(Xlat_0004136, locale);
	btnMoveUp.translateCaption(Xlat_0004137, locale);
	btnSave.translateCaption(Xlat_0009746, locale);
	lblPriority.translateCaption(Xlat_0004138, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="d3e9f116-dfae-4ad2-a594-42f38fb47f57">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// --------------------------------------------------------------------------------
// Created:		23 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// --------------------------------------------------------------------------------

begin
	inheritMethod(eventType, theObject, eventTag, userInfo);
	
	if eventType = self.myTerminal.getTerminalEvent(EVENT_YA_CP_CREATE)
	or eventType = self.myTerminal.getTerminalEvent(EVENT_YA_CP_DELETE)
	or eventType = self.myTerminal.getTerminalEvent(EVENT_YA_CP_UPDATE)
	then
		if userInfo.Process = process then
			return;
		endif;
		
		app.msgBox(	"The information you are viewing has been changed by another user or process.  " &amp;
					"When you click 'OK', the form will be refreshed.",
					"Warning",
					MsgBox_Information_Icon + MsgBox_OK_Only);
		
		beginLoad;
		
		self.refreshCPCollection();
		self.yaRefreshCriteriaPriority(null);
		
		endLoad;
	endif;
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="yaGetCriteriaPriority" id="70179bcb-614d-4ff8-a863-a2ef3b3cab40">
        <source>yaGetCriteriaPriority(): CMIF_YACriteriaPriority;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Purpose:		Returns a reference to the currently selected Yard Allocation Criteria.
//
// Parameters:	None
//
// Returns:		A reference to the selectd Criteria, otherwise null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	tableObj	: Table;
	
begin
	tableObj	:=	tblPriorities;
	rowPointer	:=	tableObj.row;
	
	if rowPointer &gt; tableObj.fixedRows and rowPointer &lt;= tableObj.rows then
		return tableObj.accessRow(rowPointer).itemObject.CMIF_YACriteriaPriority;
	endif;
end;</source>
        <ReturnType type="CMIF_YACriteriaPriority"/>
    </JadeMethod>
    <JadeMethod name="yaRefreshCriteriaPriority" id="e6adb801-5b3d-40a2-81f8-0dcc80e1f318">
        <source>yaRefreshCriteriaPriority(_obj : Object);
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Purpose:		Refreshes the display of the Yard Allocation Priorities.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj			: Table;
	criteriaPriorityObj	: CM_YACriteriaPriority;
	elementObj			: CMIF_Object;
	selectedRow,
	tmpRow,
	row					: Integer;
	
begin
	tableObj	:=	tblPriorities;
	
	tmpRow := tableObj.row;
	
	self.tableInitializeCriteria();
/*	tableObj.displayCollection(	self.yaCriteria.allSelectedCPs,
								false,
								Collection.CNEC_DISPLAY_ORDER_COLLECTION,
								null);*/
	
	
	
	
	foreach elementObj in self.yaCriteria.allSelectedCPs do
		row := tableObj.addItem(elementObj.CMIF_YACriteriaPriority.getTableDisplay());
		tableObj.accessRow(row).itemObject := elementObj;
		if 	self.aMySelectedCP &lt;&gt; null and elementObj.CMIF_YACriteriaPriority = self.aMySelectedCP then
			tableObj.accessedRow.selected := true;
			selectedRow := row;
		endif;
	endforeach;
	
	// If selectedRow = 0 the probably doing a refresh after a 
	// delete, so position cursor at closest row.
	if selectedRow = 0 and tmpRow &lt;&gt; 0 then
		if tmpRow &lt;= tableObj.rows then
			selectedRow := tmpRow;
		else
			selectedRow := tableObj.rows;
		endif;
	endif;
	
/*	if self.aMySelectedCP &lt;&gt; null then
		criteriaPriorityObj	:=	self.aMySelectedCP;
		
		foreach elementObj in yaCriteria.allSelectedCPs do
			if elementObj.CMIF_YACriteriaPriority.myCriteriaPriority = criteriaPriorityObj then
				row				:=	tableObj.cnEcFindObjectRowNo(elementObj);
				break;
			endif;
		endforeach;
	endif;
	
	if row &lt;=0 or row &gt; tblPriorities.rows then
		return;
	endif;
	tableObj.row	:=	row;*/
	
	if selectedRow &lt;&gt; 0 then
		tableObj.row := selectedRow;
	endif;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="yaSetCriteriaPriority" id="fe0ac6ab-067f-4c6b-b8bc-aa196ca146ef">
