    <JadeMethod name="setParent" id="f802d284-7837-4e21-bc8a-f5d26d455ff4">
        <updating/>
        <source>setParent(_realEDIDataBOLOutLog : CM_EDIDataBOLOutLog) updating;
// ---------------------------------------------------------------------------
// Created:     29 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.myEDIData 			:= _realEDIDataBOLOutLog;
	self.myEDIDataBOLOutLog := _realEDIDataBOLOutLog;

end;</source>
        <Parameter name="_realEDIDataBOLOutLog" type="CM_EDIDataBOLOutLog"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="0adab603-41b7-4ff7-8790-1ac9ba5f7904">
        <updating/>
        <source>setProxy(_realEDIDataBOLOutLog : CM_EDIDataBOLOutLog; _array : HugeStringArray)updating;
//--------------------------------------------------------------
//Created: 26 August 2002 By: cnwgd1
//--------------------------------------------------------------
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
vars
	tmpStr,
	tmpPlace,
	tmpAveraged,
	tmpLoadDate,
	tmpLoadTime : String;
begin

	tmpAveraged := _array[8].trimBlanks;
	if tmpAveraged = '1' then
		self.isAveraged := true;
	endif;

	tmpStr := _array[4];
	if tmpStr.isInteger then
		self.hatch := tmpStr.Integer;
	else
		app.raiseCMException2(ERR_BOL_FIELDS, tmpStr, 'hatch', null, null);
		return;	
	endif;
	//self.hatch				:= _array[4].Integer;
	
	// PAR 10166 validate it is real first
	tmpStr := _array[7];
	if tmpStr.isReal then
		self.jasVolume := tmpStr.Real;
	else
		app.raiseCMException2(ERR_BOL_FIELDS, tmpStr, 'jas Volume', null, null);
		return;	
	endif;
	//self.jasVolume			:= _array[7].Real;
	
	tmpLoadDate				:= _array[5].trimBlanks;
	self.loadDate			:= tmpLoadDate.convertYYYYMMDDToDate();
	
	tmpStr := _array[9].trimBlanks.toUpper;
	if tmpStr.length &gt; 6 then
		app.raiseCMException2(ERR_STRING_TO_LONG, 'load port code', '6', null, null);
		return;
	endif;		
	self.loadPortCode 		:= tmpStr; //_array[9].trimBlanks.toUpper;
	
	tmpLoadTime				:= _array[6].trimBlanks;	
	self.loadTime			:= tmpLoadTime.asTimeJMT();
	
	tmpStr := _array[13].trimBlanks.toUpper;
	//if tmpStr.length &gt; 4 then
	//	app.raiseCMException2(ERR_STRING_TO_LONG, 'grade code', '4', null, null);
	// 17/02/2013 cnwar2 #33521	
	if tmpStr.length &gt; 6 then
		app.raiseCMException2(ERR_STRING_TO_LONG, 'grade code', '6', null, null);
		return;
	endif;		
	self.logGradeCode		:= tmpStr; //_array[13].trimBlanks.toUpper;

	tmpStr := _array[14].trimBlanks;
	if (not tmpStr.isReal) then	
		app.raiseCMException2(ERR_BOL_FIELDS, tmpStr, 'log Length', null, null);
		return;		
	elseif tmpStr.length &gt; 6 then//PAR 18499 
		app.raiseCMException2(ERR_STRING_TO_LONG, 'length', '5', null, null);
		return;
	endif;		
	self.logLength			:= tmpStr.Decimal;//_array[14].Decimal;
//	self.logLengthCode		:= tmpStr; //&lt;-- set to string from file not the above decimal
	//self.logLengthCode := self.logLength.String;//   asStringMeasurementJMT(); // cnwrs1 mar 2006 changed back from above par 11518	
	self.logLengthCode := self.getLogLengthCode( tmpStr ); // for par 18499 cnwrd1 6.3.09
	

	tmpStr := _array[12].trimBlanks.toUpper;
	if tmpStr.length &gt; 6 then	// PAR 23173 (changed from 5 to 6)
		app.raiseCMException2(ERR_STRING_TO_LONG, 'species code', '6', null, null);
		return;
	endif;
	self.logSpeciesCode	:= tmpStr;
	
	tmpStr := _array[16].trimBlanks.toUpper;
	if tmpStr.length &gt; 4 then
		app.raiseCMException2(ERR_STRING_TO_LONG, 'treatment code', '4', null, null);
		return;
	endif;		
	self.logTreatmentCode 	:= tmpStr;//_array[16].trimBlanks.toUpper;
	
	tmpStr := _array[15].trimBlanks.toUpper;
	if tmpStr.length &gt; 4 then
		app.raiseCMException2(ERR_STRING_TO_LONG, 'type code', '4', null, null);
		return;
	endif;		
	self.logTypeCode		:= tmpStr;//_array[15].trimBlanks.toUpper;

	tmpStr := _array[2].trimBlanks.toUpper;
	if tmpStr.length &gt; 20 then
		app.raiseCMException2(ERR_STRING_TO_LONG, 'lot number', '20', null, null);
		return;
	endif;		
	self.lotNo				:= tmpStr; //_array[2].trimBlanks.toUpper;
	
	tmpStr := _array[11].trimBlanks.toUpper;
	if tmpStr.length &gt; 6 then
		app.raiseCMException2(ERR_STRING_TO_LONG, 'operator code', '6', null, null);
		return;
	endif;	
	self.operatorCode		:= tmpStr;//_array[11].trimBlanks.toUpper;

	tmpPlace := _array[3].trimBlanks.toUpper;
	if tmpPlace.length &gt; 1 then
		app.raiseCMException2(ERR_STRING_TO_LONG, 'place', '1', null, null);
		return;
	endif;	
	if tmpPlace.toUpper = 'H' then
		self.place := PlaceHold;
	elseif tmpPlace.toUpper = 'D' then
		self.place := PlaceDeck;
	endif;
	
	self.productCode := app.buildLogProductCode(logSpeciesCode, logGradeCode, logTypeCode, logTreatmentCode, logLengthCode);

	tmpStr := _array[10].trimBlanks.toUpper;
	if tmpStr.length &gt; 20 then
		app.raiseCMException2(ERR_STRING_TO_LONG, 'voyage code', '20', null, null);
		return;
	endif;	
//	self.voyageGlobalCode	:= tmpStr; //_array[10].trimBlanks.toUpper;	// cnwrl1 09/06/2010 PAR 24299 - what it was
	// make sure the manual collection on CM_EDIConfig gets maintained
	self.setVoyageCode( tmpStr );
	
	self.cargoType			:= TI_CargoType_Log;
	
	tmpStr := _array[1].trimBlanks.toUpper;
	if tmpStr.length &gt; 20 then
		app.raiseCMException2(ERR_STRING_TO_LONG, 'id', '20', null, null);
		return;
	endif;
	self.setId(tmpStr);
					
	self.setStatus(TI_STATE_NORMAL);
	self.myEDIData 			:= _realEDIDataBOLOutLog;
	self.myEDIDataBOLOutLog := _realEDIDataBOLOutLog;

	self.setMyVoyageGlobal();
	self.setMyOperator();
	self.setMyTerminal();
	self.setMyLogVoyageStruct();
	self.setMyLogLot();	
		
end;</source>
        <Parameter name="_realEDIDataBOLOutLog" type="CM_EDIDataBOLOutLog"/>
        <Parameter name="_array" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="setVoyageCode" id="27e74028-018d-484b-800f-9abfe177d868">
        <updating/>
        <source>setVoyageCode( _value : String ) updating;
/*
Date			Who		Reason
09 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
11 April 2013	cnwcs5	Make use of local variables
*/
vars
	config			:CM_EDIConfig;
	coll			:CM_EDITIsByVoyageCodeDict;
	code, codeUpper	:String;
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	config := self.myEDIConfig;
	
	if config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
	endif;
	
	code := self.voyageGlobalCode;
	
	// remove the previous non-null value from this collection
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if coll.includesKey( codeUpper, self ) then
			coll.removeKeyEntry( codeUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	code					:= _value[ 1 : self.voyageGlobalCode.maxLength ];
	self.voyageGlobalCode	:= code;
	
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if not coll.includesKey( codeUpper, self ) then
			coll.putAtKey( codeUpper, self, self );
		endif;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="31a01ac7-19b3-48fb-bb62-64e7b41f4cd6">
        <source>validateForCreate(_voyageGlobal : CM_VoyageGlobal ;_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 26 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.validateMe(_voyageGlobal , _passport);
end;</source>
        <Parameter name="_voyageGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="5dbf32ad-e1fa-4ff0-9491-d9848a9f5a93">
        <source>validateForUpdate(_voyageGlobal : CM_VoyageGlobal; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 26 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.validateMe(_voyageGlobal, _passport);
end;</source>
        <Parameter name="_voyageGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="c0d2a1e7-d39f-4d41-9a29-2f3badcd1331">
        <source>validateMe(_voyageGlobal : CM_VoyageGlobal ;_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 26 August 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 15/10/2014	cnwdap1		PAR #35077 Pass self in to product validation, so we can change my productCode if necessary
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	tmpStr,
	lengthCode : String;
	pxyProduct	: CM_ProductLog;
begin
	if self.myEDIData = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'EDIDataBOLOutLog', null, null);
		app.raiseCMException(Input_required_field_ediDtaBol, null, null);
		return;
	endif;
	if self.myEDIDataBOLOutLog = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'EDIDataBOLOutLog', null, null);
		app.raiseCMException(Input_required_field_ediDtaBol, null, null); // cnwdb2	PAR 35364
		return;
	endif;	
	if self.hatch = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'hatch', null, null);
		app.raiseCMException(Input_required_field_hatch, null, null); // cnwdb2	PAR 35364
	endif;	
	if self.lotNo = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Lot No.', null, null);
		app.raiseCMException(Input_required_field_lotNo, null, null); // cnwdb2	PAR 35364
	endif;
	if self.place = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'place', null, null);
		app.raiseCMException(Input_required_field_place, null, null); // cnwdb2	PAR 35364


	endif;
	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'id', null, null);
		app.raiseCMException(Input_required_field_Id, null, null); // cnwdb2	PAR 35364

	endif;
	// PAR 10166 this is not required
	/*if self.jasVolume = null then
		app.raiseCMException1(REQUIRED_FIELD, 'jasVolume', null, null);
	endif;*/
	if self.loadPortCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Load Port Code', null, null);
		app.raiseCMException(Input_required_field_loadPort, null, null); // cnwdb2	PAR 35364

	endif;
	if self.logGradeCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Grade', null, null);
		app.raiseCMException(Input_required_field_grade, null, null); // cnwdb2	PAR 35364

	endif;	
	if self.logLength = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Length', null, null);
		app.raiseCMException(Input_required_field_length, null, null); // cnwdb2	PAR 35364

	endif;	
	if self.logLengthCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'LengthCode', null, null);
		app.raiseCMException(Input_required_field_lngthCode, null, null); // cnwdb2	PAR 35364
	endif;		
	if self.logSpeciesCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Species', null, null);
		app.raiseCMException(Input_required_field_species, null, null); // cnwdb2	PAR 35364
	endif;
	if self.operatorCode = null then
		tmpStr := app.getTerminologyAlternate(null, _passport.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Supplier');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr &amp; ' Code', null, null);
		app.raiseCMException1(Input_required_field_varCode, tmpStr, null, null); // cnwdb2	PAR 35364

	endif;

//	if self.voyageGlobalCode = null then		// cnwrl1 09/06/2010 PAR 24299 - what it was
	if self.getVoyageCode() = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Voyage Code', null, null);
		app.raiseCMException(Input_required_field_VoyCode, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.productCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Specs', null, null);
		app.raiseCMException(Input_required_field_specs, null, null); // cnwdb2	PAR 35364
	endif;	

	if _passport.hasErrors then
		return;
	endif;
	
	if self.myVoyageGlobal = null or self.myVoyageGlobal &lt;&gt; _voyageGlobal then
//		app.raiseCMException1(ERR_INVALID_VOYAGE, self.voyageGlobalCode, null, null);	// cnwrl1 09/06/2010 PAR 24299 - what it was
		app.raiseCMException1(ERR_INVALID_VOYAGE, self.getVoyageCode(), null, null);
		return;							
	endif;
	if self.myOperator = null then
//		app.raiseCMException2(InvalidFieldForVoyage, 'Supplier ' &amp; self.operatorCode, self.voyageGlobalCode, null, null);	// cnwrl1 09/06/2010 PAR 24299 - what it was
		app.raiseCMException2(InvalidFieldForVoyage, 'Supplier ' &amp; self.operatorCode, self.getVoyageCode(), null, null);
		return;							
	endif;
	if self.myTerminal = null then
		app.raiseCMException2(InvalidFieldForVoyage, 'Load Port ' &amp; self.loadPortCode, self.getVoyageCode(), null, null);
		return;				
	endif;
//	if self.myLogVoyage = null then
	if self.myLogVoyageStructure = null then
//		app.raiseCMException2(InvalidFieldForVoyage, 'Load Port ' &amp; self.loadPortCode, self.voyageGlobalCode, null, null);	// cnwrl1 09/06/2010 PAR 24299 - what it was
		app.raiseCMException2(InvalidFieldForVoyage, 'Load Port ' &amp; self.loadPortCode, self.getVoyageCode(), null, null);
		return;							
	endif;
	if (not self.myVoyageGlobal.allVoyageOpsByTermOp.includesKey(self.loadPortCode, self.operatorCode)) then
//		app.raiseCMException2(InvalidFieldForVoyage, 'Supplier ' &amp; self.operatorCode, self.voyageGlobalCode, null, null);	// cnwrl1 09/06/2010 PAR 24299 - what it was
		app.raiseCMException2(InvalidFieldForVoyage, 'Supplier ' &amp; self.operatorCode, self.getVoyageCode(), null, null);
		return;
	endif;
	if self.myLogLot = null then
//		app.raiseCMException2(InvalidFieldForVoyage, 'Lot ' &amp; self.lotNo, self.voyageGlobalCode, null, null);	// cnwrl1 09/06/2010 PAR 24299 - what it was
		app.raiseCMException2(InvalidFieldForVoyage, 'Lot ' &amp; self.lotNo, self.getVoyageCode(), null, null);
		return;
	endif;					

	if _passport.hasErrors then
		return;
	endif;
	
	create pxyProduct transient;
	// This will raise exception if codes not valid
	pxyProduct.setProxyLogProductFromCodes(self.productCode, self.myOperator, 
						self.logSpeciesCode,
						self.logGradeCode,
						self.logTypeCode,
						self.logTreatmentCode,
						self.logLengthCode,
						//_passport, null);						// PAR #35077
						_passport, self);						// PAR #35077
	

epilog
	delete pxyProduct;
end;
</source>
        <Parameter name="_voyageGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
