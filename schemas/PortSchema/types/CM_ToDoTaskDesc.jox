    <JadeMethod name="isForCargoWorkOrder" id="2e64176e-b999-445b-a4ac-9ba1b47bdef5">
        <source>isForCargoWorkOrder() : Boolean;
/*
Purpose:			

Date		Who		Reason
16 November 2023	navab1	BUG 61158
*/

vars
	tranType : CM_TransactionType;
begin
	if self.type &lt;&gt; TODO_TYPE_GROUP_TI then
		return false;
	endif;
	
	
	tranType := self.getTrxTypeOnCompletion();
	if tranType &lt;&gt; null then
		if tranType.isForWorkOrder then
			return true;
		endif;
	endif;
	
	tranType := self.getTrxTypeOnCreation();
	if tranType &lt;&gt; null then
		if tranType.isForWorkOrder then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForGenSetAttachDetach" id="ba1e1a42-3c11-4f8f-a98b-0df824d995d4">
        <source>isForGenSetAttachDetach() : Boolean;
/* ---------------------------------------------------------------------------
Created:	25 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.trxTypeOnCompletion = TRANS_TYPE_AttachGenerator or self.trxTypeOnCompletion = TRANS_TYPE_DetachGenerator then
		return true;
	endif;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isGroupMandatory" id="964efdfe-ff99-48b7-b76b-51afbac33c8b">
        <source>isGroupMandatory(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August	2024	navcs2	Bug 64746: EUP | VAS - Without adding resources for the mandatory resource group, able to complete the job in Thin Client

*/

vars
	resourceGroup 		: CM_ResourceTypeGroup;
	taskCriteria		: CM_TaskCriteria;
	allResources		: CM_ObjectSetActual;
	resourceType 		: CM_Object;
	mandatoryGroupsArr	: ObjectArray;
begin
	taskCriteria := self.allTaskCriteria.getAtKeyGeq(app.myPassport.myTerminal, self.code);
	
	if taskCriteria = null then
		return false;
	endif;
	
	allResources := self.allResourceTypes;
	
	create mandatoryGroupsArr transient;
	
	taskCriteria.allMandatoryResourceGroups.copy(mandatoryGroupsArr);
	
	foreach resourceType in allResources do
		if mandatoryGroupsArr.includes(resourceType.CM_ResourceType.myResourceTypeGroup) then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
