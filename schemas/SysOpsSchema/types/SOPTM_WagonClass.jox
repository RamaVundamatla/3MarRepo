    <JadeMethod name="setupThumbnailDetails" id="6601697f-6f65-4276-95da-972947ebc8b4">
        <source>setupThumbnailDetails();

vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_WagonClassTbl);
//	theForm.zAddColumn('WagonClass Id', 'code', Table.InputType_None, 30);
//	theForm.zAddColumn('Description', 'description', Table.InputType_None, 70);
//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_WagonClassMaint);
	theForm.shtTblInput1.visible := true;
    
    theForm.shtMultiSelect1.caption := 'Restricted Consignees';
	theForm.mulSelect1.formDisplayEntryMethodName := 'displayEntryConsignee';
	theForm.mulSelect1.availableHeading := 'Consignees/ors';
	theForm.mulSelect1.selectedHeading  := 'Restricted Consignees';
	theForm.mulSelect1.setAvailable(app.myRoot.allConsigneeConsignors, true);

	theForm.mulSelect2.formDisplayEntryMethodName := null;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="5f528a62-d61a-49d5-aede-c0a695327039">
        <updating/>
        <source>showThumbnail(pWagonClass : CM_WagonClass) updating;
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 05/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	theForm : SOP_TableMaintForm;
	str1,str2:String;
	first:Boolean;
	consignees : CM_ConsignByCodeDict ;
	consignee : CM_ConsigneeConsignor ;
	code : String;
	
begin
  
	theForm := self.myForm;
	//theForm.tblInput1.clearValues;		// PAR #31155 we've already set the measurement values, so don't clear them

	theForm.tblInput1.setValueByName(ETRow_Code, pWagonClass.code);
	theForm.tblInput1.setValueByName(ETRow_WagonType, pWagonClass.getWagonTypeString);
	theForm.tblInput1.setValueByName(ETRow_AcceptsGenerator, pWagonClass.acceptsGenerator);
	theForm.tblInput1.setValueByName(ETRow_DoorsAccessible, pWagonClass.doorsAccessible);
	theForm.tblInput1.setValueByName(ETRow_LenInUnits, pWagonClass.lenInUnits);
	theForm.tblInput1.setValueByName(ETRow_MaxNumInStack, pWagonClass.maxNumInStack);
	if pWagonClass.myCarrier &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_MyCarrier, pWagonClass.myCarrier.code);
	else
		//01 Apr 2015 - NDL noticed wasn't getting cleared in testing
		theForm.tblInput1.setValueByName(ETRow_MyCarrier, null);
	endif;
	theForm.myAssistant.comboBoxCarrier(theForm.cmbCarrier, pWagonClass.myCarrier);
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pWagonClass.isNotAvailableForEntry);
	//Par 35346 / CCMS 1408
	foreach str1 in pWagonClass.locationIds do
		if (not first) then
			first := true;
			str2 := str1.trimBlanks;
		else
			str2 := str2 &amp; ", " &amp; str1.trimBlanks;
		endif;
	endforeach;
	if pWagonClass.isWellcar then
		theForm.tblInput1.hideRowByName(ETRow_LocationIds,false);
		theForm.tblInput1.showRowByName(ETRow_WellIds,false);
		theForm.tblInput1.setValueByName(ETRow_WellIds, str2);
	else
		theForm.tblInput1.hideRowByName(ETRow_WellIds,false);
		theForm.tblInput1.showRowByName(ETRow_LocationIds,false);
		theForm.tblInput1.setValueByName(ETRow_LocationIds, str2);
	endif;
	
	//10 Mar 2015	NDL	Par 35828
	theForm.tblInput1.setValueByName(ETRow_SealTypes, pWagonClass.getWagonSealTypesString);
	
	create consignees  transient;
	foreach code in pWagonClass.allConsigneeCodesRestricted	do
		consignee := app.myRoot.allConsigneeConsignors[code];
		if consignee &lt;&gt; null then
			if (not consignees.includes(consignee)) then
				consignees.add(consignee);
			endif;
		endif;
	endforeach;
	theForm.mulSelect1.setSelected(consignees);
	self.disableMulSelect1Contents();
	
	self.enableTypeDependantRows( theForm.tblInput1, pWagonClass );
	

	
epilog
	delete consignees;
end;</source>
        <Parameter name="pWagonClass" type="CM_WagonClass"/>
    </JadeMethod>
</Class>
