    <JadeMethod name="getAuditText" id="4a3cc054-0c96-4fb6-abfa-4c4eaadf1f96">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2020	jlgndl1	Initial creation	TFS 49670

*/

vars
	txt		: String;
	tmpStr	: String;
	delTypeGrp  : CM_DelayTypeGroup;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach delTypeGrp in self.allDelayTypeGroups do
		if tmpStr = null then
			tmpStr := delTypeGrp.description;
		else
			tmpStr := tmpStr &amp; ', ' &amp; delTypeGrp.description;
		endif;
	endforeach;
	txt := txt &amp; 'Delay Type Groups' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDelayTypeGroupDesc" id="e7dde994-edb1-4341-9ad7-d39e608dd9b3">
        <source>getDelayTypeGroupDesc() : String;
// ---------------------------------------------------------------------------
// Created:		27 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.allDelayTypeGroups.isEmpty then
		return null;
	endif;
	
	return self.allDelayTypeGroups.first.description;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="762f6a32-bb8a-4d44-a8dc-0768c4c55f80">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
----------   ----------  --------------------------------------------------
Created:	31 January 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	if _attrName = ETRow_Description  then
		return self.description;
	elseif _attrName = ETRow_Code then
		if self.myMachineAvailability &lt;&gt; null then
			return self.myMachineAvailability.code.String;
		endif;	
		return null;
	elseif _attrName = ETRow_RequiresMachine  then
		return self.requiresMachine.String;
	elseif _attrName = ETRow_Operational  then
		return self.isOperational.String;	
	elseif _attrName = ETRow_RequiresVoyage  then
		return self.requiresVoyage.String;	
	elseif _attrName = ETRow_RequiresWorkpoint then
		return self.requiresWorkpoint.String;
	elseif _attrName = ETRow_CanScheduleInAdvance  then
		return self.canScheduleInAdvance.String;	
	elseif _attrName = ETRow_DelayTypeOrder  then
		return self.delayTypeOrder.String;
	elseif _attrName = ETRow_MyVoyageEvent  then	//24 Aug 2018	NDL	TFS 
		if self.myEventTypeToCreate &lt;&gt; null then
			return self.myEventTypeToCreate.name;
		endif;
		return null;
	endif;
	
	return inheritMethod(_attrName, _short);

end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="8b0af3cb-64c8-41fc-8e06-79ff8258ac2b">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2022	navsp1	Initial creation TFS#53569

*/

vars
	n4DelayType	: CMIF_RefCraneDelayTypes;
begin
	if _opsViewTable.isKindOf(CMIF_RefCraneDelayTypes) then
		n4DelayType							:= _opsViewTable.CMIF_RefCraneDelayTypes;
		n4DelayType.gkey  			    	:= n4DelayType.generateFullGKey(self, "");
		n4DelayType.id		       			:= self.description.removeString(" ").removeFileNamInvalidChars()[1:12];
		n4DelayType.description    			:= self.description;
		n4DelayType.life_cycle_state   		:= n4DelayType.n4LifeCycleState(self);
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
