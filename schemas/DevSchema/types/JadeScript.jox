end;
</source>
    </JadeMethod>
    <JadeMethod name="iniFileLoad" id="df63ddbb-8c23-4c02-b44d-3d68fca61276">
        <source>iniFileLoad();

vars
	fileIn : File;
	str : String;
	iniFile : DEV_IniFile;
	iniGroup : DEV_IniGroup;
	iniItem : DEV_IniItem;
	startPos, endPos : Integer;
	obj : Object;
	iniFileIn : String;
	name, value : String;
begin
	iniFileIn := "c:\cnwjmast\t_bin\cnwjmast.ini";
	create fileIn transient;
	fileIn.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	fileIn.fileName := iniFileIn;
	fileIn.mode := File.Mode_Input;
	fileIn.open;
	beginTransaction;
	create iniFile;
	iniFile.set(fileIn.fileName);
	while (not fileIn.endOfFile) do
		str := fileIn.readLine();
		if str[1:1] = ';' or
		   str[1:1] = ':' then
			continue;
		endif;
		if str &lt;&gt; null then
			while str.pos(Tab, 1) &gt; 0 do
				str.replaceChar(Tab, null);
			endwhile;
			startPos := str.pos('[',1);
			if startPos &gt; 0 then
				endPos := str.pos(']',1);
				create iniGroup;
				name := str[startPos+1:endPos-2].trimBlanks;
				iniGroup.set(name, iniFile);
				continue;
			endif;
			startPos := str.pos('=',1);
			if startPos &gt; 0 then
				if startPos &lt; str.length then
					create iniItem persistent;
					name := str[1:startPos-1].trimBlanks;
					value := str[startPos+1:end].trimBlanks;
					if value.toUpper = "TRUE" then
						value := "True";
					elseif value.toUpper = "FALSE" then
						value := "False";
					endif;
					iniItem.set(name, iniGroup, value);
				endif;
			endif;
		endif;
	endwhile;
	commitTransaction;
	fileIn.close;
epilog
	delete fileIn;
end;</source>
    </JadeMethod>
    <JadeMethod name="iniFileUnloadAll" id="12f3bcd4-e351-4699-8ff7-389061f7b861">
        <source>iniFileUnloadAll();

vars
	fileOut : File;
	str : String;
	iniFile : DEV_IniFile;
	iniObject1, iniObject2 : DEV_IniObject;
	iniGroup : DEV_IniGroup;
	iniItem : DEV_IniItem;
	startPos, endPos : Integer;
	obj : Object;
begin
	create fileOut transient;
	fileOut.mode := File.Mode_Output;
	foreach iniFile in DEV_IniFile.instances do 
		fileOut.fileName := iniFile.name&amp;'s';
		fileOut.open;
		fileOut.writeLine(iniFile.name);
		foreach iniObject1 in iniFile.allIniGroups do
			iniGroup := iniObject1.DEV_IniGroup;
			fileOut.writeLine(null);
			fileOut.writeLine('['&amp;iniGroup.name&amp;']');
			foreach iniObject2 in iniGroup.allIniItems do
				iniItem := iniObject2.DEV_IniItem;
				fileOut.writeLine(iniItem.name&amp;' '&amp;'='&amp;' '&amp;iniItem.value);
			endforeach;
		endforeach;
		fileOut.close;
	endforeach;
	fileOut.close;
epilog
	delete fileOut;
end;
</source>
    </JadeMethod>
    <JadeMethod name="initialiseLoadCountries" id="072eadcf-075a-43f5-8675-493a1a466709">
        <source>initialiseLoadCountries();
/*

Purpose:			Load a CSV file of Countries into the database.  Bypass standard process, which is to load in via the
					UN Locode file load in Port Code Maintenance

Date		Who		Reason
26 Jul 2012	cnwkpd1	JMT Implementation - Load countries

*/

vars
	file 			: File;
	pxyCountry, 
	country 		: CM_Country;
	cmifCountry 	: CMIF_Country;
	line, 
	countryCode, 
	countryName 	: String;
	firstLine 		: Boolean;
	cmdFile			: CMDFileOpen;
	
begin
	app.initialize;
	
	create cmdFile transient;
	cmdFile.fileMustExist := true;
	cmdFile.filter := "CSV (*.csv)|*.csv|All files (*.*)|*.*";
	cmdFile.initDir := "c:\temp";
	
	if cmdFile.open &lt;&gt; 0 then
		return;
	endif;
		
	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := cmdFile.fileName;
	file.mode := File.Mode_Input;
	if not file.tryOpen then
		app.msgBox("Could not open file " &amp; file.fileName &amp; " - check file name", "File Error", MsgBox_OK_Only);
		return;
	endif;
	
	// Countries.csv has a header row, then detail rows
	// each row has a 2-character country code, a comma and a country description
	firstLine := true;
	while not file.endOfFile do
		line := file.readLine;
		if not firstLine then
			countryCode := line[1:2];
			countryName := line[4:end];
			write countryCode &amp; Tab &amp; countryName;
			
			country := app.myRoot.allCountries[countryCode];
			if country = null then
				create pxyCountry transient;
			else
				pxyCountry := app.createUpdateProxy(country).CM_Country;
			endif;
			pxyCountry.setProxy(countryCode, countryName, null, null, false, null);
			create cmifCountry transient;
			cmifCountry.myProxyCountry := pxyCountry;
			if country = null then
				app.myTrxCA.trxCreateCountry(cmifCountry, country, app.myPassport);
			else
				app.myTrxUA.trxUpdateCountry(cmifCountry, app.myPassport);
			endif;
				
			if app.myPassport.hasErrorsOrWarnings then
				app.myPassport.inspectModal;
				return;
			endif;
			delete cmifCountry;
			delete pxyCountry;
		endif;
		
		firstLine := false;
	endwhile;

epilog
	delete cmdFile;
	app.finalize();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initialiseLoadHazardousClasses" id="99ae8356-1580-465d-a07c-9399d7b7bba8">
        <source>initialiseLoadHazardousClasses();
/*

Purpose:			Load a CSV file of Hazard Classes into the database

					Expected layout of file is:
					
					Code,Description,Colour

Date		Who		Reason
26/07/2012	cnwkpd1	JMT Implementation - Load ISO Groups
12/05/2015	cnwdap1	PAR #36206 TFS 324/334 Graphical Representation of Hazard Class
*/

vars
	file 			: File;
	pxyHazard,
	hazard			: CM_HazardClass;
	line,
	code,
	desc			: String;
	colour			: Integer;
	firstLine 		: Boolean;
	cmdFile			: CMDFileOpen;
	fields			: StringArray;
	
begin
	app.initialize;
	
	create cmdFile transient;
	cmdFile.fileMustExist := true;
	cmdFile.filter := "CSV (*.csv)|*.csv|All files (*.*)|*.*";
	cmdFile.initDir := "c:\temp";
	
	if cmdFile.open &lt;&gt; 0 then
		return;
	endif;

	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := cmdFile.fileName;
	file.mode := File.Mode_Input;
	if not file.tryOpen then
		app.msgBox("Could not open file " &amp; file.fileName &amp; " - check file name", "File Error", MsgBox_OK_Only);
		return;
	endif;
	
	// Hazard Class.csv has a header row, then detail rows
	create fields transient;
	
	firstLine := true;
	while not file.endOfFile do
		line := file.readLine;
		if not firstLine then
			fields.clear();
			line.csvToStringArray(fields, ",");
			
			if fields.size &lt;&gt; 3 then
				write "&gt;&gt;&gt;&gt; Invalid number of fields in line: " &amp; line;
				return;
			endif;
			
			code := fields[1];
			desc := fields[2];
			colour := fields[3].Integer;
			
			write code &amp; Tab &amp; desc;
			
			hazard := app.myRoot.allHazardClasses[code];
			if hazard = null then
				create pxyHazard transient;
			else
				pxyHazard := app.createUpdateProxy(hazard).CM_HazardClass;
			endif;
			
			pxyHazard.setProxy(code, desc, null, colour, false);
			
			if hazard = null then
				//app.myTrxCA.trxCreateHazardClass(pxyHazard, hazard, app.myPassport);			// PAR #36206
				app.myTrxCA.trxCreateHazardClass(pxyHazard, hazard, null, app.myPassport);		// PAR #36206
			else
				//app.myTrxUA.trxUpdateHazardClass(pxyHazard, app.myPassport);					// PAR #36206
				app.myTrxUA.trxUpdateHazardClass(pxyHazard, null, app.myPassport);				// PAR #36206
			endif;
				
			if app.myPassport.hasErrorsOrWarnings then
				app.myPassport.inspectModal;
				return;
			endif;
			
			delete pxyHazard;
		endif;
		
		firstLine := false;
	endwhile;

epilog
	delete cmdFile;
	delete fields;
	delete pxyHazard;
	app.finalize();
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="initialiseLoadISOGroups" id="e0a16575-79b0-4a80-9ef9-ddb475202c52">
        <source>initialiseLoadISOGroups();
/*

Purpose:			Load a CSV file of ISO Groups into the database

					Expected layout of file is:
					
					Code,Description,Colour,Report Group Order

Date		Who		Reason
26 Jul 2012	cnwkpd1	JMT Implementation - Load ISO Groups

*/

vars
	file 			: File;
	pxyGroup,
	group			: CM_ISOTypeGroup;
	line,
	groupCode,
	desc			: String;
	colour,
	reportOrder		: Integer;
	firstLine 		: Boolean;
	cmdFile			: CMDFileOpen;
	fields			: StringArray;
	coll			: CM_ISOTypeByCodeDict;
	groupColl	: CM_ISOTypeGroupByCodeDict;
	
begin
	app.initialize;
	
	create cmdFile transient;
	cmdFile.fileMustExist := true;
	cmdFile.filter := "CSV (*.csv)|*.csv|All files (*.*)|*.*";
	cmdFile.initDir := "c:\temp";
	
	if cmdFile.open &lt;&gt; 0 then
		return;
	endif;

	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := cmdFile.fileName;
	file.mode := File.Mode_Input;
	if not file.tryOpen then
		app.msgBox("Could not open file " &amp; file.fileName &amp; " - check file name", "File Error", MsgBox_OK_Only);
		return;
	endif;
	
	// ISO Groups.csv has a header row, then detail rows
	create fields transient;
	create coll transient;
	create groupColl transient;
	
	firstLine := true;
	while not file.endOfFile do
		line := file.readLine;
		if not firstLine then
			fields.clear();
			line.csvToStringArray(fields, ",");
			
			if fields.size &lt;&gt; 4 then
				write "&gt;&gt;&gt;&gt; Invalid number of fields in line: " &amp; line;
				return;
			endif;
			
			groupCode := fields[1];
			desc := fields[2];
			colour := fields[3].Integer;
			reportOrder := fields[4].Integer;
			
			write groupCode &amp; Tab &amp; desc;
			
			group := app.myRoot.allISOTypeGroups[groupCode];
			if group = null then
				create pxyGroup transient;
			else
				pxyGroup := app.createUpdateProxy(group).CM_ISOTypeGroup;
			endif;
			
			pxyGroup.setProxy(groupCode, desc, colour, reportOrder, null, null, null, null, coll, groupColl); //cnwrd1 par 30414 25.9.2012
			
			if group = null then
				app.myTrxCA.trxCreateISOTypeGroup(pxyGroup, group, app.myPassport);
			else
				app.myTrxUA.trxUpdateISOTypeGroup(pxyGroup, app.myPassport);
			endif;
				
			if app.myPassport.hasErrorsOrWarnings then
				app.myPassport.inspectModal;
				return;
			endif;
			
			delete pxyGroup;
		endif;
		
		firstLine := false;
	endwhile;

epilog
	delete coll;
	delete cmdFile;
	delete fields;
	delete pxyGroup;
	delete groupColl;
	app.finalize();
	
end;

</source>
    </JadeMethod>
    <JadeMethod name="initialiseLoadPorts" id="5c78f36e-d6a0-42e1-8957-990751ca5bcd">
        <source>initialiseLoadPorts();
/*

Purpose:			Load a CSV file of Ports into the database.  Bypass standard process, which is to load in via the
					UN Locode file load in Port Code Maintenance

Date		Who		Reason
26 Jul 2012	cnwkpd1	JMT Implementation - Load ports

*/

vars
	countryArray, 
	fieldArray 		: StringArray;
	country, 
	code, 
	portCode, 
	entry, 
	name, 
	nameNoDiacritic, 
	details 		: String;
	countryIncluded : Boolean;
	isPort, 
	isRail, 
	isRoad, 
	isAirport, 
	isPostalExchange, 
	isMultiModal, 
	isFixedTransport, 
	isBorderCrossing : Boolean;
	port, 
	pxyPort 		: CM_Port;
	portFile 		: File;
	count 			: Integer;
	cmdFile			: CMDFileOpen;
	
begin
	app.initialize;
	
	create fieldArray transient;
	create countryArray transient;
	// put the countries you'd like ports loaded for in to this array - there are over 80,000 ports in the 
	// UNLOCODE files, so loading them all is probably not a great idea.
	countryArray.add("GE");
	countryArray.add("RU");
	countryArray.add("AM");
	countryArray.add("AZ");
	countryArray.add("TR");
	countryArray.add("UA");
	countryArray.add("GR");
	countryArray.add("BG");
	countryArray.add("RO");
	//countryArray.add("IT");
	//countryArray.add("FR");
	//countryArray.add("PL");
	//countryArray.add("ES");
	//countryArray.add("GB");
	//countryArray.add("DE");
	
	foreach code in countryArray do
		if app.myRoot.allCountries[code] = null then
			write "Invalid country code " &amp; code;
			return;
		endif;
	endforeach;
	
	create cmdFile transient;
	cmdFile.fileMustExist := true;
	cmdFile.filter := "CSV (*.csv)|*.csv|All files (*.*)|*.*";
	cmdFile.initDir := "c:\temp";
	
	if cmdFile.open &lt;&gt; 0 then
		return;
	endif;
		
	create portFile transient;
	portFile.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	portFile.fileName := cmdFile.fileName;
	portFile.mode := File.Mode_Input;
	if not portFile.tryOpen then
		write "Could not open file " &amp; portFile.fileName  &amp; " - please check file name";
		return;
	endif;
	
	// file has two line formats - a country header for each section, then port details for that country
	// country lines are formatted as follows:
	// 			country code 2 chars
	//			blank
	//			country name preceded by a fullstop e.g. .ANDORRA
	// Port lines are formatted as described in F:\Implementation\SourceDataFiles\UNPortList\Contents and Layout of UNLOCODE Files.docx
	while not portFile.endOfFile do
		process.sleep(1);
		// bust the csv line in to the fields it contains - 11 columns
		fieldArray.clear;
		entry := portFile.readLine;
		entry.csvToStringArray(fieldArray, ",");
		// do we have a country or a port line
		country := fieldArray[2].removeString('"');
		name := fieldArray[4].removeString('"');
		if name[1:1] = "." then
			// we have a country - is it one we want?
			if countryArray.includes(country) then
				countryIncluded := true;
			else
				countryIncluded := false;
			endif;
			write "found a country " &amp; country &amp; " include = " &amp; countryIncluded.String;
		else
			// we have a port line - is it for a country we're interested in?
			if countryIncluded and not fieldArray[1].isOneOf("X", "x", "=") then
				// get the relevant details from the port line
				code := fieldArray[3].removeString('"');
				nameNoDiacritic := fieldArray[5].removeString('"');
				details := fieldArray[7].removeString('"');
				portCode := country &amp; code;
				if not details.containsOneOf("1") then
					continue;
				endif;
				write Tab &amp; "port code " &amp; portCode &amp; Tab &amp; nameNoDiacritic &amp; Tab &amp; details;
				count := count + 1;
				// do we have this port code already
				port := app.myRoot.allPorts[country &amp; code];
				if port = null then
					create pxyPort transient;
				else
					pxyPort := app.createUpdateProxy(port).CM_Port;
				endif;
				pxyPort.setProxy(	code &amp; country,
									code,
									nameNoDiacritic,
									null,
									null,
									app.myRoot.allCountries[country],
									null,
									null, //US location
									false,
									details.containsOneOf("1"),
									details.containsOneOf("2"),
									details.containsOneOf("3"),
									details.containsOneOf("4"),
									details.containsOneOf("5"),
									details.containsOneOf("6"),
									details.containsOneOf("7"),
									details.containsOneOf("B")	);
				
				if port = null then
					app.myTrxCA.trxCreatePort(pxyPort, port, app.myPassport);
				else
					app.myTrxUA.trxUpdatePort(pxyPort, app.myPassport);
				endif;
				if app.myPassport.hasErrorsOrWarnings then
					app.myPassport.inspectModal;
					return;
				endif;
				delete pxyPort;
			endif;
		endif;
	endwhile;
	
epilog
	write "created " &amp; count.String &amp; " ports from " &amp; portFile.fileName;
	delete fieldArray;
	delete countryArray;
	delete portFile;
	delete cmdFile;
	app.finalize();
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="initialiseLoadTempConversions" id="a59cb30a-791a-4a84-9270-0e136ca321b4">
        <source>initialiseLoadTempConversions();
/*

Purpose:			Load a CSV file of Temperature Conversions into the database

					Expected layout of file is:
					
					Celsius,Fahrenheit

Date		Who		Reason
26 Jul 2012	cnwkpd1	JMT Implementation - Load Temperature Conversions

*/

vars
	file 			: File;
	pxyTemp,
	temp			: CM_TemperatureConversion;
	line			: String;
	celsius,
	fahrenheit		: Real;
	firstLine 		: Boolean;
	cmdFile			: CMDFileOpen;
	fields			: StringArray;
	
begin
	app.initialize;
	
	create cmdFile transient;
	cmdFile.fileMustExist := true;
	cmdFile.filter := "CSV (*.csv)|*.csv|All files (*.*)|*.*";
	cmdFile.initDir := "c:\temp";
	
	if cmdFile.open &lt;&gt; 0 then
		return;
	endif;

	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := cmdFile.fileName;
	file.mode := File.Mode_Input;
	if not file.tryOpen then
		app.msgBox("Could not open file " &amp; file.fileName &amp; " - check file name", "File Error", MsgBox_OK_Only);
		return;
	endif;
	
	// Temperature Conversions csv has a header row, then detail rows
	create fields transient;
	
	firstLine := true;
	while not file.endOfFile do
		line := file.readLine;
		if not firstLine then
			fields.clear();
			line.csvToStringArray(fields, ",");
			
			if fields.size &lt;&gt; 2 then
				write "&gt;&gt;&gt;&gt; Invalid number of fields in line: " &amp; line;
				return;
			endif;
			
			celsius := fields[1].Real;
			fahrenheit := fields[2].Real;
			
			write celsius.String &amp; Tab &amp; fahrenheit.String;
			
			temp := app.myRoot.allTempsCelsius[celsius];
			if temp = null then
				create pxyTemp transient;
			else
				pxyTemp := app.createUpdateProxy(temp).CM_TemperatureConversion;
			endif;
			
			pxyTemp.setProxy(celsius, fahrenheit);
			
			if temp = null then
				app.myTrxCA.trxCreateTemperatureConversion(pxyTemp, temp, app.myPassport);
			else
				app.myTrxUA.trxUpdateTemperatureConversion(pxyTemp, app.myPassport);
			endif;
				
			if app.myPassport.hasErrorsOrWarnings then
				app.myPassport.inspectModal;
				return;
			endif;
			
			delete pxyTemp;
		endif;
		
		firstLine := false;
	endwhile;

epilog
	delete cmdFile;
	delete fields;
	delete pxyTemp;
	app.finalize();
	
end;
</source>
    </JadeMethod>
