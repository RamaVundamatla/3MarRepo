    <JadeMethod name="showVesselDefinitionForImport" id="dbe58af8-96a6-4d97-9769-de6d932a002a">
        <source>showVesselDefinitionForImport(	_pxyVessel : CM_Vessel;
								_masterMenuAction : CMUI_MenuAction);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 Apr 2012	cnwer1	Initial creation CCMS MES 1035
21 Sep 2012	cnwkpd1	PAR #30392 - add in mouse pointer busy code to make GUI activity obvious

*/

vars
	form 		: SHP_VesselDefinitionForm;

begin
	form := app.loadForm(SHP_VesselDefinitionForm, SHP_Assistant, false, false, false, self.myTerminal, _masterMenuAction).SHP_VesselDefinitionForm;	
	
	if form = null then
		return;
	endif;
	
	form.mousePointer := Window.MousePointer_HourGlass;
	
	form.showWithObjectMode(null, true);
	form.doWindowEvents(0); //force the activate event to trigger because need loadDataFirstTime to execute before doImport
	form.doImport(_pxyVessel);

epilog
	if form &lt;&gt; null then
		form.mousePointer := Window.MousePointer_Default;
	endif;

	
end;</source>
        <Parameter name="_pxyVessel" type="CM_Vessel"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
