    <JadeMethod name="loadChildCombo" id="3e9010b7-563b-4315-91ea-8f1770141fd5">
        <updating/>
        <source>loadChildCombo(_child: CM_Object) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if self.myParent = null then
		return;
	endif;
	
	self.myAssistant.comboBoxVesselTanks(self.cmbChild,self.myParent,_child.CM_VesselTank);
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_child" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="loadChildFields" id="e25d57d0-16f5-4aa3-916c-d773f541f8bb">
        <source>loadChildFields(_child: CM_Object);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	vesselTank : CM_VesselTank; 
begin
	
	vesselTank :=_child.CM_VesselTank;
	self.txtCode.text:=vesselTank.code;
	self.txtDescription.text:=vesselTank.description;
	self.txtRemarks.text:=vesselTank.remarks;
	self.txtVolume.text:=vesselTank.volume.asStringJMT;
	self.cmbContentsType.setIndexFromObject(vesselTank.myVesselTankType);
	
	if vesselTank.isKindOf(CM_VesselTankVoyage) then
		self.txtWeight.text := vesselTank.CM_VesselTankVoyage.actualWeight.asStringJMT;
	endif;
epilog

end;</source>
        <Parameter name="_child" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="loadParentCombo" id="47002afa-36c2-4b05-ac5c-18ba514954eb">
        <source>loadParentCombo(_parent: CM_Object) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if _parent.isKindOf(CM_VesselStructuralElements) then	
		self.myAssistant.comboBoxROROVesselStructure(self.cmbParent,null);
	elseif _parent.isKindOf(CM_VoyageStructuralElements) then
		self.myAssistant.comboBoxCellularVoyages(self.cmbParent,self.myTerminal);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_parent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="c701ea8d-19c5-4240-a876-2ef5e39a8de6">
        <updating/>
        <source>setProxy() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	code,
	description,
	remarks  		:String;
	isMovable 		: Boolean;
	volume,	weight 	: Decimal[12,2];
	contentsType 	: CM_VesselTankContentsType;
	proxyTank 		: CM_VesselTank;
begin
	if self.mode = self.Mode_New then
		if self.myParent.isKindOf(CM_VesselStructuralElements) then //cnwrd1 31874
			create self.myProxyChild as CM_VesselTankVessel transient;
		elseif self.myParent.isKindOf(CM_VoyageStructuralElements) then
			create self.myProxyChild as CM_VesselTankVoyage transient;
		endif;
	endif;
	
	proxyTank:=self.myProxyChild.CM_VesselTank;
	
	code:=self.txtCode.text;
	description:=self.txtDescription.text;
	remarks:=self.txtRemarks.text;
	volume :=self.txtVolume.text.asDecimalJMT;
	contentsType:=self.cmbContentsType.listObject.CM_VesselTankContentsType;
	weight := self.txtWeight.text.asDecimalJMT;
	proxyTank.setProxy(code,description,remarks,volume,contentsType);
	
	if proxyTank.isKindOf(CM_VesselTankVessel) then
		proxyTank.CM_VesselTankVessel.setMyVesselStructure(self.myParent.CM_VesselStructuralElements);
	elseif  proxyTank.isKindOf(CM_VesselTankVoyage) then
		proxyTank.CM_VesselTankVoyage.setMyVoyageStructure(self.myParent.CM_VoyageStructuralElements);
		proxyTank.CM_VesselTankVoyage.setMyActualWeight(weight);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="755a610c-f658-46d3-8bc9-5e5a582c6b55">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	inheritMethod();

	self.lblChild.caption:=app.getErrorString(Tank);
	if self.myParent.isKindOf(CM_VesselStructuralElements) then
		self.lblParent.caption:=app.getErrorString(CM_Vessel_GC);	
	else
		self.lblParent.alignment := 4;
		self.lblParent.caption:=app.getErrorString(CM_VoyageExtra).trimBlanks();	
		//self.lblParent.alignment := 4;
	endif;
	self.setupWeightTextBox();
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSaveNext.enabled:= false;

	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupWeightTextBox" id="14107016-223f-45c8-b77f-5569e93e8998">
        <source>setupWeightTextBox();
/*
Date		    Who			Reason
19 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	volumeTop,	
	weightTop 	: Real;
begin
	volumeTop := self.txtVolume.top;
	weightTop := self.txtWeight.top;	
	if self.myParent.isKindOf(CM_VesselStructuralElements) then			//vessel tank form
		self.txtWeight.visible := false;
		self.lblWeight.visible := false;
		self.txtVolume.top := weightTop;
		self.lblVolume.top := weightTop;
		self.txtRemarks.top := volumeTop;
		self.lblRemarks.top := volumeTop;		
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7cc18d7c-19bb-48f0-9099-fd24f9abed4f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 August 2018 11:51:44.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022879, locale);
	btnSaveNext.translateBubbleHelp(Xlat_0016797, locale);
	btnSaveNext.translateCaption(Xlat_0016798, locale);
	lblCode.translateCaption(Xlat_0015741, locale);
	lblDescription.translateCaption(Xlat_0015742, locale);
	lblRemarks.translateCaption(Xlat_0015743, locale);
	lblType.translateCaption(Xlat_0015744, locale);
	lblVolume.translateCaption(Xlat_0015745, locale);
	lblWeight.translateCaption(Xlat_0016799, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="2709d095-7965-430e-b428-aeefd023aa2d">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
Date		    Who			Reason
06 May 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
		
	if self.myCurrentChild &lt;&gt; null then
		if self.myCurrentChild.isTransient() then
			delete self.myCurrentChild;
		endif;
	endif;	
	
	if self.myParent &lt;&gt; null then
		if self.myParent.isTransient() then
			delete self.myParent;
		endif;
	endif;	
	
	if self.myProxyChild &lt;&gt; null then
		if self.myProxyChild.isTransient() then
			delete self.myProxyChild;
		endif;
	endif;	
	
	inheritMethod();
	
epilog

end;</source>
    </JadeMethod>
</GUIClass>
