    <JadeMethod name="setForCreate" id="b5714d48-b545-4950-bd19-4055d0bc3acb">
        <updating/>
        <source>setForCreate(_pxyCargoItem : CM_CargoScanRecordData) updating;
/*

Purpose:			Sets the fields applicable for create, on our persistent CM_CargoScanRecordData

Parameters:			_pxyCargoItem		CM_CargoScanRecordData		The proxy to use to set properties for the cargo scan

Return Value:		NONE

Date			Who		Reason
30 March 2022	navpw1	Initial creation TFS: 52773
16 July 2022	navmd1	TFS 52777 Tidy up/review code

*/

begin
	self.id	:= _pxyCargoItem.id;
	
	self.setForUpdate(_pxyCargoItem);
	
end;</source>
        <Parameter name="_pxyCargoItem" type="CM_CargoScanRecordData"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9ccac94f-3b87-4eed-9347-51aa3973f13e">
        <updating/>
        <source>setForUpdate(_pxyCargoItem : CM_CargoScanRecordData) updating;
/*

Purpose:			Sets the fields for our CM_CargoScanRecordData

Parameters:			_pxyCargoItem		CM_CargoScanRecordData		The proxy to use to set properties for the cargo scan

Return Value:		NONE

Date			Who		Reason
30 March 2022	navpw1	Initial creation TFS: 52773
16 July 2022	navmd1	TFS 52777 Tidy up/review code

*/

begin
	self.type			:= _pxyCargoItem.type;
	self.alternateId	:= _pxyCargoItem.alternateId;
	
	self.sealTypes.purge();
	self.sealValues.purge();
	
	_pxyCargoItem.sealTypes.copy(self.sealTypes);
	_pxyCargoItem.sealValues.copy(self.sealValues);

end;</source>
        <Parameter name="_pxyCargoItem" type="CM_CargoScanRecordData"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCreate" id="4f9e09f4-9fa2-43f2-ae1c-0066f624a585">
        <updating/>
        <source>setProxyForCreate(_id, _alternateId, _type : String; _sealTypes : StringArray input; _sealValues : HugeStringArray) updating;
/*

Purpose:			Sets the fields applicable for create, on our proxy CM_CargoScanRecordData

Parameters:			_id				String			The cargo id for the cargo scan record
					_type			String			The cargo type abbreviation for the cargo scan record
					_sealTypes		StringArray		The seals types for the cargo scan record
					_sealValues		HugeStringArray The seal values for the cargo scan record

Return Value:		NONE

Date			Who		Reason
30 March 2022	navpw1	Initial creation TFS: 52773
16 July 2022	navmd1	TFS 52777 Tidy up/review code

*/

begin
	self.id			:= _id;
	self.type		:= _type;
	
	self.setProxyForUpdate(_alternateId, _type, _sealTypes, _sealValues);

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_alternateId" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_sealTypes" type="StringArray" usage="input"/>
        <Parameter name="_sealValues" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="setProxyForUpdate" id="a81775a5-3925-4572-b4bb-889f29cc924e">
        <updating/>
        <source>setProxyForUpdate(_alternateId, _type : String; _sealTypes : StringArray input; _sealValues : HugeStringArray) updating;
/*

Purpose:			Sets the fields for our CM_CargoScanRecordData

Parameters:			_alternateId	String			The alternate Id of the cargo item
					_type			String			The cargo type abbreviation for the cargo scan record
					_sealTypes		StringArray		The seals types for the cargo scan record
					_sealValues		HugeStringArray The seal values for the cargo scan record

Return Value:		NONE

Date			Who		Reason
30 March 2022	navpw1	Initial creation TFS: 52773
16 July 2022	navmd1	TFS 52777/52773 Tidy up/review code

*/

begin
	self.alternateId 	:= _alternateId;
	
	if _sealTypes &lt;&gt; null then
		self.sealTypes.purge();
		_sealTypes.copy(self.sealTypes);
	endif;
	
	if _sealValues &lt;&gt; null then
		self.sealValues.purge();
		_sealValues.copy(self.sealValues);
	endif;

end;</source>
        <Parameter name="_alternateId" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_sealTypes" type="StringArray" usage="input"/>
        <Parameter name="_sealValues" type="HugeStringArray"/>
    </JadeMethod>
</Class>
