    <JadeMethod name="getFileForExtract" id="8beb3257-6899-42f7-b074-41d6948bc6e2">
        <updating/>
        <source>getFileForExtract(_defaultFileName, _extension : String): File updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2023	navmv20	TFS 55650 Task 55701: Jade - Contracts XML Extract TRX

*/

vars
	filePath,
	exportPath	: String;
	file		: File; 
	fs 			: CMDFileSave;

begin
	create fs transient;
	fs.dialogTitle := app.getErrorString(Specif_file_invoic_contra_expo);
	fs.resetCurrentPath := true;
	exportPath := "%MiscDir%\"&amp; app.getErrorString(Invoicecontracts) &amp; "\";
	fs.initDir := self.getExportFileNameBase(exportPath);
	fs.fileName := self.getExportFileName(app.actualTimeAppServer,_extension);
	
	if fs.open = 0 then
		create file transient;
		file.fileName := fs.fileName;
		file.mode := File.Mode_Output;

		if (not file.tryOpen) then
			app.raiseCMException1(FileUnavailable, file.fileName, null, null);	
			return null;
		endif;
	endif;

	return file;
epilog

end;</source>
        <Parameter name="_defaultFileName" type="String"/>
        <Parameter name="_extension" type="String"/>
        <ReturnType type="File"/>
    </JadeMethod>
    <JadeMethod name="getFileForLoad" id="19a3ad54-17ad-4a5d-9c04-1898139403d7">
        <updating/>
        <source>getFileForLoad(_extension : String): File updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 January 2023	navmv20	TFS 55650 Task Task 55702: Jade - Contracts XML Load TRX: Jade - Contracts XML Load TRX

*/

vars
	impFile 		: File;
	fileGet 		: CMDFileOpen;
	
begin
	create impFile transient;
	impFile.kind := File.Kind_Unknown_Text;
	
	if impFile = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(File_null_create));
	endif;
	
	create fileGet transient;
	if _extension = ".csv" then
		fileGet.filter 	:= '.csv|*.csv';
	elseif _extension =".xml" then
		fileGet.filter 	:= '.xml|*.xml';
	endif;
	fileGet.fileName 	:= '';
	fileGet.initDir 	:= "C:\";
	
	if fileGet.open = 0 then
		impFile.fileName := fileGet.fileName;
	endif;
	
	if impFile.fileName = null then
		return null;
	else
		return impFile;
	endif;
epilog

end;</source>
        <Parameter name="_extension" type="String"/>
        <ReturnType type="File"/>
    </JadeMethod>
    <JadeMethod name="initCollection" id="a10a2792-6840-4389-878c-08d205dc0e06">
        <source>initCollection();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 January 2023	navmv20	TFS 55650 Task 55701: Jade - Contracts XML Extract TRX
24 October 2024 navrv30 MTN 14674 FR | 54089 - EUP - Invoice Contracts - CSV extract based on the search criteria [NEW SCOPE]
*/

vars
   idx : Integer;
   tbl : CM_DataTable;
   contract : CM_InvoiceContract;
   contractDetails : CM_InvoiceContractDetails;
   contractRateEntryDates : CMIF_ContractRateEntryDates;
begin
	if self.myParent = null then
		return;
	endif;
	
	self.allInvoiceContracts.clear();
	tbl := self.myParent.tblData;
	
	foreach idx in 2 to tbl.rows do
		contract := tbl.accessRow(idx).itemObject.CM_InvoiceContract;
		self.allInvoiceContracts.add(contract);
	endforeach;
	
	//24 October 2024 navrv30 MTN 14674
	tbl.clear();
	tbl := self.myParent.tblDetails;
	foreach idx in 2 to tbl.rows do
		contractDetails := tbl.accessRow(idx).itemObject.CM_InvoiceContractDetails;
		self.allInvContractDetails.add(contractDetails);
	endforeach;
	
	tbl.clear();
	tbl := self.myParent.tblRates;
	foreach idx in 2 to tbl.rows do
		contractRateEntryDates := tbl.accessRow(idx).itemObject.CMIF_ContractRateEntryDates;
		self.allInvContractRates.add(contractRateEntryDates);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadContracts" id="871c5113-d772-48fd-a8d9-e8d587f30f54">
        <updating/>
        <source>loadContracts(_file : File input; _format : Integer) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2023	navmv20	TFS 55650 Task 55702: Jade - Contracts XML Load TRX

*/

vars
 agent 		     : CM_ExtractLoadAgent;
 bank 			 : CM_Bank;
 terminal 		 : CM_Terminal;
 noOfContracts,
 warningsResult	 : Integer;
 
begin
	app.mousePointer := MP_HOURGLASS;
	if (not _file.isAvailable) then
		app.msgBox(app.getErrorString1(File_available, _file.fileName),app.getErrorString(VB_FILE_ERROR),MsgBox_OK_Only);
		return null;
	endif;
	
	create agent transient;
	bank := self.selectedBank;
	
	if bank &lt;&gt; null then
		terminal := bank.terminal;
	else
		terminal := self.myTerminal;
	endif;
	
	while true do
		noOfContracts := app.myTrxCA.trxImportContractFromFile(_file, bank, terminal, _format, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		endif;

		warningsResult := app.showErrorWarningDialog(app.getErrorString(Invoice_contracts), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		
		if app.myPassport.noErrors and
		   warningsResult = IDOK then
			// there must have just been warnings that the user has acknoledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		
		break;
		
	endwhile;

	return noOfContracts;

epilog
	delete agent;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_format" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
