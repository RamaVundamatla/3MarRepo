    <JadeMethod name="setEnableObjects" id="308751c6-955e-417f-9fbb-f9857747c7f1">
        <source>setEnableObjects();
//--------------------------------------------------
// Created:	09 January 2006 By: cnwgd1
//--------------------------------------------------
// Changed on	By			Reason
// ----------	----------	--------------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 Bulk release type no longer translatable, replaced by string constants
vars

begin
	if self.typeMode = BR_TYPE_ROAD_STR	or self.typeMode = BR_TYPE_ALL_STR then								// PAR #27972
		self.btnGeneratePin.enabled := self.viewStatusMode = BR_ACTIVE_STRING or self.viewStatusMode = BR_ACTIVE_STRING &amp; ' &amp; ' &amp; BR_ACTIVE_STRING or self.viewStatusMode = BR_TYPE_ALL_STR;							// PAR #27972
		self.btnDeletePIN.enabled 	:= self.btnGeneratePin.enabled;				
	else
		self.btnGeneratePin.enabled := false;
		self.btnDeletePIN.enabled 	:= false;				

	endif;
	
end;</source>
