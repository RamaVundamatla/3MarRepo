    <JadeMethod name="calculateCargoVolume" id="fcf0ee8c-ab74-4d30-b3fe-8b229d0da25c">
        <source>calculateCargoVolume( _ti : CM_TrackedItem; _items : Integer;  _pieces : Integer ):Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2016	cnwndl1	Initial creation	TFS 2141

*/

vars

	perQtyVolume : Decimal [16,4]; 
	volume : Decimal [16,4];
	
begin

	if self.myVolume = null or self.myVolume.value = 0 then
		return 0;
	endif;

	perQtyVolume := self.myVolume.value; //m3

	if _ti &lt;&gt; null then
		// we want the volume for the whole amount of this cargo item calculated
		volume := _ti.totalQuantity.max(1) * _ti.quantity.max(1) * perQtyVolume;
	else
		// we want the volume for a specific number of these items calculated
		volume := _items.max(1) * _pieces.max(1) * perQtyVolume;
	endif;
	
	return volume;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_items" type="Integer"/>
        <Parameter name="_pieces" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="calculateVolume" id="f05acc4e-f0cd-4cdb-bba5-12c293c94279">
        <source>calculateVolume(_length,
				_width,
				_height : Decimal) : Decimal;
// ---------------------------------------------------------------------------
// Re-Created:  15/4/2009 cnwjo3
//
// Purpose:     calculate volume depending multipliers
//
// ----------   ----------  --------------------------------------------------
vars
	//thisLength,	thisWidth, thisHeight : Decimal[23,13];
	thisVolume : Decimal[23,13];
	volumeMulti : Decimal[23,13];
	lengthMulti : Decimal[23,13];
	
	length, width, height : Decimal[23,13];
	
	precisionError : Boolean;
begin
	precisionError := false;
	on Exception do app.handlePrecisionError(exception, precisionError);
	
	//avoid divide by 0 exception
	lengthMulti := self.getMyLengthMultiplier();
	if lengthMulti &lt;= 0 then
		lengthMulti := 1;
	endif;
	
	length := _length / lengthMulti;
	width := _width / lengthMulti;
	height := _height / lengthMulti;
	
	thisVolume := (length * width * height) / 1000000;  //( 1000000 is the conversion factor for cm3 -&gt; m3)

	volumeMulti := self.getMyVolumeMultiplier();

	if precisionError then
		return 0;
	else
		return thisVolume * volumeMulti;
	endif;
end;</source>
        <Parameter name="_length" type="Decimal"/>
        <Parameter name="_width" type="Decimal"/>
        <Parameter name="_height" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="calculateWeight" id="acc2913c-23fb-42f6-a119-e346232e54a3">
        <source>calculateWeight(_volume,
				_density : Decimal) : Decimal;
// ---------------------------------------------------------------------------
// Created:     10 October 2002 by cnwth2
//
// Purpose:     should use to return Kgs where volume is metres cubed and 
//				density is Kgs per metres cubed
//
// ----------   ----------  --------------------------------------------------
vars

begin
	return _volume * _density;
	
end;</source>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_density" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
