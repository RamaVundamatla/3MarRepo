    <JadeMethod name="comboBoxRepairedReason" id="187f9855-ac94-4b75-ba66-799b6de8d1bf">
        <source>comboBoxRepairedReason(_combo : ComboBox);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details

*/

vars
	repairedReason : CM_RepairReason;
begin
	foreach repairedReason in self.myTerminal.allRepairReasons do
		if not repairedReason.isNotAvalableForEntry then
			_combo.itemObject[_combo.addItem(repairedReason.code &amp; ' - ' &amp; repairedReason.description)] := repairedReason;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox"/>
    </JadeMethod>
