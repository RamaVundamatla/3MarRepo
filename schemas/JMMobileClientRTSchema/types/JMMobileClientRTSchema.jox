    <JadeMethod name="writeSystemColorsToIni" id="bc7def72-f0d7-4fc4-aa6a-bb0c23264611">
        <source>writeSystemColorsToIni(_sysBackColorGeneral, _sysForeColorGeneral, _sysBackColorTable, _sysForeColorTable : Integer);
// -------------------------------------------
// Created 25 January 2006 by cnwdvb1
// -------------------------------------------
vars
	iniFileName	: String;

begin
	iniFileName := app.getIniFileName();
	app.setProfileString(iniFileName, RadioTelemetryIniFileSection, SysBackColorGeneral, _sysBackColorGeneral.String);
	app.setProfileString(iniFileName, RadioTelemetryIniFileSection, SysForeColorGeneral, _sysForeColorGeneral.String);
	app.setProfileString(iniFileName, RadioTelemetryIniFileSection, SysBackColorTable, _sysBackColorTable.String);
	app.setProfileString(iniFileName, RadioTelemetryIniFileSection, SysForeColorTable, _sysForeColorTable.String);
//write "Back=" &amp; _sysBackColorTable.String &amp; ", Fore=" &amp; _sysForeColorTable.String;
end;</source>
        <Parameter name="_sysBackColorGeneral" type="Integer"/>
        <Parameter name="_sysForeColorGeneral" type="Integer"/>
        <Parameter name="_sysBackColorTable" type="Integer"/>
        <Parameter name="_sysForeColorTable" type="Integer"/>
    </JadeMethod>
