    <JadeMethod name="getVesselName" id="3737ed08-07a3-4fd0-99a9-e2a2b416473f">
        <source>getVesselName(): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
26 Oct 2022 navvt20 ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	vCode: String;
	terminal: CM_Terminal;
begin
	vCode := self.getVoyageCode;
	terminal := self.getMyTerminal;
	if vCode &lt;&gt; null and terminal &lt;&gt; null then
		return self.vesselName; // 26 Oct 2022 navvt20 TFS 55084
	endif;
	return null;
epilog

end;</source>
