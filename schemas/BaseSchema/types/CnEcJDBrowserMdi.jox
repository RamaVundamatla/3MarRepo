    <JadeMethod name="confirmRefresh" id="5c46fa28-51a6-4199-82af-d0e28505563e">
        <source>confirmRefresh() protected;
// --------------------------------------------------------------------------------
// Created:		11 July 1999 by cnwdad1
//
// Purpose:		Confirms whether the User wants to refresh the Class Browser listbox.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	browserForm	: Form;

begin
	browserForm	:=	app.getForm('CnEcClassBrowserForm');

	if (browserForm &lt;&gt; null) then
		if (self.confirmAction('Do you want to refresh the Class Browser ?')) then
			app.causeEvent(self.NOTIFY_REFRESH, true, 0);
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formLoad" id="72c52fad-4603-4eb7-9cae-efbd71221358">
        <updating/>
        <source>formLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	date	: Date;
	time	: Time;

begin
	app.appVersion			:=	self.JDBROWSER_VERSION;
	beginTimer(1000, Timer_Continuous, 0);
	lblTimeStamp.caption	:=	" " &amp; date.shortFormat &amp; ",  " &amp; time.String &amp; " ";
	lblSchema.caption		:=	" " &amp; currentSchema.name &amp; " ";
	lblUserId.caption		:=	" " &amp; app.userName() &amp; "@" &amp; app.computerName() &amp; " ";
	picBusy.show3D			:=	Control.Show3D_Use3D;
	picReady.show3D			:=	Control.Show3D_Use3D;
	picBusy.move((statusLine.width - picBusy.width - 8), 0, picBusy.width, picBusy.height);
	picReady.move((statusLine.width - picReady.width - 8), 0, picReady.width, picReady.height);
	lblTimeStamp.move((picReady.left - lblTimeStamp.width - 3), 0, lblTimeStamp.width, lblTimeStamp.height);
	lblSchema.move((lblTimeStamp.left - lblSchema.width - 3), 0, lblSchema.width, lblSchema.height);
	lblUserId.move((lblSchema.left - lblUserId.width - 3), 0, lblUserId.width, lblUserId.height);
	lineRule.move(lineRule.left, lineRule.top, self.width, lineRule.height);
	mnuClassSystem.visible	:=	true;
	picBusy.visible			:=	false;
	picReady.visible		:=	true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="74b6826f-1edc-49f5-a9f4-ecf8d6e8c81f">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	centreWindow();
	self.formLoad();
epilog
	self.statusMsg('');
end;</source>
    </JadeMethod>
    <JadeMethod name="menuDisplay" id="0d4c152d-e928-4b64-8dce-25524eb51c4b">
        <source>menuDisplay(pMessage:String; pClosed:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		09 January 1999 by cnwdad1
//
// Purpose:		Displays a message in the status bar when a menu item is selected.
//
// Parameters:	Message (String) - The message to display (ie. a description of the menu item).
//				Closed (Boolean) - Whether or not the menu item is closed.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (pClosed) then
		statusLine.caption	:=	"Ready.";
	else
		statusLine.caption	:=	pMessage;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pMessage" type="String"/>
        <Parameter name="pClosed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mnuClassBrowser_click" id="43dff1b7-60f3-4361-9f57-b1a62792563f">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuClassBrowser_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 11/07/1999	cnwdad1		Added a check to find an existing instance of the Class
//							Browser form and give it the focus instead of always
//							loading a new copy of the form.
//
// --------------------------------------------------------------------------------
vars
	browserForm		: CnEcClassBrowserForm;
	existingForm	: Form;

begin
	self.statusMsg("Loading class browser...");
	existingForm	:=	app.getForm('CnEcClassBrowserForm');

	if (existingForm = null) then
		create browserForm;
		browserForm.show();
	else
		existingForm.setFocus();
	endif;
epilog
	self.statusMsg("");
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuClassBrowser_select" id="e14dd7c0-114a-4a9b-88db-3daaf2028826">
        <controlMethod name="MenuItem::select"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuClassBrowser_select(menuItem: MenuItem input; closed: Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.menuDisplay("Open the class browser.", closed);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
        <Parameter name="closed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mnuClassSingle_click" id="eea75c7e-103b-48af-8334-d02ff741c814">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuClassSingle_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	classForm	: CnEcGetClassForm;

begin
	self.statusMsg("Loading class list...");
	create classForm;
	classForm.showModal();
epilog
	self.statusMsg("");
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
