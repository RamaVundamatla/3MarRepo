    <JadeMethod name="translateForm" id="e9af55d4-b6f3-4456-9d88-a59fa3342135">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018578, locale);
	btnAddSelected.translateCaption(Xlat_0018579, locale);
	btnCancel.translateCaption(Xlat_0018580, locale);
	btnRemove.translateCaption(Xlat_0018581, locale);
	btnSave.translateCaption(Xlat_0018582, locale);
	btnSearchAll.translateCaption(Xlat_0018583, locale);
	lblResults.translateCaption(Xlat_0018584, locale);
	lblSelectedItems.translateCaption(Xlat_0018585, locale);
	mnuAddSelected.translateCaption(Xlat_0018586, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0018587, locale);
	mnuMainContext.translateCaption(Xlat_0018588, locale);
	mnuRemoveCargo.translateCaption(Xlat_0018589, locale);
end;</source>
    </JadeMethod>
</GUIClass>
