    <JadeMethod name="getProductISOTypeCode" id="707edf00-d093-4959-9629-0d399d504383">
        <source>getProductISOTypeCode() : String;

/*
Purpose:			
Date			Who			Reason
FEB 2017		CNWAB1		Initial creation
25 Mar 2024 	navma1		ChangeRequest 63141: MTN - Code Refactor to improve finding matching cargo items using reserve details
*/

vars
	str 			: String;
	invalidProduct  : Boolean; 
	product			: CM_Product;
	cargoType		: CM_CargoType;
	isoType			: CM_ISOType;
	isoTypeGrp		: CM_ISOTypeGroup;
begin

	on Exception do app.handleDeletedObject(exception, product, invalidProduct); 
	
	
	product := self.myProduct;

	
	if product &lt;&gt; null then
		return product.code;
	endif;
	
	if self.productStr &lt;&gt; null then
		return self.productStr;
	endif;
	
	isoType := self.myISOType;
	
	if isoType &lt;&gt; null then
		return  isoType.code 			 	  &amp; '  - ' &amp; isoType.code;
	endif;
	
	isoTypeGrp := self.myISOGroup;
	
	if isoTypeGrp &lt;&gt; null then
		return  app.getErrorString(ISO_Group) &amp; ' '    &amp; isoTypeGrp.code;	
	endif;
	
	
	if str = null then		//25.03.2024 navma1 #63141
		
		cargoType := self.myCargoType;
		if cargoType &lt;&gt; null and cargoType.id &lt;&gt; TI_CargoType_Container and  not cargoType.isSubCargoTypeRequired then
			str := cargoType.abbreviation;
		endif;
	endif;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProductISOTypeDescr" id="dc51a06b-af2e-481a-9631-5437bd2d99cf">
        <source>getProductISOTypeDescr() : String;
/*
----------   ----------  --------------------------------------------------
Created:	07 May 2007 By cnwth2

Purpose:	Users my either select a CM_Product that exists in the system or enter free text for this.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
25 Mar 2024 navma1	ChangeRequest 63141: MTN - Code Refactor to improve finding matching cargo items using reserve details
31/10/2025	jlizm1	MTN 36255 Rotabox Assign Release To Vessel
*/
vars
	str 			: String;
	invalidProduct  : Boolean; 
	product			: CM_Product;
	cargoType		: CM_CargoType;
	isoType			: CM_ISOType;
	isoTypeGrp		: CM_ISOTypeGroup;
begin

	on Exception do app.handleDeletedObject(exception, product, invalidProduct); 
	
	isoType := self.myISOType;				 //25.03.2024 navma1 #63141
	
	if isoType &lt;&gt; null then
		str := isoType.code 			     &amp; '  - ' &amp; isoType.description;
		
		if isoType.isRotatable then
			product := self.myProduct;
			if product &lt;&gt; null then
				str := str &amp; " - " &amp; product.description; 
				return str;
			endif;
			
			cargoType := self.myContentsCargoType;
			if cargoType &lt;&gt; null then
				str := str &amp; " - " &amp; cargoType.description; 
				return str;
			endif;
		endif;
		
		return str;
	endif;
	
	isoTypeGrp := self.myISOGroup;			 //25.03.2024 navma1 #63141
	
	if isoTypeGrp &lt;&gt; null then
		str := app.getErrorString(ISO_Group) &amp; ' '    &amp; isoTypeGrp.code;	
		return str;
	endif;
	
	product := self.myProduct;				 //25.03.2024 navma1 #63141
	
	if product &lt;&gt; null then
		str := product.description; 
		return str;
	endif;
	
	if self.productStr &lt;&gt; null then
		str := self.productStr;
		return str;
	endif;
	
	cargoType := self.myCargoType;			//25.03.2024 navma1 #63141
	
	//epr par 34406 25/6/14
	if str = null then
		if cargoType &lt;&gt; null and cargoType.id &lt;&gt; TI_CargoType_Container and  not cargoType.isSubCargoTypeRequired then
			str := cargoType.description;
		endif;
	endif;
	
	
	if str = null then		
		if cargoType &lt;&gt; null and cargoType.id = TI_CargoType_Container then
			str := app.getErrorString(Unspecified_ISO_Type);
		elseif cargoType = null or ( cargoType &lt;&gt; null and  cargoType.isSubCargoTypeRequired) then
			str := app.getErrorString(Unspecified_product);
		endif;
	endif;
	
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQuantityRemaining" id="96f45a09-72e8-45a9-8821-e79dd0bdf893">
        <source>getQuantityRemaining() : Integer
;
/*
----------   ----------  --------------------------------------------------
Created:	05 June 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	result		: Integer;
begin
	result := self.totalRequested - self.allTrackedItemsReleased.size;
	if result &lt; 0 then
		result := 0;
	endif;
	
	return result;

end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReleaseDetails" id="40bd7bb1-9b88-4d69-8df5-cd7ee67f0b4a">
        <source>getReleaseDetails() : String;
// ---------------------------------------------------------------------------
// Created:		25 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars	
	str		: String;
begin
		str := 'ISO Type' &amp; Tab &amp; Tab &amp; self.getISOCode &amp; CrLf &amp;
		       'AVA Grade' &amp; Tab &amp; self.getAvailGradesForReport() &amp; CrLf &amp;
			   'Remarks' &amp; Tab &amp; self.remarks &amp; CrLf;
		
	
	
