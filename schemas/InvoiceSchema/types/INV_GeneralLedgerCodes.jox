    <JadeMethod name="addObjectToTable" id="2e10da61-b07b-4f44-87d8-a5ee2480a956">
        <updating/>
        <source>addObjectToTable(_obj: Object; _numItems: Integer io; _breakOut: Boolean io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2015	cnwmc5	Initial creation	PAR 35858

*/

vars

begin
	if not _obj.isKindOf(CM_GLCode) then
		return;
	endif;
	
	if _obj.CM_GLCode.bank &lt;&gt; null
	and not _obj.CM_GLCode.bank.terminal = self.myTerminal then
		return;
	endif;
	
	inheritMethod(_obj, _numItems, _breakOut);

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addObjectsToTable" id="c9ad9cdd-e61e-49c7-b56a-ae2aac056320">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aGLCode : CM_GLCode;
	theGLCodes :	CM_GLCodeByCodeDict;
	tmpPassport	: CM_Passport;
	breakOut	: Boolean;
begin

	self.setMyDataClass();
	// 35872 do change of business unit
	self.myCurrentBank := self.cmbBank.listObject.CM_Bank;
	if self.myCurrentBank = null then
		return;
	endif;
//	TFS 2682	self.caption := self.myCurrentBank.code &amp; " GL Codes";
	self.setCaption("GL Codes " &amp; self.myCurrentBank.code);

	theGLCodes := self.myCurrentBank.glCodes;
	tmpPassport := app.myPassport;
	
	// do need to show all codes to maintain the 'not available for entry' option
	foreach aGLCode in theGLCodes do
		if self.includeObject(aGLCode, tmpPassport) then
			self.addObjectToTable(aGLCode, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="643c5f82-f555-476c-b0ae-82c0156a29e1">
        <source>addToolbarControls() protected;
/*

Purpose:			Adds controls to the toolbar

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
14 September 2021	navpw1	Initial creation TFS: 51912

*/

vars
	toolbar			: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
/*	//05/06/2024	navkc1 CR 63736 Task 63770 - Replaced with new control
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmFilter, CMUI_Toolbar.Control_Alignment_Left);
	
	self.txtFilterBox.parent := self.frmFilter;
	self.txtFilterBox.visible := true;
	self.txtFilterBox.left := 0;
	self.txtFilterBox.top := 2;
	
	toolbar.addButton(self.btnClearFilter, CMUI_Toolbar.Control_Alignment_Left);
*/
	self.frmToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);						//05/06/2024	navkc1 CR 63736 Task 63770
	self.frmToolbar.addFrame(self.frmTableFilter, CMUI_Toolbar.Control_Alignment_Left);		//05/06/2024	navkc1 CR 63736 Task 63770
end;</source>
        <access>protected</access>
    </JadeMethod>
