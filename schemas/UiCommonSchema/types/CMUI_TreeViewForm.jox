    <JadeMethod name="showForObject" id="8f8fa575-5720-4030-a469-726c7ae2e58d">
        <updating/>
        <source>showForObject(_obj : CM_Object; _mode : Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	27 April 2007 By cnwth2

Purpose:	_obj should be persistent entity for view mode, transient place holder for add mode and
			proxy object for update mode. This is validated in setupForm.
			
			_mode should = self.Mode_XXX class constant

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.mode := _mode;
	self.isShowingForObject := true;
	self.myMasterObject := _obj;
	
	//if adding or editing this will be populated in the 
	//self.setupForm method (needs to happen after self.show call)
	self.myMasterProxyObject := null;

	self.show();
end;


</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
