<Class name="TST_trxCreateInOut" id="8e5eddb6-7fec-4273-9033-d03a14ac945d">
    <superclass name="TST_RecordObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="testObjects"/>
    <ExplicitInverseRef name="allIntFaceObjects" id="b28fe0cc-0c2d-4b40-8cc1-2eba04bc40ea">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CMIF_TIObjectArray"/>
        <access>readonly</access>
        <Inverse name="CMIF_Object::myTestRecordObject"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myIntFaceCommon" id="082c3c85-5847-4541-bb0f-b4ad1a477ff2">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CMIF_InOutCommon"/>
        <access>readonly</access>
        <Inverse name="CMIF_Object::myTestRecordObject"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myTerminal" id="e64f6513-9e73-4d3a-a981-49a2b7b2343f">
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="init" id="191f5dad-dec1-4e8d-9db2-d91e0c4c2e84">
        <updating/>
        <source>init(pIntFaceCommon : CMIF_InOutCommon input; pIntFaceArray : CMIF_TIObjectArray; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     17 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	pxyIntFaceObj,
	realIntFaceObj		: CMIF_TIObject;

begin

	self.testCode		:= _passport.testCode;
	self.testDescription:= _passport.testDescription;
	
	self.myTerminal	:= _passport.myTerminal;
	
	// need to store away terminal config settings
	
	self.myIntFaceCommon := pIntFaceCommon.cloneForTestRecorder();

	foreach pxyIntFaceObj in pIntFaceArray do
		realIntFaceObj := pxyIntFaceObj.cloneForTestRecorder();
		self.allIntFaceObjects.add(realIntFaceObj);
	endforeach;

end;</source>
        <Parameter name="pIntFaceCommon" type="CMIF_InOutCommon" usage="input"/>
        <Parameter name="pIntFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="runTest" id="a5539300-f778-456f-801b-87b1b17653b8">
        <source>runTest(_passport : CM_Passport input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     17 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpIntFaceArray		: CMIF_TIObjectArray;
	pxyIntFaceCommon	: CMIF_InOutCommon;
	pxyIntFaceObj,
	realIntFaceObj		: CMIF_TIObject;
	result				: Integer;

begin

	_passport.setMyTerminal(self.myTerminal);
	
	// need to reset terminal config settings
	
	create tmpIntFaceArray transient;
	
	pxyIntFaceCommon := self.myIntFaceCommon.cloneForTest();

	foreach realIntFaceObj in self.allIntFaceObjects do
		pxyIntFaceObj := realIntFaceObj.cloneForTest();
		pxyIntFaceObj.setMyInOutCommon(pxyIntFaceCommon);
		tmpIntFaceArray.add(pxyIntFaceObj);
	endforeach;
	
	while true do
		//app.myTrxCA.trxCreateInOutVehicle(pxyIntFaceCommon, _passport);		//cnwmc5 - 22 Jan 2015 - PAR 35518
		app.myTrxCA.trxCreateInOut(pxyIntFaceCommon, tmpIntFaceArray, _passport, null); //TFS 53107, AjitM, navam1
		if _passport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			write class.name &amp; '::' &amp; method.name &amp; ' completed ok';
			break;
		else
			//result := app.showErrorWarningDialog($GateInOut, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAck);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				write class.name &amp; '::' &amp; method.name &amp; ' warnings acknowledged';
				_passport.warningsAcknowledged	:= true;
				continue;
			endif;
			write class.name &amp; '::' &amp; method.name &amp; '  errors found';
			//self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return false;
	endwhile;
	
	// need some validation stuff after this is called
	// do a dump as xml of orig and new ones and can compare
	return true;

epilog
	if tmpIntFaceArray = null then
	endif;
	delete tmpIntFaceArray;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
