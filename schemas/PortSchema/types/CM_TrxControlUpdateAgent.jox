    <JadeMethod name="trxUpdateWeightAutoplan" id="db7b31ac-a9d4-47a2-9872-0cfef90eeb9a">
        <updating/>
        <source>trxUpdateWeightAutoplan(_machine : CM_Machine; 
																				_task : CM_RTQueueTask input;
																				_weight : Integer;
																				_isCertified : Boolean; 
																				_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Nov 2016	cnwrh7	Initial creation
06 Nov 2024	navdap1	MTN-18897 EUP | FR 53485 EUP - Warehouse Yard Allocation
*/

vars
	cargo : CM_TrackedItem;
	
	newLocation													: CM_LocationsController;
	moveController											: CMIF_MoveController;
	plannedToGCArea : Boolean;		// MTN-18897
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

beginTransaction;
	//Update weight to complete Tasks
	cargo :=_task.ti;
	app.myUtilityUA.utlUpdateMachineWeighContainer(_machine,cargo,_weight,_isCertified,_passport);					
	//Auto Plan
	newLocation:=app.autoPlanJobTiYA(cargo.myTerminal,null,null,null,cargo,_task.myEntry.myWorkListEntry.job,true,null,plannedToGCArea);	// MTN-18897
	if newLocation &lt;&gt; null and newLocation &lt;&gt; _task.targetLocation   then
		create moveController transient;
		moveController.setMoveMode(QUEUE_MODE);
		moveController.setMyTrackedItem(cargo);
		moveController.setMyWorkListEntry(_task.myEntry.myWorkListEntry);
		moveController.setMyToPrimaryLocation(newLocation);
		moveController.setMyPassport(_passport);
		moveController.isPlannedToFullGCArea := plannedToGCArea;		// MTN-18897
		_task.changeTargetLocation(moveController,true);
	endif;
epilog
	delete moveController;
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_task" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_weight" type="Integer"/>
        <Parameter name="_isCertified" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
