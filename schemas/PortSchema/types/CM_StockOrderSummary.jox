    <JadeMethod name="calAllocatedSoFar" id="f1b997fa-59c7-4495-96c4-c6b0ffca1e83">
        <source>calAllocatedSoFar() : Decimal;
//--------------------------------------------------------------
//Created: 08 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	stockOrder		: CM_StockOrderLine;
	numAllocated	: Decimal[16,4];
	
begin

	foreach stockOrder in self.allStockOrderLines do
		numAllocated := numAllocated + stockOrder.calAllocatedAmount(); 
	endforeach;
	
	return numAllocated;

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="calAllocatedTotal" id="f5950161-6776-4182-b99e-92552dddfd21">
        <source>calAllocatedTotal() : Real;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	lineQty,
	summQty : Real;
	allocation : CM_StockOrderSummaryAlloc;
	stockOrder : CM_StockOrderLine;
begin

	foreach allocation in self.allStockAllocations do
		//amount allocated directly to summary
		summQty := summQty + allocation.allocQuantity;
	endforeach;
	
	//Total amount allocated to lines including split
	foreach stockOrder in self.allStockOrderLines do
		lineQty := lineQty + stockOrder.calLineOnlyAllocations();
	endforeach;	



	return summQty + lineQty;

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="calLineAllocRemAll" id="6a846f22-b9f4-4a91-9c9f-9bc93108ad5e">
        <source>calLineAllocRemAll(_sohLocn : CM_SOHLocation) : Real;
//--------------------------------------------------------------
//Created: 08 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	stockOrder		: CM_StockOrderLine;
	numAllocated	: Real;
begin

	foreach stockOrder in self.allStockOrderLines do
		numAllocated := numAllocated + stockOrder.callAllocOfRemAll(_sohLocn); 
	endforeach;

	return numAllocated;

end;</source>
        <Parameter name="_sohLocn" type="CM_SOHLocation"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="clearAllAllocatedLines" id="f0904a0f-7ed6-4614-993f-413d51d45e1a">
        <updating/>
        <source>clearAllAllocatedLines() updating;
//--------------------------------------------------------------
//Created: 09 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	stockOrder		: CM_StockOrderLine;
begin

	foreach stockOrder in self.allStockOrderLines do
		stockOrder.clearAllocatedForSummary();
		global.causeEvent(LogVoyageOps_Update_Event, false, stockOrder);
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="6d6684be-2f8e-4201-84ba-92f502cbe6ea">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	if _attrName = ETRow_LogGradeCode then
		return self.myProduct.getDisplayStringForAttribute(_attrName, _short);
	elseif _attrName = ETRow_LogSpeciesCode then
		return self.myProduct.getDisplayStringForAttribute(_attrName, _short);
	elseif _attrName = ETRow_LogTypeCode then
		return self.myProduct.getDisplayStringForAttribute(_attrName, _short);
	elseif _attrName = ETRow_LogTreatmentCode then
		return self.myProduct.getDisplayStringForAttribute(_attrName, _short);
	elseif _attrName = ETRow_LogLengthCode then
		return self.myProduct.getDisplayStringForAttribute(_attrName, _short);
	elseif _attrName = ETRow_ReqdQuantity then
		return self.reqdQuantity.Integer.String;												
	elseif _attrName = ETRow_AllocVolume then
		return self.calAllocatedTotal().jasVolumeString;		
		//return self.calAllocatedSoFar().jasVolumeString.cnEcStripDecimalZeros;				
	elseif _attrName = ETRow_MyLogLot then
		return null;
	elseif _attrName = ETRow_OrderNo then
		return null;				
	elseif _attrName = ETRow_MyOperator then
		return self.myOperator.code;						
	elseif _attrName = ETRow_MyVoyage then
		return self.myVoyage.code;
	elseif _attrName = ETRow_ConsigneeCode then
		return null;								
	elseif _attrName = ETRow_DischargePort then
		return null;								
	elseif _attrName = ETRow_Specifications then
		return self.myProduct.code;								
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoLogVoyOps" id="3a04fc49-56ee-43b2-bbd1-165ca1f64ca7">
        <source>getExtraInfoLogVoyOps(_array: HugeStringArray input ;_terminalForTerminology : CM_Terminal);
//--------------------------------------------------------------
//Created: 07 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	_array.add("Summary Required Quantity" &amp; Tab &amp; self.reqdQuantity.String);		
	self.myProduct.getExtraInfoOLD(_array);
	self.myStockOrderHeader.getExtraInfoLogVoyOps(_array,_terminalForTerminology);
end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminalForTerminology" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="39c39b15-5ab8-48fc-b021-685862abb325">
        <source>getMyTerminal(): CM_Terminal;
//--------------------------------------------------------------
//Created: 06 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return self.myStockOrderHeader.myTerminal;

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getSummaryAllocationObject" id="c1150e8f-068c-4a1c-a559-bc17a88f5294">
        <source>getSummaryAllocationObject(_sohLocn : CM_SOHLocation) : CM_StockOrderSummaryAlloc;
//--------------------------------------------------------------
//Created: 05 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	allocation : CM_StockOrderSummaryAlloc;
begin
	foreach allocation in self.allStockAllocations where allocation.mySOHLocation = _sohLocn do
		return allocation;
	endforeach;
	return null;
end;</source>
        <Parameter name="_sohLocn" type="CM_SOHLocation"/>
        <ReturnType type="CM_StockOrderSummaryAlloc"/>
    </JadeMethod>
    <JadeMethod name="reqdQuantity" id="3b787e16-3702-4f9a-8cd6-acd718dc791b">
        <methodInvocation>mapping</methodInvocation>
        <source>reqdQuantity(set: Boolean; _value: Decimal io) mapping;
// ---------------------------------------------------------------------------
// Created:     06 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	line		: CM_StockOrderLine;
	ls			: Boolean;
		
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	_value := 0;
	app.cmsBeginLoad(ls);
	foreach line in self.allStockOrderLines do
		sharedLock(line);
		_value := _value + line.getReqdQuantity();
	endforeach;	

epilog
	app.cmsEndLoad(ls);

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="9523ef65-9ea9-465d-aaf4-8c58f74b3869">
        <updating/>
        <source>setForCreate(_operator : CM_Operator; _product : CM_Product; _voyage : CM_Voyage;
			_header : CM_StockOrderHeader) updating;
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.setForUpdate(_operator, _product, _voyage);
	self.myStockOrderHeader	:= _header;
	
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_header" type="CM_StockOrderHeader"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6ba35815-802b-466c-afa5-22e595342f83">
        <updating/>
        <source>setForUpdate(_operator : CM_Operator; _product : CM_Product; _voyage : CM_Voyage) updating;
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.raiseExceptionIfTransient(method);
	self.myOperator := _operator;
	self.myProduct := _product;
	self.myVoyage := _voyage;
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
