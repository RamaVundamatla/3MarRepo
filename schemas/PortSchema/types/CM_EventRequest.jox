    <JadeMethod name="updateStatusAndStatusInfo" id="8008e8f6-a5aa-47dd-b6c0-8d87ff58ad8f">
        <updating/>
        <source>updateStatusAndStatusInfo(_newStatus : Integer; _statusInfo : String)updating;
//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
// 08/12/2010 	cnwcs5	CCMS MES 1112 / Par 24464 - allow for new status
vars

begin
	
	if _newStatus &lt; EventRequestPending or _newStatus &gt; EventRequestCargoDeleted then	// 08/12/2010 cnwcs5 ccms mes 1112/par 24664
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid status');
	endif;
	
	self.status 			:= _newStatus;	
	self.statusDT 			:= app.serverTimestampAtTrxStart;
	self.statusInformation 	:= _statusInfo;

end;</source>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_statusInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="c19fd203-b7bf-487a-b825-d2940621a88b">
        <source>validateCreate(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.validateMe(_passport);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="1b6e6a10-7b54-4e19-8574-089351d9582a">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	address : String;
begin
	if self.myOrganisation = null then
		app.raiseCMException(Input_required_field_org, ETRow_MyOrganisation, null); // cnwdb2	PAR 35364
	endif;

	if self.myTerminal = null then
		app.raiseCMException(Input_required_field_terminal, ETRow_UserCode, null); // cnwdb2	PAR 35364
	endif;

	if self.type &lt;= EventRequestTypeNull
	or self.type &gt;= EventRequestTypeMax then
		app.raiseCMException(Input_required_field_type, null, null); // cnwdb2	PAR 35364
	endif;	

	if self.myUser = null then
		app.raiseCMException(Input_required_field_Usr, ETRow_UserCode, null); // cnwdb2	PAR 35364
	endif;
	
	foreach address in self.allEmailAddresses do
		app.validateEmailAddress(address);
	endforeach;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="eb5f0c15-a532-48c8-abea-9a165cd9551f">
        <source>validateUpdate(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.validateMe(_passport);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
