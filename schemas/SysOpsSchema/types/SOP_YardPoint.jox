    <JadeMethod name="btnClear_click" id="29392a61-6b76-4cd9-8bf3-006fe7615a8a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClear_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.frmPoint.clearGraphics();
	self.dragPoint1 := null;
	self.dragPoint2 := null;
	self.dragPoint3 := null;
	self.dragPoint1Index := null;
	self.dragPoint2Index := null;
	self.dragPoint3Index := null;
	self.theGraphic := null;
	self.allPoints.clear();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
