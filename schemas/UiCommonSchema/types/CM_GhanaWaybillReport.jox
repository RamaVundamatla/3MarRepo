/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2015	cnwndl1	Initial creation Par 36777

*/

vars

	parentWidth : Real;
	frame : CMUI_Frame;
	
	topMMs : Real;
	leftMMs : Real;
	rightMMs : Real;
	bottomMMs : Real;

begin

	frame := self.frmSect5;

	parentWidth := frame.width - 1;

//	if _doLayoutCheck then
//		frame.borderStyle := 1;
//		frame.caption := frame.name &amp; "@" &amp; leftMMs.String &amp; "," &amp; topMMs.String &amp; "-" &amp; rightMMs.String &amp; "," &amp; bottomMMs.String &amp; "mm";
//	else
		frame.caption := null;
		frame.borderStyle := 0;	
//	endif;
	
//	if not _doLayoutCheck then
		self.pic30.picture := myWaybillPrintDetail.pdf147BarcodePic;
//	endif;
	
	self.lblVehicleExit.top := 2;
	self.lblVehicleExit.left := 3 * self.pixelsPerMM;
	
	self.frmVehicleExit.top := 6 * self.pixelsPerMM;
	self.frmVehicleExit.left := 3 * self.pixelsPerMM;
	self.frmVehicleExit.height := 8 * self.pixelsPerMM;
	self.frmVehicleExit.width := 78 * self.pixelsPerMM;
	
	topMMs := 1;
	bottomMMs := 14;
	leftMMs := 101;
	rightMMs := 170;
	self.movePicture( frame, self.pic30, topMMs, leftMMs, rightMMs, bottomMMs, _doLayoutCheck );
	
	frame.height := ( bottomMMs +.5 ) * self.pixelsPerMM;
	
	self.addNewPageFrameIfRequired( frame );
	
epilog

end;</source>
        <Parameter name="_doLayoutCheck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printReport" id="c7c89206-16b7-4490-9708-28334555beaa">
        <updating/>
        <source>printReport() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	doLayoutCheck : Boolean;
	extraFrame : CMUI_Frame;
	pageNum : Integer;

begin

//	if process.isNDL then
//		doLayoutCheck := true;
//	endif;
	
	/*
	Email from Paul outlining paper size = A$ with 1 cm borders left, right
	and bottom, with 4.5 cm at top.
	A$ is 29.7 cm high and 21 cm wide so
	29.7 - 4.5 - 1.0 = 24.2 useable height
	21.0 - 1.0 - 1.0 = 19.0 useable width
	
	Seems to be an automatic 5mm boundary.
	*/
	
	self.pixelsPerMM := 756 / 200;
	
	app.printer.rightMargin := 0;
	app.printer.topOfPage := 40;	//mm  + auto 4mm = 45mm
	app.printer.leftMargin := 5;	// mm  + auto 4mm = 10mm
	
	self.frameTopOffset := ( app.printer.topOfPage + 5 );
	self.frameLeftOffset := ( app.printer.leftMargin + 5 );
	
	self.frmMain.top := 0;
	self.frmMain.left := 0;
	self.frmMain.width := 19.0 * 10 * self.pixelsPerMM;
	self.frmMain.height := 24.2 * 10 * self.pixelsPerMM;
	
	self.pageCount := 1;
	
	if doLayoutCheck then
		app.printer.printPreview := true;
	endif;

	self.populateSect1( doLayoutCheck );
	
	self.populateFooter( doLayoutCheck );
	
	self.populateSect2( doLayoutCheck );
	
	self.populateSect3( doLayoutCheck );
	
	self.populateSect4( doLayoutCheck );
	
	self.populateSect5( doLayoutCheck );
	
	if self.pageCount = 1 then
		app.printer.print( self.frmMain );
		
	else
		self.lblPageNo.caption := "Page 1 of " &amp; pageCount.String;
		
		foreach pageNum in 2 to self.pageCount do
			extraFrame := self.frmMain.getControl( pageNum ).CMUI_Frame;
			if extraFrame &lt;&gt; null then
				extraFrame.visible := false;
			endif;
		endforeach;
		
		app.printer.print( self.frmMain );
		
		self.frmMain.visible := false;
		
		foreach pageNum in 2 to self.pageCount do
			extraFrame := self.frmMain.getControl( pageNum ).CMUI_Frame;
			if extraFrame &lt;&gt; null then
				extraFrame.visible := true;
				frmFooter.parent := extraFrame;
				app.printer.print( extraFrame );
				extraFrame.visible := false;
			endif;
		endforeach;
	
	endif;
		
epilog

end;</source>
    </JadeMethod>
</GUIClass>
