    <JadeMethod name="setForUpdate" id="bc70c2eb-e86b-40db-b473-88127bd01713">
        <updating/>
        <source>setForUpdate(_pxyEventType : CM_EventType) updating;
/*
----------   ----------  --------------------------------------------------
Created:	14 February 2007 By cnwth2

Purpose:	

Changed On	Changed By	Reason
----------	----------	--------------------------------------------------
03 Nov 2015	cnwkpd1		PAR #37128 - Check for a real change to any properties used 
						as dictionary keys or inverses for performance during the upgrade
29 Jul 2022	jlizm1		TFS 54165 EDI Voyage Events

*/

vars
	realInterestedWarn,
	pxyInterestedWarn		: CM_InterestedWarning;

begin
	self.raiseExceptionIfTransient(method);
	if self.type &lt;&gt;_pxyEventType.type then
		self.type				:= _pxyEventType.type;
	endif;
	if self.name &lt;&gt;_pxyEventType.name then
		self.name				:= _pxyEventType.name;
	endif;
	self.description			:= _pxyEventType.description;
	self.classNameToCreate 		:= _pxyEventType.classNameToCreate;
	self.colour					:= _pxyEventType.colour;
	if self.category &lt;&gt; _pxyEventType.category then
		self.category			:= _pxyEventType.category;	//29 Oct 2009	NDL	 Par 21519
	endif;
	self.amountDecimalPlaces	:= _pxyEventType.amountDecimalPlaces; //epr par 36902 14/6/15
	self.isFromToDateTimeRequired := _pxyEventType.isFromToDateTimeRequired;	//nds TFS 3047 13/01/17		
	self.unitDescription := _pxyEventType.unitDescription;						//nds TFS 3047 13/01/17		
	if self.myRoot &lt;&gt; _pxyEventType.myRoot then
		self.myRoot 			:= _pxyEventType.myRoot;
	endif;
	
	//24 Aug 2018	NDL	TFS 40309
	if self.myDelayTypeToCreate &lt;&gt; null and self.myDelayTypeToCreate &lt;&gt; _pxyEventType.myDelayTypeToCreate then
		self.myDelayTypeToCreate := null;
	endif;
	self.myDelayTypeToCreate := _pxyEventType.myDelayTypeToCreate;
	
	self.showWeight := _pxyEventType.showWeight;		// TFS 54165
	self.myWeightType := _pxyEventType.myWeightType;	// TFS 54165
	
	//first figure out warnings that we may have been removed from
	foreach realInterestedWarn in self.allInterestedWarnings do
		if _pxyEventType.allInterestedWarnings[realInterestedWarn.errorCode] = null then
			realInterestedWarn.removeEventType(self);
		endif;
	endforeach;
	//now add into any newly added (or existing - checks for already included)
	foreach pxyInterestedWarn in _pxyEventType.allInterestedWarnings do
		realInterestedWarn := app.myRoot.allInterestedWarnings[pxyInterestedWarn.errorCode];
		
		if realInterestedWarn = null then
			create realInterestedWarn persistent;
			realInterestedWarn.setForUpdate(pxyInterestedWarn);
		endif;
		realInterestedWarn.addEventType(self);
	endforeach;
	
end;


</source>
        <Parameter name="_pxyEventType" type="CM_EventType"/>
    </JadeMethod>
