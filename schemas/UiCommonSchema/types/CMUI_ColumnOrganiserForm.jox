    <JadeMethod name="addHiddenEntRow" id="c879ed48-5eea-4506-98c0-981842bea627">
        <updating/>
        <source>addHiddenEntRow(_entRowName : String ) updating;
/*

Date		Who		Reason
28 March 2017	cnwer1	Initial creation TFS 830

*/

vars
	entRow : EntTableRow;
begin
	if _entRowName = null then
		return;
	endif;
	
	if self.myEntTableDef = null then
		return;
	endif;
	
	entRow:= self.myEntTableDef.getEntTableRow(_entRowName);
	
	if entRow = null then
		return;
	endif;
	
	if not self.allTblHiddenEntRows.includes(entRow) then
		self.allTblHiddenEntRows.add(entRow);
	endif;
epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
    </JadeMethod>
    <JadeMethod name="addMeasurementRow" id="6bc06213-7a1a-46a2-a2b7-e02c8ac2ec03">
        <source>addMeasurementRow(_row 	: EntTableRow) protected;
/*

Date		Who		Reason
03 April 2014	cnwer1	Initial creation PAR 33900
20 March 2015   cnwma1  PAR #35887 Load List - weight not sorted by amount
*/

vars
	measure		: CM_MeasurementType;
	prefix		: String;
	rowHeading	: String;
	rowName		: String;
	found		: Boolean;
	proxyRow	: EntTableRowProxy;
	otherRow	: EntTableRow;
	selectedRows :  EntTableRowArray;
	cargoType	: CM_CargoBOLType;
	alteredHeaderName : String;
	hideRow 		: Boolean;
	measureType 	: CM_MeasurementType;
	
begin
	if self.myDataTable &lt;&gt; null then
		selectedRows:= self.myDataTable.allTblDataEntRows;
	else
		selectedRows:= self.myTextTable.allDisplayEntTableRows;
	endif;
	
	foreach measure in app.myRoot.allMeasurementTypesByShortName discreteLock where measure.measurementType = _row.measurementType do
		if not measure.isDisplay or not measure.isAvailableForEntry then
			continue;
		endif;
		app.getRowHeadingFromMeasure(_row, measure, prefix, rowHeading, rowName);
		// 35440 use the cargo type attribute headings if set, for the cargo enquiry screen
		if self.myDataTable.myForm &lt;&gt; null and
		   self.myDataTable.myForm.name = "CM_ContainerEnqForm" and
		   self.myDataTable.myTerminologyCargoBOLType &lt;&gt; null then
			cargoType := self.myDataTable.myTerminologyCargoBOLType;
			if cargoType.isEntTableSpecialProductAttr( _row.name ) then
				self.myDataTable.myTerminologyCargoBOLType.hasEntTableSpecialConditions(_row,
												alteredHeaderName,
												hideRow,
												measureType);
				if alteredHeaderName &lt;&gt; null then
					rowHeading := alteredHeaderName &amp; " " &amp; measure.shortName;
				endif;
			endif;
		endif;
		found := false;
		foreach otherRow in selectedRows where otherRow.isKindOf(EntTableRowProxy) and otherRow.EntTableRowProxy.nameForProxy = rowName do
			found := true;
			break;
		endforeach;
		if not found then
			create proxyRow transient;
			//proxyRow.setBasicDetails(rowName, rowHeading, Table.InputType_None, true);  // 20/03/2015 cnwma1  PAR #35887
			proxyRow.setBasicDetails(rowName, rowHeading, _row.inputType, true);		   // 20/03/2015 cnwma1  PAR #35887
			self.allTblDataEntRows.add(proxyRow);
			self.allAvailableMeasurementRows.add(proxyRow);
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="5595fd19-5376-4b27-931f-d89465c53042">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

	toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;

begin

	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrintTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrintSetup,CMUI_Toolbar.Control_Alignment_Left); //epr par 31802 23/1/14
	toolbar.addButton(self.btnExportCSVTV, CMUI_Toolbar.Control_Alignment_Left);
	
	inheritMethod();
	
	showCaptions := toolbar.showCaptions;
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
