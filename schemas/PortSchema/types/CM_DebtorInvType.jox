    <JadeMethod name="getPackageDetails" id="27f84ac2-8129-40cd-ac9a-024442f2fce0">
        <source>getPackageDetails() : String;
// for reporting
vars
	count	: Integer;
	packageInvoice	: CM_PackageInvoice;
	details	: String;
begin
	foreach packageInvoice in self.allPackageInvoices do
		count := count + 1;
		if count &gt; 1 then
			details := details &amp; ", ";
		endif;
		details := details &amp; packageInvoice.description;
	endforeach;
	
	return details;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="903b211d-c254-4971-b07c-4d325ecaba25">
        <source>pxyCreateUpdateProxy() : SelfType;
// 20 September 2011	cnwjre1	CCMS 2120 Electronic Invoicing
vars
	proxyDebtorInvType	: CM_DebtorInvType;
begin
	proxyDebtorInvType := inheritMethod();
	proxyDebtorInvType.myDebtor := self.myDebtor;
	proxyDebtorInvType.myInvoiceType := self.myInvoiceType;
	proxyDebtorInvType.defaultDebtorRefTo := self.defaultDebtorRefTo;

	return proxyDebtorInvType;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setDefaultDebtorRefTo" id="1059b84d-5693-4e22-aa10-47b47387a3e9">
        <updating/>
        <source>setDefaultDebtorRefTo(_value : Integer) updating;
// for transients from maintenance form
vars

begin
	self.defaultDebtorRefTo := _value;
end;
</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="646cf956-e148-4303-83b7-6aeefb140284">
        <updating/>
        <source>setForCreate(_proxyDebtorInvType : CM_DebtorInvType; _passport : CM_Passport input) updating;
// 20 September 2011	cnwjre1	CCMS 2120 Electronic Invoicing
begin
	_proxyDebtorInvType.raiseExceptionIfNotTransient(method);

	self.setForUpdate(_proxyDebtorInvType);
//	set any properties which are only to be done from create, not update
end;
</source>
        <Parameter name="_proxyDebtorInvType" type="CM_DebtorInvType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1354ccfd-1df2-4529-93a0-8fd4398cda61">
        <updating/>
        <source>setForUpdate(_proxyDebtorInvType : CM_DebtorInvType) updating;
// 20 September 2011	cnwjre1	CCMS 2120 Electronic Invoicing
begin
	self.defaultDebtorRefTo := _proxyDebtorInvType.defaultDebtorRefTo;
	_proxyDebtorInvType.allPackageInvoices.copy(self.allPackageInvoices);
	self.myDebtor := _proxyDebtorInvType.myDebtor;
	self.myInvoiceType := _proxyDebtorInvType.myInvoiceType;
end;</source>
        <Parameter name="_proxyDebtorInvType" type="CM_DebtorInvType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="50aa4a7f-ae89-464e-b356-c7ef2ead4516">
        <updating/>
        <source>setProxy(_debtor : CM_Debtor; _invType : CM_InvoiceDesc; _default : Integer) updating;
/*
Purpose:	

Date		Who		Reason
28 July 2025	navab1	JIRA 35465
*/

vars

begin
	self.myDebtor := _debtor;
	self.myInvoiceType := _invType;
	self.defaultDebtorRefTo := _default;
epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_invType" type="CM_InvoiceDesc"/>
        <Parameter name="_default" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setup" id="409a5536-0c60-42e5-98a1-2c1234277201">
        <updating/>
        <source>setup(_debtor : CM_Debtor; _invoiceType : CM_InvoiceDesc; _defaultRef : Integer) updating;
// for transient, from maintenance form
vars

begin
	self.myInvoiceType := _invoiceType;
	self.myDebtor := _debtor;
	self.defaultDebtorRefTo := _defaultRef;
end;
</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_defaultRef" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="ecf46891-bf9b-43cf-9cac-8d510b323bd7">
        <source>validateForCreate();
// 20 September 2011	cnwjre1	CCMS 2120 Electronic Invoicing
begin

	if self.myDebtor = null then
	 //	app.raiseCMException1(REQUIRED_FIELD, "Debtor", null, null);
		app.raiseCMException(Input_required_field_debtor, null, null); // cnwdb2	PAR 35364
		
	endif;
	if self.myInvoiceType = null then
	 //	app.raiseCMException1(REQUIRED_FIELD, "Invoice type", null, null);
		app.raiseCMException(Input_required_field_invtype, null, null); // cnwdb2	PAR 35364
	endif;

end;</source>
    </JadeMethod>
