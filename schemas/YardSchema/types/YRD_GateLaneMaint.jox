    </JadeMethod>
    <JadeMethod name="deleteProxies" id="527f616e-43f1-4f82-a14d-0eafb2d946c2">
        <updating/>
        <source>deleteProxies() updating, protected;
// ---------------------------------------------------------------------------
// Created:	16 May 2008 By Graeme Black cnwgb1
// Status: Unfinished
// ---------------------------------------------------------------------------
// 25/08/2009	cnwcs5	ccms 1061 - road ops form changes
vars
	table	: CM_DataTable;
	row 	: Integer;
	proxy 	: CM_LaneController;
begin
	table	:= self.tblGateLanes;
	
	foreach row in table.fixedRows + 1 to table.rows do
		proxy := table.accessRow(row).itemObject.CM_LaneController;
		
		if proxy &lt;&gt; null then
			// must call erase and not delete so child objects also get deleted
			proxy.erase (NORMAL_ERASE);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
