    <JadeMethod name="isUnicode" id="3c298bce-8671-48df-ab61-ddbb0d534357">
        <source>isUnicode(prod:String):Boolean;

vars
	s:String;
begin
	s:=prod.toLower;
	if s[1:3] = "cmi" or s = "sku" or s = "slu" or s = "muu" then
		return true;
	endif;
	return false;
end;
</source>
        <Parameter name="prod" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
