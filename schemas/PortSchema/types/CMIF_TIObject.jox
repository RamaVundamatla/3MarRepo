    <JadeMethod name="cloneForTest" id="7310a69f-e3f2-40ad-bd44-cabe5396c72d">
        <source>cloneForTest(): SelfType;
// ---------------------------------------------------------------------------
// Created:     17 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	rtnObj	: SelfType;
begin
	rtnObj := inheritMethod();
	
	rtnObj.myTerminal	:= self.myTerminal;
	
	return rtnObj;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
