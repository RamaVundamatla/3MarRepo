    <JadeMethod name="drawSelf" id="ea5e2161-c72d-411e-9e1d-f24a770e96b4">
        <updating/>
        <source>drawSelf(_theFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tm_x2, tm_x1,tm_y1,tm_y2, theY1, theY2	: Real;
	lOuterColourUpper,	lOuterColourLower : Integer;
	viewMode : Integer;
	makeShipLongerX : Integer;	// cnwvu1 13/11/2006 PAR 12533 - in case when containers are very deep and outside ship's aft, we have to make ship longer and move containers to the right. 
	
begin

	if self.myGridArea.SHP_BayArea.drawMe = false then
		return;
	endif;
	viewMode := self.myGridArea.mySDF.viewMode;
	if viewMode = 0 then
		viewMode := TI_ColourMode_DischargePort;
	endif;
	if displayColoursACT.isEmpty then
		if self.onDeck then
			_theFrame.drawFillColor := Red;
		else
			_theFrame.drawFillColor := Blue;
		endif;
	else
		_theFrame.drawFillColor := displayColoursACT[viewMode];
		if _theFrame.drawFillColor = 0 then
			_theFrame.drawFillColor  := White;
		endif;
	endif;
	if self.myGridArea.allSelectedPoints.includes(self) then

		lOuterColourUpper := DarkGray;
		lOuterColourLower := White;
		_theFrame.drawStyle := Frame.DrawFillStyle_Solid;
		_theFrame.drawWidth := 1;
		_theFrame.drawFillColor := Gray;
	else
		lOuterColourLower := DarkGray;
		_theFrame.drawStyle := Frame.DrawFillStyle_Solid;
		_theFrame.drawWidth := 1;
		lOuterColourUpper := Gray;
//		lOuterColourUpper := White;
	endif;
	
	_theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	self.theDrawFillColor := _theFrame.drawFillColor;


	theY1 := self.y1;
	theY2 := self.y2;
//	if not self.onDeck then
//		theY1 := self.y1 + 6;
//		theY2 := self.y2 + 6;
//	endif;
	
	tm_y1 := theY1;
	tm_x2 := self.x2;

	tm_x2 := tm_x2 - 1;
	tm_y2 := theY2 - 1;

	if not self.myGridArea.mySDF.drawInReverse then		//cnwvu1 13/11/2006	PAR12533
		makeShipLongerX := self.myGridArea.SHP_ProfileArea.getExtraShipLength();
	else
		makeShipLongerX := 0;
	endif;
	
	_theFrame.drawFilledRectangle(self.x1 + makeShipLongerX, theY1, self.x2 + makeShipLongerX, theY2, Black);	//cnwvu1 13/11/2006 PAR 12533 -  + makeShipLongerX

	_theFrame.drawLine(self.x1 + makeShipLongerX, tm_y1,     tm_x2 + 1 + makeShipLongerX, tm_y1,     lOuterColourUpper);	
	_theFrame.drawLine(self.x1 + makeShipLongerX, tm_y1,     self.x1 + makeShipLongerX,   tm_y2,     lOuterColourUpper);
	_theFrame.drawLine(tm_x2 + makeShipLongerX,   tm_y1 + 1, tm_x2 + makeShipLongerX,     tm_y2 + 1, lOuterColourLower);

	if self.isLastOnDeck then
		_theFrame.drawWidth := 2;
		_theFrame.drawLine(self.x1 + makeShipLongerX, tm_y2, tm_x2 + makeShipLongerX, tm_y2,  Black);
	endif;

	if self.isLastOnDeck then
		_theFrame.drawWidth := 1;
	endif;
	

/*
	if self.onDeck then
		if not self.myGridArea.allSelectedPoints.includes(self) then
			_theFrame.drawWidth := 2;
			_theFrame.drawLine(self.x1, tm_y2 + 4, tm_x2 + 1, tm_y2 + 4,  Black);
			_theFrame.drawWidth := 1;
		endif;
	endif;
	*/
end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoForPoint" id="7711239a-ab38-428c-ba80-4da55c2b475e">
        <source>getExtraInfoForPoint(x: Real; y: Real; _dataContainer : CM_DataContainer) : Object;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use CM_DataContainer to hold data
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;

begin
	block := _dataContainer.addNewBlock;
	block.addNewItem("Bay ", DC_Label, 1, null);
	block.addNewItem(self.myBay.id, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Tier ", DC_Label, 1, null);
	block.addNewItem(self.label, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Colour Coded Discharge ", DC_Label, 1, null);
	block.addNewItem(self.totalUDDischarge.String, DC_Data, 1, null);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Colour Coded Load ", DC_Label, 1, null);
	block.addNewItem(self.totalUDLoad.String, DC_Data, 1, null);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Job Discharge ", DC_Label, 1, null);
	block.addNewItem(self.totalODDischarge.String, DC_Data, 1, null);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Job Load ", DC_Label, 1, null);
	block.addNewItem(self.totalODLoad.String, DC_Data, 1, null);

	if app.isDevelopmentSystem then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Point ", DC_Label, 1, self);
		block.addNewItem(self.String, DC_Data, 1, self);
	endif;

	return self.myBay;
end;

/*getExtraInfo(x: Real; y: Real; _theStringArray: HugeStringArray input; _theObjectArray: ObjectArray input) : Object;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	 _theStringArray.add("Bay " &amp; Tab &amp; self.myBay.id);
	 _theObjectArray.add(null);
	 _theStringArray.add("Tier " &amp; Tab &amp; self.label);
	 _theObjectArray.add(null);

	 _theStringArray.add("Colour Coded Discharge " &amp; Tab &amp; self.totalCD.String);
	 _theObjectArray.add(null);
	 _theStringArray.add("Colour Coded Load " &amp; Tab &amp; self.totalCL.String);
	 _theObjectArray.add(null);
	 _theStringArray.add("Job Discharge " &amp; Tab &amp; self.totalJD.String);
	 _theObjectArray.add(null);
	 _theStringArray.add("Job Load " &amp; Tab &amp; self.totalJL.String);
	 _theObjectArray.add(null);
	return self.myBay;
end;
*/</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="isFirstUnderDeck" id="4265fa10-681e-43d0-9ad7-78cddcfe99a0">
        <source>isFirstUnderDeck() : Boolean;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aPoint : SHP_ProfilePoint;
begin
	if self.onDeck then
		return false;
	endif;
	
	aPoint := self.myGridArea.allGridPoints[self.row - 1, self.column].SHP_ProfilePoint;
	
	if aPoint = null then
		return true;
	endif;
	if  aPoint.onDeck then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLastOnDeck" id="652eea3f-2ec3-436d-bda2-1cf2d85eaa1c">
        <source>isLastOnDeck() : Boolean;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aPoint : SHP_ProfilePoint;
begin
	if not self.onDeck then
		return false;
	endif;
	
	aPoint := self.myGridArea.allGridPoints[self.row + 1, self.column].SHP_ProfilePoint;
	
	if aPoint = null then
		return true;
	endif;
	if not aPoint.onDeck then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateDefault" id="1cf6bbbb-b079-493c-9029-d03ffa45d77b">
        <updating/>
        <source>setForCreateDefault() updating;
/*
Purpose:	PAR 28701 - if no bays (points) then this single point is set to be large as all the drawing hangs of first/ last point's X/Ys		
Date		Who		Reason
23 November 2011	cnwab1	Initial creation
*/

vars

begin

return;


	self.x1 := 42;
	self.y1 := 120;
	
	self.x2 := 932;
	self.y2 := 130;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreateMT" id="0638a382-98ed-4d07-8b5a-08bb459073ed">
        <updating/>
        <source>setForCreateMT(_col,_row : Integer; _bayArea : SHP_ProfileArea) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	self.setForCreateSuperClass(_bayArea, _row, _col);
	self.bayDefnUnavailable := false;
epilog

end;</source>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_bayArea" type="SHP_ProfileArea"/>
    </JadeMethod>
    <JadeMethod name="setForCreateXML" id="f9472e21-5c68-4471-a01a-a17ff6a8b040">
        <updating/>
        <source>setForCreateXML(_theXMLString : String) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	totalODDischargeACT, totalODLoadACT, totalUDDischargeACT, totalUDLoadACT : Integer;
	totalODDischargePLN, totalODLoadPLN, totalUDDischargePLN, totalUDLoadPLN : Integer;
	theXMLTag, theXMLString,theXMLColours,theCode : String;
//	theGridArea : SHP_ProfileArea;
	pos2,theIndex,theColour : Integer;
begin
//	theGridArea := self.myGridArea.SHP_ProfileArea;
	theXMLString := _theXMLString;
	// ### The Colours for the tier
	theXMLTag := theXMLString.cnEcGetTagValueOfName("RTI");
	if theXMLTag &lt;&gt; null then
		self.setForCreateTIXML(theXMLTag,REAL_MODE);
	else
		self.setForCreateTIXMLNull(REAL_MODE);
	endif;

	
	theXMLTag := theXMLString.cnEcGetTagValueOfName("TD");  
	self.myTierDefn := theXMLTag.asOid.CM_TierDefn;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("BY");  
	self.myBay := theXMLTag.asOid.CM_Bay;
	// ### TOTAL CC
	theXMLTag := theXMLString.cnEcGetTagValueOfName("ODD");  
	totalODDischargeACT := theXMLTag.Integer;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("ODL");  
	totalODLoadACT := theXMLTag.Integer;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("UDD");  
	totalUDDischargeACT := theXMLTag.Integer;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("UDL");  
	totalUDLoadACT := theXMLTag.Integer;
	
	// ### TOTAL PLANNED
	theXMLTag := theXMLString.cnEcGetTagValueOfName("ODDP");  
	totalODDischargePLN := theXMLTag.Integer;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("ODLP");  
	totalODLoadPLN := theXMLTag.Integer;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("UDDP");  
	totalUDDischargePLN := theXMLTag.Integer;
	theXMLTag := theXMLString.cnEcGetTagValueOfName("UDLP");  
	totalUDLoadPLN := theXMLTag.Integer;
	self.setTotals(totalODDischargeACT, totalODLoadACT, totalUDDischargeACT, totalUDLoadACT,
						totalODDischargePLN, totalODLoadPLN, totalUDDischargePLN, totalUDLoadPLN);
	
	// ########### COLOURS AND CODES
	theXMLTag := theXMLString.cnEcGetTagValueOfName("ColCodes"); 
	pos2 := 1;
	while (pos2 &lt;&gt; 0) do
		theXMLColours := theXMLTag.cnEcGetNextTagValueOfName("IDX",pos2);  
		if pos2 = 0 then
			break;
		endif;
		theIndex := theXMLColours.Integer;
		theXMLColours := theXMLTag.cnEcGetNextTagValueOfName("CDE",pos2);  
		theCode := theXMLColours;
		theXMLColours := theXMLTag.cnEcGetNextTagValueOfName("COL",pos2);  
		theColour := theXMLColours.Integer;
		
		self.displayIconsACT.atPut(theIndex,theCode);
		self.displayColoursACT.atPut(theIndex,theColour);
	endwhile;

	theXMLTag := theXMLString.cnEcGetTagValueOfName("OD");  
	self.onDeck := theXMLTag = "Y";
	theXMLTag := theXMLString.cnEcGetTagValueOfName("LB");  
	self.label := theXMLTag ;
	self.lastUpdateByNote := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTotals" id="4b15f502-73fd-4c6e-95df-243e349a651d">
        <updating/>
        <source>setTotals(_totalODDischarge, _totalODLoad, _totalUDDischarge, _totalUDLoad,
			_totalODDischargePLN, _totalODLoadPLN, _totalUDDischargePLN, _totalUDLoadPLN : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.totalODDischarge := _totalODDischarge;
	self.totalODLoad := _totalODLoad;
	self.totalUDDischarge := _totalUDDischarge;
	self.totalUDLoad := _totalUDLoad;


	self.totalODDischargePlanned := _totalODDischargePLN;
	self.totalODLoadPlanned := _totalODLoadPLN;
	self.totalUDDischargePlanned := _totalUDDischargePLN;
	self.totalUDLoadPlanned := _totalUDLoadPLN;
end;</source>
        <Parameter name="_totalODDischarge" type="Integer"/>
        <Parameter name="_totalODLoad" type="Integer"/>
        <Parameter name="_totalUDDischarge" type="Integer"/>
        <Parameter name="_totalUDLoad" type="Integer"/>
        <Parameter name="_totalODDischargePLN" type="Integer"/>
        <Parameter name="_totalODLoadPLN" type="Integer"/>
        <Parameter name="_totalUDDischargePLN" type="Integer"/>
        <Parameter name="_totalUDLoadPLN" type="Integer"/>
    </JadeMethod>
</Class>
