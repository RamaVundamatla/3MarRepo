    <JadeMethod name="validateMe" id="689494a7-3ab4-4aa3-8a4c-146395bd0fc8">
        <source>validateMe() protected;

vars

begin
	if self.value &lt; MIN_TEMPERATURE or self.value &gt; MAX_TEMPERATURE then
		app.raiseCMException1(ERR_FIELD_TEMPRANGE, self.value.String, 'TempRange Value', null);
	endif;
//	if self.colour = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'TempRange Colour', null, null);
//	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
