    <JadeMethod name="processSystemSetConfig" id="b3cd2f28-7d75-4c65-bc38-ff52552ec1f9">
        <source>processSystemSetConfig(_systemXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Add required system setConfigs

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	text					: String;
	
begin
	
	varsStr := 'root			: CM_Root;';
	codeStr := CrLf &amp; Tab &amp; 'root := app.myRoot;' &amp; CrLf;
	
	self.processSetConfig(_systemXMLElement, codeStr, 'root');
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
