    <JadeMethod name="getCriteriaObjectSet" id="871a8ab6-950e-4552-9924-d20fbd8a3131">
        <source>getCriteriaObjectSet(_criteria : Integer) : CM_ObjectSet;
/*

Date		Who		Reason
02 February 2017	cnwer1	Initial creation TFS

*/

vars
	criteria : CM_YACriteria;	
begin
	criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(_criteria);
	if criteria &lt;&gt; null then
		return criteria.myYAData.CM_YADataObjects.allObjects;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_criteria" type="Integer"/>
        <ReturnType type="CM_ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="setLengthAttributes" id="4c31c864-c10d-432c-aa85-4226d21794f4">
        <updating/>
        <source>setLengthAttributes(_voyageAllocation : CM_VoyageAllocation) updating;
/*

Date		Who		Reason
03 February 2017	cnwer1	Initial creation TFS

*/

vars
	criteria : CM_YACriteria;	
	obj : Object;
	intValue : Integer;
	commGroup : CM_CommodityGroup;
	comm : CM_Commodity;
	hazardArray	: StringArray;
	value: String;
	length	: Integer;
	terminal: CM_Terminal;	
begin
	if _voyageAllocation = null then
		return;
	endif;
	
	self.myVoyageAllocation := _voyageAllocation;
	
	criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_IsForty);
	if criteria &lt;&gt; null then
		intValue:=criteria.myYAData.CM_YADataBoolean.getDataValue().Integer;
		is40:=intValue = CM_YADataBoolean.VALUE_TRUE;				
	endif;
	
	criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_ISOGroup);
	if criteria &lt;&gt; null then
		 criteria.myYAData.CM_YADataObjects.allObjects.copy(self.allISOTypeGroups);
	endif;
	
	criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_ISO);
	if criteria &lt;&gt; null then
		 criteria.myYAData.CM_YADataObjects.allObjects.copy(self.allISOTypes);
	endif;
	if intValue &lt;&gt; CM_YADataBoolean.VALUE_FALSE then
		if not is40   then									
				foreach obj in allISOTypeGroups discreteLock do 
					if obj.CM_ISOTypeGroup.is40ftLong then
						is40:= true;
						break;
					endif;
				endforeach;
			
		endif;
	
		if not is40 then									
			
				foreach obj in allISOTypes discreteLock do 
					if obj.CM_ISOType.is40ftLong then
						is40:= true;
						break;
					endif;
				endforeach;	
		
		endif;
	endif;
	
	intValue:=0;
	if not is40 then
		//check 45
		criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_IsFortyFive);
		if criteria &lt;&gt; null then
			intValue:=criteria.myYAData.CM_YADataBoolean.getDataValue().Integer;
			self.is45:=intValue = CM_YADataBoolean.VALUE_TRUE;
		endif;
		if intValue &lt;&gt; CM_YADataBoolean.VALUE_FALSE then
			if not self.is45   then					
				if allISOTypeGroups &lt;&gt; null then
					foreach obj in allISOTypeGroups discreteLock do 
						if obj.CM_ISOTypeGroup.is45ftLong then
							self.is45:= true;
							break;
						endif;
					endforeach;
				endif;
			endif;
		
			if not self.is45  then					
				
					foreach obj in allISOTypes discreteLock do 
						if obj.CM_ISOType.is45ftLong then
							self.is45:= true;
							break;
						endif;
					endforeach;	
			
			endif;
		endif;
		
	endif;
	intValue:=0;
	if not is40 and not is45 then
		//check 45
		criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_IsFiftyThree);
		if criteria &lt;&gt; null then
			intValue:=criteria.myYAData.CM_YADataBoolean.getDataValue().Integer;
			self.is53:=intValue = CM_YADataBoolean.VALUE_TRUE;
		endif;
		if intValue &lt;&gt; CM_YADataBoolean.VALUE_FALSE then
			if not self.is53   then					
				if allISOTypeGroups &lt;&gt; null then
					foreach obj in allISOTypeGroups discreteLock do 
						if obj.CM_ISOTypeGroup.is53ftLong then
							self.is53:= true;
							break;
						endif;
					endforeach;
				endif;
			endif;
		
			if not self.is53  then					
				
					foreach obj in allISOTypes discreteLock do 
						if obj.CM_ISOType.is53ftLong then
							self.is53:= true;
							break;
						endif;
					endforeach;	
			
			endif;
		endif;
	endif;
	intValue:=0;
	if not is40 and not is45 and not is53 then
		//check 45
		criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_IsThirty);
		if criteria &lt;&gt; null then
			intValue:=criteria.myYAData.CM_YADataBoolean.getDataValue().Integer;
			self.is30:=intValue = CM_YADataBoolean.VALUE_TRUE;
		endif;
		if intValue &lt;&gt; CM_YADataBoolean.VALUE_FALSE then
			if not self.is30   then					
			
					foreach obj in allISOTypeGroups discreteLock do 
						if obj.CM_ISOTypeGroup.is30ftLong then
							self.is30:= true;
							break;
						endif;
					endforeach;
				
			endif;
		
			if not self.is30  then					
	
					foreach obj in allISOTypes discreteLock do 
						if obj.CM_ISOType.is30ftLong then
							self.is30:= true;
							break;
						endif;
					endforeach;	
			
			endif;
		endif;
	endif;
	intValue:=0;
	if not is40 and not is45 and not is53  and not is30 then
		self.is20 := true;
	endif;
	
	criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_IsOverDimension); // PAR 23263 
	if criteria &lt;&gt; null then
		self.isOD:=  criteria.myYAData.CM_YADataBoolean.getDataValue().Integer &lt;&gt; CM_YADataBoolean.VALUE_FALSE ;			// if it has any special object set then it is special stow
	endif;

	criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_WaterCooled);			// 25/8/17 MAP TFS5481
	if criteria &lt;&gt; null then
		self.isWaterCooled := criteria.myYAData.CM_YADataBoolean.getDataValue().Integer &lt;&gt; CM_YADataBoolean.VALUE_FALSE;
	endif;
	
	criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_RequiresPower);		// 25/8/17 MAP TFS5481

	if criteria &lt;&gt; null then
		self.requiresPower := criteria.myYAData.CM_YADataBoolean.getDataValue().Integer &lt;&gt; CM_YADataBoolean.VALUE_FALSE;
	endif;

	criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_IsHazardous);			// 25/8/17 MAP TFS5481
	if criteria &lt;&gt; null then
		self.isHazardous := criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE;
	endif;
	if not self.isHazardous then
		criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_Hazardous);
		if criteria &lt;&gt; null then
			// get the critiera into an array
			value := criteria.myYAData.getDataValue().String;
			hazardArray := value.getTokens();
			
			// get the terminal and includeLQasHazard
			terminal := self.myVoyageAllocation.getTerminal();
			if terminal = null or terminal.includeLQasHazardous() then
				self.isHazardous := true;
			else
				foreach value in hazardArray do
					length := value.trimBlanks().length;
					if length = 1 or (length &gt; 1 and value[length:1] &lt;&gt; "L") then
						self.isHazardous := true;
						break;
					endif;
				endforeach;
			endif;
		endif;
	endif;

	criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_IsEmpty);			// 25/8/17 MAP TFS5481
	if criteria &lt;&gt; null then
		intValue := criteria.myYAData.CM_YADataBoolean.getDataValue().Integer;
		self.isEmpty := intValue = CM_YADataBoolean.VALUE_TRUE;
	endif;
	if not self.isEmpty and intValue &lt;&gt; CM_YADataBoolean.VALUE_FALSE then
		criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_CommodityGroup);
		if criteria &lt;&gt; null then
			commGroup := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_CommodityGroup;
			if commGroup &lt;&gt; null then
				self.isEmpty := commGroup.isEmptyCommodity();
			endif;
		else
			criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_Commodity);
			if criteria &lt;&gt; null then
				comm := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_Commodity;
				if comm &lt;&gt; null then
					self.isEmpty := comm.isEmpty;
				endif;
			endif;
		endif;		
	endif;

	criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_SpecialStow);			// 25/8/17 MAP TFS5481
	if criteria &lt;&gt; null then
		self.isSpecialStow := criteria.myYAData.CM_YADataObjects.allObjects.first &lt;&gt; null;
	endif;

	//set all attributes of the Iso types and groups
	if allISOTypeGroups &lt;&gt; null then								// 28/8/17 MAP TFS5481
		foreach obj in allISOTypeGroups discreteLock do 
			if obj.CM_ISOTypeGroup.isCrib then
				self.isCrib := true;				
			endif;
			if obj.CM_ISOTypeGroup.isFrame then	//05 Feb 2018	NDL	TFS 36752
				self.isFrame := true;				
			endif;
			if obj.CM_ISOTypeGroup.isTank then
				self.isTank := true;				
			endif;
			if obj.CM_ISOTypeGroup.isOpenTop then
				self.isOpenTop := true;
			endif;
			if obj.CM_ISOTypeGroup.isFlat then
				self.isFlat := true;
			endif;
			if obj.CM_ISOTypeGroup.isFantainer then
				self.isFantainer := true;
			endif;
			if obj.CM_ISOTypeGroup.isNonStandardHeight then
				self.isHiCube := true;
			endif;
			if obj.CM_ISOTypeGroup.isHalfHeight then
				self.isHalfHeight := true;
			endif;
		endforeach;
	endif;
	
	if  self.allISOTypes &lt;&gt; null then								// 28/8/17 MAP TFS5481
		foreach obj in allISOTypes discreteLock do 
			if not self.isCrib and obj.CM_ISOType.isCrib then
				self.isCrib := true;
			endif;
			if not self.isFrame and obj.CM_ISOType.isFrame then	//05 Feb 2018	NDL	TFS 36752
				self.isFrame := true;				
			endif;
			if not self.isTank and obj.CM_ISOType.isTank then
				self.isTank := true;
			endif;
			if not self.isOpenTop and obj.CM_ISOType.isOpenTop then
				self.isOpenTop := true;
			endif;
			if not self.isFlat and obj.CM_ISOType.isFlat then
				self.isFlat := true;
			endif;
			if  not self.isFantainer and obj.CM_ISOType.isFantainer then
				self.isFantainer := true;
			endif;
			if  not self.isHiCube and obj.CM_ISOType.isNonStandardHeight then
				self.isHiCube := true;
			endif;
			if not self.isHalfHeight and obj.CM_ISOType.isHalfHeight then
				self.isHalfHeight := true;
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_voyageAllocation" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyageAllocation" id="08c9228f-8a6b-460e-90f8-f56328d66a90">
        <updating/>
        <source>setMyVoyageAllocation(_voyageAllocation : CM_VoyageAllocation) updating;
/*

Date		Who		Reason
02 February 2017	cnwer1	Initial creation TFS

*/

vars
	criteria : CM_YACriteria;	
	obj : Object;
	intValue : Integer;
	commGroup : CM_CommodityGroup;
	comm : CM_Commodity;
	hazardArray		: StringArray;			// 19/10/2010 cnwmh5 #25626

	value			: String;				// 19/10/2010 cnwmh5 #25626
	length			: Integer;				// 19/10/2010 cnwmh5 #25626
	terminal		: CM_Terminal;	
begin
	
	
	if self.myVoyageAllocation &lt;&gt; _voyageAllocation then
		self.myVoyageAllocation :=_voyageAllocation;
		
		if self.myVoyageAllocation = null then
			return;
		endif;
		
		self.setLengthAttributes(self.myVoyageAllocation);		
			
		criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_SpecialStow); // PAR 23263 
		if criteria &lt;&gt; null then
			self.isSpecialStow:=  criteria.myYAData.CM_YADataObjects.allObjects.first &lt;&gt; null ;			// if it has any special object set then it is special stow
		endif;
		
		criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_WaterCooled); // PAR 23263 
		if criteria &lt;&gt; null then
			self.isWaterCooled:=  criteria.myYAData.CM_YADataBoolean.getDataValue().Integer &lt;&gt; CM_YADataBoolean.VALUE_FALSE ;			// if it has any special object set then it is special stow
		endif;
		
		criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_RequiresPower); // PAR 23263 
		if criteria &lt;&gt; null then
			self.requiresPower:=  criteria.myYAData.CM_YADataBoolean.getDataValue().Integer &lt;&gt; CM_YADataBoolean.VALUE_FALSE ;			// if it has any special object set then it is special stow
		endif;
		
		//set all attributes of the Iso types and groups
		if allISOTypeGroups &lt;&gt; null then
			foreach obj in allISOTypeGroups discreteLock do 
				if obj.CM_ISOTypeGroup.isCrib then
					self.isCrib:=true;				
				endif;
				if obj.CM_ISOTypeGroup.isFrame then	//05 Feb 2018	NDL	TFS 36752
					self.isFrame:=true;				
				endif;
				if obj.CM_ISOTypeGroup.isTank then
					self.isTank:=true;				
				endif;
				if obj.CM_ISOTypeGroup.isOpenTop then
					self.isOpenTop:=true;
				endif;
				if obj.CM_ISOTypeGroup.isFlat then
					self.isFlat:=true;
				endif;
				if obj.CM_ISOTypeGroup.isFantainer then
					self.isFantainer:=true;
				endif;
				
				if obj.CM_ISOTypeGroup.isNonStandardHeight then
					self.isHiCube:=true;
				endif;
				
				if obj.CM_ISOTypeGroup.isHalfHeight then
					self.isHalfHeight:=true;
				endif;
			endforeach;			
		endif;
		
		if  self.allISOTypes &lt;&gt; null then
			foreach obj in allISOTypes discreteLock do 
				if not self.isCrib and obj.CM_ISOType.isCrib then
					self.isCrib:=true;					
				endif;
				if not self.isFrame and obj.CM_ISOType.isFrame then	//05 Feb 2018	NDL	TFS 36752
					self.isFrame:=true;					
				endif;
				if not self.isTank and  obj.CM_ISOType.isTank then
					self.isTank:=true;				
				endif;
				if not self.isOpenTop and obj.CM_ISOType.isOpenTop then
					self.isOpenTop:=true;
				endif;
				if not self.isFlat and obj.CM_ISOType.isFlat then
					self.isFlat:=true;
				endif;
				if  not self.isFantainer and obj.CM_ISOType.isFantainer then
					self.isFantainer:=true;
				endif;
				
				if  not self.isHiCube and obj.CM_ISOType.isNonStandardHeight then
					self.isHiCube:=true;
				endif;
				
				if not self.isHalfHeight and  obj.CM_ISOType.isHalfHeight then
					self.isHalfHeight:=true;
				endif;
				
			endforeach;		
		endif;
		
		criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_IsEmpty); // PAR 23263 
		if criteria &lt;&gt; null then
			intValue:=criteria.myYAData.CM_YADataBoolean.getDataValue().Integer;
			self.isEmpty:=  intValue = CM_YADataBoolean.VALUE_TRUE ;			// if it has any special object set then it is special stow
		endif;
		
		if not self.isEmpty and  intValue &lt;&gt; CM_YADataBoolean.VALUE_FALSE then
			criteria :=self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_CommodityGroup); // PAR 23263 
			if criteria &lt;&gt; null then
				commGroup := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_CommodityGroup;	
				if commGroup &lt;&gt; null then
					self.isEmpty := commGroup.isEmptyCommodity();
				endif;
			else
				// PAR 23263 criteria := self.allAllocations.last().CM_VoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_Commodity);
				criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_Commodity); // PAR 23263 
				if criteria &lt;&gt; null then
					comm := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_Commodity;	
					if comm &lt;&gt; null then
						self.isEmpty := comm.isEmpty;
					endif;
				endif;
			endif;		
		endif;
		
		
		criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_IsHazardous); // PAR 23263 
		if criteria &lt;&gt; null then
			self.isHazardous:=  criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE ;			// if it has any special object set then it is special stow
		endif;
		
		if not self.isHazardous then
			criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_Hazardous);
			if criteria &lt;&gt; null then
				// get the critiera into an array
				value := criteria.myYAData.getDataValue().String;
				hazardArray := value.getTokens();
				
				// get the terminal and includeLQasHazard
				terminal := self.myVoyageAllocation.getTerminal;
				if terminal = null or terminal.includeLQasHazardous() then
					self.isHazardous := true;
				else
					foreach value in hazardArray do
						length := value.trimBlanks().length;
						if length = 1 or (length &gt; 1 and value[length:1] &lt;&gt; "L") then
							self.isHazardous := true;
							break;
						endif;
					endforeach;
				endif;
			endif;
		endif;
		
		criteria := self.myVoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_DischargePort); // PAR 23263 
		if criteria &lt;&gt; null then
			self.myDischargePort:= criteria.myYAData.CM_YADataObjects.allObjects.first().CM_Port;			
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_voyageAllocation" type="CM_VoyageAllocation"/>
    </JadeMethod>
</Class>
