    <JadeMethod name="saveDamageDetails" id="c5eb8ee3-0c4d-47d9-9f6f-f3fbd4a073af">
        <source>saveDamageDetails();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	wagon : CM_Wagon;
	damageInterface : IF_DamageDetails;
	pxyObj : CM_Object;
	isNewPxy : Boolean;
	errors : String;
	cmifUpdateController : CMIF_Object;
	mess : String;
	
begin

	wagon := self.myMobileGenericAgent.myCurrentWagon;
	if wagon &lt;&gt; null then
		damageInterface := wagon.IF_DamageDetails;
	endif;
	
	if damageInterface = null then
		return;
	endif;
	
	// get the proxy 
	pxyObj := damageInterface.getDamageProxy(isNewPxy);
	damageInterface := pxyObj.IF_DamageDetails;
	
	// update the proxy with table data
	self.tblDamage.setProxyFromTable(damageInterface,errors,null);
	
	cmifUpdateController := damageInterface.getDamageCMIFController;
	
	app.myPassport.clearErrorsWarnings();
	app.myPassport.setWarningsIgnored(true);
	damageInterface.updateDamageDetails(cmifUpdateController,app.myPassport);
	
	if not app.myPassport.hasErrors then
		app.myPassport.clearErrorsWarnings();
		return;
	else
		mess := damageInterface.getObjectDamageDesc;
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return;
	endif;
	
epilog

	delete pxyObj;
	delete cmifUpdateController;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="3ff5a417-b2a2-4b26-8aba-c694c102153f">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars
	
	wagon : CM_Wagon;
	damageInterface : IF_DamageDetails;
		
begin
	
	self.doResizeControls(true);
	
	wagon := self.myMobileGenericAgent.myCurrentWagon;
	if wagon &lt;&gt; null then
		damageInterface := wagon.IF_DamageDetails;
	endif;
	
	if damageInterface = null then
		return;
	endif;
	
	self.lblDamageFor.caption:=damageInterface.getObjectDamageDesc;
	self.tblDamage.initCombos(damageInterface);
	self.tblDamage.setTableFromDamageInterface(damageInterface);
	
	//27 Jan 2015	NDL	Par 35558
	if self.tblDamage.rows &gt; self.tblDamage.fixedRows
	and self.tblDamage.accessCell( self.tblDamage.rows, 1 ).text &lt;&gt; null then
		self.tblDamage.addNewRow(); // to allow more to be entered.
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1cb37eab-de84-4f88-a495-06c32c26b823">
