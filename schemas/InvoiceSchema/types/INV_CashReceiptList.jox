    <JadeMethod name="calculateRounding" id="b2523b59-448d-47e5-b32d-8a513e9394cc">
        <updating/>
        <source>calculateRounding() : Decimal updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Sep 2015	cnwmc5	Initial creation		PAR 36895
24 Sep 2019 cnwma1	Bug 46646: Cash Rounding not working unless default business unit configured
03 Feb 2020 cnwma1  Bug 48450: ADP - FW: 200420000856 - ##341337##
*/

vars
	decimalAmount,
	tempRoundAmount,
	roundAmount			: Real;
	roundingType		: Integer;
	
begin

	if not self.shouldRound then
		return null;
	endif;
	
	self.roundingDifference := 0;
	

	roundingType := self.myTerminal.getCashRoundingType( self.myProxyCashReceipt.myBank );  // 24.09.2019 cnwma1 #46646	
	roundAmount  := self.myTerminal.getCashRoundUpAmount( self.myProxyCashReceipt.myBank ); // 24.09.2019 cnwma1 #46646
	
	if self.cashRequiredToClearCharges &gt; 0 then
		decimalAmount := self.cashRequiredToClearCharges - self.cashRequiredToClearCharges.Integer;
		if decimalAmount &gt; 0 and
		   roundAmount &lt;&gt; 0 then
			tempRoundAmount := roundAmount;
			while true do
				if roundingType = RoundingType_Up then
					if decimalAmount &gt; tempRoundAmount then
						tempRoundAmount := tempRoundAmount + roundAmount;
						continue;
					endif;
				elseif roundingType = RoundingType_Down then
					if decimalAmount &lt; tempRoundAmount then
						tempRoundAmount := tempRoundAmount - roundAmount;
						continue;
					endif;
				endif;
				break;
			endwhile;
		endif;
		
		self.roundingDifference         := tempRoundAmount - decimalAmount;
		self.cashRequiredToClearCharges := self.cashRequiredToClearCharges + self.roundingDifference;
	endif;
	
	self.lblRoundUpValue.caption   := self.roundingDifference.asCurrencyJMT;
	//03.02.2020 cnwma1 #48450
	if self.allowSecondCurrency then 
		self.lblRoundUp2nd.caption := self.getSecondaryAmount(self.roundingDifference);
	endif;
epilog

end;
</source>
        <access>protected</access>
        <ReturnType type="Decimal"/>
    </JadeMethod>
