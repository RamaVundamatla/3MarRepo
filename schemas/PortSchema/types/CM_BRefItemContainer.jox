/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2009	cnwndl1	Initial creation	CCMS 1028

*/

vars

begin
	
	if set then
		// set code here
	else
		// get code here
		_value := self.getVentilation;
	endif;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
