    <JadeMethod name="createDebtorTypeProperties" id="7444910b-f7b0-412a-9811-3ffa4a8458dd">
        <source>createDebtorTypeProperties() protected;
// ---------------------------------------------------------------------------
// Created:	23 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
vars
	aDebtorType : CM_DebtorType;
	queryProp : CM_QRefDebtorType;
begin
	foreach aDebtorType in app.myRoot.allDebtorTypes do 
		// All the system generated debtor types are already 
		// in the list generated by createProperties
		if not aDebtorType.isSystemGenerated() 
		   and not aDebtorType.allDebtors.isEmpty() then
		   create queryProp persistent;
		   queryProp.set( "DT - " &amp; aDebtorType.description, "DT - " &amp; aDebtorType.code, self.className );
		   queryProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
		   self.allQueryProperties.add(queryProp); 
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createProperties" id="af686ca1-b64d-42a6-ba44-3527a33f96ec">
