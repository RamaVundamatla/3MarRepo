    <JadeMethod name="utlDeleteRateEntry" id="f73e944f-6643-49ca-879c-31c731ac2d60">
        <source>utlDeleteRateEntry(_rateEntry:CM_RateEntry io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 03/07/2018	jlgmd1	TFS 38937 - STWO Performance changes
vars
	rate	: CM_Rate;
	debtor	: CM_DebtorNode;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valRateEntry(_rateEntry);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_rateEntry);
	endif;

	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_RATEENTRY_DELETE),false,_rateEntry);
		rate := _rateEntry.rate;				// CCMS 1264
		debtor := _rateEntry.getMyDebtorNode;	// TFS 38937
		_rateEntry.erase(NORMAL_ERASE);
		rate.updateCharges(debtor);					// CCMS 1264
	endif;

epilog
	return;

end;</source>
        <Parameter name="_rateEntry" type="CM_RateEntry" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
