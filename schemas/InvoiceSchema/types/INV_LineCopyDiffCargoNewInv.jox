    <JadeMethod name="addToolbarControls" id="76a55b4a-151d-45c0-916d-60fe1b7ea226">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			Adds toolbar controls to the forms toolbar

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnSearchCargo, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
end;</source>
