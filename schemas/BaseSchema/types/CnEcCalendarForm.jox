        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="btnCancel_click" id="b254f015-ac63-45e7-aed5-845923ac2ae3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		17 April 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	modalResult	:=	0;
	unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="f5c86a6c-1be6-4193-8380-e2bbc4a94ca6">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		17 April 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	modalResult	:=	1;
	unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="calendar_click" id="88401e52-a845-4c2e-86a3-bb95fccbb082">
        <controlMethod name="CnEcCalendar::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>calendar_click(cntrl: CnEcCalendar input) updating;
// --------------------------------------------------------------------------------
// Created:		17 April 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
//	btnOk.enabled	:=	(self.calendar.date &lt;&gt; null);
	self.click;
end;</source>
        <Parameter name="cntrl" type="CnEcCalendar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="click" id="6c6ea9ad-6d47-4fcb-9394-256e69264da7">
        <controlMethod name="Form::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>click() updating;
// --------------------------------------------------------------------------------
// Created:		17 April 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	btnOk.enabled	:=	(self.calendar.date &lt;&gt; null);
end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="049a9efb-8c5b-49d0-a217-38fbcbab5921">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		17 April 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.positionLeft = 0 and self.positionTop = 0 then
		centreWindow();
	else
		self.left	:=	self.positionLeft;
		self.top	:=	self.positionTop;
	endif;		
	self.aIsLoading	:=	true;
//	btnOk.enabled	:=	false;
	btnOk.enabled	:=	(self.calendar.date &lt;&gt; null);
	modalResult		:=	0;
end;</source>
    </JadeMethod>
    <JadeMethod name="paint" id="7a38425a-d885-491b-94dc-1e044e7b34c1">
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>paint() updating;
// --------------------------------------------------------------------------------
// Created:		12 May 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();

	if self.aIsLoading then
		self.calendar.defaultDate	:=	aStartDate;
		self.aIsLoading				:=	false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setStartDate" id="4ddc6918-1984-4fc1-b3a5-4dac081a21e3">
        <updating/>
        <source>setStartDate(pStartDate:Date) updating;
// --------------------------------------------------------------------------------
// Created:		12 May 2000 by cnwdad1
//
// Purpose:		Sets the default start date for the calendar.
//
// Parameters:	pStartDate - The default start date.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aStartDate	:=	pStartDate;
end;</source>
        <Parameter name="pStartDate" type="Date"/>
    </JadeMethod>
</GUIClass>
