    <JadeMethod name="getRemainingQuantity" id="36366d21-d804-49f5-a368-83a38279342e">
        <source>getRemainingQuantity():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
28 Nov 2023 navhl20 ChangeRequest 61508: EUP | Ship Operations in DD - [54176.010] - [Release] Ship Job List 
29 Jan 2023 navhl20 ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues
28 May 2024 navma1	ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
*/

vars
	count : Integer;
	wle	: CM_WorkListEntry;
begin
	foreach wle in self.workListEntries discreteLock where  wle.status &lt;&gt; WLE_COMPLETED do  //28.05.2024 navma1 #63971
		if wle.myTrackedItem &lt;&gt; null then													//28.11.2023 navhl20 #61508
			count := count + wle.myTrackedItem.totalQuantity;
		else																				//29.01.2023 navhl20 #62166
			count := count + wle.quantity;
		endif;
	endforeach;

	return count.asStringJMT;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRemainingVolume" id="e220139b-f398-463a-be55-b72a62325b7a">
        <source>getRemainingVolume():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
28 Nov 2023 navhl20 ChangeRequest 61508: EUP | Ship Operations in DD - [54176.010] - [Release] Ship Job List 
*/

vars
	density,
	count		: Decimal[14,4];
	wle			: CM_WorkListEntry;
	ti			: CM_TrackedItem;
begin
	foreach wle in self.workListEntries discreteLock where wle.status &lt;&gt; WLE_COMPLETED do
		
		ti := wle.myTrackedItem;
		
		if ti &lt;&gt; null then											//28.11.2023 navhl20 #61508
			density := ti.getDensity().max(1);
			count   := count + (ti.weight/density);
		endif;
	endforeach;
	
	return count.asStringJMT;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRemainingWeight" id="ab8acd5c-b383-4e9e-b47d-aab691c159d1">
