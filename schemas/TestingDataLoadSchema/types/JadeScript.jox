    <JadeMethod name="deleteCargoForVoyage" id="ac98d5f2-74b4-46be-8066-e3540d36e87b">
        <source>deleteCargoForVoyage();

constants

	VoyageCode				: String = "HHRV10001";
	
vars

	terminal				: CM_Terminal;
	dsl						: UT_DSL;
	ti						: Object;
	voyage					: CM_Voyage;
	cont					: CM_TrackedItem;
	passportTerm			: CM_Terminal;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
				
	
begin

	
	app.initialize();
	
	create dsl transient;
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	dsl.opts.purge();
	dsl.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	voyage := dsl.getVoyage("HHRV10001");
	if voyage = null then
		app.msgBox("Unable to find voyage (" &amp; VoyageCode &amp; ").", "Voyage Error", MsgBox_OK_Only);
		return;
	endif;
	
	// delete the tracked items
	create tisToDelete transient;
	
	foreach cont in voyage.allOnshipTIsByIdCargoType do
		
		if cont.locationId[1:2] &lt;&gt; "59" and cont.locationId[1:2] &lt;&gt; "60" and cont.locationId[1:2] &lt;&gt; "61" then
			continue;
			//write cont.String &amp; Tab &amp; cont.id &amp; Tab &amp; cont.locationId;
		endif;
		write cont.String &amp; Tab &amp; cont.id &amp; Tab &amp; cont.locationId;
		tisToDelete.add(cont.id);
	
	endforeach;
	
		
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			dsl.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;

epilog

	app.myPassport.setMyTerminal(passportTerm);

	delete dsl;
	delete tisToDelete;
	delete tiSet;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="deleteCargoGroupAndAssocTIs" id="2af68711-5b7e-44fb-822c-e24811ce8483">
        <source>deleteCargoGroupAndAssocTIs();


vars

	terminal				: CM_Terminal;
	dsl						: UT_DSL;
	ti						: Object;
	ediFile					: CM_EDIFile;
	passportTerm			: CM_Terminal;
	release					: CM_BulkRelease;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;
	pinsStrDict				: CM_StringDict;

	trackedItemId			: String;
	ediData 				: String;	
	cargoGroupId			: String;
	termID					: String;
	
begin

	
	app.initialize();
	
	create dsl transient;
	dsl.setActiveProfileMDHONLY();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	termID := "Enter Terminal Code";
	read termID;
	
	terminal := app.myRoot.allTerminals[termID];
	if terminal = null then
		return;
	endif;
	
	dsl.opts.purge();
	dsl.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	cargoGroupId := "Enter Cargo Group ID";
	read cargoGroupId;
	
	// delete the vehicle
	dsl.deleteCargoGroup(cargoGroupId);
	
epilog

	app.myPassport.setMyTerminal(passportTerm);

	delete dsl;
	
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="deleteInvalidSTRTQEntry" id="28f32b17-758c-49af-b5a1-37b8c08dbe9f">
        <source>deleteInvalidSTRTQEntry();
/*

Purpose:		Deletes and RTQ entry that has either and invalid source or target

Date			Who		Reason
11/06/2013		cnwmh5	Initial creation

*/

vars

	rtqEntry				: CM_RTQueueEntry;
	obj						: Object;
	
	objArray				: ObjectArray;
	
	oid						: String;

begin

	app.initialize();

	oid := "&lt;RTQ Entry oid&gt;";
	read oid;

	rtqEntry := oid.asObject.CM_RTQueueEntry;
	if (rtqEntry = null) then
		write "unable to find RTQ Entry (" &amp; oid.String &amp; ").  Exiting JadeScript";
		return;
	endif;
	
	
	create objArray transient;
	rtqEntry.allTasks.copy(objArray);
	
	beginTransaction;
	foreach obj in objArray do
		delete obj;
	endforeach;
	commitTransaction;
	
	beginTransaction;
	delete rtqEntry;
	commitTransaction;
	
epilog

	delete objArray;

end;</source>
    </JadeMethod>
