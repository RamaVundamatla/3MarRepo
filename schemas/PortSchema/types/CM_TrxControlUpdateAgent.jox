    <JadeMethod name="trxUpdateStorageConfig" id="f47d7f0b-83e6-401a-a82a-b1dff39bfafa">
        <updating/>
        <source>trxUpdateStorageConfig(_proxyStorageConfig : CM_StorageConfig input;
						_allExtraDayCargoTypes :  IntegerArray input;
						_passport : CM_Passport input) updating;
// 13 September 2012	cnwjre1	CCMS SFW 1295 Free Storage Days
// 23/3/22 jlier1	 TFS 52292
//14/06/2023	navkc1	CR 58007 Defect 58623: Audit option not working on Storage Config Screen for "Cargo Types for Extra Days Storage" tab
vars
	storageConfigSSL 	: CM_StorageConfigTypeSSL;
	audit				: CM_UpdateTransactionAuditAgent;	//14/06/2023	navkc1	CR 58007 Defect 58623
	storageConfig 		: CM_StorageConfig;					//14/06/2023	navkc1	CR 58007 Defect 58623
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	//14/06/2023	navkc1	CR 58007 Defect 58623 - We do audit here because we want to include any changes to _allExtractDayCargoTypes in CM_StorageConfig audit;
	create audit transient;
	storageConfig := _proxyStorageConfig.pxyGetRealObject();
	audit.audUpdateGeneric(storageConfig, true);
	
	beginTransaction;
	app.myUtilityUA.utlUpdateStorageConfig(_proxyStorageConfig, _passport);
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	storageConfigSSL:=CM_StorageConfigTypeSSL.firstInstance;
	if _allExtraDayCargoTypes  &lt;&gt; null and storageConfigSSL &lt;&gt; null  then
		app.myUtilityUA.utlUpdateStorageConfigTypeSSL(_allExtraDayCargoTypes,_passport);
	endif;
	
	//14/06/2023	navkc1	CR 58007 Defect 58623
	audit.audUpdateGeneric(storageConfig, false);
	
epilog
	delete audit;
	self.finaliseActivityWithPassport(_passport);
end;
</source>
        <Parameter name="_proxyStorageConfig" type="CM_StorageConfig" usage="input"/>
        <Parameter name="_allExtraDayCargoTypes" type="IntegerArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
