    <JadeMethod name="getObjects" id="fa830a7c-b0d2-48dc-acea-6a02f7c827a9">
        <source>getObjects(objects: ObjectLongNameDict input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/09/2013	cnwdap1		Initial creation PAR #32215
//
vars
	vehicleMake    : CM_VehicleMake;
	
begin
	foreach vehicleMake in app.myDutyDocRoot.allVehicleMakes do 
		objects[vehicleMake.getYADisplay()] := vehicleMake;
	endforeach;
epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
