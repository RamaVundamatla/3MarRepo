begin
	if self.myHMSVoyageData = null then
		return null;
	endif;
	
	if _dateTime.isValid() then  //if its valid use it.  If not leave ts alone which becomes current time
		ts := _dateTime;
	endif;
	
	//hmsBerth := self.myHMSVoyageData.getBerthForDateTime(_dateTime);
	hmsBerth := self.myHMSVoyageData.getBerthForDateTime(ts);
	
