        <updating/>
        <source>removeRegisteredKey(_key : Integer) updating;
// THIS METHOD SHOULD BE CALLED AFTER CREATE METHOD FROM LOAD FORM METHODS.
vars

begin

	if self.allRegisteredKeyCodes.includes(_key) then
