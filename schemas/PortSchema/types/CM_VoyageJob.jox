    <JadeMethod name="canBeTwinLiftCheckHeights" id="4be327ae-a6c7-483d-9dbd-fb1e3ed9293e">
        <source>canBeTwinLiftCheckHeights() : Boolean;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2014		CNWAB1		Initial creation
*/

vars
	aTerm : CM_Terminal;
	shipSLiftIfDiffHeights : Boolean;
	req : CM_Request;
	aftReq, fwdReq : CM_SlotRequest;
	fwdWLE, aftWLE : CM_VoyageWLE;
	fwdTI, aftTI : CM_TrackedItem;
	reason : String;
	aCrane : CM_Crane;
	maxLiftWeightTL : Integer;
begin
	
	aTerm := self.getMyTerminal();
	if aTerm = null then
		return true;
	endif;
	
	shipSLiftIfDiffHeights := aTerm.getConfig(ShipSLiftIfDiffHeights).Boolean;
	
	if not shipSLiftIfDiffHeights then
		return true;
	endif;
	
	foreach req in self.allRequests discreteLock do
		aftReq := req.CM_SlotRequest;
		
		if req.getAttrIs40() then
			continue;
		endif;
		if  not aftReq.isAftBay() then
			continue;
		endif;
		reason := null;
		
		if not aftReq.isFwdSlotReqSameHeightBelow(reason) then
			return false;
		endif;
	endforeach;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeTwinLiftVoyageJob" id="7f8ce7ac-f109-48b3-8a4e-29dd4ff084ba">
        <source>canBeTwinLiftVoyageJob() : Boolean;
// -------------------------------------------
// Created 20 September 2005 by cnwdvb1
// -------------------------------------------
vars

	slotRequest	: CM_SlotRequest;
	request 	: CM_Request;
	crane		: CM_Crane;
	num20s : Integer;
begin

	// Can't tell if it should be a twin lift.
	if self.myJobSheet = null then
		app.writeLog(method.qualifiedName &amp; "TWINLIFT: No job sheet, can not be twin lift",LogINFO);
		return false;
	endif;
	
	crane := self.myJobSheet.CM_VoyageJobSheet.getMyCrane();
	// Can't tell if it should be a twin lift.
	if crane = null then
		app.writeLog(method.qualifiedName &amp; "TWINLIFT: No Crane associated with job, can not be twin lift",LogINFO);
		return false;
	endif;
	
	// Crane can't handle it.
	//if not crane.canTwinLift then
	if crane.machineLiftType = NORMAL_LIFT then//ccms1595 27/11/07
		app.writeLog(method.qualifiedName &amp; "TWINLIFT: Crane is not twin lift",LogINFO);
		return false;
	endif;
	
	// CCMS 1414
	if not self.canBeTwinLiftVoyageJobBays() then
		app.writeLog(method.qualifiedName &amp; "TWINLIFT: Voyage bay definition can not accept twin lift",LogINFO);
		return false;
	endif;
	
	/* PAR 25933 - Not sure what Richard was smoking when he decided to change this, 
						but his change meant that you cannot have a mixed 20/40 twin lift job, which you should be able to have.
	// PAR 24436 - switch around after renaming method
	//if self.hasOnlyFortyFootRequests() then
	if (not self.hasOnlyTwentyFootRequests()) then
		app.writeStatement(method.qualifiedName &amp; " Has non-twenty foot requests - cannot twinlift" );
		return false;
	endif;
	NOW */
	
	// If the job has only 40s then we do not tick it as a twin lift
	if self.hasOnlyFortyFootRequests() then
		app.writeLog(method.qualifiedName &amp; "TWINLIFT: Only has forty foot requests" ,LogINFO);
		return false;
	endif;
	
	if not self.canBeTwinLiftVoyageJobRequests() then
		app.writeLog(method.qualifiedName &amp; "TWINLIFT: Job requests are not twin lift."  ,LogINFO);
		return false;
	endif;
	
	
	// PAR 34834
// PAR 35031 	if not self.canBeTwinLiftCheckHeights() then
// PAR 35031 		app.writeLog(method.qualifiedName &amp; "TWINLIFT: Job items are different height so no twin lift"  ,LogAlways);
// PAR 35031 		return false;
	
// PAR 35031 	endif;
	

	return true; // by default PAR 18445



end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeTwinLiftVoyageJobBays" id="a3723d9e-8426-429a-95bd-658d7ad8642c">
        <source>canBeTwinLiftVoyageJobBays() : Boolean;
// ---------------------------------------------------------------------------
// Created:		27 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	bayOne, bayTwo : CM_Bay;
	isOnDeck, isTL : Boolean;
	aSlotRequest : CM_SlotRequest;
	aReq : CM_Request;
	theBay : CM_Bay;
begin
	isOnDeck := (self.ordinalDeck = DeckOnDeck);
	//	WAS self.getBays(bayOne, bayTwo); // PAR 18613
	
	// NOW // PAR 18613
	
	foreach aReq in self.allRequests do
		aSlotRequest := aReq.CM_SlotRequest;
		theBay := aSlotRequest.myBay;
		if theBay = null then
			theBay := aSlotRequest.mySlotController.myBayVoyage;
		endif;
		
		if bayOne = null then
			bayOne := theBay;
		elseif theBay &lt;&gt; bayOne then
			bayTwo := theBay;
			break;
		endif;
	endforeach;
	if self.allRequests.size = 0 then
		bayOne:=self.myVoyage.lookupBayVoyage(self.bayId);
	endif;
	// #####
	
	if bayOne &lt;&gt; null then
		if bayTwo &lt;&gt; null then
			// ### HAVE 2 bays for this job check both bays
			if isOnDeck then
				isTL := (bayOne.isTwinLiftOD and bayTwo.isTwinLiftOD);
			else
				isTL := (bayOne.isTwinLiftUD and bayTwo.isTwinLiftUD);
			endif;
		else
			return false; // PAR 18613 only 1 bay so is SINGLE LIFT
			/*// PAR 18613
			// ### Only 1 bay, but this can be overidden - HOW?
			if isOnDeck then
				isTL := (bayOne.isTwinLiftOD);
			else
				isTL := (bayOne.isTwinLiftUD);
			endif;
			*/
		endif;
	/*// PAR 18613
	elseif bayTwo &lt;&gt; null then
		// ### Only 1 bay, but this can be overidden
		if isOnDeck then
			isTL := (bayTwo.isTwinLiftOD);
		else
			isTL := (bayTwo.isTwinLiftUD);
		endif;
*/	
	else
		return false;
	endif;
	return isTL;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeTwinLiftVoyageJobRequests" id="ea5ab1b4-83bc-4b7a-a27d-3a0c552cd4f6">
        <source>canBeTwinLiftVoyageJobRequests() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     March 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	slotRequest	: CM_SlotRequest;
	request 	: CM_Request;
begin


	foreach request in self.allRequests discreteLock do
		slotRequest := request.CM_SlotRequest;
		if self.myVoyage.starboardBerthed then
			if slotRequest.isTwinLiftStarboard then
				return true;
			endif;
		else
			if slotRequest.isTwinLiftPort then
				return true;
			endif;
		endif;
	endforeach;
	// Return false by default.
	return false;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="causeTerminalEvent" id="0db69299-c314-42df-a50e-21b620368014">
        <source>causeTerminalEvent(_mode: Integer);
//--------------------------------------------------------------
//Created: 02 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_mode);
	if _mode = self.Event_Mode_Create then
		app.myEventManager.createSingleObjInfoNoteEvt(self.myVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event), self);					
	elseif _mode = self.Event_Mode_Update then
		app.myEventManager.createSingleObjInfoNoteEvt(self.myVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Update_Event), self);		 				
	elseif _mode = self.Event_Mode_Delete then
		app.myEventManager.createSingleObjInfoNoteEvt(self.myVoyage,self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event),self);	 //epr TFS 830 30/3/2017 make sure only one note sent						
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode ' &amp; _mode.String);
	endif;
	
end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="changeStatus" id="562c3828-cbc9-4fe0-bcce-2df114792d7f">
        <updating/>
        <source>changeStatus(newStatus : Integer) updating;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 22/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 06/12/2021	navdap1		TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
//
vars
	oldStatus : Integer;
begin

	exclusiveLock(self);

	oldStatus := self.status;

	if oldStatus = newStatus then //No change
	  	return;
	  endif;

	if newStatus = JOB_UNACTIONED then
		 //anyone can set to undefined as a precursor to deletion
		 self.deleteAllRRPs();	//23 Mar 2020	NDL	TFS 47004
		 
	elseif newStatus = JOB_PART_COMPLETE then
		if ( oldStatus &lt;&gt; JOB_UNACTIONED ) and ( not self.isLoadedToOperations ) then
			//if not self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean then			// TFS 52360	// TFS 52293
			if not self.isDirectDeliveryJob then											// TFS 52360	// TFS 52293
				app.setContinueCMExceptions(false);
				app.raiseCMException(ERR_JOB_STATUS, null, null);
				return;		
			endif;																			// TFS 52360
		endif;

	elseif newStatus = JOB_COMPLETE then
		//self.createTISnapShots();
	else
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_JOB_STATUS, null, null);
		return;	
	endif;
	self.status := newStatus;

end;</source>
        <Parameter name="newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="check20TLHeightLimits" id="72d9365a-c48c-4d2c-9dc3-8f3d531a32db">
        <source>check20TLHeightLimits(_theJobParams:CMIF_VoyageJobParams input;_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		16 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		If lifting 2 20's do either of these could be a different height from each other, 
//					if they are a diff height then they and all above in that cell must be single lift.
//
// ---------------------------------------------------------------------------
vars
	aTerm : CM_Terminal;
	shipSLiftIfDiffHeights : Boolean;
	req : CM_Request;
	aftReq, fwdReq : CM_SlotRequest;
	fwdWLE, aftWLE : CM_VoyageWLE;
	fwdTI, aftTI : CM_TrackedItem;
	reason : String;
	aCrane : CM_Crane;
	maxLiftWeightTL : Integer;
begin
	if not self.isTwinLift then
//		return; // PAR 21596
	endif;
	
	aTerm := self.getMyTerminal();
	if aTerm = null then
		return;
	endif;
	
	shipSLiftIfDiffHeights := aTerm.getConfig(ShipSLiftIfDiffHeights).Boolean;
	
	if not shipSLiftIfDiffHeights then
		return;
	endif;
	
	foreach req in self.allRequests discreteLock do
		aftReq := req.CM_SlotRequest;
		
		if req.getAttrIs40() then
			continue;
		endif;
		if  not aftReq.isAftBay() then
			continue;
		endif;
		reason := null;
		



		if not aftReq.isFwdSlotReqSameHeightBelow(reason) then
			fwdReq := aftReq.getForwardSlotRequest();
			
			if fwdReq &lt;&gt; null and fwdReq.myJob = self then
				aftWLE := aftReq.allWorkListEntries.first.CM_VoyageWLE;
				fwdWLE := fwdReq.allWorkListEntries.first.CM_VoyageWLE;
				
				aftTI := aftWLE.myTrackedItem;
				fwdTI := fwdWLE.myTrackedItem;
				if aftTI &lt;&gt; null then
//					if not _theJobParams.allTIs.includes(aftTI) then
						_theJobParams.allTIs.add(aftTI);
						_theJobParams.allReasons.add("T/L 20' Different Height at " &amp; reason);
						app.writeLog(method.qualifiedName &amp; aftTI.id &amp; "T/L 20' Different Height at " &amp; reason,LogINFO); // PAR 26858
//					endif;
				endif;
				if fwdTI &lt;&gt; null then
//					if not _theJobParams.allTIs.includes(fwdTI) then
						_theJobParams.allTIs.add(fwdTI);
						_theJobParams.allReasons.add("T/L 20' Different Height at " &amp; reason);
						app.writeLog(method.qualifiedName &amp; fwdTI.id &amp; "T/L 20' Different Height at " &amp; reason,LogINFO); // PAR 26858
//					endif;
				endif;
			endif;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="check20TLWeightLimits" id="609caaaa-fd4d-4bdc-8c10-64db627c459a">
        <source>check20TLWeightLimits(_theJobParams:CMIF_VoyageJobParams input;_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		16 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		If lifting 2 20's do either of these exceed the weight limit for either side of the crane?
//
// ---------------------------------------------------------------------------
vars
	aTerm : CM_Terminal;
	shipSLiftIfTLWgtExced : Boolean;
	maxTwinLiftDiff : Decimal[14,4];
	req : CM_Request;
	aftReq, fwdReq : CM_SlotRequest;
	fwdWLE, aftWLE : CM_VoyageWLE;
	fwdTI, aftTI : CM_TrackedItem;
	aCrane : CM_Crane;
	maxLiftWeightTL : Integer;
	idx : Integer;
begin


	if not self.isTwinLift then
//		return; // PAR 21596
	endif;
	
	aTerm := self.getMyTerminal();
	if aTerm = null then
		return;
	endif;

	shipSLiftIfTLWgtExced := aTerm.getConfig(ShipSLiftIfTLWgtExced).Boolean;
	if not shipSLiftIfTLWgtExced then
//		app.writeLog(method.qualifiedName &amp; aftTI.id &amp; " ShipSLiftIfTLWgtExced configured FALSE",LogAlways); // PAR 26858
		return;
	endif;
	aCrane := self.getJobCrane();
	if aCrane = null then
//		app.writeLog(method.qualifiedName &amp; aftTI.id &amp; " Cannot find crane",LogAlways); // PAR 26858
		return;
	endif;
	
	maxLiftWeightTL := aCrane.maxLiftWeightTL;
//	if maxLiftWeightTL = 0 then
//		app.writeLog(method.qualifiedName &amp; aftTI.id &amp; " Crane maxLiftWeightTL set to ZERO",LogAlways); // PAR 26858
//		return;
//	endif;
	app.writeLog(method.qualifiedName &amp; " self.allRequests SIZE: " &amp; self.allRequests.size.String ,LogINFO);
	
	maxTwinLiftDiff := aCrane.weightDifference; // PAR 34958 
	
	// PAR 34958 I reversed how this worked so that it is similar to the check20TLHeightLimits method. i.e. now it works through the AFT requests. Previously this method woked through the FWD req and the get aftreq does not work.
	foreach req in self.allRequests discreteLock do
		aftReq := req.CM_SlotRequest;
		
		if req.getAttrIs40() then
			continue;
		endif;
		if  not aftReq.isAftBay() then
			continue;
		endif;

		fwdReq := aftReq.getForwardSlotRequest();
		
//	app.writeLog(method.qualifiedName &amp; " aftReq: " &amp; aftReq.String &amp; " fwdReq: " &amp; fwdReq.String ,LogAlways);
		
		
		if fwdReq &lt;&gt; null and fwdReq.myJob = self then
		
			aftWLE := aftReq.allWorkListEntries.first.CM_VoyageWLE;
			fwdWLE := fwdReq.allWorkListEntries.first.CM_VoyageWLE;
			
			aftTI := aftWLE.myTrackedItem;
			fwdTI := fwdWLE.myTrackedItem;
			
			if maxLiftWeightTL &gt; 0 then

	//	app.writeLog(method.qualifiedName &amp; " maxLiftWeightTL: " &amp; maxLiftWeightTL.String &amp; " aftTI: " &amp; aftTI.id &amp; " fwdTI: " &amp; fwdTI.id ,LogAlways);
				if aftTI &lt;&gt; null then
					if aftTI.totalWeight &gt; maxLiftWeightTL then
						if not _theJobParams.allTIs.includes(aftTI) then
							_theJobParams.allTIs.add(aftTI);
							_theJobParams.allReasons.add("T/L 20' Weight Lift (" &amp; maxLiftWeightTL.String &amp;") Exceeded");
							app.writeLog(method.qualifiedName &amp; " " &amp; aftTI.id &amp; " T/L 20' Weight Lift (" &amp; maxLiftWeightTL.String &amp;") Exceeded",LogINFO); // PAR 26858
							if fwdTI &lt;&gt; null then // Add in the twin as it will also become SL
								if not _theJobParams.allTIs.includes(fwdTI) then
									_theJobParams.allTIs.add(fwdTI);
									_theJobParams.allReasons.add("T/L 20' Weight Lift (" &amp; maxLiftWeightTL.String &amp;") Exceeded");
								endif;
							endif;
						endif;
					endif;
				endif;
				if fwdTI &lt;&gt; null then
					if fwdTI.totalWeight &gt; maxLiftWeightTL then
						if not _theJobParams.allTIs.includes(fwdTI) then
							_theJobParams.allTIs.add(fwdTI);
							_theJobParams.allReasons.add("T/L 20' Weight Lift (" &amp; maxLiftWeightTL.String &amp;") Exceeded");
							app.writeLog(method.qualifiedName &amp; " " &amp; fwdTI.id &amp; " T/L 20' Weight Lift (" &amp; maxLiftWeightTL.String &amp;") Exceeded",LogINFO); // PAR 26858
							if aftTI &lt;&gt; null then // Add in the twin as it will also become SL
								if not _theJobParams.allTIs.includes(aftTI) then
									_theJobParams.allTIs.add(aftTI);
									_theJobParams.allReasons.add("T/L 20' Weight Lift (" &amp; maxLiftWeightTL.String &amp;") Exceeded");
								endif;
							endif;
						endif;
					endif;
				endif;
			endif;
		
//			app.writeLog(method.qualifiedName &amp; " maxTwinLiftDiff: " &amp; maxTwinLiftDiff.String,LogAlways); // PAR 26858
			
			
			 // PAR 34958 
			if maxTwinLiftDiff &gt; 0 then
	
				if fwdTI &lt;&gt; null and aftTI &lt;&gt; null then
				
	//			app.writeLog(method.qualifiedName &amp; " " &amp; fwdTI.id &amp; " totalWeight: " &amp; fwdTI.totalWeight.String  &amp; " " &amp; aftTI.id &amp; " totalWeight: " &amp; aftTI.totalWeight.String,LogAlways); // PAR 26858
	
				if ((aftTI.totalWeight - fwdTI.totalWeight).abs &gt; maxTwinLiftDiff) then
						app.writeLog(method.qualifiedName &amp; " " &amp; fwdTI.id &amp; "/" &amp; aftTI.id &amp; "  TL WEIGHT DIFFERENCE EXCEEDED" ,LogINFO); // PAR 26858
						_theJobParams.allTIs.add(fwdTI);
						_theJobParams.allReasons.add("T/L 20' Weight Difference (" &amp; maxTwinLiftDiff.String &amp;"kg) Exceeded");
						_theJobParams.allTIs.add(aftTI);
						_theJobParams.allReasons.add("T/L 20' Weight Difference (" &amp; maxTwinLiftDiff.String &amp;"kg) Exceeded");
						
					endif;
				endif;
				
			endif;
		
		endif;
		
		
	endforeach;
	
end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cleanup" id="58ba3d1f-2012-440c-aafc-863a498a98dd">
        <updating/>
        <source>cleanup(numCleaned	:	Integer io) updating;
//Remove ourselves from the Queue if we are complete
begin
	if self.status = JOB_COMPLETE then
		//Thats cool, nuke it!
	else
		return;
	endif;
	if allEntries.isEmpty then
		return;
	endif;
	if not tryLock(self, Exclusive_Lock, Transaction_Duration,	LockTimeout_Server_Defined	) then 
		return;
	endif;
	while allEntries.isEmpty = false do
		// Only remove what we can.
		if not allEntries.last.deleteEntry( false, null) then
			return;
		endif;
	endwhile;
	numCleaned := numCleaned +1;	
end;</source>
        <Parameter name="numCleaned" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="771833cf-9921-4b30-906b-28d1b1c58dbf">
        <source>cloneReferences(_theClone : CM_VoyageJob input);
//--------------------------------------------------------------
//Created: 24 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_theClone);

	_theClone.setJobNum(self.myVoyage.getNextJobNumber(_theClone.myJobSheet.CM_VoyageJobSheet, null).String);	// 19/05/2010 cnwmh5 #22275
	_theClone.myVoyage := self.myVoyage;			// 19/05/2010 cnwmh5 #22275 - Moved here
	
	if self.craneId &lt;&gt; null then
		_theClone.setCrane(null,self.craneId); 
	endif;
	
	
end;</source>
        <Parameter name="_theClone" type="CM_VoyageJob" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="fa7fdf23-cab6-40fa-9f25-73d60cf06597">
