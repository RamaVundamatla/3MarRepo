    <JadeMethod name="myHandHeldAgent" id="1c2bd23d-a8f2-444f-b29d-046698570f4d">
        <methodInvocation>mapping</methodInvocation>
        <source>myHandHeldAgent(set: Boolean; _value: HandHeldAgent io) mapping;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if not set then
		_value := self.myHandHeldCarAgent;
	endif;

end;


</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="MobileHandHeldThin::HandHeldAgent" usage="io"/>
