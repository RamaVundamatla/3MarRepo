    <JadeMethod name="addLogLoadError" id="fc92366a-b13a-46b2-a583-8739c6aa8c01">
        <source>addLogLoadError(_id : String; _log : CM_Log; _errStr : String; _errNum : Integer);
// ---------------------------------------------------------------------------
// Created:     30 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpLoadError,
	logLoadError	: CM_LogLoadError;

begin

	logLoadError := self.allLogLoadErrors[_id];

	if logLoadError = null then
		create logLoadError persistent;
		logLoadError.set(_id, self, _log, _errStr, _errNum);
	else
		//logLoadError.addErrorMsgNo(_errStr, _errNum);
		// Not found on site and Already on another voyage errors 
		// don't have their "myLog" reference set, so must update reference as well.
		logLoadError.setForUpdate(_log, _errStr, _errNum);		
	endif;

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_log" type="CM_Log"/>
        <Parameter name="_errStr" type="String"/>
        <Parameter name="_errNum" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addNoNumLogsByEDILogsNN" id="ade06b91-944f-449a-a825-1fd692e27972">
        <updating/>
        <source>addNoNumLogsByEDILogsNN(_ediLogs : CM_EDILogByIdDict; _passport : CM_Passport input): Boolean updating;
//--------------------------------------------------------------
//Created: 19 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ediLog			: CM_EDIBOLOutLogTI;
	tiControl 		: CMIF_TIUpdateController;
	pxyLogNN	 	: CM_LogNoNumber;
	tiSet			: CM_TISet;
	conditionCode	: String;
	term			: CM_Terminal;
	bolOut			: CM_BOLOut;
	sed				: Decimal[6,2];
begin
	
	if _ediLogs = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null collection passed to method. Contact Developer.');
		return false;
	endif;
	
	bolOut 			:= self.myBOL.CM_BOLOut;	
	term 			:= bolOut.myTerminal;
	conditionCode 	:= term.getConfig(LogDefaultConditionCode).String;

	tiControl := app.createTIUpdateControl(TI_UPDMODE_NORMAL,null, null);
	tiControl.transactionType := TRANS_TYPE_CREATED;
		
	create tiSet transient;	
		
	foreach ediLog in _ediLogs do
		create pxyLogNN transient;
		if ediLog.jasVolume &gt; 0 then			
			sed := global.calcSEDMeanFromVolume(ediLog.jasVolume, ediLog.logLength);
		else
			// PAR 10166 - No volume, not scaled
			sed := NULL_UNSCALED_LOG_SED;
		endif;
		pxyLogNN.setLogUnscaledNoNumber(bolOut, sed, conditionCode, term.logNextSeqNoNumber, null, tiControl, null, _passport);
		pxyLogNN.setFromEDILog(ediLog, _passport);
		tiSet.add(pxyLogNN);
	endforeach;
	
	tiControl.setMyTransientTIs(tiSet);

	app.myUtilityCA.utlCreateTrackedItems(tiControl, _passport);
	if _passport.hasErrors then
		return false;
	endif;

	return true;
	
epilog
	delete tiControl;
	delete tiSet;
end;</source>
        <Parameter name="_ediLogs" type="CM_EDILogByIdDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addNoNumberLog" id="eacfa25e-b3c3-4be6-bf4f-f2073a025c18">
        <updating/>
        <source>addNoNumberLog(_passport : CM_Passport input): CM_LogNoNumber updating;
//--------------------------------------------------------------
//Created: 19 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tiControl 			: CMIF_TIUpdateController;
	pxyLog				: CM_LogNoNumber;
	newLog				: CM_TrackedItem;
	newId, noNumberID	: String;
	conditionCode		: String;
	term				: CM_Terminal;
	bolOut				: CM_BOLOut;
	sed					: Decimal[6,2];
begin

	sed := self.averageSED;
	if sed = 0 then
		//Try setting as docket may have been updated
		self.setAverageSED();
		sed := self.averageSED;
	endif;

	bolOut 			:= self.myBOL.CM_BOLOut;	
	term 			:= bolOut.myTerminal;
	conditionCode 	:= term.getConfig(LogDefaultConditionCode).String;
	tiControl 		:= app.createTIUpdateControl(TI_UPDMODE_NORMAL, null, null);
	//To speed things up we create one log first and validate it. If all OK then the rest are cloned.
	create pxyLog transient;
	
	pxyLog.setLogUnscaledNoNumber(bolOut, sed, conditionCode, term.logNextSeqNoNumber, null, tiControl, null, _passport);
	pxyLog.validateTrackedItem(tiControl, _passport);
	if (not _passport.noErrors) then
		return null;
	endif;
	
	newLog := term.createTrackedItem(pxyLog, _passport);

	newLog.changeState(TI_STATE_NORMAL, _passport);
	newLog.setMyVoyage(bolOut.myVoyage, _passport);

	return newLog.CM_LogNoNumber;	

epilog
	delete tiControl;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_LogNoNumber"/>
    </JadeMethod>
    <JadeMethod name="addNoNumberLogsByNumOfNN" id="3ee63f80-3dfc-44b9-8830-ba6d5b86c646">
        <updating/>
        <source>addNoNumberLogsByNumOfNN(_numberToCreate : Integer; _passport : CM_Passport input): Boolean updating;
//--------------------------------------------------------------
//Created: 19 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tiControl 			: CMIF_TIUpdateController;
	tiSet				: CM_TISet;
	pxyLog, clonedLog,
	realLog		 		: CM_LogNoNumber;
	ti					: CM_TrackedItem;
	newId, noNumberID	: String;
	pieceCount			: Integer;
	conditionCode		: String;
	term				: CM_Terminal;
	bolOut				: CM_BOLOut;
	sed					: Decimal[6,2];
	moveController		: CMIF_MoveController;
begin

	if _numberToCreate &lt; 1 then
		return true;	//nothing to do here
	endif;
	
	sed := self.averageSED;
	if sed = 0 then
		self.setAverageSED();
		//PAR 17929  inorder to accept 'N' for No Number
		sed := self.averageSED;	// PAR 17929
	endif;
	
	bolOut 			:= self.myBOL.CM_BOLOut;	
	term 			:= bolOut.myTerminal;
	conditionCode 	:= term.getConfig(LogDefaultConditionCode).String;

	tiControl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode, null);
	tiControl.transactionType := TRANS_TYPE_CREATED;
	
	//To speed things up we create one log first and validate it. If all OK then the rest are cloned.
	create pxyLog transient;
	pieceCount := (_numberToCreate - 1); //Less the first log created 	
	pxyLog.setLogUnscaledNoNumber(bolOut, sed, conditionCode, term.logNextSeqNoNumber, null, tiControl, null, _passport);
	//pxyLog.setFromBOLOut(bolOut);
	//pxyLog.setForUnscaledLog(sed, conditionCode, term.logNextSeqNoNumber);

	create tiSet transient;
	tiSet.add(pxyLog);	

	tiControl.setMyTransientTIs(tiSet);	
	app.myUtilityCA.utlCreateTrackedItems(tiControl, _passport);
	if not _passport.noErrors() then
		return false;
	endif;

	realLog := tiControl.allPersistentTIs.first.CM_LogNoNumber;
	realLog.setMyVoyage(bolOut.myVoyage, _passport);
	realLog.changeState(TI_STATE_NORMAL, _passport);
	
	create moveController transient;
	moveController.setMoveMode(REAL_MODE);

	while pieceCount &gt; 0 do		
		clonedLog := realLog.cloneSelf(false); 
		clonedLog.setCloneIdReferences(term.logNextSeqNoNumber, realLog, false, tiControl, moveController, _passport);
		//Moved to above setCloneIdReferences. One call does all.		
		//clonedLog.changeId(term.logNextSeqNoNumber);
		// have to clone some references here!!!
		//clonedLog.cloneReferences(realLog, tiControl);
		pieceCount := (pieceCount - 1);
	endwhile;	

	if _passport.hasErrors then
		return false;
	endif;

	return true;
	
epilog
	if tiControl &lt;&gt; null then
		delete tiControl;
	endif;
	if tiSet &lt;&gt; null then
		delete tiSet;
	endif;
	delete moveController;

end;</source>
        <Parameter name="_numberToCreate" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="causeTerminalEvent" id="002fe198-da35-4b37-af85-6149daaa722f">
        <updating/>
        <source>causeTerminalEvent(_eventType : Integer)updating;
//--------------------------------------------------------------
//Created: 11 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpVoyage : CM_Voyage;
begin
	if _eventType = null then
		return;
	endif;
	tmpVoyage := self.myVoyage;
	if tmpVoyage &lt;&gt; null then
		global.causeEvent(_eventType, false, tmpVoyage);		
	endif;
end;</source>
        <Parameter name="_eventType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="checkLoadedFlags" id="c2cb5a0b-4482-4da0-95c0-eeb9bacdd8dc">
        <updating/>
        <source>checkLoadedFlags(_updateFlags : Boolean) updating;
//--------------------------------------------------------------
//Created: 19 June 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	ti 			: CM_TrackedItem;
	tiSet		: CM_TISet;
	bol 		: CM_BOLOut;
	loadedFound,
	stillToLoadFound	: Boolean;
	
begin
	
	bol 	:= self.myBOL.CM_BOLOut;
	tiSet 	:= bol.allTrackedItems;
	
	foreach ti in tiSet do
		if ti.site = TI_SITE_ONSHIP then
			loadedFound := true;
		else
			stillToLoadFound := true;
		endif;
		if loadedFound and stillToLoadFound then
			break;
		endif;
	endforeach;
	
	if _updateFlags then
		self.isPartiallyLoaded := loadedFound;
		if (not self.isInError) and (not stillToLoadFound) then
			self.isFullyLoaded := true;
		else
			self.isFullyLoaded := false;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_updateFlags" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="a024b490-a725-4260-8914-8c18297e29f5">
        <updating/>
        <source>cloneReferences(_ext: CM_BOLExtLogOut) updating;

// cnwdvb1 14 October 2002 

vars

begin

	inheritMethod(_ext);
	self.myLogLot		:= _ext.myLogLot;

end;</source>
        <Parameter name="_ext" type="CM_BOLExtLogOut"/>
    </JadeMethod>
    <JadeMethod name="detachTI" id="703e6722-89ab-4955-9e9e-48cb9bb2000f">
        <updating/>
        <source>detachTI(_log : CM_Log input)updating;
//--------------------------------------------------------------
//Created: 25 September 2002 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
22 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	tmpId : String;
	iter : Iterator;
	loadErr : CM_LogLoadError;
begin
	exclusiveLock(self);
	self.myBOL.detachTI(_log);
	self.setPartiallyLoaded();			
	self.setMyLogVoyageIfInError();
	self.setJasVolume(_log.myTerminal);

//	loadErr := self.allLogLoadErrors[_log.id];
	
	tmpId := _log.id;
	iter := self.allLogLoadErrors.createIterator;
	self.allLogLoadErrors.startKeyGeq(tmpId, iter);

	while iter.next(loadErr) do
		if loadErr.id &lt;&gt; tmpId then
			break;
		endif;
		if loadErr &lt;&gt; null then
			loadErr.erase(NORMAL_ERASE);
		endif;		
	endwhile;
	
epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_log" type="CM_Log" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMoveToLocation" id="1125df76-481c-4efb-8b74-d43b8f94098e">
        <updating/>
        <source>doMoveToLocation(_mode: Integer;  _newLocn : CM_LocationsController; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 20 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti				: CM_TrackedItem;
	moveController 	: CMIF_MoveController;

begin

	create moveController transient;	
	self.setLogsToLoadOut(moveController.allOtherTrackedItems, _passport);

	if moveController.allOtherTrackedItems.isEmpty then
		//nothing to move so lets get out of here
		return;
	endif;
	// Initialise move controller parameters.
	moveController.isSystemMove 	:= true;
	moveController.isForcedMove 	:= true;
	moveController.setMoveMode(_mode);
	moveController.setJobForMove(self.myBOL.myYardJob);		
	moveController.setMyToPrimaryLocation(_newLocn);
	
	ti := moveController.allOtherTrackedItems.first();
	moveController.setMyTrackedItem(ti);
	moveController.allOtherTrackedItems.remove(ti);
	//Par10286
	/*if self.loadDateTime.isValid then
		moveController.setEffectiveTimeStampOverride(self.loadDateTime);
	endif;*/
	moveController.setEffectiveTimeStampOverride(app.serverTimestampAtTrxStart);	

	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	if _passport.hasErrors then
		return;
	endif;
	if self.isInError then
		self.isPartiallyLoaded := true;
	else
		self.isPartiallyLoaded := false;
		self.checkLoadedFlags(true);
		if self.isFullyLoaded then
			self.setMyLogVoyageIfInError();
		endif;
	endif;
	
epilog
	delete moveController;		
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_newLocn" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doVoyageTransfer" id="252a8745-904f-4f17-be02-63edfd3a7a83">
        <updating/>
        <source>doVoyageTransfer(_mode: Integer;  _newLocn : CM_LocationsController; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 20 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti						: CM_TrackedItem;
	moveController 			: CMIF_MoveController;
	cancelSave, firstTime 	: Boolean;
	tmpLogsToMove			: CM_TISet;
begin

	tmpLogsToMove := self.myBOL.allTrackedItems;

	create moveController transient;
	
	moveController.isSystemMove 	:= true;
	moveController.isForcedMove 	:= true;
	moveController.setMoveMode(_mode);
	moveController.setJobForMove(self.myBOL.myYardJob);		
	moveController.setMyToPrimaryLocation(_newLocn);
	
	firstTime := true;
	
	foreach ti in tmpLogsToMove do
		if firstTime then
			moveController.setMyTrackedItem(ti);
			firstTime := false;
			continue;
		endif;
		moveController.allOtherTrackedItems.add(ti);
	endforeach;

	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);

	if (not _passport.noErrors) then
		return;
	endif;
	if self.isInError then
		self.isPartiallyLoaded := true;
	else
		self.isPartiallyLoaded := false;
	endif;
	
epilog
	delete moveController;		
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_newLocn" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executeMoveForMode" id="400411a3-d333-4477-a856-c279b31b9727">
        <updating/>
        <source>executeMoveForMode(_moveMode: Integer; _passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 23 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	transMode : Integer;
	tmpVoyage : CM_Voyage;
begin

	inheritMethod(_moveMode, _passport);
	
	transMode := self.myBOL.transportMode;
	
	if transMode = TI_TRANSMODE_SHIP then
		self.doMoveToLocation(_moveMode, self.myBOL.myPlannedLocation, _passport);
		tmpVoyage := self.myVoyage;
		if tmpVoyage &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(tmpVoyage, tmpVoyage.myTerminal.getTerminalEvent(LogVoyageOps_Update_Event), tmpVoyage);		
		endif;

	elseif transMode = TI_TRANSMODE_ROAD then //WIP: may be able to use the same
		self.doMoveToLocation(_moveMode, self.myBOL.myPlannedLocation, _passport);
			
	elseif transMode = TI_TRANSMODE_RAIL then
		//Not implemented yet
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown Transport Mode (' &amp; transMode.String &amp; ')');
	endif;

	//Always becomes null even if no logs loaded
//	self.myLogVoyageNotLoaded := null;
	self.myLogVoyageStructNotLoaded := null;
	self.causeTerminalEvent(LogVoyageOps_Update_Event);
			
end;</source>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="0701e053-da3e-4abe-bbc9-ab6a497beaed">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     26 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	if _attrName = ETRow_NoNumber then
		return self.numberOfNoNumbers.String;
	elseif _attrName = ETRow_SssOpt then
		return 'true';
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumberNotFoundErrors" id="5408da12-9b97-4766-b9e7-156280f431e8">
        <source>getNumberNotFoundErrors(): Integer;
//--------------------------------------------------------------
//Created: 03 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	count : Integer;
	loadErr : CM_LogLoadError;
begin
	
	foreach loadErr in self.allLogLoadErrors do
		if loadErr.myLog = null then
			count := count +1;
		endif;	
	endforeach;
	
	return count;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isInError" id="98510093-eb32-4c96-b64b-611437b1e29f">
        <methodInvocation>mapping</methodInvocation>
        <source>isInError(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     27 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := (self.allLogLoadErrors.size &gt; 0);

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
