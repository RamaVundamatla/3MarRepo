    <JadeMethod name="getAuditText" id="72bd654f-5888-4285-a60d-708475b3732f">
        <source>getAuditText(): String;
//
// 05 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	auditStr : String;
	tmpStr : String;
	terminal : CM_Terminal;
begin
	auditStr := inheritMethod();
	if self.ediConfig &lt;&gt; null then
		terminal := self.ediConfig.myTerminal;
		if terminal &lt;&gt; null then
			tmpStr := terminal.auditId;
			auditStr := auditStr &amp; "terminal" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
	endif;
	return auditStr;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="6bbe238b-34bd-4178-9864-9aaf265e8733">
        <source>getAuditTextForProperty(_property: Property): String;
//
// 05 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	propName : String;
	tmpStr : String;
begin
	propName :=	_property.name;
	if propName = CM_EDIData::ediDataType.name then
		tmpStr := self.getDisplayStringForAttribute(ETRow_DataType, true);
		return propName &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	elseif propName = CM_EDIData::ediFileCode.name then
		tmpStr := self.getDisplayStringForAttribute(propName, true);
		return propName &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	else
		return inheritMethod(_property);
	endif;
end;
</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
