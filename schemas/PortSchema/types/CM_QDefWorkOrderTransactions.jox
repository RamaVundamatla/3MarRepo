	qProp.set('Wagon Number', CM_WOTransaction::getWagonCode.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	//Start 20.06.2024 navhl20 #64718
	create qProp as CM_QStringMethod persistent;
	qProp.set('Vehicle Visit Record', CM_WOTransaction::getVVRCode.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
