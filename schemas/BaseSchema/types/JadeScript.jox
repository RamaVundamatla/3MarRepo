    <JadeMethod name="cnwdad1_Test_NextDelimitField" id="2c04a88a-934a-48ad-99ae-aa600b179822">
        <updating/>
        <source>cnwdad1_Test_NextDelimitField() updating;
// --------------------------------------------------------------------------------
// Created:		30 August 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
/// Expected the outcome:
// 
// 1    a
// 3    b
// 5    c
// 7
// 8    d
// 1    a
vars
	field		: String;
	pos			: Integer;
	startTime	: Integer;

begin
	startTime	:=	app.clock();
	field		:=	'a^b^c^^d';
	pos			:=	1;
	
	write "String=" &amp; field;
	write "Field " &amp; pos.String &amp; "=" &amp; field.cnEcNextDelimitedField('^', pos);
	write "Field " &amp; pos.String &amp; "=" &amp; field.cnEcNextDelimitedField('^', pos);
	write "Field " &amp; pos.String &amp; "=" &amp; field.cnEcNextDelimitedField('^', pos);
	write "Field " &amp; pos.String &amp; "=" &amp; field.cnEcNextDelimitedField('^', pos);
	write "Field " &amp; pos.String &amp; "=" &amp; field.cnEcNextDelimitedField('^', pos);
	write "Field " &amp; pos.String &amp; "=" &amp; field.cnEcNextDelimitedField('^', pos);		// Should now be back at the start.
epilog
	write "Next Delimited Field completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
