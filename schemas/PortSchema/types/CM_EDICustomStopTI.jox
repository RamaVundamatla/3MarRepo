    <JadeMethod name="getMyTrackedItem" id="48a5a81c-0ed3-45f8-8307-ba334a4b58bf">
        <source>getMyTrackedItem(_ti : CM_TrackedItem io) : Boolean;
// cnwrs1 mar 2006
// cnwrs1 Apr 2009 Par19446
//07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
vars
	id : String;
	invalidTI : Boolean;
	ti	: CM_TrackedItem;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidTI);
	ti := self.myTrackedItem;
	if ti &lt;&gt; null then
		id := ti.id;
		if ti.isDeleted() then //par19446 cnwrs1 Juune 2009
			_ti := null;
			invalidTI := true;
		else
			_ti := ti;
		endif;
	endif;
	return invalidTI;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyage" id="f7159d5a-1fc0-4cea-9c09-8dca7bb9c79b">
        <source>getMyVoyage() : CM_Voyage;

/*
Purpose:		If a voyage is removed for any reason eg garbage collection then
				self.myVoyage is not updated so we need to check that it is still valid,
				do this by assumming it is valid and using an exception handler if it is not.

Parameters:		none
Return Value:	returns either the voyage instance or null

Date			Who		Reason
12 May 2010		cnwrl1	Initial creation as part of PAR 24221 - EDI Custom Stops failing on invalid reference to a deleted voyage.
07/03/2011		cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/
	
vars
	isInvalid	: Boolean;
	voyageCode	: String;
	voyage		: CM_Voyage;
begin

	voyage := self.myVoyage;
	if voyage = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, voyage, isInvalid );
	// Check availability by doing a de-reference
	voyageCode	:= voyage.code;
	if isInvalid then
		return null;
	else
		return voyage;
	endif;
	
epilog
	
end;
</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getNZCSOperator" id="84122e85-2428-4c08-8645-324410a4f0a8">
        <source>getNZCSOperator(documentType : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Jul 2018	jlgsl4	TFS 390133 - Trade Single Window
*/

vars

begin
	if	Valid_TSWExportDocumentNames.pos(documentType, 1) &gt; 0 or
		Valid_TSWImportDocumentNames.pos(documentType, 1) &gt; 0 then
		return NZCS_Operator;
	else
		return "";
	endif;
epilog

end;</source>
        <Parameter name="documentType" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
