    <DbClassMap file="webservice"/>
    <JadeMethod name="includesId" id="ed584aa9-a1e1-44d7-9ed7-57e0829b5ddf">
        <source>includesId(	_id : String ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2018	jlgndl1	Initial creation	Unit Testing

*/

vars

	wsTi : WS_TrackedItem;

begin

	foreach wsTi in self do
		if wsTi.idTextBox = _id then
			return true;
		endif;
	endforeach;
	
	return false;


epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
