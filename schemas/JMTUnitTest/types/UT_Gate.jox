end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseMTWithStops" id="aee11a78-8460-4919-a084-23f69a3d3027">
        <updating/>
        <source>tReleaseMTWithStops() updating;
// cnwdap1
//27 September 2010	cnwml2
//test to set a Custom Entry Stop and a Delivery Stop, these should be set as non active stops when a clearance value is entered
//this is part of PAR25757 - updated by 07/10/2010 PAR 25958
vars
	vvr				: CM_VehicleVisitRecord;
	mt				: CM_Container;
	operator		: CM_Operator;
	beforeImport	: Boolean;
	terminal : CM_Terminal;
	stopsTable : CM_StopsTable;
	stopTableTemplate : CM_StopTableTemplate;
	isChildOnly : Boolean;
	isMT : Boolean;
begin
	terminal := self.getTerminal();
	// cnwrl1 11/10/2010 PAR 25958 - start of coding
	operator	:= self.getOperator( 'UTO2' );
	
	// save off the current operator value, to be restored later.
	beforeImport	:= operator.getRequiresImpOperatorPIN();
	// now for this test make the Import value is on.
	beginTransaction;
	operator.setRequiresImpOperatorPIN( true );
	commitTransaction;
	// cnwrl1 11/10/2010 PAR 25958 - end of coding
	
	// sort out the to be inspected stop
	stopsTable := app.myRoot.allAvailableStopsTables[10];
	if stopsTable &lt;&gt; null then
		// Now see if the stops table template for our terminal exists.
		stopTableTemplate := stopsTable.allStopTableTemplates[terminal, stopsTable];
		if stopTableTemplate &lt;&gt; null then
			isChildOnly := stopTableTemplate.isChildOnly;
			isMT := stopTableTemplate.isMT;
			beginTransaction;
			stopTableTemplate.setPropertyValue(CM_StopTableTemplate::isChildOnly.name, true);
			stopTableTemplate.setPropertyValue(CM_StopTableTemplate::isMT.name, false);
			commitTransaction;
		endif;
	endif;
	
	deleteContainer("UUT12348765");
	deleteVehicle("UTTRUCK");
	
	mt := self.addContainer( "UUT12348765", operator,"2200", "MT", TI_IMEX_STATUS_IMPORT ).CM_Container;
	self.move(mt, bs.myLocationsController);
	// expect stop IDs 1, 35, 42 and 48 to be applied automatically.
	////self.assertEqualMsg( mt.getAllActiveStopsSize, 4, 'There should be 4 stops on this container' );
	
	self.opts.purge;							// 28/05/2013 cnwar2 #31458
	self.opts.addAssoc("OperatorPin", "15975");	// set the opImpRel PIN on the container - the PIN supplied to the gate out
	self.updateTI(mt);							// process belowe will be validated against this
	
	// Now make sure the appropriate release request information is supplied to clear each of these stops!
	self.opts.purge();
	self.opts.addAssoc("customsNumber", "12345");
	self.opts.addAssoc("operImportReleasePin", "15975");
	self.opts.addAssoc("deliveryNumber", "67890");
	
	vvr := gateOutContainer("UTTRUCK", "", "UTDRIVER", mt, true, self.dualGate, null);
	self.deleteStops(mt);
	
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	self.assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, mt);
	
	// have all of the stops been removed?
	self.assertEqualMsg( mt.getAllActiveStopsSize, null, 'Should not be any stops left' );
	
	// Delete the road job 
	self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Cancelled);
	self.assertFalse(mt.isPreNote);	// PAR 23675

epilog
	// cnwrl1 11/10/2010 PAR 25958 - start of coding
	// reset the operator setting to what it was.
	beginTransaction;
	operator.setRequiresImpOperatorPIN( beforeImport );
	commitTransaction;
	// cnwrl1 11/10/2010 PAR 25958 - end of coding
	
	stopsTable := app.myRoot.allAvailableStopsTables[10];
	if stopsTable &lt;&gt; null then
		// Now see if the stops table template for our terminal exists.
		stopTableTemplate := stopsTable.allStopTableTemplates[terminal, stopsTable];
		if stopTableTemplate &lt;&gt; null then
			beginTransaction;
			stopTableTemplate.setPropertyValue(CM_StopTableTemplate::isChildOnly.name, isChildOnly);
			stopTableTemplate.setPropertyValue(CM_StopTableTemplate::isMT.name, isMT);
			commitTransaction;
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseWithAssignedFulls" id="f13f9574-a4fa-4ac8-aa04-c2375468633e">
        <source>tReleaseWithAssignedFulls();
// cnwdap1
//04 November 2009	cnwdw1	
//
vars
	releaseRequest : CM_BulkRelease;
	ti, ti1 : CM_TrackedItem;
	bs : CM_BlockStack;
	vvr1, vvr2, vvr3: CM_VehicleVisitRecord;
	useBestPickDirector : Boolean;
begin

	self.deleteVehicle("UTTRUCK1");
	self.deleteVehicle("UTTRUCK2");
	self.deleteVehicle("UTTRUCK3");

	self.setTerminalConfig(UseBestPickDirector, false);
	
	bs := self.addBlockStack("UTBS1", 100, null);
	
	self.opts.purge;
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("ISOType", "2200");
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertEqual(releaseRequest.status, BR_ACTIVE);
	assertEqual(releaseRequest.fullRelease, true);
	
	ti := self.addContainer("UUT00000001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","GENL",TI_IMEX_STATUS_IMPORT);
	self.move(ti, bs);
	self.releaseAssignCargo(releaseRequest,null, ti);
		
	ti1 := self.addContainer("UUT00000002", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","GENL",TI_IMEX_STATUS_IMPORT);
	self.move(ti1, bs);
	self.releaseAssignCargo(releaseRequest,null, ti1);
	
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	vvr1 := gateOutContainer("UTTRUCK1", "", "UTDRIVER1", null, true, singleGate, null);
	self.assertEqual(vvr1.myRoadJob.workListEntries.size, 1);
	self.assertTrue(vvr1.myRoadJob.workListEntries.first.isQueued);
	self.assertEqual(vvr1.myRoadJob.workListEntries.first.CM_YardWLE.getMySourceLocation.myTerminalArea, bs);

	vvr2 := gateOutContainer("UTTRUCK2", "", "UTDRIVER2", null, true, singleGate, null);
	self.assertEqual(vvr2.myRoadJob.workListEntries.size, 1);
	self.assertTrue(vvr2.myRoadJob.workListEntries.first.isQueued);
	self.assertEqual(vvr2.myRoadJob.workListEntries.first.CM_YardWLE.getMySourceLocation.myTerminalArea, bs);
	
	//self.expectTrxError(84917);
	self.expectTrxError(Error_relea_items_alrea_relea_);
	vvr3 := gateOutContainer("UTTRUCK3", "", "UTDRIVER3", null, true, singleGate, null);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseWithAssignedMTs" id="b47fed52-b417-48c1-b4c0-bb9967027cb3">
        <source>tReleaseWithAssignedMTs();
// cnwdap1
//04 November 2009	cnwdw1	
//
vars
	releaseRequest : CM_BulkRelease;
	ti, ti1 : CM_TrackedItem;
	bs : CM_BlockStack;
	vvr1, vvr2, vvr3: CM_VehicleVisitRecord;
	useBestPickDirector : Boolean;
begin

	self.deleteVehicle("UTTRUCK1");
	self.deleteVehicle("UTTRUCK2");
	self.deleteVehicle("UTTRUCK3");

	self.setTerminalConfig(UseBestPickDirector, false);
	
	bs := self.addBlockStack("UTBS1", 100, null);
	
	self.opts.purge;
	self.opts.addAssoc("FullRelease", false);
	self.opts.addAssoc("ISOType", "2200");
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertEqual(releaseRequest.status, BR_ACTIVE);
	assertEqual(releaseRequest.fullRelease, false);
	
	ti := self.addContainer("UUT00000001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_IMPORT);
	self.move(ti, bs);
	self.releaseAssignCargo(releaseRequest,null, ti);
		
	ti1 := self.addContainer("UUT00000002", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_IMPORT);
	self.move(ti1, bs);
	self.releaseAssignCargo(releaseRequest,null, ti1);
	
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	vvr1 := gateOutContainer("UTTRUCK1", "", "UTDRIVER1", null, true, singleGate, null);
	self.assertEqual(vvr1.myRoadJob.workListEntries.size, 1);
	self.assertTrue(vvr1.myRoadJob.workListEntries.first.isQueued);
	self.assertEqual(vvr1.myRoadJob.workListEntries.first.CM_YardWLE.getMySourceLocation.myTerminalArea, bs);

	vvr2 := gateOutContainer("UTTRUCK2", "", "UTDRIVER2", null, true, singleGate, null);
	self.assertEqual(vvr2.myRoadJob.workListEntries.size, 1);
	self.assertTrue(vvr2.myRoadJob.workListEntries.first.isQueued);
	self.assertEqual(vvr2.myRoadJob.workListEntries.first.CM_YardWLE.getMySourceLocation.myTerminalArea, bs);
	
	//self.expectTrxError(84917);
	self.expectTrxError(Error_relea_items_alrea_relea_);
	vvr3 := gateOutContainer("UTTRUCK3", "", "UTDRIVER3", null, true, singleGate, null);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tTestBatNumberReleased" id="c3e0b83d-7852-4c02-95ec-a7f846ab85e3">
        <source>tTestBatNumberReleased();

/*

Purpose:			Test Bat Number is released from Road Job Correctly	

Date				Who		Reason
08 November 2011	cnwmh5	Initial creation

*/

constants

	CarrierId				: String = "UTMHCAR1";
	CarrierDesc				: String = "Michael's Unit Test Carrier";
	VehicleId				: String = "UTMHTCK1";
	ContainerId				: String = "UTMHAA00001";
	RoadReleaseRequestId	: String = "UTMHROADREL1";
	BlockStackId			: String = "UTMHBS1";
vars

	carrier					: CM_Carrier;
	blockStack				: CM_BlockStack;
	container				: CM_Container;
	operator				: CM_Operator;
	vehicle					: CM_Vehicle;
	releaseRequest			: CM_BulkRelease;
	yardAllocation			: CM_YardAllocation;
	terminal				: CM_Terminal;
	roadJob					: CM_RoadJob;
	
	pinEmailAddresses		: CM_EmailEntityByTypeNameDict;
	
	locations				: CM_LCArray;
		
begin

	// Disable yard allocations
	self.disableAllYA(true);

	// get any default values
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNull(operator);
	terminal := self.getTerminal();
	self.assertNotNull(terminal);

	// delete stuff the needs deleting
	self.deleteVehicle(VehicleId);

	// create the carrier
	self.deleteCarrier(CarrierId);
	create pinEmailAddresses transient;
	carrier := self.addCarrier(CarrierId, CarrierDesc, pinEmailAddresses, false, false, true, null);
	self.assertNotNull(carrier);
	
	// create the blockstack
	self.deleteTerminalArea(BlockStackId);
	blockStack := self.addBlockStack(BlockStackId, 10, null);
	self.assertNotNull(blockStack);
	
	// create the container
	self.deleteContainer(ContainerId);
	container := self.addContainerAtLocation(ContainerId, operator, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController);
	self.assertNotNull(container);
	self.opts.purge;
	self.opts.addAssoc("CENum", "156");
	self.deleteStops(container);
	
		
	// create the release request
	self.deleteReleaseRequest(RoadReleaseRequestId);
	releaseRequest := self.addReleaseById(RoadReleaseRequestId, BR_TYPE_ROAD, container);
	self.assertNotNull(releaseRequest);
	
	// create the vehicle
	self.deleteVehicle(VehicleId);
	vehicle := self.addVehicle(VehicleId, carrier,terminal);
	self.assertNotNull(vehicle);

	// gate out the item
	self.opts.purge();
	self.opts.addAssoc("BatNumber", "01");
	self.gateOutPinRelease(releaseRequest.myPinNo.pinNo, VehicleId);
	
	// get the job and bat number details from the job
	roadJob := vehicle.allRoadJobs.last.CM_RoadJob;
	self.assertNotNull(roadJob);
	
	// complete the job
	self.move(container, vehicle);
	
	self.assertNullMsg(roadJob.myBatNumber, "Road Job's myBatNumber ");
	
epilog
	
	self.opts.purge();
	
	self.disableAllYA(false);
	
	delete pinEmailAddresses;
	delete locations;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTruckEvents" id="d3bba04c-f046-4246-86c4-de3bb558f16e">
        <source>tTruckEvents();
// cnwdap1
// cnwdw1 Gate In container thru to yard, and truck road exit - check that Truck Departure event is created
vars
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
	
begin
	deleteContainer("UUT12345678");
	deleteVehicle("UTTRUCK");

	vvr := gateInContainer("UTTRUCK", "UUT12345678", "2200", operator.code, "MT", dualGate);
		assertNotNull(vvr);
		
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		
	self.moveVehicleToYard(vvr.vehicle);
		
	self.workVehicle(vvr);
		
	self.roadExit(vvr);
		assertNotNull(vvr.getDepartureEvent);
		assertEqual(vvr.getDepartureEvent.myVisit, vvr);
end;</source>
    </JadeMethod>
    <JadeMethod name="tTruckWithTwoDetailsCheck" id="2a04ed66-242b-4ef8-89f1-43510017c05b">
        <source>tTruckWithTwoDetailsCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2025	navhl20 Bug MTN-35305: MTN - Optimize Saving Road Jobs to Avoid Redundant Yard Allocation Checks

*/
constants
	REF				: String  = "35305";
	BULK_REL1 		: String  = "UTRel1"&amp;REF;
	BULK_REL2 		: String  = "UTRel2"&amp;REF;
	TI_ID1 			: String  = "UTC1"&amp;REF;
	TI_ID2 			: String  = "UTC1"&amp;REF;
	TI_ID3 			: String  = "UTC1"&amp;REF;
	TI_ID4 			: String  = "UTC1"&amp;REF;
	TI_ID5 			: String  = "UTC1"&amp;REF;
	BLOCKSTACK 		: String  = "BSF" &amp;REF;
	BLOCKSTACK1 	: String  = "BSS" &amp;REF;
	Voyage			: String  = "UTVoy" &amp; REF;
	TruckId 		: String  = 'UTTRK1'&amp;REF;
vars
	bulkRel						: CM_BulkRelease;
	ti1,
	ti2,
	ti3,
	ti4,
	ti5							: CM_TrackedItem;
	ya,
	ya1							: CM_YardAllocation;
	locations 					: CM_LCArray;
	source1,
	source2						: CM_LocationsController;
	yaName 						: String;
	reserveDet 					: CM_ReserveDetail;
	term 						: CM_Terminal;
	imex						: CM_IMEXStatus;
	bs1,
	bs2							: CM_BlockStack;
	operator					: CM_Operator;
	cargoType					: CM_CargoType;
	voyage 						: CM_Voyage;
	vessel 						: CM_Vessel;
	dischargePort 				: CM_Port;
	gate						: CM_Gate;
	product						: CM_Product;
	terminalUTHelper			: UT_HelperAdmTerm;
	vvr							: CM_VehicleVisitRecord;
	vehicleName, 
	driverName					: String;
	driver						: CM_DriverDetails;
	vehicle						: CM_Vehicle;
begin

	term := self.getTerminal;
	operator := getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);

	self.setTerminalConfig(UseBestPickDirector, false);
	self.disableAllYA(true);
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyYA);
	
	self.deleteReleaseRequest(BULK_REL1);
	self.deleteReleaseRequest(BULK_REL2);
	self.deleteContainer(TI_ID1);
	self.deleteContainer(TI_ID2);
	
	yaName := self.getProfileSetting(UT_Profile.P_YA).asString;
	self.deleteYA(yaName);
	
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_Gate::tTruckWithTwoDetailsCheck;
	
	self.deleteTerminalArea(BLOCKSTACK);
	bs1 := self.addBlockStack(BLOCKSTACK, 5, null);
	self.deleteTerminalArea(BLOCKSTACK1);
	bs2 := self.addBlockStack(BLOCKSTACK1, 5, null);
	self.deleteVoyage(Voyage);
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTHM"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	cargoType := term.allCargoBOLTypes.getCargoTypeByAbbreviation("STEEL COIL").CM_CargoType;
	self.assertNotNullMsg(cargoType, "cargoType");
	
	product := cargoType.getProductFromCode("TIEWIRE10G");
	self.assertNotNullMsg(product, "product");
	
	self.deleteCargo(TI_ID3, cargoType);
	self.deleteCargo(TI_ID4, cargoType);
	self.deleteCargo(TI_ID5, cargoType);
	
	self.opts.purge();
	self.opts.addAssoc("Product", product);
	
	//create Yard Allocation
	create locations transient;
	locations.add(bs1.allLocationsControllers.first.CM_YardController);
	imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT];
	ya := self.addYA(yaName&amp;REF, YACriteriaType_CargoType, cargoType, YACriteriaType_ImexStatus, imex, null, null, locations, null);
	self.assertFalse(ya.isDisabled);
	
	locations.clear();
	locations.add(bs2.allLocationsControllers.first.CM_YardController);
	imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE];
	ya1 := self.addYA1(yaName&amp;"1"&amp;REF, YACriteriaType_ImexStatus, imex, locations);
	self.assertFalse(ya1.isDisabled);
	
	//create Cargo items
	ti1 := self.addContainer(TI_ID1, operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti1, locations.first);
	self.assertEqual(ti1.myPrimaryActualLocation, locations.first);
	
	ti2 := self.addContainer(TI_ID2, operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti2, locations.first);
	self.assertEqual(ti2.myPrimaryActualLocation, locations.first);
	
	ti3 := self.addCargoBreakBulkAtLocation(TI_ID3, cargoType, 500, bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	ti4 := self.addCargoBreakBulkAtLocation(TI_ID4, cargoType, 500, bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	ti5 := self.addCargoBreakBulkAtLocation(TI_ID5, cargoType, 500, bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	
	
	// Vehicle
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	vehicleName := TruckId;
	// Delete Vehicle
	self.deleteVehicle(vehicleName);
	
	self.opts.purge();
	self.opts.addAssoc("YardInterchangeArea", BLOCKSTACK);
	
	// Get the gate
	gate := self.getTerminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, term, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	//Get Driver
	driver := term.allDriversByCode[driverName];
	self.assertNotNullMsg(driver, "driver");
	
	//Get Vehicle
	vehicle :=  term.vehicles.getAtKeyGeq(vehicleName, null);
	self.assertNotNullMsg(vehicle, "vehicle");
	
	// first release request for container
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc(UT_OPTS_Number, 2);
	bulkRel := self.addReleaseByTypeRequestOpts(BULK_REL1, BR_TYPE_ROAD, TI_CargoType_Container);
	self.opts.purge;
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc(UT_OPTS_Number, 2);
	self.opts.addAssoc("Product", product);
	self.addReserveSelectionOpts(bulkRel, BR_TYPE_ROAD, cargoType.id);
	self.assertTrueMsg( bulkRel &lt;&gt; null, "BulkRelease not created" );
	self.assertTrueMsg( not bulkRel.allReserveDetails.isEmpty, "Reserve Details not created" );
	reserveDet := bulkRel.allReserveDetails.first;
	self.assertTrueMsg( reserveDet.isKindOf(CM_ReserveSelection), "No Reserve Selection found" );

	terminalUTHelper.opts.addAssoc("ReleaseRequest", bulkRel);
	terminalUTHelper.opts.addAssoc("both", true);
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,2,bulkRel);
	
	// Make sure that the expected source is found by autoplan
	source1 := app.sourceTisForRequestYA(term, bulkRel.allReserveDetails.first.allRequests.first);
	
	// Make sure that the expected source is found by autoplan
	source2 := app.sourceTisForRequestYA(term, bulkRel.allReserveDetails.last.allRequests.first);
	
	self.assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	terminalUTHelper.opts.purge();
	
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	self.assertEqualMsg(vvr.myRoadJob.workListEntries.first.locationSource, source1.getFullId(), "The source location not updated properly in first WLE");
	self.assertEqualMsg(vvr.myRoadJob.workListEntries.last.locationSource, source2.getFullId(), "The source location not updated properly in second WLE");
epilog
	delete locations;
	self.disableAllYA(false);
	delete terminalUTHelper;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTurnAroundPreNoteBulk" id="cdff0e66-c367-4967-bcde-521b2b74a8a6">
        <source>tTurnAroundPreNoteBulk();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2019	jlgndl1	Initial creation	TFS 46352  and  45270

*/
constants

	BulkId1 : String = "ROADTURN1";
	BulkId2 : String = "ROADTURN2";
	BulkCargoType : String = "UTCOAL";  // Pre existing Bulk cargo type allows duplicates
	TruckIn : String = "UTTRUCKTR";
	TruckIn2 : String = "UTTRUCKTR2";
	
vars

	operator : CM_Operator;
	bCargoType : CM_CargoType;
	truckPreNotes : CM_TISet;
	gate : CM_Gate;
	vvrIn : CM_VehicleVisitRecord;
	vvrIn2 : CM_VehicleVisitRecord;
	bulkTI1 : CM_Bulk;
	bulkTI2 : CM_Bulk;
	wle : CM_WorkListEntry;
	proxyWLE : CM_WorkListEntry;

begin

	//get base data
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	bCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BulkCargoType);
	self.assertTrueMsg(bCargoType &lt;&gt; null, "Cargo Type '" &amp; BulkCargoType &amp; "' not found during setup.");
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.assertTrueMsg(gate &lt;&gt; null, "No gate not found during setup.");
	
	//clean-up old data - if it exists
	
	self.deleteVehicle( TruckIn );
	self.deleteVehicle( TruckIn2 );
	self.deleteCargo( BulkId1, bCargoType );
	self.deleteCargo( BulkId2, bCargoType );
	
	//create pre-note
	create truckPreNotes transient;
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", bCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalWeight", 5000.Integer );
	bulkTI1 := self.addPrenoted( BulkId1 ).CM_Bulk;
	self.assertTrueMsg(bulkTI1 &lt;&gt; null, "'" &amp; BulkId1 &amp; "' not created during setup");
	truckPreNotes.add( bulkTI1 );
	self.opts.purge();
	
	
	self.opts.addAssoc("CargoType", bCargoType.id);
	self.opts.addAssoc("ExportVoyage", voyage);
	self.opts.addAssoc("TotalWeight", 10000.Integer );
	bulkTI2 := self.addPrenoted( BulkId2 ).CM_Bulk;
	self.assertTrueMsg(bulkTI2 &lt;&gt; null, "'" &amp; BulkId2 &amp; "' not created during setup");
	self.opts.purge();
	
	
	vvrIn := self.gateInPrenote( TruckIn, null, null, truckPreNotes, gate );
	self.assertTrueMsg(vvrIn &lt;&gt; null, "'" &amp; TruckIn &amp; "' failed to gate in during setup");
	truckPreNotes.clear();
	
	wle := bulkTI1.allWorklistEntries.first;
	self.unqueueTI( bulkTI1 );
	self.unplanTI( bulkTI1 );
	
	while true do
		delete proxyWLE;
		proxyWLE := app.createUpdateProxy(wle).CM_WorkListEntry;
		app.myTrxUA.trxUpdateWLEConvertToRelease(proxyWLE, null,  app.myPassport);
		self.assertTrueMsg( not app.myPassport.hasErrors, "Turn around failed - " &amp; app.myPassport.getErrorsAndWarningsAsString);
		if app.myPassport.trxCompletedOK then
			break;
		else
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;
	
	app.myTrxDA.trxVehicleRoadExit( vvrIn.vehicle, app.myPassport );
	
	self.assertTrueMsg( not bulkTI1.myTerminal.allOnsiteTIsByCargoTypeId.includes( bulkTI1 ), "'" &amp; bulkTI1.id &amp; "' on-site ref should NOT be populated");
	self.assertTrueMsg( bulkTI1.myTerminal.allNotifiedTIsByCargoTypeId.includes( bulkTI1 ), "'" &amp; bulkTI1.id &amp; "' off-site ref should be populated");
	
	self.opts.addAssoc( "Weight", 5000.Decimal );
	vvrIn2 := self.gateInPrenote( TruckIn2, null, null, bulkTI2, gate );
	self.assertTrueMsg(vvrIn2 &lt;&gt; null, "'" &amp; TruckIn2 &amp; "' failed to gate in during setup");
	
	bulkTI2 := vvrIn2.vehicle.locationsController.allTrackedItems.first.CM_Bulk;
	wle := bulkTI2.allWorklistEntries.first;
	self.unqueueTI( bulkTI2 );
	self.unplanTI( bulkTI2 );
	
	while true do
		delete proxyWLE;
		proxyWLE := app.createUpdateProxy(wle).CM_WorkListEntry;
		app.myTrxUA.trxUpdateWLEConvertToRelease(proxyWLE, null,  app.myPassport);
		self.assertTrueMsg( not app.myPassport.hasErrors, "Turn around failed - " &amp; app.myPassport.getErrorsAndWarningsAsString);
		if app.myPassport.trxCompletedOK then
			break;
		else
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;
	
	app.myTrxDA.trxVehicleRoadExit( vvrIn2.vehicle, app.myPassport );
	
	self.assertTrueMsg( not bulkTI2.myTerminal.allOnsiteTIsByCargoTypeId.includes( bulkTI2 ), "'" &amp; bulkTI2.id &amp; "' on-site ref should NOT be populated");
	self.assertTrueMsg( bulkTI2.myTerminal.allNotifiedTIsByCargoTypeId.includes( bulkTI2 ), "'" &amp; bulkTI2.id &amp; "' off-site ref should be populated");
	
	self.deleteVehicle( TruckIn );
	self.deleteVehicle( TruckIn2 );
	self.deleteCargo( BulkId1, bCargoType );
	self.deleteCargo( BulkId2, bCargoType );
	
epilog

	delete truckPreNotes;
	delete proxyWLE;

end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateConsignee" id="0f1af3e8-5449-4dde-bcb4-91a681e7a5bd">
        <source>tUpdateConsignee();
/*

Purpose:	PAR 37523		

Date		Who		Reason
10 March 2016	cnwmk3	Initial creation

*/
constants

	Cargo_Type 					: String = "UTREBAR";
	BsId1						: String = "UTBS_01";
	CargoId1					: String = "UT_REBAR01";
	CargoId2					: String = "UT_REBAR02";
vars

	cargoType					: CM_CargoType;
	bs1							: CM_BlockStack;
	ti, cargo					: CM_TrackedItem;
	gate						: CM_Gate;
	vvr							: CM_VehicleVisitRecord;
	newTiIds 					: StringArray;
	release						: CM_BulkRelease;
	wle							: CM_WorkListEntry;
	consignee					: String;
begin
	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	self.assertNotNull(cargoType);
	
	bs1 := self.addBlockStack(BsId1, 100, null);
	self.assertNotNull(bs1);
	
	self.deleteCargo(CargoId1, cargoType);
	
	// create some break-bulk cargo
	ti := self.addCargoAtLocation(CargoId1, cargoType, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController).CM_Cargo;
	self.assertNotNull(ti);
	beginTransaction;
	ti.setTotalQuantity(65);
	commitTransaction;
	
	//split off cargo from ti to Release some of the cargo
	create newTiIds transient;
	newTiIds.add( CargoId2 );
	app.myTrxUA.trxSplitBreakBulkToNewID(	ti.CM_Cargo,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											25,	//_quantity : Integer;
											25000,	// _weightOrVolume : Decimal;
											self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator : CM_Operator;
											false,
											false,
											false,
											false,
											app.myPassport	//_passport : CM_Passport input
											);
	cargo := self.getTerminal.lookupTrackedItem(CargoId2, cargoType.id, TI_STATE_UNDEFINED, null, false).CM_Cargo;
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	assertNotNull(gate);
	
	// release request to release cargo
	consignee := app.myRoot.allConsigneeConsignors['CCS'].code;
	self.assertNotNull(consignee);
	self.opts.addAssoc("consigneeCode", consignee);
	self.opts.addAssoc("TotalRequested", "25".Integer);
	release := self.addReleaseById("REL_001", BR_TYPE_ROAD, cargo);
	self.assertNotNull(release);
	
	// gate out truck with cargo
	deleteVehicle("UT_TRUCK01");
	self.opts.purge();
	self.opts.addAssoc("consigneeCode", consignee);
	vvr := self.gateOutGC("UT_TRUCK01", "", "UT_DRIVER01", cargo, gate, null);
	self.assertNotNull(vvr);
	assertNotNull(cargo.getPrimaryLocation(QUEUE_MODE));
	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, cargo);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem.consignee, consignee);
	
	workVehicle( vvr );
	self.roadExit(vvr);
	
	// actual test - the onsite cargo item should have the original (if any) consignee, and the released (offsite) item should have the updated consignee.
	ti := self.getTrackedItem(CargoId1);
	assertNotNull(ti);
	assertEqual(ti.consignee, null);
epilog
	delete newTiIds;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateVVDepartedTransport" id="f8322a25-badf-42df-8cfd-b78605602727">
        <source>tUpdateVVDepartedTransport();
/*

Purpose:			Test that we can retrospectively update Tracked items release through a vehicle visit

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
30/09/2025	navcs2	MTN-35846 Dev - Returning of Lot Based Cargo | PortSchema Changes
*/
constants
	TFSNUMBER = "57088";
	Container1ID = TFSNUMBER &amp; 'CNT1';
	Container2ID = TFSNUMBER &amp; 'CNT2';
	TruckId = TFSNUMBER &amp; 'Truck';
vars
	truck1		 	: CM_Vehicle;
	regNumber		: String;
	carrier			: CM_Carrier;
	vvr1,
	pxyVVR			: CM_VehicleVisitRecord;
	ti1,
	ti2,
	ti3				: CM_Container;
	tiSet			: CM_TISet;
	job1,
	job2	 		: CM_RoadJob;
	wle1,
	wle2 			: CM_WorkListEntry;
	gteEntity		: CMGTE_Release;
	gteEntArray		: CMGTE_EntitySet;
	flexiGateCnt	: CMIF_FlexiGateController;
begin
	regNumber 	:= TruckId;

	self.deleteVehicle(regNumber);
		
	carrier 	:= app.myRoot.allCarriers[self.getProfileSetting(UT_Profile.P_CARRIER).asString].CM_Carrier;
	truck1	 	:= self.addVehicle(regNumber ,carrier, app.myPassport.myTerminal);
	self.deleteContainer(Container1ID);
	self.deleteContainer(Container2ID);

	ti1 := self.addContainer(Container1ID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	ti2 := self.addContainer(Container2ID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	
	self.move(ti1, bs.myLocationsController);
	self.move(ti2, bs.myLocationsController);
	
	vvr1 := self.gateOutContainer(truck1.regNumber, "", "UTDRIVER1", ti1, true, self.dualGate, null);
	
	self.assertTrueMsg(truck1 &lt;&gt; null, "Truck 1 is null.");
	self.assertTrueMsg(truck1.allRoadJobs.size = 1, "Wrong number of jobs on the truck.");
	
	job1 := truck1.allRoadJobs.first.CM_RoadJob;
	self.assertTrueMsg(job1 &lt;&gt; null, "Can't find job1.");
	self.assertTrueMsg(job1.workListEntries.size = 1, "Wrong number of wles on the job.");
	
	wle1 := job1.workListEntries.first;
	self.assertTrueMsg(wle1 &lt;&gt; null, "Can't find the wle.");
	self.assertTrueMsg(vvr1.allReleasedTrackedItems.includes(ti1), "The vehicle visit record does not contain a released tracked item");
	
	self.workVehicle(vvr1);	
	self.roadExit(vvr1);
	
	create flexiGateCnt 	transient;
	create gteEntity		transient;
	create gteEntArray		transient;
	create tiSet			transient;
	tiSet.add(ti1);
	
	flexiGateCnt.setFromExistingPrenote(ti2);
	gteEntity.setPXYFromController(flexiGateCnt);
	gteEntity.CMGTE_Release.setMyTrackedItem(ti2);
	gteEntArray.add(gteEntity);
	
	pxyVVR := app.createUpdateProxy(vvr1).CM_VehicleVisitRecord;
	
	// 30/09/2025	navcs2	MTN-35846 Start
	while true do
		app.myTrxUA.trxUpdateVVDepartedTransport(pxyVVR, gteEntArray, self.bs.getLocationsController, null, app.myPassport);
			
		if app.myPassport.trxCompletedOK then
			return;
		else
			
			if app.myPassport.noErrors then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
				
			endif;
			return;
		endif;
	endwhile;
	// 30/09/2025	navcs2	MTN-35846 End

	
	// Check the vehicle visit record
	self.assertTrueMsg(vvr1.allReleasedTrackedItems.size = 1, "The vehicle visit record does not contain a released tracked item");
	self.assertTrueMsg(vvr1.allReleasedTrackedItems.includes(ti2), "The 2nd tracked item has not been added to the released cargo");
	
	// Check the tracked items and their transactions 
	self.assertTrueMsg(ti1.isOnSite, "The 1st tracked item is not onsite");
	self.assertTrueMsg(ti2.isOffSite, "The 2nd tracked item is not offsite");	

epilog
	delete flexiGateCnt;
	delete pxyVVR;
	delete tiSet;
	delete gteEntArray;
	delete gteEntity;

end;</source>
    </JadeMethod>
    <JadeMethod name="tVGMGateInAllocations" id="91e9d77c-f07b-4a2d-8464-b9060c242cd5">
        <source>tVGMGateInAllocations();

/*

Purpose:		

Date			Who		Reason
17/06/016		cnwmh5	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
*/

constants

	BlockStackIdVGM					: String = "UTMHV8";
	BlockStackIdNonVGM				: String = "UTMHV9";
	YardAllocationIdVGM				: String = "UTMHVGMTEST";
	YardAllocationIdNonVGM			: String = "UTMHVGMNONTEST";
	ContainerId1					: String = "UTMHVGMALL1";
	ContainerId2					: String = "UTMHVGMALL2";
	VoyageId						: String = "UTMDHVGMALL";
	VesselId						: String = "MESDIAM";
	ToDoTaskDesc					: String = "UTMDHVGMALL";
	
vars

	bsVGM							: CM_BlockStack;
	bsNonVGM						: CM_BlockStack;
	ya								: CM_YardAllocation;
	vvr								: CM_VehicleVisitRecord;
	ti								: CM_TrackedItem;
	voyage							: CM_Voyage;
	toDoTaskDesc					: CM_ToDoTaskDesc;
	tiToDoTask						: CM_TiToDoTask;
	tiTransaction					: CM_TITransaction;
	
	locations						: CM_LCArray;
	tiSet							: CM_TISet;
	
	txnFound						: Boolean;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	// delete anything that needs deleting that isn't done automatically
	self.deleteVehicle("UTMHTK1");
	self.deleteVehicle("UTMHTK2");
	ti := self.getTrackedItem(ContainerId1);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	ti := self.getTrackedItem(ContainerId2);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;

	// create the voyage
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithContainerStructur(VoyageId, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString());
	self.assertNotNull(voyage);
	
	self.disableAllYA(true);
	
	// setup the todotask to use
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey(ToDoTaskDesc);
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	toDoTaskDesc := self.createToDoTaskDesc(ToDoTaskDesc);
	self.assertNotNull(toDoTaskDesc);
	
	self.setTerminalConfig(ToDoTaskRemoveVGM, toDoTaskDesc);

	// create the block stacks to autoplan to
	bsVGM := self.addBlockStack(BlockStackIdVGM, 50, null);
	self.assertNotNull(bsVGM);
	
	bsNonVGM := self.addBlockStack(BlockStackIdNonVGM, 50, null);
	self.assertNotNull(bsNonVGM);
	
	create locations transient;
	create tiSet transient;
		
	// create the yard allocations for autoplanning
	bsVGM.allLocationsControllers.copy(locations);
	self.deleteYA(YardAllocationIdVGM);
	ya := self.addYA(YardAllocationIdVGM, YACriteriaType_ImexStatus, "EXP", YACriteriaType_IsWeightCert, CM_YADataBoolean.VALUE_TRUE, 
		null, false, locations, null);
	self.assertNotNull(ya);
	
	locations.clear();
	bsNonVGM.allLocationsControllers.copy(locations);
	self.deleteYA(YardAllocationIdNonVGM);
	ya := self.addYA(YardAllocationIdNonVGM, YACriteriaType_ImexStatus, "EXP", YACriteriaType_IsWeightCert, CM_YADataBoolean.VALUE_FALSE, 
		null, false, locations, null);
	self.assertNotNull(ya);
	
	// gate in a container without VGM
	self.opts.purge();
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("Voyage", voyage.code);
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.opts.addAssoc("IsWeightCertified", false);
	vvr := self.gateInContainer("UTMHTK1", ContainerId1, "2200", self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		"GENL", self.dualGate);
	self.assertNotNull(vvr);
	
	ti := self.getTrackedItem(ContainerId1);
	self.assertNotNull(ti);
	self.assertEqualMsg(ti.getPrimaryLocation(QUEUE_MODE).CM_LocationsController.getID(), bsNonVGM.getID(), "10. Locations are different");
	
	// set the to do task
	tiSet.clear();
	tiSet.add(ti);
	self.addToDoTask(toDoTaskDesc, tiSet);
	tiToDoTask := ti.allToDoTasksToDo.first.CM_TiToDoTask;
	self.assertNotNullMsg(tiToDoTask,"20. No To Do Tasks found on the TI");
	self.assertEqualMsg(ti.allToDoTasksToDo.size, 1, "21. Should have 1 To Do Task but has " &amp; ti.allToDoTasksToDo.size.String);
	self.assertEqualMsg(tiToDoTask.getMyToDoTaskDesc(), toDoTaskDesc, "22. To Do Task is not the expected on of " &amp; toDoTaskDesc.description);
	
	// set the vgm details
	self.opts.purge();
	self.opts.addAssoc("IsWeightCertified", true);
	self.opts.addAssoc("WeightCertBy", "Weight is Certified by");
	self.opts.addAssoc("AuthorisedPerson", "Authorised Person!!!!");
	self.updateTI(ti);
	self.assertEqualMsg(ti.allToDoTasksToDo.size, 0, "30. Should have no To Do Task but has " &amp; ti.allToDoTasksToDo.size.String);
	
	// check that the remove transaction is there
	txnFound := false;
	foreach tiTransaction in ti.allTransactions reversed, discreteLock do
		if not tiTransaction.isKindOf(CM_Edit) then
			continue;
		endif;
		if tiTransaction.getDetails().cnContains("ToDoTask =&gt; Removed.: TaskDescription =&gt; UTMDHVGMALL") then
			txnFound := true;
			break;
		endif;
	endforeach;
	self.assertTrueMsg(txnFound, "40. Edit transaction for the remove not found.");
	
	// gate in a containter with VGM
	self.opts.purge();
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("Voyage", voyage.code);
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.opts.addAssoc("IsWeightCertified", true);
	self.opts.addAssoc("WeightCertBy", "A Certified Weight Company");
	self.opts.addAssoc("AuthorisedPerson", "Authorised Person Certified Weight");
	vvr := self.gateInContainer("UTMHTK2", ContainerId2, "2200", self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		"GENL", self.singleGate);
	self.assertNotNull(vvr);
	
	ti := self.getTrackedItem(ContainerId2);
	self.assertNotNull(ti);
	self.assertEqualMsg(ti.getPrimaryLocation(QUEUE_MODE).CM_LocationsController.getID(), bsVGM.getID(), "50. Locations are different");			
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	self.disableAllYA(false);

	delete locations;
	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tVehicle" id="dc3a597c-2f48-4e7c-8af6-6780e2de3447">
        <updating/>
        <source>tVehicle()updating;
/*

Purpose:			testlink test 01-625

Date		Who		Reason
17 February 2017	cnwmk3	Initial creation

*/
constants
	BookingID1						= "BOOKING6251";
	BookingID2						= "BOOKING6252";
	BookingID3						= "BOOKING6253";
	VoyCode							= "VOY625";
	VesselCode						= "VESSEL625";
	CarID1							= "CAR6251";
	CarID2							= "CAR6252";
	TruckID							= "TRK625";
	Boat1							= "BOAT1";
	Boat2							= "BOAT2";
vars
	booking							: CM_BookingRef;
	dischargePort					: CM_Port;
	cargoType						: CM_CargoType;
	ti1, ti2, ti3, ti4				: CM_TrackedItem;
	vvr								: CM_VehicleVisitRecord;
	releaseRequest					: CM_BulkRelease;
	truck							: CM_Vehicle;
begin
	self.deleteVehicle(TruckID);
	ti1 := self.getTrackedItem(CarID1);
	self.deleteTrackedItem(ti1, false);
	
	ti1 := self.getTrackedItem(CarID2);
	self.deleteTrackedItem(ti1, false);
	
	ti1 := self.getTrackedItem(Boat1);
	self.deleteTrackedItem(ti1, false);
	
	ti1 := self.getTrackedItem(Boat2);
	self.deleteTrackedItem(ti1, false);
	
	operator := self.getOperator("MSL");
	dischargePort := self.getPort("NZAKL");
	
	deleteVoyage(VoyCode);
	deleteVessel(VesselCode);
	vessel := addVesselCellular(VesselCode, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNull(vessel);
	voyage := self.addVoyageWithContainerStructur(VoyCode, VesselCode, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(voyage);
	
	// Receive booked, prenoted system Car.
	cargoType := app.myRoot.getCargoTypeFromAbbrev("CAR");
	booking := self.addBookingForGeneralCargo(BookingID1, operator, voyage, dischargePort.code, cargoType.id, 2);
	self.opts.purge();
	self.opts.addAssoc("CargoType", cargoType.id);
	ti1 := self.addPrenoted_OLD(booking.allBookingRefItems.first, CarID1);
	
	vvr := self.gateInPrenote(TruckID, "", "", ti1, dualGate);
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// Release Car by Type.
	self.opts.purge;
	self.opts.addAssoc("FullRelease", true);
	releaseRequest := addReleaseByTypeRequestOpts("REL625", BR_TYPE_ROAD, cargoType.id);
	assertEqual(releaseRequest.status, BR_ACTIVE);
	assertEqual(releaseRequest.fullRelease, true);
	
	self.releaseAssignCargo(releaseRequest,null, ti1);
	
	// Gate Out
	self.opts.purge;
	self.opts.addAssoc("ReleaseRequest", releaseRequest);
	self.opts.addAssoc("BestPick", true);
	vvr := self.gateOutGC(TruckID, "", "", ti1, singleGate , null);
	
	truck := self.getVehicle(TruckID);
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "Q".String);

	self.workVehicle(vvr);
	self.roadExit(vvr);

	// Receive booked, prenoted system Car.
	self.opts.purge();
	self.opts.addAssoc("CargoType", cargoType.id);
	ti2 := self.addPrenoted_OLD(booking.allBookingRefItems.last, CarID2);
	
	vvr := self.gateInPrenote(TruckID, "", "", ti2, dualGate);
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// Release Car by ID.
	vvr := self.gateOutGC(TruckID, "", "", ti2, dualGate, null);
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// Receive booked, prenoted Rowing Boat.
	cargoType := app.myRoot.getCargoTypeFromAbbrev("ROWBOAT");
	booking := self.addBookingForGeneralCargo(BookingID2, operator, voyage, dischargePort.code, cargoType.id, 2);
	self.opts.purge();
	self.opts.addAssoc("CargoType", cargoType.id);
	ti3 := self.addPrenoted_OLD(booking.allBookingRefItems.first, Boat1);
	
	vvr := self.gateInPrenote(TruckID, "", "", ti3, dualGate);
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	self.roadExit(vvr);	

	// Release Rowing Boat by Type.
	self.opts.purge;
	self.opts.addAssoc("FullRelease", true);
	releaseRequest := addReleaseByTypeRequestOpts("REL6251", BR_TYPE_ROAD, cargoType.id);
	assertEqual(releaseRequest.status, BR_ACTIVE);
	assertEqual(releaseRequest.fullRelease, true);
	
	self.releaseAssignCargo(releaseRequest,null, ti3);
	
	// Gate Out
	self.opts.purge;
	self.opts.addAssoc("ReleaseRequest", releaseRequest);
	self.opts.addAssoc("BestPick", true);
	vvr := self.gateOutGC(TruckID, "", "", ti3, singleGate , null);
	
	truck := self.getVehicle(TruckID);
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "Q".String);

	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// Receive booked, prenoted Rowing boat with attached Cargo.
	cargoType := app.myRoot.getCargoTypeFromAbbrev("ROWBOAT");
	booking := self.addBookingForGeneralCargo(BookingID3, operator, voyage, dischargePort.code, cargoType.id, 1);
	self.opts.purge();
	self.opts.addAssoc("CargoType", cargoType.id);
	ti4 := self.addPrenoted_OLD(booking.allBookingRefItems.last, Boat2);
	
	vvr := self.gateInPrenote(TruckID, "", "", ti4, dualGate);
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// Release Rowing Boat by ID.
	vvr := self.gateOutGC(TruckID, "", "", ti4, dualGate, null);
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tVehicleControllerTA" id="16622c2b-237d-4e0e-8f89-c6b05e9948d6">
        <source>tVehicleControllerTA();
// CNWNDL1
//21 May 2010	cnwjo3
//The purpose of this test is just to doublely verify that
//the method on VehicleController (getTAforRadioTelemetryQueue) does not
//return invalid objects, or cause other exceptions.
vars
	vc: CM_VehicleController;
	ta : CM_TerminalArea;
	taId : String;
	foundTA : Boolean;
begin
	foreach vc in CM_VehicleController.instances do
		ta := vc.getTAforRadioTelemetryQueue();
		if ta &lt;&gt; null then
			taId := ta.id;  //if TA is invalid then this will cause exception
			foundTA := true;
		endif;
	endforeach;
	
	//we must have 1 truck in a Terminal Area!
	//If we have none then definately we aren't returning the correct TA anymore.
	self.assertEqual(foundTA,true);
end;</source>
    </JadeMethod>
    <JadeMethod name="tWLECopyAssignTI" id="6dacbffb-0bcd-4455-be33-2a846696e296">
        <source>tWLECopyAssignTI();

/*

Purpose:		trxCreateWLECopyAssignTI

Date			Who		Reason
23/06/2015		cnwmh5	Initial creation

*/

vars

	releaseRequest				: CM_BulkRelease;
	blockStack					: CM_BlockStack;
	ti 							: CM_Container;
	deliveryRequest				: CM_DeliveryRequest;
	vvr							: CM_VehicleVisitRecord;
	roadReleaseJob 				: CM_RoadJob;
	wle 						: CM_WorkListEntry;
	wleToProcess 				: CM_WorkListEntry;
	templateWle 				: CM_WorkListEntry;
	tmpFoundLC 					: CM_LocationsController;
	tiTran1						: CM_TITransaction;
	tiTran2						: CM_TITransaction;
	
	iter						: Iterator;
	
	wleIsTemplate				: Boolean;
	count 						: Integer;
	
begin

	// create the road release request
	self.deleteReleaseRequest("UTMHRELREQAAA");
	self.opts.purge();
	self.opts.addAssoc("FullRelease", false);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	releaseRequest := self.addReleaseByTypeRequest("UTMHRELREQAAA", BR_TYPE_ROAD, TI_CargoType_Container, "UT20");
	self.assertNotNull(releaseRequest);
	
	// create the block stack for the containers
	self.deleteTerminalArea("UTMHBSO");
	blockStack := self.addBlockStack("UTMHBSO", 10, null);
	self.assertNotNull(blockStack);
	
	ti := self.getTrackedItem("UTMH0000190").CM_Container;
	self.deleteTrackedItem(ti, false);
	ti := self.addContainerAtLocation("UTMH0000190", app.myRoot.allOperators["UTOP"], "UT20", "GENL", TI_IMEX_STATUS_EXPORT, blockStack);
	self.assertNotNull(ti);
	self.deleteStops(ti);	
	
	deliveryRequest := releaseRequest.requests.first.CM_DeliveryRequest;
	self.assertNotNull(deliveryRequest);
	beginTransaction;
	deliveryRequest.setPropertyValue("totalRequested", 0);
	commitTransaction;
	self.assertEqual(deliveryRequest.totalRequested, 0);
	self.assertEqual(deliveryRequest.weightRequested, 0.0000.Decimal);
	
	wleIsTemplate := (deliveryRequest.totalRequested = 0 and deliveryRequest.weightRequested = 0.0000.Decimal).Boolean;
	self.assertEqual(wleIsTemplate, true);
	
	self.deleteVehicle("UTMHTK1");
	self.opts.purge();
	self.opts.addAssoc('release', releaseRequest);
	vvr := self.gateOutContainer("UTMHTK1", "", "", ti, true, singleGate, null);
	self.assertNotNull(vvr);
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	
	roadReleaseJob := self.getVehicle("UTMHTK1").allRoadJobs.first.CM_RoadJob;
	self.assertNotNull(roadReleaseJob);
	
	foreach wle in roadReleaseJob.workListEntries do
		if wle.isReceipt or wle.status = WLE_COMPLETED or (wle.myTrackedItem &lt;&gt; null and wle.myTrackedItem &lt;&gt; ti) then
			continue;
		endif;
		wleToProcess := wle;
	endforeach;
	
	if wleToProcess &lt;&gt; null and wleIsTemplate then
		tmpFoundLC := wleToProcess.getRoadReleaseLC();
		templateWle := wleToProcess;
		app.myTrxCA.trxCreateWleCopyAssignTI(templateWle, wleToProcess, ti, tmpFoundLC, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();	
	endif;

	count := 1;
	
	iter := ti.allTransactions.createIterator;
	iter.back(tiTran1);
	iter.back(tiTran2);
	
	self.assertTrue(tiTran2.isKindOf(CM_Move) and tiTran2.CM_Move.sourceLocn = blockStack.id and tiTran2.CM_Move.targetLocn = vvr.vehicle.regNumber &amp; " Road" and 
		tiTran2.CM_Move.typeString = "Queued");
	self.assertTrue(tiTran1.isKindOf(CM_Move) and tiTran1.CM_Move.sourceLocn = blockStack.id and tiTran1.CM_Move.targetLocn = vvr.vehicle.regNumber &amp; " Road" and 
		tiTran1.CM_Move.typeString = "Moved");	
	
	self.roadExit(vvr);
	
epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="uAddPrenote" id="90548ef3-dff6-4208-9319-6168c45ff144">
        <source>uAddPrenote(_id, _isoType : String;	_operator : CM_Operator; _cargoType : CM_CargoType) : CM_TrackedItem protected;

/*

Purpose:		Create prenote	

17/09/2012		cnwmh5	Initial creation

*/

vars

	ti 					: CM_TrackedItem;
	
	totalWeight			: Decimal[12,2];
	commodity			: String;
	tiSet : CM_TISet;
	carrier : CM_Carrier;
	termEmailDef,
	tmpCarrierEmail	: CM_PINObjectDefaultEmail;
	trailerType		: CM_TILCType;
	
begin

	self.deleteContainer( _id );
	
	// get the commodity
	commodity := "MT";
	if self.opts.includesKey("commodity") then
		commodity := self.opts.str("commodity");
	endif;	
	
	beginTransaction;
	ti := self.getTerminal.createTI(_cargoType, false);
	ti.setPxyFromDefaultTI(self.getTerminal, _cargoType.id, _id, commodity, _operator);
	ti.changeState(TI_STATE_NOTIFIED, app.myPassport);
	ti.setISOType(_isoType);
	
	// set the mt grade
	if self.opts.includesKey("mtGrade") then
		ti.setAvailabilityGradeRT(self.opts.obj("mtGrade").CM_MTGrade.code, app.myPassport);
	endif;
	
	// set the total weight
	totalWeight := 4000.00;
	if self.opts.includesKey('totalWeight') then
		totalWeight := self.opts.dec('totalWeight');
	endif;
	ti.setPropertyValue( "totalWeight", totalWeight );
	
	if self.opts.includesKey('transMode') then
		ti.setReceiptTransportMode( self.opts.int("transMode") );
	endif;
	
	// set the carrier
	if self.opts.includesKey('carrier') then
		ti.setCarrier(self.opts.str('carrier'));
	endif;
	
	//25 Sep 2015	NDL	Par 36951
	if self.opts.includesKey('pin') and self.opts.bool("pin") and ti.carrier &lt;&gt; null then
		carrier := ti.getCarrierReceive;
		if carrier &lt;&gt; null then
			if ti.getCarrierRelease = null then
				ti.setReleaseCarrier(carrier.code);
			endif;
			ti.setCustomsEntryNumber("X");
			create tiSet transient;
			tiSet.add(ti);
			app.myUtilityUA.utlUpdateGeneratePin(tiSet, null, true, app.myPassport);
		endif;
	endif;
	
	if self.opts.includesKey( ETRow_TrailerType ) then
		trailerType	:= self.getTrailerType( self.opts.str( ETRow_TrailerType ) );
		ti.setMyType( trailerType );
	endif;
	
	if self.opts.includesKey(UTTI_IMEX) then						
		ti.setImExStatus(self.opts.int(UTTI_IMEX));
	endif;
	
	ti.setRemarks(self.createdByUnitTest(ti.remarks), false);					// 10/09/2015 cnwmh5
	
	commitTransaction;
	
	return ti;

epilog

	abortTransaction;

	delete tiSet;

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="uCheckSubCarrier" id="5144ff5f-7db9-4116-a2e0-1f0b5688afa1">
        <updating/>
        <source>uCheckSubCarrier() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2022	navhl20	ChangeRequest 53430: EUP - Sub Carrier registration in MTN

*/

constants
	
	SubCarrier 					: String = "Harry";
	SubCarrierNew				: String = "MASUBCAR";
	CONTAINER 					: String = "UUT12345678" ;
	TRUCK						: String = "UTTRUCK";
	
vars
	
	vvr							: CM_VehicleVisitRecord;
	driverName					: String;
	ti 							: CM_TrackedItem;
	
begin	
	// set up the vehicle
	driverName := getDriverName();
	self.deleteContainer(CONTAINER);
	self.deleteVehicle(TRUCK);
	
	opts.purge();
	opts.addAssoc("SubCarrier",SubCarrier);
	opts.addAssoc("DriverName",driverName);
	
	// Gate In/Out Transaction with Sub Carrier
	// gate in the container with no carrier
	vvr := self.gateInContainer(TRUCK, CONTAINER, "2200", operator.code, "MT", dualGate);
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	assertEqual(vvr.subCarrierCode, SubCarrier);
	
	// Update VVR Sub Carrier
	opts.addAssoc("SubCarrierCode",SubCarrierNew);
	self.updateSubCarrier(vvr);
	
	//Check VVR has the Sub Carrier updated Correctly 
	assertEqual(vvr.subCarrierCode, SubCarrierNew);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateStopTable" id="8e58dec6-4b54-4774-850e-d30876cb4f8a">
        <source>uCreateStopTable() : CM_StopsTable;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2014	cnwmc5	Initial creation	PAR 34074

*/

constants

	STOP_ID			= 303;
	STOP_CODE		= "UTMJC";
	
vars

	selectedTypes	: CM_CargoBOLTypeSet;
	stopsTable		: CM_StopsTable;
	
	localOpts 		: CM_AssociationDict;
	
	applyAreas		: IntegerArray;
	checkAreas		: IntegerArray;
	
begin

	self.deleteStopsTable(STOP_ID);
	
	//Setup Stops table
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	
	create applyAreas transient;
	applyAreas.add(StopApplyImport);
	applyAreas.add(StopApplyExport);
	
	create checkAreas transient;
	checkAreas.add(StopPreventReleaseRequest);
	checkAreas.add(StopPreventYardMove);
	checkAreas.add(StopPreventSubTerminalEdit);
	
	create localOpts transient;
	localOpts.addAssoc(ETRow_SetStopAreas, applyAreas);
	localOpts.addAssoc(ETRow_CheckStopAreas, checkAreas);
	localOpts.addAssoc(ETRow_IsFull, true);
	
	stopsTable := self.addStopsTable(STOP_ID, STOP_CODE, "Unit Test MJC Generic", selectedTypes, localOpts);
	self.assertNotNullMsg(stopsTable, "StopsTable not created");
	
	return stopsTable;
	
epilog

	delete selectedTypes;
	delete applyAreas;
	delete checkAreas;
	delete localOpts;
	
end;</source>
        <ReturnType type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="uGateInMTToYard" id="7ab2c04a-e6fe-455b-a6b3-b8e8d362d4f6">
        <source>uGateInMTToYard();
// Gate in a number of trucks into yard	 
constants
	CONTAINER = "MTSTCONT" ;
	TRUCK = "UTTRCK";
vars
	ti: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
    i: Integer;	
	start,count: String;
	cargo: String;
	truck: String;
begin
	start := "Enter number of first truck";
	read start;
	count := "Enter number of trucks to gate in";
	read count;
	
	foreach i in start.Integer to start.Integer + count.Integer do
		cargo := CONTAINER &amp; i.String;
		truck := TRUCK &amp; i.String;
		deleteContainer(cargo);
		deleteVehicle(truck);	
	
		vvr := gateInStorageContainer(truck, cargo, "2200", operator.code, "MT", dualGate);
		ti := self.getTrackedItem(cargo);
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		assertEqual(pin.myInTransitToLocation, vvr.vehicle.myPrimaryActualLocation);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
		
		self.assertNoTrxErrorsOrWarnings();
		
	
		self.moveVehicleToLane(vvr.vehicle, pin, 1);
			assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
			
		self.moveVehicleToYard(vvr.vehicle);
			assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
			
    endforeach;			
end;</source>
    </JadeMethod>
