    </JadeMethod>
    <JadeMethod name="initialiseValues" id="a26d5b30-448e-40a2-a9b6-a9d10c8a08e9">
        <updating/>
        <source>initialiseValues(_domainName : String; _clientType : Integer; _serviceVersion : String) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 03 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	self.domainName := _domainName;
	self.clientType := _clientType;
	self.serviceVersion := _serviceVersion;
end;</source>
        <Parameter name="_domainName" type="String"/>
        <Parameter name="_clientType" type="Integer"/>
