	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="619c1629-c647-4c67-9362-5a3a462277ee">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_CargoGroupController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

begin

	self.action := _tiTransCntrl.action;

	inheritMethod(_tiTransCntrl, _passport);

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_CargoGroupController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setOtherTrackedItem" id="95dfd717-6d9e-4eca-8cbb-edb6ec7eb492">
        <updating/>
        <source>setOtherTrackedItem(pTI: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

begin

	if pTI = null then
		self.otherTrackedItem			:= null;
		self.otherTrackedItemId			:= null;
		self.otherTrackedItemCargoType	:= null;
	else
		self.otherTrackedItem			:= pTI;
		self.otherTrackedItemId			:= pTI.id;
		self.otherTrackedItemCargoType	:= pTI.cargoType;
	endif;

epilog

end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
