    <JadeMethod name="utlUpdateSpecialStow" id="11c7dc35-360c-4901-9917-dc5cd446fa15">
        <source>utlUpdateSpecialStow(pProxySpecialStow : CM_SpecialStow; _pxyDraw : CM_DrawingAttribute; _passport : CM_Passport input);
//-----------------------------------------
//
// Created : by cnwaer1 19 August 2008
//-----------------------------------------
// Changed On	By			Reason
// ----------	---------	--------------------------------------------------
// 13/05/2015	cnwdap1		PAR #36206 TFS 324/334 graphical Representation of Special Stow
vars
	cancelSave :Boolean;
	realSpecialStow :CM_SpecialStow;
	expectedEdition :Integer;
	
begin

	self.initialiseActivity();

	pProxySpecialStow.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxySpecialStow.pxyGetRealObjectAndEdition(realSpecialStow, expectedEdition);
	
	if realSpecialStow = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_SpecialStow.name, null, null);
		return;
	endif;

	app.myValUA.valSpecialStow(realSpecialStow, pProxySpecialStow);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realSpecialStow);

	if _passport.noErrors and realSpecialStow.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Special Stow', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realSpecialStow, true);
	endif;
	
	if _pxyDraw &lt;&gt; null then										// PAR #36206
		if realSpecialStow.myDrawingAttribute = null then			// PAR #36206
			realSpecialStow.createDrawingAttribute();				// PAR #36206
		endif;														// PAR #36206
		realSpecialStow.myDrawingAttribute.setForUpdate(_pxyDraw); 	// PAR #36206
	else															// PAR #36206
		delete realSpecialStow.myDrawingAttribute;					// PAR #36206
		realSpecialStow.setMyDrawingAttribute(null);				// PAR #36206
	endif;															// PAR #36206
	
	if _passport.noErrors then
		realSpecialStow.setForUpdate(pProxySpecialStow);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realSpecialStow, false);
	endif;
end;</source>
        <Parameter name="pProxySpecialStow" type="CM_SpecialStow"/>
        <Parameter name="_pxyDraw" type="CM_DrawingAttribute"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
