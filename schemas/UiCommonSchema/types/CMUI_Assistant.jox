        <source>listVoyageWorkOrderTasks(_listbox : CMUI_ListBox input; _terminal : CM_Terminal);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars

begin
