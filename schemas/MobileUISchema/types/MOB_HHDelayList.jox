    <JadeMethod name="handleBtnTwo" id="0e760665-7ab0-456a-819f-8f2d776c1cc2">
        <updating/>
        <source>handleBtnTwo() updating, protected;
// Edit
vars
	row		: Integer;
	delay	: CM_Delay;
begin
	row := self.tblDelays.row;
	if row &lt; 3 then
		return;
	endif;
	delay := self.tblDelays.accessRow(row).itemObject.CM_Delay;
	self.myMobileGenericAgent.setStringField1(delay.getOidString());
	self.gotoForm( MOB_HHDelayEdit, false );

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="includeObject" id="199272b3-e92d-4599-8084-bff041095753">
        <source>includeObject(_delay : CM_Delay) : Boolean protected;
// for new delays received via notifications, to see if they should be added to the table
vars
	delayTypeGroup	: CM_DelayTypeGroup;
	row		: Integer;
begin

	// get the terminal config delay type group, if any
	delayTypeGroup := self.myTerminal().getConfig(HhDelayTypeGroup).CM_DelayTypeGroup;

	if self.myVoyage &lt;&gt; null and _delay.myVoyage &lt;&gt; self.myVoyage then 
		return false;
	endif;

	if self.myMachine &lt;&gt; null and _delay.myMachine &lt;&gt; self.myMachine then 
		return false;
	endif;
	
	if delayTypeGroup &lt;&gt; null then
		if _delay.myDelayType &lt;&gt; null and not delayTypeGroup.allDelayTypes.includes (_delay.myDelayType) then 
			return false;
		endif;
	endif;
	
	return true;

end;
</source>
        <access>protected</access>
        <Parameter name="_delay" type="CM_Delay"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateDelayForSave" id="dd352b59-5f4b-4cfb-8aed-b5cf57c2dfe6">
        <updating/>
        <source>populateDelayForSave(_proxyDelay : CM_Delay input; _delay : CM_Delay) updating, protected;
// populate the delay proxy object from the curernt delay plus current date as end date
vars
	endDT			: TimeStamp;
	voyage 			: CM_Voyage;
	
begin
	endDT := app.actualTimeServer();

	voyage := _delay.myVoyage;

	
	_proxyDelay.setProxy(self.myTerminal,
					voyage,
					_delay.myDelayType,
					_delay.startDT,
					_delay.estEndDT,
					endDT,
					_delay.myMachine,
					_delay.myDriver,
					null,
					_delay.remarks);
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_proxyDelay" type="CM_Delay" usage="input"/>
        <Parameter name="_delay" type="CM_Delay"/>
    </JadeMethod>
    <JadeMethod name="populateTable" id="ad444afc-e160-45a0-9eb9-d1ba75072cb0">
        <updating/>
        <source>populateTable() updating, protected;
// from either voyage or machine
vars
	delay	: CM_Delay;
	delayTypeGroup	: CM_DelayTypeGroup;
	filterDate	: TimeStamp;
	row		: Integer;
begin
	// get the terminal config delay type group, if any
	delayTypeGroup := self.myTerminal().getConfig(HhDelayTypeGroup).CM_DelayTypeGroup;
	filterDate := app.actualTimeServer().addHours(-24);	// 24 hours back

	self.tblDelays.columns := 1;	// fast way of clearing the table?
	self.tblDelays.columns := 3;
	self.tblDelays.rows := 2 * self.getTableSize(delayTypeGroup) + 2;
	self.tblDelays.accessCell(1,1).text := app.getErrorString(ERROR_Delay_Type);
	self.tblDelays.accessCell(1,2).text := app.getErrorString(ERROR_Start_Delay_Time);
	self.tblDelays.accessCell(1,3).text := app.getErrorString(VoyageCapitalV);
	self.tblDelays.accessCell(2,1).text := app.getErrorString(Est_End_Time);
	self.tblDelays.accessCell(2,2).text := app.getErrorString(ERROR_End_Delay_Time);
	self.tblDelays.accessCell(2,3).text := app.getErrorString(Driver) &amp; "/" &amp; app.getErrorString(Workpoint);	//21 Jun 2012	NDL	Par 29689
	
	// the table is set up with two rows per delay to fit better on the small screen
	row := 2;
	// show delays with most-recent first
	// for a voyage show all delays on the assumption that since voyage is current so are the delays
	if self.myVoyage &lt;&gt; null then
		foreach delay in self.myVoyage.allDelays reversed do
			if self.myMachine &lt;&gt; null and
			   delay.myMachine &lt;&gt; self.myMachine then
				continue;
			endif;
			if delayTypeGroup &lt;&gt; null then
				if not delayTypeGroup.allDelayTypes.includes(delay.myDelayType) then
					continue;
				endif;
			endif;
			self.doAddToTable(row, delay);
		endforeach;
	// for a machine only show non-ended delays plus the last 24 hours of ended, as there may be years of delay history
	//  also show most-recent first
	elseif self.myMachine &lt;&gt; null then
		foreach delay in self.myMachine.allDelays reversed do
			if delayTypeGroup &lt;&gt; null then
				if not delayTypeGroup.allDelayTypes.includes(delay.myDelayType) then
					continue;
				endif;
			endif;
			if delay.endDT &lt;&gt; null and
			   delay.endDT &lt; filterDate then
				continue;
			endif;
			self.doAddToTable(row, delay);
		endforeach;
	endif;
	self.colourRows();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setActionButtons" id="4e6c2c6f-2293-476e-a443-03363858b17a">
        <updating/>
        <source>setActionButtons() updating, protected;
// from table click, enable/disable Edit and End Time based on selected delay
vars
	row		: Integer;
	delay	: CM_Delay;
begin
	row := self.tblDelays.row;
	if row &gt; self.tblDelays.fixedRows and row &lt;= self.tblDelays.rows then
		delay := self.tblDelays.accessRow(row).itemObject.CM_Delay;
		self.btnTwo.enabled := true;
		self.btnOne.enabled := not delay.endDT.isValid;
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setNotifications" id="0eab126a-34e3-40c5-b51d-924c89240b1e">
        <source>setNotifications();
// called from forn load, register for delay notifications to refresh table
vars

begin
	self.beginClassNotification(CM_Delay, false, Object_Create_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_Delay, false, Object_Update_Event, Response_Continuous, 0);
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ce853776-6343-4d5b-ae43-9710ca352046">
        <updating/>
        <source>setupForm() updating, protected;
// main form load method
vars
	msg		: String;
begin
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	inheritMethod();
	
	self.myVoyage := self.myMobileGenericAgent.myVoyage;
	if self.myMobileGenericAgent.driver &lt;&gt; null then
		self.myMachine := self.myMobileGenericAgent.driver.asOid.CM_Machine;
	endif;
	self.setupCmdButtons( 3, app.getErrorString(End_Time), app.getErrorString(Edit), app.getErrorString(Back), null, null );
	
	if self.myVoyage &lt;&gt; null then
		msg := app.getErrorString(Voyage) &amp; " " &amp; self.myVoyage.code &amp; " ";
	endif;
	if self.myMachine &lt;&gt; null then
		msg := msg &amp; app.getErrorString(Machine) &amp; " " &amp; self.myMachine.code;
	endif;
	self.lblVoyageMachine.caption := msg;
	
	self.btnOne.enabled := false;
	self.btnTwo.enabled := false;
	
	self.setupTable();
	self.populateTable();

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="812f27a4-13ff-4ad4-99fe-0c41cb20985a">
        <updating/>
        <source>setupTable() protected, updating;
// set up the delay table
vars

	top	: Real;

begin

	self.doResizeControls( true );

	// the table is set up with two rows per delay to fit better on the small screen
	//  for machine-only selection, add voyage to table
	self.tblDelays.fontName := "Tahoma";
	self.tblDelays.fixedRows := 2;
	self.tblDelays.columns := 3;
	self.tblDelays.setUseHighlightColours(false);
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
