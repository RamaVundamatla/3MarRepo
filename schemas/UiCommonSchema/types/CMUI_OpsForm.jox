    <JadeMethod name="updateTIWle" id="321bf03e-d2fa-4428-87d1-df0875ca755a">
        <updating/>
        <source>updateTIWle(_ti : CM_TrackedItem)updating;
//--------------------------------------------------
// Created:	13 January 2004 By: cnwgd1
//17 Nov 2016 cnwrs1	Par 37738 TFS 2949 incorrect UPSP rail location being displayed
//--------------------------------------------------
vars
	wle : CM_WorkListEntry;
	invalid : Boolean;
	str : String;
begin
	on Exception do app.handleDeletedObject(exception, _ti, invalid);	//par 37738
	str := _ti.id;
	if invalid then
		return;
	endif;
	// PAR 17940
	if (not CM_TrackedItem.hasInstance(_ti)) then
		return;
	endif;
	
	if (not self.allNotableTIs.includes(_ti)) then
		return;
	endif;
	
	self.tblWLESaveSelected();
	
	foreach wle in _ti.allWorklistEntries do
		if CM_YardWLE.hasInstance(wle) then
			self.tblWLEUpdateWle(wle, Mode_Update);
		endif;
	endforeach;
	
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="dc925f8f-875e-4749-bd0d-c017f0b44b6a">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//--------------------------------------------------------------
//Created: 16 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

	event : Integer;
begin

	
	if (not self.isFirstActivateComplete) then
		// ignore notifications until am activated (PAR-13306)
		return;
	endif;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	/*
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-	event=' &amp; 	event.String);
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-theObject='&amp; theObject.String);
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-eventTag='&amp; eventTag.String);
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-userInfo='&amp; userInfo.String);
	*/

	
	self.tblWLESaveSelected();
	
	if event = WLE_Update_Event then
		
		self.tblWLEUpdateWle(userInfo.CM_WorkListEntry, self.Mode_Update);
	elseif event = WLE_Create_Event then
		self.tblWLEUpdateWle(userInfo.CM_WorkListEntry, self.Mode_Add);
	elseif event = WLE_Delete_Event then
		if self.selectedTableObject.String = userInfo.String then
			self.selectedTableObject := null;
		endif;
		self.tblWLEUpdateWle(userInfo.CM_WorkListEntry, self.Mode_Delete);
		return;
	else
		self.handleUserNotification(userInfo.CM_Object, event);
		self.tblWLESetSelected();		   	   
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
