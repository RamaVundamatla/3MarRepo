    <JadeWebServicesMethod name="getAboutMtmContent" id="71d0abd8-b730-4671-a4d9-c102c5fa3d43">
        <source>getAboutMtmContent(forUTCConversion : Boolean) : WS_AboutMtmResponse webService;
/*

Purpose:			
	Get About details for mobile apps.
Parameters:			

Return Value:		

Date				Who		Reason
30 November 2016	cnwsc8	Initial creation
29 November 2019	jlgmd1	TFS 47471 - Get the JMT Build date/time in the servers timezone, not NZST

*/



vars
	response	 : WS_AboutMtmResponse;
	completedOK	 : Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session is skipped for this as details are shown in the console when the server starts
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Convert the JMT Build date/time from NZST to the server timezone for UTC conversion in the Webportal
	if forUTCConversion then
		response.convertTimezone();		// TFS 47471
	endif;

	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="forUTCConversion" type="Boolean"/>
        <ReturnType type="WS_AboutMtmResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getActiveVoyages" id="74a6f659-284f-439c-b413-b4a62b8f4930">
        <usesRPC>default</usesRPC>
        <source>getActiveVoyages() : WS_VoyagesResponse webService;

/*

Purpose:			Get the active voyages the current user has access to.

Parameters:			

Return Value:		Valid Voyages repsonse


Date		Who		Reason
23 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
05 Sep 2008 cnwkao1	modified
20 Apr 2009	cnwkpd1	PAR #19438 - Remove duplicates from the voyages list returned,
					reorder checks for performance

*/

vars
	response		: WS_VoyagesResponse;
	completedOK		: Boolean;

	proxyVoyage		: WS_Voyage;
	selectedVoyages	: CM_VoyageSet;
	
	iter			: Iterator;
	voy				: CM_Voyage;
	today			: Date;
		
	thePassport		: CM_Passport;
	failedDAC		: CM_DataAccessController;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Populate response - cloned from CMUI_ComboForVoyageActive, and CMUI_Assistant::setAllVoyageCodes
	thePassport := app.myPassport;
	iter := thePassport.myTerminal.allVoyagesNew.createIterator();
	today := app.actualTimeServer.date;
	
	create selectedVoyages transient;					// PAR #19438
	
	while iter.next(voy) do
		if voy.displayOption = VoyageDisplayNever then
			continue;
		endif;

	    if voy.myTerminalArchived &lt;&gt; null then			// exclude archived
	    	continue;
	    endif;

		if selectedVoyages.includes(voy) then			// PAR #19438
			continue;
		endif;

		if (not voy.canUserAccessSelf(null, failedDAC, thePassport)) then
			continue;
		endif;
		
		// Include voyages where the departure is today and/or beyond
//		if voy.departedDT.isValid and voy.departedDT.date &lt; today then
//			continue;
//		endif;
		
		create proxyVoyage transient;
		proxyVoyage.setProxyFromObject(voy);
		response.allVoyages.add(proxyVoyage);
		
		selectedVoyages.add(voy);						// PAR #19438
	endwhile;
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up local transients
	delete iter;
	delete selectedVoyages;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get the active voyages the current user has access to.</text>
        <wsdlName>getActiveVoyages</wsdlName>
        <ReturnType type="WS_VoyagesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getAdvancedSearchCriteria" id="e5bbda9b-a0ea-4db1-8ee7-10336e81c7e0">
        <source>getAdvancedSearchCriteria() : WS_AdvancedSearchResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2017	cnwhl1	Initial creation

*/

vars
	completedOK	: Boolean;
	response : WS_AdvancedSearchResponse;
	criteriaArray : WS_AdvancedSearchArray;
	criteria : WS_AdvancedSearchCriteria;
	criteriaEntry : EntTableRow;
	hhConfig : CM_HandHeldConfig;
	proxy : CM_HandHeldConfig;
	entTableDef : EntTableDef;
	entRow : EntTableRow;
	index : Integer;
	viewRows : EntTableRowArray;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	create criteriaArray transient;
	
	hhConfig := app.myPassport.myTerminal.getHandHeldConfig( null );
	
	if hhConfig = null then 
		entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_HandHeldFind);
		
		// if the user hasn't set up custom search critera, load the mandatory values
		viewRows := entTableDef.getViewRows("HandHeldComp");
		if viewRows &lt;&gt; null then
			foreach entRow in viewRows do			
				if entRow.getRawHeadingValue.Integer &lt; 1 then
					create criteria transient;
					criteria.name := entRow.getName();
					response.allCriteria.add(criteria);
				endif;
			endforeach;	
		endif;
	else
		foreach criteriaEntry in hhConfig.allVisibleSearchRows do 
			create criteria transient;
			
			criteria.name := criteriaEntry.name;
	
			response.allCriteria.add(criteria);
		endforeach;
	endif;
	

	
	
	completedOK := true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
		delete criteriaArray;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_AdvancedSearchResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getAllLocales" id="78d94893-db69-4b18-bd85-4c2309204b52">
        <source>getAllLocales() : WS_AllLocalesResponse webService;
/*

Purpose:	Get a list of locales in the system		

Parameters:			None

Return Value:		

Date			Who		Reason
28 June 2017	cnwam15	Initial creation TFS #5193 - To support user to choose locale of his/her choice on the client side

*/

vars
	response		: WS_AllLocalesResponse;
	locale			: WS_Locale;
	completedOK		: Boolean;
	sysLocale		: CM_Locale;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	foreach sysLocale in app.myRoot.allLocales do
		create locale transient;		
		locale.setProxyFromObject(sysLocale);
		response.allLocales.add(locale);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_AllLocalesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getAllRoroVoyageDetails" id="1f238a4b-587d-4062-ba82-1074e3fecdce">
        <source>getAllRoroVoyageDetails() : WS_AllVoyageDetailsResponse webService;
/*

Purpose:			
	to return a condensed set of details for all voyages that are berthed, and can be worked
Parameters:			

Return Value:		

Date		Who		Reason
27 July 2017	jlghl1	Initial creation

*/

vars
	completedOK 	: Boolean;
	response 		: WS_AllVoyageDetailsResponse;
	thePassport		: CM_Passport;
	iter, carIter	: Iterator;
	voyage			: CM_Voyage;
	now 			: TimeStamp;
	proxyVoyage		: WS_VoyageDetails;
	gracePeriod 	: Integer;
	failedDAC		: CM_DataAccessController;
	ti				: CM_TrackedItem;
	carCount		: Integer;
	cargoType 		: Integer;

begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	thePassport := app.myPassport;
	
	gracePeriod := thePassport.myTerminal.getConfig(VoyDepartedGracePeriod).Integer;
	if gracePeriod = null then
		gracePeriod := 24;
	endif;
	now := app.actualTimeServer;
	now := now.changeByXXHours(-gracePeriod);
	
	iter := thePassport.myTerminal.allVoyagesByCode.createIterator();
	
	while iter.next(voyage) do
		if voyage.isNullVoyage then
			continue;
		endif;
		if voyage.status = Voyage_Status_Departed or voyage.status = Voyage_Status_Closed then
			continue;
		endif;
		if not voyage.arrivedDT.Date.isValid or voyage.arrivedDT &gt; app.actualTimeServer then
			// hasn't arrived yet
			continue;
		endif;
		if not voyage.isActiveDisplay(now) then			
			continue;
		endif;
		if not voyage.canUserAccessSelf(null, failedDAC, thePassport) then
			continue;
		endif;
		
		carCount := 0;
		//epr TFS 7931 performance improvements 
		carIter:=voyage.allOnshipTIsByCargoTypeId.createIterator;
		cargoType:=TI_CargoType_Car;
		voyage.allOnshipTIsByCargoTypeId.startKeyGeq(cargoType,null,carIter);
		while carIter.next(ti) do
			if ti.isCar() then
				carCount := carCount + 1;
				break;
			else
				cargoType:=ti.cargoType + 1;
				voyage.allOnshipTIsByCargoTypeId.startKeyGeq(cargoType,null,carIter);
			endif;
		endwhile;
		if carCount = 0 then
			continue;
		endif;
		delete carIter;
		
		create proxyVoyage transient;
		proxyVoyage.setProxyFromObject(voyage);
		
		response.allVoyageDetails.add(proxyVoyage);
	
	endwhile;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	// Tidy up local transients
	delete iter;
	delete carIter;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_AllVoyageDetailsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getAttachments" id="3b1d319b-1067-429a-b4a8-18db17f9e106">
        <usesRPC>default</usesRPC>
        <source>getAttachments(cmObjectId : String) : WS_AttachmentsResponse webService;
/*
Purpose:			Get any Attachments for a piece of cargo.

Parameters:

Return Value:		

Date		Who		Reason
29 Dec 2009	cnwdz2	PAR #17554 - Development of new RIA Web Service application
15 Oct   2015   cnwma1  PAR #36606 Web Service Methods need to validate Terminal/DataAccess on OIDs
*/
vars
	response		: WS_AttachmentsResponse;
	completedOK		: Boolean;
	attachment,
	trackedItem	    : CM_TrackedItem;
	attachmentProxy	: WS_Attachment;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	//create children transient;//PAR 22954
	//epr TFS 5535 4/8/17 
	trackedItem := app.myPassport.getObjectOfTypeFromOid(cmObjectId,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	//foreach attachment in children do
	if trackedItem &lt;&gt; null then																// 15/10/2015 cnwma1 PAR #36606
		foreach attachment in trackedItem.allChildren do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
			create attachmentProxy transient;
			attachmentProxy.setProxyFromObject(attachment);
			response.allAttachments.add(attachmentProxy);	
		endforeach;
	endif;
		
	// Got to here, everything is OK
	completedOK := true;
	
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <text>Get any Attachments for a piece of cargo.</text>
        <wsdlName>getAttachments</wsdlName>
        <Parameter name="cmObjectId" type="String"/>
        <ReturnType type="WS_AttachmentsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getAuditTypes" id="9988ea03-b564-48c3-ae91-e62d2fc6f7fc">
        <source>getAuditTypes() : WS_AuditTypeResponse webService;
/*

Purpose:			Get the list of Audit Types that can be generated

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2017	cnwkpd1	TFS 3369 - Push Events application


*/

vars
	response		: WS_AuditTypeResponse;
	auditType		: WS_AuditType;
	completedOK		: Boolean;
	auditConfig		: CM_AuditConfig;
	typeStrings		: StringArray;
	typeString		: String;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;

	// Populate response using all current Audit Configs
	create typeStrings transient;
	typeStrings.add('Created');
	typeStrings.add('Updated');
	typeStrings.add('Deleted');

	// Expand out the list of types for each Audit Config
	foreach auditConfig in app.myRoot.allAuditConfigs discreteLock do
		foreach typeString in typeStrings do
			create auditType transient;
			auditType.description := auditConfig.getDescription() &amp; ' ' &amp; typeString;
			
			response.allAuditTypes.add(auditType);
		endforeach;
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	// Tidy up any local transients
	delete typeStrings;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <ReturnType type="WS_AuditTypeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getAvailabilityGrades" id="ca857e6d-0b69-42a2-bae8-eefc38512c86">
        <source>getAvailabilityGrades() :WS_AvailabilityGradeResponse webService;


/*

Purpose:			Get all the Availablity Grades defined in JMT.

Parameters:			

Return Value:		


Date		Who		Reason
19 Mar 2009	#cnwdz2	PAR #17554 - Development of new RIA Web Service application 
                   

*/

vars
	response		: WS_AvailabilityGradeResponse;
	completedOK		: Boolean;
	grade			: CM_MTGrade;
	avGrade		    : WS_AvailabilityGrade;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	foreach grade in app.myRoot.allAvailableAvailabilityGrades do
		
		// Populate response
		create avGrade transient;
		avGrade.setFromAvaGradeCodeDesc(grade.code.String,grade.description);
		response.allAvailabilityGrades.add(avGrade);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get all the Availablity Grades defined in JMT.</text>
        <wsdlName>getAvailabilityGrades</wsdlName>
        <ReturnType type="WS_AvailabilityGradeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getAvailableAlerts" id="6d705c5d-f1fa-45f6-9fe6-a2b773a8c786">
        <source>getAvailableAlerts(request: WS_AlertQueryRequest) : WS_AlertResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2017	cnwhl1	Initial creation

*/

vars
	completedOK	: Boolean;
	ws_alert : WS_Alert;
	wsAlertArray : WS_AlertArray;
	response : WS_AlertResponse;
	
	cm_remark : CM_PredefinedRemark;
	
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	create wsAlertArray transient;

	foreach cm_remark in app.myRoot.allPreDefinedRemarks do 
		create ws_alert transient;		
		
		ws_alert.setProxyFromObject(cm_remark);
		response.allRemarks.add(ws_alert);
	endforeach;
	
	completedOK := true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
		delete wsAlertArray;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
