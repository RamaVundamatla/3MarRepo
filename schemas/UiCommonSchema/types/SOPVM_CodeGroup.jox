<Class name="SOPVM_CodeGroup" id="0fc34e87-dea3-4de3-a182-fb72be7077df">
    <superclass name="SOP_ViewModelObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="create" id="3de383b9-ce8e-4b32-b6d7-2d8ddec5173b">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		18 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.canAddChild 	:= true;
	self.canAddPeer 	:= true;
	self.canEdit 		:= true;
	self.canDelete 		:= true;
	expanded := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="createEmptyChild" id="286d89cd-2b32-4caa-af22-77f11bbc3ce2">
        <updating/>
        <source>createEmptyChild(_parent : SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		11 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin

	create myObject as CM_CodeGroup transient;
	self.myParent := _parent;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="c8557627-ae58-459f-8c1f-66ec89e80a3d">
        <updating/>
        <source>doDelete(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		14 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	app.myTrxDA.trxDeleteCodeGroup(self.myObject.CM_CodeGroup,app.myPassport);
	return app.myPassport.trxCompletedOK();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="4fc16ea2-dfd4-4a5c-a220-4911012cfeeb">
        <updating/>
        <source>doSave(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		11 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxyCodeGroup, newCodeGroup : CM_CodeGroup;
	
begin
	if self.myForm.mode = self.myForm.Mode_Add then
		if self.myForm.myProxyObject &lt;&gt; null then
			self.myForm.myProxyObject.erase(NORMAL_ERASE);
		endif;
		
		create self.myForm.myProxyObject as CM_CodeGroup transient;
	endif;
	
	proxyCodeGroup := self.myForm.myProxyObject.CM_CodeGroup;
	proxyCodeGroup.setProxy(	self.myForm.currentGroupType, 
								self.myForm.tblInput1.getValueByName('name').String.removeTabCrLfs(),	// 18/04/2013 cnwar2 #27130
								app.myRoot);
								
	if self.myForm.mode = self.myForm.Mode_Add then
		app.myTrxCA.trxCreateCodeGroup(proxyCodeGroup, newCodeGroup,app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.myObject := newCodeGroup;
		endif;
	elseif self.myForm.mode = self.myForm.Mode_Update then
		app.myTrxUA.trxUpdateCodeGroup(proxyCodeGroup, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.myForm.mode.String &amp; ')');
	endif;
	
	self.myForm.myProxyObject := proxyCodeGroup;
	return app.myPassport.trxCompletedOK();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelected" id="878a7d0e-ef6b-42ed-98c6-2138af1adf89">
        <updating/>
        <source>doSelected() updating;
// -----------------------------------------------------------------------------
// Created:		20 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	inheritMethod();
	self.myForm.btnNewChildTV.caption := 'New Code';
end;</source>
    </JadeMethod>
    <JadeMethod name="getChildClass" id="d5fdfe83-da43-49a9-8051-fe0cea635be2">
        <source>getChildClass(): Class protected;
// -----------------------------------------------------------------------------
// Created:		13 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
//	return SOPVM_CodeGeneric; // SOPVM_SourceLocation;

	if self.myObject.CM_CodeGroup.groupType = CodeGroup_AvailabilityGrade then
		return SOPVM_MTGrade;
	else
		return SOPVM_SourceLocation;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getPlaceHolderObject" id="bd150c22-bf70-48c4-ba4c-76fc2b9f38a6">
        <source>getPlaceHolderObject(_placeHolderType: Integer): CM_Object;
// -----------------------------------------------------------------------------
// Created:		11 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	placeHolder : CM_Object;
begin
	if _placeHolderType = PlaceHolderType_Peer then
		create placeHolder as CM_CodeGroup transient;
	elseif _placeHolderType = PlaceHolderType_Child then
		if myObject.CM_CodeGroup.groupType = CodeGroup_SourceLocation then 
			create placeHolder as CM_SourceLocation transient;
		endif;
	endif;
	return placeHolder;
end;</source>
        <Parameter name="_placeHolderType" type="Integer"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="2094de7d-10b3-4a1d-9827-f8498af628fc">
        <source>setupThumbnailDetails();
// -----------------------------------------------------------------------------
// Created:		11 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	myForm.shtTblInput1.visible := true;
	myForm.shtMultiSelect1.visible := false;
	myForm.shtMultiSelect2.visible := false;
	myForm.shtMultiSelect3.visible := false;

	myForm.shtTblInput1.caption := 'Details';
	myForm.initTblInput(myForm.tblInput1, 'CodeGroupMaint');
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="61e95684-2f25-4181-96be-5a89d44b9b1f">
        <updating/>
        <source>showThumbnail( _obj: CM_CodeGroup) updating;
// -----------------------------------------------------------------------------
// Created:		11 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.setupThumbnailDetails();
	self.myForm.sptThumbEdit.enabled := true;


	self.myForm.tblInput1.enabled := true;

	self.myForm.tblInput1.clearValues;
	self.myForm.tblInput1.setValueByName(ETRow_Name, _obj.name);
end;</source>
        <Parameter name="_obj" type="CM_CodeGroup"/>
    </JadeMethod>
</Class>
