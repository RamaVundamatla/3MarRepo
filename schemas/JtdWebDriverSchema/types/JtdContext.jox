        <Parameter name="i" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdSetDriverProfile" id="b3ea404b-862b-459a-96a1-064468d0b357">
        <updating/>
        <source>jtdSetDriverProfile(profileName : String) updating;

vars
	dpDict : JtdDriverProfileNameDict;
	dp : JtdDriverProfile;
	mp : JtdMethodProfile;
	s : String;
	
begin
	self.jtdClearTrxSelectionState;

	if self.jtdMyDriverProfile &lt;&gt; null and global.isValidObject(self.jtdMyDriverProfile) then
		delete self.jtdMyDriverProfile;
	endif;

	self.jtdMyDriverProfile := null;

	s := profileName.trimBlanks;
	if s = null then
		s := self.jtdGetDefaultProfileName;
	endif;
		
	create dpDict transient;
	self.jtdCreateDriverProfiles(dpDict, false);
	
	dp := dpDict[s];
	
	if dp = null then
		create self.jtdMyDriverProfile as JtdDefaultDriverProfile transient;
		return;
	endif;

	dpDict.remove(dp); // all other profiles will be deleted on exit

	self.jtdMyDriverProfile := dp;

	dp.jtdDeleteUnresolvedMthProfiles(true, true, true);
	
	foreach mp in dp.jtdAllPrologProfiles do
		mp.jtdSetTrxGenMethodDesc(self.jtdAllTrxGenMethodDescs[mp.jtdClassName, mp.jtdMethodName]);
	endforeach;

	foreach mp in dp.jtdAllMethodProfiles do
		mp.jtdSetTrxGenMethodDesc(self.jtdAllTrxGenMethodDescs[mp.jtdClassName, mp.jtdMethodName]);
	endforeach;
	
	foreach mp in dp.jtdAllEpilogProfiles do
		mp.jtdSetTrxGenMethodDesc(self.jtdAllTrxGenMethodDescs[mp.jtdClassName, mp.jtdMethodName]);
	endforeach;

	dp.jtdDelMthProfilesWithNoMthDesc; // belts and braces

epilog
	if dpDict &lt;&gt; null then
		dpDict.purge;
		delete dpDict;
	endif;
end;</source>
        <Parameter name="profileName" type="String"/>
    </JadeMethod>
