    <Constant name="Mode_Add" id="de554852-4b24-4798-ad16-ace2f8f55783">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="Mode_Update" id="8eb21889-d894-419b-bb04-37b412739658">
        <source>2</source>
