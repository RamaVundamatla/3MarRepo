/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2022	jlier1	Initial creation TFS 54490

*/

vars
	consignor : CM_ConsigneeConsignor;
begin
	if self.ti &lt;&gt; null and  ti.consignor &lt;&gt; null then
