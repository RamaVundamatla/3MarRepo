<Class name="WS_RestUnPackCargoChildObject" id="5fc4cd5f-eb80-43f7-a3d7-fbe9618c1e5b">
    <superclass name="WS_RestUnPackCargoObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="isValid" id="319cbcd2-ef2f-4978-8602-f2591c13623f">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="quantity" id="a8202a40-58ba-4651-940b-d3fce589a282">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="targetLocationId" id="8ee0feaa-1e0a-4477-9fd1-fc6a86da4228">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="unpackTime" id="aaad9199-7a2d-48f2-91b0-68b27195050b">
        <embedded/>
        <type name="TimeStampOffset"/>
    </PrimAttribute>
    <ImplicitInverseRef name="volume" id="09dc3470-966a-42c1-a139-23cd4b611005">
        <embedded/>
        <type name="WS_RestPackUnpackVolumeObject"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="weight" id="b44df9f2-95a4-4c12-8762-27eb5181d774">
        <embedded/>
        <type name="WS_RestPackUnpackWeightObject"/>
    </ImplicitInverseRef>
    <JadeMethod name="setIsValid" id="e82b6ac1-5aca-48dc-9e29-61878d0d1070">
