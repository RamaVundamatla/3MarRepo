    <JadeMethod name="trxCreateCargoCheck" id="88bb492e-2d44-4ab4-b90f-04b8642ac84a">
        <updating/>
        <source>trxCreateCargoCheck(	_proxyCargoCheck : CM_CargoCheck input; 
						_newCargoCheck : CM_CargoCheck output;
						_passport : CM_Passport input	) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateCargoCheck(_proxyCargoCheck, _newCargoCheck, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyCargoCheck" type="CM_CargoCheck" usage="input"/>
        <Parameter name="_newCargoCheck" type="CM_CargoCheck" usage="output"/>
