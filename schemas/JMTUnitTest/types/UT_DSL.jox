        <source>getInvoiceFinancialClass() : CM_ExtFinanceIO;
// get the current financial class before changing it (see setInvoiceFinancialClass) for a specific test, to restore after the test
vars
	ioClass 		: CM_ExtFinanceIO;
	cls 			: Class;
begin
	ioClass := self.getTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
