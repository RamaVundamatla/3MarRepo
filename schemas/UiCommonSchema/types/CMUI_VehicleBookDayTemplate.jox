    <JadeMethod name="addObjToTblTimes" id="b6f2a7d6-86bc-480f-963f-c2ce47b0253c">
        <source>addObjToTblTimes( _timeTemp : CM_VehicleBookingTimeTemplate );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	dataLine : String;
	index : Integer;

begin

	dataLine := _timeTemp.getAttributeStringForDefArray(self.tblTimes.allTblDataEntRows);
	
	index := self.tblTimes.rows + 1;
	
	self.tblTimes.addItemAt( dataLine, index );
	self.tblTimes.accessRow( index ).itemObject := _timeTemp;

epilog

end;</source>
        <Parameter name="_timeTemp" type="CM_VehicleBookingTimeTemplate"/>
    </JadeMethod>
    <JadeMethod name="btnAddTime_click" id="c5afe02d-8039-44a0-8c66-918a3d232246">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddTime_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars
	vssTemplate : CMUI_VehicleBookTimeTemplate;
	
begin

	vssTemplate := app.loadForm(CMUI_VehicleBookTimeTemplate, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookTimeTemplate;
	if vssTemplate &lt;&gt; null then
		vssTemplate.CMUI_VehicleBookTimeTemplate.setMyTemplates( self.myDayTemplate, null );
		vssTemplate.setParentForm(self);
		vssTemplate.showModal;
		self.initTblTimes();
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
