    <JadeMethod name="assertTrueMsg" id="afa488b9-3b90-46eb-9d38-7b7d35392ec3">
        <source>assertTrueMsg(value : Boolean ; message : String) protected;
//16 July 2008	cnwdw1	
//
// 06/07/2020	jlgmh5	Add writing to automatedOutputFile if it exists
vars
	failException : UT_TestFailureException;
begin
	if value &lt;&gt; true then
		write CrLf &amp; CrLf &amp; "***ERRORS***" &amp; CrLf &amp; message &amp; CrLf;
		self.raiseTestException(value, message, ExceptionCode_TestFailure);
		return;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="value" type="Boolean"/>
        <Parameter name="message" type="String"/>
    </JadeMethod>
