    <JadeMethod name="setupControls" id="c6542cdc-bac5-44b9-bd67-d8717b604c66">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	state : Integer;
	isoType : CM_ISOType;
	iter : Iterator;
	index : Integer;
	
begin

	state := self.myMobileGenericAgent.checksState;
	self.btnAddCargo.visible := false;
	
	if state = self.myMobileGenericAgent.RailReceipt then
		lblState.caption := app.getErrorString(Discharge) &amp; "  ";
		
		if app.getMyUser.canDo(self.myTerminal,PmHHAddCargo) then
			self.btnAddCargo.visible := ( self.myTrackedItem = null and self.myMobileGenericAgent.myCurrentWagon &lt;&gt; null and self.myMobileGenericAgent.myCurrentWagon.isBoxcar );	
		endif;
		
	elseif state = self.myMobileGenericAgent.RailRelease then
		lblState.caption := app.getErrorString(Load) &amp; "  ";
		
	endif;
							
	self.doResizeControls(true);

	populateTrackedItem();
		
epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7b8dfc8d-ce30-4606-8eb8-4cf5cae3e6c9">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars
	
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	self.setupCmdButtons(4, app.getErrorString(Complete), app.getErrorString(Checks), app.getErrorString(Wagon_seals), app.getErrorString(Back), null );
	
	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	//self.myTrackedItem := app.myMobileCargoFindAgent.myTrackedItemToProcess; // populated if returning from a search.
	self.setMyTrackedItem(	app.myMobileCargoFindAgent.myTrackedItemToProcess, null );	 // populated if returning from a search.
	if self.myTrackedItem = null then
		//self.myTrackedItem := self.myHandHeldCheckerAgent.myNextTiToAction;	// returning from another screen
		self.setMyTrackedItem(	self.myMobileGenericAgent.myNextTiToAction, self.myMobileGenericAgent.myWle );		// returning from another screen
	endif;
	

	inheritMethod();
	
	self.setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTblWles" id="00564872-03cc-4fc0-9f29-ce9dfad6fb63">
        <updating/>
        <source>setupTblWles() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2013	cnwndl1	Initial creation	Par 32479

*/

vars

	state : Integer;
	tabIndex : Integer;
	top : Real;
	tblHeight : Real;
	makeVisible : Boolean;
	wle : CM_WorkListEntry;
	tableString : String;
	index : Integer;
	wleLocationId : String;
	preSelectWleAt : Integer;
	preSelectWle : CM_WorkListEntry;
	lc : CM_LocationsController;

begin

	self.setResizeableMarginAndFontSize();
	top := self.txtQuantity.top + self.txtQuantity.height + self.resizedMargin;
	if self.btnAddCargo.visible then
		tblHeight := btnAddCargo.top - ( self.resizedMargin + top );
	else
		tblHeight := btnOne.top - ( self.resizedMargin + top );
	endif;
	state := self.myMobileGenericAgent.checksState;
	tabIndex := self.btnAddCargo.tabIndex + 1;
						
	self.tblWles.fixedRows := 1;
	self.tblWles.fixedColumns := 0;
	self.tblWles.rows := 1;
	self.tblWles.columns := 3;
	
	self.tblWles.setCellText(1,1,"RT" &amp; Tab &amp; "Quantity" &amp; Tab &amp; "Location");
	
	if state = self.myMobileGenericAgent.RailReceipt then
			makeVisible := false;
			
	elseif state = self.myMobileGenericAgent.RailRelease then
		if self.myWorkListEntry &lt;&gt; null then
			preSelectWle := self.myWorkListEntry;
			if self.myTrackedItem = null
			or not self.myTrackedItem.allWorklistEntries.includes(preSelectWle)
			or preSelectWle.status = WLE_COMPLETED
			or not preSelectWle.isRail
			or preSelectWle.isReceipt
			then
				preSelectWle := null;
			endif;
		endif;
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.canMergeBreakBulk then
			foreach wle in self.myTrackedItem.allWorklistEntries do
				if wle.status = WLE_COMPLETED then
					continue;
				endif;
				if not wle.isRail then
					continue;
				endif;
				if wle.isReceipt then
					continue;
				endif;
				wleLocationId := null;
				if wle.myFutureMove &lt;&gt; null then
					wleLocationId := wle.myFutureMove.getPrimaryLocationId();
				endif;
				
				tableString := wle.getDisplayStringForAttribute(ETRow_RadioTelemetry,false) &amp; Tab &amp; 
								wle.quantity.String	 &amp; Tab &amp; 
								wleLocationId;
				index := self.tblWles.addItem(tableString);
				self.tblWles.accessRow( index ).itemObject := wle;
				if preSelectWle = null then
					lc := wle.getTargetLocation;
					if lc &lt;&gt; null and lc.isWagon then
						//if self.myHandHeldCheckerAgent.myCurrentWagon.allLocationsControllers.includes( lc.CM_WagonController ) then
						if self.myMobileGenericAgent.myCurrentWagon.allLocationsControllersArray.includes( lc.CM_WagonController ) then	//04 Dec 2014	NDL	Par 35345
							preSelectWleAt := index;
							preSelectWle := wle;
						endif;
					endif;
				elseif preSelectWle = wle then
					preSelectWleAt := index;
				endif;
			endforeach;
			
			makeVisible := self.tblWles.rows &gt;= self.tblWles.fixedRows + 2;
			if makeVisible and preSelectWleAt &gt; self.tblWles.fixedRows and preSelectWleAt &lt;=  self.tblWles.rows then
				self.tblWles.accessRow( preSelectWleAt ).selected := true;
				self.setMyTrackedItem( self.myTrackedItem, preSelectWle );
				self.tblWles.row := preSelectWleAt;
				
			endif;
			
		else
			makeVisible := false;
			
		endif;
		
		
	endif;
	
	self.tblWles.visible := makeVisible;
	self.tblWles.setAndIncrementTabIndex( tabIndex );
	self.tblWles.move(	self.resizedMargin,
						top,
						self.clientWidth - self.resizedMargin -self.resizedMargin,
						tblHeight );
						
	self.setLBLQuantityCaption();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblWles_mouseUp" id="4b5ac883-8ac2-4345-b646-c12c9eaae4af">
        <controlMethod name="CM_Table::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWles_mouseUp(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2013	cnwndl1	Initial creation	Par 32479

*/

vars

	row : Integer;
	obj : Object;
	wle : CM_WorkListEntry;

begin

	self.setMyTrackedItem( self.myTrackedItem, null );
	row := self.tblWles.row;
	if row &gt; self.tblWles.fixedRows and row &lt;= self.tblWles.rows then
	
		obj := self.tblWles.accessRow( self.tblWles.row ).itemObject;
		if obj &lt;&gt; null and CM_WorkListEntry.hasInstance(obj) then
			wle := obj.CM_WorkListEntry;
			if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.allWorklistEntries.includes( wle ) then
				self.setMyTrackedItem( self.myTrackedItem, wle );
			endif;
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7d0e3ecb-495c-4f56-b98c-cf6289f9079b">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 May 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018482, locale);
	btnAddCargo.translateCaption(Xlat_0018483, locale);
	lblCargoId.translateCaption(Xlat_0018484, locale);
	lblLane.translateCaption(Xlat_0018485, locale);
	lblLocation.translateCaption(Xlat_0018486, locale);
//	lblNewCargoId.translateCaption(Xlat_0019104, locale);
	lblQuantity.translateCaption(Xlat_0019105, locale);
	lblState.translateCaption(Xlat_0018487, locale);
	lblTA.translateCaption(Xlat_0018488, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="b7fbf9c8-856a-464f-ae33-726d7de66420">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin
	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		//self.txtCargoId.text := null;
		self.txtCargoId.selStart := 0;
		self.txtCargoId.selLength := self.lblCargoId.caption.length;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_lostFocus" id="9ad24897-2bfc-4e06-9b0c-54d8d327b955">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275
	
	if self.txtCargoId.text.trimBlanks = null then
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
	else
		//self.selectCargoItem( false );
		//24 Jun 2013	NDL Par 31886
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.id &lt;&gt; self.txtCargoId.text
		or ( self.myTrackedItem = null and self.txtCargoId.text &lt;&gt; self.lblCargoId.caption.toUpper )	//01 Aug 2013	NDL	Par 32140
		then
			self.selectCargoItem( false );
		endif;
	endif;
	
	self.txtCargoId.selStart := 0;
	self.txtCargoId.selLength := 0;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtLocation_gotFocus" id="0d9cc935-aca0-46b8-b55b-dbc3d4710691">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLocation_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	if self.txtLocation.text = self.lblLocation.caption.toUpper then
		self.txtLocation.selStart := 0;
		self.txtLocation.selLength := self.lblLocation.caption.length;
	endif;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtLocation_lostFocus" id="1211008b-5a0a-40cb-b86f-584e4a197994">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLocation_lostFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	if self.txtLocation.text.trimBlanks = null then
		self.resetLocationDisplay;
	endif;
	
	if self.txtLocation.userObject &lt;&gt; null then
		if self.txtLocation.userObject.CM_LocationsController.getFullId &lt;&gt; self.txtLocation.text then
			self.txtLocation.userObject := null;
		endif;
	endif;
	
	self.txtLocation.selStart := 0;
	self.txtLocation.selLength := 0;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
