    <JadeMethod name="doDeleteBookings" id="46a1fa61-ae77-4c4f-b819-980dc5c09c9f">
        <source>doDeleteBookings();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	bookingSlot : CM_VehicleBookingTimeSlot;
	rowIndex : Integer;
	selectedSlots : CM_VehicleBookingByTs;

begin

	create selectedSlots transient;
	
	foreach rowIndex in self.tblBookings.fixedRows + 1 to self.tblBookings.rows do
		if self.tblBookings.accessRow( rowIndex ).selected then
			selectedSlots.add( self.tblBookings.accessRow( rowIndex ).itemObject.CM_VehicleBookingTimeSlot );
		endif;
	endforeach;
	
	if selectedSlots.isEmpty then
		return;
	endif;
	
	if app.msgBox( app.getErrorString(ConfirmDeleteItems), app.getErrorString(Continue), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	foreach bookingSlot in selectedSlots do
		app.myTrxDA.trxDeleteVehicleBooking(bookingSlot, app.myPassport);
		if app.myPassport.hasErrors then
			break;
		endif;
	endforeach;
	
epilog

	delete selectedSlots;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDisassociate" id="0f7dbcdb-6c59-4315-bf2e-edd98d679ba5">
        <source>doDisassociate()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
09 April 2013	cnwndl1	Initial creation	Par 31393
18 May 2023		navpw1	 TFS: 54049 (55843) - Used Vehicle Booking Time Slot instead of vvr
*/

vars
	booking : CM_VehicleBookingTimeSlot;
	vvr : CM_VehicleVisitRecord;
	theReturn : Integer;
	
begin
	if self.tblBookings.row &gt; self.tblBookings.fixedRows and self.tblBookings.row &lt;= self.tblBookings.rows then
		booking := self.tblBookings.accessRow( self.tblBookings.row ).itemObject.CM_VehicleBookingTimeSlot;
	endif;
	
	if booking = null or not booking.isUsed then
		return;
	endif;
	
	//vvr := booking.myVehicleVisitRecord;
	
	//if vvr = null then
	//	return;
	//endif;
	
	while true do
		app.myTrxUA.trxDisassocVehicleBookingVvr(booking, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Vehicle_schedul_booking_slot), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doHandleNotification" id="522d9d24-977b-46dc-b637-cb43b395b0a7">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2010	cnwndl1	Initial creation

*/

vars

	booking : CM_VehicleBookingTimeSlot;

begin

	if theObject = null then
		return;
	endif;
	
	if theObject.isKindOf( CM_VehicleBookingTimeSlot ) then
		booking := theObject.CM_VehicleBookingTimeSlot;
		self.doHandleVehicleBookingNote( eventType, booking );
		
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doHandleVehicleBookingNote" id="bd45baac-2eb8-43d8-a912-619b5a826198">
        <updating/>
        <source>doHandleVehicleBookingNote( eventType: Integer; _vvsBooking : CM_VehicleBookingTimeSlot ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 March 2011	cnwndl1	Initial creation
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	
	tmpStr : String;
	idx : Integer;
	selObj : CM_Object;
	doRefresh : Boolean;
	dateDisplayed : Date;
	now : TimeStamp;

begin

	if _vvsBooking = null then
		return;
	endif;
	
	if self.myVehicleBookingTerminal = null then
		return;
	endif;
	
	dateDisplayed := self.txtDate.getDate();
	
	if eventType = Object_Create_Event then
		//its an add, might need to include it
		if not dateDisplayed.isValid or self.systemToLocalTime(_vvsBooking.bookingTSstart).Date &lt;&gt; dateDisplayed  then// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			return;
		endif;
		if self.myVehicleBookingTerminal &lt;&gt; null then
			if _vvsBooking.myVehicleBookingTerminal &lt;&gt; self.myVehicleBookingTerminal then 
				//its new but not associated with our terminal.
				return;
			endif;
		endif;
		now := app.actualTimeServer;// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.addBookingSlotToTable( _vvsBooking, true, idx, now );
		
	elseif eventType = Object_Update_Event then
		if self.myVehicleBookingTerminal &lt;&gt; null then
			if _vvsBooking.myVehicleBookingTerminal &lt;&gt; self.myVehicleBookingTerminal then 
				//its new but not associated with our terminal.
				return;
			endif;
		endif;
		self.tblBookings.findObjectInRow(_vvsBooking, idx);
		if idx &gt; 0 then
			self.tblBookings.removeItem(idx);
		endif;
		now := app.actualTimeServer;// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.addBookingSlotToTable( _vvsBooking, true, idx, now );
		
		
		
	elseif eventType = Object_Delete_Event then
		//its a delete, make sure its not in the filter.
		self.tblBookings.findObjectInRow(_vvsBooking, idx);
		if idx &gt; 0 then
			self.tblBookings.removeItem(idx);
		endif;
		
	endif;
		
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="_vvsBooking" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="doMaintainBooking" id="ba029577-ebbc-418a-ac45-f91d142e3c70">
        <source>doMaintainBooking( _bookingSlot : CM_VehicleBookingTimeSlot )protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	slotMaintForm : CMUI_VehicleBookingSlotMaint;
	bookingSlot : CM_VehicleBookingTimeSlot;
	now : TimeStamp;
	tsInt : TimeStampInterval;
	ts : TimeStamp;
	msg : String;
	hrs : Integer;
	type : String;

begin

	//20 Mar 2015	NDL	Par 35882
	if _bookingSlot &lt;&gt; null then
		bookingSlot := _bookingSlot;
	else
		if self.tblBookings.row &gt; self.tblBookings.fixedRows and self.tblBookings.row &lt;= self.tblBookings.rows then
			bookingSlot := self.tblBookings.accessRow( self.tblBookings.row ).itemObject.CM_VehicleBookingTimeSlot;
		endif;
	endif;
	
	if bookingSlot = null then
		return;
	endif;
	
	if bookingSlot.isExpired then
		 msg := app.getErrorString(Vehic_sched_booki_not_maint_af);
		 app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only );
	//	return;  //14 May 2015	NDL	Par 36234
	endif;
	
	tsInt := bookingSlot.getBookInAdvanceTimeInterval(hrs,type);
	if tsInt &lt;&gt; null then
		now := app.actualTimeServer;// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		ts := now + tsInt;
		if bookingSlot.bookingTSstart &lt; ts then
			msg := app.getErrorString2(Vehic_sched_booki_must_made_le, hrs.String, type);
			app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only );
			return;
		endif;
	endif;

	slotMaintForm := app.loadForm(CMUI_VehicleBookingSlotMaint, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookingSlotMaint;
	if slotMaintForm &lt;&gt; null then
		slotMaintForm.setMyBookingSlot(bookingSlot,null,null);
		slotMaintForm.setMyCallingForm(self);	//20 Mar 2015	NDL	Par 35882
		slotMaintForm.show;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bookingSlot" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="doMnuAuditsForObjectClick" id="17e481e5-909d-4827-9209-18e7523898f0">
