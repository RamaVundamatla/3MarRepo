    <JadeMethod name="doResetSearch" id="9a41b640-d128-4b76-92bd-ffc4b314b966">
        <source>doResetSearch();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14/12/2009	cnwrd1	Initial creation
26/06/2018	jlgdap1	TFS 39440 PEl1 Work Order Enquiry Parameters
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	
begin
	inheritMethod();
	
	self.cmbOrganisation.listObject := null;
	self.txtWorkOrderNum.text 		:= null;
	self.txtCustomerRef.text 		:= null;	
	
	self.mltWOStatus.setSelected(self.allTaskStatus);
	
	self.chkInclArchived.value := false;
	
	//self.mskRequestlDT.setDate(null);		//26/11/2024	navkc1 JIRA Story MTN-19092
	//self.mskRequestTM.setTime(null);		//26/11/2024	navkc1 JIRA Story MTN-19092
	//self.mskRequestToDT.setDate(null);	//26/11/2024	navkc1 JIRA Story MTN-19092
	//self.mskRequestToTM.setTime(null);	//26/11/2024	navkc1 JIRA Story MTN-19092
	self.setDateTimeToNow();				//26/11/2024	navkc1 JIRA Story MTN-19092
	
	self.mskScheduleDT.setDate(null);
	self.mskScheduleTM.setTime(null);
	self.mskScheduleToDT.setDate(null);
	self.mskScheduleToTM.setTime(null);
	self.mskCompletedDT.setDate(null);
	self.mskCompletedTM.setTime(null);
	self.mskCompletedToDT.setDate(null);
	self.mskCompletedToTM.setTime(null);
	
	self.mskRequestedByFromDT.setDate(null);				//29.09.2021 navma1 #51925
	self.mskRequestedByFromTM.setTime(null);                //29.09.2021 navma1 #51925
	self.mskRequestedByToDT.setDate(null);                  //29.09.2021 navma1 #51925
	self.mskRequestedByToTM.setTime(null);                  //29.09.2021 navma1 #51925
	
	
	self.initWorkOrderTypes();								// TFS 39440
	self.initTransportMode();								//26/11/2024	navkc1 JIRA Story MTN-19092
	self.chkCargoWO.value  := true;							// TFS 39440
	self.chkVoyageWO.value := true;							// TFS 39440
	self.doSelectUnselectWOTypes(true, self.tblCargoWO);	// TFS 39440
	self.doSelectUnselectWOTypes(true, self.tblVoyageWO);	// TFS 39440
	self.doSelectUnselectTransMode(true);					//26/11/2024	navkc1 JIRA Story MTN-19092
	
	self.cmbVoyage.listIndex := -1; 						// TFS 41026
	self.cmbUsers.listIndex  := -1;							//29.09.2021 navma1 #51925
	
	self.doBuildComboBOL();									//26/11/2024	navkc1 JIRA Story MTN-19092
	self.txtBookingID.text := null; 						//26/11/2024	navkc1 JIRA Story MTN-19092
	self.txtCargoGroupID.text := null;						//26/11/2024	navkc1 JIRA Story MTN-19092
	self.txtContractID.text := null;						//26/11/2024	navkc1 JIRA Story MTN-19092	
	self.txtCustomsEntryNum.text := null;						//26/11/2024	navkc1 JIRA Story MTN-19092
	self.doBuildComboOperator();							//26/11/2024	navkc1 JIRA Story MTN-19092
	self.txtReleaseReqNum.text := null;						//26/11/2024	navkc1 JIRA Story MTN-19092
	self.doBuildComboToDoTaskDesc();						//26/11/2024	navkc1 JIRA Story MTN-19092
	self.cmbVessel.listIndex := -1;							//26/11/2024	navkc1 JIRA Story MTN-19092
	self.doBuildComboVoyage();								//26/11/2024	navkc1 JIRA Story MTN-19092
	self.doBuildComboTrain();								//26/11/2024	navkc1 JIRA Story MTN-19092
	self.doBuildComboWagon();								//26/11/2024	navkc1 JIRA Story MTN-19092
	self.cmbVehicleVisit.listIndex := -1;					//26/11/2024	navkc1 JIRA Story MTN-19092
	self.txtVBSExtRef.text := null;							//26/11/2024	navkc1 JIRA Story MTN-19092
	self.doSelectUnselectTransMode(true);					//26/11/2024	navkc1 JIRA Story MTN-19092
	self.doBuildComboVehicleVisit();						//26/11/2024	navkc1 JIRA Story MTN-19092
	
epilog

end;</source>
