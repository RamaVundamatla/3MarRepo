    <JadeMethod name="initTblBookingItems" id="7f672ba7-6bf5-4981-adb7-f335118c8c3f">
        <source>initTblBookingItems(_theEntDef : String);
//-----------------------------------------
//
// Created : by cnwaer1 26 August 2008
//-----------------------------------------
vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
begin
	theTable := self.tblBookingItems;
	theTable.allSelectedObjects.clear;
	
	if _theEntDef &lt;&gt; null then
		theTable.userInputEnabled := false;
		theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
		theTable.selectionType := CM_EntryTable.SelectionType_Row;
		theTable.rows := theTable.fixedRows;
		
		entTableDef := app.myController.getEntTableDef(_theEntDef);
		theTable.setTblDataEntRowsFromDef(entTableDef);
		theTable.setMyDataClass(CM_BookingRefItem);
		theTable.readOnly := false;	
		theTable.fixedColumns := 0;
		theTable.fixedRows := 1;
		//theTable.fixed3D := false;
		//theTable.show3D := Table.Show3D_Not3D;
		self.setColorsForTable(self.tblBookingItems);
		
		//cnwjo3, par 20606
		self.setFieldAlignmentOnTable(theTable);
	else
		theTable.rows := 1;	
	endif;
end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="inspectObject" id="2b8c4476-c92b-4de9-bf8b-a635f4e8d327">
        <source>inspectObject();
//-----------------------------------------
//
// Created : by cnwaer1 01 September 2008
//-----------------------------------------
vars
	obj 		: Object;
begin
	if self.tblBookingItems.row &gt; 1  then
		obj := self.tblBookingItems.allSelectedObjects.first;
		if obj &lt;&gt; null then
			obj.inspect;
		endif;
	else
		obj := self.tblBookingItems;
			if obj &lt;&gt; null then
			obj.inspect;
		endif;
	endif;
end;</source>
    </JadeMethod>
