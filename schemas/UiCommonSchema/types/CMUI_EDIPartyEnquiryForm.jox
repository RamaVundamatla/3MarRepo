16/10/2012	cnwcs5	par 30483
*/
vars

begin
	inheritMethod(_def);
	
	self.tblData.readOnly := true; 	// par 30483 Oct 2012
epilog

end;</source>
        <Parameter name="_def" type="String"/>
    </JadeMethod>
    <JadeMethod name="populateValidEDILicenses" id="7980637f-9017-420c-b2ed-540fde424519">
        <updating/>
        <source>populateValidEDILicenses() updating;
/*

Purpose:			Determine whether the system is licensed for any of the EDI File Types we care about.
					(The idea here is to just check the licenses once, rather than every time we need to.)

Parameters:			

Return Value:		

Date			Who		Reason
14 April 2021	navmd1	Initial creation TFS 51071 ADP - EDI Party Enquiry screen cannot be accessed despite having licensce
14 Aug 2023	jlirs1	TFS 57770 Port of Origin BOP
04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
*/

vars
	root	: CM_Root;
begin
	root := app.myRoot;
	
	self.validEDILicenses[EDIFileType_Baplie20]				:= root.canDoEDIFileType(EDIFileType_Baplie20);				// 11
	self.validEDILicenses[EDIFileType_Coreor]				:= root.canDoEDIFileType(EDIFileType_Coreor);				// 13
	self.validEDILicenses[EDIFileType_Coprar]				:= root.canDoEDIFileType(EDIFileType_Coprar);				// 19
	self.validEDILicenses[EDIFileType_CusCar]				:= root.canDoEDIFileType(EDIFileType_CusCar);				// 25
	self.validEDILicenses[EDIFileType_Coparn] 				:= root.canDoEDIFileType(EDIFileType_Coparn);				// 83
	self.validEDILicenses[EDIFileType_IFTMCS03A]			:= root.canDoEDIFileType(EDIFileType_IFTMCS03A);			// 86
	self.validEDILicenses[EDIFileTypeX12_301_4010]			:= root.canDoEDIFileType(EDIFileTypeX12_301_4010);			// 96
	self.validEDILicenses[EDIFileType_CoparnRelease]		:= root.canDoEDIFileType(EDIFileType_CoparnRelease);		// 108
	self.validEDILicenses[EDIFileTypeX12_315_4010]			:= root.canDoEDIFileType(EDIFileTypeX12_315_4010);			// 110
	self.validEDILicenses[EDIFileTypeCAMIR_CustomsStatus]	:= root.canDoEDIFileType(EDIFileTypeCAMIR_CustomsStatus);	// 113
	self.validEDILicenses[EDIFileType_XML_Milaha_Customs]	:= root.canDoEDIFileType(EDIFileType_XML_Milaha_Customs);	// 135
	self.validEDILicenses[EDIFileType_Baplie22]				:= root.canDoEDIFileType(EDIFileType_Baplie22);				// 140
	self.validEDILicenses[EDIFileType_IFCSUM94B]			:= root.canDoEDIFileType(EDIFileType_IFCSUM94B);			// 141
	self.validEDILicenses[EDIFileType_IFCSUMAUBNE94B]		:= root.canDoEDIFileType(EDIFileType_IFCSUMAUBNE94B);		// 163	//14 Aug 2023	jlirs1	TFS 57770 Port of Origin BOP

	// Urgh - whats a more sensible way to do this...
	if 	self.validEDILicenses[EDIFileType_Baplie20] or					// 11
		self.validEDILicenses[EDIFileType_Coreor] or					// 13
		self.validEDILicenses[EDIFileType_Coprar] or					// 19
		self.validEDILicenses[EDIFileType_CusCar] or					// 25
		self.validEDILicenses[EDIFileType_Coparn] or					// 83
		self.validEDILicenses[EDIFileType_IFTMCS03A] or					// 86
		self.validEDILicenses[EDIFileTypeX12_301_4010] or				// 96
		self.validEDILicenses[EDIFileType_CoparnRelease] or				// 108
		self.validEDILicenses[EDIFileTypeX12_315_4010] or				// 110
		self.validEDILicenses[EDIFileTypeCAMIR_CustomsStatus] or		// 113
		self.validEDILicenses[EDIFileType_XML_Milaha_Customs] or		// 135
		self.validEDILicenses[EDIFileType_Baplie22] or					// 140
		self.validEDILicenses[EDIFileType_IFCSUM94B] or					// 141
		self.validEDILicenses[EDIFileType_IFCSUMAUBNE94B]				// 163
	then
		self.isLicensed := true;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ad40a639-d6f7-4b0d-a3e1-a5a273abf7ff">
        <updating/>
        <source>setupForm() updating;
/*
Date		Who		Reason
17 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
22 Jul 2013	cnwcs5	par 31942 - check EDI licenses
14 Apr 2021 navmd1	TFS 51071 Move EDI License checks to one place so View and Maint forms match!
*/
vars
	//root	:CM_Root;
begin
	// we need to have a relevant EDI license to even bother showing the form
	// right now EDI party rules are only defined for Coparn and IFTMCS file types
	/*
	root := app.myRoot;

	if not root.canDoEDIFileType (EDIFileType_Coparn) and
		not root.canDoEDIFileType (EDIFileType_CoparnRelease) and
		not root.canDoEDIFileType (EDIFileType_IFTMCS03A) then
		app.msgBox (app.getErrorString1 (NotLicensedToPerformAction, self.caption), self.caption, MsgBox_OK_Only);
		self.unloadForm;
	endif;
	*/
	
	self.populateValidEDILicenses();	// TFS 51071
	
	// Now, check to make sure we have any of the licenses we're expecting...
	if not self.isLicensed then
		app.msgBox (app.getErrorString1 (NotLicensedToPerformAction, self.caption), self.caption, MsgBox_OK_Only);
		self.unloadForm;
		return;
	endif;
	
	self.staStatusBar.visible	:= true;
	self.usesQueryFrame 		:= false;
	self.toolbarStyle 			:= self.ToolbarStyle_ShowNoHide;	
	self.showToolbar 			:= true;
	self.useTableInfo 			:= true;
	self.useTableSorting 		:= true;

	inheritMethod();
	
	self.initTableData(ETDef_EDIPartyEnquiry);
	
	self.btnNew.enabled	:= true;				// may not be visible if they don't have maint permission
	
	self.setNavigatorHeading (self.caption);	// par 27612 cnwcs5 31/05/2010
	
	self.beginClassNotification(CM_EDIParty, false, Object_Create_Event, Response_Continuous, 0);
	
	self.doQuery;
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ac173d8e-06d5-473b-ad73-73c188602b76">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017234, locale);
	btnNew.translateCaption(Xlat_0017235, locale);
end;</source>
    </JadeMethod>
</GUIClass>
