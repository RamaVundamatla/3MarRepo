    <JadeMethod name="getCopiesFromJRWReport" id="ba4ba84f-ab33-4d8a-97b1-8429d20b6dad">
        <source>getCopiesFromJRWReport(_report :JadeReportWriterReport input ) :Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2019	jlger1	Initial creation

*/

vars
	documentType : Integer ;
	orientation : Integer ;
	copies : Integer ; 
	topOfPage : Integer ;
	bottomOfPage : Integer ; 
	leftMargin : Integer ; 
	rightMargin : Integer ; 
	borderWidth : Integer ; 
	collate : Boolean ;
	duplex : Integer ;
begin
	if _report = null then
		return 1;
	endif;
	
	_report.getPageOptions(documentType ,orientation ,copies ,	topOfPage ,	bottomOfPage,	leftMargin ,	rightMargin ,	borderWidth ,
	collate ,	duplex );
	
	return copies.max(1);
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_report" type="JadeReportWriterReport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFormatDescriptionForType" id="9b20ad78-ca8e-45c1-8fbc-65d71d2015a5">
        <source>getFormatDescriptionForType(_reportFormatType : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     05 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _reportFormatType = JadeReportWriterReport.CSV then
		return self.FORMAT_OPTION_CSV;
	elseif _reportFormatType = JadeReportWriterReport.RTF then
		return self.FORMAT_OPTION_RTF;
	elseif _reportFormatType = JadeReportWriterReport.HTML then
		return self.FORMAT_OPTION_HTML;
	elseif _reportFormatType = JadeReportWriterReport.XML then
		return self.FORMAT_OPTION_XML;
	elseif _reportFormatType = JadeReportWriterReport.TEXT then
		return self.FORMAT_OPTION_TEXT;		// 28128
	else
		return self.FORMAT_OPTION_STANDARD;
	endif;
	
end;</source>
        <Parameter name="_reportFormatType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
