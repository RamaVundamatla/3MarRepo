    <JadeMethod name="addObjectsToTable" id="dc86816b-517d-4c9e-8ff6-478d41289bf1">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	workTask : CM_WorkTask;
	cgAssign : CM_CargoGroupAssignment;
	iter : Iterator;
	invalidObject : Boolean;
	breakOut : Boolean;

begin

	self.tblThumb.rows := 0;
	self.tblCGN.rows := 0;
	self.tblCGNid.rows := 0;

	workTask := self.myTerminal.allWorkTasksDict.getAtKeyGeq( CM_WorkTask.Type_CargoGroupAssignment, null );
	if workTask = null or not workTask.isCargoGroupAssignment then
		return;
	endif;
	
	iter := self.myTerminal.allWorkTasksDict.createIterator;
	iter.startAtObject( workTask );
	
	on Exception do app.handleDeletedObject(exception, cgAssign, invalidObject);
	
	while iter.next( cgAssign ) do
		if not cgAssign.isCargoGroupAssignment then
			break;
		endif;
	
		if self.includeObjectCGAssign(cgAssign, _numItems, breakOut) then
			self.addObjectToTable(cgAssign, _numItems, breakOut);
		endif;
		
		if breakOut then
			break;
		endif;
	
	endwhile;
	
	self.btnGroupMaint.enabled := _numItems &gt; 0;

epilog

	delete iter;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="cbb30629-9c5a-491c-93d4-d1108a6b9392">
        <source>addToolbarControls() protected;
/*

Purpose:			

