    <JadeMethod name="tblDirector_keyUp" id="88c5015a-b690-4429-9adc-beebe9f442a3">
        <controlMethod name="Table::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDirector_keyUp(table: Table input; keyCode: Integer io; shift: Integer) updating;
/*

Date		Who		Reason
21 August 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if keyCode = J_key_UpArrow or
		keyCode = J_key_DownArrow  or 
		keyCode = J_key_Enter or 
		keyCode = J_key_Home or		
		keyCode = J_key_End	then		
		table.click(table);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblSelectTasks_click" id="39cf781e-33ba-4a7a-8d55-8a3f32ec02c8">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSelectTasks_click(table: Table input) updating;
/*

Date		Who		Reason
05 August 2014	cnwer1	Initial creation PAR

*/

vars
	multiSelect : Boolean;
	rtQueueEntry : CM_RTQueueEntry;
	itemObj	: DTO_RTQueueEntry;
	task : CM_RTQueueTask;
	selectedEntries : CM_RTQueueEntryArray;
begin
	multiSelect:=true;
	create selectedEntries transient;
/*	self.getSelectedRTQueueEntries(selectedEntries);
	if selectedEntries.size &gt; 0 then
		foreach rtQueueEntry  in selectedEntries do
			task:= rtQueueEntry.getDirectorOrPickupTask();
			if task &lt;&gt; null and task.taskType = TASK_DIRECTOR then
				multiSelect:=false;
				break;
			endif;	
		endforeach;
	endif;
	
	if multiSelect then
		itemObj:= self.tblSelectTasks.accessRow(table.row).itemObject.DTO_RTQueueEntry;
		if itemObj &lt;&gt; null then
			task:= itemObj.myRealQueueEntry.CM_RTQueueEntry.getDirectorOrPickupTask();
			if task &lt;&gt; null and task.taskType = TASK_DIRECTOR then
				multiSelect:=false;
			endif;	
		endif;
	endif;
	*/
	self.displayVMTableRow(table,table.row,multiSelect);
epilog
	delete selectedEntries;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
