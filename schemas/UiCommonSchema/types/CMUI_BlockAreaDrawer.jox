    <JadeMethod name="addLocation" id="22a73a46-a0e1-492f-9bc8-d495e4f796b6">
        <updating/>
        <source>addLocation(location : CM_IrregularBlockController input; _select : Boolean) updating;
// a new location has been added to the area
begin
	self.addLocationToCells(location);
	if _select then
		self.selectLocation(location);
	endif;
	myTopFrame.locClick(myTopFrame, location);
end;
</source>
        <Parameter name="location" type="CM_IrregularBlockController" usage="input"/>
        <Parameter name="_select" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addLocationToCells" id="0ead15d9-e29e-4c7d-9a9c-ddc2c6a99cb7">
        <source>addLocationToCells(location : CM_IrregularBlockController) protected;
// Add the location region to the cells location. 
vars
	topLeft, bottomRight : Point;
	x, y : Integer;
begin
	if location.region.isEmpty() then
		return;
	endif;
	
	topLeft := location.region.first;
	bottomRight := location.region.last;
	foreach x in topLeft.x to bottomRight.x do
		foreach y in topLeft.y to bottomRight.y do
			self.getCell(x, y).setLocation(location);
			self.deselectCell(x, y);
		endforeach;
	endforeach;
end;
</source>
        <access>protected</access>
        <Parameter name="location" type="CM_IrregularBlockController"/>
    </JadeMethod>
    <JadeMethod name="cellToPixel" id="b252b866-8a88-48a4-8842-518c4719859b">
        <source>cellToPixel(cell: Point) : Point protected; 
// Convert a cell to a pixel point
vars
	pixel: Point;
begin
	pixel.setX(gridBorderWidth + gridLineWidth + ((cellSize.x + gridLineWidth) * (cell.x - 1)));
	pixel.setY(gridBorderWidth + gridLineWidth + ((cellSize.y + gridLineWidth) * (cell.y - 1)));
	return pixel;
end;
</source>
        <access>protected</access>
        <Parameter name="cell" type="Point"/>
        <ReturnType type="Point"/>
    </JadeMethod>
    <JadeMethod name="clearAllGraphics" id="bd2872c0-0a29-4052-b42f-d12ec7cb2f47">
        <source>clearAllGraphics() protected;
// Clear all grahics on the grid
begin
	self.myDrawingFrame.clearGraphics();
	if self.myYardAllocationDrawingFrame &lt;&gt; null then
		self.myYardAllocationDrawingFrame.clearGraphics();
	endif;
	self.myHLabels.clearGraphics();
	self.myVLabels.clearGraphics();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="columns" id="378942d7-e711-4d77-8de6-de7658a18fab">
        <source>columns() : Integer protected;
// Return the number of columns in the grid
begin
	return self.myTerminalArea.columns;
end;
</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
