    </JadeMethod>
    <JadeMethod name="processLock" id="af2489ae-3ccf-467c-b76e-efe11a47a052">
        <updating/>
        <source>processLock(class : Integer; instanceId : Integer; parClass : Integer; subLevel : Integer; subId : Integer;
            waitTime : Integer64; volatility : Integer; lockKind : Integer) updating;

vars
	sampleObject : SampleObjects;
begin

	sampleObject  := app.myListener.v_sampleLocks [ class, instanceId, parClass, subLevel, subId];

	if sampleObject = null then
		create sampleObject;
		sampleObject.classnumber    := class;
		sampleObject.instanceId     := instanceId;
		sampleObject.parClassnumber := parClass;
		sampleObject.subLevel       := subLevel;
		sampleObject.subId          := subId;
		sampleObject.type           := Lock_Request;
		sampleObject.count          := 0;
		sampleObject.lockKind       := lockKind;
		sampleObject.volatility     := volatility;
		app.myListener.v_sampleLocks.add(sampleObject);
	endif;
	if waitTime &lt;&gt; 0 then
		sampleObject.queuedCount.bump;
		sampleObject.queuedTime := sampleObject.queuedTime + waitTime.Integer;
	endif;
	sampleObject.count.bump;

end;</source>
        <Parameter name="class" type="Integer"/>
        <Parameter name="instanceId" type="Integer"/>
        <Parameter name="parClass" type="Integer"/>
        <Parameter name="subLevel" type="Integer"/>
        <Parameter name="subId" type="Integer"/>
        <Parameter name="waitTime" type="Integer64"/>
        <Parameter name="volatility" type="Integer"/>
        <Parameter name="lockKind" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processNodeSamplingInput" id="0a4148d7-b265-480b-a7ea-50a26831d7dc">
        <updating/>
        <source>processNodeSamplingInput(data : String io) updating;
//
//	Process the sample text string received from Node Sampling.
//  Only handles IndividualLocalRequest and IndividualRemoteRequest and Cache Buffer Snapshots
//	Type are in ObjectManager.pdf Chapter 4
//
//	New to Jade 6.1
//
//  The two extra values occur at the end of each of these sampling records (type 10 and type 14):
//
//  object volatility : 8 is Volatility_Stable, 4 is Volatility_Frozen, 0 is Volatility_Volatile
// 
//  The second is -
//  lock kind :
//  For lock requests: 0 is a process lock, 1 is a node/local-only lock. (no constants defined for these)
//
constants

vars
	pos           : Integer;
	length        : Integer;
	ticks         : Integer64;
	cpuTime       : Integer64; 
	waitTime      : Integer64;
	type          : Integer;
	nodeNumber    : Integer;
	processNumber : String;
	class         : Integer;
	instance      : Integer;
	instance64    : Integer64;
	subLevel      : Integer;
	subId         : Integer;
	actualInstance: Integer;
	methClass     : Integer;
	methInstId    : Integer;
	parClass      : Integer;
	requestType   : Integer;
	mode          : Integer64;
	lockKind      : Integer;
	volatility    : Integer;

begin
//write data;
	pos := 1;
	length := data.length;

	type         := data.getToken(pos).Integer;
	messageCount := messageCount + 1;

	if type = FileHeader then
		processFileHeader(data, pos);
		return;
	endif;
	
	if type = BeginProcess then
		processBeginProcess(data);
		return;
	endif;
	if type = CacheStatistics then
		processCacheStatistics(data, pos);
		return;
	endif;
	if type = CacheBufferActivity then
		processCacheSnapshot(data, pos);
		return;
	endif;
	if v_remote = true then
		if type &lt;&gt; IndividualRemoteRequest then
			return;
		endif;
	else
		if type &lt;&gt; IndividualLocalRequest then
			return;
		endif;
	endif;
//write data;
	nodeNumber    := data.getToken(pos).Integer;
	processNumber := data.getToken(pos);
	ticks         := data.getToken(pos).Integer64; // clock ticks
	lastCPUTime   := data.getToken(pos).Integer64; // node cpu
	bypassTokens( 7, data, pos); // node ticks, process cpu, process ticks, process logical clocks, user number, request count, request level
	requestType   := data.getToken(pos).Integer; // request type
	mode          := data.getToken(pos).Integer64; // mode
	if startTime = 0 then
		startTime := ticks;
	else
		lastTime := ticks;
	endif;

	if processCheckIfRequired(requestType, mode) = false then
		return;
	endif;

	if requestType = CauseEvent_Request then
		incrementCauseEventCount.bump;
		causeEventCount.bump;
	endif;

	bypassTokens( 4, data, pos);
	waitTime      := data.getToken(pos).Integer64; // wait time
	if type = IndividualLocalRequest then
		bypassTokens( 1, data, pos);
	else
		bypassTokens( 6, data, pos);
	endif;

	class         := data.getToken(pos).Integer; // Class ID
	class         := class.bitAnd(16383); // get rid of transient and shared transient bits
	//
	// Problem returning large instance id
	//
	instance64    := data.getToken(pos).Integer64; // Instance ID
	if instance64 &gt; Max_Integer then
		instance  := 0;
	else
		instance  := instance64.Integer;
	endif;
	parClass      := data.getToken(pos).Integer; // Parent Class ID
	parClass      := parClass.bitAnd(16383);     // get rid of transient and shared transient bits
	subLevel      := data.getToken(pos).Integer; // subLevel
	subId         := data.getToken(pos).Integer; // subId

	if requestType = BeginTransaction_Request or requestType = EndTransaction_Request then
		processTransactions(data, requestType, pos, processNumber, mode, nodeNumber);
		return;
	endif;
	actualInstance := instance;
	//
	// Check if we want system classes - we will also drop slobs of system classes
	//
	if dropSystemClasses = true then
		if (class &lt;&gt; 0 and class &lt; 2048 ) then
			return;
		endif;
		if (class = 0 and parClass &lt; 2048) then
			return;
		endif;
	endif;

	if class &gt; 1279 and class &lt; 2048 then
		class := class - 1279;
	endif;

	if includeInstances = false then
		instance := 0;
		parClass := 0;
	endif;
	//
	// Check if we are required to output the method name of the action
	//
	if v_outputMethodName = true then
		methClass  := app.myListener.tbx_ClassId.text.trimBlanks.Integer;
		if includeInstances = false then
			methInstId := 0;
		else
			methInstId := app.myListener.tbx_InstId.text.trimBlanks.Integer;
		endif;
		//
		// Check for matching Class number (and maybe instance Id)
		//
		if (methInstId = 0 and class = methClass) or
		   (methInstId = instance and class = methClass) or
		   (methClass = 0) then
			showMethodActionOccurredIn(data, requestType, pos, mode, class, actualInstance, parClass, subLevel, subId, waitTime, processNumber);
		endif;
	endif;
	//
	// These 2 fields are the volatility and lock kind introduced in Jade 6.1
	//
	if (v_jadeMajorVersion = 6 and v_jadeMinorVersion &gt; 0 ) or
	   (v_jadeMajorVersion &gt; 6) then

		lockKind   := data.getReverseToken(length).Integer;
		volatility := data.getReverseToken(length).Integer;

	endif;

	if requestType = Get_Request then

		processGet(class, instance, parClass, subLevel, subId, waitTime, volatility, lockKind);

	elseif requestType = Lock_Request then

		processLock(class, instance, parClass, subLevel, subId, waitTime, volatility, lockKind);

	elseif requestType = Unlock_Request then

		processUnlock(class, instance, parClass, subLevel, subId, mode);

	elseif requestType = Put_Request then

		processPuts(class, instance, parClass, subLevel, subId, mode, volatility, lockKind);

	elseif requestType = Note_Request then

		processNotification(class, instance);
		
	elseif requestType = GetEdition_Request then

		processGetEdition(class, instance, parClass, subLevel, subId, waitTime);

	elseif requestType = RemoteMethod_Request then

		serverExecutionCount.bump;
		incrementServerExecutionCount.bump;

	elseif requestType = BeginNotification_Request then

		beginNoteCount.bump;
		incrementBeginNoteCount.bump;

	endif;
	
epilog

end;</source>
        <text>Jade 6.1 enhancements

The two extra values occur at the end of each of these sampling records (type 10 and type 14):
 
The first is - 
 
object volatility : 8 is Volatility_Stable, 4 is Volatility_Frozen, 0 is Volatility_Volatile
 
(these names are global constants in JDE)
 
The second is -
 
lock kind :
 
For lock requests: 0 is a process lock, 1 is a node/local-only lock. (no constants defined for these)
 
A process lock is a "normal" lock. A node/local-only lock relates to stable objects - a Node Lock
means that any process on the applicable node may have the object locked (shared, transaction
duration). A local-only lock indicates that a process has a stable object locked, but is only recorded
on the client node. This means that the first time a shared, transaction duration lock on a
stable object is requested by a client node, Node Sampling will record an individual remote request entry
from the client node, and the corresponding individual local request entry from the server node. The volatility
will be 8 (stable), and the lock kind will be 1 (node lock). There will be NO node sampling entries for
subsequent shared, transaction duration locks on the same object, as they do not go to the server, but
are handled within the client node.
 
Note that not all lock requests on stable objects result in node/local-only locks. Any lock that is not
shared, transaction duration will be a process lock. Also, there are other times when even a shared,
transaction duration lock has to be a process lock (usually when a process is trying to upgrade the
lock).
 
For unlock requests: 0 is a normal unlock request, 8 or 9 represent requests to remove node locks.
 
The client node makes a "node lock" unlock request when the stable object is no longer locked and gets
taken out of cache, or in response to a server request (because a process wants an exclusive lock). The
value will be 9 instead of 8 if the client node had the object locked when the server requested the node lock to be
released, meaning the "node lock" unlock had to be delayed.
 
 
The object volatility will appear on GET OBJECT and PUT OBJECT requests as well as lock requests. It is not
recorded for UNLOCK requests, because the object is not passed with the request.
 
For the getObjectCaches call, there are 3 new 64-bit values that appear at the end :
 
nodeLockRemoveRequestsSent
nodeLockRemoveRequestsRcvd
nodeLockSwapOutRequestsSent
 
These reflect internal notifications that are sent to request node lock release. The first counts the number of
times the server sends a notification to ask client nodes to release a node lock. The second counts the
number of times a client node receives such a request. The third counts the number of times a client node
sends a local notification to request node lock release because a stable object is being removed from
the cache. The names I have written above are the ones that appear in the JadeDynamicObject, if you are
using that technique.</text>
        <Parameter name="data" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processNotification" id="9c09299b-f596-4f4d-8e02-88273ee64bc1">
        <updating/>
        <source>processNotification(class : Integer; instanceId : Integer) updating;

vars
	sampleObject : SampleObjects;
begin
	sampleObject  := app.myListener.v_sampleNotifications [ class, instanceId, 0, 0, 0 ];

	if sampleObject = null then
		create sampleObject;
		sampleObject.classnumber := class;
		sampleObject.instanceId  := instanceId;
		sampleObject.type        := Note_Request;
		sampleObject.count       := 0;
		app.myListener.v_sampleNotifications.add(sampleObject);
	endif;
	sampleObject.count := sampleObject.count + 1;

end;</source>
        <Parameter name="class" type="Integer"/>
        <Parameter name="instanceId" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processPuts" id="9bec307c-ac66-4dfc-aa1f-ed17b6a15ae8">
        <updating/>
        <source>processPuts(class : Integer; instanceId : Integer; parClass : Integer; subLevel : Integer; subId : Integer;
            mode : Integer64; volatility : Integer; lockKind : Integer) updating;
constants

vars
	sampleObject : SampleObjects;
begin
	if mode = Create_Put then
		sampleObject  := app.myListener.v_sampleCreates [ class, instanceId, parClass, subLevel, subId];
	elseif mode = Update_Put then
		sampleObject  := app.myListener.v_sampleUpdates [ class, instanceId, parClass, subLevel, subId];
	elseif mode = Delete_Put then
		sampleObject  := app.myListener.v_sampleDeletes [ class, instanceId, parClass, subLevel, subId];
	endif;
	if sampleObject = null then
		create sampleObject;
		sampleObject.classnumber    := class;
		sampleObject.instanceId     := instanceId;
		sampleObject.parClassnumber := parClass;
		sampleObject.subLevel       := subLevel;
		sampleObject.subId          := subId;
		sampleObject.type           := Put_Request;
		sampleObject.count          := 0;
		sampleObject.lockKind       := lockKind;
		sampleObject.volatility     := volatility;
		if mode = Create_Put then
			app.myListener.v_sampleCreates.add(sampleObject);
		elseif mode = Update_Put then
			app.myListener.v_sampleUpdates.add(sampleObject);
		elseif mode = Delete_Put then
			app.myListener.v_sampleDeletes.add(sampleObject);
		endif;
	endif;
	sampleObject.count := sampleObject.count + 1;

end;</source>
        <Parameter name="class" type="Integer"/>
        <Parameter name="instanceId" type="Integer"/>
        <Parameter name="parClass" type="Integer"/>
        <Parameter name="subLevel" type="Integer"/>
        <Parameter name="subId" type="Integer"/>
        <Parameter name="mode" type="Integer64"/>
        <Parameter name="volatility" type="Integer"/>
        <Parameter name="lockKind" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processTransactions" id="43225c11-6b3a-4c31-ad63-0d0eeb96f09b">
        <updating/>
        <source>processTransactions(_data : String; requestType : Integer; _pos : Integer; 
                    _processorNumber : String; _mode : Integer64; _nodeNumber : Integer) updating;

vars
	token    : String;
	pos      : Integer;
	classNum : Integer;
	class    : String;
	instance : String;
	data     : String;
	time     : Time;
	methodName : MethodNames;
	sampleMessage : SampleMessages;	
begin

	pos  := _pos;
	data := _data;

	if requestType = BeginTransaction_Request then
		incrementTransactionCount := incrementTransactionCount + 1;
		transactionCount          := transactionCount + 1;
	endif;
	token         := data.getToken(pos); //
	token         := data.getToken(pos); //
	class         := data.getToken(pos); //
	instance      := data.getToken(pos); //

	methodName := v_environment.allMethodnames [class &amp; '.' &amp; instance];
	classNum := class.Integer;
	if methodName = null and (classNum &gt; 0 and classNum &lt; 1279) then
		token := class &amp; '.' &amp; instance &amp; ' ' &amp; (class &amp; '.' &amp; instance).asOid.Method.name;
	else
		if methodName &lt;&gt; null then
			token := methodName.schema &amp; '::' &amp; methodName.className &amp; '::' &amp; methodName.name;
		else
			token := class &amp; '.' &amp; instance;
		endif;
	endif;
	create sampleMessage transient;

	sampleMessage.message := token;
	//
	// beginTransaction or beginTransientTransaction
	// Appears that _mode = 2 for SharedTransients or _mode = 1 for Persistent
	//
	if requestType = BeginTransaction_Request then
		if _mode = 2 then
			sampleMessage.type  := 'STBT ';
		else
			sampleMessage.type  := 'BT ';
		endif;
	else
	//
	// commitTransaction or commitTransientTransaction
	//
		if _mode = 2 then
			sampleMessage.type  := 'STET ';
		else
			sampleMessage.type  := 'ET ';
		endif;
	endif;
	sampleMessage.time := time;
	v_sampleMessageSet.add(sampleMessage);

	return;
end;</source>
        <Parameter name="_data" type="String"/>
        <Parameter name="requestType" type="Integer"/>
        <Parameter name="_pos" type="Integer"/>
        <Parameter name="_processorNumber" type="String"/>
        <Parameter name="_mode" type="Integer64"/>
        <Parameter name="_nodeNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processUnlock" id="627a3f51-b336-4feb-83ed-4bcca0f8e868">
        <updating/>
        <source>processUnlock(class : Integer; instanceId : Integer; parClass : Integer; subLevel : Integer; subId : Integer; mode : Integer64) updating;

vars
	sampleObject : SampleObjects;
begin
	if mode = Remove_Locks then
		return;
	endif;
	sampleObject  := app.myListener.v_sampleUnlocks [ class, instanceId, parClass, subLevel, subId ];

	if sampleObject = null then
		create sampleObject;
		sampleObject.classnumber    := class;
		sampleObject.instanceId     := instanceId;
		sampleObject.parClassnumber := parClass;
		sampleObject.subLevel       := subLevel;
		sampleObject.subId          := subId;
		sampleObject.type           := Unlock_Request;
		sampleObject.count          := 0;
		app.myListener.v_sampleUnlocks.add(sampleObject);
	endif;
	sampleObject.count := sampleObject.count + 1;

end;</source>
        <Parameter name="class" type="Integer"/>
        <Parameter name="instanceId" type="Integer"/>
        <Parameter name="parClass" type="Integer"/>
        <Parameter name="subLevel" type="Integer"/>
        <Parameter name="subId" type="Integer"/>
        <Parameter name="mode" type="Integer64"/>
    </JadeMethod>
    <JadeMethod name="readAsynch" id="24b1f0ce-7557-4bae-95df-0a096eccbd88">
        <updating/>
        <source>readAsynch(tcp : TcpIpConnection; buffer : Binary) updating;
vars
	length : Integer;

begin

	message := tcp.String &amp; ' ' &amp; buffer.String;
	length := buffer [ 1 : 4 ].Integer;

	write length;


end;</source>
        <Parameter name="tcp" type="TcpIpConnection"/>
        <Parameter name="buffer" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="readUntil" id="71552ba1-919d-4449-abb3-a0758dc17ea2">
        <updating/>
        <source>readUntil() updating;
vars
	index : Integer;
begin
	data := connection.readUntil(Cr.Byte.Binary, 500);	// 11/3/16 cnwmp6 PAR 36286 unicode version
//	write data;
end;</source>
    </JadeMethod>
    <JadeMethod name="readUntilAsynch" id="da786d9b-7907-4db7-891f-bdafd194a887">
        <updating/>
        <source>readUntilAsynch() updating;

vars
	index : Integer;
begin
	foreach index in 1 to v_tcpArray.size do
		v_tcpArray[ index ].readUntilAsynch(Cr.Byte.Binary, 500, self, 'readUntilAsynchReply');	// 11/3/16 cnwmp6 PAR 36286 unicode version
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="readUntilAsynchOneAddress" id="945d2b6b-ac4b-4b42-80a2-35c76a6c46d2">
        <updating/>
        <source>readUntilAsynchOneAddress(_tcp : TcpIpConnection) updating;

vars

begin
//	write 'About to read ' &amp; _tcp.String;
//	_tcp.readUntilAsynch(Cr.Binary, 4, self, 'readUntilAsynchReply');  // bug - this sometimes causes jade.exe to loop
	_tcp.readBinaryAsynch( 4, self, 'readUntilAsynchReply');
end;</source>
        <Parameter name="_tcp" type="TcpIpConnection"/>
    </JadeMethod>
    <JadeMethod name="readUntilAsynchReply" id="5df2efb5-9cde-474f-bb3c-b13e54996686">
        <updating/>
        <source>readUntilAsynchReply(tcp : TcpIpConnection io; _data : Binary) updating;

vars
	time        : Time;
	messageText : String;
	length      : Integer;
	lengthData  : String;

begin

	if app.isUnicode() then	// 16/3/16 cnwmp6 PAR 36286 unicode version
		lengthData := _data.ansiToString;
	else
		lengthData := _data.String;
	endif;

	while lengthData.length &lt;&gt; 4  do
		data       := tcp.readBinary(4 - lengthData.length);
		lengthData := lengthData &amp; data.String;
	endwhile;
	length := lengthData.Integer;

	data := tcp.readBinary(length - messageText.length);
	if app.isUnicode() then	// 16/3/16 cnwmp6 PAR 36286 unicode version
		messageText := messageText &amp; data.unicodeToString;
	else
		messageText := messageText &amp; data.String;
	endif;

	processNodeSamplingInput(messageText);
epilog
	//
	// Ensure we put another read up
	//
	readUntilAsynchOneAddress(tcp);
end;</source>
        <Parameter name="tcp" type="TcpIpConnection" usage="io"/>
        <Parameter name="_data" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="saveToFile" id="3beb82a5-6357-485d-831a-8532d4d6c21e">
        <updating/>
        <source>saveToFile(_environment : Environments; _col : SampleObjectByCountDict; type : String;
           _limit : Integer; _file : File io) updating;
constants

vars

	sampleObject : SampleObjects;
	tableData    : String;
	total        : Integer;

begin

	_file.writeLine(type);
	_file.writeLine( 'Class' &amp; Tab &amp; 'Count' &amp; Tab &amp; 'Count' &amp; Tab &amp; 'Time');

	foreach  sampleObject in _col do
		total := total + sampleObject.count;
		//
		// Check to see if we have restricted the output 
		//
		if sampleObject.count &lt; _limit then
			break;
		endif;
		if sampleObject.type = Lock_Request then
			tableData := getClassDescription(_environment, sampleObject) &amp; Tab &amp; sampleObject.count.String &amp; Tab &amp; sampleObject.queuedCount.String &amp; Tab &amp; sampleObject.queuedTime.String;
		else
			tableData := getClassDescription(_environment, sampleObject) &amp; Tab &amp; sampleObject.count.String &amp; Tab &amp; '' &amp; Tab &amp; '';
		endif;

		_file.writeLine(tableData);

	endforeach;

	_file.writeLine (' Total ' &amp; type &amp; Tab &amp; total.String &amp; Tab &amp; ' ' &amp; Tab &amp; '');	
	_file.writeLine (' ');

epilog

end;</source>
        <Parameter name="_environment" type="Environments"/>
        <Parameter name="_col" type="SampleObjectByCountDict"/>
        <Parameter name="type" type="String"/>
        <Parameter name="_limit" type="Integer"/>
        <Parameter name="_file" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupClassname" id="bbfe34b6-4381-4d5a-94f3-e470a63755c1">
        <updating/>
        <source>setupClassname(_data : String; _root : Environments io) updating;

vars
	pos     : Integer;
	number  : Integer;
	aclass  : String;
	aschema : String;
	aClass  : ClassNames;
begin

	pos := 1;
	pos := _data.pos ('::', pos);
	if pos = 0 then
		return;
	endif;
	aschema := _data[1 : pos - 1];
	pos := pos + 2;
	aclass := _data.getNextToken (pos);
	number := _data.getNextToken (pos).Integer;
	aClass := _root.allClassnames [ number ];
	if aClass = null then
		create aClass;
		aClass.number        := number;
		aClass.schema        := aschema;
		aClass.name          := aclass;
		aClass.myEnvironment := _root;
	endif;
end;</source>
        <Parameter name="_data" type="String"/>
        <Parameter name="_root" type="Environments" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupListen" id="152840a6-6111-4026-a0f9-079cb381f830">
        <updating/>
        <source>setupListen(hostName : String; portNumber : Integer) updating;

begin

	beginTransientTransaction;

	create connection sharedTransient;
	listener := true;
	message := 'Listening for first connection';

	connection.name := hostName;
	connection.port := portNumber;
	connection.fillReadBuffer := true;

	commitTransientTransaction;

	connection.listenContinuousAsynch( self, "listenContinuousCallback");
	message := 'Listener state   - ' &amp; connection.state.String &amp; ' ' &amp; connection.localIpAddress &amp; ' ' &amp; connection.localPort.String;

end;</source>
        <Parameter name="hostName" type="String"/>
        <Parameter name="portNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupMethodname" id="e5200165-c4f9-4b0c-a5bc-5eca000c7187">
        <updating/>
        <source>setupMethodname(_data : String; _root : Environments io) updating;
//
// Format
// RootSchema::WindowException::text 23.221
//
vars

	pos        : Integer;
	sPos       : Integer;
	number     : Integer;
	aschema    : String;
	methodName : String;
	aclass     : String;
	aMethod    : MethodNames;
	oid        : String;
begin

	pos := 1;
	pos := _data.pos ('::', pos);
	if pos = 0 then
		return;
	endif;
	aschema    := _data[1 : pos - 1];
	pos        := pos + 2;
	aclass     := _data.getNextToken (pos);
	sPos       := pos;
	pos        := _data.pos ('::', sPos);
	sPos       := sPos + 1;
	methodName := _data.getNextToken (sPos);
	oid        := _data.getNextToken (sPos);

	aMethod := _root.allMethodnames [ oid ];
	if aMethod = null then
		create aMethod;
		aMethod.className     := aclass;
		aMethod.oid           := oid;
		aMethod.schema        := aschema;
		aMethod.name          := methodName;
		aMethod.myEnvironment := _root;
	endif;

end;</source>
        <Parameter name="_data" type="String"/>
        <Parameter name="_root" type="Environments" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupSampling" id="c46c892a-c844-4ef6-9ab6-0801fed27a9e">
        <updating/>
        <source>setupSampling(_hostPort : String; _nodes : ObjectArray; _remote : Boolean) updating;
constants

vars
	o : Object;
begin
	app.samplerHandle := system.beginSampleGroupDefinition;
	foreach o in _nodes do
		system.enableRemoteSampling ( app.samplerHandle, o.Node);
	endforeach;
	system.beginSample(app.samplerHandle, 'tcpsmpl', _hostPort);

	system.logUserCommand( app.samplerHandle, 'clear', process.number, 'Kevin' );
	if _remote = true then
		// Remote requests
		system.beginIndividualRequestsLogging(app.samplerHandle, false, true, false, false, false, process.number, 'Remote');
	else
		// Local requests
		system.beginIndividualRequestsLogging(app.samplerHandle, true, false, false, false, false, process.number, 'Local');
	endif;
	v_remote := _remote;
epilog

end;</source>
        <Parameter name="_hostPort" type="String"/>
        <Parameter name="_nodes" type="ObjectArray"/>
        <Parameter name="_remote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showMethodActionOccurredIn" id="da7fc55f-0227-443d-9cc1-36a230cc49f6">
        <updating/>
        <source>showMethodActionOccurredIn(_data : String; _requestType : Integer; _pos : Integer; _mode : Integer64;
                           _class : Integer; _instance : Integer; _parClass : Integer;
                           _subLevel : Integer; _subId : Integer; 
                           _waitTime : Integer64; _processor : String) updating;

vars
	time          : Time;
	token         : String;
	pos           : Integer;
	methClassNum  : Integer;
	methodClass   : String;
	methodInstance: String;
	receiverClass : Integer;
	receiverInstance: String;
	data          : String;
	request       : String;
	type          : String;
	className     : String;
	methodName    : MethodNames;
	receiverName  : ClassNames;
	sampleMessage : SampleMessages;
	
begin

	pos  := _pos;
	data := _data;

	token            := data.getToken(pos); //
	token            := data.getToken(pos); //
	methodClass      := data.getToken(pos); //
	methodInstance   := data.getToken(pos); //
	methodName       := v_environment.allMethodnames [methodClass &amp; '.' &amp; methodInstance];
	methClassNum     := methodClass.Integer;
	if methodName = null and methClassNum &lt; 1279 then
		methClassNum := methClassNum + 1279;
		methodName   := v_environment.allMethodnames [methClassNum.String &amp; '.' &amp; methodInstance];
	endif;
	//
	// Get receiver class info
	//
	token            := data.getToken(pos); //
	token            := data.getToken(pos); //
	token            := data.getToken(pos); //
	token            := data.getToken(pos); //
	receiverClass    := data.getToken(pos).Integer; //
	receiverInstance := data.getToken(pos); //
	if receiverClass &gt; 16384 then
		receiverClass := receiverClass - 16384;
	endif;
	receiverName     := v_environment.allClassnames [receiverClass];

	v_sample.classnumber    := _class;
	v_sample.instanceId     := _instance;
	v_sample.parClassnumber := _parClass;
	v_sample.subLevel       := _subLevel;
	v_sample.subId          := _subId;
	className := getClassDescription(v_environment, v_sample);

	if _requestType = Get_Request then
		type := 'Get';
	elseif _requestType = GetEdition_Request then
		type := 'Get Edn';
	elseif _requestType = GetOid_Request then
		type := 'Get Oid';
	elseif _requestType = Lock_Request then
		type := 'Lock';
	elseif _requestType = Unlock_Request then
		type := 'Unlock';
	elseif _requestType = Put_Request then
		type := 'Put';
	elseif _requestType = Note_Request then
		type := 'Note';
	elseif _requestType = CauseEvent_Request then
		type := 'Cause';
	elseif _requestType = ReturnNotes_Request then
		type := 'Return';
	elseif _requestType = RemoteMethod_Request then
		type := 'Remote';
	elseif _requestType = BeginNotification_Request then
		type := 'B Note';
	elseif _requestType = EndNotification_Request then
		type := 'E Note';
	endif;

	request := '  ' &amp; className &amp; '  ';

	create sampleMessage transient;
	sampleMessage.type := type;

	if methodName &lt;&gt; null then
		if _requestType &lt;&gt; Put_Request then
			request := request &amp; ' ' &amp; methodName.className &amp; '::' &amp; methodName.name;
		endif;
	else
		request := request &amp; ' ' &amp; methodClass &amp; '.' &amp; methodInstance;
	endif;
	if _waitTime &lt;&gt; 0 then
		request := request &amp; ', waited ' &amp; _waitTime.String;
	endif;
	if _requestType = Note_Request or _requestType = CauseEvent_Request then
		request := request &amp; ' Event ' &amp; _mode.String;
	endif;

	if receiverName &lt;&gt; null then
		request := request &amp; ' ' &amp; receiverName.name;
	endif;

	sampleMessage.message := request[ 1 : 120 ];
	sampleMessage.time    := time;
	v_sampleMessageSet.add(sampleMessage);

end;</source>
        <Parameter name="_data" type="String"/>
        <Parameter name="_requestType" type="Integer"/>
        <Parameter name="_pos" type="Integer"/>
        <Parameter name="_mode" type="Integer64"/>
        <Parameter name="_class" type="Integer"/>
        <Parameter name="_instance" type="Integer"/>
        <Parameter name="_parClass" type="Integer"/>
        <Parameter name="_subLevel" type="Integer"/>
        <Parameter name="_subId" type="Integer"/>
        <Parameter name="_waitTime" type="Integer64"/>
        <Parameter name="_processor" type="String"/>
    </JadeMethod>
    <JadeMethod name="shutdownListen" id="edded404-5fd2-4957-9bfc-4380f66ef2bd">
        <updating/>
        <source>shutdownListen() updating;

vars
	con : TcpIpConnection;
begin
	beginTransientTransaction;

	foreach con in v_tcpArray do

		con.close;
		delete con;

	endforeach;
	v_tcpArray.clear;

	connection.close;
	listener := false;
	message := 'Closing listener';

	delete connection;
	commitTransientTransaction;

end;</source>
    </JadeMethod>
    <JadeMethod name="state" id="856ef2b5-9c93-438f-9cb8-a3aa3c83d4d1">
        <condition/>
        <source>state():Boolean condition;


begin
	if status = 1 then
		return true ;
	else
		return false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="stopSampling" id="b8b5645f-a955-40bf-b3af-9288fd2549e8">
        <updating/>
        <source>stopSampling(_nodes : ObjectArray) updating;
constants

vars
	o : Object;
begin
	system.endIndividualRequestsLogging(app.samplerHandle, process.number, 'Individual');
	foreach o in _nodes do
		system.disableRemoteSampling ( app.samplerHandle, o.Node);
	endforeach;
	system.endSample ( app.samplerHandle );
	system.endSampleGroupDefinition( app.samplerHandle );

epilog

end;</source>
        <Parameter name="_nodes" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="takeCacheSnapshot" id="be253d7f-51b1-463a-a531-277eba4b56f2">
        <updating/>
        <source>takeCacheSnapshot(_hostPort : String; _nodes : ObjectArray; _transientCache : Boolean) updating;
constants

vars
	o : Object;
	persistentCacheStats   : Boolean;
	persistentCacheBuffers : Boolean;
	transientCacheStats    : Boolean;
	transientCacheBuffers  : Boolean;
	remoteTransientCacheStats   : Boolean;
	remoteTransientCacheBuffers : Boolean;

begin

	v_snapshotMessageSet.purge;
	app.samplerHandle := system.beginSampleGroupDefinition;
	foreach o in _nodes do
		system.enableRemoteSampling ( app.samplerHandle, o.Node);
	endforeach;
	system.beginSample(app.samplerHandle, 'tcpsmpl', _hostPort);

	system.logUserCommand( app.samplerHandle, 'clear', process.number, 'Kevin' );
	if _transientCache = true then
		persistentCacheStats        := false;
		persistentCacheBuffers      := false;
		transientCacheStats         := true;
		transientCacheBuffers       := true;
	else
		persistentCacheStats        := true;
		persistentCacheBuffers      := true;
		transientCacheStats         := false;
		transientCacheBuffers       := false;
	endif;
	remoteTransientCacheStats   := false;
	remoteTransientCacheBuffers := false;

	system.logObjectCaches(app.samplerHandle, persistentCacheStats,      persistentCacheBuffers,
	                                          transientCacheStats,       transientCacheBuffers,
	                                          remoteTransientCacheStats, remoteTransientCacheBuffers, process.number, 'Cache');
	stopSampling(_nodes);
	messageCount := 0;

epilog

end;</source>
        <Parameter name="_hostPort" type="String"/>
        <Parameter name="_nodes" type="ObjectArray"/>
        <Parameter name="_transientCache" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeAsynch" id="9a720410-46f3-439c-b77b-b5bda77ea0da">
        <updating/>
        <source>writeAsynch() updating;

vars

	index : Integer;
begin
	foreach index in 1 to v_tcpArray.size do
		v_tcpArray[ index ].writeBinaryAsynch(app.clock.String.asANSI(0) &amp; ' '.Byte.Binary &amp; v_tcpArray[ index ].String.asANSI(0) &amp; Cr.Byte.Binary, self, 'writeAsynchCompleted');	// 11/3/16 cnwmp6 PAR 36286 unicode version
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="writeAsynchCompleted" id="a947b4bb-2232-42ba-81e8-a8aea6c4a467">
        <updating/>
        <source>writeAsynchCompleted(tcp : TcpIpConnection) updating;

vars
	time : Time;
begin
	write time.String &amp; ' ' &amp; method.name;
end;</source>
        <Parameter name="tcp" type="TcpIpConnection"/>
    </JadeMethod>
</Class>
