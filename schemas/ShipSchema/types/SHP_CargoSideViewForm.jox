    <JadeMethod name="userNotify" id="9eb2c285-919d-4dd0-942d-2e8322c97d56">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Date		    Who			Reason
26 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	lController : CM_ROROSlotController;
	event : Integer;
	gotException	: Boolean;

	deckItemLayoutArray : CM_RORODeckItemLayoutArray;
	deckItem : CM_DeckItem;
	locnDefn, otherDefn : CM_ROROLocnDefn;
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);

	if event = EVENT_UPDATE_VOYAGE_AREA then
		self.noteVoyage(eventType, theObject, eventTag, userInfo);
		/*
		on Exception do app.handleDeletedObject(exception, lController, gotException);		

		if not userInfo.isKindOf(CM_ROROSlotController) then 
			return;
		endif;
		lController := userInfo.CM_ROROSlotController;
		if lController &lt;&gt; null then	
			// PAR 28986 if the note is not for a locn that we are viewing then ignore
			if not self.allOrderedROROLocns.includes(lController.mySlotDefn.myROROLocnDen) then
				return;
			endif;
			
			self.myROROLocnDrawingController.drawSlotFromNote(lController);
			self.doRedrawWeightsAndHeights(lController); 	//cnwas3 par 28401		
			if gotException then
				// Exception handler resumes here if lController was invalid.
				return;
			endif;
			// 28747 Dec 2011 clear status selected message as items have been un-selected in notification processing
			self.setStatusCaption(null,false);
		endif;
		*/
	elseif event = EVENT_RORORotationUpdate then // PAR 28990
		self.noteRotation(eventType, theObject, eventTag, userInfo);
	else
		self.noteUser(eventType, theObject, eventTag, userInfo);
	endif;
epilog
	delete deckItemLayoutArray;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
