    <JadeMethod name="is4550" id="413c3e0e-b7d4-41c1-8b88-2a7e77da9221">
        <source>is4550(): Boolean;
/*

Purpose:			If any slot in a Bay is marked for 45/48/53ft then return true.
					A 'bay' can only have one 'length' associated to it at one time - so just checking the first one works.
					(This does mean that there are multiple entries for the same bay in a JSON file!)

Parameters:			

Return Value:		

Date				Who		Reason
10 February 2021	navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars
	stack		: CMIF_MACS3ContStackPxyObj;
	stackLen	: CMIF_MACS3ContStackLenPxyObj;
	
	is4550		: Boolean;
begin
	// Doing it this way just saves extra null checks ;)
	foreach stack in self.containerStacks do :loop
		foreach stackLen in stack.containerStackLengths do
			is4550 := stackLen.is45 or stackLen.is53;
			break loop;
		endforeach;
	endforeach;
	
	return is4550;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAboveDeck" id="9e706a62-daca-4aa0-800a-93794df96780">
