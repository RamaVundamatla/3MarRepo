    <JadeMethod name="validateForDelete" id="4edc34a7-c544-4790-b38c-0395dc2ff7cc">
        <source>validateForDelete();
//--------------------------------------------------------------
//Created: 01 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.isQueuedToMove then
		app.raiseCMException2(ObjectStillHasEntries, bolTypeDesc &amp; ' ' &amp; self.number.String, 'Queue', null, null);		
	endif;
	
	if self.myExtension &lt;&gt; null then
		self.myExtension.validateForDelete();
	elseif self.bolType = BOLType_GeneralDocket then
		
		if self.hasCargoForSite(TI_SITE_ONSITE) then
			app.raiseCMException2(ERR_CANNOT_DELETE, bolTypeDesc &amp; ' ' &amp; self.number.String, 'It has cargo on site.', null, null);				
		elseif self.hasPlannedCargo() then
			app.raiseCMException2(ERR_CANNOT_DELETE, bolTypeDesc &amp; ' ' &amp; self.number.String, 'It has cargo planned to move, unplan cargo and try again.', null, null);						
		elseif self.allTrackedItems.size &gt; 0 then
			app.raiseCMWarning2(HMSConfirmDelete, bolTypeDesc &amp; ' ' &amp; self.number.String, 'Cargo', null, null, self);
		else
			app.raiseCMWarning2(CONF_DELETE, bolTypeDesc &amp; ' ', self.number.String, null, null, self);
		endif;
		
	elseif self.bolType = BOLType_GeneralBillOfLading then
	
		if self.hasCargoForSite(TI_SITE_ONSITE) then
			app.raiseCMException2(ERR_CANNOT_DELETE, bolTypeDesc &amp; ' ' &amp; self.number.String, 'It has cargo on site.', null, null);				
		elseif self.hasPlannedCargo() then
			app.raiseCMException2(ERR_CANNOT_DELETE, bolTypeDesc &amp; ' ' &amp; self.number.String, 'It has cargo planned to move, unplan cargo and try again.', null, null);						
		elseif self.allTrackedItems.size &gt; 0 then
			app.raiseCMWarning2(HMSConfirmDelete, bolTypeDesc &amp; ' ' &amp; self.number.String, 'Cargo', null, null, self);
		else
			app.raiseCMWarning2(CONF_DELETE, bolTypeDesc &amp; ' ' , self.number.String, null, null, self);
		endif;
	else
		inheritMethod();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDocketCorrection" id="9f707cc4-8aa6-4b0b-920f-383c1a78da90">
        <updating/>
        <source>validateForDocketCorrection( _control: CMIF_TIUpdateController input ) updating, protected;
//--------------------------------------------------------------
// Created:	26 March 2008 By: cnwvu1
//--------------------------------------------------------------

vars
	ti : CM_TrackedItem;
	isDocketCorrection : Boolean;
	
begin

	if app.myPassport.warningsAcknowledged then	// user has agreed with warnings before. Validation has already done before.
		return;
	endif;
	
	if self.isMatchedTodayForDocketCorrect() then	// we are interested in Docket Correction case
		foreach ti in self.allTrackedItems do
			ti.CM_Log.setDocketCorrection( self, true, _control, isDocketCorrection ); 
			/*if isDocketCorrection then	PAR 21514 we cannot break now, because there is validation for each log introduced - Inspected / Fumigated
				break;
			endif;*/
		endforeach;
	endif;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_TIUpdateController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="bebffdcd-e7f5-4d30-b9f6-eaebcdbc1bee">
        <updating/>
        <source>validateForUpdate(pControl: CMIF_TIUpdateController input; _headerOnly: Boolean; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	myLoggingOrg    : String;
	realBOL	: CM_BOLIn;
begin
	inheritMethod(pControl, _headerOnly, _passport);

	if self.bolType = BOLType_Log then
		//if self.loggingOrganisation &lt;&gt; null then
		myLoggingOrg := self.getLoggingOrganisation();
		if myLoggingOrg &lt;&gt; null then
			realBOL := self.pxyGetRealObject();
			if realBOL &lt;&gt; null and
			   //realBOL.loggingOrganisation &lt;&gt; self.loggingOrganisation then //#cnwdz2	 CCMS 1108 par22177 
			   realBOL.getLoggingOrganisation() &lt;&gt; myLoggingOrg then
				// the loggingOrg field has changed so need to check if valid
				self.validateLoggingOrgUpdate();
			endif;
		endif;
	endif;
	if self.allDocketErrors &lt;&gt; null and not self.allDocketErrors.isEmpty() then
		self.allDocketErrors.first().validateForUpdate();
	endif;
	self.validateForDocketCorrection( pControl );	//ccms1089. cnwvu1. 26/03/2008
	
end;</source>
        <Parameter name="pControl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_headerOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateLoggingOrgCreate" id="84495142-3f6c-43e0-aa04-98f310d3b4ab">
        <source>validateLoggingOrgCreate() protected;
// ---------------------------------------------------------------------------
// Created:     16 May 2005 by cnwrs2
// Updated:     22 Jan 2010 #cnwdz2	 CCMS 1108 par22177 
// Purpose:     
// ---------------------------------------------------------------------------
vars
	myLoggingOrg    : String;
	tmpLoggingOrg	: CM_LoggingOrganisation;
begin
	myLoggingOrg := self.getLoggingOrganisation();
	//if self.loggingOrganisation = null then
	if myLoggingOrg = null then
		return;
	endif;
	//if app.myRoot.allLoggingOrganisations.includesKey(self.loggingOrganisation) then
	if app.myRoot.allLoggingOrganisations.includesKey(myLoggingOrg) then
		return;
	endif;
	//app.raiseCMException2(ERR_KEY_NOT_FOUND, self.loggingOrganisation, 'Logging Organisation', CM_BOLIn::loggingOrganisation.name, null);
	app.raiseCMException2(ERR_KEY_NOT_FOUND, myLoggingOrg, 'Logging Organisation', CM_BOLIn::loggingOrganisation.name, null);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateLoggingOrgUpdate" id="3cad91b0-b073-4daf-96b5-9aa31125e95a">
        <source>validateLoggingOrgUpdate() protected;
// ---------------------------------------------------------------------------
// Created:     16 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	myLoggingOrg    : String;
	tmpLoggingOrg	: CM_LoggingOrganisation;
begin
	//22/01/2010 #cnwdz2	 CCMS 1108 par22177 
	//tmpLoggingOrg := app.myRoot.allLoggingOrganisations[self.loggingOrganisation];
	myLoggingOrg := self.getLoggingOrganisation();
	tmpLoggingOrg := app.myRoot.allLoggingOrganisations[myLoggingOrg];
	if tmpLoggingOrg &lt;&gt; null and
	   tmpLoggingOrg.notAvailableForEntry then
		app.raiseCMException1(NotAvailableForEntry, 'Logging Org (' &amp; myLoggingOrg &amp; ')', CM_BOLIn::loggingOrganisation.name, null);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateMe" id="9992883d-6779-4be0-b351-b738ca83f9c8">
        <source>validateMe(pControl: CMIF_TIUpdateController input; _headerOnly: Boolean; _passport: CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     16 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	str 		: String;
	operator	: CM_Operator;
	
begin
	inheritMethod(pControl, _headerOnly, _passport);

	operator := self.myOperator;
	
	if self.bolType = BOLType_Log then
		if operator &lt;&gt; null
		and operator.requiresConsigneeConsignor		// 22/04/2010 cnwar2 #23915
		and self.consignor = null then
			str := app.getTerminologyAlternate(app.myRoot.allBOLTypes[self.bolType], self.myTerminal, CM_TerminologyConsignor, CM_TermExpressionSingular, 'Consignor'); 
		//	app.raiseCMException1(REQUIRED_FIELD, str , ETRow_ConsignorTop, pControl.myUserObject);
			app.raiseCMException1(Input_required_field_Required, str , ETRow_ConsignorTop, pControl.myUserObject); // cnwdb2	PAR 35364
		endif;
	endif;
	
	// cnwdad1 15/04/2009 - CCMS 1735.
	if app.isSubTerminalsOn(self.myTerminal) then
		if self.mySubTerminal = null
		and not self.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean	//28 Nov 2014	NDL	Par 35295
		then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getString(SubTerminal_GC), ETRow_MySubTerminal, pControl.myUserObject);
			app.raiseCMException1(Input_required_field_Required, app.getString(SubTerminal_GC), ETRow_MySubTerminal, pControl.myUserObject); // cnwdb2	PAR 35364


		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_headerOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateNumTIs" id="4fbb4cd0-ddbb-4e96-93f4-b3f5a9e85fa4">
        <source>validateNumTIs(_headerOnly: Boolean);
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars
begin
	inheritMethod(_headerOnly);

	if (not _headerOnly) then
		if self.numItems &lt; 1 then
			//app.raiseCMException1(REQUIRED_FIELD, 'Number of Items (Quantity)', ETRow_NumItems, self);			//-cnwml2 PAR22551
			return;																									//+cnwml2 PAR22551
		else
			if self.numItems &gt; 999 then //PAR#8452
				app.raiseCMWarning1(WARN_BOLNumTIs, self.numItems.String, ETRow_NumItems, null, self);
			endif;
			
			if self.bolType = BOLType_Log then
				if (not self.isMatched) then
					// It's ok to change num tis if bol is not matched
				else
					if not self.isMatchedTodayForDocketCorrect() then	//ccms1089. cnwvu1. 26 March, 2008
						// If numItems is set then check that numTIs agrees.
						if self.numTIs &lt;&gt; self.numItems then		// was checking tmpNum &gt; 0 ...  but 0 will never match - removed  PAR# 9588											
							app.raiseCMException2(LogDocketMatched, 'Piece Count', self.number, ETRow_NumItems, self);
						endif;
					endif;
				endif;
			else
				if self.numTIs &lt;&gt; self.numItems
				   and self.getTotalTIQty() &lt;&gt; self.numItems then
					//th2 PAR #13659 - if updating BOL and adding more TIs to it, the proxy TI have not yet
					//been created from the CMIF_Attachments and associated with self, so the numItems will be erroneous at this point
					
					//app.raiseCMException3(BOLInvalidQuantity, self.numTIs.String, self.number,
					//						self.numItems.String, ETRow_NumItems, self);
				endif;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_headerOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validatePlannedLocation" id="361e63f1-bac5-4276-9a3c-cebfbb2d5af9">
        <source>validatePlannedLocation(pControl: CMIF_TIUpdateController);
//--------------------------------------------------------------
//Created: 03 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	//locations for warehouse general dockets are stored on each individual TI, so 
	//none needed on the BOL itself
	if self.bolType &lt;&gt; BOLType_GeneralDocket and self.bolType &lt;&gt; BOLType_GeneralBillOfLading then
		if self.myPlannedLocation = null and self.origTerminalAreaId = null then
	//		app.raiseCMException1(REQUIRED_FIELD, 'Location', ETRow_Location, pControl.myUserObject);
			app.raiseCMException(Input_required_field_location, ETRow_Location, pControl.myUserObject);	// cnwdb2	PAR 35364		
			return;
		endif;
	endif;
	
end;</source>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
</Class>
