<Class name="CM_EDIFileTypeXMLFonterraPack" id="32fa3b7b-5cbf-46b6-bff9-31af77e06b52">
    <superclass name="CM_EDIFileTypeXML"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="3a46e627-4e2e-42cb-bc01-1e48d629a688">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	10 December 2010 cmwrs1 ccms 1976
//----------------------------------------------------------------
vars

begin
	self.name	:= "Fonterra Pack";
	self.type	:= EDIFileType_XML_Fonterra_Pack;
end;</source>
    </JadeMethod>
    <JadeMethod name="createEDIData" id="f39042c0-b68d-49d5-9d93-fa099e356989">
        <source>createEDIData(_transient: Boolean): CM_EDIData;
//----------------------------------------------------------------
//	Created:	10 dec 2010 cnwrs1 ccms 1976
//----------------------------------------------------------------
vars
	ediData	: CM_EDIDataPack;
begin
	if _transient then
		create ediData transient;
	else
		create ediData persistent;
	endif;
	return ediData;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="c0da052e-4898-4c5d-bb83-4baf00bd04e9">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io);
//----------------------------------------------------------------
//	Created:	10 dec 2010 cnwrs1 ccms 1976
//----------------------------------------------------------------
vars

begin
	_ediDataClass 	:= CM_EDIDataPack;
	_dataType 		:= EDIFileType_XML_Fonterra_Pack;
	_fileTypeCode 	:= self.type;
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getEDIBundle" id="3dd667c3-265e-49e8-bbb2-ac4271dae223">
