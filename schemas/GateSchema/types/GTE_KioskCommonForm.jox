<GUIClass name="GTE_KioskCommonForm" id="358275ae-9818-4988-a97d-f714abf5017d">
    <superclass name="CMUI_KioskForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This form has the following common controls:

1. The "Restart" button - tab stop 1

2. The numeric key pad - tab stop starts at 5,000

3. The "Done" button at the very bottom - tab stop 10,000

Subclassed forms can add their own controls, using the tab stop ordering either before
the numeric key pad range, or between the key pad range and the Done button range, to
ensure that the tab order is sensible.</text>
    <Constant name="KEY_BACKSP" id="1f57eee1-0357-4306-967b-1dd88198bfb3">
        <source>"Backspace"</source>
        <type name="String"/>
    </Constant>
