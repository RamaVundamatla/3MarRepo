    <JadeMethod name="displayEmailAddress" id="bca46720-189d-4a44-8701-5fbaad1f439b">
        <source>displayEmailAddress(_theObject : Object) : String protected;
/*
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2015	cnwndl1	Initial creation	Par 36588

*/

vars

begin
	if _theObject = null or not _theObject.isKindOf(CM_EmailAddress2) then
		return null;
	else
		return _theObject.CM_EmailAddress2.getDisplayDetails(false);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
