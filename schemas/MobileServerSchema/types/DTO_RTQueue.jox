<Class name="DTO_RTQueue" id="34b3d025-fc90-4624-b4fd-9e04d22e6cba">
    <superclass name="DTO_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="mobileServer"/>
    <PrimAttribute name="numberOfEntries" id="3f883efa-52c8-4ef9-8f28-b260a88056ae">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="numberOfMachines" id="2c19af67-6e2a-415b-ae82-e3fc0c9070f9">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="queueId" id="3ba8d9d8-8e70-43d1-bffa-965cd7685033">
        <length>51</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setFromPersistent" id="3ca15fb8-8018-445f-91a5-36fe840377a0">
        <updating/>
        <source>setFromPersistent(_queue : CM_RadioTelemetryQueue) updating;

/*

Purpose:			Populate attributes from the persistent Queue


Return Value:		None


Date		Who		Reason
28 Feb 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars

begin
	inheritMethod(_queue);
	
	self.queueId 			:= _queue.id;
	self.numberOfEntries 	:= _queue.allEntries.size;
	self.numberOfMachines 	:= _queue.allMachines.size;
	

epilog

end;</source>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
</Class>
