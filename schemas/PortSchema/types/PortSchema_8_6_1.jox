    <JadeMethod name="setNewPmWebservices" id="d979cc67-f54a-4955-a005-d17a822edcad">
        <source>setNewPmWebservices(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2017	jlger1	Initial creation tfs 5535

*/

vars
	terminalRole : CM_SecurityRole;
	termRole	: CM_SecurityRoleTerminalRoot;
		childRole,
	pxySecurityRole : CM_SecurityRole;
	permissionAgent	: CM_PermissionAgent;
begin
	if not CM_Root.firstInstance.licenseName.startsWith("CICE Group") then
		return;
	endif;
	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Updating Permissions for new Create and Cancel Vehicle Visit permissions", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Updating Permissions for new Create and Cancel Vehicle Visit permissions") ;	
	endif;
	
	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	foreach terminalRole in termRole.allChildRoles do	
		if terminalRole.name = "Admin Terminal" then
			create permissionAgent transient;
			beginLoad;
				pxySecurityRole := terminalRole.pxyCreateUpdateProxy();
			endLoad;
			pxySecurityRole.permissions[PmWebCancelVVR]:=true;
			pxySecurityRole.permissions[PmWebCreateVVR]:=true;
			app.myTrxUA.trxUpdateSecurityRole(pxySecurityRole, permissionAgent, app.myPassport);
			delete pxySecurityRole;
			
			return;
		endif;
	endforeach;
	
	
	app.writeLog(method.qualifiedName &amp; " Updating Permissions for new Create and Cancel Vehicle Visit permissions complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Updating Permissions for new Create and Cancel Vehicle Visit permissions complete") ;	
	endif;
	self.addScriptRun(method.name);
epilog
	delete pxySecurityRole;
	delete permissionAgent;
end;</source>
