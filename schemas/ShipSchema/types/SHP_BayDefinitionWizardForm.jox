    <JadeMethod name="validateBayLabelsWizard" id="ad563011-f166-4da6-b036-c5430b3b9a71">
        <source>validateBayLabelsWizard(_bayList : String; _len1ok : Boolean) : Boolean ;
// ---------------------------------------------------------------------------
// Created:     June 2008 ANDREW BISHOP
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// // PAR 17912
// ---------------------------------------------------------------------------

vars

	aLabel : String;
	theLabels, tmpLabels : StringArray;
begin

	aLabel := _bayList.String;
	aLabel.replaceChar(CM_CellularVesselStructure.HoldSeperator," ");
	create tmpLabels transient;
	theLabels:=aLabel.getTokens();


	foreach aLabel in theLabels do
		if aLabel.trimBlanks = null then
			continue;
		endif;
		
		if aLabel.trimBlanks.length &gt; 2 then
			return false;
		endif;
		if not aLabel.trimBlanks.isInteger then
			return false;
		endif;
		if not _len1ok and aLabel.trimBlanks.length = 1 then
			return false;
		endif;
		if tmpLabels.includes(aLabel.trimBlanks) then
			app.msgBox("Duplicate Bay IDs Are Not Allowed!" &amp; Cr  &amp; "Bay ID " &amp; aLabel &amp; " Is Duplicated." &amp; Cr &amp; 
							"Please re-edit the bay IDs.",
							"Bay ID Duplication",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			self.txtBayOrder.setFocus(); // PAR 18147
			return true; // PAR 18147
		else
			tmpLabels.add(aLabel.trimBlanks);
		endif;
	endforeach;

	return true;
epilog
	delete theLabels;
	delete tmpLabels;
end;</source>
        <Parameter name="_bayList" type="String"/>
        <Parameter name="_len1ok" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCellTierLabels" id="d20b4f9b-8095-4c52-b8c7-15518edf185b">
        <source>validateCellTierLabels(_newLabels : String; _messageLabel : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aLabel, oldLabels : String;
	theLabels,theoldLabels, tmpLabels, 	theHiCubes : StringArray;
	idx,theReturn : Integer;
	 bayID : String;
	newLabelSize, oldLabelSize : Integer;
begin
	
	bayID := "";

	aLabel := _newLabels;
	aLabel.replaceString(CM_CellularVesselStructure.BaySeperator,"|");
	theLabels := aLabel.getTokens;
	idx := 0;
	
	newLabelSize := theLabels.size;
	

	// ### CHECK FOR DUPLICATES
	create tmpLabels transient;
	foreach aLabel in theLabels do
		if aLabel.trimBlanks = null then
			continue;
		endif;
		
		// PAR 16323 &amp; 17208
		if aLabel.length()  &gt; 2 then
			app.msgBox(_messageLabel &amp; " ID '" &amp; aLabel &amp; "' is too long, shorten to 2 characters.", _messageLabel &amp; " ID Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
		idx := idx + 1;

		if tmpLabels.includes(aLabel.trimBlanks) then
			app.msgBox("Duplicate " &amp; _messageLabel &amp; " IDs Are Not Allowed!" &amp; Cr  &amp; _messageLabel &amp; "ID " &amp; aLabel &amp; " Is Duplicated." &amp; Cr &amp; 
							"Please re-edit " &amp; _messageLabel &amp; " IDs For Bay " &amp; bayID,
							_messageLabel &amp; " ID Duplication",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
		else
			tmpLabels.add(aLabel.trimBlanks);
		endif;
	endforeach;


	// ## CONFIRM CHANGES
	if oldLabelSize &gt; newLabelSize
	or (_newLabels &lt;&gt; oldLabels and oldLabels &lt;&gt; null)  then
		theReturn := app.msgBox("Are You Sure That You Want To Change " &amp; _messageLabel &amp; "s From Bay " &amp; bayID &amp; "?",_messageLabel &amp; " Delete",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		return (theReturn = MsgBox_Return_Yes);
	endif;
	
	return true;
epilog
	delete theLabels;
	delete tmpLabels;
	delete theoldLabels;
	delete theHiCubes;
end;</source>
        <Parameter name="_newLabels" type="String"/>
        <Parameter name="_messageLabel" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTierLabels" id="64d9eb20-3f8e-4946-bae7-48aa93e876df">
        <source>validateTierLabels(_newLabels : String; _ondeck : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:     July 2008 ANDREW BISHOP
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 29JUL2008		CNWAB1			PAR 17603
// ---------------------------------------------------------------------------

vars

	aLabel : String;
	theLabels,theoldLabels, tmpLabels, 	theHiCubes : StringArray;
	bayID : String;
	newLabelSize : Integer;
begin
	bayID := "";
	aLabel := _newLabels;
	aLabel.replaceString(CM_CellularVesselStructure.BaySeperator,"|");
	theLabels := aLabel.getTokens;
	newLabelSize := theLabels.size;
	
	// ### CHECK FOR DUPLICATES
	create tmpLabels transient;
	foreach aLabel in theLabels do
		if aLabel.trimBlanks = null then
			continue;
		endif;
		if _ondeck then
			if aLabel.isInteger() then
				if aLabel.Integer &lt; 50 then
					app.msgBox("WARNING. On deck tier labels for bay " &amp; bayID &amp;  " may be wrong." &amp; Cr 
							&amp; "They should be '84 86 88 90 92' etc. not '" &amp; _newLabels &amp; "'." &amp; Cr &amp; Cr
							&amp; "Have you mixed up your on deck and under deck tier Labels?", "On-deck Tier ID Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
					return false;
				endif;
			endif;
		else
			if aLabel.isInteger() then
				if aLabel.Integer &gt; 50 then
					app.msgBox("WARNING. Under deck tier labels for bay " &amp; bayID &amp;  " may be wrong." &amp; Cr 
							&amp; "They should be '06 08 10 12 14' etc. not '" &amp; _newLabels &amp; "'." &amp; Cr &amp; Cr
							&amp; "Have you mixed up your on deck and under deck tier Labels?", "Under-deck Tier ID Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
					return false;
				endif;
			endif;
		endif;
	endforeach;

	
	return true;
epilog
	delete theLabels;
	delete tmpLabels;
	delete theoldLabels;
	delete theHiCubes;
end;</source>
        <Parameter name="_newLabels" type="String"/>
        <Parameter name="_ondeck" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateWizardData" id="5097d5f0-191d-4b00-9b6a-c50dda562d92">
        <source>validateWizardData() : TextBox;
// ---------------------------------------------------------------------------
// Created:     June 2008 ANDREW BISHOP
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// // PAR 17912
// ---------------------------------------------------------------------------

vars

begin

	if self.txtBayOrder.text.pos(MultiBaySeperator,1) &gt; 0 then
		self.doBayOrderLostFocus();
	endif;
	if self.txtOnDeckCells.text.pos(MultiBaySeperator,1) &gt; 0 then
		self.doCellOrderLostFocus(self.txtOnDeckCells);
	endif;
	if self.txtOnDeckTiers.text.pos(MultiBaySeperator,1) &gt; 0 then
		self.doTierOrderLostFocus(self.txtOnDeckTiers);
	endif;
	if self.txtUnderDeckCell.text.pos(MultiBaySeperator,1) &gt; 0 then
		self.doCellOrderLostFocus(self.txtUnderDeckCell);
	endif;
	if self.txtUnderDeckTier.text.pos(MultiBaySeperator,1) &gt; 0 then
		self.doTierOrderLostFocus(self.txtUnderDeckTier);
	endif;

	// validate the values
	if not self.validateCellTierLabels(self.txtOnDeckCells.text, "On Deck Cell") then
		return self.txtOnDeckCells;
	endif;
	if not self.validateCellTierLabels(self.txtOnDeckTiers.text, "On Deck Tier") then
		return self.txtOnDeckTiers;
	endif;
	if not self.validateCellTierLabels(self.txtUnderDeckCell.text, "Under Deck Cell") then
		return self.txtUnderDeckCell;
	endif;
	if not self.validateCellTierLabels(self.txtUnderDeckTier.text, "Under Deck Tier") then
		return self.txtUnderDeckTier;
	endif;
	
	// PAR 18147
	if not self.validateTierLabels(self.txtUnderDeckTier.text, false) then
		return self.txtUnderDeckTier;
	endif;
	if not self.validateTierLabels(self.txtOnDeckTiers.text, true) then
		return self.txtOnDeckTiers;
	endif;
	
	if not self.validateBayLabelsWizard(self.txtBayOrder.text,false) then
		app.msgBox("Physical Bay Order can only have zero filled numbered" &amp; Cr &amp; "bay IDs with space and comma separators." &amp;  // PAR 18147
						Cr &amp; "Bay IDs must be 2 characters in length.", "Physical Bay Order Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.txtBayOrder.setFocus();
		return self.txtBayOrder;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="TextBox"/>
    </JadeMethod>
</GUIClass>
