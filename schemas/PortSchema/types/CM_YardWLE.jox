    <JadeMethod name="checkForStatusAlerts" id="ddf1a5f9-a173-4835-89ba-ea7891cc33c6">
        <updating/>
        <source>checkForStatusAlerts()updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 February 2011	cnwer1	Initial creation

*/

vars
	createAlert : Boolean;
	alert		: CM_SystemAlert;
	request     : CM_Request;
	ti			: CM_TrackedItem;
	cargoType	: CM_CargoType;
begin
	
	createAlert := self.job.jobType &lt;&gt; BOLType_Log ; 
	
	request := self.myRequest;
	ti		:= self.myTrackedItem;
	
	if request.isKindOf(CM_TIRequest) then
		// make sure tracked item matches request before resetting status.
		
		if ti &lt;&gt; null then
			cargoType := ti.myCargoType;
			
			if not (cargoType.isBreakBulkMulti or cargoType.isBulkMulti) and //cnwrd1 ccms 2274 -  if we have split we arnt the same ti as on the request
				request.CM_TIRequest.trackedItem &lt;&gt; null then
				if ti &lt;&gt; request.CM_TIRequest.trackedItem then
					if  createAlert then
						create alert transient;
						alert.details := "WLE " &amp; self.job.jobId &amp; " : " &amp;
										 ti.id  &amp; " reset to "   &amp;
										 request.CM_TIRequest.trackedItem.id &amp; " by rebuildStatus";
						alert.setSeverity(SEVERE_INFO);
						alert.add;
					endif;
					self.setMyTrackedItem(request.CM_TIRequest.trackedItem);
				endif;
			endif;
		endif;
	endif;
	
	if createAlert and (ti = null or ti.isTBAorIsRRP ) then
		if not request.isReleaseType and not request.isReceivalType then
			create alert transient;
			alert.details := "WLE for " &amp; self.job.jobId &amp; " has no tracked item!";
			alert.setSeverity(SEVERE_ERROR);
			alert.add;
		endif;	
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkPackLoadWeight" id="8e4d2b46-fd5d-45d4-bf79-3a89c85ca9e0">
        <source>checkPackLoadWeight(_cargoWeight : Decimal): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
11 January 2024	navcs2	ChangeRequest 61549: EUP | Release Request by Weight - Pack/Load, Rail Lander
*/

vars
	request : CM_Request;
	gateEntity	: CMGTE_Entity;
	wleWeight : Decimal[14,4];
begin
	request := self.myRequest;
	
	if request &lt;&gt; null and request.isKindOf(CM_YardRequest) then
		gateEntity := request.CM_YardRequest.myGateEntity;
		if gateEntity &lt;&gt; null and gateEntity.isKindOf(CMGTE_Release) then
			wleWeight := gateEntity.CMGTE_Release.releaseWeight;
			if _cargoWeight &gt; wleWeight then
				return false;
			else
				return true;
			endif;
		endif;
	else
		return true;
	endif;
epilog

end;</source>
        <Parameter name="_cargoWeight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkTIRequestTI" id="95c51fa1-48b9-49fd-994b-3ab90af67c44">
        <source>checkTIRequestTI(): Boolean  protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 February 2011	cnwer1	Initial creation
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	requestTI,
	ti 			: CM_TrackedItem;
begin
	
	ti := self.myTrackedItem;
	
	if ti = null then
		return true;
	endif;
	
	requestTI := self.myRequest.CM_TIRequest.trackedItem;
	
	if requestTI = null then
		return true;
	endif;
	
	//split from this ti
	if (ti.isKindOf(CM_BreakBulkGeneric) and ti.myMasterTi &lt;&gt; null) and 
		ti.myMasterTi = requestTI then
		return true;
	endif;
	
	if ti = requestTI then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkToDoComplete" id="0a7a2a62-cc92-4181-be3f-4de4c954f000">
        <source>checkToDoComplete(_all : Boolean) : Boolean;
//--------------------------------------------------------------
// Created: 26 April 2002 By: cnwgd1
// 14/06/2022 	navcs2 		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
//--------------------------------------------------------------
vars
	relatedWle, wle : CM_WorkListEntry;
begin
	
	if _all then
		foreach wle in self.job.workListEntries do
			if wle.isKindOf(CM_WOToDoWLE) then //14/06/2022 navcs2 TFS 53038
				if wle.status = WLE_COMPLETED then
					return true;
				else
					return false;
				endif;
			endif;
		endforeach;
	else
		relatedWle := self.getRelatedWLE();
		if relatedWle &lt;&gt; null and relatedWle.isKindOf(CM_WOToDoWLE) then //14/06/2022 navcs2 TFS 53038
			if relatedWle.status = WLE_COMPLETED then
				return true;
			else
				return false;
			endif;
		endif;
	endif;
	
	return true;		

end;</source>
        <Parameter name="_all" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createRcvRoadCancelledTrans" id="c8fe5eac-f4f0-48ab-968e-4e053b466d6d">
        <source>createRcvRoadCancelledTrans(_reason : String);
/*

Purpose: Create 'Receive Road Cancelled' transaction

Parameters:			

Return Value:		

Date		Who		TFS		Reason
29 Oct 2019	jlgdi1	46578	Initial creation
*/

vars
	tiTransController : CMIF_RcvRoadCancelledCntlr;
	tiTrans			  : CM_TITransaction;
	vvr 			  : CM_VehicleVisitRecord;		//25 Jun 2020	NDL	TFS 49604
	roadjob			  : CM_Job;
begin

	//25 Jun 2020	NDL	TFS 496
	roadjob := self.job;
	
	if roadjob &lt;&gt; null and roadjob.isRoadJob then
		vvr := roadjob.CM_RoadJob.myVehicleVisit;
	endif;
	
	create tiTransController transient;
	
	tiTransController.type				    := TRANS_TYPE_RCVROADCANCELLED;
    tiTransController.myTrackedItem 		:= self.myTrackedItem;
	tiTransController.reason 				:= _reason;
	tiTransController.myVehicleVisitRecord  := vvr;	//25 Jun 2020	NDL	TFS 49604
    tiTrans := self.myTrackedItem.createTransaction(tiTransController, app.myPassport);
	
	tiTrans.setExternalReferenceId("");
	
epilog
	delete tiTransController;
end;</source>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteCurrentEntry" id="f115386b-bc8c-4138-90aa-9d2e6b4eb7da">
        <source>deleteCurrentEntry(_isMoveAllCargoBack : Boolean; _reason : String);
//21 December 2009	cnwml2
// Changed By	On			Reason
// ----------	--------	--------------------------------------------
// 25/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
//27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
//3/12/2018 	JLGNS1	Bug 41555: STWR - Inbound delete process for Steinweg Huntsman does not work no more in version 8.5.1.230 (deleting cargo in Road Ops and triggering CAMS). Issue found in Rotterdam UAT
//28/01/2019 	JLGNS1	Bug 43075: STWR Ticket 42865: STWR - RE: Ticket 41369
//29 Oct 2019	jlgdi1	46578	Added creation of Receive Road Cancelled transaction when Delete Current Entry option is used
//						and sets the invoice line status to void when option 'void invoice line' is selected. Refactoring - 
//						Putting the process of deleting the transaction, audit edit generation and voiding invoice line status into one method initiateDeletion()
//25 Nov 2019	jlgdi1	46578 Passed in correst reason for deletion
//19 Nov 2024	jlizm1	MTN 19267 Stops preventing road exit of cancelled prenote
constants
	Empty_Reason : String = null;
vars
	tiTxn 				 : CM_TITransaction;
	pin 				 : CM_PinNo;
	prenotedTI 			 : CM_TrackedItem;
	control 			 : CMIF_MoveController;
	attachedGenerator 	 : CM_Generator;
	wasNotified 		 : Boolean;			//29 Aug 2018	NDL	TFS 39769
	originalTi 			 : CM_TrackedItem;	//29 Aug 2018	NDL	TFS 39769
	pinTi 				 : CM_TrackedItem;	//Bug 43075
	reason 				 : String;
	setToVoidInvoiceLine : Boolean;
	isReceiptWle		 : Boolean;
	reeferProp			 : CM_TIReeferProperties;
	gen					 : CM_Generator;
begin
	
	if self.myTrackedItem = null then
		return;
	endif;
	
	isReceiptWle := self.isReceipt;
	
	//29 Aug 2018	NDL	TFS 39769
	if isReceiptWle then
		wasNotified := self.myTrackedItem.wasPrenotified();
		if not wasNotified and self.myTrackedItem.myCargoType.allowDuplicates then
			// cargo that has been unloaded and merged into an existing cargo item then split to be reloaded to the truck will not 
			// know based on the above method that its ultimate parent was originally split from a pre-notified cargo item
			// find the original ti from the cmgte if possible and check that...
			originalTi := self.getOrigTiFromGTEReceival;
			if originalTi &lt;&gt; null then
				wasNotified := originalTi.wasPrenotified();
			endif;
		endif;
	endif;
	
	if isReceiptWle and wasNotified then	
		// ###############################
		// ### We are going to work out if myTrackedItem was actually from a prenote.
		// ### If it is from a prenote then it was split off from that prenote, and we want to merge myTrackedItem back into it
		//### We are in this method because the user is deleting the WLE that represents part or all of the prenote
		//### It is possible that the split TI was then split multiple times as it is unloaded from a truck. 
		//### 		If this is the case the last part on the truck becomes a zombie
		//### So we might have a myTrackedItem with a direct link to a prenote, 
		//### 		or we might have an originalTi that is a zombie on the truck with it's own link to the prenote
		//###		or we might have an adjustment to a whole prenote that was put in a job and totally unloaded to the yard and now we want to adjust the prenote amount
		//###		or we might be a whole prenote in a job on the truck and the whole job is being deleted, so just change the TI's state so it becomes a Prenote
	
	
		
		//if is break bulk with allow duplicates may already be a prenote still 
		//epr CCMS 2274 13/5/13 
		if self.myTrackedItem.myCargoType.allowDuplicates then
		
			// ##########
			// ###  Has myTrackedItem got a direct link to a PRENOTE?
			// ##########
			if self.myTrackedItem.myMasterTi &lt;&gt; null then // TFS 43075 JLGAB1
				if self.myTrackedItem.myMasterTi.isPreNote() then // TFS 43075 JLGAB1
					prenotedTI := self.myTrackedItem.myMasterTi; // TFS 43075 JLGAB1 merge back into the Prenote I was split from.
				endif; // TFS 43075 JLGAB1
			endif; // TFS 43075 JLGAB1
		
			// ##########
			// ### Has the originalTi got a direct link to a PRENOTE?
			// ##########
			if prenotedTI = null and originalTi &lt;&gt; null then // TFS 43075 JLGAB1
				if originalTi.myMasterTi &lt;&gt; null and  originalTi.myMasterTi.isPreNote() then // TFS 43075 JLGAB1
					prenotedTI := originalTi.myMasterTi; // TFS 43075 JLGAB1 merge back into the Prenote I was split from.
				
				endif;
			endif;
			/* // TFS 43075 JLGAB1
			prenotedTI:=self.myTrackedItem.myTerminal.allNotifiedTIsByCargoTypeId[self.myTrackedItem.myCargoType.id,self.myTrackedItem.id];
			*/			
			
			
			// ##########
			// ### Are we doing an adjustment?
			//### 03 Sep 2018	NDL	TFS 39769, create a new prenote with no amounts so we can do the merge below
			// ##########
			if prenotedTI = null //	then	
			and not _isMoveAllCargoBack then
				// TFS 43075 JLGAB1 This happens from the HH Truck Unloader. If a prenote for 5000 is in the job.
				//									If 5000 is unloaded (so nothing is on the truck, the whole 'prenote' is in the yard), 
				//									The user has a new option to change the amount unloaded to say 4500. 
				//									This code will create a 500 prenote and leave the truck empty.
				app.myUtilityCA.utlCreatePreNoteForMerge( self.myTrackedItem.CM_Cargo, prenotedTI.CM_Cargo, app.myPassport );
			endif;
		endif;
		
		// ##########
		// ### Whole Prenote in job and the whole amount is being deleted? Change the state to Prenote. 
		// ##########
		if prenotedTI = null then
		
			self.myTrackedItem.changeState(TI_STATE_NOTIFIED, app.myPassport);
			self.myTrackedItem.resetReceivedDT();		// 34715 call an explicit reset method to avoid accidental clearing of received date
			self.myTrackedItem.setCarrier(null);	//Bug 41555
			if _isMoveAllCargoBack then
				self.myTrackedItem.clearMyActualLocation();
				self.myTrackedItem.setLocationId(null);
			endif;
		else
			
			// ##########
			// ### 29 Aug 2018	NDL	TFS 39769 - We now want to merge the onsite guy back into the pre-note, not just adjust the values on the pre-note
			// ##########
			app.myUtilityUA.utlMergeBreakBulk( prenotedTI.CM_Cargo, self.myTrackedItem.CM_Cargo, app.myPassport );
			
			if prenotedTI.myPinNo = null then																				//Bug 43075
				if self.myTrackedItem.myPinNo &lt;&gt; null then																	//Bug 43075
					pinTi := self.myTrackedItem;																			//Bug 43075
					pin := self.myTrackedItem.myPinNo;																		//Bug 43075
				elseif originalTi &lt;&gt; null and originalTi.myPinNo &lt;&gt; null then 												//Bug 43075
					pinTi := originalTi;																					//Bug 43075
					pin := originalTi.myPinNo;																				//Bug 43075
				endif;																										//Bug 43075
				
				if pinTi &lt;&gt; null then																						//Bug 43075	
					pin.replaceItem(pinTi,prenotedTI);																		//Bug 43075
					pin.updateStatus(PIN_Normal);																			//Bug 43075					
				endif;																										//Bug 43075	
			endif;			
			
			/*
			//epr TFS 1707 6/4/16
			//remove the amount from the prenote
			create control transient;
			control.setMyPassport(app.myPassport);
			//epr TFS 8220 6/12/17 
			control.setQuantity(-(self.myTrackedItem.totalQuantity));		
			control.setWeight(-(self.myTrackedItem.totalWeight));
			control.setVolume(-(self.myTrackedItem.totalVolume));
			prenotedTI.splitSetQVW(control,null);
			*/

		endif;
	endif;
	
	//31 March 2011	#cnwdz2	 par27146 start
	pin := self.myTrackedItem.myPinNo;
	if pin &lt;&gt; null then
		pin.updateStatus(PIN_Normal);
	endif;
	
	setToVoidInvoiceLine := self.isSetToVoidRoadRcvInvoiceLine();
	
	if isReceiptWle then // TFS 43075 JLGAB1 and self.myTrackedItem.allSplitChildrenTis.size = 0  then   // PAR 27525
		tiTxn := self.myTrackedItem.getLastTransOfType(TRANS_TYPE_REC_ROAD);
		if tiTxn &lt;&gt; null then
			// PAR 20155 tiTxn.erase(NORMAL_ERASE);
			reason := "Road Receival Job Deleted (" &amp; _reason &amp; ")"; // TFS 43075
			if self.job &lt;&gt; null then
				reason := "Road Receival Job '" &amp; self.job.jobId &amp;  "' Deleted (" &amp; _reason &amp; ")"; // TFS 43075
			endif;
			self.initiateDeletion(tiTxn, reason, setToVoidInvoiceLine);			
			
			// CCMS 1875 - check if we also have a sub-terminal receive transaction and delete it as well
			if tiTxn.mySubTerminal &lt;&gt; null then
				tiTxn := self.myTrackedItem.getLastTransOfType(app.getSubTerminalReceiveTxnType(tiTxn.mySubTerminal.type, TI_TRANSMODE_ROAD));
				if tiTxn &lt;&gt; null then
					self.initiateDeletion(tiTxn, Empty_Reason, setToVoidInvoiceLine);
				endif;
			endif;
			
			//27.02.2018 cnwma1 ChangeRequest #36813
			reeferProp := self.myTrackedItem.myReeferProperties;
			if reeferProp &lt;&gt; null then
				gen := reeferProp.generator;
				if gen &lt;&gt; null then
					attachedGenerator := gen;
					tiTxn 			  := attachedGenerator.getLastTransOfType(TRANS_TYPE_REC_ROAD);
					if tiTxn &lt;&gt; null then
						self.initiateDeletion(tiTxn, Empty_Reason, setToVoidInvoiceLine);
						
						if tiTxn.mySubTerminal &lt;&gt; null then
							tiTxn := attachedGenerator.getLastTransOfType(app.getSubTerminalReceiveTxnType(tiTxn.mySubTerminal.type, TI_TRANSMODE_ROAD));
							if tiTxn &lt;&gt; null then
								self.initiateDeletion(tiTxn, Empty_Reason, setToVoidInvoiceLine);
							endif;
						endif;
					endif;
				endif;
			endif;
			//27.02.2018 cnwma1 ChangeRequest #36813
			
		endif;
	endif;
	
	tiTxn := self.myTrackedItem.getLastTransOfType(TRANS_TYPE_Rec_Outside_Restric);
	if tiTxn &lt;&gt; null then
		self.initiateDeletion(tiTxn, _reason, setToVoidInvoiceLine);
	endif;
	
	//+cnwml2 PAR25379
	if isReceiptWle and not self.myTrackedItem.isNotified() then //cnwas3 par 26672
		self.myTrackedItem.setBookingReference(null);			
	endif;
	
	if isReceiptWle then
		self.createRcvRoadCancelledTrans(_reason);
	endif;
	
epilog
	delete control;
end;</source>
        <Parameter name="_isMoveAllCargoBack" type="Boolean"/>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="doMoveToLocn" id="82f681f2-daea-4613-b68e-b6f375c71f6e">
        <updating/>
        <source>doMoveToLocn(_moveController : CMIF_MoveController input; _passport: CM_Passport input) updating;

// cnwdvb1 28 May 2003 

vars
	invalidWLE : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self, invalidWLE); 
	inheritMethod(_moveController, _passport);

	if _passport.hasErrors then
		return;
	endif;
	
	if self.job.status = JOB_COMPLETE then
		if CM_YardInternalJob.hasInstance(self.job) then
			self.job.erase(NORMAL_ERASE);
		endif;
	endif;

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="erase" id="e7af39f7-893d-4e52-9179-d6bf481c0c70">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	ti : CM_TrackedItem;
	release	: CMGTE_Release;
	invalid 		: Boolean;
	ghostTI		: CM_TrackedItem;
begin
	
	// Lock all for update
	exclusiveLock(self);
	sharedLock(myRequest);
	if self.myRequest.myJob &lt;&gt; null then
		//AJA 31/3/00: Yard internals
		sharedLock(self.myRequest.myJob);
	endif;
	ti := self.myTrackedItem;
	if ti &lt;&gt; null then
		exclusiveLock(ti);
		self.unqueueUnplanMyTrackedItem(app.myPassport);
	else
		self.unQueueWLE(null);			
	endif;

	//Tell Job to clean up any TI Linkages..
	if ti &lt;&gt; null then
		job.CM_YardJob.removeTI(ti, self.myRequest);
		
		if not self.job.isRail then // PAR 21519 MSL 1013 
			if self.isUnactionedTIReceipt
			or (self.job.isKindOf(CM_RoadJob)
			and self.job.CM_RoadJob.isTurnAroundJob) then
				// PAR 10324 - don't delete imports
				// PAR 10790 - only delete ti's if the wle has a turnaround wle
				if (not ti.isImport)
				and self.jobHasTurnAroundWLE() then
					//ti.erase(NORMAL_ERASE); // cnwrd1 par 22624 3.5.2010 -- dont want to delete the ti here anymore just mark offsite or prenotified
					if ti.wasPrenotified() then  // cnwrd1 par 22624 3.5.2010 ++
						ti.changeState(TI_STATE_NOTIFIED, app.myPassport);
						ti.setMyNotifiedTerminal(ti.myTerminal);		
					else
						ti.changeState(TI_STATE_OFFSITE, app.myPassport);
					endif;
					
					ti.resetReceivedDT();		// 34715 call an explicit reset method to avoid accidental clearing of received date
					ti.setLocationId(null);
				endif;
			endif;
		endif;
	endif;

	ghostTI := self.ghostTrackedItem;
	if ghostTI &lt;&gt; null then
//	   global.isValidObject(self.ghostTrackedItem) then
		on Exception do app.handleDeletedObject(exception, ghostTI, invalid);
		exclusiveLock(ghostTI);
		if not invalid then
			job.CM_YardJob.removeTI(ghostTI, self.myRequest);
			ghostTI.erase(NORMAL_ERASE);
		endif;
	endif;
	
	
	//=======================
	// automatics should take care
	// of the job.wles and request.wles collections.
	//=======================

	self.causeEvent(self.job.getMyTerminal.getTerminalEvent(WLE_Delete_Event), false, self);
	
  	inheritMethod(_eraseLevel);
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findFinalIncompleteTask" id="4e869f18-010b-41f5-99da-89a19c1b7064">
        <source>findFinalIncompleteTask():CM_RTQueueTask;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 December 2010	cnwndl1	Initial creation	Par 26498

*/

vars

	entry : CM_RTQueueEntry;
	task : CM_RTQueueTask;
	
begin

	if self.allRTQueueEntries.isEmpty then
		return null;
	endif;
	
	entry := self.allRTQueueEntries.last;
	
	if entry = null or entry.allTasks.isEmpty or entry.status = ENTRY_COMPLETE then
		return null;
	endif;
	
	task := entry.allTasks.last;
	
	if task = null or task.status = TASK_COMPLETE then
		return null;
	endif;
	
	return task;
	

epilog


end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="findFirstIncompleteTask" id="8b607606-dcda-4ddc-8065-3aab8192cffd">
        <source>findFirstIncompleteTask():CM_RTQueueTask;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 November 2010	cnwndl1	Initial creation	Par 25422

*/

vars

	iter : Iterator;
	entry : CM_RTQueueEntry;
	entryToUse : CM_RTQueueEntry;
	task : CM_RTQueueTask;
	
begin

	// find the first RT Q entry that is not marked as complete.
	iter := self.allRTQueueEntries.createIterator;
	while iter.next( entry ) do
		if entry.status = ENTRY_COMPLETE then
			continue;
		endif;
		entryToUse := entry;
		break;
	endwhile;
	
	if entryToUse = null then
		// nothing here.
		return null;
	endif;
	
	delete iter;
	
	// find the first task in thsi entry that is not complete
	iter := entryToUse.allTasks.createIterator;
	while iter.next( task ) do
		if task.status = TASK_COMPLETE then
			continue;
		endif;
		return task;
	endwhile; 
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d9b64814-e8ac-4359-a361-ffa2eea96203">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 13 May 2002 By: cnwgd1
//22/11/2017 			   cnwma1 TFS #7828 QNS - System buffering
//02/10/2020 			   cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
//07/03/2023			   navdap1 TFS 57001 FR | 53667 - EUP - Inspection App checks - New Fields in Column Organiser 
//06 Aug 2025			   navbs1  Initial creation Story MTN-35549: TPT | Source Location for RT Moves on the Road Ops Screen - Dev
//--------------------------------------------------------------
vars
	tmp 		: String;
	job			: CM_RoadJob;
	vehicle		: CM_Vehicle;
	wc 			: CM_WagonController;
	theLocation : CM_LocationsController;
	request		: CM_Request;				// ### TFS 58755 (59759) 25Aug2023 NAVPW1
	consignee	: CM_ConsigneeConsignor;	// ### TFS 58755 (59759) 25Aug2023 NAVPW1
	
begin
	if _attrName = ETRow_GateLane         or
		_attrName = ETRow_RegNumber       or
		_attrName  = ETRow_CarrierId      or
		_attrName = ETRow_RegNumber       or
		_attrName = ETRow_ElapsedTimeArea or
		_attrName = ETRow_ElapsedTime 	  or
		_attrName = ETRow_Stevedore       or    //04.11.2020 cnwma1 TFS #50112
		_attrName = ETRow_TerminalAreaOid then
		
		job 	:= self.job.CM_RoadJob;
		
		if job &lt;&gt; null then
			vehicle := job.myVehicle;
			
			if vehicle &lt;&gt; null then
				return vehicle.getDisplayStringForAttribute (_attrName, _short);
			endif;
		endif;
	elseif _attrName = ETRow_WorkEntry then
		if self.myRequest.isReleaseType then
			return app.getErrorString(Load);
		else
			return app.getErrorString(Unload);
		endif;
	// added 31/12/04 HJG CCMS1304 to stop exception caused when no TI associated with job. 
	elseif  _attrName = ETRow_IsHazardous then  //epr par 36919 25/11/15
		if self.myTrackedItem = null then
			return null;
		else
			return inheritMethod(_attrName, _short);
		endif;
		
	elseif _attrName = ETRow_MySubTerminal then
		if self.myTrackedItem = null then
			return null;
		else
			return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);
		endif;
		
	elseif _attrName = ETRow_TransactionNum then // PAR 17703
		if self.job &lt;&gt; null then
			//22/11/2017 cnwma1 TFS #7828
			if self.myRequest &lt;&gt; null then
				if self.myRequest.isKindOf(CM_TIRequest) then
					if self.myRequest.CM_TIRequest.myGateEntity &lt;&gt; null then
						tmp := self.myRequest.CM_TIRequest.myGateEntity.tranNumber;
					endif;
				endif;
			endif;
			
			if tmp = null then
				tmp := self.job.getDisplayStringForAttribute(_attrName, _short);
			endif;
		endif;
		return tmp;

	elseif _attrName = ETRow_Destination or
	   _attrName = ETRow_FreightForwarder then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;
	//16 Sep 2013	NDL	Par 32479	
	elseif _attrName = ETRow_WagonPos then
		wc := self.getWagonController();
		if wc &lt;&gt; null then
			return wc.myWagon.getDisplayStringForAttribute(ETRow_WagonPos,_short);
		else
			theLocation := self.getLocationForMode(PLANNING_MODE);
			if theLocation &lt;&gt; null then
				if CM_WagonController.hasInstance(theLocation) then
					return theLocation.CM_WagonController.myWagon.getDisplayStringForAttribute(ETRow_WagonPos,_short);
				endif;
			endif;

			// PAR 34417 if not planned look at where we are
			if  self.isReceipt and wc = null and self.myTrackedItem&lt;&gt; null then
				theLocation := self.myTrackedItem.allLocations.first;
				if theLocation &lt;&gt; null and theLocation.isWagon then
					wc := theLocation.CM_WagonController;
				endif;
			endif;
			if wc &lt;&gt; null then
				return wc.myWagon.getDisplayStringForAttribute(ETRow_WagonPos,_short);
			endif;
			
			return null;
		endif;
		
	elseif _attrName = ETRow_Source then //cnwrd1 par 22331 11.02.2010
			return self.getSourceLocationId();  //cnwrd1 par 25488 23.8.2010
	elseif _attrName = ETRow_Target then //cnwrd1 par 22331 11.02.2010
		if self.isPlanOnPickupNoTarget then //cnwrd1 ccms 2014 plan on pickup
			return app.getErrorString(Autoplan);
		elseif self.isPlanOnPickup then //have a location
			return self.myTrackedItem.myPrimaryQueuedLocation.getID();
		elseif self.myRequest &lt;&gt; null then
			return self.myRequest.getTargetLocationID();		
		else
			return null;
		endif;
	elseif _attrName = ETRow_Remarks then
		if self.myTrackedItem &lt;&gt; null then
			return  self.myTrackedItem.remarks;
		else
			return self.myRequest.CM_YardRequest.remarks;
		endif;
	elseif _attrName = ETRow_CargoRemarks then		// 28051 Dec 2011 add cargo and request remarks to Rail Ops form
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.remarks;
		else
			return null;
		endif;
	elseif _attrName = ETRow_RequestRemarks then	// 28051 Dec 2011 add cargo and request remarks to Rail Ops
		if self.myRequest &lt;&gt; null then
			tmp := self.myRequest.CM_YardRequest.remarks.trimRight;	// show request remarks in preference to reserve remarks - getRemarks does it the other way around
			if tmp = null then
				tmp := self.myRequest.CM_YardRequest.getRemarks();
			endif;
			return tmp;
		else
			return null;
		endif;
	elseif _attrName = ETRow_RadioTelemetry and self.isDirectDelivery() then
		return "DD";
		
	// TSF 57001 start
	elseif _attrName = ETRow_GateInCheckStatus or _attrName = ETRow_GateInCheckTS
	or _attrName = ETRow_GateOutCheckStatus or _attrName = ETRow_GateOutCheckTS then
		if self.job &lt;&gt; null then
			tmp := self.job.getDisplayStringForAttribute(_attrName, _short);
		endif;
		return tmp;
	// TFS 57001 end
	
	// ### TFS 58755 (59759) 25Aug2023 NAVPW1
	elseif _attrName = ETRow_Consignee then
		request := self.myRequest;
		if request = null then
			return null;
		endif;
		
		consignee := request.getConsignee();
		if consignee = null then
			return null;
		endif;
		
		return consignee.description;
	// ### TFS 58755 (59759) 25Aug2023 NAVPW1
	
	elseif _attrName = ETRow_SourceLocQueued then 									//06.08.2025 navbs1 #35549
		return self.getQueuedSourceLoc();		
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEntryType" id="374be0a3-e83e-4d7e-aba8-d995230e9abe">
        <updating/>
        <source>getEntryType() : String updating;
