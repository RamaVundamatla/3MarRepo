    <JadeMethod name="connectPortHole" id="bcdcb0a6-182b-4c22-8b8e-a5ddba7d4cec">
        <updating/>
        <source>connectPortHole(params : CMIF_ConnectParams; _passport : CM_Passport input) updating;

vars
	myLC : CM_TowerController;
	tiLC : CM_StackController;
	theTI : CM_Container;
	txnParams : CMIF_ConnectParams;
	txn : CM_TITransaction;
begin

	theTI := params.myTrackedItem.CM_Container;
	
	myLC := self.getPrimaryLocation(REAL_MODE).CM_TowerController;
	tiLC := theTI.getPrimaryLocation(REAL_MODE).CM_StackController;
	
	//Find out if we are connecting to previous or next
	//side of the tower and do the connection actions
	if tiLC = myLC.getMyPreviousController(CM_StackController).CM_StackController then
		self.prevPortHole := theTI.CM_Container;
		if self.nextPortHole = null then	
			self.temperature := theTI.getTemperature;
		endif;
	elseif tiLC = myLC.getMyNextController(CM_StackController).CM_StackController then
		self.nextPortHole := theTI.CM_Container;
		if self.prevPortHole = null then	
			self.temperature := theTI.getTemperature;
		endif;	
	else
		return;
	endif;
	
	//Create a secondary transaction for ourself
	txnParams := params;
	txnParams.type := TRANS_TYPE_CONNECT_TOWER;
	txnParams.myOtherTrackedItem := theTI;
	txnParams.myTrackedItem := self;
	txn := self.createTransaction(txnParams, _passport);	
	txn.CM_ConnectTower.secondary := true;

end;</source>
        <Parameter name="params" type="CMIF_ConnectParams"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="1a2e45ed-bba4-451e-9304-d90b1ea9ba1f">
