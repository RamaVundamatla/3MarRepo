<Class name="WS_WorkPoint" id="da8af8a0-a4dc-4199-99a3-b69a80d07661">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Work Points, Terminal definable values</text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allJobSheets" id="cf89bde1-542e-4a78-8f15-246c19e48a54">
        <memberTypeInverse/>
        <type name="WS_JobSheetArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allJobs" id="cbbbe136-925e-4c0e-8e1d-62fe71780aee">
        <memberTypeInverse/>
        <type name="WS_JobArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="code" id="3497a269-1c26-4e60-a93d-24a29f6aa640">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Work Point Code.</text>
    </PrimAttribute>
    <PrimAttribute name="colour" id="0e8dd504-2114-4c22-9df7-70fef4dc26f0">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Work Point Colour.</text>
    </PrimAttribute>
    <PrimAttribute name="description" id="1d61cf92-d60a-466d-9e8b-bec086104db8">
        <length>101</length>
        <embedded/>
        <type name="String"/>
        <text>Work Point Description.</text>
    </PrimAttribute>
    <JadeMethod name="delete" id="96279c54-92c5-4eac-adba-0f276fd28604">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	self.allJobs.purge;
	self.allJobSheets.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="a8f611eb-e4c2-40c1-8a92-a9bf55a13d00">
        <updating/>
        <source>setProxyFromObject(_workPoint: CM_Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Sep 2011	cnwer1	Initial creation CCMS MES 1033
04 Jul 2011 cnwer1	par 29962 - make it work with lolo	
15 Feb 2016	cnwkpd1	PAR #35261 - Changes required for JADE 7.1 - signature change and refactor

*/

vars
	pxyJobSheet : WS_JobSheet;
	jobSheet	: CM_JobSheet;
begin
	inheritMethod(_workPoint);
	
	self.setProxyFromObjectLocal(_workPoint.IF_VoyageWorkPoint);
	
	if _workPoint.isKindOf(CM_WorkPoint) then 
		foreach jobSheet in _workPoint.CM_WorkPoint.allJobSheets do
			create pxyJobSheet transient;
			pxyJobSheet.setProxyFromObject(jobSheet);
			self.allJobSheets.add(pxyJobSheet);
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_workPoint" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObjectLocal" id="544be379-02a1-4a4f-8b4a-0a3021c35a5d">
        <updating/>
        <source>setProxyFromObjectLocal(_workPoint : IF_VoyageWorkPoint) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 Feb 2016	cnwkpd1	PAR #35261 - Changes required for JADE 7.1

*/

vars

begin
	self.code:=_workPoint.getID;
	self.colour:=_workPoint.getColour.cnEcGetHexColor;
	self.description:=_workPoint.getDescription;

epilog

end;</source>
        <Parameter name="_workPoint" type="IF_VoyageWorkPoint"/>
    </JadeMethod>
</Class>
