    <JadeMethod name="prepareAuditDetail" id="51fa2df7-b529-4259-8226-afa954bc3745">
        <source>prepareAuditDetail(_str : String io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2023	navhl20	ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
21/04/2023	navcs2	Bug 57691: MTN - WO - Audits are missing for the totalActioned
*/

vars
	tmpStr	 	: String;
	vbs			: CM_VehicleBookingTimeSlot;
begin
	inheritMethod(_str);
	tmpStr := null;
	if self.allVBSSlots.isNotEmpty then
		foreach vbs in self.allVBSSlots do
			if tmpStr = null then
				tmpStr := tmpStr &amp; vbs.id;
			else
				tmpStr :=tmpStr &amp; Comma &amp; vbs.id;
			endif;
		endforeach;
		_str := _str &amp; "VBS Slots" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	// 21/04/2023	navcs2	Bug 57691 Start
	tmpStr := null;
	if self.allVBSSlotsActioned.isNotEmpty then
		tmpStr := self.allVBSSlotsActioned.size.String;
		_str := _str &amp; "Number Actioned" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	else
		tmpStr := 0.String;
		_str := _str &amp; "Number Actioned" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	// 21/04/2023	navcs2	Bug 57691 End
epilog

end;</source>
        <Parameter name="_str" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="490f18f7-1dc9-4a8f-96d8-4d327f5359e4">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 December 2022	navcs2	ChangeRequest 56835:[56836] EUP - VAS Truck Work Order

*/

vars
	pxy 		: SelfType;
	completedOK : Boolean;
begin
	pxy := inheritMethod();
	
	self.allVBSSlots.copy(pxy.allVBSSlots);
	self.allVBSSlotsActioned.copy(pxy.allVBSSlotsActioned);
	self.allVBSSlotsCompleted.copy(pxy.allVBSSlotsCompleted);
	
	completedOK := true;
	return pxy;

epilog
	if not completedOK then
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5b2a41d3-816c-44ce-a26e-6cdc245aa89b">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WodToDoVBS) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 October 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
20 Mar 2023  	navhl20 Defect 57233: MTN - Editing Vas Tasks is not working correctly
*/

vars

begin
	
	inheritMethod(_pxyWoDDtl);
	self.allVBSSlots.clear();																//20.3.2023 navhl20	#57233
	_pxyWoDDtl.CM_WodToDoVBS.allVBSSlots.copyNoDuplicates(self.allVBSSlots, false);
epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodToDoVBS"/>
    </JadeMethod>
