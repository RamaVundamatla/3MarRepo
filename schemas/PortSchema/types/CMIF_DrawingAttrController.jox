// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	tmpPort		: CM_Port;

begin

	trimCode := _code.trimBlanks;

	iter := self.myIterLoadPort;
	self.allLoadPorts.startKeyGeq(trimCode, 0, iter);
	self.allLoadPorts.getIteratorKeys(codeKey, colorKey, iter);
	
	if codeKey = trimCode then
		// found the right one
		theCode		:= _code;
		theColor	:= colorKey;
	else
		//tmpPort := self.myRoot.allPorts[trimCode];
		tmpPort := self.myRoot.allPorts[trimCode];
		if tmpPort &lt;&gt; null then
			self.allLoadPorts.add(tmpPort);
			theCode		:= trimCode;
			theColor	:= tmpPort.colour;
		else
			theCode		:= null;
			theColor	:= NullColour;
		endif;
	endif;

	_codesArray.atPut(TI_ColourMode_LoadPort, theCode);
	_colorArray.atPut(TI_ColourMode_LoadPort, theColor);
	_objArray.atPut(TI_ColourMode_LoadPort, tmpPort);

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_codesArray" type="StringArray" usage="input"/>
