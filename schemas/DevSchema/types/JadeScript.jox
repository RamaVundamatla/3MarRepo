//	changeObject	: Object;
	pChangedTimeStamp : TimeStamp;
	changeArray : StringArray;
	objId : String;
begin
	create ctInterface transient;
//	create ctInterface.mySelectionObject transient;
	create changeArray transient;
	pClassName := "CM_ReceiveShip";
	date := "06/08/2015".Date;
	ts.setDate(date);
	time := "15:33:17.107".Time;
	ts.setTime(time);
	pFromTimeStamp := ts;
	pChangedTimeStamp := pFromTimeStamp;
	date := "07/08/2015".Date;
	ts.setDate(date);
	time := "09:14:29.781".Time;
	ts.setTime(time);
	pToTimeStamp := ts;
//	pToTimeStamp := app.actualTimeServer;
	idx := ctInterface.selectClassDeletes(pClassName, pFromTimeStamp, pToTimeStamp, null);
//	app.msgBox(idx.String, "idx",0);
	result := ctInterface.getNextClassDelete(objId, pChangedTimeStamp);
