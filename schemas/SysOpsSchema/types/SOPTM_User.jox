    <JadeMethod name="setFilterValues" id="38130254-22cc-4dea-b9ed-b2538351367b">
        <updating/>
        <source>setFilterValues() updating;
//	created 08/01/2007	cnwvu1
//	Purpose - to torganize searcher
vars

begin

	inheritMethod();

	if self.myForm.tblSearch.getValueByName(ETRow_Status) = null then
		self.filterStatus := -1;
	else
		self.filterStatus := app.userStatusStringToEnum(self.myForm.tblSearch.getValueByName(ETRow_Status).String);
	endif;
	
end;
</source>
