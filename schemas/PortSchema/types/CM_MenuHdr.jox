    <JadeMethod name="addAsUserItem" id="2fe327f6-fa10-4420-86de-f55617f3c0cb">
        <source>addAsUserItem(_parent : CM_MenuEntity input; _menuRoot : CM_MenuRoot) : CM_MenuUserItem;

vars
	pxyUserHdr	: CM_MenuUserHdr;
	realUserHdr	: CM_MenuUserItem;
	pos			: Integer;
	
begin

	create pxyUserHdr transient;
	pxyUserHdr.setProxy(self.heading, self.pictureStringButton, pictureStringButtonDown,self.pictureStringIcon, self.toolTip,self, _menuRoot);

	if self.myParent &lt;&gt; null then
		pos := self.myParent.allChildren.indexOf(self);
	endif;
//	app.myUtilityCA.utlCreateMenuUserItem(pxyUserHdr, _parent, 0, realUserHdr);
	create realUserHdr as CM_MenuUserHdr persistent;
	realUserHdr.setForCreate(pxyUserHdr, _parent, pos);

	return realUserHdr;
	
epilog
	delete pxyUserHdr;
	
end;</source>
        <Parameter name="_parent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot"/>
        <ReturnType type="CM_MenuUserItem"/>
    </JadeMethod>
    <JadeMethod name="addToUserMenuFromMenu" id="2e658a3d-d1bc-49ef-a1e2-a66e2181911f">
        <source>addToUserMenuFromMenu(_menuRoot: CM_MenuRoot input);
// ---------------------------------------------------------------------------
// Created:     03 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	sharedLock(self);

	self.addToUserMenuRoot(_menuRoot);
	
	inheritMethod(_menuRoot);

end;</source>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="canUserDo" id="a2a0c746-c532-4b5e-a96e-6437df9458d0">
