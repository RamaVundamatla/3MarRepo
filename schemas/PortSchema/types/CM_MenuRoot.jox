    <JadeMethod name="addQryReportToUserMenu" id="5008ea0a-0154-47a0-9995-36d887fe0d18">
        <updating/>
        <source>addQryReportToUserMenu(_rpt : CM_QryReport) updating;
// ---------------------------------------------------------------------------
// Created:     03 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	userItem	: CM_MenuUserItem;
	userDtl		: CM_MenuUserDtl;	
begin

	userItem := self.allMenuUserItemsWithAMenuItem[_rpt];
	if userItem &lt;&gt; null then
		// the user already has this item so check if they can still access
		if (not self.canDo(null, _rpt.menuId)) then	
			// remove
			delete userItem;
		endif;
	else
		if self.canDo(null, _rpt.menuId) then
			_rpt.addToUserMenuRoot(self);
		endif;
	endif;

end;</source>
        <Parameter name="_rpt" type="CM_QryReport"/>
    </JadeMethod>
