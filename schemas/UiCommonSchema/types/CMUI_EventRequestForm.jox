    <JadeMethod name="setCMIFSearchEventRequest" id="378e5be8-3e54-423d-a4b5-4bb9d500389e">
        <source>setCMIFSearchEventRequest(_propName, strValue : String; _obj : CMIF_SearchEventRequest input; _tbl : CM_EntryTable) : Boolean;
//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _propName = ETRow_MyOrganisation then
		_obj.myOrganisation := self.cmbOrganisation.listObject.CM_Organisation;
		return true;
	elseif _propName = ETRow_MyUser then
		_obj.myUser := self.cmbUser.listObject.CM_User;
		return true;		
	elseif _propName = ETRow_Status then
		_obj.status := app.eventRequestStatusStringToENum(strValue);
		return true;		
	else
		return false;
	endif;
end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="strValue" type="String"/>
        <Parameter name="_obj" type="CMIF_SearchEventRequest" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
