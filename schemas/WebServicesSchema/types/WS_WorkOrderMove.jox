<Class name="WS_WorkOrderMove" id="ba558a1e-53d8-4766-9a00-dfadccb70b63">
    <superclass name="WS_WorkOrderDetail"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="locationOid" id="a7e9843a-047f-4bcd-be60-19b163e3c73c">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="createProxyWorkOrder" id="ab29e2b1-0d1a-4dca-8518-d4946046f114">
        <source>createProxyWorkOrder(): CM_WorkOrderTIDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2018	jlger1	Initial creation

*/

vars
	pxyWorkOrder : CM_WodMove;
	
begin
	create pxyWorkOrder transient;
	
	return pxyWorkOrder;

epilog

end;</source>
        <ReturnType type="CM_WorkOrderTIDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="a7e29710-2a0c-4465-a818-7537e166c7f3">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodMove) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlger1	Initial creation 38520

*/

vars
	ta : CM_TerminalArea;
begin
	inheritMethod(_object);
	if _object.myTargetLocation &lt;&gt; null then
		self.locationOid := _object.myTargetLocation.myTerminalArea.getOidAsString;
	else
		if _object.targetLocation &lt;&gt; null then
			ta :=app.myPassport.myTerminal.allTerminalAreas[_object.targetLocation];
			if ta &lt;&gt; null then
				self.locationOid:=ta.getOidAsString;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_WodMove"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="c5e435c6-d0de-4970-9f93-0071a47cc4a7">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WorkOrderTIDtl input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2018	jlger1	Initial creation
19 Apr 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	targetLocation : CM_TerminalArea;
begin
	inheritMethod(_pxyWorkOrder);
	
	targetLocation:= app.myPassport.getObjectOfTypeFromOid(self.locationOid,CM_TerminalArea).CM_TerminalArea;
	
	if targetLocation &lt;&gt; null then
		_pxyWorkOrder.CM_WodMove.setProxyMove(null,targetLocation,false, null); //TFS 52351 05/05/2022 NAVCS2
	endif;
epilog

end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrderTIDtl" usage="input"/>
    </JadeMethod>
</Class>
