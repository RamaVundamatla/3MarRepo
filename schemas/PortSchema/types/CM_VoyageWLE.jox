    <JadeMethod name="isTiAssignedToResDet" id="619b5094-6fb0-47c3-8c5e-882da3b67f09">
        <source>isTiAssignedToResDet(_ti: CM_TrackedItem): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2017	cnwndl1	Initial creation	TFS 3045
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars

	req : CM_Request;
	resDet : CM_ReserveDetail;

begin

	if _ti = null then
		return false;
	endif;
	
	req := self.myRequest;
	
	if req.isKindOf( CM_SlotRequest  ) then
		resDet := req.CM_SlotRequest.myBulkReleaseReserveDetail;
	elseif req.isKindOf( CM_ROROSlotRequest  ) then
		resDet := req.CM_ROROSlotRequest.myBulkReleaseReserveDetail;
	endif; 
	if resDet &lt;&gt; null then
		//if resDet.allTrackedItems.includes( _ti ) then
		if resDet.includeTrackedItem(_ti, false) then //23/06/2023	navkc1	CR 58406 Task 58408
			return true;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTwinLift" id="c3c05d29-83ad-4b20-ad10-00d449d77d1a">
        <methodInvocation>mapping</methodInvocation>
        <source>isTwinLift(_set: Boolean; _value: Boolean io) mapping;
// -------------------------------------------
// Created 02 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if _set then
		return;
	endif;
	
	if self.job = null or not self.job.CM_VoyageJob.isTwinLift then
		_value := false;
		return;
	endif;
	
	//epr CCMS 1033 RORO deck jobs can never be twin lift so will only get here
	// if voyage job so the request will be a CM_SlotRequest
	if self.myRequest &lt;&gt; null then
		if self.job.CM_VoyageJob.myVoyage.starboardBerthed then
			_value := self.myRequest.CM_SlotRequest.isTwinLiftStarboard;
		else
			_value := self.myRequest.CM_SlotRequest.isTwinLiftPort;
		endif;
	else
		_value := false;
	endif;

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isVoyageAllocDirector" id="7788aef8-16f9-4e48-b7d6-c6405c375cef">
        <source>isVoyageAllocDirector() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 November 2012	cnwrd1	Initial creation

*/

vars

begin

	if not self.job.isAllowOutOfOrderLoading then
		return false;
	endif;
	
	if self.myRequest.myOriginatingBulkRelease &lt;&gt; null then
		return false;
	endif;
	
	
	
	if self.myTrackedItem &lt;&gt; null then
		return false;
	endif;
	
	if self.myRequest.getFirstAllocation() &lt;&gt; null then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
