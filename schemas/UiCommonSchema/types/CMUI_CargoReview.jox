        <updating/>
        <source>mnuCustDocsTICreate_click(menuItem: MenuItem input) updating;
/*
Purpose:			

Date		Who		Reason
21 September 2023	navab1	CR 60424 TASK 60549 
*/

vars
	iter      : Iterator;
	tiSet     : CM_TISet;
	ti,
	firstTi	 : CM_TrackedItem;

begin
	create tiSet transient;

	iter := self.tblCargo.allSelectedObjects.createIterator;
	while iter.next(ti) do
		tiSet.add(ti);
	endwhile;
	
	if tiSet.size &gt; 0 then
		self.openCustDocMaintForm(tiSet);
	endif;

epilog
	delete tiSet;

end;</source>
