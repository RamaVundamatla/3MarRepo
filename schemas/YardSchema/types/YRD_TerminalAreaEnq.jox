    <JadeMethod name="setColorsFromController" id="7416b8ac-1f70-47cc-9a5a-478a7b139a35">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theBackColour : Integer;
begin
	inheritMethod(_colorControl);
	
	theBackColour 				:= self.backColor;
	self.shtAreaTypes.backColor := theBackColour;
	self.shtCriteria.backColor 	:= theBackColour;
	
	self.setColorsForEntryTable(self.tblSearch);

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setRowHeight" id="a30d773f-fa98-411f-907d-d2bf2ca2dd41">
        <source>setRowHeight(_table :CM_DataTable input; _row, _colLR, _colLRWidth, _colYA, _colYAWidth :Integer) protected;
/*
Date		Who		Reason
01 Nov 2012	cnwcs5	Initial creation - par 30475
*/
vars
	strLR, strYA				: String;
	heightLR, heightYA		: Integer;
begin
	if _colLR &lt;&gt; 0 then
		strLR := _table.accessCell(_row, _colLR).text;
		
		if strLR &lt;&gt; null then
			heightLR := _table.getTextHeightForWidth(strLR, _colLRWidth) + 4;
		endif;
	endif;
	
	if _colYA &lt;&gt; 0 then
		strYA := _table.accessCell(_row, _colYA).text;
		
		if strYA &lt;&gt; null then
			heightYA := _table.getTextHeightForWidth(strYA, _colYAWidth) + 4;
		endif;
	endif;
	
	if heightLR &lt;&gt; null or heightYA &lt;&gt; null then
		_table.accessRow(_row).height := heightLR.max (heightYA);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_colLR" type="Integer"/>
        <Parameter name="_colLRWidth" type="Integer"/>
        <Parameter name="_colYA" type="Integer"/>
        <Parameter name="_colYAWidth" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSearchValues" id="f477f1c6-9071-43bc-9053-687eb1dc969d">
        <updating/>
        <source>setSearchValues() protected, updating;
// ---------------------------------------------------------------------------
// Created:     15 March 2004	cnwth2
//
// Purpose:     
// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support			 
// ----------   ----------  --------------------------------------------------
vars
	tbl					: CM_EntryTable;
	receivedFrom,
	receivedTo			: TimeStamp;
begin
	tbl := self.tblSearch;
	//set filter booleans
	self.filterIsClean 		:= tbl.getValueByName(ETRow_FiltIsClean).Boolean;
	self.filterIsPTI 		:= tbl.getValueByName(ETRow_FiltIsPTI).Boolean;
	self.filterHasRemarks 	:= tbl.getValueByName(ETRow_FiltHasRemarks).Boolean;
	self.filterHeldRail 	:= tbl.getValueByName(ETRow_FiltHeldRail).Boolean;
	self.filterHeldRoad 	:= tbl.getValueByName(ETRow_FiltHeldRoad).Boolean;
	
	//set filter operators
	self.allFilterOperators.clear();
	self.lstOperators.allSelectedObjects.copy(self.allFilterOperators);
	
	//set filter isoTypeGroup
	if self.cmbISOGroup.listObject &lt;&gt; null then
		self.filterISOTypeGroupCode := self.cmbISOGroup.listObject.CM_ISOTypeGroup.code;
	else
		self.filterISOTypeGroupCode := null;
	endif;
	
	//set filter isoType
	if self.cmbISOType.listObject &lt;&gt; null then
		self.filterISOTypeCode := self.cmbISOType.listObject.CM_ISOType.code;
	else
		self.filterISOTypeCode := null;
	endif;
	
	//set filter availability grade
	// CCMS 1235
	// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	if self.cmbAvailGrade.myObject &lt;&gt; null then
		self.filterAvailGrade := self.cmbAvailGrade.myObject.CM_MTGrade.code;
	else
		self.filterAvailGrade := null;
	endif;
	
	receivedFrom.cnEcSetDateAndTime( self.tblSearch.getValueAsDate(ETRow_FiltReceivedFrom),TimeStartOfDay) ;

	if (not receivedFrom.isValid) then
		self.filterReceivedFrom := null;
	else		
		self.filterReceivedFrom := self.localToSystemTime(receivedFrom).date;
	endif;
	
	receivedTo.cnEcSetDateAndTime(self.tblSearch.getValueAsDate(ETRow_FiltReceivedTo),TimeEndOfDay);

	if (not receivedTo.isValid) then
		self.filterReceivedTo := app.actualTimeServer().date;
	else		
		self.filterReceivedTo := self.localToSystemTime(receivedTo).date;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
