    <JadeMethod name="getDisplayDetails" id="18705a39-5113-4b55-9fd9-de62024efa25">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	if _short then
		return self.code;
	else
		return '('&amp;self.code&amp;')  '&amp;self.description;
	endif;

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="0e18380c-9d8e-4e22-97ea-7d7566d33535">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars

begin
	if _attrName = ETRow_Debtor then
		if self.myDebtor &lt;&gt; null then
			return self.myDebtor.name;
		endif;
		return null;
	elseif _attrName = ETRow_FinancialId then					//04.Mar.24 navsp1 TFS 57177
		if self.myDebtor &lt;&gt; null then
			return self.myDebtor.code;
		endif;
		return null;
	endif ; 
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
