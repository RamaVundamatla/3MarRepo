    <JadeMethod name="getDisplayDetails" id="ac735404-7b7e-4121-8463-fc694ca58d5a">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars

