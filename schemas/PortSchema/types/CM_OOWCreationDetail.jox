    <JadeMethod name="isDischarge" id="e0503b1d-89a8-4b42-8b9f-22330b82f0e1">
        <source>isDischarge() : Boolean;
vars

begin
	if self.discDLR20 &lt;&gt; null then
		return true;
	elseif self.discIMP20 &lt;&gt; null then
		return true;
	elseif self.discDLR40 &lt;&gt; null then
		return true;
	elseif self.discIMP40 &lt;&gt; null then
		return true;
	// PAR 16415 CCMS 1029
	elseif self.discDLR30 &lt;&gt; null then
		return true;
	elseif self.discIMP30 &lt;&gt; null then
		return true;
	elseif self.discDLR53 &lt;&gt; null then
		return true;
	elseif self.discIMP53 &lt;&gt; null then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
