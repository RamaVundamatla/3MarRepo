    <JadeMethod name="validateForCreate" id="152ee642-b27a-4807-90e7-97b6a533a45b">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     26 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if app.myRoot.allLogRejectRecoveryCodes.includesKey(self.code) &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	inheritMethod();


end;</source>
    </JadeMethod>
