    <JadeMethod name="showCraneAllocater" id="0db80c41-2e91-4bc3-a5a1-1adf0bb94520">
        <source>showCraneAllocater();
// ---------------------------------------------------------------------------
// Created:		March 2017 By Andrew Bishop cnwab1
//
// Purpose:		TFS 3646
//
// ---------------------------------------------------------------------------

vars

	theForm : SHP_SelectCranes;

begin
	app.mousePointer := Window.MousePointer_HourGlass;
	theForm := app.getForm(SHP_SelectCranes.name).SHP_SelectCranes;
	if theForm = null then
		create theForm as SHP_SelectCranes;
	endif;
		
	theForm.myTerminal := self.myTerminal;
	theForm.myCurrentVoyage := self.myCurrentVoyage;
	theForm.workPointJobSheetClassToCreate := CM_VoyageHoldJobSheet;
	theForm.showModal();
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="showDLRDischargeFields" id="34cff13d-d895-446f-a619-56b39e8fb8c5">
        <updating/>
        <source>showDLRDischargeFields(_table : CM_DataTable; _job : CM_VoyageHoldJob) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/03/2017	cnwdap1		Initial creation TFS 3516 LNX Hold Planning Quantity
// 28/09/2018 	JLGNS1	Bug 40500: STWO - Hold Planning(STWUJMT2)
//
vars
	job : CM_VoyageJob;
	idx : Integer;
	showFields : Boolean;

begin
	self.lblDLRDisch.visible := false;
	self.cmbDLRDisch.visible := false;
	
	if _table &lt;&gt; self.tblOnSite or self.mode &lt;&gt; self.Mode_Add then
		if _job = null then
			return;
		endif;
	endif;
	if self.myCurrentTrackedItem = null and _job = null then
		return;
	endif;
	
	// are we planning DLRs back to the ship? We need to know what their discharge job was
	if self.myCurrentTrackedItem &lt;&gt; null and self.myCurrentTrackedItem.isRehandle and _table = self.tblOnSite then
		showFields := true;
		self.cmbDLRDisch.clear;
		foreach job in self.myCurrentTrackedItem.allJobsShipReceive where job.isRehandle and job.isVoyageHoldJob do
			idx := self.cmbDLRDisch.addItemObject(job.id, job);
			self.cmbDLRDisch.listIndex := idx;
		endforeach;
	elseif _job &lt;&gt; null then
		showFields := true;
		idx := self.cmbDLRDisch.findObject(_job);
		if idx &lt; 0 then
			idx := self.cmbDLRDisch.addItemObject(_job.id, _job);
		endif;
		if idx &gt; 0 then
			self.cmbDLRDisch.listIndex := idx;
		endif;
	endif;
	
	if showFields then
		self.lblDLRDisch.visible := true;
		self.lblDLRDisch.move(self.lblSubArea.left + 55, self.lblSubArea.top, self.lblDLRDisch.width, self.lblDLRDisch.height);								//Bug 40500
		self.cmbDLRDisch.visible := true;
		self.cmbDLRDisch.move(self.lblDLRDisch.left + self.lblDLRDisch.width + 10, self.lblDLRDisch.top, self.cmbDLRDisch.width, self.cmbDLRDisch.height);	//Bug 40500
	endif;
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
    </JadeMethod>
    <JadeMethod name="showTranshipForm" id="16f52879-859d-462d-9864-ec9ec447b699">
        <source>showTranshipForm();
/*
Purpose: TFS 3561			
Date		Who			Reason
FEB 2017	CNWAB1		Initial creation
20/08/2018	jlgdap1		TFS 39964 PEl1 Hold Job Ops Loading Changes
21/10/2019	jlgzm1		TFS 47085 Direct Release Ship to Ship
*/

vars
	tiArray : CM_TIArray;
	job : CM_VoyageHoldJob;
    idx, row : Integer;
    ctrl : Control;
    table : CM_DataTable;
    topSheet : CMUI_Sheet;
	wleArray : CM_WLEArray;		// TFS 47085
	wle : CM_WorkListEntry;		// TFS 47085
begin
	create tiArray transient;
	create wleArray transient;	// TFS 47085
	if self.fldData.topSheet = self.shtOnShip then
		self.tblOnShip.allSelectedObjects.copy(tiArray);
	elseif self.fldData.topSheet = self.shtOnSite then
	elseif self.fldData.topSheet = self.shtPreNote then				// TFS 39964
	elseif self.fldData.topSheet = self.shtTranship then			// TFS 47085
	else
		topSheet := self.fldData.topSheet.CMUI_Sheet;
		table := topSheet.getFirstChildOfType(CM_DataTable).CM_DataTable;
		
		
		job := topSheet.userObject.CM_VoyageHoldJob;
		if table &lt;&gt; null and job &lt;&gt; null and job.isDischarge then
			//table.allSelectedObjects.copy(tiArray);
			table.allSelectedObjects.copy(wleArray);		// TFS 47085
			foreach wle in wleArray do						// TFS 47085
				if wle.myTrackedItem &lt;&gt; null then			// TFS 47085
					tiArray.add(wle.myTrackedItem);			// TFS 47085
				endif;
			endforeach;
		endif;
		

	endif;
		
	if tiArray &lt;&gt; null and tiArray.size &gt; 0 then
		self.myAssistant.showTranshipDetailForm(tiArray);
	endif;
	
	
epilog
	delete tiArray;
	delete wleArray;	// TFS 47085
end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="9a54b3c0-f3ee-4154-94e3-da64b6213170">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 28/11/2018	jlgdap1		TFS 42109 PEL1 Hold Job Ops Issue
// 22/07/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail - All Cargo Types
//
vars
	ti : CM_TrackedItem;
	wagon : CM_Wagon;
	vehicle : CM_Vehicle;
	wle : CM_WorkListEntry; //TFS 42872
begin
	// handle deletes first
	if eventType = Object_Delete_Event then
		if theObject.isKindOf(CM_TrackedItem) then				// TFS 42872
			// must be the prenote table or the onship table
			self.handleDeletedTI(theObject.CM_TrackedItem, true);
		elseif theObject.isKindOf(CM_WorkListEntry) then		// TFS 42872
			self.handleDeletedWLE(theObject.CM_WorkListEntry);  // TFS 42872
		endif;
		return;
	endif;
	
	if theObject &lt;&gt; null then
		if theObject.isKindOf(CM_TrackedItem) then
			ti := theObject.CM_TrackedItem;
			self.updateTI(ti);
		elseif theObject.isKindOf(CM_WorkListEntry) then		// TFS 42109
			wle := theObject.CM_WorkListEntry;					// TFS 42872
			ti := wle.myTrackedItem;							// TFS 42109
			if ti &lt;&gt; null then									// TFS 42109
				self.updateTI(ti);								// TFS 42109
			endif;												// TFS 42109
			self.updateWLE(wle);								// TFS 42872
		endif;
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tableRowChange" id="c0c09870-6698-44c6-a6cc-e4203459d5b6">
        <updating/>
        <source>tableRowChange(_table : CM_DataTable input; _newRow : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 14/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 17/07/2019	jlgzm1		TFS 42872 JMT - Direct Release Between HOLD Voyages and Rail - All Cargo Types
//
vars
	obj : CM_Object;
	
begin
	self.myCurrentWLE := null;	//TFS 42872
	self.myCurrentTrackedItem := null;
	self.myCurrentContextTbl := _table;
	
	obj := _table.accessRow(_newRow).itemObject.CM_Object;
	if not global.isValidObject(obj) then
		return;
	endif;
	if obj.isKindOf(CM_TrackedItem) then
		self.myCurrentTrackedItem := obj.CM_TrackedItem;
		self.showDLRDischargeFields(_table, null);							// TFS 3516

	elseif obj.isKindOf(CM_WorkListEntry) then		//TFS 42872
		self.myCurrentWLE := obj.CM_WorkListEntry;	//TFS 42872
	endif;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_newRow" type="Integer"/>
    </JadeMethod>
