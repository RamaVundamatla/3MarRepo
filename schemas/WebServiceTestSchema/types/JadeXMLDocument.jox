<Class name="JadeXMLDocument">
    <JadeMethod name="returnAsObject" id="799e8a6a-6c96-49df-a3ba-0d0901aada12">
        <source>returnAsObject(_transient : Boolean;
			   _createdObjects : ObjectSet input) : Object;

/*

Purpose:			


Return Value:		


Date		Who		Reason
12 December 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars
	root			: JadeXMLElement;
	className		: String;
	cls				: Class;
	obj				: Object;
	
begin
	root := self.rootElement;
	if root = null then
		return null;
	endif;
	
	return root.returnAsObject(_transient, _createdObjects);
	
	
epilog

end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
