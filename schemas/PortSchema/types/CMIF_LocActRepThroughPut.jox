    <JadeMethod name="setFromLocationActivity" id="df3ad571-0f0d-4099-b3be-87300611e155">
        <updating/>
        <source>setFromLocationActivity( _locAct : CMEVT_LocationActivity; _serviceDate : Date; _count : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	

begin

	self.count := _count;
	self.exportToId := _locAct.getExportId;
//	self.id := _locAct.getDisplayString();
	self.id := _locAct.getDisplayStringForLineRep( null, true );	//23 Jul 2021	NDL TFS 51616
	self.modeString := _locAct.directionMode;
	self.modeInt := _locAct.movementDirection;
	self.myCargoType := _locAct.getCargoType;
	self.myOperator := _locAct.getOperator;
	self.serviceDate := _serviceDate;
	self.typeString := _locAct.directionType;
	self.weight := _locAct.weight;
	self.voyageGroupCode := _locAct.getVoyageGroupCode();

epilog

end;</source>
        <Parameter name="_locAct" type="CMEVT_LocationActivity"/>
        <Parameter name="_serviceDate" type="Date"/>
        <Parameter name="_count" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="writeDebugLine" id="a2a861fa-169f-43d5-a67f-70f15bc5822b">
        <source>writeDebugLine():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	str : String;

begin

	str :=	self.myOperator.code &amp; ", " &amp; Tab &amp; 
			self.myCargoType.abbreviation &amp; ", " &amp; Tab &amp;
			self.typeString[1:3] &amp; ", " &amp; Tab &amp;
			self.modeString &amp; ", " &amp; Tab &amp;
			self.serviceDate.String &amp; ", " &amp; Tab &amp;
			self.id &amp; ", " &amp; Tab &amp;
			self.exportToId &amp; ", " &amp; Tab &amp; 
			self.getWeightAsST &amp; ", " &amp; Tab &amp;
			self.count.asStringJMT &amp; ", " &amp; Tab &amp;
			self.voyageGroupCode;
			
	return str;


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
