    <JadeMethod name="create" id="3c00f124-876e-4799-a588-9c3e8d4e8a9e">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     19 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.snapShotDateTime := app.actualTimeServer();

end;</source>
    </JadeMethod>
    <JadeMethod name="deleted" id="2f85da20-6edf-4e47-8861-207599bd4318">
        <methodInvocation>mapping</methodInvocation>
        <source>deleted(set: Boolean; _value: Boolean io) mapping;
//----------------------------------------------------------------
//	Created:	12 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	txn		: CM_Transaction;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;	
	endif;

	txn := self.getMyTransaction();		// PAR 15848
	if txn = null then
		return;
	endif;
	
	//really only applies to TITransactions (others always false)
	_value := txn.isDeleted();
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
