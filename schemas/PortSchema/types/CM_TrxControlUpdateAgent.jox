    <JadeMethod name="trxUpdateInvoiceAllocation" id="9fe9743d-68ad-4fa9-ada7-4cad3fcf03e6">
        <updating/>
        <source>trxUpdateInvoiceAllocation(pProxyObj : CM_InvoiceAllocation input;
						   pAllTransientCriteriaObj : CMIF_Array;
						   _new : Boolean;
						   pYardAllocationObj : CM_InvoiceAllocation io;
						   _passport : CM_Passport input) updating;
// ----------	----------	-------------------------------------------------------
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
// 20/04/2023	navkc1	Bug 57628: CUX-Adding Criteria to Transaction Mapping allocation configuration results in error
// --------------------------------------------------------------------------------
vars
	cmifObject		: CMIF_Object;
	transientObj	: CMIF_YACriteriaPriority;
	proxyObj		: CM_YACriteriaPriority;
	priorityValue	: Real;
	sortValue		: Real; //20/04/2023	navkc1	Bug 57628 Needs to be the same type as receive
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do self.agtPassportExHandler(exception, _passport);
	on LockException do self.agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	sortValue	:=	0;
	
	// Now calculate the Yard Allocation priority values on the proxy objects, keeping the original order
	
	foreach cmifObject in pAllTransientCriteriaObj do
		transientObj	:=	cmifObject.CMIF_YACriteriaPriority;
		
		if transientObj.isDeleted then
			continue;
		endif;
		
		proxyObj		:=	transientObj.myProxy;
		priorityValue	:=	2 ^ sortValue;
		proxyObj.setPriorityValue(priorityValue);
		sortValue		:=	sortValue + 1;
	endforeach;
	
	// Start the transaction.
	
	beginTransaction;
	
	// Perform the operation.
	
	app.myUtilityUA.utlUpdateInvoiceAllocation(pProxyObj, pAllTransientCriteriaObj, _new, pYardAllocationObj, _passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pProxyObj" type="CM_InvoiceAllocation" usage="input"/>
        <Parameter name="pAllTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_new" type="Boolean"/>
        <Parameter name="pYardAllocationObj" type="CM_InvoiceAllocation" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateInvoiceCargoAlloc" id="a5eecd0d-022c-4ad8-bd16-68495e9bd255">
        <updating/>
        <source>trxUpdateInvoiceCargoAlloc(_update : Boolean;
					_load : Boolean;
					_clear : Boolean;
					_bulkUpdate : Boolean;
					_allTransientCriteriaObj	: CMIF_Array;				 
					 _tranMap : CM_TranMapCargoAllocation input; 
					 _invoiceAlloc : CM_InvoiceCargoAllocation input;
					 _realAlloc : CM_InvoiceCargoAllocation io) updating;

/*
Purpose:			
Date				Who			Reason
MARCH 2015			CNWAB1		Initial creation
19 Jun 2017			cnwma1 		TFS #4498 JMT - Cargo Allocation Fix Up Export Script
15 Nov 2017 		jlgmd1		TFS #7659 STWO - FW: Transaction Map: PROBLEM
20/04/2023			navkc1		Bug 57628: CUX-Adding Criteria to Transaction Mapping allocation configuration results in error
*/
vars
	sortValue, priorityValue : Real; //20/04/2023	navkc1	Bug 57628 Needs to be the same type as receive
	cmifObject : CMIF_Object;
	transientObj	: CMIF_YACriteriaPriority;
	proxyObj : CM_YACriteriaPriority;
	qrm : CM_QuantityRangeMap;
	yaCritieria : CM_YACriteria;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(app.myPassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, app.myPassport);
	on LockException do agtPassportLockExHandler(exception, app.myPassport);
	
	app.setContinueCMExceptions(false);
	sortValue	:=	0;
	
	// Now calculate the Yard Allocation priority values on the proxy objects, keeping the original order
	
	foreach cmifObject in _allTransientCriteriaObj do
		transientObj	:=	cmifObject.CMIF_YACriteriaPriority;
		
		if transientObj.isDeleted then
			continue;
		endif;
		
		if app.myPassport.hasErrors then
			break;	// TFS 7659
		endif;
		
		proxyObj		:=	transientObj.myProxy;
		priorityValue	:=	2 ^ sortValue;
		proxyObj.setPriorityValue(priorityValue);
		sortValue		:=	sortValue + 1;
	endforeach;
	
	if app.myPassport.hasErrors then
		return;		// TFS 7659
	endif;
	
	beginTransaction;	
	if _realAlloc &lt;&gt; null  then  //19/06/2017 cnwma1 TFS #4498
		if _load then
			foreach  yaCritieria in _realAlloc.allCriteria do
			
				delete yaCritieria;
			endforeach;
		endif;
	endif;
	app.myUtilityUA.utlUpdateInvoiceCargoAlloc(_update, _bulkUpdate, _allTransientCriteriaObj, _tranMap, _invoiceAlloc, _realAlloc);       //14/06/2017 cnwma1 TFS #4498
	
	if _realAlloc &lt;&gt; null then
		if _clear then //19/06/2017 cnwma1 TFS #4498
			foreach  qrm in _realAlloc.myQuantityMap.allQuantityRanges  do
			
				delete qrm;
			endforeach;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(app.myPassport);
end;</source>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_load" type="Boolean"/>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_bulkUpdate" type="Boolean"/>
        <Parameter name="_allTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_tranMap" type="CM_TranMapCargoAllocation" usage="input"/>
        <Parameter name="_invoiceAlloc" type="CM_InvoiceCargoAllocation" usage="input"/>
        <Parameter name="_realAlloc" type="CM_InvoiceCargoAllocation" usage="io"/>
    </JadeMethod>
