    <JadeMethod name="getXMLSettingsForSave" id="6a73e7be-d265-477b-ab15-097a4ab6d8b5">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
//08 Dec 2011	NDL	Par 28797
vars

	xmlStr	: String;
	entRow	: EntTableRow;	
begin
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; self.tblData.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblPlanned.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblAll.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourPlanned, self.xmlColourPlanned.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourNonPlanned, self.xmlColourNonPlanned.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourOnTrain, self.xmlColourOnTrain.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XMLTag_DefaultSummaryFunction, self.defaultDblClickFunction.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagIncludeUnassigned, self.chkUnassigned.value.String);	// 22206 Apr 2011 save 'include unassigned' option
	return xmlStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="d50034c4-a2d4-4a81-af5c-62b29cfae603">
        <updating/>
        <source>getXMLSettingsForSetup() updating;

vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	flipH, flipV, hideL,hideT,hideM : Boolean;
	zoomScale : Real;
begin
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
		if userWindow = null then
			return;
		endif;
	endif;

	theXML := userWindow.xmlInfo;
		// #### HIDE MACRO
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HM);
 	hideM := false;
 	if theXMLValue &lt;&gt; null then
 		hideM := theXMLValue.Integer.Boolean;
 	endif;
	
	self.xmlMacro := hideM;

end;
</source>
    </JadeMethod>
    <JadeMethod name="handleFunctionForObject" id="4a5b14a6-7ea3-46cd-bad0-d00c39d61c9e">
        <updating/>
        <source>handleFunctionForObject(_function: Integer; _allSummariesObj: CMIF_LoadListSummaryObjectSet; _columnKey: Integer) updating;
//----------------------------------------------------------------
//	Created:	16 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	includeDestPort	: Boolean;
	objArray		: CM_ObjectArray;
	cargoEnqForm	: CM_ContainerEnqForm;
	masterTI		: CM_TrackedItem;
	allObjects		: ObjectSet;
	theENQ			: CM_EnquiryController;
	summaryObj		: CMIF_LoadListSummaryObject;
begin
	create objArray transient;
	
	// epr par 16713 deleted all the saving xml on the self.btnQuitSmmryMode.helpKeyword WTF??? 
	
	foreach summaryObj in _allSummariesObj do
		self.getTIsForColumnKey(objArray, summaryObj.allTrackedItems, _columnKey);
	endforeach;
	
	if objArray.isEmpty then
		return;
	endif;
	
	if _function = self.Function_Enquiry then
		masterTI := objArray.first.CM_TrackedItem;
		cargoEnqForm := self.myAssistant.showCargoEnquiryForTIs(masterTI, objArray,	self.myMasterMenuAction, false);
		if cargoEnqForm = null then
			return;
		endif;
		cargoEnqForm.tblData.clearAllSelected();
		cargoEnqForm.tblData.selectObject(masterTI, true);
		
	elseif _function = self.Function_LocateGridRows then
		// 29015 Feb 2012 include destination port if called from summary tab but not from the other tabs
		if self.fldMain.topSheet = self.shtSummary then
			includeDestPort := true;
		else
			includeDestPort := false;
		endif;
	
		create allObjects transient;
		objArray.copy(allObjects);
		theENQ := self.myAssistant.YRD_Assistant.doGetSelectorTIsLoadList(allObjects, self.myCurrentTrain, includeDestPort);
	
		self.myAssistant.showYardRowEnquiryForm(allObjects, self.myMasterMenuAction,  theENQ, true, VIEW_DESTPORT, 3, self.myCurrentTrain);
		
	elseif _function = self.Function_ShowInLoadList then
		//make sure DLRs are showing
//		self.doQuerySelectorDLR();
		self.mode := self.Mode_SummarySelection;
		self.showTableRowsForObjects(objArray, _columnKey);
		self.statusStub := _allSummariesObj.getCaptionDisplay();
		self.frmStatLine.caption := self.statusStub;// &amp; " " &amp; $SHP_Summary_Selection_Mode;
		self.doFldMainClick();
		self.btnQuitSmmryMode.enabled := true;
	endif;
epilog
	delete objArray;

end;</source>
        <Parameter name="_function" type="Integer"/>
        <Parameter name="_allSummariesObj" type="CMIF_LoadListSummaryObjectSet"/>
        <Parameter name="_columnKey" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="640bf817-100b-412c-81e7-80c75a9515af">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
//----------------------------------------------------------------
//	Created:	27 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _userWindow = null then
		return;
	endif;

	inheritMethod(_userWindow);

	self.defaultDblClickFunction := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XMLTag_DefaultSummaryFunction).Integer;
	self.xmlColourPlanned := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagColourPlanned).Integer;
	self.xmlColourNonPlanned := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagColourNonPlanned).Integer;
	self.xmlColourOnTrain := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagColourOnTrain).Integer;
	self.setColours();
	self.chkUnassigned.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagIncludeUnassigned).Boolean;	// 22206 Apr 2011 save 'include unassigned' option
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="777c9e18-efe5-4bb3-8172-0c6bfcf7c4df">
        <source>initQueryFrame() protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
constants
	HorzGap = 5;
vars
	sht			: CMUI_Sheet;
	lstTable	: CMUI_ListTable;
begin
	
	sht := self.shtQuery1;
	sht.caption := app.getErrorString(Train);
	self.cmbTrainNote.left := HorzGap;
	self.cmbTrainNote.width := self.cmbTrainNote.parent.width - (HorzGap * 2);
	sht.visible := true;
	
	sht := self.shtQuery2;
	sht.caption := app.getErrorString(CargoTypes);
	lstTable := self.lstCargoTypes;
	lstTable.width := sht.clientWidth;
	lstTable.height := sht.clientHeight;
	sht.visible := true;

	sht := self.shtQuery3;
	sht.caption := app.getErrorString(Operators);
	lstTable := self.lstOperators;
	lstTable.width := sht.clientWidth;
	lstTable.height := sht.clientHeight;
	sht.visible := true;
	
	sht := self.shtQuery4;
	sht.caption := app.getErrorString(Destinations);
	lstTable := self.lstPorts;
	self.chkAllPorts.visible := true;
	lstTable.top := 20;
	lstTable.width := sht.clientWidth;
	lstTable.height := sht.clientHeight - lstTable.top;
	sht.visible := true;
	
	sht := self.shtQuery5;
	sht.caption := app.getErrorString(Cargo_position);
	sht.visible := true;
	self.lblCargoPos.width := sht.clientWidth - 25;
	
	//03 Nov 2009	NDL	Par 21519
	sht := self.shtQuery6;
	sht.caption := app.getErrorString(INV_On_Ship);
	lstTable := self.lstVoyages;
	lstTable.width := sht.clientWidth;
	lstTable.height := sht.clientHeight;
	sht.visible := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initSummaryTable" id="ed359cb1-bc46-4030-bfc5-292230dc182d">
        <source>initSummaryTable();
//----------------------------------------------------------------
//	Created:	15 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------
// 29/10/2010	cnwdap1		PAR #23794 CCMS MES 1102 Show release requests on rail load list
vars
	int			: Integer;
	tbl			: CM_DataTable;
	colHeading1	: String;			// PAR #23794
	colHeading2	: String;			// PAR #23794
begin
	tbl := self.tblSummary;
	
	tbl.clear();
	tbl.selectionType	:= CM_BaseTable.SelectionType_Row;
	
// cnwdad1 13/12/2005 - CCMS #1418.
//	tbl.selectMode		:= Table.SelectMode_Row;//SelectMode_WholeRows;
	tbl.selectMode		:= Table.SelectMode_WholeRows;
	tbl.multiSelect		:=	CM_BaseTable.MultiSelect_Simple;
	tbl.fixed3D 		:= false;
	tbl.rows			:= 2;
	tbl.fixedRows		:= 2;
	tbl.fixedColumns	:= 0;
	tbl.gridLines		:= true;
	tbl.gridColor		:= Grey;
	// PAR #23794 CCMS MES 1102 add extra colums for release requests if config says so
	if self.myTerminal.getConfig(ShowRelReqOnRailLoadList).Boolean then
		tbl.columns		:= 13;
		tbl.columns		:= 13;
	else
		tbl.columns		:= 9;
		tbl.columns		:= 9;
	endif;
	self.setColorsForTable(self.tblSummary);

	foreach int in 1 to tbl.fixedRows do
		tbl.accessRow(int).alignment := Table.Alignment_Left;
	endforeach;
	
	foreach int in 5 to (tbl.columns-1) do
		tbl.accessColumn(int).alignment := Table.Alignment_Right;
	endforeach;

	tbl.accessColumn(2).width := 100;
	tbl.accessColumn(3).width := 100;
	tbl.accessColumn(4).width := 100;
	
	self.doHideSummaryColumn(5);//cnwas3 PAR 21680
	
	tbl.accessColumn(tbl.columns).alignment := Table.Alignment_Center;
	
//	tbl.accessCell(1, 2).text := "Train"&amp; Tab &amp; "Destination"	&amp; Tab &amp; "   ISO"	&amp; Tab &amp; "Colour Code  "		&amp; Tab &amp; "Load"	&amp; Tab &amp; "Load  "	&amp; Tab &amp; "Load  "		&amp; Tab &amp; "Special";
//	tbl.accessCell(2, 2).text := ""		&amp; Tab &amp; ""				&amp; Tab &amp; "Grouping"	&amp; Tab &amp; "(all operators) "	&amp; Tab &amp; "Total"	&amp; Tab &amp; "Planned"	&amp; Tab &amp; "Non-Planned"	&amp; Tab &amp; "Stows";
	
	// PAR #23794 CCMS MES 1102 add Release Request headings if terminal config says to show them
	colHeading1 := app.getErrorString(LL_Train) &amp; Tab &amp; 
					app.getErrorString(LL_Destination)	&amp; Tab &amp; 
					app.getErrorString(LL_ISO)	&amp; Tab &amp; 
					app.getErrorString(LL_Colour_code) &amp; Tab &amp; 
					app.getErrorString(LL_Load)	&amp; Tab &amp; 
					app.getErrorString(LL_Load)	&amp; Tab &amp; 
					app.getErrorString(LL_Load)	&amp; Tab;
	if self.myTerminal.getConfig(ShowRelReqOnRailLoadList).Boolean then
		colHeading1 := colHeading1 &amp; app.getErrorString(LL_ReleaseRequest) &amp; Tab &amp;
					app.getErrorString(LL_ReleaseRequest) &amp; Tab &amp;
					app.getErrorString(LL_ReleaseRequest) &amp; Tab &amp;
					app.getErrorString(LL_ReleaseRequest) &amp; Tab;
	endif;
	colHeading1 := colHeading1 &amp; app.getErrorString(LL_Special);
	
	colHeading2 := ""		&amp; Tab &amp; ""				&amp; Tab &amp; 
					app.getErrorString(LL_Grouping)	&amp; Tab &amp; 
					app.getErrorString(LL_ALLOPS) 	&amp; Tab &amp; 
					app.getErrorString(LL_Total)		&amp; Tab &amp; 
					app.getErrorString(LL_Planned)	&amp; Tab &amp; 
					app.getErrorString(LL_Nonplanned)	&amp; Tab;
	if self.myTerminal.getConfig(ShowRelReqOnRailLoadList).Boolean then
		colHeading2 := colHeading2 &amp; app.getErrorString(LL_Total) &amp; Tab &amp;
					app.getErrorString(LL_Planned) &amp; Tab &amp;
					app.getErrorString(LL_Nonplanned) &amp; Tab &amp;
					app.getErrorString(LL_Assigned) &amp; Tab;
	endif;
	colHeading2 := colHeading2 &amp; app.getErrorString(LL_Stows);
	
	tbl.accessCell(1, 2).text := colHeading1;
	tbl.accessCell(2, 2).text := colHeading2;
/*	tbl.accessCell(1, 2).text := 	app.getErrorString(LL_Train) &amp; Tab &amp; 
											app.getErrorString(LL_Destination)	&amp; Tab &amp; 
											app.getErrorString(LL_ISO)	&amp; Tab &amp; 
											app.getErrorString(LL_Colour_code) &amp; Tab &amp; 
											app.getErrorString(LL_Load)	&amp; Tab &amp; 
											app.getErrorString(LL_Load)	&amp; Tab &amp; 
											app.getErrorString(LL_Load)	&amp; Tab &amp; 
											app.getErrorString(LL_Special);
	tbl.accessCell(2, 2).text := ""		&amp; Tab &amp; ""				&amp; Tab &amp; 
											app.getErrorString(LL_Grouping)	&amp; Tab &amp; 
											app.getErrorString(LL_ALLOPS) 	&amp; Tab &amp; 
											app.getErrorString(LL_Total)		&amp; Tab &amp; 
											app.getErrorString(LL_Planned)	&amp; Tab &amp; 
											app.getErrorString(LL_Nonplanned)	&amp; Tab &amp; 
											app.getErrorString(LL_Stows);*/
	// PAR #23794 CCMS MES 1102 end
end;</source>
    </JadeMethod>
    <JadeMethod name="initTable" id="21eb0ad9-6a7e-4e4c-ab1a-996770f60055">
        <updating/>
        <source>initTable() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.initTableData(ETDef_LlHeadings);	
	self.tblData.fixedColumns := 0;
	self.tblData.fixed3D := true;
	self.tblData.accessColumn(1).width := 30;
	self.tblData.selectMode := Table.SelectMode_Multiple;
	self.tblData.multiSelect := CM_BaseTable.MultiSelect_Simple;

	self.tblData.selectionType := Table.SelectMode_FixedRow;
	self.tblData.multiSelect := CM_BaseTable.MultiSelect_Simple;


end;</source>
    </JadeMethod>
    <JadeMethod name="initTableData" id="4ff4d5d1-0b07-4a7a-ab9e-4e2c024601ed">
        <updating/>
        <source>initTableData(_theEntDef: String) updating;
// ---------------------------------------------------------------------------
// Created:     20 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
//08 Dec 2011	NDL	Par 28797
vars
	entTableView	: EntTableView;
	entTableDef		: EntTableDef;
	theTable		: CM_DataTable;
begin

	inheritMethod(_theEntDef);
	
	// Data table
	theTable := self.tblData;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;
	theTable.allowDragSelect := true;
	// use dynaDict to sort table as jade cannot sort more than 3 columns
	theTable.initTableObjectsDynaDict(CM_TrackedItem, theTable.myEntTableDef.allEntTableRows.size);

	// ################
	// ### PLANNED
	// ################
	theTable := self.tblPlanned;
	
	
	theTable.userInputEnabled := false;
	theTable.allowDragSelect := true;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	
	entTableDef := app.myController.getEntTableDef(_theEntDef);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;
	// use dynaDict to sort table as jade cannot sort more than 3 columns
	theTable.initTableObjectsDynaDict(CM_TrackedItem, theTable.myEntTableDef.allEntTableRows.size);
	

	// ################
	// ### All
	// ################
	theTable := self.tblAll;
	
	
	theTable.userInputEnabled := false;
	theTable.allowDragSelect := true;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(_theEntDef);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;
	// use dynaDict to sort table as jade cannot sort more than 3 columns
	theTable.initTableObjectsDynaDict(CM_TrackedItem, theTable.myEntTableDef.allEntTableRows.size);


end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="2e131711-c9ad-401a-9e63-2e6bd8dcb80b">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		23 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	inheritMethod(keyCode, shift);
	if keyCode = CMUI_Key_Esc then
		delete app.myMoveController;
		app.myDraggedTrackedItem := null;
		app.isDragging := false;
		self.tblData.dragMode := self.DragMode_None;
		
		return;
	elseif keyCode = J_key_A then
		if shift.isControlKeyPressed()
		and not shift.isShiftKeyPressed()
		and not shift.isAltKeyPressed() then
			self.btnSelectAllTIs.click(btnSelectAllTIs);
		endif;
	elseif keyCode = J_key_F8 then //epr 1/10/13 32613 
		self.doMnuLLLocateGridAreaClick();
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="e946c6b3-2150-497d-97a6-4d9494874a07">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      03 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	tmpH : Integer;
	regKeys : IntegerArray;
begin
	self.frmUserColours.visible := false;
	self.frmAssignTrain.visible := false;
	self.splMain.stretchHeight := true;
	
	self.splMain.parent := self.shtNonplanned;
	self.fldMain.move(0,self.frmToolbar.clientHeight,self.clientWidth,self.clientHeight);
	self.splMain.top := 0;
	self.splMain.height := self.shtNonplanned.clientHeight;
	tmpH := self.clientHeight - self.frmStatLine.clientHeight - self.frmToolbar.clientHeight - 10;
	self.fldMain.move(0,self.frmToolbar.clientHeight + 2,self.clientWidth,tmpH);
//	self.splMain.cnEcResizeContents();
	self.fldMain.cnEcResizeContents();
	self.fldMain.useSheetBackColors := true;
	self.fldMain.useSheetBackColors := true;
	self.fldMain.setDefaultSheetBackColors();
	self.fldMain.initSheetBackColors();

	create regKeys transient;
	regKeys.add(CMUI_Key_Esc);
	self.addRegisteredKeys(regKeys);


epilog
	delete regKeys;

end;</source>
        <access>protected</access>
    </JadeMethod>
