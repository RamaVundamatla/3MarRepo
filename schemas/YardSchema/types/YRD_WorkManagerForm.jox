	endif;
	
	self.frmSearcher.top := 65;
	// 36957 make the searcher wider for the longer to do task descriptions
	self.frmSearcher.width := 800;
	self.fldSearch.width := 785;
	self.mltTasks.width := 760;
	self.mltTasks.repositionAfterResize();
	self.frmQueryToolbar.positionToolbarControls();
	self.frmSearcher.centreHorizontallyInParent();
	
	self.frmSearcher.zOrder(1);

	self.frmSearcher.visible := true;

	self.mskDateFrom.setFocus();
	
epilog

end;</source>
