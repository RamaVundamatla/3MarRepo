    <JadeMethod name="btnSettings_click" id="1f6aa991-3018-423f-b737-1dde3cb543b8">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSettings_click(btn: Button input) updating;
// dh 16/6/2008 - this is a temporary way of setting flags on a file type.
//     It will need to be replaced when users can set user hooks on edi file fields. 
vars
	settingsForm	: CMUI_EDIFileTypeSettingsForm;
	fileType		: CM_EDIFileTypeUser;
	
begin
	fileType	:=	self.cmbFileDef.listObject.CM_EDIFileTypeUser;
	
	create settingsForm transient;
	settingsForm.createMyAssistant(CMUI_Assistant);
	settingsForm.setForDateFileType(cmbEDIDataType.itemData[self.cmbEDIDataType.listIndex], self.allSelectedErrors);
	settingsForm.chkPinReqd.value 	:= blnSettingPin;
	settingsForm.chkSkipDuplicate.value := blnSettingSkip;
	settingsForm.chkCreateBookings.value := blnSettingsBookings;
	settingsForm.chkInvalidVoyage.value := blnSettingsVoyage;	//03 Jan 2019	NDL	TFS 42303
	settingsForm.showModal();
	
	if settingsForm.modalResult = IDOK then
		self.blnSettingPin	:= settingsForm.chkPinReqd.value;
		self.blnSettingSkip	:= settingsForm.chkSkipDuplicate.value;
		if settingsForm.chkCreateBookings.visible then
			self.blnSettingsBookings := settingsForm.chkCreateBookings.value;			
		endif;
		if settingsForm.chkInvalidVoyage.visible then	//03 Jan 2019	NDL	TFS 42303
			self.blnSettingsVoyage := settingsForm.chkInvalidVoyage.value;			
		endif;
		
		if cmbEDIDataType.itemData[self.cmbEDIDataType.listIndex] = EDIDataType_Tranship then
			self.allSelectedErrors.clear();
			settingsForm.mulSelect1.getSelected(allSelectedErrors);
		endif;
	endif;
epilog
	delete settingsForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildHookFieldNewList" id="b2b0de23-5394-4f92-bd17-fbf979ddde17">
        <source>buildHookFieldNewList(_table :CM_DataTable input): ObjectArray;
/*
Purpose:			
Parameters:			
Return Value:		

Date				Who		Reason
11 September 2008	cnwrd1	Initial creation
01 October 2008		consw1	Par 17090 Replace app.getMyTerminal with self.myTerminal	
24/09/2009			cnwcs5	par 20320 Multiple record types (use cloned controls)
11/03/2015			cnwmh5	Tranisent Leaks
*/

vars
	stringArray			: StringArray;
	index				: Integer;
	rowsArray 			: ObjectArray;
	etDef				: EntTableDef;
	mapTable			: CM_DataTable;
	entRow				: EntTableRow;
	fieldName			: String;
begin
	// get all ETDef's for the selected type
	create stringArray transient;
	self.getTINamesForDataType (self.cmbEDIDataType.itemData[self.cmbEDIDataType.listIndex], stringArray);
	
	// get the one that matches _table
	index		:= _table.index;
	etDef 		:= app.myController.getEntTableDef(stringArray[index + 1]);
	mapTable	:= self.tblFieldMap.getControl (index);
	
	// build collection of rows that be selected - only those that are not already mapped or have hook code
	create rowsArray transient;

	foreach entRow in etDef.allEntTableRows do
		if entRow.name = ETRow_HasChanged then
			continue;
		endif;
		
		fieldName := entRow.getHeading(null, self.myTerminal, app.myCurrentLocale);
	
		if not self.fieldHasHookCode( fieldName, _table ) and not self.hasFieldMapped ( fieldName, mapTable)  then
			rowsArray.add ( entRow ) ;
		endif;
	endforeach;

	return rowsArray;
epilog
	delete stringArray;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <ReturnType type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="canHaveSettings" id="b3cb6582-ce2f-49c3-9fcc-87705ed5acd1">
        <source>canHaveSettings():Boolean;
// dh 16/6/2008 for warehousing - this is a temporary fix to allow special flags to be set on the 
// prenotes file 
vars

begin
	return self.cmbEDIDataType.listIndex &gt;= 1
		//and cmbEDIDataType.itemData[self.cmbEDIDataType.listIndex] = EDIDataType_Prenote;
		and ((cmbEDIDataType.itemData[self.cmbEDIDataType.listIndex] = EDIDataType_Prenote)
			or (cmbEDIDataType.itemData[self.cmbEDIDataType.listIndex] = EDIDataType_Tranship)  // ccms 1660 change
			or (self.cmbEDIDataType.listData = EDIDataType_LoadList)); //epr par 37430 21/1/16
//	and (app.myRoot.client = Client_PortNelson
//	or app.getMyUser.code[1:3] = 'CNW');
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
