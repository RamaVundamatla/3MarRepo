    <JadeMethod name="loadSelectionCombos" id="dace0711-84c2-4683-bd1c-f684a6b6c2a2">
        <updating/>
        <source>loadSelectionCombos() protected, updating;

vars
	voyage		: String;
	terminal	: CM_Terminal;
	tmpVoyage	: CM_Voyage;
	globalVoy	: CM_VoyageGlobal;
begin

	self.myLogVoyage := null;
	
	if self.modeInterTerminal then
		tmpVoyage := self.cmbVoyOtherTerm.listObject.CM_Voyage;
		//terminal := self.cmbVoyOtherTerm.listObject.CM_Terminal;
		//par 14934 so as to dispay  the LOT  details 
		//if tmpVoyage.isKindOf(CM_LogVoyage) then
		self.myLogVoyage := tmpVoyage;
		//endif;
	else
		terminal := self.myTerminal;
		voyage := self.tblSelection.getValueByName(ETRow_VoyageGlobal).String;
		if terminal &lt;&gt; null then
			self.myLogVoyage := terminal.lookupVoyage(voyage, null, false).CM_Voyage;
		endif;
	endif;
	
	if self.myLogVoyage &lt;&gt; null and self.myLogVoyage.myLogVoyageStructure &lt;&gt; null then
		self.cmbDocket.listCollection(self.myLogVoyage.allBOLOutByTypeStatusNumDT, true, 0);
		self.cmbLot.listCollection(self.myLogVoyage.myLogVoyageStructure.allLogLots, true, 0);
	else
		self.cmbDocket.clear;
		self.cmbLot.clear;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadSelectionData" id="2f8d97d5-5871-4bd6-86aa-9e47cec7d910">
        <source>loadSelectionData() protected;

vars
	entDef : EntTableDef;
begin

	if self.selection = DOCKET then
		//self.tblSelectData.setColumnHeadingsFromDef(ETDef_TAOffLoadDocket, false);
		entDef := app.myController.getEntTableDef(ETDef_TAOffLoadDocket);
	elseif self.selection = NONUMBER then
		//self.tblSelectData.setColumnHeadingsFromDef(ETDef_TAOffLoadNoNumber, false);
		entDef := app.myController.getEntTableDef(ETDef_TAOffLoadNoNumber);
	elseif self.selection = LOT then
		//self.tblSelectData.rows := 0;
//		entDef := app.myController.getEntTableDef(ETDef_TAOffLoadLot);
		entDef := app.myController.getEntTableDef(ETDef_TAOffLoadLot);
//		self.tblSelectData.setTblDataEntRowsFromDef(entDef);
	else
		return;
	endif;
	
	if entDef &lt;&gt; null then	
		self.tblSelectData.setTblDataEntRowsFromDef(entDef);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
