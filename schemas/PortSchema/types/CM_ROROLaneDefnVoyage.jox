    <JadeMethod name="getPointsForNewLanePosition" id="8e3bbb75-433e-4d9f-9ae1-f4eb6193dbe8">
        <source>getPointsForNewLanePosition(_points : PointArray input; _posDefn : CM_ROROLanePositionDefn);
/*
Purpose:	We are creating a position within a lane. 
				We fill right to left
				The Y values will be the same as the lane. 
				The X values are set as the first space within the lane minus the passed in  length
Date				Who			Reason
DECEMBER 2011		CNWAB1		Initial creation
*/

vars
	req : CM_RORORequest;
	sortDict : CM_ObjectByX1Y1X2Y2Dict;
	theLayout : CM_DeckItemLayout;
	thePosition : CM_ROROLanePositionController;
	theLayoutPoints : PointArray;
	obj : Object;
	iter : Iterator;
	aPoint : Point;
	theGap : Integer;
	locationLength : Integer;
	x1, y1, x2, y2, defnX1, defnX2, defnY1, defnY2, lastX1, lastX2, newX1, newX2 : Integer;
begin
	if _points = null then
		return;
	endif;

	locationLength := (_posDefn.length * ROROStructurePixelsPerMetre).Integer; //TFS 39254 _posDefn.length is in metres so need to multiply it up for pixels
	if locationLength &lt; 10 then
		locationLength := 10; // Minimum 1 metre
	endif;
	
	defnX1 := self.myLayout.myPolygonPixels[1].x;
	defnX2 := self.myLayout.myPolygonPixels[2].x;
	defnY1 := self.myLayout.myPolygonPixels[1].y;
	defnY2 := self.myLayout.myPolygonPixels[3].y;
	
	if self.myLaneController.allLanePositionsLCs.size = 1 then
		_points.clear();
		
		aPoint.set(defnX2 - locationLength, defnY1); _points.add(aPoint);
		aPoint.set(defnX2, defnY1); _points.add(aPoint);
		aPoint.set(defnX2, defnY2); _points.add(aPoint);
		aPoint.set(defnX2 - locationLength, defnY2); _points.add(aPoint);
		aPoint.set(defnX2 - locationLength, defnY1); _points.add(aPoint);
		return;
	endif;
	
	
	// ### SORT BY X1, We want reversed so sort by X2 then X1
	create sortDict transient;
	iter := sortDict.createIterator();
	foreach thePosition in self.myLaneController.allLanePositionsLCs discreteLock do
		theLayout := thePosition.myLanePositionDefn.myLayout;
		theLayoutPoints := theLayout.myPolygonPixels;
		
		sortDict.putAtKey(theLayoutPoints[2].x, 0,theLayoutPoints[1].x,0,theLayout);
	endforeach;
	
	// ### Find gap
	lastX1 := defnX1;
	lastX2 := defnX2;
	iter.startAtObject(sortDict.last());
	while iter.back(obj) do
		sortDict.getIteratorKeys(x2, y1, x1, y2, iter);
		
		if x2 = lastX2 
		or  (x2 + 10) &gt;= lastX2 then // Add 1 metre
			lastX2 := x1;
			continue;
		endif;
		
		// Room for a poly on the right - minimum is 1 metre
		
		lastX1 := x2;
		break;
		
	endwhile;
	
	theGap := 5; // 1/2 Metre gap
	
	_points.clear();
	/* WAS
	aPoint.set(lastX1 + theGap, defnY1); _points.add(aPoint);
	aPoint.set(lastX2 - theGap, defnY1); _points.add(aPoint);
	aPoint.set(lastX2 - theGap, defnY2); _points.add(aPoint);
	aPoint.set(lastX1 + theGap, defnY2); _points.add(aPoint);
	aPoint.set(lastX1 + theGap, defnY1); _points.add(aPoint);
	NOW */
	
	if (lastX2 - locationLength) &lt; defnX1 then
		app.raiseCMException4(Position_side_range, "X1", (lastX2 - locationLength).String, _posDefn.code, self.code, null, self);
	endif;
	
	aPoint.set(lastX2 - locationLength, defnY1); _points.add(aPoint);
	aPoint.set(lastX2 - theGap, defnY1); _points.add(aPoint);
	aPoint.set(lastX2 - theGap, defnY2); _points.add(aPoint);
	aPoint.set(lastX2 - locationLength, defnY2); _points.add(aPoint);
	aPoint.set(lastX2 - locationLength, defnY1); _points.add(aPoint);

epilog
	delete sortDict;
	delete iter;
end;</source>
        <Parameter name="_points" type="PointArray" usage="input"/>
        <Parameter name="_posDefn" type="CM_ROROLanePositionDefn"/>
    </JadeMethod>
    <JadeMethod name="getProposedTIs" id="f00ceb9b-41e0-4ea4-8146-067aeb3fb956">
