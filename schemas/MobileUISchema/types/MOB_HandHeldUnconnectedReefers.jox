    <JadeMethod name="tblReefers_mouseDown" id="3af2821c-1124-481a-8c88-f357e92ee639">
        <controlMethod name="Table::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReefers_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	rowClicked : Boolean;
	r,c : Integer;
begin
	rowClicked := table.getCellFromPosition(x, y, r,c);
	if button = Window.MouseButton_Right then		
		if r &lt;= table.fixedRows then
			rowClicked := false;
			table.clearAllSelected;
		else 
			// Set the cell that has been clicked on to be selected			
			table.accessRow(r).selected := true;
			table.row := r;
			self.setControlState;
		endif;
		// Refresh the table now otherwise we wont see which cell is truely
		// selected until after the popup menu disappears			
		table.refreshNow;
		
		buildContextMenu(table,self,true,x.Integer,y.Integer);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
