	dtoColorsIn.userColorBackTable		:=	_colorBackTableRT;
	dtoColorsIn.userColorForeTable		:=	_colorForeTableRT;
		
	setUserColorsRequest.dtoColors	:=	dtoColorsIn;
	setUserColorsRequest.stateInfo	:=	self.myStateObjIn;
	
