    <JadeMethod name="getRealSubClasses" id="9f8857b9-0cbd-4027-a18f-5607732a0045">
        <source>getRealSubClasses(_subClasses: ClassColl input; includeParentIfReal: Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2011	#cnwdz2	 

*/

vars
	class : Class;
	toDelete : ClassSet;
	tmpSchema	: Schema;

begin
	create toDelete transient;
	_subClasses.clear;

	class := self.getObjectClass();
	if class = null then
		return;
	endif;
	
	// As allSubClasses returns sub-schema copies of classes and
	// we need the actual classes. We need to do use PortSchema.getClass(class.name)
	// to ensure that we get the actual class instance and not the sub-schema copy of the class
	// RJS/DVD 30Dec03
	
	//class.allSubclasses(_subClasses);
	tmpSchema := rootSchema.getSchema(PortSchemaName);
	if tmpSchema = null then
		app.raiseUnexpectedProgramError(class.name, method.name, PortSchemaName &amp; ' not found');
		return;
	endif;
	
	class := tmpSchema.getClass(class.name);
	
	class.allSubclasses(_subClasses);
	if includeParentIfReal and not class.abstract then
		_subClasses.insert(1, class);
	endif;
	
	// Remove all abstract classes.  NB: Can't update an array during an iteration
	foreach class in _subClasses do // where class.abstract do
		class := tmpSchema.getClass(class.name);
		if class.abstract then
			toDelete.add(class);
		elseif class.name = CM_DailyReeferTemp.name then //rs 21/10/2003 we done want any of these
			toDelete.add(class);
		endif;
	endforeach;
	foreach class in toDelete do
		class := tmpSchema.getClass(class.name);
		_subClasses.remove(class);
	endforeach;
	
epilog
	delete toDelete;
end;</source>
        <Parameter name="_subClasses" type="ClassColl" usage="input"/>
        <Parameter name="includeParentIfReal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleInvalidObject" id="383a6628-7b02-4fb6-b05d-4cf925f09d02">
        <source>handleInvalidObject(_exc : Exception) : Integer;

/*

Purpose:			Handle invlaid object references when processing a field

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services

*/

vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	if _exc.errorCode = 4 then
		//write method.qualifiedName &amp; Tab &amp; _exc.errorObject.String;
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;
	
		
epilog
	return returnVal;
	
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initDataExtractCollectionField" id="70c3e6f7-dd1a-40ed-9f1f-639267b0826e">
        <source>initDataExtractCollectionField(_fields : CM_DataExtractFieldSet input; 
                               _childFieldClass : Class;
							   _fieldName, _niceName : String) : CM_DataExtractCollectionField protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 May 2011	#cnwdz2	 

*/

vars
	field        : CM_DataExtractCollectionField;
	fieldName,
	methodSource : String;
	strArray     : StringArray;
begin
	create field transient;
	field.initCollectionFieldProperties(_childFieldClass, _fieldName, _niceName);
	
	_fields.add(field);
	self.extractOrder.add(_fieldName);
	return field;
epilog
	delete strArray;
end;</source>
        <access>protected</access>
        <Parameter name="_fields" type="CM_DataExtractFieldSet" usage="input"/>
        <Parameter name="_childFieldClass" type="Class"/>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_niceName" type="String"/>
        <ReturnType type="CM_DataExtractCollectionField"/>
    </JadeMethod>
    <JadeMethod name="initDataExtractField" id="57d24523-9d07-481f-83b1-6b52c5617271">
        <source>initDataExtractField(_fields : CM_DataExtractFieldSet input; 
					_className, 
					_propertyPath, 
					_fieldName, 
					_fieldType, 
					_columnHeading, 
					_description, 
					_jmtFieldType, 
					_possibleValues : String) : CM_DataExtractField protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 May 2011	#cnwdz2	 

*/

vars
	field        : CM_DataExtractField;
	methodSource,
	key			 : String;
	strArray     : StringArray;
begin
	create field transient;
	methodSource := self.convertPropertyToString(_className, _propertyPath, _fieldName, _fieldType);
	key := _fieldName;
	if _propertyPath &lt;&gt; null then
		key := _propertyPath;
	endif;
	field.initProperties(key, _columnHeading, _description, _jmtFieldType, _possibleValues, methodSource);
	if _fields &lt;&gt; null and not self.extractOrder.includes(key) then		
		_fields.add(field);
		self.extractOrder.add(key);
	endif;
	return field;
epilog
	delete strArray;
end;</source>
        <access>protected</access>
        <Parameter name="_fields" type="CM_DataExtractFieldSet" usage="input"/>
        <Parameter name="_className" type="String"/>
        <Parameter name="_propertyPath" type="String"/>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_fieldType" type="String"/>
        <Parameter name="_columnHeading" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_jmtFieldType" type="String"/>
        <Parameter name="_possibleValues" type="String"/>
        <ReturnType type="CM_DataExtractField"/>
    </JadeMethod>
