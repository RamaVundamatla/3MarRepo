    <JadeMethod name="getStringForRespCode" id="c7a0b4fe-4c33-483e-bcc6-5268dec78d04">
        <source>getStringForRespCode():String;

begin
	// MOST COMMON CODES

	if self.respCode = "OK" then
		return "Approved - the Message processed correctly";
	elseif self.respCode = "FN" then
		return "Completed - using Test card";		
	elseif self.respCode = "00" then	// numeric
		return "APPROVAL";
	elseif self.respCode = "97" then	// numeric
		return "GOOD SETTLEMENT";
		
	// REMAINING BUYLINE CODES
								
	elseif self.respCode = "BE" then
		return "Batch Empty - there have been no successful transactions";
	elseif self.respCode = "BT" then
		return "Batch Transfer - the transaction is to be re-sent to the Host";
	elseif self.respCode = "CA" then
		return "Cancelled - the transaction has been cancelled";
	elseif self.respCode = "CO" then
		return "Completed - this authorisation has been completed";		
	elseif self.respCode = "IA" then
		return "Invalid Amount - the amount is not valid";
	elseif self.respCode = "IC" then
		return "Invalid Card - the card is not valid";
	elseif self.respCode = "IE" then
		return "Invalid Expiry - the expiry date is not valid";
	elseif self.respCode = "II" then
		return "Invalid IP address - the IP address is invalid for this OPS Id";
	elseif self.respCode = "IO" then
		return "Invalid OPS - the Order Processing System is invalid";
	elseif self.respCode = "IP" then
		return "Invalid Password - th epassword in the request is invalid";
	elseif self.respCode = "IR" then
		return "Invalid Request - the message type of the request is invalid";
	elseif self.respCode = "IS" then
		return "Invalid Sequence - the sequence number is invalid";
	elseif self.respCode = "IT" then
		return "Invalid Terminal - the Terminal is not activated";
	elseif self.respCode = "NA" then
		return "Not Available - the Data Capture Host is not available";
	elseif self.respCode = "NR" then
		return "No Response - no response has yet been received from the Host";
	elseif self.respCode = "NS" then
		return "Not Sent - the transaction has not yet been sent to the Host";
	elseif self.respCode = "NT" then
		return "No Transaction - no message with this Sequence Number exists";
	elseif self.respCode = "NX" then
		return "No foreigh eXchange - not enabled for this card type";
	elseif self.respCode = "OE" then
		return "Online Error - an unrecoverable processing error has occurred";
	elseif self.respCode = "PR" then
		return "Processing Reversal - not sent to Host as a reversal is pending";
	elseif self.respCode = "PS" then
		return "Processing Settlement - not sent to Host as a settle is in progress";
	elseif self.respCode = "RR" then
		return "Response Received - Internal should never be received";
	elseif self.respCode = "SE" then
		return "Settled - transaction has been settled already";
	elseif self.respCode = "TO" then
		return "Time Out - no response was received within the time out period";
	elseif self.respCode = "UN" then
		return "Unavailable - the system is not available at present";
		
	// REMAINING AS2805 CODES
		
	elseif self.respCode = "01" then	// numeric
		return "DECLINED - CALL AUTH CENTRE";
	elseif self.respCode = "02" then	// numeric
		return "REFERRAL - CALL AUTH CENTRE";
	elseif self.respCode = "03" then	// numeric
		return "INVALID MERCHANT IDENTIFIER";
	elseif self.respCode = "04" then	// numeric
		return "DECLINED - PICK UP CARD";
	elseif self.respCode = "05" then	// numeric
		return "DECLINED";
	elseif self.respCode = "06" then	// numeric
		return "ERROR";		
	elseif self.respCode = "07" then	// numeric
		return "PICK UP CARD SPECIAL CONDITION";
	elseif self.respCode = "08" then	// numeric
		return "APPROVE WITH SIGNATURE";
	elseif self.respCode = "09" then	// numeric
		return "REQUEST IN PROGRESS";
	elseif self.respCode = "10" then	// numeric
		return "PARTIAL PAYMENT";
	elseif self.respCode = "11" then	// numeric
		return "VIP TRANSACTION ACCEPTED";
	elseif self.respCode = "12" then	// numeric
		return "INVALID TRANSACTION";
	elseif self.respCode = "13" then	// numeric
		return "INVALID AMOUNT";
	elseif self.respCode = "14" then	// numeric
		return "INVALID CARD NUMBER";
	elseif self.respCode = "15" then	// numeric
		return "INVALID ISSUER";
	elseif self.respCode = "16" then	// numeric
		return "TRACK 3 UPDATED";		
	elseif self.respCode = "17" then	// numeric
		return "CUSTOMER CANCELLED";
	elseif self.respCode = "18" then	// numeric
		return "CUSTOMER DISPUTE";
	elseif self.respCode = "19" then	// numeric
		return "RE-ENTER TRANSACTION";
	elseif self.respCode = "20" then	// numeric
		return "INVALID RESPONSE";
	elseif self.respCode = "21" then	// numeric
		return "NO ACTION TAKEN";
	elseif self.respCode = "22" then	// numeric
		return "SUSPECTED MALFUNCTION";
	elseif self.respCode = "23" then	// numeric
		return "TRANSACTION FEE DECLINED";
	elseif self.respCode = "24" then	// numeric
		return "NO FILE UPDATE";
	elseif self.respCode = "25" then	// numeric
		return "UNABLE TO LOCATE TRANSACTION";
	elseif self.respCode = "26" then	// numeric
		return "DUPLICATE FILE UPDATE";		
	elseif self.respCode = "27" then	// numeric
		return "EDIT ERROR";
	elseif self.respCode = "28" then	// numeric
		return "FILE UPDATE LOCKED";
	elseif self.respCode = "29" then	// numeric
		return "FILE UPDATE FAILED";
	elseif self.respCode = "30" then	// numeric
		return "FORMAT ERROR";
	elseif self.respCode = "31" then	// numeric
		return "INVALID CARD TYPE";
	elseif self.respCode = "32" then	// numeric
		return "PARTIALLY COMPLETED";
	elseif self.respCode = "33" then	// numeric
		return "EXPIRED CARD";
	elseif self.respCode = "34" then	// numeric
		return "SUSPECTED FRAUD";
	elseif self.respCode = "35" then	// numeric
		return "CONTACT ACQUIRER";
	elseif self.respCode = "36" then	// numeric
		return "RESTRICTED CARD";		
	elseif self.respCode = "37" then	// numeric
		return "SECURITY VIOLATION";
	elseif self.respCode = "38" then	// numeric
		return "PIN RETRIES EXCEEDED";
	elseif self.respCode = "39" then	// numeric
		return "NO CREDIT ACCOUNT";
	elseif self.respCode = "40" then	// numeric
		return "NOT SUPPORTTED";
	elseif self.respCode = "41" then	// numeric
		return "LOST CARD";
	elseif self.respCode = "42" then	// numeric
		return "NO DEFAULT ACCOUNT";
	elseif self.respCode = "43" then	// numeric
		return "STOLEN CARD";
	elseif self.respCode = "44" then	// numeric
		return "NO INVESTMENT ACCOUNT";
	elseif self.respCode = "45" then	// numeric
		return "ISO RESERVED";
	elseif self.respCode = "46" then	// numeric
		return "ISO RESERVED";		
	elseif self.respCode = "47" then	// numeric
		return "ISO RESERVED";
	elseif self.respCode = "48" then	// numeric
		return "ISO RESERVED";
	elseif self.respCode = "49" then	// numeric
		return "ISO RESERVED";
	elseif self.respCode = "50" then	// numeric
		return "ISO RESERVED";
	elseif self.respCode = "51" then	// numeric
		return "INSUFFICIENT AVAILABLE FUNDS";
	elseif self.respCode = "52" then	// numeric
		return "NO CHEQUE ACCOUNT";
	elseif self.respCode = "53" then	// numeric
		return "NO SAVINGS ACCOUNT";
	elseif self.respCode = "54" then	// numeric
		return "EXPIRED CARD";
	elseif self.respCode = "55" then	// numeric
		return "INCORRECT PIN";
	elseif self.respCode = "56" then	// numeric
		return "NO RECORD OF CARD";		
	elseif self.respCode = "57" then	// numeric
		return "INVALID TRANSACTION FOR CARD";
	elseif self.respCode = "58" then	// numeric
		return "INVALID TRANSACTION FOR TERMINAL";
	elseif self.respCode = "59" then	// numeric
		return "SECURITY VIOLATION";
	elseif self.respCode = "60" then	// numeric
		return "CALL ACQUIRER";
	elseif self.respCode = "61" then	// numeric
		return "WITHDRAWAL LIMIT EXCEEDED";
	elseif self.respCode = "62" then	// numeric
		return "RESTRICTED CARD";
	elseif self.respCode = "63" then	// numeric
		return "SECURITY VIOLATION";
	elseif self.respCode = "64" then	// numeric
		return "INCORRECT AMOUNT";
	elseif self.respCode = "65" then	// numeric
		return "ACTIVITY COUNT LIMIT EXCEEDED";
	elseif self.respCode = "66" then	// numeric
		return "CALL ACQUIRER";		
	elseif self.respCode = "67" then	// numeric
		return "USE MANUAL VOUCHER";
	elseif self.respCode = "68" then	// numeric
		return "RETRY";
	elseif self.respCode = "69" then	// numeric
		return "ISO RESERVED";
	elseif self.respCode = "70" then	// numeric
		return "ISO RESERVED";
	elseif self.respCode = "71" then	// numeric
		return "ISO RESERVED";
	elseif self.respCode = "72" then	// numeric
		return "ISO RESERVED";
	elseif self.respCode = "73" then	// numeric
		return "ISO RESERVED";
	elseif self.respCode = "74" then	// numeric
		return "ISO RESERVED";
	elseif self.respCode = "75" then	// numeric
		return "TOO MANY PIN RETRIES";
	elseif self.respCode = "76" then	// numeric
		return "AMOUNT LIMIT EXCEEDED";		
	elseif self.respCode = "77" then	// numeric
		return "USE MANUAL VOUCHER";
	elseif self.respCode = "78" then	// numeric
		return "INVALID MERCHANT CARD";
	elseif self.respCode = "79" then	// numeric
		return "INVALID MERCHANT PIN";
	elseif self.respCode = "80" then	// numeric
		return "ISO RESERVED";
	elseif self.respCode = "81" then	// numeric
		return "BALANCE UNAVAILABLE";
	elseif self.respCode = "82" then	// numeric
		return "VOLUME PARAMETERS EXCEEDED";
	elseif self.respCode = "83" then	// numeric
		return "ISO RESERVED";
	elseif self.respCode = "84" then	// numeric
		return "INSUFFICIENT FUNDS";
	elseif self.respCode = "85" then	// numeric
		return "ISO RESERVED";
	elseif self.respCode = "86" then	// numeric
		return "STOLEN CARD";		
	elseif self.respCode = "87" then	// numeric
		return "ISO RESERVED";
	elseif self.respCode = "88" then	// numeric
		return "INVALID MERCHANT NUMBER";
	elseif self.respCode = "89" then	// numeric
		return "INVALID TERMINAL NUMBER";
	elseif self.respCode = "90" then	// numeric
		return "SETTLE IN PROGRESS";
	elseif self.respCode = "91" then	// numeric
		return "HOST UNAVAILABLE";
	elseif self.respCode = "92" then	// numeric
		return "UNABLE TO ROUTE TRANSACTION";
	elseif self.respCode = "93" then	// numeric
		return "SECURITY VIOLATION";
	elseif self.respCode = "94" then	// numeric
		return "DUPLICATE TRANSAMISSION DETECTED";
	elseif self.respCode = "95" then	// numeric
		return "BAD SETTLEMENT - DO BATCH TRANSFER";
	elseif self.respCode = "96" then	// numeric
		return "SYSTEM ERROR";
	elseif self.respCode = "98" then	// numeric
		return "ENCRYPTION ERROR";
	elseif self.respCode = "99" then	// numeric
		return "ISO RESERVED";															
	else
		return "'" &amp; self.respCode &amp; "' is an unknown Response Code!!";
	endif;					
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
