    <JadeMethod name="validateForManualSuspense" id="84ecf4c4-319d-4415-8cb0-1491de060b68">
        <source>validateForManualSuspense() protected;
/* ---------------------------------------------------------------------------
Created:	15 September 2008	by cnwvu1

Purpose:	Manual Suspense invoice should be one invoice per Debtor and Invoice Type
			plus possibly per voyage and tracked item. 
			(the same as automated generatorion of OPEN invoices)
   
Change Date		Who			Reason
----------		--------	------------------------------------------------
16/09/2015		cnwdap1		PAR #36909 CCMS ADP 2537 New bol number parameter for invoiceType.initialiseSelectionParameter
13/09/2022		navpw1		TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
------------------------------------------------------------------------------*/
vars
	theInvoice	: CM_Invoice;
	iter 		: Iterator;
	setInv		: CM_InvoiceBySeqNumDict;
	invoiceType	: CM_InvoiceDesc;
	param		: CMIF_InvoiceSelection;
	voyCode,
	tiId		: String;
	bolNumber	: String;						// PAR #36909
	
begin
	create param transient;
	
	invoiceType			:= self.invoiceType;
	param.debtor		:= debtor;
	param.status		:= CM_Invoice.INVOICE_SUSPENSE;
	param.companyCode	:= self.bank.code;
	param.checkManual	:= true;
	param.isManual		:= true;
	param.invoiceTypeNumber := invoiceType.number;
	param.myInvoiceType := invoiceType; // ### TFS 54565 (54384) 31Aug2022 NAVPW1
	
	if self.myVoyage &lt;&gt; null then
		voyCode := self.myVoyage.code;
	endif;
	if self.myTrackedItem &lt;&gt; null then
		tiId := self.myTrackedItem.id;
		bolNumber := self.myTrackedItem.billOfLading;											// PAR #36909
	endif;
	//invoiceType.initialiseSelectionParameter(param, null, true, voyCode, tiId );				// PAR #36909
	invoiceType.initialiseSelectionParameter(param, null, true, voyCode, tiId, bolNumber );		// PAR #36909

	
	iter := self.debtor.invoicesByStatus.createIterator();

	self.debtor.invoicesByStatus.startKeyGeq(CM_Invoice.INVOICE_SUSPENSE, iter); // PAR 17895
	while iter.next(theInvoice) do

		if theInvoice.status &lt;&gt; CM_Invoice.INVOICE_SUSPENSE then // PAR 17895
			break;
		endif;
		if not theInvoice.isMatch(param) then
			continue;
		endif;
		
		app.raiseCMException2(ERR_SuspensInvoiceExists, self.debtor.name, self.invoiceType.description, null, null);
		break;
		
	endwhile;
	
epilog
	delete param;
	delete iter;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="2a06467a-589c-4840-970d-273933316058">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Change Date		Who			Reason
// 13/09/2022	navpw1	TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
// 29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
// ---------------------------------------------------------------------------

begin
	self.validateMe();

	if self.invoiceType.accrualType &lt;&gt; CM_InvoiceDesc.Accrue_Until_Manually_Closed then
		if self.toDT.isValid = false then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Close Date', ETRow_Debtor, null);
			app.raiseCMException(Input_required_field_closeDate, ETRow_Debtor, null); // cnwdb2	PAR 35364
		endif;
	endif;
	if self.invoiceType &lt;&gt; null then
		if invoiceType.mySurchargeAndExemptions = null or (invoiceType.mySurchargeAndExemptions &lt;&gt; null and invoiceType.mySurchargeAndExemptions.allInvoiceTypeDebtorSeparation.isEmpty)then //29/05/2023 navmv20 Bug 58090
			//if invoiceType.isVoyageSpecific() and self.myVoyage = null then
			if invoiceType.isVoyageSpecificDebtor(self.debtor) and self.myVoyage = null then			// ### TFS 54565 (54384) 22Sep2022 NAVPW1
				app.raiseCMException(Voyag_speci_invoi_type_been_se, ETRow_VoyageCode, null);
			//elseif invoiceType.isVoyageGroupSpecific and self.myVoyage = null then					// ### TFS 51219 25MAY2021 NAVAB1
			elseif invoiceType.isVoyageGroupSpecificDebtor(self.debtor) and self.myVoyage = null then	// ### TFS 51219 25MAY2021 NAVAB1 // ### TFS 54565 (54384) 22Sep2022 NAVPW1
				app.raiseCMException(Voyag_speci_invoi_type_been_se, ETRow_VoyageCode, null);			// ### TFS 51219 25MAY2021 NAVAB1
			endif;
		endif; //29/05/2023 navmv20 Bug 58090
	endif;

	self.validateToDateForUpdate();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdateMoveLines" id="dc2194dd-2bc3-458b-bb8a-0a7e2d2bc3a9">
        <source>validateForUpdateMoveLines(_controller : CMIF_InvoiceLineMove);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anInvoiceLine : CM_InvoiceLine;
begin
	
//	if ( self.status = INVOICE_POSTED then
	if self.isPostedOrReversal then	//04 Sep 2017	NDL	TFS 6759	
		app.raiseCMException2(Err_CannotMoveInvoiceLine, "s","Invoice " &amp; self.sequenceNum.String &amp; " has been posted.",null, null);
	elseif self.isVoided then
		app.raiseCMException2(Err_CannotMoveInvoiceLine, "s","Invoice " &amp; self.sequenceNum.String &amp; " is void.",null, null);
	else
		foreach anInvoiceLine in _controller.allInvoiceLines do
			if anInvoiceLine.status = CM_InvoiceLine.STATUS_VOIDED then
				app.raiseCMException2(Err_CannotMoveInvoiceLine, " " &amp; anInvoiceLine.sequenceNum.String,"This invoice linie is void.",null, null);
			
			endif;
			if anInvoiceLine.invoice.isPostedOrReversal then
				app.raiseCMException2(Err_CannotMoveInvoiceLine, " " &amp; anInvoiceLine.sequenceNum.String,"Invoice " 
										&amp; anInvoiceLine.invoice.sequenceNum.String &amp; " has been posted.",null, null);
			
			endif;
		endforeach;
	endif;
	
	
end;</source>
        <Parameter name="_controller" type="CMIF_InvoiceLineMove"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdateStatus" id="68b8cf2f-e8a8-4e57-a5a4-717aa7b091ee">
        <source>validateForUpdateStatus(_status : CMIF_InvoiceStatus);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 04/04/2018	jlgdap1		TFS 37560 PEL1 Prepend Invoice Status
vars
 	pxyInv : CM_Invoice;
	newStatus : Integer;
begin
	newStatus := _status.newStatus;
	
	if newStatus = self.status then
		app.raiseCMException2(ERR_STATUS_CHANGE, self.sequenceNum.String, "Is already status of " &amp; self.getStatusDescription(newStatus),null, null);
	endif;
	if self.status = INVOICE_OPEN then
		//can go PENDING or VOID
		// TFS 37560 or PREPEND or DISPUTED
		if newStatus &lt;&gt; INVOICE_PENDING 
		and newStatus &lt;&gt; INVOICE_VOID 
		and newStatus &lt;&gt; INVOICE_PREPEND			// TFS 37560
		and newStatus &lt;&gt; INVOICE_DISPUTED then		// TFS 37560
			app.raiseCMException2(ERR_STATUS_CHANGE, self.sequenceNum.String,null,null, null);
		endif;
	elseif self.status = INVOICE_PENDING then
		//can go POSTED OR VOID
		if newStatus = INVOICE_POSTED then
			pxyInv := self.pxyGetProxyObject().CM_Invoice;
			self.validateDateForStatusPost(pxyInv.toDT);// PAR 10090
			if not self.canBePosted() then	// ccms 1773. Allows invoice posting without audits qualify
				app.raiseCMException1(ERR_CANTPOST_UNQUAL, self.sequenceNum.String,null, null);
			endif;
			// cnwjk3 PAR 18434 - Date - 06/11/2008
			if self.debtor.isPurchaseOrderMandatory then
				// Make sure that this invoice has one...
				if _status.purchaseOrderNumber = null then
					app.raiseCMException3(ERR_No_PO_Number, self.debtor.name, self.sequenceNum.String, null, null, null);
				endif;
			endif;

		endif;	
		if newStatus &lt;&gt; INVOICE_POSTED 
		and newStatus &lt;&gt; INVOICE_VOID then
			app.raiseCMException2(ERR_STATUS_CHANGE, self.sequenceNum.String,null,null, null);
		endif;
	elseif self.status = INVOICE_SUSPENSE then	//PAR 17895. September 2008
		//can go VOID
		if newStatus &lt;&gt; INVOICE_VOID then
			app.raiseCMException2(ERR_STATUS_CHANGE, self.sequenceNum.String,null,null, null);
		endif;
	elseif self.status = INVOICE_POSTED then
		//can go nowhere!
		app.raiseCMException2(ERR_STATUS_CHANGE, self.sequenceNum.String,null,null, null);
	elseif self.status = INVOICE_VOID then
		//can go PENDING or SUSPENSE
		if newStatus &lt;&gt; INVOICE_PENDING 
		and newStatus &lt;&gt; INVOICE_SUSPENSE //PAR 17895. September 2008
		then
			app.raiseCMException2(ERR_STATUS_CHANGE, self.sequenceNum.String,null,null, null);
		endif;
		
		//if _status.voidReason 
		
	elseif self.status = self.INVOICE_PREPEND then 													// TFS 37560
		// can go to PENDING or DISPUTED															// TFS 37560
		if newStatus &lt;&gt; self.INVOICE_PENDING and newStatus &lt;&gt; self.INVOICE_DISPUTED then			// TFS 37560
			app.raiseCMException2(ERR_STATUS_CHANGE, self.sequenceNum.String, null, null, null);	// TFS 37560
		endif;																						// TFS 37560
	elseif self.status = self.INVOICE_DISPUTED then 												// TFS 37560
		// can go to PENDING or PREPEND																// TFS 37560
		if newStatus &lt;&gt; self.INVOICE_PENDING and newStatus &lt;&gt; self.INVOICE_PREPEND then				// TFS 37560
			app.raiseCMException2(ERR_STATUS_CHANGE, self.sequenceNum.String, null, null, null);	// TFS 37560
		endif;																						// TFS 37560
	endif;
end;</source>
        <Parameter name="_status" type="CMIF_InvoiceStatus"/>
    </JadeMethod>
    <JadeMethod name="validateLinkCreditToInvoice" id="feb55927-2a2e-411b-a454-ad948881d22a">
        <source>validateLinkCreditToInvoice();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2023	navkc1	Initial creation TFS CR 55305 Task 55533: Jade - Invoice Credit Note Jade Code

*/

vars

begin
	if not self.isPostedOrReversal() then
		app.raiseCMWarning1(Invoice_status_not_posted, self.sequenceNum.String, null, null, null);
	endif;
	
	if self.category = InvoiceCategory_CreditNote then
		app.raiseCMWarning1(Already_is_credit_note, self.sequenceNum.String, null, null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="7133694a-48fb-4076-bbf5-ec56a52cb33a">
        <source>validateMe();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Change Date		Who			Reason
// 13/09/2022	navpw1	TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
// 09/02/2023	navkc1	TFS CR 55305 Task 55536 UI - Invoice Credit Note UI
// 16 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
// ---------------------------------------------------------------------------
vars
	debtorSep : CM_InvTypeDebtorSeparation;

begin
	if self.debtor = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Debtor', ETRow_Debtor, null);
		app.raiseCMException(Input_required_field_debtor, ETRow_Debtor, null); // cnwdb2	PAR 35364
	endif;
	if self.bank = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Company Business Unit', ETRow_Debtor, null);
		app.raiseCMException(Input_required_field_comBusUnt, ETRow_Bank, null); // cnwdb2	PAR 35364


	endif;
	
	if self.invoiceType &lt;&gt; null then //16/03/2023  navmv20 TFS 56128 Task 56129
		debtorSep := self.invoiceType.getDebtorSeparation(self.debtor); // ### BUG 56925 07MAR2023 NAVAB1
	endif; //16/03/2023  navmv20 TFS 56128 Task 56129
	
	if self.invoiceType = null then 
	//	app.raiseCMException1(REQUIRED_FIELD, 'Invoice Type', ETRow_InvoiceTypeCode, null);
		app.raiseCMException(Input_required_field_invType, ETRow_InvoiceTypeCode, null); // cnwdb2	PAR 35364
	//elseif self.invoiceType.isCargoItemSpecific() and self.myTrackedItem = null then //Par17895. should be ti for Invoice type of Cargo Item - i.e. one invoice per one ti
	elseif self.invoiceType.isCargoSpecificSeparation(debtorSep) and self.myTrackedItem = null then // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1 elseif self.invoiceType.isCargoItemSpecificDebtor(self.debtor) and self.myTrackedItem = null then // ### TFS 54565 (54384) 22Sep2022 NAVPW1
		app.raiseCMException1(ERR_TINotFoundByCargoId, null, ETRow_CargoId, null);
	endif;

	// 09/02/2023	navkc1	TFS CR 55305 TASK 55536
	// Return here so it doesn't crash in further validation
	if app.myPassport.hasErrors() then
		return;
	endif;
	
	if self.isManual then // Par 17895 Sep 2008
		if self.status = INVOICE_SUSPENSE then
			self.validateForManualSuspense();
		endif;
	endif;
	
	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
	if (self.invoiceType.isVoyageGrpSpecificSeparation(debtorSep)
		or self.invoiceType.isVoyageSpecificSeparation(debtorSep)) then
	// ### BUG 56925 07MAR2023 NAVAB1if (self.invoiceType.isVoyageSpecificDebtor(self.debtor)
		// ### BUG 56925 07MAR2023 NAVAB1or self.invoiceType.isVoyageGroupSpecificDebtor(self.debtor)) then
		if self.myVoyage = null then
			app.raiseCMWarning1(Debtor_separation_missingfield, app.getErrorString(Voyage), null, null, null);
		endif;
	endif;
	
	if self.invoiceType.isCargoSpecificSeparation(debtorSep) and self.myTrackedItem = null then // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if self.invoiceType.isCargoItemSpecificDebtor(self.debtor) and self.myTrackedItem = null then
		app.raiseCMWarning1(Debtor_separation_missingfield, app.getErrorString(TrackedItem), null, null, null);
	endif;
	
	if self.invoiceType.isBOLSpecificSeparation(debtorSep) and self.myBOL = null then // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isBOLSpecificDebtor(self.debtor)
		// ### BUG 56925 07MAR2023 NAVAB1 and self.myBOL = null
	
		app.raiseCMWarning1(Debtor_separation_missingfield, app.getErrorString(BillOfLading), null, null, null);
	endif;
	
	//separatedByBooking
	if self.invoiceType.isBookingSpecificSeparation(debtorSep) and self.myBookingRef = null then // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isBookingSpecificDebtor(self.debtor)
	// ### BUG 56925 07MAR2023 NAVAB1	and self.myBookingRef = null
	// ### BUG 56925 07MAR2023 NAVAB1then
		app.raiseCMWarning1(Debtor_separation_missingfield, app.getErrorString(Booking), null, null, null);
	endif;
	
	//separatedByCargoGroupId
	if self.invoiceType.isCargoGroupSpecificSeparation(debtorSep) and self.myCargoGroup = null then // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isCargoGroupSpecificDebtor(self.debtor) 
	 // ### BUG 56925 07MAR2023 NAVAB1	and self.myCargoGroup = null
	 // ### BUG 56925 07MAR2023 NAVAB1then
		app.raiseCMWarning1(Debtor_separation_missingfield, app.getErrorString(CargoGroup), null, null, null);
	endif;
	
	//separatedByReleaseRequest
	if self.invoiceType.isReleaseSpecificSeparation(debtorSep) and self.myReleaseRequest = null then // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isReleaseSpecificDebtor(self.debtor) 
	 // ### BUG 56925 07MAR2023 NAVAB1	and self.myReleaseRequest = null
	 // ### BUG 56925 07MAR2023 NAVAB1then
		app.raiseCMWarning1(Debtor_separation_missingfield, app.getErrorString(ReleaseRequest), null, null, null);
	endif;
	
	 // ### BUG 56925 07MAR2023 NAVAB1
	if invoiceType.isPONumberSpecificSeparation(debtorSep) 
	and self.purchaseOrderNumber = null then
		app.raiseCMWarning1(Debtor_separation_missingfield, app.getErrorString(Purchase_order_number), null, null, null);
	endif;
	
	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateReturnStatus" id="d7afc693-f576-479b-8a0f-ec69995215b4">
        <source>validateReturnStatus();
/*
Purpose:			

Date		Who		Reason
11 January 2024	navab1	CR 58085 TASK 61348
*/

vars
	invoice : CM_Invoice;
	isCredit : Boolean;
begin
	isCredit:= self.isCreditNote();
	if isCredit then
		if self.isTASCreditNote() then
			app.raiseCMException(Cannot_return_credit_note,"",null);
		endif;
	
	else
		if self.isTASInvoice() then
			app.raiseCMException(Cannot_return_invoice,"",null);
		endif;
	
	endif;
	
	
	foreach invoice in self.allMergedInvoices discreteLock do
		if isCredit then
			if invoice.isTASCreditNote() then
				app.raiseCMException(Canno_retur_invoi_that_merge_c,"",null);
			endif;
		
		else
			if invoice.isTASInvoice() then
				app.raiseCMException(Canno_retur_invoi_that_merge_i,"",null);
			endif;
		
		endif;
	
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateToDateForUpdate" id="c48fa56d-7461-4c55-8a39-21203867891a">
        <source>validateToDateForUpdate() ;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 12/12/2019	jlgdap1		TFS 47981 STWO Saving narration on voided monthly invoice gives unexpected errors
vars
	aTS : TimeStamp;
	messageString : String;
begin
	// CCMS 1018 from here
	if self.toDT.isValid 
	and self.invoiceType.accrualType &lt;&gt; CM_InvoiceDesc.Accrue_Until_Manually_Closed then
		// not after the EOP
		
		aTS := app.myRoot.myRootCompany.getPeriodEndDateDebtor(self.debtor,self.fromDT,true); // CCMS 1125
		
		//if self.fromDT.date &gt;  aTS.date then // CCMS 1125				// TFS 47981
		if self.fromDT.date &gt;  aTS.date and aTS.date.isValid then 		// TFS 47981
			messageString := "The closing date of " &amp; self.fromDT.date.String 
					&amp; " for invoice must be before the End Of Period date of " &amp; aTS.date.String;
		elseif self.toDT.date &lt;  self.fromDT.date then
			messageString := "The closing date of " &amp; self.toDT.date.String 
					&amp; " for invoice must be after the start date of " &amp; self.fromDT.date.String;
		elseif not self.toDT.date.isValid then // PAR 7752
			messageString := "The closing date is INVALID. Please enter a valid date"; // PAR 7752
		endif;

		if messageString &lt;&gt; null then
			app.raiseCMException2(ERR_INVALID_VALUE, "Closing Date", messageString, null, null);
		endif;
	endif;
	// CCMS 1018 to here

end;</source>
    </JadeMethod>
    <JadeMethod name="validateWebInvoice" id="f8877d9d-d755-4bf1-95f3-2c4fb44221d0">
        <source>validateWebInvoice();
/*

Purpose:	

	validate a newly created TAS invoice to make sure its not missing or has incorrect values

Parameters:

	None

Return Value:

	None

Date		Who		Reason
08/06/2023	navcs2	ChangeRequest 56901: [58447]: TAS Invoicing Invoice Endpoint - JADE changes
12/02/2025	navcs2 	MTN-33895 GPHA - POST /invoice error 90275 
*/

vars

begin
	self.validateMe();

	/* 12/02/2025	navcs2 	MTN-33895
	if self.exportCurrencyCode = null then
		app.raiseCMException1(Err_Is_Null, "exportCurrencyCode", null, null);
	endif;
	*/ // 12/02/2025	navcs2 	MTN-33895
	
	//if self.myOtherInvoice = null and self.category = InvoiceCategory_CreditNote then
	if self.allCreditInvoices.isEmpty() and self.category = InvoiceCategory_CreditNote then //16/10/2024	navkc1	JIRA Bug MTN-12541
		app.raiseCMException1(Err_Is_Null, "External Reference3",  null, null);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="voyageCode" id="6e7ca1f6-7dee-4878-a3a8-d543cec27fad">
        <methodInvocation>mapping</methodInvocation>
        <source>voyageCode(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if set then
		return;
	else
		if self.myVoyage &lt;&gt; null then
			_value := self.myVoyage.code.trimRight;
		else
			_value := null;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
