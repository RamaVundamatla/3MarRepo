    <JadeMethod name="setGnrcIfaceDvcDictNeedRefresh" id="c351f1a7-5bc4-4f88-b630-96bf76b78819">
        <updating/>
        <source>setGnrcIfaceDvcDictNeedRefresh() updating;
/*

Purpose:			Sets our Generic Interface API Device Dictionary to be refreshed

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
03 May 2022	navpw1	Initial creation TFS: 52773

*/

begin
	self.gnrcIfaceDvcDictNeedsRefresh := true;
	self.causeEvent(CMIF_AlternateDictionary.UpdateDynaDictionaries, true, CMIF_AlternateDictionary::setGnrcIfaceDvcDictNeedRefresh.name);
	
end;</source>
