    <JadeMethod name="tblFileError_contextMenu" id="6f1cba52-d445-4b0f-8596-912f6866ec54">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFileError_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//----------------------------------------------------------------
//	Created:	05 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	x1, y1		: Real;
	tmpMenu,
	menuItem	: MenuItem;
	showTblDataMenus,
	tblDataValidRow	: Boolean;

begin

	self.myCurrentDataTable := cntrl.CM_DataTable;
	x1 := x;
	y1 := y;
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	popupMenu(self.mnuEdiError, x1.Integer, y1.Integer);
	return false;

end;</source>
