    <JadeMethod name="dblClick" id="c33cec6c-de33-4c1b-ba67-2e9fd0e955f1">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dblClick(table: CM_EntryTable input) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     09 March 2005 by cnwrs2
//
// Purpose:
// ---------------------------------------------------------------------------
vars
	obj			: Object;
	theRow		: Integer;
	entRowTrans		: EntTableRowTransient;
begin

	theRow := self.row;
	if not self.isValidRow(theRow) then // &lt;= 0 or theRow &gt; self.rows then
		return;
	endif;

	obj := self.accessRow(theRow).itemObject;	
	
	if (obj = null) or (not EntTableRowTransient.hasInstance(obj)) then
		return;
	endif;
	
	entRowTrans := obj.EntTableRowTransient;
	//changed by cnwyl1 07062006 for PAR 11879
	//it was...
	//if entRowTrans.inputType = self.InputType_Date then
	if entRowTrans.inputType = self.InputType_Date and entRowTrans.inputEnabled = true then
		table.showCalenderForm(theRow, ColumnValue);
	endif;
	
	inheritMethod(table);
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
