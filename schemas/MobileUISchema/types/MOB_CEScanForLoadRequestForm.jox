    <JadeMethod name="getTotalWeight" id="c82ec19f-ba8a-4eb4-b6ba-5a77a755f186">
        <source>getTotalWeight():String;

vars
	totWt 		: Decimal[14,4];
	ti			: CM_TrackedItem;
begin
	totWt := self.myRoadJob.myVehicle.tareKilos;
	foreach ti in myRoadJob.allReleaseTrackedItems do
		totWt := totWt + ti.totalWeight;
	endforeach;
	return totWt.asStringWeightJMT();
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItemForRow" id="fc781ddb-3703-4b30-b532-402d0bbd36f7">
        <source>getTrackedItemForRow(blnNew : Boolean output):CM_TrackedItem protected;
// ---------------------------------------------------------------------------
