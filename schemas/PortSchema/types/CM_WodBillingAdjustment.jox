    <JadeMethod name="getExtraInfo" id="2f15fdd0-e15a-475f-bae2-5067b939f70f">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*
Purpose:	TFS 42241		
Date				Who			Reason
NOVEMBER 2018		CNWAB1		Initial creation
*/

vars
	block : CM_DataContainerBlock;
	tmpTS : TimeStamp;
begin
	inheritMethod(_dataContainer);


	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Remarks), DC_Label, 1, null);
	block.addNewItem(self.remarks , DC_Data, 1, null); 

	
	tmpTS := self.systemToLocalTime(self.oldFromDateTime);
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(WOD_OLDFROM), DC_Label, 1, null);
	block.addNewItem(tmpTS.asStringJMT() , DC_Data, 1, null); 

	
	tmpTS := self.systemToLocalTime(self.oldToDateTime);
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(WOD_OLDTO), DC_Label, 1, null);
	block.addNewItem(tmpTS.asStringJMT() , DC_Data, 1, null); 

	
	tmpTS := self.systemToLocalTime(self.newFromDateTime);
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(WOD_NEWFROM), DC_Label, 1, null);
	block.addNewItem(tmpTS.asStringJMT() , DC_Data, 1, null); 

	
	tmpTS := self.systemToLocalTime(self.newToDateTime);
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(WOD_NEWTO), DC_Label, 1, null);
	block.addNewItem(tmpTS.asStringJMT() , DC_Data, 1, null); 

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(WOD_OLDUNITS), DC_Label, 1, null);
	block.addNewItem(self.oldUnitsUsed.asStringJMT , DC_Data, 1, null); 

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(WOD_NEWUNITS), DC_Label, 1, null);
	block.addNewItem(self.newUnitsUsed.asStringJMT , DC_Data, 1, null); 


epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
