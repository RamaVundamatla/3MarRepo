    <JadeMethod name="outputFile" id="f861d913-4ae7-49c4-ad64-3e79bee33dc9">
        <updating/>
        <source>outputFile(_protocol: CM_CamProtocol input; _camAgent: CM_CamControllerAgent; _camFile: CM_CamFile input; _runDateTime: TimeStamp; _camTaskHistory: CM_CamTaskHistory input; _unhSeqNumber: Integer io; _seqNumber: Integer; _terminal: CM_Terminal; _contextObj : CM_Object; _transactions : CM_TITransactionSet) updating;
//
//11 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//13 Jan 2015	cnwrs1	Par 35505 dont createv &lt;warehouse activity&gt; for non warehouse
//22 Jan 2015	cnwrs1	Par 35539/35540 - AST EDI Formatting 
//23 jan 2015	cnwrs1	Par 35535 - AST XML remove extra CrLf
//21 Jul 2015	cnwrs1	Par 35544 - Switch Cams to camtaskhistory::rawData
//09 Jan 2020	jlgdap1	TFS 48016 SNO Deletion CODECO - new _transactions parameter
//
vars
	camVoyage : CM_CamVoyage;
	camMessage : CM_CamMessage;
	str : String;
	strLine : String;
	theLines : HugeStringArray;
	length : Integer;
begin
	create theLines transient;
	if _camFile.camVoyages.size &gt; 0 then
		_camFile.incrementMessageCount();
		strLine := strLine &amp; '&lt;?xml version="1.0"?&gt;'&amp;CrLf;
		strLine := strLine &amp; "&lt;warehouse_activity&gt;"&amp;CrLf;
		strLine := strLine &amp; '&lt;transmission_number&gt;'&amp;self.transmissionNumber.String&amp;'&lt;/transmission_number&gt;'&amp;CrLf;
		foreach camVoyage in _camFile.camVoyages do
			foreach camMessage in camVoyage.camMessages do
				foreach str in camMessage.group3 do
					if str &lt;&gt; null then
					strLine := strLine &amp; str; 
					endif;
				endforeach;
			endforeach;
		endforeach;
		strLine := strLine &amp; "&lt;/warehouse_activity&gt;";
	endif;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;strLine.length.String&amp;' '&amp;strLine;
	strLine := strLine.replaceString(CrLf, Cr);
	strLine := strLine.replaceString(Lf, Cr);
	strLine.getHugeTokensForDelimiter(Cr, theLines);
	foreach str in theLines do
		self.outputFileMessage(_camTaskHistory, str, null);
	endforeach;
	length := 0;
	while length &lt;&gt; strLine.length do
		length := strLine.length;
		strLine := strLine.replaceString(' &lt;', '&lt;');
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;length.String&amp;' '&amp;strLine.length.String;
	endwhile;
	_camTaskHistory.setRawDataString(strLine);
epilog
	delete theLines;
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="outputFileMessage" id="f805e136-577a-4dc5-837e-7116578a6ff1">
        <updating/>
        <source>outputFileMessage(_camTaskHistory: CM_CamTaskHistory input; _message: String; _coll: HugeStringArray input) : String updating;
//
//11 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//29 Sep 2015	cnwrs1	Par 35544 - Change Cams task hisoty to use JadeBytes  
//
vars
    str : String;
begin
//	_camTaskHistory.addFileDataLineRAW(_message);
	
	str := _message;
	
	if _coll &lt;&gt; null then
		if str.length &gt; 511 then
			str := str [1:511];
		endif;
		
		_coll.add (str);
	endif;
	
	return str;
end;</source>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
