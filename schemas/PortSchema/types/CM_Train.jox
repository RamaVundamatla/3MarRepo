    <JadeMethod name="isInBound" id="37874988-a2fc-4751-9c32-1a62e95ff9dc">
        <source>isInBound() : Boolean;
/*
Purpose:			

Date		Who		Reason
10 December 2021	navab1	TFS 51853
*/

vars
	aT	:	Time;
	isPos	:	Integer;
	numDays	:	Integer;
	mins : Integer;
	
	nowTS : TimeStamp;
	thenTS : TimeStamp;
begin
	if self.arrivalDT.isValid() then // ### TFS 52914 02MAR2022 NAVAB1
		return false; // ### TFS 52914 02MAR2022 NAVAB1
	endif;

	thenTS := self.scheduledArrivalDT;
	if not thenTS.isValid() then
		thenTS := self.arrivalDT;
	endif;
	
	if thenTS.isValid() then
	
		aT := nowTS.differenceAsTime(thenTS, isPos, numDays);

		// Is within 30 minutes in the future
		if numDays = 0
		and aT.hour = 0
		and isPos = 1 
		and aT.minute &lt;= 30 then
			return true;
		endif;
	endif;
	
	
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
