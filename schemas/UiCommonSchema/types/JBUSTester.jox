    <JadeMethod name="buildJBUSCommand" id="3b26b75f-a16e-498d-84be-5fb84a1ac77c">
        <source>buildJBUSCommand() : Binary;
/*

Purpose:			


Return Value:		


Date		Who		Reason
10 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	slave,
	function,
	command,
	parameter, 
	crc16,
	jbus,
	funcString,
	commandString: String;
	s : Integer;
begin

	/*slave:=self.txtSlave.text.cnEcHexValue.Character;
	if self.cmbFunc.listIndex &lt; 1 then
		//app.msgBox("Please select a function","Invalid Function",MsgBox_OK_Only);
		//return null;
	endif;
	
	funcString:=self.cmbFunc.itemText[self.cmbFunc.listIndex];
	function:=funcString.cnEcHexValue.Character;
	if self.cmbCommand.listIndex &lt; 1 then
		//app.msgBox("Please select a command","Invalid Command",MsgBox_OK_Only);
		//return null;
	endif;
	commandString:=self.cmbCommand.itemText[self.cmbCommand.listIndex];
	
	
	if commandString = self.CMD_READER_STATUS then
		command:=JBUS_GET_STATUS.String;
		parameter:=#0.Character &amp; #1.Character;
	elseif commandString = self.CMD_READ_TAG then
		command:=JBUS_READ_TAG.String;
		parameter:=#0.Character &amp; self.txtSlave_3.text.Integer.asHex(2).String.cnEcHexValue.Character;
	elseif commandString = self.CMD_READ_PRETAG then
		command:=JBUS_READ_PREVIOUS_TAG.String;
		parameter:=#0.Character &amp; self.txtSlave_3.text.Integer.asHex(2).String.cnEcHexValue.Character;
	elseif commandString = self.CMD_RESET_READER then
		command:=JBUS_RESET_READER.String;
		parameter:=#0.Character &amp; self.txtSlave_3.text.Integer.asHex(2).String.cnEcHexValue.Character;
	elseif commandString = self.CMD_JBUS_BUZZ then
		command:=JBUS_BUZZ.String;
		parameter:=self.txtSlave_3.text.Integer.asHex(2).String.cnEcHexValue.Character &amp; #0.Character ;
	endif;
	
	//command:=#0.Character &amp; commandString.cnEcHexValue.Character;
	
			
	
	jbus:= slave &amp; function &amp; command &amp; parameter;
	crc16:= app.crc16(jbus);
	txtCRC16.text:=crc16;*/
	
//	self.myConnection.CM_TcpRFIDConnection.writeJBUSCommand(slave,command,parameter);
	//self.myConnection.CM_TcpRFIDConnection.writeJBUSCommand(#01.Character,JBUS_RESET_RECORD.String,#00.Character &amp; #00.Character);
	self.myConnection.CM_TcpRFIDConnection.writeJBUSCommand(#'01',JBUS_GET_CURRENT_RECORD.String,#00.Character &amp;   #25.Character );
	//self.myConnection.CM_TcpRFIDConnection.writeJBUSCommand(#'01',JBUS_GET_CURRENT_RECORD_LENGTH.String,#00.Character &amp; #01.Character);
	//self.myConnection.CM_TcpRFIDConnection.writeJBUSCommand(#'01',GET_STATUS_MEMORY.String,#'01' &amp; #'08');
	//self.myConnection.CM_TcpRFIDConnection.writeJBUSCommand(#01.Character,JBUS_GET_NUM.String,#00.Character &amp; #01.Character);
	//self.myConnection.CM_TcpRFIDConnection.writeJBUSCommand(#01.Character,JBUS_GET_NUM.String,#00.Character &amp; #01.Character);

	
	return jbus.Binary;
epilog

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
