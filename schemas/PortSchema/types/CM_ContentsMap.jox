    <JadeMethod name="getCommodityMap" id="b5001800-1b0b-4325-815a-1813adaebc31">
        <source>getCommodityMap(ti: CM_TrackedItem): CM_CommodityMap;

vars
	commodityMap:   CM_CommodityMap;
begin
	commodityMap := self.commoditiesMap[ti.commodity];
	if commodityMap = null then
		commodityMap := self.commoditiesMap[CM_CommodityMap.Default_Commodity_Map_Key];
	endif;

	return commodityMap;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_CommodityMap"/>
    </JadeMethod>
    <JadeMethod name="getCommodityMapTrans" id="104a2473-f455-4b63-9d08-763f08e3375a">
        <source>getCommodityMapTrans(_trans : CM_TITransaction): CM_CommodityMap;
/*
Date		Who		Reason
18 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/
vars
	commodityMap:   CM_CommodityMap;
	canLogExtra	: Boolean;	//26.02.2025 navah1	#34141
begin
	canLogExtra	 := app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	commodityMap := self.commoditiesMap[_trans.commodity];
	
	if commodityMap &lt;&gt; null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("Commodity map found for " &amp; _trans.commodity, LogINFO.String);  	// navlw1 #MTN-33107
		endif;
	endif;
	
	if commodityMap = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("Commodity map for DEFAULT", LogINFO.String);  						// navlw1 #MTN-33107
		endif;
		commodityMap := self.commoditiesMap[CM_CommodityMap.Default_Commodity_Map_Key];
	endif;

	return commodityMap;
end;</source>
        <Parameter name="_trans" type="CM_TITransaction"/>
        <ReturnType type="CM_CommodityMap"/>
    </JadeMethod>
    <JadeMethod name="getContentsStatus" id="fa9a3c08-dcdf-4494-ad7d-200112e9785c">
        <source>getContentsStatus() : CM_ContentsStatus;

vars
	contentsStatus	: CM_ContentsStatus;
begin
	if self.contentsType &lt;&gt; CM_ContentsMap.DEFAULT_CONTENTS_MAP then
		contentsStatus := app.myRoot.allContentsStatuses[self.contentsType];
	endif;
	
	return contentsStatus;
end;
</source>
        <ReturnType type="CM_ContentsStatus"/>
    </JadeMethod>
    <JadeMethod name="getPath" id="65d40102-3359-47d1-98e3-630e3075c979">
        <source>getPath() : String;
// 32311
vars
	path	: String;
begin
	if self.contentsType = TI_CONTENTS_STATUS_NULL then
		path := "Default (Contents Status)";
	else
		path := self.contentsName;
	endif;
	
	return self.imexMap.getPath() &amp; "/" &amp; path;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPath2" id="1b454eb0-bba9-4f72-a876-07df9068cdbf">
        <source>getPath2() : String;
// 32311
vars
	path	: String;
begin
	if self.contentsType = TI_CONTENTS_STATUS_NULL then
		path := "Default";
	else
		path := self.contentsName;
	endif;
	
	return self.imexMap.getPath2() &amp; Tab &amp; path;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTranMapBreadCrumb" id="6e463732-a6d8-499a-8e5d-5d24b984a059">
