    <JadeMethod name="pxyCreateUpdateProxy" id="4d1dd673-8cec-451d-b4de-b681ec249890">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		31 March 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj	: SelfType;
	completedOK		: Boolean;
begin
	proxyObj	:=	inheritMethod();
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="135923f9-39f3-43f4-92b1-8a611a702d4c">
        <updating/>
        <source>setForCreate(pProxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Set the receiver's property values from the proxy object.
//
// Parameters:	pProxyObj - A reference to the proxy object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setForUpdate(pProxyObj);
	self.myYAParent	:=	pProxyObj.myYAParent;
end;</source>
        <Parameter name="pProxyObj" type="SelfType"/>
    </JadeMethod>
