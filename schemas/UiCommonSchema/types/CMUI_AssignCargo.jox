<GUIClass name="CMUI_AssignCargo" id="e2a6328f-d072-4972-90df-09648c229351">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="chkComplete" id="b8150397-bda5-4026-b033-69be4238449a">
        <embedded/>
        <type name="CMUI_CheckBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="frmMain" id="50254ded-8a07-44ac-94b5-bb07f4664510">
        <embedded/>
        <type name="CMUI_Frame"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblDescription" id="a1b1baea-fe57-4b05-b56b-25a15b907090">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblID" id="f27ee33d-20a6-42af-9743-90a247ab1b7d">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTI" id="107f04ea-c873-498d-8eea-0666f6fdedb1">
        <embedded/>
        <type name="CM_TrackedItem"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myWLE" id="4793f10b-f0ab-44fa-808f-fc97df4e3567">
        <embedded/>
        <type name="CM_WorkListEntry"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtCargoID" id="b6e93fad-db5b-4ea9-a30b-75e5df756306">
        <embedded/>
        <type name="CMUI_TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="doOK" id="cebf7628-3660-4b9c-9bb7-d53e8740ef24">
        <updating/>
        <source>doOK() updating;
/*

Date		Who		Reason
15 May 2014	cnwer1	Initial creation PAR
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/

vars
	ti : CM_TrackedItem;
	cargoType : CM_CargoType;
	tis: CM_TISet;
	cargoTypeID : Integer;
begin
	
	if self.txtCargoID.text = null then
		inheritMethod;
		return;
	endif;
	
	cargoType:=self.myWLE.myRequest.getCargoType;
	if cargoType &lt;&gt; null then
		cargoTypeID:=cargoType.id;
	endif;
	
	
	create tis transient;
	self.myTerminal.lookupAllOnsiteTrackedItems(cargoTypeID, self.txtCargoID.text, tis, false, null);
	
	if tis.size = 1 then
		self.myTI:= tis.first;
		inheritMethod();
	else
		app.msgBox(app.getErrorString2(No_Cargo_Id_Match,self.txtCargoID.text,app.getErrorString(Site)),app.getErrorString(Error),MsgBox_OK_Only);
	endif;
epilog
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="bf2f32cb-dfc0-47f2-a81d-d76eefa72c68">
        <updating/>
        <source>setupForm() updating;
/*

Date		Who		Reason
15 May 2014	cnwer1	Initial creation PAR

*/

vars

begin
	inheritMethod();
	self.txtCargoID.setFocus();
	self.chkComplete.visible:=false;
	self.lblDescription.caption:= self.myWLE.myRequest.getDisplayStringForAttribute( ETRow_CargoDetails,false);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5ee27bb3-acaf-40bc-aacd-2902aef7c609">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 May 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019689, locale);
	chkComplete.translateCaption(Xlat_0019690, locale);
	lblID.translateCaption(Xlat_0019691, locale);
end;</source>
    </JadeMethod>
</GUIClass>
