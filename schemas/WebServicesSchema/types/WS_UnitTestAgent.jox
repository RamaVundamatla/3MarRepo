    <JadeMethod name="wsRESTPutCompleteTruck" id="1f748915-c6c2-46ec-bed5-1115f9274db3">
        <source>wsRESTPutCompleteTruck(_operator: String; _json: String; _pathParamString: String; _expectFailure: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2024	navpw1	Initial creation TFS: 65623 (65624)

*/

vars
	request 			: WS_Request;
	requestLogin		: WS_RESTLoginAuthRequest;
	webService			: MTNInternalAPIService;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	response 			: WS_Response;
	ref 				: String;
	cargoType,
	truckId,
	state				: String;
	pos					: Integer;
	dict 				: WS_QueryStringParamDict;
	
begin
	create webService transient;
	create transientJSONObjs transient;
	create parser transient;
	
	// Login Request
	self.loginRestWithOperator(webService, _operator);
	webService.qsData.parseNameValuePair(_pathParamString);
	
	// set up the WS_Request object
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/completeTruck");
	request := parser.parse(_json, WS_Request, transientJSONObjs).WS_Request;
	
	pos := 2;											
	_pathParamString.scanUntil('/', pos);				
	pos += 1;											
	truckId := _pathParamString.scanUntil('/', pos);	
	response := webService.putCompleteTruck(request, truckId);
	
	// If we're expecting to fail, then return early
	if _expectFailure then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		return response.WS_Response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		if response.allErrors.size &gt; 0 then
			app.writeLog(response.allErrors.first.text, LogERROR);
		endif;
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details" &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTPutCompleteTruck.name;

epilog
	if webService.objectsToBeDeleted.isNotEmpty then
		webService.objectsToBeDeleted.purge;
	endif;
	dict := webService.qsData;
	dict.purge();
	delete webService;
