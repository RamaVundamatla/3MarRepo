    <DbClassMap file="CnEcXML"/>
    <CompAttribute name="allXmlExcludedClasses" id="66788ca3-9f57-45bc-8990-eff980a3415a">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <ExplicitInverseRef name="myBaseRoot" id="52e86af2-a7af-4f0c-ad87-ad87d1187a7f">
        <kind>child</kind>
        <embedded/>
        <type name="CnEcBaseRoot"/>
        <access>readonly</access>
        <Inverse name="CnEcBaseRoot::allXmlExcludedClassesBySchema"/>
    </ExplicitInverseRef>
    <PrimAttribute name="xmlDefaultFormatLastRebuilt" id="aaf6187a-65c0-4fa7-a338-f499c0d083fa">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addXmlExcludedClass" id="e0b36a1e-7c3d-4319-9f00-1e427e8d68bb">
        <source>addXmlExcludedClass(pString : String);
// --------------------------------------------------------------------------------
// Created:		26 October 2000 by cnwndl1
//
// Purpose:		Adds te name of an excluded class to the receiver.
//
// Parameters:	pString - The name of the class to exclude.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allXmlExcludedClasses.add(pString);
end;</source>
        <Parameter name="pString" type="String"/>
    </JadeMethod>
    <JadeMethod name="clearXmlExcludedClasses" id="d837dc2e-62e6-4577-bd98-043c3897414e">
        <source>clearXmlExcludedClasses();
// --------------------------------------------------------------------------------
// Created:		26 October 2000 by cnwndl1
//
// Purpose:		Clear the names of all excluded classes.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allXmlExcludedClasses.clear();
end;</source>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="23b21f9a-5b7e-40e8-bf8a-c88cad289cb9">
        <updating/>
        <source>initializeMe(pSchemaName : String; pMyBaseRoot : CnEcBaseRoot) updating;

begin
	self.schemaName	:=	pSchemaName;
	self.myBaseRoot	:=	pMyBaseRoot;
end;</source>
        <Parameter name="pSchemaName" type="String"/>
        <Parameter name="pMyBaseRoot" type="CnEcBaseRoot"/>
    </JadeMethod>
    <JadeMethod name="setXmlDefaultFormatLastRebuilt" id="832125b4-d5d7-44e2-a5b8-3387ec2381a6">
        <updating/>
        <source>setXmlDefaultFormatLastRebuilt(pDefaultFormatLastRebuilt:TimeStamp)updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2000 by cnwdad1
//
// Purpose:		Sets a timestamp for the last time the default XML format was rebuilt.
//
// Parameters:	pDefaultFormatLastRebuilt - Timestamp of the last rebuild.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.xmlDefaultFormatLastRebuilt &lt;&gt; pDefaultFormatLastRebuilt then
		self.xmlDefaultFormatLastRebuilt := pDefaultFormatLastRebuilt;
	endif;
end;</source>
        <Parameter name="pDefaultFormatLastRebuilt" type="TimeStamp"/>
    </JadeMethod>
</Class>
