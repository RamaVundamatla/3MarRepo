    <JadeMethod name="doSave" id="beebe3d9-73a8-4528-9560-3e77a699ab25">
        <updating/>
        <source>doSave(): Boolean updating;
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------------
// 05/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	errObj								: CM_Error;
	idx									: Integer;
	tmpListBox							: ListBox;
	ignoreWarnings,
	proxyWagonClass						: CM_WagonClass;
	lCode 								: String;
	//lDescription						: String;
    lAcceptsGenerator,lDoorsAccessible,
    rtnValue, isNotAvailableForEntry	: Boolean;
    lMaxLoadWeight,
    lMaxNumInStack,
    lLenInUnits			: Integer;
    lLocationIds,
    lLocationId							: String;
    lLocationArray,lLocationIdArray		: StringArray;
    lConsigneeRestrictions				: CM_ConsignCodeArray;	
    lConsignees 						: CM_ConsignByCodeDict;
    lConsignee  						: CM_ConsigneeConsignor;
    lConsigneeCode 						: String;
	theForm 							: SOP_TableMaintForm;
	
	//08 Jul 2009	NDL	CCMS 1067
	lDeckHeight							: Decimal[12,2];
	lMaxCargoWeight 					: Decimal [12,2];
	lMaxCargoHeight 					: Decimal [12,2];
	lTareWeight 						: Decimal [12,2];
	lMyCarrier 							: CM_Carrier;

begin
    theForm := self.myForm; 
    create lLocationIdArray transient;
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
//	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
    lAcceptsGenerator := theForm.tblInput1.getValueByName(ETRow_AcceptsGenerator).Boolean;
    lDoorsAccessible := theForm.tblInput1.getValueByName(ETRow_DoorsAccessible).Boolean;
    lMaxLoadWeight := theForm.tblInput1.getValueByName(ETRow_MaxLoadWeight).Integer;
    lMaxNumInStack := theForm.tblInput1.getValueByName(ETRow_MaxNumInStack).Integer;
    lLenInUnits    := theForm.tblInput1.getValueByName(ETRow_LenInUnits).Integer;
	//08 Jul 2009	NDL	CCMS 1067
	lDeckHeight := theForm.tblInput1.getValueByName(ETRow_DeckHeight).Decimal; 
	lMaxCargoWeight := theForm.tblInput1.getValueByName(ETRow_MaxCargoWeight).Decimal;
	lMaxCargoHeight := theForm.tblInput1.getValueByName(ETRow_MaxCargoHeight).Decimal;
	lTareWeight := theForm.tblInput1.getValueByName(ETRow_TareWeight).Decimal;
	lMyCarrier := theForm.cmbCarrier.listObject.CM_Carrier;
	
    // lNumOfForty    := theForm.tblInput1.getValueByName(ETRow_NumOfForty).Integer;	// PAR 18839
    // lNumOfTwenty   := theForm.tblInput1.getValueByName(ETRow_NumOfTwenty).Integer;	// PAR 18839
	
    lLocationIds   := theForm.tblInput1.getValueByName(ETRow_LocationIds).String;
    isNotAvailableForEntry :=  theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;
	lLocationIds.replaceChar(',',' ');	// 16/03/2009 cnwar2 #18817 - convert commas to spaces before getTokens
    lLocationArray := lLocationIds.getTokens();
    foreach lLocationId in lLocationArray do
    	lLocationId.replaceChar(',',' ');
    	lLocationId := lLocationId.trimBlanks(); 
    	lLocationIdArray.add(lLocationId);
    endforeach;
    
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_WagonClass transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
 
    create lConsignees transient;
    create lConsigneeRestrictions transient;
    theForm.mulSelect1.getSelected(lConsignees);
    foreach lConsignee in lConsignees do
    	lConsigneeCode := lConsignee.code.trimBlanks;
     	lConsigneeRestrictions.add(lConsigneeCode);
    endforeach;
		
   
 
	proxyWagonClass := theForm.myProxyObject.CM_WagonClass;
	proxyWagonClass.setProxy(lCode, lAcceptsGenerator, lDoorsAccessible, isNotAvailableForEntry, lMaxLoadWeight, lMaxNumInStack, lLenInUnits, lLocationIdArray, lConsigneeRestrictions,
								lDeckHeight,	//pDeckHeight : Decimal;
								lMaxCargoHeight,	//pMaxCargoHeight : Decimal ;
								lTareWeight,	//pTareWeight : Decimal;
								lMyCarrier,	//pMyCarrier : CM_Carrier
								0,	//pInternalHeight : Decimal;	//18 Mar 2013	NDL	Par 31278
								0,	//pInternalLength : Decimal;	//18 Mar 2013	NDL	Par 31278
								0,	//pInternalWidth : Decimal;	//18 Mar 2013	NDL	Par 31278
								0,	//pOverallHeight : Decimal;	//18 Mar 2013	NDL	Par 31278
								0,	//pOverallLength : Decimal;	//18 Mar 2013	NDL	Par 31278
								0,	//pOverallWidth : Decimal;	//18 Mar 2013	NDL	Par 31278
								1,	//pWagonType : Integer;
								null,//pTierIds : StringArray;
								null, //pSealTypes : CM_SealTypeDict	//10 Mar 2015	NDL	Par 35828
								CM_BoxcarVisit.BoxcarGraphicBreakBulk // TFS 49523
								);
								
	theForm.tblInput1.setProxyFromMeasureTables(proxyWagonClass);			// PAR #31155
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateWagonClass(proxyWagonClass, theForm.myCurrentObject, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	elseif theForm.mode = theForm.Mode_Update then
	 	app.myTrxUA.trxUpdateWagonClass(proxyWagonClass, app.myPassport);
	 	rtnValue := app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;

	return rtnValue;
	
epilog	
	 delete lLocationArray;
	 delete lLocationIdArray;
	 delete lConsigneeRestrictions;
	 delete lConsignees;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableTypeDependantRows" id="a3f4ae0a-9260-4021-8a3b-b38e5c19e065">
        <source>enableTypeDependantRows( _table : CM_EntryTable input; _wagonClass : CM_WagonClass ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

begin

	if _wagonClass = null then
		return;
	endif;
	
	if _wagonClass.isBoxcar then
		//Hide 
		_table.hideRowByName( ETRow_DoorsAccessible, false );
		_table.hideRowByName( ETRow_AcceptsGenerator, false );
		_table.hideRowByName( ETRow_LenInUnits, false );
		_table.hideRowByName( ETRow_LocationIds, false );
		_table.hideRowByName( ETRow_MaxNumInStack, false );
		_table.hideRowByName( ETRow_MaxCargoHeight, false );
		_table.hideRowByName( ETRow_DeckHeight, false );
		
		//Show
		_table.showRowByName( ETRow_InternalHeight, false );
		_table.showRowByName( ETRow_InternalLength, false );
		_table.showRowByName( ETRow_InternalWidth, false );
	
	elseif _wagonClass.isFlatcar then
	
		//hide
		_table.hideRowByName( ETRow_InternalHeight, false );
		_table.hideRowByName( ETRow_InternalLength, false );
		_table.hideRowByName( ETRow_InternalWidth, false );
		
		//Show 
		_table.showRowByName( ETRow_DoorsAccessible, false );
		_table.showRowByName( ETRow_AcceptsGenerator, false );
		_table.showRowByName( ETRow_LenInUnits, false );
		_table.showRowByName( ETRow_LocationIds, false );
		_table.showRowByName( ETRow_MaxNumInStack, false );
		_table.showRowByName( ETRow_MaxCargoHeight, false );
		_table.showRowByName( ETRow_DeckHeight, false );
		
	else
		// Not coded for...
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_wagonClass" type="CM_WagonClass"/>
    </JadeMethod>
