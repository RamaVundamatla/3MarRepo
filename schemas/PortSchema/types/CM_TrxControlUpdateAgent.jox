    <JadeMethod name="trxUpdateVVDepartedTransport" id="2775e647-f420-47a6-9726-3cdb50b0796d">
        <updating/>
        <source>trxUpdateVVDepartedTransport(_pxyVVR : CM_VehicleVisitRecord;  _addedCargo : CMGTE_EntitySet; _location : CM_LocationsController; _moveControllers : CMIF_Array;  _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
15/05/2024		navcs2	Bug 64144: Correct Release Data - Few issues found
20/09/2025	navcs2	MTN-35846 Dev - Returning of Lot Based Cargo | PortSchema Changes

*/

vars
	trackedItem			: CMGTE_Entity;
	trackedItemReleased	: CM_TrackedItem;
	bulkRelease			: CM_BulkRelease;
	reserveDetail,
	reserveDetailInner	: CM_ReserveDetail;
	reason				: String;
	reserveMatchesTi	: Boolean;
begin	
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	// Check vehicle and driver
	
	foreach trackedItem in _addedCargo do
		foreach trackedItemReleased in _pxyVVR.allReleasedTrackedItems where not trackedItemReleased.allReserveDetailsReleased.isEmpty do
			reserveMatchesTi := false;
			foreach reserveDetail in trackedItemReleased.allReserveDetailsReleased do
				foreach reserveDetailInner in reserveDetail.myReserveHeader.allReserveDetails do
					if reserveDetailInner.isKindOf(CM_ReserveSelection) and trackedItemReleased.testAgainstReserveSelection(reserveDetailInner.CM_ReserveSelection, reason, true, null) then
						reserveMatchesTi := true;
					endif;
				endforeach;
			endforeach;
			
			if not reserveMatchesTi then
				app.raiseCMWarning2(Cargo_doesnt_match_release, trackedItem.id, _pxyVVR.jobNumber, null, null, null);
			endif;
		endforeach;
	endforeach;
	
	beginTransaction;

	app.myUtilityUA.utlUpdateVVDepartedTransport(_pxyVVR, _addedCargo, _location, _moveControllers, _passport);		// 20/09/2025	navcs2	MTN-35846

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord"/>
        <Parameter name="_addedCargo" type="CMGTE_EntitySet"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_moveControllers" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateVVRCancel" id="9ee191da-f477-4dc9-80da-c5781308e69a">
        <updating/>
        <source>trxUpdateVVRCancel(_vvr : CM_VehicleVisitRecord input; _reason: String; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     September 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 22/09/2009		cnwcs5			Don't use proxy for creating VVRD - 
// 24 June 2024 	navpw1			Bug 64124: MTN - Cancel VVR Doesn't use Deferred Updates
//19 May 2025	jlier1	MTN-34221 refactoring validation so is before trx 
// ---------------------------------------------------------------------------

vars
	pxyVVR	: CM_VehicleVisitRecord;
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.useTIDictDeferUpdate 		  := true;								// ### TFS 64124 (64125) 20Jun2024 NAVPW1
	_passport.useTITransactionDeferUpdate := true;								// ### TFS 64124 (64125) 20Jun2024 NAVPW1
	
	beginTransaction;
	// this utl method updates the VVR directly and must be called b4 the proxy is created 
	// to avoid 'object already updated by another user' message
	app.myUtilityUA.utlUpdateVVRCancel(_vvr, _reason, _passport);	// cnwcs5 22/09/2009
	
	// ### TFS 64124 (64125) 20Jun2024 NAVPW1
	if _passport.hasErrors then
		return;
	endif;
	
	if _passport.noErrors then													
		_passport.doDeferredUpdates();
	endif;
	// ### TFS 64124 (64125) 20Jun2024 NAVPW1
	/*  19/6/2025	jlier1	MTN-34221 refactoring validation so is before trx - not sure why this does this - its not doing anything
	
	pxyVVR := _vvr.pxyCreateUpdateProxy().CM_VehicleVisitRecord;

	if _passport.noErrors then
		app.myUtilityUA.utlUpdateVehicleVisitFlexi(pxyVVR,  _passport);
	endif;
*/
epilog
	delete pxyVVR;
	self.finaliseActivityWithPassportEW(_passport, true);
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateVVRCancelWithJob" id="90f4a7cf-0978-475b-8e74-4128626d01e3">
        <updating/>
        <source>trxUpdateVVRCancelWithJob(_vvr : CM_VehicleVisitRecord input; _reason: String; _passport : CM_Passport input) updating;

/*

Purpose:	vvr cancel from the vehicle visit enquiry form, any vvr with a job that has been actione din some way should fail validation

Parameters:			

Return Value:		


Date		Who		Reason
27 Feb 2012	cnwrd1	Initial creation
14 May 2024 navma1	Bug 64124: MTN - Cancel VVR Doesn't use Deferred Updates
19 May 2025	jlier1	MTN-34221 refactoring validation so is before trx 
*/

vars
	pxyVVR	: CM_VehicleVisitRecord;
	
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.useTIDictDeferUpdate 		  := true;								//14.05.2024 navma1 #64124
	_passport.useTITransactionDeferUpdate := true;								//14.05.2024 navma1 #64124
	
	beginTransaction;
	app.myUtilityUA.utlUpdateVVRCancelWithJob(_vvr, _reason, _passport);	
	
	if _passport.hasErrors then
		return;
	endif;
	
	if _passport.noErrors then													//14.05.2024 navma1 #64124
		_passport.doDeferredUpdates();
	endif;
	
	/*  19/6/2025	jlier1	MTN-34221 refactoring validation so is before trx - not sure why this does this - its not doing anything
		pxyVVR := _vvr.pxyCreateUpdateProxy().CM_VehicleVisitRecord;

		if _passport.noErrors then
			app.myUtilityUA.utlUpdateVehicleVisitFlexi(pxyVVR,  _passport);
		endif;
	*/
epilog
	delete pxyVVR;
	self.finaliseActivityWithPassportEW(_passport, true);
	
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
