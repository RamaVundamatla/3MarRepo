<CollClass name="CM_FileStorageArray" id="55ae69ef-9669-4985-a69d-753abd8f6348">
    <memberType name="CM_FileDataStorageDetail"/>
    <superclass name="ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmenu"/>
    <JadeMethod name="getDataAsBinary" id="0da2c488-9008-48e7-b526-7cc1a59c9346">
        <source>getDataAsBinary() : Binary;
// -------------------------------------------
// Created 18 November 2004 by cnwdvb1
// -------------------------------------------
vars
	
	fileDtl		: CM_FileDataStorageDetail;
	tmpBin		: Binary;

begin

	foreach fileDtl in self do
	//	if fileDtl.csvBlob.length() &gt; 0 then
// cnwdad1 25/02/2009 - PAR #18366.
//			tmpBin := tmpBin &amp; fileDtl.csvBlob.uncompress;
			tmpBin := tmpBin &amp; fileDtl.csvBlob.uncompressToBinary();
	//	endif;
	endforeach;
	return tmpBin;
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
</CollClass>
