    <JadeMethod name="translateForm" id="502c2c80-1023-4096-b9aa-558a0ab349ea">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018970, locale);
	btnExit.translateBubbleHelp(Xlat_0018971, locale);
	btnExit.translateCaption(Xlat_0018972, locale);
	btnOK.translateCaption(Xlat_0018973, locale);
	chkOne.translateBubbleHelp(Xlat_0018974, locale);
	chkOne.translateCaption(Xlat_0018975, locale);
	chkThree.translateCaption(Xlat_0018976, locale);
	chkTwo.translateBubbleHelp(Xlat_0018977, locale);
	chkTwo.translateCaption(Xlat_0018978, locale);
	grpCheckOption.translateCaption(Xlat_0018979, locale);
	lblAddr1.translateCaption(Xlat_0018980, locale);
	lblAddr2.translateCaption(Xlat_0018981, locale);
	lblCityTown.translateCaption(Xlat_0018982, locale);
	lblName.translateCaption(Xlat_0018983, locale);
	lblPostCode.translateCaption(Xlat_0018984, locale);
	lblTitle.translateCaption(Xlat_0018985, locale);
	mnuExit.translateCaption(Xlat_0018986, locale);
	mnuNew.translateCaption(Xlat_0018987, locale);
	mnuOpen.translateCaption(Xlat_0018988, locale);
	mnuSave.translateCaption(Xlat_0018989, locale);
	mnuSaveAs.translateCaption(Xlat_0018990, locale);
	optOne.translateCaption(Xlat_0018991, locale);
	optThree.translateBubbleHelp(Xlat_0018992, locale);
	optThree.translateCaption(Xlat_0018993, locale);
	optTwo.translateBubbleHelp(Xlat_0018994, locale);
	optTwo.translateCaption(Xlat_0018995, locale);
	txtAddr1.translateBubbleHelp(Xlat_0018996, locale);
	txtAddr2.translateBubbleHelp(Xlat_0018997, locale);
	txtPostCode.translateBubbleHelp(Xlat_0018998, locale);
end;</source>
    </JadeMethod>
