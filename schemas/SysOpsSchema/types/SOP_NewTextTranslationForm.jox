    <JadeMethod name="doOK" id="f6e74708-1837-4f96-a007-6e9eae59278e">
        <updating/>
        <source>doOK() updating;

// 13/02/2013	cwnmh5		#31159 - Add additional check so if create process didn't finish (e.g. lock) then saving again will
//							enable you to update the constant

vars
	constantName 	: String;
	globalConstant	: GlobalConstant;
	triedJadloadb	: Boolean;
	commandLine		: String;
	result			: Integer;
	proxy 			: XLAT_TranslationsAndGCProxy; 
	constantStr		: String;
	progress		: CMIF_Monitor;
	constValue		: Integer;
	now				: TimeStamp;
	modifiedTimeStamp : TimeStamp;
	
begin

	// validation - check for duplicate global constant names
	constantName := txtConstName.text;
	//constValue	 := txtConstValue.text.Integer;
	modifiedTimeStamp := app.actualTimeServer;
	
	if txtNzText.text = null then
		app.msgBox('Please provide some text', caption, MsgBox_Stop_Icon);
		txtNzText.setFocus;
		return;
	endif;
	
	if constantName = null then
		app.msgBox('Please provide a constant name', caption, MsgBox_Stop_Icon);
		txtConstName.setFocus;
		return;
	endif;

	// get next constant value here
	constValue := agent.getNextGlobalConstantId(myCategory.constantCategoryName);
	
	if constValue &gt;= ExtDev_BaseErrorNo then
		app.msgBox('Constant Value is greater then JMT Max Error Number', caption, MsgBox_Stop_Icon);
		return;
	endif;
	
	// check the name is unique, or does it already exist?
	create progress transient;
	progress.myParent := self;
	modalDialogReturnValue := ModalDialogReturn_Null;	
	modalDialogShow(null, 'Cancel' , null, null, 'Checking for duplicates',  'Please Wait....');
	pbProgressBar.visible := true;
	
	if agent.isGlobalConstantNameUnique(constantName, globalConstant) = false then
		if globalConstant.getCategory = myCategory.myConstantCategory then
			//- cnwmd1, Par 20524.  Too easy to overwrite the translatable string that may be in use in a different format in a number of places!
			//if app.msgBox('This Global Constant already exists. Update with new details?', caption, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Cancel) = MsgBox_Return_Cancel then 
			///app.msgBox('This Global Constant already exists. Please choose another name.', caption, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			///self.txtConstName.setFocus;
			///return;
			if globalConstant.getSource().Integer = constValue then									// 13/02/2013 cnwmh5 #31159
				if app.msgBox("This Global Constant already exists with the following details:" &amp; CrLf &amp; CrLf &amp;
						"Name: " &amp; globalConstant.name &amp; CrLf &amp; 
						"Number: " &amp; globalConstant.getSource().String &amp; CrLf &amp; 
						"ConstantCategory: " &amp; globalConstant.getCategory().name &amp; CrLf &amp;
						"Created: " &amp; globalConstant.creationTime.String &amp; CrLf &amp; CrLf &amp;
						"Press 'OK' to update constant with the following details:" &amp; CrLf &amp; CrLf &amp;
						"Name: " &amp; constantName &amp; CrLf &amp; 
						"Number: " &amp; constValue.String &amp; CrLf &amp; 
						"ConstantCategory: " &amp; myCategory.myConstantCategory.name &amp; CrLf &amp;
						"Created: " &amp; now.String &amp; CrLf &amp; 
						"Text: " &amp; txtNzText.text, caption, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
					self.txtConstName.setFocus;
					return;
				endif;
			else
				app.msgBox('This Global Constant already exists. Please choose another name.', caption, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
				self.txtConstName.setFocus;
				return;
			endif;
		else
			app.msgBox('Global constant with this name already exists in category ' &amp; globalConstant.getCategory.name &amp; '...' &amp; CrLf &amp; 'Please change', caption, MsgBox_Stop_Icon);
			modalResult := 1;
			unloadForm;
			return;
		endif;
	endif;

	frmModalDialog.visible := false;

	// set up the constant definition line to go into the scm file (xml is done when creating XLAT_TranslatableText object 
	constantStr := constantName &amp; ':' &amp; Tab &amp; "Integer = " &amp; constValue.String &amp; ";" &amp; CrLf;// &amp;
	constantStr := constantStr &amp; 'setModifiedTimeStamp "' &amp; app.myPassport.userCode &amp; '" "5.2.08" ' &amp; modifiedTimeStamp.date.format("yyyy:MM:dd") &amp; ":" &amp; modifiedTimeStamp.time.format("HH:mm:ss") &amp; ';' &amp; CrLf;
	//Tab &amp; 'documentationText' &amp; CrLf &amp; '`' &amp;  documentationText() &amp; '`' &amp; CrLf &amp; CrLf;
	
		
	// Create a constant using jadloadb. If that fails, allow the developer to create their own constant manually.
	while globalConstant = null do

		if not triedJadloadb then
			result := global.addConstantsServer(self.myCategory.myConstantCategory.name, constantStr, commandLine);
			
			if result &lt;&gt; 0 then
				app.writeStatement( 'Problems adding global constant using jadloadb. Result: ' &amp; result.String);
				app.writeStatement( '	Input: ' &amp; constantStr);
				app.writeStatement( '	Jadloadb: ' &amp; commandLine);
				// apparently this return isn't reliable - at the end of the day, we need to know that the GC exists,
				// so we'll test for this at the end of the loop anyway
			endif;
			
			// just do this once
			triedJadloadb := true;
		else
			
			app.copyStringToClipboard(constantName);

			if app.msgBox('The global constant has not been created.' &amp; CrLf &amp;  CrLf &amp; 
						  'Please create it manually using the following details' &amp; CrLf &amp; 
						  'through the IDE (PortSchema, Global Constants browser), ' &amp; CrLf &amp; CrLf &amp; 
						  'Do not press OK until the constant has been created.' &amp; CrLf &amp; CrLf &amp; 
						  'ConstantCategory:		' &amp; myCategory.myConstantCategory.name &amp; CrLf &amp; 
						  'Name (in clipboard):		' &amp; constantName &amp; CrLf &amp; 
						  'Type:				Integer' &amp; CrLf &amp; 
						  'Value:				' &amp; constValue.String, caption, MsgBox_Information_Icon + MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
				return;
			endif;
		endif;
			
		globalConstant := self.myCategory.getGlobalConstant(constantName);
	endwhile;

	// proxy - Default Locale Only
	create proxy transient;
	proxy.addText(agent.myRoot.getDefaultLocale(false), txtNzText.text, txtNzShortText.text, myCategory);
		
	// Now the constant exists, create corresponding Translatable Text object, to be passed back to caller
	myTranslatableText := agent.trxCreateTranslatableText(myCategory, categoryEdition, proxy, globalConstant);
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Creating global constant - myTranslatableText: ' &amp; myTranslatableText.String, LogINFO);					// 20/09/2012 cnwmh5
	
	app.copyStringToClipboard(globalConstant.name);
	app.msgBox('The new translatable text item has been created, and the global constant is ready to be used: ' &amp; myTranslatableText.myGlobalConstant.name, caption, MsgBox_Information_Icon);

	// all is well -unloadForm
	if closeFormOnSave then
		inheritMethod();
	else
		// clear the form ready for the next one
		txtConstName.text := null;
		txtConstValue.text := null;
		txtNzShortText.text := null;
		txtNzText.text := null;
		myTranslatableText := null;
		setNextConstantValue(myCategory);
		txtNzText.setFocus;
	endif;
	
epilog
	frmModalDialog.visible := false;
	delete proxy;
	delete progress;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="f4a6d292-b2f2-4a35-908b-daae6e69b3e7">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2013	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod();
	
	btnOk.width := btnSaveNext.width;
	btnOk.left := btnCancel.left - btnOk.width - 11;
	btnSaveNext.top := btnOk.top;
	btnSaveNext.left := btnOk.left - btnSaveNext.width - 11;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="removeInvalidCharacters" id="573f146f-8470-4649-951b-4ad95026ff62">
        <source>removeInvalidCharacters(nzText : String io) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwmd1	Initial creation

*/

constants
	InvalidChars : String = "-~`!@#$%^&amp;*()+={}[]|\:;&lt;&gt;?.,/&amp;'";
vars
	int : Integer;
	chr : Character;
begin
	//+ cnwmd1, Par 20524
	foreach int in 1 to InvalidChars.length do
		chr := InvalidChars[int];
		nzText := nzText.removeString(chr);
	endforeach;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="nzText" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setNextConstantValue" id="1bf02e09-1d4a-4320-a34d-f9e349cfdfaa">
        <updating/>
        <source>setNextConstantValue(category : XLAT_Category) updating;

vars
	nextId 	: Integer;
begin
	reserveLock(myCategory);
	
	// do not set number here.  Do when save only
	//nextId := agent.getNextGlobalConstantId(myCategory.constantCategoryName);
	
	// record category edition for concurrency checking when performing the update
	categoryEdition := myCategory.edition;
	
	//txtConstValue.text := nextId.String;
epilog
	unlock(myCategory);
end;</source>
        <Parameter name="category" type="XLAT_Category"/>
    </JadeMethod>
    <JadeMethod name="setSuggestedConstantName" id="bb40dadb-16b4-4b00-8a9d-f4ea9f6a1dc3">
        <source>setSuggestedConstantName();

// make up constant name, based on text
vars
	constName	: String;
	tokens		: CnStringArray;
	segmentLen	: Integer;
	count		: Integer;
	token		: String;
	pos			: Integer;
	nzText		: String;
begin

	// first time only
	if txtConstName.text &lt;&gt; null or txtNzText.text = null then
		return;
	endif;
	
	//+ cnwmd1, Par 20524
	nzText := self.txtNzText.text;
	self.removeInvalidCharacters(nzText);
	
	create tokens transient;
	pos := 1;
	while pos &lt; nzText.length do
		token := nzText.getNextToken(pos).toLower;
	
		// include NOT as a valid token (RJS - 
		if token.toLower = 'not' or token.length &gt; 3 then
			tokens.add(token);
		endif;
	endwhile;

	if tokens.isEmpty then
		return;
	endif;
	
	// calculate average segment length	
	segmentLen := (30 div tokens.size).max(5);

	foreach token in tokens do
		count := count + 1;
		if count &gt; 1 then
			constName := constName &amp; '_';
		endif;
		constName := constName &amp; token[1:segmentLen];
	endforeach;

	txtConstName.text := constName[1:30];


epilog
	delete tokens;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ddbd281b-cb82-4af1-be52-6296e22de144">
        <updating/>
        <source>setupForm() updating;

vars
	idx		 : Integer;
	category : XLAT_Category;
begin

	self.minimumWidth := 485;
	self.minimumHeight := 450;
	
	inheritMethod();
	
	create agent transient;
	
	cmbCategory.clear;
	foreach category in agent.myRoot.allXLAT_Categories do
		idx := cmbCategory.addItem(category.constantCategoryName);
		cmbCategory.itemObject[idx] := category;
		if myCategory = category then
			cmbCategory.listIndex := idx;
			changeCategory(category);
		endif;
	endforeach;		
	
	cmbCategory.enabled := canChangeCategory;
	
	// change caption and width of inherited Ok button
	btnOk.caption := '&amp;Save - Close';
	self.doResize;
	
	txtNzText.setFocus;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d0c71116-bcd2-4c73-980f-2c2f891d577a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016846, locale);
	btnSaveNext.translateCaption(Xlat_0004877, locale);
	cmbCategory.translateBubbleHelp(Xlat_0003895, locale);
	lConstCategory.translateCaption(Xlat_0003890, locale);
	lConstName.translateCaption(Xlat_0003897, locale);
	lConstValue.translateCaption(Xlat_0003896, locale);
	lDefaultLocale.translateCaption(Xlat_0003891, locale);
	lnzShortText.translateCaption(Xlat_0003894, locale);
	lnzText.translateCaption(Xlat_0003898, locale);
	txtConstName.translateBubbleHelp(Xlat_0003893, locale);
	txtConstValue.translateBubbleHelp(Xlat_0003892, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtConstName_keyPress" id="ec9a250c-0bcf-4201-8804-f2906a8034c2">
        <controlMethod name="TextBox::keyPress"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtConstName_keyPress(textbox: TextBox input; keyCharCode: Integer io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwmd1	Initial creation

*/

vars
	
begin
	if not((keyCharCode = 8 or keyCharCode = 95) or // backspace or _
		(keyCharCode &gt; 47 and keyCharCode &lt; 58) or // 0 to 9
		(keyCharCode &gt; 64 and keyCharCode &lt; 91) or // A to Z
		(keyCharCode &gt;96 and keyCharCode &lt; 123) or // a to z
		(keyCharCode = 8) or // backspace
		(keyCharCode = 22)) then // CTRL+V
			keyCharCode := 0;
	endif;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCharCode" type="Integer" usage="io"/>
    </JadeMethod>
