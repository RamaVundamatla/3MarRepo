    <PrimAttribute name="acidBase" id="ebf04687-8ebd-43bc-9099-0a46abc890a9">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="flashpointTemperature" id="0557d046-a293-40af-9265-d98beb05279e">
