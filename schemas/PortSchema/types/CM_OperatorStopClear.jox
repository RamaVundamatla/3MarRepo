<Class name="CM_OperatorStopClear" id="2e8fc746-a7f9-4135-bef2-5b16a73408b3">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <PrimAttribute name="operatorStopEntryNumber" id="842baeeb-ef7a-418a-a9f2-c244c998dd57">
        <length>12</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="getDisplayStringForAttribute" id="70ed9102-e310-4546-8702-cee6794acf68">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			lDetail := "Operator Stop Entry No:" &amp; self.operatorStopEntryNumber;

			lDetail := lDetail &amp; " " &amp; self.urNumber.String;		
			
			return lDetail;
			
		endif;
	elseif _attrName = ETRow_OperatorStopClear then
		return self.operatorStopEntryNumber;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="64951ca1-4db7-4094-90b3-c06f9b690fc9">
        <source>getEnquiryRow():String;
// ---------------------------------------------------------------------------
// Created:		23 January 2003  by Jason Chapman  (cnwjc2) ccms1063
// ---------------------------------------------------------------------------

vars
	lDetail : String;
begin
	lDetail := inheritMethod();
	lDetail := lDetail &amp; "Operator Stop Entry No:" &amp; self.operatorStopEntryNumber;

	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="typeString" id="d1462b96-9b91-4911-9954-291e582e7211">
        <methodInvocation>mapping</methodInvocation>
        <source>typeString(_set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:		23 January 2003  by Jason Chapman  (cnwjc2)ccms1063
// ---------------------------------------------------------------------------

begin
	_value := "Op Stop Cleared";
end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
