    <JadeMethod name="getHookClass" id="48f397e0-db1e-43f2-8f73-f7cbc1c92b3b">
        <source>getHookClass() : Class;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

	hookClass	: Class;
	tmpStr		: String;

begin

	hookClass := currentSchema.getClass(self.hookClassType);
	if hookClass = null then
		tmpStr := 'Cannnot locate hook class type ' &amp; self.hookClassType;
		app.raiseUnexpectedProgramError(class.name, method.name, tmpStr);
	endif;
	
	return hookClass;

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getMethodTemplateSignature" id="1eb3a189-ba77-40b1-97ba-9b7e67aaa60b">
        <source>getMethodTemplateSignature(): String;
/*

Purpose:			

Return Value:		

Date		Who		Reason
05 June 2008	cnwer1	Initial creation - PAR#16884

*/
constants
	Vars		: String = "vars";
	Begin		: String = "begin";
	Constants	: String = "constants";
	
vars
	methodTemplate	: String;
	pos				: Integer;
	
begin
	methodTemplate	:=	self.hookMethodTemplate;
	pos				:= 	methodTemplate.pos(Constants, 1);
	
	if pos = 0 then
		pos	:=	methodTemplate.pos(Vars, 1);
	endif;
	
	if pos = 0 then
		pos	:=	methodTemplate.pos(Begin, 1);
	endif;
	
	methodTemplate	:=	methodTemplate[1:pos-1];

	return methodTemplate;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2a789735-d105-41e4-ae70-f9541ae12647">
        <updating/>
        <source>setForCreate(_proxyHookType : CM_HookType) updating;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.setForUpdate(_proxyHookType);
	self.myRoot	:= _proxyHookType.myRoot;


end;</source>
        <Parameter name="_proxyHookType" type="CM_HookType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="88c3d7ae-3210-4857-9a22-92cfcad121a2">
        <updating/>
        <source>setForUpdate(_proxyHookType : CM_HookType) updating;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.hookType		:= _proxyHookType.hookType;
	self.description	:= _proxyHookType.description;
	self.hookMethodName	:= _proxyHookType.hookMethodName;
	self.hookClassType	:= _proxyHookType.hookClassType;
	self.allAvailableLinkObjects.clear();
	_proxyHookType.allAvailableLinkObjects.copy(self.allAvailableLinkObjects);
	self.hookMethodTemplate	:= _proxyHookType.hookMethodTemplate;
	
	


end;</source>
        <Parameter name="_proxyHookType" type="CM_HookType"/>
    </JadeMethod>
    <JadeMethod name="setMetaValues" id="110e0a7b-31c3-4301-9df5-3304b1e41bc4">
        <updating/>
        <source>setMetaValues(_meta : CM_JadeMetadataAnalyzerHook input; _class : Class) updating, protected;
// -------------------------------------------
// Created 09 February 2005 by cnwdvb1
// -------------------------------------------
/* This Method will eventually get the invalid meta information
 off of the Hook Type which will be set from xml. */
vars

begin

	_meta.addMetaConstant(CM_JadeMetadataAnalyzerHook.Statement_AbortTransaction);
	_meta.addMetaConstant(CM_JadeMetadataAnalyzerHook.Statement_BeginTransaction);
	_meta.addMetaConstant(CM_JadeMetadataAnalyzerHook.Statement_CommitTransaction);
	_meta.addMetaConstant(CM_JadeMetadataAnalyzerHook.Statement_BeginLoad);
	_meta.addMetaConstant(CM_JadeMetadataAnalyzerHook.Statement_EndLoad);
	_meta.addMetaConstant(CM_JadeMetadataAnalyzerHook.Statement_Terminate);
	
	if self.hookType &lt;&gt; HookType_HMS_CheckPoint then
		// need create/delete for CheckPoint so can create/delete transients
		_meta.addMetaConstant(CM_JadeMetadataAnalyzerHook.Statement_Create);
		_meta.addMetaConstant(CM_JadeMetadataAnalyzerHook.Statement_Delete);
	endif;
	
	_meta.addSchemaEntity(CM_Object);
	_meta.addSchemaEntity(CM_ObjectSet);
	_meta.addSchemaEntity(ObjectSet);
	_meta.addSchemaEntity(CM_ObjectArray); // Par 17827 CCMS 1507 Hook for Port Otago
	_meta.addSchemaEntity(CMIF_Object);
	_meta.addSchemaEntity(Iterator);
	_meta.addSchemaEntity(StringArray);
	// Add classes they are allowed to access.
	_meta.addSchemaEntity(_class);

end;</source>
        <access>protected</access>
        <Parameter name="_meta" type="CM_JadeMetadataAnalyzerHook" usage="input"/>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="setProxyForHookType" id="7180182f-2ed7-41c0-bfc1-b144fef759e7">
        <updating/>
        <source>setProxyForHookType(	_hookType				: Integer;
						_description,
						_hookMethodName,
						_hookClassType			: String;
						_allAvailableLinkObjects: StringArray;
						_hookMethodTemplate		: String;
						_root					: CM_Root) protected, updating;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.hookType 							:= _hookType;
	self.description						:= _description[1:30];
	self.hookMethodName						:= _hookMethodName;
	self.hookClassType						:= _hookClassType;
	self.allAvailableLinkObjects.clear();
	_allAvailableLinkObjects.copy(self.allAvailableLinkObjects);
	self.hookMethodTemplate					:= _hookMethodTemplate;
	self.myRoot								:= _root;


end;</source>
        <access>protected</access>
        <Parameter name="_hookType" type="Integer"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_hookMethodName" type="String"/>
        <Parameter name="_hookClassType" type="String"/>
        <Parameter name="_allAvailableLinkObjects" type="StringArray"/>
        <Parameter name="_hookMethodTemplate" type="String"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromXML" id="065cfe3c-c623-44db-ac11-c9895446ab16">
        <updating/>
        <source>setProxyFromXML(_id: Integer; _xml: String; _root: CM_Root) updating;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

	allAvailableLinkTypes	: StringArray;
	allHookLinksStr,
	hookLinkStr				: String;
	pos,
	theLength				: Integer;

begin

	pos := 1;
	create allAvailableLinkTypes transient;
	
	allHookLinksStr := _xml.cnEcGetTagValueOfName('allAvailableLinkTypes');
	theLength := allHookLinksStr.length;
	
	while pos &lt;= theLength do
		hookLinkStr := allHookLinksStr.cnEcGetNextTagValueOfName('linkType', pos);
		if hookLinkStr = null or pos &lt; 1 then
			break;
		endif;
		allAvailableLinkTypes.add(hookLinkStr);
	endwhile;
	
	self.setProxyForHookType(
			_id,
			_xml.cnEcGetTagValueOfName('description'),
			_xml.cnEcGetTagValueOfName('hookMethodName'),
			_xml.cnEcGetTagValueOfName('hookClassType'),
			allAvailableLinkTypes,
			_xml.cnEcGetTagValueOfName('hookMethodTemplate'),
			_root);
epilog
	delete allAvailableLinkTypes;
end;</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_xml" type="String"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validate" id="da31fc29-41f8-48cd-a770-6ba9ff3399a4">
        <source>validate() protected;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars
	
	tmpStr,
	link		: String;
	theClass	: Class;
	position	: Integer;

begin

	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', null, null);
		app.raiseCMException(Input_required_field_Desc, null, null); // cnwdb2	PAR 35364


	endif;
	
	if self.hookMethodName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Hook Method Name', null, null);
		app.raiseCMException(Input_required_field_hokMthNam, null, null); // cnwdb2	PAR 35364


	endif;
	
	theClass := currentSchema.getClass(self.hookClassType);
	if theClass = null then
		tmpStr := 'Cannnot locate hook class type ' &amp; self.hookClassType;
		app.raiseUnexpectedProgramError(class.name, method.name, tmpStr);
	endif;
	
	foreach link in self.allAvailableLinkObjects do
		theClass := currentSchema.getClass(link);
		if theClass = null then
			tmpStr := 'Cannnot locate Link Class ' &amp; link;
			app.raiseUnexpectedProgramError(class.name, method.name, tmpStr);
		endif;
	endforeach;
	
	position := 1;
	if self.hookMethodTemplate.pos(self.hookMethodName, position) = 0 then
		tmpStr := 'Method signature must contain method name';
			app.raiseUnexpectedProgramError(class.name, method.name, tmpStr);
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="7ba1467d-3849-4689-90a8-980c961945ac">
        <source>validateForCreate();
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.myRoot = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Root Reference', null, null);
		app.raiseCMException(Input_required_field_rootRefer, null, null); // cnwdb2	PAR 35364


		return;
	endif;
	
	if self.hookType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Hook Type', null, null);
		app.raiseCMException(Input_required_field_hookType, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if self.myRoot.allHookTypes[self.hookType] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.hookType.String, null, null);
	endif;
	
	self.validate();

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="cf81050f-5b58-4511-b5ac-f55b54055883">
        <source>validateForUpdate();
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

	realObjFound,
	realObjForProxy : CM_HookType;

begin


	if self.hookType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'hookType', null, null);
		app.raiseCMException(Input_required_field_hookType, null, null); // cnwdb2	PAR 35364
	else
		realObjFound	:= self.myRoot.allHookTypes[self.hookType];
		realObjForProxy	:= self.pxyGetRealObject;
		if realObjFound &lt;&gt; null and realObjFound &lt;&gt; realObjForProxy then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.hookType.String, null, null);
		endif;
	endif;

	self.validate();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateJadeCode" id="b6fc6ad9-8bf1-4bc3-8d6a-f74ed0da4d92">
        <updating/>
        <source>validateJadeCode(_jadeCode	: String) updating;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------

// 25/09/2008	concms1	par 16762 - use more meaningful error message
vars
	position			: Integer;
	tmpStr				: String;
	agent				: CM_HookAgent;
	jadeMethod			: JadeMethod;
	metaAgent			: CM_JadeMetadataAnalyzerHook;
	classObj			: Class;
	errorCode,
	errorPosition,
	errLength			: Integer;
	accessErrorMessage 	: String;
	errorMsg			: String;
	strErrorInfo		: String;
begin
	classObj	:=	self.getHookClass();

	create metaAgent transient;
	
	self.setMetaValues(metaAgent, classObj);
	
	metaAgent.validateMethod(_jadeCode, classObj, currentSchema, errorCode, errorPosition, errLength, accessErrorMessage);
	
	if errorCode &lt;&gt; 0 then
		if accessErrorMessage &lt;&gt; null then
			app.raiseCMException1 (ERR_SYNTAX_ERROR_SHORT, accessErrorMessage, null, null);	// par 16762
			//app.raiseUnexpectedProgramError(classObj.name, method.name, accessErrorMessage); par 16762
		else
			errorMsg		:= process.getErrorText(errorCode);
			
			// use the field property to pass position/length info back - not pretty but about the only way to do it
			strErrorInfo	:= errorPosition.String &amp; Tab &amp; errLength.String;	// par 16762
			
			app.raiseCMException4 (ERR_SYNTAX_ERROR_LONG, errorCode.String, errorMsg, errorPosition.String, errLength.String, strErrorInfo, null); // par 16762
			/*tmpStr		:=	'Error Code ' &amp; errorCode.String &amp; CrLf &amp;
							' - ' &amp; errorMsg &amp; ". " &amp; CrLf &amp;
							'Error Position ' &amp; errorPosition.String &amp; CrLf &amp;
							'Error Length ' &amp; errLength.String;
			app.raiseUnexpectedProgramError(classObj.name, method.name, tmpStr);*/ // deleted par 16762
		endif;
		return;	// par 16762 - no point carrying on if we already know there is an error
	endif;
	// some errors can only be trapped by doing a compile, for example cannot change method name etc.
	create agent transient;
	jadeMethod := agent.compileHookCode(self.hookMethodName, _jadeCode, classObj, true);
epilog
	if jadeMethod &lt;&gt; null then
		process.deleteTransientMethod(jadeMethod);
	endif;
	delete metaAgent;
	delete agent;
end;</source>
        <Parameter name="_jadeCode" type="String"/>
    </JadeMethod>
</Class>
