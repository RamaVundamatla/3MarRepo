    <JadeMethod name="setTimings" id="6c8348db-30e3-4aa1-9b1c-7c0ab8874820">
        <updating/>
        <source>setTimings(_occursOnDT: TimeStamp; _steamingTime: Integer; _calculateSteamingTime : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     22 November 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
07 Apr 208	cnwkpd1	PAR #16465 	Any timing changes need to update owning HMS_VoyageData
								object so that Graphical View will stay in sync
30 Aug 2012	cnwcs5	par 30292 	use updateObjectEdition instead of updateEdition 
18 Jul 2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/

vars
	tmpVoyage : CM_Voyage;
begin

	if self.isCancelled() then	//19 Nov 2018	NDL	TFS 42043
		return;
	endif;
	
	inheritMethod(_occursOnDT, _steamingTime, _calculateSteamingTime); // jlgka1 TFS 45620
	
	tmpVoyage := self.myHMSVoyageData.myVoyage;
	
	self.updateObjectEdition (self.myHMSVoyageData);	// par 30292	// PAR #16465
		
	if tmpVoyage &lt;&gt; null then
		if self.moveType = HMSMovementTypeArrival then
			tmpVoyage.setArrivalDT(_occursOnDT);
		elseif self.moveType = HMSMovementTypeDeparture then
			tmpVoyage.setDepartureDT(_occursOnDT);	
		endif;
	endif;

end;</source>
        <Parameter name="_occursOnDT" type="TimeStamp"/>
        <Parameter name="_steamingTime" type="Integer"/>
        <Parameter name="_calculateSteamingTime" type="Boolean"/>
    </JadeMethod>
