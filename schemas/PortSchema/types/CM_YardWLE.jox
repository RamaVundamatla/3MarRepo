    <JadeMethod name="isROB" id="ae7f2258-3393-46b4-9c40-759371faf877">
        <source>isROB() : Boolean;
/*

Date		Who		Reason
17 July 2014	cnwer1	Initial creation PAR

*/

vars
	gteEntity : CMGTE_Entity;
	request   : CM_Request;
begin

	request := self.myRequest;
	
	if request = null or not request.isKindOf(CM_YardRequest) then
		return false;
	endif;
	
	gteEntity:= request.CM_YardRequest.myGateEntity;	
	
	if gteEntity = null then
		return false;
	endif;
	
	if gteEntity.isKindOf(CMGTE_Release) then
		
		return gteEntity.CMGTE_Release.imexStatus = TI_IMEX_STATUS_REMAINONBOARD;
	endif;
	
	if gteEntity.isKindOf(CMGTE_Receival) then
		return gteEntity.CMGTE_Receival.imexStatus = TI_IMEX_STATUS_REMAINONBOARD;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReceipt" id="948220cc-3a6c-4474-9256-35353958b6e3">
        <methodInvocation>mapping</methodInvocation>
        <source>isReceipt(set: Boolean; _value: Boolean io) mapping;
//--------------------------------------------------------------
//Created: 04 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	request : CM_Request;
begin
	inheritMethod(set, _value);
	
	request := self.myRequest;
	
	if request = null or  (not request.isYardRequest()) then
	   return;
	endif;
	
	_value := request.CM_YardRequest.isReceipt;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isReceiptToUnpack" id="a557a354-db18-4bfc-8860-113c7ac8246c">
        <source>isReceiptToUnpack(): Boolean;
/*

Date		Who		Reason
11 July 2014	cnwer1	Initial creation PAR

*/

vars
	roadJob : CM_RoadJob;
	gteEntity  : CMGTE_Receival;
	parentTI : CM_TrackedItem;
	chassis : CM_TILC;
	hasChassis : Boolean;
begin
	if not self.isReceipt then
		return false;
	endif;
	
	if self.job = null then
		return null;
	endif;
	
	if not self.job.isKindOf(CM_RoadJob) then
		return null;
	endif;
	
	roadJob:=self.job.CM_RoadJob;
	
	if self.myRequest = null or not self.myRequest.isKindOf(CM_YardRequest) then
		return false;
	endif;
	
	if self.myRequest.CM_YardRequest.myGateEntity = null then
		return false;
	endif;
	
	gteEntity:= self.myRequest.CM_YardRequest.myGateEntity.CMGTE_Receival;
	if gteEntity.myParent = null then
		return false;
	endif;
	
	parentTI:=gteEntity.myParent.CMGTE_Receival.myTrackedItem;
	if parentTI.getImExStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD then
		return false;
	endif;
	
	if parentTI.myPrimaryActualLocation = roadJob.myVehicle.locationsController then
		return true;
	endif;
	
	chassis:=roadJob.getChassis(false,hasChassis);
	if chassis &lt;&gt; null and chassis.getImExStatus = TI_IMEX_STATUS_REMAINONBOARD then
		if chassis.hasTIonChassis(parentTI) then
			return true;
		endif;
	endif;
	return false;
	

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReleaseToChassis" id="c9b9ce3d-e2ca-4a5a-bf20-85b894cccf2d">
        <source>isReleaseToChassis(): Boolean;
/*

Date		Who		Reason
13 Jan 2014	cnwer1	Initial creation PAR 33302
11 May 2018	jlgrs1	make delete Terminal work
07 Mar 2025 navma1	MTN-34119 MTN | Dead lock (1081) on CM_AuditObjectDictByTimestamp
*/

vars
	job 	: CM_Job;
	request : CM_Request;
	gte		: CMGTE_Entity;
begin
	
	job := self.job;
	
	if job = null then
		return false;
	endif;
	
	
	if not job.isRoadJob then
		return false;
	endif;
	
	if not self.isReleaseTypeRequest then
		return false;
	endif;
	
	
	//only interested in cargo to be released on to the chassis not chassis it self
	
	if self.job.CM_RoadJob.myVehicleVisit &lt;&gt; null and
	   self.job.CM_RoadJob.myVehicleVisit.myOutCMGTE_Chassis = null then
		return false;
	endif;
	
	request := self.myRequest;
	
	if request = null then
		return false;
	endif;
	
	gte := request.CM_YardRequest.myGateEntity;
	
	if gte = null then
		return false;
	endif;
	
	if  gte.isChassisOut then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReleaseToPack" id="551cf65e-f16c-4c54-a3b6-afc23b59dab4">
        <source>isReleaseToPack(): Boolean;
/*

Date		Who		Reason
14 July 2014	cnwer1	Initial creation PAR

*/

vars
	roadJob : CM_RoadJob;
	gteEntity  : CMGTE_Entity;
	parentTI : CM_TrackedItem;
begin
	if not self.isReleaseTypeRequest then
		return false;
	endif;
		
	if self.job = null then
		return false;
	endif;
	
	if not self.job.isKindOf(CM_RoadJob) then
		return false;
	endif;

	roadJob:=self.job.CM_RoadJob;
	
	if self.myRequest = null or not self.myRequest.isKindOf(CM_YardRequest) then
		return false;
	endif;
	
	if self.myRequest.CM_YardRequest.myGateEntity = null then
		return false;
	endif;
	
	
	gteEntity:= self.myRequest.CM_YardRequest.myGateEntity;
	if gteEntity.myParent &lt;&gt; null then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSetToVoidRoadRcvInvoiceLine" id="2c480c67-ebd7-4460-8181-a8525c346e87">
        <source>isSetToVoidRoadRcvInvoiceLine() : Boolean;
/*
Purpose:	Determines if selected option for 'Road Operation Delete Current Entry' is an option that will
			set the status of all invoice lines to VOID. Options that will void invoice line are :
			Option 2 = Road Receive Deleted, Road Release Created, Road Receive Invoice Line Void
			Option 4 = Road Receive Deleted, Road Release NOT Created, Road Receive Invoice Line Void
Parameters:			

Return Value:		

Date		Who		TFS		Reason
29 Oct 2019	jlgdi1	46578	Initial creation
*/

vars
	selectedOption : Integer;
	
begin
	selectedOption := self.getRoadOpsDelCurEntryOption();
	return (selectedOption = DEL_CUR_ENTRY_OPTION_2) or (selectedOption = DEL_CUR_ENTRY_OPTION_4);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isUnactionedTIReceipt" id="c681ff7a-fefb-45f4-b317-7a11c56ff102">
        <methodInvocation>mapping</methodInvocation>
        <source>isUnactionedTIReceipt(set: Boolean; value: Boolean io) mapping;
//Retruns True if this is an unactioned receipt of a TI
vars
	request : CM_Request;
begin
	
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	value := false;
	
	if self.job = null then
		return;
	endif;
	
	request := self.myRequest;
	
	if request = null then
		return;
	endif;
	//----------------
	//If not a TI request, then nothing to do here..
	//----------------
	if not request.isKindOf(CM_TIRequest) then
		return;
	endif;
	//----------------
	//If not a TI receipt, then nothing to do here..
	//----------------
	if not request.CM_TIRequest.isReceipt then
		return;
	endif;
	
	if self.status &lt;&gt; WLE_UNACTIONED then
		return;
	endif;
	
	value := true;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
