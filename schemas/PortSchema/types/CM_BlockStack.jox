    <JadeMethod name="setForCreate" id="9b78a4f0-88f5-4c4f-ad49-a043cc9de536">
        <updating/>
        <source>setForCreate(_proxy : CM_BlockStack input; _passport : CM_Passport input) updating;
//setForCreate(_proxy : CM_BlockStack; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	concms1		ccms 1061 - Changed method signature to use proxy rather than controller
// ---------------------------------------------------------------------------
vars
	aController : CM_BlockController;
begin	
	_proxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	inheritMethod(_proxy, _passport);
	
	self.maxCapacity := _proxy.maxCapacity;
	self.height := _proxy.height;
	
	//29 Aug 2011	NDL	Par 28076
	self.rows := _proxy.rows;
	self.columns := _proxy.columns;
	self.enforceMaxCapacity := _proxy.enforceMaxCapacity;
	
	aController := self.createLC; // The reference from the controller to the block stack is set in here &lt;&lt;&lt;&lt;
	self.autoPlanEnabled := _proxy.autoPlanEnabled;
    // FD for 1446 : AutoplanEnabled fields only make sense to road ,rail ,crane transfer area, 
    // So the field of all the other area will be set to be false.   
	
	self.setAutoRelease( _proxy.autoRelease, _proxy.trxTypeOnRelease );	//28 May 2018	NDL	TFS 38897
	
	self.setIsOverlapped(_proxy.isOverlapped);
	
	self.setDoCreateLogicalDelTrx( _proxy.doCreateLogicalDelTrx );	//03 Aug 2017	NDL	TFS 5679

	if app.myPassport.isOpsViewEnabled(self.myTerminal) then // ### TFS 53369 12APR2022 NAVAB1
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_TERMINALAREA, self); // ### TFS 53369 12APR2022 NAVAB1
	endif;
	
end;</source>
        <Parameter name="_proxy" type="CM_BlockStack" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="fff3033b-e9ff-43f8-b325-c4d46b5c3eab">
        <updating/>
        <source>setForUpdate(_proxy :CM_BlockStack) updating;
//setForUpdate(_proxy : CM_BlockStack) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	
	inheritMethod(_proxy);
	
	//29 Aug 2011	NDL	Par 28076
	self.rows := _proxy.rows;
	self.columns := _proxy.columns;
	self.enforceMaxCapacity := _proxy.enforceMaxCapacity;

	self.height 			:= _proxy.height;
	self.maxCapacity 		:= _proxy.maxCapacity;
	self.autoPlanEnabled	:= _proxy.autoPlanEnabled;
    // FD for 1446 : AutoplanEnabled fields only make sense to road ,rail ,crane transfer area, 
    // So the field of all the other area will be set to be false.  
	
	self.setAutoRelease( _proxy.autoRelease, _proxy.trxTypeOnRelease );	//28 May 2018	NDL	TFS 38897
	
	self.setIsOverlapped(_proxy.isOverlapped);
	
	self.setDoCreateLogicalDelTrx( _proxy.doCreateLogicalDelTrx );	//03 Aug 2017	NDL	TFS 5679
	
	if self.allLocationsControllers.size = 0 then
		self.createLC;
	endif;
	
	if app.myPassport.isOpsViewEnabled(self.myTerminal) then // ### TFS 53369 12APR2022 NAVAB1
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TERMINALAREA, self); // ### TFS 53369 12APR2022 NAVAB1
	endif;
	
end;</source>
        <Parameter name="_proxy" type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="setIsFull" id="75068258-a8a2-48fc-888e-ecc541ef1111">
        <updating/>
        <source>setIsFull(_isFull: Boolean) updating;
//----------------------------------------------------------------
