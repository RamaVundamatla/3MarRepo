end;</source>
        <Parameter name="_numHatches" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="d7a90519-296a-4bb3-936e-e42da1dce279">
        <source>validateDelete(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpLocation : CM_LocationsController;
	m: CM_Manifest;
	foundBOL: Boolean;
begin
	// If manifest has no attached BOLS then ok to delete
	foreach m in self.allManifestsById do
		if m.allBOLsDT.size &gt; 0 then
			foundBOL := true;
		endif;
	endforeach;
	if foundBOL then
		app.raiseCMException2(ObjectStillHasEntries, self.getDisplayDetails(false), "General Cargo Manifest", null, null);
	endif;
	
	if self.myVoyage.archived then // TFS 7465
		return;
	endif;
	
	foreach tmpLocation in self.allLocationsByHatchPlace discreteLock do
		tmpLocation.validateForDelete();
	endforeach;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="fe3dcba6-d487-42f2-be38-193887d08280">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpLC : CM_GeneralCargoController;
	iter : Iterator;
begin
	inheritMethod(_passport);

	return;	//10 July 2013	NDL	Par 31965
	/*
	
	if self.numberOfHatches &lt; 1 then
		app.raiseCMException2(ERR_FIELD_HATCHES, self.numberOfHatches.String, 'Number Of Hatches', null, null);
		return;
	endif;
	
	// if number of hatches has been reduced then must validate excess hatches for delete
	iter := self.allLocationsByHatchPlace.createIterator();
	// check only those hatches no longer required i.e greater than numberOfHatches
	self.allLocationsByHatchPlace.startKeyGtr(self.numberOfHatches, null, iter);
	while iter.next(tmpLC) do
		tmpLC.validateForDelete();
	endwhile;
	
	*/
	

epilog
	delete iter;	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
