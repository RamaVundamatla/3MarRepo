    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="d700ee41-876b-4876-ae9d-caedb1448977">
        <source>validateForUpdate(pRealGridArea: CM_GridArea);
/*
----------   ----------  --------------------------------------------------
Created:	15 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	firstRTGArea		: CM_RTGArea;
begin
	inheritMethod(pRealGridArea);
	
	//epr par 17760 19/8/08 removed groupAreaSequence validation 
	
	//for RTG lanes to be created correctly, we need to enforce
	//the same number of rows and columns for areas within the lane:
	firstRTGArea := pRealGridArea.allTerminalAreaGroups.first.allTAsByTypeId.first.CM_RTGArea;
	
	if firstRTGArea = null then
		return;
	endif;
	
	if firstRTGArea = self or firstRTGArea = self.pxyGetRealObject.CM_RTGArea then
		return;
	endif;
	
	if firstRTGArea.allGridColumns.size &lt;&gt; self.allGridColumns.size then
		app.raiseCMException2(ERR_INVALID_VALUE,'total number of columns','The number of columns must be the same as other RTG areas created', ETRow_NumberOfCols, null);
	endif;
	
	if firstRTGArea.allGridRows.size &lt;&gt; self.allGridRows.size then
		app.raiseCMException2(ERR_INVALID_VALUE,'total number of rows','The number of rows must be the same as other RTG areas created', ETRow_NumberOfRows, null);
	endif;
	
	//done on the proxy object
	if self.allAssociatedInterchangeAreas.size = 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Side_IC_Area_Position),null,null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Side_IC_Area_Position),null,null); // cnwdb2	PAR 35364
	endif;
end;


</source>
        <Parameter name="pRealGridArea" type="CM_GridArea"/>
    </JadeMethod>
