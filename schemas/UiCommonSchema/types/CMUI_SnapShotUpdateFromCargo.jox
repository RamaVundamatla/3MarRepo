    <JadeMethod name="showColourLegend" id="f2580172-0783-4da9-be56-bb1a86ff7e45">
        <source>showColourLegend();
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/

vars
	colLegend	: CMUI_ColourLegend;
	
begin

	create colLegend;
	colLegend.centreWindow;
	
	colLegend.addLegendItem("Same Values",		Black, White,		null, false);
	colLegend.addLegendItem("Different Values",				Black, PalePink,	null, false);
	colLegend.addLegendItem("Has Been Merged", White, Grey,		null, true);
	
	colLegend.height := 200;
	colLegend.showModal;

epilog
	delete colLegend;


end;</source>
    </JadeMethod>
    <JadeMethod name="showDataForProperty" id="61377dad-5dee-4382-aa80-d8f2b1b2e5c0">
        <source>showDataForProperty(_entRow : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2018	jlgab1	Initial creation

*/

vars

	snap : CM_SnapShot;
	snapti : CM_TISnapShot;
	table : CM_DataTable;
	ti : CM_TrackedItem;
	snapvalue, cargovalue : String;
	rowidx : Integer;
begin
	
		table := self.tblData;
		table.rows := table.fixedRows;

		
		foreach snap in self.allEditSnapShots	discreteLock do
			snapti := snap.CM_TISnapShot;
			ti := snapti.myTrackedItem;
			if ti = null then	//24 Mar 2021	NDL	TFS 50835
				continue;
			endif;
			
			snapvalue := snapti.getDisplayStringForAttribute(_entRow,false).String;
			cargovalue := ti.getDisplayStringForAttribute(_entRow, false).String;
			
			rowidx := table.addItemObject(snapti,snapti.id &amp; Tab &amp;snapvalue &amp; Tab &amp; cargovalue);
			if snapvalue &lt;&gt; cargovalue then
				table.accessRow(rowidx).backColor := PalePink;
			endif;
			if ti.hasBeenMerged() then // ZOMBIE
				table.accessRow(rowidx).backColor := Grey;
				table.accessRow(rowidx).foreColor := White;
			endif;

			self.beginNotification(snapti, Any_System_Event, Response_Continuous, 0);
			
		endforeach;
		
	epilog

end;</source>
        <Parameter name="_entRow" type="String"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="e1b9748a-31e4-4989-9bf3-c13d3e826a6d">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2018	jlgab1	Initial creation

*/

vars
	tiSnapShot	: CM_TISnapShot;
	uSnapShot : CM_UserTISnapShot;
	rowIdx		: Integer;
	bckColour	: Integer;
	entTableRow : EntTableRow;
	snapvalue : String;
begin


	if CM_UserTISnapShot.hasInstance(theObject) then
		uSnapShot := theObject.CM_UserTISnapShot;
		tiSnapShot := uSnapShot.myParentSnapShot;
	elseif CM_TISnapShot.hasInstance(theObject) then
		tiSnapShot := theObject.CM_TISnapShot;
	endif;
	
	if eventType = Object_Update_Event then
		if tiSnapShot &lt;&gt; null then
			if self.tblData.findObjectInRow(tiSnapShot, rowIdx) then
				entTableRow := self.cmbProperties.listObject.EntTableRow;
				snapvalue := tiSnapShot.getDisplayStringForAttribute(entTableRow.name,false).String;
			
				self.tblData.accessCell(rowIdx, 2).text := snapvalue;
			endif;			
			
		endif;
	endif;
	
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
