    <JadeMethod name="addCurrentCT2Combo" id="2aa191cf-3d68-4dba-a42e-5703a0a3503c">
        <source>addCurrentCT2Combo();
// ---------------------------------------------------------------------------
// Created:		12 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
// 11/09/2017	cnwma1  TFS #6897 JMT - Calculation Type Label Refactor
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// ---------------------------------------------------------------------------

vars
	aCT : CM_CalculationType;
	haveVTMIS : Boolean;
	haveCARGO : Boolean;
	tmpDesc : String;
begin
	haveVTMIS := app.myRoot.canDo(Mod_Harbour); // VTMIS License  //06.10.2017	cnwma1  TFS #7257
	haveCARGO := app.myRoot.canDo(Mod_CargoHandling); // CONTAINER LICENSE

	if self.myCurrentServiceObject.isKindOf(CM_Service) then
		aCT := self.myCurrentServiceObject.CM_Service.myCalculationType;
		// ### not in the combo, so add it in!!!
		if aCT &lt;&gt; null then
	
		/*  // ### TFS BUG 59913 31AUG2023 NAVAB1  
			// PAR 30428
			tmpDesc := "";
			if aCT.isVoyageCalcType then // TFS 39198
				tmpDesc := "HMS - ";
			elseif aCT.isCargoCalcType then // TFS 39198
					tmpDesc := "Cargo - ";
			elseif aCT.isEventCalcType then
					tmpDesc := "Event - ";
			endif;
			*/
			
			tmpDesc := tmpDesc &amp; aCT.getComboDescription(); // ### TFS BUG 59913 31AUG2023 NAVAB1  description;  //11/09/2017 cnwma1 TFS #6897
			
			if self.cmbCalcTypes.findObject(aCT) = -1 then
				if aCT.isCargoCalcType then
					if haveCARGO then
						// PAR 30428 self.cmbCalcTypes.addItemObject(aCT.description,aCT);
						self.cmbCalcTypes.addItemObject(tmpDesc,aCT);
					endif;
				elseif aCT.isVoyageCalcType then
					if haveVTMIS then
						// PAR 30428 self.cmbCalcTypes.addItemObject(aCT.description,aCT);
						self.cmbCalcTypes.addItemObject(tmpDesc,aCT);
					endif;
				else
					// PAR 30428 self.cmbCalcTypes.addItemObject(aCT.description,aCT);
					self.cmbCalcTypes.addItemObject(tmpDesc,aCT);
				endif;
			endif;
		endif;
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="4a102d79-4fa7-4a34-8e86-2ff2f10b2edb">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	frm				: CMUI_Toolbar;
begin	
//	inheritMethod();
	frm := self.frmToolbar;
	frm.addButton(self.btnPrintList, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnNewGroup, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnProperties, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnAudits, CMUI_Toolbar.Control_Alignment_Left);

	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left); 						// ### TFS 51912 14Sep2021 NAVPW1
	frm.addFrame(self.frmFilter, CMUI_Toolbar.Control_Alignment_Left);			// ### TFS 51912 14Sep2021 NAVPW1
	frm.addButton(self.btnClearFilter, CMUI_Toolbar.Control_Alignment_Left);	// ### TFS 51912 14Sep2021 NAVPW1
	
	frm.positionToolbarControls();
	frm.visible := true;

	frm := self.frmPropToolbar;
	frm.addButton(self.btnPropSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPropNext, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPropCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;

	frm := self.frmSeachToolbar;
	frm.addButton(self.btnSearchSearch, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSearchCancel, CMUI_Toolbar.Control_Alignment_Left);
	frm.positionToolbarControls();
	frm.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
