    <JadeMethod name="setQueueStatus" id="0fda0b12-3eed-462d-9ef1-9539514cc7f5">
        <updating/>
        <source>setQueueStatus(newStatus : Integer) updating;
// 29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	queueObj	: CM_RadioTelemetryQueue;
	entry		: CM_RTQueueEntry;
	term		: CM_Terminal;
	ti			: CM_TrackedItem;
begin
	if newStatus &lt;&gt; QSTATUS_HELD and newStatus &lt;&gt; QSTATUS_RUNNING then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_INVALID_QSTATUS, null, null);
		return;
	endif;
	
	//cnwrd1 20.6.2008 par #17012 start
	if status = QSTATUS_HELD and newStatus = QSTATUS_RUNNING then
		isInStartup	:= true;
	else
		isInStartup := false;
	endif;
	//cnwrd1 20.6.2008 par #17012 end
	
	//-----------
	//Catch enabling of sub queue of a disabled queue
	//-----------
	if newStatus = QSTATUS_RUNNING then
		if self.isKindOf(CM_SubQueue) then
			if self.CM_SubQueue.myParentQueue.status &lt;&gt;  newStatus then
				app.setContinueCMExceptions(false);
				app.raiseCMException1(ERR_PARENT_QSTATUS, '"' &amp; self.CM_SubQueue.myParentQueue.id &amp; '"', null, null);
				return;
			endif;
		elseif self.isKindOf(CM_VoyageQueue) then
			if self.CM_VoyageQueue.myParentQueue.status &lt;&gt;  newStatus then
				app.setContinueCMExceptions(false);
				app.raiseCMException1(ERR_PARENT_QSTATUS, '"' &amp; self.CM_VoyageQueue.myParentQueue.id &amp; '"', null, null);
				return;
			endif;
		endif;
	endif;
	exclusiveLock(self);	
	status := newStatus;
	//-------------
	//Status applies to all sub-queues
	//-------------
	foreach queueObj in self.allSubQueuesById do
		queueObj.setQueueStatus(newStatus);
	endforeach;
	//-------------
	//Set status to the Entries as well
	//-------------
	//foreach entry in self.allEntries do
	foreach entry in self.allEntries discreteLock do	//15 Feb 2011	NDL	Par 26994
		entry.setEntryStatus(status);
		// sends not to ti to update display (for held). 		
		if entry.myWorkListEntry &lt;&gt; null then 
			ti := entry.myWorkListEntry.myTrackedItem;
			if ti &lt;&gt; null then 
				ti.updateObjectEdition (ti);	// par 30292
			endif; 
		endif;	
	endforeach;
	
	term := app.myPassport.myTerminal;
	if term &lt;&gt; null then
		self.causeEvent(term.getTerminalEvent(RTQueue_Update_Event), false, null);
	endif;
	isInStartup := false; //cnwrd1 20.6.2008 par #17012
end;</source>
        <Parameter name="newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setQueueType" id="fdb83447-d5bd-427a-a4e0-3bc6cb50605f">
