<Class name="JadeScript">
    <JadeMethod name="eprMaxTransactionMap" id="c0338a87-3f2d-4063-a823-0e644831874a">
        <source>eprMaxTransactionMap();
/*

Date		Who		Reason
29 November 2016	cnwer1	Initial creation TFS

*/

vars

	i : Integer;
	pxyETM,realETM : CM_TranMapEvent;
	jblBank : CM_Bank;
begin
	app.initialize();
	app.myPassport.setMyUserFromCode("CNWER1");
	app.myPassport.setMyTerminal( app.myRoot.allTerminals["JBL"]);
	jblBank:="2202.136".asOid.CM_Bank;
	i:=4000;
	while i &lt; 6000 do
		realETM := jblBank.allEventTranMaps[i.padLeadingWith("0",5)];
		if realETM &lt;&gt; null then
			beginTransaction;
			delete  realETM;
			commitTransaction;
		endif;
		
		/*create pxyETM transient;
		pxyETM.setProxy(jblBank,i.padLeadingWith("0",5) , null);
		app.myTrxCA.trxCreateInvoiceTranMapEvent(pxyETM,realETM,app.myPassport);
		
		delete pxyETM;*/
		i:=i+1;
	endwhile;
	
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="exportFileTest" id="08197d21-e9f7-48ec-985d-e185d50249ec">
        <source>exportFileTest();
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 04 June 2008
//
// Implemented version:
// 
//----------------------------------------------------------------------
constants
	FileName : String = "TEST3.txt" ;
vars
	inv : CM_Invoice;
	finIO : CM_NAVPOE;
	filePathNAV : String;
	filePathDecfin : String;
begin
	app.initialize;
	app.myPassport.setMyUserFromCode("CNWSH3");
	
	inv := '2216.40'.asOid.CM_Invoice;
	finIO := CM_NAVPOE.firstInstance;
	
	filePathNAV := "C:\temp\NAV" &amp; FileName;
	//filePathDecfin := "C:\temp\Decfin" &amp; FileName;
	
	finIO.exportToFile(inv, filePathNAV);
//	finio1.exportToFile(inv, filePathDecfin);
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="transhipTranMapExtract" id="69ca29e1-298a-4e86-b9ce-2500e57ba9c5">
        <source>transhipTranMapExtract();
//----------------------------------------------------------------------
//  Created by cnwjre1 May 2010 for 23659
// 	extract invoicing cargo transaction map details relating to transhipment
//----------------------------------------------------------------------
vars
	filePath,
	fileName,
	fileSuffix	: String;
	name	: String;
	nameList	: StringArray;
	term	: CM_Terminal;
	tmcRoot	: CMIF_TMCRoot;
	tranGroup	: CMIF_TMCTranGroup;
begin
	app.initialize();
	if app.myPassport.myTerminal = null then 
		term := CM_Root.firstInstance.allTerminals['T01'];		// change as applicable
		app.myPassport.setMyTerminal(term);
	endif;
	
	create tmcRoot transient;
	tmcRoot.itemName := app.myPassport.myTerminal.getDefaultCompanyBank.code;
	tmcRoot.extractName := tmcRoot.itemName;
	tmcRoot.initialise(tmcRoot.groupCount);			// this creates the rest of the transients
	
	// change as appropriate
	filePath := "c:\temp\Tranship";
	fileSuffix := ".csv";
	
	create nameList transient;
	tmcRoot.getCargoMapNames(nameList);
	foreach name in nameList do
		tranGroup := tmcRoot.getCargoMap(name);
		fileName := filePath &amp; name &amp; fileSuffix;
		tranGroup.transhipOutputOnly := true;
		tranGroup.outputAsCSV(fileName, true);
	endforeach;

epilog
	delete tmcRoot;
	delete nameList;
end;</source>
    </JadeMethod>
</Class>
