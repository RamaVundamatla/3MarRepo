    <JadeMethod name="doAggregateBreakBulk" id="c2de98db-f28d-46a3-be9a-0927f0c57a16">
        <updating/>
        <source>doAggregateBreakBulk():Boolean protected, updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

	allTisToAggregate : CM_TISet;
	theReturn : Integer;
	lc : CM_LocationsController;
	itemPackagingWeightKgs : Decimal [16,4];
	operator : CM_Operator;
	aggregatedTi : CM_TrackedItem;
	txnController : CMIF_TITransactionController;
	newTITxn : CM_TITransaction;

begin

	create allTisToAggregate transient;
	if not self.validate( allTisToAggregate, lc, operator ) then
		return false;
	endif;
	
	itemPackagingWeightKgs := tblPkgingWeight.getConvertedValue();
	
	while true do 
	 								
		app.myTrxUA.trxAggregateBreakBulk(	self.cmbIDs.listObject.CM_Bulk,	//_targetTi : CM_Bulk;
											itemPackagingWeightKgs,	//_pkgWeight : Decimal;
											self.cmbIDs.text.trimBlanks.toUpper,	//_id : String;
											self.cmbNewCargoType.listObject.CM_CargoType,	//_cargoType : CM_CargoType;
											self.cmbNewSubCargo.listObject.CM_Product,	//_product : CM_Product;
											operator,	//_operator : CM_Operator;
											lc,	//_location : CM_LocationsController;
											allTisToAggregate,	//_allItemsToBeMerged : CM_TISet;
											aggregatedTi,	//_aggregateTi : CM_TrackedItem output;
											app.myPassport	//_passport : CM_Passport input
											);
	
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
			
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Merge_breakbulk), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			return false;
		endif;
		break;
		
	endwhile;
	
	//02 Oct 2017	NDL	TFS 5744
	if aggregatedTi &lt;&gt; null then
		if app.msgBox(app.getErrorString( Aggregation_complete), app.getErrorString(Complete), MsgBox_Yes_No ) = MsgBox_Return_Yes then
			
			create txnController transient;
			txnController.type := TRANS_TYPE_AGGREGATEDCOMPLETE;
			txnController.noCharge := false; 
			txnController.myTerminal := self.myTerminal;
			txnController.myTrackedItem := aggregatedTi;
			
			app.myTrxCA.trxCreateTITransaction(txnController, newTITxn, app.myPassport);
			
		endif;
	endif;

	return true;

epilog

	delete allTisToAggregate;
	delete txnController;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="f3335725-33f7-475a-a0ad-457a18b5ab6c">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

begin

	if not self.doAggregateBreakBulk() then
		return;
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="287a005f-d239-4918-925b-38ed39fdcaef">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

begin

