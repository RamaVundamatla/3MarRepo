    <JadeMethod name="addItem" id="9772cb82-ad12-4923-9c9f-1cbfbed3b31a">
        <updating/>
        <source>addItem(pItem : CM_Object; _carrierEmail: CM_ObjectEmail) updating;
// ---------------------------------------------------------------------------
// Created:     26 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if (not self.allItems.includes(pItem)) then
		self.allItems.add(pItem);
		pItem.emailNotify(_carrierEmail, false, self);
	endif;

end;</source>
        <Parameter name="pItem" type="CM_Object"/>
        <Parameter name="_carrierEmail" type="CM_ObjectEmail"/>
    </JadeMethod>
    <JadeMethod name="addRecipientEmails" id="e78a69f4-60a5-4c65-bee7-a3b1cf83c7ff">
        <source>addRecipientEmails(_carrierEmail: CM_PINObjectDefaultEmail; _clearFirst: Boolean);
//----------------------------------------------------------------
//	Created:	07 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpObjectEmail	: CM_PINObjectDefaultEmail;
	emailCtrl		: CMIF_EmailTemplateController;
	carrierAddr		: String;
begin

	tmpObjectEmail	:= _carrierEmail;
	if _clearFirst then
		self.allEmailRecipients.clear;
	endif;
	
	if tmpObjectEmail = null then
		return;
	endif;
	
	carrierAddr := tmpObjectEmail.allCarrierAddresses.getAddresses;

	if not(self.allEmailRecipients.includes(carrierAddr)) and
	   carrierAddr &lt;&gt; null then //par15417 cnwrs1 nov 2007 
		self.allEmailRecipients.add(carrierAddr);
	endif;
	
	if tmpObjectEmail.myEmailController &lt;&gt; null then
		emailCtrl := tmpObjectEmail.myEmailController;
		
		if emailCtrl.freeTxtToAddesses &lt;&gt; null 
		and not(self.allEmailRecipients.includes(emailCtrl.freeTxtToAddesses)) then
			self.allEmailRecipients.add(emailCtrl.freeTxtToAddesses);
		endif;
		
		if emailCtrl.freeTxtCcAddesses &lt;&gt; null 
		and not(self.allEmailRecipients.includes(emailCtrl.freeTxtCcAddesses)) then
			self.allEmailRecipients.add(emailCtrl.freeTxtCcAddesses);
		endif;
		
		if emailCtrl.freeTxtBccAddesses &lt;&gt; null 
		and not(self.allEmailRecipients.includes(emailCtrl.freeTxtBccAddesses)) then
			self.allEmailRecipients.add(emailCtrl.freeTxtBccAddesses);
		endif;
	endif;
	
end;</source>
        <Parameter name="_carrierEmail" type="CM_PINObjectDefaultEmail"/>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDelete" id="574d9591-0266-4099-9a65-142746e7e71a">
        <source>canDelete(_removeTIs : CM_TISet input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     27 August 2004 by cnwrs2
//
// Purpose:     Should only be called from CM_Terminal.fixupPINs
//				We pass in the removeTIs set to avoid overhead of
//				creating it each time
// ---------------------------------------------------------------------------
vars
	tmpObj	: CM_Object;
	tmpTI	: CM_TrackedItem;
begin

	exclusiveLock(self);
	
	if self.allItems.isEmpty then
		return true;
	endif;
	
	_removeTIs.clear();
	
	foreach tmpObj in self.allItems do
		if (not CM_TrackedItem.hasInstance(tmpObj)) then
			// don't currently handle non-TI objects so cannot delete
			return false;
		endif;
		tmpTI := tmpObj.CM_TrackedItem;
		exclusiveLock(tmpTI);
		if tmpTI.isChild then
			// child TI's should never have a PIN
			_removeTIs.add(tmpTI);
			continue;
		endif;

		if tmpTI.site = TI_SITE_ONSITE or
		   tmpTI.state = TI_STATE_NOTIFIED then
			// pre-notified TI's are valid for a PIN
			// on-site TI's can have a release PIN
			continue;
		endif;

		// assume that the TI can have its PIN removed
		_removeTIs.add(tmpTI);

	endforeach;
	
	if (not _removeTIs.isEmpty()) then
		foreach tmpTI in _removeTIs do
			// do not call tmpTI.clearPIN here as
			// that deletes this object and we are
			// iterating through a collection of these
			self.allItems.remove(tmpTI);
		endforeach;
	endif;

	return self.allItems.isEmpty;

end;</source>
        <Parameter name="_removeTIs" type="CM_TISet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erasePIN" id="b67943eb-f4f1-411e-8dc7-defe911a7f2e">
        <updating/>
        <source>erasePIN(_carrierEmail: CM_ObjectEmail) updating;
//----------------------------------------------------------------
//	Created:	24 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	obj			: CM_Object;
begin

	exclusiveLock(self);
	foreach obj in self.allItems do
		obj.emailNotify(_carrierEmail, true, self);	
	endforeach;

	self.erase(0);
	
end;</source>
        <Parameter name="_carrierEmail" type="CM_ObjectEmail"/>
    </JadeMethod>
    <JadeMethod name="getContainerFromWO" id="61d078df-382c-4517-a483-db7fa7cfd9bf">
        <source>getContainerFromWO( _contId : String ):CM_Container;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2019	jlgndl1	Initial creation	TFS 43491

*/

vars

	item : CM_Object;
	wo : CM_WorkOrderTI;
	ti : CM_TrackedItem;

begin

	foreach item in self.allItems where item.isKindOf(CM_WorkOrderTI) do
		wo := item.CM_WorkOrderTI;
		foreach ti in wo.allTIs do
			if ti.id = _contId and ti.isContainer then
				return ti.CM_Container;
			endif;
		endforeach;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_contId" type="String"/>
        <ReturnType type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="getCreatedLocalTZ" id="3776a7fe-dfd5-479c-a67b-8b0c71e426fd">
        <source>getCreatedLocalTZ() :TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2016	cnwns1	Initial creation
// 30 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.created);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
