    <JadeMethod name="setupForm" id="039e766b-18d1-47df-97f9-f046e9226d66">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Apr 2025 navlc30 JIRA 34266 TPT | FR 33661.040 VBS - One Release Request and Multiple VBS - On Schedule
07 Apr 2025	navnk30	JIRA 34267: TPT | FR 33661.050 VBS - One Release Request and Multiple VBS Appointments ? Off Schedule

*/

vars
	etDef			: EntTableDef;
begin
	inheritMethod();
	self.tblBookings.selectMode := CM_DataTable.SelectMode_CurrentRow;
	
	etDef := app.myController.getEntTableDef(ETDef_AssociateBooking);
	self.tblBookings.setTblDataEntRowsFromDef(etDef);
	self.populateBookings();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblBookings_contextMenu" id="07c85187-9bb1-4e2e-a8f2-088a58aba290">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblBookings_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Apr 2025	navnk30	JIRA 34267: TPT | FR 33661.050 VBS - One Release Request and Multiple VBS Appointments ? Off Schedule

*/

vars

begin
	self.mnuInspectObject.visible := app.isAllowedToInspect() and
			self.tblBookings.accessRow(self.tblBookings.row).itemObject &lt;&gt; null;
	self.popupMenu(self.mnuContextOptions, x, y);
	return false;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="41f2a1c6-0aa1-4c93-b69a-3a2f6d7cf92a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 08 April 2025 22:00:27.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0027076, locale);
	btnNoBooking.translateCaption(Xlat_0027077, locale);
	btnReject.translateCaption(Xlat_0027078, locale);
	btnUseBooking.translateCaption(Xlat_0027079, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0027080, locale);
	mnuContextOptions.translateCaption(Xlat_0027081, locale);
	mnuInspectObject.translateCaption(Xlat_0027082, locale);
end;</source>
    </JadeMethod>
</GUIClass>
