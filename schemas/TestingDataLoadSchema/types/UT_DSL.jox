    <JadeMethod name="addInterTermConfig" id="5edb9bf8-353d-4799-aac1-5ae1b11f9b3f">
        <source>addInterTermConfig( 	configName : String ; 
						gate       : CM_Gate;
						laneController : CM_YardController;
						sourceTerm : CM_Terminal ; 
						ta : CM_TerminalArea;
						autoIn, autoOut : Boolean; 
						destTerm : CM_Terminal;
						consignee : CM_ConsigneeConsignor;
						voyCode : String;
						voyage : CM_Voyage;
						delReasonID : Integer;
						delReason : String;
						subTerm : CM_SubTerminal
						) : CM_InterTerminalConfig;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2010	cnwrd1	Initial creation

*/

vars
	myITCProxyObject,
	realInterTerminalConfig : CM_InterTerminalConfig ;
	targetTermInfo  		: CM_InterTermTargetTermInfo;
	myITBRProxyObject     	: CM_InterTerminalBulkRelease;
	taSet 					: CM_TerminalAreaSet;
begin


	create taSet transient;
	
	create myITCProxyObject transient;
	create myITBRProxyObject transient;
	create targetTermInfo transient;
	
	
	taSet.add(ta);
	
			
	myITBRProxyObject.setProxyForITBR(	configName, 
										consignee, 
										voyCode, 
										delReasonID,
										delReason,
										sourceTerm, 
										null, 
										voyage, 
										subTerm);

	
	myITCProxyObject.setProxy(	configName,
								gate,
								laneController.CM_GateAreaLaneController, //going to barf:(
								myITBRProxyObject,
								sourceTerm,
								taSet,
								autoIn, 
								autoOut
								);

	targetTermInfo.updateProxy(	true,
								null,
								destTerm);
								
	myITCProxyObject.allInterTermTargetTermInfo.add(targetTermInfo);
	
	
	app.myTrxCA.trxCreateInterTerminalConfig(myITCProxyObject, realInterTerminalConfig, myITBRProxyObject, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return realInterTerminalConfig;
epilog
	delete myITCProxyObject ;
	delete myITBRProxyObject ;
	delete targetTermInfo;
	delete taSet;
end;</source>
        <Parameter name="configName" type="String"/>
        <Parameter name="gate" type="CM_Gate"/>
        <Parameter name="laneController" type="CM_YardController"/>
        <Parameter name="sourceTerm" type="CM_Terminal"/>
        <Parameter name="ta" type="CM_TerminalArea"/>
        <Parameter name="autoIn" type="Boolean"/>
        <Parameter name="autoOut" type="Boolean"/>
        <Parameter name="destTerm" type="CM_Terminal"/>
        <Parameter name="consignee" type="CM_ConsigneeConsignor"/>
        <Parameter name="voyCode" type="String"/>
        <Parameter name="voyage" type="CM_Voyage"/>
        <Parameter name="delReasonID" type="Integer"/>
        <Parameter name="delReason" type="String"/>
        <Parameter name="subTerm" type="CM_SubTerminal"/>
        <ReturnType type="CM_InterTerminalConfig"/>
    </JadeMethod>
