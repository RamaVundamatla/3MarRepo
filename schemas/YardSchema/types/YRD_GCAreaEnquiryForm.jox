    <JadeMethod name="setAllRacks" id="87c4e577-bded-494b-a4d9-1988f7a1fd31">
        <source>setAllRacks();
/*
Purpose:			
Date		Who		Reason
04 September 2013	cnwab1	Initial creation
*/

vars
	idx, x1, y1, z1 : Integer;
	rack : CM_IrregularBlockController;
	obj : Object;
	objs : ObjectSet;
begin

	objs := self.userObject.ObjectSet;
	foreach obj in objs discreteLock do
		rack := obj.CM_IrregularBlockController;
		
		x1 := rack.region.first.x;
		y1 := rack.region.first.y;
		z1 := rack.locationOrdinal;
		
		self.allRacks.putAtKey(y1,x1,z1,rack);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCaptionForModesGetView" id="9e9847c6-5f0c-429b-89fb-75b5ff0c532b">
        <source>setCaptionForModesGetView(_theMode : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 12/11/2012	cnwcs5	par 30519 - translations
vars
	theString : String;
begin
	
	theString := app.getErrorString1 (Yard_area_view_mode, app.getViewModeString(self.myCurrentDrawingController.viewMode)); 
	
	theString := theString &amp; " ";

	return theString;	

end;</source>
