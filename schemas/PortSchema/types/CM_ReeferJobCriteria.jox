    <JadeMethod name="getConnectReeferTS" id="3cd03dff-9a51-46ee-9a31-5356ab9edffe">
        <source>getConnectReeferTS():TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	now : TimeStamp;
	interval : TimeStampInterval;
	newTimeStamp : TimeStamp;

begin

	if not self.connect then
		return null;
	endif;
	
	now := app.actualTimeAppServer;
	
	if connectDelayMins &gt; 0 then
		interval.set(0, connectDelayMins * 60000 );
		newTimeStamp := now + interval;
	else
		newTimeStamp := now; 
	endif;
	
	return newTimeStamp;
	
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisconnectReeferTS" id="e820c534-c73a-49d3-876c-053b29a95318">
        <source>getDisconnectReeferTS():TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	now : TimeStamp;
	interval : TimeStampInterval;
	newTimeStamp : TimeStamp;

begin

	if not self.disconnect then
		return null;
	endif;
	
	now := app.actualTimeAppServer;
	
	if disconnectDelayMins &gt; 0 then
		interval.set(0, disconnectDelayMins * 60000 );
		newTimeStamp := now + interval;
	else
		newTimeStamp := now; 
	endif;
	
	return newTimeStamp;
	
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getNextReeferMonitorTS" id="d28f9990-cac3-4c4e-b727-5a233d9855fc">
        <source>getNextReeferMonitorTS():TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	newTimeStamp : TimeStamp;
	now : TimeStamp;
	nowPlusTS : TimeStamp;
	minNextTime : Time;
	loopTime: Time;
	timeSet : Boolean;
	nextTime : Time;

begin

	if not self.monitor then
		return null;
	endif;
	
	//get the minimum re-monitor time ( It might be tomorrow i.e earlier than now as a time)
	now := app.actualTimeAppServer;  //timestamp
	nowPlusTS := now + self.variance; // timestamp plus timestampinterval = new timestamp
	minNextTime := nowPlusTS.Time; // now just the time portion of that
	
	if self.allTimes.isEmpty then
		return nowPlusTS;
	endif;
	
	// rip thru the times to find teh next one after our value
	foreach loopTime in self.allTimes do
		if loopTime &gt; minNextTime then
			nextTime := loopTime;
			timeSet := true;
			break;
		endif;
	endforeach;
	//there wasn't one today later than now, so we must want tomorrows first one
	if not timeSet then
		nextTime := self.allTimes.first;
	endif;
	
	newTimeStamp.setTime( nextTime );
	if nextTime &lt; now.time then // must be for tomorrow
		newTimeStamp.setDate( now.date + 1 );
	else
		newTimeStamp.setDate( now.date );
	endif;
	
	return newTimeStamp;

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplayString" id="48fee4fe-8200-428d-ba3e-bebf1727b879">
