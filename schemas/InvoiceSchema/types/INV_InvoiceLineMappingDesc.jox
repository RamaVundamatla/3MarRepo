	self.btnShowSearcher.enabled	:= true;
	self.frmProperties.visible		:= false;
	self.searcherShowHideControls(true);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbBankBuild" id="0a0a67d8-55ce-49e8-aed0-5f063e446577">
        <source>doCmbBankBuild() protected;
/*

Purpose:			Builds the Bank combo box

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	company			: CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
	combo			: CMUI_ComboBox;
	
begin
	combo := self.cmbBank;
	
	create businessUnits transient;
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	
	foreach company in businessUnits do
		combo.addItem(company.code);
		combo.itemObject[combo.newIndex] := company;
	endforeach;
	
	if currentBU &lt;&gt; null then
		combo.listObject := currentBU;
	endif;
	
epilog
	delete businessUnits;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbBankPropBuild" id="1a4b8634-41f8-4aa3-9a38-db07366c926f">
        <updating/>
        <source>doCmbBankPropBuild() updating, protected;
/*

Purpose:			Builds the Bank combo box for the properties frame

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
11 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	company			: CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
	combo			: CMUI_ComboBox;
	
begin
	combo := self.cmbBankProp;
	
	create businessUnits transient;
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	
	foreach company in businessUnits do
		combo.addItem(company.code);
		combo.itemObject[combo.newIndex] := company;
	endforeach;
	
	if currentBU &lt;&gt; null then
		combo.listObject := currentBU;
	endif;
	
epilog
	delete businessUnits;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbDebtorBuild" id="8e3ccccc-d236-4496-b892-6ae22cc312b4">
        <updating/>
        <source>doCmbDebtorBuild() updating, protected;
/*

Purpose:			Builds the Debtor combo box

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
11 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	debtor	: CM_Debtor;
	combo	: CMUI_ComboBox;
	
begin
	combo := self.cmbDebtor;
	
	combo.clear;
	combo.sorted := false;
	
	foreach debtor in app.myRoot.myRootCompany.debtors where not debtor.isSuspended do
		combo.addItem(debtor.name);
		combo.itemObject[combo.newIndex] := debtor;
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbInvLineTypeBuild" id="eca9591d-b95d-43af-8339-a41287f02aea">
        <updating/>
        <source>doCmbInvLineTypeBuild() updating, protected;
/*

Purpose:			Builds the Invoice Line Type combo box

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
11 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	invLineType	: CM_InvoiceLineDesc;
	combo		: CMUI_ComboBox;
	
begin
	combo := self.cmbInvoiceLineType;
	
	combo.clear;
	combo.sorted := true;
	
	foreach invLineType in self.myCurrentBank.invoiceLineDescriptors do
		if invLineType.isNotAvailableForEntry then
			continue;
		endif;
		
		combo.addItem(invLineType.narration);
		combo.itemObject[combo.newIndex] := invLineType;
		
	endforeach;
	
	combo.sorted := false;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbInvoiceTypeBuild" id="4485cbe5-9d1f-4545-accc-dbe2ea63b6e4">
        <updating/>
        <source>doCmbInvoiceTypeBuild() protected, updating;
/*

Purpose:			Builds the Invoice Type combo box

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
11 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	invType	: CM_InvoiceDesc;
	combo	: CMUI_ComboBox;
	
begin
	combo := self.cmbInvoiceType;
	
	combo.clear;
	combo.sorted := true;
	
	// show 'not available for entry' invoice types for the enquiry combo
	//	but not for the new invoice combo
	foreach invType in self.myCurrentBank.invoiceTypes do
		if invType.isNotAvailableForEntry then
			continue;
		endif;
		
		combo.addItem(invType.description);
		combo.itemObject[combo.newIndex] := invType;
		
	endforeach;
	
	combo.sorted := false;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="44a3c4e2-7995-4dad-a537-34daabf2b126">
        <updating/>
        <source>doDelete() updating;
/*

Purpose:			What to do when we delete an Invoice Line Mapping

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
10 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	selectedInvLineDescMapping,
	realMapping					: CM_InvoiceLineDescMapping;
	theReturn					: Integer;
	
begin
	selectedInvLineDescMapping := self.myCurrentInvLineMapping;
	
	if selectedInvLineDescMapping = null then
		return;
	endif;
	
	realMapping := self.myCurrentBank.allInvoiceLineDescMappings[selectedInvLineDescMapping.myDebtor.CM_Debtor, selectedInvLineDescMapping.myInvoiceLineDesc, selectedInvLineDescMapping.myInvoiceType];
	
	if realMapping = null then	
		return;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteInvoiceLineDescMap(realMapping, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.frmProperties.visible := false;
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Mapping Remove", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doEditItem" id="09dd1dcf-1d22-4305-8f08-148937a24d6b">
        <updating/>
        <source>doEditItem() updating;
/*

Purpose:			What to do when we delete an Invoice Line Mapping

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
10 October 2022	navpw1	Initial creation TFS: 54566

*/

begin
	self.mode := self.Mode_Update;
	self.initCreateEditFrame(self.myCurrentInvLineMapping);
	self.btnShowSearcher.enabled := false;
	self.searcherShowHideControls(false);
	self.setControlsForView();
	self.btnAddItem.enabled := false;
	self.frmProperties.visible := (not self.frmProperties.visible);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doExportMappings" id="72419e46-2364-4ef8-b80b-cb39573ea2a7">
        <source>doExportMappings() protected;
/*

Purpose:			Used to export invoice line type mappings for debtors and invoice types

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
06 October 2022	navpw1	Initial creation TFS: 54566
20 March 2023	navmk20	Bug 56954: FR | 53978 - EUP - Invoicing - Configuration Enhancements - User Story 050 issues
*/

vars
	cmifInvoiceLineMapping		: CMIF_InvoiceLineMapping;
	exportFile					: File;
	fileSave					: CMDFileSave;
	cmifMonitor					: CMIF_Monitor;
	selectedDebtors				: CM_DebtorNodeByNameDict;
	bank						: CM_Bank;
	selectedInvLineTypes		: CM_InvLineDescByNarrDupsADict;
	exportPath					: String;			// 20.3.2023 navmk20 TFS 59654
	
begin
	bank := self.cmbBank.listObject.CM_Bank;
	
	if bank = null then
		bank := self.myCurrentBank;
	endif;
	
	if self.myCurrentBank = null then
		app.msgBox(app.getErrorString(Bank_selected), app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	/* Start - 20.3.2023 navmk20 TFS 56954
	create exportFile transient;
	exportFile.mode := File.Mode_Output;
	
	create fileSave transient;
	fileSave.filter 	:= '.csv|*.csv';
	fileSave.fileName 	:= '';
	fileSave.initDir	:= "C:\";
	
	if fileSave.open = 0 then
		exportFile.fileName := fileSave.fileName;
	endif;
	
	if exportFile.fileName = null then
		return;
	endif; End - 17.3.2023 navmk20 TFS 56954 */
	// Start - 17.3.2023 navmk20 TFS 56954
	create fileSave transient;
	fileSave.dialogTitle := app.getErrorString(INV_InvLineMappingDesc);
	fileSave.resetCurrentPath := true;
	exportPath := "%MiscDir%\"&amp; app.getErrorString(INV_InvLineMappingDesc) &amp; "\";
	fileSave.initDir := self.getExportFileNameBase(exportPath);
	fileSave.fileName := self.getExportFileName(app.actualTimeAppServer,CSV_Filetype);
	
	if fileSave.open = 0 then
		create exportFile transient;
		if fileSave.fileName.toUpper().pos(".CSV",1) = 0  // 20 March 2023	navmk20	Bug 56954, No CSV
		and fileSave.fileName.pos(".",1) = 0 then // 20 March 2023	navmk20	Bug 56954, no suffix
			exportFile.fileName := fileSave.fileName &amp; ".csv"; // 20 March 2023	navmk20	Bug 56954
		else // 20 March 2023	navmk20	Bug 56954
			exportFile.fileName := fileSave.fileName;
		endif;
		exportFile.mode := File.Mode_Output;

		if (not exportFile.tryOpen) then
			app.raiseCMException1(FileUnavailable, exportFile.fileName, null, null);	
		endif;
	endif; 
	
	if exportFile = null then
		return;
	endif;
	// End - 20.3.2023 navmk20 TFS 56954
	
	self.initModalDialog();
	self.lblModalMessage.caption := Cr &amp; (app.getErrorString(Exporting) &amp; ' ' &amp; app.getErrorString(INV_InvLineMappingDesc));
	
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	
	if cmifMonitor &lt;&gt; null then
		cmifMonitor.updateProgress(app.getErrorString(Writing_export_file), 100, 0);
	endif;
	
	self.frmModalDialog.visible := true;
	self.doWindowEvents(2);
	if self.frmModalDialog.visible then
		self.frmModalDialog.doWindowEvents(2);
	endif;
	
	create selectedDebtors transient;
	self.mulDebtors.getSelected(selectedDebtors);
	
	create selectedInvLineTypes transient;
	self.mulInvLineTypes.getSelected(selectedInvLineTypes);
	
	create cmifInvoiceLineMapping transient;
	//exportFile.openOutput(exportFile.fileName); //20.3.2023 navmk20 TFS 56954
	cmifInvoiceLineMapping.doExtractInvLnMappingCsvFile(exportFile, bank, selectedDebtors, selectedInvLineTypes, cmifMonitor);
	
epilog
	app.mousePointer := MP_DEFAULT;
	delete cmifInvoiceLineMapping;
	delete exportFile;
	self.frmModalDialog.visible := false;
	delete fileSave;
	delete cmifMonitor;
	delete selectedDebtors;
	delete selectedInvLineTypes;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doImportMappings" id="9fc85411-c18e-4c9f-b35d-2a5c8c64dba0">
        <updating/>
        <source>doImportMappings() protected, updating;
/*

Purpose:			Used to import invoice line type mappings for debtors and invoice types

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	impFile 		: File;
	fileGet 		: CMDFileOpen;
	cmifMonitor		: CMIF_Monitor;
	warningsResult	: Integer;
	
begin
	create impFile transient;
	impFile.kind := File.Kind_Unknown_Text;
	
	if impFile = null then
		app.raiseUnexpectedProgramError(class.name, method.name, " file is null - create file before calling ");
	endif;
	
	create fileGet transient;
	fileGet.filter 		:= '.csv|*.csv';
	fileGet.fileName 	:= '';
	fileGet.initDir 	:= "C:\";
	
	if fileGet.open = 0 then
		impFile.fileName := fileGet.fileName;
	endif;
	
	if impFile.fileName = null then
		return;
	endif;
	
	self.initModalDialog();
	self.lblModalMessage.caption := Cr &amp; (app.getErrorString(Importing) &amp; ' ' &amp; app.getErrorString(INV_InvLineMappingDesc));
	
	if app.myPassport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		//cmifMonitor.callBackMethodName := "updateProgress";
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
		
	endif;
	
	if cmifMonitor &lt;&gt; null then
		cmifMonitor.updateProgress(app.getErrorString(Reading_import_file), 100, 0);
		
	endif;
	
	self.frmModalDialog.visible := true;
	self.doWindowEvents(2);
	
	if self.frmModalDialog.visible then
		self.frmModalDialog.doWindowEvents(2);
	endif;
	
	while true do
		app.myTrxCA.trxImportInvLnMappingFromFile(impFile, self.myCurrentBank, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		endif;
		
		warningsResult := app.showErrorWarningDialog(app.getErrorString(Invoice_line_type_narra), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		
		if app.myPassport.noErrors and
		   warningsResult = IDOK then
			// there must have just been warnings that the user has acknoledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		
		break;
		
	endwhile;
	
	self.doQuery();
	
epilog
	delete impFile;
	self.frmModalDialog.visible := false;
	delete cmifMonitor;
	delete fileGet;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadData" id="da056618-d1be-4f67-8afa-f3b25032ce72">
        <source>doLoadData() protected;
/*

Purpose:			Loads the data into the table based on the query

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	invLineDescMapping	: CM_InvoiceLineDescMapping;
	pd					: CMS_Progress;
	ls					: Boolean;
	bank				: CM_Bank;
	invLineDescMapArray	: CM_InvLineDescMapByDebtorLType;
	theTable			: CM_DataTable;
	idx					: Integer;
	lastUpdate			: Decimal [20];
	invLineTypes		: CM_InvLineDescByNarrDupsADict;
	debtors				: CM_DebtorByNameDict;
	
begin
	bank := self.myCurrentBank;
	
	self.setNavigatorHeading(self.caption);
	
	on CM_ProgressException do haltProgress(exception, ls);
	
	create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.setAction("Loading Debtors...");
	
	//Populate Line Mappings
	create invLineDescMapArray transient;
	bank.allInvoiceLineDescMappings.copy(invLineDescMapArray);
	
	self.tblInfo.rows := 0;
	theTable := self.tblData;
	theTable.rows := theTable.fixedRows;
	theTable.clearAllSelected ();
	
	if not self.doMaxTableSizeCheck(invLineDescMapArray.size, null) then
		return;
	endif;
	
	pd.progress.partsInJob := invLineDescMapArray.size;
	
	create invLineTypes transient;
	create debtors transient;
	
	self.mulInvLineTypes.getSelected(invLineTypes);
	self.mulDebtors.getSelected(debtors);
	
	foreach invLineDescMapping in invLineDescMapArray do
		idx := idx + 1;
		if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then
			pd.setAction(app.getErrorString1(Loading_invoices,invLineDescMapping.myInvoiceLineDesc.narration));
			pd.progress.partsDone := idx;
			lastUpdate := app.relativeMachineTime;
		endif;
		
		if self.includeObject(invLineDescMapping, invLineTypes, debtors) then
			self.doQueryAddItem(invLineDescMapping);
		endif;
		
		if self.tblData.rows = JadeTableRowLimit then
			break;
		endif;
		
	endforeach;
	
epilog
	delete pd;
	delete invLineDescMapArray;
	delete invLineTypes;
	delete debtors;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="941c16cb-bebc-4e04-ac0b-01ccf2632b96">
        <source>doNotableClear();
/*

Purpose:			Clears notification objects

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
11 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	removedNotification	: Integer;
	
begin
	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="12189690-806c-45e2-bc40-05e5f5cfd092">
        <updating/>
        <source>doQuery() updating;
/*

Purpose:			What to do when we run a query

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	bank		: CM_Bank;
	theTable	: CM_DataTable;
	
begin
	bank := self.cmbBank.listObject.CM_Bank;
	
	if bank = null then
		bank := self.myCurrentBank;
	endif;
	
	if bank = null then
		return;
	endif;
	
	if bank &lt;&gt; self.myCurrentBank then
		self.myCurrentBank := bank;
	endif;
	
	self.doLoadData();
	
	self.setMyCaption();
	
	inheritMethod();
	
	theTable :=  self.tblData;
	
	if theTable.rows = 1 then
		self.btnImportCSVMap.enabled := false;
		self.btnExportCSVMap.enabled := false;
	else
		self.btnImportCSVMap.enabled := true;
		self.btnExportCSVMap.enabled := true;
	endif;
	
	if theTable.selectedCount &gt; 0 then
		self.setControlsForAddEdit();
	else
		self.setControlsForView();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItem" id="2ac9e2e2-c000-4cdd-9aaa-c0f24c1f3d7c">
        <source>doQueryAddItem(_invoiceLineDescMapping : CM_InvoiceLineDescMapping) protected;
/*

Purpose:			Adds an item to the data table

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	theDataLine		: String;
	idx				: Integer;
	theTable		: CM_DataTable;
	
begin
	if not global.isValidObject(_invoiceLineDescMapping) then
		return;
	endif;
	
	theTable := self.tblData;
	theDataLine := _invoiceLineDescMapping.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	idx := theTable.addItem(theDataLine);
	theTable.accessRow(idx).itemObject := _invoiceLineDescMapping;
	
end;</source>
        <access>protected</access>
        <Parameter name="_invoiceLineDescMapping" type="CM_InvoiceLineDescMapping"/>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="0a7cef3b-2440-4ed5-b424-2d6dae301bd8">
        <source>doResetSearch();
/*

Purpose:			Resets the search for the query

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
14 October 2022	navpw1	Initial creation TFS: 55142

*/

vars
	bankIndex : Integer;
	
begin
	inheritMethod();
	
	bankIndex := self.cmbBank.findObject(self.myCurrentBank);
	self.cmbBank.listIndex := bankIndex;
	self.mulDebtors.setSelected(null);
	self.mulInvLineTypes.setSelected(null);
	
end;</source>
