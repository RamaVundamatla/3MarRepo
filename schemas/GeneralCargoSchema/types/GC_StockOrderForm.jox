    </JadeMethod>
    <JadeMethod name="doTblDtlDataContext" id="f80eff52-1bb6-46f3-a998-3cd07eed3526">
        <updating/>
        <source>doTblDtlDataContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	x1, y1				: Real;
	ti					: CM_TrackedItem;
begin
	if not app.myCurrentUserCan(self.myTerminal,PmGCStockOrderMaint).Boolean then
		return false;
	endif;
	
	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if cntrl.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := cntrl.positionTop();
	    endif;
	endif;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	
	if self.mode &lt;&gt; self.Mode_Edit
	and self.mode &lt;&gt; self.Mode_New then
		self.mnuStockOrderNew.visible := true;
	else 
		self.mnuStockOrderNew.visible := false;
	endif;



	if self.tblDataDetail.rows &lt;= self.tblDataDetail.fixedRows and not (self.mode = self.Mode_Edit
	or self.mode = self.Mode_New) then 
		self.mnuDetailNew.visible := false; 
		self.mnuDetailEdit.visible := false;
		self.mnuDetailRemove.visible := false;
	elseif self.tblDataDetail.rows &lt;= self.tblDataDetail.fixedRows then 
		self.mnuDetailNew.visible := true; 
		self.mnuDetailEdit.visible := false;
		self.mnuDetailRemove.visible := false;
	elseif self.tblDataDetail.rows &gt; self.tblDataDetail.fixedRows and (self.mode = self.Mode_Edit
	or self.mode = self.Mode_New) then 
		self.mnuDetailNew.visible := true; 
		self.mnuDetailEdit.visible := false;
		self.mnuDetailRemove.visible := true;	
	else
		self.mnuDetailNew.visible := false;
		self.mnuDetailEdit.visible := true;
		self.mnuDetailRemove.visible := false;
//		self.mnuDetailRemove.caption := 'Remove StockOrderLine...';

	endif;	

	self.doMnuContextDetailBuild();
	
	//Not allowed to remove some items in this table as they are required for the rebuilding of the form.
	//Need to tweak Column Organiser and entTableDefs to allow a sort but not a removal of some fields.
	self.mnuDetailOrganiser.visible := false;
	
	self.popupMenu(self.mnuDetailContext, x1.Integer, y1.Integer);

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
