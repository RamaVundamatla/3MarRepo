    <JadeMethod name="getPINNumber" id="de1dc21d-d13e-424b-9522-7ebfcd0615fa">
        <source>getPINNumber() : String;

/*

Purpose:			// TFS 38524

Parameters:			

Return Value:		


Date		Who		Reason
23 May 2018	jlgab1	Initial creation

*/

vars

	relExt : CM_WodReleaseExtension;
	rel : CM_WodRelease;
	parent : CM_WorkOrder;

begin

	//12 Mar 2019	NDL	TFS 43405
	if self.isWorkOrderForReleaseExtension then
		relExt := self.allWoDtls.first.CM_WodReleaseExtension;
		if relExt &lt;&gt; null then
			rel := relExt.myReleaseWorkOrder;
			if rel &lt;&gt; null then
				parent := rel.getMyParent();
				if parent &lt;&gt; null then
					return parent.getPINNumber();
				endif;
			endif;
		endif;
	endif;

	if self.myPinNo&lt;&gt; null then
		return self.myPinNo.pinNo.String;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
