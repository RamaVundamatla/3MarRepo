    <JadeMethod name="createBookingRefDiscrepField" id="1d92731a-9fde-4221-93f1-398de1ebe73c">
        <source>createBookingRefDiscrepField(	_bookingRefFieldValue : String;
								_fieldName : String;
								_tiFieldValue : String
								):CM_BookingRefDiscrepFieldValue;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars
	discrepFieldValue : CM_BookingRefDiscrepFieldValue;
begin
	if self.isTransient then
		create discrepFieldValue transient;
	else
		create discrepFieldValue;
	endif;
	discrepFieldValue.setDetails(	_bookingRefFieldValue,	//_bookingRefFieldValue : String;
									_fieldName,	//_fieldName : String;
									_tiFieldValue,	//_tiFieldValue : String;
									self	//_myCMEVT_BookingRefDiscrep : CMEVT_BookingRefDiscrep
									);
	return discrepFieldValue;
			
epilog

end;</source>
        <Parameter name="_bookingRefFieldValue" type="String"/>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_tiFieldValue" type="String"/>
        <ReturnType type="CM_BookingRefDiscrepFieldValue"/>
    </JadeMethod>
