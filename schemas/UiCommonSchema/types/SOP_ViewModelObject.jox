    <JadeMethod name="allVMObjectsInsert" id="7c6a55ea-b0ad-4a1c-baac-d5663f7c8789">
        <source>allVMObjectsInsert(_index : Integer; _allVMs : ViewModelObjectArray input);
// -----------------------------------------------------------------------------
// Created:		30 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	_allVMs.insert(_index, self);
end;</source>
