27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars

begin
	return ETDef_EDITIVBSSlotItem;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTI" id="3e3fe4db-ce8c-4dd3-b6e5-f0ac35a38669">
        <source>getTI() : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars
	terminal : CM_Terminal;
	booking : CM_BookingRef;
	bookingItem : CM_BookingRefItem;
	tmpTI : CM_TrackedItem;
	ti : CM_TrackedItem;
	bulkRelease : CM_BulkRelease;
	reserveDetail : CM_ReserveDetail;
	cType : CM_CargoType;
	
begin
	if self.cargoId = null or self.cargoTypeDescr = null then
		return null;
	endif;
	
	terminal := self.getMyTerminal;
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, app.getErrorString(Terminal), ETRow_Terminal, null);
		return null;
	endif;
	
	if self.source.toUpper() = self.SRC_BOOKING.toUpper() then
		booking := self.getBookingRef(bookingItem);
		if bookingItem &lt;&gt; null and self.cargoId &lt;&gt; null then
			foreach tmpTI in bookingItem.allTIs do
				if tmpTI.id = self.cargoId then
					ti := tmpTI;
					break;
				endif;
			endforeach;
		endif;
		
	elseif self.source.toUpper() = self.SRC_RELEASE.toUpper() then
		bulkRelease := self.getBulkRelease(reserveDetail);
		if reserveDetail &lt;&gt; null and reserveDetail.isKindOf(CM_ReserveTI) then
			ti := reserveDetail.CM_ReserveTI.getTI();
		endif;
		
	else
		if self.cargoId &lt;&gt; null and self.cargoTypeDescr &lt;&gt; null then
			cType := self.getCargoTypeObj();
			if cType &lt;&gt; null then
				if self.direction.toUpper() = self.DIR_DELIVERY.toUpper() then
					ti := terminal.allNotifiedTIsByCargoTypeId[cType.id, self.cargoId];
				else
					ti := terminal.allOnsiteTIsByCargoTypeId[cType.id, self.cargoId];
				endif;
			endif;
		endif;
	endif;
	
	return ti;
	
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getVBTerminal" id="c57aa9be-ad06-4ea8-8a48-af25a3368f55">
        <source>getVBTerminal() : CM_VehicleBookingTerminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars
	terminal : CM_Terminal;
	
begin
	terminal := self.getMyTerminal;
	if terminal = null then
		return null;
	endif;
	
	return terminal.myVehicleBookingTerminal;
	
epilog

end;</source>
        <ReturnType type="CM_VehicleBookingTerminal"/>
    </JadeMethod>
    <JadeMethod name="getVbsSlot" id="c4b2f587-7d26-4e57-8a4b-e343cd7b2c65">
        <source>getVbsSlot():CM_VehicleBookingTimeSlot;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Aug 2023	navma1	ChangeRequest 59487: EUP | VBS EDI - VBS ID/EXT REF number mandate


*/

vars
	vbsSlot: CM_VehicleBookingTimeSlot;
begin
	
	if self.externalReference &lt;&gt; null then
		vbsSlot := self.getMyTerminal.myVehicleBookingTerminal.allVBTimeslotsByExtRef[self.externalReference];
	elseif self.id &lt;&gt; null then
		vbsSlot := self.getMyTerminal.myVehicleBookingTerminal.allVBTimeslotsById[self.id];
	endif;
	
	return vbsSlot;
epilog

end;</source>
        <ReturnType type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
