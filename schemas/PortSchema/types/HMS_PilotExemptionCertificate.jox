    <JadeMethod name="auditId" id="82aa73da-00c3-415a-b11f-bbf1750550c3">
        <source>auditId(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	str : String;

begin

	str := self.myMaster.code &amp; "/" &amp; self.myHarbour.code &amp; "/"
			&amp; self.myVessel.code &amp; "/" &amp; self.certifiedDate.String;

	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
