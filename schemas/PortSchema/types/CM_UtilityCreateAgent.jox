	create _realObject persistent;
	_realObject.setForCreate(_pxyObject);
	
	if _passport.noErrors then
		// only required if the class is audited
		self.myCreateAuditAgent.audCreateGeneric(_realObject);
		
		theTerminal := _realObject.getMyTerminal();
		app.myEventManager.createSingleObjInfoNoteEvt(_realObject.myBusinessUnit,theTerminal.getTerminalEvent(Event_InvContractCreate),_realObject); // ### TFS CR 55645 TASK 55662 13DEC2022 NAVAB1
