    <JadeMethod name="addTableItem" id="3edc1484-5bdf-4759-8f35-6af66c7bf23c">
        <source>addTableItem(_deck : CM_Deck) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 March 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	parentDeck: CM_Deck;
	idx,newIdx , subIdx: Integer;
	str : String;
begin
	str := _deck.getAttributeStringForDefArray(self.tbRoRolDecks.allTblDataEntRows);
	idx:=1;
	if _deck.isKindOf(CM_DeckVesselSub) or _deck.isKindOf(CM_DeckVoyageSub) then
		if _deck.isKindOf(CM_DeckVesselSub) then
			parentDeck:=_deck.CM_DeckVesselSub.myParentDeck;
			self.tbRoRolDecks.findObjectInRow(parentDeck,idx);
			subIdx:=parentDeck.CM_DeckVessel.allSubDecks.indexOf(_deck.CM_DeckVessel);
		else
			parentDeck:=_deck.CM_DeckVoyageSub.myParentDeck;
			self.tbRoRolDecks.findObjectInRow(parentDeck,idx);
			subIdx:=parentDeck.CM_DeckVoyage.allSubDecks.indexOf(_deck.CM_DeckVoyage);
		endif;
		idx := idx +subIdx;
		self.tbRoRolDecks.addItemObjectAt(_deck, str,idx);
		
		self.tbRoRolDecks.accessRow(idx).backColor:=LightSkyBlue;
	else
		idx:=self.tbRoRolDecks.addItemObject(_deck, str);
		self.tbRoRolDecks.accessRow(idx).backColor:=SkyBlue;
	endif;

	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_deck" type="CM_Deck"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="58ef820b-690f-43dd-a836-b43b72231c76">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 March 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	toolbar			: CMUI_Toolbar;
begin
