// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return self.myTrain;
epilog

end;</source>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="getTrainUsed" id="70ed0252-3d56-4ed1-8b3b-c242a0a9a58b">
        <source>getTrainUsed(): String;
// ---------------------------------------------------------------------------
// Created:     13 October 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//// PAR 25980
// ---------------------------------------------------------------------------

vars

begin
	if self.myTrain &lt;&gt; null then
		return self.myTrain.code;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
