    <JadeMethod name="getCargoUpdateDescription" id="957c13cf-dd81-467e-a903-c7a5c4860f55">
        <source>getCargoUpdateDescription() : String;
/*

Date		Who		Reason
06 May 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if self.type = EventRequestTypeStops then
		return self.getStopDescription();
	endif;
	
	if self.type = EventRequestTypeToDo then
		if self.myToDoTaskDesc &lt;&gt; null then
			return self.myToDoTaskDesc.description;
		endif;	
	endif;
	
	if self.type = EventRequestTypeRemarks then
		return self.cargoRemarks;
	endif;
	
	if self.type = EventRequestTypeGrade then
		if self.myGrade &lt;&gt; null then
			return self.myGrade.description;
		endif;
	endif;
	
	return  app.getErrorString (Unknown);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="7fdd6c2d-8ffb-4715-abd1-25fd1956d060">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
// Updated On	By			Reason
// ----------	--------	------------------------------------------------------
// 10/05/2016	cnwdap1		TFS #1699 Verified Gross Mass changes
vars
	tmpStopTbl : CM_StopsTable;
	addStr,str : String;
	
begin
	if  _attrName = ETRow_Stops then
		if self.myStopsTable &lt;&gt; null then
			return self.myStopsTable.heading;	
		endif;
	elseif _attrName = ETRow_ToDoTasks then
		if self.myToDoTaskDesc &lt;&gt; null then
			return self.myToDoTaskDesc.description;
		endif;		
	elseif _attrName = ETRow_Event or
		_attrName = ETRow_UpdateDetails then
	
		return self.getUpdateDetails;
		
	elseif _attrName = ETRow_IsNotify then
		return app.getYesNo(self.isNotify);		
		
	elseif _attrName = ETRow_WeightCertifiedReference then			// TFS #1699
		if self.type = EventRequestTypeWeight then
			return self.reference;										// TFS #1699
		endif;
		return null;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSendMessage" id="14cd8ab9-4916-43e8-a61f-e308f0dce9fe">
        <source>getSendMessage(): String;
//--------------------------------------------------
// Created:	17 May 2005 By: cnwgd1
// 06 Oct 2010	NDL		Par 25771 - 1090 error in Email notification when no tracked item.... and status = zero.
// 14/12/2010	cnwcs5	ccms mes 1112 / par 24464 - new status
//--------------------------------------------------
vars
	tmpStr : String;
begin
	if self.status = EventRequestCargoDeleted then	//	14/12/2010	cnwcs5	ccms mes 1112 / par 24464
		return self.getSendMessageCargoDeleted;
	elseif self.status = EventRequestActioned then
		if self.isClear then
			return app.getErrorString4(Cargo_Update_Request_Cleared,self.myTerminal.name,self.typeString,getCargoUpdateDescription, self.getMyTrackedItemId) &amp; '. ' &amp; self.remarks;
		else
			return app.getErrorString4(Cargo_Update_Request_Added,self.myTerminal.name,self.typeString,getCargoUpdateDescription, self.getMyTrackedItemId) &amp; '. ' &amp; self.remarks;
		endif;
		
	elseif ( self.status = EventRequestMatched and self.actionFailedReason &lt;&gt; null and self.myTrackedItem &lt;&gt; null ) then
		return app.getErrorString3(Cargo_Update_Request_Failed,self.typeString,self.getMyTrackedItemId, self.actionFailedReason);
		
	else
		return null;
		
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSendMessageCargoDeleted" id="a31c0acb-95b0-481a-a292-0003085168a9">
        <source>getSendMessageCargoDeleted():String protected;
// ---------------------------------------------------------------------------
// Created:     14 December 2010 by cnwcs5 ccms mes 1112 / par 24464
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	userCode, str, strCargoType, strId, stopDesc, strRecipients, strTimes	:String;
begin
	strId := self.getMyTrackedItemId;
	
	userCode 		:= app.myPassport.getUserCode;
	strCargoType 	:= self.getMyCargoTypeDescription;	
	stopDesc := self.getStopDescription;
	
	// record details for stop request
	str := app.getErrorString2 (Prenote_stop_deleted_by, userCode, app.actualTimeServer.asStringJMT);// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if strCargoType &lt;&gt; null then
		str := str &amp; CrLf &amp; app.getErrorString1 (Prenote_stop_cargo_type, strCargoType);
	endif;
	
	str := str &amp; CrLf &amp; app.getErrorString1 (Prenote_stop_cargo_id, strId);

	
	//epr CCMS  2289 12/5/14
	str := str &amp; CrLf &amp;  app.getErrorString1 (Prenote_stop_clear, self.getUpdateDetails());
	if self.type = EventRequestTypeStops then
		if self.isClear then
			
			if self.clearanceExpiryDate &lt;&gt; null then
				str := str &amp; CrLf &amp; app.getErrorString1 (Prenote_stop_date, self.clearanceExpiryDate.asStringJMT);
			endif;
			
			if self.additionalRequiredInfo &lt;&gt; null then
				str := str &amp; CrLf &amp; app.getErrorString1 (Prenote_stop_info, self.additionalRequiredInfo);
			endif;
		endif;
	endif;
	
	if self.remarks &lt;&gt; null then
		str := str &amp; CrLf &amp; app.getErrorString1 (Prenote_stop_remarks, self.remarks);
	endif;
	
	if self.myOrganisation &lt;&gt; null then
		str := str &amp; CrLf &amp; app.getErrorString1 (Prenote_stop_org, self.myOrganisation.name);
	endif;
	
	str := str &amp; CrLf &amp; app.getErrorString1 (Prenote_stop_user, self.getMyUserCode);
	
	if self.reference &lt;&gt; null then
		str := str &amp; CrLf &amp; app.getErrorString1 (Prenote_stop_reference, self.reference);
	endif;
	
	if self.autoCleanup then
		str := str &amp; CrLf &amp; app.getErrorString (Prenote_Stop_AC_true);
	else
		str := str &amp; CrLf &amp; app.getErrorString (Prenote_Stop_AC_false);
	endif;
	
	if self.isNotify then
		str := str &amp; CrLf &amp; app.getErrorString (Prenote_stop_email_true);
	else
		str := str &amp; CrLf &amp; app.getErrorString (Prenote_stop_email_false);
	endif;
	
	strRecipients := self.getEmailAddresses (null);
	
	if strRecipients &lt;&gt; null then
		str := str &amp; CrLf &amp; app.getErrorString1 (Prenote_stops_recipients, strRecipients);
	endif;
	
	strTimes := self.getRunTimesAsStringJMT;
	
	if strTimes &lt;&gt; null then 
		str := str &amp; CrLf &amp; app.getErrorString1 (Prenote_stops_times, strTimes);
	endif;
	
	return str;
epilog
	
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSendSubject" id="0d64f0bd-ffa2-47b3-851e-a76381f21c43">
        <source>getSendSubject(): String;
//--------------------------------------------------
// Created:	17 May 2005 By: cnwgd1
//--------------------------------------------------
// 14/12/2010	cnwcs5	ccms mes 1112/par 24464
vars
	str, strCargoType, strId, strStop, strUnknown : String;
begin
	strId			:= self.getMyTrackedItemId;	
// 14/12/2010	cnwcs5	ccms mes 1112/par 24464 - start
	if self.status = EventRequestCargoDeleted then
		
		strCargoType	:= self.getMyCargoTypeDescription;			
		
		strStop			:= self.getStopDescription;
		
		str := app.getErrorString3 (Prenote_stop_deleted, strCargoType, strId, strStop);
		
		return str;
	endif;
// 14/12/2010	cnwcs5	ccms mes 1112/par 24464 - end
	if self.isClear then
		return app.getErrorString4(Cargo_Update_Request_Cleared, self.myTerminal.name,self.typeString,null, strId);	
	else
		return app.getErrorString4(Cargo_Update_Request_Added,self.myTerminal.name,self.typeString,null, strId);
		
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStopDescription" id="0341e1ad-b06e-4d1a-8012-87760d052e4a">
        <source>getStopDescription():String;
// ---------------------------------------------------------------------------
// Created:     14 December 2010 by cnwcs5 ccms mes 1112 / par 24464
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	stop	:CM_StopsTable;
begin
	stop := self.myStopsTable;
	
	if stop &lt;&gt; null then
		return stop.heading;
	endif;
		
	return  app.getErrorString (Unknown);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUpdateDetails" id="d87afeb1-9bde-4075-b2f3-883eeecdbe25">
        <source>getUpdateDetails()  : String;
/*

Date		Who		Reason
12 May 2014	cnwer1	Initial creation PAR

*/

vars
	result,
	addStr : String;
begin
	
	
	
	if self.isClear then
		addStr:=app.getErrorString(Clear);
	else
		addStr:=app.getErrorString(Add_Caption);
	endif;
	if self.myToDoTaskDesc &lt;&gt; null then
		return addStr &amp; " - " &amp; self.myToDoTaskDesc.description;
	endif;
	if self.myStopsTable &lt;&gt; null then
		return addStr &amp; " - " &amp;  self.myStopsTable.heading;
	endif;
	if self.myGrade &lt;&gt; null then
		return self.myGrade.description;
	endif;
	
	if self.cargoRemarks &lt;&gt; null then
		return self.cargoRemarks;
	endif;
	
	if self.type = EventRequestTypeWeight then
		result:=app.getWeightForDefaultDisplay(self.totalWeight);
		if self.isWeightCertified then
			result := result &amp; " " &amp; app.getErrorString(Certified);
		endif;
		return result;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="matchesSearchCriteria" id="dfa7290a-ece4-4426-8860-dfe666212364">
        <source>matchesSearchCriteria(_search: CMIF_SearchEventRequest): Boolean;
//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
vars
begin
	if (not inheritMethod(_search)) then
		return false;
	endif;
	
	if self.type = EventRequestTypeStops then
		if _search.allStopTables.isEmpty then
			return true;
		elseif not _search.allStopTables.includes(self.myStopsTable) then
			return false;
		endif;	
	endif;
	
	if self.type = EventRequestTypeToDo then
		if _search.allUpdateFields.isEmpty then
			return true;
		elseif not _search.allUpdateFields.includes(self.myToDoTaskDesc) then
			return false;
		endif;
	endif;
	
	if self.type = EventRequestTypeGrade then
		if _search.allUpdateFields.isEmpty then
			return true;
		elseif not _search.allUpdateFields.includes(self.myGrade) then
			return false;
		endif;
	endif;
	
	return true;
end;</source>
        <Parameter name="_search" type="CMIF_SearchEventRequest"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d1a3f640-ddc8-47f5-9c21-5b1ed1e952a9">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy 			: SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myStopsTable := self.myStopsTable;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="62948945-be22-440c-b4be-9470d3ad3b48">
        <updating/>
        <source>setForUpdate( _pxyEventRequest : CM_EventRequestStops; _passport : CM_Passport input ) updating;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
// 13/12/2010 	cnwcs5	par 24426 / ccms mes 1112 - stop requests for pre-notes
// 05/05/2016	cnwdap1	TFS #1699 Verified Gross Mass changes
// 16 Jan 2017	cnwma1	TFS #2885:QNS - Additional Data Mapping in Customs Message
// 16/11/2022 	navcs2	Bug 55099: MTN - Cargo Update Request - No audits on update

vars
	terminal	: CM_Terminal;			// 13/12/2010 cnwcs5 par 24464 / ccms mes 1112
	tmpTI 		: CM_TrackedItem;
	beforeAudit,
	afterAudit  : String;
begin
	beforeAudit := self.getAuditText(); // 16/11/2022 	navcs2	Bug 55099
	
	self.type:=_pxyEventRequest.type;
	inheritMethod(_pxyEventRequest, _passport);
	
	self.isNotify 				:= _pxyEventRequest.isNotify;
	if self.type = EventRequestTypeStops then
		self.myStopsTable 			:= _pxyEventRequest.myStopsTable;
		self.additionalRequiredInfo	:= _pxyEventRequest.additionalRequiredInfo;	// cnwrl1 18/09/2009 PAR 20320 - MES 1011 New Messina Messages
		self.clearanceExpiryDate	:= _pxyEventRequest.clearanceExpiryDate;	// cnwrl1 12/01/2010 PAR 21889
		self.myCustomsAgent			:= _pxyEventRequest.myCustomsAgent;	//30 Jun 2015	NDL	Par 36543
		self.tiBillOfLading			:= _pxyEventRequest.tiBillOfLading;		//cnwmc5 - 11 Jan 2016 - PAR 37275
		self.clearCustomsAgent		:= _pxyEventRequest.clearCustomsAgent;	//cnwmc5 - 11 Jan 2016 - PAR 37275
		self.tiDescription			:=_pxyEventRequest.tiDescription;		// 16/01/2017 cnwma1 TFS #2885
		self.tiSealNumOperator		:= _pxyEventRequest.tiSealNumOperator;  // 16/01/2017 cnwma1 TFS #2885
		self.ediNotificationType	:=_pxyEventRequest.ediNotificationType; // 16/01/2017 cnwma1 TFS #2885
	endif;
	
	if self.type = EventRequestTypeToDo then
		self.remarks	:=null;
		self.myToDoTaskDesc:=_pxyEventRequest.myToDoTaskDesc;
		self.toDoRemarks := _pxyEventRequest.toDoRemarks;	//06 Oct 2015	NDL	Par 37011
	endif;
	
	if self.type = EventRequestTypeGrade then
		self.remarks	:=null;
		self.myGrade:=_pxyEventRequest.myGrade;
	endif;
	
	if self.type = EventRequestTypeRemarks then
		self.remarks	:=null;
		self.cargoRemarks:= _pxyEventRequest.cargoRemarks;
	endif;
	
	if self.type = EventRequestTypeWeight then
		self.totalWeight :=_pxyEventRequest.totalWeight;
		self.isWeightCertified:=_pxyEventRequest.isWeightCertified;
		self.weightCertifiedName := _pxyEventRequest.weightCertifiedName;				// TFS #1699
		self.reference := _pxyEventRequest.reference;									// TFS #1699
	endif;
	
	if self.isEventRequestForStop() then	//02 May 2019	NDL	TFS 43918
		//No terminal or Cargo assoicated with this type, they are a template on stops...
		return;
	endif;
	
	terminal := self.myTerminal;

	if _pxyEventRequest.myTrackedItem &lt;&gt; null then//01 Jul 2015	NDL	Par 36543
		tmpTI :=  _pxyEventRequest.myTrackedItem;
	else
		//5/11/2009 cnwdz2 par21272 
		tmpTI := terminal.lookupTrackedItem(self.cargoId, self.myCargoType.id, TI_STATE_NORMAL, null, false);
	endif;

//	13/12/2010 cnwcs5 ccms mes 1112 / par 24464 - start		
	if tmpTI = null and terminal.getApplyEventReqToPreNote then
		tmpTI := terminal.lookupTrackedItem(self.cargoId, self.myCargoType.id, TI_STATE_NOTIFIED, null, false);
	endif;
	
//	13/12/2010 cnwcs5 ccms mes 1112 / par 24464 - end
	if tmpTI &lt;&gt; null and not isActioned then
		//TI is on site so process the request.
		self.actionCargoUpdateRequest( tmpTI,false, _passport);
	endif;
	
	afterAudit := self.getAuditText();  // 16/11/2022 	navcs2	Bug 55099
	app.myAA.auditUpdateTrx(self, beforeAudit, afterAudit);  // 16/11/2022 	navcs2	Bug 55099
epilog
	
end;
</source>
        <Parameter name="_pxyEventRequest" type="CM_EventRequestStops"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="a50d0060-0b64-4ee4-a189-afbdf9dbde52">
        <updating/>
        <source>setMyTrackedItem(_trackedItem: CM_TrackedItem; _passport: CM_Passport input): Boolean updating;
/*

Purpose:	TFS 1618 		

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2016	cnwgb1	TFS 1618 Initial creation

*/

vars
    applicable : Boolean;
	tmpStopTable : CM_StopsTable;
    forImport : Boolean;
    forExport : Boolean;
    forFull : Boolean;
    forEmpty : Boolean;
    validImex : Boolean;
    validStorage : Boolean;
    extraCheck : Boolean;

begin
	applicable := inheritMethod(_trackedItem, _passport);
    if self.myTerminal &lt;&gt; null then
        extraCheck := self.myTerminal.getConfig(ValidateEventStopRequest).Boolean;
    endif;
    if extraCheck and applicable and _trackedItem &lt;&gt; null then 
        	tmpStopTable := self.myStopsTable;
            if tmpStopTable &lt;&gt; null then
                forImport := tmpStopTable.isImportStop(self.myTerminal);
                forExport := tmpStopTable.isExportStop(self.myTerminal);
                forFull := tmpStopTable.isValidForFulls(false, self.myTerminal);
                forEmpty := tmpStopTable.isValidForMTs(true, self.myTerminal);
                validImex := (_trackedItem.getImExStatus=TI_IMEX_STATUS_IMPORT and forImport) or (_trackedItem.getImExStatus=TI_IMEX_STATUS_EXPORT and forExport);
                if not validImex then
                    self.actionFailedReason := app.getErrorString(Imex_cargo_does_not_match);
                    applicable := false; 				
               endif;
                validStorage := (_trackedItem.isEmpty and forEmpty) or (_trackedItem.isFull and forFull);
                if not validStorage then
                    self.actionFailedReason := app.getErrorString(Content_stat_does_not_match);
                    applicable := false; 				
                endif;
            endif;

    endif;
    return applicable;
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyMyStopsTable" id="d41688e2-0f51-4179-8ab2-34e2633853ea">
        <updating/>
        <source>setProxyMyStopsTable(_stopsTable : CM_StopsTable)updating;
//--------------------------------------------------
// Created:	17 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myStopsTable := _stopsTable;
end;</source>
        <Parameter name="_stopsTable" type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="setProxyRequestStops" id="b84860bc-c39d-497d-83b0-89b73171f6c7">
        <updating/>
        <source>setProxyRequestStops(	_type 				: Integer;
						_addresses			: CM_StringArray;
						_remarks			: String;
						_cargoId			: String;
						_user				: CM_User;
						_cargoType			: CM_CargoType;
						_organisation		: CM_Organisation;
						_terminal			: CM_Terminal;
						_status				: Integer;       //10/09/2009 cnwdz2 20629
						_isClear			: Boolean;
						_isNotify			: Boolean;
						_ref				: String;
						_cleanup			: Boolean;
						_stopTable			: CM_StopsTable;
						_additionalReqInfo	: String;						// cnwrl1 18/09/2009 PAR 20320 - MES 1011 New Messina Messages
						_expiryDate			: Date;							// cnwrl1 12/01/2010 PAR 21889
						_isEDI				: Boolean;
						_toDoDesc			: CM_ToDoTaskDesc;
						_grade				: CM_MTGrade;
						_cargoRemarks		: String;
						_custAgent			: CM_CustomsAgent;	//30 Jun 2015	NDL	Par 36543
						_toDoRemarks		: String;	//06 Oct 2015	NDL	Par 37011
						_tiBOL				: String;	//cnwmc5 - 11 Jan 2016 - PAR 37275
						_clearCustAgent		: Boolean;	//cnwmc5 - 11 Jan 2016 - PAR 37275
						_tiDesc				: String;     // 16/01/2017 cnwma1 TFS #2885
						_tiSealNumOper  : String ;    // 16/01/2017 cnwma1 TFS #2885
						_tiNotificationType : Integer    // 16/01/2017 cnwma1 TFS #2885
						)updating;			// cnwrl1 21/09/2009 PAR 20320 - MES 1011 New Messina Messages
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
// 16 Jan 2017	cnwma1	TFS #2885:QNS - Additional Data Mapping in Customs Message
//--------------------------------------------------
vars

begin
	self.type:=_type;
	self.setProxyRequestTI(	_addresses,
							_remarks,
							_cargoId,
							_user,
							_cargoType,
							_organisation,
							_terminal,
							_status,
							_isClear,
							_ref,
							_cleanup,
							_isEDI );
	
	
	self.isNotify				:= _isNotify;
	
	if self.type = EventRequestTypeStops then
	
		self.myStopsTable			:= _stopTable;
		self.additionalRequiredInfo	:= _additionalReqInfo;	// cnwrl1 18/09/2009 PAR 20320 - MES 1011 New Messina Messages
		self.clearanceExpiryDate	:= _expiryDate;			// cnwrl1 12/01/2010 PAR 21889
		self.myCustomsAgent			:= _custAgent;	//30 Jun 2015	NDL	Par 36543
		self.tiBillOfLading			:= _tiBOL;				//cnwmc5 - 11 Jan 2016 - PAR 37275
		self.clearCustomsAgent		:= _clearCustAgent;		//cnwmc5 - 11 Jan 2016 - PAR 37275
		self.tiDescription			:=_tiDesc;              // 16/01/2017 cnwma1 TFS #2885
		self.tiSealNumOperator      :=_tiSealNumOper;   // 16/01/2017 cnwma1 TFS #2885
		self.ediNotificationType	:= _tiNotificationType; // 16/01/2017 cnwma1 TFS #2885
	endif;
	
	if self.type = EventRequestTypeToDo then
		self.myToDoTaskDesc :=_toDoDesc;
		self.toDoRemarks := _toDoRemarks;
	endif;
	
	if self.type = EventRequestTypeGrade then
		self.myGrade :=_grade;
	endif;
	
	if self.type = EventRequestTypeRemarks then
		self.cargoRemarks:=_cargoRemarks;
	endif;
end;
</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_addresses" type="CM_StringArray"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_organisation" type="CM_Organisation"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_isClear" type="Boolean"/>
        <Parameter name="_isNotify" type="Boolean"/>
        <Parameter name="_ref" type="String"/>
        <Parameter name="_cleanup" type="Boolean"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <Parameter name="_additionalReqInfo" type="String"/>
        <Parameter name="_expiryDate" type="Date"/>
        <Parameter name="_isEDI" type="Boolean"/>
        <Parameter name="_toDoDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_grade" type="CM_MTGrade"/>
        <Parameter name="_cargoRemarks" type="String"/>
        <Parameter name="_custAgent" type="CM_CustomsAgent"/>
        <Parameter name="_toDoRemarks" type="String"/>
        <Parameter name="_tiBOL" type="String"/>
        <Parameter name="_clearCustAgent" type="Boolean"/>
        <Parameter name="_tiDesc" type="String"/>
        <Parameter name="_tiSealNumOper" type="String"/>
        <Parameter name="_tiNotificationType" type="Integer"/>
