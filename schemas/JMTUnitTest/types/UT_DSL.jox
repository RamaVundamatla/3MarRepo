    <JadeMethod name="deleteTrade" id="9501f1a7-fbc8-4edb-89f4-8f96b34bb701">
        <source>deleteTrade(_tradeDesc : String);

/*

Purpose:		Delete a trade

Date			Who		Reason
30/11/2011		cnwmh5	Initial creation

*/

vars

	trade			: CM_Trade;
	voyage			: CM_Voyage;
	operator		: CM_Operator;
	
begin

	trade := app.myRoot.allTradesByDescription[_tradeDesc];
	if trade &lt;&gt; null then
	
		beginTransaction;
		foreach voyage in trade.allVoyages do
			voyage.setPropertyValue("myTrade", null);
		endforeach;
		
		foreach operator in trade.operators do
			operator.trades.remove(trade);
		endforeach;
		
		commitTransaction;
	
	
	
		app.myTrxDA.trxDeleteTrade(trade, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

end;</source>
        <Parameter name="_tradeDesc" type="String"/>
    </JadeMethod>
