    <JadeMethod name="setMode" id="db98e3d8-0ca9-49e3-9224-1db0eebacfc0">
        <updating/>
        <source>setMode( _mode : Integer ) updating ;
/*--------  ----------  --------------------------------------------------
Created:	07 April 2007 By cnwvu1
Purpose:	controll buttons and fields by form mode
Parameters	_mode: =0 - par not chosen, =1 - par is chosen, but not Edit, =2 - Edit mode
----------  ----------  --------------------------------------------------
*/
vars

begin

	self.btn_createPar.enabled	:= false;
	self.btn_editPar.enabled	:= false;
	self.btn_savePar.enabled	:= false;
	self.btn_cancelPar.enabled	:= false;
	self.btn_deletePar.enabled	:= false;
	self.txt_parNo.enabled		:= false;
	self.txt_patch.enabled		:= false;
	self.btn_createFiles.enabled:= false;
	self.txt_notepad.enabled	:= false;
	self.txt_tag.enabled		:= false;		// TFS 38497 jlgmd1 12/10/2018
	//self.txt_ParTopic.enabled		:= false;
	self.txt_ParDescr.enabled		:= false;
	self.txt_CloseDetail.enabled	:= false;
	self.txt_AreasAffect.enabled	:= false;
	self.chk_autoPatchNo.enabled:= false;
	self.chk_formatUNL.enabled	:= false;
	self.chk_SCMDDB.enabled		:= false;
	self.chk_singleuser.enabled	:= false;
	self.cmb_Customer.enabled  	:= false;
	self.cmb_Topic.enabled  	:= false;
	self.opt_PriorityA.enabled 	:= false;
	self.opt_PriorityB.enabled 	:= false;
	
	if _mode = self.MODE_EMPTY then
		self.mode 					:= _mode;
		self.txt_parNo.enabled		:= true;
		self.btn_createPar.enabled	:= true;
		self.chk_autoPatchNo.enabled:= true;
		self.chk_formatUNL.enabled	:= true;
		self.chk_webPatch.value 	:= false;
		self.txt_parNo.setFocus();
		
	elseif _mode = self.MODE_NORMAL or _mode = self.MODE_NORMAL_TFS then
		self.mode 					:= _mode;
		self.txt_parNo.enabled		:= true;
		self.btn_createPar.enabled	:= true;
		self.btn_editPar.enabled	:= true;
		self.btn_deletePar.enabled	:= true;
		self.chk_autoPatchNo.enabled:= true;
		self.chk_formatUNL.enabled	:= true;
		if not self.chk_autoPatchNo.value then
			self.txt_patch.enabled		:= true;
		endif;
		self.btn_createFiles.enabled:= true;
	
	elseif _mode = self.MODE_INSERT or _mode = self.MODE_EDIT or _mode = self.MODE_EDIT_TFS then
		self.mode					:= _mode;
		self.btn_savePar.enabled	:= true;
		self.btn_cancelPar.enabled	:= true;
		self.txt_notepad.enabled	:= true;
		self.txt_tag.enabled		:= true;		// TFS 38497 jlgmd1 12/10/2018
		//self.txt_ParTopic.enabled		:= true;
		self.txt_ParDescr.enabled 		:= true;
		self.txt_CloseDetail.enabled	:= true;
		self.txt_AreasAffect.enabled	:= true;
		self.chk_SCMDDB.enabled		:= true;
		self.chk_singleuser.enabled	:= true;
		self.chk_formatUNL.enabled	:= false;
		self.cmb_Customer.enabled  	:= true;
		self.cmb_Topic.enabled  	:= true;
		self.opt_PriorityA.enabled 	:= true;
		self.opt_PriorityB.enabled 	:= true;
		self.txt_notepad.setFocus();
		
	else
//		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode for PAR');
		app.msgBox('Error. MODE is unknown...', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
	
	endif;

end;
</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTextForNotepad" id="9ec46b14-0756-40ba-9e3a-6936705b8bf9">
        <updating/>
        <source>setTextForNotepad( _patch : Patch ) updating;
/*--------------------------------------------------------------------
Created:	08 April 2007 By cnwvu1
Purpose:	prepare text for "Notepad"
Parameters:	_patchExists = true  - retrieves data from _patch
			_patchExists = false - prepares example for new par
----------------------------------------------------------------------
 Changes

Date		Name	TFS#		Description
============================================================================
13/07/2017	cnwma1	TFS #4847	JMT - Change to HotFixesCommonSchema PatchCreateApp
10/06/2019	jlgka1	TFS 41865	JMT - Patch schema load order.
============================================================================*/

vars
	n			: Integer;
	scm			: SchemaInPatch;
	web 		: WebInPatch;
	firstLine	: Boolean;
	str, 
	topic, 
	priority, 
	customer 	: String;
	int 		: Integer;
	
	//cnwmc5 - 14 Jan 2014 - PAR 32864
	rpt 		: ReportInPatch;
	rptView		: ReportViewInPatch;
begin
	self.txt_notepad.text := '';
	
	if _patch = null then
		
		// create example of new par for Notepad
		if self.chk_webPatch.value then
			///cnwmc5 - PAR 31922 - 27 Feb 2014
			self.txt_notepad.text := self.txt_notepad.text &amp; 'Web JMT_RIA "C:\RIA\JMT"';
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'Web Tallyman "C:\TallymanBuild\TallymanSigned.xap" Tallyman.xap';
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'Web MasterTerminal "C:\MasterTerminal\ClientBin"';
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'Web KEA "C:\KEA\KEA.xap"';
		elseif self.chk_formatUNL.value then
			self.txt_notepad.text := self.txt_notepad.text &amp; 'Schema PortSchema ERRORSOK';					//cnwmc5 - 29 Nov 2013 - PAR 33105
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'Method CM_Terminal setForUpdate';  
			//self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'Method JadeScript appJadeScript';	// 13.07.2017 cnwma1 TFS #4847
			//self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'Run PortSchema JadeScript';			// 13.07.2017 cnwma1 TFS #4847
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'Run PortSchema JMTRelease';			// 13.07.2017 cnwma1 TFS #4847
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'Schema UiCommonSchema';
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'Method CM_ContainerEnqForm doSave';
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'Class CMUI_EDIForm';
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'ReportView CM_TrackedItemView';		//cnwmc5 - 15 Jan 2014 - PAR 32864
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'Report CM_SealCheckReport';			//cnwmc5 - 15 Jan 2014 - PAR 32864
		else
			self.txt_notepad.text :='PortSchema';
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; ' CM_Terminal';
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; '  setForUpdate';
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; '  setForCreate';
			//self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; ' JadeScript';						// 13.07.2017 cnwma1 TFS #4847
			//self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; '  appJadeScript';					// 13.07.2017 cnwma1 TFS #4847
			//self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; ' ' &amp; self.RUN_JADE &amp; ' JadeScript';	// 13.07.2017 cnwma1 TFS #4847
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'UiCommonSchema';
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; ' CM_ContainerEnqForm';
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; '  doSave';
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; ' CMUI_EDIForm' &amp; ' ' &amp; self.EXPORT_CLASS;
		endif;

		//self.txt_ParTopic.text		:= app.myRootHotFix.README_PreTopic;
		self.txt_ParDescr.text		:= '';
		self.txt_CloseDetail.text	:= '';
		self.txt_AreasAffect.text	:= '';
		self.txt_patch.text			:= '';
		self.txt_tag.text			:= '';		// TFS 38497 jlgmd1 12/10/2018
		self.chk_SCMDDB.value		:= true;
		self.chk_singleuser.value	:= true;	// 07/07/2011 cnwar2 #27819 - changed to default to singleuser
		self.opt_PriorityB.value 	:= true;
		self.cmb_Topic.listIndex	:= -1;		// TFS 38497 jlgmd1 12/10/2018
		self.cmb_Customer.listIndex	:= -1;		// TFS 38497 jlgmd1 12/10/2018

	else
		self.chk_webPatch.value := false;
		if _patch.isWebPatch then
			foreach web in _patch.allWebsInPatch do
				//cnwmc5 - PAR 31922 - 28/6/2013
				self.txt_notepad.text := self.txt_notepad.text &amp; web.formatForNotepad &amp; CrLf;
			endforeach;
			//cnwmc5 - PAR 31922 - 28/6/2013
			self.txt_notepad.text := self.txt_notepad.text[1:self.txt_notepad.text.length-1];
			self.chk_webPatch.value := true;
		else
			// create text for Notepad from existing _patch
			foreach scm in _patch.allSchemasInPatchArray do
				if scm &lt;&gt; null then					
					if self.txt_notepad.text = '' then
						if self.chk_formatUNL.value then
							self.txt_notepad.text := 'Schema ' &amp; scm.name;
							//cnwmc5 - 29 Nov 2013 - PAR 33105
							if scm.errorsOk then
								self.txt_notepad.text := self.txt_notepad.text &amp; ' ERRORSOK';
							endif;
						else
							self.txt_notepad.text := scm.name;
						endif;
					else
						self.txt_notepad.text := self.txt_notepad.text &amp; CrLf;
						if self.chk_formatUNL.value then
							self.txt_notepad.text := self.txt_notepad.text &amp; 'Schema ' &amp; scm.name;
							//cnwmc5 - 29 Nov 2013 - PAR 33105
							if scm.errorsOk then
								self.txt_notepad.text := self.txt_notepad.text &amp; ' ERRORSOK';
							endif;
						else
							self.txt_notepad.text := self.txt_notepad.text &amp; scm.name;
						endif;
					endif;
					self.setTextForNotepadForSchema( scm );
				endif;
			endforeach;
			
			//cnwmc5 - 14 Jan 2014 - PAR 32864 - must do Report Views before Reports, jsut incase the new Reports are dependant on the views..
			foreach rptView in _patch.allReportViewsInPatch do
				if self.chk_formatUNL.value then
					if self.txt_notepad.text = '' then
						self.txt_notepad.text := 'ReportView ' &amp; rptView.name;
					else
						self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'ReportView ' &amp; rptView.name;
					endif;
				endif;
			endforeach;
			
			//cnwmc5 - 14 Jan 2014 - PAR 32864
			foreach rpt in _patch.allReportsInPatch do
				if self.chk_formatUNL.value then
					if self.txt_notepad.text = '' then
						self.txt_notepad.text := 'Report ' &amp; rpt.name;
					else
						self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'Report ' &amp; rpt.name;
					endif;
				endif;
			endforeach;
		endif;
		
		//self.txt_ParTopic.text		:= _patch.readme_parTopic;
		str 		:= _patch.readme_parTopic;
		int 		:= str.pos(', Priority ',1);
		if int &gt; 1 then
			topic 		:= str[1:int-1];
			priority 	:= str[int+11:1];
		endif;
		int			:= str.pos('Advised by : ', 1);	//***************************
		if int &gt; 1 and ((int + 13) &lt; str.length) then
			customer	:= str[int+13:end];
		endif;
		
		self.cmb_Topic.listIndex 	:= self.cmb_Topic.findStringExact(1, topic);
		self.cmb_Customer.listIndex := self.cmb_Customer.findStringExact(1, customer);
		if priority = 'A' then
			self.opt_PriorityA.value := true;
		elseif priority = 'B' then
			self.opt_PriorityB.value := true;
		endif;
		
		self.txt_ParDescr.text		:= _patch.readme_parDescription;
		self.txt_CloseDetail.text	:= _patch.readme_closeDetail;
		self.txt_AreasAffect.text	:= _patch.readme_areasAffected;
		
		self.txt_patch.text			:= _patch.patchNo;
		self.chk_SCMDDB.value		:= _patch.extractOptionDDB;
		self.chk_singleuser.value	:= _patch.singleUser;
		self.txt_tag.text			:= _patch.tag;			// TFS 38497 jlgmd1 12/10/2018
		
	endif;
end;</source>
        <Parameter name="_patch" type="Patch"/>
    </JadeMethod>
    <JadeMethod name="setTextForNotepadForSchema" id="71a9eb77-d9a8-4f87-954f-7f33e9d3f156">
        <updating/>
        <source>setTextForNotepadForSchema( _schema : SchemaInPatch ) updating;
/*--------------------------------------------------------------------
Created:	08 April 2007 By cnwvu1
Purpose:	prepare text for "Notepad" - all classes and methods in _schema
Parameters:	_schema - has got classes, each class has got methods
----------------------------------------------------------------------
*/
vars
	cls	: ClassInSchema;
	mth : MethodInClass;
	appl: AppInSchema;
	
begin

	if self.chk_formatUNL.value then	// UNL format

		// output of all classes in schema
		foreach cls in _schema.allClassesInSchema do
			if cls.extractWholeClass then
				self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp;'Class '&amp; cls.name;			
				if cls.extractSubClassesWhenExtrClass then
					self.txt_notepad.text := self.txt_notepad.text &amp; app.myRootHotFix.EXTRACT_SUBCLASSES_STR;	// adding "..." at the end
				endif;
			endif;
			// output of all methods in class
			foreach mth in cls.allMethodsInClass do
				self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'Method ' &amp; cls.name &amp; ' ' &amp; mth.name;
			endforeach;
		endforeach;
		
		
	else	// Tree format

		// output of all classes in schema
		foreach cls in _schema.allClassesInSchema do
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; ' ' &amp; cls.name;
			if cls.extractWholeClass then
				self.txt_notepad.text := self.txt_notepad.text &amp;' '&amp; self.EXPORT_CLASS;			
				if cls.extractSubClassesWhenExtrClass then
					self.txt_notepad.text := self.txt_notepad.text &amp; app.myRootHotFix.EXTRACT_SUBCLASSES_STR;	// adding "..." at the end
				endif;
			endif;
			// output of all methods in class
			foreach mth in cls.allMethodsInClass do
				self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; '  ' &amp; mth.name;
			endforeach;
		endforeach;
	
	endif;
	
	// Run Application
	foreach appl in _schema.allAppsInSchema do
		if self.chk_formatUNL.value then	// UNL format
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; 'Run ' &amp; _schema.name &amp; ' ' &amp;  appl.name;
		else
			self.txt_notepad.text := self.txt_notepad.text &amp; CrLf &amp; ' ' &amp; self.RUN_JADE &amp; ' ' &amp;  appl.name;
		endif;
	endforeach;

	
end;
</source>
        <Parameter name="_schema" type="SchemaInPatch"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="83b831a1-36a9-42a1-bf95-3c211c7386b0">
        <updating/>
        <source>setupForm() updating;

vars

begin
	
	inheritMethod();

	self.setMode( self.MODE_EMPTY );
	
	self.width := 800;
	self.height:= 600;
	self.centreWindow();
	self.txt_parNo.maxLength := app.myRootHotFix.LENGTH_OF_PAR;
	self.txt_patch.maxLength := app.myRootHotFix.LENGTH_OF_PATCH_MAX;
	
//	self.txtBox_readme.backColor := 140 + (120 * 256) + (100 * 256 * 256);
	self.frm_notepad.left	:= 0;
	self.frm_notepad.top	:= 0;

	self.txt_notepad.foreColor := DarkBlue;
	self.frm_development.visible := false;
	self.chk_formatUNL.value	:= true;
	self.chk_formatUNL.enabled	:= true;
	self.chk_singleuser.value	:= false;
	
	self.chk_thinClient.visible := true;
	self.chk_thinClient.value := process.isUsingThinClient();
	
	self.addCustomersTopics();
	
	self.doResize();
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="txt_parNo_change" id="d550c05c-17ec-4d03-af16-24b9c6f1378d">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txt_parNo_change(textbox: TextBox input) updating;
/*--------  ----------  --------------------------------------------------
Created:	09 April 2007 By cnwvu1
Purpose:
----------  ----------  --------------------------------------------------
09/05/2018	jlgmd1		TFS 38497 JMT - Patch Create App Changes
*/

vars

begin

	self.changeTextParNo();
	
	// Don't count the 't' towards the max par number
	if textbox.text.length &gt; 0 and textbox.text[1:1] = 't' then
		textbox.maxLength := app.myRootHotFix.LENGTH_OF_PAR + 1;
	else
		textbox.maxLength := app.myRootHotFix.LENGTH_OF_PAR;
	endif;
	
end;
</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txt_parNo_keyDown" id="e49dac9b-0688-4683-a9e7-f3acab3a34b6">
        <controlMethod name="TextBox::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txt_parNo_keyDown(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
/* ---------------------------------------------------------------------------
Created:	01 August 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	newPar	: String;
	rt		: RootHotFixes;
	patch	: Patch;

begin

	if keyCode = J_key_Enter then 
	
		rt := app.myRootHotFix;
		newPar := self.txt_parNo.text;
	
		if not rt.isValidParNo( newPar ) then
			return;
		endif;

		patch := rt.allPatches[ newPar ];
		if patch &lt;&gt; null then
			self.setTextForNotepad( patch );
			if patch.isTFSPatch then
				self.setMode( self.MODE_NORMAL_TFS );		// TFS 38497 jlgmd1 12/10/2018
			else
				self.setMode( self.MODE_NORMAL );
			endif;
		endif;

	endif;

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateNewPatchBeforeFiles" id="493734aa-0f63-4016-bbb9-6d912a1f6724">
        <source>validateNewPatchBeforeFiles() : Boolean;

vars
	patch		: Patch;
	n, rtnValue	: Integer;
	str			: String;
begin

// check auto patchNo
	if not chk_autoPatchNo.value and self.txt_patch.text.trimRight = '' then
		app.msgBox('Patch No is empty...', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;

// check parNo &lt;&gt; null
	if self.txt_parNo.text.trimRight = '' then
		app.msgBox('Please choose Par.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
// check readme &lt;&gt; null
	/*if self.txt_ParTopic.text.trimRight = '' then
		app.msgBox('Par Topic is empty...', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;*/
	if self.cmb_Customer.text.trimRight = '' then
		app.msgBox('Customer is empty...', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	if self.cmb_Topic.text.trimRight = '' then
		app.msgBox('Topic is empty...', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	if self.opt_PriorityA.value = false and self.opt_PriorityB.value = false then
		app.msgBox('Priority must be A or B...', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	if self.txt_ParDescr.text.trimRight = '' then
		app.msgBox('Par Description is empty...', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	if self.txt_CloseDetail.text.trimRight = '' then
		app.msgBox('Close Detail is empty...', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	if self.txt_AreasAffect.text.trimRight = '' then
		app.msgBox('Areas Affected is empty...', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	// 07/07/2011 cnwar2 #27819
	if not self.chk_singleuser.value then
		str := self.txt_notepad.text.toUpper();
		if str.length &gt; 0
		and str.pos('CLASS', 1) &gt; 0 then
			rtnValue := app.msgBox("Install includes a full Class but SINGLEUSER not selected.  Continue?", "Multi-user Class Load", MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon);
			if rtnValue = MsgBox_Return_Cancel then
				return false;
			endif;
		endif;
	endif;
	
	
	
	if str.pos('appJadeScript', 1) &gt; 0 then
		if str.pos('Run PortSchema JadeScript', 1) &lt;= 0 then
			rtnValue := app.msgBox("Install includes 'appJadeScript' method but no 'Run PortSchema JadeScript'.  Continue?", "Missing Run JadeScript", MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon);
			if rtnValue = MsgBox_Return_Cancel then
				return false;
			endif;
		endif;	
	elseif str.pos('JadeScript', 1) &gt; 0 then
		rtnValue := app.msgBox("Install includes JadeScript method but no 'appJadeScript'.  Continue?", "Missing appJadeScript", MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon);
		if rtnValue = MsgBox_Return_Cancel then
			return false;
		endif;
		if str.pos('Run PortSchema JadeScript', 1) &lt;= 0 then
			rtnValue := app.msgBox("Install includes JadeScript method but no 'Run PortSchema Jadescript'.  Continue?", "Missing Run JadeScript", MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon);
			if rtnValue = MsgBox_Return_Cancel then
				return false;
			endif;
		endif;		
	elseif str.pos('Run PortSchema JadeScript', 1) &gt; 0 then
		rtnValue := app.msgBox("Install includes 'Run PortSchema Jadescript' method but no JadeScript methods.  Continue?", "Missing JadeScript methods", MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon);
		if rtnValue = MsgBox_Return_Cancel then
			return false;
		endif;
	endif;
	
	// yes / no do you want to continue?
	if self.inTFSMode then																						// TFS 38497 jlgmd1 12/10/2018
		patch := app.myRootHotFix.allPatches [ self.txt_parNo.text ];											// TFS 38497 jlgmd1 12/10/2018
		if patch = null or not patch.isTFSPatch then															// TFS 38497 jlgmd1 12/10/2018
			patch := app.myRootHotFix.allPatches[ app.myRootHotFix.TFS_NUMBER_MASK &amp; self.txt_parNo.text ];		// TFS 38497 jlgmd1 12/10/2018
		endif;																									// TFS 38497 jlgmd1 12/10/2018
	else
		patch := app.myRootHotFix.allPatches[ self.txt_parNo.text ];
	endif;
	
	if (patch.patchNo &lt;&gt; null) and (patch.releaseVersionNoForPatch &lt;&gt; null) then
		// Show just the number, not the 't' if its a TFS patch
		//n := app.msgBox("The patch " &amp; patch.patchNo &amp;"_"&amp; patch.parNo &amp; " Release " &amp; patch.releaseVersionNoForPatch &amp; " has been created before. Do you want to create another one for this Par?", "Creation Confirmation", MsgBox_Yes_No);
		n := app.msgBox("The patch " &amp; patch.patchNo &amp;"_"&amp; /*patch.parNo*/ self.txt_parNo.text &amp; " Release " &amp; patch.releaseVersionNoForPatch &amp; " has been created before. Are you sure you want to create the files again?", "Creation Confirmation", MsgBox_Yes_No);
		if n = MsgBox_Return_No then 
			return false;
		endif;
	endif;
	
	return true;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateNotepad" id="afbff78e-6dbb-4443-a7dc-6f495500936f">
        <updating/>
        <source>validateNotepad( _validateMe: Boolean; _patch: Patch; _scm: SchemaInPatch io; _cls: ClassInSchema io; _mtd: MethodInClass io; _app: AppInSchema io) : Boolean updating;
/*--------------------------------------------------------------------
Created:	08 April 2007 By cnwvu1
Purpose:	validateMe = true - validates notepad content
			validateMe = false - writes data from notepad to DB
----------------------------------------------------------------------
*/
vars
	str		: String;
	nPos	: Integer;
	nStart	: Integer;
	lineStatusBefore, lineStatusLast : Integer;
	
begin

	if self.txt_notepad.text = '' then
		return false;
	endif;

	// adding CrLf to the end
	if self.txt_notepad.text [ self.txt_notepad.text.length-1 : 2 ] &lt;&gt; CrLf then	
		self.txt_notepad.text := self.txt_notepad.text &amp; CrLf;
	endif;	

	//------------- some control for the firts line - schema line ---------------------
	nStart := 1;

	str := getNextLineFromNotepad( self.txt_notepad.text, nStart, nPos );
	if not self.validateNotepadString ( str, self.LINE_IS_THE_FIRST, lineStatusLast, _validateMe, _patch, _scm, _cls, _mtd, _app ) then
		return false;
	endif;
	lineStatusBefore := lineStatusLast;
	
	//--------------- Loop through all lines in notepad ------------------------------
	while self.txt_notepad.text.length &gt; nStart do
		nStart := nPos + 2;
		if nStart &gt; self.txt_notepad.text.length then
			break;
		endif;
		str := getNextLineFromNotepad( self.txt_notepad.text, nStart, nPos );
		if str.trimRight &lt;&gt; '' then
			if not validateNotepadString( str, lineStatusBefore, lineStatusLast, _validateMe, _patch, _scm, _cls, _mtd, _app ) then
				return false;
			endif;
			lineStatusBefore := lineStatusLast;
		endif;	
	endwhile;
	
	
	return true;
	
end;
</source>
        <Parameter name="_validateMe" type="Boolean"/>
        <Parameter name="_patch" type="Patch"/>
        <Parameter name="_scm" type="SchemaInPatch" usage="io"/>
        <Parameter name="_cls" type="ClassInSchema" usage="io"/>
        <Parameter name="_mtd" type="MethodInClass" usage="io"/>
        <Parameter name="_app" type="AppInSchema" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateNotepadString" id="46a2348f-7f57-4f8c-84ef-32aea404adb6">
        <updating/>
        <source>validateNotepadString( _string : String; _lineStatusBefore : Integer; _lineStatusLast : Integer output;
	_validateMe: Boolean; _patch: Patch; _scm: SchemaInPatch io; _cls: ClassInSchema io; _mtd: MethodInClass io; _app: AppInSchema io) : Boolean updating;
/*--------------------------------------------------------------------
Created:	08 April 2007 By cnwvu1
Purpose:	
----------------------------------------------------------------------
*/
vars
	strDataValue : String;
	
begin

	if _lineStatusBefore = self.LINE_IS_THE_FIRST then
		// The first line is schema - no gaps
		if not self.validateNotepadStringFirstLine( _string, strDataValue, _lineStatusLast ) then
			return false;
		endif;
		
	elseif _lineStatusBefore = self.LINE_IS_SCHEMA then
		// line after schema should be class and have one gap in the beginning
		if not self.validateNotepadStringAfterSchm( _string, strDataValue, _lineStatusLast ) then
			return false;
		endif;
		
	elseif _lineStatusBefore = self.LINE_IS_CLASS then
		// line after class should be method (or method with RUNJADE) and have two gaps in the beginning
		if not self.validateNotepadStringAfterCls( _string, strDataValue, _lineStatusLast ) then
			return false;
		endif;
		
	elseif _lineStatusBefore = self.LINE_IS_CLASS_WHOLE_EXPORT then
		// line after classWholeExport should be eiher class or schema (no gap or one gap)
		if not self.validateNotepadStringAfterExpC( _string, strDataValue, _lineStatusLast ) then
			return false;
		endif;
	
	elseif _lineStatusBefore = self.LINE_IS_METHOD then
		// line after method should be either schema, class or next method (no gap or two gaps in the beginning)
		if not self.validateNotepadStringAfterMtd( _string, strDataValue, _lineStatusLast ) then
			return false;
		endif;
		
	elseif _lineStatusBefore = self.LINE_IS_RUN_APPLICATION then
		// line after method should be either schema, class or next method (no gap or two gaps in the beginning)
		if not self.validateNotepadStringAfterApp( _string, strDataValue, _lineStatusLast ) then
			return false;
		endif;
		
	else
		app.msgBox('Bad line status. Program error.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	// ---------------------------- set data -------------------------------
	if not _validateMe then 
	
		//------------------------------ SCHEMA --------------------------------
		if _lineStatusLast = self.LINE_IS_SCHEMA then

			_scm := _patch.allSchemasInPatch[ strDataValue, _patch.parNo ];
			if _scm = null then
				create _scm;
				_scm.setForCreate( strDataValue, _patch );
			else
				_scm.set( strDataValue );
			endif;

		//------------------------------ CLASS --------------------------------
		elseif _lineStatusLast = self.LINE_IS_CLASS 
			or _lineStatusLast = self.LINE_IS_CLASS_WHOLE_EXPORT then

			_cls := _scm.getClassInSchema( strDataValue );
			if _cls = null then
				create _cls;
				_cls.setForCreate( strDataValue, _lineStatusLast = self.LINE_IS_CLASS_WHOLE_EXPORT, self.isExportSubClasses(_string), _scm );
			 else
				_cls.set( strDataValue, _lineStatusLast = self.LINE_IS_CLASS_WHOLE_EXPORT, self.isExportSubClasses(_string) );
			 endif;
			
		//------------------------------ METHOD --------------------------------
		elseif _lineStatusLast = self.LINE_IS_METHOD then
			_mtd := _cls.getMethodInClass( strDataValue );
			if _mtd = null then
				create _mtd;
				_mtd.setForCreate( strDataValue, /*_lineStatusLast = self.LINE_IS_RUN_APPLICATION,*/ _cls );
			else
				_mtd.set( strDataValue );
			endif;

		//------------------------------ RUN APPLICATION --------------------------------
		elseif _lineStatusLast = self.LINE_IS_RUN_APPLICATION then
			
			_app := _scm.getAppInSchema( strDataValue );
			if _app = null then
				create _app;
				_app.setForCreate( strDataValue, /*_lineStatusLast = self.LINE_IS_RUN_APPLICATION,*/ _scm );
			else
				_app.set( strDataValue );
			endif;
			
		else
			app.msgBox('Bad line status for saving data. Program error.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
			return false;
		
		endif;
	endif;
	
	return true;
	
end;
</source>
        <Parameter name="_string" type="String"/>
        <Parameter name="_lineStatusBefore" type="Integer"/>
        <Parameter name="_lineStatusLast" type="Integer" usage="output"/>
        <Parameter name="_validateMe" type="Boolean"/>
        <Parameter name="_patch" type="Patch"/>
        <Parameter name="_scm" type="SchemaInPatch" usage="io"/>
        <Parameter name="_cls" type="ClassInSchema" usage="io"/>
        <Parameter name="_mtd" type="MethodInClass" usage="io"/>
        <Parameter name="_app" type="AppInSchema" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateNotepadStringAfterApp" id="997d5959-e9a7-41f3-8e1e-59883eda939d">
        <source>validateNotepadStringAfterApp( _string : String; _strDataValue: String output; _lineStatusLast : Integer output ) : Boolean;
/*--------------------------------------------------------------------
Created:	08 April 2008 By cnwvu1

	Line after method should be either:
		schema 
		class	- simple or for whole export
----------------------------------------------------------------------
*/

vars
	pos : Integer;
	s	: String;


begin

	if _string[1:1] &lt;&gt; ' ' then		//-------------- this is SCHEMA ------------------------
	
		if not validateNotepadStringSchema( _string, _strDataValue, _lineStatusLast ) then
			return false;
		endif;
		
	elseif _string[1:2] &lt;&gt; '  ' then	//-------------- this is CLASS ------------------------
		
		if not validateNotepadStringClass( _string, _strDataValue, _lineStatusLast ) then
			return false;
		endif;
	
	else
		app.msgBox('After RUN Application should follow either Schema or Class: ' &amp; _string, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	
	endif;

	return true;
	
end;
</source>
        <Parameter name="_string" type="String"/>
        <Parameter name="_strDataValue" type="String" usage="output"/>
        <Parameter name="_lineStatusLast" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateNotepadStringAfterCls" id="4e9663fd-6e66-4764-9ac5-03fc597691ff">
        <source>validateNotepadStringAfterCls( _string : String; _strDataValue: String output; _lineStatusLast : Integer output ) : Boolean;
/*--------------------------------------------------------------------
Created:	09 April 2007 By cnwvu1
Purpose:	
----------------------------------------------------------------------
*/

vars

begin

	// The method line should begin with two gaps (or more)
	if _string[1:2] &lt;&gt; '  ' then
		app.msgBox('Method should be with two gaps in the beginning. Line ' &amp; _string, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	if not validateNotepadStringMethod( _string, _strDataValue, _lineStatusLast ) then
		return false;
	endif;
	
	return true;
	
end;
</source>
        <Parameter name="_string" type="String"/>
        <Parameter name="_strDataValue" type="String" usage="output"/>
        <Parameter name="_lineStatusLast" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateNotepadStringAfterExpC" id="b1799ce9-f147-4982-94c8-068d013fe8d5">
        <source>validateNotepadStringAfterExpC( _string : String; _strDataValue: String output; _lineStatusLast : Integer output ) : Boolean;
/*--------------------------------------------------------------------
Created:	09 April 2007 By cnwvu1
Purpose:	
----------------------------------------------------------------------
*/

vars

begin

		// line after classWholeExport should be eiher class or schema (no gap or one gap)
	if _string[1:2] = '  ' then
		app.msgBox('After class for whole export should follow either next class or schema. Line ' &amp; _string, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;

	if _string[1:1] &lt;&gt; ' ' then		//there is schema

		if not validateNotepadStringSchema( _string, _strDataValue, _lineStatusLast ) then
			return false;
		endif;
		
	else		// there  is class
	
		if not validateNotepadStringClass( _string, _strDataValue, _lineStatusLast ) then
			return false;
		endif;
	
	endif;

	return true;
	
end;
</source>
        <Parameter name="_string" type="String"/>
        <Parameter name="_strDataValue" type="String" usage="output"/>
        <Parameter name="_lineStatusLast" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateNotepadStringAfterMtd" id="e9490efc-6bca-492b-b722-091efb546cf8">
        <source>validateNotepadStringAfterMtd(_string : String; _strDataValue: String output; _lineStatusLast : Integer output ) : Boolean;
/*--------------------------------------------------------------------
Created:	09 April 2007 By cnwvu1
Purpose:	

Line after method should be either:
	schema 
	class	- simple or for whole export
	method	- simple or run jade

----------------------------------------------------------------------
*/

vars
	pos : Integer;
	s	: String;


begin

	if _string[1:1] &lt;&gt; ' ' then		//-------------- this is SCHEMA ------------------------
	
		if not validateNotepadStringSchema( _string, _strDataValue, _lineStatusLast ) then
			return false;
		endif;
		
	elseif _string[1:2] &lt;&gt; '  ' then	//-------------- this is CLASS ------------------------
		
		if not validateNotepadStringClass( _string, _strDataValue, _lineStatusLast ) then
			return false;
		endif;
	
	elseif _string[1:2] = '  ' then		//-------------- this is METHOD ------------------------
		
		if not validateNotepadStringMethod( _string, _strDataValue, _lineStatusLast ) then
			return false;
		endif;
	
	else
		app.msgBox('Bad line ' &amp; _string, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	
	endif;

	return true;
	
end;
</source>
        <Parameter name="_string" type="String"/>
        <Parameter name="_strDataValue" type="String" usage="output"/>
        <Parameter name="_lineStatusLast" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateNotepadStringAfterSchm" id="c00dc4ac-86a4-47ed-8522-889e6d2e294f">
        <source>validateNotepadStringAfterSchm( _string : String; _strDataValue: String output; _lineStatusLast : Integer output ) : Boolean;
/*--------------------------------------------------------------------
Created:	08 April 2007 By cnwvu1
Purpose:	
----------------------------------------------------------------------
*/

vars
	pos : Integer;
	s	: String;
	
begin

	// The class line should begin with one gap
	if (_string[1:1] &lt;&gt; ' ') or (_string[1:2] = '  ') then
		app.msgBox('Class should be with one gap. Line ' &amp; _string, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	if not validateNotepadStringClass( _string, _strDataValue, _lineStatusLast ) then
		return false;
	endif;
	
	return true;
	
end;
</source>
        <Parameter name="_string" type="String"/>
        <Parameter name="_strDataValue" type="String" usage="output"/>
        <Parameter name="_lineStatusLast" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateNotepadStringClass" id="31f548a5-ec82-4a38-945e-ea7d91d0e7b1">
        <source>validateNotepadStringClass( _string : String; _strDataValue: String output; _lineStatusLast : Integer output ) : Boolean;
/*--------------------------------------------------------------------
Created:	09 April 2007 By cnwvu1
Purpose:	_string is CLASS line - should validate it and count _strDataValue
			Class can be either simple or for whole export
----------------------------------------------------------------------
*/

vars
	pos : Integer;
	s	: String;

begin

	s	:= _string;
	pos	:= s.toUpper().pos( self.EXPORT_CLASS, 1);
	
	if pos = 0 then		// Class not for whole export
		
		pos	:= s.toUpper().pos( self.RUN_JADE, 1);
		if pos = 0 then // Class is simple
			_lineStatusLast := self.LINE_IS_CLASS;
		else	// this is actualy RUN Application
			_lineStatusLast := self.LINE_IS_RUN_APPLICATION;
			s := _string[ pos+self.RUN_JADE.length +1 : _string.length ];
		endif;	
		
	else	// Class for whole export

		_lineStatusLast := self.LINE_IS_CLASS_WHOLE_EXPORT;
		s := _string[1:pos-1];
	
	endif;
	
	// no gaps inside
	if not validateNotepadStringDataValue( s ) then
		return false;
	endif;
	_strDataValue := s;

	return true;
	
end;
</source>
        <Parameter name="_string" type="String"/>
        <Parameter name="_strDataValue" type="String" usage="output"/>
        <Parameter name="_lineStatusLast" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateNotepadStringDataValue" id="7e5e3bb5-2935-440e-89da-0752a654b46e">
        <source>validateNotepadStringDataValue( _str : String io ) : Boolean;
/*--------------------------------------------------------------------
Created:	08 April 2007 By cnwvu1
Purpose:	to trim gaps at the ends and look for gaps inside
----------------------------------------------------------------------
*/
vars
	pos : Integer;
	
begin

	_str := _str.trimRight;
	_str := _str.trimLeft;
	pos := _str.pos( ' ', 1);
	if pos &gt; 0 then
		app.msgBox('There is gap in line ' &amp; _str, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;

	return true;
	
end;
</source>
        <Parameter name="_str" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateNotepadStringFirstLine" id="bbf6ff2f-524a-43bd-8d1e-40fafc4d85ac">
        <source>validateNotepadStringFirstLine( _string : String; _strDataValue: String output; _lineStatusLast : Integer output ) : Boolean;
/*--------------------------------------------------------------------
Created:	08 April 2007 By cnwvu1
Purpose:	
----------------------------------------------------------------------
*/

vars
	s	: String;
	
begin

	if _string = '' then
		app.msgBox('The first line cannot be empty.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	// The first line cannot begin with gap
	if _string[1:1] = ' ' then
		app.msgBox('The first line should be without gap.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	if not validateNotepadStringSchema( _string, _strDataValue, _lineStatusLast ) then
		return false;
	endif;
	
	return true;
	
end;
</source>
        <Parameter name="_string" type="String"/>
        <Parameter name="_strDataValue" type="String" usage="output"/>
        <Parameter name="_lineStatusLast" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateNotepadStringMethod" id="1ef31cbb-5a06-4062-b530-da559c90748b">
        <source>validateNotepadStringMethod( _string : String; _strDataValue: String output; _lineStatusLast : Integer output ) : Boolean;
/*--------------------------------------------------------------------
Created:	09 April 2007 By cnwvu1
Purpose:	_string is METHOD line - should validate it and count _strDataValue
			Method can be either simple or for run jade (put into JMTInstall.txt - RUNJADE...)
----------------------------------------------------------------------
*/

vars
	s		: String;

begin

	s	:= _string;
		
	_lineStatusLast := self.LINE_IS_METHOD;	// after class should be method
	// Class cannot have gaps inside
	if not validateNotepadStringDataValue( s ) then
		return false;
	endif;
	_strDataValue := s;

	return true;

end;
</source>
        <Parameter name="_string" type="String"/>
        <Parameter name="_strDataValue" type="String" usage="output"/>
        <Parameter name="_lineStatusLast" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateNotepadStringSchema" id="75e801e4-60ed-49ea-907b-404a1a14f992">
        <source>validateNotepadStringSchema(_string : String; _strDataValue: String output; _lineStatusLast : Integer output ) : Boolean;
/*--------------------------------------------------------------------
Created:	09 April 2007 By cnwvu1
Purpose:	_string is SCHEMA line - should validate it and count _strDataValue
----------------------------------------------------------------------
*/

vars
	s	: String;

begin

	_lineStatusLast := self.LINE_IS_SCHEMA;
	
	s := _string;
	if not validateNotepadStringDataValue( s ) then
		return false;
	endif;
	_strDataValue := s;

	return true;
	
end;
</source>
        <Parameter name="_string" type="String"/>
        <Parameter name="_strDataValue" type="String" usage="output"/>
        <Parameter name="_lineStatusLast" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateUNL" id="8c057d93-8328-4775-be5b-a7060cf983f6">
        <updating/>
        <source>validateUNL( _validate : Boolean; _ptch : Patch ) : Boolean updating, protected;
// ----------------------------------------------------------------------------
//	created by cnwvu1	09 April 2008
//	Notes.	_validate = true - only validation
//			_validate = false - puts changes into DB
// ----------------------------------------------------------------------------
/* Changes

Date		Name	TFS#	Description
============================================================================

============================================================================*/
vars
	str,
	s		: String;
	pos,
	posPrev	: Integer;
	strArray: HugeStringArray;
	isFirst	: Boolean;
	scm		: SchemaInPatch;
	
	//cnwmc5 - 6 Nov 2013 - PAR 32864
	hasMethod,
	hasAppMethod,
	hasRun			: Boolean;
begin
	if self.txt_notepad.text = '' then
		return false;
	endif;

	// adding CrLf to the end
	if self.txt_notepad.text [ self.txt_notepad.text.length-1 : 2 ] &lt;&gt; CrLf then	
		self.txt_notepad.text := self.txt_notepad.text &amp; CrLf;
	endif;	

	//strArray := self.txt_notepad.text.getTokens;
	str := self.txt_notepad.text;
	pos := 1;
	posPrev := 0;
	s := str.scanUntil( CrLf, pos );
	
	create strArray transient;
	while (pos &lt;&gt; 0) do	// going through all UNL text
		if s &lt;&gt; null then	// when playing with CrLf - it can be null 
			strArray.add( s );
		endif;
		pos := pos + 1;
		posPrev := pos;
		if pos &gt; str.length then
			break;
		endif;
		s := str.scanUntil( CrLf, pos );
	endwhile;
	
	isFirst := true;
	foreach str in strArray do		
		//cnwmc5 - 25 Feb 2014 - PAR 32864
		if not convertToUNLFormat(str, scm, _ptch, _validate, isFirst) then
			return false;
		endif;
		
		if isFirst then	// the first line should be Schema SchemaName
			
			isFirst := false;
			//cnwmc5 - 15 Jan 2014 - PAR 32864
			if str[1:7] &lt;&gt; "Schema " and str[1:7] &lt;&gt; "Report " and str[1:11] &lt;&gt; "ReportView " then
				app.msgBox('The first line should be "Schema SchemaName", "Report ReportName" or "ReportView ReportViewName.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
				return false;
			endif;
			//cnwmc5 - 15 Jan 2014 - PAR 32864
			if str[1:7] = "Report " then
				if not self.validateUNLReport( _validate, str, _ptch ) then
					return false;
				endif;
			elseif str[1:11] = "ReportView " then
				if not self.validateUNLReportView( _validate, str, _ptch ) then
					return false;
				endif;
			else
				if not self.validateUNLSchema( _validate, str, _ptch, scm ) then
					return false;
				endif;
			endif;
			
		else	// all others strings
			
			if str[1:7] = 'Schema ' then		// the line is Schema				
				if not self.validateUNLSchema( _validate, str, _ptch, scm ) then
					return false;
				endif;				
			elseif str[1:7] = 'Method ' then	// the line is Method
				if not self.validateUNLMethod( _validate, str, scm ) then
					return false;
				endif;
				
				//cnwmc5 - 6 Nov 2013 - PAR 32864
				self.checkForJadescriptMethods(hasMethod, hasAppMethod, hasRun, str, true);
			elseif str[1:6] = 'Class ' then		// the line is Class - export whole class
				if not self.validateUNLClassExport( _validate, str, scm ) then
					return false;
				endif;
			
			elseif str[1:4] = 'Run ' then		// the line is Run Application
				if not self.validateUNLRunApplication( _validate, str, _ptch ) then
					return false;
				endif;
				
				//cnwmc5 - 6 Nov 2013 - PAR 32864
				self.checkForJadescriptMethods(hasMethod, hasAppMethod, hasRun, str, false);
				
			elseif str[1:7] = 'Report ' then
				//cnwmc5 - 14 Jan 2014 - PAR 32864
				if not self.validateUNLReport( _validate, str, _ptch ) then
					return false;
				endif;
				
			elseif str[1:11] = 'ReportView ' then
				//cnwmc5 - 14 Jan 2014 - PAR 32864	
				if not self.validateUNLReportView( _validate, str, _ptch ) then
					return false;
				endif;
				
			else
				app.msgBox('The line is of unknown format: ' &amp; str, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
				return false;
			endif;
		
		endif;
		
	endforeach;
	
	//cnwmc5 - 6 Nov 2013 - PAR 32864
	if not _validate then
		/*if hasMethod or hasAppMethod or hasRun then
			//Check to see if any are false, and display an error
			if not hasMethod then
				if app.msgBox('Missing line: "Method JadeScript rel' &amp; CM_Version.VERSION.replaceString('.', '') &amp; '_parXXXXX". Continue?', 'Error!', MsgBox_Yes_No + MsgBox_Information_Icon) = MsgBox_Return_No then
					return false;
				endif;
			elseif not hasAppMethod then
				if app.msgBox('Missing line: "Method JadeScript appJadeScript". Continue?', 'Error!', MsgBox_Yes_No + MsgBox_Information_Icon) = MsgBox_Return_No then
					return false;
				endif;
			elseif not hasRun then
				if app.msgBox('Missing line: "Run PortSchema JadeScript". Continue?', 'Error!', MsgBox_Yes_No + MsgBox_Information_Icon) = MsgBox_Return_No then
					return false;
				endif;
			endif;
		endif;*/
	endif;
	
	return true;

epilog
	delete strArray;	
end;
</source>
        <access>protected</access>
        <Parameter name="_validate" type="Boolean"/>
        <Parameter name="_ptch" type="Patch"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateUNLClassExport" id="d23cd133-2aa0-454e-90c6-e2931cd1afad">
        <updating/>
        <source>validateUNLClassExport( _validate : Boolean; _strUNL : String; _scm : SchemaInPatch ) : Boolean updating, protected;
// ----------------------------------------------------------------------------
//	Created by cnwvu1	09 April 2008
//	Notes.	_validate = true - only validation
//			_validate = false - puts changes into DB
// ----------------------------------------------------------------------------
// 16/03/2015	cnwmh5	Transient Leaks
vars
	className	: String;
	cls			: ClassInSchema;
	
	//cnwmc5 - 22 Jan 2014 - PAR 32864
	tokens : StringArray;
begin

	if _strUNL.length &lt;= 6 then
		app.msgBox('The line Class requires className: ' &amp; _strUNL, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	//cnwmc5 - 22 Nov 2013 - PAR 32864
	create tokens transient;
	_strUNL.getTokensForDelimiter(' ', tokens);
	
	self.removeNullsFromTokens(tokens);

	// getting class name
	//cnwmc5 - 22 Nov 2013 - PAR 32864
	className := tokens[2];
	if self.isExportSubClasses(className) then		// &lt;className&gt; can be &lt;className...&gt;, "..." means extract with sub-classes
		className := className[1 : className.length-3];
	endif;
	
	// DB changes
	if not _validate then

		// class
		cls := _scm.getClassInSchema( className );
		if cls = null then
			create cls;
			cls.setForCreate( className, true, self.isExportSubClasses(_strUNL), _scm );
		 else
			cls.set( className, true, self.isExportSubClasses(_strUNL) );
		 endif;
	
	endif;
	
	return true;
epilog
	delete tokens;
end;
</source>
        <access>protected</access>
        <Parameter name="_validate" type="Boolean"/>
        <Parameter name="_strUNL" type="String"/>
        <Parameter name="_scm" type="SchemaInPatch"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateUNLMethod" id="5528bc42-a23a-4ffc-b2a6-bb8925aeeba0">
        <updating/>
        <source>validateUNLMethod( _validate : Boolean; _strUNL : String; _scm : SchemaInPatch ) : Boolean updating, protected;
// ----------------------------------------------------------------------------
//	Created by cnwvu1	09 April 2008
//	Notes.	_validate = true - only validation
//			_validate = false - puts changes into DB
// ----------------------------------------------------------------------------

vars
	className	: String;
	cls			: ClassInSchema;
	mthName		: String;
	mth			: MethodInClass;
	str,
	strCls,
	strMth		: String;
	pos			: Integer;
	
	//cnwmc5 - 21 Jan 2014 - PAR 32864
	tokens : StringArray;
begin

	if _strUNL.length &lt;= 7 then
		app.msgBox('The line Method requires methodName: ' &amp; _strUNL, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	//cnwmc5 - 21 Jan 2014 - PAR 32864
	create tokens transient;
	_strUNL.getTokensForDelimiter(' ', tokens);
	
	self.removeNullsFromTokens(tokens);

	// getting class name
	//cnwmc5 - 21 Jan 2014 - PAR 32864
	if tokens.size &lt; 2 then
		app.msgBox('The line Method: there is no gap between class and method: ' &amp; _strUNL, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	else
		strCls := tokens[2];
	endif;
	
	// getting method name
	//cnwmc5 - 21 Jan 2014 - PAR 32864
	if tokens.size &lt; 3 then
		app.msgBox('The line Method: there is no gap between class and method: ' &amp; _strUNL, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	else
		strMth := tokens[3];
	endif;
	
	// DB changes
	if not _validate then
		// class
		cls := _scm.getClassInSchema( strCls );
		if cls = null then
			create cls;
			cls.setForCreate( strCls, false, false, _scm );
		 else
			cls.set( strCls, false, false );
		 endif;
		// Method
		mth := cls.getMethodInClass( strMth );
		if mth = null then
			create mth;
			mth.setForCreate( strMth, cls );
		else
			mth.set( strMth );
		endif;
	
	endif;
	
	return true;
epilog
	delete tokens;
end;
</source>
        <access>protected</access>
        <Parameter name="_validate" type="Boolean"/>
        <Parameter name="_strUNL" type="String"/>
        <Parameter name="_scm" type="SchemaInPatch"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateUNLReport" id="9f3e5eba-66a5-4d05-a63f-b9809881e0a6">
        <source>validateUNLReport(_validate : Boolean; _strUNL : String; _ptch : Patch) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 January 2014	cnwmc5	Initial creation	PAR 32864
16/03/2015		cnwmh5	Transient Leaks
*/

vars
	reportName	: String;
	report		: ReportInPatch;
	
	//cnwmc5 - 22 Jan 2014 - PAR 32864
	tokens : StringArray;
begin
	if _strUNL.length &lt;= 7 then
		app.msgBox('The line Report requires reportName: ' &amp; _strUNL, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	//cnwmc5 - 22 Nov 2013 - PAR 32864
	create tokens transient;
	_strUNL.getTokensForDelimiter(' ', tokens);
	
	self.removeNullsFromTokens(tokens);
	
	reportName := tokens[2];
	
	if not _validate then
		report	:= _ptch.allReportsInPatch[ reportName, _ptch.parNo ];
		if report = null then
			create report;
			report.setForCreate( reportName, _ptch );
		endif;
	endif;

	return true;
epilog
	delete tokens;
end;</source>
        <access>protected</access>
        <Parameter name="_validate" type="Boolean"/>
        <Parameter name="_strUNL" type="String"/>
        <Parameter name="_ptch" type="Patch"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateUNLReportView" id="86ffdaa7-01fb-44c6-8bb0-01682946d73d">
        <source>validateUNLReportView(_validate : Boolean; _strUNL : String; _ptch : Patch) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 January 2014	cnwmc5	Initial creation	PAR 32864
16/03/2015		cnwmh5	Transient Leaks
*/

vars
	reportViewName 	: String;
	reportView		: ReportViewInPatch;
	
	//cnwmc5 - 22 Jan 2014 - PAR 32864
	tokens : StringArray;
begin
	if _strUNL.length &lt;= 11 then
		app.msgBox('The line ReportView requires reportViewName: ' &amp; _strUNL, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	//cnwmc5 - 22 Nov 2013 - PAR 32864
	create tokens transient;
	_strUNL.getTokensForDelimiter(' ', tokens);
	
	self.removeNullsFromTokens(tokens);
	
	reportViewName := tokens[2];
	
	if not _validate then
		reportView	:= _ptch.allReportViewsInPatch[ reportViewName, _ptch.parNo ];
		if reportView = null then
			create reportView;
			reportView.setForCreate( reportViewName, _ptch );
		endif;
	endif;

	return true;
epilog
	delete tokens;
end;</source>
        <access>protected</access>
        <Parameter name="_validate" type="Boolean"/>
        <Parameter name="_strUNL" type="String"/>
        <Parameter name="_ptch" type="Patch"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateUNLRunApplication" id="0ab5da9c-e76b-4d02-bb82-2a1189bb6e27">
        <updating/>
        <source>validateUNLRunApplication( _validate : Boolean; _strUNL : String; _ptch : Patch ) : Boolean updating, protected;
// ----------------------------------------------------------------------------
//	Created by cnwvu1	09 April 2008
//	Notes.	_validate = true - only validation
//			_validate = false - puts changes into DB
// ----------------------------------------------------------------------------
// 16/03/2015	cnwmh5 	Transient Leaks
vars
	appl	: AppInSchema;
	scm		: SchemaInPatch;
	str,
	strScm,
	strApp	: String;
	pos		: Integer;
	
	//cnwmc5 - 22 Jan 2014 - PAR 32864
	tokens : StringArray;
begin

	if _strUNL.length &lt;= 4 then
		app.msgBox('The line Run requires applicationName: ' &amp; _strUNL, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	//cnwmc5 - 21 Jan 2014 - PAR 32864
	create tokens transient;
	_strUNL.getTokensForDelimiter(' ', tokens);
	
	self.removeNullsFromTokens(tokens);

	// getting Schema name
	if tokens.size &lt; 2 then
		app.msgBox('The line Run: there is no gap between Schema and Application: ' &amp; _strUNL, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	else
		strScm := tokens[2];
	endif;
	
	// getting Application name
	if tokens.size &lt; 3 then
		app.msgBox('The line Run: there is no gap between Schema and Application: ' &amp; _strUNL, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	else
		strApp := tokens[3];
	endif;
	
	// remind devs that they shouldn't use the JadeScript app any more (part of TFS 4847)
	// as this won't be called when deploying a patch via JSM.
	// (only the full JMTRelease app has been configured to run.)
	if strApp = "JadeScript" then
		app.msgBox('The JadeScript Application should no longer be used. Use the JMTRelease Application instead.',self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	// DB changes
	if not _validate then

		scm	:= _ptch.allSchemasInPatch[ strScm, _ptch.parNo ];
		if scm = null then
			create scm;
			scm.setForCreate( strScm, _ptch );
		else
			scm.set( strScm );
		endif;
	
		// application
		appl := scm.getAppInSchema( strApp );
		if appl = null then
			create appl;
			appl.setForCreate( strApp, scm );
		 else
			appl.set( strApp );
		 endif;
	
	endif;
	
	return true;

epilog
	delete tokens;
end;</source>
        <access>protected</access>
        <Parameter name="_validate" type="Boolean"/>
        <Parameter name="_strUNL" type="String"/>
        <Parameter name="_ptch" type="Patch"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateUNLSchema" id="8c089f69-2973-483a-aabf-1692dc5eba80">
        <updating/>
        <source>validateUNLSchema( _validate : Boolean; _strUNL : String; _ptch : Patch; _scm : SchemaInPatch output ) : Boolean updating, protected;
// ----------------------------------------------------------------------------
//	Created by cnwvu1	09 April 2008
//	Notes.	_validate = true - only validation
//			_validate = false - puts changes into DB
// ----------------------------------------------------------------------------
// 16/03/2015	cnwmh5	Transient Leaks
vars
	scmName	: String;
	token	: String;
//	scm		: SchemaInPatch;
	
	//cnwmc5 - 22 Jan 2014 - PAR 32864
	tokens	: StringArray;
begin

	if  _strUNL.length &lt;= 7 then
		app.msgBox('The line Schema requires SchemaName', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	//cnwmc5 - 22 Jan 2014 - PAR 32864
	create tokens transient;
	_strUNL.getTokensForDelimiter(' ', tokens);
	
	self.removeNullsFromTokens(tokens);

	if not _validate then
		if tokens.size &gt;= 2 then		//cnwmc5 - 22 Jan 2014 - PAR 32864
			scmName	:= tokens[2];		//cnwmc5 - 22 Jan 2014 - PAR 32864
		endif;							//cnwmc5 - 22 Jan 2014 - PAR 32864
		_scm	:= _ptch.allSchemasInPatch[ scmName, _ptch.parNo ];
		if _scm = null then
			create _scm;
			_scm.setForCreate( scmName, _ptch );
			//cnwmc5 - 29 Nov 2013 - PAR 33105
			if tokens.size &gt; 2 and tokens[3].toUpper() = 'ERRORSOK' then
				_scm.errorsOk := true;
			endif;
		else
			_scm.set( scmName );
			//cnwmc5 - 29 Nov 2013 - PAR 33105
			if tokens.size &gt; 2 and tokens[3].toUpper() = 'ERRORSOK' then
				_scm.errorsOk := true;
			endif;
		endif;
	
	endif;
	
	return true;
	
epilog
	delete tokens;
end;</source>
        <access>protected</access>
        <Parameter name="_validate" type="Boolean"/>
        <Parameter name="_strUNL" type="String"/>
        <Parameter name="_ptch" type="Patch"/>
        <Parameter name="_scm" type="SchemaInPatch" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateWeb" id="4c3d4cd4-fba2-4a19-ad94-2e595e24d4c5">
        <updating/>
        <source>validateWeb( _validate : Boolean; _ptch : Patch input) : Boolean updating, protected;
// ----------------------------------------------------------------------------
//	Notes.	_validate = true - only validation
//			_validate = false - puts changes into DB
// ----------------------------------------------------------------------------
vars
	str,
	s,
	details	: String;
	pos,
	posPrev	: Integer;
	strArray: HugeStringArray;
	tokens: String200Array;
	web		: WebInPatch;
	webSite, pathName, targetName: String;
begin

	if self.txt_notepad.text = '' then
		return false;
	endif;

	// adding CrLf to the end
	if self.txt_notepad.text [ self.txt_notepad.text.length-1 : 2 ] &lt;&gt; CrLf then	
		self.txt_notepad.text := self.txt_notepad.text &amp; CrLf;
	endif;	

	str := self.txt_notepad.text;
	pos := 1;
	posPrev := 0;
	s := str.scanUntil( CrLf, pos );
	
	create strArray transient;
	while (pos &lt;&gt; 0) do	// going through all UNL text
		if s &lt;&gt; null then	// when playing with CrLf - it can be null 
			strArray.add( s );
		endif;
		pos := pos + 1;
		posPrev := pos;
		if pos &gt; str.length then
			break;
		endif;
		s := str.scanUntil( CrLf, pos );
	endwhile;
	
	if not _validate then
		_ptch.allWebsInPatch.purge;
	endif;
	
	//cnwmc5 - PAR 31922 - 28/6/2013 - restructured the below foreach
	create tokens transient;
	foreach str in strArray do
		tokens.clear;
		str.asString200ArrayByDelimiter(tokens, '"');
		
		if str.countOccurrences('"') &lt;&gt; 2 then
			app.msgBox('Please specify a path name to copy from, surrounded by "quotes".', "Error", MsgBox_OK_Only + MsgBox_Information_Icon);
			return false;
		endif;
		
		details := tokens[1][1:tokens[1].length-1];
		if tokens.size = 3 then
			details := details &amp; tokens[3];
		endif;
		
		pathName := tokens[2];
		
		tokens.clear;
		details.asString200ArrayByDelimiter(tokens, ' ');
		
		if (tokens.size = 3 or tokens.size = 2) and tokens[1] = 'Web' then
			webSite := tokens[2];
			targetName := null;
			if tokens.size = 3 then
				targetName := tokens[3];
			endif;
			
			if not _validate then
				create web;
				web.setForCreate(webSite, pathName, targetName, _ptch);
			endif;
		else
			app.msgBox('The line is of unknown format: ' &amp; str, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
			return false;
		endif;
	endforeach;
	
	return true;

epilog
	delete strArray;
	delete tokens;

end;</source>
        <access>protected</access>
        <Parameter name="_validate" type="Boolean"/>
        <Parameter name="_ptch" type="Patch" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
