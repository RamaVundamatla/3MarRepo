    </JadeMethod>
    <JadeMethod name="doAPOverstowChange" id="f55f1abf-d43d-4d1d-902e-218a96205b70">
        <source>doAPOverstowChange();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 September 2011	cnwrd1	Initial creation

*/

vars
	index : Integer;
begin
	index := self.cmbAPOverstow.listIndex -1;
	
	if index = app.getErrorStringShortText(CMUI_YAConfigForm_HookCode).Integer then
		self.btnHookCode.enabled := true;
	else
		self.btnHookCode.enabled := false;
	endif;

epilog

end;</source>
    </JadeMethod>
