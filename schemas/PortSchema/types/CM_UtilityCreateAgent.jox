    <JadeMethod name="utlCreateTisTranShipEDI" id="7dad96b1-2f46-41a1-be96-8ea0e5311fab">
        <updating/>
        <source>utlCreateTisTranShipEDI(_tsController : CMIF_TranshipTIController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On 	By			Reason
// ----------	--------	--------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 22/07/2010	cnwdap1		PAR #25021 reverse order of TI validation and controller validation
//							(so having no voyage selected gets checked before TI voyage validation)
// 15/11/2010   cnwrs1      par 26215 remove the begintransaction that does not belong here so it can be used by EDI
// 26/09/2011	cnwkpd1		PAR #28277 - Use TI dictionary to speed up matching process
// 22/07/2013	cnwdap1		PAR #31196 New parameter for setTranship method
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 20/11/2019	jlgzm1		TFS 47222 Remove All Import stops is redundant
// 02/05/2022	jlizm1		TFS 53083 GPHA revceival/release of tranship cargo
vars
	control	: CMIF_TIUpdateController;
	realTI, pxyTI : CM_TrackedItem;
	objs : CM_TISet;
	sortedTIs : CM_TIByIdDups;
	theCMIFMonitor : CMIF_Monitor;
begin
	theCMIFMonitor := _passport.myCMIFMonitor;	//we dont want app.myValCA.valTrackedItems to write out progress updates for clumps of data
	_passport.setMyCMIFMonitor(null);
	if _tsController.allTrackedItems.isEmpty then
		app.raiseCMException2(MethodWithNullParam, method.name, 'Tranship TrackedItems', null, null);
		return;
	endif;

	control := app.createTIUpdateControl(TI_UPDMODE_TRANSHIP, _passport.userCode, null);	// 19/02/2010 cnwar2 #21962
	create objs transient;
	
	foreach realTI in _tsController.allTrackedItems do
		pxyTI := app.createUpdateProxy(realTI).CM_TrackedItem;
		pxyTI.setPxyFromCMIF_TranShip(_tsController, realTI);
		control.allTransientTIs.add(pxyTI);
	endforeach;
	_tsController.validate();						// PAR #25021
	app.myValCA.valTrackedItems(control, _passport);
	
	// PAR #28277
	create sortedTIs transient;
	control.allTransientTIs.copy(sortedTIs);
	
	// go through the Import TS
	foreach realTI in _tsController.allTrackedItems do : outerLoop
		// find the matching Proxy
		//foreach pxyTI in control.allPersistentTIs do
//		foreach pxyTI in control.allTransientTIs do
//			if realTI.id = pxyTI.id then

		pxyTI := sortedTIs[realTI.id];
		if pxyTI &lt;&gt; null then
			// pxyTI is the transient tranship version of realTI - update tranship details
			//realTI.setTranship(pxyTI, _passport, _tsController.removeStops);			// PAR #31196
			realTI.setTranship(pxyTI, _passport, false);		// PAR #31196
			if _tsController.interModal then											// TFS 53083
				realTI.setTransitStatus(TI_TransitStatusInterModal, true, _passport);	// TFS 53083
			endif;
//				continue outerLoop;
		endif;
//		endforeach;
	endforeach;	
epilog
	delete objs;
	delete control;	
	delete sortedTIs;
	_passport.setMyCMIFMonitor(theCMIFMonitor);
end;
</source>
        <Parameter name="_tsController" type="CMIF_TranshipTIController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateToDoInternalJob" id="cd98d19f-34e2-4004-9749-f0c0cb002660">
