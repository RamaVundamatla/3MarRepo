    <JadeMethod name="canUserAccessSelf" id="34f3ffe2-e8f3-4a6a-af4b-7cb44bec45e3">
        <source>canUserAccessSelf(_user: CM_User; _failedDAC  :CM_DataAccessController output; _passport: CM_Passport): Boolean;
// --------------------------------------------------------------------------------
// Created:		10 October 2006 by cnwdad1
//
// Purpose:		Reimplementation of superclass method with additional behaviour to
//				check whether the User can access the receiver's Operator.
//
// Returns:		True if the User can access the reciver, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	operatorObj		: CM_Operator;
	
begin
	operatorObj	:=	self.myOperator;
	
	if operatorObj &lt;&gt; null then
		if not operatorObj.canUserAccessSelf(_user, _failedDAC, _passport) then
			return false;
		endif;
	endif;
	
	return inheritMethod(_user, _failedDAC, _passport);
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cloneMySelf" id="2dd7e621-2251-4cbc-8a9f-29e30ec529ca">
        <source>cloneMySelf(_transient : Boolean; _theNewCode : String) : SelfType;
//--------------------------------------------------
// Created:	25 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	newVessel		: CM_Vessel;
	vtDataObj		: CM_VesselTerminalData;
	newVtDataObj	: CM_VesselTerminalData;
	newCriteriaType  : CM_YACriteriaType;
begin
	newVessel := self.cloneSelf(false);
	
	newVessel.code 				:= _theNewCode.trimBlanks;
	newVessel.clonedFromVessel 	:= self.code; //epr TFS 3614 12/4/17 changed length 
	newVessel.myRootForVessel 	:= app.myRoot;
	newVessel.myOperator 		:= self.myOperator;
	
	//epr TFS 3614 10/4/17
	newVessel.myDefaultTrade	:= self.myDefaultTrade;
	
	newVessel.lloydsNumber :=null;
	newVessel.callSign := null;
	
	if self.myHMSVesselData &lt;&gt; null
	and (app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE(), Mod_Harbour) )
	then
		newVessel.myHMSVesselData := self.myHMSVesselData.cloneMySelf(_transient);
	endif;

	if self.myCellularVesselStructure &lt;&gt; null
//	and app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE(), PmShipPlanning)
// ### JIRA 33505 30DEC2024 NAVAB1 (Mod_CargoShip in part of base now)	and app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE(), Mod_CargoShip)//07 Oct 2019	NDL	TFS 46169
	then
		newVessel.myCellularVesselStructure := self.myCellularVesselStructure.cloneMySelf(_transient);
	endif;

	if self.myROROVesselStructure &lt;&gt; null
//	and app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE(), PmShipPlanning)
// ### JIRA 33505 30DEC2024 NAVAB1 (Mod_CargoShip in part of base now)	and app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE(), Mod_CargoShip)	//07 Oct 2019	NDL TFS 46169
	then
		newVessel.myROROVesselStructure := self.myROROVesselStructure.cloneMySelf(_transient);
	endif;

	if self.myGeneralCargoVesselStructure &lt;&gt; null
	and app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE(), Mod_GeneralCargo)
	then
		newVessel.myGeneralCargoVesselStructure := self.myGeneralCargoVesselStructure.cloneMySelf(_transient);
	endif;
	
	//cnwrd1 par 31874
	if self.myStructuralElements &lt;&gt; null then
		newVessel.myStructuralElements := self.myStructuralElements.cloneMySelf(_transient);
	endif;
	
	//epr TFS 3614 10/4/17
	if self.myVoyageAllocationConfig &lt;&gt; null then
		newVessel.myVoyageAllocationConfig := self.myVoyageAllocationConfig.cloneSelf(_transient);
		newVessel.myVoyageAllocationConfig.setYACriteriaTypeForColour(self.myVoyageAllocationConfig.myYACriteriaTypeForColour);
		
		foreach newCriteriaType in self.myVoyageAllocationConfig.allOpCriteria do
				newVessel.myVoyageAllocationConfig.allOpCriteria.add(newCriteriaType);
		endforeach;
		
	endif;
	
// cnwdad1 06/09/2007 - PAR #14811.
	foreach vtDataObj in self.allTerminalDatas do
		newVtDataObj	:=	vtDataObj.cloneMe(_transient);
		newVtDataObj.setVessel(newVessel);
	endforeach;
	
	return newVessel;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <Parameter name="_theNewCode" type="String"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="copyVoyageAllocConfigToVoyage" id="cdb0fe51-0528-484d-a5e7-ef1e9b999c80">
        <updating/>
        <source>copyVoyageAllocConfigToVoyage(_voyage : CM_Voyage input) updating;
// ---------------------------------------------------------------------------
// Created:     19 February 2015 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// // PAR 35679
// ---------------------------------------------------------------------------

vars
	pxyVAConfig : CM_VoyageAllocationConfig;

begin
	if self.myVoyageAllocationConfig = null then
		return;
	endif;
	
	create pxyVAConfig transient;
	pxyVAConfig.setForUpdate(self.myVoyageAllocationConfig);
	
	pxyVAConfig.setForUpdateVoyage(_voyage);
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createGCStructureDefault" id="b8a52707-365e-4e80-90d1-a22658e516b7">
        <updating/>
        <source>createGCStructureDefault() updating;
/*
Purpose:			
Date				Who			Reason
FEB 2014		CNWAB1		Initial creation
*/
vars

begin
	
	if self.isTransient then
		return;
	endif;
	
	if self.myGeneralCargoVesselStructure = null then
		create self.myGeneralCargoVesselStructure persistent;
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="createHMSVesselDataDefault" id="7e37cde5-54db-4f90-b146-7ab413bd6b2d">
        <updating/>
        <source>createHMSVesselDataDefault() updating;
//--------------------------------------------------
// Created:	31 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if self.isTransient then
		return;
	endif;
	
	if self.myHMSVesselData = null then
		create self.myHMSVesselData persistent;
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="createProxyVoyageRequest" id="f7f7122d-5ff1-4196-b0c3-ae873600361e">
        <source>createProxyVoyageRequest(	_terminal : CM_Terminal;
							_voyageCode : String;
							_operator : CM_Operator;
							_arrivalTS  : TimeStamp;
							_departureTS : TimeStamp;
							_hasCargo : Boolean;
							_externalCode : String; //tfs 37939
							_externalRef : String;
							_originPort,
							_lastPortOfCall,
							_nextPortOfCall,
							_lastPort : CM_Port;
							_vesselCategory : HMS_VesselCategory;
							_visitType : HMS_VisitType;
							_cargoLoadOperator,
							_cargoDischargeOperator : CM_Operator;
							_voyageProcess : CM_VoyageProcess;
							_passport : CM_Passport input) : CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

/****Changes

Date		Name	TFS#			Description
============================================================================
26/03/2018	jlger1	37663			Initial creation
13/06/2018 	jlger1	tfs 39129
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
============================================================================*/

vars
	pxyVoyage 					: CM_Voyage;
	craneClearance 				: Integer;
	lastVoyage 					: CM_Voyage;
	callSign					: String;
	lloydsNumber 				: String;
	starboardBerthed 			: Boolean;
	vesselType					: Integer;
	voyageColor					: Integer;
	displayOption 				: Integer;
	defaultLineGroupDebtor 		: CM_LineGroupDebtor;
	dishargeCompany 			: CM_Bank;
	trade 						: CM_Trade;
	shippingLine 				: CM_ShippingLine;
	pxyGlobalVoyage 			: CM_VoyageGlobal;
	voyagePlanningCode 			: CM_VoyagePlanningCode;
	moveMapRec, moveMapRel 		: CM_MoveMap;
	altVoyage 					: CM_Voyage;
	voyageNumber 				: Integer;
	allOperators 				: CM_OperatorByCodeDict;
	useVoyageAllocations 		: Boolean;
	externalRef					: String;
	yearOfBuild 				: Integer;
	airDraft 					: Decimal[6,2];
	maxVesselBeam 				: Decimal[6,2];
	draftBow 					: Decimal[6,2];
	draftMid 					: Decimal[6,2];
	draftStern 					: Decimal[6,2];
	buildingLine				: Decimal[6,2];
	loaWithRampDown 			: Decimal[6,2];
	useOutOfSequenceLoadingJobs : Boolean;
	pxyPortRoation				: CM_PortRotation;
	portRotation 				: CM_PortRotation;
	voyageStatusCode 			: Integer;
	voyageStatus				: CM_VoyageStatus;
	voyageProcess				: CM_VoyageProcess;		// TFS 37427
	pxyHMSVoyage 				: HMS_VoyageData;
	pxyVoyageAllocationConfig 	: CM_VoyageAllocationConfig;
	includeLOLO					: Boolean;
	includeRORO					: Boolean;
	includeHOLDS 				: Boolean;
	daysAtPort 					: Real;
	tsInt 						: TimeStampInterval;
	paymentType					: Integer;
	isBarge						: Boolean; // jlgka1 TFS 37102
	defaultBerth				: HMS_Berth; //TFS 52194  15/10/21
begin
	
	
	
	if _voyageCode = null then
		app.raiseCMException(Voyage_code_must_specifi,null,null);
		return null;
	endif;
	
	if _terminal = null then
		app.raiseCMException(Input_required_field_terminal,null,null);
		return null;
	endif;
	
	if  _arrivalTS = null or  not _arrivalTS.isValid then
		app.raiseCMException(Input_required_field_arrDatTim,null,null);
		return null;
	endif;
	
	
	if _terminal.myHarbour &lt;&gt; null then
		lastVoyage := _terminal.myHarbour.getVesselsLastVoyage(self.code);
	else
		lastVoyage := self.getLastVoyage(_terminal);
	endif;
	
	create allOperators transient;
	displayOption		 := VoyageDisplayDefault;
	voyageColor			 := Cn_LightGray;
	useVoyageAllocations := true;
	if lastVoyage &lt;&gt; null then
		lloydsNumber 			:= lastVoyage.lloydsNumber;
		craneClearance			:= lastVoyage.craneClearance;
		callSign				:= lastVoyage.callSign;
		starboardBerthed 		:= lastVoyage.starboardBerthed;
		displayOption			:= lastVoyage.displayOption;
		voyageColor				:= lastVoyage.colour;
		vesselType				:= lastVoyage.vesselType;
		defaultLineGroupDebtor 	:= lastVoyage.myDefaultLineGroupDebtor;
		dishargeCompany 		:= lastVoyage.myDischargeCompany;
		trade 					:= lastVoyage.myTrade;
		shippingLine 			:= lastVoyage.myShippingLine;
		voyagePlanningCode		:= lastVoyage.myVoyagePlanningCode;
		moveMapRec 				:= lastVoyage.myMMReceival;
		moveMapRel 				:= lastVoyage.myMMRelease;
		altVoyage 				:= lastVoyage.myCusresAltVoyage;
		voyageNumber 			:= lastVoyage.voyageNumber +1;
		useVoyageAllocations 	:= lastVoyage.useVoyageAllocations;
		externalRef 			:= lastVoyage.externalRef;
		yearOfBuild 			:= lastVoyage.yearOfBuild;
		airDraft 				:= lastVoyage.airDraft;
		maxVesselBeam 			:= lastVoyage.maxVesselBeam;
		draftBow 				:= lastVoyage.draftBow;
		draftMid				:= lastVoyage.draftMid;
		draftStern				:= lastVoyage.draftStern;
		buildingLine			:= lastVoyage.buildingLine;
		loaWithRampDown			:= lastVoyage.loaWithRampsDown;
		useOutOfSequenceLoadingJobs := lastVoyage.allowOutOfOrderJobs;
	//	externalCode := lastVoyage.voyageCodeExternal;

		isBarge					:= lastVoyage.isBarge; // jlgka1 TFS 37102
	endif;
	paymentType 			:= PaymentType_None; //epr TFS 43823 13/3/19
	//if no last voyage or no value default from the vessel
	if lloydsNumber = null then
		lloydsNumber:=self.lloydsNumber;
	endif;
	if craneClearance = null then
		craneClearance:=self.craneClearance;
	endif;
	if callSign = null then
		callSign:=self.callSign;
	endif;
	if vesselType = null then //never used
		vesselType:=self.vesselType;
	endif;
	if trade = null then
		trade:=self.myDefaultTrade;
	endif;
	if self.myHMSVesselData &lt;&gt; null then
		if shippingLine = null then
			shippingLine :=self.myHMSVesselData.myDefaultShippingLine;
		endif;
	endif;
	if yearOfBuild = null then
		yearOfBuild :=self.yearOfBuild;
	endif;
	if airDraft = null then
		airDraft :=self.airDraft;
	endif;
	if maxVesselBeam = null then
		maxVesselBeam :=self.maxVesselBeam;
	endif;
	if draftBow = null then
		draftBow :=self.draftBow;
	endif;
	if draftMid = null then
		draftMid :=self.draftMid;
	endif;
	if draftStern = null then
		draftStern :=self.draftStern;
	endif;
	if buildingLine = null then
		buildingLine :=self.buildingLine;
	endif;
	if loaWithRampDown = null then
		loaWithRampDown :=self.loaWithRampsDown;
	endif;
	if trade &lt;&gt; null then
		trade.operators.copy(allOperators);
	endif;
	
	if app.myRoot.allVoyagesGlobal[_voyageCode] = null then
		create pxyGlobalVoyage transient;
		pxyGlobalVoyage.setProxy(_voyageCode, self.name, null, null, null, null, null, 0, null, app.myRoot);
	endif;
	
	if _voyageProcess &lt;&gt; null then
		voyageProcess:=_voyageProcess;
	else
		voyageProcess := _terminal.getDefaultVoyageProcess();
	endif;
	if voyageProcess &lt;&gt; null then													// TFS 37427
		voyageStatus := voyageProcess.getInitialVoyageStatus;
	endif;
	voyageStatusCode:=Voyage_Status_VoyRequested;
	if voyageStatus &lt;&gt; null then
		voyageStatusCode:=voyageStatus.id;
	endif;
	
	if _externalRef &lt;&gt; null then
		externalRef:=_externalRef;
	endif;
	
	if _cargoLoadOperator &lt;&gt; null then
		allOperators.addNoDuplicates(_cargoLoadOperator,false);
	endif;
	
	if _cargoDischargeOperator &lt;&gt; null then	
		allOperators.addNoDuplicates(_cargoDischargeOperator,false);		
	endif;
	
	if _operator &lt;&gt; null then
		allOperators.addNoDuplicates(_operator,false);
	endif;
	
	create pxyVoyage transient;
	pxyVoyage.setProxyVoyage(null, //vessel image
							callSign, //callsign
							_voyageCode, 
							null,//inward
							self.remarks, // TFS 52425 NAVAB1 23NOV2021 put the vessel remarks onto the voyage
							self.code,
							self.name,
							lloydsNumber, //lloyds
							false, //archived
							false, //transferred
							starboardBerthed, //starboard berthed - defaults to false
							craneClearance, //crane clearance
							displayOption, 
							voyageColor,
							voyageStatusCode,
							vesselType,
							null, //archivedDT
							_arrivalTS,
							_departureTS,
							null, //loadStartDT
							null, //loadEndDT
							null, //nonPlannedEffectiveDT
							null, //cutoffDT
							defaultLineGroupDebtor,
							dishargeCompany,
							_operator,
							trade,
							shippingLine,
							_terminal,
							pxyGlobalVoyage,
							voyagePlanningCode,
							Voyage_Invoice_Status_NotGen,
							moveMapRec,
							moveMapRel,
							altVoyage,
							voyageNumber,
							false, //ovveride defaults
							allOperators,
							null, //default receival cutoffs from terminal,
							useVoyageAllocations,
							externalRef,
							yearOfBuild,
							airDraft   ,
							maxVesselBeam ,
							draftBow ,
							draftMid ,
							draftStern ,
							buildingLine ,
							loaWithRampDown ,
							useOutOfSequenceLoadingJobs,
							_arrivalTS,  //expected arrival 
							_departureTS,  //expected departure
							null,  //generalLandingDate
							_externalCode,
							paymentType,
							isBarge,	 // jlgka1 TFS 37102
							null,         //03/06/2020 cnwma1 Tfs #49400
							false	// 31.Aug.2023 navsp1 TFS 57809
							);
	pxyVoyage.setMyVessel(self);	//19 Apr 2018	NDL	TFS 38135
	if _hasCargo then		
		includeLOLO:= self.structureIncludesLOLO ;
		includeRORO:= self.structureIncludesRORO;
		includeHOLDS:= self.structureIncludesHolds;
	endif;
	pxyVoyage.setProxyForVoyageType(includeLOLO ,
									includeRORO ,
									includeHOLDS,
									self);
	
	if trade &lt;&gt; null then
		foreach portRotation in trade.allPortRotations discreteLock do
			if portRotation.myPort = null then
				continue;
			endif;
			create pxyPortRoation transient;
			pxyPortRoation.setProxy(portRotation.myPort,pxyVoyage);
			pxyVoyage.allPorts.add(portRotation.myPort);
		endforeach;
	endif;
	
	pxyVoyage.setProxyNextLastPortRotations(_originPort,_lastPortOfCall,_nextPortOfCall,_lastPort);	
	
	
	tsInt := _departureTS - _arrivalTS;
	daysAtPort := tsInt.inDaysAndPartOf();
	
	pxyVoyage.setProxyExchangeData(starboardBerthed,
									null, //pilotOnBoardDT,
									null, //abourOB,
									null, //labourOS,
									null, //dateAvailable,
									null, //shipExangeDT,
									null, //exchangeCompleteDT,
									null , //tmpDepartTargetDT,
									daysAtPort, //totalTimeInPort,
									_terminal.getConfig(NonChargeTime).Decimal, //nonChargeTime,
									_terminal.getConfig(StopCharging).String, //stopChargingAt,
									_terminal.getConfig(VesselLoadRate).Decimal,
									_terminal.getConfig(VesselDischargeRate).Decimal,
									voyageStatusCode,
									null,
									null,
									_terminal.getConfig(IsShipLanderSealCheck).Boolean,
									voyageProcess	);		
									
	if 	self.myHMSVesselData &lt;&gt; null and  _terminal.myHarbour &lt;&gt; null then
		create pxyHMSVoyage transient;
		pxyVoyage.setHMSVoyageData(pxyHMSVoyage);
		//jlier1 TFS 52194  15/10/21
		defaultBerth:=_terminal.myHarbour.getDefaultBerthForMoveType(HMSMovementTypeArrival);
		if lastVoyage &lt;&gt; null and lastVoyage.myHMSVoyageData &lt;&gt; null then
			lastVoyage.myHMSVoyageData.setProxyVoyageHMSData(pxyHMSVoyage,defaultBerth);
		else
			
			self.myHMSVesselData.setProxyVoyageHMSData(pxyHMSVoyage,true,_terminal);
		endif;
		
		if _vesselCategory &lt;&gt; null then
			pxyHMSVoyage.setVesselCategoryIn(_vesselCategory);
		endif;
		if _visitType &lt;&gt; null then
			pxyHMSVoyage.setMyVisitType(_visitType);
		endif;
		
	
	endif;
	
	if useVoyageAllocations then
		create pxyVoyageAllocationConfig transient;
		if self.myVoyageAllocationConfig &lt;&gt; null then
			pxyVoyageAllocationConfig.setProxyVoyage(self.myVoyageAllocationConfig.allOpCriteria,self.myVoyageAllocationConfig.allGroupLabelCriteria,Red,self.myVoyageAllocationConfig.myYACriteriaTypeForColour,pxyVoyage, null);
		else
			pxyVoyageAllocationConfig.setProxyVoyage(null,null,Red,null,pxyVoyage, null);
		
		endif;
	endif;

	return pxyVoyage;
epilog
	delete allOperators;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_arrivalTS" type="TimeStamp"/>
        <Parameter name="_departureTS" type="TimeStamp"/>
        <Parameter name="_hasCargo" type="Boolean"/>
        <Parameter name="_externalCode" type="String"/>
        <Parameter name="_externalRef" type="String"/>
        <Parameter name="_originPort" type="CM_Port"/>
        <Parameter name="_lastPortOfCall" type="CM_Port"/>
        <Parameter name="_nextPortOfCall" type="CM_Port"/>
        <Parameter name="_lastPort" type="CM_Port"/>
        <Parameter name="_vesselCategory" type="HMS_VesselCategory"/>
        <Parameter name="_visitType" type="HMS_VisitType"/>
        <Parameter name="_cargoLoadOperator" type="CM_Operator"/>
        <Parameter name="_cargoDischargeOperator" type="CM_Operator"/>
        <Parameter name="_voyageProcess" type="CM_VoyageProcess"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createTerminalDataProxy" id="57b22c69-bece-4f86-88a8-a7ff14f9569f">
        <source>createTerminalDataProxy(_isUseTerminalDefaults:Boolean;
						_nonChargeTime:Decimal;
						_stopChargingAt:String;
						_grossLoadingTime:Decimal;
						_grossDischargeTime:Decimal;
						_downTime:Decimal;
						_loadRate:Decimal;
						_dischargeRate:Decimal;
						_draftArrival:Decimal;
						_draftDeparture:Decimal;
						_preferredBerthObj:HMS_Berth;
						_terminalObj:CM_Terminal):Boolean;
// --------------------------------------------------------------------------------
// Created:		25 August 2006 by cnwdad1
//
// Purpose:		Creates a proxy Vessel Terminal Data object for the receiver.
//
// Parameters:	_isUseTerminalDefaults - True if Terminal default values are to be used.
//				_nonChargeTime - The number of hours after arrival at the harbour
//					before charging begins.
//				_stopChargingAt - A constant value (CM_Terminal) to indicate when
//					charging stops.
//				_grossLoadingTime - The expected number of days the ship will be 
//				loading in the port.
//				_grossDischargeTime - The expected number of days the ship will be 
//				discharging in	the port.
//				_downTime - The number of hours at the wharf where the vessel is
//					neither loading nor discharging cargo.
//				_loadRate - The standard load rate in tonnes per hour.
//				_dischargeRate - The standard discharge rate in tonnes per hour.
//				_draftArrival - The default draft of the vessel upon arrival.
//				_draftDeparture - The default draft of the vessel upon departure.
//				_terminalObj - A reference to the Terminal the ship is visiting.
//
// Returns:		True if the proxy was created, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyObj	: CM_VesselTerminalData;
	
begin
	self.raiseExceptionIfNotTransient(method);
	
	if self.allTerminalDatas[_terminalObj] &lt;&gt; null then
		return false;
	endif;
	
	create proxyObj transient;
	proxyObj.setProxy(	_isUseTerminalDefaults,
						_nonChargeTime,
						_stopChargingAt,
						_grossLoadingTime,
						_grossDischargeTime,
						_downTime,
						_loadRate,
						_dischargeRate,
						_draftArrival,
						_draftDeparture,
						_preferredBerthObj,
						_terminalObj, self);
	
	return true;
end;</source>
        <Parameter name="_isUseTerminalDefaults" type="Boolean"/>
        <Parameter name="_nonChargeTime" type="Decimal"/>
        <Parameter name="_stopChargingAt" type="String"/>
        <Parameter name="_grossLoadingTime" type="Decimal"/>
        <Parameter name="_grossDischargeTime" type="Decimal"/>
        <Parameter name="_downTime" type="Decimal"/>
        <Parameter name="_loadRate" type="Decimal"/>
        <Parameter name="_dischargeRate" type="Decimal"/>
        <Parameter name="_draftArrival" type="Decimal"/>
        <Parameter name="_draftDeparture" type="Decimal"/>
        <Parameter name="_preferredBerthObj" type="HMS_Berth"/>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createUnavailability" id="0f5ca7c1-547a-4738-bf8d-d7b0033a0160">
        <source>createUnavailability():CM_VesselUnavailability;
// --------------------------------------------------------------------------------
// Created:		12 September 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	unavailabilityObj	: CM_VesselUnavailability;
	
begin
	create unavailabilityObj;
	
	return unavailabilityObj;
end;</source>
        <ReturnType type="CM_VesselUnavailability"/>
    </JadeMethod>
    <JadeMethod name="createVoyage" id="1870d8f9-9d59-4948-82e0-dee6b6b14983">
        <updating/>
        <source>createVoyage(_pxyVoyage : CM_Voyage; _passport : CM_Passport input) : CM_Voyage updating;
/*
------------------------------------------------------------------------
Created:			14 January 2003 by cnwdwq1
Purpose:			This is the only way to create a CM_Cellullar voyage.
Parameters:		As above. Special comment:
Returns:			As above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	pxyVesselData : HMS_VesselData;
	voyage : CM_Voyage;
begin
	exclusiveLock(self);
	if self.canCreateVoyages = false then
		app.raiseCMException1(Err_VesselIsLocked, self.name, null, null);
		return null;
	endif;
	if _pxyVoyage = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_pxyVoyage',null, null);
		return null;
	endif;
	
	if _pxyVoyage.myHMSVoyageData &lt;&gt; null then
		self.createHMSVesselDataDefault();
	endif;

	create voyage as _pxyVoyage.class persistent;
	voyage.setForCreateInternal(self, _passport);
		
	return voyage;	

epilog
	delete pxyVesselData;	
end;</source>
        <Parameter name="_pxyVoyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="delete" id="a7e933c7-b46f-4a24-8d5d-0079079ff77b">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2021	jlgndl1	Initial creation

*/

vars
	
begin
	
	self.resetAuditsDuringDelete();	//21 Jan 2021	NDL	TFS 50152

end;</source>
    </JadeMethod>
    <JadeMethod name="displayForXlation" id="e3a05ca6-2fd2-4509-b675-5d0ebde69bc2">
        <source>displayForXlation(_codeFirst : Boolean) : String;

vars

begin
	if _codeFirst then
		return self.code.trimBlanks&amp;' ['&amp;self.name.trimBlanks&amp;']';
	else
		return self.name.trimBlanks&amp;' ['&amp;self.code.trimBlanks&amp;']';
	endif;
end;
</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doObjectVolatilityConversion" id="9b55229c-f370-4b17-8145-b3f5339859e9">
        <updating/>
        <source>doObjectVolatilityConversion(_converter: CM_ObjectVolatilityConverter input; _logIndent: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars
	indent			: Integer;
	
begin
	//_converter.logMessage("Processing collections for " &amp; self.String, _logIndent);				navma1 14.01.2026
	indent := _logIndent + 1;
	
	inheritMethod(_converter, indent);

	if self.myCellularVesselStructure &lt;&gt; null then
		self.myCellularVesselStructure.doObjectVolatilityConversion(_converter, indent);
	endif;
	
	//_converter.logMessage("Finished processing collections for " &amp; self.String, _logIndent);		navma1 14.01.2026
	
	
epilog

end;</source>
        <Parameter name="_converter" type="CM_ObjectVolatilityConverter" usage="input"/>
        <Parameter name="_logIndent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="erase" id="6a2ea93d-3c80-49d6-be58-66cebe9ffcd6">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
Date		Who		Reason
25 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
*/
vars

begin
	self.exclusiveLock(self);

	self.eraseXlations (self.allXlations, NORMAL_ERASE);
	
	//21.09.2020 cnwma1 TFS #49906
	if app.myPassport.isOpsViewEnabled(null) then
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE,
									 BGP_OpsViewWSRequest.OPS_TYPE_VESSEL,
									 self.getOidString);
	endif;
	//21.09.2020 cnwma1 TFS #49906
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocGetChildRefKey" id="810d0477-14a7-49c1-a760-c704733ca80c">
        <source>exportAsXMLDocGetChildRefKey(_property: Property input) : Property;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	
	if _property = CM_Vessel::myOperator then
		return CM_Operator::code;
	elseif _property = CM_Vessel::myDefaultTrade then
		return CM_Trade::description;
	endif;
		
	return inheritMethod(_property);
	
epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Property"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="9de41dc1-19c1-4dc8-9714-76a9e173a680">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 April 2011	cnwer1	Initial creation

*/

vars

begin
	if _property = CM_Vessel::myOperator then
		return ExportAsChild;
	elseif _property = CM_Vessel::myROROVesselStructure then
		return ExportAsParent;
	elseif _property = CM_Vessel::myHMSVesselData then
		return ExportAsParent;
	elseif _property = CM_Vessel::myCellularVesselStructure then
		return ExportAsParent;
	elseif _property = CM_Vessel::myGeneralCargoVesselStructure then
		return ExportAsParent;
	elseif _property = CM_Vessel::myDefaultTrade then
		return ExportAsChild;
	elseif _property = CM_Vessel::myVoyageAllocationConfig then
		return ExportAsParent;
	elseif _property = CM_Vessel::myStructuralElements then
		return ExportAsParent;
	endif;
	
	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findVoyageMovementAtTime" id="3580fdb5-4a7e-4507-8d4d-81875fadd76b">
        <source>findVoyageMovementAtTime(_occursOnDateTime : TimeStamp) : HMS_Movement;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2009	cnwer1	Initial creation

*/

vars
	iter,
	iter2: Iterator;
	voyageGlobal,
	theVoyageGlobal : CM_VoyageGlobal;
	movement : HMS_Movement;
begin
	iter :=self.allVoyageGlobals.createIterator;
	self.allVoyageGlobals.startKeyLss(_occursOnDateTime,iter);
	while iter.next(voyageGlobal)  do
		
		if voyageGlobal.arrivalDT &gt; _occursOnDateTime then
			break;
		endif;

		if voyageGlobal.getLastDepartureTime &gt;= _occursOnDateTime then
			theVoyageGlobal:=voyageGlobal;
			break;
		endif;

	endwhile;
	
	if theVoyageGlobal &lt;&gt; null then
		
		iter2:=theVoyageGlobal.allHMSMovements.createIterator;
		theVoyageGlobal.allHMSMovements.startKeyLeq(_occursOnDateTime,iter2);
		
		while iter2.next(movement) do
			if movement.arrivalTimeAtToRegion &lt;  _occursOnDateTime then
				break;
			endif;
			
			if movement.occursOnDTNEW &gt; _occursOnDateTime then
				break;
			endif;
			
			return movement;
			
		endwhile;
	endif;
	
	return null;
epilog
	delete iter;
	delete iter2;
end;</source>
        <Parameter name="_occursOnDateTime" type="TimeStamp"/>
        <ReturnType type="HMS_Movement"/>
    </JadeMethod>
    <JadeMethod name="getAllMasters" id="faff9f3a-e8c2-43e0-85fd-53b4689a0e95">
        <source>getAllMasters() : String;
//-----------------------------------------------------------------------
//	Created:	03 August 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	masterColl	: HMS_MasterByCodeDict;
	voyage		: CM_Voyage;
	movement	: HMS_VoyageMovement;
	string		: String;
	master		: HMS_Master;
	iter 		: Iterator;
	terminal 	: CM_Terminal;
begin

	create masterColl transient;
	foreach terminal in app.myRoot.allTerminals do
		delete iter;		// PAR #26678
		iter := terminal.allVoyagesByVesselCodeArrivDT.createIterator();
		terminal.allVoyagesByVesselCodeArrivDT.startKeyGeq(code, null, iter);
	
		// return the last voyage to arrive, usually a future voyage as typically voyages
		// are added to the system in advance, with an arrival date that is in the future
		while iter.next(voyage) do
			if voyage.vesselCode &lt;&gt; code then
				break;
			endif;
			
			if voyage.myHMSVoyageData &lt;&gt; null then
				if voyage.myHMSVoyageData.myMaster &lt;&gt; null then
					if not masterColl.includes (voyage.myHMSVoyageData.myMaster) then
						masterColl.addNoDuplicates (voyage.myHMSVoyageData.myMaster, false);
						string := string &amp; voyage.myHMSVoyageData.myMaster.description &amp; CrLf;
					endif;
				endif;
				foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
					if movement.myMaster &lt;&gt; null then
						if not masterColl.includes (movement.myMaster) then
							masterColl.addNoDuplicates (movement.myMaster, false);
							string := string &amp; movement.myMaster.description &amp; CrLf;
						endif;
					endif;
				endforeach;
			endif;
		endwhile;
	endforeach;
	return string;
	

epilog
	delete masterColl;
	delete iter;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllMastersForRwr" id="6a2f04de-3234-4172-ab99-ed9ccef5a0fe">
        <source>getAllMastersForRwr():HMS_MasterByCodeDict;

/*

Purpose:			Basically a copy of getAllMasters specifically for report writer.

Parameters:			

Return Value:		


Date		Who		Reason
01 May 2012	cnwndl1	Initial creation	Par 29496

*/

vars
	masterColl	: HMS_MasterByCodeDict;
	voyage		: CM_Voyage;
	movement	: HMS_VoyageMovement;
	master		: HMS_Master;
	iter 		: Iterator;
	terminal 	: CM_Terminal;
begin

	create masterColl transient;
	
	foreach terminal in app.myRoot.allTerminals do
		delete iter;
		iter := terminal.allVoyagesByVesselCodeArrivDT.createIterator();
		terminal.allVoyagesByVesselCodeArrivDT.startKeyGeq(code, null, iter);
	
		// return the last voyage to arrive, usually a future voyage as typically voyages
		// are added to the system in advance, with an arrival date that is in the future
		while iter.next(voyage) do
			if voyage.vesselCode &lt;&gt; code then
				break;
			endif;
			
			if voyage.myHMSVoyageData &lt;&gt; null then
				master := voyage.myHMSVoyageData.myMaster;
				if master &lt;&gt; null then
					if not masterColl.includes (master) then
						masterColl.addNoDuplicates (master, false);
					endif;
				endif;
				foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
					master := movement.myMaster;
					if master &lt;&gt; null then
						if not masterColl.includes (master) then
							masterColl.addNoDuplicates (master, false);
						endif;
					endif;
				endforeach;
			endif;
		endwhile;
	endforeach;

	return masterColl;
	
epilog
	
	delete iter;
	
end;</source>
        <ReturnType type="HMS_MasterByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="getAllVoyageGlobals" id="61a2ee62-a9c1-499c-b688-7b8fd2f3458e">
        <source>getAllVoyageGlobals() : CM_VoyageGlobalByArrivalDict;

/*

Purpose:			Get the appropriate collections of all global voyages for the receiver, dependant on
					whether or not we are in scenario mode


Return Value:		Dictionary of all the receiver's global voyages


/* Changes

Date		Name	TFS#		Description
============================================================================
31 Mar 2008	cnwkpd1	PAR #xxxxx - Initial creation
23 Sep 2019 jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
begin
	return self.allVoyageGlobals;	
end;
</source>
        <ReturnType type="CM_VoyageGlobalByArrivalDict"/>
    </JadeMethod>
    <JadeMethod name="getArrivalDraught" id="84d214ff-4401-4e7d-9c69-e05d8da1eaae">
        <source>getArrivalDraught(_terminalObj:CM_Terminal):Decimal;
// --------------------------------------------------------------------------------
// Created:		17 April 2007 by lorcan
//
// Purpose:		Returns the arrival draught at the specified Terminal.
//
// Parameters:	_terminalObj - A reference to the Terminal at which the cargo is
//					to be discharged.
//
// Returns:		The arrival draught 
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	terminalDataObj		: CM_VesselTerminalData;
	realTermObj			: CM_Terminal;
	
begin
	if _terminalObj = null then
		return 0;
	endif;
	
	realTermObj		:=	_terminalObj.getRealTerminal();
	terminalDataObj	:=	self.allTerminalDatas[realTermObj];
	
	if terminalDataObj = null then
		return realTermObj.getConfig(VesselDraftArrival).Decimal;
	endif;
	
	return terminalDataObj.defaultDraftArrival;
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="f08fe192-ed65-48e4-ac21-8c2afdbd5420">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     May 2007 by cnwvu1
// 30/03/2017 	cnwma1 TFS # 3704:PNL - Voyage definition - Create Harbour Details
// Purpose:     
// ---------------------------------------------------------------------------

vars
	txt		: String;
	tmpStr	: String;
	patchSegmentDuration: HMS_PSD_Vessel;
	terminalData		: CM_VesselTerminalData;
	vesselUnavailability: CM_VesselUnavailability;
	vdh : HMS_VesselDataHarbour;
begin

	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();

	// ----------------------------
	// Patch Duration estimatedTime
	// ----------------------------
	foreach patchSegmentDuration in self.allPathSegmentDurations do
		tmpStr := patchSegmentDuration.estimatedTime.String;
		txt := txt &amp; 'Path estimatedTime: ' &amp; patchSegmentDuration.myPathSegment.code &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endforeach;

	// ----------------------------
	//  Patch Duration minimumTime
	// ----------------------------
	foreach patchSegmentDuration in self.allPathSegmentDurations do
		tmpStr := patchSegmentDuration.minimumTime.String;
		txt := txt &amp; 'Path minimumTime: ' &amp; patchSegmentDuration.myPathSegment.code &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endforeach;

	// ----------------------------
	//     Vessel Terminal Data
	// ----------------------------
	foreach terminalData in self.allTerminalDatas do
		// isUseTerminalDefaults
		tmpStr := terminalData.isUseTerminalDefaults.String;
		txt := txt &amp; 'Terminal ' &amp; terminalData.myTerminal.code &amp; ': isUseTerminalDefaults'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		// grossLoadingTime
		tmpStr := terminalData.grossLoadingTime.String;
		txt := txt &amp; 'Terminal ' &amp; terminalData.myTerminal.code &amp; ': grossLoadingTime'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		// grossDischargeTime
		tmpStr := terminalData.grossDischargeTime.String;
		txt := txt &amp; 'Terminal ' &amp; terminalData.myTerminal.code &amp; ': grossDischargeTime'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//nonChargeTime
		tmpStr := terminalData.nonChargeTime.String;
		txt := txt &amp; 'Terminal ' &amp; terminalData.myTerminal.code &amp; ': nonChargeTime'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//stopChargingAt
		tmpStr := terminalData.stopChargingAt.String;
		txt := txt &amp; 'Terminal ' &amp; terminalData.myTerminal.code &amp; ': stopChargingAt'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//vesselDownTime
		tmpStr := terminalData.vesselDownTime.String;
		txt := txt &amp; 'Terminal ' &amp; terminalData.myTerminal.code &amp; ': Operational DownTime'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//vesselLoadRate
		tmpStr := terminalData.vesselLoadRate.String;
		txt := txt &amp; 'Terminal ' &amp; terminalData.myTerminal.code &amp; ': Load Rate'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//vesselDischargeRate
		tmpStr := terminalData.vesselDischargeRate.String;
		txt := txt &amp; 'Terminal ' &amp; terminalData.myTerminal.code &amp; ': Discharge Rate'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//defaultDraftArrival
		tmpStr := terminalData.defaultDraftArrival.String;
		txt := txt &amp; 'Terminal ' &amp; terminalData.myTerminal.code &amp; ': defaultDraftArrival'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		//defaultDraftDeparture
		tmpStr := terminalData.defaultDraftDeparture.String;
		txt := txt &amp; 'Terminal ' &amp; terminalData.myTerminal.code &amp; ': defaultDraftDeparture'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endforeach;
	
	// ----------------------------
	//     Vessel Terminal Data
	// ----------------------------
	foreach vesselUnavailability in self.allUnavailabilities do
		// dateFrom
		tmpStr := vesselUnavailability.dateFrom.String;
		txt := txt &amp; 'vesselUnavailability ' &amp; vesselUnavailability.dateFrom.String &amp; ': dateFrom'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		// dateTo
		tmpStr := vesselUnavailability.dateTo.String;
		txt := txt &amp; 'vesselUnavailability ' &amp; vesselUnavailability.dateFrom.String &amp; ': dateTo'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		// comments
		tmpStr := vesselUnavailability.comments;
		txt := txt &amp; 'vesselUnavailability ' &amp; vesselUnavailability.dateFrom.String &amp; ': comments'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		// myReasonCode
		if vesselUnavailability.myReasonCode &lt;&gt; null then
			tmpStr := vesselUnavailability.myReasonCode.code;
			txt := txt &amp; 'vesselUnavailability ' &amp; vesselUnavailability.dateFrom.String &amp; ': myReasonCode'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
	
	
	endforeach;
	
	//30 Apr 2012	NDL	Par 2012
	if self.myHMSVesselData &lt;&gt; null then
		foreach vdh in  self.myHMSVesselData.allVesselDataForHarbour do
			tmpStr := vdh.isPilotExempt.String;
			txt := txt &amp; vdh.myHarbour.code &amp; ' : isPilotExempt' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endforeach;
		
		tmpStr := myHMSVesselData.hasHarbourDetails.asStringJMT;    //30/03/2017 cnwma1 TFS #3704
		txt := txt &amp; 'canCreateHarbourDetails' &amp;  AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;  //30/03/2017 cnwma1 TFS #3704

	endif;
	
	return txt;
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultBerth" id="37db352b-a6ea-4892-a8e0-26e8fc77138a">
        <source>getDefaultBerth(_harbour : HMS_Harbour) : HMS_Berth;
//--------------------------------------------------
// Created:	01 April 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _harbour = null then
		return null;
	endif;
	
	if self.myHMSVesselData = null then
		return null;
	endif;
	
	return self.myHMSVesselData.getDefaultBerthForHarbour(_harbour);
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getDepartureDraught" id="fc432964-35d8-4cf9-98c6-45f2892e9fc7">
        <source>getDepartureDraught(_terminalObj:CM_Terminal):Decimal;
// --------------------------------------------------------------------------------
// Created:		17 April 2007 by lorcan
//
// Purpose:		Returns the departure draught at the specified Terminal.
//
// Parameters:	_terminalObj - A reference to the Terminal at which the cargo is
//					to be discharged.
//
// Returns:		The departure draught 
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	terminalDataObj		: CM_VesselTerminalData;
	realTermObj			: CM_Terminal;
	
begin
	if _terminalObj = null then
		return 0;
	endif;
	
	realTermObj		:=	_terminalObj.getRealTerminal();
	terminalDataObj	:=	self.allTerminalDatas[realTermObj];
	
	if terminalDataObj = null then
		return realTermObj.getConfig(VesselDraftDeparture).Decimal;
	endif;
	
	return terminalDataObj.defaultDraftDeparture;
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="dbb65092-28ff-44ab-9711-b06d74c7bfdb">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     10 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _short then
		return self.code;
	else
		return '('&amp;self.code &amp; ')  ' &amp; self.name;
	endif;

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b8e8de11-26dd-4097-a384-0dbc1e567777">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
//07 Mar 13		PJS		PAR #31232
//06 Dec 21	    navma1	ChangeRequest 52511: SAL - Web Portal - Ports of Call
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_ISOVessel or
		_attrName = ETRow_NumberOfHolds or
		_attrName = ETRow_Use40Id 
		or _attrName = ETRow_NumSlotsDefined 
		or _attrName = ETRow_NumSlotsExpected 
		or _attrName = ETRow_BridgeAfterBay or
		_attrName = ETRow_BayOrder  then
		if self.myCellularVesselStructure &lt;&gt; null then     
			return  self.myCellularVesselStructure.getDisplayStringForAttribute(_attrName,_short);
		else
			return null;
		endif;
	elseif _attrName = ETRow_GeneralCargoHolds then		// 05/02/2015 cnwar2 #35611
		if self.myGeneralCargoVesselStructure &lt;&gt; null then
			return self.getNumberOfGCHolds().asStringJMT();
		else
			return null;
		endif;
	elseif _attrName = ETRow_VesselType then
		return app.vesselAccessTypeEnumToStr(self.vesselType);
	elseif _attrName = ETRow_CargoStructure then
		return structureTypeString;
	elseif _attrName = ETRow_MyShippingAgentDefault
	or _attrName = ETRow_MyTidalClass
	or _attrName = ETRow_MyTidalClassDept
	or _attrName = ETRow_MyVesselType
	or _attrName = ETRow_MyDefaultLineCompany
	or _attrName = ETRow_CountryCode
	or _attrName = ETRow_CoastalServiceVessel		
	or _attrName = ETRow_MyVesselCategoryOut
	or _attrName = ETRow_MyVesselCategoryIn	
	or _attrName = ETRow_MyHMSVesselType		
	or _attrName = ETRow_MyDefaultShippingLine 
	or _attrName = ETRow_LengthOverall 
	or _attrName = ETRow_GrossRegTonnes
	or _attrName = ETRow_NetRegTonnes		// QNS 2178
	or  _attrName = ETRow_DeadWeight 
	or _attrName = ETRow_Beam 
	or _attrName = ETRow_DraftFore 
	or  _attrName = ETRow_DraftAft 
	or _attrName = ETRow_BridgeToBow 
	or  _attrName = ETRow_BridgeToStern 
	or _attrName = ETRow_BowToFwdBay 
	or _attrName = ETRow_SternToAftBay 
	or _attrName = ETRow_SternToBunker then
		if self.myHMSVesselData &lt;&gt; null then
			return self.myHMSVesselData.getDisplayStringForAttribute(_attrName, _short);
		endif;
		return null;
	elseif _attrName = ETRow_AirDraft then
		return self.airDraft.asStringJMT;
	elseif _attrName = ETRow_MaxVoyageBeam then
		return self.maxVesselBeam.asStringJMT;
	elseif _attrName = ETRow_DraftBow then
		return self.draftBow.asStringJMT();
	elseif _attrName = ETRow_DraftMid then
		return self.draftMid.asStringJMT();
	elseif _attrName = ETRow_DraftStern then
		return self.draftStern.asStringJMT();
	elseif _attrName = ETRow_BuildingLine then
		return self.buildingLine.asStringJMT();
	elseif _attrName = ETRow_LoaWithRampsDown then
		return self.loaWithRampsDown.asStringJMT();
	// 31232
	elseif _attrName = ETRow_IncludesLOLO then
		return self.structureIncludesLOLO.asStringJMT();
	elseif _attrName = ETRow_IncludesRORO then
		return self.structureIncludesRORO.asStringJMT();
	elseif _attrName = ETRow_IncludesHolds then
		return self.structureIncludesHolds.asStringJMT();
	elseif _attrName = ETRow_DefaultTrade then					//06.12.2021 navma1 #52511
		if self.myDefaultTrade&lt;&gt; null then
			return self.myDefaultTrade.description;
		endif;
		return null;
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="f359be7d-92e2-4aa1-ae86-c7979d6113f8">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
//--------------------------------------------------
// Created:	05 September 2005 By: cnwgd1
//
// 26 Mar 2013	PJS		PAR # 31232
// 19 Nov   2018   cnwma1  Bug 42058: PEL1 - Workorder Voyage Missing port
//--------------------------------------------------
vars
	block      : CM_DataContainerBlock;
	passport   : CM_Passport;
	vslHarbour : HMS_VesselDataHarbour;
begin
	inheritMethod(_dataContainer);

	passport := app.myPassport;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('Vessel Remarks', DC_Label, 1, null);
	block.addNewItem(self.remarks, DC_Data, 1, null);	

	if self.myHMSVesselData &lt;&gt; null then
		self.myHMSVesselData.getExtraInfo(_dataContainer);
	endif;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('Masters', DC_Label, 1, null);
	block.addNewItem(self.getAllMasters(), DC_Data, 1, null);	
	
	if self.myCellularVesselStructure &lt;&gt; null then
		self.myCellularVesselStructure.getExtraInfo(_dataContainer);
	endif;
	
	// PAr #31232
	block := _dataContainer.addNewBlock;
	block.addNewItem('Cargo Structure', DC_Label, 1, null);
	block.addNewItem(self.structureTypeString, DC_Data, 1, null);	
	
	//19.11.2018 cnwma1 Bug #42058
	if self.myHMSVesselData &lt;&gt; null then
		if self.myHMSVesselData.allVesselDataForHarbour.isNotEmpty then
			block.addNewItem("Configured Harbours", DC_Label, 1,vslHarbour);
			block.addNewItem(self.myHMSVesselData.getHarboursString(CrLf),DC_Data, 1, vslHarbour);
		endif;
	endif;

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getGrossDischargeTime" id="b633f6cc-1e1e-4e32-b3bb-5b0e5dc1b406">
        <source>getGrossDischargeTime(_terminalObj:CM_Terminal):Decimal;
// --------------------------------------------------------------------------------
// Created:		28 February 2007 by cnwdad1
//
// Purpose:		Returns the time taken to discharge the receiver's cargo at the
//				specified Terminal.
//
// Parameters:	_terminalObj - A reference to the Terminal at which the cargo is
//					to be discharged.
//
// Returns:		The time required to discharge the cargo.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	terminalDataObj		: CM_VesselTerminalData;
	realTermObj			: CM_Terminal;
	
begin
	if _terminalObj = null then
		return 0;
	endif;
	
	realTermObj		:=	_terminalObj.getRealTerminal();
	terminalDataObj	:=	self.allTerminalDatas[realTermObj];
	
	if terminalDataObj = null then
		return realTermObj.getConfig(GrossDischargeTime).Decimal;
	endif;
	
	return terminalDataObj.grossDischargeTime;
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getGrossDischargeTimeMinutes" id="ce2a23cb-9434-4bb7-b1d4-2b3e4a41f2a3">
        <source>getGrossDischargeTimeMinutes(_terminalObj:CM_Terminal):Integer;
// --------------------------------------------------------------------------------
// Created:		28 February 2007 by cnwdad1
//
// Purpose:		Returns the time taken to load the receiver's cargo at the specified
//				Terminal.
//
// Parameters:	_terminalObj - A reference to the Terminal at which the cargo is
//					to be loaded.
//
// Returns:		The time required to load the cargo.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	terminalDataObj		: CM_VesselTerminalData;
	realTermObj			: CM_Terminal;
	
begin
	if _terminalObj = null then
		return 0;
	endif;
	
	realTermObj		:=	_terminalObj.getRealTerminal();
	terminalDataObj	:=	self.allTerminalDatas[realTermObj];
	
	if terminalDataObj = null then
		return (realTermObj.getConfig(GrossDischargeTime).Decimal * 60).Integer;
	endif;
	
	return terminalDataObj.getGrossDischargeTimeMinutes();
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
