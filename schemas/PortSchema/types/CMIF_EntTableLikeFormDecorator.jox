    <JadeMethod name="addCargoForEntRowName" id="b3288dd1-eacd-41d6-be1a-d2b2f36db7fc">
        <source>addCargoForEntRowName(_entRowName : String;_cargo: CM_TrackedItem);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwer1	Initial creation TFS 6863

*/

vars
	entRow : EntTableRow;
	row,col : Integer;
	data : String;
begin
	entRow := self.myEntTableDef.getEntTableRow(_entRowName);
	if entRow = null then
		return;
	endif;
	row:=self.findRowWithEntRow(entRow);
	if row = 0 then
		return;
	endif;
	col:= self.dataColumn;
	if self.myTable.accessCell(row, self.dataColumn-1).mergeCells = Table.MergeCells_Merge then
		col:= self.dataColumn-1;
	endif;
	
	if _cargo &lt;&gt; null then
		data:=_cargo.id;
	endif;
	//self.myTable.accessRow(row).itemObject:=_cargo;
	self.myTable.accessCell(row,col).text:=data;
	self.myTable.accessedCell.itemObject:=_cargo;
	
end;</source>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addDataForEntRow" id="828bbd99-638c-4547-bed6-a1382725fae5">
        <source>addDataForEntRow(_entRow : EntTableRow;_data: String) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2012	cnwer1	Initial creation HAT 2200

*/

vars
	row,
	col 	: Integer;
begin
	row:=self.findRowWithEntRow(_entRow);
	if row = 0 then
		return false;
	endif;
	col:= self.dataColumn;
	if self.myTable.accessCell(row, self.dataColumn-1).mergeCells = Table.MergeCells_Merge then
		col:= self.dataColumn-1;
	endif;
	
	self.myTable.accessCell(row,col).text:=_data;
	self.myTable.accessedCell.itemObject:=null;
	return true;
epilog

end;</source>
        <Parameter name="_entRow" type="EntTableRow"/>
        <Parameter name="_data" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
