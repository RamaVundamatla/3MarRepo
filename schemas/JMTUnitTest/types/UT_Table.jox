    <JadeMethod name="adjustHeight" id="202fbc8d-c7ba-4b74-931c-29d03ec9583f">
        <updating/>
        <source>adjustHeight(pMaxHeight : Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 April 2025	navpw1	Initial creation JIRA MTN-34402

*/

vars
	idx			: Integer;
	numRows		: Integer;
	totHeight	: Real;

begin
	numRows := self.rows;
	
	foreach idx in 1 to numRows do
		if self.accessRow(idx).visible then
			totHeight := totHeight + self.accessedRow.height;
			if totHeight &gt; pMaxHeight then
				break;
			endif;
		endif;
	endforeach;

	if totHeight &gt; 0 then
		totHeight := totHeight + 2;
		if self.show3D = self.Show3D_Use3D then
			totHeight := totHeight + 2;
		endif;
	endif;
	
	if totHeight &gt; pMaxHeight then
		totHeight := pMaxHeight;
	endif;
	
	self.height := totHeight;

end;</source>
        <Parameter name="pMaxHeight" type="Real"/>
    </JadeMethod>
    <JadeMethod name="fitTextToCell" id="7bc8e22a-dc49-4767-aba1-cc56bbf3f0e7">
        <source>fitTextToCell(pInputText: String; pOutputText: String output; pCellWidth: Integer; pCellHeight: Integer output);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 April 2025	navpw1	Initial creation JIRA MTN-34402

*/

constants
	NewLine = CrLf;
	Space = ' ';

vars
 	currentPos, tempPos, i, j : Integer;
 	tempString, line, tempLine, token : String;

begin
	// Copy input string, and strip out any new line characters and tabs
	tempString := pInputText;
 	tempString := tempString.replaceString(NewLine, Space);
 	tempString := tempString.replaceString(Tab, Space);
 	tempString := tempString.eliminateContiguousSpaces();

	// If the resulting string will fit in the cell, then return
	if self.getTextExtent(tempString) &lt; pCellWidth then
		pOutputText := tempString;
		return;
	endif;

	// Build up a multi-line string 
	currentPos := 1;
	pOutputText := null;
	line := null;
	while currentPos &lt;= tempString.length do
		// First get the next token, not including its trailing space
		tempPos := tempString.pos(Space, currentPos);
		if tempPos = 0 then
			tempPos := tempString.length + 1;
		endif;
		token := tempString[currentPos:tempPos - currentPos];

		// now check if the current line will still fit in the cell
		if line = null then
			tempLine := token;
		else
			tempLine := line &amp; Space &amp; token;
		endif;

		// if the line so far fits in the cell, then move currentPos past this token
		if self.getTextExtent(tempLine) &lt; pCellWidth then
			line := tempLine;
			currentPos := tempPos + 1;

    	else
    		// current token puts current line over boundary
			if line &lt;&gt; null then
				if pOutputText = null then
					pOutputText := line;
				else
					pOutputText := pOutputText &amp; NewLine &amp; line;
				endif;
				line := null;
			else
				// current token is too big to fit in a cell, so we need to break
				//  it up
  				line := token;

/* 				i := 1;
         		while i &lt; token.length do
         			j := i;
         			while j &lt;= token.length and self.getTextExtent(token[i:j - i + 1]) &lt; pCellWidth do
         				j := j + 1;
         			endwhile;
         			line := token[i:j - i];

					if j &lt; token.length then
						if pOutputText = null then
							pOutputText := line;
						else
							pOutputText := pOutputText &amp; NewLine &amp; line;
						endif;
						line := null;
					endif;

					i := j;
         		endwhile;
*/
				currentPos := tempPos + 1;
         	endif;
		endif;

  	endwhile;

	if line &lt;&gt; null then
		if pOutputText = null then
			pOutputText := line;
		else
			pOutputText := pOutputText &amp; NewLine &amp; line;
		endif;
	endif;

epilog	
	pCellHeight := self.getTextHeight(pOutputText) + 5;
	
end;</source>
        <Parameter name="pInputText" type="String"/>
        <Parameter name="pOutputText" type="String" usage="output"/>
        <Parameter name="pCellWidth" type="Integer"/>
        <Parameter name="pCellHeight" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCellByControlName" id="7aa955d5-7ea1-4ad3-9af8-40a1136f7078">
        <updating/>
        <source>getCellByControlName(pControlName: String): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 April 2025	navpw1	Initial creation JIRA MTN-34402

*/

vars
	idx		: Integer;
	maxRows		: Integer;
	obj			: Object;
	cell : JadeTableCell;
	
begin
	maxRows := self.columns;
	foreach idx in 1 to maxRows do
		cell := self.accessCell(2, idx);
		if cell.cellControl &lt;&gt; null and cell.cellControl.name = pControlName then
			return idx;
		endif;
	endforeach;
	
	return 0;
epilog

end;</source>
        <Parameter name="pControlName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isValidRow" id="da0455a8-5e58-404c-b8c2-a5aeec66fd68">
        <source>isValidRow(pRow : Integer) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 April 2025	navpw1	Initial creation JIRA MTN-34402

*/

vars

begin
	if pRow &gt;= 2 and pRow &lt;= self.rows then //Look at CM_EntryTable::topNonHeadingRow to set this correctly when we subclass this
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="optimiseHeightForRow" id="b7e5aa64-bbcf-40ae-8e75-25673897cdc9">
        <updating/>
        <source>optimiseHeightForRow(_cellInputType: Integer; _row: Integer; _inputText: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 April 2025	navpw1	Initial creation JIRA MTN-34402

*/

vars
	newRowHeight : Integer;
	
begin
	if _cellInputType &lt;&gt; InputType_None and
	   _cellInputType &lt;&gt; InputType_TextBox then
		return;
	endif;
	
	if _row &gt; self.rows then
		return;
	endif;
	
	if _inputText &lt;&gt; null then
		newRowHeight := (self.getTextHeight(_inputText) + 5);
		if self.defaultRowHeight &gt; newRowHeight then
			newRowHeight:=self.defaultRowHeight;
		endif;
	endif;

	if newRowHeight &lt;&gt; self.rowHeight[_row] then
		self.rowHeight[_row] := newRowHeight;
	endif;
	
end;</source>
        <Parameter name="_cellInputType" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_inputText" type="String"/>
    </JadeMethod>
    <JadeMethod name="optimiseValueRowHeight" id="2f1858bb-1c25-46d6-8715-ef8cdc42e78c">
        <updating/>
        <source>optimiseValueRowHeight(_row : Integer; _column : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
15 April 2025	navpw1	Initial creation JIRA MTN-34402

*/

vars
	numRows,
	numColumns : Integer;
	inputText, 
	outputText 	: String;
	cellInputType,
	newRowHeight, 
	cellWidth, 
	cellHeight 	: Integer;
	idx			: Integer;
	colWidthArray	: IntegerArray;

begin
	if self.columns &lt; 1 then
		return;
	endif;

	numRows := self.rows;

	cellWidth := self.clientWidth - self.columnWidth[1];
	
	newRowHeight := 0;				// self.rowHeight[r];

	cellInputType := self.accessCell(_row, _column).inputType;
	if cellInputType &lt;&gt; InputType_None and
	   cellInputType &lt;&gt; InputType_TextBox then
		return;
	endif;
	
	inputText := self.getCellText(_row, _column);
	if inputText &lt;&gt; null then
		self.fitTextToCell(inputText, outputText, cellWidth, cellHeight);
		if outputText &lt;&gt; inputText then
			self.setCellText(_row, 2, outputText);
		endif;
		newRowHeight := newRowHeight.max(cellHeight);
	endif;

	if newRowHeight &lt;&gt; self.rowHeight[_row] then
		self.rowHeight[_row] := newRowHeight;
	endif;
	
end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="optimiseValueRowHeights" id="8cfc749e-d5a3-419a-93d2-78b9896d70ca">
        <updating/>
        <source>optimiseValueRowHeights(_column : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 April 2025	navpw1	Initial creation JIRA MTN-34402

*/

vars
	numRows,
	numColumns,
	r	 		: Integer;
	inputText, 
	outputText 	: String;
	cellInputType,
	newRowHeight, 
	cellWidth, 
	cellHeight 	: Integer;
	idx			: Integer;
	colWidthArray	: IntegerArray;

begin
	if self.columns &lt; 1 then
		return;
	endif;

	numRows := self.rows;

	cellWidth := self.clientWidth - self.columnWidth[1];
	
	foreach r in 1 to numRows do
		newRowHeight := 0;				// self.rowHeight[r];

		cellInputType := self.accessCell(r, _column).inputType;
		if cellInputType &lt;&gt; InputType_None and
		   cellInputType &lt;&gt; InputType_TextBox then
			continue;
		endif;
				
		inputText := self.getCellText(r, _column);
		if inputText &lt;&gt; null then
			self.fitTextToCell(inputText, outputText, cellWidth, cellHeight);
			if outputText &lt;&gt; inputText then
				self.setCellText(r, 2, outputText);
			endif;
			newRowHeight := newRowHeight.max(cellHeight);
		endif;

 		if newRowHeight &lt;&gt; self.rowHeight[r] then
 			self.rowHeight[r] := newRowHeight;
 		endif;
 	endforeach;
	
end;</source>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setControl" id="d977e29c-6ef7-4fb0-be3f-4fdf5364d643">
        <updating/>
        <source>setControl(_row : Integer; _column : Integer; _control : Control input) updating;
/*

Purpose:			Sets the control on the table cell

Parameters:			_row		Integer	The row to add the control to
					_column		Integer	The column to add the control to
					_control	Control	The control to add to the cell

Return Value:		NONE

Date			Who		Reason
16 April 2025	navpw1	Initial creation JIRA: MTN-34402

*/

begin
	if not self.isValidRow(_row) then
		return;
	endif;
	
	self.accessCell(_row, _column).cellControl := _control;
	_control.parent := self;
	
end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_control" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="2cabdd71-e8aa-496d-bd94-17fbf09cf29e">
        <updating/>
        <source>setValue(pRow : Integer; pValue : Any; _column : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 April 2025	navpw1	Initial creation JIRA MTN-34402

*/

vars
	cell				: JadeTableCell;
	entRowInputType,
	cellInputType,
	numDecimals,
	startPos			: Integer;
	valueStr,
	noTabString			: String;
	entRowTrans			: EntTableRowTransient;
	obj					: Object;
	ctrl				: Control;
	
	row : JadeTableRow;
	
begin
	if self.isValidRow(pRow) then
		row := self.accessRow(pRow);
		
		cell := self.accessCell(pRow, _column);
		cellInputType	:= cell.inputType;
		
		if pValue.isKindOf(TimeStamp) and 
			   pValue.TimeStamp.isValid then
				cell.text := pValue.TimeStamp.shortCurrentLocaleFormat();	// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support  - TFS 2679:Multi-timezone issues
		else
			if cellInputType = Table.InputType_TextNumeric or 
			   cellInputType = Table.InputType_SignedNumeric
			then
				if pValue = null then
					valueStr := null;
				elseif pValue.isKindOf(String) and
					   pValue.String = null 
				then
					valueStr := null;
				else
					numDecimals := cell.decimals;
					if pValue.isKindOf(Real) then
						valueStr := pValue.Real.roundedTo(numDecimals).asStringJMT;
					elseif pValue.isKindOf(Decimal) then
						valueStr := pValue.Decimal.roundedTo(numDecimals).asStringJMT();
					elseif pValue.isKindOf(String) then						
						valueStr := pValue.String.asDecimalJMT.roundedTo(numDecimals).asStringJMT;	//asStringJMT();
					else
						valueStr := pValue.Decimal.roundedTo(numDecimals).asStringJMT;	//asStringJMT();
						// PAR 13701
						// Need to assume a decimal and roundedTo will return a
						// decimal of the precision indicated by numDecimals so
						// we get the correct trailing zeros.
						//valueStr := pValue.Real.roundedTo(numDecimals).String;
					endif;
				endif;
			
			elseif pValue = null then
				valueStr := null;					
				
			elseif pValue.isKindOf(Date) then
				valueStr := pValue.Date.shortFormatJMT();
			elseif pValue.isKindOf(Decimal) then
				valueStr := pValue.Decimal.asStringJMT();
			else
				valueStr := pValue.String;
			endif;
			
			if cell.text &lt;&gt; valueStr then 		
				//ctrl := cell.cellControl;
				//if ctrl &lt;&gt; null
				//and ComboBox.hasInstance(ctrl) or  TextBox.hasInstance(ctrl) and valueStr &lt;&gt; null then
					cell.text := valueStr;
					cell.alignment := Alignment_Left_Top;
					//if self.optimiseRowHeight then
						// PAR 9317 
						self.optimiseHeightForRow(cellInputType, pRow, valueStr);
					//endif;
				//endif;
			endif;
			
			if pValue = null then
				// we are clearing the values
				ctrl := cell.cellControl;
				if ctrl &lt;&gt; null
				and ctrl.name[1] &lt;&gt; '_' then // This is NOT one of our controls.
				   	// this is one of our controls
				   	if ComboBox.hasInstance(ctrl) then
				   		ctrl.ComboBox.listObject := null;
				   	elseif TextBox.hasInstance(ctrl) then
				   		ctrl.TextBox.text := null;
				   	endif;
				endif;
			endif;
		endif;
		
	else
		//if self.warningMethod &lt;&gt; null then
		//	self.form.sendMsgWithParams(self.warningMethod, self.name, method.name, 'Cannot set value for row (' &amp; pRow.String &amp; ') - invalid row');
		app.msgBox('Cannot set value for row (' &amp; pRow.String &amp; ') - invalid row', 'Invalid Row', MsgBox_OK_Only + MsgBox_Stop_Icon);
		//endif;
	endif;
epilog

end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pValue" type="Any"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
