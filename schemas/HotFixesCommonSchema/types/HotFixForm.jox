<GUIClass name="HotFixForm" id="5d0f6841-cbd1-46de-9082-ff8c235a5f28">
    <superclass name="HotfixCommonForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="btnStart" id="8e48573f-18ad-42d9-8fcf-baa57d89bece">
