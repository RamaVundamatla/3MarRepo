    <JadeMethod name="isSnapShotDataMatch" id="04d4cd3b-398e-4218-8184-99448e63f2ef">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
*/
vars
	obj		: Object;
	yaData	: CM_YAData;
begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	yaData := _criteria.myYAData;								//05.10.2022 navma1 #52967
	
	foreach obj in yaData.CM_YADataObjects.allObjects do
		if obj.CM_Product.description = _propertyValue then
			return true;
		endif;
		
		if obj.CM_Product.code = _propertyValue then			//29 May 2019	TFS 44902
			return true;
		endif;
	endforeach;
	
	if yaData.isKindOf(CM_YADataPattern) and					//05.10.2022 navma1 #52967
	   yaData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="501c8e28-4603-4e13-a095-db07ed64e7b9">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
/*

Purpose:			
	CCMS 1295 free storage days
Parameters:			

Return Value:		

Date		Who		Reason
05 Oct 2022  navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details

*/
vars
	product	: CM_Product;
	yaData	: CM_YAData;
begin

	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344
		product := _tiTrx.myTrackedItem.myProduct;			// product not kept on the generic transaction
	else
		product := _ti.myProduct;
	endif;
	
	yaData := _criteria.myYAData;								//05.10.2022 navma1 #52967
	
	// specific value - 31221 handle wild cards as well
	if yaData.CM_YADataObjects.matchesStorage(product) then		//05.10.2022 navma1 #52967
		return true;
	endif;
	
	// default value
	if yaData.isKindOf(CM_YADataPattern) and					//05.10.2022 navma1 #52967
	   yaData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
