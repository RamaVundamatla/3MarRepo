    <JadeMethod name="setMyTrackedItem" id="ec0aae7f-21e4-484f-939f-57668b8b884a">
        <updating/>
        <source>setMyTrackedItem(pTI: CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2024	jlier1	Initial creation 62513

*/

vars

begin
	inheritMethod(pTI, _tiTransCntrl);
	if pTI &lt;&gt; null then
		self.cargoTypeId:=pTI.cargoType;
		self.isoTypeGroup:=pTI.isoTypeGroup;
		self.trailerTypeCode:=pTI.getTrailerType;
	endif;

epilog

end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
