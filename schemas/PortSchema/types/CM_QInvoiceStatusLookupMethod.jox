    <JadeMethod name="setComboValues" id="8003917a-69b4-41ea-add2-5590496a3549">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
15 May 2014	cnwndl1	Par 34142	Initial creation	
03 Apr 2019	jlgka1 	43982		Fixed the bug that when selecting Invoice Status
								is it still shwoing a warning message stating 
								that the Business Unit is not selected eventhough
								there is Business Unit currently specified in the
								criteria line.
01/07/2019	jlgdap1	TFS 45423	SNO Selector with Invoice Status property
============================================================================*/

vars
	invStatus : CM_InvoiceStatus;
	crit : CM_SelectorCriteriaLine;
	bank : CM_Bank;
	invProcess : CM_InvoiceProcess;
begin
	_combo.clear;
	
	/* // TFS 39618 PATCH 1 
	_combo.addItem(app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_SUSPENSE)); //app.getErrorString(Suspense)); // TFS 39618
	_combo.addItem(app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_OPEN)); //getErrorString(Open_GC)); // TFS 39618
	_combo.addItem(app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_PENDING)); //getErrorString(Pending)); // TFS 39618
	_combo.addItem(app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_POSTED)); //getErrorString(Posted)); // TFS 39618
	_combo.addItem(app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_VOID)); //getErrorString(Void)); // TFS 39618

	NOW  // TFS 39618 PATCH 1 */
	
	invProcess := self.myInvoiceProcess;
	
	if invProcess = null then
		crit := _params.allCriteriaByPropertyName["bank", "CM_InvoiceLine"]; // jlgka1 TFS 43982
		// TFS 45423 Could be Invoice Line mode or Invoice mode					// TFS 45423
		if crit = null then														// TFS 45423
			crit := _params.allCriteriaByPropertyName["bank", "CM_Invoice"];	// TFS 45423
		endif;																	// TFS 45423
		if crit &lt;&gt; null then
			bank := crit.myQueryOperator.getSearchValue().CM_Bank;
		endif;
		
		if bank = null then
			app.msgBox("You must specify a business unit before you can select an invoice status", 'Warning', 0);		
			return;
		endif;
		
		if bank.myInvoiceProcess = null then
			app.msgBox("Your business unit must have an invoice process set, before you can select an invoice status", 'Warning', 0);		
			return;
		
		endif;
		invProcess := bank.myInvoiceProcess;
	endif;
	
	if invProcess &lt;&gt; null then
		foreach invStatus in invProcess.allStatuses	discreteLock do
			_combo.addItem (invStatus.description);
		endforeach;
	endif;
	
	
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.text := app.getInvoiceStatusString(self.myInvoiceProcess, _queryOperator.CM_QIntegerLookupEqual.searchValue); // TFS 39618
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := app.getInvoiceStatusString(self.myInvoiceProcess, _queryOperator.CM_QIntegerLookupNotEqual.searchValue); // TFS 39618
	endif;

epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="d14651eb-62df-4a56-927d-c8cf6b9d7bc3">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QIntegerIsOneOf; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

/****Changes

Date		Name	TFS#			Description
============================================================================
15/05/2014	cnwndl1	Par 34142		Initial creation	
04/04/2018	jlgdap1	TFS 37560 		PEL1 Prepend Invoice Status
26/09/2018	jlgka1	TFS 40200		Address the bug with regards to the	"is one of" option 
									where the Argument are always defaulted to selected.
31/10/2018  cnwma1  41703: 			PEL1 - Sap Integration - Post Billing Cancelled Invoice
03 Apr 2019	jlgka1 	43982			Fixed the bug that when selecting Invoice Status
									is it still shwoing a warning message stating 
									that the Business Unit is not selected eventhough
									there is Business Unit currently specified in the
									criteria line.
12/08/2019	jlgdap1	TFS 45922		JMT Bugs in Invoice Selector Query
============================================================================*/

vars
	//intArray	: IntegerArray;
	idx			: Integer;
	//int			: Integer;
	cmString	: CM_String;
	invStatus 	: CM_InvoiceStatus;
	crit 		: CM_SelectorCriteriaLine;
	bank 		: CM_Bank;
	invProcess 	: CM_InvoiceProcess;
begin
	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	/* // TFS 39618 PATCH 1 
	create intArray transient;
	
	intArray.add(CM_Invoice.INVOICE_SUSPENSE);
	intArray.add(CM_Invoice.INVOICE_OPEN);
	intArray.add(CM_Invoice.INVOICE_PENDING);
	intArray.add(CM_Invoice.INVOICE_POSTED);
	intArray.add(CM_Invoice.INVOICE_VOID);
	intArray.add(CM_Invoice.INVOICE_POSTED_CREDIT);	//04 Sep 2017	NDL	TFS 6759
	intArray.add(CM_Invoice.INVOICE_POSTED_REVERSE);	//04 Sep 2017	NDL	TFS 6759	
	intArray.add(CM_Invoice.INVOICE_PENDING_REVERSE); //31.10.2018 cnwma1 TFS #41703
	intArray.add(CM_Invoice.INVOICE_PREPEND);				// TFS 37560
	intArray.add(CM_Invoice.INVOICE_DISPUTED);				// TFS 37560
	
	foreach int in intArray do
		create cmString transient;
		cmString.string := app.getInvoiceStatusString(self.myInvoiceProcess, int); // TFS 39618
		
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(int) then
			idx := _tbl.addItem(1.String &amp; Tab &amp; cmString.string);
		else
			idx := _tbl.addItem(0.String &amp; Tab &amp; cmString.string);	
		endif;
		_tbl.accessRow(idx).itemObject := cmString;
		_tbl.row := idx;
		_tbl.change(_tbl);	
	endforeach;
	
	NOW // TFS 39618 PATCH 1 */
	
	invProcess := self.myInvoiceProcess;
	
	if invProcess = null then
		crit := _params.allCriteriaByPropertyName["bank", "CM_InvoiceLine"]; //jlgka1 TFS 43982
		if crit = null then															// TFS 45922
			crit := _params.allCriteriaByPropertyName["bank", "CM_Invoice"];		// TFS 45922
		endif;																		// TFS 45922
		if crit &lt;&gt; null then
			bank := crit.myQueryOperator.getSearchValue().CM_Bank;
		endif;
		
		if bank = null then
			app.msgBox("You must specify a business unit before you can select an invoice status", 'Warning', 0);		
			return;
		endif;
		
		if bank.myInvoiceProcess = null then
			app.msgBox("Your business unit must have an invoice process set, before you can select an invoice status", 'Warning', 0);		
			return;
		
		endif;
		invProcess := bank.myInvoiceProcess;
	endif;
	
	foreach invStatus in invProcess.allStatuses	discreteLock do
		create cmString transient;
		cmString.string := invStatus.description;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(invStatus.id) then
			idx := _tbl.addItem(1.String &amp; Tab &amp; cmString.string);
		else
			idx := _tbl.addItem(0.String &amp; Tab &amp; cmString.string);	
		endif;
		_tbl.accessRow(idx).itemObject := cmString;
		_tbl.row := idx;
		_tbl.change(_tbl);	
	endforeach;
	


epilog
//	delete intArray;
end;

</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="8b150117-be77-4e6a-9ac0-00724191f60b">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars
	str		: String;
	numRows,
	idx		: Integer;
	ia		: IntegerArray;

begin

	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			str := _tbl.accessCell(idx, 2).text;
			ia.add(self.translateToSearchValue(str).Integer);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="ddbab0b7-37a3-49a7-afb5-8e09e5f2b6b2">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine: CM_SelectorCriteriaLine): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2014	cnwndl1	Initial creation	Par 34142
04/04/2018	jlgdap1	TFS 37560 PEL1 Prepend Invoice Status
31/10/2018  cnwma1	ChangeRequest 41703: PEL1 - Sap Integration - Post Billing Cancelled Invoice
12/08/2019	jlgdap1	TFS 45922 JMT Bugs in Invoice Selector Query
*/

vars
	intStatus	: Integer;
	invStatus : CM_InvoiceStatus;
	crit : CM_SelectorCriteriaLine;
	bank : CM_Bank;
	invProcess : CM_InvoiceProcess;
	
begin
	if _value.String.isInteger then
		return _value;
	endif;
	
	if _value.String = app.getErrorString(CM_Any_Status) then
		intStatus := CM_Invoice.INVOICE_ALL_STATUS;
		
	/*	// TFS 39618 PATCH 1 
	elseif _value.String = app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_SUSPENSE) then //app.getErrorString(Suspense) then // TFS 39618
		intStatus := CM_Invoice.INVOICE_SUSPENSE;
	elseif _value.String = app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_OPEN) then //app.getErrorString(Open_GC) then // TFS 39618
		intStatus := CM_Invoice.INVOICE_OPEN;
	elseif _value.String = app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_PENDING) then //app.getErrorString(Pending) then // TFS 39618
		intStatus := CM_Invoice.INVOICE_PENDING;
	elseif _value.String = app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_POSTED) then //getErrorString(Posted) then // TFS 39618
		intStatus := CM_Invoice.INVOICE_POSTED;
	elseif _value.String = app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_VOID) then //getErrorString(Void) then // TFS 39618
		intStatus := CM_Invoice.INVOICE_VOID;
	elseif _value.String = app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_POSTED_REVERSE) then //getErrorString(Posted_returned) then	//04 Sep 2017	NDL	TFS 6759 // TFS 39618
		intStatus := CM_Invoice.INVOICE_POSTED_REVERSE;
	elseif _value.String = app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_POSTED_CREDIT) then //getErrorString(Posted_credit) then	//04 Sep 2017	NDL	TFS 6759 // TFS 39618
		intStatus := CM_Invoice.INVOICE_POSTED_CREDIT;
	elseif _value.String = app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_PREPEND) then //app.getErrorString(Prepend) then		// TFS 37560 // TFS 39618
		intStatus := CM_Invoice.INVOICE_PREPEND;				// TFS 37560
	elseif _value.String = app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_DISPUTED) then //app.getErrorString(Disputed) then	// TFS 37560 // TFS 39618
		intStatus := CM_Invoice.INVOICE_DISPUTED;				// TFS 37560
	elseif _value.String = app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_PENDING_REVERSE) then //app.getErrorString(Pending_returned) then	//31.10.2018 cnwma1 TFS #41703 // TFS 39618
		intStatus := CM_Invoice.INVOICE_PENDING_REVERSE;				//31.10.2018 cnwma1 TFS #41703
	NOW // TFS 39618 PATCH 1  */
	else
		if self.myInvoiceProcess &lt;&gt; null then										// TFS 45922
			foreach invStatus in self.myInvoiceProcess.allStatuses discreteLock do	// TFS 45922
				if _value.String = invStatus.description then						// TFS 45922
					intStatus := invStatus.id;										// TFS 45922
				endif;																// TFS 45922
			endforeach;																// TFS 45922
		else																		// TFS 45922
			// We do not and cannot get to a process, but all the status ids are unique for their meaning, 
			// even if some ('open') are in all processes the Id is always the same
			foreach invStatus in 	app.myRoot.allInvoiceStatuses	discreteLock do
				if _value.String = invStatus.description then
					intStatus := invStatus.id;
				endif;
			endforeach;
		endif;																		// TFS 45922
	endif;
	return intStatus;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="f02f7fdc-e1f8-4192-9da8-aa118a9b5ea1">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2014	cnwndl1	Initial creation
12/08/2019	jlgdap1	TFS 45922 JMT Bugs in Invoice Selector Query
*/

vars
	invStatus : CM_InvoiceStatus;

begin
	if _value.String.isInteger then
		// TFS 39618 PATCH 1  return app.getInvoiceStatusString(self.myInvoiceProcess, _value.Integer); // TFS 39618
		// TFS 39618 PATCH 1 
		if self.myInvoiceProcess &lt;&gt; null then											// TFS 45922
			foreach invStatus in self.myInvoiceProcess.allStatuses discreteLock do		// TFS 45922
				if _value.Integer = invStatus.id then									// TFS 45922
					return invStatus.description;										// TFS 45922
				endif;																	// TFS 45922
			endforeach;																	// TFS 45922
		else																			// TFS 45922
			foreach invStatus in 	app.myRoot.allInvoiceStatuses	discreteLock do
				if _value.Integer = invStatus.id then
					return invStatus.description;
				endif;
			endforeach;
		endif;																			// TFS 45922
	endif;
	
	return _value.String;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="5f255c1f-186f-4f62-abab-3882da47c1fd">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation

*/

vars

begin
	if _value.isKindOf(IntegerArray) then
		return _value;
	elseif _value.isKindOf(Integer) then	
		return _value.String;
	endif;
	
	return translateStringToSearchValue( _value.String, null).Integer;
	
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
