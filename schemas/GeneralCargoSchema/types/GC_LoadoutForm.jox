    <JadeMethod name="cmbItemDetail_click" id="51ddeed4-2190-40a1-9927-6edc18561225">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbItemDetail_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tbl				: CM_DataTable;
	tmpCmbProd		: CMUI_ComboProduct;
	tmpCmbItem 		: CMUI_ComboGeneralCargoTIs;
	theRow 			: Integer;
	tmpCell 		: JadeTableCell;
	beforeTxt		: String;
	tmpCargoType	: CM_CargoType;
	tmpTI			: CM_TrackedItem;
begin
/////*************** NOT using this one at moment *****************************************



	tbl	:= self.tblDataDetail;
	theRow  := tbl.row;
	
	//find out what table text is to see if combo has changed.  
	tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_Id));
	beforeTxt := tmpCell.text;

	if combobox.text &lt;&gt; beforeTxt then 
		// this may be called alot but if left to lost focus method can get funny values 
		// in table when more than one row and changing rows. 
		
//		not much to do in here. except check product combo has been populated 
		
		tmpTI := combobox.listObject.CM_TrackedItem;
		self.myCurrentDetailObject.CMIF_BOLOutLine.myTrackedItem := tmpTI;
		
		
		if tmpTI &lt;&gt; null then 
			// populate product combo
			tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_Product));
			tmpCmbProd := tmpCell.cellControl.CMUI_ComboProduct;
			if tmpCmbProd.listObject &lt;&gt; tmpTI.myProduct then 
				tmpCmbProd.clear(); 
				tmpCmbProd.setCargoType(tmpTI.myCargoType);
				tmpCmbProd.setObject(tmpTI.myProduct);
			endif; 
			
//			tmpCmbProd.clear(); // cargo type has changes so what if anything in hear it is bunk.
//			tmpCmbProd.setCargoType(tmpCargoType);
			
			// also populate Items combo with all avail items of this cargo
//			tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_Id));
//			tmpCmbItem := tmpCell.cellControl.CMUI_ComboGeneralCargoTIs;
//			tmpCmbItem.clear(); // cargo type has changes so what if anything in hear it is bunk.
//			tmpCmbItem.myCargoType := tmpCargoType;
		endif;
		//update proxy object in table 
		self.zDoTblDetailDataRowColChg(self.tblDataDetail);
		self.myCurrentDetailObject.CMIF_BOLOutLine.myCargoType := tmpCargoType;
	endif;
	// of text hasnt changed then dont need to do anything. 
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
