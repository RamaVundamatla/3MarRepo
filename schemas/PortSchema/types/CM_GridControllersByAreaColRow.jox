<CollClass name="CM_GridControllersByAreaColRow" id="062c3072-1a12-46aa-9717-3669e2b156db">
    <loadFactor>66</loadFactor>
    <memberType name="CM_GridController"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <MemberKey>
        <property name="CM_LocationsController::myTerminalArea"/>
    </MemberKey>
    <MemberKey>
        <keyPath>
            <ExplicitInverseRef name="CM_GridController::myGridColumn"/>
        </keyPath>
        <property name="CM_GridColumn::column"/>
    </MemberKey>
    <MemberKey>
        <keyPath>
            <ExplicitInverseRef name="CM_GridController::myGridRow"/>
        </keyPath>
        <property name="CM_GridRow::row"/>
    </MemberKey>
    <JadeMethod name="removeMatching" id="c4a2ca56-f092-43a9-b540-48ebd6dd20b1">
        <lockReceiver/>
        <updating/>
        <source>removeMatching( ta : CM_TerminalArea; _minRow, _maxRow, _minColumn, _maxColumn : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2018	jlgndl1	Initial creation	TFS 36566

*/

vars

	localSet : CM_GridControllersByAreaColRow;
	obj : CM_GridController;

begin

	create localSet transient;
	
	foreach obj in self where ta = obj.myTerminalArea do
		if obj.row &lt; _minRow then
			continue;
		endif;
		if obj.row &gt; _maxRow then
			continue;
		endif;
		if obj.column &lt; _minColumn then
			continue;
		endif;
		if obj.column &gt; _maxColumn then
			continue;
		endif;
		localSet.add( obj );
	endforeach;
	
	if not localSet.isEmpty then
		foreach obj in localSet do
			self.remove( obj );
		endforeach;
	endif;

epilog

	delete localSet;

end;</source>
        <Parameter name="ta" type="CM_TerminalArea"/>
        <Parameter name="_minRow" type="Integer"/>
        <Parameter name="_maxRow" type="Integer"/>
        <Parameter name="_minColumn" type="Integer"/>
        <Parameter name="_maxColumn" type="Integer"/>
    </JadeMethod>
</CollClass>
