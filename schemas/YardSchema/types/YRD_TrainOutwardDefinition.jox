    <JadeMethod name="validateDetails" id="bedbe140-da53-4863-a53e-e6568bc342cd">
        <source>validateDetails( _wagonSequence : CM_WagonArray io ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwndl1	Initial creation

*/

vars

	pos : Integer;
	grpRake : CMUI_GroupBox;
	txtRakeLeft : CMUI_TextBox;
	txtRakeRight : CMUI_TextBox;
	dummyTextBox : CMUI_TextBox;
	lblRake : CMUI_Label;
	rakeWagons : ObjectArray;
	lastValidPos : Integer;
	intArray : IntegerArray;
	value : Integer;
	rakesArray : ObjectArray;
	localRakeArray : ObjectArray;
	obj : Object;
	wagon : CM_Wagon;
	
begin

	_wagonSequence.clear();

	create intArray transient;
	create rakesArray transient;
	
	foreach pos in 1 to self.cloneSize do
		self.getControlsForPosition(pos, grpRake, lblRake, txtRakeLeft, txtRakeRight, dummyTextBox, rakeWagons);
		
		if txtRakeLeft.text.Integer = 0 and txtRakeRight.text.Integer = 0 then
			app.msgBox(app.getErrorString1(Selection_value_required, lblRake.caption),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Information_Icon);
			return false;
		endif;
		create localRakeArray transient;
		rakesArray.add(localRakeArray);
		if txtRakeLeft.text.Integer &gt; 0 then
			intArray.add(txtRakeLeft.text.Integer);
			rakeWagons.copy(localRakeArray);
		elseif txtRakeRight.text.Integer &gt; 0 then
			intArray.add(txtRakeRight.text.Integer);
			foreach obj in rakeWagons reversed do
				wagon := obj.CM_Wagon;
				localRakeArray.add(wagon);
			endforeach;
		endif;
		lastValidPos := pos;
	endforeach;
	
	if intArray.size &lt;&gt; lastValidPos or rakesArray.size &lt;&gt; lastValidPos then
		app.msgBox(app.getErrorString(Array_size_error),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	
	foreach obj in self.noRakeWagons do
		if not CM_Wagon.hasInstance(obj) then
			continue;
		endif;
		wagon := obj.CM_Wagon;
		_wagonSequence.add(wagon);
	endforeach;
	
	foreach value in 1 to lastValidPos do
		if not intArray.includes( value )then
			app.msgBox(app.getErrorString1(Values_must_sequence,value.String),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Information_Icon);
			return false;
		endif;
		pos := intArray.indexOf(value);
		rakeWagons := rakesArray[pos].ObjectArray;
		foreach obj in rakeWagons do
			wagon := obj.CM_Wagon;
			_wagonSequence.add(wagon);
		endforeach;

	endforeach;

	return true;
	
epilog
	delete intArray;
	if rakesArray &lt;&gt; null then
		rakesArray.purge();
		delete rakesArray;
	endif;
	
end;</source>
        <Parameter name="_wagonSequence" type="CM_WagonArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
