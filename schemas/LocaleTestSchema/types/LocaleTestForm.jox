    <JadeMethod name="btnGo_click" id="396a52ee-eb33-439b-9585-6e2d8a42a558">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnGo_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		05 August 2010 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doPopulateData();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPopulateData" id="a2f0bbd4-b2ff-4438-a593-ba2ec1a32c7e">
        <source>doPopulateData() protected;
// --------------------------------------------------------------------------------
// Created:		05 August 2010 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cTimestamp	: TimeStamp;
	currencyVal	: Decimal[16,2];
	decimalVal	: Decimal[16,4];
	
begin
	cTimestamp	:=	app.actualTimeServer();
	currencyVal	:=	1234.25;
	decimalVal	:=	1234.4321;
	
	// Current method of populating controls.
	
	txtDate.text		:=	cTimestamp.date().asStringJMT();
	txtTime.text		:=	cTimestamp.time().asStringJMT();
	txtCurrency.text	:=	currencyVal.asStringJMT();
	txtDecimal.text		:=	decimalVal.asStringJMTWithPrecision(app.currentLocaleInfo.numericInfo.decimalPlaces, false);
	
	// Alternative method of populating controls.
	// This works, but can it work when populating tables ?
	// JMT makes extensive use of Table controls for data entry.
	
//	txtDate.setTextFromDate(cTimestamp.date());
//	txtTime.setTextFromTime(cTimestamp.time());
//	txtCurrency.setTextFromDecimal(currencyVal);
//	txtDecimal.setTextFromDecimal(decimalVal);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPopulateListbox" id="245abe39-bbce-4fd9-af75-2d343ec6f3c4">
        <source>doPopulateListbox(pAllLocales:ObjectArray; pListbox:ListBox input) protected;
// --------------------------------------------------------------------------------
// Created:		05 August 2010 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	object		: Object;
	localeObj	: Locale;
	displayStr	: String;
	
begin
	pListbox.clear();
	
	foreach object in pAllLocales do
		if object.isKindOf(Locale) then
			localeObj	:=	object.Locale;
		
			displayStr	:=	localeObj.makeLocaleName;
			
			if localeObj.isClone() then
				displayStr	:=	displayStr &amp; " (Close of " &amp; localeObj.getPropertyValue(Locale::cloneOf.name).Locale.makeLocaleName() &amp; ")";
			endif;
			
		elseif object.isKindOf(LocaleNameInfo) then
			displayStr	:=	object.LocaleNameInfo.localizedLangName;
		endif;
		
		pListbox.addItem(displayStr);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pAllLocales" type="ObjectArray"/>
        <Parameter name="pListbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="24e2e5c1-8631-4e72-8ee5-49db8f4ece95">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		05 August 2010 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	localeObj		: Locale;
	cloneObj		: Locale;
	fullInfoObj		: LocaleFullInfo;
	dateInfo		: DateFormat;
	timeInfo		: TimeFormat;
	currencyInfo	: CurrencyFormat;
	numberInfo		: NumberFormat;
	allLocales		: ObjectArray;
	
begin
	// Get locale info objects.
	
	localeObj		:=	app.currentLocale;
	
	if localeObj.isClone() &lt;&gt; null then
		cloneObj	:=	localeObj.getPropertyValue(Locale::cloneOf.name).Locale;
	endif;
	
	fullInfoObj		:=	app.currentLocaleInfo;
	dateInfo		:=	fullInfoObj.dateInfo;
	timeInfo		:=	fullInfoObj.timeInfo;
	currencyInfo	:=	fullInfoObj.currencyInfo;
	numberInfo		:=	fullInfoObj.numericInfo;
	
	// Set up the controls.
	
	lblLocaleName.caption	:=	localeObj.makeLocaleName();
	
	if cloneObj = null then
		lblClone.caption	:=	"(Not a clone)";
	else
		lblClone.caption	:=	"(Clone of " &amp; cloneObj.makeLocaleName() &amp; ")";
	endif;
	
	txtDate.mask			:=	dateInfo.shortFormat;
	write class.name &amp; "::" &amp; method.name &amp; " line 50 - THIS DOESN'T WORK ==&gt; txtDate.mask := dateInfo.shortFormat;";
	txtDate.mask			:=	"dd/MM/yyyy";
	
	txtTime.mask			:=	timeInfo.format.toLower();		// Only supports 24-hour time ?
	write class.name &amp; "::" &amp; method.name &amp; " line 54 - THIS DOESN'T WORK ==&gt; txtTime.mask := timeInfo.format.toLower();";
	txtTime.mask			:=	"hh:mm";
	
	txtCurrency.dataType	:=	TextBox.DataType_Numeric;
	txtCurrency.decimals	:=	currencyInfo.decimalPlaces;
	txtDecimal.dataType		:=	TextBox.DataType_Numeric;
	txtDecimal.decimals		:=	numberInfo.decimalPlaces;
	
	// Populate the data.
	
	self.doPopulateData();
	
	create allLocales transient;
	
	currentSchema.getAllBaseLocales(allLocales);
	self.doPopulateListbox(allLocales, lstBase);
	
	allLocales.clear();
	currentSchema.getAllInheritedLocales(allLocales);
	self.doPopulateListbox(allLocales, lstInherited);
	
	allLocales.clear();
	currentSchema.getAllLocales(allLocales);
	self.doPopulateListbox(allLocales, lstAllLocales);
	
	allLocales.clear();
	currentSchema.getAllLocalLocales(allLocales);
	self.doPopulateListbox(allLocales, lstLocal);
	
	allLocales.clear();
	currentSchema.getAllSystemLocales(allLocales);
	self.doPopulateListbox(allLocales, lstSystem);
	
	allLocales.clear();
	currentSchema.getBaseLocalesLocal(allLocales);
	self.doPopulateListbox(allLocales, lstBaseLocal);
	
	// All done.
	
	self.centreWindow();
epilog
	delete allLocales;
end;</source>
    </JadeMethod>
</GUIClass>
