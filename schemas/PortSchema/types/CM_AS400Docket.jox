    <JadeMethod name="setForCreate" id="1f8b0d34-6d25-4176-b75c-208815201d9b">
        <updating/>
        <source>setForCreate(_array : HugeStringArray; _fileLoad : CM_AS400FileLoad) updating;
// ---------------------------------------------------------------------------
// Created:     27 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	delimited	: String;
	array		: HugeStringArray;
	theSpecies,
	theGrade,
	theType		: String;

begin

	self.myAS400FileLoad	:= _fileLoad;
	self.status 			:= _array[1].trimBlanks;
	self.supplier 			:= _array[2].trimBlanks;
	self.docket 			:= _array[3].trimBlanks;
	self.dateIn 			:= _array[4].trimBlanks;
	self.timeIn 			:= _array[5].trimBlanks;
	self.timeOut 			:= _array[6].trimBlanks;
	self.recType 			:= _array[7].trimBlanks;
//	self.species 			:= _array[8].trimBlanks;
//	self.grade 				:= _array[9].trimBlanks;
//	self.type 				:= _array[10].trimBlanks;
	self.length 			:= _array[11].Decimal;
	self.volumeType 		:= _array[12].trimBlanks;
	self.totalItems 		:= _array[13].Integer;
	self.fellDate 			:= _array[14].trimBlanks;
	self.carrier 			:= _array[15].trimBlanks;
	self.truck 				:= _array[16].trimBlanks;
	self.trailer 			:= _array[17].trimBlanks;
	self.logPrefix 			:= _array[18].trimBlanks;
	self.grossWeight 		:= _array[19].Decimal;
	self.netWeight 			:= _array[20].Decimal;
	self.tareWeight 		:= _array[21].Decimal;
	self.logOrg 			:= _array[22].trimBlanks;
	self.logContractor 		:= _array[23].trimBlanks;
	self.logGang			:= _array[24].trimBlanks;
	self.logOperation 		:= _array[25].trimBlanks;
	self.loadOperation 		:= _array[26].trimBlanks;
	self.loadOrg 			:= _array[27].trimBlanks;
	self.loadContractor 	:= _array[28].trimBlanks;
	self.loadLoader 		:= _array[29].trimBlanks;
	self.loadDriver 		:= _array[30].trimBlanks;
	self.forest 			:= _array[31].trimBlanks;
	self.compartment 		:= _array[32].trimBlanks;
	self.skid 				:= _array[33].trimBlanks;
	self.buyer 				:= _array[34];
	self.scaler 			:= _array[35].trimBlanks;
	self.tripNo 			:= _array[36].trimBlanks;
	self.stand 				:= _array[37].trimBlanks;
	self.comments 			:= _array[38];
	self.pieces 			:= _array[39].Integer;
	self.volume 			:= _array[40].Decimal;
	self.averageVolume 		:= _array[41].Decimal;
	self.samplePieces 		:= _array[42].Integer;
	self.sampleVolume 		:= _array[43].Decimal;
	
	// Do specific species grade stuff.
	theSpecies 				:= _array[8].trimBlanks;
	theGrade				:= _array[9].trimBlanks;
	theType 				:= _array[10].trimBlanks;
	self.processExtra(theSpecies, theGrade, theType);
	
end;</source>
        <Parameter name="_array" type="HugeStringArray"/>
        <Parameter name="_fileLoad" type="CM_AS400FileLoad"/>
    </JadeMethod>
