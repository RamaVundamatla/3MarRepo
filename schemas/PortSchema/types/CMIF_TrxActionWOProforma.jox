<Class name="CMIF_TrxActionWOProforma" id="f7d91be5-5e0a-4e5b-9b84-bfa241bcd2b2">
    <superclass name="CMIF_TrxPostAction"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myWorkOrder" id="e730c8c4-ff7d-45c4-ba76-d6cf8624397a">
        <embedded/>
        <type name="CM_WorkOrder"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="action" id="550325d9-c906-4c8d-90d1-e23ed252fe6a">
        <updating/>
        <source>action(_passport : CM_Passport	 ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2018	jlger1	Initial creation  tfs 39166

*/

vars
	controller : CMIF_ProformaWOController;
	invalidWO : Boolean;
	workOrderId : String;
	passport  : CM_Passport;
	proxyBGPRequest : BGP_SAPWSRequest;
begin
	if self.myWorkOrder = null then
		return;
	endif;
	on Exception do app.handleDeletedObject(exception,self.myWorkOrder,invalidWO);
	workOrderId:=self.myWorkOrder.id;
	
	if invalidWO then
		return;
	endif;
	create controller transient;
	controller.initialise(self.myWorkOrder);
	
	//epr TFS 43260 8/2/19 
	if self.myWorkOrder.isWorkOrderForIMSR then
		controller.createSAPRequest:=true;
		if  self.trxMode &lt;&gt; CM_TrxControlAgent.Trx_Create then
			//check if we need to create a SAP Cancel Request 
			if self.myWorkOrder.canCancelSAPEstimate then
				//create sap cancel request 
				self.myWorkOrder.processSAPRequest(true);
				return;
			endif;
		endif;
	endif;
	
	passport:=_passport;
	passport.setWarningsIgnored( true);
	passport.setWarningsAcknowledged( true);
	app.myTrxCA.trxCreateProformaPaymentWO(controller,"",  passport);

	//the abort trx in above transaction if it is successfull in doing the proforma leaves status as incomplete because no longer in trx state
	// 26 Jul 2018	NDL	TFS 39948 - If the Pro Forma stuff fails we don't care, and not just on the web
	
	passport.clearErrorsWarnings;
	passport.initialiseTransaction;
	passport.finaliseTransaction(TRXStatus_Committed);
	
epilog

	if controller&lt;&gt; null then
		controller.purger();	//Otherwise we get left with a transient leak;
		delete controller;
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setMyWorkOrder" id="a4efcefb-3ed9-487a-b282-7f9c9f3904bc">
        <updating/>
        <source>setMyWorkOrder(_workOrder : CM_WorkOrder;
				_trxMode : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2018	jlger1	Initial creation

*/

vars

begin
	self.myWorkOrder:=_workOrder;
	self.trxMode:= _trxMode; //epr TFS 43260 5/2/19
epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
        <Parameter name="_trxMode" type="Integer"/>
    </JadeMethod>
</Class>
