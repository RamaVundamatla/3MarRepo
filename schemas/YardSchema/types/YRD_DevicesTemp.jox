    <JadeMethod name="lbHandHelds_mouseUp" id="c5617faa-b0bc-4991-a9b0-1772a0dbd922">
        <controlMethod name="ListBox::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lbHandHelds_mouseUp(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//----------------------------------------------
//Created: 3 October 2001 By: cnwgd1
//----------------------------------------------
vars

begin
	if button = 2 then
		popupMenu(mnuView, (lbHandHelds.left + x).Integer, (lbHandHelds.top + y).Integer);
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="load" id="ded48f6e-1cd3-4d2c-b996-1321d84625b2">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
//----------------------------------------------
//Created: 3 October 2001 By: cnwgd1
//----------------------------------------------
vars

begin

	inheritMethod();
	app.niceName := "Radio Telemetry Hand Held Devices";
 	beginClassNotification(CM_RadioTelemetryDevice, false, EVENT_RT_SESSION_CHANGE , Response_Continuous, 0);
	beginClassNotification(CM_RadioTelemetryDevice, false, Object_Create_Event, Response_Continuous, 0);
 	beginClassNotification(CM_RadioTelemetryDevice, false, Object_Delete_Event, Response_Continuous, 0);
	self.centreWindow;
	self.setEnableObjects();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mnuResetLockH_click" id="a7625133-c313-4e4e-a496-85bb80feb646">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuResetLockH_click(menuItem: MenuItem input) updating;
//----------------------------------------------
//Created:  3 October 2001 By: cnwgd1
//----------------------------------------------
vars

begin

	if self.sessions = null then
		app.msgBox("There are no In Session devices to reset.", "No Sessions Running!", MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	if self.myCurrentDevice = null or
		self.myCurrentDevice.status = DEVICE_STATUS_DISCONN or
		self.myCurrentDevice.status = DEVICE_STATUS_UNKNOWN then
		app.msgBox("You must select an In Session device before you can Reset LockH.", "Select Device", MsgBox_Stop_Icon + MsgBox_OK_Only);
	elseif
		self.myCurrentDevice.status = DEVICE_STATUS_INSESSION then
		self.myCurrentDevice.resetDeviceLockH();
	endif;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sessions" id="326d51c6-5569-4718-a9b5-44cfb9839ec2">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>sessions(set: Boolean; _value: Integer io) mapping, updating;
//--------------------------------------------------------------
//Created: 3 October 2001 By: cnwgd1
//--------------------------------------------------------------
vars
	rt		: CM_RadioTelemetry;
	rtd 	: CM_RadioTelemetryDevice;
	
begin
	if set then
		return;
	endif;
	
	rt := self.myTerminal.radioTelemetry;
	
	foreach rtd in rt.allRTDevices discreteLock do
		if rtd.isKindOf(CM_RTDeviceHandHeld) then
			if rtd.status = DEVICE_STATUS_INSESSION then
				_value := _value + 1;
			endif;				
		endif;
	endforeach;
	
	return;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="01776ba1-00fb-4a3f-9f88-9352a072faf6">
        <updating/>
        <source>setEnableObjects() updating, protected;
//----------------------------------------------
//Created: 3 October 2001  By: cnwgd1
//----------------------------------------------
vars
	coll	: CM_RTDeviceArray;
	hh	 	: CM_RTDeviceHandHeld;
	rt		: CM_RadioTelemetry;
	rtd 	: CM_RadioTelemetryDevice;
begin
	
	self.myCurrentDevice := null;
	self.mnuView.visible := false;
	rt := self.myTerminal.radioTelemetry;
	
	self.allRTDevices.clear();
		
	foreach rtd in rt.allRTDevices discreteLock do
		if rtd.isKindOf(CM_RTDeviceHandHeld) then
			self.allRTDevices.add(rtd);
		endif;
	endforeach;
	
	self.lbHandHelds.listCollection(self.allRTDevices, false, 0);

		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="e030990e-3c73-4a20-894b-3f9d5d6397b0">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------------------
//Created: November 2001 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.setEnableObjects();
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="62f75104-4aa5-44b8-9d72-cc19e7565ef0">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017721, locale);
	mnuResetLockH.translateCaption(Xlat_0008407, locale);
	mnuView.translateCaption(Xlat_0008408, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="231faacf-c60b-4b5e-870b-2941c7242ea7">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
//--------------------------------------------------------------
//Created: November 2001 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	endNotificationForSubscriber(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="a9551613-3183-4a31-a01c-a8c46bffb959">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//----------------------------------------------
//Created: 3 October 2001  By: cnwgd1
//----------------------------------------------
//Expected eventType: EVENT_RT_SESSION_CHANGE.
vars

begin

	if eventType = EVENT_RT_SESSION_CHANGE then
	 	self.setEnableObjects();
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
