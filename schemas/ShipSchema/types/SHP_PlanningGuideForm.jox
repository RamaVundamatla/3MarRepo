    <JadeMethod name="userNotificationUpdate" id="5ec57d6b-1ec7-481e-a96f-9bace2162815">
        <updating/>
        <source>userNotificationUpdate(_event: Integer; _noteobj : CM_Object; _obj: CM_Object) updating;
//--------------------------------------------------------------
//Created: 09 May 2003 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
08 Jun 2010	cnwkpd1	PAR #21995 - Performance changes - allow multiple slot updates in the same bay
					to accumulate before refreshing bay

*/

vars
	theGuide : CMIF_PlanningGuideBay;
	theVoyage : CM_Voyage;
	theBay : CM_BayVoyage;
	aSlot : CM_SlotController;
	idx : Integer;
	
begin
	if _event = EVENT_UPDATE_VOYAGE_AREA then
		if _obj.isKindOf(CM_SlotController) then
			aSlot := _obj.CM_SlotController;
			if aSlot.myVoyage = self.myCurrentVoyage then

				theBay := aSlot.myBayVoyage;
				
				if theBay &lt;&gt; null then
					if not self.allBaysToUpdate.includes(theBay) then
						self.allBaysToUpdate.add(theBay);
					endif;
					self.doStartBayRefreshTimer();
				endif;

/*	Old code moved to doProcessBayRefreshTimer
				
				self.tblData.findObjectInColumn(theBay,idx);
				if idx &gt; self.tblData.fixedColumns then

					create theGuide transient;
					self.doQueryUpdateBayColumn(theBay,theGuide,idx);

					//### AKB2005JUNE
					if theBay.canHandle4045() 
					and theBay.idBay40.trimBlanks &lt;&gt; null then
						theGuide.id := theBay.idBay40.trimBlanks;
						theGuide.is40Bay := true;
						self.myCurrentVoyage.myCellularVoyageStructure.getPlanningGuideForBay(theGuide);
						theGuide.id := "[" &amp; theBay.idBay40.trimBlanks &amp; "]";
						self.doQueryDisplayBay(theGuide,idx + 1);
					endif;
					//###	

					self.doQueryUpdateTotals();
				endif;
*/				
			endif;
		endif;
	elseif _event = RORODeckRemarks_Event then
		if CM_DeckVoyage.hasInstance(_obj) then
			foreach idx in 2 to self.tblData.columns do
				if self.tblData.accessColumn(idx).itemObject = _obj then
					//if _obj.CM_DeckVoyage.remarks &lt;&gt; null then
						self.tblData.accessCell(self.Row_Remarks,idx).text := "Yes";
					//else
					//	self.tblData.accessCell(self.Row_Remarks,idx).text := "";
					//endif;
					break;
				endif;
			endforeach;
		endif;
	elseif _event = BayRemarks_Event then
		if CM_BayVoyage.hasInstance(_obj) then
			foreach idx in 2 to self.tblData.columns do
				if self.tblData.accessColumn(idx).itemObject = _obj then
					self.tblData.accessCell(self.Row_Remarks,idx).text := "Yes";
					break;
				endif;
			endforeach;
		endif;
	else
		if _obj.String = self.myCurrentVoyage.String then
			if _event = Voyage_Delete_Event then
				self.myCurrentVoyage := null;
				self.doCmbVoyageBuild();
				self.doComboVoyageClick();
				
			elseif _event = Voyage_Update_Event then
				self.doQuery();
			endif;
		endif;
	endif;
epilog
	delete theGuide;
end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_noteobj" type="CM_Object"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
</GUIClass>
