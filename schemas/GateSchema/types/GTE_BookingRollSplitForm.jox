    </JadeMethod>
    <JadeMethod name="cmbVoyage_click" id="50502b9c-02fb-463a-bcc4-6f0fab9d1908">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_click(combobox: ComboBox input) updating;

vars
	port	: CM_Port;
	index	: Integer;
begin	
	if cmbVoyage.listObject &lt;&gt; null then
		cmbDischargePort.listCollection(cmbVoyage.listObject.CM_Voyage.allPorts, false, 0);
		if isSplit then
			cmbBooking.listCollection(cmbVoyage.listObject.CM_Voyage.allBookingRefs, false, 0);
		else // is Roll
			if myBookingRef &lt;&gt; null then
				port	:= app.myRoot.allPorts[myBookingRef.dischargePort];
				if port &lt;&gt; null then
					index	:= cmbDischargePort.findObject(port);
					if index &lt;&gt; -1 then
						cmbDischargePort.listIndex	:= index;
						cmbDischargePort.enabled	:= false;
					else
						cmbDischargePort.enabled	:= true;
					endif;
				endif;
			endif;
		endif;
	else
		cmbBooking.clear;
		cmbDischargePort.clear;
	endif;
end;
</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbVoyage_displayEntry" id="2c8e8731-fcf3-4fcf-b8ab-6a8742b451f1">
        <controlMethod name="CMUI_ComboVoyage::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_displayEntry(combobox: ComboBox input; _voyageObj: CM_Voyage; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 December 2008	cnwer1	Initial creation

*/

vars

begin

	if _voyageObj = null then
		return null;
	endif;
	
	if self.myBookingRef &lt;&gt; null and  _voyageObj = self.myBookingRef.myVoyage then
		return null;
	endif;
	
	return _voyageObj.getId();
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_voyageObj" type="CM_Voyage"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="aa6994ca-d0c8-4e05-a856-196eab23bb52">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// 09/03/2010	cnwcs5	par 22605
vars

begin
	self.permissionView  := PmGteBookingRefView;	// par 22605
	self.permissionMaint := PmGteBookingRefMaint;	// par 22605

//	self.permissionView  := PmGteBookingRefRollSplit;	// par 22605
//	self.permissionMaint := PmGteBookingRefRollSplit;	// par 22605
end;
</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="f02da0b0-2569-4551-bc98-ef559c83d6a0">
        <updating/>
        <source>doSave() :Boolean updating;
// 10 May 2018 	jlgrh7 TFS38548  MSL - Roll Booking not works for on board tranship containers
// 18 Nov 2019  jlger1 TFS 47457 - Refactor so roll set tis in trx 
vars
	newBooking, 
	bookingRef		: CM_BookingRef;
	voyage			: CM_Voyage;
	tis				: CM_TISet;
	result			: Integer;
	heading,
	dischargePortCode	: String;
	bookingRefSet	: CM_BookingRefSet;
	remarks			: String;
	
begin

	create bookingRefSet transient;
	
	if self.isBookingBulkRollMode then	

		voyage	:= cmbVoyage.listObject.CM_Voyage;

		foreach bookingRef in self.allBookingRefs do
			if voyage &lt;&gt; null then // check that voyage is different
				if bookingRef.myVoyage = voyage then
					app.raiseCMException2(ERR_BooRollSameVoy, bookingRef.bookingReference, voyage.code, null, null);	//+cnwml2 PAR19817
					return false;
				endif;
			endif;
			bookingRefSet.add(bookingRef);
		endforeach;

	else	//// when not bul roll edit - should use self.myBookingRef and the tis set
	
		if self.myBookingRef = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "BookingRef not found.");
			return false;
		endif;
		
		create tis transient;
		if self.isSplit then
			tblContainers.allSelectedObjects.copy(tis);
		endif;

		bookingRefSet.add(self.myBookingRef);
	
	endif;
		
	if cmbDischargePort.listObject &lt;&gt; null then
		dischargePortCode	:= cmbDischargePort.listObject.CM_Port.code;
	endif;
	
	remarks := self.txtRemarks.text;
		
	while true do
		if isSplit then
			newBooking	:= cmbBooking.listObject.CM_BookingRef;
			if newBooking &lt;&gt; null then												//+cnwml2 PAR19817
				app.myTrxUA.trxSplitBooking(tis, myBookingRef, newBooking, remarks, app.myPassport);
			else																	//+cnwml2 PAR19817
				app.raiseCMException(Input_required_field_newBoking, null, null);	// cnwdb2 PAR 35364
			endif;																	//+cnwml2 PAR19817
		else
			voyage	:= cmbVoyage.listObject.CM_Voyage;
			if voyage &lt;&gt; null then													//+cnwml2 PAR19817
				app.myTrxUA.trxRollBooking( bookingRefSet, txtBooking.text, voyage, dischargePortCode, null, remarks, app.myPassport);
			else																	//+cnwml2 PAR19817
				app.raiseCMException(Input_required_field_new_voyag, null, null);	// cnwdb2 PAR35364
			endif;																	//+cnwml2 PAR19817
		endif;
		if app.myPassport.trxCompletedOK then
			return true;
		else
		
			heading	:= self.getTypeString();
			
			result := app.showErrorWarningDialog(heading, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
	
epilog
	delete tis;
	
	delete bookingRefSet;
	
end;

</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTypeString" id="a5b3bd82-6568-4f34-83b0-4566bf6833cd">
        <source>getTypeString() : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 December 2008	cnwer1	Initial creation

*/

vars

begin

	if self.isSplit then	
		return app.getErrorString(Split_booking);		
	elseif self.isBookingBulkRollMode then
		return app.getErrorString(Roll_bookings);
	else
		return app.getErrorString(Roll_booking);
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadTable" id="0c7ad57e-47c7-4a53-8bbf-ac1d8b87cef3">
        <source>loadTable(pBookingRef : CM_BookingRef);

vars
	ti	: CM_TrackedItem;
	tis	: CM_TISet;
begin
	//cnwmc5 - 25 July 2013 - PAR 32084
	create tis transient;
	pBookingRef.getTIsForRollSplit(tis);
	
	foreach ti in tis do
		self.tblContainers.addItemObject(ti.id &amp; Tab &amp; ti.isoTypeDesc &amp; Tab &amp; ti.getDisplaySiteForReports , ti);
	endforeach;
	
	if not isSplit then
		self.tblContainers.selectAll;
	endif;
epilog
	delete tis;
end;
</source>
        <Parameter name="pBookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setAllBookingRefs" id="2f0adaee-289a-4c2e-b09b-c0d2145e7804">
        <updating/>
        <source>setAllBookingRefs(_allBookingRefs : CM_BookingRefSet) updating;
/* ---------------------------------------------------------------------------
Created:	30 September 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.allBookingRefs.clear;
	if _allBookingRefs &lt;&gt; null then
		_allBookingRefs.copy(self.allBookingRefs);
	endif;

end;</source>
        <Parameter name="_allBookingRefs" type="CM_BookingRefSet"/>
    </JadeMethod>
    <JadeMethod name="setBookingRef" id="8577a89c-7612-44d7-8d92-0b892ebec270">
        <updating/>
        <source>setBookingRef(pBookingRef : CM_BookingRef) updating;

vars
	captionStr : String;	
begin

	captionStr:=self.getTypeString;
	self.myBookingRef	:= pBookingRef;
	
	if self.myBookingRef &lt;&gt; null then
		
		if self.tblContainers.visible then
			self.loadTable(myBookingRef);
		endif;
		captionStr:=captionStr &amp; " " &amp; self.myBookingRef.bookingReference;
		self.lblCurBookDis.caption := self.myBookingRef.bookingReference;	
		//self.lblCurVoyDis.caption:=self.myBookingRef.myVoyage.getDisplayDetails(false);																							//-cnwml2 PAR20173 SFW CCMS 1091
		if self.myBookingRef.myVoyage &lt;&gt; null then					//+cnwml2 PAR24322
			self.lblCurVoyDis.caption:= self.myBookingRef.myVoyage.getDisplayDetails(true) &amp; " " &amp; self.myBookingRef.myVoyage.description &amp;" - " &amp; self.myBookingRef.dischargePort;		//+cnwml2 PAR20173 SFW CCMS 1091
		else
			self.lblCurVoyDis.caption := null;
		endif;
		
		if txtBooking.visible  then
			txtBooking.text	:= myBookingRef.bookingReference;
		endif;
	endif;
	
end;
</source>
        <Parameter name="pBookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="d758733e-56b7-4d22-818e-337a70885f8a">
        <updating/>
        <source>setCaption(_caption: String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2009	cnwml2	Initial creation

*/

vars
	caption : String;
begin
	
	if isSplit then
		caption := app.getErrorString(Split_booking);
	elseif self.isBookingBulkRollMode then
		caption := app.getErrorString(Roll_bookings);
	else
		caption := app.getErrorString(Roll_booking);
	endif;
	
	inheritMethod(caption);

epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setIsBookingBulkRollMode" id="aa286348-e435-4099-8618-88da11540300">
        <updating/>
        <source>setIsBookingBulkRollMode(_allBookingRefs : CM_BookingRefSet) updating;
/* ---------------------------------------------------------------------------
Created:	30 September 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.isBookingBulkRollMode := true;
	self.setAllBookingRefs(_allBookingRefs);
	
end;</source>
        <Parameter name="_allBookingRefs" type="CM_BookingRefSet"/>
    </JadeMethod>
    <JadeMethod name="setIsSplit" id="cead4049-6ae8-463f-9faa-78f25ab3170e">
        <updating/>
        <source>setIsSplit(_value : Boolean)updating;

vars

begin
	self.isSplit := _value;
	
	// moved to showHideControls( )	PAR 20297 Sep 2009
	/*self.txtBooking.visible 	:= not self.isSplit;
	self.cmbBooking.visible 	:= self.isSplit;
	self.lblMessage.visible:=self.isSplit;
	self.tblContainers.visible:=self.isSplit;
	
	
	if not self.tblContainers.visible then
		self.height:=self.height- self.tblContainers.height;
	endif;*/
end;
</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a6a19a46-7ef7-45c2-9aba-02a30e2aea09">
        <updating/>
        <source>setupForm() updating;

vars

begin

	inheritMethod();

	self.setCaption(null);
	if self.myBookingRef &lt;&gt; null then					//+cnwml2 PAR23364
		self.lblCurBookDis.caption := self.myBookingRef.bookingReference;	
		if self.myBookingRef.dischargePort &lt;&gt; null then
			if self.myBookingRef.myVoyage &lt;&gt; null then					//+cnwml2 PAR234322
				if self.myBookingRef.dischargePort &lt;&gt; null then
					self.lblCurVoyDis.caption := self.myBookingRef.myVoyage.getDisplayDetails(true) &amp; " " &amp; self.myBookingRef.myVoyage.description &amp;" - " &amp; self.myBookingRef.dischargePort;		//+cnwml2 PAR20173 SFW CCMS 1091
				else
					self.lblCurVoyDis.caption := self.myBookingRef.myVoyage.getDisplayDetails(true) &amp; " " &amp; self.myBookingRef.myVoyage.description ;		//+cnwml2 PAR24578
				endif;
			else
				self.lblCurVoyDis.caption := null;
			endif;
		else
			if self.myBookingRef.myVoyage &lt;&gt; null then					//+cnwml2 PAR24322
				if self.myBookingRef.dischargePort &lt;&gt; null then
					self.lblCurVoyDis.caption := self.myBookingRef.myVoyage.getDisplayDetails(true) &amp; " " &amp; self.myBookingRef.myVoyage.description &amp;" - " &amp; self.myBookingRef.dischargePort;		//+cnwml2 PAR20173 SFW CCMS 1091
				else
					self.lblCurVoyDis.caption := self.myBookingRef.myVoyage.getDisplayDetails(true) &amp; " " &amp; self.myBookingRef.myVoyage.description ;		//+cnwml2 PAR24578
				endif;
			else
				self.lblCurVoyDis.caption := null;
			endif;		
		endif;
	endif;
	self.cmbVoyage.listCollection(self.myTerminal.allVoyagesByCode,false,null);
	
	self.showHideControls();
	
	self.portCmbOrderDescrFirst := app.myRoot.getConfig(PortCmbOrderDescrFirst).Boolean;
	
	self.chkTranships.visible := false; // TFS 40417
	self.lblTranship.visible := false; // TFS 40417
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="showHideControls" id="7d8d160f-bcb6-4489-ae29-0c7c9d1f1550">
        <updating/>
        <source>showHideControls() updating;
/* ---------------------------------------------------------------------------
Created:	30 September 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.txtBooking.visible 	:= not self.isSplit;
	self.cmbBooking.visible 	:= self.isSplit;
	self.lblMessage.visible		:= self.isSplit;
	self.tblContainers.visible	:= self.isSplit;

	if not self.tblContainers.visible then
		self.height:=self.height- self.tblContainers.height;
	endif;

	if self.isSplit then
		self.height:=430;
		self.btnSave.top := 373;
		self.btnCancel.top := 373;
		self.lblMessage.caption	:= "Select the Containers that you want moved to the new Booking:";
		self.btnSave.top	:= self.height - 68;
		self.btnCancel.top	:= self.height - 68;
	else	// for Roll and for Bulk Roll the from.height is the same
		self.btnSave.top := 243;
		self.btnCancel.top := 243;
		self.height := 236;
		self.btnSave.top	:= self.height - 64;
		self.btnCancel.top	:= self.height - 64;
	endif;
	
	if self.isBookingBulkRollMode then	//Bulk Roll
		self.txtBooking.visible 	:= false;
		self.lblNewBooking.visible	:= false;
		self.lbCurVoy.visible		:= false;
		self.lblCurVoyDis.visible	:= false;
		self.lblCurBook.top			:= 15;
		self.lblCurBookDis.top		:= self.lblCurBook.top + 1;
		self.lblDischarge.top		:= self.lblNewBooking.top;
		self.cmbDischargePort.top	:= self.txtBooking.top;
		self.lblCurBook.caption		:= "Bookings:";
		self.lblCurBookDis.caption	:= self.allBookingRefs.size.asStringJMT();
		self.btnSave.top	:= self.height - 74;
		self.btnCancel.top	:= self.height - 74;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ada7f1ce-d354-42f3-90a5-58f27aa5c927">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 May 2018 16:06:35.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009436, locale);
	btnCancel.translateCaption(Xlat_0009437, locale);
	btnSave.translateCaption(Xlat_0009438, locale);
	lbCurVoy.translateCaption(Xlat_0009439, locale);
	lblCurBook.translateCaption(Xlat_0009440, locale);
	lblCurBookDis.translateCaption(Xlat_0012933, locale);
	lblCurVoyDis.translateCaption(Xlat_0012934, locale);
	lblDischarge.translateCaption(Xlat_0009443, locale);
	lblNewBooking.translateCaption(Xlat_0014349, locale);
	lblNewVoyage.translateCaption(Xlat_0014350, locale);
	lblRemarks.translateCaption(Xlat_0018144, locale);
	lblTranship.translateCaption(Xlat_0022405, locale);
end;</source>
    </JadeMethod>
</GUIClass>
