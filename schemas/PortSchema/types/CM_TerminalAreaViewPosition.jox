    <JadeMethod name="getAuditTextDescription" id="38c9e54c-6ab2-45af-b04c-04611aa67449">
        <source>getAuditTextDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 December 2010	cnwer1	Initial creation

*/

vars
	str, rtnStr : String;
begin
	str:=self.myTerminalArea.id;
	rtnStr:=self.auditIdDisplay() &amp; '-terminal area' &amp;  AuditStringSeparator &amp; str.length.String &amp; AuditStringSeparator &amp; str &amp; AuditStringSeparator;  
	
	str := origin.asStringJMT;
	rtnStr := rtnStr &amp;
			self.auditIdDisplay() &amp; '-origin' &amp;  AuditStringSeparator &amp; str.length.String &amp; AuditStringSeparator &amp; str &amp; AuditStringSeparator;  
			
	str := self.rotation.asStringJMT;
	rtnStr := rtnStr &amp;
			self.auditIdDisplay() &amp; '-rotation' &amp;  AuditStringSeparator  &amp; str.length.String &amp; AuditStringSeparator &amp; str &amp; AuditStringSeparator;
			
	str:=self.horizontalFlip.asStringJMT;		
		rtnStr := rtnStr &amp;
			self.auditIdDisplay() &amp; '-horizontal flip' &amp;  AuditStringSeparator  &amp; str.length.String &amp; AuditStringSeparator &amp; str &amp; AuditStringSeparator;
	
	str:=self.verticalFlip.asStringJMT;	
		rtnStr := rtnStr &amp;
			self.auditIdDisplay() &amp; '-horizontal flip' &amp;  AuditStringSeparator  &amp; str.length.String &amp; AuditStringSeparator &amp; str &amp; AuditStringSeparator;
	
	return rtnStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHeight" id="d81635a1-019c-420e-949d-b8c5f661666d">
        <source>getHeight() : Integer;
/*

Date		Who		Reason
12 November 2015	cnwer1	Initial creation PAR 37168

*/

vars

begin
	if self.height &lt;&gt; 0 then
		return self.height;
	endif;
	
	if  self.myTerminalArea &lt;&gt; null then
		if self.myTerminalArea.isKindOf(CM_BlockStack) then
			return self.myTerminalArea.CM_BlockStack.getRows(true) * 12;
		else
			return 5 * 12;
		endif;
	endif;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLeftAlignment" id="d0d644b5-0783-4b71-b966-6bd9ba79cb76">
        <source>getLeftAlignment() : Integer;

/*

Purpose:		Determines the alignment of the left edge of the area after rotation and flipping

Parameters:			

Return Value:	Refer AlignXXXX constants defined for this class


Date				Who		Reason
03 September 2008	consw1	Initial creation

*/

vars
	alignment : Integer;
	
begin
	if self.rotation &lt; 45 then
		alignment := self.AlignLeft;
	elseif self.rotation &lt; 135 then
		alignment := self.AlignTop;
	elseif self.rotation &lt; 225 then
		alignment := self.AlignRight;
	elseif self.rotation &lt; 315 then
		alignment := self.AlignBottom;
	else
		alignment := self.AlignLeft;
	endif;
	
	if self.horizontalFlip then
		alignment := ( alignment + 2 ) mod 4;
	endif;

	return alignment;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTopAlignment" id="7405327a-d24b-4fd5-92b1-c25dff583f55">
        <source>getTopAlignment() : Integer;

/*

Purpose:		Determines the alignment of the top of the area after rotation and flipping

Parameters:			

Return Value:	Refer AlignXXXX constants defined for this class


Date				Who		Reason
03 September 2008	consw1	Initial creation

*/

vars
	alignment : Integer;
	
begin
	if self.rotation &lt; 45 then
		alignment := self.AlignTop;
	elseif self.rotation &lt; 135 then
		alignment := self.AlignRight;
	elseif self.rotation &lt; 225 then
		alignment := self.AlignBottom;
	elseif self.rotation &lt; 315 then
		alignment := self.AlignLeft;
	else
		alignment := self.AlignTop;
	endif;
	
	if self.verticalFlip then
		alignment := ( alignment + 2 ) mod 4;
	endif;

	return alignment;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWidth" id="4782a76c-f4eb-4c2b-97fe-99270bf69a6b">
        <source>getWidth() : Integer;
/*

Date		Who		Reason
12 November 2015	cnwer1	Initial creation PAR 37168

*/

vars

begin
	if self.width &lt;&gt; 0 then
		return self.width;
	endif;
	
	if  self.myTerminalArea &lt;&gt; null then
		if self.myTerminalArea.isKindOf(CM_BlockStack) then
			return self.myTerminalArea.CM_BlockStack.getColumns(true) * 24;
		else
			return 5 * 24;
		endif;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isBlockStack" id="ab0873c2-8037-44b6-b8ec-00507f00fa62">
        <source>isBlockStack():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2011	cnwndl1	Initial creation	Par 28076

*/

vars

begin

	if self.myTerminalArea = null then
		return false;
	else
		return self.myTerminalArea.isKindOf(CM_BlockStack);
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFlippedHorizontal" id="0f91ad00-0c4f-4ad6-a081-66f9d7fadb6a">
        <source>isFlippedHorizontal() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 October 2009	cnwer1	Initial creation

*/

vars

begin
	if self.rotation = 0 and self.horizontalFlip or
			(self.rotation = 180 and not self.horizontalFlip) then
		return true;
	else
		return self.horizontalFlip;
	endif;
	
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFlippedVertical" id="6677b728-415b-47b3-9c4d-a4075f32b858">
        <source>isFlippedVertical() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 October 2009	cnwer1	Initial creation

*/

vars

begin
	if (self.rotation = 90 and   self.horizontalFlip) or
			(self.rotation = 270 and not self.horizontalFlip) then
		return true;
	elseif (self.rotation = 90 and not self.horizontalFlip and self.verticalFlip) then
		return false;
	elseif (self.rotation = 270 and self.verticalFlip and self.horizontalFlip) then
		return false;
	
	else
		return self.verticalFlip;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
