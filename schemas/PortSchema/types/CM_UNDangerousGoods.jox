vars

begin

	self.isCodeGroupNOTRequired := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="e249bd90-c891-4b6f-936f-5c22a6098713">
        <source>getAuditTextForProperty(_property: Property): String;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 16 March 2007
//
//----------------------------------------------------------------------

vars
	propName : String;
begin
	propName := _property.name;
	//if propName = CM_Container::allCustomsSealNumbers.name then
	if propName = CM_UNDangerousGoods::allClassCodes.name then
		return self.formatAuditText(propName, self.getAuditTextForStringArray(self.allClassCodes));
	endif;
	
	if propName = CM_UNDangerousGoods::allPackingGroups.name then
		return self.formatAuditText(propName, self.getAuditTextForStringArray(self.allPackingGroups));
	endif;
	
	return inheritMethod(_property);
epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="3d9cd41d-c3b3-44d6-9a50-53b22fe30418">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/* ---------------------------------------------------------------------------
Created:     25 September 2009 by cnwrs2

Purpose:     
        
Change Date	Who			Reason
-----------	--------	------------------------------------------------------
12/06/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
07/11/2016	cnwdap1		TFS 2841 STWR Hazardous Details Enhancements
------------------------------------------------------------------------------*/
vars

begin

	if _attrName = ETRow_AllClassCodes or 
	   _attrName = ETRow_SecondaryClasses then				// PAR #36421
		return self.allClassCodes.asCSV(false);
	elseif _attrName = ETRow_HazardClass then
		if self.myHazardClass &lt;&gt; null then
			return self.myHazardClass.code;
		endif;
	elseif _attrName = ETRow_AllPackingGroups then
		return self.allPackingGroups.asCSV(false);
	elseif _attrName = ETRow_Symbols then
		return self.symbols;
	elseif _attrName = ETRow_Emergency then
		return self.emergencyNumber;
	elseif _attrName = ETRow_MarinePollutant then
		return self.marinePollutant;
	elseif _attrName  = ETRow_Additional then
		return self.additionalDesc;
		
	elseif _attrName = ETRow_IsMarinePollutant then					// TFS 2841
		return self.isMarinePollutant.asStringJMT;					// TFS 2841
	elseif _attrName = ETRow_IsMarinePollutantMand then				// TFS 2841
		return self.isMarinePollutantMandatory.asStringJMT;			// TFS 2841
		
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="1c8fafd8-1dce-4ecb-9317-cc04ba002c22">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2013	cnwer1	Initial creation HAT 2189

*/

vars
	pxySelf : CM_UNDangerousGoods;
	completedOK : Boolean;
begin
	pxySelf:= inheritMethod();

	pxySelf.myHazardClass := self.myHazardClass;
	completedOK := true;	
	return pxySelf;
	
epilog
	if not completedOK then
		delete pxySelf;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="7379970c-9cb4-4000-bc7a-7f762811a036">
        <updating/>
        <source>setForCreate(pProxy: CM_UNDangerousGoods) updating;
//----------------------------------------------------------------
//	Created:	31 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 12/06/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
vars

begin
	inheritMethod(pProxy);
	
	self.myRoot	:= app.myRoot;
	
	self.allClassCodes.clear;									// PAR #36421
	pProxy.allClassCodes.copy(self.allClassCodes);				// PAR #36421

end;</source>
        <Parameter name="pProxy" type="CM_UNDangerousGoods"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="89a75d20-5cde-42a1-942d-6ed3bcae4992">
        <updating/>
        <source>setForProxy(	pCode,
				pDescription		: String;
				_notAvailableForEntry	: Boolean;
				_myHazardClass			: CM_HazardClass;
				_packingGroups			: StringArray;
				_symbols				: String;
				_emergency				: String;
				_marinePollutant		: String;
				_isMarinePollutant		: Integer;					// TFS 2841
				_isMarinePollMandatory	: Boolean;					// TFS 2841
				_additionalDesc			: String;
				_secondaryClasses		: CM_StringArray;			// PAR #36421
				_doNotUse				: Boolean) updating;
				
//----------------------------------------------------------------
//	Created:	31 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 12/06/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
// 07/11/2016	cnwdap1		TFS 2841 STWR Hazardous Details Enhancements
vars

begin

	self.setSuperClassDetailsForProxy(pCode, pDescription[1:100], _notAvailableForEntry, null);
	
	self.nameDesc := pDescription;
	
	self.marinePollutant :=_marinePollutant;
	self.isMarinePollutant := _isMarinePollutant;					// TFS 2841
	self.isMarinePollutantMandatory := _isMarinePollMandatory;		// TFS 2841
	self.additionalDesc:=_additionalDesc;
	self.emergencyNumber:=_emergency;
	self.symbols:=_symbols;
	
	self.myHazardClass:=_myHazardClass;
	
	self.allPackingGroups.clear;
	_packingGroups.copy(self.allPackingGroups);
	
	self.noLongerUsed := _doNotUse;
	
	if _secondaryClasses &lt;&gt; null then								// PAR #36421
		self.allClassCodes.clear;									// PAR #36421
		_secondaryClasses.copy(self.allClassCodes);					// PAR #36421
	endif;															// PAR #36421
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_myHazardClass" type="CM_HazardClass"/>
        <Parameter name="_packingGroups" type="StringArray"/>
        <Parameter name="_symbols" type="String"/>
        <Parameter name="_emergency" type="String"/>
        <Parameter name="_marinePollutant" type="String"/>
        <Parameter name="_isMarinePollutant" type="Integer"/>
        <Parameter name="_isMarinePollMandatory" type="Boolean"/>
        <Parameter name="_additionalDesc" type="String"/>
        <Parameter name="_secondaryClasses" type="CM_StringArray"/>
        <Parameter name="_doNotUse" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="efb25f14-2de4-468f-8246-577336732d9c">
        <updating/>
        <source>setForUpdate(_proxy: CM_UNDangerousGoods) updating;
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 12/06/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
// 07/11/2016	cnwdap1		TFS 2841 STWR Hazardous Details Enhancements
vars

begin
	inheritMethod(_proxy);
	
	self.nameDesc := _proxy.nameDesc;
		
	self.allPackingGroups.clear;
	_proxy.allPackingGroups.copy(self.allPackingGroups);
	
	self.noLongerUsed := _proxy.noLongerUsed;
	
	self.myHazardClass :=_proxy.myHazardClass;
	self.marinePollutant:=_proxy.marinePollutant;
	self.emergencyNumber:=_proxy.emergencyNumber;
	self.additionalDesc:=_proxy.additionalDesc;
	self.symbols:=_proxy.symbols;
	
	self.allClassCodes.clear;										// PAR #36421
	_proxy.allClassCodes.copy(self.allClassCodes);					// PAR #36421
	
	self.isMarinePollutant := _proxy.isMarinePollutant;						// TFS 2841
	self.isMarinePollutantMandatory := _proxy.isMarinePollutantMandatory;	// TFS 2841
	
end;</source>
        <Parameter name="_proxy" type="CM_UNDangerousGoods"/>
    </JadeMethod>
    <JadeMethod name="setMyHazardClass" id="e09f161e-8a4b-4351-ba1f-406ba95b32c5">
        <updating/>
        <source>setMyHazardClass(_value : CM_HazardClass) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2013	cnwer1	Initial creation CCMS 2280

*/

vars

begin
	self.myHazardClass :=_value;
epilog

end;</source>
        <Parameter name="_value" type="CM_HazardClass"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="9bb85c5f-2850-4022-ab22-046d80ed18e7">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 16 March 2007
//
//----------------------------------------------------------------------

vars
	
begin
	if _property.name = CM_UNDangerousGoods::nameDesc.name then
		return false;
	endif;
	
	if _property.name = CM_UNDangerousGoods::isCodeGroupNOTRequired.name then
		return false;
	endif;
	
	if _property.name = CM_UNDangerousGoods::myCodeGroup.name then
		return false;
	endif;
	
	if _property.name = CM_UNDangerousGoods::notAvailableForEntry.name then
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="bac18c45-5310-47ee-9275-41d1491552c1">
        <source>validateForCreate();

vars
	undgCode	: CM_UNDangerousGoods;
begin
	inheritMethod();
	
	undgCode := app.myRoot.allUNDangerousGoodsCodes[self.code];
	
	if undgCode &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, 'code', null);
	endif;
	
end;</source>
    </JadeMethod>
</Class>
