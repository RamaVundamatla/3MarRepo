    <JadeMethod name="addToJobTotals" id="b68067dc-26cc-4631-b5bd-a8f9e41c8162">
        <source>addToJobTotals(_theTotals: CMIF_JobTITotals input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 Aug 2011	cnwer1	Initial creation CCMS MES 1033
12 Oct 2011 cnwer1	Par 28386 - wasn't adding up bbk totals
14 May 2013 cnwer1	CCMS 2274 - use getWLEQuantity rather than wles.size can now have wle with a quantity i.e. 50 rebars
							- also doing the cargo type summary here rather than on cargo because need the wle quantity
//15 Aug 2017	jlgrh7 TFS 5216	 Load Hold Jobs not showing all info on OOW
*/

vars
	 workListEntrySize			: Integer;
	isEmpty : Boolean; 	//cnwas3 PAR 24273	
	wle : CM_WorkListEntry;
	ti		: CM_TrackedItem;
	cargoTypeTotal : CM_Association;
	totalKey 	: String;
begin
	_theTotals.myJob := self.myJob.CM_VoyageJob;
	isEmpty := self.getAttrEmpty();	//cnwas3 PAR 24273
	workListEntrySize := self.getWLEQuantity; //epr CCMS 2274 14/5/13
	//if self.moveType = LOAD_MOVETYPE or self.moveType = DISCHARGE_MOVETYPE 																		//-TFS5216
	if self.moveType = LOAD_MOVETYPE or self.moveType = DISCHARGE_MOVETYPE 																			//+TFS5216
	or (self.isHoldRequest and (self.moveType = JOB_TYPE_DISCHARGE or self.moveType = JOB_TYPE_LOAD)) then 
		if self.getAttrOverDimensioned() then // PAR 7685
			_theTotals.numOD := _theTotals.numOD + workListEntrySize; // PAR 7685
		endif;
		self.addJobTotalsPerCargoType( _theTotals.allBBLKTotals);
		_theTotals.numFull := _theTotals.numFull +workListEntrySize;
	elseif self.isRehandle then
		if self.getAttrOverDimensioned() then // PAR 7685
			_theTotals.numODRH := _theTotals.numODRH + workListEntrySize; // PAR 7685
		endif;
		self.addJobTotalsPerCargoType( _theTotals.allBBLKTotalsRH);
		_theTotals.numFullRH := _theTotals.numFullRH + workListEntrySize;
	elseif self.isSoB and not self.isLoad then // do not include the load part of the SOB, as it doubles up the figures
		if self.getAttrOverDimensioned() then // PAR 7685
			_theTotals.numODSOB := _theTotals.numODSOB + workListEntrySize; // PAR 7685
		endif;
		self.addJobTotalsPerCargoType( _theTotals.allBBLKTotalsSOB);
		_theTotals.numFullSOB := _theTotals.numFullSOB + workListEntrySize;
	endif;
epilog

end;</source>
        <Parameter name="_theTotals" type="CMIF_JobTITotals" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addWLE" id="86089c7f-d3fb-4c84-a5e6-2709ad3921a8">
        <updating/>
        <source>addWLE(_wle : CM_VoyageWLE io; _ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	jobType: Integer;
	associatedRequest: CM_SlotRequest;
	tmpLC: CM_LocationsController;
begin
	if _ti = null then
		app.raiseCMException1(ERR_NO_WLE_TI, self.myJob.jobId, null, null);
		return;
	endif;

	exclusiveLock(self);
	
	
	if _wle = null then
		//-------------------------------------------------------------
		// Create WLEs for any requests that do not already have one
		// ie the first time this request has been loaded
		//-------------------------------------------------------------
		// We do not have one yet so lets create one
		create _wle persistent;
	endif;

	//MUST SET KEY for memberKeyDict add. DWQ 20/8/96
	_wle.setMyTrackedItem(_ti);

	if self.myJob &lt;&gt; null then
		exclusiveLock(self.myJob);
	endif;

	_wle.setForCreate(self.myJob, self);


	if self.myJob &lt;&gt; null then
		jobType := self.myJob.jobType;
	
		if jobType = JOB_TYPE_SOB then //SOB have two requests but still only one wle per ti
			tmpLC := _ti.getPrimaryLocation(PLANNING_MODE);
			if tmpLC &lt;&gt; null and 
			   tmpLC.isKindOf(CM_SlotController) then
				associatedRequest := tmpLC.CM_SlotController.mySlotRequestLoad;
				// Add  wle:request links
				_wle.setAssociatedRequest(associatedRequest);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_wle" type="CM_VoyageWLE" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
