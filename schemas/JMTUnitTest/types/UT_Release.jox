    <JadeMethod name="xChangeSlotReqDoorDirection" id="7a7d6986-ac7c-4eaa-a809-510494b024cc">
        <source>xChangeSlotReqDoorDirection(_voyage : CM_Voyage);

/*

Purpose:		Change a Slot Requests Door Direction

Date			Who		Reason
21/02/2014		cnwmh5	Initial creation

*/

vars

	bay							: CM_Bay;
	slotDefn					: CM_SlotDefnVoyage;
	slotRequest					: CM_Request;
	pxySlotRequest				: CM_Request;
		
	currentDoorDirection		: Integer;
	newDoorDirection			: Integer;
	
begin
	
	bay := _voyage.myCellularVoyageStructure.allBayVoyagesById["09"];
	self.assertNotNull(bay);
	
	slotDefn := bay.allSlotsOnDeck.first.CM_SlotDefnVoyage;
	self.assertNotNull(slotDefn);
	
	slotRequest := slotDefn.mySlotController.getRequest(true);
	self.assertNotNull(slotRequest);
	
	currentDoorDirection := slotRequest.getDoorsDirection();
	
	// change the door direction
	newDoorDirection := TI_DOORSDIRN_AFT;
	if currentDoorDirection = TI_DOORSDIRN_AFT then
		newDoorDirection := TI_DOORSDIRN_FWD;
	endif;		
	
	beginLoad;
	pxySlotRequest := slotRequest.pxyCreateUpdateProxy();
	endLoad;
	
	pxySlotRequest.setProxyForDoorDirection(newDoorDirection);
	
	app.myTrxUA.trxUpdateSlotRequestDirection(pxySlotRequest, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotEqual(slotRequest.getDoorsDirection(), currentDoorDirection);
	
epilog

	endLoad;
	
	delete pxySlotRequest;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xCreateDischContsCCAddToJob" id="817b2fdf-977b-410e-8335-c3dda559d8c6">
        <source>xCreateDischContsCCAddToJob(_voyage : CM_Voyage; _jobSet : CM_VoyageJobSet io);

/*

Purpose:		Create discharge containers, colour code, and add to job

Date			Who		Reason
21/02/2014		cnwmh5	Initial creation

*/

vars

	job							: CM_VoyageJob;
	container					: CM_Container;
	moveController 				: CMIF_MoveController;
	bay							: CM_Bay;
	slotDefn					: CM_SlotDefn;
	voyageJob					: CM_VoyageJob;
	tmpLoadCC					: CMIF_LoadColorCode;
		
	tiSet						: CM_TIArray;
	theSlots					: CM_SlotControllerArray;
	theSlots2					: CM_SlotControllerArray;
	lc 							: CM_LCArray;
	
	index						: Integer;

begin

	
	create theSlots transient;
	create theSlots2 transient;
	bay := _voyage.myCellularVoyageStructure.allBayVoyagesById["11"];
	index := 0;
	foreach slotDefn in bay.allSlotsOnDeck do
		if index &gt; 17 then
			break;
		endif;
		theSlots.add(slotDefn.CM_SlotDefnVoyage.mySlotController);
		theSlots2.add(slotDefn.CM_SlotDefnVoyage.mySlotController);
		index := index + 1;
	endforeach;
	self.assertEqual(theSlots.size, 18);	
	
	// create items in bs to assign to load job
	
	self.opts.purge();
	self.opts.addAssoc("Voyage", _voyage);
	self.opts.addAssoc("CENum", "12345");
	create tiSet transient;
	foreach index in 1 to theSlots.size step 1 do
		container := self.addContainerAtLocation("UTMISCZA" &amp; index.padLeadingWith("0", 3), 
			self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200", "GENL", TI_IMEX_STATUS_REMAINONBOARD, 
				theSlots2[index]);
		self.assertNotNull(container);
		self.updateTI(container);
		self.deleteStops(container);
		tiSet.add(container);
	endforeach;
	app.myTrxUA.trxUpdateTIsReadyToShip(tiSet, true, app.myPassport);
	
	
	self.markSlotsAsDischargeCC(theSlots2, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRN1", theSlots2, true);
	self.assertTrue(voyageJob &lt;&gt; null);
	_jobSet.add(voyageJob);
		
	
	foreach job in _jobSet do
		self.loadVoyJobToOps(job, true, false);
	endforeach;
		
epilog

	delete tiSet;
	delete lc;
	delete moveController;
	delete theSlots;
	delete theSlots2;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_jobSet" type="CM_VoyageJobSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xCreateLoadContsLoadToOps" id="b27a61db-d4aa-413a-b031-726881a9e506">
        <source>xCreateLoadContsLoadToOps(_voyage : CM_Voyage; _jobSet : CM_VoyageJobSet io; _bs : CM_BlockStack);

/*

Purpose:		Create containers and load to ops

Date			Who		Reason
21/02/2014		cnwmh5	Initial creation

*/

vars

	job							: CM_VoyageJob;
	container					: CM_Container;
	moveController 				: CMIF_MoveController;
	bay							: CM_Bay;
	slotDefn					: CM_SlotDefn;
	voyageJob					: CM_VoyageJob;
	tmpLoadCC					: CMIF_LoadColorCode;
		
	tiSet						: CM_TIArray;
	theSlots					: CM_SlotControllerArray;
	theSlots2					: CM_SlotControllerArray;
	lc 							: CM_LCArray;
	
	index						: Integer;

begin

	
	create theSlots transient;
	create theSlots2 transient;
	bay := _voyage.myCellularVoyageStructure.allBayVoyagesById["09"];
	index := 0;
	foreach slotDefn in bay.allSlotsOnDeck do
		if index &gt; 17 then
			break;
		endif;
		theSlots.add(slotDefn.CM_SlotDefnVoyage.mySlotController);
		theSlots2.add(slotDefn.CM_SlotDefnVoyage.mySlotController);
		index := index + 1;
		if index mod 6 = 0 then
			self.markSlotsAsLoadJob(theSlots2, tmpLoadCC);
			self.markSlotsAsLoadCC(theSlots2, tmpLoadCC, CM_SlotRequest.Attribute_D20);
			voyageJob := self.addVoyageJob(_voyage, "CRN1", theSlots2, false);
			self.assertTrue(voyageJob &lt;&gt; null);
			theSlots2.clear();
			//if (index / 6) &lt;= 2 then
				_jobSet.add(voyageJob);
			//endif;
		endif;
	endforeach;
	self.assertEqual(theSlots.size, 18);	
	
	// create items in bs to assign to load job
	
	self.opts.purge();
	self.opts.addAssoc("Voyage", _voyage);
	self.opts.addAssoc("CENum", "12345");
	create tiSet transient;
	foreach index in 1 to theSlots.size step 1 do
		container := self.addContainerAtLocation("UTMISCZ" &amp; index.padLeadingWith("0", 4), 
			self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200", "GENL", TI_IMEX_STATUS_STORAGE, _bs);
		self.assertNotNull(container);
		self.updateTI(container);
		self.deleteStops(container);
		tiSet.add(container);
	endforeach;
	app.myTrxUA.trxUpdateTIsReadyToShip(tiSet, true, app.myPassport);
	
	
	create lc transient;
	theSlots.copy(lc);
	
	create moveController transient;
	moveController.isRehandleMove := true;
	moveController.mySlotRequest := theSlots.first.mySlotRequestLoad;
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isSystemMove := true;
	moveController.isForcedMove := true;
	moveController.doingAutoLoadPlanning := true;

	
	app.myTrxUA.trxMoveTIsAUTOAssignToJob(tiSet, lc, moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	foreach job in _jobSet do
		self.loadVoyJobToOps(job, true, false);
	endforeach;

epilog

	delete tiSet;
	delete lc;
	delete moveController;
	delete theSlots;
	delete theSlots2;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_jobSet" type="CM_VoyageJobSet" usage="io"/>
        <Parameter name="_bs" type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="xDeleteVoyageAllocation" id="cbcd2021-0722-4245-95fb-87907250955b">
        <updating/>
        <source>xDeleteVoyageAllocation(_voyage : CM_Voyage io) updating;

/*

Purpose:		Delete voyage allocation

Date			Who		Reason
20/02/2014		cnwmh5	Initial creation

*/

vars

	allocation						: CM_VoyageAllocation;
	
	voyageAllocationSize			: Integer;

begin


	self.opts.purge();
	self.opts.addAssoc("ISOType", "UT53");
	self.opts.addAssoc("Operator", _voyage.myOperator);
	allocation := self.addVoyageAllocation(_voyage, "NZAKL", "", "", 1, false, false);	
	self.assertNotNull(allocation);
	
	voyageAllocationSize := _voyage.allVoyageAllocations.size;
	allocation := _voyage.allVoyageAllocations.last.CM_VoyageAllocation;
	self.assertNotNull(allocation);
	app.myTrxDA.trxDeleteVoyageAllocation(allocation, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(_voyage.allVoyageAllocations.size, voyageAllocationSize - 1);

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xDeleteVoyageJobs" id="90450e6c-0762-483c-9bf4-d5d4869a91de">
        <source>xDeleteVoyageJobs(_voyage : CM_Voyage; _jobSet : CM_VoyageJobSet io);

/*

Purpose:		Delete voyage jobs

Date			Who		Reason
20/02/2014		cnwmh5	Initial creation

*/

vars

	job						: CM_VoyageJob;

begin

	if _voyage = null or _jobSet.isEmpty() then
		return;
	endif;
	
	// unload jobs from job ops
	foreach job in _jobSet do
		self.loadVoyJobToOps(job, false, false);
	endforeach;
	
	app.myTrxDA.trxDeleteVoyageJobs(_jobSet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	self.assertEqual(_voyage.allVoyageJobs.size, 2);
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_jobSet" type="CM_VoyageJobSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xMoveLastJobUp" id="ceecedac-7ebb-487d-8f66-cfec07e7fce8">
        <source>xMoveLastJobUp(_voyage : CM_Voyage; _voyageJob : CM_VoyageJob io);

/*

Purpose:		Move the last job in the job sheet up

Date			Who		Reason
21/02/2014		cnwmh5	Initial creation

*/

vars

	job						: CM_VoyageJob;
	jobSheet				: CM_JobSheet;
	
	seqJobs					: ObjectArray;


begin

	jobSheet := _voyageJob.myJobSheet;
	create seqJobs transient;
	jobSheet.allJobsByOrder.copy(seqJobs);
	self.assertEqual(seqJobs[3], _voyageJob);


	app.myTrxUA.trxShiftJobInJobSheet(_voyageJob, app.myPassport, -1);
	self.assertNoTrxErrorsOrWarnings();
	
	seqJobs.clear;
	jobSheet.allJobsByOrder.copy(seqJobs);
	self.assertEqual(seqJobs[2], _voyageJob);	

epilog

	delete seqJobs;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_voyageJob" type="CM_VoyageJob" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xRebuildJobWLEStatus" id="86fb387a-362d-47ec-9b13-de8f58050b27">
        <source>xRebuildJobWLEStatus(_voyageJob : CM_VoyageJob io);

/*

Purpose:		rebuild a jobs wle status	

Date			Who		Reason
21/02/2014		cnwmh5	Initial creation

*/

vars

	wle							: CM_WorkListEntry;

begin

	foreach wle in _voyageJob.workListEntries do
	
		app.myTrxUA.trxUpdateWLESeqd(wle, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	
		app.myTrxUA.trxUpdateWLEStatus(wle, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	
	endforeach;

epilog

end;</source>
