    <JadeMethod name="setCMIFFromBulkRelease" id="bb2be046-48fd-4cba-9491-42105053ab4b">
        <updating/>
        <source>setCMIFFromBulkRelease(bulkRelease : CM_BulkRelease; cmifGrouping : CMIF_ReserveTIGrouping io) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 26 February 2019
TFS#		: 41708
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	reserveDetail			: CM_ReserveDetail;	
	iter 					: Iterator;
	sortedTIRequests		: DynaDictionary;	
	isComplete				: Boolean;
	currentCargoTypeDes		: String;
	id						: String;
	cargoTypeDescription	: String;
	
	ti 						: CM_TrackedItem;
	currentCargoType		: CM_CargoType;
	cargoSubType			: CM_Product;
	listObj 				: Object;
	
	prevCargoType			: CM_CargoType;	
	cmifDetails				: CMIF_ReserveTIDetail;	
begin

	if bulkRelease = null or (not app.isValidObject(bulkRelease)) then
		return;
	endif;
	
	if not bulkRelease.isPackingType then
		if not bulkRelease.releaseByType then
			create sortedTIRequests transient;
			sortedTIRequests.setMembership(CM_ReserveDetail);
			sortedTIRequests.addExternalKey(String,100,true,false); //cargo product description    
			sortedTIRequests.addExternalKey(Boolean,1,false,false); //is complete
			sortedTIRequests.addExternalKey(String,100,true,false);// ti id
			sortedTIRequests.endKeys(true);
			foreach reserveDetail in bulkRelease.allReserveDetails do
				if reserveDetail.isKindOf(CM_ReserveTI) then
					ti := reserveDetail.CM_ReserveTI.getTI;
					if  ti &lt;&gt; null then
					//	cargoTypeDescription := ti.getProductOrISODescr;
						cargoTypeDescription := ti.getProductDescription;	//18 May 2021	NDL	TFS 51183
					endif;
				endif;
				  sortedTIRequests.putAtKey(cargoTypeDescription,reserveDetail.isComplete,reserveDetail.getDescription, reserveDetail);
			endforeach;	
		endif;
	endif;
	
	if sortedTIRequests = null then
		iter:=bulkRelease.allReserveDetails.createIterator;
		currentCargoTypeDes:=null;		
	else
		iter:=sortedTIRequests.createIterator;
	endif;
	
	while iter.next(reserveDetail) do		
			if reserveDetail.isAllocationById then
				if sortedTIRequests &lt;&gt; null then
					iter.getCurrentKeys(cargoTypeDescription,isComplete,id);
					if currentCargoTypeDes &lt;&gt; cargoTypeDescription  then								
						prevCargoType := currentCargoType;	
						currentCargoType:=reserveDetail.getCargoType;
						cargoSubType:=reserveDetail.getMyProduct;
						if cargoSubType &lt;&gt; null then
							listObj := cargoSubType;
						else
							listObj:=currentCargoType;
						endif;
						
						create cmifDetails transient;
			
						cmifDetails.setFromReserveTI(reserveDetail.CM_ReserveTI);
						
						cmifGrouping.addDetailToHeader(cmifDetails);
						
						currentCargoTypeDes:=cargoTypeDescription;						
					else	
						cmifDetails.updateFromReserveTI(reserveDetail.CM_ReserveTI);					
					endif;										
				endif;
			endif;
	endwhile;
epilog
	delete iter;
	delete sortedTIRequests;
end;</source>
        <Parameter name="bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="cmifGrouping" type="CMIF_ReserveTIGrouping" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setCMIFFromLoaderAndRelease" id="5f1ac1dd-d896-4aa5-84bb-56bd6f05a204">
        <updating/>
        <source>setCMIFFromLoaderAndRelease(bulkRelease  : CM_BulkRelease; 
							cmifGrouping : CMIF_ReserveTIGrouping io; 
							cmifMobile 	 : CMIF_MobileGenericAgent;
							quantity 	 : Integer;
							weight 		 : Decimal;
							currentTI	 : CM_TrackedItem) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 26 February 2019
TFS#		: 41708
Function	: This creates the object including all the Loaded Quantity that is currently in the process of releasing (not yet completed).

*** Changes ***
Date		Name	TFS#		Description
26/07/2019	jlgka1 	TFS 45830	STWO - Partial Release for Break Bulk.
****************************************************/

vars
	reserveDetail			: CM_ReserveDetail;	
	iter 					: Iterator;
	sortedTIRequests		: DynaDictionary;	
	isComplete				: Boolean;
	currentCargoTypeDes		: String;
	id						: String;
	cargoTypeDescription	: String;
	
	ti 						: CM_TrackedItem;
	currentCargoType		: CM_CargoType;
	cargoSubType			: CM_Product;
	listObj 				: Object;
	
	prevCargoType			: CM_CargoType;	
	cmifDetails				: CMIF_ReserveTIDetail;	
begin

	if bulkRelease = null or (not app.isValidObject(bulkRelease)) then
		return;
	endif;
	
	if not bulkRelease.isPackingType then
		if not bulkRelease.releaseByType then
			create sortedTIRequests transient;
			sortedTIRequests.setMembership(CM_ReserveDetail);
			sortedTIRequests.addExternalKey(String,100,true,false); //cargo product description    
			sortedTIRequests.addExternalKey(Boolean,1,false,false); //is complete
			sortedTIRequests.addExternalKey(String,100,true,false);// ti id
			sortedTIRequests.endKeys(true);
			foreach reserveDetail in bulkRelease.allReserveDetails do
				if reserveDetail.isKindOf(CM_ReserveTI) then
					ti := reserveDetail.CM_ReserveTI.getTI;
					if  ti &lt;&gt; null then
					//	cargoTypeDescription := ti.getProductOrISODescr;
						cargoTypeDescription := ti.getProductDescription;	//18 May 2021	NDL	TFS 51183
					endif;
				endif;
				  sortedTIRequests.putAtKey(cargoTypeDescription,reserveDetail.isComplete,reserveDetail.getDescription, reserveDetail);
			endforeach;	
		endif;
	endif;
	
	if sortedTIRequests = null then
		iter:=bulkRelease.allReserveDetails.createIterator;
		currentCargoTypeDes:=null;		
	else
		iter:=sortedTIRequests.createIterator;
	endif;
	
	while iter.next(reserveDetail) do		
			if reserveDetail.isAllocationById then
				if sortedTIRequests &lt;&gt; null then
					iter.getCurrentKeys(cargoTypeDescription,isComplete,id);
					if currentCargoTypeDes &lt;&gt; cargoTypeDescription  then								
						prevCargoType := currentCargoType;	
						currentCargoType:=reserveDetail.getCargoType;
						cargoSubType:=reserveDetail.getMyProduct;
						if cargoSubType &lt;&gt; null then
							listObj := cargoSubType;
						else
							listObj:=currentCargoType;
						endif;
						
						create cmifDetails transient;
			
						cmifDetails.setFromReserveTI(reserveDetail.CM_ReserveTI);
					//	cmifDetails.setFromLoaderAgent(cmifMobile, reserveDetail.CM_ReserveTI, quantity, weight, currentTI);
						cmifDetails.updateFromLoaderAgent(cmifMobile, reserveDetail.CM_ReserveTI, quantity, weight, currentTI);	//18 Mar 2021	NDL	TFS 50940
												
						cmifGrouping.addDetailToHeader(cmifDetails);
						
						currentCargoTypeDes:=cargoTypeDescription;						
					else	
						cmifDetails.updateFromReserveTI(reserveDetail.CM_ReserveTI);	
						cmifDetails.updateFromLoaderAgent(cmifMobile, reserveDetail.CM_ReserveTI, quantity, weight, currentTI);
					endif;										
				endif;
			endif;
	endwhile;
epilog
	delete iter;
	delete sortedTIRequests;
end;</source>
        <Parameter name="bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="cmifGrouping" type="CMIF_ReserveTIGrouping" usage="io"/>
        <Parameter name="cmifMobile" type="CMIF_MobileGenericAgent"/>
        <Parameter name="quantity" type="Integer"/>
        <Parameter name="weight" type="Decimal"/>
        <Parameter name="currentTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateLoaded" id="15149209-4ae2-4c9a-af8e-b88066f878be">
        <source>validateLoaded(	firstRun 	: Boolean io;
				errorCodes 	: IntegerArray input;
				mess 		: String200Array input;
				mobileAgent : CMIF_MobileGenericAgent;
				currentTI	: CM_TrackedItem);
				
				
/*							
				
01 July 2020	NDL	TFS 49647 - No longer used, the subtle changes in this one were merged back into "validateReserveDetails"	
				
											
*/				
				
				
				
				
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 June 2019
TFS#		: 45162
Function	: This validates the Loaded Quantity (Released and Currently in the process of Releasing) 
			  versus the allowed quantity.

*** Changes ***
Date	Name	TFS#	Description
45162	jlgka1	45162	Change Warning code with Error Codes.
****************************************************/
vars

/*	sumOfTotalAllowed 	: Integer;
	sumOfTotalRelease 	: Integer;
	object 				: Object;
	cmifDetails 		: CMIF_ReserveTIDetail;
	totalRequested 		: Integer;
	totalRelease 		: Integer;
	totalAllowed 		: Integer;
	totalOnSiteNoWarn 	: Integer;
	totalOnsite 		: Integer;
	hasStops 			: Boolean;
	allHasStops 		: Boolean;
	tmpMess 			: String;
	allError 			: Boolean;
	tmpErrorCodes 		: IntegerArray;
	tmpErrMess 			: String200Array;
	tmpWarnCodes 		: IntegerArray;
	tmpWarnMess 		: String200Array;
	hasStopString 		: String;
	trackedItem 		: CM_TrackedItem;
	stops 				: String;
	row 				: Integer;
	tmpHolder 			: Integer;
	tmpHolderMess 		: String;	
	cargoType			: CM_CargoType;
	product				: CM_Product; */
begin

/*	allError := true;
	create tmpErrorCodes transient;
	create tmpErrMess transient;
	create tmpWarnCodes transient;
	create tmpWarnMess transient;

	if self.allDetails &lt;&gt; null then			
		sumOfTotalRelease := 0;
		sumOfTotalAllowed := 0;
		foreach object in self.allDetails do
			if object.isKindOf(CMIF_ReserveTIDetail) then
				cmifDetails 		:= object.CMIF_ReserveTIDetail;
				cargoType			:= cmifDetails.myCargoType;
				product				:= cmifDetails.myProduct;
				
				if currentTI.myProduct &lt;&gt; null then
					if product &lt;&gt; currentTI.myProduct then
						continue;
					endif;					
				else
					if cargoType &lt;&gt; currentTI.myCargoType then
						continue;
					endif;					
				endif;
				
				totalRequested		:= cmifDetails.totalRequested;
				totalRelease		:= cmifDetails.totalReleased + cmifDetails.totalReleasedFromAgent;
				totalAllowed		:= cmifDetails.totalAllowed;
				totalOnSiteNoWarn	:= cmifDetails.totalOnsiteWithoutStops;
				totalOnsite			:= cmifDetails.totalOnsite;
				sumOfTotalRelease	:= sumOfTotalRelease + cmifDetails.totalReleased + cmifDetails.totalReleasedFromAgent;
				sumOfTotalAllowed	:= sumOfTotalAllowed + cmifDetails.totalAllowed;
				if firstRun then							
					hasStops := cmifDetails.totalOnsite &lt;&gt; 0 and cmifDetails.totalOnsiteWithoutStops = 0;
					allHasStops := cmifDetails.totalOnsite &lt;&gt; 0 and cmifDetails.totalOnsiteWithoutStops = 0;							
				else
					hasStops := cmifDetails.totalOnsite &lt;&gt; 0 and cmifDetails.totalOnsiteWithoutStops = 0;
					if not hasStops and not firstRun then
						allHasStops := false;
					endif;
				endif;
			endif;
			
			if totalRelease &gt; totalAllowed then						
				if cmifDetails.myCargoType &lt;&gt; null then
					if cmifDetails.myCargoType.isSubCargoTypeRequired then
						if cmifDetails.myProduct &lt;&gt; null then
							tmpMess := app.getErrorString4(ErrorGreaterThanEqualAllowed, cmifDetails.myProduct.description, totalRelease.asStringJMT, cmifDetails.totalAllowed.asStringJMT, cmifDetails.myProduct.description);
						endif;
					else
						tmpMess := app.getErrorString4(ErrorGreaterThanEqualAllowed, cmifDetails.myCargoType.description, totalRelease.asStringJMT, cmifDetails.totalAllowed.asStringJMT, cmifDetails.myCargoType.description);
					endif;
				elseif cmifDetails.myProduct &lt;&gt; null then
					tmpMess := app.getErrorString4(ErrorGreaterThanEqualAllowed, cmifDetails.myProduct.description, totalRelease.asStringJMT, cmifDetails.totalAllowed.asStringJMT, cmifDetails.myProduct.description);
				endif;						
				errorCodes.add(ErrorGreaterThanEqualAllowed);	
				mess.add(tmpMess);							
			endif;
			
			if totalOnsite = 0 then
				if cmifDetails.myCargoType &lt;&gt; null then
					if cmifDetails.myCargoType.isSubCargoTypeRequired then
						if cmifDetails.myProduct &lt;&gt; null then
							tmpMess := app.getErrorString3(ErrorZeroOnsiteQuantity, cmifDetails.myProduct.description, cmifDetails.totalOnsite.asStringJMT, cmifDetails.myProduct.description);
						endif;
					else
						tmpMess := app.getErrorString3(ErrorZeroOnsiteQuantity, cmifDetails.myCargoType.description, cmifDetails.totalOnsite.asStringJMT, cmifDetails.myCargoType.description);
					endif;
				elseif cmifDetails.myProduct &lt;&gt; null then
					tmpMess := app.getErrorString3(ErrorZeroOnsiteQuantity, cmifDetails.myProduct.description, cmifDetails.totalOnsite.asStringJMT, cmifDetails.myProduct.description);
				endif;						
				errorCodes.add(ErrorZeroOnsiteQuantity);	
				mess.add(tmpMess);						
			endif;
			
			if (totalRelease + totalOnSiteNoWarn) &lt; totalAllowed and totalOnsite &lt;&gt; 0 then						
				if allError then							
					if cmifDetails.myCargoType &lt;&gt; null then
						if cmifDetails.myCargoType.isSubCargoTypeRequired then
							if cmifDetails.myProduct &lt;&gt; null then
								tmpMess := app.getErrorString4(ErrorLessThanAllowed, cmifDetails.myProduct.description, cmifDetails.totalReleased.asStringJMT, cmifDetails.totalAllowed.asStringJMT, cmifDetails.myProduct.description);
							endif;
						else
							tmpMess := app.getErrorString4(ErrorLessThanAllowed, cmifDetails.myCargoType.description, cmifDetails.totalReleased.asStringJMT, cmifDetails.totalAllowed.asStringJMT, cmifDetails.myCargoType.description);
						endif;
					elseif cmifDetails.myProduct &lt;&gt; null then
						tmpMess := app.getErrorString4(ErrorLessThanAllowed, cmifDetails.myProduct.description, cmifDetails.totalReleased.asStringJMT, cmifDetails.totalAllowed.asStringJMT, cmifDetails.myProduct.description);
					endif;
					tmpErrorCodes.add(ErrorLessThanAllowed);
					tmpErrMess.add(tmpMess);							
					
					// for in case not all got a stop
					if cmifDetails.myCargoType &lt;&gt; null then
						if cmifDetails.myCargoType.isSubCargoTypeRequired then
							if cmifDetails.myProduct &lt;&gt; null then
								tmpMess := app.getErrorString4(WarningLessThanAllowed, cmifDetails.myProduct.description, cmifDetails.totalReleased.asStringJMT, cmifDetails.totalAllowed.asStringJMT, cmifDetails.myProduct.description);
							endif;
						else
							tmpMess := app.getErrorString4(WarningLessThanAllowed, cmifDetails.myCargoType.description, cmifDetails.totalReleased.asStringJMT, cmifDetails.totalAllowed.asStringJMT, cmifDetails.myCargoType.description);
						endif;
					elseif cmifDetails.myProduct &lt;&gt; null then
						tmpMess := app.getErrorString4(WarningLessThanAllowed, cmifDetails.myProduct.description, cmifDetails.totalReleased.asStringJMT, cmifDetails.totalAllowed.asStringJMT, cmifDetails.myProduct.description);
					endif;
					tmpWarnCodes.add(WarningLessThanAllowed);
					tmpWarnMess.add(tmpMess);							
				else
					if cmifDetails.myCargoType &lt;&gt; null then
						if cmifDetails.myCargoType.isSubCargoTypeRequired then
							if cmifDetails.myProduct &lt;&gt; null then
								tmpMess := app.getErrorString4(WarningLessThanAllowed, cmifDetails.myProduct.description, cmifDetails.totalReleased.asStringJMT, cmifDetails.totalAllowed.asStringJMT, cmifDetails.myProduct.description);
							endif;
						else
							tmpMess := app.getErrorString4(WarningLessThanAllowed, cmifDetails.myCargoType.description, cmifDetails.totalReleased.asStringJMT, cmifDetails.totalAllowed.asStringJMT, cmifDetails.myCargoType.description);
						endif;
					elseif cmifDetails.myProduct &lt;&gt; null then
						tmpMess := app.getErrorString4(WarningLessThanAllowed, cmifDetails.myProduct.description, cmifDetails.totalReleased.asStringJMT, cmifDetails.totalAllowed.asStringJMT, cmifDetails.myProduct.description);
					endif;
					errorCodes.add(WarningLessThanAllowed);
					mess.add(tmpMess);
					allError := false;
				endif;						
			endif;
			if (totalRelease + totalOnSiteNoWarn) = totalAllowed then
				if cmifDetails.myCargoType &lt;&gt; null then
					if cmifDetails.myCargoType.isSubCargoTypeRequired then
						if cmifDetails.myProduct &lt;&gt; null then
							tmpMess := app.getErrorString2(WarningEqualAllowed, cmifDetails.myProduct.description, cmifDetails.totalOnsiteWithoutStops.asStringJMT);
						endif;
					else
						tmpMess := app.getErrorString2(WarningEqualAllowed, cmifDetails.myCargoType.description, cmifDetails.totalOnsiteWithoutStops.asStringJMT);
					endif;
				elseif cmifDetails.myProduct &lt;&gt; null then
					tmpMess := app.getErrorString2(WarningEqualAllowed, cmifDetails.myProduct.description, cmifDetails.totalOnsiteWithoutStops.asStringJMT);
				endif;
				errorCodes.add(WarningEqualAllowed);
				mess.add(tmpMess);
				allError := false;
			endif;
			firstRun := false;
		endforeach;	
		if allHasStops then								
			foreach object in self.allDetails do
				if object.isKindOf(CMIF_ReserveTIDetail) then
					cmifDetails	:= object.CMIF_ReserveTIDetail;
					if cmifDetails.myCargoType &lt;&gt; null then
						if hasStopString = null then
							hasStopString := cmifDetails.myCargoType.description;
						else
							hasStopString := hasStopString &amp; ", " &amp; cmifDetails.myCargoType.description;
						endif;
					elseif cmifDetails.myProduct &lt;&gt; null then
						if hasStopString = null then
							hasStopString := cmifDetails.myCargoType.description;
						else
							hasStopString := hasStopString &amp; ", " &amp; cmifDetails.myProduct.description;
						endif;
					endif;
					foreach trackedItem in cmifDetails.allTIs do
						if trackedItem.hasStops then
							stops := trackedItem.stopDesc(); // jlgka1 TFS 44334
						endif;				
						tmpMess := app.getErrorString2(ErrorRelResrvAllHasStops, trackedItem.id.asStringJMT, stops);
						errorCodes.add(ErrorRelResrvAllHasStops);	
						mess.add(tmpMess);
					endforeach;
				endif;	
			endforeach;		
			if hasStopString &lt;&gt; null then
				tmpMess := app.getErrorString1(Error_Display, " No " &amp; hasStopString &amp; " are available");
				errorCodes.add(Error_Display);	
				mess.add(tmpMess);
			endif;
		endif; 
		if allError then
			row := 1;
			foreach tmpHolder in tmpErrorCodes do
				errorCodes.add(tmpHolder);
				row := row + 1;
			endforeach;
			row := 1;
			foreach tmpHolderMess in tmpErrMess do
				mess.add(tmpHolderMess);
				row := row + 1;
			endforeach;							
		else// Add everything that fall into the warning
			row := 1;
			foreach tmpHolder in tmpWarnCodes do
				errorCodes.add(tmpHolder);
				row := row + 1;
			endforeach;
			row := 1;
			foreach tmpHolderMess in tmpWarnMess do
				mess.add(tmpHolderMess);
				row := row + 1;
			endforeach;							
		endif; 
	endif;
*/
epilog

/*	delete tmpErrorCodes;
	delete tmpErrMess;
	delete tmpWarnCodes;
	delete tmpWarnMess; */

end;</source>
        <Parameter name="firstRun" type="Boolean" usage="io"/>
        <Parameter name="errorCodes" type="IntegerArray" usage="input"/>
        <Parameter name="mess" type="String200Array" usage="input"/>
        <Parameter name="mobileAgent" type="CMIF_MobileGenericAgent"/>
        <Parameter name="currentTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateReserveTIs" id="4f541c81-4fba-4797-8afb-869089373b11">
        <source>validateReserveTIs(	_errorCodes : IntegerArray input;
					_mess : String200Array input;
					_currentTI	: CM_TrackedItem
					);
/*

Purpose:			

Parameters:			If _currentTI is supplied we are checking via the hand held and check total released AND loaded for release

Return Value:		

Date		Who		Reason
18 June 2019	jlgndl1	Initial creation - migrated from CM_VehicleVisitRecord::validateReserveTI
30 Jun 2020		NDL		Rewrite to meet original requirements of tech spec - I.e. Message can be errors, Warnings or Informational,
						and consolidated the extra copy with a subtle changes (validateLoaded) into one method
07 Jan 2020		NDL		TFS 50581 - 1035 error

*/

vars

	object : Object;
	cmifDetails : CMIF_ReserveTIDetail;
	totalRequested : Integer;
	totalReleased : Integer;
	totalAllowed : Integer;
	totalOnsiteWithoutStops : Integer;
	totalOnsite : Integer;
	hasStops : Boolean;
	allHasStops : Boolean;
	tmpMess : String;
	allError : Boolean;
	tmpErrorCodes : IntegerArray;
	tmpErrMess : String200Array;
	hasStopString : String;
	trackedItem : CM_TrackedItem;
	stops : String;
	tmpHolder : Integer;
	tmpHolderMess : String;
	
	cmifCargoProdStr : String;
	index : Integer;
	hasErrors : BooleanArray;
	noError : Boolean;
	cargoType : CM_CargoType;
	product : CM_Product;
	

begin

	//If all of the items have errors (i.e. none can be processed), we want to show the reasons as errors
	//But if any of the items can be processed, we only want warnings, because otherwise the user wont be able to save, but we do want to show the errors (just as warnings), so they know what to choose.
	//So we need two passes.  The first to decide whether we have any errors, and if so have all items got errors or are there some we could process.
	
	if self.allDetails = null then
		return;
	endif;
	
	//Pass One - just looking to see if we have anything that we can really do, i.e. capture which ones have errors.
	index := 0;
	create hasErrors transient;
	app.writeLog(method.qualifiedName &amp; Tab &amp; "self.allDetails has " &amp; self.allDetails.size.String &amp; " entries", LogINFO);
	foreach object in self.allDetails do
		if object.isKindOf(CMIF_ReserveTIDetail) then
			cmifDetails := object.CMIF_ReserveTIDetail;
			totalReleased := cmifDetails.totalReleased;
			totalAllowed := cmifDetails.totalAllowed;
			totalOnsiteWithoutStops	:= cmifDetails.totalOnsiteWithoutStops;
			app.writeLog(method.qualifiedName &amp; Tab &amp; "totalReleased is " &amp; totalReleased.String &amp; " , totalAllowed is " &amp; totalAllowed.String &amp; ", totalOnsiteWithoutStops is " &amp; totalOnsiteWithoutStops.String, LogINFO);
			if _currentTI &lt;&gt; null then
				app.writeLog(method.qualifiedName &amp; Tab &amp; "_currentTI &lt;&gt; null", LogINFO);
				cargoType := cmifDetails.myCargoType;
				product := cmifDetails.myProduct;
				if _currentTI.myProduct &lt;&gt; null then
					if product &lt;&gt; _currentTI.myProduct then
						continue;
					endif;					
				else
					if cargoType &lt;&gt; _currentTI.myCargoType then
						continue;
					endif;					
				endif;
				totalReleased := cmifDetails.totalReleased + cmifDetails.totalReleasedFromAgent;
				app.writeLog(method.qualifiedName &amp; Tab &amp; "totalReleased is cmifDetails.totalReleased + cmifDetails.totalReleasedFromAgent - " &amp; cmifDetails.totalReleased.String &amp; " + " &amp; cmifDetails.totalReleasedFromAgent.String &amp; " - which is " &amp; totalReleased.String, LogINFO);
			endif;
		
		else
			continue;
			
		endif;
		
		index := index + 1;

	//	if totalReleased &gt;= totalAllowed then	//fully released
		if totalAllowed &gt; 0 and totalReleased &gt;= totalAllowed then	//fully released
			app.writeLog(method.qualifiedName &amp; Tab &amp; "totalAllowed &gt; 0 and totalReleased &gt;= totalAllowed :1 - set hasErrors[index] true where index is " &amp; index.String, LogINFO);
			hasErrors[index] := true;
		elseif totalOnsiteWithoutStops = 0 then	//no more to select
			app.writeLog(method.qualifiedName &amp; Tab &amp; "totalOnsiteWithoutStops = 0 :1 - set hasErrors[index] true where index is " &amp; index.String, LogINFO);
			hasErrors[index] := true;
		else
			hasErrors[index] := false;
		endif;
		
	endforeach;	
	
	//Pass Two
	create tmpErrorCodes transient;
	create tmpErrMess transient;

	allHasStops := true; // default position.
	allError := hasErrors.allValuesAre( true );
	noError := hasErrors.allValuesAre( false );
	
	if self.allDetails &lt;&gt; null then			
		
		foreach object in self.allDetails do
			if object.isKindOf(CMIF_ReserveTIDetail) then
				cmifDetails 		:= object.CMIF_ReserveTIDetail;
				totalRequested		:= cmifDetails.totalRequested;
				totalReleased		:= cmifDetails.totalReleased;
				totalAllowed		:= cmifDetails.totalAllowed;
				totalOnsiteWithoutStops	:= cmifDetails.totalOnsiteWithoutStops;
				totalOnsite			:= cmifDetails.totalOnsite;
				if _currentTI &lt;&gt; null then
					cargoType := cmifDetails.myCargoType;
					product := cmifDetails.myProduct;
					if _currentTI.myProduct &lt;&gt; null then
						if product &lt;&gt; _currentTI.myProduct then
							continue;
						endif;					
					else
						if cargoType &lt;&gt; _currentTI.myCargoType then
							continue;
						endif;					
					endif;
					totalReleased := cmifDetails.totalReleased + cmifDetails.totalReleasedFromAgent;
				endif;
			
				hasStops := totalOnsite &lt;&gt; 0 and totalOnsiteWithoutStops = 0;
				if not hasStops then
					allHasStops := false;
				endif;
			else
				continue;
			endif;
			
			//30 Jun 2020	NDL	TFS 49647 - get the description to use for messages
			if cmifDetails.myCargoType &lt;&gt; null then
				cmifCargoProdStr := cmifDetails.myCargoType.description;
				if cmifDetails.myCargoType.isSubCargoTypeRequired and cmifDetails.myProduct &lt;&gt; null then
					cmifCargoProdStr := cmifDetails.myProduct.description;
				endif;
			elseif cmifDetails.myProduct &lt;&gt; null then
				cmifCargoProdStr := cmifDetails.myProduct.description;
			endif;	

			// If the total amount released is equal to (or more than the amount allowed) add a messages
	//		if totalReleased &gt;= totalAllowed then
			if totalReleased &gt; totalAllowed then	//12 Feb 2021	NDL	TFS 50789
				app.writeLog(method.qualifiedName &amp; Tab &amp; "totalReleased &gt; totalAllowed - setting tmpErrorCodes", LogINFO);
				tmpMess := app.getErrorString4(WarningGreaterThanEqualAllowed, cmifCargoProdStr, totalReleased.asStringJMT, totalAllowed.asStringJMT, cmifCargoProdStr);
				tmpErrorCodes.add(WarningGreaterThanEqualAllowed);	
				tmpErrMess.addTruncated(tmpMess);
			endif;
			
			// None onsite, add a messages
			if totalOnsiteWithoutStops = 0 then
				tmpMess := app.getErrorString3(ErrorZeroOnsiteQuantity, cmifCargoProdStr, totalOnsite.asStringJMT, cmifCargoProdStr);
				tmpErrorCodes.add(ErrorZeroOnsiteQuantity);	
				tmpErrMess.addTruncated(tmpMess);						
			endif;
			
			if not allError and not noError then
				// We have some, but less than they are allowed add a message
				if (totalReleased + totalOnsiteWithoutStops) &lt; totalAllowed and totalOnsite &lt;&gt; 0 then													
					tmpMess := app.getErrorString4(ErrorLessThanAllowed, cmifCargoProdStr, totalReleased.asStringJMT, totalAllowed.asStringJMT, totalOnsite.asStringJMT);
					tmpErrorCodes.add(ErrorLessThanAllowed);
					tmpErrMess.addTruncated(tmpMess);													
				endif;
				
				//We have the exact amount onsite without stops to meet the total allowed add a messages
				if (totalReleased + totalOnsiteWithoutStops) = totalAllowed then
					tmpMess := app.getErrorString2(WarningEqualAllowed, cmifCargoProdStr, totalOnsiteWithoutStops.asStringJMT);
					tmpErrorCodes.add(WarningEqualAllowed);
					tmpErrMess.addTruncated(tmpMess);
				endif;
			endif;
				
		endforeach;	
		
		if allHasStops then								
			foreach object in self.allDetails do
				if object.isKindOf(CMIF_ReserveTIDetail) then
					cmifDetails	:= object.CMIF_ReserveTIDetail;
					if cmifDetails.myCargoType &lt;&gt; null then
						if hasStopString = null then
							hasStopString := cmifDetails.myCargoType.description;
						else
							hasStopString := hasStopString &amp; ", " &amp; cmifDetails.myCargoType.description;
						endif;
					elseif cmifDetails.myProduct &lt;&gt; null then
						if hasStopString = null then
							hasStopString := cmifDetails.myCargoType.description;
						else
							hasStopString := hasStopString &amp; ", " &amp; cmifDetails.myProduct.description;
						endif;
					endif;
					foreach trackedItem in cmifDetails.allTIs do
						if trackedItem.hasStops then
							stops := trackedItem.stopDesc(); // jlgka1 TFS 44334
						endif;				
						tmpMess := app.getErrorString2(ErrorRelResrvAllHasStops, trackedItem.id.asStringJMT, stops);
						tmpErrorCodes.add(ErrorRelResrvAllHasStops);	
						tmpErrMess.addTruncated(tmpMess);
					endforeach;
				endif;	
			endforeach;		
			if hasStopString &lt;&gt; null then
				tmpMess := app.getErrorString1(Error_Display, " No " &amp; hasStopString &amp; " are available");
				tmpErrorCodes.add(Error_Display);	
				tmpErrMess.addTruncated(tmpMess);
			endif;
		endif; 
		
		//Add the errors or warnings as appropriate
		foreach tmpHolder in tmpErrorCodes do
			_errorCodes.add(tmpHolder);
		endforeach;
		foreach tmpHolderMess in tmpErrMess do
			if allError then
				if tmpHolderMess[2:5] = "Error" or tmpHolderMess[1:5] = "Error" then
					_mess.add(tmpHolderMess);
				else
					_mess.add( app.getErrorString1(Error_Display, tmpHolderMess) );
				endif;
			else
				_mess.add(tmpHolderMess);
			endif;
		endforeach;							
		
	endif;

epilog

	delete tmpErrorCodes;
	delete tmpErrMess;
	delete hasErrors;

end;</source>
        <Parameter name="_errorCodes" type="IntegerArray" usage="input"/>
        <Parameter name="_mess" type="String200Array" usage="input"/>
        <Parameter name="_currentTI" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
