    <JadeMethod name="sysNotify" id="53c307a4-51c0-4df0-92d3-9b9235fbf2a7">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*****************************************************
	Written by	:	cnwgrp1		18 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	txtSearchName.text := null;
	tblSearchResults.rows := tblSearchResults.fixedRows;
	loadSearchResults(blnAll);

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblSearchResults_click" id="230a895f-92bd-45c9-a458-179a9e447e5f">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSearchResults_click(table: Table input) updating;

/*****************************************************
	Written by	:	cnwgrp1:2		05 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
		btnUpdate.enabled := tblSearchResults.row &gt; tblSearchResults.fixedRows;
		btnDelete.enabled := tblSearchResults.row &gt; tblSearchResults.fixedRows;
		btnExtract.enabled := tblSearchResults.row &gt; tblSearchResults.fixedRows;
		
		btnNew.enabled := not blnAll;
		if myDA.myAssociatedObject = null then
			btnNew.enabled := tblSearchResults.row &gt; tblSearchResults.fixedRows;
		endif;
		
		if tblSearchResults.row &gt; tblSearchResults.fixedRows then
			tblSearchResults.clearAllSelected;
			tblSearchResults.accessRow(tblSearchResults.row).selected := true;
		else
			tblSearchResults.clearAllSelected;	
		endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
