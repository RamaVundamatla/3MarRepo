    <JadeMethod name="mnuFindErrorName_click" id="7e57a0d7-ec34-4bec-a86d-11e2fdd657c7">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFindErrorName_click(menuItem: MenuItem input) updating;
//11 February 2011	cnwdw1	
//
vars
	errorNumber: String;
	category	: ConstantCategory;
	constant	: Constant;
	value		: Integer;

begin

	errorNumber := "Enter Error Number";
	read errorNumber;

	value := errorNumber.Integer;
	if value &gt; 0 then
		category := currentSchema.getCategory(XLAT_Exceptions);		
		
		foreach constant in category.getConstants do
			if constant.valueAsInteger = value then
				app.copyStringToClipboard(constant.name);
				app.msgBox(constant.name &amp; " " &amp; constant.text &amp; CrLf &amp; CrLf &amp; "Name has been copied to clipboard", "Find Error Name", MB_OK);
				return;
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
