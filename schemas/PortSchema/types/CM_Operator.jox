    <JadeMethod name="getNextStockOrderSeqNumber" id="2ead949c-5028-4480-8e70-5d70c3a53eea">
        <source>getNextStockOrderSeqNumber(_term : CM_Terminal) : String;
//--------------------------------------------------
// Created:	28 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	orderNo : String;
begin
	if _term = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Terminal');
		return null;
	endif;
	
	//PAR 9659 duplicate order number error
	//This shouldn't happen but they may change the terminal code to one that has already been used.
	//Added as a double check
	
	while true do
		orderNo := _term.stockOrderNextSeqNumber;
		if (not self.allStockOrderHeaders.includesKey(orderNo)) then
			break;
		endif;
	endwhile;
	
	return orderNo;
	
end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOperatorGroupIfOnlyOne" id="a3b7f6b3-7a89-474b-9e89-007e93dfdc8a">
