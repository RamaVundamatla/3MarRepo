<Class name="BGP_KPISpaceUtilisationRequest" id="f7f5104d-f214-48a6-b0a6-a22bc6bd486b">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;KPI Space Utilisation&lt;/display&gt;</text>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="allQryCargoTypes" id="ed2e65f7-088f-4e4b-8d13-ed2e69db842b">
        <memberTypeInverse/>
        <type name="CM_CargoTypesByIdDict"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allQryTerminalAreas" id="d12c241d-b875-4c14-af73-b1d6e9940037">
        <memberTypeInverse/>
        <type name="CM_TerminalAreaMasterSet"/>
    </ImplicitInverseRef>
    <JadeMethod name="action" id="c0b34a74-1604-4ee7-883b-fa5d0484fc8d">
        <updating/>
        <source>action(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	anAgent : CM_KPISpaceUtilisationAgent;
	errCode	: Integer;
	errTxt	: String;
	msg : String;
begin
//app.createAlert(class.name &amp; '::' &amp; method.name &amp;  ' 1. ' , true);
	on Exception do app.alertExceptionHandler(exception, null,  self.getErrorDesc(),errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	msg := 'Processing';
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	self.setUser();
	
	create anAgent transient;
	anAgent.initialise(self.myTerminal,app.myPassport, self.allQryTerminalAreas, self.allQryCargoTypes);
	anAgent.runProcess();

epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	else
		app.createActivityHistory(ActivityHistoryGeneral, self.myTerminal, null, "Successful KPI Space Utilisation Update", false, false);
	endif;
	inheritMethod();
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="0da046e8-e376-4008-9af2-cfdae87d7d8b">
        <source>getDisplay(): String;

// cnwdvb1 28 March 2003 

vars

	str, detail : String;

begin

	str := inheritMethod();
	detail := 'KPI Space Utilisation ';
	return str &amp; Tab &amp; detail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="f85856b0-743f-4525-99d4-e9d86535d7cd">
        <updating/>
        <source>initRequestFromTask(_task : CM_AutoTaskKPISpaceUtilisation) updating;
// ---------------------------------------------------------------------------
// Created:		January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	user : CM_User;

begin

	user := _task.myUser;
	if global.isValidObject(user) then
		self.myUser	:= user;
	endif;
	self.myTerminal	:= _task.myTerminal;	
	_task.allQryCargoTypes.copy(self.allQryCargoTypes);
	_task.allQryTerminalAreas.copy(self.allQryTerminalAreas);
	self.initRequestEvent(true, false, _task);


end;</source>
        <Parameter name="_task" type="CM_AutoTaskKPISpaceUtilisation"/>
    </JadeMethod>
</Class>
