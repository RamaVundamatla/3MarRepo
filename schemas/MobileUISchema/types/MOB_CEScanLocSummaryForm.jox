        <source>doClearTable(_confirm: Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 May 2009	#cnwdz2	ccms1801

*/

vars

begin
	if _confirm then
		self.loadCount := 0;
		self.allLocations.clear(); //23/06/2009 cnwdz2 19969
		self.txt_OrderCount.text := self.getLoadCountAsString();//09/06/2009 cnwdz2 par19867
		self.tbl_Items.rows := 1;
	endif;
epilog

end;</source>
