/*

Purpose:			Dummy method for 070 patch as filterObjects was renamed -&gt; filterVoyageLoadObjects
					after 070 cut...
Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2019	jlgsl4	TFS 46513 - ASPA - Load/Unload Summary Report errors
*/

vars

begin
	inheritMethod(_collection, _passport);
epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
