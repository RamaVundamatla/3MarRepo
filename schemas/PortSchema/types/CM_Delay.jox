epilog

end;</source>
        <ReturnType type="Integer64"/>
    </JadeMethod>
    <JadeMethod name="getDelayLengthDesc" id="a9cbf728-9869-4598-b8a1-329a0f6debf7">
        <source>getDelayLengthDesc() : String;
// ---------------------------------------------------------------------------
// Created:		30 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	posNeg, numOfDays, mins, millis : Integer;
	tmpStr : String;
	a,b : TimeStamp;
	tmpTime : Time;
begin
	a := self.startDT;
	b := self.getEndDT();
	tmpTime := a.differenceAsTime(b,posNeg, numOfDays);
	mins := (tmpTime.hour * 60 + tmpTime.minute ) * 60; 
	
	tmpStr := mins.getHMS();
	numOfDays := numOfDays - posNeg;
	if numOfDays &gt; 0 then
		tmpStr := numOfDays.String &amp; "d " &amp; tmpStr;
	endif;
	
	return tmpStr; 
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
