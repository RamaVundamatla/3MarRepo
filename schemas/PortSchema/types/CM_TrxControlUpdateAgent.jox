    <JadeMethod name="trxUpdateOwnershipChangeDtls" id="c0e64404-9883-4058-99ff-8189d4d45131">
        <updating/>
        <source>trxUpdateOwnershipChangeDtls(_cmifOwnershipChangeDtl : CMIF_OwnershipChangeDetail io;
						_passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 June 2023 navtnr20    TFS CR 58507    Task 58210: Jade - TRX CM_OwnershipChangeDetail

*/

vars
	pxyOwnershipChangeDetail, realDetail: CM_OwnershipChangeDetail;
begin
	//Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;
	
	foreach pxyOwnershipChangeDetail in _cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails do
		// ### TFS CR 58230 TASK 58232 26JUL2023 NAVAB1
		if pxyOwnershipChangeDetail.pxyIsProxy() then 
			app.myUtilityUA.utlUpdateOwnershipChangeDetail(pxyOwnershipChangeDetail, _passport);
		else
			app.myUtilityCA.utlCreateOwnershipChangeDetail(pxyOwnershipChangeDetail, realDetail,_passport);
			if realDetail &lt;&gt; null then			//20.07.2024 navrv30 Bug 64858
				_cmifOwnershipChangeDtl.allRealOwnershipChangeDtls.add(realDetail);
			endif;
		endif;
		if _passport.hasErrorsOrWarnings() then
			return;
		endif;
	endforeach;
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_cmifOwnershipChangeDtl" type="CMIF_OwnershipChangeDetail" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
