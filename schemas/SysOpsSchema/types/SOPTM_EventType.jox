//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.name := SOP_TableMaintForm.Table_EventType;
	self.permissionView	 := PmAdmEventTypeView;
	self.permissionMaint := PmAdmEventTypeMaint;
