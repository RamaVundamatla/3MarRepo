    <JadeMethod name="createPropertyChanges" id="935bc4e0-414e-4733-bc8a-1876bbd6f9dd">
        <updating/>
        <source>createPropertyChanges(_cmifTrans: CMIF_HMS_TransactionController) updating, protected;
//--------------------------------------------------
// Created:	20 January 2005 By: cnwgd1
//--------------------------------------------------
vars
 	propertyChange : HMS_PropertyChange;
begin
	inheritMethod(_cmifTrans);
	// This method creates a 'VoyageDeleted' transaction for a voyage which has been deleted from the database
	create propertyChange;
	propertyChange.set(self, "Voyage Deleted", null, null);

end;</source>
        <access>protected</access>
        <Parameter name="_cmifTrans" type="CMIF_HMS_TransactionController"/>
    </JadeMethod>
    <JadeMethod name="getArrivalDTLocalTZ" id="185fd335-556b-43e7-8d32-cb32d017195f">
        <source>getArrivalDTLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.arrivalDT);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDepartureDTLocalTZ" id="86a9917f-7ab8-489d-915d-d53790fe6ce4">
        <source>getDepartureDTLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.departureDT);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="4ae19a8d-dbdb-4be2-92f5-f38fc48a47fb">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	20 January 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _attrName = ETRow_VesselName then
		return self.vesselName &amp; ' (' &amp; self.vesselCode &amp; ')';
	elseif _attrName = ETRow_MyHMSVoyageData then
		return self.vesselName &amp; ' (' &amp; self.voyageCode &amp; ')';
	elseif _attrName = ETRow_MoveType then
		return null;
	elseif _attrName = ETRow_OccursOnDT then
		return self.systemToLocalTime(self.arrivalDT).shortCurrentLocaleFormat() &amp; ' Departing ' &amp; self.systemToLocalTime(self.departureDT).shortCurrentLocaleFormat();	// 24/5/16 cnwmp6 TFS 488 - Multi timezone support
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setGeneralProperties" id="1775386f-2352-4000-91a3-e0d0dd3e280d">
        <updating/>
        <source>setGeneralProperties(_transController: CMIF_HMS_TransactionController; _passport: CM_Passport input) updating, protected;
//--------------------------------------------------
// Created:	20 January 2005 By: cnwgd1
//--------------------------------------------------
vars
	workingVoyage : CMIF_HMS_WorkingVoyage;
	tmpVoyageData : HMS_VoyageData;
begin
	inheritMethod(_transController, _passport);
	tmpVoyageData := _transController.myHMSVoyageData;

	if tmpVoyageData = null then
		return;
	endif;
	
	self.vesselCode := tmpVoyageData.vesselCode;
	self.vesselName := tmpVoyageData.vesselName;

	if tmpVoyageData.myVoyage &lt;&gt; null then
		// should not be null but check anyway 
		self.voyageCode := tmpVoyageData.myVoyage.code;		
		self.arrivalDT := tmpVoyageData.myVoyage.arrivedDT;
		self.departureDT := tmpVoyageData.myVoyage.departedDT;
	endif;
	
	// Exception to the rule
	// Voyage will be deleted from the database
	// so null out refs otherwise this transaction will be deleted along with it
	self.myHMSVoyageData := null; 
	self.myMovement := null;
	
end;</source>
        <access>protected</access>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTypeDetails" id="8b613068-23e2-4c97-8ec7-ea94d01b0819">
        <updating/>
        <source>setTypeDetails() updating, protected;
//--------------------------------------------------
// Created:	20 January 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
  	// Set type and typeString
	self.type := TRANS_TYPE_HMSVoyageDeleted;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validate" id="5f0d282e-2aae-41e5-9348-b600219946cc">
        <source>validate(_transController: CMIF_HMS_TransactionController): Boolean;
//--------------------------------------------------
// Created:	20 January 2005 By: cnwgd1
//--------------------------------------------------
vars
	rtnValue : Boolean;
begin
	rtnValue := inheritMethod(_transController);
	if (not rtnValue) then
		return rtnValue;
	endif;
	
	if _transController.myHMSVoyageData = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'HMS Voyage', 'Null', null, null);
		return false;
	endif;

	return rtnValue;

end;</source>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
