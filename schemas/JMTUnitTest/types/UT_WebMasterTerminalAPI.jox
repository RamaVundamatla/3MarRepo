    <JadeMethod name="uRegexMatchingInvalidDate" id="393d3c1a-ca72-4d5d-b663-96ae95b6f5bf">
        <updating/>
        <source>uRegexMatchingInvalidDate() updating;
/*

Purpose:			

Parameters:		 To check the regex pattern	

Return Value:		

Date		Who		Reason
17 March 2025	navsp1	Initial creation JIRA-23126

*/
constants
	JsonWithLeadingComma  = '{"estimatedArrivalDT":"\/Date(-62135596800000)\/","estimatedDepartureDT":"\/Date(-62135596800000)\/","allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"arrivalDT":"2024-11-01T01:26:00:000Z","cargoSummary":null,"departureDT":"2024-12-28T11:00:00:000Z","externalCode":"194N","id":"VOYSP888","inwardsCode":"194S","operatorId":"APL","portRotation":[{"id":"AUBNE","tranship":false},{"id":"AUPKL","tranship":false},{"id":"KRINC","tranship":false},{"id":"KRPUS","tranship":false},{"id":"CNSHA","tranship":false},{"id":"CNRZH","tranship":false},{"id":"NZPOE","tranship":false},{"id":"AUSYD","tranship":false},{"id":"SGSIN","tranship":false},{"id":"THLCH","tranship":false},{"id":"AEJEA","tranship":false},{"id":"THBKK","tranship":false},{"id":"JPUKB","tranship":false},{"id":"KRMAS","tranship":false}],"remarks":"","shippingLineId":"APL","status":112,"tradeId":"AAL Shipping","vessel":{"callSign":"","id":"VESSP888","imo":"","loa":0,"name":"VESSP888","operatorId":"APL"},"voyageType":{"holds":true,"lolo":false,"roro":false}';
	
	JsonWithLeadingCommaExpectedResult  = '{"allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"arrivalDT":"2024-11-01T01:26:00:000Z","cargoSummary":null,"departureDT":"2024-12-28T11:00:00:000Z","externalCode":"194N","id":"VOYSP888","inwardsCode":"194S","operatorId":"APL","portRotation":[{"id":"AUBNE","tranship":false},{"id":"AUPKL","tranship":false},{"id":"KRINC","tranship":false},{"id":"KRPUS","tranship":false},{"id":"CNSHA","tranship":false},{"id":"CNRZH","tranship":false},{"id":"NZPOE","tranship":false},{"id":"AUSYD","tranship":false},{"id":"SGSIN","tranship":false},{"id":"THLCH","tranship":false},{"id":"AEJEA","tranship":false},{"id":"THBKK","tranship":false},{"id":"JPUKB","tranship":false},{"id":"KRMAS","tranship":false}],"remarks":"","shippingLineId":"APL","status":112,"tradeId":"AAL Shipping","vessel":{"callSign":"","id":"VESSP888","imo":"","loa":0,"name":"VESSP888","operatorId":"APL"},"voyageType":{"holds":true,"lolo":false,"roro":false}';
	
	JsonWithTrailingComma  = '{"allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"arrivalDT":"2024-11-01T01:26:00:000Z","cargoSummary":null,"departureDT":"2024-12-28T11:00:00:000Z","externalCode":"194N","id":"VOYSP888","inwardsCode":"194S","operatorId":"APL","portRotation":[{"id":"AUBNE","tranship":false},{"id":"AUPKL","tranship":false},{"id":"KRINC","tranship":false},{"id":"KRPUS","tranship":false},{"id":"CNSHA","tranship":false},{"id":"CNRZH","tranship":false},{"id":"NZPOE","tranship":false},{"id":"AUSYD","tranship":false},{"id":"SGSIN","tranship":false},{"id":"THLCH","tranship":false},{"id":"AEJEA","tranship":false},{"id":"THBKK","tranship":false},{"id":"JPUKB","tranship":false},{"id":"KRMAS","tranship":false}],"remarks":"","shippingLineId":"APL","status":112,"tradeId":"AAL Shipping","vessel":{"callSign":"","id":"VESSP888","imo":"","loa":0,"name":"VESSP888","operatorId":"APL"},"voyageType":{"holds":true,"lolo":false,"roro":false},"estimatedArrivalDT":"\/Date(-62135596800000)\/","estimatedDepartureDT":"\/Date(-62135596800000)\/"}"';
	
	JsonWithTrailingCommaExpectedResult  = '{"allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"arrivalDT":"2024-11-01T01:26:00:000Z","cargoSummary":null,"departureDT":"2024-12-28T11:00:00:000Z","externalCode":"194N","id":"VOYSP888","inwardsCode":"194S","operatorId":"APL","portRotation":[{"id":"AUBNE","tranship":false},{"id":"AUPKL","tranship":false},{"id":"KRINC","tranship":false},{"id":"KRPUS","tranship":false},{"id":"CNSHA","tranship":false},{"id":"CNRZH","tranship":false},{"id":"NZPOE","tranship":false},{"id":"AUSYD","tranship":false},{"id":"SGSIN","tranship":false},{"id":"THLCH","tranship":false},{"id":"AEJEA","tranship":false},{"id":"THBKK","tranship":false},{"id":"JPUKB","tranship":false},{"id":"KRMAS","tranship":false}],"remarks":"","shippingLineId":"APL","status":112,"tradeId":"AAL Shipping","vessel":{"callSign":"","id":"VESSP888","imo":"","loa":0,"name":"VESSP888","operatorId":"APL"},"voyageType":{"holds":true,"lolo":false,"roro":false}}"';
	JsonWithMiddleComma = '{"allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"arrivalDT":"2024-11-01T01:26:00:000Z","cargoSummary":null,"departureDT":"2024-12-28T11:00:00:000Z","estimatedArrivalDT":"\/Date(-62135596800000)\/","estimatedDepartureDT":"\/Date(-62135596800000)\/","externalCode":"194N","id":"VOYSP888","inwardsCode":"194S","operatorId":"APL","portRotation":[{"id":"AUBNE","tranship":false},{"id":"AUPKL","tranship":false},{"id":"KRINC","tranship":false},{"id":"KRPUS","tranship":false},{"id":"CNSHA","tranship":false},{"id":"CNRZH","tranship":false},{"id":"NZPOE","tranship":false},{"id":"AUSYD","tranship":false},{"id":"SGSIN","tranship":false},{"id":"THLCH","tranship":false},{"id":"AEJEA","tranship":false},{"id":"THBKK","tranship":false},{"id":"JPUKB","tranship":false},{"id":"KRMAS","tranship":false}],"remarks":"","shippingLineId":"APL","status":112,"tradeId":"AAL Shipping","vessel":{"callSign":"","id":"VESSP888","imo":"","loa":0,"name":"VESSP888","operatorId":"APL"},"voyageType":{"holds":true,"lolo":false,"roro":false}}"';
	
	JsonWithMiddleCommaExpectedResult = '{"allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"arrivalDT":"2024-11-01T01:26:00:000Z","cargoSummary":null,"departureDT":"2024-12-28T11:00:00:000Z","externalCode":"194N","id":"VOYSP888","inwardsCode":"194S","operatorId":"APL","portRotation":[{"id":"AUBNE","tranship":false},{"id":"AUPKL","tranship":false},{"id":"KRINC","tranship":false},{"id":"KRPUS","tranship":false},{"id":"CNSHA","tranship":false},{"id":"CNRZH","tranship":false},{"id":"NZPOE","tranship":false},{"id":"AUSYD","tranship":false},{"id":"SGSIN","tranship":false},{"id":"THLCH","tranship":false},{"id":"AEJEA","tranship":false},{"id":"THBKK","tranship":false},{"id":"JPUKB","tranship":false},{"id":"KRMAS","tranship":false}],"remarks":"","shippingLineId":"APL","status":112,"tradeId":"AAL Shipping","vessel":{"callSign":"","id":"VESSP888","imo":"","loa":0,"name":"VESSP888","operatorId":"APL"},"voyageType":{"holds":true,"lolo":false,"roro":false}}"';
	
	MultiLineString = '[
    {
        "datetime": "\/Date(-62135596800000)\/",
        "source": "Master Terminal",
        "environment": "penUjmt",
        "terminal": "2351.1",
        "terminalCode": "PTI",
        "type": "Event",
        "subtype": "Truck Departure",
        "replayIdentifier": "",
        "body": {
            "oid": "12768.3504676",
            "class": "CMEVT_TruckEvent",
            "amount": 0.0000,
            "createdTime": "-4713-11-23T12:00:00:000Z",
            "dateTime": "2023-11-01T15:38:32.161Z",
            "edition": 1,
            "getDescription": "Truck has departed the terminal (GEL639)",
            "getEndTS": "\/Date(-62135596800000)\/",
            "getOperator": null,
            "getTrackedItem": null,
            "getTrain": null,
            "getVehicleVisit": "3100.1040792",
            "getVoyage": null,
            "getWagon": null,
            "myEventType": "2553.34",
            "mySnapShot": null,
            "myTerminal": "2351.1",
            "noCharge": false,
            "remarks": null,
            "userCode": "SUPERUSER",
			"someOtherMadeUpDTAtTheEnd": "-4713-11-23T12:00:00:000Z"
        }
    }
]';
	MultiLineStringExpectedResult = '[
    {
        "source": "Master Terminal",
        "environment": "penUjmt",
        "terminal": "2351.1",
        "terminalCode": "PTI",
        "type": "Event",
        "subtype": "Truck Departure",
        "replayIdentifier": "",
        "body": {
            "oid": "12768.3504676",
            "class": "CMEVT_TruckEvent",
            "amount": 0.0000,
            "dateTime": "2023-11-01T15:38:32.161Z",
            "edition": 1,
            "getDescription": "Truck has departed the terminal (GEL639)",
            "getOperator": null,
            "getTrackedItem": null,
            "getTrain": null,
            "getVehicleVisit": "3100.1040792",
            "getVoyage": null,
            "getWagon": null,
            "myEventType": "2553.34",
            "mySnapShot": null,
            "myTerminal": "2351.1",
            "noCharge": false,
            "remarks": null,
            "userCode": "SUPERUSER"
        }
    }
]';
	vars
	jsonStr : String;
	regex : CMIF_RegexPattern;
begin
	
	//regex := create CMIF_RegexPattern('(^\s*\"\w+\"\:[ ]*(?:\"\\\/Date\(\-62135596800000\)\\\/\"|\"-4713-11-23T12:00:00:000Z\"),?\s*|,\s*\"\w+\"\:[ ]*(?:\"\\\/Date\(\-62135596800000\)\\\/\"|\"-4713-11-23T12:00:00:000Z\")\s*|^\s*\"\w+\"\:[ ]*(?:\"\\\/Date\(\-62135596800000\)\\\/\"|\"-4713-11-23T12:00:00:000Z\")\s*)', '', true);
	regex := create CMIF_RegexPattern('(,)*\s*\"\w+\"\:[ ]*(?:\"\\\/Date\(\-62135596800000\)\\\/\"|\"-4713-11-23T12:00:00:000Z\")(?(1)|,)', '', true);
	
	
	//Check JSON with leading comma
	jsonStr := JsonWithLeadingComma;


	regex.replaceAll(jsonStr);
	self.assertEqualMsg(jsonStr, JsonWithLeadingCommaExpectedResult, "");
	
	//Check JSON with trailing comma
	
	jsonStr := JsonWithTrailingComma;

	regex.replaceAll(jsonStr);
	self.assertEqualMsg(jsonStr, JsonWithTrailingCommaExpectedResult, "");
	
	//Check JSON with match in the middle 

	jsonStr := JsonWithMiddleComma;

	regex.replaceAll(jsonStr);
	self.assertEqualMsg(jsonStr, JsonWithMiddleCommaExpectedResult, "");
	
	// Check MultiLine JSON
	jsonStr := MultiLineString;
	
	regex.replaceAll(jsonStr);
	self.assertEqualMsg(jsonStr, MultiLineStringExpectedResult, "Multiline JSON");
epilog
	delete regex;
end;</source>
    </JadeMethod>
