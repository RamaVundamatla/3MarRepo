    <JadeMethod name="populateIFObject" id="2bd3c47d-c465-4225-b77f-8f17f05abd0d">
        <source>populateIFObject(_schedule : CM_WorkOrderSchedule; _total : Integer ; _woActionIF : CMIF_WorkOrderAction io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2009	cnwrd1	Initial creation

*/

vars

beginresult : Boolean;
	numRows,
	idx		: Integer;
	noToAction,
	noAvailable : Integer;
	requestDesc : String;
	woRBT : CM_WorkOrderRequestByType;
begin
	//shouldnt be dealing with RBT here

	_woActionIF.myWorkOrderDtl := _schedule.myParent ;
	_woActionIF.myWorkOrderSchedule  := _schedule ;
		
	_woActionIF.numberFromKnownCargo := _total;
	_woActionIF.populateFromAvailable := false; //auto prefill??
	

epilog

end;</source>
        <Parameter name="_schedule" type="CM_WorkOrderSchedule"/>
        <Parameter name="_total" type="Integer"/>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction" usage="io"/>
