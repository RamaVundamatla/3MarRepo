	entTableDef := self.myEntTableDataRoot.allEntTableDefs[ETDef_InvoiceStatusEmail];
	foreach entTableRow in entTableDef.allEntTableRows do
		if entTableRow.name.isOneOf(ETRow_Debtor, ETRow_VoyageCode, ETRow_VesselName, ETRow_BusinessUnit, ETRow_EndDate) then
			sa.add(entTableRow.getHeading(null, null, app.myCurrentLocale));
