    <JadeMethod name="setControlsForAddEdit" id="f5d7fe5c-6156-4b43-8337-c879750bace8">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;
	
begin
  
  theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	
	theForm.myAssistant.comboBoxCargoBolType(theForm.cmbCargoType,TI_CargoType_Null,true, true, false, false);
	
	// This is the new one for after 7.4.1 release	
//	theForm.myAssistant.comboBoxCargoBOLTypeGate(theForm.cmbCargoType,TI_CargoType_Null,true, true, false);
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.setValueByName(ETRow_Colour, White.String);
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);	
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.fldInput.initSheetBackColors();
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_ISOType);
		// cannot update code		
		theForm.tblInput1.disableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
	endif;
	
	//18 Mar 2014	NDL	Par 33268
	if theForm.mode = theForm.Mode_Add then
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_TareWeight,  0, self.weightType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxTareWeight,  0, self.weightType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxTotalWeight,  0, self.weightType );
		
	else
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_TareWeight,  theForm.myProxyObject.CM_ISOType.tareKilos, self.weightType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxTareWeight,  theForm.myProxyObject.CM_ISOType.maxTareWeight, self.weightType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxTotalWeight,  theForm.myProxyObject.CM_ISOType.maxTotalWeight, self.weightType );
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="90d40fec-bbb8-4295-9e78-9251d00a87d6">
