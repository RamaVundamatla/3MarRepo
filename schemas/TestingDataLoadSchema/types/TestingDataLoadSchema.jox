    <JadeMethod name="runScriptExceptionHandler" id="24c0124a-7572-46e3-bb36-2b839478b4f9">
        <source>runScriptExceptionHandler(_ex : Exception; errorDirectoryName : String; scriptToRun : String; startTS : TimeStamp; errorLogName : String) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2020	jlgmh5	Initial creation

*/

vars

	callStack						: ProcessStackArray;
	methCallDesc					: MethodCallDesc;
	
	errorFile						: File;
	fileFolder						: FileFolder;

begin

	// Check folder actually exists is not then create
	create fileFolder transient;
	fileFolder.fileName := errorDirectoryName;
	if not fileFolder.isAvailable() then
		fileFolder.make();
	endif;
	
	create errorFile transient;
	//create app.automatedOutputFile transient;
	errorFile.fileName := fileFolder.fileName &amp; "\" &amp; scriptToRun &amp; errorLogName &amp; 
		startTS.date.year.String &amp; startTS.date.month.String.padLeadingZeros(2) &amp; startTS.date.day.String.padLeadingZeros(2) &amp; "_" &amp;
		startTS.time.hour.String.padLeadingZeros(2) &amp; startTS.time.minute.String.padLeadingZeros(2) &amp; 
		startTS.time.second.String.padLeadingZeros(2) &amp; ".log";
	errorFile.writeLine(_ex.errorCode.String &amp; Tab &amp; _ex.extendedErrorText);
	
	create callStack transient;
	process.currentStack(callStack);
	foreach methCallDesc in callStack do
		errorFile.writeLine(methCallDesc.display);
	endforeach;
			
	
	return Ex_Resume_Next;
	
epilog

	delete errorFile;
	delete fileFolder;
	
	callStack.purge;
	delete callStack;

end;</source>
        <Parameter name="_ex" type="Exception"/>
        <Parameter name="errorDirectoryName" type="String"/>
        <Parameter name="scriptToRun" type="String"/>
        <Parameter name="startTS" type="TimeStamp"/>
        <Parameter name="errorLogName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="saveTermActiveCargoMapSet2Dflt" id="33ac480d-5809-46f8-8de9-57699058a7a1">
        <source>saveTermActiveCargoMapSet2Dflt(_savedCargoMapArray : ObjectArray io);

/*

Purpose:		Save all terminals active cargo maps and set to default	

Date			Who		Reason
20/03/2013		cnwmh5	Initial creation
16/01/2014		cnwmh5	Change to use sendMsgWithParams rather than creating a transient and deleting it
						because delete clears sets CMIF_Logger to null which means no writeLogs come out.
17/05/2016 		cnwmh5	After talking to John E have removed the creating of the default tran map as not needed
*/

vars

	bank				: CM_Bank;
	cargoMap			: CM_TranMap;
	terminal			: CM_Terminal;
	obj					: Object;

	fileName 			: String;
	mapName				: String;
	fileContent			: String;
	
begin
	
	_savedCargoMapArray.clear();
	
	// read through all the terminals and save the current active cargo map.  Set terminal to default
	foreach terminal in app.myRoot.allTerminals do
		
		app.myPassport.setMyTerminal(terminal);
		
		// get the terminal's default company bank
		bank := terminal.getDefaultCompanyBank();
		if bank &lt;&gt; null then
			foreach cargoMap in bank.myCurrentTranMapCargo do
				// active cargo map found so exit
				if cargoMap.isActive then
					break;
				endif;
			endforeach;
			
			// if active cargo map found then save to array
			if cargoMap &lt;&gt; null then
				_savedCargoMapArray.add(cargoMap);
			endif;
			
			// check to see if default cargo map exists
			///cargoMap := bank.myCurrentTranMapCargo['Default'];
			
			// if default cargo map doesn't exist then create it
			/*
			if cargoMap = null then
				fileName := "CargoLoaded";
				mapName := "Default";
				fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
					'Cargo,' &amp; mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) �,(Default),VOID,';
				cargoMap := UT_DSL.sendMsgWithParams("loadTranMap", fileContent, fileName, mapName).CM_TranMap;					// 14/01/2014 cnwmh5
				if cargoMap = null then
					app.writeLog("Default Cargo Map for Terminal (" &amp; bank.terminal.code &amp; ") could not be created", LogAlways);
					return;
				endif;
			endif;
			*/
			
			// set to default cargo map
			////app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_savedCargoMapArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
