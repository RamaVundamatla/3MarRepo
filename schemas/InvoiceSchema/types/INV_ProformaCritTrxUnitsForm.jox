    <JadeMethod name="createProxys" id="c4ff3c64-d325-4b59-b0f1-80bfc0ffe5d5">
        <source>createProxys( _allPxys : CM_ProformaTransactionUnitDict input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation

*/

vars

	ls : Boolean;
	row : Integer;
	tType : CM_TransactionType;
	unitType : Integer;
	unitValue : Decimal[16,4];
	proxy : CM_ProformaTransactionUnit;

begin

	app.cmsBeginLoad(ls);
	
	foreach row in self.tblUnits.fixedRows + 1 to self.tblUnits.rows do
		tType := self.tblUnits.accessCell(row,1).itemObject.CM_TransactionType;
		unitType := self.tblUnits.accessCell(row,2).cellControl.CMUI_ComboBox.listData;
		unitValue := self.tblUnits.getCellText(row,3).asDecimalJMT;
		
		create proxy transient;
		proxy.setProxy(	tType,	//_myTransactionType : CM_TransactionType;
						unitType,	//_unitType : Integer;
						unitValue,	//_unitValue : Decimal;
						self.myProformaTransactionCriteria	//_myProformaTransactionCriteria : CM_ProformaTransactionCriteria
						);
		_allPxys.add( proxy );
	endforeach;

epilog

	app.cmsEndLoad(ls);

end;</source>
        <Parameter name="_allPxys" type="CM_ProformaTransactionUnitDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="0664b5f0-d114-4e23-bfb4-93ff91173934">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation

*/

vars

	allPxys : CM_ProformaTransactionUnitDict;
	theReturn : Integer;

begin

	create allPxys transient;
	self.createProxys(allPxys);
	
	while true do
	
		app.myTrxUA.trxUpdateProformaCritUnits(self.myProformaTransactionCriteria, allPxys, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.unloadForm();
			return;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Proforma_criteria), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
		
	endwhile;


epilog

	if allPxys &lt;&gt; null and not allPxys.isEmpty then
		allPxys.purge();
	endif;
	delete allPxys;

end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="869e59ca-eba1-4dde-8639-e90362bf1feb">
        <updating/>
        <source>init() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation

*/

vars

	headings : String;
	trxType : CM_TransactionType;
	proformaTrxUnit : CM_ProformaTransactionUnit;
	dataString : String;
	row : Integer;
	comboOption : String;
	unitValue : String;
	combo : CMUI_ComboBox;

begin

	self.minimumHeight := 230;

	self.tblUnits.columns := 3;
	self.tblUnits.fixedColumns := 0;
	self.tblUnits.rows := 1;
	self.tblUnits.fixedRows := 1;
	self.tblUnits.accessColumn(1).inputType := Table.InputType_None;
	self.tblUnits.accessColumn(3).inputType := Table.InputType_TextBox;
	self.tblUnits.accessRow(1).inputType := Table.InputType_None;
	
	headings := app.getErrorString(Transaction_Type) &amp; Tab &amp; app.getErrorString(Unit_type) &amp; Tab &amp; app.getErrorString(Unit_s);
	self.tblUnits.setCellText(1,1,headings);
	
	foreach trxType in self.myProformaTransactionCriteria.allTransactionTypes do
		self.tblUnits.rows := self.tblUnits.rows + 1;
		row := self.tblUnits.rows;
		proformaTrxUnit := self.myProformaTransactionCriteria.getUnitDetailsForTrxType(trxType);
		if proformaTrxUnit = null then
			comboOption := CM_ProformaTransactionCriteria.UserUnit;
			unitValue := "1";
			self.setUpCombo( row, comboOption );
		else
			comboOption := proformaTrxUnit.getUnitTypeString;
			unitValue := proformaTrxUnit.getUnitValueAsString;
			self.setUpCombo( row, comboOption );
		endif;
		dataString := trxType.description &amp; Tab &amp; comboOption &amp; Tab &amp; unitValue;
		self.tblUnits.accessCell(row,1).itemObject := trxType;
		self.tblUnits.setCellText(row,1,dataString);
		self.setCellAccess(row,2);
	endforeach;
	// TFS 2071 'OK' to 'Save'
	self.btnOk.caption := app.getErrorString(Save);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCellAccess" id="717725d1-cc10-40a5-a6ea-6790c256cc9a">
        <updating/>
        <source>setCellAccess( row, column : Integer ):Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	text : String;

begin

	if row &lt;= self.tblUnits.fixedRows then
		return true;
	endif;
	if column = 1 then
		return true;
	endif;
	
	text := self.tblUnits.getCellText( row, column );
	if column = 2 then
		if text = CM_ProformaTransactionCriteria.PerDay then
			self.tblUnits.setCellText(row, 3, null);
			self.tblUnits.accessCell(row, 3).inputType := Table.InputType_None;
		else
			self.tblUnits.accessCell(row, 3).inputType := Table.InputType_TextBox;
			if text = CM_ProformaTransactionCriteria.UserUnit then
				if self.tblUnits.getCellText( row, 3 ).trimBlanks = null then
					self.tblUnits.setCellText(row, 3, "1");
				endif;
			endif;
		endif;
		
	elseif column = 3 then
		if self.tblUnits.getCellText( row, 2 ) = CM_ProformaTransactionCriteria.UserUnit then
			if not text.isInteger then
				app.msgBox(app.getErrorString(Value_must_integer),app.getErrorString(Error) ,MsgBox_OK_Only + MsgBox_Stop_Icon );
				return false;
			endif;
		endif;
	
	endif;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="row" type="Integer"/>
        <Parameter name="column" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setReferences" id="701215be-cec0-43c4-adbb-b20f7e4cee80">
        <updating/>
        <source>setReferences( _myProformaTransactionCriteria : CM_ProformaTransactionCriteria ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation

*/

vars

begin

	self.myProformaTransactionCriteria := _myProformaTransactionCriteria;

epilog

