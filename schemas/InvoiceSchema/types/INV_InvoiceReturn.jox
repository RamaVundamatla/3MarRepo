    <JadeMethod name="create" id="e1f15a71-021f-407c-b540-352fb763c692">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2017	jlgndl1	Initial creation	TFS 6759

*/

vars

begin

	// TFS 39618 PATCH 1 self.permissionView  := PmAdmInvListStatusReturn;
	// TFS 39618 PATCH 1 self.permissionMaint := PmAdmInvListStatusReturn;
	self.permissionView  := PmAdmInvoicelistMaint;// TFS 39618 PATCH 1 
	self.permissionMaint := PmAdmInvoicelistMaint;// TFS 39618 PATCH 1 

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayInvoice" id="78daa03d-13a9-48ce-bf16-c97fe3f5471b">
        <source>displayInvoice();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2017	jlgndl1	Initial creation	TFS 6759

*/

vars

	text : String;
	invTerm : CM_InvoiceTermsOfTrade;
	invTermCode : String;
	finIO : CM_ExtFinanceIO;
begin

	text := app.getErrorString(Invoice) &amp; " " &amp; self.myInvoiceToReturn.sequenceNum.String;
	text := text &amp; " - " &amp; /*app.getErrorString(Posted)*/ app.getInvoiceStatusString(self.myInvoiceToReturn.getMyInvoiceProcess, CM_Invoice.INVOICE_POSTED) &amp; " " &amp; self.systemToLocalTime(self.myInvoiceToReturn.postedDT).String; // TFS 39618
	text := text &amp; CrLf &amp; app.getErrorString(INV_Debtor) &amp; " - " &amp; self.myInvoiceToReturn.debtor.name;
	
	self.lblInvoice.caption := text;

	self.txtNarration.text := self.myInvoiceToReturn.narration;
	
	self.chkZero.value := self.myInvoiceToReturn.isZeroRatedTax;
	
	//1/4/22 jlier1 TFS 53286
	finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	self.chkExport.value := true;
	if finIO &lt;&gt; null then
		if finIO.isKindOf(CM_SALInterface) then
			self.chkExport.value := false;
			self.chkExport.visible:=false;
		elseif finIO.isKindOf(CM_POBFinanceOneInterface) then //jlier1 TFS 57426 3/4/22 
			self.chkExport.value := false;
			self.chkExport.visible:=false;
		endif;
	endif;
	invTermCode := self.myInvoiceToReturn.termsOfTradeCode;
	if invTermCode &lt;&gt; null then
		foreach invTerm in app.myRoot.myRootCompany.allInvoiceTermsOfTrade do
			if invTerm.code = invTermCode then
				self.cmbTerms.listIndex := self.cmbTerms.findObject(invTerm);
				break;
			endif;
		endforeach;
	endif;
	
	self.txtPONumber.text := self.myInvoiceToReturn.purchaseOrderNumber;
	
	if self.myInvoiceToReturn.toDT.isValid then
		self.txtEndDate.setDate( self.systemToLocalTime(self.myInvoiceToReturn.toDT).Date );
	else
		self.txtEndDate.setDate( null );
	endif;
	
	self.txtDrRef.text := self.myInvoiceToReturn.debtorReference;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="a6c2f1d4-c159-45b2-8d65-4fcb797fc8bb">
        <source>doOK();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Aug 2017	jlgndl1	Initial creation	TFS 6759
05 Mar 2020 cnwma1 ChangeRequest 48524: CPL - Credit Invoice Details for Print
*/

vars
	creditCMIF  	 : CMIF_InvoiceStatus;
	creditInv, 
	pendingInv  	 : CM_Invoice;
	finIOClass  	 : CM_ExtFinanceIO;
	returnInt,
	edition 		 : Integer;
	invalid,
	createdTransient : Boolean;
	schedule		 : CM_AutoSchedule;
	debtorInvType    : CM_DebtorInvType;
	package          : CM_PackageInvoice;
	task             : CM_AutoTask;
	isPOBFinanceOneInterface : Boolean;
	allFailedInvoices : CM_InvoiceBySeqNumDict;
	financeOneMessage : String;
begin 

	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIOClass = null 
		or not global.isValidObject(finIOClass) then
			create finIOClass as CM_DefaultFinanceIO transient;
			createdTransient := true;
	endif;
	isPOBFinanceOneInterface:=finIOClass.isKindOf(CM_POBFinanceOneInterface);
	
	create creditCMIF transient;
	creditCMIF.myInvoice 		   := self.myInvoiceToReturn;
	creditCMIF.narration 		   := self.txtNarration.text;
	creditCMIF.isZeroRatedTax 	   := self.chkZero.value;
	creditCMIF.doExport 		   := self.chkExport.value or isPOBFinanceOneInterface;
	creditCMIF.myTermsOfTrade 	   := self.cmbTerms.listObject.CM_InvoiceTermsOfTrade;
	creditCMIF.purchaseOrderNumber := self.txtPONumber.text;
	creditCMIF.toDT.setDate( self.txtEndDate.getDate );
	creditCMIF.debtorReference     := self.txtDrRef.text;
	creditCMIF.newPending 		   := self.chkCopyPosted.value;
	
	while true do
		app.myTrxUA.trxUpdInvStatusToReturned(	creditCMIF,	    //_creditCMIF : CMIF_InvoiceStatus input;
												creditInv,	    //_creditInv  : CM_Invoice output;
												pendingInv,     //_pendingInv : CM_Invoice output;
												app.myPassport	//_passport   : CM_Passport input
												);
		if app.myPassport.trxCompletedOK then
		
			if creditCMIF.doExport and creditInv &lt;&gt; null then
				finIOClass.export( creditInv );
				//jlier1 TFS 57426 3/4/22 
				if isPOBFinanceOneInterface then
					if creditInv.externalIntefaceStatus &lt;&gt; CM_EWSActivityFinanceOne.Status_Success then
						app.msgBox(app.getErrorString(No_success_fin_one),app.getErrorString(Finance_one),MsgBox_OK_Only);	
					else
						app.msgBox(app.getErrorString(Successful_Fin_One_response),app.getErrorString(Finance_one),MsgBox_OK_Only);	
					endif;
				endif;
			endif;
			
			//05/03/2020 cnwma1 TFS #48524
			debtorInvType := creditInv.debtor.allDebtorInvTypes[creditInv.invoiceType];
			if debtorInvType &lt;&gt; null then
				if self.cmbPackage.listObject &lt;&gt; null then
					package := self.cmbPackage.listObject.CM_PackageInvoice;
					foreach task in package.allTasks do
						schedule := task.allAutoSchedules.first;
						app.runEventScheduleInvoice(schedule, creditInv, null);
					endforeach;
				endif;
			endif;
			//05/03/2020 cnwma1 TFS #48524
			
			
			self.myParentForm.INV_ListInvoices.refreshInvoice( self.myInvoiceToReturn );
			self.btnCancel.click( self.btnCancel );
			break;
		else
			returnInt := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and returnInt = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

epilog

	delete creditCMIF;
	
	if createdTransient then
		delete finIOClass;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateCombo" id="57116453-23b3-4c9f-b03e-1566ed8b3999">
        <source>populateCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Aug 2017	jlgndl1	Initial creation	TFS 6759
05 Mar 2020 cnwma1 ChangeRequest 48524: CPL - Credit Invoice Details for Print
*/

vars

	invTerm : CM_InvoiceTermsOfTrade;
	invoice : CM_Invoice;
	dit     : CM_DebtorInvType;
	package : CM_PackageInvoice;
begin

	self.cmbTerms.clear();
	
	foreach invTerm in app.myRoot.myRootCompany.allInvoiceTermsOfTrade do
		self.cmbTerms.addItem(invTerm.description);
		self.cmbTerms.itemObject[self.cmbTerms.newIndex] := invTerm;
	endforeach;
	
	self.cmbTerms.addItemAt(null, 1);
	
	
	//05/03/2020 cnwma1 TFS #48524
	self.cmbPackage.clear();
	self.cmbPackage.addItemAt(null, 1);
	invoice := self.myInvoiceToReturn;
	dit := invoice.debtor.allDebtorInvTypes[invoice.invoiceType];
	
	if dit &lt;&gt; null then
		foreach package in dit.allPackageInvoices do
			self.cmbPackage.addItem(package.code);
			self.cmbPackage.itemObject[self.cmbPackage.newIndex] := package;
		endforeach;
		
		if dit.allPackageInvoices.size =1 then
			self.cmbPackage.listObject := dit.allPackageInvoices.first.CM_PackageInvoice;
		endif;
	endif;
	//05/03/2020 cnwma1 TFS #48524
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyInvoice" id="7a7ba259-71db-4fe3-978f-525155e9f48b">
        <updating/>
        <source>setMyInvoice( _inv : CM_Invoice ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2017	jlgndl1	Initial creation	TFS 6759

*/

vars

begin

	self.myInvoiceToReturn := _inv;
	if _inv &lt;&gt; null then
		self.myBank := _inv.bank;
	endif;

epilog

end;</source>
        <Parameter name="_inv" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7871a650-b12f-48ca-abe5-8d5f5b5563a7">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2017	jlgndl1	Initial creation	TFS 6759

*/

vars

	offSet : Real;
begin

	self.grpMain.left := 1;
	offSet := ( self.width - self.clientWidth ) + 2;
	self.width := self.grpMain.width + offSet;
	
	
	self.minimumHeight := 570;
	self.minimumWidth := 305;
	
	inheritMethod();
	
	if self.myInvoiceToReturn = null then
		self.unloadForm();
		return;
	endif;
	
	
	self.populateCombo();
	
	self.displayInvoice();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a67059be-1c44-4aba-867d-fa8f22d2e1a9">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 March 2020 14:06:55.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022084, locale);
	chkCopyPosted.translateCaption(Xlat_0022085, locale);
	chkExport.translateCaption(Xlat_0022086, locale);
	chkZero.translateCaption(Xlat_0022087, locale);
	grpNewCredit.translateCaption(Xlat_0022088, locale);
	grpNewPend.translateCaption(Xlat_0022089, locale);
	lblDrRef.translateCaption(Xlat_0022090, locale);
	lblEndDate.translateCaption(Xlat_0022091, locale);
	lblInvoice.translateCaption(Xlat_0022092, locale);
	lblNarration.translateCaption(Xlat_0022093, locale);
	lblPONumber.translateCaption(Xlat_0022094, locale);
	lblPackage.translateCaption(Xlat_0023891, locale);
	lblTerms.translateCaption(Xlat_0022095, locale);
end;</source>
    </JadeMethod>
</GUIClass>
