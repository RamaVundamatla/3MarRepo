<Class name="UT_IFTMCS_BOOKINGS" id="9a7b7fff-a9c0-4cc9-a8c7-c7ebbddf4560">
    <superclass name="UT_EDI"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="iIFTMCS_03A_PAR26152" id="53b713db-a749-4122-ad5d-38fd7d943fd6">
        <updating/>
        <source>iIFTMCS_03A_PAR26152() updating;
//cnwrs1	the version from xmast
// cnwrl1 - for emails

constants
	VoyageName	= "UTV111";
	BookingNo	= "IFTMCS_03A";
	Vessel		= "MISBOAT2";
	
vars
	vessel		: CM_Vessel;
	voyage		: CM_Voyage;
	ediFile		: CM_EDIFile;
	text		: String;
	tempStr		: String;
	
begin
	self.deleteVoyage( VoyageName );
	self.deleteVessel( Vessel );
	self.deleteBooking( BookingNo );
	self.opts.addAssoc( ETRow_LloydsNumber, '9227341' );
	vessel := self.addVesselCellular( Vessel, self.getOperator( self.getProfileSetting( UT_Profile.P_OPERATOR ).asString ));
	self.assertNotNullMsg( vessel, "Add vessel failed" );
	voyage := self.addVoyageWithContainerStructur( VoyageName, Vessel, 'MIS', self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString );
	/////MDH/////beginTransaction;
	/////MDH/////self.getTerminal().setConfig(EdiBookingCommodity, true); // cnwgb1 Flag introduced for PAR 26681 30.12.2010
	/////MDH/////commitTransaction;
	self.setTerminalConfig(EdiBookingCommodity, true); 
	
	text :=
"UNB+UNOC:1+MISC BERHAD+SFL+0908210954:1403110+207'"&amp;
"UNH+1403111+IFTMCS:D:03A:UN'"&amp;
"BGM+770+8993-0+5'"&amp;
"DTM+137:200908210954:203'"&amp;
"LOC+88+NZPOE'"&amp;
"RFF+BN:"&amp;BookingNo&amp;"'"&amp;
"TDT+20+"&amp;VoyageName&amp;"+1++MIS:172:87+++9227341:146::"&amp;Vessel&amp;"'"&amp;
"LOC+9+NZPOE'"&amp;
"LOC+11+DEBRV'"&amp;
"LOC+7+IDBLW'"&amp;
"NAD+MS+MISC BERHAD'"&amp;
"EQD+CN++2210+++5'"&amp;
"EQN+7'"&amp;
"MEA+AAE+AAB+KGM:47000'"&amp;
"FTX+AAA+++PAINT'"&amp;
"UNT+16+1403111'"&amp;
"UNZ+1+1403110'";
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS1"&amp;method.name);
	self.assertNotNull( ediFile );
	
	// NOTE: status of 19 is DB Partially Loaded
	self.ediVerify( ediFile );
	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	self.assertEqualMsg( tempStr, "Code :70099. An invalid Commodity 'PAIN' was specified.", 'The expected error message is wrong during verification' );
	
	// now check that just doing a DB Load also gives the same error.
	self.ediDBLoad( ediFile );
	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS);
	
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	self.assertEqualMsg( tempStr, "Code :70099. An invalid Commodity 'PAIN' was specified.", 'The expected error message is wrong during DBLoad' );
	
	text :=
"UNB+UNOC:1+MISC BERHAD+SFL+0908210954:1403110+207'"&amp;
"UNH+1403111+IFTMCS:D:03A:UN'"&amp;
"BGM+770+8993-0+5'"&amp;
"DTM+137:200908210954:203'"&amp;
"LOC+88+NZPOE'"&amp;
"RFF+BN:"&amp;BookingNo&amp;"'"&amp;
"TDT+20+"&amp;VoyageName&amp;"+1++MIS:172:87+++9227341:146::"&amp;Vessel&amp;"'"&amp;
"LOC+9+NZPOE'"&amp;
"LOC+11+DEBRV'"&amp;
"LOC+7+IDBLW'"&amp;
"NAD+MS+MISC BERHAD'"&amp;
"EQD+CN++2210+++5'"&amp;
"EQN+7'"&amp;
"MEA+AAE+AAB+KGM:47000'"&amp;
"FTX+AAA+++UT_4'"&amp;
"UNT+16+1403111'"&amp;
"UNZ+1+1403110'";
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS2"&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	self.assertEqualMsg(tempStr, "Code :86180. The Cargo Type used (ISO Container) is not valid for the Commodity (UT_4).", 'The expected error message is wrong during verification' );
	
	self.ediDBLoad(ediFile);
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS);
	
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	self.assertEqualMsg(tempStr, "Code :86180. The Cargo Type used (ISO Container) is not valid for the Commodity (UT_4).", 'The expected error message is wrong during verification' );

epilog
	/////MDH/////beginTransaction;
	/////MDH/////self.getTerminal().setConfig(EdiBookingCommodity, false); // cnwgb1 Flag introduced for PAR 26681 30.12.2010
	/////MDH/////commitTransaction;
end;
</source>
    </JadeMethod>
    <JadeMethod name="iIFTMCS_03A_PAR26681" id="5ea4ea1c-8721-414c-b026-43b52f36b387">
        <source>iIFTMCS_03A_PAR26681();
//cnwrs1	the version from xmast
// cnwrs1 - for emails

constants
	VoyageName	= "PAR26681";
	BookingNo	= "IFTMCS_03A";
	Vessel		= "PAR26681";
	ErrorMessage1 = "Code :70099. An invalid Commodity 'PAIN' was specified.";
vars
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediFile : CM_EDIFile;
	text : String;
	tempStr : String;
	length : Integer;
	ediBookingAllowPartial : Boolean;
	ediBookingCommodity : Boolean;
begin
	ediBookingAllowPartial := self.getTerminal().getConfig(EdiBookingAllowPartial).Boolean;
	ediBookingCommodity := self.getTerminal().getConfig(EdiBookingCommodity).Boolean;
	self.deleteVoyage(VoyageName);
	self.deleteVessel(Vessel);
	self.deleteBooking(BookingNo);
	self.opts.addAssoc( ETRow_LloydsNumber, '9227341' );
	vessel := self.addVesselCellular(Vessel, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	voyage := self.addVoyageWithContainerStructur(VoyageName, Vessel, 'MIS', self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	/////MDH/////beginTransaction;
	/////MDH/////self.getTerminal().setConfig(EdiBookingAllowPartial, true);
	/////MDH/////commitTransaction;
	self.setTerminalConfig(EdiBookingAllowPartial, true);
	
	text :=
"UNB+UNOC:1+MISC BERHAD+SFL+0908210954:1403110+207'"&amp;
"UNH+1403111+IFTMCS:D:03A:UN'"&amp;
"BGM+770+8993-0+5'"&amp;
"DTM+137:200908210954:203'"&amp;
"LOC+88+NZPOE'"&amp;
"RFF+BN:"&amp;BookingNo&amp;"'"&amp;
"TDT+20+"&amp;VoyageName&amp;"+1++MIS:172:87+++9227341:146::"&amp;Vessel&amp;"'"&amp;
"LOC+9+NZPOE'"&amp;
"LOC+11+DEBRV'"&amp;
"LOC+7+IDBLW'"&amp;
"NAD+MS+MISC BERHAD'"&amp;
"EQD+CN++2210+++5'"&amp;
"EQN+7'"&amp;
"MEA+AAE+AAB+KGM:47000'"&amp;
"FTX+AAA+++PAINT'"&amp;
"UNT+16+1403111'"&amp;
"UNZ+1+1403110'";
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS1"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	length := ErrorMessage1.length;
	self.assertEqualMsg(tempStr[1:length], ErrorMessage1, 'The expected error message is wrong during verification');
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	length := ErrorMessage1.length;
	self.assertEqualMsg(tempStr[1:length], ErrorMessage1, 'The expected error message is wrong during verification');

	/////MDH/////beginTransaction;
	/////MDH/////self.getTerminal().setConfig(EdiBookingCommodity, true);
	/////MDH/////commitTransaction;
	self.setTerminalConfig(EdiBookingCommodity, true);
	
	text :=
"UNB+UNOC:1+MISC BERHAD+SFL+0908210954:1403110+207'"&amp;
"UNH+1403111+IFTMCS:D:03A:UN'"&amp;
"BGM+770+8993-0+5'"&amp;
"DTM+137:200908210954:203'"&amp;
"LOC+88+NZPOE'"&amp;
"RFF+BN:"&amp;BookingNo&amp;"'"&amp;
"TDT+20+"&amp;VoyageName&amp;"+1++MIS:172:87+++9227341:146::"&amp;Vessel&amp;"'"&amp;
"LOC+9+NZPOE'"&amp;
"LOC+11+DEBRV'"&amp;
"LOC+7+IDBLW'"&amp;
"NAD+MS+MISC BERHAD'"&amp;
"EQD+CN++2210+++5'"&amp;
"EQN+7'"&amp;
"MEA+AAE+AAB+KGM:47000'"&amp;
"FTX+AAA+++PAINT'"&amp;
"UNT+16+1403111'"&amp;
"UNZ+1+1403110'";
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS2"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	
	length := ErrorMessage1.length;
	self.assertEqualMsg(tempStr[1:length], ErrorMessage1, 'The expected error message is wrong during verification');
	
	self.ediDBLoad(ediFile);
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, tempStr);
	
	length := ErrorMessage1.length;
	self.assertEqualMsg(tempStr[1:length], ErrorMessage1, 'The expected error message is wrong during verification');

	// now do it all again with EdiBookingAllowPartial turned off
	/////MDH/////beginTransaction;
	/////MDH/////self.getTerminal().setConfig(EdiBookingAllowPartial, false);
	/////MDH/////commitTransaction;
	self.setTerminalConfig(EdiBookingAllowPartial, false);
	
	text :=
"UNB+UNOC:1+MISC BERHAD+SFL+0908210954:1403110+207'"&amp;
"UNH+1403111+IFTMCS:D:03A:UN'"&amp;
"BGM+770+8993-0+5'"&amp;
"DTM+137:200908210954:203'"&amp;
"LOC+88+NZPOE'"&amp;
"RFF+BN:"&amp;BookingNo&amp;"'"&amp;
"TDT+20+"&amp;VoyageName&amp;"+1++MIS:172:87+++9227341:146::"&amp;Vessel&amp;"'"&amp;
"LOC+9+NZPOE'"&amp;
"LOC+11+DEBRV'"&amp;
"LOC+7+IDBLW'"&amp;
"NAD+MS+MISC BERHAD'"&amp;
"EQD+CN++2210+++5'"&amp;
"EQN+7'"&amp;
"MEA+AAE+AAB+KGM:47000'"&amp;
"FTX+AAA+++PAINT'"&amp;
"UNT+16+1403111'"&amp;
"UNZ+1+1403110'";
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS3"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= 'Verifiy failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	length := ErrorMessage1.length;
	self.assertEqualMsg(tempStr[1:length], ErrorMessage1, 'The expected error message is wrong during verification');
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'Verifiy failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	length := ErrorMessage1.length;
	self.assertEqualMsg(tempStr[1:length], ErrorMessage1, 'The expected error message is wrong during verification');

	/////MDH/////beginTransaction;
	/////MDH/////self.getTerminal().setConfig(EdiBookingCommodity, true);
	/////MDH/////commitTransaction;
	self.setTerminalConfig(EdiBookingCommodity, false);
	
	text :=
"UNB+UNOC:1+MISC BERHAD+SFL+0908210954:1403110+207'"&amp;
"UNH+1403111+IFTMCS:D:03A:UN'"&amp;
"BGM+770+8993-0+5'"&amp;
"DTM+137:200908210954:203'"&amp;
"LOC+88+NZPOE'"&amp;
"RFF+BN:"&amp;BookingNo&amp;"'"&amp;
"TDT+20+"&amp;VoyageName&amp;"+1++MIS:172:87+++9227341:146::"&amp;Vessel&amp;"'"&amp;
"LOC+9+NZPOE'"&amp;
"LOC+11+DEBRV'"&amp;
"LOC+7+IDBLW'"&amp;
"NAD+MS+MISC BERHAD'"&amp;
"EQD+CN++2210+++5'"&amp;
"EQN+7'"&amp;
"MEA+AAE+AAB+KGM:47000'"&amp;
"FTX+AAA+++PAINT'"&amp;
"UNT+16+1403111'"&amp;
"UNZ+1+1403110'";
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS4"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= 'Verifiy failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	length := ErrorMessage1.length;
	self.assertEqualMsg(tempStr[1:length], ErrorMessage1, 'The expected error message is wrong during verification');
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	
	tempStr	:= app.myPassport.getAllErrorsWarningsAsString();
	length := ErrorMessage1.length;
	self.assertEqualMsg(tempStr[1:length], ErrorMessage1, 'The expected error message is wrong during verification');

epilog
	/////MDH/////beginTransaction;
	/////MDH/////self.getTerminal().setConfig(EdiBookingCommodity, ediBookingCommodity);
	/////MDH/////self.getTerminal().setConfig(EdiBookingAllowPartial, ediBookingAllowPartial);
	/////MDH/////commitTransaction;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tIFTMCSId_CCMS1855" id="898e4af5-24d5-4af6-92a4-1c6325d8bd61">
        <updating/>
        <source>tIFTMCSId_CCMS1855() updating;
// 2 Sept 2009 cnwrs1
// Test CCMS 1855 that we remove the - from id for MIS Versioned stuff 
constants
	VoyageName = "UTV101";
	BookingNo = "528466678012345";		// cnwrl1 12/02/2010 PAR 22346
	Vessel = "MISBOAT";
vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	ediFile : CM_EDIFile;
	booking : CM_BookingRef;
	text : String;
	origProcessMISVersionBkRef : Boolean;
	tempStr : String;
begin
	self.deleteVoyage(VoyageName);
	self.deleteVessel(Vessel);
	self.deleteBooking(BookingNo);
	self.deleteBooking(BookingNo &amp; '-1');
	self.deleteBooking(BookingNo &amp; '-2');
	self.opts.addAssoc( ETRow_LloydsNumber, '9227340' );
	vessel := self.addVesselCellular(Vessel, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	voyage := self.addVoyageWithContainerStructur(VoyageName, Vessel, 'MIS', self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.setTerminalConfig(ProcessMISVersionBkRef, false);
	
	text :=
"UNB+UNOC:1+MISC BERHAD+SFL+0908210954:1403110+207'"&amp;
"UNH+1403111+IFTMCS:D:03A:UN'"&amp;
"BGM+770+8993-0+5'"&amp;
"DTM+137:200908210954:203'"&amp;
"LOC+88+NZPOE'"&amp;
"RFF+BN:"&amp;BookingNo&amp;"-1'"&amp;
"TDT+20+"&amp;VoyageName&amp;"+1++MIS:172:87+++9227340:146::"&amp;Vessel&amp;"'"&amp;
"LOC+9+NZPOE'"&amp;
"LOC+11+SGSIN'"&amp;
"LOC+7+IDBLW'"&amp;
"NAD+MS+MISC BERHAD'"&amp;
"EQD+CN++2210+++5'"&amp;
"EQN+7'"&amp;
"MEA+AAE+AAB+KGM:47000'"&amp;
"FTX+AAA+++ALUMINIUM'"&amp;
"UNT+16+1403111'"&amp;
"UNZ+1+1403110'";
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS1"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	booking := self.getBooking(BookingNo &amp; '-1');
	self.assertNotNull(booking);
	self.assertEqual(booking.bookingReference, BookingNo &amp; '-1');
// rerun with config setting
	self.setTerminalConfig(ProcessMISVersionBkRef, true);
	text :=
"UNB+UNOC:1+MISC BERHAD+SFL+0908210954:1403110+207'"&amp;
"UNH+1403111+IFTMCS:D:03A:UN'"&amp;
"BGM+770+8993-0+5'"&amp;
"DTM+137:200908210954:203'"&amp;
"LOC+88+NZPOE'"&amp;
"RFF+BN:"&amp;BookingNo&amp;"-1'"&amp;
"TDT+20+"&amp;VoyageName&amp;"+1++MIS:172:87+++9227340:146::"&amp;Vessel&amp;"'"&amp;
"LOC+9+NZPOE'"&amp;
"LOC+11+SGSIN'"&amp;
"LOC+7+IDBLW'"&amp;
"NAD+MS+MISC BERHAD'"&amp;
"EQD+CN++2210+++5'"&amp;
"EQN+7'"&amp;
"MEA+AAE+AAB+KGM:47000'"&amp;
"FTX+AAA+++ALUMINIUM'"&amp;
"UNT+16+1403111'"&amp;
"UNZ+1+1403110'";
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS2"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	booking := self.getBooking(BookingNo);
	self.assertNotNull(booking);
	self.assertEqual(booking.bookingReference, BookingNo);
// rerun with other operator
	self.setTerminalConfig(ProcessMISVersionBkRef, true);
	
	text :=
"UNB+UNOC:1+MISC BERHAD+SFL+0908210954:1403110+207'"&amp;
"UNH+1403111+IFTMCS:D:03A:UN'"&amp;
"BGM+770+8993-0+5'"&amp;
"DTM+137:200908210954:203'"&amp;
"LOC+88+NZPOE'"&amp;
"RFF+BN:"&amp;BookingNo&amp;"-2'"&amp;
"TDT+20+"&amp;VoyageName&amp;"+1++MSK:172:87+++9227340:146::"&amp;Vessel&amp;"'"&amp;
"LOC+9+NZPOE'"&amp;
"LOC+11+SGSIN'"&amp;
"LOC+7+IDBLW'"&amp;
"NAD+MS+MISC BERHAD'"&amp;
"EQD+CN++2210+++5'"&amp;
"EQN+7'"&amp;
"MEA+AAE+AAB+KGM:47000'"&amp;
"FTX+AAA+++ALUMINIUM'"&amp;
"UNT+16+1403111'"&amp;
"UNZ+1+1403110'";
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS", "IFTMCS3"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	booking := self.getBooking(BookingNo &amp; "-2");
	self.assertNotNull(booking);
	self.assertEqual(booking.bookingReference, BookingNo&amp; "-2");
epilog

	abortTransaction;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tIFTMCS_03A_MSCFTX" id="df9f50ff-f0e2-44ea-8602-b3ce898fde55">
        <source>tIFTMCS_03A_MSCFTX();
// cnwrs1
/*
Date		Who		Reason
22 Jul 2013	cnwcs5	Initial Creation - par 31942 CCMS POL 2220 - FTX segment processing for Coparn/IFTMCS bookings
*/
constants
	ShipName 	= "SHP2220e";
	VoyageName 	= "VOY2220E";
	Booking1	= "CCMS22204001";
	Booking2	= "CCMS22204002";
	Booking3	= "CCMS22204003";
	Booking4	= "CCMS22204004";
	Booking5	= "CCMS22204005";
	Booking6	= "CCMS22204006";
	Booking7	= "CCMS22204007";
	Booking8	= "CCMS22204008";
	Booking9	= "CCMS22204009";
	
	PARTY		= 'MSC';
	SENDER1		= 'MSCA';
	SENDER2		= 'MSC2';
	REMARKS		= 'Some remarks';
	REMARKS3_1	= 'TEMP  0.5 DEGREES CELSIUS';
	REMARKS3_2	= 'VENT 5M/H CONT RUNNING';
	REMARKS3_3	= 'HUM 85% DRAINS OPEN';
	REMARKS3	= REMARKS3_1 &amp; ' ' &amp; REMARKS3_2 &amp; ' ' &amp; REMARKS3_3;
vars
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	ediFile 		: CM_EDIFile;
	booking 		: CM_BookingRef;
	bookingItem		: CM_BookingRefItem;
	text 			: String;
	tempStr 		: String;
	bookingItems 	: Integer;
	ediParty		: CM_EDIParty;
	rules			: CM_EDIPartyCoparnRules;
	code			: String;
	operator		: CM_Operator;
	ediBookingCommodity : Boolean;
begin
	self.setTerminalConfig(ReeferBookingReqsTemp, false);
	code 		:= self.getTerminal.code;
	operator	:= app.myRoot.allOperators ['MSC']; 
	self.setTerminalConfig(EdiBookingCommodity, true);
	
	self.assertNotNull (operator);
	
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	
	self.deleteBooking(Booking1);
	self.deleteBooking(Booking2);
	self.deleteBooking(Booking3);
	self.deleteBooking(Booking4);
	self.deleteBooking(Booking5);
	self.deleteBooking(Booking6);
	self.deleteBooking(Booking7);
	self.deleteBooking(Booking8);
	self.deleteBooking(Booking9);
	
	vessel := self.addVesselCellular(ShipName, operator);
	self.assertNotNullMsg(vessel, "Add vessel failed");
	
	voyage := self.addVoyageWithContainerStructur(VoyageName, ShipName, 'MSC', self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, "Add voyage failed");
	
	ediParty	:= self.createEDIPartyAndRules ('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY, PARTY, SENDER1, SENDER2, operator, true);
	rules		:= ediParty.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;



	text :=
"UNB+UNOC:1+"&amp;SENDER1&amp;"+SFL+0908210954:1403110+207'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;Booking1&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;operator.code&amp;":172:87+++" &amp; vessel.lloydsNumber &amp; ":146::"&amp;ShipName&amp;"'
LOC+9+NZPOE'
LOC+11+AUSYD'
LOC+7+IDBLW'
NAD+MS+"&amp;SENDER1&amp;"'
EQD+CN++2210+++5'
EQN+7'
MEA+AAE+AAB+KGM:47000'
FTX+AAA+++GENLRD'
FTX+ABC+++" &amp; REMARKS &amp; "'
FTX+ABC+++" &amp; REMARKS3_1 &amp; ":" &amp; REMARKS3_2 &amp; ":" &amp; REMARKS3_3 &amp;":STANDARD TEXT'
DGS+IMD+5.1+2014'
UNT+16+1403111'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;Booking2&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;operator.code&amp;":172:87+++" &amp; vessel.lloydsNumber &amp; ":146::"&amp;ShipName&amp;"'
LOC+9+NZPOE'
LOC+11+AUSYD'
LOC+7+IDBLW'
NAD+MS+"&amp;SENDER1&amp;"'
EQD+CN++2210+++5'
EQN+7'
MEA+AAE+AAB+KGM:47000'
FTX+AAA+++FZFS'
FTX+OSI++15:MTQ'
UNT+16+1403111'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;Booking3&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;operator.code&amp;":172:87+++" &amp; vessel.lloydsNumber &amp; ":146::"&amp;ShipName&amp;"'
LOC+9+NZPOE'
LOC+11+AUSYD'
LOC+7+IDBLW'
NAD+MS+"&amp;SENDER1&amp;"'
EQD+CN++2210+++5'
EQN+7'
MEA+AAE+AAB+KGM:47000'
FTX+AAA+++REEF'
DGS+IMD+8:1234+2586''
UNT+16+1403111'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;Booking4&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;operator.code&amp;":172:87+++" &amp; vessel.lloydsNumber &amp; ":146::"&amp;ShipName&amp;"'
LOC+9+NZPOE'
LOC+11+AUSYD'
LOC+7+IDBLW'
NAD+MS+"&amp;SENDER1&amp;"'
EQD+CN++2210+++5'
EQN+7'
MEA+AAE+AAB+KGM:47000'
DGS+IMD+3.1:3139+1263+++'
DGS+IMD+8:1234+2586'
UNT+16+1403111'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;Booking5&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;operator.code&amp;":172:87+++" &amp; vessel.lloydsNumber &amp; ":146::"&amp;ShipName&amp;"'
LOC+9+NZPOE'
LOC+11+AUSYD'
LOC+7+IDBLW'
NAD+MS+"&amp;SENDER1&amp;"'
EQD+CN++22R1+++5'
EQN+7'
MEA+AAE+AAB+KGM:47000'
TMP+2+-10:CEL'
UNT+20+1403111'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;Booking7&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;operator.code&amp;":172:87+++" &amp; vessel.lloydsNumber &amp; ":146::"&amp;ShipName&amp;"'
LOC+9+NZPOE'
LOC+11+AUSYD'
LOC+7+IDBLW'
NAD+MS+"&amp;SENDER1&amp;"'
EQD+CN++22R1+++4'
EQN+7'
MEA+AAE+AAB+KGM:47000'
UNT+20+1403111'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;Booking8&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;operator.code&amp;":172:87+++" &amp; vessel.lloydsNumber &amp; ":146::"&amp;ShipName&amp;"'
LOC+9+NZPOE'
LOC+11+AUSYD'
LOC+7+IDBLW'
NAD+MS+"&amp;SENDER1&amp;"'
EQD+CN++22R1+++4'
EQN+7'
MEA+AAE+AAB+KGM:47000'
TMP+2+-10:CEL'
FTX+AAA+++REEF'
TMP+2+-20:CEL'
UNT+20+1403111'
UNH+1403111+IFTMCS:D:03A:UN'
BGM+770+8993-0+5'
DTM+137:200908210954:203'
LOC+88+NZPOE'
RFF+BN:"&amp;Booking6&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;operator.code&amp;":172:87+++" &amp; vessel.lloydsNumber &amp; ":146::"&amp;ShipName&amp;"'
LOC+9+NZPOE'
LOC+11+AUSYD'
LOC+7+IDBLW'
NAD+MS+"&amp;SENDER1&amp;"'
EQD+CN++2231+++5'
EQN+7'
MEA+AAE+AAB+KGM:47000'
FTX+AAA+++REEF'
DGS+IMD+9+3082+++NONE+NONE+++9'
TMP+2+-10:CEL'
UNZ+1+1403110'";

	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "IFTMCS03A-1", "IFTMCS"&amp;method.name);
	
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertNotEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr );
	
	self.ediDBLoad(ediFile);
	
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	
	booking := self.getBooking(Booking1);
	self.assertNotNull(booking);
	
	bookingItems := booking.allBookingRefItems.size;
	self.assertEqual(bookingItems, 1);
	
	bookingItem := booking.allBookingRefItems.first;
	
	self.assertEqualMsg (bookingItem.remarks[1:REMARKS.length + REMARKS3.length + 1], REMARKS &amp; ' ' &amp; REMARKS3, 'Remarks not set');
	
	booking := self.getBooking(Booking2);
	self.assertNotNull(booking);
	
	bookingItems := booking.allBookingRefItems.size;
	self.assertEqual(bookingItems, 1);
	
	bookingItem := booking.allBookingRefItems.first;
	
	self.assertEqualMsg (bookingItem.getVentilation, 15.Decimal, 'Ventiation not set');
		
epilog

end;
</source>
