    <JadeMethod name="createEvent" id="a7be423b-f97f-4cf7-bed6-bb3afa4cd25a">
        <source>createEvent();
// ---------------------------------------------------------------------------
// Created:		17 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	type : Integer;
	et : CM_EventTransaction;
	cmifEventCtrl : CMIF_VoyageEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
	dateTime	: TimeStamp;
begin
	
	if self.status = Voyage_Status_Arrived and self.getVoyageArrivalEvent() = null then
		/* //17/02/2025	navkc1 JIRA Bug MTN-33582
		et := app.createEvent(EVT_VoyageArrival, self.arrivedDT, self.myTerminal, app.myPassport.userCode, false, false,0);
		if et &lt;&gt; null then
			et.CMEVT_VoyageEvent.setMyVoyage(self);
		endif;
		*/
		type := EVT_VoyageArrival; //17/02/2025	navkc1 JIRA Bug MTN-33582
		dateTime := self.arrivedDT; //17/02/2025	navkc1 JIRA Bug MTN-33582
	elseif self.status = Voyage_Status_Departed and self.getVoyageDepartureEvent() = null then
		/* //17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor
		et := app.createEvent(EVT_VoyageDeparture, self.departedDT, self.myTerminal, app.myPassport.userCode, false, false,0);
		if et &lt;&gt; null then
			et.CMEVT_VoyageEvent.setMyVoyage(self);
		endif;
		*/
		type := EVT_VoyageDeparture; //17/02/2025	navkc1 JIRA Bug MTN-33582
		dateTime := self.departedDT; //17/02/2025	navkc1 JIRA Bug MTN-33582
	endif;
	
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582 - Done in the new method app.createEventUsingCMIF
	if et  &lt;&gt; null then
		//et.createCharge(app.myPassport);
		app.myPassport.addEventTransactionForDeferUpd(et,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
	endif;
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	create cmifEventCtrl transient;
	cmifEventCtrl.type := type;
	cmifEventCtrl.dateTime := dateTime;
	cmifEventCtrl.myTerminal := self.myTerminal;
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVoyage := self;
	
	et := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
    </JadeMethod>
    <JadeMethod name="createGraphicForNullVoyage" id="719cf0f0-9f54-430b-ac6d-cf5b25262425">
        <updating/>
        <source>createGraphicForNullVoyage() updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theGraphic : CM_VoyageLayoutGraphic;
begin

	//if self.code &lt;&gt; NULL_VOYAGE_CODE then
	if not self.isNullVoyage then
		return;
	endif;
	
	if self.myLayoutGraphic &lt;&gt;  null then
		return;
	endif;

	beginTransaction;
	create theGraphic;
	self.setMyLayoutGraphic(theGraphic);
	commitTransaction;

end;</source>
