    <JadeMethod name="doFormValidate" id="f365b75c-115c-42bd-bc66-2fc5c9b2c58d">
        <updating/>
        <source>doFormValidate():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 July 2001 by cnwdad2
