    <DbClassMap file="cmtrans"/>
    <JadeMethod name="getTrainCode" id="3b60046a-b7b9-4b78-ab94-8e0b4ca36069">
        <source>getTrainCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 January 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
04 Aug 2023		navlw1	ChangeRequest 59284:[59660] EUP | FR - VAS Work Order Transactions - Fixing Duplicate Values

*/

vars

begin
	if self.myWorkOrderDetail = null then
		return null;
	endif;

	if self.myWorkOrderDetail.CM_WodToDoTrain.allTrains.isEmpty() then
		return null;
	endif;
	
	return self.myWorkOrderDetail.CM_WodToDoTrain.allTrains.listStringNoDuplicate(Comma,CM_Train::code.name); // 04.08.2023 navlw1 tfs #59284:#59660
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
