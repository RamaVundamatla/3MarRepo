    <JadeMethod name="validateLabel" id="d05e84c1-af94-4895-b682-d8995fc48a18">
        <source>validateLabel() protected;
// ---------------------------------------------------------------------------
// Created:     04 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pos : Integer;
begin

	
	if self.label[1] = '_' and (not self.isGap()) then
		app.raiseCMException(Label_Blank_Grid_Gap, null, null);
		return;
	endif;
	
	//epr par 21526 - add validation to model to not allow spaces
	pos:=1;
	self.label.scanUntil(Space,pos);
	if pos &lt;&gt; 0 then
		app.raiseCMException2(ERR_INVALID_VALUE," label", "Can not include spaces.", null, null);
		return;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
