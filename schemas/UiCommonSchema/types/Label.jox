<GUIClass name="Label">
    <JadeMethod name="setCaptionForMeasurementType" id="8f306e44-b877-4248-b7d2-301ecaa08d6f">
        <updating/>
        <source>setCaptionForMeasurementType(_measurement: String) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2013	cnwdap1	Initial creation
*/
vars
	measure 	: CM_MeasurementType;
	length 		: Integer;
	hasColon	: Boolean;

begin
	measure := app.getDefaultMeasurementForType(_measurement);
	length := self.caption.length;
	if self.caption[length:end] = Colon then
		hasColon := true;
		self.caption := self.caption[1:length-1];
	endif;
	
	self.caption := self.caption &amp; Space &amp; Left_Round_Bracket &amp; measure.shortName &amp; Right_Round_Bracket;
	if hasColon then
		self.caption := self.caption &amp; Colon;
	endif;
epilog

end;</source>
        <Parameter name="_measurement" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCaptionForTranslation" id="1c42d500-ca0a-42e1-9db6-f6eed67f5023">
        <updating/>
        <source>setCaptionForTranslation(_str: String) updating;
//15 October 2009	cnwml2


vars

begin
	inheritMethod(_str);
	self.caption := _str;
epilog

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
</GUIClass>
