    <JadeMethod name="validateForStatus" id="487c64ed-54f1-47f1-94a0-ebd5ffa09290">
        <source>validateForStatus();
// ##### CR 64615 TASK 64646 NAVAB1 03JUL2024
vars
	voyProcess : CM_VoyageProcess;
begin
	
	if self.myVoyageStatusForClosure = null then
		app.raiseCMException(Requir_voyage_status_auto_clos,null,null);
	endif;
	
	voyProcess := app.myRoot.allVoyageProcesses[VoyageProcessAutomatic]; // ### JIRA 33001 03OCT2024 NAVAB1
	if not voyProcess.allStatuses.includes(self.myVoyageStatusForClosure) then
		app.raiseCMException(Auto_closu_statu_must_statu_au,null,null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="13fbbe6f-173d-4660-b4d8-c7569f3a4814">
        <source>validateForUpdate();
// ##### CR 64615 TASK 64646 NAVAB1 03JUL2024
vars
	voyProcess : CM_VoyageProcess;
begin
	
	if self.myTranshipDischargeLC = null then
		app.raiseCMException(Auto_movem_confi_requr_disch_y,null,null);
	elseif not self.myTranshipDischargeLC.isYardLocation() then
		app.raiseCMException(Discha_locati_must_yard_locati,null,null);
	endif;
	
	if self.minutesOffset &lt; -600 or self.minutesOffset &gt; 600 then
		app.raiseCMException(Minut_offse_only_withi_minut_h,null,null);
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
