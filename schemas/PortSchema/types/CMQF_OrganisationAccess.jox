/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

begin

	self.myOrganisation := _object;

epilog

end;</source>
        <Parameter name="_object" type="CM_Organisation"/>
    </JadeMethod>
