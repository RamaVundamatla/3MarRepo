    <JadeMethod name="isTopTI" id="bc77c5bd-4f3c-4f64-ad40-c0a75fb3fb39">
        <source>isTopTI(ti: CM_TrackedItem; mode: Integer): Boolean;
/*
 ------------------------------------------------------------------------
Created:			04 December 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	array : CM_TIArray;
begin

	if not self.isOverStowPossible then
		return true;
	endif;
	
	create array transient;
	self.getTIs(array, mode, true); // PAR 27749
	if not array.includes(ti) then
		return false;
	endif;
	return (array.last = ti);
epilog
	delete array;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isYardLocation" id="3ed3358e-a70e-48c1-96a7-b94441fd11b7">
        <source>isYardLocation(): Boolean;

// Created by cnwdvb1 on 21 March 2007

/*

Date		Who		Reason
11 Jun 2009	cnwkpd1	PAR #19844 - Handle possible null myPrimaryQueue

*/

vars

begin
	// Par 13431
	if self.myMachine.myPrimaryQueue &lt;&gt; null and self.myMachine.myPrimaryQueue.isKindOf(CM_VoyageQueue) then
		return false;
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myTerminal" id="da42eb00-7f37-443a-8cf9-bb47c573e76a">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;

vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := null;
	
	if self.myMachine &lt;&gt; null then
		_value := self.myMachine.myTerminal;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Terminal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="76137828-22c7-4ab8-adb0-61425edfad93">
        <source>validateMoveTo(_control: CMIF_MoveController input);
/*

Date		Who		Reason
03 Feb 2015	cnwer1	Initial creation PAR 35635
05 Apr 2016	cnwkpd1	Issue found in Unit Test - should only be checking the config if machine
					is an IMV
					
*/

vars
	ti 		: CM_TrackedItem;
	remainingTEU,
	imvTEUCount,
	maxTEUCount : Integer;
begin
	inheritMethod(_control);

	if self.myMachine.machineType = MACHINETYPE_IMV then
		if _control.moveMode = REAL_MODE and _control.myTrackedItem.isKindOf(CM_Container) then
			maxTEUCount:=self.myTerminal.getConfig(NoIMVmoveTEUs).Integer;
			if maxTEUCount &gt; 0 then
				foreach ti in self.allTrackedItems discreteLock do
					if not ti.isContainer then
						continue;
					endif;
					imvTEUCount:=imvTEUCount + ti.getNumTEU.Integer;	
				endforeach;
				remainingTEU:=maxTEUCount - imvTEUCount;
				if remainingTEU &lt;= 0 then
					app.raiseCMException2(MACH_IMV_FULL, self.id.trimRight,_control.myTrackedItem.id,null,null);
				else
					if remainingTEU &lt;  _control.myTrackedItem.getNumTEU() then
						app.raiseCMException3(MACH_IMV_ALREADY_CONT,self.id.trimRight,_control.myTrackedItem.id,remainingTEU.asStringJMT,null,null);
					endif;
				endif;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
