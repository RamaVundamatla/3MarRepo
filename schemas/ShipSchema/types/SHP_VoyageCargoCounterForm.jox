    <JadeMethod name="addToolbarControls" id="7d658734-3bcb-40e3-851f-44e267bfb8a3">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Date		Who		Reason
18 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	frm			: CMUI_Toolbar;
begin	
	frm := self.frmToolbar;
	
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	frm.addButton(self.btnUserColours, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExportCSVQE, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	

	frm.addButton(self.btnCargoEnquiry, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSummariseAll, CMUI_Toolbar.Control_Alignment_Left);

	inheritMethod();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="c5dadc43-cb80-41ff-a006-3576a4c8efaa">
        <source>addToolbarControlsQuery() protected;
/*
Date		Who		Reason
18 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	frm			: CMUI_Toolbar;
begin	
	frm := self.frmQueryToolbar;

	frm.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
	
	
	inheritMethod();
end;</source>
        <access>protected</access>
    </JadeMethod>
