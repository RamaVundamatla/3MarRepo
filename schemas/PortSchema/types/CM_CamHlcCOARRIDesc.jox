    <JadeMethod name="getSenderCode_UNB" id="95db3848-8de3-4f0c-8e86-2211d7357aac">
        <source>getSenderCode_UNB(_protocol :CM_CamProtocol):String protected;
/*	
Return Value:	sender code to use in UNB segment

Date		Who		Reason
16 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
vars
	code		:String;
	terminal	:CM_Terminal;
begin
	code 		:= _protocol.camGroup.senderCode.trimBlanks;
	
	if code = null then
		terminal	:= _protocol.terminal;
		code 		:= terminal.getConfig(PortDestCode).String.trimBlanks;
	endif;
	
	// no translation
	
	return code;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageLOC" id="985ac2d4-4a24-47b8-94c2-088e4f9ca6e6">
        <source>makeMessageLOC(_protocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer; _ti :CM_TrackedItem) protected;
/*
Purpose: Refactored code

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
// 30 Nov 2017  cnwma1  TFS #7780: SNO - Tranship Discharge needs to use the incoming voyage info
vars
	terminal			:CM_Terminal;
	code, fCode, pCode,
	value				:String;
	location			:CM_LocationsController;
begin
	terminal	:= _protocol.terminal;
	
	// LOC+9 - load port
	code 		:= _ti.loadPort.trimRight;
	
	//30.11.2017 cnwma1 TFS #7780
	if _activity = COARRI_SHIPDISCHARGE then
		if _ti.isTranshipItem then
			if _ti.myTranshipDetail &lt;&gt; null then
				if  _ti.myTranshipDetail.importOriginalLoadPort &lt;&gt; null then
					code := _ti.myTranshipDetail.importOriginalLoadPort;
				endif;
			endif;
		endif;
	endif;
	
	fCode 		:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
	
	if fCode = null then
		fCode := code.trimRight;
	endif;
	
	self.makeLOCSegment (_protocol, _group, '9', fCode, '139', '6', null, null, null);
	
	if _activity = COARRI_SHIPLOAD then
		// LOC+11 - get the discharge port code
		code 	:= _ti.dischargePort;
		pCode 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
		
		if pCode = null then
			pCode := code;
		endif;
		
		pCode := pCode.trimRight;
		
		self.makeLOCSegment (_protocol, _group, '11', pCode, '139', '6', null, null, null);
				
		// LOC+147 - setup bay position
		location := _ti.getPrimaryLocation(REAL_MODE);
		
		if location &lt;&gt; null and location.isKindOf(CM_SlotController) and not location.isKindOf(CM_ShipBlockController) then
			value := location.CM_SlotController.getStowageId(_ti).trimRight;
			
			if value.length = 6 then 
				value := '0' &amp; value;		//ccms 1522
			endif;
			
			self.makeLOCSegment (_protocol, _group, '147', value, null, '5', null, null, null);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_RFF" id="7b7c6dc3-81be-455a-823f-2fb8ddf026ba">
        <updating/>
        <source>outputHeader_RFF(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _camMessage :CM_CamMessage input; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars

begin
	// do nothing - LOC not required
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_TDT" id="60ba3056-1e64-4d3d-ae4f-200874374964">
        <updating/>
        <source>outputHeader_TDT(_camTaskHistory :CM_CamTaskHistory input; _protocol :CM_CamProtocol; _camVoyage :CM_CamVoyage; _count :Integer io; _coll :HugeStringArray input) : String updating, protected;
/*
Purpose:		Output TDT+20 segment for voyage			

Date		Who		Reason
17 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
19 Dec 2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	voyage	:CM_Voyage;
	msg		:String;
	strLine : String;
begin
	voyage		:= _camVoyage.voyageOid;
	
	if _protocol.camGroup.useCallSign then
		msg := self.makeTDT20Segment (_protocol, _camVoyage.getSanitisedVoyageCode(), "1", 
									null, "HLCU", "172", "166", null, null, voyage.callSign.trimRight, '103', null, voyage.vesselName.trimRight.toUpper);
	else
		msg := self.makeTDT20Segment (_protocol, _camVoyage.getSanitisedVoyageCode(), "1", 
									null, "HLCU", "172", "166", null, null, voyage.lloydsNumber, '146', null, voyage.vesselName.trimRight.toUpper);
	endif;
	
	//this is a kludge until this can be sorted out properly by replacing StringArrays with HugeStringArrays
//	if msg.length &gt; 61 then
//		msg := msg[1:60] &amp; "'";
//	endif;
				
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, msg, _coll);	
	
	_count := _count + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camVoyage" type="CM_CamVoyage"/>
        <Parameter name="_count" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNB" id="48e2e323-1f6b-42bb-945f-b56a9a381296">
        <updating/>
        <source>outputHeader_UNB(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _seqNumber :Integer; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
vars
	
begin
	return self.outputFileMessage (_camTaskHistory, 
									self.makeUNBSegment (_protocol, "UNOA", 2, self.getSenderCode_UNB (_protocol), "ZZ", _protocol.camGroup.recipient.trimBlanks, "ZZ", _seqNumber, null, false, _camTaskHistory.runDateTime),
									_coll);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
