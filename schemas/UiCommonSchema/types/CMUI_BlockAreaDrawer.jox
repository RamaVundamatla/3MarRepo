    <JadeMethod name="getColumnLabels" id="46d5df04-1c92-4f82-a840-31cfc25d14b3">
        <source>getColumnLabels(columnLabels : StringArray io) protected;
// Return a collection of labels to use as column headings
// If less than 27 columns use A thru Z
// If between 27 and 676 use AA thru ZZ
// otherwise AAA thru ZZZ
// Assume max of 37856 columns (26*3)
vars
	indexes : IntegerArray;
	i : Integer;
begin
	if self.myTerminalArea.hasColumnLabels() then
		self.myTerminalArea.allColumnLabels.copy(columnLabels);
	endif;
	self.myTerminalArea.getDefaultColumnLabels(columnLabels);
epilog
	delete indexes;
end;
</source>
        <access>protected</access>
        <Parameter name="columnLabels" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getLabelOfCell" id="dc2658a8-b275-4692-b9ce-05c6ae18a731">
        <source>getLabelOfCell( x, y : Integer ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

	cell : CMUI_BlockGridCell;
	columnLabels : StringArray;
	rowLabels : StringArray;
	retStr : String;
	cellPoint : Point;
idx : Integer;
begin

	cellPoint := pixelToCell(x - self.myVLabels.width, y - self.myHLabels.height);
	
	idx :=  self.getCellIndex( cellPoint.x, cellPoint.y) ;
	
	if idx &lt; 1 or idx &gt; self.myCells.size() then // PAR 32886
		return null;
	endif;
	
	cell := self.myCells[idx].CMUI_BlockGridCell;
	
	if cell = null then
		return null;
	endif;
	
	create columnLabels transient;
	self.getColumnLabels(columnLabels);
	
	create rowLabels transient;
	self.getRowLabels(rowLabels);
	
	if cell.column &gt; columnLabels.size then
		return null;
	endif;
	
	if cell.row &gt; rowLabels.size then
		return null;
	endif;
	
	retStr := columnLabels[cell.column] &amp; "," &amp; rowLabels[cell.row];
	
	return retStr;

epilog

	delete columnLabels; 
	delete rowLabels;

end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationAt" id="2e67fbe7-8f89-49ef-9914-d52c490b9727">
        <source>getLocationAt(x, y : Integer) : CM_LocationsController;
//03 July 2008	cnwdw1	
// Return the location found at pixel point (x, y). The pixel point is relative to the
// blockFrame so need to allow for the label frames
begin
	return self.getLocationForCell(pixelToCell(x - self.myVLabels.width, y - self.myHLabels.height));
end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getLocationForCell" id="b3ee83e6-d606-4661-8783-ca3d750a2dd9">
        <source>getLocationForCell(cell: Point) : CM_IrregularBlockController protected;
// Return the location that contains this cell
vars
	location: CM_LocationsController;
	region: PointArray;
	topLeft, bottomRight: Point;
begin
	foreach location in myTerminalArea.allLocationsControllers do
		topLeft := location.CM_IrregularBlockController.region.first;
		bottomRight := location.CM_IrregularBlockController.region.last;
		if (not cell.leftOf(topLeft) and not cell.above(topLeft) 
			and not cell.rightOf(bottomRight) and not cell.below(bottomRight)) then
			return location.CM_IrregularBlockController;
		endif;
	endforeach;
	return null;
end;
</source>
        <access>protected</access>
        <Parameter name="cell" type="Point"/>
        <ReturnType type="CM_IrregularBlockController"/>
    </JadeMethod>
    <JadeMethod name="getRowLabels" id="1e9c0e2d-defb-420d-96ff-3f33962d5da5">
        <source>getRowLabels(rowLabels : StringArray io) protected;
// Return a collection of labels to use as row headings
vars
	i : Integer;
begin
	if self.myTerminalArea.hasRowLabels() then
		self.myTerminalArea.allRowLabels.copy(rowLabels);
	endif;
	self.myTerminalArea.getDefaultRowLabels(rowLabels);
end;
</source>
        <access>protected</access>
        <Parameter name="rowLabels" type="StringArray" usage="io"/>
    </JadeMethod>
