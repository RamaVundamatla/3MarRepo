	self.doResize();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblContextMnu" id="7da13d25-1199-4b18-bc55-30ae07934b28">
        <updating/>
        <source>doTblContextMnu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation

*/

vars
	lLeft 	: Real;
	tTop 	: Real;
	leftControl : Control;
	date : Date;
begin
	lLeft := x;
	tTop := y;

	conwin.windowToScreen(lLeft, tTop);
	self.screenToWindow(lLeft, tTop);   // convert x, y relative to form
	
	self.mnuDay.enabled := self.cmbPeriod.text &lt;&gt; ByDay;
	self.mnuWeek.enabled := self.cmbPeriod.text &lt;&gt; ByWeek;
	self.mnuMonth.enabled := self.cmbPeriod.text &lt;&gt; ByMonth;
	
	self.mnuDayMaint.enabled := app.getMyUser.canDo(self.myTerminal, PmAdmCalTermMaint);
	date := self.getDateFromTable();
	if date = null then
		self.mnuDayMaint.enabled := false;
		self.mnuDayMaint.caption := app.getErrorString(Maintain) &amp; " " &amp; app.getErrorString(Day);
	else
		self.mnuDayMaint.caption := app.getErrorString(Maintain) &amp; " " &amp; date.asStringJMT;
	endif;
	
	leftControl := self.splMain.getMyLeftControl();
	
	if leftControl.visible then
		self.mnuFiltSumm.caption := app.getErrorString(Hide_filter_summary);
	else
		self.mnuFiltSumm.caption := app.getErrorString(Show_filter_summary);
	endif;
	
	self.popupMenu(self.mnuCalendar, lLeft.Integer, tTop.Integer);
		
	return true;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDateFromTable" id="efeb9177-7d70-4f29-b235-8ab1bd090ab8">
        <source>getDateFromTable():Date;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation
// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	timeStampLocal : TimeStamp;
	date : Date;
	cell : JadeTableCell;
	cellControl : Control;
	dateStr : String;

begin

	date := null;
	
	if self.cmbPeriod.text = ByDay then

		dateStr := self.tblCalendar.getCellText( 1, 1 ).trimBlanks;
		if dateStr &lt;&gt; null and dateStr.asDateJMT.isValid then
			timeStampLocal.cnEcSetDateAndTime(dateStr.asDateJMT,TimeStartOfDay);
			//date := dateStr.asDateJMT;
		endif;
			
	elseif self.cmbPeriod.text = ByWeek or self.cmbPeriod.text = ByMonth then
	
		cell := self.tblCalendar.accessCell( self.tblCalendar.row, self.tblCalendar.column );
		if cell &lt;&gt; null then
			cellControl := cell.cellControl;
			if cellControl &lt;&gt; null and cellControl.isKindOf( CMUI_ListBox ) then
				dateStr := cellControl.CMUI_ListBox.itemText[1].trimBlanks;
				if dateStr &lt;&gt; null and dateStr.asDateJMT.isValid then
					timeStampLocal.cnEcSetDateAndTime(dateStr.asDateJMT,TimeStartOfDay);
					//date := dateStr.asDateJMT;
				endif;
			endif;
		endif;
	
	endif;
	
	return self.localToSystemTime(timeStampLocal).date();// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	//return date;

epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="54f1f04e-f1df-4c9c-a93b-f00f0539d9cb">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation

*/

vars

	xmlStr : String;
	leftControl : Control;

begin

	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; global.formatAsXML(self.cmbPeriod.name,self.cmbPeriod.text.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourCurrentDay, self.xmlColourCurrentDay.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourNonCurrMth, self.xmlColourNonCurrMth.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourDateBack, self.xmlColourDateBack.String);
	
	leftControl := self.splMain.getMyLeftControl();
	xmlStr := xmlStr &amp; global.formatAsXML(XML_ShowFilter, leftControl.visible.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_ShowFilterRatio, self.splMain.leftToRightRatio.String);
	
	return xmlStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="d05f55cf-96a4-456f-bfaa-98f36fcba76c">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation

*/

vars

	theXML,
	theXMLValue: String;
	index : Integer;
	leftControl : Control;

begin

	self.populateCombos();

	inheritMethod(_userWindow);
	
	theXML:= _userWindow.xmlInfo;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(self.cmbPeriod.name);
 	if theXMLValue &lt;&gt; null then
 		index := self.cmbPeriod.findStringExact(1, theXMLValue);
		if index &gt; 0 then
			self.cmbPeriod.listIndex := index;
		endif;
 	endif;
	
	self.xmlColourCurrentDay := theXML.cnEcGetTagValueOfName(XML_TagColourCurrentDay).Integer;
	self.xmlColourNonCurrMth := theXML.cnEcGetTagValueOfName(XML_TagColourNonCurrMth).Integer;
	self.xmlColourDateBack := theXML.cnEcGetTagValueOfName(XML_TagColourDateBack).Integer;
	self.setColours();
	
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_ShowFilterRatio);
	if theXMLValue &lt;&gt; null then
		self.splMain.setLeftToRightRatio( theXMLValue.Integer );
	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_ShowFilter);
	if theXMLValue &lt;&gt; null then
		leftControl := self.splMain.getMyLeftControl();
		if leftControl.visible &lt;&gt; theXMLValue.Boolean then
			self.doShowHideFilterSummary();
		endif;
	endif;
	
	
	

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTblCalendar" id="013d0571-dffa-429a-b59a-88e6dc947ab3">
        <source>initTblCalendar();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2010	cnwndl1	Initial creation
//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars
	
	pos : Integer;
	index : Integer;
	listBox : CMUI_ListBox;
	byDay : Boolean;
	byWeek : Boolean;
	byMonth : Boolean;
	numWeeks  : Integer;
	dayHeadings : String;
	
	today : Date;
	date : Date;
	monday : Date;
	timeStampSystem : TimeStamp;
		
begin
	//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	today := self.systemToLocalTime(app.actualTimeServer()).date();
	
	if not self.listBoxIndexArray.isEmpty then
		foreach pos in 1 to self.listBoxIndexArray.size do
			index := self.listBoxIndexArray[pos];
			listBox := self.lstActivity.getControl(index).CMUI_ListBox;
			if listBox &lt;&gt; null then
				delete listBox;
			endif;
		endforeach;
		self.listBoxIndexArray.clear();
	endif;
	
	self.tblCalendar.clear();
	self.allCalendarDatesDisplayed.clear();
	
	dayHeadings := dayListArray[1] &amp; Tab
					&amp; dayListArray[2] &amp; Tab
					&amp; dayListArray[3] &amp; Tab
					&amp; dayListArray[4] &amp; Tab
					&amp; dayListArray[5] &amp; Tab
					&amp; dayListArray[6] &amp; Tab
					&amp; dayListArray[7];
	
	byMonth := self.cmbPeriod.text = ByMonth;
	byWeek := self.cmbPeriod.text = ByWeek;
	byDay := self.cmbPeriod.text = ByDay;
	
	timeStampSystem.setDateTime(self.year,self.month,self.day,0,0,0,0);	// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	//date.setDate(self.day,self.month,self.year);
	if timeStampSystem.isValid then										// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		date := self.systemToLocalTime(timeStampSystem).date();			// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	else
		//if not date.isValid then
		date := today;
	endif;
	
	if byMonth then
	
		self.tblCalendar.columns := 7;
		self.tblCalendar.fixedColumns := 0;
		self.tblCalendar.rows := 1;
		self.tblCalendar.fixedRows := 1;
		
		self.tblCalendar.setCellText(1,1,dayHeadings);
		
		date.setDate(1,self.month,self.year);
		if date.dayOfWeek = 1 then
			monday := date;
		else
			monday := date.lastMonday;
		endif;
		self.setCellDataForWeek( date );
		monday := monday + 7;
		while monday.month = self.month do
			self.setCellDataForWeek( monday );
			monday := monday + 7;
		endwhile;
		
		self.reScaleWeekMonthHeight();
		
	elseif byWeek then
		self.tblCalendar.columns := 7;
		self.tblCalendar.fixedColumns := 0;
		self.tblCalendar.rows := 1;
		self.tblCalendar.fixedRows := 1;
		
		self.tblCalendar.setCellText(1,1,dayHeadings);
		
		self.setCellDataForWeek( date );
		
		self.reScaleWeekMonthHeight();
		 
		
	elseif byDay then
		self.tblCalendar.columns := 2;
		self.tblCalendar.fixedColumns := 1;
		self.tblCalendar.rows := 1;
		self.tblCalendar.fixedRows := 1;
		
		self.setCellDataForDay( date );
		
	endif;
	
	self.setFilterMacroInfo();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="eb24c592-168d-4052-97ae-75f7d34ceee0">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation

*/

vars

begin

	if keyCode = CMUI_Key_F3 then
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			inheritMethod(keyCode, shift);
		else
			if self.frmFilter.visible then
				self.frmFilter.visible := false;
			else
				self.showFilter();
			endif;
		endif;
		return;
	endif;

	inheritMethod(keyCode, shift);

epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="localToolBarResize" id="523fb2a0-915e-4fc9-abb9-a81d86b8411e">
        <source>localToolBarResize();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation

*/

vars

	toolbar	: CMUI_Toolbar;

begin

	toolbar	:=	self.frmToolbar;
	
	self.btnBack.caption := 215.Character;
	self.btnNext.caption := 216.Character;
	
	if toolbar.showCaptions then
		toolbar.height := toolbar.HeightWithCaptions;
		self.cmbPeriod.top := 9;
		self.mthPicker.top := 5;
		self.txtDate.top := 9;
		self.btnBack.top := 10;
		self.btnNext.top := 10;

	else
		toolbar.height := toolbar.HeightWithoutCaptions + 2;
		self.mthPicker.top := -2;
		self.cmbPeriod.top := 4;
		self.txtDate.top := 4;
		self.btnBack.top := 5;
		self.btnNext.top := 5;

	endif;
	
	self.mthPicker.left := 190;
	self.mthPicker.width := 300;
	self.mthPicker.maximumYear := 2200;
		
	self.txtDate.left := 190;
	self.txtDate.width := 125;
	
	self.btnBack.left := 320;
	self.btnNext.left := 340;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="lstActivity_dblClick" id="1caf4db3-e4f3-4233-bdf5-acbadca56667">
        <controlMethod name="CMUI_ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstActivity_dblClick(listbox: ListBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation

*/

vars

	date : Date;
	obj : Object;
	
begin

	obj := listbox.listObject;

	if obj = null then
		date := listbox.text.asDateJMT;
		if date.isValid then
			self.cmbPeriod.listIndex := self.cmbPeriod.findStringExact( 1, ByDay );
			self.txtDate.setDate(date);
			self.doChangeDate( true );
			return;
		endif;
	endif;

	if app.isAllowedToInspect then
		if obj &lt;&gt; null then
			obj.inspectModal();
		endif;
	endif;

epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
