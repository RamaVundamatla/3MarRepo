    <JadeMethod name="setupForm" id="c2f0bf6f-a822-4e10-879b-9188e3411ad7">
        <source>setupForm();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	points : RealArray;
begin
	self.cmbFillStyle.addItemAt("DrawFillStyle_Transparent",1);
	self.cmbFillStyle.addItemAt("DrawFillStyle_HorzLine",2);
	self.cmbFillStyle.addItemAt("DrawFillStyle_VertLine",3);
	self.cmbFillStyle.addItemAt("DrawFillStyle_UpDiagonal",4);
	self.cmbFillStyle.addItemAt("DrawFillStyle_DownDiagonal",5);
	self.cmbFillStyle.addItemAt("DrawFillStyle_Cross",6);
	self.cmbFillStyle.addItemAt("DrawFillStyle_DiagonalCross",7);
	self.drawFilledSquare(Window.DrawFillStyle_Cross);
	
	
epilog
	delete points;
end;</source>
    </JadeMethod>
</GUIClass>
