    <JadeMethod name="setAllPointsPoints" id="eeca508c-b292-4764-b723-d6b5eed1e33d">
        <source>setAllPointsPoints(_x1,_y1,_x2,_y2 : Real);
// ---------------------------------------------------------------------------
// Created:		05 July 2005 By Andrew Bishop cnwab1
//
// Purpose:		we want the first point to be the top left corner of the rectangle 
//				and the second point to be the bottom right hand corner
//
// ---------------------------------------------------------------------------

vars
	tmpPoint : Point;

begin
	// TopLeft to BotRight
	// _x1 = 50 _y1 = 125
	// _x2 = 600 _y2 = 455
	if _x2 &gt;= _x1 and _y2 &gt;= _y1 then
		tmpPoint.set(_x1.Integer,_y1.Integer);
		self.allPoints.add(tmpPoint);
		
		tmpPoint.set(_x2.Integer,_y2.Integer);
		self.allPoints.add(tmpPoint);
	// BotRight to TopLeft
	// _x1 = 600 _y1 = 455
	// _x2 = 50 _y2 = 125
	elseif _x1 &gt;= _x2 and _y1 &gt;= _y2 then
		tmpPoint.set(_x2.Integer,_y2.Integer);
		self.allPoints.add(tmpPoint);

		tmpPoint.set(_x1.Integer,_y1.Integer);
		self.allPoints.add(tmpPoint);
	// BotLeft to TopRight
	// _x1 = 50 _y1 = 455
	// _x2 = 600 _y2 = 125
	elseif _x2 &gt;= _x1 and _y1 &gt;= _y2 then
		tmpPoint.set(_x1.Integer,_y2.Integer);
		self.allPoints.add(tmpPoint);

		tmpPoint.set(_x2.Integer,_y1.Integer);
		self.allPoints.add(tmpPoint);
	// BotRight to TopLeft
	// _x1 = 600 _y1 = 125
	// _x2 = 50 _y2 = 455
	elseif _x1 &gt;= _x2 and _y2 &gt;= _y1 then
		tmpPoint.set(_x2.Integer,_y2.Integer);
		self.allPoints.add(tmpPoint);

		tmpPoint.set(_x1.Integer,_y1.Integer);
		self.allPoints.add(tmpPoint);
	endif;
end;</source>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setAllYABlocks" id="17fea3a9-4d75-4d18-8d00-b694ed1b234d">
        <source>setAllYABlocks(_objs : CMUI_GridObjectByX1Y1X2Y2Dict);
vars

begin
	self.allYABlocks.clear();
	_objs.copy(self.allYABlocks);
end;</source>
        <Parameter name="_objs" type="CMUI_GridObjectByX1Y1X2Y2Dict"/>
    </JadeMethod>
    <JadeMethod name="setCurrentEditYardAllocation" id="cd9ddedb-baa8-4a84-b561-46ad0a3af6ca">
        <updating/>
        <source>setCurrentEditYardAllocation(_ya: CM_YardAllocation) updating;
/*
Purpose: Set the YA currently being editted and update the graphic pane display

Date		Who		Reason
28 April 2011	cnwdw1	Initial creation
*/
vars
	rect: CMUI_ResizableRectFrame;
begin
	self.myCurrentEditYardAllocation := _ya;
	
	if not self.isYADisplayed(_ya) then
		// Add the YA to the display 
		self.getYardAllocationPoints(_ya, null);
		self.getYABlockPoints(_ya, null);
		self.drawYARectFrames(_ya);
	endif;
	
	if self.visible then
		foreach rect in self.allRectFrames do
			if rect.visible then
				rect.lockRect(rect.myObject.CMIF_YABlock.myYardAllocation &lt;&gt; self.myCurrentEditYardAllocation);
			endif;
			rect.isSelected := false;
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="02bf564e-5d2e-4bb0-ae61-3bc41961ad51">
        <updating/>
        <source>setForCreate(_edit : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _edit then
		self.name := "Overlay EDIT Frame";
	else
		self.name := "Overlay VIEW Frame";
	endif;

	self.bevelInner := Frame.Bevel_None;
	self.bevelOuter := Frame.Bevel_None;
	self.borderStyle := Frame.BorderStyle_None;
	self.boundaryWidth := 0;
	self.caption := null;
	self.visible := false;
	self.lockBottom := true;
	self.lockRight := true;
	self.inEditMode := _edit;
	self.stretchHeight := true;
	self.stretchWidth := true;
	create self.allPoints transient;
	create self.allRowPoints transient;
	create self.allColumnPoints transient;

end;</source>
        <Parameter name="_edit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setObjects" id="0d9b8679-4376-45dc-ac5f-81ffe1261499">
