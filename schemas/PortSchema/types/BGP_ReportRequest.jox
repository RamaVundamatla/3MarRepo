    <JadeMethod name="action" id="5f6c7e9c-3126-4320-b8e3-d1582de339eb">
        <updating/>
        <source>action(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     23 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	errCode		: Integer;
	errTxt,
	userCode,
	reportName	: String;
	user		: CM_User;
begin
	app.isReportWriter := true; // SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface to prevent errors from occurring in Invoicing
	on Exception do app.alertExceptionHandler(exception, null, 'Report Standard', errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	user := self.runReport();
epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	else
		if user &lt;&gt; null then
			userCode := app.getErrorString(For_User) &amp; user.code;
		endif;
		if self.myReportTemplate &lt;&gt; null then
			reportName := self.myReportTemplate.name;
		endif;
		app.createActivityHistory(ActivityHistoryGeneral, null, null, app.getErrorString1(Background_Report, reportName &amp; userCode &amp; ' ' &amp; self.printerName), false, false);
	endif;
	inheritMethod();
	app.isReportWriter := false;// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface.  Some Invoice objects call beginTransaction; which causes expected UHE's.
	return (errCode = null);

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="appendToOriginalFile" id="4054b140-4193-4ba2-b420-12b8d0f7760b">
        <source>appendToOriginalFile(_originalFile, _temporarySecondaryFile : String) protected;
// ---------------------------------------------------------------------------
// Created:     07 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	orginalFile, 
	tempFile	: File;
	blob		: Binary;
	msg : String;
begin

	// For Northport and there network.
	msg := 'Append to original file';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	process.sleep(5000);
	create orginalFile transient;
	orginalFile.mode		:=	File.Mode_Append;
	orginalFile.shareMode	:=	File.Share_Exclusive;
	orginalFile.kind		:=	File.Kind_Binary;
	orginalFile.fileName	:= 	_originalFile;
	// Create file.
	if not orginalFile.tryOpen() then
		msg := 'Unable to open file ' &amp; orginalFile.fileName;
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
	//	app.msgBox('Cannot open file ' &amp; _originalFile, 'Open', 0);
		return;
	endif;
	
	create tempFile transient;
	tempFile.mode		:=	File.Mode_Input;
	tempFile.shareMode	:=	File.Share_Exclusive;
	tempFile.kind		:=	File.Kind_Binary;
	tempFile.fileName	:= 	_temporarySecondaryFile;
	if not tempFile.tryOpen() then
		msg := 'Unable to open file ' &amp; tempFile.fileName;
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		return;
	endif;
	
	blob := tempFile.readBinary(tempFile.fileLength);
	orginalFile.writeBinary(blob);
	
	tempFile.close;
	orginalFile.close;
	tempFile.purge;
epilog
	delete tempFile;
	delete orginalFile;
end;</source>
        <access>protected</access>
        <Parameter name="_originalFile" type="String"/>
        <Parameter name="_temporarySecondaryFile" type="String"/>
    </JadeMethod>
    <JadeMethod name="createReports" id="63f2d27d-38db-4f07-add1-2559bd342214">
        <source>createReports(_pxyJadeReport : JadeReport input; _pxyFilter : CMQF_FilterReports; _blob : Binary output) : Boolean protected;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
03 Jan 2013	cnwrs1	32983 crash after user deleted.
13 Dec 2017	jlgkpd1	TFS #8294 - Initiate compact of transient file after running a report
12 Jan 2018 jlgmd1	TFS #36427 - DQM - Vessel Schedule Report
13 Mar 2025	jlizm1	MTN 34050 Successfully run reports created empty
19 Jan 2026 navah1	MTN-36669: PEN | Report Generation - SFTP Reports
*/

vars
	jrwManager			: JadeReportWriterManager;
	tmpJadeReport		: JadeReport;
	idx					: Integer;	
	repName,
	repNameLetter,
	iniFileName,
	secondFileName,
	tempDir,
	fileName 			: String;
	report				: JadeReportWriterReport;
	fileFolder			: FileFolder;
	theSchema			: Schema;
	reportClass			: Class;
	printForm			: Form;
	localBlob			: Binary;
	startTime			: TimeStamp;
	isSecondTime		: Boolean;
	tmpPrintData,
	pxyPrintData		: JadePrintData;
	partNum,
	pageNum				: Integer;
	reportArray			: StringArray;
	passport			: CM_Passport;
	documentType		: Integer;
	msg 				: String;
	filter				: CMQF_FilterReports;
begin

	passport := app.myPassport;
	
	jrwManager := app.createReportWriterManager();
		
	create reportArray transient;
	create tmpJadeReport transient;
	app.printer.printPreview := false;
	documentType := app.printer.getDefaultDocumentType ();
	
	//Print the report
	if not self.myReportDef.isFormBasedReport then

		filter := self.myFilter;		//TFS 36427
		//If we've been passed in a proxy filter, then use it instead
		if _pxyFilter &lt;&gt; null then		//TFS 36427
			filter := _pxyFilter;		//TFS 36427
		endif;							//TFS 36427
		
		app.myQAFilter.getReportsToRun(self.myReportDef, filter, reportArray);
	//	foreach idx in 1 to self.myReportDef.jrwReportName.size do
		foreach idx in 1 to reportArray.size do
			app.printer.setReport(tmpJadeReport);
			//repName := self.myReportDef.jrwReportName[idx];
			repName := reportArray[idx];
			msg := 'Running Report Writer report (' &amp; repName &amp; ')';
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
			// 7/6/2006 Lorcan If the printer is set up for letter try to get the report for letter (i.e repName followed by _L)
			if documentType = Print_Letter then
				repNameLetter := repName &amp; "_L";
				report := jrwManager.getReport(repNameLetter);
			endif;
		
			if report = null then
				report := jrwManager.getReport(repName);
			endif;
			
			if report = null then
				app.myTrxUA.trxUpdateMenuUserReportErrMsg(self.myReportTemplate, CM_MenuUserReport.MSG_INVALID_REPORT_NAME &amp; ' ' &amp; repName, passport);
				if (not passport.trxCompletedOK) then	
					app.raiseCMException1(BackgroundErrorGeneral, 'trxUpdateMenuUserReport failed', null, null);
					//????
				endif;
				self.myReportTemplate.sendCreatedEvent(true);
				app.raiseCMException1(BackgroundErrorGeneral, CM_MenuUserReport.MSG_INVALID_REPORT_NAME &amp; ' ' &amp; repName, null, null);
				return false;
			endif;
			
			if self.profileName &lt;&gt; null then
				report.setProfile(self.profileName);
			endif;
				
			self.setParameters(report, filter);
						
			if self.outputDestination = CM_QryReport.PDF_Format then
				report.setOutputDestination(report.PRINTER);
			else
				report.setOutputDestination(self.outputDestination);
			endif;
			
			if self.outputDestination = report.PRINTER or self.outputDestination = CM_QryReport.PDF_Format then
				msg := 'Attempting to set printer options';
				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
				//CNWTH2 - in Jade 6 setPrinterOptions doesn't exist - setPreviewOptions does the same anyway
				//report.setPrinterOptions(null, false, true, true, false, null);
				report.setPreviewOptions(false, false, false, true, null);
			else
				msg := 'Setting up CSV for report runner';
				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
				tempDir := self.myProcessingController.BGP_ReportController.tempFileLocation;
				app.checkTempDirFolderPath(tempDir, method.qualifiedName, BGP_ReportController.name &amp; '::' &amp; BGP_ReportController::tempFileLocation.name); //PAR22336 - cnwsh3 28/07/2010
				
				delete fileFolder;
				create fileFolder transient;
				fileFolder.fileName := tempDir;
				
				if not fileFolder.isAvailable then
					app.raiseCMException1(BackgroundErrorGeneral, 'File path ' &amp; fileName &amp; ' is invalid', null, null);
					return false;
				endif;
				
				if isSecondTime then
					secondFileName := tempDir &amp; 'TempCSV2_' &amp; app.actualTimeServer.date.formatAsYYYYMMDD() &amp; self.getInstanceIdForObject64(process).String &amp; '.txt';
					report.setOutputFileTitle(secondFileName);
				else
					fileName := tempDir &amp; 'TempCSV_' &amp; app.actualTimeServer.date.userFormat($CnCCYYMMDD_ns) &amp; self.getInstanceIdForObject64(process).String &amp; '.txt';
					report.setOutputFileTitle(fileName);
				endif;
			endif;
			msg := 'Starting to run report writer report';	
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
			startTime := app.actualTimeServer();
			app.lockKeeperNotifyStartActivity(startTime, method, null, self.myReportDef.getNameForLockKeeper(idx), passport);
			app.printer.suppressDialog := true;
			report.run;
			
			process.initiateTransientCompact();		// TFS #8294
			
			if not isSecondTime then
		//		tmpJadeReport := _pxyJadeReport.cloneSelf(true);
		//		tmpJadeReport.description := self.myReportDef.heading;
				isSecondTime := true;
			else
				if self.outputDestination &lt;&gt; report.PRINTER then
					self.appendToOriginalFile(fileName, secondFileName);
				endif;	
			endif;
			msg := 'Number of generated pages ' &amp; tmpJadeReport.printArray.size().String;
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
			foreach pxyPrintData in tmpJadeReport.printArray do
				msg := 'Adding print data' ;
				app.writeLog(msg,LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
	//			tmpPrintData := pxyPrintData.cloneSelf(true);
				_pxyJadeReport.printArray.add(pxyPrintData);
			endforeach;
			
			pageNum := tmpJadeReport.printArray.size();
			tmpJadeReport.printArray.clear();
			abortTransaction;
			app.lockKeeperNotifyEndActivity(startTime, true, passport);
			delete report;
		endforeach;
		msg := 'Report writer finished';
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		if self.outputDestination &lt;&gt; report.PRINTER and self.outputType &lt;&gt; self.FTP_SFTP then //19.01.2026 navah1 #MTN-36669
		//if self.outputDestination &lt;&gt; report.PRINTER then //19.01.2026 navah1 #MTN-36669
			beginTransaction;
				_blob := self.myReportTemplate.setFromFile(fileName, false, false);
			commitTransaction;
		endif;
	else
		// Do a static report.
		app.printer.setReport(_pxyJadeReport);
		msg := 'Running form based report';
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		theSchema := rootSchema.getSchema(self.myReportDef.schemaName);		// TFS 978 was currentSchema, no good when running from DevSchema JadeScript ...
		if theSchema &lt;&gt; null then
			reportClass := theSchema.getClass(self.myReportDef.formClassName);
			if reportClass &lt;&gt; null then
				create printForm as reportClass transient;
				startTime := app.actualTimeServer();
				app.lockKeeperNotifyStartActivity(startTime, method, null, self.myReportDef.getNameForLockKeeper(0), passport);
				localBlob := printForm.sendMsgWithParams('run', false, self.outputDestination &lt;&gt; report.PRINTER, self.myExtraDetail).Binary;
				app.lockKeeperNotifyEndActivity(startTime, true, passport);
				if localBlob &lt;&gt; null then
					_blob := localBlob;
					self.myReportTemplate.setFromBlob(localBlob);
				endif;
			endif;
		endif;
	endif;
	_pxyJadeReport.description := self.myReportDef.heading;
	return true;

epilog
	app.lockKeeperNotifyEndActivity(startTime, true, passport);
	delete jrwManager;
	delete printForm;
	delete fileFolder;
	delete tmpJadeReport;
	delete report;
	delete reportArray;
end;
</source>
        <access>protected</access>
        <Parameter name="_pxyJadeReport" type="JadeReport" usage="input"/>
        <Parameter name="_pxyFilter" type="CMQF_FilterReports"/>
        <Parameter name="_blob" type="Binary" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="df0c33a8-2ca2-480f-8669-963b22ffbbb3">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	invalidRef : Boolean;

begin

	//13 June 2013	NDL	Par 31562
	on Exception do app.handleDeletedObject(exception, self.myReportDef, invalidRef );
	if self.myReportDef &lt;&gt; null then
		//bogus one created in CM_ReportTemplate
		if self.myReportDef.isSystemMenuItem and self.myReportDef.myMenuReportRoot = null then
			delete self.myReportDef;
		endif;
	endif;

//	delete self.myFilter;
	delete self.myExtraDetail;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doFiltering" id="787ae6d7-dce0-430c-92b9-fab4fd33b630">
        <source>doFiltering(_pxyFilter : CMQF_FilterReports output) : Boolean protected;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	pxyFilter			: CMQF_FilterReports;
	numItems			: Integer;
	msg : String;	
begin	
	pxyFilter := self.myFilter.cloneSelf(true);
	pxyFilter.cloneReferences(self.myFilter, true);
	
	numItems := self.myReportDef.doFilter(pxyFilter, app.myPassport);
	msg := 'Data filter run. ' &amp; numItems.String &amp; ' items returned';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
// CCMS 1250 Reports now continue regardless and display not data message. 
	if numItems = 0 and not app.myRoot.getConfig(RunReportWhenNoData).Boolean then
		app.myTrxUA.trxUpdateMenuUserReportErrMsg(self.myReportTemplate, CM_MenuUserReport.MSG_NO_ITEMS_FOUND, app.myPassport);
		if (not app.myPassport.trxCompletedOK) then
			app.raiseCMException1(BackgroundErrorGeneral, 'trxUpdateMenuUserReport failed', null, null);
			//????
		endif;
		self.myReportTemplate.sendCreatedEvent(true);
		return false;	
	endif;

	return true;

epilog
	_pxyFilter := pxyFilter;
end;</source>
        <access>protected</access>
        <Parameter name="_pxyFilter" type="CMQF_FilterReports" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintPDF" id="8357c8b2-7fed-4fa0-9c68-9af58454276d">
        <source>doPrintPDF(_printer :  CM_PrinterDef; _jadeReport : JadeReport; _reportTemplate : CM_ReportTemplate input;  _onlyBlob : Boolean) : Binary;
// -------------------------------------------
// Created 01 September 2004 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
13 Mar 2025	jlizm1	MTN 34050 Successfully run reports created empty
23 Apr 2025	jlizm1	MTN 34729 STWO Implement Handling for Intermittent PDF Print Failures in BGP Reports
	
*/

constants
	RetryLimit : Integer = 4;
	
vars
	tmpDir,
	fileName		: String;
	binary			: Binary;
	thePaperSource,
	i				: Integer;
	msg				: String;
	jadePage		: JadePrintData;
	excOccurred 	: Boolean;
	file			: File;
	delay			: Integer;	
	strArray		: StringArray;
	printArrayEmpty	: Boolean;
	
begin
	if _printer = null or 
	   not _printer.printerIsPDF then
		return null;
	endif;
	
	if self.setPrinter(_printer.physicalPrinterName) then
		//PAR22336 - cnwsh3 28/07/2010 - need the ability to process files off the Windows System directory drive for managed services.
		tmpDir := self.myProcessingController.BGP_ReportController.tempFileLocation;
		app.checkTempDirFolderPath(tmpDir, method.qualifiedName, BGP_ReportController.name &amp; '::' &amp; BGP_ReportController::tempFileLocation.name); //PAR22336 - cnwsh3 28/07/2010
		
		fileName := tmpDir &amp; 'Temp_' &amp; app.actualTimeServer.date.formatAsYYYYMMDD() &amp; self.getInstanceIdForObject64(process).String &amp; '.pdf';
		app.printer.printPreview := false;
		// DVB testing whether this resolves paper source crash 19/07/2007 PAR 14969
		thePaperSource := app.printer.getDefaultPaperSource();
		
		printArrayEmpty := _jadeReport.printArray.isEmpty;
		
		beginTransaction;
		foreach jadePage in _jadeReport.printArray do
			jadePage.JadePrintPage.setPropertyValue(JadePrintPage::paperSource.name, thePaperSource);
		endforeach;
		commitTransaction;
		
		app.printer.setPrintFileName(fileName);

		app.printerFixPAR34782(_jadeReport);

		app.printer.printReport(_jadeReport);
		process.sleep(1000);	// apparently have previously had issues with file not being available when it should be
		
		if not printArrayEmpty then
			// don't expect to get this far with nothing to print, but if we do, don't bother trying to keep reprinting it
			create file transient;
			file.fileName := fileName;
			
			foreach i in 1 to RetryLimit do
				// if file comes out empty when it shouldn't be, wait and retry print
				if file.fileLength &gt; 0 then
					app.writeLog("File length is " &amp; file.fileLength.String, LogINFO);
					break;
				endif;
				app.writeLog("Printer created an empty file, trying again", LogINFO);
				file.purge;
				app.printer.setPrintFileName(fileName);
				
				delay := i * 1000; // increase delay on each retry
				process.sleep(delay);
				app.printer.printReport(_jadeReport);
				process.sleep(1000);
			endforeach;
			
			if file.fileLength &gt; 0 then
				app.writeLog("Print to pdf complete", LogINFO);
			else
				// create alert so users know nothing printed
				msg :=  app.getErrorString(Printer_generated_empty_file);
				app.writeLog(msg, LogINFO);
				create strArray transient;
				msg := 'Background Error (' &amp; Printer_generated_empty_file.String &amp; ') ' &amp; msg;
				strArray.add(self.myReportDef.reportName &amp; ' user ' &amp; _reportTemplate.userCodeToRunAs);
				app.remoteErrorWarningToAlert(msg, null, null, strArray, true, true);
			endif;
		endif;

		if not _onlyBlob then
			beginTransaction;
			_reportTemplate.setOutputDestination(CM_QryReport.PDF_Format);
		endif;
		
		binary := _reportTemplate.setFromFile(fileName, _onlyBlob, false);
		
		if not _onlyBlob then
			commitTransaction;
		endif;
	
		return binary;
	endif;
	
	return null;
	
epilog
	delete file;
	delete strArray;
	
end;</source>
        <Parameter name="_printer" type="CM_PrinterDef"/>
        <Parameter name="_jadeReport" type="JadeReport"/>
        <Parameter name="_reportTemplate" type="CM_ReportTemplate" usage="input"/>
        <Parameter name="_onlyBlob" type="Boolean"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="b38ef458-e424-42f8-ad2e-0de4a885a534">
        <source>getDisplay(): String;

// cnwdvb1 17 February 2003 

vars

	user 	: CM_User;
	userStr	: String;

begin

	user := self.myUser;
	if user &lt;&gt; null then
		userStr := ' (' &amp; user.code &amp;')';
	elseif self.myReportTemplate &lt;&gt; null then
		userStr := ' (' &amp; self.myReportTemplate.userCodeToRunAs &amp; ')';
	endif;

	if global.isValidObject(self.myReportDef) then
		return inheritMethod() &amp; Tab &amp; app.getErrorString1(Background_Report, self.myReportDef.reportName &amp; userStr);
	endif;
	return inheritMethod() &amp; Tab &amp; app.getErrorString1(Background_Report, userStr);

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="45f9db51-bf9f-4bb3-968b-ddc58ab43a12">
        <source>getMyTerminal() : CM_Terminal;
// -------------------------------------------
// Created 13 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin

/*	if self.myMenuUserReport &lt;&gt; null then
		return self.myMenuUserReport.getMyTerminal();
	endif;*/
	return null;

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getPrinter" id="f5a17a92-4ff8-48aa-b0c3-a4d5f68d61ac">
        <source>getPrinter(_printerName : String) : CM_PrinterDef protected;
// -------------------------------------------
// Created 01 September 2004 by cnwdvb1
// -------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars

	printer2,
	printer				: CM_PrinterDef;
	needDefaultPDF		: Boolean;
	msg : String;
begin

	// Have changed it so we use the pdf printer specified
	// on the controller if possible when a pdf printer is required.
	
	if _printerName &lt;&gt; null then
		printer := app.myRoot.getPrinter(_printerName);
		//epr TFS 2728 23/9/16
		if printer = null  then
			printer := app.myRoot.findPrinterByPhysicalName(_printerName);
		endif;
	endif;
	
	// This is how a pdf printer is specified by background reports.
	if printer &lt;&gt; null and printer.printerIsPDF then
		needDefaultPDF := true;
	endif;
	
	// This is how a pdf printer is specified for the web.
	if self.outputDestination = CM_QryReport.PDF_Format then
		needDefaultPDF := true;
	endif;
	
	
	if needDefaultPDF then
		printer2 := self.myProcessingController.BGP_ReportController.myPDFPrinter;
		if printer2 &lt;&gt; null then
			msg := 'Using default PDF';
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
			return printer2;
		endif;
	endif;
	
	return printer;

end;</source>
        <access>protected</access>
        <Parameter name="_printerName" type="String"/>
        <ReturnType type="CM_PrinterDef"/>
    </JadeMethod>
