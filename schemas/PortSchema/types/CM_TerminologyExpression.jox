    <JadeMethod name="setForUpdate" id="d4d97749-8584-4b37-9d5f-0b4844692494">
        <updating/>
        <source>setForUpdate(_pxyTermExp : CM_TerminologyExpression; _termHdr : CM_TerminologyDef) updating;
// ---------------------------------------------------------------------------
// Created:     12 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.userExpression 		:= _pxyTermExp.userExpression;
	self.myTermTypeExpression 	:= _pxyTermExp.myTermTypeExpression;
	self.myTerminologyDef		:= _termHdr;

end;</source>
