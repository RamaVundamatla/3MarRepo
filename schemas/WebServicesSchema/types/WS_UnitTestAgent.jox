        <source>wsRESTGetCustomer(_paramString : String; _testDesc: String; _response : String io; _errors : String output) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
30 March 2023	navra1	Initial creation TFS 56641
20/07/2023		navcs2	ChangeRequest 57650: MTN - Refactor getCustomer(s) REST Webservice
26 Feb 2024 	navhn30 ChangeRequest 59198: MTN - REST GET /Customers and /Customer/Id TerminalConfiguration optional
04 Mar 2024		navlw1	ChangeRequest 62669: MTN - MTN | Unit Tests - add validation checks to getCustomer
*/

vars
	webService			: MasterTerminalAPIService;	
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	response 			: WS_Response;
	responseLogin  		: WS_NAuthTokenResponse;
	ref 				: String;
	customer 			: WS_RestCustomerObject;
	respCust 			: WS_CustomerArray;
	errorListStr 		: String;
	dict 				: WS_QueryStringParamDict;
	startFrom 			: Integer;
	relEnts 			: Boolean;
	spcConfig 			: Boolean;
	pos 				: Integer;
	custCode 			: String;
	jsonHelper 			: JMTJadeJson;

begin
	
	create webService transient;
	create parser transient;
	create transientJSONObjs transient;		
	
	self.loginREST(webService);	
	
	webService.qsData.parseNameValuePair(_paramString);
	
	pos := 2;
	custCode := _paramString.scanUntil('/?', pos);	
	
	response := webService.getCustomer(custCode);
	
	if response = null then
		return "Response is null"; 
	endif;
	
	// this will capture if we have any exceptions raised from the web call
	if response.allErrors.isNotEmpty then
		return response.allErrors.first.text;
	endif;
	
	create jsonHelper transient;
	_response := jsonHelper.generateJson(response.WS_CustomerResponse, JadeJson.Format_Json_Microsoft);

	//verification stuff
	if _testDesc = "existingCustomer_withRel" then		
		relEnts := true;
		respCust := response.WS_CustomerResponse.customers;
		self.verifySpecificCustomer(respCust, relEnts, null,custCode, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;
	elseif _testDesc = "existingCustomer_woRel" then		
		relEnts := false;
		respCust := response.WS_CustomerResponse.customers;
		self.verifySpecificCustomer(respCust, relEnts, null, custCode, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;	
	elseif _testDesc = "nonExistingCustomer" then		
		relEnts := false;
		respCust := response.WS_CustomerResponse.customers;
		self.verifySpecificCustomer(respCust, relEnts, null, custCode, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;
	elseif _testDesc = "existingCustomer_withSpConf" then			// 26.02.24		navhn30		TS #59198	
		spcConfig := true;
		respCust := response.WS_CustomerResponse.customers;
		self.verifySpecificCustomer(respCust, null, spcConfig, custCode, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;
	elseif _testDesc = "existingCustomer_woSpConf" then		
		spcConfig := false;
		respCust := response.WS_CustomerResponse.customers;
		self.verifySpecificCustomer(respCust, null, spcConfig, custCode, errorListStr);
		if errorListStr &lt;&gt; '' then
			_errors := errorListStr;
		endif;
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTGetCustomers.name; 
	
epilog
	webService.unitTestData.removeAssoc("HTTP_AUTHORIZATION");
	
	dict := webService.qsData;
	dict.purge();
	
	// 20/07/2023	navcs2	ChangeRequest 57650 Start
	// Removed code that deleted transients here and moved it to the classes themselves
	if webService.objectsToBeDeleted.isNotEmpty then
		webService.objectsToBeDeleted.purge;
	endif;
	// 20/07/2023	navcs2	ChangeRequest 57650 End
	
	delete webService;
	
	delete parser;
	transientJSONObjs.purge();
	delete transientJSONObjs;
	delete jsonHelper;
end;</source>
