vars

begin

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="66906352-a11c-4b88-a587-0b3a6b15eae2">
        <source>validateForUpdate(pExistingTemperatureConversion:CM_TemperatureConversion);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tempConv: CM_TemperatureConversion;
begin
	tempConv := app.myRoot.allTempsCelsius[celsius];
	if tempConv &lt;&gt; null and tempConv &lt;&gt; pExistingTemperatureConversion then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.celsius.String, null, null);
	endif;
	tempConv := app.myRoot.allTempsFahrenheit[fahrenheit];
	if tempConv &lt;&gt; null and tempConv &lt;&gt; pExistingTemperatureConversion then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.fahrenheit.String, null, null);
	endif;

	self.validateMe;
end;</source>
        <Parameter name="pExistingTemperatureConversion" type="CM_TemperatureConversion"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="7ed9e870-ff6b-495e-abb9-f3691fd6e9d8">
        <source>validateMe() protected;

vars
	calcFahreinheit:Real;
begin
	//cnwmc5 - 15 May 2014 - PAR 34156 - removed this warning because it defeats the purpose of manual temperature conversions..
	//calcFahreinheit := ((self.celsius*9/5)+32).roundedTo(1);
	//if self.fahrenheit &lt;&gt; calcFahreinheit then
	//	app.raiseCMWarning1(WARN_TEMPCONVERSION_WRONG, calcFahreinheit.String, null, null, self);
	//endif;	
	if self.fahrenheit &lt; -30 or fahrenheit &gt; 187 then
		app.raiseCMWarning1(ERR_INVALID_VALUE, "The temperatures entered are outside the Maersk Conversion Chart range. ",null, null,self);  
	endif;	
	if self.celsius &lt;&gt; self.celsius.Integer and
	   self.fahrenheit &lt;&gt; self.fahrenheit.Integer then
		app.raiseCMWarning1(ERR_INVALID_VALUE, "One of the temperatures should be a whole number to be on the Maersk Conversion Chart.",null, null,self);  
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
