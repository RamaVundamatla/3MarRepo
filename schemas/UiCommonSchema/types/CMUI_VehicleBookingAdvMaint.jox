    <JadeMethod name="createProxyVbsItems" id="803171df-768b-4231-9a26-49c006d0fe03">
        <updating/>
        <source>createProxyVbsItems(pxyVehicleBookingSlots : CM_VehicleBookingByTs io)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 December 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot (Task 55831)
25 Apr 2023 		navhl20 ChangeRequest 57733:[57734] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 02]
15 May 2023 		navhl20	Defect 57958:[57959] MTN - When bulk editing the carrier and sub-carrier, the VBS slot items are also getting changed.
11 Jul 2024			navpw1	TFS: 61525 (61527) - Added Max Weight Field

*/

vars
	vbsItem,
	proxyVbsItem	: CM_VehicleBookingTimeSlot;	
	item,
	newItem			: CM_VehicleBookingTimeSlotItem;
	itemSet,
	itemSetNew		: CM_VehicleBookingTSItemSet;
	ls 				: Boolean;
begin
	//delete self.myProxyVehicleBookingTimeSlot;
	
	app.cmsBeginLoad(ls);
	create itemSet transient;																							//24.4.2023 navhl20 #57733[57734]
	create itemSetNew transient;																						//24.4.2023 navhl20 #57733[57734]
	self.myProxyVehicleBookingTimeSlot.allVehicleBookingItems.copyNoDuplicates(itemSet,false);							//24.4.2023 navhl20 #57733[57734]
	foreach vbsItem in self.allVehicleBookingTimeSlots do
		//proxyVbsItem := vbsItem.pxyCreateUpdateProxy;																	//24.4.2023 navhl20 #57733[57734]
		//vbsItem.allVehicleBookingItems.copy(proxyVbsItem.allVehicleBookingItems);										//24.4.2023 navhl20 #57733[57734]
		if self.myProxyVehicleBookingTimeSlot.id = vbsItem.id then														//24.4.2023 navhl20 #57733[57734]
			proxyVbsItem := self.myProxyVehicleBookingTimeSlot;
		elseif app.myProxyManager.allReals.includesKey(vbsItem) then
			proxyVbsItem := app.myProxyManager.getProxyObject(vbsItem).CM_VehicleBookingTimeSlot;
		else
			proxyVbsItem := vbsItem.pxyCreateUpdateProxy;
		endif;
		if isVBSItemChanged then																							//15.5.2023 navhl20	#57958[57959]
			if self.myProxyVehicleBookingTimeSlot.id &lt;&gt; proxyVbsItem.id then												//24.4.2023 navhl20 #57733[57734]
				proxyVbsItem.allVehicleBookingItems.purge();
			endif;
			itemSetNew.clear();
			foreach item in itemSet do																						//24.4.2023 navhl20 #57733[57734]
				create newItem transient;
				newItem.setProxy(item.direction,item.myBooking,item.myBookingItem,item.myBulkRelease,item.myReserveDetails,item.myTrackedItem,proxyVbsItem,item.quantity,item.sequence,item.sourceType,item.weight, item.volume, // ### TFS 58256 02Jun2023 NAVPW1 - Added Volume
									item.maxWeight);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1 - Added MaxWeight
				itemSetNew.addNoDuplicates(newItem,false);
			endforeach;
			itemSetNew.copyNoDuplicates(proxyVbsItem.allVehicleBookingItems,false);											//24.4.2023 navhl20 #57733[57734]
		endif;
		self.setPxyVehicleBookTimeSlot(proxyVbsItem, true);																//24.4.2023 navhl20 #57733[57734]
		pxyVehicleBookingSlots.addNoDuplicates(proxyVbsItem,false);
	endforeach;
	
epilog
	if isVBSItemChanged then																								//15.5.2023 navhl20	#57958[57959]
		itemSet.purge;
		delete itemSet;
	endif;
	delete itemSetNew;
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="pxyVehicleBookingSlots" type="CM_VehicleBookingByTs" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createPxyVehicleBookTimeSlot" id="5d45971e-57a4-4001-8457-20612749a722">
        <updating/>
        <source>createPxyVehicleBookTimeSlot() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot

*/

begin
	if self.vehicleBookingMode &lt;&gt; self.MODE_ADD then
		return;
	endif;
	
	create self.myProxyVehicleBookingTimeSlot as CM_VehicleBookingTimeSlot transient;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="ec505c94-d26f-4986-93a3-ed3214d77e9d">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
23 Dec 2022		navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
24 Apr 2023		navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
25 Apr 2023 	navhl20 ChangeRequest 57733:[57734] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 02]
04 May 2023 	navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
23 May 2023 	navma1  ChangeRequest 54049: EUP - VBS MTN - [9] - Linking Multiple Slots to Vehicle visit
24 May 2023 	navhl20 Defect 58041: MTN - Unable to copy the slots with the status "Booked - Current"
*/

vars
	newVehicleBookingTimeSlot	: CM_VehicleBookingTimeSlot;
	result						: Integer;
	proxyVbsItems				: CM_VehicleBookingByTs;
	vbTimeSlot					: CM_VehicleBookingTimeSlot;		
	vbsSlotType					: CM_VehicleBookingTimeSlotType;	// ### TFS 53898:[53961] 03Feb2022 NAVPW1
	numCopies					: Integer;
	itemSet						: CM_VehicleBookingTSItemSet;
begin
	
	if self.cmbVbsSlotType.listObject &lt;&gt; null then
		vbsSlotType := self.cmbVbsSlotType.listObject.CM_VehicleBookingTimeSlotType;
	endif;
	
	numCopies 	:= self.txtCopySlots.text.Integer;																		    //24.4.2023 navhl20 #57716[57718]
	vbTimeSlot  := self.myProxyVehicleBookingTimeSlot;																 	    // 23.12.2022 navak20 TFS 55979
	create itemSet transient;																								//24.4.2023 navhl20 #57733[57734]
	vbTimeSlot.allVehicleBookingItems.copyNoDuplicates(itemSet,false);														//24.4.2023 navhl20 #57733[57734]
	
	if vbTimeSlot.validateVbsSlotCriteria(CM_VehicleBookingTimeSlot.CHECK_MODE_VBSSLOT,null,itemSet) and 					//23.05.2023 navma1 #54049
		(self.vehicleBookingMode = self.MODE_ADD or self.vehicleBookingMode = self.MODE_UPDATE) then						// 23.12.2022 navak20 TFS 55979
		if not self.setPxyVehicleBookTimeSlot(vbTimeSlot, true) then														// 23.12.2022 navak20 TFS 55979
			return;
		endif;
		
		while true do
			if self.vehicleBookingMode = self.MODE_ADD then
				if numCopies = 1 then																						//24.4.2023 navhl20 #57716[57718]
					app.myTrxCA.trxCreateVehicleBookingAdv(vbTimeSlot, newVehicleBookingTimeSlot,false, app.myPassport);	//24.5.2023 navhl20 #58041
				else																										//24.4.2023 navhl20 #57716[57718]
					app.myTrxCA.trxCreateMultiVBSAdv(numCopies,vbTimeSlot, newVehicleBookingTimeSlot, app.myPassport);		//24.4.2023 navhl20 #57716[57718]
				endif;																										//24.4.2023 navhl20 #57716[57718]
			elseif self.vehicleBookingMode = self.MODE_UPDATE then
				app.myTrxUA.trxUpdateVehicleBookingAdv(vbTimeSlot, app.myPassport);
			endif;

			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				self.modalResult := IDOK;
				self.unloadForm();
				return;
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
			endif;
			return;
		endwhile;
	
	elseif self.vehicleBookingMode = self.MODE_UPDATE_BULK then
		create proxyVbsItems transient;
		self.createProxyVbsItems(proxyVbsItems);
		while true do
			app.myTrxUA.trxUpdateBulkVehicleBookingAdv(proxyVbsItems, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				self.modalResult := IDOK;
				if proxyVbsItems.isNotEmpty() then																					//24.4.2023 navhl20 #57733[57734]
					foreach newVehicleBookingTimeSlot in proxyVbsItems do
						newVehicleBookingTimeSlot.allVehicleBookingItems.purge();
						delete newVehicleBookingTimeSlot;
					endforeach;
				endif;
				proxyVbsItems.purge;																								//27.04.2023 navma1 #57716:[57718]
				delete proxyVbsItems;																								//27.04.2023 navma1 #57716:[57718]
				self.unloadForm();
				return;
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
			endif;
			return;
		endwhile;
		self.clearErrorWarnings();
		self.modalResult := IDOK;
		self.unloadForm();
	endif;
epilog
	delete itemSet;
	delete proxyVbsItems;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnCancel" id="c75d9dc9-8055-44e5-94c4-7ef165a2744f">
