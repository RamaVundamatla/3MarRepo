    <DbClassMap file="basedvr"/>
    <ImplicitInverseRef name="myTimeFrom" id="77b7c2d5-4e41-4f0d-bf40-75047fed7efe">
        <embedded/>
        <type name="CnEcTime"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTimeTo" id="b530b264-1d21-4979-ab27-cc7ef813da00">
        <embedded/>
        <type name="CnEcTime"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getTimeFrom" id="b4785d20-3565-40cc-b6e3-55b9fb2230ad">
        <source>getTimeFrom():Time;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Get the time from value.
//
// Parameters:	None
//
// Returns:		The time from value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myTimeFrom.timeClient;
end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="getTimeTo" id="29ceaf7d-2911-4fd4-a788-1ef0773c9f80">
        <source>getTimeTo():Time;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Get the time to value.
//
// Parameters:	None
//
// Returns:		The time to value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myTimeTo.timeClient;
end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="setTimeFrom" id="683f7e4f-931e-48cf-a217-8de73d206f38">
        <updating/>
        <source>setTimeFrom(pTimeFromObj:CnEcTime) updating;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Set the time from value object.
//
// Parameters:	pTimeFromObj - The time from object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(pTimeFromObj.timeClient, self.myTimeTo.timeClient) then
		self.myTimeFrom	:=	pTimeFromObj;
	endif;
end;</source>
        <Parameter name="pTimeFromObj" type="CnEcTime"/>
    </JadeMethod>
    <JadeMethod name="setTimeTo" id="ddbaf733-647e-4285-b50d-78372fe4a4d7">
        <updating/>
        <source>setTimeTo(pTimeToObj:CnEcTime) updating;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Set the time to value object.
//
// Parameters:	pTimeToObj - The time to object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(self.myTimeFrom.timeClient, pTimeToObj.timeClient) then
		self.myTimeTo	:=	pTimeToObj;
	endif;
end;</source>
        <Parameter name="pTimeToObj" type="CnEcTime"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="5eaa4624-0711-454c-92a4-c4b5b2edf8e7">
        <updating/>
        <source>updateMe(pTimeFrom:Time; pTimeTo:Time) updating;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Update the receiver's time range.
//
// Parameters:	pTimeFrom - The time from value.
//				pTimeTo - The time to value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(pTimeFrom, pTimeTo) then
		self.myTimeFrom.updateMe(pTimeFrom);
		self.myTimeTo.updateMe(pTimeTo);
	endif;
end;</source>
        <Parameter name="pTimeFrom" type="Time"/>
        <Parameter name="pTimeTo" type="Time"/>
    </JadeMethod>
</Class>
