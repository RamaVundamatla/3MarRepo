    <JadeMethod name="setupForm" id="377cfe02-26b2-45d5-90c1-13fd261b5aa1">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	now : Date;
begin
	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	self.frmProperties.height := PROPHEIGHT;
	inheritMethod();
	self.splMain.hideRightControl(true);

	
	// 35872 this doesn't actually use business unit
	self.caption := "Financial Period Maintenance";
	
	self.enableControls();
	
	self.initPropertyTable(ETDef_InvMaintPeriod);

	self.setNavigatorHeading(self.caption);
	
	self.loadPeriods();
	
	self.initMSG(self.msgPropTwo,"Debtors Available","Debtors Selected","displayMSGDebtors");
	self.shtPropTwo.visible := true;
	self.shtPropTwo.caption := "Debtors";

	self.beginNotification(app.myRoot, EVENT_FINPERIOD_CREATE, Response_Continuous, null);
	self.beginNotification(app.myRoot, EVENT_FINPERIOD_DELETE, Response_Continuous, null);
	self.beginNotification(app.myRoot, EVENT_FINPERIOD_UPDATE, Response_Continuous, null);
	self.tblProperties.setValueByName(ETRow_PeriodDate, now);

	
	self.lstData.defaultLineHeight := 30; // ### TFS 50421 27OCT2021 NAVAB1
	self.lstData.fontSize := 10; // ### TFS 50421 27OCT2021 NAVAB1
	
	self.btnBulk.enabled := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="showPropertyFrame" id="ce5f9ec6-b8d0-4c84-9b07-8a8c747966d6">
        <updating/>
        <source>showPropertyFrame(_entTableView: String; _mode: Integer; _actualHeight: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_entTableView, _mode, _actualHeight);
