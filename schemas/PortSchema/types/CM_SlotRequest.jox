    <JadeMethod name="isBulkReleaseEDIDraw" id="b455c4f0-635f-41e5-9107-8aefa6c75d69">
        <source>isBulkReleaseEDIDraw(_bulkRelease : CM_ReserveDetail output) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwmh5	Initial creation #20661

*/

vars
	bulkRelease : Boolean;
begin

	_bulkRelease := self.myBulkReleaseReserveDetail;
	
	if _bulkRelease = null then
		//if fortyBack then
		if self.getAttrIsBackend() then
			if self.mySlotRequestForward &lt;&gt; null then
				_bulkRelease := self.mySlotRequestForward.myBulkReleaseReserveDetail;
			endif;
		endif;
	endif;
	
	return _bulkRelease &lt;&gt; null;
epilog

end;</source>
        <Parameter name="_bulkRelease" type="CM_ReserveDetail" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCompletedBackend" id="55559380-cd94-4e93-a154-a197450f19d6">
        <source>isCompletedBackend() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 February 2013	cnwmc5	Initial creation

*/

vars
	fwdSlot : CM_SlotRequest;
begin

	/* WAS
	fwdSlot := self.getForwardSlotRequest();
	NOW */
	
	// PAR 31217 do not use self.getForwardSlotRequest(); it just gets the slot in the next bay and then just gets that slot's load request, 
	//					we want the forward request that will be created because this is 40 foot load colour coding so use the proper reference
	fwdSlot := self.mySlotRequestForward; 
	
	if fwdSlot &lt;&gt; null then
		if fwdSlot.isComplete then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
