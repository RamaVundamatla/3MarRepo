    <JadeMethod name="getOwnerString" id="9dae9dff-0a76-44c2-a434-39724b23bfc1">
        <source>getOwnerString(_short : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     25 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpStr : String;
	invalidOwner,
	invalidOperatorNew : Boolean;
	owner			   : CM_Operator;
	operatorNew		   : CM_Operator;
begin
	
	owner := self.myOwner;
	operatorNew := self.myOperatorNew;
	if owner &lt;&gt; null then
		//07/02/2011 cnwdz2 26874 start
		on Exception do app.handleDeletedObject(exception, owner, invalidOwner);			
		tmpStr := owner.code;
		if invalidOwner then
			return null;
		endif;	
		//tmpStr := self.myOwner.code;
		//26874 end
		
		if _short then 
			return tmpStr;
		endif;
		tmpStr := tmpStr &amp; " - " &amp; owner.description;
	elseif operatorNew &lt;&gt; null then
		//07/02/2011 cnwdz2 26874 start
		on Exception do app.handleDeletedObject(exception, operatorNew, invalidOperatorNew);	
		tmpStr := operatorNew.code;
		if invalidOperatorNew then
			return null;
		endif;	
		//tmpStr := self.myOperatorNew.code;
		//26874 end
		
		if _short then 
			return tmpStr;
		endif;
		tmpStr := tmpStr &amp; " - " &amp; operatorNew.description;
	else
		return null;
	endif;
	
	return tmpStr;
	
epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
