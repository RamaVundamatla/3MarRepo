    <JadeMethod name="cmbSearchFor_click" id="51783df3-43dd-45ec-89e6-e87e07857916">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSearchFor_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Mar 2023	navmv20 Bug 57023: EUP - inconsistent search behaviour with external number

*/

vars
	searchFor,
	invByInvoiceNum,
	invByLineNumber,
	invByInvExtInvNum,
	invByInvExtNum,
	invByNum		: String;
begin
	if self.cmbSearchFor.listIndex &gt; 0 then
		searchFor := self.cmbSearchFor.itemText[self.cmbSearchFor.listIndex];
	endif;
		
	invByInvExtInvNum := app.getErrorString(Inv_ext_inv_number);
	invByInvExtNum := app.getErrorString(Inv_external_number);
	invByInvoiceNum := app.getErrorString(Invoice_invoice_number);
	invByLineNumber := app.getErrorString(Invoice_line_number);
	
	self.textSearch.text := null;
	self.textSearch.maxLength := 9;

	if searchFor = invByInvExtInvNum or searchFor = invByInvExtNum then
		self.textSearch.maxLength :=50;
		self.textSearch.dataType := TextBox.DataType_AlphaNumeric;
	elseif searchFor = invByInvoiceNum or searchFor = invByLineNumber then
		self.textSearch.dataType := TextBox.DataType_Numeric;
		self.textSearch.maxLength := 9;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
