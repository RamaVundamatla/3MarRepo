    <JadeMethod name="extractInvoiceLineTranslation" id="110c645c-a174-4d58-8f12-1fb68c73dc21">
        <source>extractInvoiceLineTranslation(_file : File input; _bank : CM_Bank input) : Integer;
/*

Purpose:			Extracts all the invoice line translations for the bank

Parameters:			_file	File	The file to extract the translations to
					_bank	CM_Bank	The bank to get all the invoice line translations from for extracting

Return Value:		Integer	Representing the amount of records extracted

Date		Who		Reason
02 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

