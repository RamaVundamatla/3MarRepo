    <JadeMethod name="createRTGTelegram" id="a359bed1-bd3c-4e60-9008-38aa6af9a136">
        <updating/>
        <source>createRTGTelegram(_telegramStr : String input; _machine : CM_Machine input) :CM_RTGTelegram updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	twistLockXML : JadeXMLDocument;
	rootXMLElement,
	childElement : JadeXMLElement;
	num,
	ver,
	height,
	weight,
	length,
	xPos,
	yPos,
	locn,
	twistLock : String;
	pxyRTGTelegram,
	realRTGTelegram: CM_RTGTelegram;
	error : CM_Error;
begin
	if _telegramStr = null then
		//self.writeLog("twistlock info is null ???");
		return null;
	endif;
	//on JadeXMLException do self.xmlExceptionHandler(exception);
	
	create twistLockXML transient;
	twistLockXML.parseString(_telegramStr);
	rootXMLElement:=twistLockXML.rootElement;
	if rootXMLElement.tagName &lt;&gt; CM_RTGTelegram.XMLRoot then
		app.writeLog(method.name &amp; " -  xml root tag invalid is " &amp; CM_RTGTelegram.XMLRoot,0);
		return null;
	endif;
	
	if _machine = null then
		app.writeLog(method.name &amp; " machine is null",0);
		return null;
	endif;
	
	//get num 
	num:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLNum);	
	// get ver
	ver:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLVer);
	// get height
	height:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLHeight);
	// get weight
	weight:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLWeight);
	// get length
	length:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLLength);
	// get location
	locn:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLLocn);
	// get xPos
	xPos:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLXpos);
	//get yPos
	yPos:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLYpos);
	// get Twistlock
	twistLock:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLTwist);
	
	create pxyRTGTelegram transient;
	pxyRTGTelegram.setProxy(ver.Integer,
							height.Real,
							length.Integer,
							xPos.Real,
							yPos.Real,
							locn,
							twistLock.Character,
							weight.Real,
							num.Integer);
	//self.writeLog("machine is " &amp; _machine.String);
	app.myTrxCA.trxCreateRTGTelegram(pxyRTGTelegram,realRTGTelegram,_machine,app.myPassport);
	
	if app.myPassport.noErrors then
		if realRTGTelegram = null then
			app.writeLog("no errors but telegram is null",0);
		else
			app.writeLog("created telegram " &amp; realRTGTelegram.String,0);
		endif;
		return realRTGTelegram;
	else
	//	self.writeLog(method.name &amp; " had errors ");
	//create hand held errors
		foreach error in app.myPassport.allErrors do
			app.writeLog(method.name &amp; " -"  &amp; error.errorCode.String &amp; " - " &amp; error.text,0);
		endforeach;
	endif;
	
	return null;
epilog
	delete twistLockXML;
	delete pxyRTGTelegram;

end;</source>
        <Parameter name="_telegramStr" type="String" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <ReturnType type="CM_RTGTelegram"/>
    </JadeMethod>
    <JadeMethod name="delete" id="889a542e-2e0c-4d34-93c7-7d4487140b25">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	delete self.myAssistant;
	delete self.myConnection;
	app.finalize;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClose" id="b2f32651-5da3-4a02-b19c-e18ebebb144c">
        <source>doClose();
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.myConnection.state = Connection.Connected then
		self.myConnection.close;
	endif;
	write self.myConnection.state ;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCreateXMLString" id="19e604a2-60b9-4fb1-8916-9d12b78b1d2c">
        <source>doCreateXMLString();
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	telegramString : String;
	openStr,
	locStr,
	len,
	xpos,
	ypos,
	zpos,
	weight,
	str: String;
	ver,num : Integer;
begin

	ver:=1;
	if self.cmbLen.listIndex = -1 then
		app.msgBox("You must select length","Name",MsgBox_OK_Only);
		return;
	endif;
	len:=self.cmbLen.itemText[self.cmbLen.listIndex];
	xpos :=self.txtXpos.text.trimBlanks;
	ypos :=self.txtYPos.text.trimBlanks;
	zpos := self.txtZpos.text.trimBlanks;
	locStr :=self.txtLoc.text.trimBlanks;
	if self.chkTLOpen.value then
		openStr :="O";
	else
		openStr :="C";
	endif;
	
	weight :=self.txtWeight.text;
	num :=12;
	
	telegramString:="&lt;MSG&gt;&lt;VER&gt;" &amp; ver.String &amp; "&lt;/VER&gt;&lt;LEN&gt;" &amp; len &amp; "&lt;/LEN&gt;&lt;XPOS&gt;"
					&amp; xpos &amp; "&lt;/XPOS&gt;&lt;YPOS&gt;" 
					&amp; ypos &amp; "&lt;/YPOS&gt;&lt;ZPOS&gt;"
					&amp; zpos &amp; "&lt;/ZPOS&gt;&lt;LOCN&gt;"
					&amp; locStr &amp; "&lt;/LOCN&gt;&lt;TWL&gt;"
					&amp; openStr &amp; "&lt;/TWL&gt;&lt;WGHT&gt;"
					&amp; weight &amp; "&lt;/WGHT&gt;&lt;NUM&gt;"
					&amp; num.String &amp; "&lt;/NUM&gt;&lt;/MSG&gt;" &amp; CrLf;
					
	self.txtXMLDetails.text:=telegramString;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOpen" id="d1a8c7c8-62b9-47c4-9759-6e27563e9897">
        <source>doOpen();
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 March 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if txtName.text = null then
		app.msgBox("You must input Com Port name","Name",MsgBox_OK_Only);
		return;
	endif;
	

	self.myConnection.name:=txtName.text.trimBlanks;
	self.myConnection.timeout:=60000;//txtTimeout.text.Integer;
	self.myConnection.JadeSerialPort.usePresentationClient:=false;

	
	app.writeStatement( self.txtSpeed.text.trimBlanks);
	self.myConnection.JadeSerialPort.speedBps := 57600;//self.txtSpeed.text.trimBlanks.Integer; //usually default to 56700
	self.myConnection.JadeSerialPort.dataBits := WinCEJadeSerialPort.DataBits8;//self.cmbDataBits.itemText[self.cmbDataBits.listIndex].Integer; //been using WinCEJadeSerialPort.DataBits8
	self.myConnection .JadeSerialPort.parity :=  WinCEJadeSerialPort.Parity_None;//self.cmbParity.itemText[self.cmbParity.listIndex].Integer;// been using WinCEJadeSerialPort.Parity_None;
	self.myConnection .JadeSerialPort.stopBits := WinCEJadeSerialPort.StopBits_1_0;//self.cmbStopBits.itemText[self.cmbStopBits.listIndex].Integer;// been using WinCEJadeSerialPort.StopBits_1_0;
	self.myConnection .JadeSerialPort.flowControl := WinCEJadeSerialPort.FlowControl_Hardware;//self.cmbFlowControl.itemText[self.cmbFlowControl.listIndex].Integer;// been using WinCEJadeSerialPort.FlowControl_Hardware;
	
	//self.myConnection.open;
	self.myConnection.openAsynch(self,TwistlockTester::doOpenSuccessful.name);

	self.shtTLDetails.enabled:=true;
	self.shtXMLDetails.enabled:=true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenSuccessful" id="200251ff-fb49-4190-be89-c1126e8d59cc">
