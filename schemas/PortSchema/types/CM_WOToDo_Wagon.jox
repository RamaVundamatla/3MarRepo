<Class name="CM_WOToDo_Wagon" id="3d0fbf46-6ae8-41f1-90de-19871e4b2011">
    <superclass name="CM_WOTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="getWagonCode" id="dec6c46a-8d9a-43fa-971c-e6093a5fcee5">
        <source>getWagonCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 January 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
04 Aug 2023		navlw1	ChangeRequest 59284:[59660] EUP | FR - VAS Work Order Transactions - Fixing Duplicate Values 

*/

vars

begin
	if self.myWorkOrderDetail = null then
		return null;
	endif;

	if self.myWorkOrderDetail.CM_WodToDoWagon.allWagons.isEmpty() then
		return null;
	endif;
	
	return self.myWorkOrderDetail.CM_WodToDoWagon.allWagons.listStringNoDuplicate(Comma, CM_Wagon::id.name); // 04.08.2023 navlw1 tfs #59284:#59660
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
