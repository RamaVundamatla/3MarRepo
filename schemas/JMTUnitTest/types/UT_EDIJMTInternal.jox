    <JadeMethod name="tRequestMultiLineAction" id="a028608f-3762-4fa6-bdab-ebfb1975c8c6">
        <source>tRequestMultiLineAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalRequestMultiLine";
	RELEASE_001 : String = "UT_REL2221011";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	relRequest : CM_BulkRelease;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	self.deleteReleaseRequest(RELEASE_001);
	relRequest := self.getReleaseRequest(RELEASE_001);
	self.assertIsDeleted(relRequest);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalRequestMultiLine xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalRequestMultiLine.xsd"&gt;
	&lt;AllRequestHeader&gt;
		&lt;RequestHeader&gt;
			&lt;allowCargoMultiReleases/&gt;
			&lt;customsAssistance/&gt;
			&lt;mtRelease&gt;true&lt;/mtRelease&gt;
			&lt;releaseByType&gt;true&lt;/releaseByType&gt;
			&lt;removeStops/&gt;
			&lt;requestDateDoUpdate/&gt;
			&lt;deliveryReason/&gt;
			&lt;bookingRef/&gt;
			&lt;businessUnit/&gt;
			&lt;cargoSubType/&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;carrierCode/&gt;
			&lt;consignee&gt;UTCOE&lt;/consignee&gt;
			&lt;consignor/&gt;
			&lt;consignorVoyage/&gt;
			&lt;customsAgent/&gt;
			&lt;deliveryReleaseNumber/&gt;
			&lt;description/&gt;
			&lt;destTerminal/&gt;
			&lt;destinationPort/&gt;
			&lt;dischargePort/&gt;
			&lt;freightForwarder/&gt;
			&lt;fullOrMT&gt;E&lt;/fullOrMT&gt;
			&lt;generatorType/&gt;
			&lt;id/&gt;
			&lt;loadPort/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;operatorGroup/&gt;
			&lt;releaseRequestNumber&gt;'&amp;RELEASE_001&amp;'&lt;/releaseRequestNumber&gt;
			&lt;releaseType/&gt;
			&lt;releaseTypeStr&gt;Rail&lt;/releaseTypeStr&gt;
			&lt;remarks/&gt;
			&lt;senderCode/&gt;
			&lt;statusBulkRelease&gt;Active&lt;/statusBulkRelease&gt;
			&lt;subTerminalCode&gt;UT_Depot&lt;/subTerminalCode&gt;
			&lt;trailerType/&gt;
			&lt;vesselName/&gt;
			&lt;voyageCode/&gt;
			&lt;estimatedRequiredDate/&gt;
			&lt;expiryTimeStamp/&gt;
			&lt;requestDate/&gt;
			&lt;AllRequestDetail&gt;
				&lt;RequestDetail&gt;
					&lt;checkISOGroup/&gt;
					&lt;clean/&gt;
					&lt;heavyDuty/&gt;
					&lt;isChild/&gt;
					&lt;isGeneratorAttachment/&gt;
					&lt;volume/&gt;
					&lt;weight/&gt;
					&lt;quantity&gt;1&lt;/quantity&gt;
					&lt;availabilityGrades/&gt;
					&lt;billOfLading/&gt;
					&lt;cargoSubType/&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;description/&gt;
					&lt;fullOrMT/&gt;
					&lt;id/&gt;
					&lt;ids/&gt;
					&lt;isoType&gt;22G1&lt;/isoType&gt;
					&lt;isoTypeGroup&gt;GEN2&lt;/isoTypeGroup&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;releaseRequestNumber&gt;'&amp;RELEASE_001&amp;'&lt;/releaseRequestNumber&gt;
					&lt;remarks/&gt;
					&lt;requestDetailID/&gt;
					&lt;sequence/&gt;
					&lt;stopsToApply/&gt;
					&lt;AllRequestCriteria&gt;
						&lt;RequestCriteria&gt;
							&lt;cargoTypeDescr/&gt;
							&lt;criteriaName&gt;Cargo Group ID&lt;/criteriaName&gt;
							&lt;criteriaValue&gt;8123928&lt;/criteriaValue&gt;
							&lt;description/&gt;
							&lt;fullOrMT/&gt;
							&lt;id/&gt;
							&lt;messageMode&gt;A&lt;/messageMode&gt;
							&lt;releaseRequestNumber/&gt;
							&lt;requestDetailID/&gt;
						&lt;/RequestCriteria&gt;
					&lt;/AllRequestCriteria&gt;
					&lt;AllTaskActionsToApply&gt;
						&lt;TaskActionsToApply&gt;
							&lt;bookingId/&gt;
							&lt;bookingItemSeq/&gt;
							&lt;cargoTypeDescr/&gt;
							&lt;description/&gt;
							&lt;fullOrMT/&gt;
							&lt;id/&gt;
							&lt;messageMode&gt;A&lt;/messageMode&gt;
							&lt;releaseRequestNumber/&gt;
							&lt;requestDetailID/&gt;
							&lt;taskCode&gt;UT_ToDo1&lt;/taskCode&gt;
							&lt;toDoRemarks&gt;To Do Task 1 Remarks&lt;/toDoRemarks&gt;
						&lt;/TaskActionsToApply&gt;
					&lt;/AllTaskActionsToApply&gt;
				&lt;/RequestDetail&gt;
			&lt;/AllRequestDetail&gt;
 		&lt;/RequestHeader&gt;
	&lt;/AllRequestHeader&gt;
&lt;/JMTInternalRequestMultiLine&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 4, "incorrect number of EDI trackedItems");
	relRequest := self.getReleaseRequest(RELEASE_001);
	self.assertNotNull(relRequest);
	self.assertEqualMsg(relRequest.consigneeCode, "UTCOE", "consigneeCode wrong");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tShipManifest" id="8edca51e-5a33-4b22-8aaa-27fe5ac5d14d">
        <source>tShipManifest();
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
// 21 Jun 2018	jlgrs1	TFS 39298 (TFS 36430) Penn Ship Manifest too many locks
// 10 Apr 2025	navdap1	MTN-14781 CPL | Increase BOL Field Length
constants
	USER_DEF_NAME : String = "JMTInternalShipManifest";
	ShipName	: String = "SHIPGEN";
	VoyageName	: String = "VOYSHIPGENXX";
	TestOperator = 'MSK';
	CONTAINER_ID01 : String = "TEST0000001";
	CONTAINER_ID02 : String = "TEST0000002";
	CONTAINER_ID03 : String = "TEST0000003";
vars
	containerObj : CM_TrackedItem;
	vesselObj : CM_Vessel;
	voyageObj : CM_Voyage;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	voyage : CM_Voyage;
	bol : CM_BOL;
	ti : CM_TrackedItem;
begin
	self.setTerminalConfig(EdiShipManAllowPartial, true);
	passportObj	:=	app.myPassport;
	self.deleteContainer(CONTAINER_ID01);
	containerObj := self.getTrackedItem(CONTAINER_ID01);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID02);
	containerObj := self.getTrackedItem(CONTAINER_ID02);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID03);
	containerObj := self.getTrackedItem(CONTAINER_ID03);
	self.assertIsDeleted(containerObj);
	self.deleteVoyage(VoyageName);
	voyageObj	:=	self.getVoyage(VoyageName);
	self.assertIsDeleted(voyageObj);
	self.deleteVessel(ShipName);
	vesselObj := self.getVessel(ShipName);
	self.assertIsDeleted(vesselObj);
	// now set up cleanly
	vesselObj := self.addVesselGeneralCargo(ShipName, self.getOperator(TestOperator), 10);
	self.assertNotNullMsg(vesselObj, 'Add vessel failed');

	voyageObj	:= self.addVoyageWithGeneralCargoStruc(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													10);
	self.assertNotNullMsg( voyageObj, 'Add voyage failed' );
	voyageObj := self.getVoyage(VoyageName);
	self.assertNotNull(voyageObj);
	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalShipManifest&gt;
&lt;AllBOLHeader&gt;
  &lt;BOLHeader&gt;
    &lt;bolType&gt;5003&lt;/bolType&gt;
