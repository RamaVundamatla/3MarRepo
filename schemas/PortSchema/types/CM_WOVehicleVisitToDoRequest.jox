<Class name="CM_WOVehicleVisitToDoRequest" id="a5ce74cd-8cea-4227-b8b8-78f6a07e9e25">
    <superclass name="CM_WOToDoRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <ExplicitInverseRef name="allVehicleVisits" id="65039712-7d8b-484a-97c2-2845f3332fc6">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_VehicleVisitRecordSet"/>
        <access>readonly</access>
        <Inverse name="CM_VehicleVisitRecord::allWorkOrderRequests"/>
    </ExplicitInverseRef>
    <JadeMethod name="createWLEs" id="ca7eb481-afff-4c5e-b6d6-f907718888ab">
        <source>createWLEs();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars
	aWLE				:	CM_WOVehicleVisitToDoWLE;
	vehicleVisitDetail	:	CM_VehicleVisitRecord;
	vehicleVisit		: 	CM_VehicleVisitRecord;	
	recordIter			: 	Iterator;	
begin
	recordIter := self.myJob.CM_WOToDoVehicleVisitJob.allVehicleVisits.createIterator();
	
	while recordIter.next(vehicleVisit) do
		create aWLE persistent;
		aWLE.setForCreate(self.myJob, self); 
		aWLE.setMyVehicleVisit(vehicleVisit);
	endwhile;
epilog
	delete recordIter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreateInternal" id="47efef86-8b80-44d1-a73b-0c5ca67f58f6">
        <updating/>
        <source>setForCreateInternal(_myJob: CM_WOToDoTaskJob; _toDoInternalJobParam: CMIF_WorkOrderJobParams) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars

begin
	inheritMethod(_myJob, _toDoInternalJobParam);
	
	self.myJob.CM_WOToDoVehicleVisitJob.allVehicleVisits.copy(self.allVehicleVisits);
epilog

end;</source>
        <Parameter name="_myJob" type="CM_WOToDoTaskJob"/>
        <Parameter name="_toDoInternalJobParam" type="CMIF_WorkOrderJobParams"/>
    </JadeMethod>
</Class>
