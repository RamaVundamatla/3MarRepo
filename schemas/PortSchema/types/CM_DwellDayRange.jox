    <JadeMethod name="isValueWithinRange" id="1e57fcd2-0a66-4193-bf83-29186878d8da">
        <source>isValueWithinRange( _int : Integer ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2011	cnwndl1	Initial creation	par 27890

*/

vars

begin

	if _int &gt;= lower then
		if _int &lt;= upper then
			return true;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_int" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
