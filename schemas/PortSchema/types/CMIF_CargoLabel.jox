		dischargePortCode := self.myBOL.dischargePort;
	elseif self.myGateReceival &lt;&gt; null then
		dischargePortCode := self.myGateReceival.dischargePort;
	elseif self.myGateReceivalByType &lt;&gt; null then			// 10/12/2010 cnwmh5 #26556
		dischargePortCode := self.myGateReceivalByType.myReceivalInfo.myBooking.dischargePort;
	endif;
	
	if dischargePortCode &lt;&gt; null then
		dischargePort := app.myRoot.allPorts[dischargePortCode];
		if dischargePort &lt;&gt; null then
			return app.getErrorString(DischargePort) &amp; "  =  " &amp; dischargePort.getDisplayDetails(false);
		endif;
	else
