    <JadeMethod name="createDefaultGraphic" id="0428c928-91f9-4648-bbf8-2c8c7cc9629b">
        <updating/>
        <source>createDefaultGraphic() updating;
/* ---------------------------------------------------------------------------
Created:     03 March 2009 by cnwrs2

Purpose:     Add in ability to create the graphic (par 18996)
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	xmlStr	: String;
	
begin

	if self.myGraphic = null then
		self.createGraphic();
	endif;
	
	if self.myGraphic.allCommands.isEmpty then
		xmlStr := self.getDefaultGraphicXML();
		if xmlStr &lt;&gt; null then
			self.myGraphic.setXMLData(xmlStr);
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createGraphic" id="e3899b1f-812e-4b5b-8cff-596f4c446ffc">
        <updating/>
        <source>createGraphic() updating;
// ---------------------------------------------------------------------------
// Created:		01 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		PAR 18996 - remove begin/commit transactions
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myGraphic = null then
		//beginTransaction;
		if self.isTransient then
			create self.myGraphic transient;
		else
			create self.myGraphic persistent;
		endif;
		
		//self.myGraphic.myTIBehaviour := self;	// should not need to do this as inversed
		//commitTransaction;
	endif;
end;</source>
    </JadeMethod>
