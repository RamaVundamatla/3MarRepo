    </JadeMethod>
    <JadeMethod name="setupForm" id="a7fc9e8d-2a3d-44f6-a731-9a426a64c601">
        <updating/>
        <source>setupForm() updating;
/*
Date		Who		TSF		Reason
05/08/2009	cnwjk3	Initial creation
14/04/2010	cnwdap1	PAR #23565 Add read-only freight forwarder
25/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk
18/03/2019	jlgdi1	TFS# 41721 Added btnCargoAvailabilityCheck
13/11/2019	jlgsl4	TFS 47373 - PEN - Save-Next prevents use of Remarks Additional
29 Nov 2019	jlgdi1	47771	Removed the line that determines if the cargo avaialbility check button is enabled or disabled
							Let the method enableByTypeFields() handles it
*/

vars
	terminal: CM_Terminal;
	settingDefaults: Boolean;
	comboWidth: Integer;
begin
	inheritMethod();

	terminal := self.getMyTerminal();
	if terminal &lt;&gt; null then
		settingDefaults := terminal.getConfig(UpdateReleasedCargo).Integer &lt;&gt; UpdateNone;		// 11/2/19 MAP TFS40701
	endif;

	self.loadCombos();
	self.txtNumItemsBB.enabled := false;								// 12/06/2013 cnwmh5 #31733

	if self.isFullContainer() then
		self.initFieldsForEntDefName(ETDef_ReleaseContainerFull, true);
		self.setupFormFull();
		self.btnCargoIDsearch.enabled := true;
	elseif self.isEmptyContainer() then
		self.initFieldsForEntDefName(ETDef_ReleaseContainerEmpty, true);
		self.setupFormEmpty();
		self.btnCargoIDsearch.enabled := true;
	elseif self.isGeneralCargo() then
		self.initFieldsForEntDefName(ETDef_ReleaseGeneralCargo, true);	
		self.btnCargoIDsearch.enabled:= false;
	endif;
	// set measurement tables up regardless												// PAR #33606
	self.tblTotalWeight.setup(Type_Weight, self.backColor);								// PAR #33606
	self.tblTotalVolume.setup(Type_Volume, self.backColor);								// PAR #33606
	self.tblWeight.setup(Type_Weight, self.backColor);									// PAR #33606
	self.tblVolume.setup(Type_Volume, self.backColor);									// PAR #33606
	self.tblWeightRequested.setup(Type_Weight, self.backColor);	//jlier1 TFS 53678 28/6/22
	self.txtReleaseWeight.setup(Type_Weight, self.backColor);	//29.Jan.24 navsp1 TFS 62064
	
	self.txtNumItems.setValue('1');
	// 23840 for release types where txtNumItems is not visible, the code setting the control inputKind to Integer from the 
	//	ent table row definition is not done so the txtNumItems.getInteger call in doSave doesn't return this value of 1
	//  as the inputKind is still 'String' from painter.  Fixed in code rather than painter for an easier 781 patch as well as being more explicit.
	self.txtNumItems.setInputKind("Integer");
	
	self.clearUpdReleasedCargoFields( null, settingDefaults );	//22 Aug 2019	NDL	TFS 46168
	
	if self.hasBulkRelease() then
		// We have opened from a PIN code
		self.setFieldsFromBulkRelease();
	elseif self.myTerminal.roadProcessIsASPA and self.myBOLDtl &lt;&gt; null then	//06 Oct 2020	NDL	TFS 49189
		// We have opened from a PIN code that was a BOL
		self.setFieldsFromBOLDetail();
	elseif self.myRealGTEEntity &lt;&gt; null then
		self.onContainerIdChange(self.myRealGTEEntity.id, self.myRealGTEEntity.CMGTE_Release.myTrackedItem);//17 Nov 2015	NDL	Par 37092
		self.setFieldsFromItem(self.myRealGTEEntity);
		//self.onContainerIdChange(self.myRealGTEEntity.id, self.myRealGTEEntity.CMGTE_Release.myTrackedItem);//cnwas3 par 21204
	elseif self.myRealGTEEntityToCopy &lt;&gt; null then
		self.setFieldsFromItem(self.myRealGTEEntityToCopy);
		self.txtCargoID.setValue(null);
	elseif self.myTI &lt;&gt; null then
		self.setFieldsFromItem(self.myTI);
	endif;

	//jlier1 TFS 53678 28/6/22
	if self.myReserveDetail &lt;&gt; null and self.myRealGTEEntity = null then
		if self.myReserveDetail.defaultAnyId then
			self.chkAnyId.setValue(true);
			chkAnyIdChanged();
		endif;
		if self.myReserveDetail.defaultAnyAmount then
			self.chkAnyAmount.setValue(true);
		endif;
	endif;
	
	self.doShowPicture();
	self.doSetCaption();

	if not self.isVVRUpdatable() then
		self.enableAllControls(false);
		self.btnCancel.enabled := true;
		self.grpAdditionalRel.enabled := true;
		self.btnAdditionalRel.enabled := true;		
	endif;
	
	// TFS# 41721
	if (self.isGeneralCargo()) and (self.isRoadGateCargoCheckSet()) then 
		self.btnCargoAvailCheck.visible := true;
		self.alignCargoCheckBtn();
	else
		self.btnCargoAvailCheck.visible := false;
	endif;
	
	// PAR #23565 freight forwarder is read-only
	self.cmbFreightFwdr.enabled:=false; // epr par 36674 1/9/15
	self.txtAddRemarks1.setIsEnabled(/*false*/true);	//04 May 2018	NDL	TFS 37795 // TFS 47373 - PEN want these fields to be editable
	self.txtAddRemarks2.setIsEnabled(/*false*/true);	//04 May 2018	NDL	TFS 37795 // TFS 47373

	comboWidth := terminal.getConfig(RoadGateReleaseItemWidth).Integer;		// 8/11/19 MAP TFS46955
	if comboWidth &lt;&gt; 0 then
		self.cmbReleaseItem.setListWidth(comboWidth);
	endif;
	
	self.initDetailsForByTypeByWeight();	//12.Dec.2023 navsp1 TFS 61547
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupFormEmpty" id="a4081916-68e8-4eec-ae16-e272be6400f1">
        <updating/>
        <source>setupFormEmpty() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwjk3	Initial creation

*/

vars
