    <JadeMethod name="initForm" id="2f9a4f85-ff79-40e2-b47c-3452a6c3c7e8">
        <updating/>
        <source>initForm() updating;
//05 August 2009	cnwdw1	
// 15/03/2010	cnwcs5	par 23159 - rationalise notification handling
vars

begin
	inheritMethod();
	
	self.initNotes();
	
	self.lblExpected.caption := app.getErrorString(Booking_Items);	
	//self.lblActual.caption := app.getErrorString(Cargo_Receivals);	
	//self.lblUnreconciled.caption := app.getErrorString(Unreconciled_Receivals);	
	
	self.btnEditRecon.caption := app.getErrorString(Edit_Booking);
	
	self.optBooking.value := true;

	if self.xmlStrTblExpected &lt;&gt; null then
		self.tblExpected.setTblDataEntRowsArray(app.myController.getEntTableDef(ETDef_BookRecon), null, self.xmlStrTblExpected);	
	else	
		self.tblExpected.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_BookRecon));
	endif;
	
	if self.xmlStrTblActual &lt;&gt; null then
		self.tblActual.setTblDataEntRowsArray(app.myController.getEntTableDef(ETDef_DefaultCargoEnt), null, self.xmlStrTblActual);	
	else	
		self.tblActual.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_DefaultCargoEnt));
	endif;
	
	if self.xmlStrTblUnreconciled &lt;&gt; null then
		self.tblUnreconciled.setTblDataEntRowsArray(app.myController.getEntTableDef(ETDef_DefaultCargoEnt), null, self.xmlStrTblUnreconciled);	
	else	
		self.tblUnreconciled.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_DefaultCargoEnt));
	endif;
// par 23159 - moved to initBookingNotes	
//	self.beginClassNotification(CM_BookingRef, false, self.myTerminal.getTerminalEvent(Event_BookingRefUpdate), Response_Continuous, 0);

	
end;</source>
    </JadeMethod>
    <JadeMethod name="initNotes" id="67fc377e-d6d9-42ce-92e0-c834f17dcd0c">
        <source>initNotes()protected;
// 12 August 2009	cnwdw1	
//	15/03/2010		cnwcs5	par 23159 - rationalise notification handling
vars

begin
	// a delete of any booking or booking item could affected what is displayed on this form
	self.beginClassNotification(CM_BookingRef, false, Object_Delete_Event, Response_Continuous, 0);
	// any update to any booking could affect what is displayed on this form
	self.beginClassNotification(CM_BookingRef, false, self.myTerminal.getTerminalEvent(Event_BookingRefUpdate), Response_Continuous, 0);
	// any change to booking or booking item on a ti
	self.beginClassNotification (CM_TrackedItem, false, self.myTerminal.getTerminalEvent(EVENT_TI_BOOKING_RECON), Response_Continuous, 0);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="inspectObject" id="c1ddb6ca-a822-4c66-912c-32b33d33e0fc">
        <source>inspectObject();
// ---------------------------------------------------------------------------
// Created:     12 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj 		: Object;
begin
	//obj := self.myBooking;
	obj := self.myCurrentObject;
	if obj &lt;&gt; null then
		obj.inspect;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadActualTable" id="f492b0ea-9380-4790-8762-4eaf19b357be">
        <source>loadActualTable();
//05 August 2009	cnwdw1	
// 15/03/2010	cnwcs5	par 23159 - use translation
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	rowString: String;
	bookingItem: CM_BookingRefItem;
	ti: CM_TrackedItem;
	obj : Object;
	
	itemCount : Integer;
begin
	if self.myBooking &lt;&gt; null then
		self.tblActual.clearAllData;
		itemCount := 0;
		beginLoad;
		if self.chkShowAllCargo.value then
			foreach bookingItem in self.myBooking.allBookingRefItems do
				foreach ti in bookingItem.allTIs do
					if not ti.isNotified then				//+cnwml2 PAR21736
						rowString := ti.getAttributeStringForDefArray(self.tblActual.allTblDataEntRows);
						self.tblActual.addItemObject(ti, rowString);
						itemCount := itemCount + 1;
					endif;
				endforeach;
			endforeach;
		else
			foreach obj in self.tblExpected.allSelectedObjects do
				bookingItem := obj.CM_BookingRefItem;
				foreach ti in bookingItem.allTIs do
					if not ti.isNotified then				//+cnwml2 PAR21736
						rowString := ti.getAttributeStringForDefArray(self.tblActual.allTblDataEntRows);
						self.tblActual.addItemObject(ti, rowString);
						itemCount := itemCount + 1;
					endif;
				endforeach;
			endforeach;
		endif;
		endLoad;
		self.lblActual.caption := app.getErrorString1 (CARGO_RECEIVED, itemCount.asStringJMT);	// par 23159 
		self.tblActual.colourRows(self.colorRow1, self.colorRow2);

		self.tblActualMacro.rows := 0;
		self.tblActualMacro.columns := 0;
	endif;

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;</source>
    </JadeMethod>
    <JadeMethod name="loadData" id="1a4caed8-9cd8-4c65-98f9-56d36eebf0a9">
        <updating/>
        <source>loadData()updating;
//05 August 2009	cnwdw1	
//
vars
	bItem : CM_BookingRefItem;
	expected : Integer;
begin
	//self.txtBooking.text := self.myBooking.bookingReference;
	//self.lblReconDetail.caption := app.getString( ReconBookDetails, self.myBooking.voyageCode, self.myBooking.dischargePort);
	if self.myBooking &lt;&gt; null then
	
		foreach bItem in self.myBooking.allBookingRefItems do
			expected := expected + bItem.quantity;
		endforeach;
		
		if self.myBooking.reconciliation then
			if self.myBooking.recReason &lt;&gt; null then
				self.lblReconDetail.caption := app.getString(ReconBookDetails, expected, self.myBooking.numTIs) &amp; " " &amp; app.getString(Reconciled) &amp; " - " &amp; self.myBooking.recReason;
			else
				self.lblReconDetail.caption := app.getString(ReconBookDetails, expected, self.myBooking.numTIs) &amp; " " &amp; app.getString(Reconciled);
			endif;			
		else
			self.lblReconDetail.caption := app.getString(ReconBookDetails, expected, self.myBooking.numTIs);
		endif;
		self.loadExpectedTable();
		self.loadActualTable();
		self.loadUnreconciledTable();
		self.loadReconComplete();
	else
		self.clearForm();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadExpectedTable" id="2c3b0440-2835-4fea-b90e-34283c041563">
        <updating/>
        <source>loadExpectedTable()updating, protected;
//05 August 2009	cnwdw1	
//18/03/2010		cnwcs5	par 23159
//08/04/2011		cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	table		: CM_DataTable;
	rowString	: String;
	bookingItem	: CM_BookingRefItem;
	selectedObj	: Object;
begin
	table		:= self.tblExpected;
	selectedObj := table.allSelectedObjects.first;
	
	table.clearAllData;
	
	
	foreach bookingItem in self.myBooking.allBookingRefItems discreteLock do
		rowString := bookingItem.getAttributeStringForDefArray(self.tblExpected.allTblDataEntRows);
		table.addItemObject(bookingItem, rowString);
	endforeach;

	
	table.colourRows(self.colorRow1, self.colorRow2);
	
	//+ cnwmd1 Par 21741
	table.selectObject(selectedObj, false);
	self.tblExpected_click(table);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadReconComplete" id="ce8aeffe-2929-45bc-8333-464012047da9">
        <source>loadReconComplete();
//18 September 2009	cnwml2


vars

begin
	self.chkReconciled.value := self.myBooking.reconciliation;
	self.dateComplete.text := self.myBooking.reconDate.asStringJMT;
	self.txtCompleteReaso.text := self.myBooking.recReason;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadUnreconciledTable" id="0e9bbac5-ab94-4d76-aa14-7f56624d737a">
        <source>loadUnreconciledTable();
// 05 August 2009	cnwdw1	
// 11/03/2010	cnwcs5	Use translated text for heading
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	rowString: String;
	ti: CM_TrackedItem;
	bookingItem: CM_BookingRefItem;
	bookings: CM_BookingRefsByRefDups;
	booking: CM_BookingRef;
	voyage: CM_Voyage;
	itemCount : Integer;


begin 
	self.tblUnreconciled.clearAllData;
	itemCount := 0;
	// from 29795 also clear the macro table
	self.tblUnreconMacro.rows := 0;
	self.tblUnreconMacro.columns := 0;

	if self.optVoyage.value then			// 29795 'voyage' option is to find all export cargo for this voyage with no booking ref
		voyage := self.myBooking.myVoyage;
		if voyage &lt;&gt; null then
			foreach ti in voyage.allExportTIs discreteLock do
				if ti.myBookingRefItem = null then
					rowString := ti.getAttributeStringForDefArray(self.tblUnreconciled.allTblDataEntRows);
					self.tblUnreconciled.addItemObject(ti, rowString);
					itemCount := itemCount + 1;
				endif;
			endforeach;
		endif;

	elseif self.optBooking.value or self.optAllBookings.value then
		create bookings transient;
		if self.optBooking.value then
			bookings.add(self.myBooking);
		elseif self.optVoyage.value then
			voyage := self.myBooking.myVoyage;
			if voyage &lt;&gt; null then
				voyage.allBookingRefs.copy(bookings);
			endif;
		elseif self.optAllBookings.value then
			self.myTerminal.getAllActiveBookingRefs(bookings);	
		endif;
		
		foreach booking in bookings discreteLock where booking.status = BOOKING_REF_ACTIVE  do

			foreach ti in booking.allTIs  discreteLock do
				// Look for TIs that do not have a booking item
				if ti.myBookingRefItem = null then
					rowString := ti.getAttributeStringForDefArray(self.tblUnreconciled.allTblDataEntRows);
					self.tblUnreconciled.addItemObject(ti, rowString);
					itemCount := itemCount + 1;
				endif;
				
			endforeach;

		endforeach;
	elseif self.optUnbookedCargo.value then
		//+cnwml2 PAR23809
		foreach ti in self.myTerminal.allOnsiteTIsByBookingRef discreteLock do
			if ti.myBookingRef &lt;&gt; null then
				break;
			endif;
			if ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_EXPORT then	//21 Nov 2013	NDL	Par 33013
				continue;
			endif;
			rowString := ti.getAttributeStringForDefArray(self.tblUnreconciled.allTblDataEntRows);
			self.tblUnreconciled.addItemObject(ti, rowString);
			itemCount := itemCount + 1;
		endforeach;
	endif;

	self.lblUnreconciled.caption := app.getErrorString1 (UNRECONCILED_CARGO, itemCount.asStringJMT);	// 11/03/2010 - make locale aware

	//+ cnwmd1 Par 21741
	foreach ti in self.allCurrentTrackedItems do
		self.tblUnreconciled.selectObject(ti, false);
	endforeach;
	self.tblUnreconciled.click(self.tblUnreconciled);
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete bookings;
end;</source>
    </JadeMethod>
