    <JadeMethod name="doHideSearcher" id="d74b106b-7f24-4bc0-a7ab-1d12a2f8af8f">
        <source>doHideSearcher();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 02 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	frame : CMUI_MoveableFrame;
begin
	frame := self.frmSearch;
	
	frame.parent := self;
	frame.centreHorizontallyInParent;
	frame.centreVerticallyInParent;
	frame.zOrder(0);
 	frame.visible := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuFormContextMenu" id="4f81e919-fba3-4dab-ac00-cf77dfe95c80">
        <updating/>
        <source>doMnuFormContextMenu(table: CM_DataTable input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 04 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description
18/06/2020		jlgmd1		49599		Refactor search to make it faster and less lock prone

****************************************************/
vars
	x1, y1				: Real;
	isShowDataMenus		: Boolean;
	isDataValidRow		: Boolean;
	locale				: CM_Locale;	
begin

	if self.frmSearch.visible or not table.rows &gt; table.fixedRows then
		return false;
	endif;

	// Determine the locale for translations.
	//locale := app.myCurrentLocale;
	
	if self.frmMode = self.Monitoring_Mode then
		// he stop processing menu will be part of a different TFS story always make this one invisible for a moment.
		self.mnuTblStopProcessing.visible := false;
		
		if app.myCurrentUserCan(self.myTerminal, PmMonitorControlEDI) then
			self.mnuTblStopProcessing.enabled := true;
		else
			self.mnuTblStopProcessing.enabled := false;
		endif;		
	else
		self.mnuTblStopProcessing.visible := false;
	endif;
	
	/*isShowDataMenus	:=	(table = tblLogInformation);
	
	if isShowDataMenus then
		isDataValidRow	:=	(table.row &gt; table.fixedRows);
	endif;*/

	x1	:=	x;
	y1	:=	y;
	
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;

	table.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	self.popupMenu(mnuTblViewContext, x1.Integer, y1.Integer);
	return false;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuTblViewEDIData" id="d384df3a-da78-41ba-b108-73bb0a23787b">
        <source>doMnuTblViewEDIData():CMUI_EDIForm protected;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 04 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	coll 		: ObjectArray;	
	ediFile		: CM_EDIFile;
	table		: CM_DataTable;
	rowPointer	: Integer;
	tableObj	: Object;
	ediAgent 	: CMUI_EDIAgent;
	ediData		: CM_EDIData;
	invalidObj : Boolean; 	//22 Nov 2019	NDL	TFS 47651
begin
	create ediAgent transient;
	
	table	:=	self.tblLogInformation.getControl(0);
	rowPointer	:=	table.row;
	tableObj	:=	table.accessRow(rowPointer).itemObject;
	
	ediAgent.setMyTerminal(self.myTerminal);
		
	ediFile := tableObj.CM_EDIFile;
	
	//22 Nov 2019	NDL	TFS 47651
	if ediFile = null then
		app.msgBox( app.getErrorString(Nothing_Selected), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return null;
	endif;
	on Exception do app.handleDeletedObject( exception, ediFile, invalidObj );
	
	ediData := ediFile.ediData;
	
	//22 Nov 2019	NDL	TFS 47651
	if invalidObj then
		app.msgBox( app.getErrorString(Selec_item_not_avail_been_dele), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return null;
	endif;
	
	if ediData = null then
		return null;
	endif;
	
	return ediAgent.showEDIForm(ediData, self.myMasterMenuAction, false, false);	
	
epilog
	delete ediAgent;
end;</source>
        <access>protected</access>
        <ReturnType type="CMUI_EDIForm"/>
    </JadeMethod>
    <JadeMethod name="doMnuTblViewRawEDIMessage" id="645dab1b-fbf2-4d89-800e-a461eb96000e">
        <updating/>
        <source>doMnuTblViewRawEDIMessage() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 04 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description
21/08/2023		navmd1		59024		Handle JSON messages
24/08/2023		navmd1	 	59451		Refactor EDI Ops/EDI Web Service viewer to call one method

****************************************************/

vars
	table			: CM_DataTable;
	rowPointer		: Integer;
	ediFile			: CM_EDIFile;
	tableObj		: Object;
	fileData		: CM_EDIData;
	invalidObj 		: Boolean; 	//22 Nov 2019	NDL	TFS 47651
	
begin
	table	:=	self.tblLogInformation.getControl(0);
	rowPointer	:=	table.row;
	tableObj	:=	table.accessRow(rowPointer).itemObject;
	
	ediFile := tableObj.CM_EDIFile;
	
	//22 Nov 2019	NDL	TFS 47651
	if ediFile = null then
		app.msgBox( app.getErrorString(Nothing_Selected), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, ediFile, invalidObj );
	fileData := ediFile.ediData;
	
	//22 Nov 2019	NDL	TFS 47651
	if invalidObj then
		app.msgBox( app.getErrorString(Selec_item_not_avail_been_dele), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	self.myEDIAgent.doEDIViewRawData(fileData, self);
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuTblViewRequest" id="eaf21f16-69ce-487b-8e8f-dda435703bc2">
        <source>doMnuTblViewRequest();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 04 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description
25/11/2019		jlgzm		TFS 47653	Changing how EDI Webservice Monitor displays XML
18/08/2023		navmd1		TFS 59024	Handle JSON POST /SendEDI requests

****************************************************/

vars
	table			: CM_DataTable;
	rowPointer		: Integer;
	ediFile			: CM_EDIFile;
	tableObj		: Object;
	selectText		: String;
	fileData		: String;
	invalidObj 		: Boolean; 	//22 Nov 2019	NDL	TFS 47651
	messageLogForm	: CMUI_MessageLogForm;	// TFS 47653
	startString		: String;
	match			: JadeRegexMatch;
	
begin
	table	:=	self.tblLogInformation.getControl(0);
	rowPointer	:=	table.row;
	tableObj	:=	table.accessRow(rowPointer).itemObject;
	
	ediFile := tableObj.CM_EDIFile;
	
	//22 Nov 2019	NDL	TFS 47651
	if ediFile = null then
		app.msgBox( app.getErrorString(Nothing_Selected), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	on Exception do app.handleDeletedObject( exception, ediFile, invalidObj );
	
	selectText := ediFile.fileName;
	
	//22 Nov 2019	NDL	TFS 47651
	if invalidObj then
		app.msgBox( app.getErrorString(Selec_item_not_avail_been_dele), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	fileData := ediFile.getWebReqString();		//navra1 - TFS 54078 - 21st July 2023
	if fileData &lt;&gt; null then
		startString := fileData[1:100];
		
		create messageLogForm transient;			// TFS 47653
		messageLogForm.caption := "EDI Request";	// TFS 47653
		
		// Check if its an 'old' XML/SOAP request, if it starts with &lt;? or contains &lt;soap:Envelope&gt;
		if JadeRegex@findFirst(startString, "^&lt;\?|&lt;.*Envelope", true, false, match) then
			messageLogForm.myXMLString := fileData;		// TFS 47653
			messageLogForm.isXMLRequest := true;		// TFS 47653
			messageLogForm.show;						// TFS 47653
		else
		//Otherwise, assume its a 'new' JSON/REST request
			messageLogForm.isXMLRequest := true;
			messageLogForm.setMyObject(ediFile);
			messageLogForm.show;
		endif;
	endif;
epilog
	delete match;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuTblViewResponse" id="7c445594-272d-47f3-b8a4-eb407b8eb273">
        <source>doMnuTblViewResponse();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 04 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description
25/11/2019		jlgzm		TFS 47653	Changing how EDI Webservice Monitor displays XML
18/08/2023		navmd1		TFS 59024	Handle JSON POST /SendEDI requests

****************************************************/

vars
	table			: CM_DataTable;
	rowPointer		: Integer;
	ediFile			: CM_EDIFile;
	tableObj		: Object;
	selectText		: String;
	fileData		: String;
	invalidObj 		: Boolean; 	//22 Nov 2019	NDL	TFS 47651
	messageLogForm	: CMUI_MessageLogForm;	// TFS 47653
	startString		: String;
	match			: JadeRegexMatch;
	
begin
	table	:=	self.tblLogInformation.getControl(0);
	rowPointer	:=	table.row;
	tableObj	:=	table.accessRow(rowPointer).itemObject;
	
	ediFile := tableObj.CM_EDIFile;
	
	//22 Nov 2019	NDL	TFS 47651
	if ediFile = null then
		app.msgBox( app.getErrorString(Nothing_Selected), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	on Exception do app.handleDeletedObject( exception, ediFile, invalidObj );	
	
	selectText := ediFile.fileName;
	
	//22 Nov 2019	NDL	TFS 47651
	if invalidObj then
		app.msgBox( app.getErrorString(Selec_item_not_avail_been_dele), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;	
	
	fileData := ediFile.getWebResString();		//navra1 - TFS 54078 - 21st July 2023	
	if fileData &lt;&gt; null then
		startString := fileData[1:100];		
		
		create messageLogForm transient;			// TFS 47653
		messageLogForm.caption := "EDI Response";	// TFS 47653
		
		// Check if its an 'old' XML/SOAP request, if it starts with &lt;? or contains &lt;soap:Envelope&gt;
		if JadeRegex@findFirst(startString, "^&lt;\?|&lt;.*Envelope", true, false, match) then
			messageLogForm.myXMLString := fileData;		// TFS 47653
			messageLogForm.isXMLResponse := true;		// TFS 47653
			messageLogForm.show;						// TFS 47653
		else
		//Otherwise, assume its a 'new' JSON/REST request
			messageLogForm.isXMLResponse := true;
			messageLogForm.setMyObject(ediFile);
			messageLogForm.show;
		endif;
	endif;
epilog
	delete match;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItem" id="8ec974c8-cea2-472d-a378-4ead6077fa8b">
        <source>doQueryAddItem(_object : CM_EDIFile) protected;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 04 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description
18/06/2020		jlgmd1		49599		Refactor search to make it faster and less lock prone

****************************************************/
vars
	table	: CM_DataTable;
	str		: String;
	dac		: CM_DataAccessController;
	index	: Integer;
begin
	if _object.requestTimestamp = null then
		return;
	endif;
	table := self.tblLogInformation;
	
	if not _object.canUserAccessSelf(null, dac, app.myPassport) then
		return;
	endif;
	
	str 	:= _object.getAttributeStringForDefArray(table.allTblDataEntRows);	
	index	:= table.addItemObject (_object, str);
	
	// TFS 49599 - Don't do UI stuff here, it makes the loading *SIGNIFICANTLY* slower
	//self.statusLine.caption := (self.tblLogInformation.rows - self.tblLogInformation.fixedRows).String &amp; ' rows found.';
	//self.doWindowEvents(0);
end;</source>
        <access>protected</access>
        <Parameter name="_object" type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="doRecordQuery" id="b5c279b0-579e-4546-bc0a-1d2863412b0d">
        <updating/>
        <source>doRecordQuery() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 04 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description
18/06/2020		jlgmd1		49599		Refactor search to make it faster and less lock prone
18/08/2023		navmd1		59024		Fix files not showing when there has been a mix of web and non-web files loaded in the given time period

****************************************************/
vars
	ediFile 		: CM_EDIFile;
	iterator		: Iterator;	
	ediFiles		: CM_EDIFileByCreatedTSDict;
	cmifMonitor		: CMIF_Monitor;
	count			: Integer;
	reachedMaxRows	: Boolean;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	self.tblLogInformation.clearAllData();
	
	self.filterReqDateTime := self.tblSearch.getValueByName(ETRow_FilterFromDate).Date;
	self.filterResDateTime := self.tblSearch.getValueByName(ETRow_FilterToDate).Date;
	
	// Set up the monitor
	create cmifMonitor transient;
	app.myPassport.setMyCMIFMonitor(cmifMonitor);
	cmifMonitor.myParent := self;
	cmifMonitor.message := "Searching...";
	cmifMonitor.partsInJob := 0; // I wonder if we can work this out ahead of time...
	cmifMonitor.partsDone := 0;
	
	self.modalDialogShow(null, 'Cancel', null, null, 'Searching for EDI Files', cmifMonitor.message);
	self.updateProgress(cmifMonitor);
	self.modalDialogReturnValue := 0;
	
	// Create our iterator and jump it forward to where we are interested in
	ediFiles := self.myTerminal.myEdiConfig.ediFiles;	// A collection of EDI files ordered by creation timestamp
	iterator := ediFiles.createIterator();
	ediFiles.startKeyGeq(self.filterReqDateTime.asTimeStamp(), iterator);
	
	// 32,000 row limit
	on Exception do app.handleUE14025(exception, reachedMaxRows);
	
	while iterator.next(ediFile) do
		// Too many results
		if reachedMaxRows then
			break;
		endif;
		
		// EDI File not created via web
		if ediFile.requestTimestamp = null then
			continue;
		endif;
		
		// Newer than our filterTo date, bail
		if self.filterResDateTime &lt;&gt; null and ediFile.requestTimestamp.date &gt; self.filterResDateTime then
			break;
		endif;
		
		// User pressed cancel
		if self.modalDialogReturnValue = 1 then
			break;
		endif;
		
		count := count + 1;
		cmifMonitor.partsDone := count;
		updateProgress(cmifMonitor);
		
		// Otherwise, add to our table
		doQueryAddItem(ediFile);
	endwhile;
	
	if not reachedMaxRows then
		self.statusLine.caption := (self.tblLogInformation.rows - self.tblLogInformation.fixedRows).String &amp; ' rows found.';
	else
		self.statusLine.caption := app.getErrorString(ERR_MAX_TABLE_ROW_EXCEEDED);
	endif;
	
	// Keep the searcher open if the operation was cancelled
	if self.modalDialogReturnValue = 0 then
		self.doHideSearcher();
	endif;
epilog
	delete iterator;
	
	self.frmModalDialog.visible := false;
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRecordUpdateItemQuery" id="01dbae30-e60e-401a-8a56-4e0bdaee074f">
        <updating/>
        <source>doRecordUpdateItemQuery(ediFile : CM_EDIFile; userInfo : Any) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 04 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	object 	: Object;
	str		: String;
	index	: Integer;
	table	: CM_DataTable;
	proc	: String;
	ediControllerAgent	: CM_EDIControllerAgent;
begin
	create ediControllerAgent transient;
	
	if ediFile.requestTimestamp = null then
		return;
	endif;
	table := self.tblLogInformation;
	
	if table.findObjectInRow(ediFile, index) then
		index	:= table.updateItemObject (ediFile, self.colorRow1, self.colorRow2, app.myPassport);		
		if userInfo &lt;&gt; null then
			if userInfo.asString = "DBLoading" then
				if ediFile.fileStatus = CM_EDIFile.EDI_STATUS_VERIFIED then	
					proc := ediControllerAgent.displayStatus( CM_EDIFile.EDI_STATUS_DBLOADING );
					table.accessCell(index, table.getColumnByRowName(ETRow_Status)).text := proc;					
				endif;
			else			
				proc := userInfo.Decimal.roundedTo(0).String &amp; "%";
				table.accessCell(index, table.getColumnByRowName(ETRow_Process)).text := proc;
				
				if ediFile.fileStatus = CM_EDIFile.EDI_STATUS_VERIFIED then	
					proc := ediControllerAgent.displayStatus( CM_EDIFile.EDI_STATUS_DBLOADING );
					table.accessCell(index, table.getColumnByRowName(ETRow_Status)).text := proc;					
				endif;
			endif;
		else
			if self.frmMode = self.Monitoring_Mode then	
				if ediFile.fileStatus.isOneOf(CM_EDIFile.EDI_STATUS_DBLOADED,  CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, CM_EDIFile.EDI_STATUS_LOADED) then
					proc := "100%";
					table.accessCell(index, table.getColumnByRowName(ETRow_Process)).text := proc;
				endif;
			endif;
		endif;
		
	endif;
	
	self.statusLine.caption := (self.tblLogInformation.rows - self.tblLogInformation.fixedRows).String &amp; ' rows found.';
	self.doWindowEvents(0);
epilog
	delete ediControllerAgent;	
end;</source>
        <Parameter name="ediFile" type="CM_EDIFile"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doResetSearcher" id="5bcfdd8c-04a9-4224-94a6-7fe6d58823f0">
        <updating/>
        <source>doResetSearcher() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 02 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	self.filterReqDateTime := null;
	self.tblSearch.setValueByName(ETRow_FilterFromDate, null); 	
	self.filterResDateTime := null;
	self.tblSearch.setValueByName(ETRow_FilterToDate, null); 
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="9441104e-1f41-41f7-a9b8-fa2830e0c0ca">
        <updating/>
        <source>doResize() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 04 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	table		: CM_DataTable;
	status		: CMUI_StatusLine;
	container	: CMUI_SplitContainer;
	tableSearch : CM_EntryTable;
	tableFrame  : CMUI_MoveableFrame;
begin
	// is the status bar is visible make sure it does not cover the horizontal scroll bar on the table
	status 	:= self.statusLine;
	table 	:= self.tblLogInformation;
	container := self.dataContainer;
	container.top := self.frmToolbar.top + self.frmToolbar.height;
	
	if status.visible then
		container.height := container.parent.height - status.height - self.frmToolbar.height;
		table.height := container.height - 50;		
	endif;	
	
	tableSearch	  		:= self.tblSearch;
	tableFrame 	  		:= self.frmSearch;
	tableSearch.top 	:= self.frmSearchToolbar.top + self.frmSearchToolbar.height;	
	tableFrame.height 	:= tableSearch.height + self.frmSearchToolbar.height + 10;
	
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowSearcher" id="d7e79c27-f912-4bae-8a73-4467afc9807c">
        <source>doShowSearcher();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 02 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	frame : CMUI_MoveableFrame;
begin
	frame := self.frmSearch;
	
	frame.parent := self;
	frame.centreHorizontallyInParent;
	frame.centreVerticallyInParent;
	frame.zOrder(1);
 	frame.visible := true;
	self.btnSearch.setFocus();	//05 Dec 2019	NDL	TFS 47715
	self.btnSearch.zOrder(1);	//05 Dec 2019	NDL	TFS 47715
end;</source>
    </JadeMethod>
    <JadeMethod name="doUserNotifications" id="061b2b9c-cb35-4da6-a6ff-eac771371e26">
        <updating/>
        <source>doUserNotifications(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 10 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	localEvent 	: Integer;	
	ediFIle 	: CM_EDIFile;	
begin
	localEvent := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if self.frmMode = self.Monitoring_Mode then	
		if CM_EDIFile.hasInstance(theObject) then
			ediFIle := theObject.CM_EDIFile;
		else
			return;
		endif;
		
		if localEvent = EventEDIProgress or localEvent = EventDBLoading then			
			self.doRecordUpdateItemQuery(ediFIle, userInfo);			
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="6ad15ac5-5e4e-47b0-8479-a4cfa5c67496">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 02 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	type, xmlStr	: String;
	obj				: Object;
begin
	xmlStr := inheritMethod();
	xmlStr := xmlStr &amp; self.tblLogInformation.getXmlStrForColumns(true);
	
	return xmlStr;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleNotifications" id="d03f6923-1c45-4766-a7c5-99aa8258dd6c">
        <updating/>
        <source>handleNotifications(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 09 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description
18/06/2020		jlgmd1		49599		Refactor search to make it faster and less lock prone

****************************************************/
vars
	tmpEDIFile : CM_EDIFile;
begin
	if self.frmMode = self.Monitoring_Mode then	
		if CM_EDIFile.hasInstance(theObject) then
			tmpEDIFile := theObject.CM_EDIFile;
		else
			return;
		endif;
		
		if eventType = Object_Update_Event then			
			self.doRecordUpdateItemQuery(tmpEDIFile, null);				
		elseif eventType = Object_Create_Event then
			// Add to the table
			self.doQueryAddItem(tmpEDIFile);
			
			// Refresh the form
			self.statusLine.caption := (self.tblLogInformation.rows - self.tblLogInformation.fixedRows).String &amp; ' rows found.';
			self.refreshNow();
			
			// Listen for any more updates
			self.beginNotification(tmpEDIFile, self.myTerminal.getTerminalEvent(EventEDIProgress), Response_Continuous, 0);
			self.beginNotification(tmpEDIFile, self.myTerminal.getTerminalEvent(EventDBLoading), Response_Continuous, 0);
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initTableData" id="c638522b-2bbf-419e-847c-5423e7c35f63">
        <updating/>
        <source>initTableData(_theEntDef: String) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 30 August 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	entTableView	: EntTableView;
	entTableDef		: EntTableDef;
	theTable		: CM_DataTable;
begin
	theTable := self.tblLogInformation;
	
	theTable.userInputEnabled := false;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(_theEntDef);
	if entTableDef &lt;&gt; null then
		theTable.setTblDataEntRowsFromDef(entTableDef);
	endif;
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="6690c253-da61-4d7b-81d6-544ea7873290">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 November 2019	jlgma1	Bug 47217: JMT F3 does not toggle the searcher on the EDI Web Service Viewer screen

*/

vars

begin

	
	if keyCode = CMUI_Key_F3 then	
		if not self.frmSearch.visible then 
			self.doShowSearcher();
			return;
		else
			self.doHideSearcher();
		endif;
	elseif keyCode = J_key_Enter then	//05 Dec 2019 NDL	TFS 47715
		if self.frmSearch.visible then
			self.doRecordQuery();
		endif;		
	else
		inheritMethod(keyCode, shift);
	endif;

epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
