    <JadeMethod name="setProxy" id="6d0d815b-0e13-4241-91e0-687a5f9ca9eb">
        <updating/>
        <source>setProxy(pCode, pDescription : String; _notAvailableForEntry :Boolean; pCodeGroup : CM_CodeGroupLogSpecs) updating;
// ---------------------------------------------------------------------------
// Created:     19 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpDecimal	: Decimal[12,2];
	
begin

	self.setSuperClassDetailsForProxy(pCode, pDescription,_notAvailableForEntry, null);
	self.myCodeGroupLogSpecs := pCodeGroup;
	
	tmpDecimal := pCode.Decimal;
	if pCode.isDecimal then
		self.sortOrder	:= tmpDecimal;
	else
		// need to set sortOrder from alpha code
		self.sortOrder := pCode.getWeightedAsciiValue();
	endif;
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="pCodeGroup" type="CM_CodeGroupLogSpecs"/>
    </JadeMethod>
    <JadeMethod name="setSortKey" id="92d26f69-d8ce-444d-b765-7e5e8a77a3c5">
        <updating/>
        <source>setSortKey(_value : Decimal) updating;

/*
Date			Who		Reason
18 March 2010	cnwar2	Initial creation

*/
vars

begin
	self.sortOrder := _value;
end;</source>
        <Parameter name="_value" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="ace334c5-cb53-445a-879e-297681b95068">
        <source>validateForCreate();
// -----------------------------------------------------------------------------
// Created:		27 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	logLen	: CM_LogLength;
begin
	inheritMethod();
	if self.myCodeGroupLogSpecs &lt;&gt; null and
	   self.myCodeGroupLogSpecs.allLogLengths.includesKey(self.code) then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, 'code', null);
	endif;
	
	//cannot allow an item with the same sortOrder - other collections are sorted and unique on this key
	// 19/03/2010 cnwar2 #22738 - moved to validateMe
	/*foreach logLen in self.myCodeGroupLogSpecs.allLogLengths do
		if (logLen.sortOrder = self.sortOrder) 
		and (logLen &lt;&gt; self) then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.code &amp; " - with sort value of " &amp; self.sortOrder.String, 'code', null);
			break;
		endif;
	endforeach;*/

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="6f13adaf-3389-48bc-b589-59137fb56759">
        <source>validateForDelete();
// -----------------------------------------------------------------------------
// Created:		14 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if (not self.allLogGrades.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, 'Log Length ' &amp; self.code, 
							  self.allLogGrades.size.String &amp; ' Log Grades', null, null);
	endif;
	
	if (not self.allProducts.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, 'Log Length ' &amp; self.code, 
							  self.allProducts.size.String &amp;' '&amp; app.getErrorString(Cargo_subtype_data), null, null);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="48165f56-b02f-490e-9746-3c2d47b3a0e3">
        <source>validateMe() protected;

/*
Date			Who		Reason
19 March 2010	cnwar2	Initial creation
// 08/12/2014   cnwdb2	PAR #35364


*/
vars
	logLen : CM_LogLength;
	
begin
	inheritMethod();

	foreach logLen in self.myCodeGroupLogSpecs.allLogLengths do
		if (logLen.sortOrder = self.sortOrder) 
		and (logLen.code &lt;&gt; self.code) then
		//	app.raiseCMException3(ERR_DUPLICATE_KEY, 'Sort Key', self.sortOrder.asStringJMT, null,'sortOrder', null);
			app.raiseCMException1(Already_exists_sort_key,  self.sortOrder.asStringJMT,'sortOrder', null); // cnwdb2	PAR 35364

			break;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
