/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 December 2009	cnwkpd1	CCMS MES 1014 - ITS RDT Interface

*/

vars

begin
	self.doUserNotify(eventType, theObject, eventTag, userInfo);
	
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
