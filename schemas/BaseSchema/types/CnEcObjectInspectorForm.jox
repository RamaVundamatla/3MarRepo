        <controlMethod name="TextBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtSource_mouseDown(textbox: TextBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		03 November 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	actualXPos	: Real;
	actualYPos	: Real;
	
begin
	if button = Window.MouseButton_Right then
		actualXPos	:=	x;
		actualYPos	:=	y;
		
		self.cnEcGetRelativePosition(textbox, actualXPos, actualYPos);
		popupMenu(mnuSource, actualXPos.Integer, actualYPos.Integer);
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="unload" id="1bcbdb9c-ea4c-4170-9ac6-c45174bb14b8">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// -----------------------------------------------------------------------------
// Created:		31 October 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.aAllProcessCalls.purge();
	self.stopTimer();
	endNotificationForSubscriber(self);
end;</source>
    </JadeMethod>
</GUIClass>
