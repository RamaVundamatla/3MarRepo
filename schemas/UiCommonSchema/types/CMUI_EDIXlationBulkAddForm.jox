    <JadeMethod name="populateTable" id="776464ed-c798-49ef-aab6-6e30a6827a14">
        <updating/>
        <source>populateTable() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 01 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	voyage 			: CM_Voyage;
	selectedVoyage 	: CM_Voyage;
	terminal 		: CM_Terminal;
	passport		: CM_Passport;
	failedDAC  		: CM_DataAccessController;	
	table			: CM_DataTable;
	rowTable		: String;
	operator		: CM_Operator;
	columnIndex 	: Integer;
	rowIndex 		: Integer;
	operatorArray	: CM_OperatorArray;
	operatorColumn  : Integer;
	headerRow		: Integer;
	terminalColl 	: CM_TerminalByCodeDict;
	cmifMonitor		: CMIF_Monitor;
	count			: Integer;
	reachedMaxRows	: Boolean;
	type			: Integer;
	opTerm			: CM_OperatorTerminal;
	xlationTable	: CM_XlationTable;
	xlation			: CM_Xlation_In;
	selectedXlation	: CM_Xlation_In;
	foreignCode		: String;
	iter			: Iterator;	
begin
	type := XLATION_TYPE_VOYAGETERMINAL;
	table := self.tblTermVoyageOper;
	passport := app.myPassport;
	selectedVoyage := self.cmbVoyage.listObject.CM_Voyage;
	
	if selectedVoyage = null then
		return;
	endif;
	
	table.columns := 1;	
	table.rows := 1;
	
	create operatorArray transient;
	
	columnIndex := 1;
	rowIndex  := 1;
	headerRow := 1;
	
	// Initialized the table
	self.initTable(table);
	
	// Set up the monitor
	create cmifMonitor transient;
	app.myPassport.setMyCMIFMonitor(cmifMonitor);
	cmifMonitor.myParent := self;
	cmifMonitor.message := "Searching...";
	cmifMonitor.partsInJob := 0; 
	cmifMonitor.partsDone := 0;	
	
	self.modalDialogShow(null, 'Cancel', null, null, 'Searching for Voyages Operator', cmifMonitor.message);
	self.updateProgress(cmifMonitor);
	self.modalDialogReturnValue := 0;
	
	// 32,000 row limit
	on Exception do app.handleUE14025(exception, reachedMaxRows);
	
	create terminalColl transient;
	app.getMyUser.getTerminals(terminalColl);	
	
	foreach terminal in terminalColl do		
		iter := terminal.allVoyagesByCode.createIterator();
		terminal.allVoyagesByCode.startKeyGeq(selectedVoyage.code,null,iter);		
		
		while iter.next(voyage) do
			if voyage.code &lt;&gt; selectedVoyage.code then
				break;
			endif;
			
			if not self.isVoyageIncluded(voyage) then
				continue;
			endif;
			
			// Too many results
			if reachedMaxRows then
				break;
			endif;
			
			self.txtManifestCode.text := voyage.customsManifest;
			
			rowIndex := rowIndex + 1;
			table.addItemAt(terminal.code, rowIndex);
			table.accessRow(rowIndex).itemObject := terminal;
			
			foreach operator in voyage.allOperators discreteLock do
				operatorColumn := operatorArray.indexOf(operator);
				if operatorColumn = 0 then
					operatorArray.add(operator);
					operatorColumn := operatorArray.indexOf(operator);					
					table.inputType := Table.InputType_TextBox;					
					table.insertColumn(columnIndex+operatorColumn);
					table.allTblDataColHeadings.add(operator.code);
					table.accessCell(headerRow,columnIndex+operatorColumn).text := operator.code;
					table.accessColumn (columnIndex+operatorColumn).itemObject := operator;					
				endif;
				//get vallue from CM_XlationTable
				opTerm := terminal.allOperatorTerminals[operator];
				foreignCode := "";
				if opTerm &lt;&gt; null then
					selectedXlation := null;
					xlationTable := opTerm.allXlationTables[type, null];
					if xlationTable &lt;&gt; null then						
						foreach xlation in xlationTable.allInwardTranslations do
							if xlation.systemCode &lt;&gt; selectedVoyage.code then
								continue;
							endif;
							
							selectedXlation := xlation;
							if xlation.canHaveCriteria then
								foreignCode	:= xlation.getCriteriaDisplay (false);
							else
								foreignCode := xlation.foreignCode;
							endif;
							break;
						endforeach;
						
						if selectedXlation &lt;&gt; null then
							// we have found the outward translation for this system code
							table.accessCell(rowIndex,columnIndex+operatorColumn).text := foreignCode;
							table.accessCell (rowIndex,columnIndex+operatorColumn).itemObject := xlation;
						else
							table.accessCell(rowIndex,columnIndex+operatorColumn).text := selectedVoyage.code;
						endif;
					else
						table.accessCell(rowIndex,columnIndex+operatorColumn).text := selectedVoyage.code;
					endif;										
				else
					table.accessCell(rowIndex,columnIndex+operatorColumn).text := selectedVoyage.code;
				endif;
				
			endforeach;			
		endwhile;
		delete iter;
	endforeach;
	
	self.setTableControl(terminalColl);
	
epilog
	delete iter;
	delete operatorArray;
	delete terminalColl;
	delete cmifMonitor;
	
	self.frmModalDialog.visible := false;	
	app.myPassport.setMyCMIFMonitor(null);	
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromForm" id="bc8ce437-4809-4386-a755-257fcf619020">
        <source>setProxyFromForm(_proxy :CM_XlationSet output):Boolean protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 01 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	type						: Integer;
	systemCode					: String;
	xlationTable				: CM_XlationTable;	
	pxyXlationIn				: CM_Xlation_In;
	xlationOut, pxyXlationOut	: CM_Xlation_Out;
	operator					: CM_Operator;
	terminal					: CM_Terminal;
	pxyOpTerm					: CM_OperatorTerminal;
	opTerm						: CM_OperatorTerminal;
	strCodeOut					: String;	
	headerIndex 				: Integer;
	columnIndex 				: Integer;
	rowIndex 					: Integer;
	terminalIndex 				: Integer;
	table						: CM_DataTable;
	foreignCode 				: String;
	selectedVoyage				: CM_Voyage;
begin
	create _proxy transient;
	selectedVoyage := self.cmbVoyage.listObject.CM_Voyage;
	table := self.tblTermVoyageOper;
	headerIndex := 1;
	terminalIndex := 1;
	rowIndex := 2;	//Skip the header
	
	while rowIndex &lt;= table.rows do				
		columnIndex := 2;		
		type	:= XLATION_TYPE_VOYAGETERMINAL;
		
		while columnIndex &lt;= table.columns do
				if (table.accessCell(rowIndex, columnIndex).enabled = false) 
					or (table.accessCell(rowIndex, columnIndex).text.trimBlanks = "")
					or (table.accessCell(rowIndex, columnIndex).text = selectedVoyage.code) then
					columnIndex:=columnIndex+1;		
					continue;
				endif;
				foreignCode := table.accessCell(rowIndex, columnIndex).text;
				systemCode := selectedVoyage.code;
				
				pxyXlationIn:= null;
				pxyXlationOut:= null;			
				
				create xlationTable transient;
					
				operator := table.accessColumn(columnIndex).itemObject.CM_Operator;						
				terminal := table.accessRow(rowIndex).itemObject.CM_Terminal;			
								
				create pxyOpTerm transient;
				
				pxyOpTerm.setMyOperator (operator);
				pxyOpTerm.setMyTerminal (terminal);
				
				xlationTable.setProxy(type, null, null, pxyOpTerm, null,null);
				
				create pxyXlationIn as CM_Xlation_In transient;		
				pxyXlationIn.setSystemObject(type, terminal);
					
				// set inward xlation values
				if pxyXlationIn &lt;&gt; null then
					pxyXlationIn.setProxy (systemCode, foreignCode, xlationTable);
					pxyXlationIn.setXlationTable (xlationTable);		
				endif;
				
				// set outward xlation values
				strCodeOut := foreignCode;				
				
				if xlationTable &lt;&gt; null then					
					xlationOut := xlationTable.allOutwardTranslations[systemCode];
				endif;
				
				create pxyXlationOut transient;
				
				if pxyXlationOut &lt;&gt; null then		
					pxyXlationOut.setProxy (systemCode, strCodeOut, xlationTable);
				endif;
			
			xlationTable.allInwardTranslations.copy(_proxy);			
	
			columnIndex:=columnIndex+1;		
			endwhile;	
		rowIndex := rowIndex + 1;
	endwhile;
	
	
	return true;
epilog	
	
end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="CM_XlationSet" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableControl" id="d3e0f889-972e-41f9-a0fa-37f274231c31">
        <updating/>
        <source>setTableControl(_terminalColl : CM_TerminalByCodeDict) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 01 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	voyage 			: CM_Voyage;
	table			: CM_DataTable;
	headerIndex 	: Integer;
	columnIndex 	: Integer;
	rowIndex 		: Integer;
	terminalIndex 	: Integer;
	terminalCode	: String;
	row				: JadeTableRow;	
	terminal 		: CM_Terminal;
	operator		: CM_Operator;
	operatorCode	: String;
	selectedVoyage  : CM_Voyage;
	txtBox			: TextBox;
	ctrl 			: Control;
begin
	selectedVoyage := self.cmbVoyage.listObject.CM_Voyage;
	table := self.tblTermVoyageOper;
	headerIndex := 1;
	terminalIndex := 1;
	rowIndex := 2;	//Skip the header
	while rowIndex &lt;= table.rows do				
		columnIndex := 2;
		row := table.accessRow(rowIndex);
		terminalCode := table.accessCell(rowIndex, terminalIndex).text;
		terminal := _terminalColl.getAtKeyGeq(terminalCode);
		voyage := terminal.allVoyagesByCode.getAtKeyGeq(selectedVoyage.code, null);
		
		if voyage &lt;&gt; null then 
			while columnIndex &lt;= table.columns do
				ctrl := table.accessCell(rowIndex, columnIndex).cellControl;
				if ctrl &lt;&gt; null then
					if TextBox.hasInstance(ctrl) then
						txtBox := ctrl.TextBox;
						txtBox.case := TextBox.Case_Upper;
					endif;
				endif;				
				
				operatorCode := table.accessCell(headerIndex, columnIndex).text;
				operator := voyage.allOperators[operatorCode];
				if operator = null then				
					table.accessCell(rowIndex, columnIndex).enabled := false;
					table.accessCell(rowIndex, columnIndex).backColor := getSystemColor(Window.Color_InactiveBorder);					
				endif;
				
				columnIndex:=columnIndex+1;		
			endwhile;	
		endif; 
		
		rowIndex := rowIndex + 1;
	endwhile;

epilog

end;</source>
        <Parameter name="_terminalColl" type="CM_TerminalByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="4cd75484-3cf7-423b-a927-3935ae7ee725">
        <updating/>
        <source>setupForm() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 30 March 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	errMsg : XLAT_Translation;
begin
	inheritMethod();
	
	self.setCaption(app.getErrorString(Voyage_manifest_translatio));
	errMsg := app.zGetUntranslatedText(XLAT_Exceptions, Voyage_manifest_translatio);
	if errMsg &lt;&gt; null then
		self.helpKeyword := HelpFile_SearchString &amp; errMsg.text;
	endif;
	
	self.minimumWidth := 790;
	self.minimumHeight := 200;
	
	self.setNavigatorHeading (self.caption);
	
	self.initData();	
	
epilog

end;</source>
    </JadeMethod>
