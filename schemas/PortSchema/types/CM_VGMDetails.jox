        <source>setMyContainer(_container : CM_Container) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 30/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars

begin
	self.myContainer := _container;
epilog

end;</source>
        <Parameter name="_container" type="CM_Container"/>
    </JadeMethod>
</Class>
