        <source>setButtons() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

begin

	// 'print' button
	if self.txtNumIds.text.Integer &lt; 1 then
		self.btnOk.enabled := false;
	elseif self.txtNumCopys.text.Integer &lt; 1 then
