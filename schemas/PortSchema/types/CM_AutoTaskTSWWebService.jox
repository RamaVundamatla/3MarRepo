    <JadeMethod name="getValueForRow" id="083962c8-30e1-4372-b55e-1e98a00618e1">
        <source>getValueForRow(_rowName: String; _obj: Object output): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/08/2016	cnwdap1		Initial creation TFS #1832 TSW Changes
//
vars

begin
	if _rowName = ETRow_BgpName then
		return self.name;
	endif;
	
	return inheritMethod(_rowName, _obj);

epilog

end;</source>
