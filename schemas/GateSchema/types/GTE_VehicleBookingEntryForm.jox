end;</source>
    </JadeMethod>
    <JadeMethod name="setUpMock" id="fffbe6a4-ee5d-45eb-93b2-8fe0fe16649a">
        <updating/>
        <source>setUpMock() updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 22 November 2007
//
//----------------------------------------------------------------------

vars
	carrier : CM_Carrier;
	veh : CM_Vehicle;
	cont : CM_TrackedItem;
	str : String;
begin
	self.setCaption('Vehicle Booking');
	
	self.cmbTerminal.addItem('Terminal One');
	self.cmbTerminal.listIndex := 1;
	
	self.cmbCarrier.initialise(false);
	carrier := '2184.1401'.asOid.CM_Carrier;
	self.cmbCarrier.setIndexFromObject(carrier);
	
	foreach veh in carrier.vehicles do
		self.cmbVehicleID.addItemObject(veh.code, veh);
	endforeach;
	self.cmbVehicleID.listIndex := 72;
	
	self.cmbVehicleType.addItem('Fork Lift');
	self.cmbVehicleType.addItem('Normal');
	self.cmbVehicleType.addItem('Reach Stacker');
	self.cmbVehicleType.addItem('Side Loader');
	self.cmbVehicleType.listIndex := 4;
	
	self.cmbItemType.addItem('Release Request');
	self.cmbItemType.addItem('Cargo Item');
	self.cmbItemType.addItem('Pre-Note');
	self.cmbItemType.listIndex := 2;
	
	cont := CM_Container.lastInstance();
	str := cont.getAttributeStringForDefArray(self.tblSearch.allTblDataEntRows);
	self.tblSearch.addItemObject(cont, str);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2f5378a8-e77a-4de8-8d65-c46a7e4d058d">
        <updating/>
        <source>setupForm() updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 22 November 2007
//
//----------------------------------------------------------------------

vars

begin
	//inheritMethod();
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	
	
	self.initTblItems();
	self.initTblSearch();
	self.setUpMock();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e8efd742-4ae3-4a81-891f-9e339123cef1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017566, locale);
	btnAdd.translateCaption(Xlat_0005505, locale);
	btnBookingChange.translateCaption(Xlat_0005506, locale);
	btnDeleteTV.translateCaption(Xlat_0005507, locale);
	btnEditTV.translateCaption(Xlat_0005508, locale);
	btnNewTV.translateCaption(Xlat_0005509, locale);
	btnRemove.translateCaption(Xlat_0005510, locale);
	btnSearch.translateCaption(Xlat_0005511, locale);
	cMUI_Frame2.translateCaption(Xlat_0005512, locale);
	cMUI_Label3.translateCaption(Xlat_0005513, locale);
	cMUI_Label3_1.translateCaption(Xlat_0005514, locale);
	cMUI_Label3_2.translateCaption(Xlat_0005515, locale);
	cMUI_Label3_3.translateCaption(Xlat_0005516, locale);
	cMUI_Label3_4.translateCaption(Xlat_0005517, locale);
	cMUI_Label3_5.translateCaption(Xlat_0005518, locale);
	cMUI_Label3_6.translateCaption(Xlat_0005519, locale);
end;</source>
    </JadeMethod>
