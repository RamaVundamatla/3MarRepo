    <JadeMethod name="btnMenuTemplate_click" id="2fce0890-09bf-48ac-a61b-2362545df273">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnMenuTemplate_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:	31 December 2008 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin
	//epr TFS 37901 3/4/18 now storing class to go to on btn user
	if btn.userObject &lt;&gt; null then
		self.gotoForm( btn.userObject.Class, false );
	endif;
	

epilog
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMenuOperation" id="199835a2-7421-46c4-8dfe-a2cd657bc8c3">
        <updating/>
        <source>doMenuOperation(index: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:	31 December 2008 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin
	if index &lt;= self.getSessionAgent().allAvailableForms.size then
		self.gotoForm( self.getSessionAgent().allAvailableForms[index].Class, false );
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="5a67771c-cc82-45c0-8a44-9b691de7a1df">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	index : Integer;
	buttonWidth : Real;
	menuButton : MOB_Button;
	scrollStart : Integer;
	size : Integer;
	fontSize : Decimal[5,2];
	cmdButtonHeight : Integer;
	scrollWidth : Real;
	buttonTop : Integer;
	buttonHeight : Integer;

begin

	self.setResizeableMarginAndFontSize();

	inheritMethod(_initialSetup);

	fontSize := self.drawFontSize;
	cmdButtonHeight := self.getCMDButtonsHeight();
	
	self.frmMenu.move(	self.resizedMargin,
						self.resizedMargin,
						self.clientWidth - (2*self.resizedMargin),
						self.clientHeight - cmdButtonHeight - (3*self.resizedMargin)
						);
						
	size := self.getSessionAgent().allAvailableForms.size;
	
	buttonHeight := self.getCMDButtonsHeight();
	self.btnMenuTemplate.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmMenu, buttonHeight, self.scrMenu );
	
	buttonTop := self.resizedMargin - 1;
	foreach index in 1 to size do
		menuButton := self.btnMenuTemplate.getControl(index).MOB_Button;
		if menuButton &lt;&gt; null then
			menuButton.fontSize := fontSize;
			menuButton.width := buttonWidth;
			menuButton.height := buttonHeight;
			menuButton.top := buttonTop;
			buttonTop := buttonTop + buttonHeight + self.resizedMargin;
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getHelpDescr" id="1b5a251d-5c1e-44e3-ac35-c07d2aa27055">
        <source>getHelpDescr(): String;
/*
Date		Who		Reason
03 February 2009	cnwcp2	Initial creation
*/

vars

begin
	return self.HELP_DESCRIPTION;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
