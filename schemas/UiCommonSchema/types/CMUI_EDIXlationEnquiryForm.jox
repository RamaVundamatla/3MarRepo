    <JadeMethod name="cmbTerminal_click" id="1b2192f9-d095-4783-b5c2-5f4f76af85d3">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTerminal_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 January 2023		jlier1	Initial creation 56291
01 February 2023	jlizm1	TFS 56291 POB - CSV Import of translation terms

*/

vars
	type : Integer;
begin
	type:=self.cmbType.getCurrentItemData; 
	self.cmbSystemCod.enabled:=CM_XlationTable@isOperatorTerminalXlation(type) or type = XLATION_TYPE_WORKPOINT ;
	self.lblSystemCode.enabled:=CM_XlationTable@isOperatorTerminalXlation(type) or type = XLATION_TYPE_WORKPOINT ;

	self.doGetSystemCodes();

epilog

end;</source>
