    <JadeMethod name="setControlsForAddEdit" id="a5a83214-8cdc-42a4-8598-281809e1e2b6">
        <updating/>
        <source>setControlsForAddEdit() updating;
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
vars

	pxyRule		: CM_YAOverstowRule;
	objSet		: ObjectSet;
	attrib		: CM_YAOverstowAttribute;
	cmif		: Object;

begin
	
	self.setControlsVisibility(true);
	if self.mode = Mode_Add then
		self.doEnableVoyageAttributes();
		self.lstAttributes.clearSelected();
		self.lstImex.clearSelected();
		self.txtCode.text := null;
		self.txtDescr.text := null;
		self.txtSpaces.text := null;
		self.cmbVoyageLater.listIndex := 1;
		self.cmbVoyageLater.lostFocus(self.cmbVoyageLater);
		self.chkVoyageJobs.value := false;
	else
		create objSet transient;
		pxyRule := self.myProxyObject.CM_YAOverstowRule;
		
		self.txtCode.text := pxyRule.code;
		self.txtDescr.text := pxyRule.description;
		self.txtSpaces.text := pxyRule.numberOfFreeTEUs.String;

		// Find out what attributes we need to preselect.
		foreach attrib in pxyRule.allYAOverstowAttributes do
			cmif := self.getCMIFOverstowAttribute(attrib.type);
			if cmif &lt;&gt; null then
				objSet.add(cmif);
			endif;
		endforeach;
		
		self.lstAttributes.setSelected(objSet);
		self.lstImex.setSelected(pxyRule.allImexStatuses);
		
		self.cmbVoyageLater.listIndex := self.cmbVoyageLater.itemDataIndex(pxyRule.overstowLaterVoyages);
		self.cmbVoyageLater.lostFocus(self.cmbVoyageLater);
		
		self.chkVoyageJobs.value := pxyRule.doVoyageJobChecks;
		
		self.doEnableVoyageAttributes();
		
	endif;
	self.txtCode.setFocus();
epilog
	delete objSet;
end;</source>
    </JadeMethod>
