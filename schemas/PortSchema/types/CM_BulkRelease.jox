    <JadeMethod name="getInstructionsForContext" id="2536db7d-25c7-47a8-9b1c-1aea1b94e5f4">
        <source>getInstructionsForContext(_instructions: CM_InstructionsIssuedSet io; _passingObject: Object; _context: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2
10 Nov 2023 navnk30 ChangeRequest 60646: EUP | Mobile DD - [53891.060] - Special Instructions in the Mobile App

*/

vars
	dynaDict	: DynaDictionary;
	obj			: Object;
	reserveDtl	: CM_ReserveDetail;
	wo			: CM_WorkOrder;
	woDtl		: CM_WorkOrderDtl;
begin
	_instructions.tryAddIfNotNull(self.myInstructions);
	
	create dynaDict transient;
	dynaDict.setMembership(CM_ReserveDetail);
	dynaDict.addMemberKey(CM_ReserveDetail::myInstructions.name, true, true);
	dynaDict.endKeys(true);
	
	self.allReserveDetails.copy(dynaDict);
	
	if _context = Truck_Load or _context = Pack_by_Request or _context = Pack_Cargo or _context = Rail_Load then	//10.11.2023 navnk30 #60646
		self.allReservePackingChildren.copy(dynaDict);
	endif;
	
	foreach obj in dynaDict do
		reserveDtl := obj.CM_ReserveDetail;
		if reserveDtl.getInstructions() = null then
			break;
		endif;
		reserveDtl.getInstructionsForContext(_instructions, _passingObject, _context);
	endforeach;
	
	if _context = Truck_Load or			//10.11.2023 navnk30 #60646
		_context = Rail_Load then
		woDtl := self.allWOReleases.first;
		if woDtl = null then
			return;
		endif;
		
		wo := woDtl.myParent;
		if wo = null then
			return;
		endif;
		_instructions.tryAddIfNotNull(wo.myInstructions);
	elseif _context = Pack_by_Request then
		woDtl := self.allWOPacks.first;
		if woDtl = null then
			return;
		endif;
		
		wo := woDtl.myParent;
		if wo = null then
			return;
		endif;
		_instructions.tryAddIfNotNull(wo.myInstructions);
	endif;
epilog
	delete dynaDict;
end;</source>
        <Parameter name="_instructions" type="CM_InstructionsIssuedSet" usage="io"/>
        <Parameter name="_passingObject" type="Object"/>
        <Parameter name="_context" type="String"/>
    </JadeMethod>
    <JadeMethod name="getIsClean" id="5dfcd714-1020-460b-b4b4-e821b005f65f">
        <source>getIsClean():String;
// ---------------------------------------------------------------------------
// Created:		25 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

//For reports - only for releases by type
vars
	req : CM_Request;
begin

	if self.requests.size &lt;&gt; 1 then
		return "";
	endif;
	
	req := self.requests.first;
	
	if not req.isKindOf(CM_DeliveryRequest) then
		return "";
	endif;
	
	if req.CM_DeliveryRequest.clean then
		return "Yes";
	else
		return "No";
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
