    <JadeMethod name="changeBackColor" id="9d2937a9-83da-4a55-893b-6aa779614598">
        <updating/>
        <source>changeBackColor(_newColor : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	ydc : YRD_ContainerDrawingController;
begin
	ydc := self.getDrawingController;
	if ydc = null then	
		return;
	endif;
	
//	if ydc.allGridObjects.isEmpty then PAR 18682
//		return;
//	endif;

	self.myDockBar.myScrollableFrame.myHLabels.backColor := _newColor;
	self.myDockBar.myScrollableFrame.myVLabels.backColor := _newColor;
	self.myDockBar.myScrollableFrame.myTopLeftFillerFrame.backColor := _newColor;
	self.backColor := _newColor;
	self.myDockBar.backColor := _newColor;
	self.myDockBar.myScrollableFrame.backColor := _newColor;
end;</source>
        <Parameter name="_newColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="changeRoRoBackColor" id="fcfdf13c-8aec-4381-809f-c67223e6bab1">
        <updating/>
        <source>changeRoRoBackColor(_newColor : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		Dec 7 2009 cnwjk3 ccms 1018
//
// Purpose:		Same as changeBackColor, but without the check for the yard controller
//              being null.  I have no idea why that check is there, but the drawing code 
//				is pretty 'delicate', so i don't want to remove it, which is why I push the
//				RoRo areas through this method. 
//
// ---------------------------------------------------------------------------
vars
	endx, endy : Integer;
begin
	if self.backColor &lt;&gt; _newColor then
		
		// If we don't clear graphics here, everything is drawn bold
		self.myDockBar.myScrollableFrame.myHLabels.clearGraphics();
		self.myDockBar.myScrollableFrame.myVLabels.clearGraphics();
		self.myDockBar.myScrollableFrame.myTopLeftFillerFrame.clearGraphics();
		self.myDockBar.myScrollableFrame.clearGraphics();
		//self.clearGraphics();
		
		self.myDockBar.myScrollableFrame.myHLabels.backColor := _newColor;
		self.myDockBar.myScrollableFrame.myVLabels.backColor := _newColor;
		self.myDockBar.myScrollableFrame.myTopLeftFillerFrame.backColor := _newColor;
		self.myDockBar.backColor := _newColor;
		self.myDockBar.myScrollableFrame.backColor := _newColor;
		self.backColor := _newColor;
		
		self.myDockBar.myRoRoLaneDrawingController.setIsDrawFromAreaSelect(true);
		self.visible := false;
		self.myDockBar.myRoRoLaneDrawingController.drawRoRoLaneAreaFromSelect(endx, endy);	
		self.visible := true;
	endif;
epilog
	self.myDockBar.myRoRoLaneDrawingController.setIsDrawFromAreaSelect(false);
end;</source>
        <Parameter name="_newColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="contextMenu" id="294da89b-845b-4ee9-acce-318970689092">
        <controlMethod name="Frame::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>contextMenu(frame: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	yrdForm : Form;
begin
	
	return self.doDFContextMenu(frame,conwin,mouse, x,y);
	/*
	yrdForm := self.getForm();
	if yrdForm  = null then
		return true;
	endif;
	
	if self.isEnquiry then
		return yrdForm.YRD_GridAreaEnquiryForm.doDFContextMenu(frame,conwin,mouse, x,y);
	elseif self.myDockBar.isForTrailers then
		yrdForm.YRD_TrailerAreasForm.doDFContextMenu(frame,conwin,mouse, x,y);
	elseif self.myDockBar.isForOverview then
		yrdForm.YRD_GridAreasOverviewForm.doDFContextMenu(frame,conwin,mouse, x,y);
	else
		return yrdForm.YRD_GridAreasForm.doDFContextMenu(frame,conwin,mouse, x,y);
	endif;
	*/
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
