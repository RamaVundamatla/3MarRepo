    <JadeMethod name="updatePortGroup" id="5f2a7715-5c3d-4d5c-989a-712fff2f4493">
        <source>updatePortGroup(_portGroup : CM_PortGroup);
/*

Purpose:		Update Port Group	

Date		Who		Reason
06/03/2014	cnwma1	Initial creation

*/

vars
	pxyPortGroup 	: CM_PortGroup;
	portGroupDesc	: String;
	ports			: CM_PortByCodeDict;
	

begin
	
	create ports transient;
	beginLoad;
	pxyPortGroup :=_portGroup.pxyCreateUpdateProxy();
	endLoad;
	
	portGroupDesc := _portGroup.description.asStringJMT();
	
	if self.opts.includesKey("portGroupDesc") then
		portGroupDesc := self.opts.str("portGroupDesc");
		_portGroup.allPorts.copy(ports);
		ports.add(app.myRoot.allPortLocodes["AEJEA"]);
	endif;
	
	pxyPortGroup.setProxy(_portGroup.code,
						  portGroupDesc,
						  ports);
	app.myTrxUA.trxUpdatePortGroup(pxyPortGroup,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete ports;
	delete pxyPortGroup;

end;</source>
        <Parameter name="_portGroup" type="CM_PortGroup"/>
    </JadeMethod>
    <JadeMethod name="updateProduct" id="09fb922c-8437-4cdc-9353-3897289b872e">
        <source>updateProduct(_product : Any; _operator: CM_Operator; _cargoType: CM_CargoType);

/*

Purpose:		Update Product Details

Date			Who		Reason
15/05/2015		cnwmh5	Initial creation

*/

vars

	product					: CM_Product;
	pxyProduct				: CM_Product;
	autoWeightCalculate : Boolean;
	isReefer : Boolean;

begin

	if _product.isKindOf(String) then
		product := _cargoType.allProducts[_operator.code, _product.String];
	elseif _product.isKindOf(CM_Product) then
		product := _product.CM_Product;
	endif;
	
	if product &lt;&gt; null then
		beginLoad;
		pxyProduct := product.pxyCreateUpdateProxy();
		pxyProduct.createProductAttributes();	
		pxyProduct.setForUpdate(product);
		endLoad;
		
	//	pxyProduct.setPropertyValue("isReefer", self.opts.bool("isReefer").Boolean);
		if self.opts.includesKey("isReefer") then
			isReefer := self.opts.bool("isReefer");
		else
			isReefer := pxyProduct.isReefer;
		endif;
		
		if self.opts.includesKey("AutoWeightCalculate") then
			autoWeightCalculate := self.opts.bool("AutoWeightCalculate");
		else
			autoWeightCalculate := pxyProduct.autoWeightCalculate;
		endif;
		
		pxyProduct.setProxy(pxyProduct.myCargoType,	//_cargoType		: CM_CargoType; 
							pxyProduct.myOperator,	//_operator 		: CM_Operator;
							pxyProduct.defaultCommodityCode,	//_defaultCommodityCode	: String;
							pxyProduct.myProductGroup,	//_productGroup	: CM_ProductGroup;
							pxyProduct.myHandlingType,	//_handlingType 	: CM_HandlingType;
							pxyProduct.myHandlingSubType,	//_handlingSubType : CM_HandlingSubType;
							pxyProduct.storageCharge,	//_storageCharge	: Decimal;
							pxyProduct.code,	//_code, _description : String;
							pxyProduct.description,
							pxyProduct.colour,	//_colour			: Integer;
							isReefer,	//_reefer			: Boolean;
							pxyProduct.isPowered,	//_powered		: Boolean;
							pxyProduct.isIntegral,	//_integral		: Boolean;
							pxyProduct.isFan,	//_fan			: Boolean;
							pxyProduct.isNotActive,	//_isNotAvail : 	Boolean;
							pxyProduct.autoVolumeCalculate,	//_autoVolumeCalculate : Boolean;	
							autoWeightCalculate	//_allowAutoWeightCalc : Boolean
							);
		
		app.myTrxUA.trxUpdateProduct(pxyProduct, app.myPassport);
		self.assertNoTrxErrors();
	endif;

epilog
	delete pxyProduct;
end;</source>
        <Parameter name="_product" type="Any"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
