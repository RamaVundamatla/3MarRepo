    <JadeMethod name="checkTextTableRowChange" id="a6e33f25-dad4-4123-8d2f-f4114249215a">
        <updating/>
        <source>checkTextTableRowChange(): Boolean updating;
/*
	Created on 19 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	result	: Integer;
begin
	if self.itemEditMode &lt;&gt; self.Mode_Update then
		return true;
	endif;
	if not dck_BRefItem.visible then
		// viewing so no check needed.
		return true;
	endif;
	if self.itemEditMode = self.Mode_Add then
		return false;
	endif;
	if not tblExtra.hasChanged then
		return true;
	endif;

	result := app.msgBox(app.getErrorString(QueryRowChange),  app.getErrorString(Warning), MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon);
	
	if result = MsgBox_Return_Cancel then
		// do NOT move to new row.
		return false;
	elseif result = MsgBox_Return_No then
		// cancel changes to existing item and move to the next row
		self.doCancelBookRefItem(false);
		return true;
	elseif result = MsgBox_Return_Yes then
		// save the existing item, if successful then move to the new row;
		self.doOKBookRefItem(false);
		return true;
	endif;

	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
