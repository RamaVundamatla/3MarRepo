    <JadeMethod name="updateSelf" id="074b7588-f465-4e6d-99a6-437b0d5a2ef8">
        <updating/>
        <source>updateSelf(_value: Any; _obj :Object) updating;
// ---------------------------------------------------------------------------
// Created:     11 February 2010 by cnwcs5
// Purpose:     par 22140 - new functions
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/02/2010	cnwcs5		par 22435 - release summary extenstions
// ---------------------------------------------------------------------------
vars

begin
	if _value.isKindOf (CM_SnapshotField_Count_Null) then
		self.count 	:= self.count + _value.CM_SnapshotField_Count_Null.count;
		return;
	endif;
	
	// it will be a boolean
	if _value.Boolean then
		self.count := self.count + 1;
		
		self.allObjects.addNoDuplicates	(_obj, false);	// 22/02/2010
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
