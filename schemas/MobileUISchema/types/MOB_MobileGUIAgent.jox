    <JadeMethod name="createNewCargoItem" id="8bc75c1a-71b9-4979-bd27-3754e0a4c934">
        <source>createNewCargoItem(_cargoID : String; _cmif : CMIF_TIGenCargo; _roadJob : CM_RoadJob): CMIF_Receival;
/*
	Created on 10 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	form : MOB_NewCargoItemForm;	
begin
	form := findOrShowForm(MOB_NewCargoItemForm, null, true).MOB_NewCargoItemForm;
	form.setCargoId(_cargoID);
	form.setMyTemplateCMIF(_cmif);
	form.setMyRoadJob(_roadJob);
	if not form.tag = form.FormOpen then
		form.showModal;
	endif;
	if form.modalResult = ModalResultOK then
		return form.myIntFacePrenote;
	else
		return null;
	endif;
epilog
	delete form;
end;</source>
        <Parameter name="_cargoID" type="String"/>
        <Parameter name="_cmif" type="CMIF_TIGenCargo"/>
        <Parameter name="_roadJob" type="CM_RoadJob"/>
        <ReturnType type="CMIF_Receival"/>
    </JadeMethod>
    <JadeMethod name="findExistingForm" id="505dde5f-0a22-4ad6-8d02-c879d124fda1">
        <source>findExistingForm(_formClass : Class; _mainObject : CM_Object) : MOB_BaseForm;

vars
	index 		: Integer;
	formGen		: Form;
	form		: MOB_BaseForm;
	numForms	: Integer;
	
begin
	numForms	:=	app.formsCount();
	
	foreach index in 1 to numForms do
		formGen := app.forms(index);
		
		if not formGen.isKindOf(MOB_BaseForm) then
			continue;
		endif;
		
		form := formGen.MOB_BaseForm;
		
		if form.isKindOf(_formClass) 
		and (_mainObject = null or _mainObject = form.getMyMainObject())
		then
			form.setFocus();
			return form;
		endif;
	endforeach;
	
	return null;
end;
</source>
        <Parameter name="_formClass" type="Class"/>
        <Parameter name="_mainObject" type="CM_Object"/>
        <ReturnType type="MOB_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="findFormsForUser" id="8739553e-8ba9-46f7-8620-7ccd28fc2484">
        <updating/>
        <source>findFormsForUser(allAvailableForms : ObjectArray input; _passport : CM_Passport input)updating;
// ---------------------------------------------------------------------------
// Created:	05 January 2009 By Graeme Black cnwgb1
// Purpose:	Interogates the permissions for this user to 
//          work out which forms to display for the user.
//			PNL CCMS 1794
// ---------------------------------------------------------------------------
// epr 	tfs 36405 2/2/18 moved from app because i wan't to call from another app to get permission references and that was very problematic
//epr TFS 37901 3/4/18 menus that share permissions where missing

vars
	passport : CM_Passport;
	term : CM_Terminal;
	form	: Class;
begin
	if allAvailableForms.size &gt; 0 then
		return;
	endif;
		// ####################################
		
		// If adding new items please slot it alphabetically
		
		// ####################################
		// ####################################

		// 32612 - AKB made the options alphabetic
		
		self.getFormForPermisson(_passport, PmHHBBDiscrepancy,allAvailableForms);	// cargo Discrepancy	//26 Nov 2013	NDL	Par 33073
	
		self.getFormForPermisson(_passport,PmHHCargoEnquiry,allAvailableForms);	// cargo Discrepancy	//26 Nov 2013	NDL	Par 33073
		
		
		self.getFormForPermisson(_passport,PmHHGrading,allAvailableForms);	// Cargo Grading
	
			
		if app.isCargoGroupEnabled then	//04 Jun 2015	NDL	Par 36338
			 self.getFormForPermisson(_passport, PmHHCargoGroupComp,allAvailableForms);
			
			 self.getFormForPermisson(_passport, PmHHCargoGroupMove,allAvailableForms) ;
			
		endif;

		self.getFormForPermisson(_passport, PmHHCargoAltId,allAvailableForms) ; // Cargo Identifier     //30 Apr 2013	NDL	Par 31506
		
	
		
		 self.getFormForPermisson(_passport,PmHHBBMerge,allAvailableForms) ; // Cargo Merge			// CCMS 2274 - Break-bulk
		
		 self.getFormForPermisson(_passport,PmHHBBSplit,allAvailableForms); // Cargo Split			// CCMS 2274 - Break-bulk
		
		
		 self.getFormForPermisson(_passport, PmHHMaintainStops,allAvailableForms); // Cargo Stops
		
		 self. getFormForPermisson(_passport, PmHHMaintainTasks,allAvailableForms); // Cargo Tasks
			
		  self.getFormForPermisson(_passport, PmHHDamageReport,allAvailableForms); // Damage Report
		
		  self.getFormForPermisson(_passport,PmHandHeldShipDelays,allAvailableForms);	// Delays			// CCMS 2059 - Par 27755		
		
		  self.getFormForPermisson(_passport,PmHandHeldDocActions,allAvailableForms);	// Document Actions			//20 Oct 2016	TFS 2655 / 2419
		
		 self.getFormForPermisson(_passport,PmHandHeldGateChecker,allAvailableForms); // Gate Checker
		
		self.getFormForPermisson(_passport,PmHandHeldInterTerminal,allAvailableForms); // Inter Terminal
		
		 self.getFormForPermisson(_passport,PmHandHeldLander,allAvailableForms); // Lander
		
		 self.getFormForPermisson(_passport, PmHHHatchman,allAvailableForms); // Loading MTs to Vessel		
		
		 self.getFormForPermisson(_passport,PmHHLocationCheck,allAvailableForms);	//11 Aug 2015 NDL Par 36608		
		
		self.getFormForPermisson(_passport, PmHHMove,allAvailableForms); // Move Cargo
		
		
		 self.getFormForPermisson(_passport, PmHHMultiBooking,allAvailableForms);	//11 Oct 2016	TFS 2811 / 2549
		
		
		//14 Sep 2015	NDL	Par 36900
		 self.getFormForPermisson(_passport, PmHHMultiMovePack,allAvailableForms );	// Multi Move or Pack
		
		
		 self.getFormForPermisson(_passport,PmHHPackContainer,allAvailableForms) ;	// Pack Container		// CCMS 1119	- Par 26476
			
		self.getFormForPermisson(_passport,PmHHPackLoadByBat,allAvailableForms);	// Pack/Load by Bat		//18 Aug 2015	NDL	Par 36782
			
		 self.getFormForPermisson(_passport,PmHHPackLoadRequest,allAvailableForms);	// Pack/Load by Request		// CCMS 2384	- Par 34717
		
		self.getFormForPermisson(_passport, PmAdmHHRailConfirm,allAvailableForms);		// Rail Placement
		
		self.getFormForPermisson(_passport, PmHHRailLander,allAvailableForms);		// Rail Lander
			
		self.getFormForPermisson(_passport, PmHHRaiseAlert,allAvailableForms); // Raise Alert
		
		self.getFormForPermisson(_passport, PmHHReeferConnect,allAvailableForms); // Reefer Connect
			
		 self.getFormForPermisson(_passport, PmHHReeferEnquiry,allAvailableForms); // Reefer Enquiry
		
		 self.getFormForPermisson(_passport, PmHHReeferReadings,allAvailableForms); // Reefer Heading
		
		self.getFormForPermisson(_passport, PmHHReleaseStaging,allAvailableForms);	//28 Oct 2014 NDL	Par 35146
				
		self.getFormForPermisson(_passport,PmHandHeldYardRoadLander,allAvailableForms); // Road to Yard Lander
		
		 self.getFormForPermisson(_passport,PmHandHeldRoRoShipLoader,allAvailableForms); // RORO Ship Lander			// CCMS 1077	- Par 23761		

		self.getFormForPermisson(_passport,PmHandHeldShipLander,allAvailableForms); // Ship to Yard Lander
			
		self.getFormForPermisson(_passport,PmHandHeldTruckLoader,allAvailableForms); // Truck Loader
			
		self.getFormForPermisson(_passport,PmHandHeldTruckUnloader,allAvailableForms) ; // Truck Unloader
		
		self.getFormForPermisson(_passport,PmHHTruckWarehouseRelease,allAvailableForms) ; // Truck Warehouse Release epr par 36908 17/9/15
			
		// self.getFormForPermisson(_passport, PmHHReeferConnect,allAvailableForms); // Reefer Connect
			
		//	PAR 34417 moved here
		self.getFormForPermisson(_passport,PmHHUnpackContainer,allAvailableForms);	// Unpack Container  		// CCMS 1119	- Par 26476		
		
	//	if app.myRoot.canDo(PmOmanBespoke) then			//29 Feb 2016	TFS 1593  STW Oman Bespoke Apps Licence.
		if app.myRoot.isClientSTWOman or app.myPassport.myUser.isSuperUser() or process.isJLGAB1	then //07 Oct 2019	NDL	TFS 46169
			self.getFormForPermisson(_passport,PmHHVehicleLander,allAvailableForms);		
			self.getFormForPermisson(_passport,PmHHVehicleRORO,allAvailableForms);		
			self.getFormForPermisson(_passport,PmHHVehicleMove,allAvailableForms) ;		
		endif;
		
		self.getFormForPermisson(_passport,PmHHRoRoLandConf,allAvailableForms);	
		
		//17 May 2017	NDL	TFS 4460 - Bespoke app for AAT to load vehicles on to a truck with all nut no checks and balances....
	/*	if app.myRoot.canDo(PmVehicleHandling) then
			self.getFormForPermisson(_passport,PmHHVTLoader,allAvailableForms);			
		endif; */ //07 Oct 2019	NDL	TFS 46169
		self.getFormForPermisson(_passport,PmHHAttachDetach,allAvailableForms); //27.02.2018 cnwma1 ChangeRequest #36813

	epilog
end;</source>
        <Parameter name="allAvailableForms" type="ObjectArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findOrShowForm" id="735b3cc7-2bb5-46cf-9180-daeea13915dd">
        <source>findOrShowForm(_formClass : Class; _mainObject : CM_Object; _modal : Boolean): Form;
/*
	Created on 13 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/
vars
	formGen	: Form;
 	form	: MOB_BaseForm;
	index 	: Integer;
	
begin
	if _modal then
		form := findExistingForm(_formClass, _mainObject);
		if form &lt;&gt; null then
			form.tag := form.FormOpen;
			return form;
		else
			create form as _formClass transient;
			form.setMyMainObject(_mainObject); //Anca
			return form;
		endif;
	endif;
	
	form := findExistingForm(_formClass, _mainObject);
	
	if form &lt;&gt; null then
		form.setFocus;
		return form;
	endif;
	
	create form as _formClass transient;
	form.setMyMainObject(_mainObject);
	form.show();
	
	return form;
end;</source>
        <Parameter name="_formClass" type="Class"/>
        <Parameter name="_mainObject" type="CM_Object"/>
        <Parameter name="_modal" type="Boolean"/>
        <ReturnType type="Form"/>
    </JadeMethod>
    <JadeMethod name="findRoadJob" id="5f66483c-93f0-4f86-89d4-93f9b05abea7">
        <source>findRoadJob(): CM_RoadJob;
/*
	Created on 04 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	form	: MOB_TruckIDForm;	
begin
	create form transient;
	form.showModal();
	if form.modalResult = ModalResultOK then
		return form.myRoadJob;
	endif;
	return null;
epilog
	delete form;
end;</source>
        <ReturnType type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="getFormForPermisson" id="1577467b-9da3-4fcb-9c0e-4e05aa574c1d">
        <source>getFormForPermisson(_passport : CM_Passport; _permission : Integer;
					_allForms : ObjectArray input) ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2018	jlger1	Initial creation
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
3 April 2018 jlger1	tfs 37901 missing menu items 
*/

vars
	user : CM_User;
begin
	user := _passport.myUser;
	if not user.canDo(_passport.myTerminal,_permission) then	
		return ;
	endif;
	
	if (_permission = PmHHBBDiscrepancy) then	// cargo Discrepancy	//26 Nov 2013	NDL	Par 33073
		_allForms.add(MOB_HHCargoDiscrepancy);
	endif;
	if (_permission = PmHHCargoEnquiry) then // Cargo Enquiry
		_allForms.add(MOB_HHCargoEnquiryForm);
	endif;
		
		if (_permission =  PmHHGrading) then // Cargo Grading
			_allForms.add(MOB_HHCargoGrading);
		endif;
		
		//04 Jun 2015	NDL	Par 36338
		if (_permission =  PmHHCargoGroupComp) then
			_allForms.add(MOB_HHCargoGroupComplete);
		endif;
		if (_permission =  PmHHCargoGroupMove) then
			_allForms.add(MOB_HHCargoGroupAssignMove);
		endif;
		

		if (_permission =  PmHHCargoAltId) then // Cargo Identifier     //30 Apr 2013	NDL	Par 31506
			_allForms.add(MOB_HHCargoIdentifier);
		endif;
		
		if (_permission = PmHHBBMerge) then // Cargo Merge			// CCMS 2274 - Break-bulk
			_allForms.add(MOB_HHCargoMerge);
		endif;
		if (_permission = PmHHBBSplit) then // Cargo Split			// CCMS 2274 - Break-bulk
			_allForms.add(MOB_HHCargoSplit);
		endif;
		
		if (_permission =  PmHHMaintainStops) then // Cargo Stops
			_allForms.add(MOB_HHCargoStopsForm);
		endif;
		if (_permission =  PmHHMaintainTasks) then // Cargo Tasks
			_allForms.add(MOB_HHCargoTasksForm);
			//Current Cargo Tasks	05 Oct 2015	NDL Par 37011
			//30 Sep 2015	NDL	Par 36993
			_allForms.add(MOB_HHCargoTasksCurrent);
			_allForms.add(MOB_HHMultiCargoToDoComplete);
		endif;

		if (_permission =  PmHHDamageReport) then // Damage Report
			_allForms.add(MOB_HHDamageForm);
		endif;
		if (_permission = PmHandHeldShipDelays) then	// Delays			// CCMS 2059 - Par 27755
			_allForms.add(MOB_HHDelaySelect);
		endif;
		
		if (_permission = PmHandHeldDocActions) then	// Document Actions			//20 Oct 2016	TFS 2655 / 2419
			_allForms.add(MOB_HHDocumentSelect);
		endif;
		
		if (_permission = PmHandHeldGateChecker) then // Gate Checker
			_allForms.add(MOB_HHGateCheckTruck);
		endif;
		if (_permission = PmHandHeldInterTerminal) then // Inter Terminal
			_allForms.add(MOB_HH_ITSSelector);
		endif;
		
		if (_permission = PmHandHeldLander) then // Lander
			_allForms.add(MOB_HHLanderVoyageQueue);
		endif;
		if (_permission =  PmHHHatchman) then // Loading MTs to Vessel
			_allForms.add(MOB_HandHeldSelectVoyageForm);
		endif;
		
		if (_permission = PmHHLocationCheck) then	//11 Aug 2015 NDL Par 36608
			_allForms.add(MOB_HHCargoLocationCheck);	//Location Check
		endif;
		
		if (_permission =  PmHHMove) then // Move Cargo
			_allForms.add(MOB_HHMoveCargo);
		endif;
		
		if (_permission =  PmHHMultiBooking) then	//11 Oct 2016	TFS 2811 / 2549
			_allForms.add(MOB_HHMultiBookingSelectForm);
		endif;
		
		//14 Sep 2015	NDL	Par 36900
		if (_permission =  PmHHMultiMovePack ) then	// Multi Move or Pack
			_allForms.add(MOB_HHMultiCargoMovePack);
		endif;
			
		if (_permission = PmHHPackContainer) then	// Pack Container		// CCMS 1119	- Par 26476
			_allForms.add(MOB_HHPackForm);
		endif;
		if (_permission = PmHHPackLoadByBat) then	// Pack/Load by Bat		//18 Aug 2015	NDL	Par 36782
			_allForms.add(MOB_HHPackLoadByBAT);
		endif;
		if (_permission = PmHHPackLoadRequest) then	// Pack/Load by Request		// CCMS 2384	- Par 34717
			if app.isCargoGroupEnabled then	//12 Apr 2018	NDL	TFS 38083
				_allForms.add(MOB_HHPackRequest);	// Pack/Load by Request	
				_allForms.add(MOB_HHPackRequestViewSTW);// Pack/Load by Request	Overview (the Huntsman version) //20 Dec 2018	NDL	TFS 38083
			else
				_allForms.add(MOB_HHPackRequest);
				if app.isDevelopmentSystem() or app.isSpecial() then
					_allForms.add(MOB_HHPackRequestViewSTW);
				endif;
			endif;
		endif;
		if (_permission =  PmAdmHHRailConfirm) then		// Rail Placement
			_allForms.add(MOB_HHRailPlaceIOForm);	//24 Aug 2010	NDL		Par 25215
		endif;
		if (_permission =  PmHHRailLander) then		// Rail Lander
			_allForms.add(MOB_HHLanderTrainWagon);	//21 Mar 2013	NDl	Par 31278
		endif;
		if (_permission =  PmHHRaiseAlert) then // Raise Alert
			_allForms.add(MOB_HHRaiseAlertForm);
		endif;
		if (_permission =  PmHHReeferConnect) then // Reefer Connect
			_allForms.add(MOB_HHReeferConnectForm);
		endif;
		if (_permission =  PmHHReeferEnquiry) then // Reefer Enquiry
			_allForms.add(MOB_HHReeferEnquiryForm);
		endif;
		if (_permission =  PmHHReeferReadings) then // Reefer Heading
			_allForms.add(MOB_HHReeferReadingsForm);
		endif;
		if (_permission =  PmHHReleaseStaging) then	//28 Oct 2014 NDL	Par 35146
			if app.isCargoGroupEnabled then
				_allForms.add(MOB_HHReleaseStagingSTW);
				if app.isDevelopmentSystem() or app.isSpecial() then
					_allForms.add(MOB_HHReleaseStaging);
				endif;
			else
				_allForms.add(MOB_HHReleaseStaging);
				if app.isDevelopmentSystem() or app.isSpecial() then
					_allForms.add(MOB_HHReleaseStagingSTW);
				endif;
			endif;
		endif;
		if (_permission = PmHandHeldYardRoadLander) then // Road to Yard Lander
			_allForms.add(MOB_HHYardRoadLander);
		endif;
		if (_permission = PmHandHeldRoRoShipLoader) then // RORO Ship Lander			// CCMS 1077	- Par 23761
			_allForms.add(MOB_HHRoRoShipLoaderVoyage);
		endif;

		if (_permission = PmHandHeldShipLander) then // Ship to Yard Lander
			_allForms.add(MOB_HHShipLanderVoyage);
		endif;
		
		if (_permission = PmHandHeldTruckLoader) then // Truck Loader
			_allForms.add(MOB_HHTruckLoaderSelect);
		endif;
		if (_permission = PmHandHeldTruckUnloader) then // Truck Unloader
			_allForms.add(MOB_HHTruckUnloaderSelect);
		endif;
		if (_permission = PmHHTruckWarehouseRelease) then // Truck Warehouse Release epr par 36908 17/9/15
			_allForms.add(MOB_HHTruckReleaseEntry);
		endif;
		
		if (_permission =  PmHHReeferConnect) then // Reefer Connect
			_allForms.add(MOB_HandHeldUnconnectedReefers);
		endif;
		//	PAR 34417 moved here
		if (_permission = PmHHUnpackContainer) then	// Unpack Container  		// CCMS 1119	- Par 26476
			_allForms.add(MOB_HHUnpackFromForm);
		endif;
		
				//29 Feb 2016	TFS 1593  STW Oman Bespoke Apps Licence.
		if (_permission = PmHHVehicleLander) then
			_allForms.add(MOB_HHVehicleLanderVoyForm);	// Vehicle Lander
		endif;
		if (_permission = PmHHVehicleRORO) then
			_allForms.add(MOB_HHVehicleROROArea);	// Vehicle Location Confirmation
		endif;
		if (_permission = PmHHVehicleMove) then
			_allForms.add(MOB_HHVehicleMove);	//Vehicle Move
		endif;
		
		
		if (_permission = PmHHRoRoLandConf) then
			_allForms.add(MOB_HHVehicleLanderConfirm);	// Vehicle Lander RORO Confirmation TFS  2246 / 2680
		endif;
		
	
		if (_permission = PmHHVTLoader) then
			_allForms.add(MOB_HHVehicleTransLoad);
		endif;
		
		if _permission = PmHHAttachDetach then  //27.02.2018 cnwma1 ChangeRequest #36813
			_allForms.add(MOB_HHAttachDetachGenerator);
		endif;
		
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_permission" type="Integer"/>
        <Parameter name="_allForms" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getLocation" id="98e894c5-7fee-47db-abcf-0ff55473212e">
        <source>getLocation(modeString : String): CM_LocationsController;
/*
	Created on 23 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	form : MOB_GetLocationForm;
begin
	create form transient;
	form.setCaption(modeString);
	form.showModal();
	if form.modalResult = ModalResultOK then
		return form.myLocation;
	endif;
	return null;
epilog
	delete form;
end;</source>
        <Parameter name="modeString" type="String"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getTranslationOfMenu" id="bd7ee3d1-3e40-425c-a833-d4d7bb770e00">
        <source>getTranslationOfMenu(_form : Class input; _locale : CM_Locale input) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2018	jlger1	Initial creation
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	currentLocale : CM_Locale;
	localeId : String;
	invalidLocale	: Boolean;
	translation		: XLAT_Translation;
begin
	currentLocale:=_locale;
	if currentLocale = null then
		currentLocale:=CM_Root.firstInstance.getLocale(StandardTextLocaleStr, false);
	endif;
	on Exception do app.handleDeletedObject(exception, currentLocale, invalidLocale);
	localeId:=currentLocale.localeId;
	
	if invalidLocale then
		currentLocale:=CM_Root.firstInstance.getLocale(StandardTextLocaleStr, false);
	endif;
	
	if _form = MOB_HHCargoDiscrepancy then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0019371);
	endif;
		
	if _form = MOB_HHCargoEnquiryForm then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0013018);
	endif;
	
	if _form = MOB_HHCargoGrading then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0013035);
	endif;
	
	if _form = MOB_HHCargoIdentifier then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0019046);
	endif;
	
	if _form = MOB_HHCargoMerge then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0019116);
	endif;
	
	if _form = MOB_HHCargoSplit then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0019118);
	endif;
	
	if _form = MOB_HHCargoStopsForm then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0013147);
	endif;
		
	if _form = MOB_HHCargoTasksForm then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0013148);
	endif;
	
	if _form = MOB_HHDamageForm then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0013024);
	endif;
	
	if _form = MOB_HHDelaySelect then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0016602);
	endif;
	if _form = MOB_HHGateCheckTruck then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0015175);
	endif;	
	if _form = MOB_HH_ITSSelector then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0014437);
	endif;
	if _form = MOB_HHLanderVoyageQueue then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0014418);
	endif;
	if _form = MOB_HandHeldSelectVoyageForm then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0013139);
	endif;
	if _form = MOB_HHMoveCargo then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0019053);
	endif;
	if _form = MOB_HHPackForm then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0016621);
	endif;
	if _form = MOB_HHPackLoadByBAT then	//18 Aug 2015	NDL	Par 36782
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0020790);
	endif;
	if _form = MOB_HHPackRequest then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0019834);
	endif;	
	if _form = MOB_HHPackRequestViewSTW then	//20 Dec 2018	NDL	TFS 38083 - Huntsman version of Pack/Load Request, i.e. starts with Overview form
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0023127);
	endif;	
	if _form = MOB_HHRailPlaceIOForm then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0015190);
	endif;	
	if _form = MOB_HHLanderTrainWagon then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0018489);
	endif;
	if _form = MOB_HHRaiseAlertForm then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0013108);
	endif;	
	if _form = MOB_HHReeferConnectForm then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0013109);
	endif;	
	if _form = MOB_HHReeferEnquiryForm then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0013112);
	endif;	
	if _form = MOB_HHReeferReadingsForm then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0013118);
	endif;	
	if _form = MOB_HHReleaseStaging or _form = MOB_HHReleaseStagingSTW then	//12 Oct 2015	NDL	Par 37033
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0019977);
		if (app.isDevelopmentSystem() or app.isSpecial()) and _form = MOB_HHReleaseStagingSTW then
			if translation &lt;&gt; null then
				return translation.text &amp; " - SteinWeg";
			endif;
			
		endif;	
	endif;		
	if _form = MOB_HHYardRoadLander then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0014249);
	endif;	
	if _form = MOB_HHRoRoShipLoaderVoyage then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0015218);
	endif;
	if _form = MOB_HHShipLanderVoyage then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0014428);
	endif;
	if _form = MOB_HHTruckLoaderSelect then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0013988);
	endif;	
	if _form = MOB_HHTruckUnloaderSelect then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0014436);
	endif;		
	if _form = MOB_HandHeldUnconnectedReefers then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0013159);
	endif;		
	if _form = MOB_HHUnpackFromForm then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0016638);
	endif;
	if _form = MOB_HHCargoGroupAssignMove then	//11 Jun 2015	NDL	Par 36338
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0020711);
	endif;	
	if  _form = MOB_HHCargoGroupComplete then	//24 Aug 2015	NDL	Par 36608
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0020804);
	endif;
	if _form = MOB_HHCargoLocationCheck then	//11 Aug 2015 NDL Par 36608
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0020761);
	endif;
	
	if _form = MOB_HHTruckReleaseEntry then	//10/9/15 epr CCMS 2534 par 36908
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0020920);
	endif;
	
	if _form = MOB_HHMultiCargoMovePack then	//14 Sep 2015	NDL	Par 36900
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0020940);
	endif;
	
	if _form = MOB_HHMultiCargoToDoComplete then	//30 Sep 2015	NDL	Par 36993
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0020981);
	endif;
	
	if _form = MOB_HHCargoTasksCurrent then	//05 Oct 2015	NDL	Par 37011
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0020986);
	endif;
	
	if _form = MOB_HHVehicleLanderVoyForm then	// Vehicle Lander 		29 Feb 2016	TFS 1593
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0021290);
	endif;
	if _form = MOB_HHVehicleROROArea then	// Vehicle Location Confirmation		29 Feb 2016	TFS 1593
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0021174);
	endif;
	
	if _form = MOB_HHVehicleMove then	// Vehicle Location Confirmation		29 Feb 2016	TFS 1593
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0021187);
	endif;
	
	if _form = MOB_HHVehicleLanderConfirm then	//12 Sep 2016	NDL	TFS 2246
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0021299);
	endif;
	
	if _form = MOB_HHMultiBookingSelectForm then	//11 Oct 2016	TFS 2811 / 2549
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0021523);
	endif;
	
	if _form = MOB_HHDocumentSelect then	//20 Oct 2016	TFS 2655 / 2419
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0021355);
	endif;
	
	//17 May 2017	NDL	TFS 4460 - Bespoke app for AAT to load vehicles on to a truck with all nut no checks and balances....
	if _form = MOB_HHVehicleTransLoad then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0021997);
	endif;
	
	//27.02.2018 cnwma1 ChangeRequest #36813
	if _form = MOB_HHAttachDetachGenerator then
		translation	:= currentLocale.getTranslatedText(XLAT_FormCaptions, Xlat_0022211); //27.02.2018 cnwma1 ChangeRequest #36813
		
	endif;
	
	if translation &lt;&gt; null then
		return translation.text;
	endif;
	
	if currentLocale &lt;&gt; CM_Root.firstInstance.getLocale(StandardTextLocaleStr, false) then
		return self.getTranslationOfMenu(_form,null);
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_form" type="Class" usage="input"/>
        <Parameter name="_locale" type="CM_Locale" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
