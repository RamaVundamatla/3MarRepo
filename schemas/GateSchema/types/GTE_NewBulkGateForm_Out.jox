    <JadeMethod name="searchTable" id="f2da5671-279a-44dc-a264-9bff4c5c291e">
        <source>searchTable(_table :CM_DataTable;_searchValue : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2016	cnwns1	Initial creation

*/

vars
	searchValue : String;
	row 		: Integer;
	coll 		: Integer;	
	matchingRows : IntegerArray;
	cellText 	: String;
	table		: CM_DataTable;
begin
	searchValue := _searchValue;
	table := _table;
	
	if searchValue.isBlank() or table.rows = table.fixedRows then
		return;
	endif;
	
	create matchingRows transient;
	
	row := table.fixedRows + 1;
		
	while row &lt;= table.rows do
		coll := 1;
		while coll &lt;= table.columns   do
			cellText := tblItems.getCellText(row,coll);
			if cellText.toUpper().cnContains(searchValue) then
				if not matchingRows.includes(row) then
					matchingRows.add(row);
				endif;
			endif;
			coll := coll + 1;	
		endwhile;
		row := row + 1;
	endwhile;
	
	if matchingRows.size = 0 then
		return;
	endif;
	
	table.clearAllSelected;
	table.selectRow(matchingRows.first(),true);
	
epilog
	delete matchingRows;
end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_searchValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="setDefaultGate" id="36239730-038e-4198-96b2-fbf986d94677">
        <updating/>
        <source>setDefaultGate() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason


*/

vars
	gate : CM_Gate;
	
begin
	if not self.myBulkGateAgent.gateAndLaneSet then
		self.getXMLSettingsForSetup();									
	endif;
	
	gate := self.myBulkGateAgent.myGate;
	
	if gate = null then	 
		gate := self.myTerminal.getDefaultGate_OUT;	
	endif;
		
	if gate &lt;&gt; null and self.cmbGate.findObject(gate) &lt;&gt; -1 then	
		self.doChangeGate(gate);									
	else															
		self.cmbGate.setIndex(1);									
		self.doChangeGate(self.cmbGate.listObject.CM_Gate);			
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setNotifications" id="cbc2cc38-790f-4cc7-97a0-cdee9b49daf0">
        <source>setNotifications(_set : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2016	cnwns1	Initial creation

*/

vars
	
begin
	self.endNotificationForSubscriber(self);
	
	if _set then
		self.beginClassNotification(CM_VehicleVisitRecordDetail,false, Object_Create_Event, Response_Continuous,0);
		self.beginClassNotification(CM_GenericGateScanRecord, false, Any_System_Event, Response_Continuous, 0); 			//11 Apr 2022 navhl20 TFS 52777
