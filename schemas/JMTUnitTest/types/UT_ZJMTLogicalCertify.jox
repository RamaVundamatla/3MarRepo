    <JadeMethod name="uExtractUnitTestStaticData" id="5b5b6b55-e663-4ac7-80b3-d4ec242ccf91">
        <source>uExtractUnitTestStaticData();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2014	cnwndl1	Initial creation
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	allSelectedObjects : ObjectArray;
	formatName : String;
	
	ts : TimeStamp;
	outputFileName : String;
	
	oidTableRootObj : CnEcOidTable;
	hubbleObj : CnEcHubble;

begin

	app.cnEcInitializeBaseSchema();
	app.cnEcSetXmlSchema("PortSchema");

	//populate a collection with all the 'static data' you want to extract.
	create allSelectedObjects transient;
	
	CM_CargoType.instances.copy( allSelectedObjects );
	CM_ISOType.instances.copy( allSelectedObjects );
	
	formatName := "Default Full Attribute";  //Don't change this line...
	
	ts := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	outputFileName := "c:\temp\unitTestExtract" &amp; ts.date.format("yyMMdd_") &amp; ts.time.format("hhmm") &amp; ".txt";
	
	create oidTableRootObj transient;
	create hubbleObj transient;
	
	hubbleObj.initializeMe(	null,
							null,
							null,
							null,
							outputFileName,
							formatName,
							oidTableRootObj,
							allSelectedObjects
							);
							
	hubbleObj.export(0,false);

epilog

	app.cnEcFinalizeBaseSchema();

	delete allSelectedObjects;
	delete oidTableRootObj;
	delete hubbleObj;

end;</source>
    </JadeMethod>
