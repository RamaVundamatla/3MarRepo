    <JadeMethod name="setPxyFromCMGTE_Receival" id="ea1366a4-49df-49bf-806b-6a340c333445">
        <updating/>
        <source>setPxyFromCMGTE_Receival(_pxyGTE: CMGTE_Receival; _passport: CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/09/2009	cnwdap1	Initial creation
12/09/2013	cnwdap1	PAR #32215 New attributes for Cars
*/
vars
	pxyCar		: CMGTE_Car;									// PAR #32215

begin
	inheritMethod(_pxyGTE, _passport);
	
	pxyCar 					:= _pxyGTE.CMGTE_Car;				// PAR #32215
	//if _pxyGTE.CMGTE_Car.hasRadio then						// PAR #32215
	if pxyCar.hasRadio then										// PAR #32215
		self.hasRadio 		:= self.HasRadio;
	else
		self.hasRadio 		:= self.NoRadio;
	endif;
	//self.selfPropelled	:= _pxyGTE.CMGTE_Car.selfPropelled;	// PAR #32215
	self.selfPropelled		:= pxyCar.selfPropelled;			// PAR #32215
	
	self.colour				:= pxyCar.colour;					// PAR #32215
	self.make				:= pxyCar.make;						// PAR #32215
	self.model				:= pxyCar.model;					// PAR #32215
	self.carType			:= pxyCar.carType;					// PAR #32215
	self.year				:= pxyCar.year;						// PAR #32215
	self.trackingNumber1	:= pxyCar.trackingNumber1;			// PAR #32215
	self.trackingNumber2	:= pxyCar.trackingNumber2;			// PAR #32215
	self.docsReceived		:= pxyCar.docsReceived;				// PAR #32215
	self.docsSent			:= pxyCar.docsSent;					// PAR #32215
	self.docsCleared		:= pxyCar.docsCleared;				// PAR #32215
	self.docsReturned		:= pxyCar.docsReturned;				// PAR #32215
	self.nbrDoors			:= pxyCar.nbrDoors;					// PAR #32215
	self.isNew				:= pxyCar.isNew;					// PAR #32215
epilog

end;</source>
        <Parameter name="_pxyGTE" type="CMGTE_Receival"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
