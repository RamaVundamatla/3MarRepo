    <JadeMethod name="doMatch" id="968ec10e-de2b-4070-8c6d-843f4f36d80f">
        <source>doMatch(_value: Any): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Apr 2013	cnwpjs1	Initial creation

*/

vars

	obj	: Object;

begin
	if self.allSelectionValues.isEmpty then //Haven't selected any items so assume it's ok.  
		return true;
	endif;
	
	if _value = null then
		return false;
	endif;
	
	foreach obj in allSelectionValues do
		if _value.Collection.includes(obj) then
			return false;
		endif;
	endforeach;
													
	return true;

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
