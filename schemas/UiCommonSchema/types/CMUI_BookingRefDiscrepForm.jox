    <JadeMethod name="doEditBookingRef" id="0e4512c2-58d2-4753-bdec-7817a4703728">
        <source>doEditBookingRef(_bookingRef : CM_BookingRef);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

begin

	if (not CM_BookingRef.hasInstance(_bookingRef)) then
		return;
	endif;
	
	self.myAssistant.showBookingForm(_bookingRef, self.myMasterMenuAction, self.myTerminal);
	
epilog

end;</source>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="doEditRemarks" id="17a6d980-1753-4bc8-b2e4-412c98b98794">
        <source>doEditRemarks( eventDiscrep : CMEVT_BookingRefDiscrep );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars
	form : CMUI_BookRefDiscrepRemarksForm;
begin
	
	form := app.loadForm(CMUI_BookRefDiscrepRemarksForm, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_BookRefDiscrepRemarksForm;
	form.setMyCMEVT_BookingRefDiscrep(eventDiscrep);
	form.show;
	
epilog

end;</source>
        <Parameter name="eventDiscrep" type="CMEVT_BookingRefDiscrep"/>
    </JadeMethod>
