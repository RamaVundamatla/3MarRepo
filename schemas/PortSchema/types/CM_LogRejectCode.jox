vars

begin

	self.isCodeGroupNOTRequired := true;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="43322f20-6195-4d1c-838d-d8eb6c4d7c61">
        <updating/>
        <source>setForCreate(pProxy: CM_Code) updating;
// ---------------------------------------------------------------------------
// Created:     25 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pProxy);
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="pProxy" type="CM_Code"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="9b125e4c-6e70-4795-927a-7997b20318ed">
        <updating/>
        <source>setProxy(pCode, pDescription : String;_notAvailableForEntry:Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     25 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.setSuperClassDetailsForProxy(pCode, pDescription,_notAvailableForEntry,null);
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="ff5478ba-4c4c-44a3-8f9a-ba19408e979a">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     25 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.allLogRejectCodes.includesKey(self.code) &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;
	inheritMethod();

end;</source>
    </JadeMethod>
