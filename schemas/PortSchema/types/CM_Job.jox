    <JadeMethod name="validateForDelete" id="8a67a893-6a25-4720-84ea-217b2d661590">
        <source>validateForDelete();
//--------------------------------------------------------------
//Created: 01 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	wle	: CM_WorkListEntry;
begin
	if self.status = JOB_UNACTIONED or self.status = JOB_COMPLETE or self.allEntries.size = 0 then
		//Carry on.
	else
		app.setContinueCMExceptions(false);
		app.raiseCMException2(VB_JOB_NO_DELETE, self.jobId &amp; " oid - " &amp; self.String, self.statusString, null, null);
		return;
	endif;

	foreach wle in self.workListEntries do
		wle.validateForDelete();
	endforeach;
end;</source>
    </JadeMethod>
