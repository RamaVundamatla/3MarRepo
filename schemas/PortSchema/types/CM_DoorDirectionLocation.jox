    <JadeMethod name="setForCreate" id="afb78c94-d54d-4156-87f4-6cf22c59012a">
        <updating/>
        <source>setForCreate(_isoGroup : CM_ISOTypeGroup; _locationsController : CM_LocationsController; _doorDirectionRule : CM_DoorDirectionRule) updating;

// Created by cnwdvb1 on 16 August 2007

vars

begin

	self.myIsoGroup 				:= _isoGroup;
	self.myLocationsController		:= _locationsController;
	self.myDoorDirectionRule		:= _doorDirectionRule;

end;</source>
