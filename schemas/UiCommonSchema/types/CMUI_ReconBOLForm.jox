    </JadeMethod>
    <JadeMethod name="loadActualTable" id="e00abf47-aeca-44a1-b2df-2076788b205d">
        <source>loadActualTable();
//05 August 2009	cnwdw1	
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	rowString: String;
	bolDtl : CM_BOLDtl;
	ti: CM_TrackedItem;
	obj : Object;
	
	itemCount : Integer;
begin
	if self.myBOL &lt;&gt; null then
		self.tblActual.clearAllData;
		itemCount := 0;
		beginLoad;
		
		if self.chkShowAllCargo.value then
			foreach bolDtl in self.myBOL.allBOLDtls do
				foreach ti in bolDtl.allTrackedItems do
					if not ti.isNotified then				//+cnwml2 PAR21736
						rowString := ti.getAttributeStringForDefArray(self.tblActual.allTblDataEntRows);
						self.tblActual.addItemObject(ti, rowString);
						itemCount := itemCount + 1;
					endif;
				endforeach;
			endforeach;
		else
			foreach obj in self.tblExpected.allSelectedObjects do
				bolDtl := obj.CM_BOLDtl;
				foreach ti in bolDtl.allTrackedItems do
					if not ti.isNotified then				//+cnwml2 PAR21736
						rowString := ti.getAttributeStringForDefArray(self.tblActual.allTblDataEntRows);
						self.tblActual.addItemObject(ti, rowString);
						itemCount := itemCount + 1;
					endif;
				endforeach;
			endforeach;
		endif;
		endLoad;
		self.tblActual.colourRows(self.colorRow1, self.colorRow2);
		self.lblActual.caption := app.getString(BOL_Cargo)&amp; " (" &amp; itemCount.asStringJMT &amp; ")";
		
		self.tblActualMacro.rows := 0;
		self.tblActualMacro.columns := 0;
	endif;	

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;</source>
    </JadeMethod>
    <JadeMethod name="loadData" id="1f14b6d0-2878-44a9-ba62-5a189836d9b2">
        <updating/>
        <source>loadData()updating, protected;
//05 August 2009	cnwdw1	
//
vars
	bolDtl : CM_BOLDtl;
	expected : Integer;
begin
	if self.myBOL &lt;&gt; null then
		foreach bolDtl in self.myBOL.allBOLDtls do
			expected := expected + bolDtl.quantity;
		endforeach;
		
		if self.myBOL.reconciledDate &lt;&gt; null then
			if self.myBOL.reconciledReason &lt;&gt; null then
				self.lblReconDetail.caption := app.getString(ReconBookDetails, expected, self.myBOL.numTIs) &amp; " " &amp; app.getString(Reconciled) &amp; " - " &amp; self.myBOL.reconciledReason;
			else
				self.lblReconDetail.caption := app.getString(ReconBookDetails, expected, self.myBOL.numTIs) &amp; " " &amp; app.getString(Reconciled);
			endif;			
		else
			self.lblReconDetail.caption := app.getString(ReconBookDetails, expected, self.myBOL.numTIs);
		endif;
		self.loadExpectedTable();
		self.loadActualTable();
		self.loadUnreconciledTable();
		self.loadReconComplete();
	else
		self.clearForm();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadExpectedTable" id="e93042e3-3c25-4300-84bb-bda2d075c4dd">
        <updating/>
        <source>loadExpectedTable()updating, protected;
//05 August 2009	cnwdw1	
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	table		: CM_DataTable;
	rowString	: String;
	bolDtl 		: CM_BOLDtl;
	selectedObj	: Object;
begin
	table		:= self.tblExpected;				// par 23239
	selectedObj := table.allSelectedObjects.first;	// par23239
	
	table.clearAllData;
	
	beginLoad;
	foreach bolDtl in self.myBOL.allBOLDtls do
		rowString := bolDtl.getAttributeStringForDefArray(self.tblExpected.allTblDataEntRows);
		table.addItemObject(bolDtl, rowString);
	endforeach;
	endLoad;
	
	table.colourRows(self.colorRow1, self.colorRow2);
	
	//+ cnwmd1 Par 21741
	table.selectObject(selectedObj, false);	// par 23239
	self.tblExpected_click(table);

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadReconComplete" id="097fca97-8465-473e-bd7f-a6e3560d950e">
        <source>loadReconComplete();
//18 September 2009	cnwml2


vars

begin
	self.chkReconciled.value := self.myBOL.reconciledDate.Date &lt;&gt; null;
	self.dateComplete.text := self.myBOL.reconciledDate.Date.asStringJMT;
	self.txtCompleteReaso.text := self.myBOL.reconciledReason;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadUnreconciledTable" id="81b59171-0ce9-4e27-843b-1ccbd05d1371">
        <source>loadUnreconciledTable();
//05 August 2009	cnwdw1	
// PAR 26671 
vars
	rowString: String;
	ti: CM_TrackedItem;
	voyage: CM_Voyage;
	itemCount : Integer;
	tis: CM_TISet;
begin
	self.tblUnreconciled.clearAllData;
	itemCount := 0;
	
	create tis transient;
	if self.optBOL.value then
		self.myBOL.CM_BOLIn.allTrackedItems.copy(tis);
	elseif self.optVoyage.value then
		if self.myBOL &lt;&gt; null then							//  par 23241
			voyage := self.myBOL.CM_BOLIn.myVoyage;
		else												// par 23241
			voyage := self.cmbVoyage.listObject.CM_Voyage;	// par 23241
		endif;												// par 23241
		if voyage &lt;&gt; null then
			voyage.getAllTrackedItems(tis);
		endif;
	endif;
	
	foreach ti in tis do
		if ti.myBOLDtl = null and ti.isImport then
			rowString := ti.getAttributeStringForDefArray(self.tblUnreconciled.allTblDataEntRows);
			self.tblUnreconciled.addItemObject(ti, rowString);
			itemCount := itemCount + 1;
		endif;
	endforeach;
	
	self.tblUnreconciled.colourRows(self.colorRow1, self.colorRow2);
	self.lblUnreconciled.caption := app.getErrorString1 (UNRECONCILED_CARGO, itemCount.asStringJMT);	// par 23241 - made locale aware
	
	//+ cnwmd1 Par 21741
	foreach ti in self.allCurrentTrackedItems do
		self.tblUnreconciled.selectObject(ti, false);
	endforeach;
	self.tblUnreconciled.click(self.tblUnreconciled);
epilog
	delete tis;
end;</source>
    </JadeMethod>
