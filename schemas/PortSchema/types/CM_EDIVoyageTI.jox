    <JadeMethod name="assignValueSpecial" id="b5f80ad6-6859-41fa-800c-8dca7fb2f08f">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
// 31 July 2018	jlgrh7 TFS 39472 Internal EDI Format for Voyage doesn't allow the entry of Valid Operators
//
vars

begin
	if _propName = ETRow_ValidOperators or 
	   _propName = CM_EDIVoyageTI::allValidOperatorCodes.name then
		self.setValidOperatorsFromString(_processedValue);
		return true;
	else
		return inheritMethod(_propName, _processedValue, _xlationOperator);
	endif;
epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="62f1b6c1-4ba0-4ea4-bd49-2de58c6170d8">
        <source>canUserSet(_propName: String): Boolean;
//
// 31 July 2018	jlgrh7 TFS 39472 Internal EDI Format for Voyage doesn't allow the entry of Valid Operators
//
vars

begin
	if _propName = CM_EDIVoyageTI::allValidOperatorCodes.name then
		return true;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
