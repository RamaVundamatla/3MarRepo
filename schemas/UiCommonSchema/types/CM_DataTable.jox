    <JadeMethod name="delete" id="7a747fa7-b67f-4a12-b21f-c38372e8830e">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
/*

Date		Who		Reason
03 April 2014	cnwer1	Initial creation PAR 33900
17 Mar 2025	navnk30	JIRA 34245: Develop a generic solution to show data in a CM_DataTable using "Pagination"

*/

vars
	
begin
	self.deleteEntTableRowProxy();
	if self.isPaginated() then			//17.03.2025 navnk30 JIRA 34245
		delete self.getCollection();
	endif;
epilog
	
end	;</source>
    </JadeMethod>
    <JadeMethod name="deleteEntTableRowProxy" id="26af769a-0f82-4e9e-8ce9-b781bfcde666">
        <source>deleteEntTableRowProxy();
/*

Date		Who		Reason
03 April 2014	cnwer1	Initial creation PAR

*/

vars
	entTableRow : EntTableRow;
	obj			: Object;
	proxyRows 	: ObjectArray;
	pos  :Integer;
begin
	

	create proxyRows transient;
	foreach entTableRow in self.allTblDataEntRows discreteLock do
		if entTableRow.isKindOf(EntTableRowProxy) then
			if entTableRow.EntTableRowProxy.nameForProxy = "amount" then	//03 Nov 2020	NDL	TFS 49189
				continue;
			endif;
			
			pos:= entTableRow.EntTableRowProxy.nameForProxy.pos("debtorTypes",1);
			if pos = 0 then
				pos:= entTableRow.EntTableRowProxy.nameForProxy.pos("stops",1);	//21 July 2014	Par 34613
				if pos = 0 then
					proxyRows.add(entTableRow);
					continue;
				endif;
			endif;
			
		endif;
	endforeach;
	
	foreach obj in proxyRows discreteLock do
		self.allTblDataEntRows.remove(obj.EntTableRow);
	endforeach;
	proxyRows.purge;
epilog
	delete proxyRows;

end;</source>
    </JadeMethod>
    <JadeMethod name="deselectAll" id="86136f9d-9a58-4d63-8748-f86ba52d21a0">
        <updating/>
        <source>deselectAll()updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	stRow,numRows,
	rowIdx		: Integer;
	jRow		: JadeTableRow;
begin
	numRows := self.rows;
	stRow := self.fixedRows + 1;
	self.allSelectedObjects.clear();

	foreach rowIdx in stRow to numRows do
		jRow := self.accessRow(rowIdx);
		jRow.selected := false;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="deselectRow" id="23358ed6-4122-4d74-a223-d37c9474137e">
        <updating/>
        <source>deselectRow(_idx : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 September 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 25/03/2010		cnwcs5	par 22602 - moved call to interface method

vars
	theObj	: Object;
	theRow	: JadeTableRow;
	dtInterface : IF_CM_DataTable;
begin

	if _idx &lt;= self.fixedRows or _idx &gt; self.rows then
		return false;
	endif;

	theRow 			:= self.accessRow(_idx);
	theRow.selected := false;
	

	theObj 		:= theRow.itemObject;
	self.row 	:= _idx;
	
/*	dtInterface:= self.getIF_CM_DataTable;
	if dtInterface &lt;&gt; null then
		dtInterface.deselectRow(self,_idx);
	endif;
*/	
	if theObj &lt;&gt; null then
		if ( self.allSelectedObjects.includes(theObj)) then
			self.allSelectedObjects.remove(theObj);
		endif;
	endif;
	// par 22602 - start
	dtInterface:= self.getIF_CM_DataTable;
	if dtInterface &lt;&gt; null then
		dtInterface.deselectRow(self,_idx);
	endif;
	// par 22602 - end
epilog

end;</source>
        <Parameter name="_idx" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="disableReadOnlyColumns" id="2a8c9634-0418-4a22-861d-e507425ad94c">
        <updating/>
        <source>disableReadOnlyColumns() updating;

/*
Purpose:	This method will go through all of this tables entTable rows and for each row
			that is defined as read only (ie input type of none) set the matching column to disabled.
			This is being used in the EDI Operations form where each "entTable row" is really a column
			of possible data when the users goes into edit (update) mode.
			
Date				Who		Reason
19 November 2009	cnwrl1	Initial creation as part of PAR 21009
*/
	
vars
	index			: Integer;
	entTableRow		: EntTableRow;
	
begin
	foreach entTableRow	in self.allTblDataEntRows do : disable_loop
		if entTableRow.inputType &lt;&gt; Table.InputType_None then		// ie not Read Only
			continue disable_loop;
		endif;
		index	:= self.getColumnByRowName( entTableRow.name );
		if index &lt;&gt; null then
			self.accessColumn( index ).enabled	:= false;
		endif;
	endforeach disable_loop;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="disallowColumnShiftUpDown" id="aed7b267-a2dc-44a9-afdc-0a3708f9872d">
        <source>disallowColumnShiftUpDown() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2009	cnwer1	Initial creation

*/

vars

begin
	if self.myForm &lt;&gt; null and 
		self.myForm.name = "YRD_QueueForm" then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayRow" id="2d2a8df9-55b2-4929-8505-714d76f3de61">
        <updating/>
        <source>displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io): String updating;
// ---------------------------------------------------------------------------
// Created:    2025
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13 Mar 2025	navnk30	JIRA 34245: Develop a generic solution to show data in a CM_DataTable using "Pagination"
// 11 Aug 2025	jlizm1		MTN 35316 Pagination - Work Order Complete
// 13 Aug 2025  navsaa30 	MTN 35313 | Pagination - Invoice List
// 25 Aug 2025 	navhl20 	Story MTN-35317: MTN | Pagination - Work Order Operations
// 04 Nov 2025 	navhl20 	Bug MTN-36136: MTN | In Cargo Work Order new screen, for the completed WO the cargos not greyed out in selected cargo items tab
// ---------------------------------------------------------------------------
vars
	theStr, filterText	: String;
	invalid : Boolean;
	frm		: CM_BaseForm;
	allText : HugeStringArray;
begin
	
	on Exception do app.handleDeletedObject(exception, obj, invalid);  // 07/08/2025	navkc1	MTN 35563
	
	//theStr := inheritMethod(table, theSheet, obj, theRow, bcontinue);		//13.03.2025 navnk30 JIRA 34245
	if self.isPaginated() then												//13.03.2025 navnk30 JIRA 34245
		
		// 07/08/2025	navkc1	MTN 35563
		if obj &lt;&gt; null then
			obj.edition();  
		endif;
		
		// 07/08/2025	navkc1	MTN 35563
		if invalid then
			self.removeKeyValForPagination(obj);
			return null;
		endif;
		
		if CM_BaseForm.hasInstance(self.form) then
			frm := self.form.CM_BaseForm;
			if not frm.rowPreprocess(table.CM_DataTable, obj) then
				return null;
			endif;
		endif;
		
		if obj.isKindOf(CM_Object) then													//navsaa30 #35313 13/8/25
			obj.CM_Object.setPaginationCellColour(self, self.allTblDataEntRows, obj,theRow); 
		endif;
		
		theStr := obj.getAttributeStringForDefArray(self.allTblDataEntRows);
		
		 // ### JIRA 35966 08DEC2025 NAVAB1
		 
		if self.myTableFilterFrame &lt;&gt; null then
			filterText := self.myTableFilterFrame.txtFilterBox.text.trimBlanks();
			if filterText &lt;&gt; null then
			
				create allText transient;
				filterText.parseCSV(allText);
				if not self.doesMatchFilter(allText, theStr) then
					return null;
				endif;

			endif;
		endif;
		
		
		if frm &lt;&gt; null then
		//	frm.rowPostprocess(tblData, theRow, obj);  //getDataAndDisplayRowsPaginat already arms the notes - note sure why we need to do this again
			if frm.name = "YRD_WorkOrderOperation" or 									//25.08.2025 navhl20 #35317
			frm.name = "YRD_WorkOrder" then												//04.11.2025 navhl20 #36136
				frm.rowPostprocess(table.CM_DataTable, theRow, obj);  	
			else
				self.setRowColorForPagination(theRow, frm);
			endif;
		endif;
		
		if table.CM_BaseTable.allSelectedObjects.includes(obj) then
			table.accessRow(theRow).selected:=true;
		endif;
		
		return theStr;
	else
		theStr := inheritMethod(table, theSheet, obj, theRow, bcontinue);
	endif;
	
	if theStr &lt;&gt; null then	
		if table.CM_BaseTable.allSelectedObjects.includes(obj) then
			table.accessRow(theRow).selected := true;
		else
			table.accessRow(theRow).selected := false;
		endif;
	endif;
	
	return theStr;	

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayRowsForCollection" id="b0d0b9f4-47d0-481e-9a2d-ebc65587607c">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayRowsForCollection(_collection : Collection; _colour1, _colour2 : Integer; _passport : CM_Passport)updating, clientExecution;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	backColour,
	idx : Integer;
	str : String;
	any : Any;
	obj : CM_Object;
	failedDAC  :CM_DataAccessController;
begin
	if _collection = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null collection');
		return;
	elseif _passport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null passport');
		return;	
	endif;
	
	//self.rows := self.fixedRows; don't clear table as could be adding multiple collections
	
	foreach any in _collection do
		if CM_Object.hasInstance(any.Object) then
			obj := any.CM_Object;
			if (not obj.canUserAccessSelf(null, failedDAC, _passport)) then
				continue;
			endif;
		else
			continue;
		endif;

		str := obj.getAttributeStringForDefArray(self.allTblDataEntRows);
		idx := self.addItemObject(obj, str);
		if idx mod 2 = 0 then
			backColour := _colour1;
		else
			backColour := _colour2;
		endif;			
		self.accessRow(idx).backColor := backColour;

	endforeach;
	
end;</source>
        <Parameter name="_collection" type="Collection"/>
        <Parameter name="_colour1" type="Integer"/>
        <Parameter name="_colour2" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="displayRowsPaginated" id="f9136e43-21f3-465c-9a32-fe2e6866c39b">
        <updating/>
        <source>displayRowsPaginated(_coll : Collection; _form : CM_BaseForm io) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2025	navnk30	JIRA 34245: Develop a generic solution to show data in a CM_DataTable using "Pagination"
9 Jun 2025  jlier1  JIRA 34711 - Need the sorted collection do not copy to array. Also would expect all pre filtering down before passing the collection in. rowPostprocess - is done on display row
					if we do it here it is only the rows that are showing not all the rows. So is done when display each row.
*/

vars
	startTs,
	endTs			: TimeStamp;
begin
	if process.isNavnk30() then
		startTs := app.actualTimeServer();
	endif;
	if not self.isPaginated() then
		return;
	endif;
	
	self.displayCollection(_coll, false, self.myPaginationParams.showHow, self.myPaginationParams.startObj);
	
	if process.isNavnk30() then
		endTs := app.actualTimeServer();
		write "Started = " &amp; startTs.displayWithMilliSeconds__() &amp; ", Ended = " &amp; endTs.displayWithMilliSeconds__() &amp; 
			"Rows = " &amp; _coll.size().String &amp; " Time Taken = " &amp; (endTs - startTs).getMilliseconds.String &amp; "ms. " &amp; " method : " &amp; method.name &amp; " userID : " &amp; app.getMyUserCode();
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="Collection"/>
