    <JadeMethod name="getPreviousLocationBalance" id="72442ace-f8a4-476d-96a7-627d53dfb279">
        <source>getPreviousLocationBalance( _locAct : CMEVT_LocationActivity ):CMEVT_LocationActivity;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	iter : Iterator;
	startObject : CMEVT_LocationActivity;
	locAct : CMEVT_LocationActivity;
	tooOld : TimeStamp;

begin

	if _locAct &lt;&gt; null then
		tooOld := _locAct.dateTime.cnEcAddDays( -1 );
	else
		tooOld := app.actualTimeAppServer.cnEcAddDays( -1 );
	endif;

	iter := self.allLocationActivity.createIterator;
	if _locAct &lt;&gt; null then
		iter.startAtObject( _locAct );
	endif;
	while iter.back( locAct ) do
		if locAct.dateTime &lt; tooOld then
			break;
		endif;
		if _locAct &lt;&gt; null then
			if locAct = _locAct then
				continue;
			endif;
			if locAct.cargoType &lt;&gt; _locAct.cargoType then
				continue;
			endif;
			if locAct.operatorCode &lt;&gt; _locAct.operatorCode then
				continue;
			endif;
		endif;
		if locAct.isLocationBalance then
			return locAct;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_locAct" type="CMEVT_LocationActivity"/>
        <ReturnType type="CMEVT_LocationActivity"/>
    </JadeMethod>
    <JadeMethod name="getProductMinMaxAuditText" id="8c7677b0-d06d-4e48-92b6-4a2d83c0c9b8">
        <source>getProductMinMaxAuditText() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	prodMinMax : CM_TerminalAreaProductMinMax;
	result : String;

begin
	foreach prodMinMax in self.allProductMinMax do
		result := result &amp; prodMinMax.getAuditTextDescription() &amp; Comma &amp; Space;
	endforeach;
	
	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQVWforDate" id="fa340da2-9437-46a8-aafb-34b0efa6bc91">
        <source>getQVWforDate(	_requiredDate 	: Date; 
				_startFromDate	: Date;	
				_closingLevel 	: Boolean; 
				_product 		: CM_Product; 
				_quantity 		: Integer output; 
				_volume 		: Decimal output; 
				_weight 		: Decimal output);
// --------------------------------------------------------------------------------
// Created:		05 December 2006 by cnwdad1
//
// Purpose:		Return Quantity, Volume and Weight for the given date and product
//				at this location. Can select opening or closing levels for the day.
//				Future dates will include projected levels based on auto task
//				adjustments and planned cargo movements.
//
// Parameters:	Refer to the method called for parameter details.
//
// Returns:		The values of the output parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controllerObj	: CM_LocationsController;
	
begin
	if (not self.isStockControlled) then
		return;
	endif;

	foreach controllerObj in self.allLocationsControllers do
		controllerObj.getQVWforDate(_requiredDate,
									_startFromDate,
									_closingLevel,
									_product,
									_quantity,
									_volume,
									_weight);
	endforeach;
end;</source>
        <Parameter name="_requiredDate" type="Date"/>
        <Parameter name="_startFromDate" type="Date"/>
        <Parameter name="_closingLevel" type="Boolean"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_quantity" type="Integer" usage="output"/>
        <Parameter name="_volume" type="Decimal" usage="output"/>
        <Parameter name="_weight" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getQueues" id="56bf85f7-6fe6-4332-8515-60f1e79a2e85">
        <source>getQueues(queueSet : CM_RTQueueSet io);
//Returns the queue(s) associated with this terminal area.
//If we dont have any, then by default we return the MasterQueue.
vars
	term 	: CM_Terminal;
	ta		: CM_TerminalArea;
	queue	: CM_RadioTelemetryQueue;
begin

	// DVB 6th July All queues need to be returned. This is done
	// by terminal.getQueues. The below code was redundant.
	// Important queue evaluation done during getMatchPriority. 

/*	queueSet.clear;
	if queues.size &gt; 0 then
		foreach queue in self.queues do
			if not queueSet.includes(queue) then
				queueSet.add(queue);
			endif;
		endforeach;
	endif;*/
	
	term := self.myTerminal;	
	if self.type = TA_TYPE_RAIL_TRANS then
		//We are a rail transfer area, have a look on our RAIL track
		//We have to find the sucker 1st!
		foreach ta in term.allTerminalAreas do
			if ta.isKindOf(CM_Rail) then
				if ta.CM_Rail.myTransferArea = self then
					ta.getQueues(queueSet);
					if queueSet.size &gt; 0 then
						return;
					endif;
					break;	//Get terminal's Queues
				endif;
			endif;
		endforeach;
	endif;

	//----------------
	//No Queues on the terminal area, Ask Terminal for global Queues
	//----------------
	term.getQueues(queueSet);
end;</source>
        <Parameter name="queueSet" type="CM_RTQueueSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getReeferWalkIncluding" id="81f63d11-f3d4-4c22-852b-a1ea2b2517ff">
        <source>getReeferWalkIncluding( _lc : CM_LocationsController; _tier : Integer ):CM_ReeferBlock;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	iterBlock : Iterator;
	reeferBlock : CM_ReeferBlock;

begin

	iterBlock := self.allReeferBlocks.createIterator;
	while iterBlock.next( reeferBlock ) do
		if reeferBlock.hasReeferWalkIncluding( _lc, _tier ) then
			return reeferBlock;
		endif;
	endwhile;
	
	return null;

epilog

	delete iterBlock;

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_tier" type="Integer"/>
        <ReturnType type="CM_ReeferBlock"/>
    </JadeMethod>
