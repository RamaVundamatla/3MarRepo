    <JadeMethod name="initializeMe" id="55b39aa7-15dd-4082-864a-ef5f4c3a57c2">
        <updating/>
        <source>initializeMe(	pAllAttachmentsArray:StringArray;
				pBccList:String;
				pCcList:String;
				pContentType:String;
				pEncodingType:String;
				pMessageBody:String;
				pMessageHeader:String;
				pMyEmailBaseData:CnEcEmailBaseData;
				pSentTime:TimeStamp;
				pSentTo:String)  : String updating; 

// This method created by JediMethodGenerator at 15:53:23 on 14 March 2001

vars
	errorMessage	: String;
	attach			: String;

begin
	// Validation

	errorMessage := self.validateMe(
				pAllAttachmentsArray,
				pBccList,
				pCcList,
				pContentType,
				pEncodingType,
				pMessageBody,
				pMessageHeader,
				pMyEmailBaseData,
				pSentTime,
				pSentTo);  

	if errorMessage &lt;&gt; null then
		return errorMessage;
	endif;

	// Attributes (Non Keys)
	self.bccList :=			pBccList;
	self.ccList :=			pCcList;
	self.contentType :=		pContentType;
	self.encodingType :=	pEncodingType;
	self.messageBody := 	pMessageBody;
	self.messageHeader := 	pMessageHeader;
	
	if pAllAttachmentsArray.size() &gt; 0 then
		foreach attach in pAllAttachmentsArray do
			self.allAttachmentsArray.add(attach);
		endforeach;
	endif;

	// Attributes (Keys)

	self.sentTime	:= 	pSentTime;
	self.sentTo		:= 	pSentTo;

	// Singleton References

	self.myEmailBaseData := 	pMyEmailBaseData;
epilog
	return errorMessage;
end;</source>
        <Parameter name="pAllAttachmentsArray" type="StringArray"/>
        <Parameter name="pBccList" type="String"/>
        <Parameter name="pCcList" type="String"/>
        <Parameter name="pContentType" type="String"/>
        <Parameter name="pEncodingType" type="String"/>
        <Parameter name="pMessageBody" type="String"/>
        <Parameter name="pMessageHeader" type="String"/>
        <Parameter name="pMyEmailBaseData" type="CnEcEmailBaseData"/>
        <Parameter name="pSentTime" type="TimeStamp"/>
        <Parameter name="pSentTo" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="sendMeFromCode" id="6b8a0a45-f95a-4635-a3ff-fe8017c93b88">
        <source>sendMeFromCode(pReturnAddress : String);

vars
	theKarmaControl		: CnKarmaCntrl;
	theSMTP				: CnSmtpConnection;
	theAttachment		: CnAttachment;
	arrayPointer		: Integer;
	
begin
	create theSMTP;										// Create SMTP Control.
	theSMTP.myCnKarmaCntrl	:=	theKarmaControl;		// Create reference to CnKarmaCntrl	.

	theSMTP.clientName		:=	self.myEmailBaseData.emailClientName;		
	theSMTP.name			:=	self.myEmailBaseData.emailServerName;		
	theSMTP.sendFrom		:=	pReturnAddress;	
	theSMTP.sendTo			:=	self.sentTo.trimBlanks();
	theSMTP.cc				:=	self.ccList.trimBlanks();
	theSMTP.bcc				:=	self.bccList.trimBlanks();
	theSMTP.subject			:=	self.messageHeader;
	theSMTP.message			:=	self.messageBody;
	theSMTP.contentType		:=	self.contentType;
	theSMTP.encodingType	:=	self.encodingType;
	theSMTP.isUserEncoded	:=	(
								(self.encodingType &lt;&gt; "")
								and (self.encodingType &lt;&gt; CnSmtpConnection.None)
								and (self.encodingType &lt;&gt; CnSmtpConnection.Base64)
								);
	
	// get any attachments.
	
	if self.allAttachmentsArray.size() &gt; 0 then
		foreach arrayPointer in 1 to self.allAttachmentsArray.size() do
			create theAttachment;
			theAttachment.fileName			:=	self.allAttachmentsArray[arrayPointer];
			theAttachment.mySmtpConnection	:=	theSMTP;
		endforeach;
	endif;

	theSMTP.send();			// Send it .
end;</source>
        <Parameter name="pReturnAddress" type="String"/>
    </JadeMethod>
    <JadeMethod name="sendMeFromForm" id="7e9ba4e0-219b-41c2-87b0-7e65dba0b406">
        <updating/>
        <source>sendMeFromForm(pForm:CnEcEmailForm io) updating;

vars
	theSMTP			: CnSmtpConnection;
	theAttachment	: CnAttachment;
	arrayPointer	: Integer;
	
begin
	create theSMTP;					// Create SMTP connection.
	theSMTP.myCnKarmaCntrl	:=	app.myCnKarmaCntrl;

	if pForm &lt;&gt; null then
		pForm.beginNotification(theSMTP, CnSmtpConnection.Completion_Event_Type, Response_Cancel, 0);
		on Exception do pForm.xHandlerEmail(exception);
	else
		on Exception do self.xHandlerEmail(exception);			
	endif;
	
	theSMTP.clientName		:=	self.myEmailBaseData.emailClientName;
	theSMTP.name			:=	self.myEmailBaseData.emailServerName;
	theSMTP.sendFrom		:=	self.myEmailBaseData.emailReturnAddress;
	theSMTP.sendTo			:=	self.sentTo.trimBlanks();
	theSMTP.cc				:=	self.ccList.trimBlanks();
	theSMTP.bcc				:=	self.bccList.trimBlanks();
	theSMTP.subject			:=	self.messageHeader;
	theSMTP.message			:=	self.messageBody;
	theSMTP.contentType		:=	self.contentType;
	theSMTP.encodingType	:=	self.encodingType;
	theSMTP.isUserEncoded	:=	(
								(self.encodingType &lt;&gt; "")
								and (self.encodingType &lt;&gt; CnSmtpConnection.None)
								and (self.encodingType &lt;&gt; CnSmtpConnection.Base64)
								);
	
	// Get any attachments.
	
	if self.allAttachmentsArray.size() &gt; 0 then
		foreach arrayPointer in 1 to self.allAttachmentsArray.size() do
			create theAttachment;
			theAttachment.fileName			:=	self.allAttachmentsArray[arrayPointer];
			theAttachment.mySmtpConnection	:=	theSMTP;
		endforeach;
	endif;

	theSMTP.send(); 		// Send it.
end;</source>
        <Parameter name="pForm" type="CnEcEmailForm" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="13318ddd-f5cf-4a65-b887-ee238fb12daa">
        <updating/>
        <source>updateMe(	pAllAttachmentsArray:StringArray;
			pBccList:String;
			pCcList:String;
			pContentType:String;
			pEncodingType:String;
			pMessageBody:String;
			pMessageHeader:String;
			pMyEmailBaseData:CnEcEmailBaseData;
			pSentTime:TimeStamp;
			pSentTo:String)  : String updating; 

// This method created by JediMethodGenerator at 15:53:23 on 14 March 2001
// Please add any validation required then delete this comment.

vars
	errorMessage	: String;
	attach : String;

begin
	// Validation

	errorMessage := self.validateMe(
				pAllAttachmentsArray,
				pBccList,
				pCcList,
				pContentType,
				pEncodingType,
				pMessageBody,
				pMessageHeader,
				pMyEmailBaseData,
				pSentTime,
				pSentTo);  

	if errorMessage &lt;&gt; null then
		return errorMessage;
	endif;

	// Attributes (Non Keys)

	if self.bccList &lt;&gt; pBccList then
		self.bccList :=			pBccList;
	endif;
	
	if self.ccList &lt;&gt; pCcList then
		self.ccList :=			pCcList;
	endif;
	
	if self.contentType &lt;&gt; pContentType then
		self.contentType :=		pContentType;
	endif;
	
	if self.encodingType &lt;&gt; pEncodingType then
		self.encodingType :=	pEncodingType;
	endif;
	
	if self.messageBody &lt;&gt; pMessageBody then
		self.messageBody := 	pMessageBody;
	endif;
	
	if self.messageHeader &lt;&gt; pMessageHeader then
		self.messageHeader := 	pMessageHeader;
	endif;
	
	self.allAttachmentsArray.clear();
	
	if pAllAttachmentsArray.size() &gt; 0 then
		foreach attach in pAllAttachmentsArray do
			self.allAttachmentsArray.add(attach);
		endforeach;
	endif;

	// Attributes (Keys)

	if self.sentTime &lt;&gt; pSentTime then
		self.sentTime := 	pSentTime;
	endif;
	
	if self.sentTo &lt;&gt; pSentTo then
		self.sentTo := 	pSentTo;
	endif;

	// Singleton References

	if self.myEmailBaseData &lt;&gt; pMyEmailBaseData then
		self.myEmailBaseData := 	pMyEmailBaseData;
	endif;
epilog
	return errorMessage;
end;</source>
        <Parameter name="pAllAttachmentsArray" type="StringArray"/>
        <Parameter name="pBccList" type="String"/>
        <Parameter name="pCcList" type="String"/>
        <Parameter name="pContentType" type="String"/>
        <Parameter name="pEncodingType" type="String"/>
        <Parameter name="pMessageBody" type="String"/>
        <Parameter name="pMessageHeader" type="String"/>
        <Parameter name="pMyEmailBaseData" type="CnEcEmailBaseData"/>
        <Parameter name="pSentTime" type="TimeStamp"/>
        <Parameter name="pSentTo" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="2a247eec-033b-40bd-9bb6-27024eddb18b">
        <updating/>
        <source>validateMe(		pAllAttachmentsArray:StringArray;
				pBccList:String;
				pCcList:String;
				pContentType:String;
				pEncodingType:String;
				pMessageBody:String;
				pMessageHeader:String;
				pMyEmailBaseData:CnEcEmailBaseData;
				pSentTime:TimeStamp;
				pSentTo:String)  : String updating, protected;

// This method created by JediMethodGenerator at 15:53:23 on 14 March 2001
// Please add any validation required then delete this comment.

vars
	errorMessage	: String;

begin
	// Validation

	if pMessageBody = null then
		errorMessage := errorMessage &amp; 'Emails must have some content in the message body.  ';
	endif;
	if pMessageHeader = null then
		errorMessage := errorMessage &amp; 'Emails must have a heading/subject.  ';
	endif;
	if pMyEmailBaseData = null then
		errorMessage := errorMessage &amp; "Email not associated with an 'EmailBaseData' Object.  ";
	endif;
	if pSentTime = null then
		errorMessage := errorMessage &amp; 'Sent time is null.  ';
	endif;
	if pSentTo = null then
		errorMessage := errorMessage &amp; 'Emails must have an addressee.  ';
	endif;
epilog
	return errorMessage;
end;</source>
        <access>protected</access>
