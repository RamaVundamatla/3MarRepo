    <JadeMethod name="valBay" id="769bb90c-1f6c-461e-bb7f-260490f028f0">
        <source>valBay(_existingBayDefn,_proxyBayDefn:CM_Bay);
// ---------------------------------------------------------------------------
// Created:     16 June 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNull(_proxyBayDefn, 'BayDefn Proxy');
	self.raiseExceptionIfNull(_existingBayDefn, "BayDefn Existing");
	_proxyBayDefn.raiseExceptionIfNotProxy(method);

	_proxyBayDefn.validateForUpdate();
	

epilog
	
end;</source>
        <Parameter name="_existingBayDefn" type="CM_Bay"/>
        <Parameter name="_proxyBayDefn" type="CM_Bay"/>
    </JadeMethod>
