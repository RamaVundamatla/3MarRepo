    <JadeMethod name="doesVesselNameExist" id="9bbf5f2b-0412-4cfb-921c-68a6df035da3">
        <source>doesVesselNameExist(_vesselName: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2024	naviv1	Initial creation - TFS 63310 - EUP | FR 54871 Search EDI Message on Vessel Behaviour Not Clear

*/

vars
	ediFile			: CM_EDIFile;
	fileType		: CM_EDIFileType;
	message			: String;
begin

	if self.myEDIFile &lt;&gt; null then 
		ediFile := self.myEDIFile; 
	endif;
	
	if ediFile = null then
		return false;
	endif;

	fileType := ediFile.myEDIFileType;

	message := ediFile.getOriginalFileDataString();
	
	if message = null and fileType = null then
		message := ediFile.getRawDataString();
	endif;
	
	if message &lt;&gt; null then
		return message.toUpper.cnContains(_vesselName.toUpper);
	endif;
	
	return false;
epilog
end;</source>
        <Parameter name="_vesselName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
