    <JadeMethod name="getDLRDischargeRemarks" id="e025c946-c8ae-4101-9174-2dcc315fdbcc">
        <source>getDLRDischargeRemarks(): String protected;
//----------------------------------------------------------------
//	Created:	07 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	strJobNum,
	strRemarks		: String;
	jobNums			: StringArray;
	wle				: CM_WorkListEntry;
	ti				: CM_TrackedItem;
begin
	
	create jobNums transient;
	
	foreach wle in self.workListEntries do
		ti := wle.myTrackedItem;	
		if ti = null then
			continue;
		endif;
		if not ti.isRehandle then // PAR 11170
			continue;
		endif;
		
		strJobNum := ti.getShipReceiveJobsString();
		if strJobNum &lt;&gt; null 
		and (not jobNums.includes(strJobNum)) then
			jobNums.add(strJobNum);	
		endif;
		
	endforeach;
		
	if jobNums.isNotEmpty then
		strRemarks := "Discharge Job: ";
		foreach strJobNum in jobNums do
			strRemarks := strRemarks &amp; " " &amp; strJobNum &amp; ",";
		endforeach;
		strRemarks := strRemarks[1:(strRemarks.length-1)];
	endif;
	
	return strRemarks;

epilog
	delete jobNums;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
