    <JadeMethod name="getAuditText" id="df93d57b-ca1d-40e6-8996-d95b7200e011">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/

vars
	txt,
	tmpInvLineDesc,tmpStr	: String;
	
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	

		
	if self.myInvoiceLineDesc &lt;&gt; null then
		tmpStr :=self.myInvoiceLineDesc.narration&amp;" "&amp; tmpStr ;
		txt := txt &amp; app.getErrorString(Invoice_line) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;


	tmpStr := null;
	if self.myBank &lt;&gt; null then
		tmpStr :=self.myBank.code&amp;" "&amp; tmpStr ;
		txt := txt &amp; app.getErrorString(CM_Business_Unit) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	

	
	return txt;
	

epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="10bdadfb-3c97-4944-9076-dbb440632548">
        <source>getDescription(_len : Integer) : String;

vars
	tmp : String;
begin
	tmp := self.getObjectDesc(self.myParentMappingObject) &amp; " and Invoice Line '" &amp; self.getLineTypeString() &amp; "'";
			
	if _len &gt;= 2 then
		tmp := tmp  &amp; " in combination with " &amp; self.getObjectDesc(self.myCombinationMappingObject);
	endif;
	if _len = 3 then
		tmp := tmp &amp;  " &gt;&gt; "	&amp; self.myDebtorType.description; // app.getInvoiceChargeTypeString(self.chargeByOpCon); CP CCMS 1047 cnwgb1
	endif;
	
	return tmp;
end;</source>
        <Parameter name="_len" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="a13d832f-399f-46fd-a75d-7486de20cab5">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;

begin
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Invoice Line Type", DC_Label, 1, self);
	block.addNewItem(self.myInvoiceLineDesc.narration, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Parent", DC_Label, 1, self);
	block.addNewItem(self.getObjectDesc(self.myParentMappingObject), DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Combination", DC_Label, 1, self);
	block.addNewItem(self.getObjectDesc(self.myCombinationMappingObject), DC_Data, 1, self);

	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getLineTypeString" id="cba09931-1df9-4d1c-be1e-22b2c04563be">
        <source>getLineTypeString()  : String;

vars

begin
	if self.myInvoiceLineDesc &lt;&gt; null then
		return self.myInvoiceLineDesc.narration;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjectDesc" id="88f2ecf5-a764-4253-8c10-11b9b9f746a6">
        <source>getObjectDesc(_object : CM_Object) : String;
// ---------------------------------------------------------------------------
// Created:		19 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	con : CM_ConsigneeConsignor;
begin
	if _object = null then
		return null;
	endif;
	
	if _object.isKindOf(CM_Operator) then
		return "Operator '" &amp; _object.CM_Operator.description &amp; "'";
	elseif _object.isKindOf(CM_ConsigneeConsignor) then
		con := _object.CM_ConsigneeConsignor;
		if con.isFreightFwdr then
			return "Freight Forwarder '" &amp; con.description &amp; "'";
		elseif con.isConsignee then
			return "Consignee '" &amp; con.description &amp; "'";
		elseif con.isConsignor then
			return "Consignor '" &amp; con.description &amp; "'";
		endif;
	elseif _object.isKindOf(CM_CustomsAgent) then
		return "Customs Agent '" &amp; _object.CM_CustomsAgent.name &amp; "'";
	elseif _object.isKindOf(CM_Bank) then
		return "Business Unit '" &amp; _object.CM_Bank.code &amp; "'";
	elseif _object.isKindOf(CM_Debtor) then  
		return "User Defined Debtor Types";
	elseif _object.isKindOf(CM_DebtorType) then  //cp ccms 1047 Par 16666 cnwgb1 18 April 2008
		return _object.CM_DebtorType.description;
	endif;
	
end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjectTypeString" id="bf6941e1-ee82-425f-99a8-f365708ac193">
        <source>getObjectTypeString(_object : CM_Object) : String;
// ---------------------------------------------------------------------------
// Created:		19 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	con : CM_ConsigneeConsignor;
begin
	if _object = null then
		return null;
	endif;
	
	if _object.isKindOf(CM_Operator) then
		return "Operator";
	elseif _object.isKindOf(CM_ConsigneeConsignor) then
		con := _object.CM_ConsigneeConsignor;
		if con.isFreightFwdr then
			return "Freight Forwarder";
		elseif con.isConsignee then
			return "Consignee";
		elseif con.isConsignor then
			return "Consignor";
		endif;
	elseif _object.isKindOf(CM_CustomsAgent) then
		return "Customs Agent";
	elseif _object.isKindOf(CM_Bank) then
		return "Business Unit";
	elseif _object.isKindOf(CM_Debtor) then  
		return "User Defined Debtor Types";
	elseif _object.isKindOf(CM_DebtorType) then  //cp ccms 1047 Par 16666 cnwgb1 18 April 2008
		return _object.CM_DebtorType.description;
	endif;
	
end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="eb9960f2-9815-43ac-ba2c-d5a9f5ebf551">
        <updating/>
        <source>setForCreate(_pxyMe : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		19 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.myCombinationMappingObject := _pxyMe.myCombinationMappingObject;
	self.myParentMappingObject := _pxyMe.myParentMappingObject;
	self.myInvoiceLineDesc := _pxyMe.myInvoiceLineDesc;
	self.chargeByOpCon := _pxyMe.chargeByOpCon;
	self.myDebtorType := _pxyMe.myDebtorType; //cp ccms 1047 Par 16666 cnwgb1 18 April 2008
	self.chargeTypeCode := _pxyMe.chargeTypeCode; 
	
	self.myBank := _pxyMe.myBank;
end;</source>
        <Parameter name="_pxyMe" type="SelfType"/>
    </JadeMethod>
