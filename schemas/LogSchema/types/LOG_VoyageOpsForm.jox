    <JadeMethod name="tblAllocDetail_queryRowColChg" id="4e458ee2-e369-49d5-b74e-e3eca846a954">
        <controlMethod name="CM_DataTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAllocDetail_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
//--------------------------------------------------------------
//Created: 24 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
/*	colOrdered, 
	rowAvail,
	volAllocated	: Decimal[16,4];
	idx 			: Integer;*/
begin
	return self.tblAllocDetailQueryRowColChg(table);
	/*if table.row &gt; table.fixedRows and table.column &gt; 4 then
		idx := table.columns;
		while idx &gt; table.fixedColumns do
			volAllocated := (volAllocated + table.accessCell(table.row, idx).text.Decimal);
			idx := (idx-1);
		endwhile;
		rowAvail := table.accessCell(table.row, 3).text.Decimal;
		table.accessCell(table.row, 4).text := (rowAvail - volAllocated).jasVolumeString;
		idx := table.rows;
		volAllocated := 0;
		while idx &gt; table.fixedRows do
			volAllocated := (volAllocated + table.accessCell(idx, table.column).text.Decimal);
			idx := (idx-1);
		endwhile;
		colOrdered := table.accessCell(2, table.column).text.Decimal;
		table.accessCell(3, table.column).text := (colOrdered - volAllocated).jasVolumeString;								
	endif;

	return true;*/
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
