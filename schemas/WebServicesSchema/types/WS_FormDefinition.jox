    <JadeMethod name="buildAttachmentsFormDef" id="c3ecef9d-7f87-448d-ac71-41d2fca420d3">
        <updating/>
        <source>buildAttachmentsFormDef() updating;

/*

Purpose:			Build the form definition for the attachments form

Parameters:			None

Return Value:		None


Date		Who		Reason
21 Jan 2009	cnwdz2	PAR #17554 

*/

constants

vars	
	entTableGroup	: EntTableGroup;
	resp			: WS_FormDefinitionResponse;
	fieldDef		: WS_FieldDefinition;
	rowName			: String;
	mainRows	: StringArray;
	entTableRow		: EntTableRow;
begin
	self.proxyClassName			:= WS_AttachmentUpdateRequest.name;	
	self.proxySearchClassName	:= WS_Attachment.name; 	

	create mainRows transient;
	mainRows.add(ETRow_CargoType); 	
	mainRows.add(ETRow_IdTextBox); 
	mainRows.add(ETRow_IsoType);
	mainRows.add(ETRow_ProductType);
	mainRows.add(ETRow_WeightTotal);	
	
	//consolidate all the rows we are interested in - for this form they are spread throughout three table definitions
	entTableGroup	:= CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_GateReceivals);
	
	foreach rowName in mainRows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);
		if entTableRow &lt;&gt; null then 
			fieldDef := self.loadFieldFromRow(entTableRow);	
		endif;
	endforeach;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_WeightTotal);
	fieldDef.controlType := ControlType_NumericField;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_IsoType);
	fieldDef.dataReloadField := ETRow_CargoType;
	fieldDef.dataStore := JMTUserInterfaceService::getISOTypesForCargoType.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_ProductType);
	fieldDef.dataReloadField := ETRow_CargoType;
	fieldDef.dataStore := JMTUserInterfaceService::getCargoSubtypesForCargoType.name;
	
epilog
	delete mainRows;	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildBookRefItemSelectFormDef" id="7934621a-f436-42ca-a13b-e3556f437484">
        <updating/>
        <source>buildBookRefItemSelectFormDef() updating;

/*

Purpose:			Build the form definition for the booking reference item select form

Parameters:			None

Return Value:		None


Date		Who		Reason
12 Jan 2009	cnwdz2	PAR #17554 

*/

constants
	
vars	
	entTableGroup	: EntTableGroup;
	resp			: WS_FormDefinitionResponse;
	fieldDef		: WS_FieldDefinition;
	rowName			: String;
	readOnlyRows	: StringArray;
	entTableRow		: EntTableRow;
begin
	//self.proxyClassName			:= WS_PreNoteUpdateRequest.name;	
	self.proxySearchClassName	:= WS_PrenoteFromBookRef.name; 	
	
	create readOnlyRows transient;
	readOnlyRows.add(ETRow_BookingReference); 
	readOnlyRows.add(ETRow_MyBookingRefItem);
	readOnlyRows.add(ETRow_OperatorCode);
	readOnlyRows.add(ETRow_VoyageCode);
	readOnlyRows.add(ETRow_CreationDateTime);
	
	//consolidate all the rows we are interested in - for this form they are spread throughout three table definitions
	entTableGroup	:= CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_GateReceivals);
	
	foreach rowName in readOnlyRows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);
		if entTableRow &lt;&gt; null then 
			fieldDef := self.loadFieldFromRow(entTableRow);	
			fieldDef.readOnly	:= true;
		endif;
	endforeach;
	
epilog
	delete readOnlyRows;	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildCargoEnquiryFormDef" id="f12b80ee-5e3a-46cb-a415-a9286949e87f">
        <updating/>
        <source>buildCargoEnquiryFormDef() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27/08/2008	cnwkao1	Initial creation
11/02/2009 	cnwdz2 	updated according to RIA.doc
14/06/2013	cnwdap1	PAR #31800 extra fields for cargo enquiry
24/09/2103	cnwdap1	PAR #32215 CCMS DPH 2290 New Car Attributes
28/07/2015	cnwdap1	PAR #36682 Added Expiry Date to reefer section
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
*/
constants
	Main_Group_Desc			: String = "Main Details";
	Main_Group_Key			: String = "main";
	
	Voyage_Group_Desc		: String = "Voyage Details";
	Voyage_Group_Key		: String = "voyage";
	
	Status_Group_Desc			: String = "Status Details";				
	Status_Group_Key			: String = "status";
	
	/*Reefer_Chk_Group_Desc	: String = "Is Reefer";
	Reefer_Chk_Group_Key	: String = "isReefer";*/
	
	Reefer_Group_Desc		: String = "Reefer Details";
	Reefer_Group_Key		: String = "reefer";
	
	Dimension_Group_Desc	: String = "Dimension Details";			// PAR #31800
	Dimension_Group_Key		: String = "dimensions";				// PAR #31800
	
	Vehicle_Group_Desc		: String = "Vehicle Details";			// PAR #32215
	Vehicle_Group_Key		: String = "vehicle";					// PAR #32215
vars	
	entTableGroup	: EntTableGroup;
	entTableRow		: EntTableRow;
	resp			: WS_FormDefinitionResponse;
	mainRows		: StringArray;
	//reefVisibleRows	: StringArray;
	reeferRows		: StringArray;
	fieldDef		: WS_FieldDefinition;
	rowName			: String;
	voyageRows		: StringArray;
	statusRows      : StringArray;
	dimensionRows	: StringArray;						// PAR #31800
	vehicleRows		: StringArray;						// PAR #32215
begin
	self.proxySearchClassName	:= WS_TrackedItem.name; 
	
	create mainRows transient;
	mainRows.add(ETRow_BookingReference);
	mainRows.add(ETRow_CargoType);
	mainRows.add(ETRow_MyProduct);				//cnwmc5 - 30 April 2014 - PAR 33988
	mainRows.add(ETRow_IsoType); 
	mainRows.add(ETRow_TrailerType);			//cnwmc5 - 30 April 2014 - PAR 33988
	mainRows.add(ETRow_Id); 
	mainRows.add(ETRow_AlternativeId); 
	mainRows.add(ETRow_TotalWeight);			//+cnwml2 MSL CCMS 1017
	
	// cnwmc5 - 1 June 2016 - TFS 2030
	mainRows.add(ETRow_IsWeightCertified);
	mainRows.add(ETRow_WeightCertifiedBy);
	mainRows.add(ETRow_WeightCertifiedPerson);
	
	mainRows.add(ETRow_TotalVolume);			//cnwmc5 - 23 April 2014 - PAR 33988
	mainRows.add(ETRow_TotalQuantity);			//cnwmc5 - 23 April 2014 - PAR 33988
	mainRows.add(ETRow_State);										// PAR #31800
	mainRows.add(ETRow_Colour);										// PAR #31800
	mainRows.add(ETRow_Consignor);									// PAR #31800
	mainRows.add(ETRow_ItemDesc);									// PAR #31800
	mainRows.add(ETRow_Remarks);									// PAR #31800
	mainRows.add(ETRow_Parent);										// PAR #31800
	if app.isSubTerminalsOn(app.myPassport.myTerminal) then
		mainRows.add(ETRow_MySubTerminal);
	endif;

	fieldDef := self.buildGroupHeader(Main_Group_Key, null, Main_Group_Desc); //hold above entries
	fieldDef.showTableColumn := Visibility_Unavailable;
	
	create voyageRows transient;
	voyageRows.add(ETRow_ImexStatus);
	voyageRows.add(ETRow_MyVoyage);
	voyageRows.add(ETRow_OperatorCode);
	voyageRows.add(ETRow_DischargePort); 
	voyageRows.add(ETRow_ReceivedDT);
	voyageRows.add(ETRow_FreightForwarderCode);

	fieldDef := self.buildGroupHeader(Voyage_Group_Key, null, Voyage_Group_Desc); //hold above entries
	fieldDef.showTableColumn := Visibility_Unavailable;
	
	create statusRows transient;
	statusRows.add(ETRow_IsClean);
	statusRows.add(ETRow_Damaged);
	statusRows.add(ETRow_AvailabilityGrade);
	statusRows.add(ETRow_AllStops);
	statusRows.add(ETRow_ShowToDoTasks);
	statusRows.add(ETRow_ImportReleasePIN);
	statusRows.add(ETRow_ExportReleaseNumber);
	statusRows.add(ETRow_CustomExportEntryNumber);	
	statusRows.add(ETRow_CustomExportStop);
	//statusRows.add(ETRow_MyProduct);								//cnwmc5 - 30 April 2014 - PAR 33988
	statusRows.add(ETRow_AllTIHazards);								// PAR #31800
	statusRows.add(ETRow_SealNum);									// PAR #31800
	statusRows.add(ETRow_SealNumCustoms);							// PAR #31800
	statusRows.add(ETRow_SealNumShippers);							// PAR #31800
	statusRows.add(ETRow_SealNumVent);								// PAR #31800
	statusRows.add(ETRow_SealNumTerminalOperator);
	statusRows.add(ETRow_SealNumUnknown);
	
	fieldDef := self.buildGroupHeader(Status_Group_Key, null, Status_Group_Desc); //hold above entries
	fieldDef.showTableColumn := Visibility_Unavailable;
	
	create reeferRows transient;
	reeferRows.add(ETRow_IsReefer);
	reeferRows.add(ETRow_PreTripDT);
	reeferRows.add(ETRow_Temperature);
	reeferRows.add(ETRow_IsControlledAtmosphere);
	reeferRows.add(ETRow_Oxygen);
	reeferRows.add(ETRow_CarbonDioxide);
	reeferRows.add(ETRow_Ventilation);
	reeferRows.add(ETRow_Humidity);
	reeferRows.add(ETRow_CurtainsIn);
	//+ cnwmd1 CCMS 1871 Start
	reeferRows.add(ETRow_PackTempC);
	reeferRows.add(ETRow_PackTempF);
	reeferRows.add(ETRow_PackDate);
	reeferRows.add(ETRow_PackTime);
	reeferRows.add(ETRow_AllowableTimeOffPower);
	//+ cnwmd1 CCMS 1871 End
	reeferRows.add(ETRow_ExpiryDate);					// PAR #36682

	fieldDef := self.buildGroupHeader(Reefer_Group_Key, null, Reefer_Group_Desc);
	fieldDef.showTableColumn := Visibility_Unavailable;
	
	create dimensionRows transient;														// PAR #31800
	dimensionRows.add(ETRow_Length);													// PAR #31800
	dimensionRows.add(ETRow_Width);														// PAR #31800
	dimensionRows.add(ETRow_Height);													// PAR #31800
	//dimensionRows.add(ETRow_Volume);													// PAR #31800		//cnwmc5 - 23 April 2014 - PAR 33988
	
	fieldDef := self.buildGroupHeader(Dimension_Group_Key, null, Dimension_Group_Desc);	// PAR #31800
	fieldDef.showTableColumn := Visibility_Unavailable;									// PAR #31800
	
	create vehicleRows transient;														// PAR #32215
	vehicleRows.add(ETRow_Make);														// PAR #32215
	vehicleRows.add(ETRow_Model);														// PAR #32215
	vehicleRows.add(ETRow_VehicleType);													// PAR #32215
	vehicleRows.add(ETRow_Year);														// PAR #32215
	vehicleRows.add(ETRow_TrackingNumber1);												// PAR #32215
	vehicleRows.add(ETRow_TrackingNumber2);												// PAR #32215
	vehicleRows.add(ETRow_DocsReceived);												// PAR #32215
	vehicleRows.add(ETRow_DocsSent);													// PAR #32215
	vehicleRows.add(ETRow_DocsCleared);													// PAR #32215
	vehicleRows.add(ETRow_DocsReturned);												// PAR #32215
	vehicleRows.add(ETRow_IsSelfPropelled);												// PAR #32215	
	vehicleRows.add(ETRow_Doors);														// PAR #32215
	vehicleRows.add(ETRow_NewVehicle);													// PAR #32215
																						// PAR #32215
	fieldDef := self.buildGroupHeader(Vehicle_Group_Key, null, Vehicle_Group_Desc);		// PAR #32215
	fieldDef.showTableColumn := Visibility_Unavailable;									// PAR #32215
	
	//get the applicable group
	entTableGroup := CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_TrackedItemDetails);
	
	//load each of the fields in order
	foreach rowName in mainRows do 
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);				
		if entTableRow &lt;&gt; null then //the trouble is that the main rows are included in all three tableDefs
			fieldDef := self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Main_Group_Key;
			fieldDef.readOnly := true;
		endif;
	endforeach;
	
	foreach rowName in voyageRows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);				
		if entTableRow &lt;&gt; null then 
			fieldDef := self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Voyage_Group_Key;
			fieldDef.readOnly := true;
		endif;
	endforeach;
	
	foreach rowName in statusRows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);				
		if entTableRow &lt;&gt; null then 
			fieldDef := self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Status_Group_Key;
			fieldDef.readOnly := true;
		endif;
	endforeach;

	foreach rowName in reeferRows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);			
		fieldDef := self.loadFieldFromRow(entTableRow);
		fieldDef.parent := Reefer_Group_Key;	
		fieldDef.readOnly := true;
	endforeach;

	foreach rowName in dimensionRows do													// PAR #31800
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);			// PAR #31800
		fieldDef := self.loadFieldFromRow(entTableRow);									// PAR #31800
		fieldDef.parent := Dimension_Group_Key;											// PAR #31800
		fieldDef.readOnly := true;														// PAR #31800
	endforeach;																			// PAR #31800
	
	foreach rowName in vehicleRows do													// PAR #32215
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);			// PAR #32215
		fieldDef := self.loadFieldFromRow(entTableRow);									// PAR #32215
		fieldDef.parent := Vehicle_Group_Key;											// PAR #32215
		fieldDef.readOnly := true;														// PAR #32215
	endforeach;																			// PAR #32215

	//lastly remap the field names to the proxy property names
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Id);
	fieldDef.key := WS_TrackedItem::idTextBox.name;
	fieldDef.isUppercaseText := true;
	
	//03 may 2013	NDL	Par 31506
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_AlternativeId);
	fieldDef.isUppercaseText := true;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_BookingReference);
	fieldDef.isUppercaseText := true;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_MyVoyage);
	fieldDef.key := WS_TrackedItem::voyageCode.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_ImexStatus);
	fieldDef.key := WS_TrackedItem::imexStatusString.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_TotalWeight);					//+cnwml2 MSL CCMS 1017
	fieldDef.key := WS_TrackedItem::weightTotal.name;
	if not app.getMyUser.canDo(app.getMyTerminalDO_NOT_USE, PmAdmWeightOverride) then
		fieldDef.readOnly := true;	
	endif;
	
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FreightForwarderCode);
	fieldDef.key := WS_TrackedItem::freightForwarder.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_ShowToDoTasks);
	fieldDef.key := WS_TrackedItem::toDoTasks.name;
	fieldDef.controlType := ControlType_MultiTextBox;	//cnwmc5 - PAR 32753
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_AllStops);
	fieldDef.key := WS_TrackedItem::stopsDescription.name;
	fieldDef.controlType := ControlType_MultiTextBox;	//cnwmc5 - PAR 32753
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Temperature);
	fieldDef.key := WS_TrackedItem::carriageTempC.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Humidity);  //par 15301
	fieldDef.key := WS_TrackedItem::humidity.name;
	
	//cnwmc5 - PAR 32206
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_AllTIHazards);
	fieldDef.controlType	:= self.ControlType_Custom_GridPanel;
	fieldDef.storeDescriptionField	:= WS_TIHazard::code.name;		//cnwmc5 - 16 July 2015 - PAR 36421
	fieldDef.storeIdField	:= WS_TIHazard::code.name;				//cnwmc5 - 16 July 2015 - PAR 36421
	
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_IsClean);	//cnwmc5 - PAR 32680
	fieldDef.controlType	:= self.ControlType_CheckBox;			//cnwmc5 - PAR 32680
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Damaged);	//cnwmc5 - PAR 32680
	fieldDef.controlType	:= self.ControlType_CheckBox;			//cnwmc5 - PAR 32680

	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_IsReefer);	//cnwmc5 - PAR 32680
	fieldDef.controlType	:= self.ControlType_CheckBox;			//cnwmc5 - PAR 32680
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_CustomExportStop);	//cnwmc5 - PAR 32680
	fieldDef.controlType	:= self.ControlType_CheckBox;					//cnwmc5 - PAR 32680
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_IsControlledAtmosphere);	//cnwmc5 - PAR 32680
	fieldDef.controlType	:= self.ControlType_CheckBox;						//cnwmc5 - PAR 32680
	
	//cnwmc5 - 23 April 2014 - PAR 33988
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_TotalQuantity);
	fieldDef.key := WS_TrackedItem::totalQuantity.name;
	
	//cnwmc5 - 30 April 2014 - PAR 33988
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_TotalVolume);
	fieldDef.key := WS_TrackedItem::volume.name;
	
	//cnwmc5 - 1 June 2016 - TFS 2030
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_WeightCertifiedPerson);
	fieldDef.key := WS_TrackedItem::weightCertifiedName.name;
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_WeightCertifiedBy);
	fieldDef.key := WS_TrackedItem::weightCertifiedReference.name;
	
epilog
	delete mainRows;
	delete voyageRows;
	delete statusRows;
	//delete reefVisibleRows;
	delete reeferRows;
	delete dimensionRows;											// PAR #31800
	delete vehicleRows;												// PAR #32215
end;</source>
    </JadeMethod>
    <JadeMethod name="buildCargoEnquirySearchFormDef" id="f9398502-8981-4ca9-9280-fbdbef02cec7">
        <updating/>
        <source>buildCargoEnquirySearchFormDef() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2008	cnwkao1	Initial creation
11 Feb 2009	cnwdz2	updated according to RIA.doc
*/
constants
	Parent_Column1	: String = "column1";
	Parent_Column2	: String = "column2";
	
vars
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	response		: WS_FormDefinitionResponse;	
	fieldDef		: WS_FieldDefinition;
	column1Rows		: StringArray; //perhaps a more appropriate collection should be used
	column2Rows		: StringArray;
	parent			: String;
	rowName			: String;
	//defaultCargoTypeId : Integer;
begin
	self.proxyClassName			:= WS_TrackedItemQueryRequest.name;
	self.proxySearchClassName	:= WS_TrackedItem.name;
	
	//get the applicable group
	entTableGroup := CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_TrackedItemDetails);
	
	//get the applicable definition - now following alternative approach of retrieving the ETRows directly from the group rather than the def
	//entTableDef := entTableGroup.allEntTableDefsByName.getAtKey(ETDef_TIEnqHeader);
		
	
	create column1Rows transient;
	column1Rows.add(ETRow_FilterTiType);
	column1Rows.add(ETRow_FilterISOType);
	column1Rows.add(ETRow_FilterProduct);		//cnwmc5 - 16 Sep 2014 - PAR 34888
	column1Rows.add(ETRow_FilterOperator);
	column1Rows.add(ETRow_FilterBookingRef);//09/06/2009 cnwdz2 ccms1090 par19869
	self.buildGroupHeader(Parent_Column1, null, null); //hold above entries
	
	create column2Rows transient;
	column2Rows.add(ETRow_FilterIMEX);	
	column2Rows.add(ETRow_FilterVoyage);
	column2Rows.add(ETRow_FilterBOL);
	//column2Rows.add(ETRow_FilterTAType);		
	//column2Rows.add(ETRow_FilterTerminalArea);
	//column2Rows.add(ETRow_FilterYardLocation);
	column2Rows.add(ETRow_FilterSite);//04/08/2010 cnwdz2 24696
	//column2Rows.add(ETRow_CustomsDSK); //filterDSK doesnt appear any where - and not in spec
	self.buildGroupHeader(Parent_Column2, null, null); //hold above entries
	
	//build the main search field
	fieldDef := self.loadFieldFromRow(entTableGroup.allEntTableRowsByName.getAtKey(ETRow_FilterId));
	fieldDef.isUppercaseText := true;	
		
	foreach rowName in column1Rows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);
		if entTableRow &lt;&gt; null then
			fieldDef		:= self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Parent_Column1;	
		endif;
	endforeach;
		
	foreach rowName in column2Rows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);
		if entTableRow &lt;&gt; null then
			fieldDef		:= self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Parent_Column2;
		endif;
	endforeach;

	
	// ISO Type is dependent on Cargo Type
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterISOType);
	fieldDef.dataReloadField := ETRow_FilterTiType;
	fieldDef.dataStore := JMTUserInterfaceService::getISOTypesForCargoType.name;
	
	//cnwmc5 - 16 Sep 2014 - PAR 34888
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterProduct);
	fieldDef.dataReloadField := ETRow_FilterTiType;
	fieldDef.dataStore := JMTUserInterfaceService::getCargoSubtypesForCargoType.name;


	
	// Terminal Area is dependent on Terminal Area Type
	/*fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterTerminalArea);
	fieldDef.dataReloadField := ETRow_FilterTAType;

	// Yard Location is dependent on Terminal Area 
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterYardLocation);
	fieldDef.dataReloadField := ETRow_FilterTerminalArea;*/

	//set default values
	//fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterTiType);
	//defaultCargoTypeId := app.myPassport.myTerminal.defaultCargoType;
	//fieldDef.defaultId := defaultCargoTypeId.String;
	//fieldDef.defaultDescription := app.myRoot.allCargoTypesById[defaultCargoTypeId].description;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterBookingRef);
	fieldDef.isUppercaseText := true;	
epilog
	delete column1Rows;
	delete column2Rows;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildCargoNoteFormDefinition" id="11bf66f0-de59-483a-8afb-f059177501eb">
        <updating/>
        <source>buildCargoNoteFormDefinition() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2008	cnwkao1	Initial creation
// tfs 2708 cnwns1 26/09/16 PAR38242 POL - query on permissions
*/
constants
	Notify_Times	: String = "Notify Times";
	General_Group	: String = "General"; //9/10/2009 cnwdz2 par21027
	//Hidden_Group_Key	: String = "hidden";	//cnwmc5 - 12 Jan 2015 - PAR 35003
vars
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	fieldDef		: WS_FieldDefinition;	
	rowName			: String;
	readOnlyRows	: StringArray;
	generalRows		: StringArray;
	hiddenRows		: StringArray;		//cnwmc5 - 12 Jan 2015 - PAR 35003
begin
	self.proxyClassName			:= WS_CargoNoteUpdateRequest.name; // used by SOAP parser to create the correct type
	self.proxySearchClassName 	:= WS_EventRequestNotification.name; 
	
	//get the applicable group
	entTableGroup := CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_EventRequest);
	
	//get the applicable definition
	entTableDef := entTableGroup.allEntTableDefsByName.getAtKey(ETDef_EventRequestNotify); //this contains 12 rows
	
	//cnwmc5 - 4 March 2015 - PAR 33796 - removed to make status visible
	//cnwmc5 - 12 Jan 2015 - PAR 35003 - begin
	//self.buildHiddenGroup(Hidden_Group_Key);
	//create hiddenRows transient;
	//hiddenRows.add(ETRow_Status);
	
	//foreach rowName in hiddenRows do
	//	self.buildHiddenField(rowName,Hidden_Group_Key);
	//endforeach;
	//cnwmc5 - 12 Jan 2015 - PAR 35003 - end
	
	create generalRows transient;
	generalRows.add(ETRow_MyCargoType);
	generalRows.add(ETRow_CargoId);
	generalRows.add(ETRow_Status);			//cnwmc5 - 4 March 2015 - PAR 33796
	generalRows.add(ETRow_MyOrganisation);
	generalRows.add(ETRow_Event);
	generalRows.add(ETRow_Remarks);
	generalRows.add(ETRow_EmailAddresses);
	fieldDef := self.buildGroupHeader(General_Group, null, General_Group); //hold above entries
	fieldDef.showTableColumn := Visibility_Unavailable;
	
	create readOnlyRows transient;
	readOnlyRows.add(ETRow_MyCargoType);
	readOnlyRows.add(ETRow_CargoId);
	readOnlyRows.add(ETRow_MyOrganisation);
	readOnlyRows.add(ETRow_Event);
	readOnlyRows.add(ETRow_Status);			//cnwmc5 - 4 March 2015 - PAR 33796
	
	/* hidden rows
		ETRow_UserCode				//userCode		
		ETRow_Status				//status
		ETRow_StatusInformation		//statusInformation
		ETRow_ActionFailedReason	//actionFailedReason
		ETRow_StatusDT				//statusDT
		ETRow_EnteredDT				//enteredDT
	*/
	
	foreach rowName in generalRows do
		entTableRow := entTableDef.allEntTableRows[entTableDef.getRowByName(rowName)];
		fieldDef := self.loadFieldFromRow(entTableRow);	
		fieldDef.parent := General_Group;	//9/10/2009 cnwdz2 par21027
	endforeach;
	
	//build the custom time picker control
	self.buildField(WS_CargoNoteUpdateRequest::allNotifyTimesString.name,		//key					: String;
					Notify_Times,												//label					: String;
					ControlType_Custom_TimePicker,								//controlType			: Integer;
					General_Group,														//parent				: String;
					null,														//dataStore				: String;
					false,														//readOnly				: Boolean;
					null,														//dataList				: String;
					null,														//storeIdField			: String;
					null,														//storeDescField 		: String;
					null,
					null,
					null//repeatedStoreField	: String
					);
					
			
	//setup any additional details
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_CargoId);
	fieldDef.controlType := self.ControlType_MultiTextBox;//29/10/2010 cnwdz2	26182
	fieldDef.isUppercaseText := true;
	fieldDef.initialFieldForSaveNext := true;
	//fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_MyCargoType);
	//fieldDef.defaultId := app.myPassport.myTerminal.defaultCargoType.String; //ISO Container type

	
	
	
	foreach rowName in readOnlyRows do
		fieldDef := self.allFormFieldsByKey.getAtKey(rowName);
		fieldDef.readOnly := true;
	endforeach;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Event);							//TFS2708
	fieldDef.dataStore	:= JMTUserInterfaceService::getEventRequestTypesUpdateDel.name;	//TFS2708
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_EmailAddresses);
	fieldDef.controlType := ControlType_Custom_Recipients;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Remarks);
	fieldDef.controlType := ControlType_MultiTextBox; //all text boxes on the JMT form are multi-line
	
	
	
	
	
	//cnwmc5 - 4 March 2015 - PAR 33796
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Status);
	fieldDef.defaultId := EventRequestPending.asStringJMT();
	fieldDef.defaultDescription := EventRequestPendingStr;
	fieldDef.readOnlyAlways := true;
	
epilog
	delete generalRows;
	delete readOnlyRows;
end;
</source>
    </JadeMethod>
    <JadeMethod name="buildCargoNoteSearchFormDef" id="e088759a-0908-4628-a309-d14855b56e27">
        <updating/>
        <source>buildCargoNoteSearchFormDef() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2008	cnwkao1	Initial creation

*/
vars	
	
begin
	proxyClassName				:= WS_CargoNoteQueryRequest.name; // used by SOAP parser to create the correct type
	proxySearchClassName		:= WS_EventRequestNotification.name;
	self.primarySearchLabel	    := "Notification Request ";
	
	self.buildCommonEventReqSearchDef(); //this search form definition is utilised for cargo note stop and cargo note request	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildCargoQuickViewFormDef" id="9d8e8408-62b8-4c9c-8a96-744399047c84">
        <updating/>
        <source>buildCargoQuickViewFormDef() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 Feb 2009	cnwdz2	Initial creation

*/
constants
	General_Group	: String = "General";
	
vars
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	fieldDef		: WS_FieldDefinition;
	generalRows		: StringArray; //perhaps a more appropriate collection should be used

	parent			: String;
	rowName			: String;
begin
	//self.proxyClassName			:= WS_CargoEnqUpdateRequest.name;
	self.proxySearchClassName	:= WS_TrackedItem.name;
	
	//get the applicable group
	entTableGroup := CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_TrackedItemDetails);


	create generalRows transient;	
	generalRows.add(ETRow_Id);
	generalRows.add(ETRow_AlternativeId);	//05 May 2013	NDL	Par 31506
	generalRows.add(ETRow_CargoType);
	generalRows.add(ETRow_MyProduct);				//cnwmc5 - 30 April 2014 - PAR 33988
	generalRows.add(ETRow_IsoType);
	generalRows.add(ETRow_TrailerType);
	generalRows.add(ETRow_ImexStatus);
	generalRows.add(ETRow_TotalWeight);
	generalRows.add(ETRow_TotalVolume);			//cnwmc5 - 23 April 2014 - PAR 33988
	generalRows.add(ETRow_TotalQuantity);		//cnwmc5 - 23 April 2014 - PAR 33988
	generalRows.add(ETRow_MyVoyage);
	generalRows.add(ETRow_OperatorCode);//04/11/2010 cnwdz2 26201
	generalRows.add(ETRow_ReceivedDT);
	generalRows.add(ETRow_ReleasedDT);
	generalRows.add(ETRow_LoadPort);	
	generalRows.add(ETRow_Tranship);//04/11/2010 cnwdz2 26201
	generalRows.add(ETRow_LocationGeneral);
	generalRows.add(ETRow_TransportMode);//04/11/2010 cnwdz2 26201
	generalRows.add(ETRow_AllStops);
		
	fieldDef := self.buildGroupHeader(General_Group, null, General_Group); //hold above entries
	fieldDef.showTableColumn := Visibility_Unavailable;
	
	foreach rowName in generalRows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);		
		fieldDef := self.loadFieldFromRow(entTableRow);
		fieldDef.parent := General_Group;		
		fieldDef.readOnly	:= true; //currently no maintenance allowed
	endforeach;
	
	//lastly remap the field names to the proxy property names
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Id);
	fieldDef.key := WS_TrackedItem::idTextBox.name;
	fieldDef.isUppercaseText := true;
	
	//03 may 2013	NDL	Par 31506
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_AlternativeId);
	fieldDef.isUppercaseText := true;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_MyVoyage);
	fieldDef.key := WS_TrackedItem::voyageCode.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_ImexStatus);
	fieldDef.key := WS_TrackedItem::imexStatusString.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_TotalWeight);
	fieldDef.key := WS_TrackedItem::weightTotal.name;
	
	//cnwmc5 - 23 April 2014 - PAR 33988
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_TotalVolume);
	fieldDef.key := WS_TrackedItem::volume.name;
	
	//cnwmc5 - 23 April 2014 - PAR 33988
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_TotalQuantity);
	fieldDef.key := WS_TrackedItem::totalQuantity.name;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_AllStops);
	fieldDef.key := WS_TrackedItem::stopsDescription.name;	
	fieldDef.controlType := ControlType_MultiTextBox;	//cnwmc5 - PAR 32753
epilog
	delete generalRows;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildCargoQuickViewSearchDef" id="dbfdb9f4-2301-4b5d-8589-8da42889ed45">
        <updating/>
        <source>buildCargoQuickViewSearchDef() updating;
/*

Purpose:		//04/11/2010 cnwdz2 26201	

Parameters:			

Return Value:		


Date		Who		Reason
11 Feb 2009	cnwdz2	Initial creation

*/
constants
	Parent_Column1	: String = "column1";
	Parent_Column2	: String = "column2";
	
vars
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	response		: WS_FormDefinitionResponse;	
	fieldDef		: WS_FieldDefinition;
	column1Rows		: StringArray; //perhaps a more appropriate collection should be used
	column2Rows		: StringArray;
	parent			: String;
	rowName			: String;
	defImexStatus   : CM_IMEXStatus;
	//defaultCargoTypeId : Integer;
begin
	self.proxyClassName			:= WS_TrackedItemQueryRequest.name;
	self.proxySearchClassName	:= WS_TrackedItem.name;
	
	//get the applicable group
	entTableGroup := CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_TrackedItemDetails);
	
	//build the main search field
	fieldDef := self.loadFieldFromRow(entTableGroup.allEntTableRowsByName.getAtKey(ETRow_FilterId));
	fieldDef.isUppercaseText := true;	
	
	//04/11/2010 cnwdz2 26201
	create column1Rows transient;
	column1Rows.add(ETRow_FilterTiType);
	column1Rows.add(ETRow_FilterLimitedSite);
	self.buildGroupHeader(Parent_Column1, null, null); //hold above entries
	
	create column2Rows transient;
	column2Rows.add(ETRow_FilterIMEX);	
	self.buildGroupHeader(Parent_Column2, null, null); //hold above entries
		
	foreach rowName in column1Rows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);
		if entTableRow &lt;&gt; null then
			fieldDef		:= self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Parent_Column1;	
		endif;
	endforeach;
		
	foreach rowName in column2Rows do
		entTableRow := entTableGroup.allEntTableRowsByName.getAtKey(rowName);
		if entTableRow &lt;&gt; null then
			fieldDef		:= self.loadFieldFromRow(entTableRow);
			fieldDef.parent := Parent_Column2;
		endif;
	endforeach;
	
	//build the main search field
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterLimitedSite);
	fieldDef.key := WS_TrackedItemQueryRequest::filterSite.name;
	fieldDef.controlType := ControlType_ComboBox;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_FilterIMEX);
	fieldDef.dataReloadField := WS_TrackedItemQueryRequest::filterSite.name;
	fieldDef.dataStore := JMTUserInterfaceService::getFilterImexForSite.name;
	defImexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT]; //sep/2009 cnwdz2 20635
	if defImexStatus &lt;&gt; null then
		fieldDef.defaultId	:= defImexStatus.code.asStringJMT();
		fieldDef.defaultDescription := defImexStatus.description;	
	endif;
epilog
	delete column1Rows;
	delete column2Rows;
end;</source>
    </JadeMethod>
