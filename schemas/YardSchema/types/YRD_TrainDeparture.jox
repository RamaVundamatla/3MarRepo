    <JadeMethod name="setSelectedProfiles" id="4a9740cf-76d1-4c71-8b74-41fab663c16b">
        <source>setSelectedProfiles(_strProfiles: StringArray input);
//----------------------------------------------------------------
//	Created:	18 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	_strProfiles.clear;
	if self.chkPrintCargoOP.value then
		_strProfiles.add('By Operator'); // #### DO NOT TRANSLATE
	endif;
	
	if self.chkPrintCargoWAG.value then
