    <JadeMethod name="detailsDelete" id="4eeac57c-81b9-414b-919b-d0343fbff418">
        <updating/>
        <source>detailsDelete()updating;
//--------------------------------------------------------------
//Created: 22 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	rtValue 			: Boolean;
	msgStr 				: String;
	tmpStockOrderLine	: CM_StockOrderLine;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	if self.myCurrentStockOrderLine = null then
		app.msgBox('Please select an Stock Order Line from the table to Delete.','Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;			
	endif;
	tmpStockOrderLine := self.myCurrentStockOrderLine;	
	if tmpStockOrderLine.CM_LogStockOrderLine.checkOnShip then
		app.msgBox('Cannot edit Stock Order for customer' &amp; tmpStockOrderLine.CM_LogStockOrderLine.consigneeCode &amp;
					' as stock has been loaded or partially loaded to the ship.',
					'Stock Order Edit', MsgBox_Stop_Icon + MsgBox_OK_Only);			
		return;
	endif;	

	msgStr := 'Are you sure you want to delete' &amp;CrLf &amp; 'Stock Order for customer ' &amp; tmpStockOrderLine.CM_LogStockOrderLine.consigneeCode &amp; ' ?';
	if app.msgBox(msgStr, 'Voyage Delete', MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;
	self.setMode(Mode_Delete);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteStockOrderLine(tmpStockOrderLine, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Voyage Ops', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

	self.myCurrentStockOrderLine := null;
	
	if self.myCurrentVoyage &lt;&gt; null then
		self.loadAllOrdersByVoyageTerminal(self.myCurrentVoyage, null);
	elseif self.myCurrentVoyageGlobal &lt;&gt; null then
		self.loadAllOrdersByVoyageGlobal(self.myCurrentVoyageGlobal);
	elseif self.myCurrentVoyageOperator &lt;&gt; null then
		self.loadAllOrdersByVoyageOperator(self.myCurrentVoyageOperator);
	else
		self.listsTreeViewLoadAll();	
	endif;
	
	self.detailsRefresh();
		
end;</source>
    </JadeMethod>
    <JadeMethod name="detailsDisplaySelected" id="c958f53e-3c39-4e70-85cc-4db2f47eab82">
        <source>detailsDisplaySelected();
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	orderLine : CM_LogStockOrderLine;
	product	: CM_ProductLog;
	assist	: LOG_Assistant;
	voyOperator	: CM_VoyageOperator;
	operator	: CM_Operator;
	theVoyage	: CM_Voyage;
	voyCntrl	: CM_LogVoyageController;
	loadStateSet : Boolean;
begin

	if self.fldInfo.topSheet &lt;&gt; self.shtDetails then
		return;
	endif;
	if self.mode &lt;&gt; Mode_Add then //  par14640 by conks1
		tblLotDetails.clearValues();
	endif;
	tblLotDetails.clearValues();
	tblHatchPlaceEnt.clearValues();
	tblHatchPlaceDtl.rows := tblHatchPlaceDtl.fixedRows;

	if self.myCurrentStockOrderLine = null then
		return;
	endif;	
	
	app.cmsBeginLoad(loadStateSet);
	orderLine := self.myCurrentStockOrderLine.CM_LogStockOrderLine;
	voyOperator := orderLine.getMyVoyageOperator();

	if voyOperator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "VoyageOperator null, contact developer");
		return;
	endif;
		
	product := orderLine.myProduct.CM_ProductLog;
	operator := voyOperator.myOperator;
	theVoyage := voyOperator.myVoyage;

	assist := self.myAssistant.LOG_Assistant;
	assist.comboBoxVoyageOperator(self.cmbVoyOperator, voyOperator, theVoyage);
	cmbVoyOperator.lostFocus(cmbVoyOperator);
	self.cmbConsignee.setObject(orderLine.myConsignee);
	cmbConsignee.lostFocus(cmbConsignee);
	self.cmbDischargePort.myAssistant := self.myAssistant;
	self.cmbDischargePort.setObjectFromCode(orderLine.dischargePort);
	cmbDischargePort.lostFocus(cmbDischargePort);	
	
	self.cmbSpecies.setObjectAndOperator(product.myLogSpecies,operator);
	cmbSpecies.lostFocus(cmbSpecies);
	self.cmbGrade.setObjectAndSpecies(product.myLogGrade,product.myLogSpecies);	
	cmbGrade.lostFocus(cmbGrade);
	self.cmbType.setObjectAndGrade(product.myLogType,product.myLogGrade);
	cmbType.lostFocus(cmbType);
	self.cmbTreatment.setObjectAndGrade(product.myLogTreatment,product.myLogGrade);
	cmbTreatment.lostFocus(cmbTreatment);
	self.cmbLength.setObjectAndGrade(product.myLogLength,product.myLogGrade);
	cmbLength.lostFocus(cmbLength);					

	tblLotDetails.setValueByName(ETRow_LotNo, orderLine.lotNo);	
	//par no 14774--reopened &amp; changed
	tblLotDetails.setValueByName(ETRow_ReqdQuantity, orderLine.reqdQuantity.Integer);
	tblLotDetails.setValueByName(ETRow_MinContractQuantity, orderLine.minContractQuantity.Integer);
	tblLotDetails.setValueByName(ETRow_MaxContractQuantity, orderLine.maxContractQuantity.Integer);
	tblLotDetails.setValueByName(ETRow_Comments, orderLine.comments);
	tblLotDetails.setValueByName(ETRow_CommentsOperator, orderLine.commentsOperator);
	tblLotDetails.setValueByName(ETRow_OperatorRef1, orderLine.operatorRef1);
	tblLotDetails.setValueByName(ETRow_OperatorRef2, orderLine.operatorRef2);	
		
	foreach voyCntrl in orderLine.allLogVoyageLocations do
		tblHatchPlaceDtl.addItem(voyCntrl.hatch.String &amp; Tab &amp; app.vesselPlaceEnumToStr(voyCntrl.place));
		tblHatchPlaceDtl.accessedRow.itemObject := voyCntrl;		
	endforeach;

epilog
	app.cmsEndLoad(loadStateSet);
end;</source>
    </JadeMethod>
    <JadeMethod name="detailsEdit" id="68cd208f-92dc-47ac-8de4-2752ba97af54">
        <updating/>
        <source>detailsEdit()updating;
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	realLogLine : CM_LogStockOrderLine;
	loadStateSet : Boolean;
begin
	if self.myCurrentStockOrderLine = null then
		self.showCannotAccessSheetMsg(shtDetails, 'You must select a Stock Order Line from the above table before you can edit.');
		return;
	else
		self.hideCannotAccessSheetMsg(shtDetails);
	endif;
	
	app.cmsBeginLoad(loadStateSet);
		
	realLogLine := self.myCurrentStockOrderLine.CM_LogStockOrderLine;	
	if realLogLine.checkOnShip then
		app.msgBox('Cannot edit Stock Order for customer' &amp; realLogLine.consigneeCode &amp;
					' as stock has been loaded or partially loaded to the ship.',
					'Stock Order Edit', MsgBox_Stop_Icon + MsgBox_OK_Only);			
		return;
	endif;
		
	self.setMode(Mode_Update);
	self.tblLotDetails.goToRowByName(ETRow_MyLogLot);
	self.setEnableObjectsDetails();
	
	if self.myCMIF_LogStockOrderLine = null then
		create self.myCMIF_LogStockOrderLine transient;
	endif;
	self.myCMIF_LogStockOrderLine.expectedEditionForLine := realLogLine.edition;
	
	sharedLock(realLogLine.myStockOrderHeader);
	self.myCMIF_LogStockOrderLine.expectedEditionForHeader := realLogLine.myStockOrderHeader.edition;
	
epilog
	app.cmsEndLoad(loadStateSet);
end;</source>
    </JadeMethod>
    <JadeMethod name="detailsHPAdd" id="c3be85b8-c9f0-44ec-8c3d-650cd65f72c9">
        <source>detailsHPAdd();
//--------------------------------------------------------------
//Created: 22 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	hatch,
	place : String;
	row : Integer;
begin
	hatch := tblHatchPlaceEnt.getValueByName(ETRow_Hatch).String;
	place := tblHatchPlaceEnt.getValueByName(ETRow_Place).String;
	
	if hatch &lt;&gt; null and place &lt;&gt; null then
		row := tblHatchPlaceDtl.rows;
		while row &gt; tblHatchPlaceDtl.fixedRows do
			if tblHatchPlaceDtl.accessCell(row, 1).text = hatch and
				tblHatchPlaceDtl.accessCell(row, 2).text = place then
				return;
			endif;
			//CNWTH2 - umm..if your going to do it this way you might want to include:
			row := row -1;
		endwhile;
		
		tblHatchPlaceDtl.addItem(hatch &amp; Tab &amp; place);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="detailsHPRemove" id="996f168a-c037-4646-be17-8680b6774ede">
        <source>detailsHPRemove();
//--------------------------------------------------------------
//Created: 22 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	voyCntrl : CM_LogVoyageController;
begin

	if self.tblHatchPlaceDtl.row &gt; 1 and tblHatchPlaceDtl.row &lt;= tblHatchPlaceDtl.rows then
		if self.mode = Mode_Update then
			self.tblHatchPlaceDtl.deleteRow(tblHatchPlaceDtl.row);			
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="detailsNew" id="304d54d8-c846-4886-b550-b0f4afe7b716">
        <updating/>
        <source>detailsNew()updating;
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.myCurrentVoyage = null then
		self.showCannotAccessSheetMsg(shtDetails, 'You must select a Terminal from the list before you can Add/Update deatils.');
		return;
	else
		self.hideCannotAccessSheetMsg(shtDetails);
	endif;
	if self.myCurrentStockOrderLine = null then
		if self.myCurrentVoyageOperator &lt;&gt; null then
			self.myAssistant.LOG_Assistant.comboBoxVoyageOperator(self.cmbVoyOperator,
																 self.myCurrentVoyageOperator,
																 self.myCurrentVoyageOperator.myVoyage);
			cmbVoyOperator.lostFocus(cmbVoyOperator);
		else
			self.myAssistant.LOG_Assistant.comboBoxVoyageOperator(self.cmbVoyOperator, 
																  self.cmbVoyOperator.listObject.CM_VoyageOperator,
																  self.myCurrentVoyage);
			if self.cmbVoyOperator.listObject = null then
				cmbVoyOperator.lostFocus(cmbVoyOperator);
			endif;
		endif;
	endif;

	self.setMode(Mode_Add);
	self.tblLotDetails.goToRowByName(ETRow_LotNo);	
	self.setEnableObjectsDetails();
	self.tblLotDetails.setFocus();


end;</source>
    </JadeMethod>
    <JadeMethod name="detailsRefresh" id="7e3b22dd-6825-41d0-a663-7a6919618bed">
        <updating/>
        <source>detailsRefresh()updating;
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	rowIdx : Integer;
	topRow : Integer;
begin
	topRow := self.tblOrderData.topRow;

	self.detailsDisplaySelected();
	
	self.setMode(self.viewMode);
	self.setEnableObjectsDetails();
	self.btnDetailsNew.setFocus();
	self.optionChange();
	
	if self.myCurrentStockOrderLine &lt;&gt; null then
		if self.tblOrderData.findObjectInRow(self.myCurrentStockOrderLine, rowIdx) then
			self.tblOrderData.accessRow(rowIdx).selected := true;
			self.tblOrderData.row := rowIdx;
		endif;
	endif;		

	if topRow &gt; self.tblOrderData.fixedRows
	and topRow &lt;= self.tblOrderData.rows then
		if topRow &lt;&gt; self.tblOrderData.topRow then
			self.tblOrderData.topRow := topRow;
		endif;
	elseif rowIdx &gt; self.tblOrderData.fixedRows
	and rowIdx &lt;= self.tblOrderData.rows then
		if rowIdx &lt;&gt; self.tblOrderData.topRow then
			self.tblOrderData.topRow := rowIdx;
		endif; 
	endif;
				
end;</source>
    </JadeMethod>
    <JadeMethod name="detailsSave" id="1651d3a0-fd12-45e7-a9b3-fcd001471006">
        <updating/>
        <source>detailsSave()updating;
//--------------------------------------------------------------
//Created: 19 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	iFaceOrder	: CMIF_LogStockOrderLine;
	voyOperator	: CM_VoyageOperator;
	theVoyage	: CM_Voyage;
	result		: Integer;
	tmpStr 		: String;
begin

	app.mousePointer := MousePointer_HourGlass;
	
	if cmbVoyOperator.listObject &lt;&gt; null then
		voyOperator := cmbVoyOperator.listObject.CM_VoyageOperator;
	else
		tmpStr := app.getTerminologyAlternate(null, self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Supplier');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr, ETRow_VoyageOperator, null);
		app.raiseCMException1(Input_required_field_Required, tmpStr, ETRow_VoyageOperator, null); // cnwdb2	PAR 35364
		return;
	endif;

	if self.myCMIF_LogStockOrderLine &lt;&gt; null then
		iFaceOrder := self.myCMIF_LogStockOrderLine;
	else
		create iFaceOrder transient;
		self.myCMIF_LogStockOrderLine := iFaceOrder;
	endif;
	self.tblLotDetails.setObjectFromTable(iFaceOrder, LOG_VoyageOpsForm::stripCarriageReturns.name, false);	// 10 Dec 2012	NDL	Par 30709
	
	iFaceOrder.myOperator := voyOperator.myOperator;

	if self.cmbSpecies.myObject &lt;&gt; null then
		iFaceOrder.myLogSpecies := self.cmbSpecies.myObject.CM_LogSpecies; 
	endif;
	iFaceOrder.myLogGrade := self.cmbGrade.myObject.CM_LogGrade; 
	iFaceOrder.myLogType := self.cmbType.myObject.CM_LogType;
	iFaceOrder.myLogTreatment := self.cmbTreatment.myObject.CM_LogTreatment;
	iFaceOrder.myLogLength := self.cmbLength.myObject.CM_LogLength;

	if self.cmbConsignee.myObject &lt;&gt; null then
		iFaceOrder.consigneeCode := self.cmbConsignee.myObject.CM_ConsigneeConsignor.code;
	else
		iFaceOrder.consigneeCode := null;
	endif;
		
	if self.mode = Mode_Update then
		theVoyage := self.myCurrentStockOrderLine.myStockOrderSummary.myVoyage;
	else
		theVoyage := self.myCurrentVoyage;
	endif;
	iFaceOrder.myLogVoyage := theVoyage.CM_Voyage;	
	iFaceOrder.myTerminal := theVoyage.myTerminal;
	iFaceOrder.mode := self.mode;
//	if self.mode = Mode_Update then  // Par 9970 - When in New mode but adding LogStockOrderLines to exsisting Lot
//	need details from myCurrentStockOrderLine. In transactions there are other checks on mode to stop it being used badly
		iFaceOrder.myLogStockOrderLine := self.myCurrentStockOrderLine.CM_LogStockOrderLine;	
//	endif;

	while true do
		app.myTrxUA.trxUpdateStockOrderFromCMIF(iFaceOrder, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Log Voyage Ops', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return;
	endwhile;

	self.detailsRefresh();
	// do not delete if there has been an error
	delete self.myCMIF_LogStockOrderLine;
	
epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteSelectedAllocations" id="106e0a85-ae81-4215-afda-2ff756cd4ed6">
        <updating/>
        <source>doDeleteSelectedAllocations() updating;
//--------------------------------------------------------------
//Created: 25 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	row, col : Integer;	
	allocation : CM_StockOrderAllocation;
	allocSet : CM_StockOrderAllocationSet;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	app.mousePointer := MousePointer_HourGlass;
	
	create allocSet transient;
	row := self.tblAllocatedRows.rows;
	col := self.tblAllocatedRows.getColumnByRowName(ETRow_Opt);
	
	while row &gt; tblAllocatedRows.fixedRows do
		if self.tblAllocatedRows.accessCell(row, col).text &lt;&gt; '1' then
			row := (row - 1);		
			continue;
		endif;
		allocation := tblAllocatedRows.accessRow(row).itemObject.CM_StockOrderAllocation;
		allocSet.add(allocation);
		row := (row - 1);
	endwhile;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteStockOrderAllocation(allocSet, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Voyage Ops', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	self.btnAllocSelect.caption := 'Select All';
	
epilog
	delete allocSet;
	app.mousePointer := MousePointer_Default;		
end;</source>
    </JadeMethod>
    <JadeMethod name="doLstDataContextMenu" id="61fd1d3b-dfb8-4724-8fc6-7f0be02c354a">
        <updating/>
        <source>doLstDataContextMenu(listbox: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     16 December 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	self.mnuInspect.visible := app.isAllowedToInspect();
	self.mnuInspectMain.visible := self.mnuInspect.visible;
	return self.showContextMenu(self.mnuInspectMain, listbox, conwin, mouse, x, y);

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
