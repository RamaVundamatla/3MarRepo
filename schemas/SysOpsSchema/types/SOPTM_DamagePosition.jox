    <JadeMethod name="doSave" id="6bb64906-eeae-4da4-8d6a-141fedfaea80">
        <updating/>
        <source>doSave(): Boolean updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 07 July 2009
//
// Implemented version: 7.7.3
// CCMS SFW1066  - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	theForm 				: SOP_TableMaintForm;
	tbl						: CM_EntryTable;
	code,
	description				: String;
	isNotAvailableForEntry 	: Boolean;
	pxyDamagePosition,
	newDamagePosition		: CM_DamagePosition;
	cargoTypes				: ObjectSet;
	machineTypes			: ObjectSet;
begin
	theForm := self.myForm;
	tbl := theForm.tblInput1;
	
	code := tbl.getValueByName(ETRow_Code).String;
	description := tbl.getValueByName(ETRow_Description).String;
	isNotAvailableForEntry := tbl.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;
	
	//Get the cargo types and machine types that have been selected from the form.
	create cargoTypes transient;
	theForm.mulSelect1.getSelected(cargoTypes);
	create machineTypes transient;
	theForm.mulSelect2.getSelected(machineTypes);
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DamagePosition transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object null for update');
			return false;
		endif;
	endif;
	
	pxyDamagePosition := theForm.myProxyObject.CM_DamagePosition;
	pxyDamagePosition.setProxy(code, description, isNotAvailableForEntry, cargoTypes, machineTypes);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateDamagePosition(pxyDamagePosition, newDamagePosition, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateDamagePosition(pxyDamagePosition, app.myPassport);
	endif;
	
	return app.myPassport.trxCompletedOK();
epilog
	delete cargoTypes;
	delete machineTypes;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
