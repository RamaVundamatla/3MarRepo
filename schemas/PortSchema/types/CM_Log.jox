    <JadeMethod name="setPxyFromCMIF_InOutAttachment" id="22e30975-390c-4d8b-9c91-b97a0efd151f">
        <updating/>
        <source>setPxyFromCMIF_InOutAttachment(pAttach: CMIF_InOutAttachment;pPassport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 04 February 2002 By: cnwgd1
