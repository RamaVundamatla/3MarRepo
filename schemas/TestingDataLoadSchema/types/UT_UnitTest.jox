    <JadeMethod name="assertIsOneOf" id="713c54af-a31d-4f0b-8f53-51d83761003c">
        <source>assertIsOneOf(_actual: Any; _message : String; _paramList:ParamListType) protected;
// --------------------------------------------------------------------------------
// Created:		13 April 2010 by cnwdad1
//
// Purpose:		Asserts that the specified value (_actual parameter) is equal to
//				one of the values in the specified parameter list.
//
// Parameters:	_actual - The actual value which must match a value in the parameter list.
//				_message - The message to be shown if the assert fails.
//				_paramList - A list of value to compare to the _actual parameter.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	paramCount	: Integer;
	displayStr	: String;
	
begin
	paramCount	:=	app.getParamListTypeLength(_paramList);
	
	foreach paramCount in 1 to paramCount do
		if displayStr = null then
			displayStr	:=	app.getParamListTypeEntry(paramCount, _paramList).String;
		else
			displayStr	:=	displayStr &amp; ", " &amp; app.getParamListTypeEntry(paramCount, _paramList).String;
		endif;
	endforeach;
	
	self.assertTrueMsg(	app.cnEcIsOneOf(_actual, _paramList),
						"Actual:   " &amp; _actual.String.removeTabCrLfs() &amp; CrLf &amp; "Expected: " &amp; displayStr.String.removeTabCrLfs() &amp; CrLf &amp; _message);
end;
</source>
        <access>protected</access>
        <Parameter name="_actual" type="Any"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_paramList" type="ParamListType"/>
    </JadeMethod>
    <JadeMethod name="assertNoTrxErrors" id="8425b9cd-cfa2-481b-9e96-22fe2863743a">
        <source>assertNoTrxErrors();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 June 2013	cnwer1	Initial creation CCMS DPH 2274

*/

vars

begin
	self.assertTrueMsg(app.myPassport.trxCompletedOK() and app.myPassport.allErrors.size = 0, app.myPassport.getErrorsAsString());
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="assertNoTrxErrorsOrWarnings" id="64720b33-df17-4c88-aa45-6fc98418566c">
        <source>assertNoTrxErrorsOrWarnings() protected;
//17 November 2008	cnwdw1	
// 02/09/2013	cnwmh5	Change so that if a Jade Error occurs it fails unless that Jade Error is in the extected errors
vars
	error: CM_Error;
	unitTest: UT_UnitTest;
begin
	if self.expectedTrxErrors.size &gt; 0 then
		foreach error in app.myPassport.allErrorWarnings do
			if self.expectedTrxErrors.includes(error.errorCode) then
				unitTest := self;						// bodge to stop having to create method as updating
				unitTest.expectedTrxErrorFound := true;
				continue;			// 02/09/2013 cnwmh5 
			endif;
			if error.errorCode &lt;= app.myRoot.baseErrorNum then				// 02/09/2013 cnwmh5 
				self.assertTrueMsg(false, error.text);
				return;
			endif;	
		endforeach;
	endif;
	if not self.expectedTrxErrorFound then
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsAndWarnsFullAsStr());
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="assertNoTrxErrorsPassport" id="5ea77922-12ea-425e-92f2-b62a461a54ec">
        <source>assertNoTrxErrorsPassport(_message : String);
// ---------------------------------------------------------------------------
// Created:     22 July 2014 by cnwab1
