    <JadeMethod name="initForm" id="7af7620d-8432-4391-a675-664f5e1220ab">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     03 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theType	: String;
	navObj	: CMUI_NavigatorObject;

begin
	self.setNavigatorHeading(self.caption);
	self.allowPrint 	:= false;
	self.allowExportCSV	:= false;
	self.allowPrintSelected	:= false;
	
	self.allowAdd	 := true;
	self.allowUpdate := true;
	self.allowDelete := true;
	self.allowSearch := true;
	self.initTblInput1();
	self.myAssistant.comboBoxHMSTideDataType(self.cmbDataType, null);
	btnSaveBase.caption := "Save Tidal Restriction";
	btnSaveBase.bubbleHelp := "Save Tidal Restriction";	
	
	//epr 17684 7/8/08 just for debugging
	self.setupSpecialMenus();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblInput1" id="83ae9fc2-fd8e-4489-8b1f-601d2a3ba6a9">
        <updating/>
        <source>initTblInput1() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	
begin

	theTable := self.tblInput1;
	theTable.warningMethod := 'entTableWarning';
	
	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
		
	entTableDef := app.myController.getEntTableDef(ETDef_HMSTidalModelEnt);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	theTable.adjustHeight(200);

	theTable.optimiseHeadingColumn();
	theTable.changeMode := theTable.ChangeMode_FirstOnly;

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="a5483401-c9ff-48c9-85ee-54d8c447e2e3">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tidalModelDef		: HMS_TidalModelDefinition;
begin
	inheritMethod();
	
	
	if self.mode = self.Mode_Add then
		self.tblInput1.clearValues();
	elseif HMS_TidalModelDefinition.hasInstance(self.myProxyObject) then
		tidalModelDef := self.myProxyObject.HMS_TidalModelDefinition;
		self.tblInput1.setValueByName(ETRow_Code, tidalModelDef.code);
		self.tblInput1.setValueByName(ETRow_Description, tidalModelDef.description);
		self.tblInput1.setValueByName(ETRow_DataType, tidalModelDef.getDataTypeDescr());
		self.tblInput1.setValueByName(ETRow_DataSource, tidalModelDef.dataSource);
		self.tblInput1.setValueByName(ETRow_HighestValue, tidalModelDef.highestValue);
		self.tblInput1.setValueByName(ETRow_LowestValue, tidalModelDef.lowestValue); //.abs	); //cnwrs1 par 19108 Mar 2009
		//self.tblInput1.setValueByName(ETRow_ChartDatum, tidalModelDef.chartDatum);
		self.tblInput1.setValueByName(ETRow_DeclaredDepth, tidalModelDef.declaredDepth);
		self.tblInput1.setValueByName(ETRow_UnderKeelClearance, tidalModelDef.underKeelClearance);
		self.tblInput1.setValueByName(ETRow_GetTideFileName, tidalModelDef.getTideFileName);
		
		self.cmbDataType.listIndex := self.cmbDataType.findString(1, app.tidalDataTypeEnumToString(tidalModelDef.dataType));
		self.doCmbDataTypeClick();
		self.cmbDataSource.listIndex := self.cmbDataSource.findString(1, tidalModelDef.dataSource);
		
	
		if tidalModelDef.dataSource = HMS_TidalDataSourceGetTideFile then  //CCMS1640 cnwrs1 jan 2009
			self.tblInput1.showRowByName(ETRow_LowestValue, true);
			self.tblInput1.showRowByName(ETRow_HighestValue, true);
			self.tblInput1.enableRowByName(ETRow_LowestValue);
			self.tblInput1.enableRowByName(ETRow_HighestValue);
		//if tidalModelDef.dataSource = HMS_TidalDataSource_File then
		elseif tidalModelDef.dataSource &lt;&gt; HMS_TidalDataSource_File then	// 26/03/2008 cnwar2 #16272
			self.btnLoadTidalData.enabled := false;  //epr par 16927 16/6/08
			self.tblInput1.hideRowByName(ETRow_LowestValue, false);
			self.tblInput1.hideRowByName(ETRow_HighestValue, false);
		else
			self.btnLoadTidalData.enabled := true; //epr par 16927 16/6/08
			self.tblInput1.showRowByName(ETRow_LowestValue, false);
			self.tblInput1.showRowByName(ETRow_HighestValue, false);
			self.tblInput1.disableRowByName(ETRow_LowestValue);			// 26/03/2008 cnwar2 #16272
			self.tblInput1.disableRowByName(ETRow_HighestValue);		// 26/03/2008 cnwar2 #16272
		endif;	
	endif;
	if self.cmbDataSource.text = HMS_TidalDataSourceGetTideFile then //CCMS cnwrs1 jan 2009
		self.tblInput1.showRowByName(ETRow_GetTideFileName, false);
	else
		self.tblInput1.hideRowByName(ETRow_GetTideFileName, false);
	endif;
	
	self.tblInput1.hideRowByName(ETRow_EarliestDate, false);
	self.tblInput1.hideRowByName(ETRow_LatestDate, false);
	
	self.tblInput1.resetSize();		// 26/03/2008 cnwar2 #16272
end;


</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="9f310fc5-3639-47e0-964f-2c40d79e6543">
