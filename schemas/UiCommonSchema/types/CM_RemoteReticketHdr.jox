<Class name="CM_RemoteReticketHdr">
    <JadeMethod name="loadRemoteTable" id="1ea28c70-c540-43fb-932b-c53de2974786">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

vars

	detail	: CM_RemoteDataDtl;

begin

	inheritMethod(_table);
	self.addRemoteRow(_table, 'Area/Location', self.areaLocation, null);
	foreach detail in self.allRemoteDataDtl do
		self.addRemoteRow(_table, 'Reticketing ', Click, detail);
	endforeach;


end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
