    <JadeMethod name="translateForm" id="84b32e8d-d9b2-45c9-b3eb-e9ddf5ca83ab">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 09 June 2022 19:54:14.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008178, locale);
	btnAll.translateBubbleHelp(Xlat_0000975, locale);
	btnAll.translateCaption(Xlat_0000988, locale);
	btnDelete.translateBubbleHelp(Xlat_0000976, locale);
	btnDelete.translateCaption(Xlat_0000989, locale);
	btnDeleteAll.translateBubbleHelp(Xlat_0010043, locale);
