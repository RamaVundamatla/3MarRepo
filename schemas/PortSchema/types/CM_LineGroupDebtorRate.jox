    <JadeMethod name="getTimeRate" id="2350a08b-af65-449a-985b-1a7f4545b648">
        <source>getTimeRate(bank : CM_Bank; t: TimeStamp): CM_RateEntry;

vars
	found	: Boolean;
	retVal	: CM_RateEntry;
	iter	: Iterator;
begin
	// code before 23582
	//return rateEntries.getAtKeyLeq(t);
	retVal := self.rateEntries.getAtKeyLeq(t);
	// 23582 add expiry date and ignore checks
	iter := self.rateEntries.createIterator;
	self.rateEntries.startKeyLeq(t, iter);
	found := false;
	while iter.back(retVal) do
		if retVal.ignoreThisEntry then
			continue;
		endif;
		if retVal.expiryTimestamp &lt;&gt; null and
		   retVal.expiryTimestamp &lt;= t then
			continue;
		endif;
		found := true;
		break;
	endwhile;
	if not found then
		retVal := null;
	endif;

	return retVal;
epilog
	delete iter;
end;</source>
        <Parameter name="bank" type="CM_Bank"/>
        <Parameter name="t" type="TimeStamp"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
