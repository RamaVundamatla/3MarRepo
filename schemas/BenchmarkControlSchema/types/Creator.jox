    <JadeMethod name="startSpawner" id="8877fad5-7274-4b69-bafa-e92e673a701a">
        <source>startSpawner(host:String);

vars
	retCode,i,j,k,iid,portNum:Integer;
	s,path,envName:String;
	sa:StringArray;
	proc:Process;
begin
	iid:=getInstanceIdForObject(process).Integer;
	process.sleep((iid mod 20)*1500+1000);
	create sa transient;
	portNum:=51700;  // number of first app server
	if app.computerName.toLower="cnwchcs73" then
//		path:="c:\thinbin_host\skidemo";	//SKIDEMO
		path:="c:\thinbin_host\skidemo";
	else
//		path:="c:\thinbin\skidemo";	//SKIDEMO
		path:="c:\thinbin\skidemo";
	endif;
	// allocate port numbers in instance order
	foreach proc in node.processes do
		if proc.persistentApp.name="Creator" then
//			app.logMessage(proc.String);
			if getInstanceIdForObject(proc)&lt;iid then
				i:=i+1;
			endif;
		endif;
	endforeach;
	portNum:=portNum+i;
	sa[1]:="ini="&amp;path&amp;"\skidemo.ini";
	sa[2]:="schema=SKIPTON app=Spawner";	//SKIDEMO
//	sa[3]:="AppServer=cnwchcs73";
	sa[3]:="AppServer=cnwchcs46";
	sa[4]:="AppServerPort="&amp;portNum.String;
	app.logMessage(process.String&amp;" "&amp;i.String&amp;" "&amp;sa[4]&amp;": "&amp;process.userCode&amp;"@"&amp;process.userInfo);
	node.createExternalProcess(path,path&amp;"\jade.exe",sa,null,true,false,retCode);
epilog
	delete sa;
end;</source>
        <Parameter name="host" type="String"/>
    </JadeMethod>
    <JadeMethod name="stopMyChildren" id="fe3ca3a1-4acc-4f91-b456-81685bb02ce9">
        <updating/>
        <source>stopMyChildren() updating;

vars
	checkfile:File;
	procid,retCode:Integer;
	result:String;
begin
	create checkfile;
	// Leave this here for now to check u want to execute the CreatorCleanup 
	checkfile.fileName:=app.getJadeInstallDir&amp;"\CreatorCleanup.ini";
		
	if checkfile.isAvailable then
		global.causeEvent(Bmk_Stop_Creator, true, myBmkControl.session);
		procid := call getCurrentProcessId;  
		node.createExternalProcess(null,'C:\thinbin\creator\CreatorCleanup.exe -c ' &amp; procid.String &amp; ' -d y -i y -s 5',null,null,true,true,retCode);
		result:=" CreatorCleanup ="&amp;retCode.String&amp;" "&amp;process.userCode&amp;"@"&amp;process.userInfo;
		app.logMessage(result);
		global.causeEvent(Bmk_Result, true, result);
	else
		global.causeEvent(Bmk_Result, true, checkfile.fileName&amp;" not found"&amp;" "&amp;process.userCode&amp;"@"&amp;process.userInfo);
	endif;
epilog
	delete checkfile;
end;</source>
    </JadeMethod>
    <JadeMethod name="stopRapHostCreatorCreator" id="f2a37fe2-3864-4adf-ac34-8fba1d9c0be0">
        <updating/>
        <source>stopRapHostCreatorCreator(sess:Integer) updating;

begin
	if global.allBmkControls[sess] &lt;&gt; null and global.allBmkControls[sess].rapHost.toLower = app.computerName.toLower then
		global.causeEvent(Bmk_Result, true, app.name&amp;" ("&amp;process.userCode&amp;"@"&amp;process.userInfo&amp;") terminating");
		terminate;
	endif;
end;</source>
        <Parameter name="sess" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="syncThinbin" id="864e5103-382f-4e7c-bc8a-76672c92369c">
        <updating/>
        <source>syncThinbin(sess:Integer) updating;

vars
	ff:FileFolder;  fn:FileNode;  f,g:File;
	localThinbin:String;
begin
	myBmkControl:=global.allBmkControls[sess];
	if app.name = "CreatorCreator" then  // always do it for CreatorControlApp
		if myBmkControl.owner &lt;&gt; userCode then  // don't do it for other people's CreatorCreators
			return;
		endif;

		targetSession:=sess;  // only do it on machines involved in this benchmark
		setInfo_Creator;
		//if myBmkControl.rapHost &lt;&gt; computerName and copies &lt;= 0 then
		if copies &lt;= 0 then
			return;
		endif;
	endif;
	
	process.sleep((instanceId mod 3) * 100);  // try to avoid clashes when using multiple sessions on one machine
	if computerName='cnwchcs73' then
		localThinbin:="c:\thinbin_host\"&amp;myBmkControl.envid;
	else
		localThinbin:="c:\thinbin\"&amp;myBmkControl.envid;
	endif;
	create ff;
	create f;
	create g;
	f.mode:=File.Mode_Input;
	f.shareMode:=File.Share_Read;  // "optimisation" for static files
	g.mode:=File.Mode_Output;
	f.kind:=File.Kind_Binary;
	g.kind:=File.Kind_Binary;
	f.usePresentationFileSystem:=false;
	g.usePresentationFileSystem:=true;

	// ensure local thinbin folder exists
	ff.fileName:=localThinbin;
	ff.usePresentationFileSystem:=true;
	if not ff.isAvailable then
		ff.make;
		global.causeEvent(Bmk_Result, true, computerName&amp;": made "&amp;localThinbin);
	endif;
	
	// ensure each file is up to date
	ff.fileName:=app.dbPath.replace("c_system", "c_misc\thinbin\"&amp;myBmkControl.envid);
	ff.usePresentationFileSystem:=false;
	foreach fn in ff.files where fn.isKindOf(File) and fn.name[fn.name.length-3:4] &lt;&gt; ".log" and fn.name.toLower &lt;&gt; "thumbs.db" do
		f.fileName:=fn.fileName;
		g.fileName:=localThinbin&amp;"\"&amp;fn.name;
		if g.isAvailable = false
		or fn.name.toLower &lt;&gt; "jade.ini" and f.lastModifiedTime &lt;&gt; g.lastModifiedTime
		or fn.name.toLower = "jade.ini"  and f.lastModifiedTime &gt; g.lastModifiedTime then
			if g.isAvailable = false then
				global.causeEvent(Bmk_Result, true, computerName&amp;": creating "&amp;g.fileName);
			else
				global.causeEvent(Bmk_Result, true, computerName&amp;": updating "&amp;g.fileName);
			endif;
			g.writeBinary(f.readBinary(f.fileLength));
			g.lastModifiedTime:=f.lastModifiedTime;
			f.close;
			g.close;
		endif;
		if fn.name.toLower = "jade.ini" then
			setAutoDownLoad(g.fileName);
			if myBmkControl.product = "CMIS3" or myBmkControl.product = "CMIS4" then  // jhp 20110217 skinny forms
				app.setProfileString(g.fileName, "Jade", "ShowUserInterrupt", "false");
				global.causeEvent(Bmk_Result, true, computerName&amp;": ShowUserInterrupt=false");
				process.sleep(200);
			endif;/**/
		endif;
	endforeach;
	global.causeEvent(Bmk_Result, true, computerName&amp;": syncThinbin done for "&amp;localThinbin);
	global.causeEvent(Bmk0_Sync_Thinbin*-1, true, sess);
epilog
	delete ff;
	delete f;
	delete g;
end;</source>
        <Parameter name="sess" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sysNotification" id="f146069f-0f28-424a-a1bc-6f0e78d90be5">
        <updating/>
        <source>sysNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;

begin
	// keep global in sync
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="133be1a3-d596-42ad-a540-f9681832b796">
        <updating/>
        <source>userNotification(eventType:Integer; oo:Object; tag:Integer; userInfo:Any) updating;

begin
	app.logMessage(method.qualifiedName
			&amp;" eventType="&amp;currentSchema.getConstantName(eventType.String)
			&amp;" theObject="&amp;oo.String  // .display.replace(CrLf,", ")
			&amp;" tag="&amp;tag.String
			&amp;" userInfo="&amp;userInfo.String); /**/
	if eventType = Bmk0_Stop_All_Mine and userInfo.String = userCode then
		global.causeEvent(Bmk_Result, true, app.name&amp;" ("&amp;process.userCode&amp;"@"&amp;process.userInfo&amp;") terminating");
		terminate;
	endif;

	if session = 0 then  // special CreatorCreator stuff
		if eventType = Bmk0_Start_Creators then
			startCreators(userInfo.Integer);

		elseif eventType = Bmk0_Show_Jade_Version then
			showJadeVersion(userInfo.Integer);

		elseif eventType = Bmk0_Start_Rap then
			startRap(userInfo.Integer);

		elseif eventType = Bmk0_Stop_RapHost_CreatorCreator then
			stopRapHostCreatorCreator(userInfo.Integer);

		elseif eventType = Bmk0_Start_SingleUserAppServer then
			startSingleUserAppServer(userInfo.Integer);

		elseif eventType = Bmk0_Start_SingleUser then
			startSingleUser(userInfo.Integer);
			
		elseif eventType = Bmk0_Fix_Environment_ID then
			fixEnvid(userInfo.Integer);

		elseif eventType = Bmk0_Start_SingleUserJdbUtil then
			startSingleUserJdbUtil(userInfo.Integer);

		elseif eventType = Bmk0_Sync_Thinbin and iAmTheFirst then
			syncThinbin(userInfo.Integer);

		elseif eventType = Bmk0_Start_Background_Monitor then
			startBackgroundMonitor(userInfo.Integer);

		elseif eventType = Bmk0_Save_Log_Files then
			saveLogFiles(userInfo.Integer);

		elseif eventType = Bmk0_Stop_My_Children and userInfo.String = userCode then
			stopMyChildren;

		elseif (eventType = Bmk0_Start_PerfMonLog or eventType = Bmk0_Stop_PerfMonLog) and iAmTheFirst then
			doPerfMonLog(userInfo.Integer, eventType);
	
		elseif eventType=Bmk_Stop_Creator and userInfo.Integer = 0 then
			global.causeEvent(Bmk_Result, true, app.name&amp;" ("&amp;process.userCode&amp;"@"&amp;process.userInfo&amp;") terminating");
			terminate;
		endif;
	
	elseif userInfo.Integer=session then  // normal Creator commands
		if eventType=Bmk_Start_App then
			startApp;
	
		elseif eventType=Bmk_Start_Fat_Client then
			startFatClient(userInfo.Integer);
	
		elseif eventType=Bmk_Start_Spawner then
			startSpawner(userInfo.String);
	
		elseif eventType=Bmk_Stop_Creator then
			global.causeEvent(Bmk_Result, true, app.name&amp;" ("&amp;process.userCode&amp;"@"&amp;process.userInfo&amp;") terminating");
			terminate;
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="oo" type="Object"/>
        <Parameter name="tag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="writeSummaryGeneratorInfo" id="477ec1fc-dcc4-4e12-847a-c2bffe1e2710">
        <source>writeSummaryGeneratorInfo(s:String);

vars
	outFile:File;
begin

	create outFile;
	outFile.usePresentationFileSystem := true;
	outFile.mode:= 3;
	outFile.fileName:= 'C:\thinbin\tools\summarygenerator.txt';
	outFile.writeLine(s);
	
	outFile.close;

epilog
	delete outFile;
end;
</source>
        <Parameter name="s" type="String"/>
    </JadeMethod>
</Class>
