<Class name="CnEcHtmlTextBoxTag" id="417c1fb2-59bd-4c9c-889f-66bc36bb5384">
    <superclass name="CnEcHtmlInputTag"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
