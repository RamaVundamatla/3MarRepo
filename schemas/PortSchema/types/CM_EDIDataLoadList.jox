    <JadeMethod name="createPreNotes" id="8e9625e6-835a-477a-972c-ad3a09ba5df8">
        <updating/>
        <source>createPreNotes(_allTIs : ObjectArray; _passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		3 August 2009 by cnwjo3
//
// Purpose:		Create PreNotes from CM_EDILoadListTI, CCMS 1084
//
// Parameters:	_allTI is a collection of CM_EDILoadListTI
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 30 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
// --------------------------------------------------------------------------------
vars
	intFaceArray		: CMIF_TIObjectArray;
	obj					: Object;
	cmifPrenoteObj		: CMIF_PreNote;
	carrierObj			: CM_Carrier;
	obj2 : Object;
	fileTypeObj			: CM_EDIFileType;
	isNotGeneratePin	: Boolean;
	
	termEmailDefaults	: CM_PINObjectDefaultEmail;
	emailDefaults		: CM_PINObjectDefaultEmail;
	emailArray			: ObjectArray;
begin
	create intFaceArray transient;
	create emailArray transient;
	
	foreach obj in _allTIs do
		if obj.isKindOf(CM_EDILoadListTI) then
			isNotGeneratePin := false;
			
			if obj.CM_EDILoadListTI.myEDIData &lt;&gt; null then
				if obj.CM_EDILoadListTI.myEDIData.myEDIFile &lt;&gt; null then // ediFileArray.size &gt; 0 then // ccms1117 cnwrs1 29 Apr 2010
					fileTypeObj := obj.CM_EDILoadListTI.myEDIData.myEDIFile.myEDIFileType; // ccms1117 cnwrs1 29 Apr 2010
					if fileTypeObj.isKindOf(CM_EDIFileTypeUser) then
						if fileTypeObj &lt;&gt; null then
							isNotGeneratePin := not fileTypeObj.CM_EDIFileTypeUser.getConfig(GeneratePins).Boolean;
						endif;
					endif;
				endif;
			endif;
		
			//create the prenote interface object and add it from the iterface array
			cmifPrenoteObj := self.setPreNoteInterfaceObject(obj.CM_EDILoadListTI,isNotGeneratePin);
			intFaceArray.add(cmifPrenoteObj);
			cmifPrenoteObj.myTerminal := self.getMyTerminal();
			
			//since its on a ship we make the assumption its transport mode will be road
			if cmifPrenoteObj.CMIF_PreNote.transportMode.trimBlanks = TI_TRANSMODE_ROAD_STR then
				termEmailDefaults := cmifPrenoteObj.myTerminal.getEmailDefaultsSettings( PINEmail_Prenote );
				emailDefaults 	  := termEmailDefaults.cloneSelf(true).CM_PINObjectDefaultEmail;
				emailArray.add(emailDefaults);
				
				carrierObj := app.myRoot.allCarriers[cmifPrenoteObj.carrier];
				
				if carrierObj &lt;&gt; null then
					emailDefaults.setAddresses( cmifPrenoteObj.myTerminal, carrierObj, null, PINEmail_Prenote );
				endif;
				
				if emailDefaults &lt;&gt; null then
					cmifPrenoteObj.setEmailDefaultObject(emailDefaults);
				endif;			
			endif;
			foreach obj2 in _allTIs do
				if obj2.isKindOf(CM_EDISealTI) and obj2.CM_EDISealTI.id = obj.CM_EDILoadListTI.id then
					obj2.CM_EDISealTI.setSealNumCMIFReceive(cmifPrenoteObj);
				endif;
			endforeach;
		endif;
	endforeach;

	app.myTrxCA.trxCreateEDIPreNotes(intFaceArray, false, self, _passport); //ccms1845
	
//	if app.myPassport.trxCompletedOK() then
//		app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_DBLOADED); //ccms1845
//		beginTransaction;
//		self.status := CM_EDIFile.EDI_STATUS_DBLOADED;
//		app.cmsCommitTransaction(_passport);
//	endif;	
	
epilog
	intFaceArray.purge();
	delete intFaceArray;
	
	if emailArray &lt;&gt; null then
		emailArray.purge();
		delete emailArray;
	endif;	
end;</source>
        <Parameter name="_allTIs" type="ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createTBA" id="6dd7b316-31a3-4849-8cd8-d727c99d3638">
        <updating/>
        <source>createTBA(_allTIs: ObjectArray; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2019	jlgmp6	Initial creation	TFS 45590

*/

vars
	cmifTBA: CMIF_TBACargo;
	intFaceArray: CMIF_TIObjectArray;
	obj: Object;

begin

	create intFaceArray transient;
	
	foreach obj in _allTIs where obj.isKindOf(CM_EDILoadListTI) do
		cmifTBA := self.setTBAInterfaceObject(obj.CM_EDILoadListTI);
		intFaceArray.add(cmifTBA);
		cmifTBA.myTerminal := self.getMyTerminal();
	
	endforeach;
	app.myTrxCA.trxCreateEDIPreNotes(intFaceArray, false, self, _passport);

epilog

end;</source>
        <Parameter name="_allTIs" type="ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doesReceiptTransportModeExist" id="323af739-216c-4de7-806c-05d5019ac981">
        <source>doesReceiptTransportModeExist(_receiptTransportMode: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
6 April 2023	navra1	Initial creation for 57263

*/

vars
	ediTi: CM_EDITrackedItem;
begin
	foreach ediTi in self.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDICargoTI) then
			if app.transportModeENumToString(ediTi.CM_EDICargoTI.receiptTransportMode).toUpper().compareEql(_receiptTransportMode.toUpper(), true, false, null) then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_receiptTransportMode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findCommodityCode" id="6c862ae1-9fa2-4a57-a0b0-1d561917355e">
        <source>findCommodityCode(_ediTI : CM_EDILoadListTI) : String;
// --------------------------------------------------------------------------------
// Created:		4 August 2009 by cnwjo3
//
// Purpose:		Find the commodity code from the EDI TI commodity.  First
//				look through the commodities dictionary, if not found
//				use the default commodities (found in terminal config, not system config)
// 22/11/2012	cnwmh5	#30756 - Add code for null iso type to set commodity to default mtCommodity
vars
	commodityCode	: String;
	tempCommodity	: CM_Commodity;
	isoType			: CM_ISOType;
	
	mtCmdty,
	defCmdty,
	refCmdty,
	hazCmdty		: String;
begin
	//hopefully translation has already occurs and commodities have been matched up
	tempCommodity := app.myRoot.allCommodities[_ediTI.commodity];
	if tempCommodity &lt;&gt; null then
		commodityCode := tempCommodity.code;
	endif;
	
	/*  This code has been removed since russell believes you'll never get a match
	//	via the description.  Makes since, it seems a little dangerous anyways
	//
	//maybe translation never occurs, we only have descriptions
	//try to match up.  
	if commodityCode = null then
		foreach tempCommodity in app.myRoot.allCommodities discreteLock do 
			if tempCommodity.description = _ediTI.commodity then
				commodityCode := tempCommodity.code;
				break;
			endif;
		endforeach;
	endif;
	*/
	
	//ok, couldn't find code in dictionary.  Maybe there is no translation for commodities
	//set the default commodity depending on the type of container
	if commodityCode = null then
		app.getTerminalDefCmdty(mtCmdty, defCmdty, refCmdty, hazCmdty);
		isoType := app.myRoot.allISOTypes[_ediTI.isoType];
		if isoType = null then										// 22/11/2012 cnwmh5 #30756
			commodityCode := mtCmdty;
		elseif isoType.isReefer then
			commodityCode := refCmdty;
		elseif _ediTI.hazardous = true then
			commodityCode := hazCmdty;
		elseif _ediTI.fullOrMT = "E" then
			commodityCode := mtCmdty;
		else
			commodityCode := defCmdty;
		endif;
	endif;
	
	return commodityCode;
end;</source>
        <Parameter name="_ediTI" type="CM_EDILoadListTI"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDataTypeFromDefName" id="325dee92-ad54-49e4-bfda-4cea450cbf67">
        <source>getDataTypeFromDefName(_name: String): Integer;
