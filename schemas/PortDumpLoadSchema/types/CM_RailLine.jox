<Class name="CM_RailLine">
    <JadeMethod name="exportPDXMLMyReferences" id="6b61ddaa-c886-4d86-aaf6-77e4fa895da1">
        <source>exportPDXMLMyReferences(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars

begin
	// before we write out the rail area we write out which terminal we are in
	if _property.name = CM_RailLine::myRailArea.name then
		_file.writeLine("&lt;"&amp;CM_Rail::myTerminal.name&amp;"&gt;"&amp;self.myRailArea.myTerminal.theKey&amp;"&lt;/"&amp;CM_Rail::myTerminal.name&amp;"&gt;");
	endif;
	inheritMethod(_file, _objArray, _property, _object);
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="f319a6b9-e264-4224-8931-d87cda751a0f">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_RailLine::myRailArea.name then
		return app.getMyTerminalDO_NOT_USE().allTerminalAreaMastersById[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
