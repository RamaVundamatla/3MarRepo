    <JadeMethod name="doDelete" id="6dd7d1e1-612b-4a25-9d33-5c7c1b5c5a13">
        <updating/>
        <source>doDelete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwer1	Initial creation

*/

vars
	lstObject : Object;
	
	machineType :	CM_MachineType;
	termMachConfig : CM_RTTermMachTypeConfig;
	realRTVehicleConfig : CM_RTVehicleConfig;
	machine 	: CM_Machine;
begin
	if self.lstObject.listIndex &lt; 0 then
		app.msgBox(app.getErrorString(Please_select_item_delete),app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;
	
	lstObject:=self.lstObject.listObject;
	if lstObject.isKindOf(CM_Terminal) then
		app.msgBox(app.getErrorString(Cant_Delete_Term_RTVConfig),app.getErrorString(Error), MsgBox_OK_Only);
		return;
		
	elseif lstObject.isKindOf(CM_MachineType) then
		machineType:=lstObject.CM_MachineType;
		termMachConfig:=self.myTerminal.allRTTermMachTypeConfigs[machineType];
		if termMachConfig &lt;&gt; null then
			realRTVehicleConfig:=termMachConfig.myRTVehicleConfig;
		endif;
	elseif lstObject.isKindOf(CM_Machine) then
		machine:=lstObject.CM_Machine;
		realRTVehicleConfig:=machine.myRTVehicleConfig;
	endif;
	
	if realRTVehicleConfig = null then
		app.msgBox(app.getErrorString(Cant_delete_inherit_settings),app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;
	
	app.myTrxDA.trxDeleteRTVehicleConfig(realRTVehicleConfig,app.myPassport);
	
	self.loadDataFromObject(lstObject);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doEditCriteria" id="02400ea2-ea39-449f-8d66-b8f37eee6747">
        <updating/>
        <source>doEditCriteria() updating;
/* ---------------------------------------------------------------------------
Created:	15 September 2010	by cnwvu1

Purpose:	CCMS MES 1080
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	
begin
	//epr refactored part of tfs  1882 13/5/16
	if self.myAssistant.showCritieriaMaintForm(self,self.myTerminal,CMUI_YACriteriaMaintForm.RTConfigCriteria,self.allCriteria) then
		self.displayCriteriaDesc();
	endif;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="2fc11621-81dd-4152-a57b-27274d35b55f">
