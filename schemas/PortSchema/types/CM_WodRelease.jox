    <JadeMethod name="getWagons" id="9c66f83a-8681-4da5-ba48-c44d352582d4">
        <source>getWagons(_wagons: CM_WagonSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	train 	: CM_Train;
	ti		: CM_TrackedItem;
	wagon	: CM_Wagon;
begin
	//14/01/2025	navkc1 JIRA Bug MTN-33804
	foreach ti in self.allSelectedTIs discreteLock do
		
		wagon := ti.getMyWagonRelease();
		
		if wagon = null then
			wagon := ti.getMyWagon();
		endif;
		
		if wagon = null then
			continue;
		endif;
		
		_wagons.tryAdd(wagon);
	endforeach;
	
	if _wagons.isNotEmpty() then
		return;
	endif;
	
	//14/01/2025	navkc1 JIRA Bug MTN-33804 - If no wagons found from the TI then only we return then wagons of the selected train
	train := self.myTrain;
	
	if train &lt;&gt; null then
		train.allWagonsByIdInward.copyNoDuplicates(_wagons, false);
		train.allWagonsByIdOutward.copyNoDuplicates(_wagons, false);
	endif;

epilog

end;</source>
        <Parameter name="_wagons" type="CM_WagonSet" usage="input"/>
    </JadeMethod>
