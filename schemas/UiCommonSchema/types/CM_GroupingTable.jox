    <JadeMethod name="addColumns" id="25a51632-c1e6-427c-97ea-40a3dfebabfb">
        <updating/>
        <source>addColumns() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin	
	inheritMethod();
	
	self.addGroupingColumn;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addGroupColsToJadeSortOrder" id="be094df1-7dc4-428a-87b8-98e9a1192648">
        <source>addGroupColsToJadeSortOrder() protected;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entRow	:EntTableRow;
	col		:Integer;
begin
	// add in our grouping colums
	entRow 	:= self.getGroupingETRow;

	col := self.getColumnByRowName(entRow.name);	// par 21171

	self.sortColumn[1]	:= col;  
	self.sortAsc[1] 	:= true;
	self.sortCased[1]	:= false;
	self.sortType[1] 	:= self.convertInputTypeToSortType(entRow.inputType);
	
	
	// now add in the hiden column at the end
	col := self.getColumnByHeading(self.Level_Col_Name);	// par 21171
	
	
	self.sortColumn[2]	:= col;		// par 21171   
	self.sortAsc[2] 	:= false;	// detail = 0, level 1 heading = 1 etc
	self.sortCased[2]	:= false;
	self.sortType[2] 	:= Table.SortType_Numeric; 
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addGroupingColumn" id="903f3854-cd4f-4815-890c-ff9777a9cbd2">
        <updating/>
        <source>addGroupingColumn() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/10/2009	cnwcs5		par 21171
// ---------------------------------------------------------------------------
vars
	group	:EntTableRow;
	col		:Integer;
begin
	group := self.getGroupingETRow;
	
	if group &lt;&gt; null then
		if not self.allTblDataEntRows.includes (group) then
			self.zAddColumn (group.getShortHeading(self.myTerminologyCargoBOLType, self.myTerminologyTerminal, app.myCurrentLocale),
								group.name, self.SortColInputType);
			self.allTblDataEntRows.add (group);	// par 21171
		endif;
		// now add a hidden column to use to indicate group level
		// detail lines will be null for this column
		if not self.allTblDataColHeadings.includes (self.Level_Col_Name) then
			self.addHiddenSortColumn (col);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addHiddenSortColumn" id="bb4a3cf4-04d0-42eb-bb3c-168304483faf">
        <updating/>
        <source>addHiddenSortColumn(_sortColumn :Integer output) updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	col	: JadeTableColumn;
begin
	self.zAddColumn (self.Level_Col_Name, null, self.SortColInputType);
end;</source>
        <access>protected</access>
        <Parameter name="_sortColumn" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="addItemObject" id="76ea70b5-f4d1-44f4-a6dd-8ebaac621a5c">
        <updating/>
        <source>addItemObject(_obj: Object; _str: String): Integer updating;
// ---------------------------------------------------------------------------
// Created:     11 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	group	:EntTableRow;
begin
	group := self.getGroupingETRow;

	if group &lt;&gt; null then 
		// add a heading for the group if it is not already there
		self.doGroupHeadings (_obj, group);
	endif;

	return inheritMethod(_obj, _str);

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addItemObjectAt" id="205d59b8-7c96-4dde-bc01-4d118ad1479e">
        <updating/>
        <source>addItemObjectAt(_obj: Object; _str: String; _rowIdx: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	group	:EntTableRow;
begin
	group := self.getGroupingETRow;

	if group &lt;&gt; null then 
		self.doGroupHeadings (_obj, group);
	endif;	
	
	inheritMethod(_obj, _str, _rowIdx);

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_str" type="String"/>
        <Parameter name="_rowIdx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addTableObjectsMemberKeys" id="ea175195-60fa-4646-8fbe-9c42c8d3e80b">
        <updating/>
        <source>addTableObjectsMemberKeys(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cols		: Integer;
	dd 			: CM_ExtKeyDynaDictionary;
	entRow	 	: EntTableRow;
begin
	dd := self.allTableObjects;
	
	if dd.noKeys() then
		// defintion incomplete
	else
		dd.clear();
		dd.clearKeys();
	endif;
	
	// set the member keys form the selected sort columns
	// caseInsensitive := true; not used - only ever set to true
	
	cols := self.getNumberOfSortColumns;
	
	if cols &gt; self.maxSortColumns then
		cols := self.maxSortColumns;
	elseif cols = 0 then
		return false;
	endif;
	
	// 12/08/2009 - moved code below to its own method
	self.zAddTableObjectsMemberKeys (cols, dd);

	dd.endKeys(true);
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
