    <JadeMethod name="getParentDefn" id="10e6b2cc-48f8-497b-a287-0c6935e94fc8">
        <source>getParentDefn(): CM_DeckItem;
/*
Purpose:			
Date		Who		Reason
08 December 2011	cnwab1	Initial creation
*/

vars

begin
	if self.myLanePositionController = null then
		return null;
	elseif self.myLanePositionController.myLaneController = null then
		return null;
