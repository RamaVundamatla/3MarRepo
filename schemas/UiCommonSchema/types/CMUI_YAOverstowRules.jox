	self.cmbVoyageLater.left := self.lstAttributes.left;
	self.chkVoyageJobs.left := self.lstAttributes.left;
	self.lblLaterVoyages.left := self.lblAttributes.left;
	self.cmbVoyageLater.top := self.lstAttributes.top + self.lstAttributes.height + (self.VerticalSpacing * 3);
	self.lblLaterVoyages.top := self.cmbVoyageLater.top;
	self.chkVoyageJobs.top := self.cmbVoyageLater.top + self.cmbVoyageLater.height + self.VerticalSpacing;
end;</source>
