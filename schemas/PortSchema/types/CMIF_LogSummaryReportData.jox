    <JadeMethod name="getLogLocation" id="a8ce4d83-6a65-4789-9b1c-079eb1cf554e">
        <source>getLogLocation() : CM_LogController;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		16 November 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// 16/11/2010 CCMS JML 1115 PAR26245 cnwsh3
// For flattening report structure for Log Summary (CM_TrackedItemView)
//----------------------------------------------------------------------
vars
	location : CM_LocationsController;
	sohLocation : CM_SOHLocation;
begin
	sohLocation := self.mySOHLocation;
	
	if sohLocation = null then
		return null;
	endif;
	
	location := sohLocation.myLocationsController;
	
	if location.isKindOf(CM_LogController) then
		return location.CM_LogController;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_LogController"/>
    </JadeMethod>
    <JadeMethod name="getLogSpecies" id="0f8bae7b-e3ee-4481-89f4-08ae4a96b354">
        <source>getLogSpecies() : CM_LogSpecies;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		16 November 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// 16/11/2010 CCMS JML 1115 PAR26245 cnwsh3
//----------------------------------------------------------------------
vars

begin
	if self.myProduct &lt;&gt; null and self.myProduct.isKindOf(CM_ProductLog) then
		return self.myProduct.CM_ProductLog.myLogSpecies;
	endif;
	
	return null;

end;</source>
        <ReturnType type="CM_LogSpecies"/>
    </JadeMethod>
