vars
	cmbConsignee:ComboBox;
	tblExtra:Table;
begin
	cmbConsignee:=myGTE_InOutForm_2.getPropertyValue('cmbConsignee').ComboBox.getControl(1);
	cmbConsignee.listIndex:=app.atcgGetComboStringIndex(cmbConsignee, 1, 'Fairwood Meat Works Ltd	FWS', 4);
	cmbConsignee.closeup(cmbConsignee);
	cmbConsignee:=myGTE_InOutForm_2.getPropertyValue('cmbConsignee').ComboBox.getControl(1);
	tblExtra:=myGTE_InOutForm_2.getPropertyValue('tblExtra').Table.getControl(1);
	app.doWindowEvents(shortPause);
	cmbConsignee.listIndex:=app.atcgGetComboStringIndex(cmbConsignee, 1, 'Fairwood Meat Works Ltd	FWS', 4);
	tblExtra.accessCell(52, 2).text:='Fairwood Meat Works Ltd	FWS';
	cmbConsignee.click(cmbConsignee);  // 16:06:22
	return 0;
end;</source>
        <ReturnType type="Integer"/>
