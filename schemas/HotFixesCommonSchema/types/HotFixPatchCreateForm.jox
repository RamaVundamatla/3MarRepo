	self.cmb_Customer.addItem('Gulftainer Umm Qasar');
	//self.cmb_Customer.addItem('Gulftainer Ruwais');					// TFS 38497
	//self.cmb_Customer.addItem('Gulftainer Recife');					// TFS 38497
	self.cmb_Customer.addItem('Hutchison Ajman');
