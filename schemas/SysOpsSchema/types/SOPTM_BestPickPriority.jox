    <JadeMethod name="doMnuContext1Click" id="b77ce0dc-cc49-4acd-9120-47a80ab09af5">
        <updating/>
        <source>doMnuContext1Click(theMenuItem: MenuItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation  JIRA-35632

*/

vars
	theResult : Integer;
begin

	inheritMethod(theMenuItem);
	if 	app.msgBox(app.getErrorString(Are_You_Sure) , app.getErrorString(Updat_onsit_cargo_best_pick_pr), MsgBox_Yes_No )  = MsgBox_Return_Yes then
		
		while true do	
			app.mousePointer := Window.MousePointer_HourGlass;
			app.myTrxUA.trxUpdateBestPickOnsite(self.myForm.myTerminal,app.myPassport);
			if not app.myPassport.trxCompletedOK then
				app.mousePointer := Window.MousePointer_Default;
				theResult := app.showErrorWarningDialog(app.getErrorString(Updat_onsit_cargo_best_pick_pr), app.myPassport, ErrWarnMode_AddUpdate);		
				if app.myPassport.noErrors and theResult = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;		
			break;			
		endwhile;
	endif;
	
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="28b6cf49-7c0f-4f4a-9d1d-ae3f2bbe861e">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation  JIRA-35632

*/

vars
	proxy						: CM_BestPickPriority;
	code						: String;
	priority,
	bestPickDateType 			: Integer; 
	bestPickDateTypeDesc		: String;
	form 						: SOP_TableMaintForm;
	table						: CM_EntryTable;	
	array						: CMIF_Array;
	
begin
  	form 	:= self.myForm;
	table	:= form.tblInput1;
	
	code 					:= table.getValueByName(ETRow_Code).String;
	priority			:= table.getValueByName(ETRow_Priority).Integer;
	bestPickDateTypeDesc:=table.getValueByName(ETRow_BestPickDateType).String;
	bestPickDateType	:= CM_BestPickPriority@getBestPickDateTypeFromDesc(bestPickDateTypeDesc).Integer;
	
	create array transient;
	self.getCriteriaAllCMIF( array );
	
	if form.myProxyObject = null then
		if form.mode = form.Mode_Add then
			create form.myProxyObject as CM_BestPickPriority transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxy := form.myProxyObject.CM_BestPickPriority;
	
	proxy.setProxy(code,  priority, bestPickDateType, form.myTerminal);	
							
	if form.mode = form.Mode_Add then
		app.myTrxCA.trxCreateBestPickPriority(proxy, array, form.myCurrentObject, app.myPassport);
	elseif form.mode = form.Mode_Update then
		app.myTrxUA.trxUpdateBestPickPriority(proxy, array, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; form.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
	
epilog
	if array &lt;&gt; null then
		array.purge;
	endif;
	
	delete array;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowCriteriaForm" id="26cdf4e3-d4c5-46e2-88d3-a6d74faa39f6">
        <source>doShowCriteriaForm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation  JIRA-35632

*/

vars
	table : CM_EntryTable;
begin
	table 	:= self.myForm.tblInput1;									

	if self.myForm.myAssistant.showCritieriaMaintForm(null,self.myForm.myTerminal,CMUI_YACriteriaMaintForm.BestPickCriteria, self.allCriteria) then
		table.setValueByName(ETRow_Criteria, self.getCriteriaText());
	endif;	

epilog

end;</source>
    </JadeMethod>
