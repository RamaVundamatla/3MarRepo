    <JadeMethod name="checkKeyMethod" id="32d10834-ab0a-436e-8d17-7c628a862189">
        <source>checkKeyMethod(classname, methodname : String);
/*

Purpose:	TELL Andrew if someone is changing any key methods		

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2019	NAVAB1	Initial creation

*/

vars

	sch : Schema;
	cls : Class;
	mth : Method;
	who : String;
	whn, now : TimeStamp;
	
begin
	sch := rootSchema.getSchema("PortSchema");
	
	cls := sch.getClass(classname);
	mth := cls.getMethod(methodname);

	who := mth.getModifiedBy();
	whn := mth.cnEcGetModifyTimeStamp();
	
	self.assertTrueMsg((now.addDays(-2) &gt;= whn), classname &amp; "::" &amp; methodname &amp; " - HAS BEEN CHANGED BY " &amp; who &amp; " on " &amp; whn.String);
	


epilog

end;</source>
        <Parameter name="classname" type="String"/>
        <Parameter name="methodname" type="String"/>
    </JadeMethod>
    <JadeMethod name="createContract" id="e1ec805a-9560-4f23-b0b3-f92bfd70a0a9">
        <updating/>
        <source>createContract(_debtor : CM_Debtor; _contractId : String; _active, primary : Boolean; _fromTS, _toTS : TimeStamp; _purgeContracts : Boolean) : CM_InvoiceContract updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Nov 2023 navrv30 #61154: FR | 54089 - EUP - Invoice Contracts - EDI upload for Contract ID

*/

vars
	pxyCon, realCon : CM_InvoiceContract;
	terminal : CM_Terminal;
	bank : CM_Bank;
	debtor : CM_Debtor;
begin
	debtor := _debtor;
	terminal := self.getTerminal();
	bank := terminal.getDefaultCompanyBank();

	if _purgeContracts then
		self.deleteAllContractsForDebtor(debtor);
	endif;
	
	create pxyCon transient;
	pxyCon.setProxy(_active,_contractId, _fromTS, _toTS, primary, bank, terminal, debtor, "Generated By Unit Test");
	
	app.myTrxCA.trxCreateInvContract(pxyCon, realCon, app.myPassport);
	
	assertNoTrxErrorsOrWarnings();
	assertTrueMsg(realCon.contractId = _contractId, "Contract Id should be " &amp; _contractId &amp; ", it is &gt;&gt;&gt;" &amp; realCon.contractId &amp; "&lt;&lt;&lt;");
	assertTrueMsg(realCon.primary = primary, "Contract should NOT be PRIMARY");
	assertTrueMsg(realCon.active = _active, "Contract should NOT be ACTIVE");
	assertTrueMsg(realCon.myBusinessUnit &lt;&gt; null, "BANK is null");
	assertTrueMsg(realCon.myBusinessUnit = bank, "BANK is wrong");
	assertTrueMsg(realCon.myTerminal &lt;&gt; null, "TERMINAL is null");
	assertTrueMsg(realCon.myTerminal = terminal, "TERMINAL is wrong");
	assertTrueMsg(realCon.myDebtor &lt;&gt; null, "DEBTOR is null");
	assertTrueMsg(realCon.myDebtor = debtor, "DEBTOR is wrong");
	assertTrueMsg(realCon.description = "Generated By Unit Test", "Description is wrong");
	
	return realCon;
epilog
	delete pxyCon;
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_contractId" type="String"/>
        <Parameter name="_active" type="Boolean"/>
        <Parameter name="primary" type="Boolean"/>
        <Parameter name="_fromTS" type="TimeStamp"/>
        <Parameter name="_toTS" type="TimeStamp"/>
        <Parameter name="_purgeContracts" type="Boolean"/>
        <ReturnType type="CM_InvoiceContract"/>
    </JadeMethod>
    <JadeMethod name="deleteAllContractsForDebtor" id="e9dd0c68-924e-462e-9bf6-ce474a86dd5a">
        <updating/>
        <source>deleteAllContractsForDebtor(_debtor : CM_Debtor) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Nov 2023 navrv30 #61154: FR | 54089 - EUP - Invoice Contracts - EDI upload for Contract ID

*/

vars
	
begin
	if _debtor = null then
		return;
	endif;
	
	beginTransaction;
	_debtor.allInvoiceContracts.purge();
	commitTransaction;
	
epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="initTxnControllerForEdit" id="2de1e2e6-4408-4775-98f8-aa696a92fbbc">
        <source>initTxnControllerForEdit(txnController : CMIF_TITransactionController io; txn : CM_TITransaction input);
/*

Purpose:			initialise the passed in transaction controller with the values from the transaction

Parameters:			

Return Value:		

Date				Who		Reason
14 November 2019	jlgzm1	Initial creation

*/

vars

begin
	txnController.ammended := txn.ammended;
	txnController.dateTime := txn.dateTime;
	txnController.deleted := txn.deleted;
	txnController.freightForwarderCode := txn.freightForwarderCode;
	txnController.noCharge := txn.noCharge;
	txnController.operatorCode := txn.operatorCode.trimBlanks;
	txnController.superseded := txn.superseded;
	txnController.type := txn.type;
	txnController.myToDoTask := txn.myToDoTask;
	txnController.urNumber := txn.urNumber;
	txnController.userGenerated := txn.userGenerated;
	txnController.userId := txn.userId.trimBlanks;
	txnController.myTerminal := txn.myTerminal;
	txnController.myTrackedItem := txn.myTrackedItem;
	txnController.totalQuantity := txn.totalQuantity;
	txnController.totalVolume := txn.totalVolume;
	txnController.totalWeight := txn.totalWeight;
epilog

end;</source>
        <Parameter name="txnController" type="CMIF_TITransactionController" usage="io"/>
        <Parameter name="txn" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tChangeIMEXToStorage" id="c4e927bb-dabe-4347-96b4-4a3776c5f31f">
        <source>tChangeIMEXToStorage();
// jlgmd1
// cnwrh7
/*

Purpose:			This Unit Test is here to test that cargo items with an IMEX changed to Storage, from anything else,
					have their Voayge set to the null voyage. By using the config option 'ClearVoyageIMEXStorage'.

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2013	cnwmc5	Initial creation

*/
constants
	TI_CODE				: String = "MJCTI00001";
	VES_CODE			: String = "MJCVES0001";
	VOY_CODE			: String = "MJCVOY0001";
vars
	op 					: CM_Operator;
	ti, pxyTI			: CM_TrackedItem;
	bs 					: CM_BlockStack;
	ves					: CM_Vessel;
	voy					: CM_Voyage;
	
	extraParams			: CMIF_TIUpdateExtraParams;
	
	txnControllerDict 	: CMIF_TITxnContrlrByTypeDTDict;
begin
	create extraParams transient;
	create txnControllerDict transient;
	
	//Set terminal config option required for clearing voyage when imex changed to storage
	self.setTerminalConfig(ClearVoyageIMEXStorage, true);
	self.assertTrue(self.getTerminalConfig(ClearVoyageIMEXStorage).Boolean);
	
	//Delete old objects
	self.deleteVoyage(VOY_CODE);
	self.deleteVessel(VES_CODE);
	ti := self.getTrackedItem(TI_CODE);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	
	//Create all the required new objects
	op := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	bs := self.getTerminalArea("UT_BS1").CM_BlockStack;
	ti := self.addContainerAtLocation(TI_CODE, op, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.allLocationsControllers.first);
	ves := self.addVesselCellular(VES_CODE, op);
	voy := self.addVoyageWithContainerStructur(VOY_CODE, ves.code, op.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	/* 
		*****************************
	Test changing the imex from export to 
	storage to ensure it changes the voyage
			to the null voyage
		*****************************
	*/
	
	//Update the newly created TI's voayge
	self.opts.purge();
	self.opts.addAssoc("Voyage", voy);
	self.updateTI(ti);
	
	//Assert that the imex is export and the voyage is MJCVOY0001 before starting
	self.assertEqual(ti.getImExStatus(), TI_IMEX_STATUS_EXPORT);
	self.assertEqual(ti.myVoyage, voy);
	
	//Create the proxy TI and change its iemx to storage
	pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
	pxyTI.createTITxnControllers(txnControllerDict);
	pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_STORAGE);
	
	//Call the trx used on the cargo enquiry form
	app.myTrxUA.trxUpdateTIandExtraInfo(pxyTI, TI_UPDMODE_NORMAL, extraParams, txnControllerDict, null, app.myPassport);
	
	//Assert that the imex has changed to storage and the voyage is now the null voyage
	self.assertEqual(ti.getImExStatus(), TI_IMEX_STATUS_STORAGE);
	self.assertEqual(ti.myVoyage, self.getTerminal().getNullVoyage());
	
	/* 
		*****************************
	Test changing the voyage from the null 
	  voayge to any other to ensure it 
		changes the imex to export
		*****************************
	*/
	
	//Create the proxy TI and change its voayge back to MJCVOY0001 from the null voyage
	delete pxyTI;
	pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
	pxyTI.zSetPxyVoyage(voy, voy.code);
	
	//Call the trx used on the cargo enquiry form
	app.myTrxUA.trxUpdateTIandExtraInfo(pxyTI, TI_UPDMODE_NORMAL, extraParams, txnControllerDict, null, app.myPassport);
	
	//Assert that the imex has changed back to export and the voyage is now MJCVOY0001
	self.assertEqual(ti.getImExStatus(), TI_IMEX_STATUS_EXPORT);
	self.assertEqual(ti.myVoyage, voy);
epilog
	delete pxyTI;
	delete extraParams;
	delete txnControllerDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="tChangeIMEXToStorageBulk" id="fe03b95b-5f72-4a58-89f5-cced6522d368">
        <source>tChangeIMEXToStorageBulk();
// jlgmd1
// cnwrh7
/*

Purpose:			This Unit Test is here to test that cargo items with an IMEX changed to Storage, from anything else,
					have their Voayge set to the null voyage. By using the config option 'ClearVoyageIMEXStorage'.

Parameters:			

Return Value:		

Date			Who		Reason
17 July 2013	cnwmc5	Initial creation
08 July 2025	jlizm1	MTN 35208 Error for invalid transit Status when bulk updating imex status

*/
constants
	TI_CODE_MASTER		: String = "MJCTI10001";
	TI_CODE_1			: String = "MJCTI10002";
	TI_CODE_2			: String = "MJCTI10003";
	TI_CODE_3			: String = "MJCTI10004";
	VES_CODE			: String = "MJCVES1001";
	VOY_CODE			: String = "MJCVOY1001";
vars
	masterTI, 
	pxyMasterTI,
	ti1,
	ti2,
	ti3,
	pxyTI1,
	pxyTI2,
	pxyTI3				: CM_TrackedItem;
	op 					: CM_Operator;
	bs 					: CM_BlockStack;
	ves					: CM_Vessel;
	voy					: CM_Voyage;
	
	extraParams			: CMIF_TIUpdateExtraParams;
	txnControllerDict 	: CMIF_TITxnContrlrByTypeDTDict;
	updateController	: CMIF_TIUpdateController;
	bulkEditController	: CMIF_BulkEditController;
	
	allPxys				: CM_ObjectSet;
	
	allStopsToAdd,
	allStopsToRemove,
	allStopsToUpdate	: CM_StopsByIdDict;
	
	allTasksToAdd,
	allTasksToComplete,
	allTasksToRemove	: IntegerArray;
	
	hasEditedToDoTasks	: Boolean;
	
	editObject			: CMIF_EditObject;
	
begin
	create extraParams transient;
	create txnControllerDict transient;
	create bulkEditController transient;
	create allPxys transient;
	create allStopsToAdd transient;
	create allStopsToRemove transient;
	create allStopsToUpdate transient;
	create allTasksToAdd transient;
	create allTasksToComplete transient;
	create allTasksToRemove transient;
	
	//Set terminal config option required for clearing voyage when imex changed to storage
	self.setTerminalConfig(ClearVoyageIMEXStorage, true);
	self.assertTrue(self.getTerminalConfig(ClearVoyageIMEXStorage).Boolean);
	
	//Delete old objects
	self.deleteVoyage(VOY_CODE);
	self.deleteVessel(VES_CODE);
	masterTI := self.getTrackedItem(TI_CODE_MASTER);
	if masterTI &lt;&gt; null then
		self.deleteTrackedItem(masterTI, false);
	endif;
	ti1 := self.getTrackedItem(TI_CODE_1);
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, false);
	endif;
	ti2 := self.getTrackedItem(TI_CODE_2);
	if ti2 &lt;&gt; null then
		self.deleteTrackedItem(ti2, false);
	endif;
	ti3 := self.getTrackedItem(TI_CODE_3);
	if ti3 &lt;&gt; null then
		self.deleteTrackedItem(ti3, false);
	endif;
	
	
	//Create all the required new objects
	op := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	bs := self.getTerminalArea("UT_BS1").CM_BlockStack;
	ves := self.addVesselCellular(VES_CODE, op);
	voy := self.addVoyageWithContainerStructur(VOY_CODE, ves.code, op.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	masterTI := self.addContainerAtLocation(TI_CODE_MASTER, op, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.allLocationsControllers.first);
	ti1 := self.addContainerAtLocation(TI_CODE_1, op, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.allLocationsControllers.first);
	ti2 := self.addContainerAtLocation(TI_CODE_2, op, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.allLocationsControllers.first);
	ti3 := self.addContainerAtLocation(TI_CODE_3, op, "2200", "GENL", TI_IMEX_STATUS_REMAINONBOARD, bs.allLocationsControllers.first);
	
	//Update the newly created TI's voayge
	self.opts.purge();
	self.opts.addAssoc("Voyage", voy);
	self.updateTI(masterTI);
	self.updateTI(ti1);
	self.updateTI(ti2);
	self.opts.addAssoc("TransitStatus", TI_TransitStatusSOB);
	self.updateTI(ti3);
	
	pxyMasterTI := app.createUpdateProxy(masterTI).CM_TrackedItem;
	pxyTI1 := app.createUpdateProxy(ti1).CM_TrackedItem;
	pxyTI2 := app.createUpdateProxy(ti2).CM_TrackedItem;
	pxyTI3 := app.createUpdateProxy(ti3).CM_TrackedItem;
	
	updateController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);
	bulkEditController.myMasterTI := pxyMasterTI;
	bulkEditController.updateOption := 1;
	pxyMasterTI.cloneReferences(bulkEditController.myMasterTI, updateController, app.myPassport);
	
	allPxys.add(pxyMasterTI);
	allPxys.add(pxyTI1);
	allPxys.add(pxyTI2);
	allPxys.add(pxyTI3);
	
	self.assertEqualMsg(masterTI.getImExStatus(), TI_IMEX_STATUS_EXPORT, "master ti imex before");
	self.assertEqualMsg(masterTI.myVoyage, voy, "master ti voyage before");
	self.assertEqualMsg(ti1.getImExStatus(), TI_IMEX_STATUS_EXPORT, "ti1 imex before");
	self.assertEqualMsg(ti1.myVoyage, voy, "ti1 voyage before");
	self.assertEqualMsg(ti2.getImExStatus(), TI_IMEX_STATUS_EXPORT, "ti2 imex before");
	self.assertEqualMsg(ti2.myVoyage, voy, "ti2 voyage before");
	self.assertEqualMsg(ti3.getImExStatus(), TI_IMEX_STATUS_REMAINONBOARD, "ti3 imex before");
	self.assertEqualMsg(ti3.myVoyage, voy, "ti3 voyage before");
	self.assertEqualMsg(ti3.getTransitStatus, TI_TransitStatusSOB, "ti3 TransitStatus before");
	
	pxyMasterTI.setImExStatus(TI_IMEX_STATUS_STORAGE);
	
	create editObject transient;
	editObject.myBulkEditController := bulkEditController;
	editObject.attrName := ETRow_ImexStatus;
	
	bulkEditController.setProxiesForUpdate(allPxys, allStopsToAdd, allStopsToRemove, allStopsToUpdate, extraParams, app.myPassport);
	
	app.myTrxUA.trxUpdateTIsForBulkEdit(allPxys,
										bulkEditController,
										TI_UPDMODE_NORMAL,
										allTasksToAdd,
										allTasksToComplete,
										allTasksToRemove,
										allStopsToAdd,
										allStopsToRemove,
										allStopsToUpdate,
										hasEditedToDoTasks,
										extraParams,
										app.myPassport );
	
	self.assertEqualMsg(masterTI.getImExStatus(), TI_IMEX_STATUS_STORAGE, "master ti imex after");
	self.assertEqualMsg(masterTI.myVoyage, self.getTerminal().getNullVoyage(), "master ti voyage after");
	self.assertEqualMsg(ti1.getImExStatus(), TI_IMEX_STATUS_STORAGE, "ti1 imex after");
	self.assertEqualMsg(ti1.myVoyage, self.getTerminal().getNullVoyage(), "ti1 voyage after");
	self.assertEqualMsg(ti2.getImExStatus(), TI_IMEX_STATUS_STORAGE, "ti2 imex after");
	self.assertEqualMsg(ti2.myVoyage, self.getTerminal().getNullVoyage(), "ti2 voyage after");
	self.assertEqualMsg(ti3.getImExStatus(), TI_IMEX_STATUS_STORAGE, "ti3 imex after");
	self.assertEqualMsg(ti3.myVoyage, self.getTerminal().getNullVoyage(), "ti3 voyage after");
	self.assertEqualMsg(ti3.getTransitStatus, TI_TransitStatusNull, "ti3 TransitStatus after");

epilog
	
	delete allPxys;
	delete pxyMasterTI;
	delete pxyTI1;
	delete pxyTI2;
	delete pxyTI3;
	delete extraParams;
	delete txnControllerDict;
	delete bulkEditController;
	delete allStopsToAdd;
	delete allStopsToRemove;
	delete allStopsToUpdate;
	delete allTasksToAdd;
	delete allTasksToComplete;
	delete allTasksToRemove;
	delete updateController;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckCantChangeTxnTranType" id="0c58d419-8554-4b3c-abdf-ae639f811dab">
        <source>tCheckCantChangeTxnTranType();

/*

Purpose:		Check that can change the ti's txn transaction type.
				e.g from Receive to Recieve Ship

Parameters:			

Return Value:		


Date			Who		Reason
04 August 2011	cnwmh5	Initial creation

*/
constants

	ContainerId1				: String = "UTMHQR00001";
	ContainerId2				: String = "UTMHQR00002";
	BlockStackId				: String = "UTMHBS1";

vars

	container1					: CM_Container;
	container2					: CM_Container;
	operator					: CM_Operator;
	blockStack					: CM_BlockStack;
	cont1RecTxn					: CM_Receive;
	cont2RecTxn					: CM_Receive;
	txnController				: CMIF_TITransactionController;

begin

	// set up any default stuff
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNull(operator);
	
	// create the block stack
	self.deleteTerminalArea(BlockStackId);
	blockStack := self.addBlockStack(BlockStackId, 10, null);
	self.assertNotNull(blockStack);
	
	
	// create the container's 
	self.deleteContainer(ContainerId1);
	container1 := self.addContainerAtLocation(ContainerId1, operator, "2200", "GENL", TI_IMEX_STATUS_STORAGE, blockStack);
	self.assertNotNull(container1);
	
	self.deleteContainer(ContainerId2);
	container2 := self.addContainerAtLocation(ContainerId2, operator, "2200", "GENL", TI_IMEX_STATUS_STORAGE, blockStack);
	self.assertNotNull(container2);

	/*
	Get container1's receive txn.  Change the transaction type so that it is like what happened in #27888.  Then can run the 
	Commercial Enquiry report and see that this works correctly still. (No 1086 error)
	This will bypass the trx so that the transaction type can be updated.  There is an error returned if you try and do this 
	and use the trx.  That will be tested against container2 in the test below.
	*/
	cont1RecTxn := container1.getTransReceiveFirst();
	self.assertNotNull(cont1RecTxn);
	self.assertNotEqual(cont1RecTxn.type, TRANS_TYPE_REC_SHIP);
	
	app.writeStatement("******************************" &amp; CrLf &amp; "BEFORE" &amp; CrLf &amp; 
		"ti: " &amp; container1.id &amp; CrLf &amp;
		"Rec Txn: " &amp; cont1RecTxn.String &amp; CrLf &amp;
		"Rec Txn Type: " &amp; cont1RecTxn.type.String &amp; " - " &amp; cont1RecTxn.typeString &amp; CrLf &amp; 
		"******************************");	
		
	beginTransaction;
	cont1RecTxn.setPropertyValue('type', TRANS_TYPE_REC_SHIP);
	commitTransaction;
	self.assertEqual(cont1RecTxn.type, TRANS_TYPE_REC_SHIP);
	
	app.writeStatement("******************************" &amp; CrLf &amp; "AFTER" &amp; CrLf &amp; 
		"ti: " &amp; container1.id &amp; CrLf &amp;
		"Rec Txn: " &amp; cont1RecTxn.String &amp; CrLf &amp;
		"Rec Txn Type: " &amp; cont1RecTxn.type.String &amp; " - " &amp; cont1RecTxn.typeString &amp; CrLf &amp; 
		"******************************");	
	
	/* 
	Get container2's receive txn.  Update the transaction type and run through the trx.  Should return a 87071 error, saying
	can't change the transaction type from A to B
	*/
	cont2RecTxn := container2.getTransReceiveFirst();
	self.assertNotNull(cont2RecTxn);
	self.assertEqual(cont2RecTxn.type, TRANS_TYPE_RECEIVE);
	
	app.writeStatement("******************************" &amp; CrLf &amp; "BEFORE" &amp; CrLf &amp; 
		"ti: " &amp; container1.id &amp; CrLf &amp;
		"Rec Txn: " &amp; cont1RecTxn.String &amp; CrLf &amp;
		"Rec Txn Type: " &amp; cont1RecTxn.type.String &amp; " - " &amp; cont1RecTxn.typeString &amp; CrLf &amp; 
		"******************************");	
	
	// create the proxy for the txn
	// creates the txnController as a transient, so need to delete in the epilog
	global.createTxnControllerForType(cont2RecTxn.type, txnController);
	
	txnController.ammended := cont2RecTxn.ammended;
	txnController.dateTime := cont2RecTxn.dateTime;
	txnController.deleted := cont2RecTxn.deleted;
	txnController.freightForwarderCode := cont2RecTxn.freightForwarderCode;
	txnController.noCharge := cont2RecTxn.noCharge;
	txnController.operatorCode := cont2RecTxn.operatorCode.trimBlanks;
	txnController.superseded := cont2RecTxn.superseded;
	txnController.type := cont2RecTxn.type;
	txnController.myToDoTask := cont2RecTxn.myToDoTask;
	txnController.urNumber := cont2RecTxn.urNumber;
	txnController.userGenerated := cont2RecTxn.userGenerated;
	txnController.userId := cont2RecTxn.userId.trimBlanks;
	txnController.myTerminal := cont2RecTxn.myTerminal;
	txnController.myTrackedItem := container2;
	
	// update the type to fumigate
	beginTransaction;
	cont2RecTxn.setPropertyValue('type', TRANS_TYPE_FUMIGATE);
	commitTransaction;	
	
	app.writeStatement("******************************" &amp; CrLf &amp; "AFTER" &amp; CrLf &amp; 
		"ti: " &amp; container2.id &amp; CrLf &amp;
		"Rec Txn: " &amp; cont2RecTxn.String &amp; CrLf &amp;
		"Rec Txn Type: " &amp; cont2RecTxn.type.String &amp; " - " &amp; cont2RecTxn.typeString &amp; CrLf &amp; 
		"******************************");	
	
	// try and update using the trx.  Should get and error 87071
	app.writeStatement("Use the Trx to update TI Transaction.  Should return a 87071 Error (Transaction Type can't change from Receive to Fumigate)");
	app.writeStatement("If test passes then has correctly returned the 87071 Error, will fail if this error isn't returned");
	self.expectTrxError(Transa_type_cannot_change_from);
	app.myTrxUA.trxUpdateTITransaction(txnController, cont2RecTxn, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrxError(Transa_type_cannot_change_from);
	
epilog

	// create transiently in setControllerFromObject so need to delete here.
	delete txnController;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckKeyMethodChanged" id="0d3ce1b4-29a5-45c9-92ee-b5ace99f95a1">
        <source>tCheckKeyMethodChanged();
/*

