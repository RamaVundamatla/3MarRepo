    <JadeMethod name="create" id="664dc22e-6c25-444e-8f3c-c699761890bc">
        <updating/>
        <source>create() updating;

vars

begin

	self.permissionView  := PmLogTransferMaint;
	self.permissionMaint := PmLogTransferMaintMaint; // TFS 2198
	self.btnBackground.enabled := true;
	
	self.helpFileName := HelpFile_Logs;

