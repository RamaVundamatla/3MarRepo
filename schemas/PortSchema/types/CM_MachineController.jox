    <JadeMethod name="id" id="75219fb6-c15b-49ed-b360-afcb4e535985">
        <methodInvocation>mapping</methodInvocation>
        <source>id(set: Boolean; value: String io) mapping;
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	value := null;
	if self.myMachine = null then
		return;
	endif;
	value := self.myMachine.id;
end;</source>
