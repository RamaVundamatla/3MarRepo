    <JadeMethod name="doUserNoteDebtor" id="6ee26684-4965-4c7e-a0af-557ad6f44f61">
        <updating/>
        <source>doUserNoteDebtor(_theMap : CM_DebtorMap; _event : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------
vars
	trGroup : CMIF_TMCDebtorGroup;
	tmcGroup : CMIF_TMCGroup;
	theSB : CM_ServiceBroker;
	idx		: Integer;
	useMoveLevels, useResourceLevels : Boolean;
begin
	// 35872 ignore notes for changes from other business units
	if _theMap &lt;&gt; null and
	   global.isValidObject(_theMap) then
		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;

	if _event = EVENT_TRANSACTIONMAP_CREATE then
		theSB := _theMap.myServiceBroker;
		if theSB.isKindOf(CM_ResourceServiceBroker) then
			tmcGroup := self.getIndexInList(theSB,CMIF_TranMapController.TM_Level_04_Resource, idx);
		elseif theSB.isKindOf(CM_EventServiceBroker) then
			tmcGroup := self.getIndexInList(theSB,CMIF_TranMapController.TM_Level_04_Event, idx);
		elseif theSB.isKindOf(CM_WorkOrderServiceBroker) then // TFS 39236
			tmcGroup := self.getIndexInList(theSB,CMIF_TranMapController.TM_Level_04_WorkOrder, idx);
		elseif theSB.isKindOf(CM_BOLServiceBroker) then //01 Nov 2019	NDL	TFS 47100
			tmcGroup := self.getIndexInList(theSB,CMIF_TranMapController.TM_Level_04_BolTrx, idx); 
		elseif theSB.isKindOf(CM_MoveServiceBroker) then
			tmcGroup := self.getIndexInList(theSB,CMIF_TranMapController.TM_Level_11_Debtor, idx);
		elseif theSB.isKindOf(CM_TransResourceServiceBroker) then
			tmcGroup := self.getIndexInList(theSB, CMIF_TranMapController.TM_Level_12_Debtor, idx);
		elseif theSB.isToDoRsrcServiceBroker() then // 15/05/2023	navkc1	CR 57927 Task 54268
			tmcGroup := self.getIndexInList(theSB, CMIF_TranMapController.TM_Level_06_ResourceType, idx);
		else
			tmcGroup := self.getIndexInList(theSB,CMIF_TranMapController.TM_Level_10_TranServiceBroker, idx);
		endif;
		if idx &gt; 0 then
			create trGroup;
			trGroup.myDebtorMap := _theMap;
			trGroup.myDebtor := _theMap.myDebtorNode;
			trGroup.itemName := trGroup.getItemName();
			trGroup.extractName := trGroup.getItemCode();	// 23659
			trGroup.myGroup := tmcGroup;
			trGroup.initialise(self.myTMCRoot.groupCount);
			trGroup.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	elseif _event = EVENT_TRANSACTIONMAP_UPDATE then
		theSB := _theMap.myServiceBroker;
		// find the transient
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_11_Debtor, idx);
		if tmcGroup = null then
			tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_14_MoveTransactions, idx);
			if tmcGroup = null then
				tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_05_Debtor, idx);
				useResourceLevels := true;
			else
				useMoveLevels := true;
			endif;
		endif;
		// remove from list box and delete
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		// get Parent object
		idx := 0;
		if useMoveLevels then
			tmcGroup := self.getIndexInList(theSB,CMIF_TranMapController.TM_Level_11_Debtor, idx); 
		elseif useResourceLevels then
			tmcGroup := self.getIndexInList(theSB,CMIF_TranMapController.TM_Level_04_Resource, idx); 
		else
			tmcGroup := self.getIndexInList(theSB,CMIF_TranMapController.TM_Level_10_TranServiceBroker, idx); 
		endif;	
		// recreate transient;
		if idx &gt; 0 then
			create trGroup;

			trGroup.myDebtorMap := _theMap;
			trGroup.myDebtor := _theMap.myDebtorNode;
			trGroup.itemName := trGroup.getItemName();
			trGroup.extractName := trGroup.getItemCode();	// 23659
			trGroup.myGroup := tmcGroup;
			trGroup.initialise(self.myTMCRoot.groupCount);
			trGroup.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
		endif;
	elseif _event = EVENT_TRANSACTIONMAP_DELETE then
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_11_Debtor, idx); // CARGO TRANSACTION or MOVE DEBTOR
		if tmcGroup = null then
			tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_05_Debtor, idx); // VOYAGE RESOURCE DEBTOR
		endif;
		if tmcGroup = null then
			tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_12_Debtor, idx); // RESOURCE TYPE DEBTOR
		endif;
		if tmcGroup = null then
			tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_07_Debtor, idx); // 15/05/2023	navkc1	CR 57927 Task 54268
		endif;
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		
	endif;
end;</source>
        <Parameter name="_theMap" type="CM_DebtorMap"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteIMEX" id="f8449a75-37df-4e23-8398-85a3960f1ff3">
        <updating/>
        <source>doUserNoteIMEX(_theMap : CM_ImexServiceMap; _event : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	trGroup : CMIF_TMCImexGroup;
	tmcGroup : CMIF_TMCGroup;

	idx		: Integer;
begin
	// 35872 ignore notes for changes from other business units
