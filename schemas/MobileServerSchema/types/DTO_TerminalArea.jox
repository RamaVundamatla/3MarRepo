<Class name="DTO_TerminalArea" id="00938524-8ffc-4ddd-8df7-ce78f7fa4f9d">
    <superclass name="DTO_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="mobileServer"/>
    <ExplicitInverseRef name="allLocationsControllers" id="2cc8a552-1b0c-4877-b55f-e9b275580a6a">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <type name="DTO_LocationsControllerArray"/>
        <access>readonly</access>
        <Inverse name="DTO_LocationsController::myTerminalArea"/>
    </ExplicitInverseRef>
    <PrimAttribute name="id" id="6f741835-2586-492c-b5f1-51eb5d1e30f1">
        <length>21</length>
        <embedded/>
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="typeString" id="11a440c4-e0bf-4960-b9ae-0635232b54d2">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="setFromPersistent" id="4df47ea0-44f4-4bbe-b989-31715a67363a">
        <updating/>
        <source>setFromPersistent(_ta: CM_TerminalArea) updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tmpLC	: CM_LocationsController;
	dtoLC	: DTO_LocationsController;
idx	: Integer;
begin
	self.id		:= _ta.id;
	self.typeString	:= _ta.typeString;
	
	foreach tmpLC in _ta.allLocationsControllers do
		create dtoLC transient;
		self.allLocationsControllers.add(dtoLC);
		dtoLC.setFromPersistent(tmpLC);
		
		idx := idx + 1;
		if idx &gt; 20 then
			break;
		endif;
	endforeach;
	
	inheritMethod(_ta);
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
</Class>
