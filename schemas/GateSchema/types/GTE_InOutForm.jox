    <JadeMethod name="txtTrackedItemID_lostFocus" id="90bd0b5f-48c5-438f-96dd-e26231e5054c">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtTrackedItemID_lostFocus(textbox: GTE_TextBox input) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sheet		: GTE_Sheet;
	mainTbl,
	extraTbl	: CM_EntryTable;
	cmb			: GTE_ComboISOType;
	tmpTI		: CM_TrackedItem;
	txtStr		: String;
	
begin
	sheet := textbox.GTE_TextBox.mySheet;

	if sheet = null then
		return;
	endif;
	
	txtStr := textbox.text;
	if self.hasFieldChanged and txtStr &lt;&gt; null then
		app.mousePointer := MousePointer_HourGlass;
		tmpTI := self.getPreNoteTI(txtStr);
		
		if tmpTI &lt;&gt; null then
			//self.setValuesFromReceivalTI(tmpTI, textbox.mySheet);
			self.setDefaultsFromObject(textbox.mySheet, tmpTI);
			self.fromPrenoteID := tmpTI.id;
			self.setIsFromPrenote(tmpTI, sheet);
		else
			if sheet.isPopulatedFromPrenote 
			and self.fromPrenoteID &lt;&gt; null then
				if self.fromPrenoteID &lt;&gt; txtStr then
					sheet.setIsFromPrenote(null);
					self.fromPrenoteID := "";
				endif;
			endif;
			mainTbl := sheet.myTblMain;
			extraTbl := sheet.myTblExtra;
			cmb := sheet.getControlByName(Cntrl_cmbISOType).GTE_ComboISOType;
	
			self.myAssistant.GTE_Assistant.setFieldsFromContainerRange(txtStr, mainTbl, extraTbl, cmb);
		endif;
		sheet.setSubHeading(txtStr);
	endif;

epilog
	app.mousePointer := MousePointer_Default;
	
end;</source>
        <Parameter name="textbox" type="GTE_TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtTrailerNumber_gotFocus" id="b002d778-808f-408c-bbd9-43adc68b0287">
