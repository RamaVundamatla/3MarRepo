    <JadeMethod name="doRefreshBookings" id="24de6862-3f19-4c46-acfa-d4a2845c8bba">
        <updating/>
        <source>doRefreshBookings() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
21 October 2010	cnwndl1	Initial creation
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
30/05/2023   	navlw1  CR 58146 EUP - VBS MTN - [6] - Selector Query and JRW
*/

vars
	localTimeStamp :TimeStamp;
	date : Date;
	today : Date;
	msg : String;
	
begin

	if not self.chkInclBooked.value
	and not self.chkInclUnbooked.value
	and not self.chkInclUsed.value
	then
		msg := app.getErrorString2(Must_select_one_of, "'" &amp; self.chkInclBooked.caption &amp; "', '" &amp; self.chkInclUnbooked.caption &amp; "'", "'" &amp; self.chkInclUsed.caption &amp; "'");
		app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only);
		if not self.frmFilter.visible then
			self.showFilter();
		endif;
		return;
	endif;
	
	today := self.systemToLocalTime(app.actualTimeServer()).date();// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	date.setDate(day, month, year);

	if self.cmbPeriod.text = ByMonth then
		self.txtDate.visible := false;
		self.btnBack.visible := false;
		self.btnNext.visible := false;
		self.mthPicker.visible := true;
		if date.isValid then
			self.mthPicker.setYear( date.year );
			self.mthPicker.setMonth( date );
		else
			self.mthPicker.setYear( today.year );
			self.mthPicker.setMonth( today );
		endif;
		
	elseif self.cmbPeriod.text = ByDay then
		self.txtDate.visible := true;
		self.btnBack.visible := true;
		self.btnNext.visible := true;
		self.mthPicker.visible := false;
		date.setDate(day, month, year);
		if date.isValid then
			self.txtDate.setDate( date );
		else
			self.txtDate.setDate( today );
		endif;
		self.txtDate.setDate( date );	
	
	endif;
	
	self.setFilterString();
	
	self.lblCalendar.caption := self.myVehicleBookingTerminal.getTemplateCalendarString( date );
	
	// 30/05/2023 navlw1 tfs 58146
	if self.isSelectorQuery = false then
		self.initTblBookings();
	endif;
	self.isSelectorQuery := false;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="636ea212-1dd0-4889-a360-b4fdbd039d62">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2010	cnwndl1	Initial creation

*/

vars

	vLeft : Real;
	vTop : Real;
	vWidth : Real;
	vHeight : Real;

begin

	inheritMethod();
	
	self.localToolBarResize();
	
	vLeft := 0;
	vTop := self.frmToolbar.top + self.frmToolbar.height + 2;
	vWidth := self.clientWidth;
	vHeight := self.clientHeight - vTop;
	self.splMain.move(	vLeft,	//x : Real;
						vTop,	//y : Real;
						vWidth,	//width2 : Real;
						vHeight	//height2 : Real
						);
						
	self.splMain.cnEcResizeContents();
	
	if self.cmbPeriod.text = ByMonth or self.cmbPeriod.text = ByWeek then
		self.reScaleWeekMonthHeight();
	endif;
	
	self.reColourBookings();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblContextMnu" id="5b39275f-afff-4498-baae-4dc2a34bc1d8">
        <updating/>
        <source>doTblContextMnu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
30 November 2010	cnwndl1	Initial creation
18 May 2016			cnwns1	TFS 488 - Multi Timezone Support
10 Aug 2023			navlw1	ChangeRequest 59132:[59133] EUP | VBS Audits
*/

vars

	lLeft 	: Real;
	tTop 	: Real;
	bookingSlot : CM_VehicleBookingTimeSlot;
	canMaint : Boolean;
	canMaintSpecificCarrier : Boolean;
	canDel : Boolean;
	failedDAC  :CM_DataAccessController;
	purgeBeforeDays : Integer;
	purgeBeforeDate : Date;
	tiArray : CM_TIArray;
	
begin

	lLeft := x;
	tTop := y;
	
	self.mnuBookAdd.visible := app.getMyUser.canDo( self.myTerminal, PmGteVehSchMaint );
	self.mnuBookDel.visible := false;
	self.mnuBookMaint.visible := false;
	self.mnuUnbookSlot.visible := false;
	self.mnuDisassoc.visible := false;
	self.mnuInspectObj.visible := false;
	self.mnuCargoEnq.visible := false;
	self.mnuColOrg.visible := ( self.cmbPeriod.text = ByDay );
	self.mnuExport.visible := ( self.cmbPeriod.text = ByDay );					//navra1 - MTN-34420 - 31st Mar 2025
	
	
	if self.tblBookings.row &gt; self.tblBookings.fixedRows and self.tblBookings.row &lt;= self.tblBookings.rows then
		bookingSlot := self.tblBookings.accessRow( self.tblBookings.row ).itemObject.CM_VehicleBookingTimeSlot;
		if bookingSlot &lt;&gt; null then
			self.mnuCargoEnq.visible := true;
			create tiArray transient;
			bookingSlot.getDeliveryTis( tiArray );
			bookingSlot.getPickUpTis( tiArray );
			self.mnuCargoEnq.enabled := not tiArray.isEmpty;
			
			self.mnuAuditsForObject.visible := bookingSlot.hasAudits; // 10.08.2023 navlw1 tfs #59132:#59133
		endif;
	endif;
	
	
	canMaint := app.getMyUser.canDo( self.myTerminal, PmGteVehSchMaint );
	canDel := app.getMyUser.canDo( self.myTerminal, PmGteVehSchMaint );
	if not canMaint then
		//Hasn't got general updating but has got specific carrier updating permission
		canMaintSpecificCarrier := app.getMyUser.canDo( self.myTerminal, PmGteVehSchWeb );
	endif;
	
	if canMaint or canMaintSpecificCarrier then
		if self.tblBookings.row &gt; self.tblBookings.fixedRows and self.tblBookings.row &lt;= self.tblBookings.rows then
			bookingSlot := self.tblBookings.accessRow( self.tblBookings.row ).itemObject.CM_VehicleBookingTimeSlot;
			if bookingSlot &lt;&gt; null then
			
				if bookingSlot.isUsed then
					self.mnuDisassoc.visible := canMaint;
				endif;
				
				if bookingSlot.myCarrier &lt;&gt; null and canMaintSpecificCarrier then
					canMaint := bookingSlot.myCarrier.canUserAccessSelf(null, failedDAC, app.myPassport);
				endif;
				
				if canMaint then
					self.mnuBookMaint.visible := true;
					self.mnuBookMaint.enabled := true;
					self.mnuUnbookSlot.visible := true;
					self.mnuUnbookSlot.enabled := bookingSlot.isBookedNotYetUsed;
					if bookingSlot.isExpired then
						self.mnuBookMaint.enabled := false;
						self.mnuUnbookSlot.enabled := false;
					endif;
				endif;
				
				if canDel then
					if not app.getMyUser.canDo(null, PmCmpTerminalMaint) then
						purgeBeforeDays := self.myTerminal.getConfig( VsPurgeSlotsOlderThan ).Integer;
						purgeBeforeDate := (self.systemToLocalTime(app.actualTimeServer).Date - purgeBeforeDays);// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
						canDel := bookingSlot.bookingTSstart.Date &lt; purgeBeforeDate;
					endif;
				endif;
				self.mnuBookDel.visible := canDel;
	
				if app.isAllowedToInspect then
					self.mnuInspectObj.visible := true;
					self.mnuInspectObj.userObject := bookingSlot;
				endif;
			endif;
		endif;
	endif;
	
	conwin.windowToScreen(lLeft, tTop);
	self.screenToWindow(lLeft, tTop);   // convert x, y relative to form
	
	self.popupMenu(self.mnuMaint, lLeft.Integer, tTop.Integer);
		
	return true;

epilog

	delete tiArray;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnbookSlot" id="14df8804-c9ef-4cc4-b0d0-ee93e9e31bed">
        <updating/>
        <source>doUnbookSlot() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2013	cnwndl1	Initial creation
18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot

*/

vars

	bookingSlot : CM_VehicleBookingTimeSlot;
	now : TimeStamp;
	tsInt : TimeStampInterval;
	ts : TimeStamp;
	msg : String;
	hrs : Integer;
	type : String;
	loadState : Boolean;
	proxy : CM_VehicleBookingTimeSlot;
	strArray : StringArray;
	theReturn : Integer;

begin

	if self.tblBookings.row &gt; self.tblBookings.fixedRows and self.tblBookings.row &lt;= self.tblBookings.rows then
		bookingSlot := self.tblBookings.accessRow( self.tblBookings.row ).itemObject.CM_VehicleBookingTimeSlot;
	endif;
	
	if bookingSlot = null then
		return;
	endif;
	
	if bookingSlot.isExpired then
		 msg := app.getErrorString(Vehic_sched_booki_not_maint_af);
		 app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	tsInt := bookingSlot.getBookInAdvanceTimeInterval(hrs,type);
	if tsInt &lt;&gt; null then
		now := self.systemToLocalTime(app.actualTimeServer);// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		ts := now + tsInt;
		if bookingSlot.bookingTSstart &lt; ts then
			msg := app.getErrorString2(Vehic_sched_booki_must_made_le, hrs.String, type);
			app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only );
			return;
		endif;
	endif;

	app.cmsBeginLoad(loadState);
	proxy := bookingSlot.pxyCreateUpdateProxy().CM_VehicleBookingTimeSlot;
	app.cmsEndLoad(loadState);
	
	create strArray transient;
	
	proxy.setProxy(	bookingSlot.bookingTSstart,	//_scheduleTSstart : TimeStamp;
					bookingSlot.bookingTSend,	//_scheduleTSend : TimeStamp;
					bookingSlot.myVehicleBookingTerminal,	//_myVBTerminal : CM_VehicleBookingTerminal;
					null,	//_myCarrier : CM_Carrier;
					null,	//_mySubCarrier : CM_Carrier;
					null,	//_myDriver : CM_DriverDetails;
					null,	//_myVehicle : CM_Vehicle;
					null,	//_remarks : String;
					false,	//_includesDelivery : Boolean;
					false,	//_includesPickUp : Boolean;
					strArray,	//_bookedTiIds : StringArray;
					null,	//_myVehicleVisitRecord : CM_VehicleVisitRecord
					bookingSlot.myVBTimeSlotType,	//_myVBTimeslotType : CM_VehicleBookingTimeSlotType
					bookingSlot.id,	//_id : String;
					null,	//_allBookingRefs : CM_BookingRefSet;
					null,	//_allBulkReleases : CM_BulkReleaseSet
					null,	//_allVBSTimeSlots : CM_VehicleBookingTSItemSet;
					null,	//_preGateInCheck : Boolean;
					null,	//_preGateOutChck : Boolean;
					null,	//_kioskCheck : Boolean;
					null,	//_externalReference : String
					null 	//_myTILCType : CM_TILCType	// 08 Aug 2024 navcs2	ChangeRequest 63928
					);
					
	while true do
	
		//app.myTrxUA.trxUpdateVehicleBooking(proxy, app.myPassport);				// TFS 51248
		app.myTrxUA.trxUpdateVehicleBooking(proxy, null, null, app.myPassport);		// TFS 51248

		if app.myPassport.trxCompletedOK then
			break;
			
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Vehicle_schedul_booking_slot), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

epilog

	delete proxy;
	delete strArray;
	app.cmsEndLoad(loadState);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getDateFromTable" id="f4f25bd5-054a-4392-9d73-e5e54abb5d35">
        <source>getDateFromTable():Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2013	cnwndl1	Initial creation

*/

vars

	date : Date;
	cell : JadeTableCell;
	cellControl : Control;
	dateStr : String;

begin

	date := null;
	
	if self.cmbPeriod.text = ByMonth then
	
		cell := self.tblBookings.accessCell( self.tblBookings.row, self.tblBookings.column );
		if cell &lt;&gt; null then
			cellControl := cell.cellControl;
			if cellControl &lt;&gt; null and cellControl.isKindOf( CMUI_ListBox ) then
				dateStr := cellControl.CMUI_ListBox.itemText[1].trimBlanks;
				if dateStr &lt;&gt; null and dateStr.asDateJMT.isValid then
					date := dateStr.asDateJMT;
				endif;
			endif;
		endif;
	
	endif;
	
	return date;

epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="7a685a36-6192-43a0-823d-bc8831ff22d6">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation

*/

vars

	xmlStr : String;
	leftControl : Control;

begin

	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; global.formatAsXML(self.cmbPeriod.name,self.cmbPeriod.text.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourCurrentDay, self.xmlColourCurrentDay.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourNonCurrMth, self.xmlColourNonCurrMth.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourDateBack, self.xmlColourDateBack.String);
	
	xmlStr := xmlStr &amp; global.formatAsXML(self.chkInclUsed.name, self.chkInclUsed.value.String);
	xmlStr := xmlStr &amp; global.formatAsXML(self.chkInclUnbooked.name, self.chkInclUnbooked.value.String);
	xmlStr := xmlStr &amp; global.formatAsXML(self.chkInclBooked.name, self.chkInclBooked.value.String);
	
	leftControl := self.splMain.getMyLeftControl();
	xmlStr := xmlStr &amp; global.formatAsXML(XML_ShowFilter, leftControl.visible.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_ShowFilterRatio, self.splMain.leftToRightRatio.String);
	
	xmlStr := xmlStr &amp; global.formatAsXML(self.tblBookings.name, xmlTblBookings);
	 
	return xmlStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="78328397-76d6-48fd-9c43-5764c41522a1">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation

*/

vars

	theXML,
	theXMLValue: String;
	index : Integer;
	leftControl : Control;

begin

	self.populateCombos();

	inheritMethod(_userWindow);
	
	theXML:= _userWindow.xmlInfo;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(self.cmbPeriod.name);
 	if theXMLValue &lt;&gt; null then
 		index := self.cmbPeriod.findStringExact(1, theXMLValue);
		if index &gt; 0 then
			self.cmbPeriod.listIndex := index;
		endif;
 	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(self.chkInclUsed.name);
	if theXMLValue &lt;&gt; null then
		self.chkInclUsed.value := theXMLValue.Boolean;
	else
		self.chkInclUsed.value := true;
	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(self.chkInclUnbooked.name);
	if theXMLValue &lt;&gt; null then
		self.chkInclUnbooked.value := theXMLValue.Boolean;
	else
		self.chkInclUnbooked.value := true;
	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(self.chkInclBooked.name);
	if theXMLValue &lt;&gt; null then
		self.chkInclBooked.value := theXMLValue.Boolean;
	else
		self.chkInclBooked.value := true;
	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_ShowFilterRatio);
	if theXMLValue &lt;&gt; null then
		if theXMLValue.Integer &lt; 5 then
			theXMLValue := "5";
		endif;
		self.splMain.setLeftToRightRatio( theXMLValue.Integer );
	else
		self.splMain.setLeftToRightRatio( 5 );
	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TagColourCurrentDay);
	if theXMLValue = null then
		self.xmlColourCurrentDay := 16777215;
	else
		self.xmlColourCurrentDay := theXMLValue.Integer;
	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TagColourNonCurrMth);
	if theXMLValue = null then
		self.xmlColourNonCurrMth := 14807794;
	else
		self.xmlColourNonCurrMth := theXMLValue.Integer;
	endif;
	
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TagColourDateBack);
	if theXMLValue = null then
		self.xmlColourDateBack := 15269887;
	else
		self.xmlColourDateBack := theXMLValue.Integer;
	endif;
	
	self.setColours();
	
	xmlTblBookings := theXML.cnEcGetTagValueOfName(self.tblBookings.XMLTag_Table &amp; self.tblBookings.name);
	

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTblBookings" id="87588b6f-4931-4b4a-90c7-000e5c0d00f8">
        <updating/>
        <source>initTblBookings()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2010	cnwndl1	Initial creation
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	
	pos : Integer;
	index : Integer;
	
	formDate : Date;
	heading1 : String;
	
	vvsBooking : CM_VehicleBookingTimeSlot;
	iter : Iterator;
	dataLine : String;
	now : TimeStamp;
	startObject : CM_VehicleBookingTimeSlot;
	fromTS : TimeStamp;
	toTS : TimeStamp;
	indexLine : Integer;
	firstHighLightLine : Integer;
	highLightObject : CM_VehicleBookingTimeSlot;
	
	numVisibleRows : Integer;
	halfWay : Integer;
	
	byDay : Boolean;
	byMonth : Boolean;
	dayHeadings : String;
	
	today : Date;
	date : Date;
	monday : Date;
	listBox : CMUI_ListBox;
	
begin

	if not self.listBoxIndexArray.isEmpty then
		foreach pos in 1 to self.listBoxIndexArray.size do
			index := self.listBoxIndexArray[pos];
			listBox := self.lstActivity.getControl(index).CMUI_ListBox;
			if listBox &lt;&gt; null then
				delete listBox;
			endif;
		endforeach;
		self.listBoxIndexArray.clear();
	endif;
	
	self.tblBookings.clear();
	if self.timerSet then
		self.endTimer(1);
		self.timerSet := false;
	endif;
	
	now := app.actualTimeServer;// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	formDate.setDate(self.day,self.month,self.year);
	if not formDate.isValid then
		formDate := now.Date;
	endif;
	
	byMonth := self.cmbPeriod.text = ByMonth;
	byDay := self.cmbPeriod.text = ByDay;
	
	if byMonth then
	
		self.lblCalendar.visible := false;
	
		dayHeadings := dayListArray[1] &amp; Tab
					&amp; dayListArray[2] &amp; Tab
					&amp; dayListArray[3] &amp; Tab
					&amp; dayListArray[4] &amp; Tab
					&amp; dayListArray[5] &amp; Tab
					&amp; dayListArray[6] &amp; Tab
					&amp; dayListArray[7];
	
		self.tblBookings.columns := 7;
		foreach index in 1 to 7 do
			self.tblBookings.accessColumn(index).visible := true;
		endforeach;
		self.tblBookings.fixedColumns := 0;
		self.tblBookings.rows := 1;
		self.tblBookings.fixedRows := 1;
		self.tblBookings.selectMode := Table.SelectMode_Default;
		
		self.tblBookings.setCellText(1,1,dayHeadings);
		
		date.setDate(1,self.month,self.year);
		if date.dayOfWeek = 1 then
			monday := date;
		else
			monday := date.lastMonday;
		endif;
		self.setCellDataForWeek( date );
		monday := monday + 7;
		while monday.month = self.month do
			self.setCellDataForWeek( monday );
			monday := monday + 7;
		endwhile;
		
		self.reScaleWeekMonthHeight();
		
	elseif byDay then
	
		self.lblCalendar.visible := true;
		
		self.setupMyEntTableDef();
		
		self.tblBookings.selectMode := Table.SelectMode_WholeRows;
	
		if self.myVehicleBookingTerminal = null then
			return;
		endif;
		
		iter := self.myVehicleBookingTerminal.allBookingsByTS.createIterator;
		
		fromTS.setDate(formDate);
		fromTS.setTime("00.00".Time);
		toTS.setDate(formDate + 1);
		toTS.setTime("01.00".Time);
		
		
		
		startObject := self.myVehicleBookingTerminal.allBookingsByTS.getAtKeyGeq(fromTS,null);
		
		if startObject &lt;&gt; null then
			highLightObject := self.myVehicleBookingTerminal.allBookingsByTS.getAtKeyGeq(now,null);
			
			iter.startAtObject(startObject);
			
			while iter.next( vvsBooking ) do
				if vvsBooking.bookingTSstart &gt; toTS then
					break;
				endif;
				
				self.addBookingSlotToTable( vvsBooking, false, indexLine, null );
				if highLightObject = vvsBooking and indexLine &gt; 0 then
					firstHighLightLine := indexLine;
				endif;
			endwhile;
			
			self.reColourBookings();
				
		endif;
	
	endif;
	
	if now.Date = formDate then
		self.beginTimer(60000, Timer_OneShot, 1);
		self.timerSet := true;
	endif;
	
epilog

	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="af89eff6-a407-455a-925d-395fdeee3f0c">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation

*/

vars

begin

	if keyCode = CMUI_Key_F3 then
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			inheritMethod(keyCode, shift);
		else
			if self.frmFilter.visible then
				self.frmFilter.visible := false;
			else
				self.showFilter();
			endif;
		endif;
		return;
	endif;

	inheritMethod(keyCode, shift);

epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="607a41ca-618c-41d6-a106-b30f886688e4">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
23 Aug 2023 		navhl20 Bug 59107: FR | EUP 53429 - BR - VBS changes MTN - Enquiry screen (NU)
*/

vars
	showAdvanced 	: Boolean;
	vbsEnqForm  	: CMUI_VehicleBookingEnqForm;
begin
	if self.myTerminal.getMyVBSProcess &lt;&gt; null and self.myTerminal.getMyVBSProcess.isVbsSlotValidation then
		showAdvanced := true;
	endif;
	
	if showAdvanced then
		vbsEnqForm := app.getForm(CMUI_VehicleBookingEnqForm.name).CMUI_VehicleBookingEnqForm;
		/* 
		//23.8.2023 navhl20 #59107
		if vbsEnqForm &lt;&gt; null and vbsEnqForm.myTerminal = self.myTerminal then
			vbsEnqForm.windowState := vbsEnqForm.WindowState_Normal;
			vbsEnqForm.zOrder(1);
			return;
		endif;
		*/
		//if vbsEnqForm = null or vbsEnqForm.myTerminal &lt;&gt; self.myTerminal then								//23.8.2023 navhl20 #59107
		vbsEnqForm := app.loadForm(CMUI_VehicleBookingEnqForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_VehicleBookingEnqForm;
		//endif;																							//23.8.2023 navhl20 #59107
		if vbsEnqForm &lt;&gt; null then
			vbsEnqForm.show;
		endif;
		self.unloadForm();
	else
		inheritMethod();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="localToolBarResize" id="77c0c58b-7ab2-48e4-bc93-cbe88081d981">
        <source>localToolBarResize();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation

*/

vars

	toolbar	: CMUI_Toolbar;
	gap : Integer;

begin

	toolbar	:=	self.frmToolbar;
	
	self.btnBack.caption := 215.Character;
	self.btnNext.caption := 216.Character;
	
	if toolbar.showCaptions then
		toolbar.height := toolbar.HeightWithCaptions;
		self.cmbPeriod.top := 10;
		self.mthPicker.top := 6;
		self.txtDate.top := 11;
		self.btnBack.top := 10;
		self.btnNext.top := 10;
		self.lblCalendar.top := 13;

	else
		toolbar.height := toolbar.HeightWithoutCaptions + 2;
		self.mthPicker.top := -1;
		self.cmbPeriod.top := 5;
		self.txtDate.top := 6;
		self.btnBack.top := 5;
		self.btnNext.top := 5;
		self.lblCalendar.top := 7;

	endif;
	
	gap := 5;
	self.cmbPeriod.left := 10;
	self.btnBack.left := self.cmbPeriod.left + self.cmbPeriod.width + gap;
	self.btnNext.left := self.btnBack.left + self.btnBack.width + gap;
	self.txtDate.width := 125;	
	self.txtDate.left := self.btnNext.left + self.btnNext.width + gap;
	self.lblCalendar.left := self.txtDate.left + self.txtDate.width + gap;
	self.lblCalendar.width := 500; // PAR 33905 - was truncating the text in the label
	self.frmPeriod.width := 600; // PAR 33905
	
	
	self.mthPicker.left := self.txtDate.left;
	self.mthPicker.width := 300;
	self.mthPicker.maximumYear := 2200;
	
epilog

end;</source>
    </JadeMethod>
