    <JadeMethod name="create" id="6047b3c8-bbf2-4d65-b62f-64f6d379b6b3">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	navhl20	ChangeRequest 53430: EUP - Sub Carrier registration in MTN

*/

vars
	queryOperator	: CM_QueryOperator;
begin

	if self.isTransient then	
		return;
	endif;

	create queryOperator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(queryOperator);	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="d9273440-dca8-4af5-a473-eae2b9add580">
