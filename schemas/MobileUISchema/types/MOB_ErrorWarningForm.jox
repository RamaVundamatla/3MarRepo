    <JadeMethod name="btnCancel_click" id="d6de23d8-2cc2-457e-a6f4-3f42a6d553a0">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
/*
	Created on 01 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	app.mousePointer	:=	Busy;
	modalResult := ModalResultCancel;
	self.doCloseForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOK_click" id="137b6d28-8430-4008-852e-ca3792ce8f15">
