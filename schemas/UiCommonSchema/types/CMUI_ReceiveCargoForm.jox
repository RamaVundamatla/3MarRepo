    <JadeMethod name="clearReeferDetails" id="2ce2fd79-a35f-4901-ae4f-b64adc107c30">
        <source>clearReeferDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2014	cnwmc5	Initial creation		PAR 34590

*/

vars

	commodity		: CM_Commodity;
	
begin
	
	//cnwmc5 - 27 August 2014 - PAR 34818
	commodity	:= cmbCommodity.getObject.CM_Commodity;
	if commodity &lt;&gt; null and commodity.hasTemp then
		return;
	endif;
	
	self.txtCarriageTemp.setValue(null);
	self.txtPackTemp.setValue(null);
	self.txtPackDate.setValue(null);
	self.txtPackTime.setValue(null);
	self.txtTimeOffPower.setValue(null);
	self.chkTransitPower.setValue(false);
	self.txtTransitOnDate.setValue(null);
	self.txtTransitOnTime.setValue(null);
	self.txtTransitRemark.setValue(null);
	self.txtHumidity.setValue(null);
	self.tblVentilation.setValueDefault(null);
	self.txtCO2Percent.setValue(null);
	self.txtOxygenPercent.setValue(null);
	self.chkCurtainsIn.setValue(false);
	self.cmbVoltageType.setValue(null);
	self.cmbCoolingType.setValue(null);
	
epilog

end;</source>
