    <JadeMethod name="trxUpdateRepack" id="9437f6ba-7397-4796-bd6d-0270a053be6c">
        <updating/>
        <source>trxUpdateRepack(_pxyContainerToEmpty, _pxyContainerToRepack: CM_TrackedItem input; 
				_noCharge : Boolean input; 
				_passport : CM_Passport input ) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 02 December 2003
//
// Repack is different to Pack/Unpack in that the contents of a container
// are swapped from one container to another.  PackUnpack literally shifts
// one container into another.
//********************************************************************
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	//Pass a to be filled proxy container, a to be emptied proxy container that has the details swapped.
	app.myUtilityUA.utlUpdateRepack( _pxyContainerToEmpty, _pxyContainerToRepack, _noCharge, TI_UPDMODE_NORMAL, _passport);
	
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyContainerToEmpty" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_pxyContainerToRepack" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_noCharge" type="Boolean" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
