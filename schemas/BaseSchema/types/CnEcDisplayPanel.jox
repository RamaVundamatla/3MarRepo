    <JadeMethod name="getDataColumnWidths" id="a043c571-c6b5-4d94-98cd-f9761c5433c6">
        <source>getDataColumnWidths() : IntegerArray;
// --------------------------------------------------------------------------------
// Created:		16 August 1999 by cnwdad1
//
// Purpose:		Returns an array of column widths in the data table.
//
// Parameters:	None
// Returns:		An integer array, where each element represents the width of its
//				corresponding column width, i.e. element 1 is column 1 etc.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	return  dataColumnWidths;
end;</source>
        <ReturnType type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="getDisplayColumnWidths" id="25ad2890-e8ad-4198-945d-d1c8a001635d">
        <source>getDisplayColumnWidths() : IntegerArray;
// --------------------------------------------------------------------------------
// Created:		16 August 1999 by cnwdad1
