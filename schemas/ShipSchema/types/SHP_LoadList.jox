    <JadeMethod name="doMnuHideClick" id="094166ae-faa7-479b-9baa-452c33a3d0dd">
        <updating/>
        <source>doMnuHideClick(_menuItem :MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		22 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 10/03/2011	cnwcs5 	Added menu item as parameter so it superclass method can 
//						be used in sub-forms with their own show/hide menu
vars

begin
	if _menuItem.caption = self.MNU_MACRO_HIDE then
		_menuItem.caption := self.MNU_MACRO_SHOW;
		self.splMain.hideRightControl(true);
		self.splTranShip.hideRightControl(true);
		self.splTBA.hideRightControl(true); // TFS 45590
		self.splPlanned.hideRightControl(true);
		self.splDLR.hideRightControl(true);
	else
		_menuItem.caption := self.MNU_MACRO_HIDE;
		self.splMain.showRightControl(30, true);
		self.splTranShip.showRightControl(30, true);
		self.splTBA.showRightControl(30, true); // TFS 45590
		self.splPlanned.showRightControl(30, true);
		self.splDLR.showRightControl(30, true);
		self.frmPopupInfo.visible := false;
	endif;
	xmlMacro := self.mnuContextHide.caption = self.MNU_MACRO_SHOW;
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuInspectObject" id="e4437b79-259a-4d70-9aa9-98eec551764b">
        <source>doMnuInspectObject();
//--------------------------------------------------
// Created:	12 December 2003 By: cnwgd1
//--------------------------------------------------
// 08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
vars

	invalidVoyage : Boolean;
	currentVoyage 	: CM_Voyage;
begin
	on Exception do app.handleDeletedObject(exception, currentVoyage, invalidVoyage); //10/10/08 cnwdz2 Par 17732
	
	if self.mnuInspectObject.userObject &lt;&gt; null then
		self.mnuInspectObject.userObject.inspectModal;
	else
		currentVoyage := self.myCurrentVoyage;
		if currentVoyage &lt;&gt; null then
			currentVoyage.inspectModal;
			//10/10/08 cnwdz2 Par 17732
			if invalidVoyage then						
				return;
			endif;
		else
			inheritMethod();
		endif;
	endif;
end;</source>
    </JadeMethod>
