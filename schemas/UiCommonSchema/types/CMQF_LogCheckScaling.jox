<Class name="CMQF_LogCheckScaling">
    <JadeMethod name="setFromAgent" id="b652f68f-728c-4214-9cf3-592377223176">
        <updating/>
        <source>setFromAgent(_agent : CMUI_ReportAgent input) updating;
// ---------------------------------------------------------------------------
// Created:     15 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	speciesCodeStr,
	gradeCodeStr,
	typeCodeStr,
	treatmentCodeStr,
	lengthCodeStr,
	scalerCodeStr,
	operatorCodeStr			: String;
begin
	inheritMethod(_agent);
	//PAR16192 cnwsh3 - Check date is returned based on locale also.
	//self.fromDate:= _agent.getValueByName(ETRow_StartDate).Date;
	//self.toDate:= _agent.getValueByName(ETRow_EndDate).Date;
	self.fromDate := _agent.getValueByNameForDateIfVisible(ETRow_StartDate);
	self.endDate := _agent.getValueByNameForDateIfVisible(ETRow_EndDate);
	
	self.batchNo := _agent.getValueByName(ETRow_BatchNo).Integer;

	scalerCodeStr := _agent.getValueByName(ETRow_ScalerCode).String;
	if scalerCodeStr &lt;&gt; Any_String then
		self.checkScalerCode := scalerCodeStr;
	endif;
	
	scalerCodeStr := _agent.getValueByName(ETRow_OrigScaler).String;
	if scalerCodeStr &lt;&gt; Any_String then
		self.scalerCode := scalerCodeStr;
	endif;
	
	operatorCodeStr := _agent.getValueByName(ETRow_OperatorCode).String;
	
	if operatorCodeStr &lt;&gt; Any_String then
		self.operatorCode := operatorCodeStr;
	endif;
	
	speciesCodeStr := _agent.getValueByName(ETRow_LogSpecies).String;
	if speciesCodeStr &lt;&gt; Any_String then
		self.speciesCode := speciesCodeStr;
	endif;
	
	gradeCodeStr := _agent.getValueByName(ETRow_LogGrade).String;
	if gradeCodeStr &lt;&gt; Any_String then
		self.gradeCode := gradeCodeStr;
	endif;
	
	typeCodeStr := _agent.getValueByName(ETRow_LogType).String;
	if typeCodeStr &lt;&gt; Any_String then
		self.typeCode := typeCodeStr;
	endif;
	
	treatmentCodeStr := _agent.getValueByName(ETRow_LogTreatment).String;
	if treatmentCodeStr &lt;&gt; Any_String then
		self.treatmentCode := treatmentCodeStr;
	endif;
	
	lengthCodeStr := _agent.getValueByName(ETRow_LogLength).String;
	if lengthCodeStr &lt;&gt; Any_String then
		self.lengthCode := lengthCodeStr;
	endif;

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
