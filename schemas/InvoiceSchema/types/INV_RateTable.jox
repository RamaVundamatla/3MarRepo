    </JadeMethod>
    <JadeMethod name="initDebtorMSG" id="9bf1186b-4873-4a31-9fba-c202c2c2406a">
        <source>initDebtorMSG();
// ---------------------------------------------------------------------------
// Created:		July 2010 by cnwjre1 for par 24052, multi-select debtors and services
//
// Purpose:		initialise the debtor CMUI_MultiSelectGroupBox
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	---------	--------------------------------------------------
// 05/02/2025	navlw1		JIRA-33945: MTN | Add Filter MSG to Some Forms
// ---------------------------------------------------------------------------
vars
	theGroupBox : CMUI_MultiSelectFilterGroupBox; // navlw1 #JIRA-33945 05/02/2025
begin
	theGroupBox := self.msgbDebtors;
	theGroupBox.caption := null;
	
	// navlw1 End #JIRA-33945 05/02/2025
	theGroupBox.myAvailableListBox.stretchHeight	:= true;
	theGroupBox.myAvailableListBox.stretchWidth	:= false;
	theGroupBox.myAvailableListBox.integralHeight	:= false;
	theGroupBox.mySelectedListBox.stretchHeight	:= true;
	theGroupBox.mySelectedListBox.stretchWidth	:= false;
	theGroupBox.mySelectedListBox.integralHeight	:= false;
	// navlw1 End #JIRA-33945 05/02/2025
	
	theGroupBox.multiSelect 	:= ListBox.MultiSelect_Extended;
	theGroupBox.formDisplayEntryMethodName := "displayDebtor";
