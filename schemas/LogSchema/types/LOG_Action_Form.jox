    <JadeMethod name="create" id="27788a4e-cd4a-4de7-b5c7-1681595a284b">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     15 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

// need to change these when permissions worked out
	self.permissionView  := PmAdmRestrictionsView;
	self.permissionMaint := PmAdmRestrictionsMaint;
	
	self.helpFileName := HelpFile_Logs;

end;</source>
    </JadeMethod>
    <JadeMethod name="displayLocation" id="305eacbd-9ba6-4ee4-9f33-8d5691f57a1f">
        <updating/>
        <source>displayLocation(_location : CM_LogController input) protected, updating;

vars
	display 	: String;
	ti			: CM_TrackedItem;
	volume		: Decimal[12,2];
	analysis	: CM_SOHLocation;
	logProduct	: CM_ProductLog;
	tmpDef		: CMIF_DocketLogDef;
	species, grade, type, treatment, length : String;
	failedDAC  :CM_DataAccessController;

begin

	if _location &lt;&gt; null then
		self.allDocketLogDef.purge;
		
		if _location.myTerminalArea.isStockControlled then
			// Get analysis data from location.
			foreach analysis in _location.allProductLocations do
				if analysis.myProduct.isKindOf(CM_ProductLog) and analysis.allTrackedItems.size &gt; 0 then	
					logProduct := analysis.myProduct.CM_ProductLog;
					if (not logProduct.canUserAccessSelf(null, failedDAC,app.myPassport)) then
						continue;
					endif;
					// Once we have a code extract relevant details.
					grade 		:= logProduct.gradeCode;
					species 	:= logProduct.speciesCode;
					type 		:= logProduct.typeCode;
					length 		:= logProduct.lengthCode;
					treatment	:= logProduct.treatmentCode;
					// Store detail in cmif docket object.
					create tmpDef transient;
					tmpDef.init(_location, logProduct.myOperator, species, grade, type, treatment, length, false, analysis.currentQuantity, analysis.currentVolume, null);
					analysis.allTrackedItems.copy(tmpDef.allTi);
					//tmpDef.copyTis(analysis.allTrackedItems, false);
					self.allDocketLogDef.add(tmpDef);
				endif;
			endforeach;
		else
			create tmpDef transient;
			//tmpDef.init(_location, logProduct.myOperator, species, grade, type, treatment, length, false, null);
			tmpDef.init(_location, null, null, null, null, null, null, false, 0,0, null);
			beginLoad;
			tmpDef.copyTis(_location.allTrackedItems, true);
			endLoad;
			self.allDocketLogDef.add(tmpDef);
		endif;
		// Load up data for display.
		self.setSelectionData();
		self.myLocation := _location;
	endif;
epilog
	endLoad;
end;</source>
        <access>protected</access>
        <Parameter name="_location" type="CM_LogController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displaySelectedDocketLocation" id="7c49f84d-0563-4394-ba54-3723018a760b">
        <updating/>
        <source>displaySelectedDocketLocation(_docketDef : CMIF_DocketLogDef) : String  protected, updating;

vars
	operatorTerminology,
	display 					: String;
	termTextLength				: Integer;
begin

	// This is the selected definition.
	self.mySelectedDocketDef := _docketDef;
	// Get dta for display.
	display := 'Number of logs' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.mySelectedDocketDef.numberOfLogs.String &amp; CrLf;
	if self.mySelectedDocketDef.myLocationsController &lt;&gt; null then
		display := display &amp; 'Location' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.mySelectedDocketDef.myLocationsController.getID &amp; CrLf;
	endif;
	if self.mySelectedDocketDef.myOperator &lt;&gt; null then
	
		if self.selection = LOGDOCKET then
			operatorTerminology := self.terminologyForOperatorDocket;
		else
			operatorTerminology := self.terminologyForOperatorLog;
		endif;
	
		termTextLength := self.getTextExtent(operatorTerminology);
		
		if termTextLength  &lt; 48 then 
			display := display &amp; operatorTerminology &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.mySelectedDocketDef.getDisplayStringForAttribute(ETRow_OperatorCode, true) &amp; CrLf;
		elseif termTextLength  &lt; 96 then 
			display := display &amp; operatorTerminology &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.mySelectedDocketDef.getDisplayStringForAttribute(ETRow_OperatorCode, true) &amp; CrLf;
		elseif termTextLength  &lt; 144 then 
			display := display &amp; operatorTerminology &amp; Tab &amp; Tab &amp; Tab &amp; self.mySelectedDocketDef.getDisplayStringForAttribute(ETRow_OperatorCode, true) &amp; CrLf;
		elseif termTextLength  &lt; 192 then 
			display := display &amp; operatorTerminology &amp; Tab &amp; Tab &amp; self.mySelectedDocketDef.getDisplayStringForAttribute(ETRow_OperatorCode, true) &amp; CrLf;
		else // should not be any larger 
			display := display &amp; operatorTerminology &amp; Tab &amp; self.mySelectedDocketDef.getDisplayStringForAttribute(ETRow_OperatorCode, true) &amp; CrLf;
		endif;
	endif;

	display := display &amp; 
			'Species' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.mySelectedDocketDef.species &amp; CrLf &amp;
			'Grade' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.mySelectedDocketDef.grade &amp; CrLf &amp;
			'Type' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.mySelectedDocketDef.type &amp; CrLf &amp;
			'Treatment' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.mySelectedDocketDef.treatment &amp; CrLf &amp;
			'Length' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.mySelectedDocketDef.length &amp; CrLf &amp;
			'Volume' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.mySelectedDocketDef.volume.String;
	
//	txtDetails.text := display; // par11583

	display := display &amp; CrLf;
	return display;


end;</source>
        <access>protected</access>
        <Parameter name="_docketDef" type="CMIF_DocketLogDef"/>
        <ReturnType type="String"/>
    </JadeMethod>
