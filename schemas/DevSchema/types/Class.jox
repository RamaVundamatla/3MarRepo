begin
	return self.properties;
end;
</source>
        <ReturnType type="PropertyNDict"/>
    </JadeMethod>
    <JadeMethod name="isSubclassOfSubschemaCopy" id="d1c950ad-141e-4e04-a335-ff36b2eb812d">
        <source>isSubclassOfSubschemaCopy(cls: Class) : Boolean;

begin
	if self.superclass = null then
		return false;
	endif;
		
	if self.superclass = cls then
		return true;
	endif;
		
	return self.superclass.isSubclassOf(cls);
			
end;</source>
        <Parameter name="cls" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSubschemaCopy" id="7e37cb46-b7db-4c2b-894d-3582e4c1df2f">
        <source>isSubschemaCopy(): Boolean ; 

begin
	return superschemaType &lt;&gt; null;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="superclassIncludesMethodName" id="3dc1160e-133e-423a-918b-50f84874029d">
        <source>superclassIncludesMethodName(str: String) : Method;
vars
	meth: 	Method;
	sst,
	cls:	Class;
	superCls:Class;
begin
	if superclass &lt;&gt; null then
		superCls := superclass;
	endif;	
	//if superCls = null and self.isKindOf(JadeImportedClass) then
	//	superCls := self.JadeImportedClass.getFirstSystemSuperClass;
	//endif;
	if superCls &lt;&gt; null then
		meth := superCls.methods.getAtKey(str);
		if meth = null then
			if superCls.isSubschemaCopy then
				sst := superCls.superschemaType.Class;
				meth := sst.getMethodInHTree(str);
			elseif superCls.schema &lt;&gt; app._getWorkingSchema then
				cls := app._getWorkingSchema.getClass(superCls.name);
				if cls &lt;&gt; null then
					meth := cls.methods.getAtKey(str);
					if meth = null then	
						return cls.superclassIncludesMethodName(str);
					endif;
				endif;
			endif;
			if meth = null then	
				return superCls.superclassIncludesMethodName(str);
			endif;
		endif;
		if meth &lt;&gt; null then
			return meth;
		endif;
	endif;
	return null;
end;</source>
        <Parameter name="str" type="String"/>
        <ReturnType type="Method"/>
    </JadeMethod>
</Class>
