    <JadeMethod name="cnEcGetDuplicate" id="1517622c-0d12-4269-b1f9-982867ac5d5d">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	description : String;
	trade : CM_Trade;

begin

	description := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "description" ).String; 
	
	if description &lt;&gt; null then
		trade := app.myRoot.allTradesByDescription.getAtKey( description );
	endif;

epilog

	return trade;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
