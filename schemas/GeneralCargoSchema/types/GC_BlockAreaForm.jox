    <JadeMethod name="doMnuLocationStatus" id="e0275fe7-b600-4d21-9e2c-4a096aacc755">
        <updating/>
        <source>doMnuLocationStatus(status : Integer; location : CM_LocationsController input) updating, protected;
//03 July 2008	cnwdw1	
//
vars
	allAllocationsObj	: CM_YardAllocationSet;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	create allAllocationsObj transient;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxSetControllerStatusWithYA(status, location, location.edition, allAllocationsObj, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.showExtraInforForLocation(location);
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	delete allAllocationsObj;
end;</source>
        <access>protected</access>
        <Parameter name="status" type="Integer"/>
        <Parameter name="location" type="CM_LocationsController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuYardAllocBuild" id="aea3b05d-9eb4-4a90-8028-3b3b26af776d">
        <updating/>
        <source>doMnuYardAllocBuild(_menuItem : MenuItem input) updating;
/*
Purpose:			
Date				Who			Reason
SEPT 2013		CNWAB1		Initial creation
*/

vars
	index :Integer;
	mnuChild,mnuMaster,
	tmpMenu	: MenuItem;
	ta		: CM_TerminalArea;
	yalloc : CM_YardAllocation;
begin

	_menuItem.visible := true;
	mnuMaster := _menuItem;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.userObject := null;
	mnuMaster.helpKeyword := "MAIN"; // DO NOT TRANSLATE

	
	self.mnuYardAllocNew.caption := app.getErrorString(GCEnqAllocationNew); // "&amp;New Allocation...";
	self.mnuYardAllocNew.visible := true;
	self.mnuYardAllocNew.enabled := true;
	self.mnuYardAllocNew.helpKeyword := "YAChild"; // DO NOT TRANSLATE
	self.mnuYardAllocNew.userObject := null;
	
//23 Jul 2020	NDL	TFS 49775 - Not currently coded to do anything.
//	self.mnuYardAllocRemove.caption := app.getErrorString(GCEnqAllocationRemove); // "&amp;Remove Allocation...";
//	self.mnuYardAllocRemove.visible := true;
//	self.mnuYardAllocRemove.enabled := true;
//	self.mnuYardAllocRemove.helpKeyword := "YAChild"; // DO NOT TRANSLATE
//	self.mnuYardAllocRemove.userObject := null;


	foreach index in 1 to 50 do
		tmpMenu := null;
		mnuChild := mnuMaster.getMenuItem(index);
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
	endforeach;
	
	ta := self.myCurrentTerminalArea;

	index := 1;
	foreach yalloc in ta.allYardAllocations where yalloc.includeInYardDisplays() do
		mnuChild := mnuMaster.loadSubMenu(index);
		mnuChild.caption := yalloc.code &amp; "...";
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := "YAChild"; // DO NOT TRANSLATE
		mnuChild.userObject := yalloc;
		tmpMenu := mnuChild;
		index := index + 1;
	endforeach; 
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doNotableNotification" id="ed6424ff-ae94-4a34-a699-86a8cc90d327">
        <updating/>
        <source>doNotableNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
vars
	event		: Integer;
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if event = Event_YardAllocationCreate or
	   event = Event_YardAllocationUpdate or
	   event = Event_YardAllocationDelete then
	   if self.myDrawingController.viewMode = VIEW_YARD_ALLOC then
		self.myDrawingController.drawSelf(true);
		endif;
   		self.frmColLegendTIs.displayCodesForMode(self.myDrawingController.viewMode, self.myDrawingController.myDrawingAttrController);
	endif;
	
	if event = EVENT_TI_MOVE then
		self.updateUsedProducts();
		// Force the lengend table to rebuild itself by changing view to current view
		self.frmColLegendTIs.doChangeViewModeEx(self.frmColLegendTIs.viewMode, self.myDrawingController.myDrawingAttrController);
		self.frmBlockArea.refresh();
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
