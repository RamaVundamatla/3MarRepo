    <JadeMethod name="setProxyVesselFromEDI" id="8f37af49-32da-4932-b28f-12312fc948b7">
        <updating/>
        <source>setProxyVesselFromEDI(_ediVesselTI : CM_EDIQshipsVesselTI; _operator : CM_Operator; _callSign : String) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 06 September 2023
TFS#		: 59855
Function	:

*** Changes ***
Date			Name		TFS#		Description
12.Dec.2024		navsp1      MTN-33622   NSW - OnePort - Getting a 1090 on verifying a oneport message after creating a vessel present in the message but didn't exist in MTN
****************************************************/

begin	
	self.callSign  := _callSign;	
	self.myOperator  := _operator;
	if _ediVesselTI &lt;&gt; null then							//MTN-33622
		self.lloydsNumber  := _ediVesselTI.lloydsNumber;	
		self.name  := _ediVesselTI.vesselName;
		self.maxVesselBeam  := _ediVesselTI.beam;
		self.draftBow  := _ediVesselTI.draftFore;
		self.draftStern  := _ediVesselTI.draftAft;
		self.draftMid  := _ediVesselTI.draftMid;	
	endif;
end;</source>
        <Parameter name="_ediVesselTI" type="CM_EDIQshipsVesselTI"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_callSign" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyVesselFromXML" id="9f76ab5c-d0b0-47b3-9f09-264621fa48a5">
        <updating/>
        <source>setProxyVesselFromXML(_theXML: String) updating;
//--------------------------------------------------
// Created:	06 October 2005 By: cnwgd1
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//--------------------------------------------------
vars
	class				: String;
	pxyHMSVesselData	: HMS_VesselData;
	tmpOper				: CM_Operator;
	theStructuralType : Integer;
begin
	self.raiseExceptionIfNotTransient(method);
	
	if _theXML = null then
		app.raiseCMException2(ERR_INVALID_VALUE, "XML", "The XML is Empty", null, null);
	endif;
	
	// SET ME
	self.canCreateVoyages	:=	_theXML.cnEcGetTagValueOfName("cv").Integer.Boolean;
	self.code				:=	null; // _theXML.cnEcGetTagValueOfName("cd");
	self.name				:=	_theXML.cnEcGetTagValueOfName("nm");
	self.classLabel			:=	_theXML.cnEcGetTagValueOfName("cl");
	self.callSign			:=	_theXML.cnEcGetTagValueOfName("cs");
	self.lloydsNumber		:=	_theXML.cnEcGetTagValueOfName("ln");
	self.dailyCost			:=	_theXML.cnEcGetTagValueOfName("dc").Integer;
	self.despatchRate		:=	_theXML.cnEcGetTagValueOfName("dr").Integer;
	self.craneClearance		:=	_theXML.cnEcGetTagValueOfName("cc").Integer;
	self.remarks			:=	_theXML.cnEcGetTagValueOfName("rm");
	self.vesselType			:=	_theXML.cnEcGetTagValueOfName("vt").Integer;
	// set operator 
	self.myOperator			:=	app.myRoot.allOperators[_theXML.cnEcGetTagValueOfName("op")];

	if _theXML.cnEcGetTagValueOfName("hms").Integer.Boolean
	and app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE(), Mod_Harbour)  //06.10.2017	cnwma1  TFS #7257
	then
		// create HMS vessel data
		create pxyHMSVesselData transient;
		self.setHMSVesselData(pxyHMSVesselData);
		pxyHMSVesselData.setProxyVesselFromXML(_theXML);
	endif;

	if _theXML.cnEcGetTagValueOfName("gcv").Integer.Boolean 
	and app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE(), Mod_GeneralCargo)
	then
		// create general cargo structure data
		create self.myGeneralCargoVesselStructure transient;
		self.myGeneralCargoVesselStructure.setProxyVesselFromXML(_theXML);
	endif;	

	if _theXML.cnEcGetTagValueOfName("cell").Integer.Boolean 
//	and app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE(), PmShipPlanning)
// ### JIRA 33505 30DEC2024 NAVAB1 (Mod_CargoShip in part of base now)	and app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE(), Mod_CargoShip)//07 Oct 2019	NDL	TFS 46169
	then
		// create cellular structure data
		create self.myCellularVesselStructure transient;
		self.myCellularVesselStructure.setProxyVesselFromXML(_theXML);
		
		//cnwrd1 par 31874
		create self.myStructuralElements transient;
		self.myStructuralElements.setProxyVesselFromXML(_theXML);
		
//	elseif app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE(), PmShipPlanning) then
	else // ### JIRA 33505 30DEC2024 NAVAB1 (Mod_CargoShip in part of base now) if app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE(), Mod_CargoShip) then//07 Oct 2019	NDL	TFS 46169
		class	:=	_theXML.cnEcGetTagValueOfName('class');
		
		if class = "CM_CellularVessel" 
		or class = null // old JTVs
		or class = CM_CellularVesselStructure.name
		then
			// create Cellular structure
			create self.myCellularVesselStructure transient;	
			self.myCellularVesselStructure.setProxyVesselFromXML(_theXML);
	
			//cnwrd1 par 31874
			create self.myStructuralElements transient;
			self.myStructuralElements.setProxyVesselFromXML(_theXML);
		endif;
	endif;
	
	if theStructuralType = CellularStructureRORO 
	and app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE(), Mod_VesselRORO) then
			create self.myROROVesselStructure transient;	
			self.myROROVesselStructure.setType(CellularStructureRORO);
	endif;
	
	self.airDraft := _theXML.cnEcGetTagValueOfName("ADRFT").Decimal;
	self.buildingLine :=  _theXML.cnEcGetTagValueOfName("BLINE").Decimal;
	 self.draftBow := _theXML.cnEcGetTagValueOfName("DRBOW").Decimal;
	 self.draftMid := _theXML.cnEcGetTagValueOfName("DMID").Decimal;
	 self.draftStern := _theXML.cnEcGetTagValueOfName("DSTRN").Decimal;
	 self.yearOfBuild := _theXML.cnEcGetTagValueOfName("YRBLD").Integer;
	 self.loaWithRampsDown := _theXML.cnEcGetTagValueOfName("LOARMP").Decimal;


end;</source>
        <Parameter name="_theXML" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyVesselStructures" id="73bc38ff-591d-4291-950b-5f9961bc50c6">
        <updating/>
        <source>setProxyVesselStructures(	_pxyGCVessel : CM_GeneralCargoVesselStructure;
							_pxyCellularVessel : CM_CellularVesselStructure;
							_pxyStructElements : CM_VesselStructuralElements ) updating;
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	if _pxyGCVessel &lt;&gt; null then
		_pxyGCVessel.raiseExceptionIfNotTransient(method);
		
		if self.myGeneralCargoVesselStructure &lt;&gt; null 
		and _pxyGCVessel &lt;&gt; self.myGeneralCargoVesselStructure then
			app.raiseUnexpectedProgramError(class.name, method.name, 'myVesselGeneralCargoStructure reference is already set');
			return;
		endif;
		
		self.myGeneralCargoVesselStructure := _pxyGCVessel;
	endif;

	if _pxyCellularVessel &lt;&gt; null then
		_pxyCellularVessel.raiseExceptionIfNotTransient(method);
		
		if self.myCellularVesselStructure &lt;&gt; null
		and _pxyCellularVessel &lt;&gt; self.myCellularVesselStructure then		
			app.raiseUnexpectedProgramError(class.name, method.name, 'myVesselCellularStructure reference is already set');
			return;
		endif;
		
		self.myCellularVesselStructure := _pxyCellularVessel;
	endif;	
	
	//cnwrd1 31874
	if _pxyStructElements &lt;&gt; null then
		_pxyStructElements.raiseExceptionIfNotTransient(method); //cnwrd1 par 32696 
		if self.myStructuralElements &lt;&gt; null 
			and _pxyStructElements &lt;&gt;  self.myStructuralElements  then
				app.raiseUnexpectedProgramError(class.name, method.name, 'myStructuralElements reference is already set');
			return;			
		endif;	
		self.myStructuralElements := _pxyStructElements;
	
		
	endif;
end;</source>
        <Parameter name="_pxyGCVessel" type="CM_GeneralCargoVesselStructure"/>
        <Parameter name="_pxyCellularVessel" type="CM_CellularVesselStructure"/>
        <Parameter name="_pxyStructElements" type="CM_VesselStructuralElements"/>
    </JadeMethod>
