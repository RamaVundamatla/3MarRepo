    <JadeMethod name="doCOOApproval" id="fc05ff1a-4dfe-4d06-b85e-7463ae6b9258">
        <source>doCOOApproval(_cmifAgent : CMIF_COOAgent);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 58257: Jade - TRX Ownership Change Approval
08/12/2023	navkc1 ChangeRequest 58261 Task 58259: Jade - COO Future Storage Resync
15/05/2024	navkc1 Bug 64126: MTN - Cargo Review - Group and Detail columns details for COO is not appearing correctly on the Target
02/09/2024	navnk30	Bug 65914: EUP | COO - Changes to be made on the Transactions after approving the COO
05/09/2024	navnk30	Bug 65869: FR - 53382 - Invoice Contract is not getting updated on New operator if the old operator has Invoice contract.
*/

vars
	expiryDate	: Date;
	pxyTi,
	newTi,
	ti 				: CM_TrackedItem;
	transferQty		: Integer;
	transferWgtVol	: Decimal[23,4];
	doSplit			: Boolean;
	newContractId,
	newId			: String;
	newIds			: StringArray;
	terminal		: CM_Terminal;
	cooHeader		: CM_OwnershipChange;
	newOperator		: CM_Operator;
	txnParams		: CMIF_BBDiscrepancyController;
	aTITrans		: CM_TITransaction;
	cargoGroup		: CM_CargoGroup;
	moveController	: CMIF_MoveController;
	cmifDetail		: CMIF_COODetails;
	sourceStoDetail,
	clonedStoDetail,
	newStoExpDetail	: CM_StorageExpiryDetail;
	storageDetail : CM_StorageDetail;
	freeStoExp : CM_StorageExpiryDetail;
	oldOpExtDays : Integer;
	info			: StringArray512;
	freeStoExpTS : TimeStamp;
	ftAnniversary : Date;
	deleteBGPFT, deleteFSTrans : Boolean;
	extraParams : CMIF_TIUpdateExtraParams;
begin
	ti := self.myTrackedItem;
	
	if ti = null then
		return;
	endif;
	
	ftAnniversary := ti.getFutureStorageAnniversary(); // ### TFS BUG 64680 17JUNE024 NAVAB1 - get current anniversary, before we change it.
	
	cargoGroup := ti.myCargoGroup;
	
	terminal := ti.myTerminal;
	
	cooHeader := self.getOwnershipChangeHeader();
	
	newOperator := cooHeader.myOperatorNew;
	
	create moveController transient;
	
	if ti.isBulkByVolume() then
		transferWgtVol := self.transferredVolume;
		doSplit := transferWgtVol &lt; ti.totalVolume;
	
	elseif ti.isBulkByWeight() then
		transferWgtVol := self.transferredWeight;
		doSplit := transferWgtVol &lt; ti.totalWeight;
												 
	else
		transferQty := self.transferredQuantity;
		doSplit := transferQty &lt; ti.totalQuantity;
										   
	endif;
	
	if doSplit then
		create newIds transient;
		cmifDetail := _cmifAgent.allCmifCooDetails[self];
		if cmifDetail = null then
			return;
		endif;
		
		newId := cmifDetail.newId;
		if newId = null then
			newId := self.getNewIDForTI(self.myTrackedItem.id);
		endif;
		
		sourceStoDetail := ti.getStorageExpiryDetail();
		
		newIds.add(newId);
		app.myValUA.valBreakBulkSplitManual( ti.CM_Cargo, newIds, transferQty, transferWgtVol, app.myPassport);
		
		if app.myPassport.hasErrors() then
			return;
		endif;
		
		app.myUtilityUA.utlSplitBreakBulkToNewID( ti.CM_Cargo, newId, newTi, transferQty, transferWgtVol, newOperator, true,
							true,
							true,
							true, null, app.myPassport);
	
		// ### JIRA 33701 19DEC2024 NAVAB1
		if app.myPassport.hasErrorsOrWarnings() then
			return;
		endif;
		
		if cooHeader.condition &lt;&gt; null then
			newTi.setCondition(cooHeader.condition);
		endif;
		
		if cooHeader.myFreightForwarder &lt;&gt; null then
			newTi.setFreightForwarder(cooHeader.myFreightForwarder.code);
		endif;
		
		// ### TFS CR 64873 TASK 65509 02AUG2024 NAVAB1
		if cooHeader.myIncoterm &lt;&gt; null then
			newTi.setINCOTermCode(cooHeader.myIncoterm.code);
		endif;
		
		if _cmifAgent.newLocation &lt;&gt; null 
		and newTi.locationId &lt;&gt; _cmifAgent.newLocation then // ### TFS CR 58263 TASK 58264 02FEB2024 NAVAB1
			moveController.setMyTrackedItem(newTi);
			moveController.setMyToPrimaryLocnFromString(terminal, _cmifAgent.newLocation, REAL_MODE);
			moveController.isForcedMove := true;
			moveController.isSystemMove := true;
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, app.myPassport);
		endif;
		
		// We should have a cloned storage details here, because it got done during split.
		// We wanna change the cloned date to be the same as source rather than current date.
		if sourceStoDetail &lt;&gt; null then
			clonedStoDetail := newTi.getStorageExpiryDetail();
			clonedStoDetail.setDateTime(sourceStoDetail.dateTime);
		endif;
		
		
		  if not _cmifAgent.reapproval then // ### JIRA 33015 04OCT2024 NAVAB1
			// Create a new storage expiry detail to the new TI;
			// This storage expiry details will have the COO reference 
			newStoExpDetail := self.doCreateStorageExpDetai(newTi, self);
		endif;
		//15/05/2024	navkc1 Bug 64126 Add newTI to the Ownership Change split off collection
		newTi.setMySplitOffCOO(cooHeader);
	else
		
		if cargoGroup &lt;&gt; null and not cargoGroup.allOperators.includes(newOperator) then
			cargoGroup.allOperators.add(newOperator);
		endif;
		
		
		pxyTi := ti.pxyCreateUpdateProxy();
		
		if cooHeader.condition &lt;&gt; null then
			pxyTi.setCondition(cooHeader.condition);
		endif;
		
		// ### TFS CR 64873 TASK 65509 02AUG2024 NAVAB1
		if cooHeader.myIncoterm &lt;&gt; null then
			pxyTi.zSetPxyINCOTermCode(cooHeader.myIncoterm.code);
		endif;
		
		
		if cooHeader.myFreightForwarder &lt;&gt; null then
			pxyTi.setFreightForwarder(cooHeader.myFreightForwarder.code);
		endif;
		
		pxyTi.setMyOperator(newOperator);
		if self.myOwnershipChange &lt;&gt; null and self.myOwnershipChange.myInvoiceContract &lt;&gt; null then		//05.09.2024 navnk30 #65869
			newContractId := self.myOwnershipChange.myInvoiceContract.contractId;
		endif;
		pxyTi.setContractId(newContractId);																//05.09.2024 navnk30 #65869
		pxyTi.checkProxyStopApplicable(); //25/03/2024	navkc1 Defect 62985 - Cancel stop if no longer valid as the operator changed
		
		// ### TFS BUG 65978 04SEP2024 NAVAB1
		create extraParams transient;
		extraParams.dateTime := cooHeader.dateTimeCOO;
		app.myPassport.setWarningsIgnored(true);	// ### JIRA 33962 01APR 2025 NAVAB1
		app.myUtilityUA.utlUpdateTrackedItem(pxyTi, null, TI_UPDMODE_NORMAL, null, extraParams, null, app.myPassport); //02.09.2024 navnk30 #65914 // ### TFS BUG 65978 04SEP2024 NAVAB1

		ti.latestEdition();
		
		// Accumulate the transfer amount in COO header
		cooHeader.addTransferredQty(self.transferredQuantity);
		cooHeader.addTransferredVol(self.transferredVolume);
		cooHeader.addTransferredWeight(self.transferredWeight);
		
		if not _cmifAgent.reapproval then // ### JIRA 33015 04OCT2024 NAVAB1 
			// In full approval, we create new storage expiry details.
			newStoExpDetail := self.doCreateStorageExpDetai(ti, self);
		 endif;
	endif;
	
	expiryDate := cooHeader.storageExpiryOperatorNew.date(); // ### TFS BUG 64680 21JUNE024 NAVAB1
	// ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1 - these were not used in the end - expiryDate.addDays(cooHeader.freeDaysAdditional + cooHeader.freeDaysOperatorNew);
	
	// Create COO transaction - New TI
	if doSplit and newTi &lt;&gt; null then
		delete txnParams;
		create txnParams transient;
		txnParams.type := TRANS_TYPE_OWNERSHIP_CHANGED;
		txnParams.dateTime := cooHeader.dateTimeCOO; //02.09.2024 navnk30 #65914

		aTITrans := newTi.createTransaction(txnParams, app.myPassport);
		// ### JIRA 33701 19DEC2024 NAVAB1
		if app.myPassport.hasErrorsOrWarnings() then
			return;
		endif;
		aTITrans.CM_OwnershipChanged.setDetailsFromCOO(self, cooHeader, newTi);
		
		// Need to re-evaluate stop for the new TI
		if newTi.getImExStatus() = TI_IMEX_STATUS_TRANSHIP then
			newTi.setStopsForTranship();
		elseif newTi.isExport then
			newTi.setStopsForExport();
		elseif newTi.isImport then
			newTi.setStopsForImport();
		endif;
		
		// Create BGP FS transaction and invoice line for new TI
		newTi.doCOOResyncFSTransactions(cooHeader.dateTimeCOO.date(), true, true, true, self, expiryDate,"Change of Ownership Re-sync"); // ### JIRA 33011 10OCT2024 NAVAB1
		
		// Accumulate the transfer amount in COO header
		cooHeader.addTransferredQty(newTi.totalQuantity);
		cooHeader.addTransferredVol(newTi.totalVolume);
		cooHeader.addTransferredWeight(newTi.totalWeight);
	endif;
	
	// Create COO transaction - Source TI
	delete txnParams;
	create txnParams transient;
	txnParams.type := TRANS_TYPE_OWNERSHIP_CHANGED;
	txnParams.dateTime := cooHeader.dateTimeCOO; //02.09.2024 navnk30 #65914

	aTITrans := ti.createTransaction(txnParams, app.myPassport);
	
	// ### JIRA 33701 19DEC2024 NAVAB1
	// ### JIRA 33962 01APR 2025 NAVAB1
	if app.myPassport.hasErrors then
		return;
	endif;
	if app.myPassport.hasWarnings() then
		if not app.myPassport.warningsIgnored then
			return;
		endif;
	endif;
	
	aTITrans.CM_OwnershipChanged.setDetailsFromCOO(self, cooHeader, newTi);
	
	//08/12/2023	navkc1 ChangeRequest 58261 Task 58259, if we are splitting, then the source TI should still have the transaction (new qty/weight????)
	if ti.isFutureStorage(storageDetail) then // ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1
	
		// ### TFS BUG 64680 17JUNE024 NAVAB1
		deleteBGPFT:= not doSplit;
		deleteFSTrans :=  not doSplit; // ### TFS BUG 65978 04SEP2024 NAVAB1
		if cooHeader.storageExpiryOperatorNew.date() &gt;= ftAnniversary then
			deleteBGPFT := false;
			deleteFSTrans := false; // ### TFS BUG 65978 04SEP2024 NAVAB1
		endif;
		
// ### JIRA 33011 10OCT2024 NAVAB1		ti.doCOOResyncFSTransactions(cooHeader.dateTimeCOO.date(), not doSplit, deleteFSTrans, deleteBGPFT, self, expiryDate); // ### TFS BUG 65978 04SEP2024 NAVAB1


		ti.doCOOResyncFSTransactions(expiryDate, not doSplit, deleteFSTrans, deleteBGPFT, self, expiryDate, "Change of Ownership Re-sync"); // ### JIRA 33011 10OCT2024 NAVAB1 // ### JIRA 33011 10OCT2024 NAVAB1
	endif; 
	
	ti.doCOOResyncTransactions(self, expiryDate); // ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1 // CR 64873 TASK 65509 06AUG2024 NAVAB1
	
	// ### TFS CR 58263 TASK 58264 30JAN2024 NAVAB1
	// Add the COO additional free days
	/* 20FEB2024 Not doing this now, the additional free days was for the NEW operator only
	oldOpExtDays := cooHeader.freeDaysOperatorOld;
	if oldOpExtDays &gt; 0 then
		freeStoExp := ti.getStorageExpiryDetaiForOp(cooHeader.myOperatorOld.code, cooHeader.dateTimeCOO);
		if freeStoExp &lt;&gt; null then
			create info transient;
			info.add(oldOpExtDays.String &amp; " days added to " &amp; freeStoExp.freeStorageExpiry.asStringJMT() &amp; " for ownership change " &amp; cooHeader.refNumber);
				
			freeStoExpTS:= freeStoExp.freeStorageExpiry.addDays(oldOpExtDays);
			info.add("New free storage expiry is " &amp; freeStoExpTS.asStringJMT());
			
			freeStoExp.setFreeStorageExpDate(freeStoExpTS);
			freeStoExp.setAdditionalStorageDays(oldOpExtDays);
			freeStoExp.setStorageChangeReason(oldOpExtDays.String &amp; " Days Added For Ownership Change " &amp; cooHeader.refNumber);
			
			ti.createInfomationTransaction("Free storage expiry date amended for " &amp; freeStoExp.operatorCode, info, null, app.myPassport);					

		endif;
	endif;
	*/
epilog
	delete info;
	delete pxyTi;
	delete newIds;
	delete txnParams;
	delete moveController;
	delete extraParams;
end;</source>
        <Parameter name="_cmifAgent" type="CMIF_COOAgent"/>
    </JadeMethod>
    <JadeMethod name="doCreateStorageExpDetai" id="2c22fab8-3b7a-4a0d-8d25-08c9d5d4168d">
        <source>doCreateStorageExpDetai(_ti : CM_TrackedItem; _cooDetail : CM_OwnershipChangeDetail) : CM_StorageExpiryDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/12/2023	navkc1 ChangeRequest 58261 Task 58260: Jade - COO Invoice Issues Send Email
17/05/2024	navkc1 Bug 64185: MTN - COO (Storage Detail is not created in Cargo Enquiry even if the COO is approved)
*/

vars
	storageDetail 	: CM_StorageDetail;
	pxyStoExpDtl,
	realStoExpDtl,
	prevStoExpDtl: CM_StorageExpiryDetail;
	now, stoExpDT		: TimeStamp;
	cooHeader		: CM_OwnershipChange;
	chargedDaysType, addDays, freeDays, freeDayRem, freeDaysType, freeStoDays : Integer;
	incocode, opbillcode, changeReason : String;
	newDate : Date;
	isFutureStorage : Boolean;
	futureStorageTS	: TimeStamp;
begin

	// ### TFS BUG 65978 04SEP2024 NAVAB1
	if not _ti.isOnSite() then
		return null;
	endif;

	storageDetail := _ti.getMatchingFreeStorageDetail(null);
	
	isFutureStorage := _ti.isFutureStorage(storageDetail); //31/05/2024	navkc1 Bug 64355
	
	//17/05/2024	navkc1 Bug 64185 - We still need to create storage expiry details for COO even if ther's no matching storage config.
	/*if storageDetail = null then
		return null;
	endif;
	*/
	
	cooHeader := _cooDetail.getOwnershipChangeHeader();
	
	if cooHeader &lt;&gt; null then
		stoExpDT := cooHeader.dateTimeCOO;
	endif;
	
	create pxyStoExpDtl transient;
	
	addDays := cooHeader.freeDaysOperatorNew;
	
	//17/05/2024	navkc1 Bug 64185
	if storageDetail &lt;&gt; null then
		// ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1
		addDays += storageDetail.cooFreeStorageDays; // ### TFS CR 58263 TASK 58264 20FEB2024 NAVAB1
		//	stoExpDT := stoExpDT.addDays(addDays);
		
		//// ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1 -  use calendars to push the expiry date out, skipping days that are in the calendar
		
		freeDaysType := storageDetail.cooFreeDaysType;
	endif;
	
	if addDays &gt; 0  then
		if freeDaysType = CM_StorageDetail.Working_Days 
		or freeDaysType = CM_StorageDetail.Working_Compulsory_Days then
			if storageDetail &lt;&gt; null then
				newDate := null;
				newDate := storageDetail.addAdditionalCalendarDays(cooHeader.dateTimeCOO.date, addDays, freeDaysType);
				if newDate &lt;&gt; null then
					stoExpDT.setDate(newDate);
					stoExpDT.setTime(stoExpDT.time);
				endif;
			endif;
		else
			stoExpDT := stoExpDT.addDays(addDays);
		endif;
	
	endif;

	// if the previous storage expiry is greater than the calculated one for the new operator then use the previous storage expiry so they are the same
	prevStoExpDtl := _ti.allStorageExpiryDetails.last;
	if prevStoExpDtl.freeStorageExpiry.date &gt; stoExpDT.date then
		stoExpDT.setDate(prevStoExpDtl.freeStorageExpiry.date);
		stoExpDT.setTime(stoExpDT.time);
	endif;

// ################	
	
	if cooHeader.myIncoterm &lt;&gt; null then
		incocode := cooHeader.myIncoterm.code;
	endif;
	
	freeDayRem:=  (now.date - stoExpDT.date).Integer;
	
	if cooHeader.myOperatorStorage &lt;&gt; null then
		opbillcode := cooHeader.myOperatorStorage.code;
	endif;
	
	//17/05/2024	navkc1 Bug 64185
	if storageDetail &lt;&gt; null then
		freeDays := storageDetail.chargeDays;
		
		freeDaysType := storageDetail.cooFreeDaysType;
		if freeDaysType = 0 then
			freeDaysType := storageDetail.freeDaysType;
		endif;
		
		freeStoDays := storageDetail.cooFreeStorageDays;
		if freeStoDays = 0 then
			freeStoDays := storageDetail.freeStorageDays;
		endif;
		
		chargedDaysType := storageDetail.chargedDaysType;
	endif;
	
	// ### TFS CR 58263 TASK 58264 20FEB2024 NAVAB1 - added change reason
	if cooHeader.freeDaysOperatorNew &gt; 0 then
		changeReason := cooHeader.freeDaysOperatorNew.String &amp; " Days Added For Ownership Change " &amp; cooHeader.refNumber;
	endif;
	
	//31/05/2024	navkc1 Bug 64355
	if isFutureStorage then
		futureStorageTS := stoExpDT;
	endif;
	
//	pxyStoExpDtl.setStorageExpiryDetail(_ti.additionalStorageDays, stoExpDT, null, storageDetail.freeDaysType, null, storageDetail.freeStorageDays, null, null, null, null, 
//			null, storageDetail, _ti, _ti.operatorCode, null, null, _ti.totalQuantity, _ti.totalVolume, _ti.totalWeight, storageDetail.chargedDaysType);
	// ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1
	pxyStoExpDtl.setProxy(cooHeader.freeDaysOperatorNew, now,freeDays, freeDaysType, null, // ### TFS CR 58263 TASK 58264 20FEB2024 NAVAB1 set additional days given
														freeStoDays,freeDayRem, stoExpDT, 
														//null, incocode, cooHeader, // ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1 have done DB change so can set proxy to persistant
														futureStorageTS, incocode, cooHeader, //31/05/2024	navkc1 Bug 64355
														storageDetail, _ti,cooHeader.myOperatorNew.code, opbillcode, 
														changeReason, _ti.totalQuantity, _ti.totalVolume, _ti.totalWeight, chargedDaysType);
	
	app.myUtilityCA.utlCreateStorageExpDtl(pxyStoExpDtl, realStoExpDtl, app.myPassport);
	
	return realStoExpDtl;
epilog
	delete pxyStoExpDtl;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_cooDetail" type="CM_OwnershipChangeDetail"/>
        <ReturnType type="CM_StorageExpiryDetail"/>
    </JadeMethod>
    <JadeMethod name="erase" id="6579da22-e999-4eec-a09c-177f13e56fe3">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
Purpose:			

Date		Who		Reason
21 July 2023	navab1	 // ### TFS CR 58246 TASK 59249 21JUL2023 NAVAB1
*/

vars

begin
	if self.myOwnershipChange &lt;&gt; null then
		self.myOwnershipChange.removeTI(self.myTrackedItem);
	endif;
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
