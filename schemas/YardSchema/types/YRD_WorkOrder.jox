    <JadeMethod name="cmbTransport_click" id="ab5dfa84-18f2-4fa7-bdd9-873b05330cc4">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTransport_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Mar 2023	navcs2	ChangeRequest 55443:[54991]: Receive Cargo Work Order - Enhancements
28 Jul 2023	navlw1	ChangeRequest 58730: EUP | Link bill of lading item to Receive work orders
11 Jul 2023 navma1  Defect 59095: EUP - Able to save the Receive Cargo Work Order without the Booking selected when the VAS Subscription is on/off
19 Jul 2023 navhl20 Bug 59175: MTN - Issues with selected cargo items when Loading cargo Receive and Release work orders 
14 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes
15 Sep 2023 navhl20 Bug 60510: MTN - Work Order Enquiry Release Cargo Rail not populating release request details
04 Oct 2023 navhl20 Bug 60373: MTN - Expected to see a validation message to save the changes before closing the work order form.
20 Oct 2023	navsaa30 ChangeRequest 60819: EUP | Ship Operations in DD - [54176.010] - [Release] Attach cargo items for selected voyage
*/

vars
	voyage : CM_Voyage;
begin
	
	//if self.cmbTransport.listObject.isKindOf(CM_Voyage) &lt;&gt; null then    	//20.10.2023 navsaa30 #60819
	if self.cmbTransport.listObject.isKindOf(CM_Voyage) then				//20.10.2023 navsaa30 #60819
		voyage := self.cmbTransport.listObject.CM_Voyage;
		self.maintainBtnAttachCargo();										//20.10.2023 navsaa30 #60819
	endif;
	self.tblSelectedCargo.clearAllData();									//20.10.2023 navsaa30 #60819
	if self.myPxyTask.isKindOf(CM_WodReceive) then
		self.filterBookingCombo(voyage);
		//if combobox.text = TI_TRANSMODE_SHIP_STR then										//19.7.2023 navhl20 #59175	
		if self.cmbTransMode.text = TI_TRANSMODE_SHIP_STR then								//14.9.2023 navhl20 #60063		
			self.buildCmbBol(voyage);
			self.btnCreateCargo.enabled := true;						//04.10.2023 navhl20 #60373				
		else
			self.buildCmbBooking(voyage);
		endif;
	elseif self.myPxyTask.isKindOf(CM_WodRelease) then
		if self.optBtnBooking.value then							//15.9.2023 navhl20 #60510
			self.buildCmbBooking(voyage);							//11.07.2023 navma1 #59095
		else
			self.buildCmbRelease();
		endif;
	else
		//if combobox.text = TI_TRANSMODE_SHIP_STR then										//19.7.2023 navhl20 #59175
		if self.cmbTransMode.text = TI_TRANSMODE_SHIP_STR then								//14.9.2023 navhl20 #60063
			self.buildCmbBol(null);
		else
			self.buildCmbBooking(null);
		endif;
	endif;
	
	//self.doSaveCargoProxy();
	self.btnSelectCargo.enabled := true; // 28.6.2023 navlw1 tfs 58730
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
