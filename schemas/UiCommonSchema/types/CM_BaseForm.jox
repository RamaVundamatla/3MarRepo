    <JadeMethod name="setFormChanged" id="4e538f61-5548-4c52-bd09-ebcfa4e9d950">
        <updating/>
        <source>setFormChanged(_value: Boolean; bNew, bUpdate, bDelete, bCancel : Button input) updating;
// ---------------------------------------------------------------------------
// Created:     27 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	// set or reset the flag
	isFormChanged := _value;

	// set button states as appropriate
	if bNew &lt;&gt; null then
		bNew.enabled := (not _value);
	endif;
	if bUpdate &lt;&gt; null then
		bUpdate.enabled := _value;
	endif;
	if bDelete &lt;&gt; null then
		bDelete.enabled := (not _value);
	endif;
	if bCancel &lt;&gt; null then
		bCancel.enabled := true;
	endif;

end;</source>
        <Parameter name="_value" type="Boolean"/>
        <Parameter name="bNew" type="Button" usage="input"/>
        <Parameter name="bUpdate" type="Button" usage="input"/>
        <Parameter name="bDelete" type="Button" usage="input"/>
        <Parameter name="bCancel" type="Button" usage="input"/>
    </JadeMethod>
