    <JadeMethod name="canEditAmount" id="4f51816f-78d3-430a-ba16-2fc0c6886db2">
        <source>canEditAmount(): Boolean;
/*

Date		Who		Reason
07 December 2016	cnwer1	Initial creation TFS 2996

*/

vars
	ct : CM_CargoType;
	subType : CM_Product;
begin
	
	self.getCargoTypeAndSubType(ct,subType);
	
	if ct = null or not ct.allowDuplicates then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
