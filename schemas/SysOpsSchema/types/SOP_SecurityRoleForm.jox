    <JadeMethod name="initMulToDoTasks" id="5afc9254-319e-490f-8463-b35c9f4b373e">
        <source>initMulToDoTasks();
// ---------------------------------------------------------------------------
// Created:     17 April 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Date			Who		Reason
// 02/04/2025	navlw1	JIRA-34469: MTN | Filtering in Security Roles
vars

begin

	mulToDoTasksAdd.formDisplayEntryMethodName := 'displayEntryToDoTask';
	mulToDoTasksComp.setAvailable(app.myRoot.allToDoTaskDescriptions, true);
	mulToDoTasksAdd.availableHeading := 'To Do Tasks available';
	mulToDoTasksAdd.selectedHeading := 'To Do Tasks this role can add/remove';
	
	mulToDoTasksAdd.lockBottom 		:= false;
	mulToDoTasksAdd.lockRight		:= false;
	mulToDoTasksAdd.stretchHeight 	:= false;
	mulToDoTasksAdd.stretchWidth 	:= true;
	mulToDoTasksAdd.multiSelect 	:= ListBox.MultiSelect_Extended;

	mulToDoTasksAdd.top 	:= 10;
	mulToDoTasksAdd.left	:= 10;
	
	mulToDoTasksAdd.width 	:= mulToDoTasksAdd.parent.width - 10;
	mulToDoTasksAdd.height 	:= 200;	// navlw1 #JIRA-34469 02/04/2025

	mulToDoTasksAdd.cnEcResizeContents();
	self.shtToDoTasks.cnEcResizeContents();

	mulToDoTasksAdd.readOnly 	:= true;


	// To do Tasks can complete
	mulToDoTasksComp.formDisplayEntryMethodName := 'displayEntryToDoTask';
	mulToDoTasksComp.setAvailable(app.myRoot.allToDoTaskDescriptions, true);
	mulToDoTasksComp.availableHeading := 'To Do Tasks available';
	mulToDoTasksComp.selectedHeading := 'To Do Tasks this role can complete';
	
	mulToDoTasksComp.lockBottom 	:= false;
	mulToDoTasksComp.lockRight		:= false;
	mulToDoTasksComp.stretchHeight 	:= true;
	mulToDoTasksComp.stretchWidth 	:= true;
	mulToDoTasksComp.multiSelect 	:= ListBox.MultiSelect_Extended;

	mulToDoTasksComp.top 	:= mulToDoTasksAdd.top + mulToDoTasksAdd.height + 15;
	mulToDoTasksComp.left	:= 10;
	
	mulToDoTasksComp.width 	:= mulToDoTasksComp.parent.width - 10;
	mulToDoTasksComp.height := mulToDoTasksComp.parent.height - mulToDoTasksComp.top - 10;

	mulToDoTasksComp.cnEcResizeContents();

	mulToDoTasksComp.readOnly 	:= true;

	
	// setup the sheet
	self.shtToDoTasks.cnEcResizeContents();

end;</source>
    </JadeMethod>
