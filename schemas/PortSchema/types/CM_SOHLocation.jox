    <JadeMethod name="getTotalQuantityActual" id="20f5d07b-4974-4114-b472-17055519089f">
        <source>getTotalQuantityActual()  : Integer ;
// ---------------------------------------------------------------------------
// Created:     10 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	ti			: CM_TrackedItem;
	actualQty	: Integer;
	loadState	: Boolean;
begin
	app.cmsBeginLoad(loadState);
	sharedLock(self);
	foreach ti in self.allTrackedItems do
		sharedLock(ti);
		actualQty := actualQty + ti.quantity;
	endforeach;
	return actualQty;
	
epilog
	app.cmsEndLoad(loadState);
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
