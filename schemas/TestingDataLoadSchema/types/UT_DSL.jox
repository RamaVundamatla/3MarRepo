    <JadeMethod name="machineAllocateTask" id="1a1e61b4-6d7e-48c0-81f6-6edfffc76baa">
        <source>machineAllocateTask(_machine: CM_Machine; _task: CM_RTQueueTask) protected;
/*

Purpose:			Allocate the passed in task to the machine

Parameters:			Machine and Task

Return Value:		None

Date		Who		Reason
21 Oct 2011	cnwkpd1	PAR #28383 - Allocate Held tasks

*/
vars
	pxyTask			: CM_RTQueueTask;
	loadStateSet	: Boolean;
	
begin
	app.cmsBeginLoad(loadStateSet);
	pxyTask := _task.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadStateSet);
	pxyTask.setProxyAllocMachine(_machine, _task.myEntry, _task.sourceLocation, _task.targetLocation, _task.ti);

	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateTaskAllocateMachine(pxyTask,false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	app.cmsEndLoad(loadStateSet);
	delete pxyTask;
	
end;</source>
