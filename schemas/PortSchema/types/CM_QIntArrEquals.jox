    <JadeMethod name="doMatch" id="c3358a96-b7e5-4502-9328-2b9def31bf3b">
        <source>doMatch(_value: Any): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	intValue : Integer;
begin
	if _value = null or _value.IntegerArray.isEmpty() then
		return false;
	endif;
	
	foreach intValue in _value.IntegerArray do
		if  intValue = self.searchValue then
			return true;
		endif;	
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
