        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Date		Who		Reason
11 December 2014	cnwer1	Initial creation PAR

*/

vars
	deleteRow : Integer;
	eventTrans : CM_EventTransaction;
begin

/* TFS 2198
	if userInfo &lt;&gt; null and userInfo.isKindOf(CM_EventTransaction) then
		eventTrans:=	userInfo.CM_EventTransaction;
	endif;
	if eventType = EventTransaction_Create_Event then
		if eventTrans &lt;&gt; null and not self.tblEvents.findObjectInRow(eventTrans,deleteRow)  then
			self.tblEvents.addObject(eventTrans);
		endif;
	elseif eventType = EventTransaction_Update_Event then
		if eventTrans &lt;&gt; null  then
			//self.tblEvents.updateItemObject(eventTrans,null,null,app.myPassport);
			self.loadTblEvents(); // PAR 35397 to load charges as well
		endif;
	elseif eventType = EventTransaction_Delete_Event then
		if eventTrans &lt;&gt; null  then
			self.tblEvents.removeItemObject(eventTrans);
		endif;
	endif;
	*/

	self.loadTblEvents(); 
epilog

end;</source>
