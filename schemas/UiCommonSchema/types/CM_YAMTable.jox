        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="replaceItemYA" id="73c4f3fa-f9d3-4b83-9b6c-b0ab09ca8217">
        <updating/>
        <source>replaceItemYA( _ya: CM_YardAllocation ) updating;

/*

Purpose:			Replace updated Yard Allocation

Parameters:			

Return Value:		


Date				Who		Reason
13 November 2008	consw1	Initial creation

*/

vars
	codeOld			: String;
	codeNew			: String;
	obj				: Object;
	rowBlock		: Integer;
	rowYA			: Integer;
	selectedBlocks	: StringArray;
	yaSelected		: Boolean;
	
begin
	
	if not self.findObjectInRow( _ya, rowYA ) then
		if not self.isManuallyMaintained and self.mySearchParameters.isMatchingYA( _ya ) then
			self.addItemYardAllocation( _ya );
		endif;
		return;
	endif;

	//  Save off selected row details
	
	create selectedBlocks transient;

	yaSelected := self.accessRow( rowYA ).selected;
	
	rowBlock := rowYA + 1;

	while rowBlock &lt;= self.rows and self.isChildRow(row) do
		if self.accessedRow.selected then
			selectedBlocks.add( self.getCellValueByName( ETRow_Code, rowBlock ) );
		endif;
		rowBlock := rowBlock + 1;
	endwhile;

	//  Replace item
	
	self.removeItemYAAt( _ya, 0 );

	if not self.isManuallyMaintained and not self.mySearchParameters.isMatchingYA( _ya ) then
		return;
	endif;

	rowYA := self.addItemYardAllocation( _ya );

	//  Restore selected row details
	
	rowBlock := rowYA + 1;

	while rowBlock &lt;= self.rows do
		obj := self.accessRow( rowBlock ).itemObject;
		if not obj.isKindOf(CM_YABlock) then
			break;
		endif;
		codeNew := self.getCellValueByName( ETRow_Code, rowBlock );
		foreach codeOld in selectedBlocks where codeOld = codeNew do
			self.selectObject( obj, false );
			break;
		endforeach;
		rowBlock := rowBlock + 1;
	endwhile;

	if yaSelected then
		self.selectObject( _ya, false );
	endif;
	self.drawTableGrid;
epilog
	delete selectedBlocks;
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="resizeColumn" id="3968451b-b814-4463-95a9-6c6bc34418b1">
