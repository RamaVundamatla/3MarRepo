    <JadeMethod name="shouldAuditProperty" id="e811645f-72bb-4fb1-9b26-e8cc5f3f187a">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Sep 2016	cnwma1	Initial creation
08 Jan 2020 cnwma1	Bug 48197: SNO - Re: Data Base Lock - URGENT - 835582
*/
vars
	propName	: String;

begin

	propName := _property.name;
	
	if propName = CM_BookingRefItem::myBookingRefItemActions.name or 
	   propName = CM_BookingRefItem::cutoffTS.name				  or    //08.01.2020 cnwma1 #48197
	   propName = CM_BookingRefItem::earliestReceivalTS.name      then  //08.01.2020 cnwma1 #48197
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
