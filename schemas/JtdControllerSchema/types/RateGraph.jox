    <JadeMethod name="calculateMaxY" id="7c1d7c22-ae72-4457-9f57-27a493f7b547">
        <updating/>
        <source>calculateMaxY() : Real updating, protected;

constants
	// set a 50% buffer above actual maximum value
	MaxMultiplier : Real = 1.50;
	
vars
	r, max : Real;
	
begin
	max := self.yMax;
	
	foreach r in self.valueArray do
		if r &gt; max then
			max := r * MaxMultiplier;
		endif;
	endforeach;

	if max &lt; self.minMaxY then
		max := self.minMaxY;
	endif;
	
	self.yMax := max;
	
	return max;
end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="clear" id="22d01a87-654e-4361-b550-eb2c0a1bd16c">
        <source>clear(ctrl : Control) protected;

vars
	hDC, hWnd : Integer;
	
begin
	hWnd := ctrl.hwnd;
	hDC := call winGetDC(hWnd);

	if hDC &lt;&gt; 0 then
		call winBitBlt(hDC, 0, 0, ctrl.clientWidth,
			ctrl.clientHeight, 0, 0, 0, self.BLACKNESS);
	endif;

epilog
	if hDC &lt;&gt; 0 then
		call winReleaseDC(hWnd, hDC);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="ctrl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="copyOffScreenToControl" id="9e77887c-434d-4fb5-b63d-40d3747f2110">
        <source>copyOffScreenToControl(ctrl : Control) protected;

vars
	hDC, hPicDC, hWnd : Integer;
	
begin
	hDC := self.hOffScreenDC;
	
	hWnd := ctrl.hwnd;
	hPicDC := call winGetDC(hWnd);

	if hPicDC &lt;&gt; 0 and hDC &lt;&gt; 0 then
		call winBitBlt(hPicDC, 0, 0, ctrl.clientWidth,
			ctrl.clientHeight, hDC, 0, 0, self.SRCCOPY);
	endif;

epilog
	if hPicDC &lt;&gt; 0 then
		call winReleaseDC(hWnd, hPicDC);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="ctrl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="create" id="1642fb70-95d4-448a-bfe3-640e538d9520">
        <updating/>
        <source>create() updating;

begin
	self.yMax := 5;

	self.hPenAxis := call winCreatePen(self.PS_SOLID, 0, self.ColorAxis);
end;</source>
    </JadeMethod>
    <JadeMethod name="createOffScreenResources" id="8c1ae7e7-67a6-4b21-9213-c17ff4355921">
        <updating/>
        <source>createOffScreenResources(ctrl : Control) updating, protected;

vars
	hPicWnd, hPicDC, hOffDC, fontHeight : Integer;
	
begin
	self.freeOffScreenResources;
	
	hPicWnd := ctrl.hwnd;
	hPicDC := call winGetDC(hPicWnd);
	
	if hPicDC = 0 then
		return;
	endif;

	self.hOffScreenDC := call winCreateCompatibleDC(hPicDC);
	hOffDC := self.hOffScreenDC;
	
	if hOffDC = 0 then
		return;
	endif;
		
	self.hOffScreenBmp := call winCreateCompatibleBitmap(hPicDC, ctrl.clientWidth,
		ctrl.clientHeight);
		
	if self.hOffScreenBmp &lt;&gt; 0 then
		call winSelectObject(hOffDC, self.hOffScreenBmp);
	endif;
			
	fontHeight := -(call winMulDiv(self.TextPointSize, call winGetDeviceCaps(hOffDC,
		self.LOGPIXELSY), 72));

	if app.isUnicode then
	//	self.hFont := call winCreateFontW(fontHeight, 0, 0, 0, 0, 0, 0, 0, self.ANSI_CHARSET,
//			0, 0, 0, 0, self.TextFontTypeFace.bufferAddress);
	//		0, 0, 0, 0, self.TextFontTypeFace);
	else				
		//self.hFont := call winCreateFontA(fontHeight, 0, 0, 0, 0, 0, 0, 0, self.ANSI_CHARSET,
//			0, 0, 0, 0, self.TextFontTypeFace.bufferAddress);
		//	0, 0, 0, 0, self.TextFontTypeFace);
	endif;
				
	if self.hFont &lt;&gt; 0 then
		call winSelectObject(hOffDC, self.hFont);
	endif;
	
	call winSetBkColor(hOffDC, Black);
	call winSetTextColor(hOffDC, self.ColorText);
	
epilog
	if hPicDC &lt;&gt; 0 then
		call winReleaseDC(hPicWnd, hPicDC);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="ctrl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="delete" id="0efed6ae-4572-400a-bf61-c64b3e637cda">
        <updating/>
        <source>delete() updating;

begin
	self.freeOffScreenResources;

	if self.hPenValue &lt;&gt; 0 then
		call winDeleteObject(self.hPenValue);
		self.hPenValue := 0;
	endif;

	if self.hPenAxis &lt;&gt; 0 then
		call winDeleteObject(self.hPenAxis);
		self.hPenAxis := 0;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="26a250fa-a7f8-4b50-a26d-262bde00656b">
        <updating/>
        <source>doRefresh() updating, protected;

vars
	i, n, graphBottom, hDC : Integer;
	max, mid, r : Real;
	ctrl : Control;
	
begin
	return; //jlgmd1 - 12/12/2017 - Skip the graph updates for now, as they break the controller app on windows 10 or server 2016
	
	/*self.updateCount := 0;
	
	ctrl := self.myControl;

	if not ctrl.visible then
		// window is not visible so don't bother drawing anything
		self.freeOffScreenResources;
		return;
	endif;

	self.createOffScreenResources(ctrl);
	
	self.clientHeight := ctrl.clientHeight;
	self.clientWidth := ctrl.clientWidth;

	self.graphHeight := self.clientHeight - (self.TopBottomMargin * 2);
	self.graphWidth := self.clientWidth - (self.LeftMargin + self.RightMargin);

	self.yScale := self.graphHeight / self.calculateMaxY;
	
	self.maxDisplayableValues := (self.graphWidth div self.AxisIncrement) + 1;
	
	self.pictureTooSmall := (self.graphHeight &lt;= 0 or self.graphWidth &lt;= 0);
	if self.pictureTooSmall then
		// window is too small to draw anything of use
		self.clear(ctrl);
		return;
	endif;

	hDC := self.hOffScreenDC;
	if hDC = 0 then
		// we haven't got an off-screen device context to draw in!
		self.clear(ctrl);
		return;
	endif;

	graphBottom := self.clientHeight - self.TopBottomMargin;

	call winSelectObject(hDC, self.hPenAxis);
	
	foreach n in 0 to self.graphWidth step self.AxisIncrement do
		call winMoveToEx(hDC, self.LeftMargin + n, graphBottom, 0);
		call winLineTo(hDC, self.LeftMargin + n, self.TopBottomMargin);
	endforeach;

	foreach n in 0 to self.graphHeight step self.AxisIncrement do
		call winMoveToEx(hDC, self.LeftMargin, graphBottom - n, 0);
		call winLineTo(hDC, self.clientWidth - self.RightMargin, graphBottom - n);
	endforeach;

	self.drawTextRightAligned(hDC, '0', graphBottom - 6, self.LeftMargin - 3);
	self.drawTextRightAligned(hDC, "Rate", self.TopBottomMargin - 14, self.LeftMargin + 11);
	self.drawTextRightAligned(hDC, "Time", graphBottom + 2, (self.clientWidth - self.RightMargin) + 1);

	n := (self.graphHeight div self.AxisIncrement) * self.AxisIncrement;
	if (graphBottom - n) &lt; (graphBottom - (graphHeight - 4)) then
		n := n - self.AxisIncrement;
	endif;

	i := n div self.AxisIncrement;
	if i &gt;= 1 then	
		max := (n / self.yScale).roundedTo(0);
		if max &gt;= 1 then
			self.drawTextRightAligned(hDC, max.String, graphBottom - n - 6, self.LeftMargin - 3);
			if i &gt;= 2 then
				mid := (max / 2).roundedTo(0);
				r := graphBottom - ((mid / max) * n) - 6;
				self.drawTextRightAligned(hDC, mid.String, r.Integer, self.LeftMargin - 3);
			endif;
		endif;
	endif;

	self.refreshValues(self.valueArray, hDC);

	self.copyOffScreenToControl(ctrl);*/
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="7de867e3-3813-42dc-b86f-78c2bb8af1b7">
        <updating/>
        <source>doUpdate(newValue : Real) updating, protected;

vars
	valArray    : RealArray;
	maxValues   : Real;
	graphBottom : Integer;
	numValues   : Integer;
	hDC, n      : Integer;
	updCount    : Integer;
	ctrl        : Control;
	priorValue  : Real;
	r           : Real;
	
begin
	return; //jlgmd1 - 12/12/2017 - Skip the graph updates for now, as they break the controller app on windows 10 or server 2016
	
	/*updCount := self.updateCount + 1;
	self.updateCount := updCount;
	
	maxValues := self.maxDisplayableValues;
	
	valArray := self.valueArray;

	numValues := valArray.size;
			
	if numValues &gt; maxValues then
		// remove the oldest value
		valArray.removeAt(1);
	else
		// we're about to add another value to the array
		numValues := numValues + 1;
	endif;

	priorValue := valArray.last;
	valArray.add(newValue);

	if newValue &gt; self.yMax then
		// we need to adjust the y-scale and refresh the graph
		self.refresh;
		return;
	endif;
	
	if self.pictureTooSmall then
		// window is too small to draw anything of use
		return;
	endif;

	if updCount &gt; maxValues and numValues &gt; 2 then
		r := self.yMax * 0.5;
		if priorValue &lt;= r and newValue &lt;= r then
			// We've had a window's worth of updates and the last two values
			// are both in the bottom half of the graph. Decay the y-scale
			// by 25% so that the graph will slowly adjust to be appropriate
			// for the incoming values.
			self.yMax := self.yMax * 0.75;
			self.refresh;
			return;
		endif;
	endif;

	ctrl := self.myControl;
	if not ctrl.visible then
		// window is not visible so don't bother drawing anything
		return;
	endif;
	
	hDC := self.hOffScreenDC;

	self.scrollOffScreen;
	
	graphBottom := self.clientHeight - self.TopBottomMargin;
	
	call winSelectObject(hDC, self.hPenAxis);

	foreach n in 0 to self.graphHeight step self.AxisIncrement do
		call winMoveToEx(hDC, self.LeftMargin + self.graphWidth - self.AxisIncrement,
			graphBottom - n, 0);
		call winLineTo(hDC, self.clientWidth - self.RightMargin, graphBottom - n);
	endforeach;

	call winMoveToEx(hDC, self.LeftMargin + ((self.graphWidth div self.AxisIncrement) *
		self.AxisIncrement), graphBottom, 0);
	call winLineTo(hDC, self.LeftMargin + ((self.graphWidth div self.AxisIncrement) *
		self.AxisIncrement), graphBottom - self.graphHeight);

	self.updateValue(valArray, numValues, graphBottom, hDC);
	
	self.copyOffScreenToControl(ctrl);*/
end;</source>
        <access>protected</access>
        <Parameter name="newValue" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawTextRightAligned" id="89cce15c-77f8-43d6-882b-8ab3be8896b1">
        <source>drawTextRightAligned(hDC : Integer; text : String; top, right : Integer) protected;

vars
	rect : Binary;
	
begin
	rect[ 1 : 4] := 0.Binary;
	rect[ 5 : 4] := top.Binary;
	rect[ 9 : 4] := right.Binary;
	rect[13 : 4] := self.clientHeight.Binary;

	if app.isUnicode then
//		call winDrawTextExW(hDC, text.bufferAddress, text.length,
//			rect.bufferAddress, self.DT_RIGHT, 0);
		//call winDrawTextExW(hDC, text, text.length,
		//	rect.String, self.DT_RIGHT, "");
	else
//		call winDrawTextExA(hDC, text.bufferAddress, text.length,
//			rect.bufferAddress, self.DT_RIGHT, 0);
	//	call winDrawTextExA(hDC, text, text.length,
	//		rect.String, self.DT_RIGHT, "");
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="hDC" type="Integer"/>
        <Parameter name="text" type="String"/>
        <Parameter name="top" type="Integer"/>
        <Parameter name="right" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="freeOffScreenResources" id="7a04cf74-ed26-4b1a-81f1-c300a42eccf0">
        <updating/>
        <source>freeOffScreenResources() updating, protected;

begin
	if self.hOffScreenDC &lt;&gt; 0 then
		call winDeleteDC(self.hOffScreenDC);
		self.hOffScreenDC := 0;
	endif;
	
	if self.hOffScreenBmp &lt;&gt; 0 then
		call winDeleteObject(self.hOffScreenBmp);
		self.hOffScreenBmp := 0;
	endif;
	
	if self.hFont &lt;&gt; 0 then
		call winDeleteObject(self.hFont);
		self.hFont := 0;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initialize" id="3af256d6-5793-4ec6-871e-abd25f8ca7ee">
        <updating/>
        <source>initialize(pic : Picture; color : Integer; minY : Real) updating;

begin
	self.freeOffScreenResources;

	if minY &lt; 0 then
		self.minMaxY := 0;
	else
		self.minMaxY := minY;
	endif;
		
	self.yMax := self.minMaxY;
	
	self.myControl := pic;
	self.myControl.autoRedraw := false;
	    
	if self.hPenValue &lt;&gt; 0 then
		call winDeleteObject(self.hPenValue);
		self.hPenValue := 0;
	endif;

	self.hPenValue := call winCreatePen(self.PS_SOLID, 0, color);

	self.refresh;
end;</source>
        <Parameter name="pic" type="Picture"/>
        <Parameter name="color" type="Integer"/>
        <Parameter name="minY" type="Real"/>
    </JadeMethod>
    <JadeMethod name="refresh" id="33d90605-e9cf-4305-a394-6b1d2cea84c4">
        <updating/>
        <source>refresh() updating;

vars
	errNo : Integer; // initialized to zero
		
begin
	on Exception do self.resumeNextExHandler(exception, errNo);
	
	self.doRefresh;

	// if the refresh encounters an exception, our handler will
	// resume to here and we'll simply abandon the operation
	if errNo &lt;&gt; 0 then
		self.freeOffScreenResources;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="refreshValues" id="11a0d8e2-d805-4244-9470-28ead64e638f">
        <source>refreshValues(values : RealArray; hDC : Integer) protected;

vars
	x, xPrior : Real;
	y, yPrior : Real;
	r         : Real;
	graphBase : Real;
	graphWide : Real;
	scaleY    : Real;
	maxValues : Integer;
	n         : Integer;
	
begin
	return; //jlgmd1 - 12/12/2017 - Skip the graph updates for now, as they break the controller app on windows 10 or server 2016
	
	/*scaleY := self.yScale;
	
	maxValues := self.maxDisplayableValues;
		
	graphBase := self.clientHeight - self.TopBottomMargin;
	graphWide := self.graphWidth;

	xPrior := -1;
	yPrior := -1;

	n := 0;
	
	call winSelectObject(hDC, self.hPenValue);

	foreach r in values reversed do
		x := self.LeftMargin + (graphWide - (self.AxisIncrement * n));
		y := graphBase - (r * scaleY);

		if xPrior &gt;= 0 and yPrior &gt;= 0 then
			call winMoveToEx(hDC, xPrior.Integer, yPrior.Integer, 0);
			call winLineTo(hDC, x.Integer, y.Integer);
		endif;

		xPrior := x;
		yPrior := y;

		n := n + 1;
				
		if n &gt;= maxValues then
			break;
		endif;
	endforeach;*/
end;</source>
        <access>protected</access>
        <Parameter name="values" type="RealArray"/>
        <Parameter name="hDC" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resumeNextExHandler" id="2df2c912-5d89-403b-8c4b-6a3499af81d9">
        <source>resumeNextExHandler(exObj : Exception; errNo : Integer output) : Integer protected;

begin
	errNo := exObj.errorCode;
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="errNo" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="scrollOffScreen" id="8db984c6-4b0a-4454-9d50-0d915f5cf3ce">
        <updating/>
        <source>scrollOffScreen() updating, protected;

vars
	hDC : Integer;
	
begin
	hDC := self.hOffScreenDC;
	
	if hDC &lt;&gt; 0 then
		call winBitBlt(hDC,
					   self.LeftMargin,
					   self.TopBottomMargin,
					   self.graphWidth + 1,
					   self.graphHeight + 1,
					   hDC,
					   self.LeftMargin + self.AxisIncrement,
					   self.TopBottomMargin,
					   self.SRCCOPY);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="update" id="2f5a38db-2f45-42a7-a0a5-148b010fde87">
        <updating/>
        <source>update(newValue : Real) updating;

vars
	errNo : Integer; // initialized to zero

begin
	on Exception do self.resumeNextExHandler(exception, errNo);

	self.doUpdate(newValue);

	// if the update encounters an exception, our handler will
	// resume to here and we'll simply abandon the operation
end;</source>
        <Parameter name="newValue" type="Real"/>
    </JadeMethod>
