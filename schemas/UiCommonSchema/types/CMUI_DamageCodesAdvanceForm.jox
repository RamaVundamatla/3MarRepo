    <JadeMethod name="addItem" id="86e56270-08a2-429c-9a60-6616ceb618bb">
        <updating/>
        <source>addItem() updating;
/*
Created by cnwsh3
Date 28 July 2009

Implemented version: 7.7.3
CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
Attempt to create a proxy damage instance item using the values entered
and assign this to the proxy ti that was assigned when the form was created.

Date		Name	TFS#		Description
============================================================================
29 Apr 2019	jlgdi1	TFS# 44530 Added a line that will update the 'timeStamp' attribute 
06 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
============================================================================*/

vars
	damageInstance 	: CM_DamageInstance;
	str 			: String;
	tsNow			: TimeStamp;	// 06.07.2022 navak20 TFS 53862
begin
	str := self.hasInfoEntered();
	if str &lt;&gt; null then
		app.msgBox(app.getErrorString1(RequiredFields, str),null , MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	//Create a new instance now that we know we have all the necessary fields
	create damageInstance transient;
	damageInstance.setTimeStamp(app.actualTimeServer());
	self.setSelectedItem(damageInstance);
	
	// ### TFS BUG 58861 27JUN2023 NAVAB1	
	if self.myRealMasterItem &lt;&gt; null then
		damageInstance.setMySubject(self.myRealMasterItem);
	endif;

	//Set the damage instance details and add to the data table
	self.updateItem();
	
	//Add to the damage collection on the form.
	self.allProxyDamageInstances.add(damageInstance);
	
	self.clearItem();
	
	self.txtQuantity.text := 1.String;									// 06.07.2022 navak20 TFS 53862
	tsNow := self.systemToLocalTime(app.actualTimeServer);				// 06.07.2022 navak20 TFS 53862
	self.damageDate.setDate(tsNow.date());								// 06.07.2022 navak20 TFS 53862
	self.damageTime.setTime(tsNow.time());								// 06.07.2022 navak20 TFS 53862
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="addPxyToParentForm" id="29679b65-efe2-47c1-905e-698680aa8fe7">
        <updating/>
        <source>addPxyToParentForm(pxyDamage : CM_DamageInstance) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		12 October 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars

begin
	if self.myParentForm.isKindOf(CMUI_MasterGeneratorMaintForm) then
		self.myParentForm.CMUI_MasterGeneratorMaintForm.allDamageInstancesByPos.add(pxyDamage);
	elseif self.myParentForm.isKindOf(CMUI_MasterContainerMaintForm) then
		self.myParentForm.CMUI_MasterContainerMaintForm.allDamageInstancesByPos.add(pxyDamage);
	elseif self.myParentForm.isKindOf(CMUI_TIMasterMaintForm) then
		self.myParentForm.CMUI_TIMasterMaintForm.allDamageInstancesByPos.add(pxyDamage);
	endif;
epilog
end;</source>
        <Parameter name="pxyDamage" type="CM_DamageInstance"/>
    </JadeMethod>
