    <JadeMethod name="showEventRequestModal" id="135874fb-a82c-4664-9c78-96047f5e1c1c">
        <updating/>
        <source>showEventRequestModal(_mode : Integer)updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
	form : CMUI_EventRequestModal;
begin
	
	if self.mode = _mode then
		return;
	endif;

	if _mode &lt; self.Mode_View
	or _mode &gt; self.Mode_Update then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Invalid_Mode));
		return;
	elseif _mode = self.Mode_Add then
		str := app.getErrorString(Add);
	elseif _mode = self.Mode_Update then
		if self.tblData.allSelectedObjects.size &gt; 1 then
			app.msgBox(app.getErrorString(Please_Select_One_Item), app.getErrorString(Select_Item), MsgBox_Stop_Icon  + MsgBox_OK_Only);
			return;
		elseif self.myCurrentEventRequest = null then
			app.msgBox(app.getErrorString(Cannot_Perform_Edit), app.getErrorString(No_Current_Item), MsgBox_Stop_Icon  + MsgBox_OK_Only);
			return;
		endif;
		str := app.getErrorString(Update);
	endif;	
	
	str.firstCharToUpper();
	self.mode := _mode;
	
	create form;
	form.setCaption(str &amp; ' ' &amp; self.eventRequestType);
	self.setNavigatorHeading(form.caption);
	form.mode := _mode;	
	if _mode = self.Mode_Update then 
		form.myEventRequest := self.myCurrentEventRequest;
	endif;
	form.setAssistantAndTerminalRefs(self.myAssistant, self.myTerminal);
	form.eventRequestType := self.eventRequestType;	
	form.centreWindow;
	form.showModal;


epilog
	self.mode := self.Mode_View;
end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showHideSearcher" id="c64316b0-398a-4803-aa82-4de3ae9ea610">
        <source>showHideSearcher();
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.btnSearch.enabled := false;
	
	if self.frmSearch.visible then
		self.frmSearch.visible := false;
	else
		self.btnSearch.enabled := true;
		self.frmSearch.visible := true;
		self.frmSearch.zOrder(1);
		self.frmSearch.centreHorizontallyInParent();
		self.frmSearch.centreVerticallyInParent();
		//We're showing the searcher and want move to the first row ready for new values.
		self.tblSearch.clearAllSelected;
		self.tblSearch.accessColumn(1).width := 100;
		self.tblSearch.setFocus();
		self.tblSearch.moveFirst();
	endif;
end;</source>
    </JadeMethod>
