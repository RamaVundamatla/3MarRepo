    <JadeMethod name="mnuLabourAddRegion1_click" id="3f9d61d3-37a3-462f-9f91-1ce8371adea7">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuLabourAddRegion1_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 September 2011	cnwndl1	Initial creation

*/

vars

	newLabRestForm : CMUI_LabourRestrictAddAndSet;
	termArea : CM_TerminalArea;

begin

	if self.allSelectedRegionLocs.isEmpty or self.allSelectedRegionLocs.first = null then
		return;
	endif;
	
	if self.allSelectedRegionLocs.size = 1 then
		termArea := self.allSelectedRegionLocs.first.myTerminalArea;
		if termArea &lt;&gt; null
		and ( 	termArea.isKindOf( CM_YardInterchangeArea )
				or termArea.isKindOf( CM_YardInterchangeArea )
				or termArea.isKindOf( CM_BlockStack )	//03 Dec 2013	NDL	Par 33130
		)
		then
			self.showLabourRestrictionForm( null, termArea );
			return;
		endif;
	endif;

	
	create newLabRestForm;
	newLabRestForm := app.loadForm(CMUI_LabourRestrictAddAndSet, CMUI_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).CMUI_LabourRestrictAddAndSet;
	if newLabRestForm = null then
		return;
	endif;
	newLabRestForm.setTeminalArea( null, self.allSelectedRegionLocs.first.myTerminalArea ); 
	newLabRestForm.setFormForNewLocationSet( self.allSelectedRegionLocs );

	newLabRestForm.showModal();
	

epilog

	delete newLabRestForm;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
