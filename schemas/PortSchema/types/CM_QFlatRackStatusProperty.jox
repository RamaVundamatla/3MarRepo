    <JadeMethod name="setComboValues" id="77d462d5-97b6-486c-aaab-e5c2d986c0bb">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars
	searchValue : Integer;

begin
	_combo.clear;
	_combo.addItem(app.flatRackEndsEnumToString(TI_DOORSDIRN_ENDUP));
	_combo.addItem(app.flatRackEndsEnumToString(TI_DOORSDIRN_ENDDOWN));
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		searchValue := _queryOperator.CM_QIntegerLookupEqual.searchValue; 
		_combo.text := app.flatRackEndsEnumToString(searchValue);
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		searchValue := _queryOperator.CM_QIntegerLookupNotEqual.searchValue;
		_combo.text := app.flatRackEndsEnumToString(searchValue);
	endif;
	
	if searchValue = 0 then
		_combo.listIndex:=-1;
	endif;
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="d093434e-be6e-4f2e-9fc9-3ed5cfe395cb">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QIntegerIsOneOf; _passport: CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars
	intArray : IntegerArray;

begin
	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create intArray transient;
	
	intArray.add(TI_DOORSDIRN_ENDUP);
	intArray.add(TI_DOORSDIRN_ENDDOWN);

	self.setListTableFromIntConstants(_tbl, _operator, intArray, TI_DOORSDIRN_Constant);	

epilog
	delete intArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="10b980cd-178c-405a-80d6-f3d9c33f8741">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars
	ia : IntegerArray;
	numRows, idx : Integer;
	str : String;

begin
	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			str := _tbl.accessCell(idx, 2).text;
			ia.add(self.translateToSearchValue(str).Integer);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="a253919f-2bb4-42a3-a0de-57f49876c79a">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine: CM_SelectorCriteriaLine): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars
	doorsDirn : Integer;

begin
	if _value.String.isInteger then
		return _value;
	endif;
	
	doorsDirn := app.flatRackEndsStringToEnum(_value.String);
	if doorsDirn = null and _value &lt;&gt; null then
		app.raiseCMException2( ERR_FIELD_VALUE, _value.String, _criteriaLine.myQueryProperty.niceName, null, self );
	endif;
	
	return doorsDirn;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="400224df-1d24-4f20-8240-5b534a05303e">
        <source>translateToDisplayValue(_value: Any): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars

begin
	return app.flatRackEndsEnumToString(_value.Integer);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="472b0391-53d2-45d4-be49-472f13dc5da9">
        <source>translateToSearchValue(_value: Any): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars

begin
	return app.flatRackEndsStringToEnum(_value.String);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="249eec5c-0ef3-478b-97b1-bf593850689d">
        <source>translateToSearchValueForWeb(_value: Any; _sending: Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars
	int : Integer;
	strValue, collStr : String;
	strArray : StringArray;
	intArray : IntegerArray;

begin
	if _value.isKindOf(Integer) then
		return app.flatRackEndsEnumToString(_value.Integer);
		
	elseif _value.isKindOf(IntegerArray) then
		foreach int in _value.IntegerArray do
			strValue := strValue &amp; app.flatRackEndsEnumToString(int) &amp; CNEC_COMMA &amp; Space;
		endforeach;
		strValue := strValue[1:strValue.length-2];
		return strValue;
		
	elseif _value.isKindOf(String) and _value.String.cnContains("|") then
		collStr := _value.String;
		create strArray transient;
		create intArray transient;
		collStr.getTokensForDelimiter("|", strArray);
		foreach strValue in strArray do
			intArray.add(app.flatRackEndsStringToEnum(strValue));
		endforeach;
		return intArray;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
