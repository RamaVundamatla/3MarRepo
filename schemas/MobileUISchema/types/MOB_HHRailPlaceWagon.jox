    <JadeMethod name="translateForm" id="831a54a8-add2-4a72-99a3-51dea423b860">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 12 March 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020302, locale);
	btnCargo.translateCaption(Xlat_0020303, locale);
	btnCargo2.translateCaption(Xlat_0020304, locale);
	btnConfirmWagon.translateCaption(Xlat_0020305, locale);
	btnRakeBack.translateCaption(Xlat_0020306, locale);
	btnRakeForward.translateCaption(Xlat_0020307, locale);
	btnWagonChecks.translateCaption(Xlat_0020308, locale);
	btnWagonPos.translateCaption(Xlat_0020309, locale);
	btnWagonPos2.translateCaption(Xlat_0020310, locale);
	lblRakePos.translateCaption(Xlat_0020311, locale);
	lblWagon.translateCaption(Xlat_0020312, locale);
end;</source>
