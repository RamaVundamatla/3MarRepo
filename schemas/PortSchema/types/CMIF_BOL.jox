    <JadeMethod name="delete" id="a0d722a1-5937-461e-93cb-d00b4b5168d0">
        <updating/>
        <source>delete() updating;
//--------------------------------------------------------------
//Created: 18 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	bolYardRequest		: CM_BOLYardRequest;
	
begin

	if (not updating) and self.myProxyBOL &lt;&gt; null then
		self.myProxyBOL.erase(NORMAL_ERASE);
	endif;
/*
	foreach bolYardRequest in self.allProxyBOLRequests do
		if bolYardRequest &lt;&gt; null then
			bolYardRequest .erase(NORMAL_ERASE);
		endif;
	endforeach;

*/	
	if self.myProxyBOLRequest &lt;&gt; null then
		self.myProxyBOLRequest.erase(NORMAL_ERASE);
	endif;

end;</source>
    </JadeMethod>
