    <JadeMethod name="getMyTerminal" id="678166a8-64d3-4a85-8542-5ebaeaacfdd8">
        <source>getMyTerminal() : CM_Terminal;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpTerminal	: CM_Terminal;
	tmpTrans	: HMS_Transaction;
	
begin
	if self.myVoyage &lt;&gt; null then
		tmpTerminal := self.myVoyage.getMyTerminal;
		if tmpTerminal &lt;&gt; null then
			return tmpTerminal;
		endif;
		// in some cases (e.g. when updating voyages from global voyage
		// the voyage.myTerminal is set to null to detach from the terminal
		// to avoid a dup key error when updating multiple CM_Voyages on same
		// CM_VoyageGlobal. Need another method to get terminal referrence
		tmpTrans := self.allHMSTransactions.last;
		if tmpTrans &lt;&gt; null then
			return tmpTrans.myTerminal;
		endif;
	endif;
	return null;
end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
