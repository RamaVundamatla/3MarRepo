    <JadeMethod name="jssGetCellObject" id="e6d2551e-b563-453e-9cf5-55d46b6b5e7b">
        <updating/>
        <source>jssGetCellObject(pRow: Integer; pCol: Integer): Object updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 by cnwdad1
//
// Purpose:		Returns a cell object from the specified row and column, whilst
//				preserving the currently selected cell(s).
//
// Parameters:	pRow (Integer) - The cell row number.
//				pColumn (Integer) - The cell column.
//
// Returns:		The requested cell's itemObject (Object).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex	: Integer;
	columnIndex	: Integer;
	theObject	: Object;

begin
	rowIndex	:=	self.row;
	columnIndex	:=	self.column;
	theObject	:=	self.jssGetItemObject(pRow, pCol);
	self.row	:=	rowIndex;
	self.column	:=	columnIndex;
	
	return theObject;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pCol" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="jssGetItemObject" id="fd161ddc-c406-43a6-96b4-230a23700aa8">
        <updating/>
        <source>jssGetItemObject(pRow: Integer; pCol: Integer): Object updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 - jssGetItemObject
// By:			cnwdad1
//
// Purpose:		Returns a cell object from the specified row and column.
//
// Parameters:	pRow (Integer) - The cell row number.
//				pColumn (Integer) - The cell column.
// Returns:		itemObject (Object)
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if pRow &gt; 0 and pRow &lt;= self.rows and pCol &gt; 0 and pCol &lt;= self.columns then
		self.row	:=	pRow;
		self.column	:=	pCol;
		return self.itemObject;
	endif;

	return null;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pCol" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="jssGetRowObject" id="08dd5a7c-abb4-41b9-864a-cc6f8efa30e4">
        <source>jssGetRowObject():Object;
// --------------------------------------------------------------------------------
// Created:		06 October 2001 by cnwdad1
//
// Purpose:		Returns the itemObject of the JadeTableRow for the receiver's
//				currently selected row.
//
// Parameters:	None
//
// Returns:		The object for currently selected row.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTable	: Table;
	theObject	: Object;
	currentRow	: Integer;
	theTableRow	: JadeTableRow;
	
begin
	theTable	:=	self;
	currentRow	:=	self.row;
	
	if currentRow &gt; theTable.fixedRows and currentRow &lt;= theTable.rows then
		theTableRow	:=	theTable.accessRow(currentRow);
		theObject	:=	theTableRow.itemObject;
	else
		theObject	:=	null;
	endif;
epilog
	return theObject;
end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="jssIsRowSelected" id="2d2a0e3f-a45b-4f02-8f6d-62b4b3a039ad">
        <source>jssIsRowSelected(pRow:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		25 July 2000	By: cnwdad1
//
// Purpose:		Returns a flag to indicate whether the requested row is selected.
//
// Parameters:	pRow (Integer) - The cell row number.
//
// Returns:		True if the row is selected, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	columnPointer	: Integer;
	columnCount		: Integer;

begin
	columnCount	:=	self.columns;

	foreach columnPointer in 1 to columnCount do
		if getCellSelected(pRow, columnPointer) then
			return true;
		endif;
	endforeach;

	return false;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssSelectAllRows" id="248d66c3-2441-4c1b-a37b-841eb64dd91e">
        <updating/>
        <source>jssSelectAllRows() updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad1
//
// Purpose:		This method will set all rows in the receiver to selected.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowCount			: Integer;
	rowPointer			: Integer;
	columnCount			: Integer;
	columnPointer		: Integer;
	firstNonFixedRow	: Integer;
	firstNonFixedColumn	: Integer;

begin
	firstNonFixedRow	:=	self.fixedRows + 1;
	rowCount			:=	self.rows;
	firstNonFixedColumn	:=	self.fixedColumns + 1;
	columnCount			:=	self.columns;
	
	foreach rowPointer in firstNonFixedRow to rowCount do
		foreach columnPointer in firstNonFixedColumn to columnCount do
			self.setCellSelected(rowPointer, columnPointer, true);	
		endforeach;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="jssSelectRow" id="f0523e9a-d4b8-46aa-b82a-9843e07d6cad">
        <updating/>
        <source>jssSelectRow() updating;
// --------------------------------------------------------------------------------
// Created:		19 April 1999 - jssSelectRow
// By:			cnwdad1
//
// Purpose:		This method will select all columns for the receiver's current row.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	columnPointer		: Integer;
	columnCount			: Integer;
	firstNonFixedColumn	: Integer;

begin
	self.clearAllSelected();
	columnCount			:=	self.columns;
	firstNonFixedColumn	:=	self.fixedColumns + 1;

	if self.row &gt; self.fixedRows then
		foreach columnPointer in firstNonFixedColumn to columnCount do
			self.setCellSelected(self.row, columnPointer, true);	
		endforeach;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="jssSetCellBackColor" id="0d83b5fc-9330-42be-b55b-376658008475">
        <updating/>
        <source>jssSetCellBackColor(pRow:Integer; pColumn:Integer; pColor:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		02 May 1999 - jssSetCellBackColor
// By:			cnwdad1
//
// Purpose:		Assigns the specified backcolor to a cell for the specified row and column.
//
// Parameters:	pRow (Integer) - The cell row number.
//				pColumn (Integer) - The cell column.
//				pColor (Integer) - The colour to assign to the cell's backcolor.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cRow	: Integer;
	cColumn	: Integer;
	mode	: Integer;

begin
	mode			:=	self.accessMode;
	self.accessMode	:=	Table.AccessMode_Cell;
	cRow			:=	self.row;
	cColumn			:=	self.column;
	self.row		:=	pRow;
	self.column		:=	pColumn;
	self.backColor	:=	pColor;
	self.row		:=	cRow;
	self.column		:=	cColumn;
	self.accessMode	:=	mode;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pColumn" type="Integer"/>
        <Parameter name="pColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssSetCellForeColor" id="1ad12ce4-fe6d-405f-8b9f-5f1708f2fcde">
        <updating/>
        <source>jssSetCellForeColor(pRow:Integer; pColumn:Integer; pColor:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 - jssSetCellForeColor
// By:			cnwdad1
//
// Purpose:		Assigns the specified forecolor to a cell for the specified row and column.
//
// Parameters:	pRow (Integer) - The cell row number.
//				pColumn (Integer) - The cell column.
//				pColor (Integer) - The colour to assign to the cell's forecolor.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cRow	: Integer;
	cColumn	: Integer;
	mode	: Integer;

begin
	mode			:=	self.accessMode;
	self.accessMode	:=	Table.AccessMode_Cell;
	cRow			:=	self.row;
	cColumn			:=	self.column;
	self.row		:=	pRow;
	self.column		:=	pColumn;
	self.foreColor	:=	pColor;
	self.row		:=	cRow;
	self.column		:=	cColumn;
	self.accessMode	:=	mode;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pColumn" type="Integer"/>
        <Parameter name="pColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssSetCellObject" id="ffae684a-740c-41c3-825b-1c4726a3414b">
        <updating/>
        <source>jssSetCellObject(pRow:Integer; pColumn:Integer; pObject:Object) updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 - jssSetCellObject
// By:			cnwdad1
//
// Purpose:		Assigns the specified object to a cell for the specified row and
//				column, whilst preserving the currently selected cell(s).
//
// Parameters:	pRow (Integer) - The cell row number.
//				pColumn (Integer) - The cell column.
//				pObject (Object) - The object to assign to the cell.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cRow	: Integer;
	cColumn	: Integer;

begin
	cRow		:=	self.row;
	cColumn		:=	self.column;
	self.row	:=	pRow;
	self.column	:=	pColumn;
	self.jssSetItemObject(pRow, pColumn, pObject);
	self.row	:=	cRow;
	self.column	:=	cColumn;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pColumn" type="Integer"/>
        <Parameter name="pObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="jssSetColumnWidths" id="1f25119d-863a-4ba4-8540-caa9c3bfc6c2">
        <updating/>
        <source>jssSetColumnWidths(pColumnWidthArray:IntegerArray) updating;
// --------------------------------------------------------------------------------
// Created:		13 May 2000 by cnwdad1
//
// Purpose:		Sets the widths of the table's columns.
//
// Parameters:	pColumnWidthArray (IntegerArray) - An array of width percentages.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
/*
	Each column's width will be set as a percentage of the
	table's overall width.  The column's width percentages
	should be specified sequentially as subscripts of the
	"pColumnWidthArray" array.
*/
vars
	savedAccessMode	: Integer;
	colWidth		: Integer;
	colIndex		: Integer;
	colCount		: Integer;
	tableColumns	: Integer;

begin
	if pColumnWidthArray = null or pColumnWidthArray.size() = 0 then
		return;
	endif;

	// First, count the number of visible columns, then work out a
	// default (average) width based upon that number of columns.

	savedAccessMode	:=	self.accessMode;
	self.accessMode	:=	Table.AccessMode_Column;
	colIndex		:=	1;
	tableColumns	:=	self.columns;

	foreach colIndex in 1 to tableColumns do
		if self.columnVisible[colIndex] then
			colCount := colCount + 1;
		endif;
	endforeach;

	colWidth	:=	self.width.Integer div colCount;	// Average the width;

	// Now set the column width(s).

	colCount	:=	self.columns;
	colIndex	:=	1;

	foreach colIndex in 1 to colCount do
		if colIndex &lt;= pColumnWidthArray.size() and self.columnVisible[colIndex] then
			colWidth := pColumnWidthArray[colIndex];

			if colWidth = 0 then
				self.columnWidth[colIndex] := colWidth;		// Use the default width.
			else
				self.columnWidth[colIndex] := ((colWidth * self.width.Integer) / 100).Integer;
			endif;
		endif;
	endforeach;

epilog
	self.accessMode	:=	savedAccessMode;	// Restore the original accessMode.
end;</source>
        <Parameter name="pColumnWidthArray" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="jssSetItemObject" id="793ab1b7-cc63-45ea-a6b4-c13d77ee87f6">
        <updating/>
        <source>jssSetItemObject(pRow:Integer; pColumn:Integer; pObject:Object) updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 - jssSetItemObject
// By:			cnwdad1
//
// Purpose:		Assigns the specified object to a cell for the specified row and column.
//
// Parameters:	pRow (Integer) - The cell row number.
//				pColumn (Integer) - The cell column.
//				pObject (Object) - The object to assign to the cell.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if pRow &gt; 0 and pRow &lt;= self.rows and pColumn &gt; 0 and pColumn &lt;= self.columns then
		self.row		:=	pRow;
		self.column		:=	pColumn;
		self.itemObject	:=	pObject;
	endif;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pColumn" type="Integer"/>
        <Parameter name="pObject" type="Object"/>
    </JadeMethod>
</GUIClass>
