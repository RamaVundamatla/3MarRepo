    <JadeMethod name="canUpdateTotalWeight" id="9f756ea0-01cc-4a47-9c6f-bbede73b9e37">
        <source>canUpdateTotalWeight() : Boolean;
/*

Purpose:			This method returns whether the total weight can be updated
					Based on the self.typeAttributes
					Updated when self.myTILCType.allowUpdateTotalWeight changed

Parameters:			

Return Value:		

Date		Who		Reason
15/10/2025	navkc1 JIRA 36057 CUX | Total Weight Specification for Trailers - DB Changes / Form /Jade

*/

vars
	
begin
	
	return self.typeAttributes.bitAnd(TILCTypeEnableTotalWeightEdit) &lt;&gt; null;
	
epilog

