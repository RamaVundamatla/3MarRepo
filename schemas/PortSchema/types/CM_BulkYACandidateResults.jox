<Class name="CM_BulkYACandidateResults" id="f6737dfc-e881-48e9-8e5c-f672d33a66c2">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <ImplicitInverseRef name="allCandidates" id="032bb568-315b-4fd5-a741-032b2236e398">
        <memberTypeInverse/>
        <type name="CM_BulkYACandidateSet"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="8905561b-89f8-4740-8e3b-4aec5829d0ba">
        <updating/>
        <source>delete() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/09/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations 
//
vars

begin
	if self.allCandidates &lt;&gt; null then
		self.allCandidates.purge();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="ce50e754-0a7f-4773-9a95-c47a41b30920">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/08/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations
//
vars

begin
	self.allCandidates.purge();
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasExistingYardAllocations" id="7603412f-80f3-483a-bc65-fe464f0b2b04">
        <source>hasExistingYardAllocations() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations
//
vars
	candidate : CM_BulkYACandidate;
	existingYA : CM_YardAllocation;
	invalid : Boolean;

begin
	on Exception do app.handleDeletedObject(exception, candidate, invalid);
	
	foreach candidate in self.allCandidates do
		if candidate.myExistingYardAllocation &lt;&gt; null then
			existingYA := candidate.myExistingYardAllocation;
			invalid := false;
			existingYA.edition;
			if invalid then
				continue;
			endif;
			
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="23ee5739-39e2-4c31-8b1f-a9188ee3c3a3">
        <updating/>
        <source>setForCreate(_pxyCandidateResults : CM_BulkYACandidateResults) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/08/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations
//
vars
	pxyCandidate, realCandidate : CM_BulkYACandidate;

begin
	foreach pxyCandidate in _pxyCandidateResults.allCandidates do
		create realCandidate persistent;
		realCandidate.setForCreate(pxyCandidate);
		self.allCandidates.add(realCandidate);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_pxyCandidateResults" type="CM_BulkYACandidateResults"/>
    </JadeMethod>
</Class>
