vars

begin
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setObjectAndHarbour" id="9bb6ba09-c993-408a-aa19-12a77e95c5bb">
        <updating/>
        <source>setObjectAndHarbour(_pilot : HMS_Pilot; _harbour : HMS_Harbour) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars

begin
	self.amInitialised := false;
	self.myHarbour := _harbour;
	self.setObject(_pilot);
epilog

end;</source>
        <Parameter name="_pilot" type="HMS_Pilot"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
