// 12/02/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// ---------------------------------------------------------------------------
vars
	
begin

	tblGroup.addItemAt('', pIdx);
	tblGroup.accessCell(pIdx, Col_InputType).comboList := self.getInTypeComboValues();
	tblGroup.accessCell(pIdx, Col_InputTypeWeb).comboList := self.getInputTypeWebComboValues();
	tblGroup.accessCell(pIdx, Col_TerminologyType).comboList := self.getTerminologyTypeNames();
	tblGroup.accessCell(pIdx, Col_MeasurementType).comboList := self.getMeasurementTypeNames();	// PAR #31155
	tblGroup.accessCell(pIdx, 1).text := self.displayEntTableRow(pRow, true);
	tblGroup.accessRow(pIdx).itemObject := pRow;
	
end;</source>
