    <JadeMethod name="getCraneType" id="cc47c72c-f977-4147-982b-187b9640ca4c">
        <source>getCraneType() : Integer;
// ---------------------------------------------------------------------------
// Created:		31 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	craneType : Integer;
begin
	if self.myCraneJobSheet = null then
		return 	JobTypePriority_Crane1;
	else
		craneType :=  self.myCraneJobSheet.getCraneType();
		return craneType;

	endif;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
