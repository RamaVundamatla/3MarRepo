    <JadeMethod name="convertHexColourToJadeColor" id="232d3b72-7c9e-47e7-8965-07dd55f948e4">
        <source>convertHexColourToJadeColor() : Integer;
/*
Purpose:			
Date		Who		Reason
25 September 2013	cnwab1	Initial creation
*/

vars
	hex1, hex2, hex3 : String;
	num1, num2, num3 : Integer;
begin
	if self.length() &gt; 9 then
		return 0;
	endif;
	
	if self.length() = 9 then // #FF231E5F
		hex1 := self[4:2];
		hex2 := self[6:2];
		hex3 := self[8:2];
	elseif self.length() = 7 then // #231E5F
		hex1 := self[2:2];
		hex2 := self[4:2];
		hex3 := self[6:2];
	else
		return 0;
	endif;

	num1 := hex1.convertHexToInteger;
	num2 := hex2.convertHexToInteger;
	num3 := hex3.convertHexToInteger;
	
	return (num3 * 256 * 256) + (num2 * 256) + num1;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="convertHexToInteger" id="833908ba-ef20-4d09-8f48-e6f9adb2eaaf">
        <source>convertHexToInteger() : Integer;

/*

Purpose:			Convert the receiver from a Hex value to its equivalent Integer value, using the rules
					matching the msvcrt::strtol external function
					
					Rules are:
						Leading blanks are ignored
						Negative values are allowed
						Conversion proceeds until first non-hex character is encountered
						Any Hex value larger than Max_Integer returns this as a result
						Any Hex value smaller than Min_Integer returns this as a result

Parameters:			None

Return Value:		Equivalent Integer value


Date		Who		Reason
19 Apr 2010	cnwkpd1	PAR #23610 - Allow for 64-bit deployment

*/

constants
	HexChars		= "0123456789ABCDEF";
	
vars
	pos,
	hexPos,
	len,
	result			: Integer;
	temp			: String;
	isNegative,
	isMaxValue		: Boolean;
	firstChar		: Character;
	
begin
	temp := self.trimBlanks().toUpper();
	len := temp.length();
	
	// Check for first character being a "+" or "-" sign
	if len &gt; 1 then
		firstChar := temp[1];
		if firstChar = "+" or firstChar = "-" then
			temp := temp[2:end];
			len := len - 1;
			isNegative := firstChar = "-";
		endif;
	endif;
	
	pos := 1;
	while pos &lt;= len do
		hexPos := HexChars.pos(temp[pos:1], 1);
		
		// Have read past last hex character
		if hexPos = 0 then 
			break;
		endif;
		
		// Build up result value
		result := (result * 16) + hexPos - 1;
		
		// If result has wrapped around and gone negative, then return max value
		if result &lt; 0 then
			isMaxValue := true;
			break;
		endif;
		
		pos := pos + 1;
	endwhile;

	if isMaxValue then
		if isNegative then
			result := Min_Integer;
		else
			result := Max_Integer;
		endif;
	elseif isNegative then
		result := result * (-1);
	endif;

	
	return result;
	
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="convertISO8601ToUTCTimeStamp" id="48e4b52b-5b62-4398-9344-56d99a0d45b3">
        <source>convertISO8601ToUTCTimeStamp(): TimeStamp;
/*

Purpose:			Converts ISO8601 datetime (e.g. 2018-07-10T14:25:58+00:00) to timestamp in UTC

Parameters:			

Return Value:		TimeStamp of above string, expressed in UTC
					Null if it can't be converted to a timestamp,
					note that this will reject valid strings that have month or date omitted
					Doesn't support all formats such as week number

Date		Who		Reason
14 January 2019	jlgmp6	Initial creation	TFS42015

*/

vars
	datePart,
	timePart,
	zonePart,
	nextBit: String;
	posT,
	posZone,
	year,
	month,
	day,
	hour,
	minute,
	second,
	milli,
	daysToAdd,
	minutesToShift: Integer;
	addMinutes: Boolean;
	date: Date;
	time: Time;
	dateTime: TimeStamp;
begin
	posT := self.pos("T", 1);
	if posT &lt; 8 then
		return null;
	endif;

	posZone := self.pos("Z", posT);
	if posZone = 0 then
		posZone := self.pos("+", posT);
	endif;
	if posZone = 0 then
		posZone := self.pos("-", posT);
	endif;
	if posZone = 0 then
		return null;
	endif;

	datePart := self[1:posT - 1];
	timePart := self[posT + 1:posZone - posT - 1];
	zonePart := self[posZone:end];

	if timePart.length() &lt; 2 then
		return null;
	endif;

	// Date
	nextBit := datePart[1:4];
	if not nextBit.isInteger() then
		return null;
	endif;
	year := nextBit.Integer;
	datePart := datePart[5:end];

	if datePart[1:1] = Hyphen and datePart.length() &gt; 1 then
		datePart := datePart[2:end];
	endif;

	if datePart.length() = 3 then
		// YYYY-DDD
		if (not datePart.isInteger()) or datePart.Integer &gt; (365 + year.cnEcIsLeapYear().Integer) then
			return null;
		endif;
		daysToAdd := datePart.Integer;
		date.setDate(1, 1, year);
		date := date + daysToAdd - 1;
	else
		nextBit := datePart[1:2];
		if not nextBit.isInteger() then
			return null;
		endif;
		month := nextBit.Integer;
		if datePart.length() &lt; 3 then
			return null;
		endif;
		datePart := datePart[3:end];

		if datePart[1:1] = Hyphen and datePart.length() &gt; 1 then
			datePart := datePart[2:end];
		endif;

		if datePart.length() &lt;&gt; 2 then
			return null;
		endif;

		nextBit := datePart;
		if not nextBit.isInteger() then
			return null;
		endif;
		day := nextBit.Integer;

		date.setDate(day, month, year);
		if not date.isValid() then
			return null;
		endif;
	endif;

	// Time
	nextBit := timePart[1:2];
	if (not nextBit.isInteger()) or nextBit.Integer &gt; 23 then
		return null;
	endif;
	hour := nextBit.Integer;
	if timePart.length() &gt; 2 then	// still some left after getting hours, try for minutes
		timePart := timePart[3:end];

		if timePart[1:1] = Colon and timePart.length() &gt; 1 then
			timePart := timePart[2:end];
		endif;

		if timePart.length() &lt; 2 then
			return null;
		endif;

		nextBit := timePart[1:2];
		if (not nextBit.isInteger()) or nextBit.Integer &gt; 59 then
			return null;
		endif;
		minute := nextBit.Integer;
		if timePart.length() &gt; 2 then	// still some left after getting minutes, try for seconds
			timePart := timePart[3:end];

			if timePart[1:1] = Colon and timePart.length() &gt; 1 then
				timePart := timePart[2:end];
			endif;

			if timePart.length() &lt; 2 then
				return null;
			endif;

			nextBit := timePart[1:2];
			if (not nextBit.isInteger()) or nextBit.Integer &gt; 59 then
				return null;
			endif;
			second := nextBit.Integer;
			if timePart.length() &gt; 2 then	// still some left after getting seconds, try for fractions
				timePart := timePart[3:end];

				if (timePart[1:1] = Period or timePart[1:1] = Comma) and timePart.length() &gt; 1 then
					nextBit := timePart[2:end];
					if nextBit.isInteger() then
						milli := nextBit[1:3].Integer;
					else
						return null;
					endif;
				else
					return null;
				endif;
			endif;
		endif;
	endif;
	time.setTime(hour, minute, second, milli);

	dateTime.setDate(date);
	dateTime.setTime(time);

	// Zone
	nextBit := zonePart[1:1];
	if nextBit &lt;&gt; "Z" then		// Z = UTC, no adjustment to make
		if zonePart.length() &lt; 3 then
			return null;
		endif;

		zonePart := zonePart[2:end];
		if nextBit = "-" then
			addMinutes := true;
		elseif nextBit &lt;&gt; "+" then
			return null;
		endif;

		nextBit := zonePart[1:2];
		if (not nextBit.isInteger()) or nextBit.Integer &gt; 14 then		// recognised timezones span -12:00 to +14:00
			return null;
		endif;
		minutesToShift := 60 * nextBit.Integer;

		if zonePart.length() &gt; 2 then	// still some left after getting hours, try for minutes
			zonePart := zonePart[3:end];

			if zonePart[1:1] = Colon and zonePart.length() &gt; 1 then
				zonePart := zonePart[2:end];
			endif;

			if zonePart.length() &lt;&gt; 2 then
				return null;
			endif;

			nextBit := zonePart;
			if (not nextBit.isInteger()) or nextBit.Integer &gt; 59 then
				return null;
			endif;
			minutesToShift := minutesToShift + nextBit.Integer;
		endif;

		if minutesToShift &lt;&gt; 0 then
			if addMinutes then
				dateTime := dateTime.addMinutes(minutesToShift);
			else
				dateTime := dateTime.addMinutes(-minutesToShift);
			endif;
		endif;
	endif;

	return dateTime;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="convertJadeXMLNodeStringToXML" id="a9fa5e1b-4080-470d-a984-684a413f1508">
        <source>convertJadeXMLNodeStringToXML() : String;
/*
Purpose:			
Date		Who		Reason
18 March 2015	cnwab1	Initial creation
*/

vars
	xmlString : String;
begin
	xmlString := self;
	xmlString := xmlString.replace("&amp;lt;","&lt;");
	xmlString := xmlString.replace("&amp;gt;","&gt;");
	
	return xmlString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="convertSpecialToAlphaEquiv" id="cab6422b-c9a3-4f07-825b-ab61ce0f15d0">
        <source>convertSpecialToAlphaEquiv() : String;

/*

Purpose:			Convert special characters in the receiver to their A-Z equivalents


Return Value:		Converted String


Date		Who		Reason
01 Apr 2005	cnwkpd1	Initial creation

*/

constants
	SpecialCharMapIn	= "ŔÁÂĂÄĹĆÇĐČÉĘËĚÍÎĎŃŇÓÔŐÖŘŚŠŮÚŰÜÝźŽŕáâăäĺćçđčéęëěíîďńňóôőöřśšůúűüý˙ž";
	SpecialCharMapOut	= "AAAAAAACDEEEEIIIINOOOOOOOSUUUUYYZaaaaaaacdeeeeiiiinooooooosuuuuyyz";
	
vars
	tempString		: String;
	inputChar		: Character;
	inputPos,
	inputLen,
	pos				: Integer;
	
begin
	tempString := null;
	inputLen := self.length;
	inputPos := 1;
	
	while inputPos &lt;= inputLen do
		tempString := tempString &amp; self.scanUntil(SpecialCharMapIn, inputPos);
		
		if inputPos = 0 then		// have reached the end
			break;
		endif;
		
		inputChar := self[inputPos];
		pos := SpecialCharMapIn.pos(inputChar, 1);
		if pos &lt;&gt; 0 then		// Should always be the case
			tempString := tempString &amp; SpecialCharMapOut[pos];
		endif;
		
		inputPos := inputPos + 1;
	endwhile;

	return tempString;
	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="convertStringArrToRealArr" id="46a0a9f5-78ca-4e10-a8bf-4bb71573e3ed">
        <source>convertStringArrToRealArr(_decimalArray : RealArray io);
/*

Purpose:			Should only ever be called from "convertPolygonFromXML" (located on String).

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2013	cnwmc5	Initial creation	CCMS 1259

*/

vars
	index 		: Integer;
	str			: String;	
	char		: Character;
	
	strArray	: HugeStringArray;
	subStrArr	: HugeStringArray;
begin
	create strArray transient;
	create subStrArr transient;
	char := " ";
	self.getHugeTokensForDelimiter(char, strArray);
	
	char := ",";
	foreach str in strArray do
		str.getHugeTokensForDelimiter(char, subStrArr);
	endforeach;
	
	strArray.clear();
	
	foreach str in subStrArr do
		if str[1:1].Character.isAlpha then
			_decimalArray.add(str[2:end].Real);
		else
			_decimalArray.add(str.Real);
		endif;
	endforeach;
	
	strArray.clear();
	subStrArr.clear();
epilog
	delete strArray;
	delete subStrArr;
end;</source>
        <Parameter name="_decimalArray" type="RealArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="convertToBoolean" id="434b500a-a4dc-450a-ace6-c5c9eea237d2">
        <source>convertToBoolean() : Boolean;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.toUpper = "YES" then
		return true;
	elseif self.toUpper = "TRUE" then
		return true;
	else
		return false;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="convertToDelimitedArray" id="574a2633-aa97-4144-9064-693f7f2a4111">
        <source>convertToDelimitedArray(delimiter : Character; array : StringArray io);
//AA 17/5/01: Breaks up delimited string into separate array elements
vars
	str, tempCopy : String;
	pos : Integer;
begin
	tempCopy := self &amp; delimiter &amp; " ";	//Add a bit to the end to get the last id
	pos := 1;
	while true do
		str := tempCopy.scanUntil(delimiter, pos);
		str := str.trimLeft;		//Loose any blanks after last delimiter
		if pos = 0 then 
			break; 
		endif;
		pos  := pos + 1;	//Skip the delimiter chars
		if str &lt;&gt; "" then
			array.add(str);
		else
			break;
		endif;
	endwhile;	
end;</source>
        <Parameter name="delimiter" type="Character"/>
        <Parameter name="array" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="convertToTitleCase" id="c08f1d4f-1ee5-44b3-be59-a6e39b2834e0">
        <source>convertToTitleCase() : String;
/*
Purpose:			
Date		Who		Reason
15 January 2013	cnwab1	Initial creation
*/

vars
	str, tmp : String;
	sta: StringArray;
	idx, stIdx, endIdx : Integer;
begin
	str := self;
	create sta transient;
	str.asStringArrayByDelimiter(sta, " ");
	
	stIdx := 1;
	endIdx := sta.size;
	
	
	str := "";
	
	foreach idx in stIdx to endIdx do
		tmp := sta[idx];
		tmp := tmp.toLower();
		tmp.firstCharToUpper();
		str := str &amp; tmp &amp; " ";
	endforeach;
	
	return str.trimBlankCharacters();
epilog
	delete sta;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="convertXAMLPathToPointArray" id="38cc8ac7-76c1-47b7-9259-224b60f53d70">
        <source>convertXAMLPathToPointArray(_pntArray : PointArray io);
/*
Purpose:			
Date		Who		Reason
30 August 2013	cnwab1	Initial creation
*/

vars
	reals : RealArray;
	reel, x1, y1 : Real;
	pnt : Point;
	idx : Integer;
begin
	if self = "" then
		return;
	endif;
	
	create reals transient;
	convertXAMLPathToRealArray(reals);
	
	foreach reel in reals do
		idx := idx + 1;
		if idx = 1 then
			x1 := reel;
		else
			y1 := reel;
			idx := 0;
			pnt.set(x1.Integer,y1.Integer);
			_pntArray.add(pnt);
		endif;
		
		
	endforeach;
epilog
	delete reals;
end;</source>
        <Parameter name="_pntArray" type="PointArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="convertXAMLPathToRealArray" id="e0169fcc-78fe-472f-a604-589f2be6e588">
        <source>convertXAMLPathToRealArray(_realArray : RealArray io);
/*

Purpose:			This method assumes that it is being called off a string containing the
					XML data in the correct format. This format is described below:
					
					&lt;Path Data="M0.5,0.5 L280.5,44.5 M0.50000042,0.50000495 L111.523,110.81001 M280,45.000008 L112.5,109.50001" Margin="8,150,0,0"/&gt;
					
					Where "Data" is the positions of the lines (e.g. L280.5,44.5 = x,y) and the "Margin" is how far it is offset from 0,0.
					(The "L" and "M" characters will be stripped for the positioning).
					
					This method calulates the offset from the "Margin" and returns a RealArray that is ajusted to position the polygon
					in the same place it was located in reference to where it was when being used by the XML.
					
					
					For examples on usage, see GRP_Mitchell on the GraphicsSchema.

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2013	cnwmc5	Initial creation	CCMS 1259

*/

vars
	index 			: Integer;
	dataStr			: String;
	marginStr		: String;
	str				: String;	
	char			: Character;
	real			: Real;
	
	dataDecArr		: RealArray;
	marginDecArr 	: RealArray;
	
	x, y			: Real;
	pos				: Integer;
begin
	index := 1;
	
	//Get the data string
	dataStr := self.scanUntil('"', index);
	index := index + 1;
	dataStr := self.scanUntil('"', index);
	
	//Get the margin string
	index := index + 1;
	marginStr := self.scanUntil('"', index);
	index := index + 1;
	marginStr := self.scanUntil('"', index);
	
	create dataDecArr transient;
	create marginDecArr transient;
	dataStr.convertStringArrToRealArr(dataDecArr);
	marginStr.convertStringArrToRealArr(marginDecArr);
	
	x := marginDecArr[1];
	y := marginDecArr[2];
	
	pos := 0;
	foreach real in dataDecArr do
		pos := pos + 1;
		if pos.isOdd then
			_realArray.add(real + x);
			continue;
		endif;
		_realArray.add(real + y);
	endforeach;
epilog
	delete dataDecArr;
	delete marginDecArr;
end;</source>
        <Parameter name="_realArray" type="RealArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="convertYYYYMMDDToDate" id="5d167896-6f1a-4526-96a3-88bc5f799049">
        <source>convertYYYYMMDDToDate() : Date;
//--------------------------------------------------------------
//Created: 27 August 2002 By: cnwgd1
//--------------------------------------------------------------
//takes yyyymmdd or yymmdd and converts to dd/mm/yyyy
vars
	dateResult	: Date;
begin
	if self.length = 8 then
		dateResult.setDate(self[7:2].Integer, self[5:2].Integer, self[1:4].Integer);
		return dateResult;
	elseif self.length = 6 then
		dateResult.setDate(self[5:2].Integer, self[3:2].Integer, self[1:2].Integer);
		return dateResult;		
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="countOccurrences" id="7d3a1a4e-7a3c-4792-b75a-c11377c1fb02">
        <source>countOccurrences(_ofString: String): Integer;
//----------------------------------------------------------------
//	Created:	07 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//Date			Who		Reason
//07 April 2025	navpw1	JIRA: MTN-34331 - Ignore preceeding question mark characters before apostrophes when counting the occurrances of apostrophes.
//											This avoids the UNT segment of a Baplie 2.2 extract file from having a wrong count, due to an "ignored" apostrophe in the middle of the line.
//											This is denoted by a Question Mark Character and looks like ?' in the file
vars
	count,
	intPos				: Integer;
	targetStr,
	selfStr				: String;
	checkingApostrophe	: Boolean;	//This prevents the need to re-evaluate the apostrophe check inside a loop
	
begin
	targetStr := _ofString;
	selfStr := self;
	intPos := 0;
	
	if _ofString = Apostrophe then
		checkingApostrophe := true;
	endif;
	
	while true do
		intPos := intPos + 1;
		intPos := selfStr.pos(_ofString, intPos);
		
		if intPos &gt; 0 then
			//If we are counting apostrophes and we have a Question Mark (EDI Baplie Ignore Character) before an apostrophe then skip counting it as we have ignored it.
			if checkingApostrophe and selfStr[intPos-1:1] = QuestionMark then
				continue;
			endif;
			count := count + 1;
		else
			break;
		endif;
	endwhile;
	
	return count;
	
end;</source>
        <Parameter name="_ofString" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="covertTokensToStringArray" id="f39dc005-9eeb-4a9f-8426-bdbdf05e19e9">
        <source>covertTokensToStringArray(_sa: StringArray input);

/*

Date		Who		Reason
08 Oct 2008	cnwkpd1	PAR #18009 - Prevent transient leaks

*/

vars
	wrkStr 			: String;
	sa				: StringArray;
	
begin
	_sa.clear;
	if self.trimBlanks = null then
		return;
	endif;
	
	//replace comma with Tab so we can use getTokens - allows for lots of delimiters
	wrkStr := self.replaceString(",", Tab);
	sa := wrkStr.getTokens();		// PAR #18009
	sa.copy(_sa);
	
epilog
	delete sa;						// PAR #18009
	
end;</source>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="csvConvert" id="2f29dcc8-fc3f-42da-9c75-4d6a1bb43534">
        <source>csvConvert(stringArray : HugeStringArray input; _delimiter:Character);
/*

Date: 18 August 1999
Developer: Richard Greer

Date		Developer            Modification
--------    -----------------    ---------------------
31/5/2006	RBarr	Added this method to extract fields from csv data. Does the same as csvToStringArray(),
					except that it correctly handles double quote and embedded comma combinations. Also
					takes HugeStringArray as parameter.
13 Jun 2008	cnwkpd1	PAR #17040 - Correct EDI loading of CSV files with embedded commas and quotes in fields
					Replaced existing code with calls to new getNextCSVToken method, to allow common code
					and rules to be shared
09 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Allow for last character being a delimiter.
25/11/2009	cnwdad1	PAR #21720 Added delimiter parameter.
*/

vars
/*	workingString 		: String;
	workingChar	  		: Character;
	lastChar	  		: Character;
	currentPos     		: Integer;
	lookAheadPos		: Integer;
	nextQuotePosition 	: Integer;
	startQuotePosition  : Integer;
	stringLength		: Integer;
    startPos			: Integer;
    
*/
	length			: Integer;
	pos				: Integer;
	
begin
	pos := 1;
	length := self.length();
	
	if pos &gt; length then
		return;
	endif;
	
	while pos &lt;= length and pos &lt;&gt; 0 do
		stringArray.add(self.getNextCSVToken(pos, _delimiter));		// cnwdad1 25/11/2009 - PAR #21720 Added delimiter parameter.
	endwhile;
	
	// PAR #18743 - if the final character is a delimiter, then need to add 1 more field
	if pos &gt; length then
		stringArray.add(null);
	endif;
	
/*
	Old code replaced PAR #17040

	while currentPos &lt; self.length do
		currentPos := currentPos + 1;
		workingChar := self[currentPos];

		if nextQuotePosition &lt;&gt; -1 then
			// If we think there are more quotes we do this, 
			// obviously we won't know the first time we come into here.
			if workingString = null then
				if workingChar = '"' and nextQuotePosition = 0 then

					// Find the next quote if there is one
					startQuotePosition := nextQuotePosition;
					lookAheadPos := currentPos;
					length := self.length;
					while lookAheadPos &lt; length do
						lookAheadPos := lookAheadPos + 1;
						if self[lookAheadPos] = '"' and lastChar &lt;&gt; '"' and (lookAheadPos = length or self[lookAheadPos + 1] = ',') then
							nextQuotePosition := lookAheadPos;
							break;
						endif;
						lastChar := self[lookAheadPos];
					endwhile;

					// There are no other quotes so set the next position to
					// -1 so that we don't check for them any more.
					if startQuotePosition = nextQuotePosition then
						nextQuotePosition := -1;
					endif;
				endif;
			endif;

		endif;

		// Now decide what to add to the stringArray
		if nextQuotePosition &gt; 0 and workingChar = '"' then
			// Place the string between the quotes into the array.
			workingString := self[currentPos + 1 : nextQuotePosition - 1 - currentPos];
			stringArray.add(workingString);
			currentPos := nextQuotePosition + 1;
			nextQuotePosition := 0;			
			workingString := null;
		elseif workingChar = ',' then
			// Place the string since the last comma into the stringArray
			// if we are not withing quotes.
			stringArray.add(workingString);
			workingString := null;
		else
			// We are not in quotes and have not reached another comma so
			// just add the current character to the string we are building
			// and go through the loop again.
	    	workingString := workingString &amp; workingChar;
	    endif;


	endwhile;

	if workingString &lt;&gt; null then
		stringArray.add(workingString);
	endif;

*/

end;</source>
        <Parameter name="stringArray" type="HugeStringArray" usage="input"/>
        <Parameter name="_delimiter" type="Character"/>
    </JadeMethod>
    <JadeMethod name="csvDecode" id="54e07198-7b30-44cb-aef9-74141648bccd">
        <updating/>
        <source>csvDecode(readerObject : Object; processRecordMethod : String) updating;

// Purpose: To decode a CSV file that complies with the RFC4180 specification

//          A CSV file has the following format
//          field1,field2,field3,field4&lt;line-break&gt;
//          field1,field2,field3,field4&lt;line-break&gt;
//          field1,field2,field3,field4&lt;line-break&gt;
//          where the &lt;line-break&gt; can be CrLf, Cr, or Lf.
//          Sometimes the final &lt;line-break&gt; is missing.

//          Parsing each record produces an array of fields, which is passed as
//          a parameter to 'processRecordMethod' of the 'readerObject'.

//          Geoff Davies, 8 September 2006

constants
	Comma = #'2C';
	DoubleQuote = #'22';

vars
	len : Integer;
	pos : Integer;
	char : Character;
	fields : HugeStringArray;
	field : String;
	isBuildingField : Boolean;
	groupOfDoubleQuotes : String;
	numberOfDoubleQuotes : Integer;
	delimiter : Character;
	result : Any;

begin
	// The last line of a CSV file should be terminated
	// with a line-break, but just in case it isn't.
	self := self &amp; CrLf;
	len := self.length;

	create fields transient;
	pos := 1;

	// At the top of this 'while' loop the 'pos' variable is at the
	// start of a new field, or possibly on a line-break character.
	while true do

		char := self[pos];

		// The 'if' branch decodes a field if it is enclosed in double-quotes;
		// the 'else' branch decodes a field that is not.
		if char = DoubleQuote then
			pos := pos + 1;
			isBuildingField := true;
			while isBuildingField do
				// Look for the next double-quote, which may be a single double-quote
				// or it may be the start of a group of double quotes.
				// An even number of double-quotes corresponds to double-quotes
				// embedded in the field that have been escaped.
				// An odd number of double quotes occurs at the end of a field.
				field := field &amp; self.scanUntil(DoubleQuote, pos);
				groupOfDoubleQuotes := self.scanWhile(DoubleQuote, pos);
				numberOfDoubleQuotes := groupOfDoubleQuotes.length;
				if numberOfDoubleQuotes.isOdd then
					isBuildingField := false;
				endif;
				field := field &amp; DoubleQuote.makeString((numberOfDoubleQuotes) div 2);
			endwhile;

		else
			// The field does not have enclosing double-quotes
			// so the next comma marks the end of the field.
			field := self.scanUntil(Comma &amp; CrLf, pos);
		endif;

		fields.add(field);
		field := null;
		delimiter := self[pos];
		
		// The delimiter is either Comma, Cr, or Lf.
		if delimiter = Cr or delimiter = Lf then
			result := readerObject.sendMsgWithParams(processRecordMethod, fields, pos);
			// Leave the method if the processing of a record fails.
			if result.Boolean = false then
				return;
			endif;
			fields.clear;
			self.scanWhile(CrLf, pos);
			// pos = 0 indicates the end of the self string.
			if pos = 0 then
				break;
			endif;
		else
			pos := pos + 1;
			char := self[pos];
			// Here delimiter is a comma and the usual situation is that char
			// is the first character of the next field, but if it is a line-break
			// then there is a null field at the end of the record.
			// Also send pos and len so if a progress update is needed.
			if char = Cr or char = Lf then
				fields.add(null);
				// Leave the method if the processing of a record fails.
				result := readerObject.sendMsgWithParams(processRecordMethod, fields, pos);
				if result.Boolean = false then
					return;
				endif;
				fields.clear;
				self.scanWhile(CrLf, pos);
				// pos = 0 indicates the end of the self string.
				if pos = 0 then
					break;
				endif;
			endif;
		endif;

	endwhile;
	
epilog
	delete fields;
	
end;</source>
        <Parameter name="readerObject" type="Object"/>
        <Parameter name="processRecordMethod" type="String"/>
    </JadeMethod>
    <JadeMethod name="csvEncode" id="94b5af5c-73dc-4e24-990f-5e7f1bb4d497">
        <source>csvEncode() : String;
// Purpose: To convert a field into CSV according to the RFC4180 specification
//          Build a CSV record by calling this method on all fields, as follows:
//          field1.csvEncode &amp; "," &amp; field2.csvEncode &amp; "," &amp; field3.csvEncode &amp; CrLf

//          If a field contains a double-quote, comma, or line-break,
//          it must be enclosed in double-quotes.
//          If a field starts or ends with white space characters,
//          it must also be enclosed in double-quotes.
//          A double-quote in a field enclosed by double quotes
//          is escaped with another double quote.

//          It is permissible to put double quotes around every field,
//          so the following records are equivalent
//          CSV record #1:    "John","Smith","Christchurch, New Zealand"&lt;line-break&gt;
//          CSV record #2:    John,Smith,"Christchurch, New Zealand"&lt;line-break&gt;
//          The second record avoids double-quotes around the first two fields.
//          The third field required double-quotes because it contained a comma.

//          However the method avoids enclosing fields with double-quotes
//          where they are not absolutely necessary.

//          Geoff Davies, 8 September 2006

constants
	Comma = #'2C';
	DoubleQuote = #'22';
	Space = #'20';
vars
	idx : Integer;
	len : Integer;
	str : String;
begin
	if self = null then
		return null;
	endif;

	// Escape double-quotes in the field by adding another double-quote
	idx := 1;
	len := self.length;
	while idx &lt;= len do
		str := str &amp; self.scanUntil(DoubleQuote, idx);
		if idx = 0 then
			break;
		else
			str := str &amp; DoubleQuote &amp; DoubleQuote;
		endif;
		idx := idx + 1;
	endwhile;

	// Surround the field with double-quotes if the field
	// (1) contains a comma, double-quote, or line-break
	// (2) starts or ends with white space
	idx := 1;
	self.scanUntil(Comma &amp; DoubleQuote &amp; CrLf, idx);
	if idx &gt; 0 or self[1] = Tab or self[1] = Space or self[len] = Tab or self[len] = Space then
		str := DoubleQuote &amp; str &amp; DoubleQuote;
	endif;

	return str;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="csvFormat" id="58845381-7228-481d-9cb5-158c9c830560">
        <source>csvFormat() : String;
//--------------------------------------------------------------
//Created: 20 September 2002 By: cnwgd1
//--------------------------------------------------------------
//Single quotes in data represented by two consecutive double quotes
//ie. Da'ta or Da"ta becomes Da""ta.
/*

Date		Who		Reason
01 Apr 2008	cnwkpd1	PAR #16409 - need to correct code to handle fields containing comma
					and quote characters

*/

constants
	DoubleQuote = '""';

vars
	pos			: Integer;
	rtnValue	: String;
//	targetSubString 	: String;
//	tmpLen,
//	i, j, targetLength	:  Integer;

begin

	rtnValue := self;

	if rtnValue.pos(',', 1) &gt; 0 or rtnValue.pos('"', 1) &gt; 0 
	or rtnValue.pos(CrLf, 1) &gt; 0	//18624. When there is  CrLf, the field will be under quotes. Dec 2008
	then
		return '"' &amp; rtnValue.replaceString('"', '""') &amp; '"';
	else
		return rtnValue;
	endif;
	
/*
	PAR #16409 - old code replaced
	
	if self = '' then
		return "";
	endif;
	
	//return '"' &amp; self.replaceString('"', '""') &amp; '"';
	return self.replaceString('"', '""');		// 22/01/2008 cnwar2 #14235
*/	
/*
	targetSubString := '"';
	targetLength := targetSubString.length;
	i := 1;
	j := 1;
	
	tmpLen := self.length;
	
	while i &lt;= tmpLen do
		i := self.pos(targetSubString, i);
		if i = 0 then
			rtnValue := rtnValue &amp; self[j:end];
			break;
		else
			rtnValue := rtnValue &amp; self[j: i - j] &amp; DoubleQuote &amp; self[i + j:end];
			i := i + targetLength;
			j := i;
			return rtnValue;			
		endif;
	endwhile;

	targetSubString := "'";
	targetLength := targetSubString.length;
	i := 1;
	j := 1;
	rtnValue := null;
	while i &lt;= self.length do 
		i := self.pos(targetSubString, i);
		if i = 0 then
			rtnValue := rtnValue &amp; self[j:end];
			break;
		else
			rtnValue := rtnValue &amp; self[j: i - j] &amp; DoubleQuote &amp; self[i + j:end];
			i := i + targetLength;
			j := i;
			return rtnValue;			
		endif;
	endwhile;
	
	return rtnValue;
*/	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="csvToStringArray" id="3da892ed-d979-4191-807f-dd010277b90d">
        <source>csvToStringArray(_theStringArray: StringArray input; _delimiter:Character);
//----------------------------------------------------------------
//	Created:	15 November 2004	by Jason Chapman  (cnwjc2)
//
// 			Should take any comma separated variable string and put variables into string array
// Note:  	Only good for short strings
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
13 Jun 2008	cnwkpd1	PAR #17040 - Correct EDI loading of CSV files with embedded commas and quotes in fields
					Replaced existing code with calls to new getNextCSVToken method, to allow common code
					and rules to be shared
10 Sep 2008	cnwkpd1	PAR #17644 - rework patch to use StringArray::addTruncated method
09 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Allow for last character being a delimiter
25/11/2009	cnwdad1	PAR #21720 - Added delimiter parameter.
*/
vars
/*	field,
	length,
	endPos,
	startPos	: Integer;
	
	value,
	strRec		: String;
*/	
	length			: Integer;
	pos				: Integer;

begin
	_theStringArray.clear();
	
	pos := 1;
	length := self.length();
	
	if pos &gt; length then
		return;
	endif;
	
	while pos &lt;= length and pos &lt;&gt; 0 do
//		_theStringArray.add(self.getNextCSVToken(pos)[1:63]); //par17644 cnwrs1 Aug 2008
		_theStringArray.addTruncated(self.getNextCSVToken(pos, _delimiter));		// cnwdad1 25/11/2009 - PAR #21720.
	endwhile;
	
	// PAR #18743 - if the final character is a delimiter, then need to add 1 more field
	if pos &gt; length then
		_theStringArray.add(null);
	endif;
	
/*
	Old code replaced PAR #17040	
	
	startPos := 1;
	endPos := 1;
	field := 1;

	while startPos &lt;= strRec.length do
		//find end of field
		endPos := strRec.pos("," , startPos) - 1;
		
		//get the value
		if endPos &gt;= startPos then	//field to add
			length := (endPos+1)- startPos;	
			value := strRec[startPos:length].trimBlanks;
			
		elseif endPos = -1 then		//last field
			length := (strRec.length+1)- startPos;	
			value := strRec[startPos:length].trimBlanks;
		
		else
			value := null;
		endif;
		
		//check for use of '"', then correct it (we may have found an non-delimiting comma).
		if value[1] = '"' then
			//set new startPos to after the first '"'
			startPos := strRec.pos('"', startPos)+1;
			
			//set new endPos to before the next '"'
			endPos := strRec.pos('"', startPos) - 1;
			
			//could just be a single "
			if endPos = -1 then
				//backup 1
				startPos := startPos - 1;
				
				//look for end of field
				endPos := strRec.pos("," , startPos+1) - 1;
				
				//check for last
				if endPos = -1 then
					endPos := startPos;
				endif;
			
			endif;
			
			length := (endPos+1)- startPos;	
			value := strRec[startPos:length].trimBlanks;
			
			//reset endPos to before the comma after the '"' (where it would be normally)
			endPos := strRec.pos("," , endPos+1) - 1;
		endif;
		
		
		//deal with it
		if value &lt;&gt; null then
			_theStringArray.add(value[1:62].trimBlanks);	
		else
			_theStringArray.add(null);	
		endif;
		
		if endPos = -1 then //there are no more commas, we have the last field
			break;
		else
			startPos := endPos + 2;
			field := field + 1;
		endif;
		
	endwhile;	
*/

epilog
	
end;</source>
        <Parameter name="_theStringArray" type="StringArray" usage="input"/>
        <Parameter name="_delimiter" type="Character"/>
    </JadeMethod>
    <JadeMethod name="dataDumpFormat" id="dc52fa94-8b24-4ce3-bd2d-dd1e6b91168b">
        <source>dataDumpFormat() : String;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwsb1
