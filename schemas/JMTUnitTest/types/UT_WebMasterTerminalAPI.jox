    <JadeMethod name="verifyCntsOfTrnCnstEDIFile" id="3af557fb-db22-49ae-ace8-684a5d80d3b2">
        <source>verifyCntsOfTrnCnstEDIFile(_ediFile : CM_EDIFile) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2023	navra1	Initial creation

*/

vars
	trainConsist : CM_EDIDataTrainConsist;
	ediTi : CM_EDITrackedItem;
	wagonTiCnt:Integer;	
	hazTiCnt:Integer;	
	ediPrenoteTiCnt:Integer;	
	trainTICnt : Integer;
	unknownTiCnt:Integer;
	
begin
	//check the data on the edifile
	assertTrueMsg(_ediFile.allEDIData.size() = 1, "The allEDIData size is not 1 as expected");
	
	assertTrueMsg(_ediFile.allEDIData.first().isKindOf(CM_EDIDataTrainConsist), "The edi data is not CM_EDIDataTrainConsist");	
	
	assertTrueMsg(_ediFile.allHeaderReferences.size() = 1 , "There is more than 1 header references!");
	
	assertTrueMsg(_ediFile.allHeaderReferences.first().name = "ReferenceCustomer", "The header reference name is not as expected");
	
	assertTrueMsg(_ediFile.allHeaderReferences.first().value = "355427", "The header reference value is not as expected");	
	
	assertTrueMsg(_ediFile.ediData.isKindOf(CM_EDIDataTransManifest), "There edi data type is not as expected");
	
	assertTrueMsg(_ediFile.ediMessageType = "Manifest", "The edi message type is not as expected");
	
	assertTrueMsg(_ediFile.fileRecipientCode = "EBTA", "The fileRecipientCode data is not as expected");
	
	assertTrueMsg(_ediFile.fileSenderCode = "UT97", "The sender code is not as expected");
	
	assertTrueMsg(_ediFile.guid = "f0c633e1-95dc-443c-b87f-8c15221fdfea", "The guid is not as expected");
	
	assertTrueMsg(_ediFile.mode = "Create", "The mode is not as expected");
	
	//check the train consist
	trainConsist := _ediFile.allEDIData.first().CM_EDIDataTrainConsist;	
	
	assertTrueMsg(trainConsist.currentTrainCode = "******", "The currentTrainCode is not as expected");		
	
	assertTrueMsg(trainConsist.currentWagonCode= "UT-WAG-01", "The currentWagonCode is not as expected");	
	
	assertTrueMsg(trainConsist.myTransportManifest &lt;&gt; null, "The myTransportManifest is null");
	
	assertTrueMsg(trainConsist.allEDITrackedItems.size() = 8, "The allEDITrackedItems size is not as expected");	
	
	assertTrueMsg(trainConsist.ediConfig&lt;&gt;null, "The ediConfig is not null");
	
	assertTrueMsg(trainConsist.myEDIFile&lt;&gt;null, "The myEDIFile is null");	
	
	//check the edi tracked items counts
	foreach ediTi in trainConsist.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDITrainTI) then
			trainTICnt := trainTICnt + 1;
		elseif ediTi.isKindOf(CM_EDIWagonTI) then
			wagonTiCnt := wagonTiCnt + 1;
		elseif ediTi.isKindOf(CM_EDIPrenoteTI) then
			ediPrenoteTiCnt := ediPrenoteTiCnt + 1;
		elseif ediTi.isKindOf(CM_EDIHazDetailsTI) then
			hazTiCnt := hazTiCnt + 1;		
		else
			unknownTiCnt := unknownTiCnt + 1;
		endif;		
	endforeach;
	
	assertTrueMsg(trainTICnt =1, "The TrainTICnt is not as expected");
	
	assertTrueMsg(wagonTiCnt=1, "The wagonTiCnt is not as expected");
	
	assertTrueMsg(ediPrenoteTiCnt=3, "The ediPrenoteTiCnt is not as expected");
	
	assertTrueMsg(hazTiCnt=3, "The hazTiCnt is not as expected");	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="verifyPostCargoProperties" id="ee1293c6-dbfc-43c7-b0db-1f45649c16b4">
        <source>verifyPostCargoProperties(_id : String; _type : String) protected;
/*

Purpose:	Generic method for verifying all the post cargo related properties
Please add all the extra fields here.

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2024	navsp1	Initial creation TFS 66117

*/

vars
	realTI : CM_TrackedItem;
begin
	
	realTI := self.getTrackedItem(_id);
	assertNotNull(realTI);
	
	if _type = "ContentStatus" then
		if realTI.isContainer or realTI.isMAFI then
			assertEqual(realTI.getContentsStatusDesc(false), "FCL");
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
