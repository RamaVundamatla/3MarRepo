    <JadeMethod name="validateCreate" id="0c930e1d-b534-4a44-a6c8-9f9c1d798c9d">
        <source>validateCreate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	inheritMethod(_passport);
	
	if self.myParentQueue &lt;&gt; null and  self.myParentQueue.allSubQueuesById[self.id] &lt;&gt; null then				// 21/12/2009 cnwmh5 #21729
		app.raiseCMException2(ERR_INVALID_VALUE, 'ID', 'Parent Queue already has Sub-Queue with this Id',null,null);
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
