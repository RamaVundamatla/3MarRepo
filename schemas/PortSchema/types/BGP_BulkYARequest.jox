<Class name="BGP_BulkYARequest" id="fd3e0b32-53bf-48a9-b992-06812f4d2181">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Bulk Yard Allocation Calculation&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="allTIs" id="ccaaba28-a14d-4ab0-9571-1384b879e958">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
    </ImplicitInverseRef>
    <JadeMethod name="action" id="f82f75c8-d632-4735-b2be-7aee6025cedd">
        <updating/>
        <source>action(): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/08/2025	navdap1		Initial creation MTN-35615 MTN | Bulk Creation of Yard Allocations 
//
vars
	errCode : Integer;
	errText : String;
	cmifAgent : CMIF_BulkYAAgent;
	ti : CM_TrackedItem;

begin
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errText, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	create cmifAgent transient;
	cmifAgent.myBGPRequest := self;
	ti := self.allTIs.first;
	if ti &lt;&gt; null then
		cmifAgent.setDetails(ti.myTerminal, ti.getImExStatus(), self.allTIs);
	else
		self.allTIs.copy(cmifAgent.allTIsToProcess);
	endif;
	cmifAgent.doCalculations();
	
epilog
	if errCode &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Process Failed - error is " &amp; errCode.String, LogINFO);
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errText, app.myPassport);
		self.causeEvent(Event_BulkYAFailed, true, null);
	endif;
	delete cmifAgent;
	
	inheritMethod();
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="1bd1ab30-ed38-4727-8291-88c7ac34140b">
        <source>getDisplay(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/08/2025	navdap1		Initial creation MTN-35615 MTN | Bulk Creation of Yard Allocations
//
vars

begin
	return inheritMethod() &amp; Tab &amp; "Bulk Yard Allocation Analysis";

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="23ab269a-3e1b-45ff-ab9d-e6d80a39aa36">
        <updating/>
        <source>setForCreate(_pxyRequest : BGP_BulkYARequest) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2025	navdap1		Initial creation MTN-35615 ENS | Bulk Creation of Yard Allocations
//
vars

begin
	_pxyRequest.allTIs.copy(self.allTIs);
epilog

end;</source>
        <Parameter name="_pxyRequest" type="BGP_BulkYARequest"/>
    </JadeMethod>
</Class>
