    </JadeMethod>
    <JadeMethod name="trxUpdateReeferAPIData" id="cea4e8c9-be03-48ad-8311-601bd64cee38">
        <updating/>
        <source>trxUpdateReeferAPIData(	_connectParams, _disconnectParams : CMIF_ConnectParams io; 
						_controller : CMIF_TIUpdateController input;
						_readings : ObjectSet;
						_jobs : CM_YardActivityArray;
						_context : String;								// MTN-36569
						_passport : CM_Passport input	) updating;
//
// Purpose:			Connects, disconnects and updates reefer attributes
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/10/2020	jlgdap1		Initial creation TFS 49227 Navis API - nReefer API
// 21/12/2020	jlgdap1		TFS 50522 MTN Reefer API Testing
// 18/01/2021	jlgdap1		TFS 50648 MTN Reefer API Issue (4)
// 25/08/2021	navdap1		TFS 51810 POL Nreefer App Temp Reading charging for ALL the Temp reading and Not for first reading ONLY
// 15/12/2025	navdap1		MTN-36569 CPL | Reefer Runner Integration
//
vars
	pxyTI : CM_TrackedItem;
	agent : CMIF_MobileGenericAgent;
	obj : Object;
	humidParams : CMIF_HumidReading;
	ventParams : CMIF_VentReading;
	tempParams : CMIF_TempReading;
	realTi : CM_TrackedItem;
	lastReading, tempReading : CM_TempReading;
	tempController : CMIF_TempTransController;
	tempDifference : Real;
	tempReadingTransaction : CM_TITransaction;
	humidController : CMIF_HumidTransController;
	humidReading : CM_HumidReading;
	humidReadingTransaction : CM_TITransaction;
	ventController : CMIF_VentTransController;
	ventReading : CM_VentReading;
	ventReadingTransaction : CM_TITransaction;
	job : CM_YardActivity;
	iter : Iterator;				// TFS 50648
	// MTN-36569 variables
	co2Params : CMIF_CO2Reading;
	o2Params : CMIF_O2Reading;
	co2Transacton, o2Transaction : CM_TITransaction;
	co2Controller : CMIF_CO2TransController;
	o2Controller : CMIF_O2TransController;
	co2Reading : CM_CO2Reading;
	o2Reading : CM_O2Reading;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
		
	if _connectParams = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "Connection Parameters", null, null);
	endif;
	if _disconnectParams = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "Disconnection Parameters", null, null);
	endif;
	if _connectParams.allTrackedItems.isEmpty
	and _disconnectParams.allTrackedItems.isEmpty
	and (_controller &lt;&gt; null and _controller.allTransientTIs.isEmpty) 		// MTN-36569
	and _readings.isEmpty then
		app.raiseCMException2(MethodWithNullParam, method.name, "allTrackedItems", null, null);
	endif;	

	app.setContinueCMExceptions(false);
	
	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate := true;
	_passport.setWarningsIgnored(true);
	_passport.setWarningsAcknowledged(true);
	
	beginTransaction;
	
	create agent transient;
	
	// updates first - otherwise we end up with proxy link issues
	// MTN-36569 Reefer Runner doesn't pass in a _controller (because we can't update the TIs through Reefer Runner
	if _controller &lt;&gt; null then
		app.myUtilityUA.utlUpdateTrackedItems(_controller, _passport);
	endif;
	
	// MTN-36569 connections and disconnections from MasterTerminalAPI are in the _readings array
	if _context = ReeferAPIContext_NReefer then
		// then connections 
		self.doUpdateTIConnectDisconnect(_connectParams, agent, _passport);
		/*foreach pxyTI in _connectParams.allTrackedItems do
			if pxyTI.myTerminalArea.isKindOf(CM_ForkLiftStack) and not pxyTI.myPrimaryActualLocation.hasPower then
				power := agent.findClosestPowerPoint(pxyTI);
				if power = null then
					app.raiseCMException(No_power_avail, null, null);
					return;
				endif;
			endif;
			
			// don't connect if it's already connected - reefer API can work in offline mode
			if not pxyTI.isConnected then
				app.myUtilityUA.utlUpdateConnect(_connectParams, pxyTI, _passport);
			endif;
			if _passport.hasErrors() then
				return;
			endif;
		endforeach;*/
		
		// then disconnections
		self.doUpdateTIConnectDisconnect(_disconnectParams, agent, _passport);
		/*foreach pxyTI in _disconnectParams.allTrackedItems do
			if pxyTI.myTerminalArea.isKindOf(CM_ForkLiftStack) and not pxyTI.myPrimaryActualLocation.hasPower then
				power := agent.findClosestPowerPoint(pxyTI);
				if power = null then
					app.raiseCMException(No_power_avail, null, null);
					return;
				endif;
			endif;
			
			// don't disconnect if already disconnected - reefer app can work in offline mode 
			if pxyTI.isConnected then
				app.myUtilityUA.utlUpdateDisconnect(_disconnectParams, pxyTI, _passport);
			endif;
			if _passport.hasErrors then
				return;
			endif;
		endforeach;*/
	endif;
	
	// then all the readings - humidity, ventilation and temperature ( and connect / disconnect from MasterTerminalAPI messages)
	app.writeLog(method.qualifiedName &amp; Tab &amp; "We have " &amp; _readings.size.String &amp; " to process", LogDEBUG);
	foreach obj in _readings do
		if _context = ReeferAPIContext_Rest and obj.isKindOf(CMIF_ConnectParams) then
			self.doUpdateTIConnectDisconnect(obj.CMIF_ConnectParams, agent, _passport);
			continue;
		endif;
		tempParams := null;
		humidParams := null;
		ventParams := null;
		co2Params := null;		// MTN-36569
		o2Params := null;		// MTN-36569
		if obj.isKindOf(CMIF_TempReading) then
			tempParams := obj.CMIF_TempReading;
		elseif obj.isKindOf(CMIF_HumidReading) then
			humidParams := obj.CMIF_HumidReading;
		elseif obj.isKindOf(CMIF_VentReading) then
			ventParams := obj.CMIF_VentReading;
		// MTN-36569 CO2 and O2 readings
		elseif obj.isKindOf(CMIF_CO2Reading) then
			co2Params := obj.CMIF_CO2Reading;
		elseif obj.isKindOf(CMIF_O2Reading) then
			o2Params := obj.CMIF_O2Reading;
		endif;
		
		if tempParams &lt;&gt; null then
			if not tempParams.myTrackedItem.isTransient then
				pxyTI := app.createUpdateProxy(tempParams.myTrackedItem).CM_TrackedItem;
				tempParams.myTrackedItem := pxyTI;
			else
				pxyTI := tempParams.myTrackedItem;
			endif;
			realTi := tempParams.myTrackedItem.pxyGetRealObject();
			lastReading := realTi.getLastTempReading;
			if lastReading &lt;&gt; null and lastReading.getTemperatureValue() &lt;&gt; NULL_TEMPERATURE then
				tempDifference := lastReading.getTemperatureValue() - tempParams.temperature;
				if tempDifference &gt;= 10 or tempDifference &lt;= -10 then
					app.raiseCMWarning(Reefer_temp_difference, null, null, null);
				endif;
			endif;
			
			tempParams.noCharge := realTi.noChargeForTemperature(false, app.actualTimeServer);	// TFS 51810
			tempReading := app.myUtilityCA.utlCreateTempReading(tempParams, _passport);
			
			if _passport.noErrors then
				//create temperature reading TI transaction
				create tempController transient;
				tempParams.setTITransController(tempController);
				
				tempController.myTempReading := tempReading;
				app.myUtilityCA.utlCreateTITransaction(tempController, tempReadingTransaction, _passport);
				delete tempController;			// TFS 50648
			endif;
			
			delete pxyTI;
		endif;
		
		if humidParams &lt;&gt; null then
			if not humidParams.myTrackedItem.isTransient then
				pxyTI := app.createUpdateProxy(humidParams.myTrackedItem).CM_TrackedItem;
				humidParams.myTrackedItem := pxyTI;
			else
				pxyTI := tempParams.myTrackedItem;
			endif;
			humidReading := app.myUtilityCA.utlCreateHumidityReading(humidParams, _passport);
			
			if _passport.noErrors then
				//create humidity reading TI transaction
				create humidController transient;
				humidParams.setTITransController(humidController);
				humidController.myHumidReading := humidReading;
				app.myUtilityCA.utlCreateTITransaction(humidController, humidReadingTransaction, _passport);
				delete humidController;			// TFS 50648
			endif;
			
			delete pxyTI;
		endif;
		
		if ventParams &lt;&gt; null then
			if not ventParams.myTrackedItem.isTransient then
				pxyTI := app.createUpdateProxy(ventParams.myTrackedItem).CM_TrackedItem;
				ventParams.myTrackedItem := pxyTI;
			else
				pxyTI := tempParams.myTrackedItem;
			endif;
			ventReading := app.myUtilityCA.utlCreateVentilationReading(ventParams, _passport);
			
			if _passport.noErrors then
				//create ventilation reading TItrans
				create ventController transient;
				ventParams.setTITransController(ventController);
				ventController.myVentReading := ventReading;
				app.myUtilityCA.utlCreateTITransaction(ventController, ventReadingTransaction, _passport);
				delete ventController;			// TFS 50648
			endif;
			
			delete pxyTI;
		endif;
		
		// MTN-36569 CO2 and O2 readings
		if co2Params &lt;&gt; null then
			if not co2Params.myTrackedItem.isTransient then
				pxyTI := app.createUpdateProxy(co2Params.myTrackedItem).CM_TrackedItem;
				co2Params.myTrackedItem := pxyTI;
			else
				pxyTI := tempParams.myTrackedItem;
			endif;
			co2Reading := app.myUtilityCA.utlCreateCO2Reading(co2Params, _passport);
			if _passport.noErrors then
				// Create CO2 reading tTI transaction
				create co2Controller transient;
				co2Params.setTITransController(co2Controller);
				co2Controller.myCO2Reading := co2Reading;
				app.myUtilityCA.utlCreateTITransaction(ventController, co2Transacton, _passport);
				delete co2Controller;
			endif;
			
			delete pxyTI;
		endif;
		
		if o2Params &lt;&gt; null then
			if not o2Params.myTrackedItem.isTransient then
				pxyTI := app.createUpdateProxy(o2Params.myTrackedItem).CM_TrackedItem;
				o2Params.myTrackedItem := pxyTI;
			else
				pxyTI := tempParams.myTrackedItem;
			endif;
			o2Reading := app.myUtilityCA.utlCreateO2Reading(o2Params, _passport);
			if _passport.noErrors then
				// Create CO2 reading tTI transaction
				create o2Controller transient;
				o2Params.setTITransController(o2Controller);
				o2Controller.myO2Reading := o2Reading;
				app.myUtilityCA.utlCreateTITransaction(ventController, o2Transaction, _passport);
				delete o2Controller;
			endif;
			
			delete pxyTI;
		endif;
	endforeach;
	
	if _passport.hasErrors then
		return;
	endif;
	
	// now mark all the jobs as complete
	// TFS 50648 change of emphasis - check for jobs that we can complete based on the things we've updated
	// connected TIs
	foreach pxyTI in _connectParams.allTrackedItems do
		realTi := pxyTI.pxyGetRealObject();
		if realTi = null then
			realTi := pxyTI;
		endif;
		if realTi.isConnected then
			// delete any connection jobs that aren't future dated
			iter := realTi.allYardActivities.createIterator;
			while iter.next(job) do
				if job.isReeferConnect and job.actionTime &lt;= app.actualTimeServer then
					job.doAction();
				endif;
			endwhile;
			delete iter;
		endif;
	endforeach;
	// disconnected TIs
	foreach pxyTI in _disconnectParams.allTrackedItems do
		realTi := pxyTI.pxyGetRealObject();
		if realTi = null then
			realTi := pxyTI;
		endif;
		if not realTi.isConnected then
			// delete any connection jobs that aren't future dated
			iter := realTi.allYardActivities.createIterator;
			while iter.next(job) do
				if job.isReeferDisconnect and job.actionTime &lt;= app.actualTimeServer then
					job.doAction();
				endif;
			endwhile;
			delete iter;
		endif;
	endforeach;
	// monitor jobs
	foreach obj in _readings do 
		tempParams := null;
		humidParams := null;
		ventParams := null;
		realTi := null;
		if obj.isKindOf(CMIF_TempReading) then
			tempParams := obj.CMIF_TempReading;
			realTi := tempParams.myTrackedItem.pxyGetRealObject();
			if realTi = null then
				realTi := tempParams.myTrackedItem;
			endif;
		elseif obj.isKindOf(CMIF_HumidReading) then
			humidParams := obj.CMIF_HumidReading;
			realTi := humidParams.myTrackedItem.pxyGetRealObject();
			if realTi = null then
				realTi := humidParams.myTrackedItem;
			endif;
		elseif obj.isKindOf(CMIF_VentReading) then
			ventParams := obj.CMIF_VentReading;
			realTi := ventParams.myTrackedItem.pxyGetRealObject();
			if realTi = null then
				realTi := ventParams.myTrackedItem;
			endif;
		endif;
		if realTi &lt;&gt; null then
			iter := realTi.allYardActivities.createIterator;
			while iter.next(job) do
				if tempParams &lt;&gt; null and job.isReeferMonitor and job.actionTime &lt;= app.actualTimeServer then
					job.doAction();
				elseif realTi.isConnected and job.isReeferConnect and job.actionTime &lt;= app.actualTimeServer then
					job.doAction();
				elseif not realTi.isConnected and job.isReeferDisconnect and job.actionTime &lt;= app.actualTimeServer then
					job.doAction();
				endif;
			endwhile;
			delete iter;
		endif;
	endforeach;
	// TFS 50648 end
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;
	
epilog	
	delete agent;
	if _controller &lt;&gt; null then								// MTN-36569
		foreach pxyTI in _controller.allTransientTIs do
			app.myProxyManager.deleteProxyLink(pxyTI);
		endforeach;
	endif;
	delete iter;				// TFS 50648
	delete tempController;		// TFS 50648
	delete humidController;		// TFS 50648
	delete ventController;		// TFS 50648
	
	self.finaliseActivityWithPassport(_passport);
end;</source>
