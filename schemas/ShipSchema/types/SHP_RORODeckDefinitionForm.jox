    <JadeMethod name="addDeckItemTableItem" id="56dcca75-a468-4486-b265-83d60efcd611">
        <source>addDeckItemTableItem(_deckItem : CM_DeckItem) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	str : String;
begin
	str := _deckItem.getAttributeStringForDefArray(self.tblDeckItems.allTblDataEntRows);
	self.tblDeckItems.addItemObject(_deckItem, str);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_deckItem" type="CM_DeckItem"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="1cab0df4-1802-4547-8360-c05bb7571d16">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars

toolbar			: CMUI_Toolbar;
begin
	toolbar := self.frmToolbar;
	inheritMethod();

	toolbar.addFrame(self.frmToolbarCombos,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNewDeck, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNewSubDeck, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditDeck, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeleteDeck,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCopyDeck,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrintRoRo,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnROROConfig,CMUI_Toolbar.Control_Alignment_Left);
	
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	
	// ### ADD NEW BUTTONS TO enableControls
	toolbar := self.frmROROTB;
	toolbar.addButton(self.btnLayers, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMultiSelect, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRotate, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDrawRemarks, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShowText, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnDrawTBCross, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDrawAlignLeft, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDrawAlignTop, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDrawAlignRght, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDrawAlignBot, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnDrawSameH, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnDrawSameW, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnDrawSameHW, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTBScale, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTBMouseXY, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTBArea, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	
	// TOOL BAR BUTTONS FOR DECK ITEMS
	toolbar:=self.frmTBDeckItems;
	toolbar.addButton(self.btnNewDeckItem, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditDeckItem, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDelDeckItem, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrintDeckItem,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
