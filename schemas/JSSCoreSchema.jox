        <Parameter name="pErrorMessage" type="String" length="4096" usage="output"/>
        <Parameter name="pBufferLength" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </Function>
    <Function name="internetOpen" id="9aa69e5d-2b67-40ea-8e5c-17b2400c282a">
