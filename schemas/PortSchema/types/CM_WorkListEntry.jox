    <JadeMethod name="getLocationId" id="b7e88f88-a245-4beb-ac6d-f73b20525d85">
        <source>getLocationId():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2023 navhl20 Bug 60931: EUP - Delivery Dispatch Remedial [2]
25 Apr 2024 navhl20 ChangeRequest 63857: EUP - Bulk Load ship in retrospective mode
*/

vars
	ti : CM_TrackedItem;
	lc : CM_LocationsController;
begin
	ti := self.getTi();
	
	
	if ti &lt;&gt; null then
		if ti.terminalAreaId &lt;&gt; null then
			return ti.terminalAreaId;
		endif;
		
		lc := ti.myPrimaryActualLocation;
		
		if lc &lt;&gt; null then
			return lc.getFullId();
		endif;
		
		lc := ti.myPrimaryPlannedLocation;
		
		if lc &lt;&gt; null then
			return lc.getFullId();
		endif;
		
		lc := ti.myPrimaryQueuedLocation;
		
		if lc &lt;&gt; null then
			return lc.getFullId();
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationIdForMode" id="25be7fb5-f6e5-47ee-a518-4c3fc8b5f082">
        <source>getLocationIdForMode(_mode :Integer) : String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	location : CM_LocationsController;
	theIndex : String;
begin
	location:=getLocationForMode(_mode);
	if location = null then
		return null;
	endif;
	
	/*if location.myTerminalArea &lt;&gt; null and 
	   location.myTerminalArea.isHeightRequiredForLabel then
		theIndex := location.getIndexOfTiDisplay(REAL_MODE, self.myTrackedItem);//_mode
	endif;
	return location.getFullId() &amp; " " &amp; theIndex;*/
	
	return location.getFullIdForTIForMode(_mode);

epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocnsForAnyIdAnyAmount" id="63c22119-840b-40a7-b037-c22d1621577a">
        <source>getLocnsForAnyIdAnyAmount( locations : CM_LCArray input; cargoTypeStrings : StringArray512 input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2018	jlgndl1	Initial creation	TFS 39950

*/

vars

begin

	locations.clear();
	cargoTypeStrings.clear();

	if not self.isAnyAmount then
