<Class name="CM_ModelEventManager" id="1d2ad9e9-9810-4154-86e3-043cbd5deb38">
    <superclass name="CM_Agent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="allNoUserInfoNotes" id="1e9702e4-68a3-4148-807c-409d6bcf1826">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <type name="CM_NoInfoNoteEvtDict"/>
        <access>readonly</access>
        <Inverse name="CM_ModelEvent::myModelEventManager"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allSingleObjInfoNotes" id="431b1986-4d3d-4fdd-aa29-d9519fa9a740">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <type name="CM_SingleObjInfoNoteEvtDict"/>
        <access>readonly</access>
        <Inverse name="CM_ModelEvent::myModelEventManager"/>
    </ExplicitInverseRef>
    <PrimAttribute name="eventCreationEnabled" id="91725e98-1783-4ecc-8ce9-0c580b9fa1dd">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isMultiTransactionTrx" id="eb155f2e-8c3a-4f95-a09d-eb57f3ae68ca">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myApp" id="84af8ba3-bc42-4b30-acda-ce26f97baae4">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="PortSchema"/>
        <access>readonly</access>
        <Inverse name="PortSchema::myEventManager"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="0866de08-98f5-402a-8ae2-8e9bd02565d5">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.eventCreationEnabled := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="createNoUserInfoNoteEvt" id="347ebcf0-bf19-45e1-b577-77d7e68a9bde">
        <source>createNoUserInfoNoteEvt(target : CM_Object; eventNo : Integer) : CM_NoUserInfoNoteEvt;
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	evt : CM_NoUserInfoNoteEvt;
	
begin

	if not self.eventCreationEnabled then
		return null;
	endif;

	evt := self.allNoUserInfoNotes[target, eventNo];
	if evt &lt;&gt; null then
		// this event has already been raised
		return evt;
	endif;
	
	create evt transient;
	evt.updateForCreate(target, eventNo);
	self.allNoUserInfoNotes.add(evt);
	
	return evt;
end;</source>
        <Parameter name="target" type="CM_Object"/>
        <Parameter name="eventNo" type="Integer"/>
        <ReturnType type="CM_NoUserInfoNoteEvt"/>
    </JadeMethod>
    <JadeMethod name="createSingleObjInfoNoteEvt" id="f3512370-4404-42fc-aae8-94cbae4d2e34">
        <source>createSingleObjInfoNoteEvt(target : CM_Object; eventNo : Integer;
	userInfo : Object) : CM_SingleObjectUserInfoNoteEvt;
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	evt : CM_SingleObjectUserInfoNoteEvt;
	
begin

	if not self.eventCreationEnabled then
		return null;
	endif;

	evt := self.allSingleObjInfoNotes[target, eventNo, userInfo];
	if evt &lt;&gt; null then
		// this event has already been raised
		return evt;
	endif;
	
	create evt transient;
	evt.updateForCreate(target, eventNo, userInfo);
	self.allSingleObjInfoNotes.add(evt);
	return evt;
end;</source>
        <Parameter name="target" type="CM_Object"/>
        <Parameter name="eventNo" type="Integer"/>
        <Parameter name="userInfo" type="Object"/>
        <ReturnType type="CM_SingleObjectUserInfoNoteEvt"/>
    </JadeMethod>
    <JadeMethod name="dispatchAllEvents" id="25b618fd-f85a-4f47-b4e3-abad1f10fcb4">
        <updating/>
        <source>dispatchAllEvents() updating;
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	evt : CM_ModelEvent;
	isImmediate	: Boolean;
	
begin

	isImmediate := (process.isInTransactionState);

	foreach evt in self.allNoUserInfoNotes do
		evt.dispatch;
	endforeach;

	foreach evt in self.allSingleObjInfoNotes do
		app.myPassport.myActivityCapture.logDiagnostic('Event dispatched&gt;&gt; number=' &amp; evt.number.String &amp; ', object= ' &amp; evt.mySubject.String);
		evt.dispatch;
	endforeach;

	// Delete all events once they've been dispatched
	self.purgeAllEvents;
	// reset flag
	self.isMultiTransactionTrx := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="initialise" id="5cadb1c3-e973-48bf-9b4b-efeae52cc7d0">
        <updating/>
        <source>initialise() updating;
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.eventCreationEnabled := false;
	self.isMultiTransactionTrx := false;
	self.purgeAllEvents();
	
epilog
	self.eventCreationEnabled := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="purgeAllEvents" id="910315a4-80c6-4a28-8e74-98a0521697c5">
        <source>purgeAllEvents() protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.allNoUserInfoNotes.purge;
	self.allSingleObjInfoNotes.purge;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMultiTransactionTrx" id="b1154579-2e2d-41e4-a31d-a5ba35b0547f">
        <updating/>
        <source>setMultiTransactionTrx() updating;
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwsb1
//
// Purpose:		Called at the start of a Multi Transaction trx, after the call
//				to initialiseActivityWithPassport.
//				This is the type of transaction where we commitTransaction/
//				beginTransaction multiple times for efficiency and concurrency
//				reasons.  We want to dispatch event notifications after the final
//				commit/abort, as we delay all notifications until then.
//				They will be sent as immediate notifications.
// ---------------------------------------------------------------------------
begin
	self.isMultiTransactionTrx := true;
end;</source>
    </JadeMethod>
</Class>
