    <JadeMethod name="btnClose_click" id="6907b7af-579a-4c47-835c-22efe9cca060">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="0096d26f-e8f5-4969-a70e-d4b308252844">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	historyMasterObj	: CnEcReleaseHistoryMaster;
	
begin
	inheritMethod();
	
	historyMasterObj	:=	self.aMyHistoryMaster;
	self.initializeTable();
	
	if historyMasterObj = null then
		txtApplication.text		:=	null;
		txtRelease.text			:=	null;
		txtStart.text			:=	null;
		txtFinish.text			:=	null;
		txtUser.text			:=	null;
		txtComputer.text		:=	null;
		txtSuccessful.text		:=	null;
	else
		txtApplication.text		:=	historyMasterObj.processAppName;
		txtRelease.text			:=	historyMasterObj.currentReleaseNumber &amp; ' ' &amp; historyMasterObj.currentPatchNumber;
		txtStart.text			:=	historyMasterObj.processStartTime.String;
		txtFinish.text			:=	historyMasterObj.processFinishTime.String;
		txtUser.text			:=	historyMasterObj.processUser;
		txtComputer.text		:=	historyMasterObj.computerName;
		txtSuccessful.text		:=	historyMasterObj.isCompletedOK.cnEcGetYesNo();
		
		self.loadHistoryDetails(historyMasterObj);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initializeTable" id="77e7e619-763b-4437-abdd-cc7665e725e6">
        <updating/>
        <source>initializeTable() updating, protected;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Purpose:		Initialize the table control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: CnEcTable;
	
begin
	tableObj		:=	tblDetails;
	tableObj.rows	:=	1;
	tableObj.addColumnHeading(1, "Date/Time" &amp; Tab &amp; "Description");
	tableObj.initialize();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadHistoryDetails" id="64dbd68b-6767-4704-97e4-49ea9b26984b">
        <source>loadHistoryDetails(pHistoryMasterObj:CnEcReleaseHistoryMaster) protected;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Purpose:		Populate the table with release history details.
//
// Parameters:	pHistoryMasterObj - The master history object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	historyDetailObj	: CnEcReleaseHistoryDetail;
	tableObj			: CnEcTable;
	
begin
	tableObj	:=	tblDetails;
	
	foreach historyDetailObj in pHistoryMasterObj.allDetails do
		tableObj.addItem(historyDetailObj.itemTime.String &amp; Tab &amp; historyDetailObj.itemText);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pHistoryMasterObj" type="CnEcReleaseHistoryMaster"/>
    </JadeMethod>
    <JadeMethod name="resize" id="ccddb7cb-8cf1-45f2-bdc5-74889bb12379">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	tblDetails.move(tblDetails.left, tblDetails.top, (self.width - 27), (self.height - tblDetails.top - 67));
	btnClose.move((self.width - btnClose.width - 17), (self.height - btnClose.height - 36), btnClose.width, btnClose.height);
end;</source>
    </JadeMethod>
    <JadeMethod name="setHistoryMaster" id="96ec1909-de5f-449a-81df-057ddb9d5c29">
        <updating/>
        <source>setHistoryMaster(pHistoryMasterObj:CnEcReleaseHistoryMaster) updating;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Purpose:		Sets a reference to the master history object.
//
// Parameters:	pHistoryMasterObj - The master object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aMyHistoryMaster &lt;&gt; pHistoryMasterObj then
		self.aMyHistoryMaster	:=	pHistoryMasterObj;
	endif;
end;</source>
        <Parameter name="pHistoryMasterObj" type="CnEcReleaseHistoryMaster"/>
    </JadeMethod>
</GUIClass>
