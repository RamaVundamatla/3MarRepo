    <JadeMethod name="setIds" id="a2b6c5e1-1931-49cf-846b-83d86fd1ec25">
        <updating/>
        <source>setIds(pStringArray : StringArray) updating;
// ---------------------------------------------------------------------------
// Created:     16 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str : String;
begin
	exclusiveLock(self);
	if self.ids = null and pStringArray = null then
		return;
	endif;
	if self.ids = null then
		if self.isTransient then
			create self.ids transient;
		else
			create self.ids persistent;
		endif;
	endif;
	exclusiveLock(self.ids);
	self.ids.clear;
	if pStringArray = null then
		return;
	endif;
	foreach str in pStringArray do
		self.ids.add(str);
	endforeach;
end;</source>
        <Parameter name="pStringArray" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setIsoGroup" id="630e5696-0f13-44f6-831f-7145a0e376ca">
