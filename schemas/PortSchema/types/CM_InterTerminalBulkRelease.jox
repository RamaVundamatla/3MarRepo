    <JadeMethod name="setForCreateFromPxy" id="a7a2258f-837a-420d-9139-b2a43a762ce1">
        <updating/>
        <source>setForCreateFromPxy(_proxyBulkRelease: CM_InterTerminalBulkRelease; _newBookingRef: CM_BookingRef; _cmif_Booking :CMIF_BookingRef) updating;
/*
Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#			Description
============================================================================
05/02/2010	conkc1					Initial creation
25/08/2011	cnwdap1	PAR #27972 		set new converted attribute
12/02/2012	cnwcs5	par 28756 - 	changed parameter usage from input to constant for _proxyBulkRelease
									new parameter _cmifBooking :CMIF_BookingRef (for consistency with superclass method)
24/01/2019	jlgka1	41708			STWo - CCRO Management. Add myBOLIn.
============================================================================*/

begin
	self.code                  := _proxyBulkRelease.code;
	self.consigneeDesc         := _proxyBulkRelease.consigneeDesc;
	self.consigneeCode         := _proxyBulkRelease.consigneeCode;
	self.dateRequested         := _proxyBulkRelease.dateRequested;
	self.type                  := _proxyBulkRelease.type;
	self.status                := BR_ACTIVE;
	self.consignorVoyageCode   := _proxyBulkRelease.consignorVoyageCode;
	self.myVoyage              := _proxyBulkRelease.myVoyage;
	self.mySubTerminal         := _proxyBulkRelease.mySubTerminal;
	self.deliveryReasonCode    := _proxyBulkRelease.deliveryReasonCode;
	self.deliveryReasonDescr   := _proxyBulkRelease.deliveryReasonDescr;
	self.myBOLIn			   := _proxyBulkRelease.myBOLIn;		//jlgka1 TFS 41708
	self.converted			   := _proxyBulkRelease.converted;		// PAR #27972
	//
	// Note we do not set the Terminal yet as we will get a duplicate on CM_InterTerminalConfig :: validateForCreate
	//
	
epilog

end;</source>
        <Parameter name="_proxyBulkRelease" type="CM_InterTerminalBulkRelease"/>
        <Parameter name="_newBookingRef" type="CM_BookingRef"/>
        <Parameter name="_cmif_Booking" type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setProxyForITBR" id="2f576f5c-0c53-4083-86ea-adb53d1a503f">
        <updating/>
        <source>setProxyForITBR(_releaseNumber: String;  _consignee : CM_ConsigneeConsignor; _consignorVoyageCode: String; 
				_deliveryReasonCode: Integer; _deliveryReasonDescr: String; _terminal: CM_Terminal;
				_operator: CM_Operator;  _voyage: CM_Voyage; _subTerminal: CM_SubTerminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05/02/2010	conkc1	Initial creation
25/08/2011	cnwdap1	PAR #27972 set converted fag
*/
vars
	timeStamp    : TimeStamp;
	date         : Date;
	time         : Time;
begin
	date.setDate(01, 01, 2090);
	time.setTime(23,59,59,0);
	timeStamp.setDate(date);
	timeStamp.setTime(time);
	self.code                   := _releaseNumber;
	self.status                 := BR_ACTIVE;
	self.type                   := BR_TYPE_ROAD;
	self.consigneeDesc			:= _consignee.description;
	self.consigneeCode			:= _consignee.code;
	self.consignorVoyageCode 	:= _consignorVoyageCode;
	self.myVoyage               := _voyage;
	self.dateRequested 			:= timeStamp;
	self.deliveryReasonCode		:= _deliveryReasonCode;
	self.deliveryReasonDescr	:= _deliveryReasonDescr.trimBlanks();
	self.mySubTerminal          := _subTerminal;
	self.myTerminal             := _terminal;
	
	self.converted				:= true;		// PAR #27972

epilog

end;</source>
        <Parameter name="_releaseNumber" type="String"/>
        <Parameter name="_consignee" type="CM_ConsigneeConsignor"/>
        <Parameter name="_consignorVoyageCode" type="String"/>
        <Parameter name="_deliveryReasonCode" type="Integer"/>
        <Parameter name="_deliveryReasonDescr" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_subTerminal" type="CM_SubTerminal"/>
    </JadeMethod>
