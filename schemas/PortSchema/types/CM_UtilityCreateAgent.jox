    <JadeMethod name="utlCreateAnyIDDirectorTask" id="f5f8c9a5-1051-49bc-8450-abfb14f13174">
        <source>utlCreateAnyIDDirectorTask( _origWle : CM_WorkListEntry; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2014	cnwndl1	Initial creation	Par 34675

*/

vars

	request : CM_Request;
	source : CM_LocationsController;
	newWle : CM_YardWLE;
	job : CM_Job;
	arbiter	: CM_RTQueueArbiter;

begin

	if _origWle &lt;&gt; null then
		request := _origWle.myRequest;
	endif;
	
	if request &lt;&gt; null then
		source := request.getFirstLocationForAnyId();
		job := request.myJob;
	endif;
	
	if source = null or job = null or job.isCompleteForExit then
		return;
	endif;
	
	create newWle persistent;
	newWle.setForCreate( job, request);
	
	
	create arbiter;
	arbiter.job := job;
	newWle.enqueueWLE( arbiter );
	
	if not _passport.noErrors then
		return;
	endif;
	
	job.rebuildStatus();
	
epilog

	if arbiter &lt;&gt; null then
		arbiter.erase(0);
	endif;

end;</source>
        <Parameter name="_origWle" type="CM_WorkListEntry"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
