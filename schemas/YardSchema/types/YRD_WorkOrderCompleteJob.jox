    <JadeMethod name="txtSelectCount_lostFocus" id="524b2483-228b-4dba-b2bb-ee57027b48a7">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtSelectCount_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group

*/

vars
	keyCode,
	idx,
	count,selectedCount		: Integer;
	ti			:CM_TrackedItem;
	row :JadeTableRow;
begin
	count := textbox.text.Integer;
	self.tblAvailCargo.clearAllSelected();
	if count &lt;&gt; null then
		if self.isCargoGrouping then	//22.07.2024 navbs1 #64884
		idx:=2;
		while idx &lt;= self.tblAvailCargo.rows do
			if selectedCount = count then 
			break;
			endif;
			 row :=self.tblAvailCargo.accessRow(idx);
			 ti:= row.itemObject.CM_TrackedItem;
			 if ti = null or ti.isCargoGroupItem then 
				self.doExpandAndCollapse(self.Expand,idx);
				idx:= idx+1;
			 continue;
			 else
			self.tblAvailCargo.selectRow(idx,false);
			selectedCount:=selectedCount+1;
			endif;
			idx:= idx+1;
		endwhile;
		else
			foreach idx in 2 to count + 1 do
				self.tblAvailCargo.selectRow(idx,false);
			endforeach;
			endif;
	else
		self.tblAvailCargo.deselectAll();
	endif;
	
	self.tblAvailCargo_keyUp(self.tblAvailCargo,keyCode,null);
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
