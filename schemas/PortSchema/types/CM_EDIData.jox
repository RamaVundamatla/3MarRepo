    <JadeMethod name="setStatus" id="d4abeb5a-c212-4dc6-bfa7-c5ed6948e137">
        <updating/>
        <source>setStatus(_newStatus: Integer) updating;
//----------------------------------------------------------------
//	Created:	11 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 17 Apr 2012	cnwrs1	Par 29182
// 31/05/2012	cnwcs5	CCMS SFW 1284 - EDI BGP Split. Always use this  method to update status
// 05 Sep 2014	cnwrs1	par 34849 dont set non processed EDIdata to lock error
//6/3/2025 navsaa30 TFS 20518 MTN - Notify user when a background DB Load has completed
//11/3/25 navsaa30 TFS-34317 MTN - When loading an EDI file via the api it is putting a dialog saying 'You have a new message!' unexpectedly popping up
//14 May 2025 naviv1    MTN-19104 - MTN - Transport Manifest Handling of locking in EDI Operations
vars
	ediFile : CM_EDIFile;
	beforeAudit, afterAudit : String;
	auditAgent : CM_AuditAgent;
	audit : CM_AuditObject;
	proc : Process;
	userNames, msg : String;
	ts : TimeStamp;
	ediAgent : CM_EDIControllerAgent;
begin
	if self.status &lt;&gt; _newStatus then
		if _newStatus = CM_EDIFile.EDI_STATUS_DBLOADED or _newStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
			self.processDateTime := app.actualTimeServer(); //17 Apr 2012  cnwrs1  Par 29182
		endif;
		if _newStatus = CM_EDIFile.EDI_STATUS_LOCKERROR and not self.status.isOneOf(CM_EDIFile.EDI_STATUS_VERIFYING,CM_EDIFile.EDI_STATUS_DBLOADING) then  //MTN-19104 -- if the file status is verifying / db loading, unable to set the lock error status when the system lock happens. So, skipping this check if the edi file status is verifying / db loading 
			if not self.canBeReprocessedByBGP and
				not self.canBeDBLoaded then
				return;
			endif;
		endif;
		if _newStatus = CM_EDIFile.EDI_STATUS_QUEUED_FOR_BGP and not (app.isBackGroundApp or app.isWebApp) and
			self.ediConfig.myTerminal.getConfig(RecNoteWhenBGPEDIDone).Boolean then		//6/3/25 navsaa30 #20518 //11/3/2025 navsaa30 #34317
			beforeAudit := self.getAuditText();
		endif;
		self.status := _newStatus;
 
		ediFile := self.myEDIFile;
 
		if ediFile &lt;&gt; null then 
			ediFile.fileStatus := _newStatus;
		endif;
 
		if beforeAudit &lt;&gt; null then
			afterAudit := self.getAuditText();
			create auditAgent transient;
			auditAgent.initialiseAudit();
			auditAgent.auditUpdateTrx(self, beforeAudit, afterAudit);
			app.writeLog('audit created ' &amp; beforeAudit &amp; ' ' &amp; afterAudit ,LogDEBUG);
		endif;
 
		if app.isBackGroundApp and _newStatus.isOneOf(CM_EDIFile.EDI_STATUS_DBLOADED, CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X)
			and self.ediConfig.myTerminal.getConfig(RecNoteWhenBGPEDIDone).Boolean  then			//11/3/25  navsaa30 #34317
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Attempting to send a message for a BGP processed EDI file", LogDEBUG);
			// get last audit
			audit := self.allAuditObjects.last;
			if audit &lt;&gt; null then
				app.writeLog(method.qualifiedName &amp; Tab &amp; "Looking for a audit record to retrieve the user code who queued the EDI file", LogDEBUG);
				foreach proc in Process.instances where proc.persistentApp.name = JMTerminal and proc.userCode = audit.userCode do
					userNames := userNames &amp; '&amp;&amp;' &amp; audit.userCode;
					app.writeLog(method.qualifiedName &amp; Tab &amp; "Found an audit record created by " &amp; audit.userCode, LogDEBUG);
					break;
				endforeach;
				if userNames &lt;&gt; null then
					userNames := userNames &amp; '&amp;&amp;' &amp; '%^%';
					create ediAgent transient;
					msg := "The EDI file " &amp; self.fileName &amp; " queued for processing by you has completed with status " &amp; ediAgent.displayStatus(_newStatus);
					app.writeLog(method.qualifiedName &amp; Tab &amp; "Sending a message to " &amp; userNames &amp; ": " &amp; msg, LogDEBUG);
					msg := userNames &amp; app.getErrorString2(Send_MessageSentBy, process.userCode, ts.String) &amp; msg;
					system.causeEvent(Event_SendMessage, true, msg);
				endif;
			endif;
		endif;								//6/3/2025 navsaa30 #20518
	endif;
epilog
	delete auditAgent;
	delete ediAgent;
end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setStringValue" id="b5416ab7-d509-46b3-9221-8f9475aeb2c5">
        <updating/>
        <source>setStringValue(_propName, _value : String) protected, updating;
//----------------------------------------------------------------
//	Created:	cnwrs1 CCMS 1976 1 dec 2010
//----------------------------------------------------------------
// 14 Dec 2010  cnwrs1      ccms 1976 - need to keep XML and CSV EDI Files types working the same so this method 
//                          is in CM_EDIFieldMapping and in CM_EDITrackedItem they both must be kept in step in 782 the CM_EDIFieldMapping method will be removed in 791	
vars
	origValue				: String;
	lenRemaining			: Integer;
	prop					: Attribute;
begin
	prop := self.class.getPropertyInHTree(_propName).Attribute;
	if prop  = null then
		return;
	endif;
	
	if prop.length &gt; 0 then//if it's a max length string the length integer value here will be -1
		//N.B the length integer value of a string attribute is always 1 more than what you see
		//in the IDE - hence the subtraction of 1 below
		self.setPropertyValue(_propName, _value[1:prop.length - 1]);
	else//it's max length
		self.setPropertyValue(_propName, _value);
	endif;
end;


</source>
        <access>protected</access>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTerminal" id="a4a718d3-3313-40a8-8344-bfc3d72b3fa7">
        <updating/>
        <source>setTerminal(_terminalCode : String) updating;
//
// cmms 2049 cnwrs1 7 Apr 2011
//
vars
	newTerminal : CM_Terminal;
	ediFile : CM_EDIFile;
begin
	newTerminal := app.myRoot.allTerminals[_terminalCode];
	if newTerminal = null then
		return;
	endif;
	if newTerminal = self.ediConfig.myTerminal then
		return;
	endif;
	self.setEDIConfig(newTerminal.myEdiConfig);
	foreach ediFile in self.ediFileArray do
		ediFile.setEDIConfig(newTerminal.myEdiConfig);
	endforeach;
end;
</source>
        <Parameter name="_terminalCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setType" id="3f6dfca8-3d2a-4103-b3aa-1aae2aef6411">
        <updating/>
        <source>setType() updating;
//----------------------------------------------------------------
//	Created:	24 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
// 08 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
vars

begin
	//can be removed after everyone is on JMT7 722c or higher - maybe not
	// wait for NP
	
	if CM_EDIDataCustomStop.hasInstance(self) then
		self.ediDataType := EDIDataType_CustomStop;				//01
	elseif CM_EDIDataOpCarrierAcessByCT.hasInstance(self) then
		self.ediDataType := EDIDataType_OpCarrierAcessByCT;		//75
	elseif CM_EDIDataOperatorStop.hasInstance(self) then
		self.ediDataType := EDIDataType_OperatorStop;			//02
	elseif CM_EDIDataBayPlan.hasInstance(self) then
		self.ediDataType := EDIDataType_BayPlan;				//03
	elseif CM_EDIDataBookingRef.hasInstance(self) then
		self.ediDataType := EDIDataType_BookingSingleLine;		//04
	elseif CM_EDIDataLoadList.hasInstance(self) then
		self.ediDataType := EDIDataType_LoadList;				//05
	elseif CM_EDIDataPrenote.hasInstance(self) then
		self.ediDataType := EDIDataType_Prenote;				//06
	elseif CM_EDIDataStowAdvice.hasInstance(self) then
		self.ediDataType := EDIDataType_StowAdvice;				//07
	elseif CM_EDIDataOutwardRail.hasInstance(self) then
		self.ediDataType := EDIDataType_OutwardRail;			//08
	elseif CM_EDIDataBOLOutLog.hasInstance(self) then
		self.ediDataType := EDIDataType_BOLOutLog;				//09
	elseif CM_EDIDataGenCSV.hasInstance(self) then
		self.ediDataType := EDIDataType_CSV;					//10
	elseif CM_EDIDataPack.hasInstance(self) then							//ccms 1976 01 Dec 2010 cnwrs1
		self.ediDataType := EDIDataType_Pack;					//43
	//Nelson Anca 10/04/2008
	elseif CM_EDIDataProduct.hasInstance(self) then				//17
		self.ediDataType := EDIDataType_Product;
	// cnwrl1 28/08/2009 PAR 20320 - MES 1011 New Messina Messages - start of coding
	elseif CM_EDIDataReleaseRequest.hasInstance(self) then
		self.ediDataType := EDIDataType_ReleaseRequest;			//22
	elseif CM_EDIDataRequestMultiLine.hasInstance(self) then
		self.ediDataType := EDIDataType_RequestMultiLine;		//60
	// cnwrl1 28/08/2009 PAR 20320 - MES 1011 New Messina Messages - end of coding
	//cnwrs1 Messina CCMS 1008 par 20320 sept 2009
	elseif CM_EDIDataBOL.hasInstance(self) then 
		self.ediDataType := EDIDataType_BOL;					//28
	elseif CM_EDIDataStop.hasInstance(self) then
		self.ediDataType := EDIDataType_Stop;					//29
	elseif CM_EDIDataTrain.hasInstance(self) then
		self.ediDataType := EDIDataType_Train;					//26
	elseif CM_EDIDataVGM.hasInstance(self) then
		self.ediDataType := EDIDataType_VGM;					//65
	elseif CM_EDIDataVoyage.hasInstance(self) then
		self.ediDataType := EDIDataType_Voyage;					//25
	elseif CM_EDIDataWagon.hasInstance(self) then
		self.ediDataType := EDIDataType_Wagon;					//27
	elseif CM_EDIDataTrainConsist.hasInstance(self) then
		self.ediDataType := EDIDataType_TrainConsist;			//23
	elseif CM_EDIDataShipManifest.hasInstance(self) then
		self.ediDataType := EDIDataType_ShipManifest;			//24
	elseif CM_EDIDataDeckPlan.hasInstance(self) then
		self.ediDataType := EDIDataType_DeckPlan;				//46
	elseif CM_EDIDataBooking.hasInstance(self) then 						//par21718 nwrs1 nov 2009
		self.ediDataType := EDIDataType_BookingMultiLine;		//14
// cnwdad1 11/12/2009 - PAR 21946.
	elseif CM_EDIDataCargoFieldUpdate.hasInstance(self) then
		self.ediDataType := EDIDataType_CargoFieldUpdate;		//32
	elseif CM_EDIDataToDoTask.hasInstance(self) then 						//cnwgb1 PAR 22022 18.2.2010
		self.ediDataType := EDIDataType_ToDoTask;				//39
	elseif CM_EDIDataConsignoree.hasInstance(self) then						// cnwrl1 22/02/2010 PAR 21735
		self.ediDataType := EDIDataType_Consignoree;			//41		// cnwrl1 22/02/2010 PAR 21735
	else
		self.ediDataType := EDIDataType_Unknown;
	endif;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setXlationOperator" id="709f8fb7-4850-471f-bae6-f29c9925a831">
        <updating/>
        <source>setXlationOperator(_xlateOperator : CM_Operator)updating;
//25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
//18 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
vars

begin
	if _xlateOperator &lt;&gt; null then
		//global.setExtraData(self.allExtraData, self, ETRow_XlateOperatorCode, _xlateOperator.code);	//18.11.2022 navma1 #55424
