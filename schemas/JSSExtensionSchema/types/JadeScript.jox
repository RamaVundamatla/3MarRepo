    <JadeMethod name="cnwdad1_Test_HttpGetBinary" id="0e6727f9-bbdc-45df-ab51-1a4abda99c69">
        <source>cnwdad1_Test_HttpGetBinary();
// --------------------------------------------------------------------------------
// Created:		17 March 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startTime		: Integer;
	requestResponse	: String;
	binaryData		: Binary;
	theDataFile		: File;
	
begin
	startTime		:=	app.clock();
	create app.myCnKarmaCntrl transient;
	requestResponse	:=	global.jssGetHttpBinary("http://cnwdad1a/Darrell/images/h_shbridge.gif", false, false, binaryData);

	if requestResponse = null then
		create theDataFile transient;
		theDataFile.fileName	:=	"c:\temp\webfile.dat";
		theDataFile.kind		:=	File.Kind_Binary;
		theDataFile.writeBinary(binaryData);
		write "Success!";
	else
		write requestResponse;
	endif;
epilog
	delete theDataFile;
	delete app.myCnKarmaCntrl;
	write "Done in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
