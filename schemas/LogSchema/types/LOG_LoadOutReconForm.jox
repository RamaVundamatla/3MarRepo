    <JadeMethod name="addTblBOLExtRow" id="a92eface-5f25-44af-a019-1d16e2cc9639">
        <source>addTblBOLExtRow(_bolExt : CM_BOLExtLogOut);
// ---------------------------------------------------------------------------
// Created:     26 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	pieceCnt,
	idx				: Integer;
	bolOut			: CM_BOLOut;
	partialLoadout	: String;
	opCode			: String;
begin
	bolOut := _bolExt.myBOL.CM_BOLOut;
	
	if bolOut.myOperator &lt;&gt; null then
		opCode := bolOut.myOperator.code;
	else
		opCode := 'No Operator';
	endif;
	
	partialLoadout := bolOut.partialLoadout.cnEcGetTableCheckBoxValue;
	
	pieceCnt := bolOut.numTIs + _bolExt.getNumberNotFoundErrors();

	idx := tblBOLExt.addItem(bolOut.number &amp; Tab &amp;
							_bolExt.myLogLot.lotNo &amp; Tab &amp;
							_bolExt.hatch.String &amp; Tab &amp;
							app.vesselPlaceEnumToStr(_bolExt.place) &amp; Tab &amp;
							 opCode &amp; Tab &amp;
							_bolExt.getProductCode() &amp; Tab &amp;
							 pieceCnt.String &amp; Tab &amp;
							_bolExt.allNoNumberLogs.size.String &amp; Tab &amp;
							_bolExt.isPartiallyLoaded.cnEcGetTableCheckBoxValue &amp; Tab &amp;
							_bolExt.isFullyLoaded.cnEcGetTableCheckBoxValue);
							
	tblBOLExt.accessRow(idx).itemObject := _bolExt;
	
	if _bolExt = self.myCurrentBOLExt then
		tblBOLExt.accessedRow.selected := true;
	endif;
	
end;</source>
        <Parameter name="_bolExt" type="CM_BOLExtLogOut"/>
    </JadeMethod>
    <JadeMethod name="addTblLogErrorRow" id="84e1f358-c938-40b4-9947-83ecc1fe2fc5">
        <source>addTblLogErrorRow(_error : CM_LogLoadError; _checked : String);
// ---------------------------------------------------------------------------
// Created:     26 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	invalidObject	: Boolean;
	idx				: Integer;
	opCode			: String;
	log				: CM_Log;
	bolOutExt 		: CM_BOLExtLogOut;
	allErrorMsg		: String;
begin
	on Exception do app.handleDeletedObject(exception, log, invalidObject);
	log := _error.myLog;
	bolOutExt := _error.myBOLExtLogOut;
	
	foreach idx in 1 to _error.allErrorMsgs.size do
		allErrorMsg := allErrorMsg &amp; ' (' &amp; idx.String &amp; ')' &amp; _error.allErrorMsgs[idx];
	endforeach;
	
	if log &lt;&gt; null then
		opCode := log.myOperator.code;
		// from 28082 testing Sep 2011
		if invalidObject then
			log := null;
		endif;
	endif;

	if log &lt;&gt; null then
		idx := tblLogError.addItem(_checked &amp; Tab &amp; 
									log.id &amp; Tab &amp;
									opCode &amp; Tab &amp; 
									log.myProduct.code &amp; Tab &amp;
									allErrorMsg);
	//might be good to  color code SOME of the rows depending on certain errors?
	else
		//this is temp - need to find out what to put here if myLog = null
		idx := tblLogError.addItem(_checked &amp; Tab &amp;
						 		   _error.id &amp; Tab &amp; //because the error id should be the log it is looking for 
								   bolOutExt.myBOL.myOperator.code &amp; Tab &amp; 
								   bolOutExt.getProductCode() &amp; Tab &amp;
								   allErrorMsg);
		
	endif;
	
	tblLogError.accessRow(idx).itemObject := _error;
	
end;</source>
        <Parameter name="_error" type="CM_LogLoadError"/>
        <Parameter name="_checked" type="String"/>
    </JadeMethod>
