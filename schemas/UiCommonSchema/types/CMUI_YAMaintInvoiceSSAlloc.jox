    <JadeMethod name="populateCriteria" id="7e7086e4-3fbf-4e6e-8c49-043360e5e653">
        <updating/>
        <source>populateCriteria() updating;
/*
Purpose:			
Date		Who		Reason
04 Feb 2019	NDL	TFS 43153
*/

vars

	opCriteria: CM_YACriteriaArray;
	criteria, proxyCriteria: CM_YACriteria;
	obj : Object;
	oa : ObjectArray;
	criteriaType: CM_YACriteriaType;
	itemCode : String;
	nullValue : String;
	
begin
	self.allOperationalCriteria.purge();
	self.allTemplateCriteria.purge();

	create opCriteria transient;	

	if self.mySSBroker &lt;&gt; null then
		create oa transient;
		self.mySSBroker.getYACriteriaTypes(self.mySSBroker.allYACriteriaTypes, oa);
		foreach obj in oa do
			criteriaType := obj.CM_YACriteriaType;
			create proxyCriteria transient;
			itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length - 1);
			nullValue := "";
			if criteriaType.isBooleanType() then
				nullValue := CM_YADataBoolean.VALUE_FALSE.String;
			endif;
			proxyCriteria.setProxy(criteriaType, nullValue, itemCode);
			
			if self.myYardAllocation &lt;&gt; null then
				criteria := self.myYardAllocation.allCriteriaByType.getAtKey( criteriaType.type );
				if criteria &lt;&gt; null then
					proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
				endif;
			endif;

			self.allOperationalCriteria.add( proxyCriteria.getTransient() );
		endforeach;
		
	endif;
				
	self.populateCriteriaFrames(true);
	
epilog

	delete opCriteria;
	delete oa;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateForm" id="ed27a81d-f441-4063-b86b-cf68f35931d7">
        <updating/>
        <source>populateForm() updating;
/*
Purpose:			
Date		Who		Reason
04 Feb 2019	NDL	TFS 43153
*/

vars

	realAlloc : CM_InvoiceAllocation;
	realQM : CM_QuantityMap;

begin
	populateCriteria();
	
	self.txtDescription.text		:= self.myProxyYA.description;
	
	realAlloc := self.myYardAllocation.CM_InvoiceAllocation;
	if realAlloc &lt;&gt; null then		
		realQM := realAlloc.myQuantityMap;
		if realQM &lt;&gt; null and realQM.mySnapShotQuantityType &lt;&gt; null then
			self.cmbQuantityType.listIndex := self.cmbQuantityType.findStringExact( 1, realQM.mySnapShotQuantityType.heading );
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resizeForVoyage" id="095168ee-f236-40fe-a084-2da30397bf96">
        <updating/>
        <source>resizeForVoyage() updating;
/*
Date		Who		Reason
04 Feb 2019	NDL	TFS 43153

*/
vars

	maxIndex : Integer;
	criteriaFrame		: CMUI_YACriteriaCntl;
	index				: Integer;
	topOfLastControl 	: Real;
	topOfNextControl 	: Real;
begin


	self.minimumWidth := 420; // PAR 35325
	self.minimumHeight := 450;

	self.lblDescription.top := self.shtCriteria.clientHeight - 110;
	self.txtDescription.top := self.lblDescription.top;
	self.lblDescription.left := 10;
	self.txtDescription.left := 137;
	self.lblDescription.parentAspect := Label.ParentAspect_AnchorBottom;
	self.txtDescription.parentAspect := TextBox.ParentAspect_AnchorBottom;
	
	//13 Feb 2019	NDL	TFS 43153
	self.lblQuantityType.top := self.lblDescription.top + 30;
	self.lblQuantityType.left := self.lblDescription.left;
	self.lblQuantityType.width := self.shtCriteria.clientHeight;
	self.cmbQuantityType.top := self.lblQuantityType.top + 20;
	self.cmbQuantityType.left := self.lblQuantityType.left;
	self.cmbQuantityType.width := self.txtDescription.width + self.txtDescription.left - 10;
	self.lblQuantityType.parentAspect := Label.ParentAspect_AnchorBottom;
	self.cmbQuantityType.parentAspect := ComboBox.ParentAspect_AnchorBottom;
	
	self.lblYAColour.top := self.shtCriteria.clientHeight - 30;
	self.clrYAColour.top := self.lblYAColour.top;
	self.lblYAColour.left := 20;
	self.clrYAColour.left := 157;
	self.clrYAColour.width := 40;
	
	self.picCriteria.height := 200;
	self.picCriteria.top := 10;
//	self.picCriteria.backColor := Red;
//	self.picCriteria.transparent := false;
	
	self.lblYAColour.parentAspect := Label.ParentAspect_AnchorBottom;
	self.clrYAColour.parentAspect := TextBox.ParentAspect_AnchorBottom;
	self.picCriteria.parentAspect := Picture.ParentAspect_StretchBoth;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="saveData" id="89e60e5a-70cf-4516-9aa4-7cdfda2a7e2b">
        <updating/>
        <source>saveData(_saveAs: Boolean): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Feb 2019	NDL	TFS 43153

*/
vars

	proxyYAObj : CM_InvoiceAllocation;
	cmif_object : CMIF_Object;
	cmif_criteria : CMIF_YACriteriaPriority;
	pxyCriteria : CM_YACriteria;
	allTransientCriteriaObj	: CMIF_Array;
	result : Integer;
	realAlloc : CM_InvoiceAllocation;
	yas : ObjectArray;
	proxyQM : CM_QuantityMap;
	bu : CM_Bank;
	invLineType : CM_InvoiceLineDesc;
	lineTypes : CM_InvoiceLineDescSet;
	proxyQRM : CM_QuantityRangeMap;
	load : Boolean;
	realQM : CM_QuantityMap;
	realQMR : CM_QuantityRangeMap;
	
begin

	if self.mySSBroker = null then
		return false;
	endif;
	
	if self.updateMode then
		realAlloc := self.myYardAllocation.CM_InvoiceAllocation;
		if self.myYardAllocation = null then
			return false;
		endif;
		realQM := realAlloc.myQuantityMap;
		realQMR := realQM.allQuantityRanges.first;
	endif;
	
	//27 Oct 2017	NDL	TFS 7477
	if _saveAs and self.txtDescription.text = self.myProxyYA.code then
		self.txtDescription.text := null;
	endif;
	
	//09 Jan 2016	NDL	TFS 3174
	if self.txtDescription.text.trimBlanks = null then
		self.formatDescription();
	endif;
	
	bu := self.mySSBroker.getBank();
	
	proxyYAObj := self.myProxyYA.CM_InvoiceAllocation;
	proxyYAObj.setServiceBroker( self.mySSBroker );
	
	create allTransientCriteriaObj transient;
	if _saveAs then	//27 Oct 2017	NDL	TFS 7477
		self.getSaveAsCriteria( allTransientCriteriaObj );
	else
		self.getCriteriaAllCMIF( allTransientCriteriaObj );
	endif;
	
	proxyYAObj.setProxy(self.txtDescription.text,self.txtDescription.text,
								null,
								YAFillOption_InOrder,
								YAFillOption_InOrder,
								YAExpiryType_Never,
								null,
								null,
								
								null, 
								YAOverlap_Never,
								YANoLocation_Continue,
								null,
								0, 
								false,
								false,
								null,
								null,
								true,
								self.myTerminal);

	create lineTypes transient;
	if not self.updateMode or _saveAs then
		create proxyQM transient;
		proxyQM.setProxy( self.mySSBroker, false, CM_QuantityMap.MapType_Single, null, null );
		proxyQM.setAllocationDetails( proxyYAObj, self.cmbQuantityType.listObject.CM_XTABField );	//13 Feb 2019	NDL	TFS 43153
		
		invLineType := bu.getVoidInvoiceLineType();
		lineTypes.add( invLineType );
	
		create proxyQRM transient;
		proxyQRM.setProxy( proxyQM, 1, 99999999, 0);
		proxyQRM.setProxyInvoiceLineTypes( lineTypes, bu.getInvLineGroupByType(TranMapInvLineGroupTypeAll) );
	
	else
		app.cmsBeginLoad(load);
		proxyQM := realQM.pxyCreateUpdateProxy();
		app.cmsEndLoad(load);
		proxyQM.setProxy( self.mySSBroker, realQM.chargeZero, realQM.mappingType, null, null );
		proxyQM.setAllocationDetails( proxyYAObj, self.cmbQuantityType.listObject.CM_XTABField );
		
		app.cmsBeginLoad(load);
		proxyQRM := realQMR.pxyCreateUpdateProxy();
		app.cmsEndLoad(load);
		proxyQRM.setProxy( proxyQM, realQMR.rangeStart.Integer, realQMR.rangeEnd.Integer, realQMR.rangeType );
		
	endif;

	while true do
		if _saveAs then
			self.myYardAllocation := null;
			realAlloc := null;
			app.myTrxUA.trxUpdateInvoiceAllocation( proxyYAObj, allTransientCriteriaObj, not self.updateMode, realAlloc, app.myPassport );
			if realAlloc &lt;&gt; null then
				delete self.myProxyYA;
				create yas transient;
				yas.add( realAlloc );
				self.setYardAllocation( yas );
			endif;
		else
			app.myTrxUA.trxUpdateInvoiceAllocation( proxyYAObj, allTransientCriteriaObj, not self.updateMode, realAlloc, app.myPassport );
		endif;
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			if not self.updateMode or _saveAs then
				app.myEventManager.createSingleObjInfoNoteEvt( self.mySSBroker, app.myPassport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_CREATE), realAlloc );
			else
				app.myEventManager.createSingleObjInfoNoteEvt( self.mySSBroker, app.myPassport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE), realAlloc );
			endif;
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Invoice_cargo_allocation), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return false;
	endwhile;	
	
	return true and not _saveAs;	//27 Oct 2017	NDL	TFS 7477
	
epilog

	if allTransientCriteriaObj &lt;&gt; null then
		allTransientCriteriaObj.purge;
	endif;
	delete allTransientCriteriaObj;	
	delete yas;
	delete proxyQRM;
	delete proxyQM;
	delete lineTypes;

end;</source>
        <Parameter name="_saveAs" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCriteriaResizeScrollBar" id="df2b9cd1-1974-47c5-b21b-4950ef6d5026">
        <updating/>
        <source>setCriteriaResizeScrollBar() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/11/2023	navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues

*/

vars
	max			: Integer;
	numOfCrit	: Integer;
	oa			: ObjectArray;
begin

	create oa transient;
	
	self.mySSBroker.getYACriteriaTypes(self.mySSBroker.allYACriteriaTypes, oa);
	
	numOfCrit := oa.size();
	max := (numOfCrit * (self.frmCriteria.height)).Integer;
	if self.picCriteria.height &lt; max then
		self.picCriteria.scrollBars := Picture.ScrollBar_Vertical;
		self.picCriteria.setScrollRange(ScrollBar_Vertical, 0, max, 20, 100);
	else
		self.picCriteria.scrollBars := 0;
	endif;
epilog
	delete oa;
end;</source>
    </JadeMethod>
    <JadeMethod name="setYardAllocation" id="6934dc72-1b6c-430e-b3d4-68fe140c0470">
        <updating/>
        <source>setYardAllocation(_yas: ObjectArray) updating;

/* PAR 35833
Purpose:			
Date				Who			Reason
04 Feb 2019	NDL	TFS 43153
*/

vars
	ya, proxyObj		: CM_InvoiceAllocation;
	blockGroupObj	: CM_YABlockGroup;
	isLoadSet		: Boolean;
	criteria		: CM_YACriteria;
	imex			: CM_YACriteria;
	proxyCriteria	: CM_YACriteria;
	imexStatus		: CM_IMEXStatus;
	yaIMEXConfig	: CM_YAIMEXConfig;
	criteriaType: CM_YACriteriaType;
	opCriteria: CM_YACriteriaArray;
begin
	self.doClearCurrentYA();
	
	
	if _yas = null then
		create proxyObj transient;
		create blockGroupObj transient;
		proxyObj.allYABlockGroupsIn.add(blockGroupObj);
		proxyObj.allYABlockGroupsOut.add(blockGroupObj);
		self.myProxyYA	:=	proxyObj;
		self.myProxyYA.setTerminal(self.myTerminal);
		self.updateMode := false;
	elseif _yas.size = 1 then
		ya := _yas.first.CM_InvoiceAllocation;
		proxyObj	:=	app.createUpdateProxy(ya).CM_InvoiceAllocation;
		self.isTemplateModified := ya.isTemplateModified;
		self.myProxyYA			:=	proxyObj;
		self.myYardAllocation	:=	ya;
		self.updateMode := true;
	else
		_yas.copy(self.allBulkEditYAs);
	endif;
	
	self.doBuildComboQuantityType();	//13 Feb 2019	NDL	TFS 43153
	
epilog
	delete opCriteria;
end;</source>
        <Parameter name="_yas" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="72da4aa6-e409-4154-9f08-424e26730d58">
        <updating/>
        <source>setupForm() updating;
/*
Date		Who		Reason
04 Feb 2019	NDL	TFS 43153
*/

vars

begin
	inheritMethod();
	self.openWithSavedSettings();
	self.resizeForVoyage();
	self.btnMap.left 		:= 22;	
	
	self.lblYAColour.visible 	:= false;
	self.clrYAColour.visible 	:= false;

	self.grpTemplate.visible 	:= false;
	self.cmbIMEX.visible 		:= false;
	self.lblHeader.visible 		:= false;
	self.chkDisableYA.visible 	:= false;
	self.btnFindImex.visible 	:= false;
	self.shtLocation.visible 	:= false;
	self.shtOptions.visible 	:= false;
	self.txtGroupName.visible 	:= false;
	self.lblGroupName.visible 	:= false;
	self.txtImex.visible 		:= false;
	self.btnNext.visible 		:= true; // TFS 6536
// TFS 6536	self.btnSave.left 			:= self.btnNext.left;
	
	self.btnCancel.setCaptionForTranslation("&amp;Close");
	
	self.frmHeader.transparent 	:= true;
	// must set height before fldYardAlloc height
	self.height 				:= self.fldYardAlloc.top + self.clrYAColour.top + 60 + 80;
	self.fldYardAlloc.height 	:= self.clrYAColour.top + 60;
	self.shtRemarks.visible 	:= false;
	self.fldYardAlloc.top 		:= 25;
	
	self.mnuFile.visible 		:= false;
	self.mnuHelp.visible 		:= false;
	self.mnuOptions.visible 	:= false;
	self.mnuWindows.visible 	:= false;
	self.mnuTerminal.visible 	:= false;
	self.mnuView1.visible 		:= false;
	
	self.btnMap.visible := false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3933899d-23b0-4c66-9be4-0ab4a07661de">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 14 February 2019 08:20:35.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023209, locale);
	btnMap.translateCaption(Xlat_0023210, locale);
	lblDescription.translateCaption(Xlat_0023211, locale);
	lblQuantityType.translateCaption(Xlat_0023213, locale);
end;</source>
    </JadeMethod>
</GUIClass>
