    <JadeMethod name="getDisplayStringForAttribute" id="6b594ca8-ad24-481e-8c17-87b34a1458ef">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars

begin
	if _attrName = ETRow_Code then
		return self.code;
	elseif _attrName = ETRow_Description then
		return self.description;
	endif;
	return inheritMethod(_attrName, _short);

epilog

end;</source>
