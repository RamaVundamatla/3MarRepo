<Class name="CM_QCollHazTempProperty" id="3107855b-9c3c-40ad-8ead-bf2117fba75a">
    <superclass name="CM_QCollectionProperty"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="098892db-190e-438d-b1d6-74cb16937c6b">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	oper : CM_QueryOperator;
	oper1 : CM_QueryOperator;
	oper2 : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
	
	foreach oper in self.allAllowedOperators do
		if oper.isKindOf(CM_QCollIncludesNoneOf) then
			oper1 := oper;
		elseif oper.isKindOf(CM_QCollIncludesAllOf) then
			oper2 := oper;
		endif;
	endforeach;
	
	if oper1 &lt;&gt; null then
		self.allAllowedOperators.remove(oper1);
		delete oper1;
	endif;
	
	if oper2 &lt;&gt; null then
		self.allAllowedOperators.remove(oper2);
		delete oper2;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="79090649-fa2e-403d-8418-e6321a2dca37">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars

begin
	if _op.isKindOf(CM_QCollIncludesOneOf) then
		return QueryControl_MultiSelect;
	endif;

	return inheritMethod(_op);
epilog

end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
