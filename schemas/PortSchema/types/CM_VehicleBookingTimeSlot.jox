    <JadeMethod name="getOperatorsAsString" id="4eb19244-1c39-4ec9-a22b-d864510f1bd3">
        <source>getOperatorsAsString() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Nov 2023 navlc30 ChangeRequest 61256: EUP | FR | 54329 | VBS - Pending issues - Issue 12
*/

vars
	item 	          : CM_VehicleBookingTimeSlotItem;
	str 	          : String;
	operator          : CM_Operator;
	operatorCodeArray : StringArray;
begin
	
	create operatorCodeArray transient;
	
	foreach item  in self.allVehicleBookingItems do
		operator := item.getOperator();
		if operator &lt;&gt; null and operator.code &lt;&gt; null then
		
			if operatorCodeArray.includes(operator.code) then
				continue;
			endif;
			operatorCodeArray.add(operator.code);
			
			if str &lt;&gt; null then
				str := str &amp; ", ";
			endif;
			str := str &amp; operator.code;
			
		endif;
	endforeach;

	return str;
	
epilog
	delete operatorCodeArray;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPickUpIds" id="0c363205-0c61-4861-bc7d-2780687e03f9">
        <source>getPickUpIds( _delim : String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24 April 2013	cnwndl1	Initial creation	Par 31393
25 Aug 2023		navlw1	Bug 60046:[60047] FR | 53429 - VBS MTN - Enquiry Screen issues

*/

vars

	tiArray 	: CM_TIArray;
	ti 			: CM_TrackedItem;
	str 		: String;
	invalid 	: Boolean;

begin

	on Exception do app.handleDeletedObject( exception, ti, invalid); // 25.08.2023 navlw1 #60046
	
	create tiArray transient;
	self.getPickUpTis( tiArray );
	
	foreach ti in tiArray do
		
		invalid := false;
		
		ti.edition;
		if invalid then
			continue;
		endif;
		
		if str = null then
			str := ti.id;
		else
			str := str &amp; _delim &amp; ti.id;
		endif;
	endforeach;
	
	return str;

epilog
	delete tiArray;
end;</source>
        <Parameter name="_delim" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPickUpTis" id="69546666-8021-42d0-a717-21e72998e8f2">
        <source>getPickUpTis( _tiArray : CM_TIArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Apr 2013	cnwndl1	Initial creation	Par 31393
22 May 2023	navpw1	TFS: 54049 (55840) - Added code to get the correct delivering tis for Slot type validation vbs process
06 Jul 2023	navma1	ChangeRequest 58753: EUP | Slot Creation - Date and Time defaults and updates
10 Jul 2023	navma1	Defect 59075: MTN - The Picking Up field is not populating correctly based on the selected cargo items
*/

vars
	vbt				: CM_VehicleBookingTerminal;		// ### TFS 54049 (55840) 22May2023 NAVPW1
	vbsProcess		: CM_VBSProcess;					// ### TFS 54049 (55840) 22May2023 NAVPW1
	terminal		: CM_Terminal;						// ### TFS 54049 (55840) 22May2023 NAVPW1
	vbtsi			: CM_VehicleBookingTimeSlotItem;	// ### TFS 54049 (55840) 22May2023 NAVPW1
	reserveDetails	: CM_ReserveDetail;					// ### TFS 54049 (55840) 22May2023 NAVPW1
	vvr				: CM_VehicleVisitRecord;			// ### TFS 54049 (55840) 22May2023 NAVPW1
	ti				: CM_TrackedItem;
begin
	vbt := self.myVehicleBookingTerminal;
	
	if vbt &lt;&gt; null then
		terminal := vbt.myTerminal;
		
	endif;
	
	if terminal &lt;&gt; null then
		vbsProcess := terminal.getMyVBSProcess();
	endif;
	
	if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then
		/*
		06.07.2023 navma1 #58753
		foreach vbtsi in self.allVehicleBookingItems do
			if vbtsi.myTrackedItem &lt;&gt; null then
				_tiArray.addExclusive( vbtsi.myTrackedItem );
				continue;
			endif;
			
			reserveDetails := vbtsi.myReserveDetails;
			if reserveDetails = null then
				continue;
			endif;
			
			foreach ti in reserveDetails.allTrackedItems do
				if ti.isOnSite or ti.isOnShip then
					if ti.isOnSite and ti.isOnTruck and ti.jobRoadReceive &lt;&gt; null and ti.jobRoadReceive.status &lt;&gt; JOB_COMPLETE then
						continue;
					endif;
					_tiArray.addExclusive( ti );
				endif;
			endforeach;
			
			foreach ti in reserveDetails.allTrackedItemsReleased do
				if ti.isOnSite or ti.isOnShip then
					if ti.isOnSite and ti.isOnTruck and ti.jobRoadReceive &lt;&gt; null and ti.jobRoadReceive.status &lt;&gt; JOB_COMPLETE then
						continue;
					endif;
					_tiArray.addExclusive( ti );
				endif;
			endforeach;
		endforeach;
		return;
		*/
		//06.07.2023 navma1 #58753
		vvr := self.myVehicleVisitRecord;
		if vvr &lt;&gt; null then
			if not vvr.allReleasedTrackedItems.isEmpty then
				vvr.allReleasedTrackedItems.copyNoDups( _tiArray );
			endif;
		endif;
		
		foreach vbtsi in self.allVehicleBookingItems do
			if vbtsi.direction = DIRECTION_PICKUP then
				if vbtsi.myTrackedItem &lt;&gt; null then
					_tiArray.addExclusive( vbtsi.myTrackedItem); //11.07.2023 navma1 #59075
				endif;
			endif;
		endforeach;
	else
		vvr := self.myVehicleVisitRecord;
		
		if vvr &lt;&gt; null then
			if not vvr.allReleasedTrackedItems.isEmpty then
				vvr.allReleasedTrackedItems.copy( _tiArray );
			endif;
			
		else
			foreach ti in self.allBookedTrackedItems do
				if ti.isOnSite or ti.isOnShip then
					//13 Feb 2014	NDL	Par 33500
					if ti.isOnSite and ti.isOnTruck and ti.jobRoadReceive &lt;&gt; null and ti.jobRoadReceive.status &lt;&gt; JOB_COMPLETE then	//12 Feb 2014	NDL	Par 33500 
						continue;
					endif;
					_tiArray.add( ti );
				endif;
			endforeach;
			
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPickupString" id="9c25d719-2600-458f-a4dd-79fd8a8cb141">
        <source>getPickupString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 September 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
28 Aug 2023			navma1	Bug 60046 FR | 53429 - VBS MTN - Enquiry Screen issues
16 Oct 2023         navlc30 ChangeRequest 58996: EUP | VBS changes MTN - Adding multiple items at once (From Ticket FR 53429)
*/
constants
	MaxLen = 100;
vars
	str		:	String;
	invalid : 	Boolean;
	
begin
	str :=  self.getPickUpIds(",");
	
	if str &lt;&gt; null then
		if str.length &gt; MaxLen then												//16.10.2023 navlc30 #58996
			return str[1:MaxLen-3] &amp; '...';
		else 	
			return str;
		endif;	
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.myCarrier, invalid);
	
	if self.myCarrier = null then
		return null;
	endif;
	
	self.myCarrier.edition;
	
	if invalid then
		return null;
	endif;
	
	if self.myTerminal.isUsingVbsStandardProcess then						   // 28.08.2023 navma1 #60046
		return self.includesPickUp.getYesNo;
	endif;

	return null;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRange" id="c8e5487c-db6c-4ecb-8211-ff180607684b">
        <source>getRange():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2022	navhl20 ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen

*/

vars
	str : String;
begin
	str := self.bookingTSstart.asStringJMT &amp; " - ";
	if self.bookingTSstart.date = self.bookingTSend.date then
		return str &amp; self.bookingTSend.Time.asStringJMT;
	else
		return str &amp; self.bookingTSend.asStringJMT;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReleaseIdsAsString" id="8cf71a4e-17a3-41d2-aa93-4136f9419332">
