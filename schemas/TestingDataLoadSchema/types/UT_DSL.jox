								terminal.getConfig(AutoReseqJobsSetDown).Boolean,
								overstowMoveMode,
								0,
								true,
								true,
								terminal.getConfig(MaxNumOverstowMoves).Integer,
								terminal.getConfig(MaxRowsForRTQueries).Integer,
								terminal.getConfig(RtMaxNumQueueEntries).Integer,
								terminal.getConfig(RtNumOfSearchResults).Integer,
								allAvailableViews,
								defaultGraphicView,
								COLUMN_LABEL_TOP,
								ROW_LABEL_LEFT,
								terminal.getConfig(SelectorQueriesForRT).CM_SelectorQueryAccess,
								pxyNightScreenConfig,
								pxyDayScreenConfig,
								14,
								16,
								pxyCargoView,
								pxyDirectorView,
								pxyTaskView,
								false,
								false,
								false,
								null,
								false,
								null,
								null,
								null,
								0,
								0,
								true,
								false,	    // 29/11/19 JLGNS1 TFS47394
								false,		// TFS 51409
								false,		// TFS 51409
								false,       //01.09.2021 navma1 #51485
								false,
								false		//29/10/2025	navkc1 JIRA 36186
								);


	app.myTrxCA.trxCreateRTVehicleConfig(pxyRTVehicleConfig, realRTVehicleConfig, null, terminal, machineType, machine, app.myPassport);
	self.assertNoTrxErrorsOrWarnings(); // cnwma1 30/04/2014

epilog
