    <JadeMethod name="createSnapshotData" id="7be85293-3e8f-473f-821f-f784f2189a35">
        <source>createSnapshotData(_definition : CM_OutputFormat_SS) : CM_SnapshotData;
// copy of BGP_SummarySnapshot::action + getCollection with just the data creation, no file creation or invoicing
//	return the data
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

vars 
	
	userQuery 		: CM_MenuUserQuery;
	queryAgent 		: CM_QueryAgentFilter;
	qDef 			: CM_QueryDefinition;
	enqController	: CM_EnquiryController;
	criteriaHolder	: CM_QueryCriteriaLineHolder;
	collection 		: Collection;
	snapshotData 	: CM_SnapshotData;
	terminal		: CM_Terminal;
	user			: CM_User;
	ts				: TimeStamp;

begin
	
	terminal := self.getTerminal();
	user := app.getMyUser();

	//get a collection of data based on the selector query
	create collection as CM_TISet transient;
	userQuery := _definition.mySelectorQuery;
	queryAgent := app.myQAFilter;
	
	qDef := app.myRoot.allQueryDefinitionObjects[userQuery.getType, userQuery.queryMode];
	queryAgent.createEnqControllerForMode(userQuery.queryMode, userQuery.getType, enqController);
	delete enqController.allObjects;
	create enqController.allObjects as CM_TISet transient;
	
	foreach criteriaHolder in userQuery.allCriteriaLineHolders do
		enqController.myCriteriaLineHolder := criteriaHolder;
		enqController.doQuery(qDef);
	endforeach;
	
	ts := app.actualTimeServer;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	
	enqController.allObjects.copy(collection);	
	
	if not collection.isEmpty then
		// build the snapshotdata from the collection and the OutputFormat
		snapshotData := _definition.generateSnapshotDataFromColl(collection, null, ts, terminal, user);
	endif;
		
	return snapshotData;
epilog
	if enqController &lt;&gt; null then
		delete enqController.allObjects;
	endif;
	delete enqController;
	delete collection;
end;</source>
        <Parameter name="_definition" type="CM_OutputFormat_SS"/>
        <ReturnType type="CM_SnapshotData"/>
    </JadeMethod>
    <JadeMethod name="createStorageConfig" id="d17cbe71-910c-400f-b5e8-50ee6bd26ff8">
        <source>createStorageConfig(_criteria : CM_YACriteriaTypeArray; _triggers : CM_StorageTriggerByType; _deriveDebtorFrom : CM_DebtorType; _firstDayTimeCutoff : Time; _includeFirstDay : Boolean; _includeLastDay : Boolean; _lastDayTimeCutoff : Time; 
					_shipReceivalType : Integer; _shipReleaseType : Integer; _calendar : CM_Calendar; _compulsory : CM_Calendar;
					_allExtraDayCargoTypes : IntegerArray input; _roadReceivalType : Integer; _railReceivalType : Integer; _unpackReceivalType : Integer) : CM_StorageConfig;
// CCMS 1295
vars
	proxy		: CM_StorageConfig;
	realConfig	: CM_StorageConfig;
	terminal	: CM_Terminal;
begin
	create proxy transient;
	terminal := self.getTerminal();
	proxy.setProxy(_criteria, _triggers, _firstDayTimeCutoff, _includeFirstDay, _includeLastDay, terminal, _shipReceivalType, _shipReleaseType, _calendar, _compulsory, _roadReceivalType, _railReceivalType, _unpackReceivalType);

	app.myTrxCA.trxCreateStorageConfig(proxy, realConfig,_allExtraDayCargoTypes, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return realConfig;

epilog
	delete proxy;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteriaTypeArray"/>
        <Parameter name="_triggers" type="CM_StorageTriggerByType"/>
        <Parameter name="_deriveDebtorFrom" type="CM_DebtorType"/>
        <Parameter name="_firstDayTimeCutoff" type="Time"/>
        <Parameter name="_includeFirstDay" type="Boolean"/>
        <Parameter name="_includeLastDay" type="Boolean"/>
        <Parameter name="_lastDayTimeCutoff" type="Time"/>
        <Parameter name="_shipReceivalType" type="Integer"/>
        <Parameter name="_shipReleaseType" type="Integer"/>
        <Parameter name="_calendar" type="CM_Calendar"/>
        <Parameter name="_compulsory" type="CM_Calendar"/>
        <Parameter name="_allExtraDayCargoTypes" type="IntegerArray" usage="input"/>
        <Parameter name="_roadReceivalType" type="Integer"/>
        <Parameter name="_railReceivalType" type="Integer"/>
        <Parameter name="_unpackReceivalType" type="Integer"/>
        <ReturnType type="CM_StorageConfig"/>
    </JadeMethod>
    <JadeMethod name="createTemperatureReading" id="25dfe9e6-0df2-41cb-a65f-b2cbde2526cd">
        <source>createTemperatureReading(_ti : CM_TrackedItem; _dateTime : TimeStamp; _temp : Real; _noCharge : Boolean);
//
// 27/09/2021	navdap1		TFS 52081 MTN Cannot Add Reading for a Reefer for a time other than Now
vars
	tempReadingParams	: CMIF_TempReading;
	loadState			: Boolean;
	theProxyTI			: CM_TrackedItem;

begin

	create tempReadingParams transient;
	
/*	tempReadingParams.isRefConReading := false;
	tempReadingParams.isRefConAlarm := false;
	tempReadingParams.refConRawData := null;
	tempReadingParams.dateTime := _dateTime;
	tempReadingParams.noCharge := _noCharge;
	tempReadingParams.userId := app.getMyUserCode();
	tempReadingParams.myTerminal := self.getTerminal; */
					
	app.cmsBeginLoad(loadState);
	theProxyTI := _ti.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);

/*	tempReadingParams.myTrackedItem := theProxyTI;
	tempReadingParams.noCharge := _ti.noChargeForTemperature(_noCharge, _dateTime);
	tempReadingParams.temperature := _temp; */
	
	//01 Sep 2021	NDL	TFS 51874 - Use common code instead of 14 different variant copies....
	tempReadingParams.initialise(	theProxyTI,	//_reefer : CM_TrackedItem;
									_noCharge,	//_defaultNoChargeValue : Boolean;
									_dateTime,	//_dateTime : TimeStamp;			// TFS 52081
									_temp	//_temperature : Real
									);
			
	app.myTrxCA.trxCreateTempReading(tempReadingParams, null, app.myPassport);	

epilog
	app.cmsEndLoad(loadState);
	delete tempReadingParams;
	delete theProxyTI;
			
end;
</source>
