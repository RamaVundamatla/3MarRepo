    <JadeMethod name="jssCreateIniFile" id="90918249-4fb8-4a2b-945a-c37835aa35ce">
        <source>jssCreateIniFile(pFileName:String):JSSIniFile protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniFile	: JSSIniFile;

begin
	create iniFile transient;
	iniFile.set(pFileName);
	return iniFile;
end;</source>
        <access>protected</access>
        <Parameter name="pFileName" type="String"/>
        <ReturnType type="JSSIniFile"/>
    </JadeMethod>
    <JadeMethod name="jssLoadCsvFile" id="41c2e262-d739-498b-a1e4-0bca760d889b">
        <updating/>
        <source>jssLoadCsvFile(pFileDef:JSSFileDefinition io; pShowProgress:Boolean; pProgressPercent:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		29 May 1999 by cnwdad1
//
// Purpose:		Reads a comma-delimited file (quote-enclosed) into an array of arrays.
//
// Parameters:	pFileDef (JSSFileDefinition) - This is a efinition of the disk file
//					that will be opened and read.
//				pShowProgress (Boolean) - Indicates whether a progress dialog is to be
//					shown whilst the file is being read.
//
//				pProgressPercent (Integer) - Specifies how frequently to refresh the
//					progress bar (as a percent value).
//
// Returns:		pFileDef (JSSFileDefinition) - Returned as an output parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 30/08/2000	cnwdad1		Added "pProgressPercent" parameter.  This will determine
//							how frequently to refresh the progress bar by specifying
//							a percent value, e.g. if the value is 10, then the
//							progress bar will be refreshed with every 10 percent
//							of the job that is completed.
// 12/08/2002	cnwdad1		Fixed bug where the updating of the progress form was
//							being done unconditionally.  Added a check of the
//							pShowProgress parameter.
// --------------------------------------------------------------------------------
constants
	COMMA			: String = ',';
	DOUBLE_QUOTE	: String = '"';

vars
	fieldNo			: Integer;
	fieldPos		: Integer;
	fieldLen		: Integer;
	inString		: String;
	stringLen		: Integer;
	progressForm	: JSSProgressForm;
	partsInJob		: Integer;
	partsDone		: Integer;
	percentLastDone	: Integer;
	percentNowDone	: Integer;

	record			: JSSFileRecord;
	recordNo		: Integer;
	field			: JSSFileField;
	headerRecord	: JSSFileRecord;
	headerField		: Integer;
	headerId		: String;
	trailerField	: Integer;
	trailerId		: String;

begin
	self.openInput(pFileDef.fileName);	// Open the file.
	self.kind := File.Kind_Unknown_Text; // 1/3/16  cnwns1 PAR 36286 unicode version
	pFileDef.setHeaderRecord(null);
	pFileDef.setTrailerRecord(null);
	pFileDef.allRecords.purge();
	headerField		:=	self.headerFieldNo;
	headerId		:=	self.headerIdentifier;
	trailerField	:=	self.trailerFieldNo;
	trailerId		:=	self.trailerIdentifier;

	if pShowProgress then
		partsInJob	:=	self.fileLength();
		create progressForm;
		progressForm.startProgress('Reading ' &amp; pFileDef.fileName &amp; '...', partsInJob);
		progressForm.show();
		partsDone	:=	0;
		progressForm.refreshNow();
	endif;
	
	while (not self.endOfFile()) do
		inString	:=	self.readLine();	// Get the (next) file record.
		stringLen	:=	inString.length();	// Get the length of the record.
		fieldPos	:=	1;					// Initialize the field position.
		fieldNo		:=	1;					// Initialize the field number.
		recordNo	:=	recordNo + 1;

		if pShowProgress then
			partsDone	:=	partsDone + stringLen;
		endif;

		// Create a new array of record fields.

		create record transient;
		record.set(pFileDef, recordNo, null, false, false, false);
		headerRecord	:=	pFileDef.myHeaderRecord;

		// Now scan the record...

		while fieldPos &lt; stringLen do
			fieldLen	:=	inString.pos(COMMA, fieldPos);		// Locate the next subsequent comma (field delimiter).
			fieldLen	:=	fieldLen - fieldPos;				// Get the length of this field.

			if inString.pos(COMMA, fieldPos) = 0 and fieldPos &lt; stringLen then
				// This must be the last field in the record.
				fieldLen	:=	stringLen - fieldPos + 1;
			endif;

			create field transient;
			field.set(record, fieldNo, null, inString[fieldPos:fieldLen], false);	// Add this field to the array of fields.

			// If the comma is inside double-quotes, scan ahead in the record for the next double-quote.

			while	field.fieldValue[1] = DOUBLE_QUOTE and
					field.fieldValue[field.fieldValue.length()] &lt;&gt; DOUBLE_QUOTE do
				fieldPos			:=	fieldPos + fieldLen + 1;
				fieldLen			:=	inString.pos(COMMA, fieldPos);
				fieldLen			:=	fieldLen - fieldPos;
				field.setFieldValue(field.fieldValue &amp; COMMA &amp; inString[fieldPos:fieldLen]);
			endwhile;

			// String any double-quotes that surround the field value.

			if	field.fieldValue[1] = DOUBLE_QUOTE and
				field.fieldValue[field.fieldValue.length()] = DOUBLE_QUOTE then
				field.setFieldValue(field.fieldValue[2:(field.fieldValue.length() - 2)]);
			endif;

			// Update the header and trailer record flags.

			if headerField &lt;&gt; 0 and headerId &lt;&gt; null then
				if fieldNo = headerField and field.fieldValue = headerId then
					record.setIsHeader(true);
				endif;
			endif;

			if trailerField &lt;&gt; 0 and trailerId &lt;&gt; null then
				if fieldNo = trailerField and field.fieldValue = trailerId then
					record.setIsTrailer(true);
				endif;
			endif;

			// If we're reading a header record, then use each field's value as the field name,
			// otherwise, get the field name from the Header record fields.

			if record.isHeader then
				field.setFieldName(field.fieldValue);
			elseif headerRecord &lt;&gt; null then
				field.setFieldName(headerRecord.allFields.getAtKey(field.fieldNo).fieldName);
			endif;

			// Increment positions to the next field position.

			fieldPos	:=	fieldPos + fieldLen + 1;
			fieldNo		:=	fieldNo + 1;
		endwhile;

		// Update the header or trailer reference onthe file definition object.

		if record.isHeader then
			pFileDef.setHeaderRecord(record);
		elseif record.isTrailer then
			pFileDef.setTrailerRecord(record);
		endif;

		// Update the progress bar (if required).

		if pShowProgress then
			percentNowDone	:=	partsDone div (partsInJob div 100);
			
			if (percentNowDone - percentLastDone) &gt;= pProgressPercent then
				progressForm.updateProgress(partsDone);
				percentLastDone	:=	percentNowDone;
			endif;

			if progressForm.isCancelled then
				self.isCancelled	:=	true;
				return;
			endif;
		endif;
	endwhile;
	
	if pShowProgress then							// cnwdad1 12/08/2002.
		progressForm.updateProgress(partsInJob);
	endif;											// cnwdad1 12/08/2002.
epilog
	self.close();

	if progressForm &lt;&gt; null then
		progressForm.unload();
		delete progressForm;
	endif;
end;</source>
        <Parameter name="pFileDef" type="JSSFileDefinition" usage="io"/>
        <Parameter name="pShowProgress" type="Boolean"/>
        <Parameter name="pProgressPercent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssLoadIniFile" id="d8e3d179-0922-4618-9ee2-0f56581934df">
        <updating/>
        <source>jssLoadIniFile(pFileName:String):JSSIniFile updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	inString	: String;
	iniFile		: JSSIniFile;
	iniSection	: JSSIniSection;
	iniElement	: JSSIniKey;
	elementName	: String;
	setPosition	: Integer;

begin
	self.openInput(pFileName);							// Open the disk file.
	self.kind := File.Kind_Unknown_Text; // 1/3/16  cnwns1 PAR 36286 unicode version
	iniFile	:=	self.jssCreateIniFile(pFileName);

	while (not self.endOfFile()) do
		inString	:=	self.readLine().trimBlanks();		// Get the (next) file record.

		if inString &lt;&gt; null then
			if inString[1:1] = "[" then
				iniSection	:=	iniFile.createSection(inString[2:(inString.length() - 2)]);

			elseif (inString[1:1] &lt;&gt; "/") and (inString[1:1] &lt;&gt; ";") then
				setPosition	:=	inString.pos("=", 1);

				if setPosition &gt; 1 then
					elementName	:=	inString[1:(setPosition - 1)];
					iniElement	:=	iniSection.createKey(elementName, null);
				endif;

			endif;
		endif;
	endwhile;

	return iniFile;
epilog
	self.close();
end;</source>
        <Parameter name="pFileName" type="String"/>
        <ReturnType type="JSSIniFile"/>
    </JadeMethod>
</Class>
