    <JadeMethod name="processLoggerInitialize" id="60b87633-0f65-44f3-bf56-5488f324faf7">
        <updating/>
        <source>processLoggerInitialize(initObj:Object) updating;

begin
//	cnActivateKarmaControl(Cn_Fat_Client,null,null);	// Arms default exception handlers
	create myProcessLogger transient;
	myProcessLogger.commandProcessor := initObj.CommandProcessor;
	myProcessLogger.setUp();
end;</source>
        <Parameter name="initObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="startAppServerInitilize" id="17755b0f-471d-4c4f-8416-25fe77fb6b78">
        <updating/>
        <source>startAppServerInitilize() updating;

vars
	s,t,path,iniFile,bgp:String;
	i,appServers,appServerPort,delay,retCode,result,queues:Integer;
	sa:StringArray;
begin
	s:=getUserCmdLine;
	logMessage(method.qualifiedName&amp;" &lt;"&amp;s&amp;"&gt;");
	path:=getJadeInstallDirAppServer;
	iniFile:=getIniFileNameAppServer;
	appServers:=getProfileStringAppServer(iniFile,"JBL","AppServers","1").Integer;
	appServerPort:=getProfileStringAppServer(iniFile,"JBL","AppServerPort",(getProfileStringAppServer(iniFile,"JadeServer","TcpServerPort","0").Integer+1).String).Integer;
	queues:=getProfileStringAppServer(iniFile,"JBL","TradeQueues","0").Integer;

	if s &lt;&gt; null then  // cmdLine parameters override ini file settings
		i:=1;   appServers:=s.scanUntil(";",i).Integer;
		i:=i+1; appServerPort:=s.scanUntil(";",i).Integer;
		i:=i+1; delay:=s.scanUntil(";",i).Integer;

		if appServers &lt;&gt; 0 then
			// do this when starting bmk appservers, not control appserver
			foreach i in 1 to queues do
				app.doWindowEvents(delay*1000); fatClientStart("TradeEmSchema", 'MatchMaker');
				app.doWindowEvents(delay*1000); fatClientStart("TradeEmSchema", 'Feeder');
				//app.doWindowEvents(delay); fatClientStart(currentSchema.name, 'Concentrator', 'jtpc62102');
			endforeach;
		endif;
	endif;

	create sa transient;
	sa[1]:="path="&amp;dbPath;
	sa[2]:="ini="&amp;iniFile;

	foreach i in 1 to appServers do
		sa[3]:="AppServerPort="&amp;(i+appServerPort-1).String;
		sa[4]:="server=multiuser name=appserver";
		logMessage("starting app server "&amp;sa[3]);
		retCode:=node.createExternalProcess(path,path&amp;"\jadapp.exe",sa,null,false,false,result);
		if retCode&lt;&gt;0 and retCode&lt;&gt;4 then logMessage("startup failed, retCode="&amp;retCode.String&amp;CrLf&amp;sa.display); endif;
		app.doWindowEvents(delay*1000);
	endforeach;/**/

	if appServers &gt; 1 then  // only do this when starting appservers, not in initial startup or sync master thinbin
		bgp:=getProfileStringAppServer(iniFile,"JBL","BGP_Manager","");
		if bgp &lt;&gt; null then
			sa[3]:="server=multiuser";
			sa[4]:="app=BGP_ManagerShortcutApp schema=UiCommonSchema";
			sa[5]:="endJade BGP_Manager="&amp;bgp;
			logMessage("starting BGP_Manager for "&amp;bgp);
			retCode:=node.createExternalProcess(path,path&amp;"\jade.exe",sa,null,false,false,result);
			if retCode&lt;&gt;0 and retCode&lt;&gt;4 then logMessage("startup failed, retCode="&amp;retCode.String&amp;CrLf&amp;sa.display); endif;
		endif;
	endif;

	logMessage("finished");
	terminate;
epilog
	delete sa;
end;</source>
    </JadeMethod>
    <JadeMethod name="workerFinalize" id="9de07c5c-1da7-4766-9db5-fea5b8e7f104">
