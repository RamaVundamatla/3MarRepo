<Class name="ReportInPatch" id="08b2209d-c0c4-48de-bb9a-3f54acbf40b2">
    <superclass name="Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="HotFixesCommonSchema"/>
    <ExplicitInverseRef name="myPatch" id="83e6419a-3ba4-437a-bdfc-aeb4d9d80fee">
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="Patch"/>
        <Inverse name="Patch::allReportsInPatch"/>
    </ExplicitInverseRef>
    <PrimAttribute name="name" id="67f0ab39-1f26-4955-92e4-047ddd7b4f39">
        <length>257</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="extractReport" id="7b1abe20-8992-483e-beca-eceb70ca9e9a">
        <source>extractReport(_jadeMaster, _client : String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2014	cnwmc5	Initial creation

*/
constants
	
vars
	agent		: DEV_ReleaseExtractAgent;
	rptFileName	: String;
	serverStr 	: String;
begin
	create agent transient;
	
	serverStr := app.cnGetServerMiscPath() &amp; '\';
	
	rptFileName := self.getNameWithDetails &amp; '.rwr';
	
	agent.extractReport(serverStr &amp; rptFileName, self.name);
	
	app.copyAFile(serverStr &amp; rptFileName, false, _jadeMaster &amp; rptFileName, true);
	app.copyAFile(serverStr &amp; rptFileName, false, _client &amp; rptFileName, true);
	
	app.deleteAFile(serverStr &amp; rptFileName, false);
epilog
	delete agent;
end;</source>
        <Parameter name="_jadeMaster" type="String"/>
        <Parameter name="_client" type="String"/>
    </JadeMethod>
    <JadeMethod name="getNameWithDetails" id="d1585975-7db1-4cf8-8718-f9bb22452f10">
        <source>getNameWithDetails() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2014	cnwmc5	Initial creation

*/

vars

begin
	return self.name &amp; '_' &amp; app.myRootHotFix.releaseVersionNo &amp; '_' &amp; self.myPatch.patchNo;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="9407e1d8-1239-4136-885b-9819c3bc0a63">
        <updating/>
        <source>setForCreate( _name: String; _patch: Patch ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2014	cnwmc5	Initial creation

*/

vars

begin
	self.name := _name;
	self.myPatch := _patch;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_patch" type="Patch"/>
    </JadeMethod>
    <JadeMethod name="validate" id="ae454829-497a-471e-886f-4a6b3239a5d9">
        <source>validate() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2014	cnwmc5	Initial creation

*/

vars
	agent: DEV_ReleaseExtractAgent;
begin
	create agent transient;
	
	if not agent.validateReport(self.name) then
		app.writeLogMessage('Report ' &amp; self.name &amp; ' - not found.');
		return false;
	endif;
	
	app.writeLogMessage('Report ' &amp; self.name &amp; ' - ok.');
	return true;
epilog
	delete agent;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
