        <source>utlCreateAutoIdGenerator(	_proxy : CM_AutoIdGenerator;
							_newGenerator : CM_AutoIdGenerator output;
							_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2014	cnwndl1	Initial creation	Par 34660

*/

vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valAutoIdGenerator(_proxy);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _newGenerator as _proxy.class persistent;
	_newGenerator.setForCreate(_proxy);
	
	if _passport.noErrors then
		_newGenerator.addActivityRecord( true );
	endif;
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newGenerator);
	endif;

epilog

end;</source>
