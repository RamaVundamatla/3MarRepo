        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setForCreate" id="662e39c1-9b83-4e1a-810f-7b65a0676df7">
        <updating/>
        <source>setForCreate(_html : String; _pageType : Integer; _webSiteConfig : CM_WebSiteConfig) updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.html	:= _html;
	self.pageType	:= _pageType;
	self.myWebSiteConfig	:= _webSiteConfig;
end;</source>
        <Parameter name="_html" type="String"/>
        <Parameter name="_pageType" type="Integer"/>
        <Parameter name="_webSiteConfig" type="CM_WebSiteConfig"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="bd72dda7-f1f0-433e-8341-8bd610ab1d1e">
        <updating/>
        <source>setForUpdate(_html : String) updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.html := _html;
end;</source>
        <Parameter name="_html" type="String"/>
    </JadeMethod>
</Class>
