    <JadeMethod name="create" id="3373b82c-55c5-4e1a-b3ad-e06d79a545e8">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
22/02/2010	cnwcs5		par 21748 - store osDescription
*/
vars
	tmpVersion	: String;
	
begin
	self.type := EVT_UserLogin;
	if app.niceName &lt;&gt; null then
		self.appName := app.niceName;
	else
		self.appName := app.name;
	endif;
	
	self.osDescription := process.getOSDescription;	// par 21748 22/02/2010 cnwcs6
	
	self.osPlatform := process.getOSPlatform(tmpVersion, self.osArchitecture);
	self.osVersion := tmpVersion[1:10];
	
	self.timeLoggedOnSeconds := -1;
	self.computerName := app.computerName[1:30];
	
end;


</source>
    </JadeMethod>
    <JadeMethod name="getBank" id="2146a250-c81b-4103-9d46-479bf28daf9c">
        <source>getBank() : CM_Bank;
// ---------------------------------------------------------------------------
// Created:		18 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		need to put bank on Organisation?
//
// ---------------------------------------------------------------------------
vars
	u : CM_User;
	ut : CM_UserTerminal;
	t : CM_Terminal;
begin
	u := self.getUserObject();
	t := self.getTerminal();
	
	if t &lt;&gt; null then
		//return t.getConfig(DefCompany).CM_Bank;
		return t.getDefaultCompanyBank();	//17 Apr 2012	NDL	Par 29393
	endif;
	return null;
end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getDebtor" id="f277ca2e-b450-41f0-83a6-ef10c30d0b55">
        <source>getDebtor(): CM_Debtor;
// ---------------------------------------------------------------------------
// Created:		19 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	myUser : CM_User;
begin
	myUser := self.getUserObject();
	if myUser &lt;&gt; null then
		if myUser.myOrganisation &lt;&gt; null then
			if myUser.myOrganisation.myDebtor &lt;&gt; null then
				return myUser.myOrganisation.myDebtor;
			endif;
		endif;
	endif;
	
	return inheritMethod();

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c82a3d0f-8cec-46b5-b097-0e06f4940ef9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
----------   ----------  --------------------------------------------------
Created:	30 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
//19 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars

begin
	if _attrName = ETRow_ErrorText or
	   _attrName = ETRow_AppName then
		return self.appName;
	elseif _attrName = ETRow_ComputerName then
		return self.computerName;
	elseif _attrName = ETRow_LogoutTime then
		return self.systemToLocalTime(self.getLogoutTime).asStringJMT();
	elseif _attrName = ETRow_OsDescription then
		return self.osDescription;
	elseif _attrName = ETRow_TimeLoggedOnMinutes then
		return self.timeLoggedOnMinutes.asStringJMT();
	else
		return inheritMethod(_attrName, _short);
	endif;

end;


</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLogoutTime" id="fdd7d8d5-9889-41bb-b65b-fc66824d5261">
        <source>getLogoutTime() : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     09 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.myEventLogout &lt;&gt; null then
		return self.myEventLogout.dateTime;
	endif;
	return null;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getLogoutTimeLocalTZ" id="1a180fa1-2aeb-465d-b9e5-a463ac6efc96">
        <source>getLogoutTimeLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2016	cnwns1	Initial creation
// 01 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	if self.myEventLogout &lt;&gt; null then
		return self.systemToLocalTime(self.myEventLogout.dateTime);
	endif;
	return null;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getName" id="5782fdec-00f5-4c9d-abd6-d6ff7101752f">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:		18 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.userCode &lt;&gt; null then
		return self.userCode &amp; " " &amp; self.myEventType.name;
	else
		return inheritMethod();
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTerminal" id="0b4eb882-7d60-439d-81c6-f6b6246c6c23">
        <source>getTerminal() : CM_Terminal;
// ---------------------------------------------------------------------------
// Created:		19 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	u : CM_User;
	ut : CM_UserTerminal;
	t : CM_Terminal;
begin
	u := self.getUserObject();
	if u = null then
		t := inheritMethod;
	else
		foreach ut in u.allUserTerminals discreteLock do
			t := ut.myTerminal;
			break;
		endforeach;
	endif;
	return t;
end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
