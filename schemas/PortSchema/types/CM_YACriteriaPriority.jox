    </PrimAttribute>
    <ExplicitInverseRef name="myYACriteriaType" id="903bcb05-f568-448a-aaf0-bc7f68396d20">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
