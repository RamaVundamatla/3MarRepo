    <JadeMethod name="chkVisible_change" id="a506bd33-d8fd-425a-8dd7-a1abc2962e61">
        <controlMethod name="CheckBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkVisible_change(checkbox: CheckBox input) updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	control	:Control;
	form	:SOP_FormConfigCustomiseForm;
begin
	control := self.getSelectedControl;
	
	if control = null then
		return;	// oops
	endif;
	
	form := self.getFormParent.SOP_FormConfigCustomiseForm;
	
	form.setControlVisible (control, checkbox.value);
	
	if checkbox.value then
		form.selectControl (control);
	endif;
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbControl_click" id="8729ecd1-4694-48ab-9c67-fbe1cc98e747">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbControl_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	control	:Control;
begin
	control	:= combobox.listObject.Control;
	
	self.displaySelectedControl (control);
	
	self.getFormParent.SOP_FormConfigCustomiseForm.selectControl(control);
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="579d5f7f-1a98-4bc6-af25-bc61ec83e775">
        <updating/>
        <source>create() updating;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date				Who		Reason
02 September 2008	concms1	User definable forms
*/
vars

begin
	// just use these permissions for the time being till we create some new ones
	self.permissionView   := PmFaultEnquiryView;
	self.permissionMaint  := PmFaultEnquiryView;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displaySelectedControl" id="1ad9d07b-a742-4359-9a40-197c3ffcbcd9">
        <source>displaySelectedControl(_control :Control);
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	index 	:Integer;
begin
	// clear out all values and disable
	textBox1.text	:= null;
	
	if _control = null then
		cmbControl.listIndex := -1;
		fldLayout.enabled := false;
	endif;
	
	cmbControl.listIndex := cmbControl.findObject (_control);
	
	if cmbControl.listIndex = -1 then
		return;
	endif;
	
	if _control.isKindOf (Label) then
		textBox1.text	:= _control.Label.caption;
	elseif _control.isKindOf (Button) then
		textBox1.text	:= _control.Button.caption;
	endif;
	
	chkVisible.value := _control.visible;
	
	// font
	tblFont.accessCell (1, 1).text := 'Bold' &amp; Tab &amp; _control.fontBold.String;
	tblFont.accessCell (2, 1).text := 'Italic' &amp; Tab &amp; _control.fontItalic.String;
	
	if _control.fontName &lt;&gt; null then
		tblFont.accessCell (3, 1).text := 'Font Name' &amp; Tab &amp; _control.fontName.String;
	else
		tblFont.accessCell (3, 1).text := 'Font Name' &amp; Tab &amp; app.fontName.String;
	endif;
	
	tblFont.accessCell (4, 1).text := 'Size' &amp; Tab &amp; _control.fontSize.String;
	tblFont.accessCell (5, 1).text := 'Underline' &amp; Tab &amp; _control.fontUnderline.String;
	tblFont.accessCell (6, 1).text := 'Colour'; 
	tblFont.accessCell (6, 2).backColor := _control.foreColor;
	
	// layout
	tblLayout.rows := 4;
	tblLayout.setCellText (1, 1, 'Left' &amp; Tab &amp; _control.left.String);
	tblLayout.setCellText (2, 1, 'Top' &amp; Tab &amp; _control.top.String);
	tblLayout.setCellText (3, 1, 'Width' &amp; Tab &amp; _control.width.String);
	tblLayout.setCellText (4, 1, 'Height' &amp; Tab &amp; _control.height.String);
	
	tblLayout.accessCell (1, 2).cellControl := txtInput;
	tblLayout.accessCell (2, 2).cellControl := txtInput;
	
	txtInput.automaticCellControl := true;
	txtInput.borderStyle			:= TextBox.BorderStyle_None;
epilog
	

end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="getSelectedControl" id="154f5d41-d338-413b-94a6-c0a029ba24e4">
        <source>getSelectedControl():Control;
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return cmbControl.listObject.Control;
epilog

end;</source>
        <ReturnType type="Control"/>
    </JadeMethod>
    <JadeMethod name="loadControlList" id="f0bdfe10-033d-4418-be41-e9ce0f07802b">
        <source>loadControlList()protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date		Who		Reason
03 September 2008	concms1	Initial creation
*/

vars
	form	:SOP_FormConfigCustomiseForm;
	coll	:ObjectSet;
	obj		:Object;
	strName	:String;
	index	:Integer;
begin
	cmbControl.clear;
	
	form := self.getFormParent.SOP_FormConfigCustomiseForm;
	
	coll := form.getCustomisableControls;
	
	foreach obj in coll do
		strName := form.getControlDisplayName (obj.Control);
		
		if strName = null then
			continue;	// not customisable
		endif;
		
		index := cmbControl.addItem (strName);
		
		cmbControl.itemObject[index]	:= obj;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFontProperties" id="802baefe-aaac-4b53-8b4d-aa26f688e251">
        <source>setFontProperties();
// ---------------------------------------------------------------------------
// Created:     04 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	control	:Control;
	dlg		:CMDFont;
begin
	control := self.getSelectedControl;
	
	if control = null then
		return;
	endif;
	
	create dlg;
	
	dlg.fontBold	:= control.fontBold;
	dlg.fontItalic	:= control.fontItalic;
	
	if control.fontName &lt;&gt; null then
		dlg.fontName	:= control.fontName;
	else
		dlg.fontName	:= app.fontName;
	endif;
	
	dlg.fontSize	:= control.fontSize;
	dlg.fontUnderline	:= control.fontUnderline;
	dlg.textColor	:= control.foreColor;
	
	if dlg.open &lt;&gt; 0 then
		return;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ee2a060c-460d-4266-8a86-111261648e48">
        <updating/>
        <source>setupForm() updating;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date		Who		Reason
03 September 2008	concms1	Initial creation
*/

vars

begin 
	self.showToolbar 	:= false;
	self.toolbarStyle 	:= self.ToolbarStyle_None;

	// hide all menus
	mnuFile.visible			:= false;
	mnuOptions.visible		:= false;
	mnuView1.visible		:= false;
	mnuTerminal.visible		:= false;
	mnuWindows.visible		:= false;
	mnuHelp.visible			:= false;
	
	inheritMethod();
	
	self.loadControlList;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblFont_dblClick" id="98b88b19-fec2-4bb3-a037-90426de8db8a">
