<Class name="CMIF_MoveParams" id="6679aa30-1c4f-4815-ad4a-3afec57f58b5">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Responsible for passing the parameters for a move process </text>
    <DbClassMap file="planning"/>
    <PrimAttribute name="dateTime" id="654b34fb-2a47-444d-8819-8594bec15096">
        <embedded/>
        <type name="TimeStamp"/>
        <text>This returns the date and time the move was completed.</text>
    </PrimAttribute>
    <PrimAttribute name="errorCode" id="8ab12f75-25ec-41fd-8e3c-5d50dbc67e67">
        <embedded/>
        <type name="Integer"/>
        <text>USED INTERNALLY. Do NOT set.</text>
    </PrimAttribute>
    <PrimAttribute name="flags" id="16483103-dafd-4f3a-a692-77ec00821d66">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="forced" id="a2e2212b-dae1-4b72-a7b1-86bb2f7b8498">
        <embedded/>
        <type name="Boolean"/>
        <text>This indicates that the move should ignore any warnings and attempt to proceed to completion.</text>
    </PrimAttribute>
    <PrimAttribute name="machineId" id="da7a98e4-f3e7-4c0b-b26d-af93751ad919">
        <length>6</length>
        <embedded/>
        <type name="String"/>
        <text>This is the key of the machine used for the move.</text>
    </PrimAttribute>
    <PrimAttribute name="maxStackHeight" id="435ec59e-8018-49b9-8fef-614367e8f109">
        <embedded/>
        <type name="Integer"/>
        <text>USED INTERNALLY. Do NOT set.</text>
    </PrimAttribute>
    <PrimAttribute name="mode" id="1c7281be-321c-4a33-81ca-4f180cdbe6b6">
        <embedded/>
        <type name="Integer"/>
        <text>Real/Planned/Rehandle</text>
    </PrimAttribute>
    <PrimAttribute name="nextNumInStack" id="d67f4a69-0f0a-40e2-b20f-de53f388e979">
        <embedded/>
        <type name="Integer"/>
        <text>USED INTERNALLY. Do NOT set.</text>
    </PrimAttribute>
    <PrimAttribute name="nextStackHeight" id="14e15409-3bce-4ee7-9c0b-0c92c8f36c5c">
        <embedded/>
        <type name="Integer"/>
        <text>USED INTERNALLY. Do NOT set.</text>
    </PrimAttribute>
    <ImplicitInverseRef name="nextTargetLC" id="b8dd740b-13b5-4acd-9568-04563b483da9">
        <embedded/>
        <type name="CM_LocationsController"/>
        <text>USED INTERNALLY. Do NOT set.</text>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="nextTopTI" id="e81c9144-b0c9-4c62-8914-398903eed166">
        <embedded/>
        <type name="CM_TrackedItem"/>
        <text>USED INTERNALLY. Do NOT set.</text>
    </ImplicitInverseRef>
    <PrimAttribute name="noCharge" id="764f41a5-9bb7-4909-a608-f17e09e838ac">
        <embedded/>
        <type name="Boolean"/>
        <text>This indicates that the move will not be charged for.</text>
    </PrimAttribute>
    <PrimAttribute name="numInStack" id="b77d4440-cff8-4a39-8366-47eafe34437e">
        <embedded/>
        <type name="Integer"/>
        <text>USED INTERNALLY. Do NOT set.</text>
    </PrimAttribute>
    <PrimAttribute name="operational" id="ba1bab36-6d29-4587-8496-793259fd6b15">
        <embedded/>
        <type name="Boolean"/>
        <text>This move forms part of a Job Operation.</text>
    </PrimAttribute>
    <PrimAttribute name="rehandle" id="46497bf1-bb11-4820-a037-1ae4a7155e10">
        <embedded/>
        <type name="Boolean"/>
        <text>This indicates that this move is a rehandle move.</text>
    </PrimAttribute>
    <PrimAttribute name="sourceHeight" id="c4e78b56-7610-4c6f-86c5-249ef9c1e3fe">
        <embedded/>
        <type name="Integer"/>
        <text>USED INTERNALLY. Do NOT set.</text>
    </PrimAttribute>
    <PrimAttribute name="sourceLocn" id="49ee2524-68f2-415a-bffa-79e66f6603b8">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>This returns the source location of the move.</text>
    </PrimAttribute>
    <ImplicitInverseRef name="sourceLocnOid" id="35cc0f34-9eae-442e-a7e7-f3c124313d8a">
        <embedded/>
        <type name="CM_LocationsController"/>
        <text>USED INTERNALLY. Do NOT set.</text>
    </ImplicitInverseRef>
    <PrimAttribute name="stackHeight" id="b4a7fabc-2e72-4b1b-b8ad-108b3034973a">
        <embedded/>
        <type name="Integer"/>
        <text>USED INTERNALLY. Do NOT set.</text>
    </PrimAttribute>
    <PrimAttribute name="supplementary" id="2740ec8f-62fe-40f1-9dee-45ff59a5ee24">
        <embedded/>
        <type name="Boolean"/>
        <text>This indicates that this is the second or later part of a move multi-location move, required for BBLK.</text>
    </PrimAttribute>
    <PrimAttribute name="systemInitiated" id="b93e7146-7f3b-46c0-884b-87fef03d51e5">
        <embedded/>
        <type name="Boolean"/>
        <text>This indicates that this is a system initiated move, this is used for internal processes.</text>
    </PrimAttribute>
    <PrimAttribute name="targetBayPlansIndex" id="70b220f1-e98c-4675-a05f-a848709bbcb6">
        <embedded/>
        <type name="Integer"/>
        <text>This is the index of the target bayplans to use for the move, if applicable. 
For all but EDI operations it is 0.</text>
    </PrimAttribute>
    <PrimAttribute name="targetHeight" id="e885944b-b96a-4393-83dd-f40022c82caa">
        <embedded/>
        <type name="Integer"/>
        <text>USED INTERNALLY. Do NOT set.</text>
    </PrimAttribute>
    <PrimAttribute name="targetLocn" id="99d115a4-ce63-497d-8cf6-3114b24a648e">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>This is a string representing the target for the move.</text>
    </PrimAttribute>
    <ImplicitInverseRef name="targetLocnOid" id="a86dc526-5360-4d24-8f11-df75a692f063">
        <embedded/>
        <type name="CM_LocationsController"/>
        <text>The move sets this with the Oid of the place we moved the TI to.
USED INTERNALLY. Do NOT set.</text>
    </ImplicitInverseRef>
    <PrimAttribute name="tbaPatch" id="34407897-81d2-4f7e-be83-dd810c99ee9e">
        <embedded/>
        <type name="Boolean"/>
        <text>This indicates that this move is part of a tbaPatch process.</text>
    </PrimAttribute>
    <ImplicitInverseRef name="topTI" id="898be9e3-4150-4c19-af98-cd675567e895">
        <embedded/>
        <type name="CM_TrackedItem"/>
        <text>USED INTERNALLY. Do NOT set.</text>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="trackedItem" id="08312aac-2950-4949-a281-efcfc377b899">
        <embedded/>
        <type name="CM_TrackedItem"/>
        <text>This is the trackeditem being moved.</text>
    </ImplicitInverseRef>
    <PrimAttribute name="unplan" id="f1de680f-0bd4-45e1-824f-e437821ea33c">
        <embedded/>
        <type name="Boolean"/>
        <text>This indicates that this move is part of an unplan process.</text>
    </PrimAttribute>
    <PrimAttribute name="urNumber" id="db2de515-1606-44b5-ace4-6d3d8399fc83">
        <length>8</length>
        <embedded/>
        <type name="String"/>
        <text>This is the user request number to associate with the move.</text>
    </PrimAttribute>
    <PrimAttribute name="userId" id="20d02c43-b63f-4589-9ac6-641799105568">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <text>This is the user code of the user requesting the move.</text>
    </PrimAttribute>
    <PrimAttribute name="validateOnly" id="c2d0c0bd-32a8-4021-8f6a-4f69d7abd557">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="warningCode" id="017e48a0-a12b-4819-bf78-f391f9df7f69">
        <embedded/>
        <type name="Integer"/>
        <text>USED INTERNALLY. Do NOT set.</text>
    </PrimAttribute>
    <PrimAttribute name="westernView" id="e7b3ed86-b544-4a3c-b8aa-9eaa0f20eb55">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
</Class>
