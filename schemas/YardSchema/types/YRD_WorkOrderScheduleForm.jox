    <JadeMethod name="loadDataForFirstTime" id="c18d43c9-c149-4ef0-b1d3-8ab4f58395da">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// -----------------------------------------------------------------------------
// Created:		13 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	inheritMethod();

	self.tblSchedule.rows := self.tblSchedule.fixedRows;
	self.tblSchedule.columns := self.tblSchedule.fixedColumns;
	self.tblSchedule.backColor := self.colorControlBack;
	
	self.loadSchedule();

	self.tblSummary.backColor := self.colorControlBack;
	
	self.loadSummary();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadSchedule" id="e09b7d93-ed48-4db4-8416-6285bbc9013a">
        <updating/>
        <source>loadSchedule() updating;
// -----------------------------------------------------------------------------
// Created:		13 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// -----------------------------------------------------------------------------

vars
	col, row : Integer;
	colPlanned : Integer;
	dateTime : TimeStamp;
	lastDT : TimeStamp;
	lastMonth,
	lastDay : String;
	monthText,
	dayText,
	tmpDayText	: String;	
	numberActioned : Integer;
	schedule,
	proxySchedule: CM_WorkOrderSchedule;
	scheduleColl : CM_WorkOrderScheduleDict;
	selectedTask : CM_WorkOrderDtl;
	tbl : CM_BaseTable;
	woDetail : CM_WorkOrderDtl;
	localDateTime : TimeStamp;
	localScheduleDT : TimeStamp;
begin
	create scheduleColl transient;

	tbl := self.tblSchedule;

	//  End existing notifications for table
	
	self.timerClear();
	
	col := tbl.fixedColumns + 1;
	while col &lt; tbl.columns do
		woDetail := self.getWorkOrderTIDtl(col);
		self.endNotification(woDetail, self.myTerminal.getTerminalEvent(Event_WorkOrderSchedule_Update));
		self.endNotification(woDetail, Object_Delete_Event);
		col := col + self.TaskColumns;
	endwhile;
	
	//  Initialise and set up headings
	//27 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.currentTS := self.systemToLocalTime(app.actualTimeServer());
	
	tbl.clearAllSelected();
	tbl.rows := tbl.fixedRows;
	tbl.columns := tbl.fixedColumns;

	tbl.gridLines := true;
	tbl.accessMode := Table.AccessMode_Cell;
	tbl.selectMode := Table.SelectMode_Single;
	tbl.tabKey := J_key_Tab;

	tbl.accessColumn(2).width := ((self.widthDTColumn/3)*2).Integer;
	tbl.accessColumn(3).width := (self.widthDTColumn/3).Integer;
	tbl.accessCell(1,1).gridBottom := false;

	tbl.columns := tbl.columns + 1;
	tbl.accessColumn(tbl.columns).visible := true;
	
	
	tbl.accessCell(1, 1).mergeCells := Table.MergeCells_Merge;
	tbl.accessCell(2, 1).mergeCells := Table.MergeCells_Merge;	
	
	selectedTask := self.cmbTask.listObject.CM_WorkOrderDtl;
	
	foreach woDetail in self.myWorkOrder.allWoDtls
	where woDetail = selectedTask or selectedTask = null do
		colPlanned := tbl.columns;
		tbl.columns := tbl.columns + self.TaskColumns;

		tbl.accessColumn(colPlanned).alignment := Table.Alignment_Center_Middle;
		tbl.accessColumn(colPlanned + 1).alignment := Table.Alignment_Center_Middle;
		tbl.accessColumn(colPlanned + 2).alignment := Table.Alignment_Center_Middle;
		tbl.accessColumn(colPlanned + 3).alignment := Table.Alignment_Center_Middle;// Alignment_Center_Middle;
				
		tbl.accessCell(1, colPlanned).mergeCells := Table.MergeCells_Merge;
		
		if woDetail.requiredByDT &lt;&gt; null then
			tbl.accessedCell.text := woDetail.getDisplayString(true) &amp; CrLf &amp;  'Required by : ' &amp; woDetail.requiredByDT.asStringJMT() ;
		else
			tbl.accessedCell.text := woDetail.getDisplayString(true);
		endif;
		
		
		tbl.accessCell(1, colPlanned + 4).mergeCells := Table.MergeCells_NotAvailable;

		tbl.accessCell(2, colPlanned).text := app.getErrorString(Planned);
		tbl.accessedCell.backColor := self.colorHeadingColumn;
		tbl.accessCell(2, colPlanned+1).text := app.getErrorString(Planned) &amp; CrLf &amp; "(" &amp; app.getErrorString(Not_Actioned).toLower() &amp; ")";
		tbl.accessedCell.backColor := self.colorHeadingColumn;
		//tbl.accessCell(2, colPlanned+2).text := app.getErrorString(Actioned) &amp; "/" &amp; CrLf &amp; app.getErrorString(Complete);
		//tbl.accessedCell.backColor := self.colorHeadingColumn;
		tbl.accessCell(2, colPlanned+2).text := app.getErrorString(Actioned) ;
		tbl.accessedCell.backColor := self.colorHeadingColumn;
		
		tbl.accessCell(2, colPlanned+3).text := app.getErrorString(Complete);
		tbl.accessedCell.backColor := self.colorHeadingColumn;
		
		tbl.accessColumn(colPlanned).itemObject := woDetail;
		tbl.accessedColumn.width := self.widthValueColumn;
		tbl.accessColumn(colPlanned + 1).width := self.widthValueColumn;
		tbl.accessColumn(colPlanned + 2).width := self.widthValueColumn;
		tbl.accessColumn(colPlanned + 3).width := self.widthValueColumn;
		
		
		//foreach schedule in woDetail.CM_WorkOrderTIDtl.allSchedules do
		//	scheduleColl.add(schedule);
		//endforeach;
		// RJS - just copy this (16 June 2010)
		woDetail.CM_WorkOrderTIDtl.allSchedules.copy(scheduleColl);
		
	endforeach;
	
	tbl.accessColumn(tbl.columns).visible := false;


	//  Load rows for entered date/times
	
	foreach dateTime in self.allDateTimes do
		localDateTime := self.localToSystemTime( dateTime);
		if scheduleColl[localDateTime, self.myWorkOrder] = null then  //no schedule found for this date time
		
		foreach woDetail in self.myWorkOrder.allWoDtls do
			//want to create a new schedule for each task for the date
			
			create proxySchedule transient;
			proxySchedule.setProxy( 0, localDateTime);
			app.myTrxCA.trxCreateWorkOrderSchedule(proxySchedule, schedule,woDetail.CM_WorkOrderTIDtl, app.myPassport);

			scheduleColl.add(schedule);
		endforeach;
		
			//this adds  'empty' rows'
			/*
			row := tbl.rows;
			while true do
				if row &lt;= tbl.fixedRows or self.getScheduledDT(row) &lt; dateTime then
					self.addRowToSchedule(dateTime, row + 1);
					break;
				endif;
				row := row - 1;
			endwhile;
			*/
			// which we dont want to do now.
			
		endif;
	endforeach;
	
	//  Load schedule details
	
	lastDT := null;
	
	foreach schedule in scheduleColl do
		localScheduleDT := self.systemToLocalTime(schedule.scheduledDT);//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
		if localScheduleDT &lt;&gt; lastDT then
			lastDT := localScheduleDT;
	
			if lastMonth &lt;&gt;  lastDT.date.monthName() then
				lastMonth := lastDT.date.monthName();
				monthText := lastMonth;
			else
				monthText := '';			
			endif;
			
			tmpDayText :=  lastDT.date.dayName()[1:3] &amp; ' ' &amp; lastDT.date.day.asStringJMT();
			
			if lastDay &lt;&gt;  tmpDayText then
				lastDay := tmpDayText;
				dayText := lastDay;
			else
				dayText := '';			
			endif;		
			
			self.addRowToSchedule(lastDT,monthText  , dayText , lastDT.time.asStringJMT()  , 0);
		endif;
		col := tbl.fixedColumns + 1;
		while col &lt; tbl.columns do
			if self.getWorkOrderTIDtl(col) = schedule.myParent then
				self.displaySchedule(schedule, tbl.rows, col);
				break;
			endif;
			col := col + self.TaskColumns;
		endwhile;
	endforeach;


	//  Set up notifications for table
	
	col := tbl.fixedColumns + 1;
	while col &lt; tbl.columns do
		woDetail := self.getWorkOrderTIDtl(col);
		self.beginNotification(woDetail, Object_Delete_Event, Response_Continuous, 0);
		self.beginNotification(woDetail, self.myTerminal.getTerminalEvent(Event_WorkOrderSchedule_Update), Response_Continuous, 0);
		col := col + self.TaskColumns;
	endwhile;
	
	self.timerSetup();
	
epilog
	delete scheduleColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadSummary" id="3c63ecf0-3400-40cf-bbc4-b632f531fce7">
        <updating/>
        <source>loadSummary() updating;
// -----------------------------------------------------------------------------
// Created:		18 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	col, row : Integer;
	tbl : CM_BaseTable;
	woDetail : CM_WorkOrderTIDtl;
	
begin
	tbl := self.tblSummary;
	
	tbl.rows := 0;
	tbl.fixedColumns := self.tblSchedule.fixedColumns;

	tbl.gridLines := true;

	tbl.addItem( app.getErrorString(Planned) );
	tbl.addItem( app.getErrorString(Planned) &amp; " (" &amp; app.getErrorString(Not_Actioned).toLower() &amp; ")" );
	tbl.addItem( app.getErrorString(Planned_still_to_do) );
	tbl.addItem( app.getErrorString(Actioned));
	tbl.addItem( app.getErrorString(Complete) );
	tbl.addItem( app.getErrorString(Required) );
	tbl.addItem( app.getErrorString(Still_to_Plan) );
	
	tbl.accessColumn(1).width := (self.widthDTColumn/3).Integer;
	tbl.accessColumn(2).width := (self.widthDTColumn/3).Integer;
	tbl.accessColumn(3).width := (self.widthDTColumn/3).Integer;
	
	tbl.accessCell(1, 1).mergeCells := Table.MergeCells_Merge;
	tbl.accessCell(2, 1).mergeCells := Table.MergeCells_Merge;	
	tbl.accessCell(3, 1).mergeCells := Table.MergeCells_Merge;	
	tbl.accessCell(4, 1).mergeCells := Table.MergeCells_Merge;	
	tbl.accessCell(5, 1).mergeCells := Table.MergeCells_Merge;	
	tbl.accessCell(6, 1).mergeCells := Table.MergeCells_Merge;	
	tbl.accessCell(7, 1).mergeCells := Table.MergeCells_Merge;	
	
	tbl.columns := tblSchedule.columns - 1;
	
	col := tbl.fixedColumns;
	
	while col &lt; tbl.columns do
		col := col + 1;
		woDetail := self.getWorkOrderTIDtl(col);
		tbl.accessColumn(col).width := self.widthValueColumn;
		tbl.accessedColumn.alignment := Table.Alignment_Center_Middle;
		foreach row in 1 to tbl.rows do
			tbl.accessCell(row,col).gridRight := false;
		endforeach;
		col := col + 1;
		tbl.accessColumn(col).width := self.widthValueColumn;
		foreach row in 1 to tbl.rows do
			tbl.accessCell(row,col).gridRight := false;
		endforeach;
		col := col + 1;
		tbl.accessColumn(col).width := self.widthValueColumn;
		foreach row in 1 to tbl.rows do
			tbl.accessCell(row,col).gridRight := false;
		endforeach;		
		col := col + 1;
		tbl.accessColumn(col).width := self.widthValueColumn;
		self.updateSummary(woDetail);
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mnuActionAll_click" id="9647078b-dd10-442e-95d1-7b43beb195da">
