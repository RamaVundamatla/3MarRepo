    <JadeMethod name="utlCreateHMSMovement" id="63227ba7-310a-4f12-8faf-492936fe1173">
        <updating/>
        <source>utlCreateHMSMovement(_pxyHMSMovement : HMS_Movement input; _realHMSMovement : HMS_Movement output; _calculateSteamingTime : Boolean; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
//-----------------------------------------
vars
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	app.myValCA.valHMSObject(_pxyHMSMovement , _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _realHMSMovement as _pxyHMSMovement.class persistent;
	_realHMSMovement.setForCreateMovement(_pxyHMSMovement, null, _calculateSteamingTime, _passport );

	// OK to call this from here as we are only creating an 
	// individual movement.  If ever changed to be called
	// to create multiple movements then will need to change
	_realHMSMovement.maintainLinkedList();
	
	//21.09.2020 cnwma1 TFS #49906
	if _passport.isOpsViewEnabled(_realHMSMovement.getMyTerminal()) then
		_realHMSMovement.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,
												 BGP_OpsViewWSRequest.OPS_TYPE_HMSMOVE,
												 _realHMSMovement);
	endif;
	//21.09.2020 cnwma1 TFS #49906
end;</source>
        <Parameter name="_pxyHMSMovement" type="HMS_Movement" usage="input"/>
        <Parameter name="_realHMSMovement" type="HMS_Movement" usage="output"/>
        <Parameter name="_calculateSteamingTime" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
