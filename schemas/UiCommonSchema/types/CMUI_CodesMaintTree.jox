    <JadeMethod name="addChild" id="fccec054-5175-4358-9749-dd416e942947">
        <updating/>
        <source>addChild() : Boolean updating;
// -----------------------------------------------------------------------------
// Created:		11 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	current, child  : SOP_ViewModelObject;
	x : CMUI_ViewModelObject;
	index : Integer;
begin
	current := self.myCurrentVMObject;
	index := self.allVMObjects.indexOf(current);
	child := current.createChild();
	child.initializeMe(child.myObject, current.index + 1, current);
	child.myForm := self;
	self.allVMObjects.insert(index + 1, child);
	self.showTree(self.currentGroupType, false);
	self.lstData.listIndex := index + 1;
	self.setMyCurrentVMObject( child); //epr par 16841 17/7/08

	return child &lt;&gt; null;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addPeer" id="b664461d-0b9e-4a49-a108-e0aed8ac166d">
        <updating/>
        <source>addPeer() : Boolean updating;
// -----------------------------------------------------------------------------
// Created:		19 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	current, newVM	: SOP_ViewModelObject;
	index 			: Integer;
	class			: Class;
begin
	current := self.myCurrentVMObject;
	index := self.allVMObjects.indexOf(current);
	if current = null or not global.isValidObject(current) then
		class := self.getNewPeerClass;
		newVM := self.createTopLevelObject(class);
		newVM.initializeMe(newVM.myObject, 1, null);
		index := 1;
		// create new top level object.
	else	
		newVM := current.createPeer();
		newVM.initializeMe(newVM.myObject, current.index, current.myParent);
	endif;
	
	newVM.myForm := self;
	newVM.allVMObjectsInsert(index, self.allVMObjects);
	self.showTree(self.currentGroupType, false);
	self.lstData.listIndex := index;
	self.setMyCurrentVMObject(self.allVMObjects[index].SOP_ViewModelObject); //epr par 16841 17/7/08
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="allowCodeGroupType" id="c8fec3e4-ca0f-4cf0-9ee2-b8083ace0d72">
        <source>allowCodeGroupType(_canDoLogs, _canDoContainers : Boolean; _codeGroupType : Integer) : Boolean;
//-----------------------------------------
// Created: September 2004 By: cnwgd1
//-----------------------------------------
vars

begin
		
	if _codeGroupType = CodeGroup_LoadingContractor
	or _codeGroupType = CodeGroup_LogSpecs
	or _codeGroupType = CodeGroup_LoggingContractor
	or _codeGroupType = CodeGroup_SourceLocation then
		if _canDoLogs then
			return true;
		else
			return false;
		endif;
	endif;

	if _codeGroupType = CodeGroup_AvailabilityGrade then
	// CCMS 1286 DVB Ready do go
	//	return false; //CCMS1286 Not implemented yet, remove when quote accepted
		
		if _canDoContainers then
			return true;
		else
			return false;			
		endif;
	endif;				
	
	// was returing true regardless of type
	return false;
	
end;</source>
        <Parameter name="_canDoLogs" type="Boolean"/>
        <Parameter name="_canDoContainers" type="Boolean"/>
        <Parameter name="_codeGroupType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
