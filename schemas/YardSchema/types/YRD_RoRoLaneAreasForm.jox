    <JadeMethod name="getData" id="fe0212a1-c2c0-4d38-8456-c3b815b0d413">
        <updating/>
        <source>getData(pText: String input; pType: Integer input) updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		Passback method called from CMUI_GetData form
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------

vars
	loadStateSet : Boolean;
	aProxyTI : CM_TrackedItem;
	result : Boolean;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin

	if pType = self.GetData_Remarks then
		app.cmsBeginLoad(loadStateSet);
		aProxyTI := self.mnuRemarks.userObject.CM_TrackedItem.pxyCreateUpdateProxy;
		app.cmsEndLoad(loadStateSet);
		
		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateTIRemarks(aProxyTI, pText, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Grid Area', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return;
			
		endwhile;
	
	endif;
	
epilog
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	if aProxyTI &lt;&gt; null then
		delete aProxyTI;
	endif;
end;</source>
        <Parameter name="pText" type="String" usage="input"/>
        <Parameter name="pType" type="Integer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayMode" id="7c61070d-6bdc-48e1-b7ca-2d23fcb49006">
        <source>getDisplayMode() : Integer;
// ---------------------------------------------------------------------------
