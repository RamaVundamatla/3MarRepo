    <JadeMethod name="lbHandHelds_click" id="6d65768f-8fde-4fdc-8b06-5a2e73763760">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lbHandHelds_click(listbox: ListBox input) updating;
//--------------------------------------------------------------
//Created: 3 October 2001 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.myCurrentDevice := self.lbHandHelds.listObject.CM_RTDeviceHandHeld;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lbHandHelds_displayEntry" id="e4a32393-dfc6-46a8-b0c7-672ffce5ffee">
        <controlMethod name="ListBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lbHandHelds_displayEntry(listbox: ListBox input; obj: Any; lstIndex: Integer):String updating;
//----------------------------------------------
//Created: 3 October 2001 By: cnwgd1
//----------------------------------------------
vars
	hh 	: CM_RTDeviceHandHeld;
	str	: String;
begin

	hh := obj.CM_RTDeviceHandHeld;
	str :=  " " &amp; "ID: " &amp; hh.id;
	
	if hh.status = DEVICE_STATUS_INSESSION then
		str := str &amp; "  &lt;In Session&gt;";
	elseif
		hh.status = DEVICE_STATUS_DISCONN then
		str := str &amp; "  &lt;Disconnected&gt;";
	else
		return str;
	endif;
	
	return str;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="lbHandHelds_mouseDown" id="9536dd01-7f33-4db5-b95d-cd5c8c59f507">
        <controlMethod name="ListBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lbHandHelds_mouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
