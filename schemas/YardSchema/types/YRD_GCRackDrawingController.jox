    <JadeMethod name="selectLocationBlock" id="7e32f78a-c77c-4ba5-a056-c4358e2fff90">
        <updating/>
        <source>selectLocationBlock(_toLocation: Object) updating, protected;
/*
Purpose:			 // PAR 32308
Date		Who		Reason
02 September 2013	cnwab1	Initial creation
*/

vars
	fromLocation : CM_IrregularBlockController;
	location: CM_LocationsController;
	region: PointArray;
	topLeft, bottomRight: Point;
	x1, y1, x2, y2 : Integer;
	key1, key2 : Point ;
begin
	fromLocation := self.allSelectedObjects.last().CM_IrregularBlockController;
	
	self.allGridObjects.findObjectInDictGetXY(fromLocation,key1, key2);

	x1 := key1.x+2;
	y1 := key1.y+2;
	
	self.allGridObjects.findObjectInDictGetXY(_toLocation,key1, key2);
	x2 := key2.x-2;
	y2 := key2.y-2;

	self.selectBlockOfObjectsFromXYs(CM_IrregularBlockController, x1, y1, x2, y2);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_toLocation" type="Object"/>
    </JadeMethod>
    <JadeMethod name="userNotificationAreaUpdate" id="dd1b0246-efca-43c9-b2c5-cdb70a80fd1f">
        <updating/>
        <source>userNotificationAreaUpdate(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Purpose:			
Date		Who		Reason
19 September 2013	cnwab1	Initial creation
*/

vars
	anLC : CM_RackShelfController;
	event,idx		: Integer;
	breakOut, gotException : Boolean;
	aTI : CM_TrackedItem;
	selForm : CMUI_Selector;
	aMove : CM_Move;
	src : String;
	tX1, tY1, tX2, tY2, tmp1 : Real;

begin
	on Exception do app.handleDeletedObject(exception, anLC, gotException);		// PAR #16814
	if userInfo.isKindOf(CM_RackShelfController) then
		anLC := userInfo.CM_RackShelfController;
	endif;

	if anLC = null then
		return;
	endif;

	if eventType = self.noteTAMove or eventType = self.noteTIUpdate then
		// ###########################
		// Check to see if this location controller is on our form
		self.drawFromNote := true;
		if self.useSelectorObjects then
			foreach aTI in anLC.allTrackedItems do
				self.userNotificationHandleSelector(aTI,breakOut);
			endforeach;
		endif;
		
		self.drawObject(self.myDrawingFrame, anLC);
		
		if gotException then
			// Exception handler resumes here if anLC was invalid.
			return;
		endif;
	endif;
epilog
	self.drawFromNote := false;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationYardAllocation" id="22e3f803-ac76-447d-9ead-2145cb2e08e0">
        <updating/>
        <source>userNotificationYardAllocation(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Purpose:			
Date				Who			Reason
SEPT 2013		CNWAB1		Initial creation
*/

vars
	yalloc 			: CM_YardAllocation;
	anObject 		: Object;
	invalidObject	: Boolean;
	
begin
	if self.myTerminalArea = null then
		return;
	endif;
	anObject := userInfo.Object;

//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1.' &amp; anObject.String &amp; " " &amp; eventType.String);
	if anObject &lt;&gt; null then
		yalloc := anObject.CM_YardAllocation;
		
		on Exception do app.handleDeletedObject(exception, yalloc, invalidObject);	// PAR #16814

		if eventType = self.myTerminal.getTerminalEvent(Event_YardAllocationDelete) // TFS 43424
		or eventType = self.myTerminal.getTerminalEvent(Event_YardAllocationCreate) // TFS 43424
		or eventType = self.myTerminal.getTerminalEvent(Event_YardAllocationUpdate) then
			self.drawSelf(true);
			if eventType = self.myTerminal.getTerminalEvent(Event_YardAllocationDelete) then // TFS 43424
				if self.myDrawingAttrController.allYardAllocations.includes(yalloc) then // TFS 43424
					self.myDrawingAttrController.allYardAllocations.remove(yalloc); // TFS 43424
				endif;
			endif;
		endif;

		if  self.myGCAreaEnquiryForm  &lt;&gt; null then
			self.myGCAreaEnquiryForm.setYardAllocLegend();
		endif;
		
	
	endif;
epilog
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
