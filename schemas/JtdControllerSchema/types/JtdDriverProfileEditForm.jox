    </JadeMethod>
    <JadeMethod name="lstDrvProfiles_keyDown" id="75acc7d3-c240-4cbb-aa63-781733475a90">
        <controlMethod name="ListBox::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstDrvProfiles_keyDown(listbox: ListBox input; keyCode: Integer io; shift: Integer) updating;

begin
	if keyCode = 46 then // delete key
		self.jtdDeleteSelectedDriverProfile;
		keyCode := 0;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
