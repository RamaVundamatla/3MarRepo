    <DbClassMap file="_usergui"/>
    <Constant name="DEFAULT_HEIGHT" id="107059d8-f592-4ff0-8fd6-b3808838a4fc">
        <source>2</source>
        <type name="Integer"/>
    </Constant>
    <JadeMethod name="create" id="6b35c2fc-6fd0-4e8e-a4cc-0c90819bf741">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		13 February 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.borderStyle		:=	0;
	self.caption			:=	null;
	self.height				:=	self.DEFAULT_HEIGHT;
	self.bevelColor			:=	self.getSystemColor(Color_3DHighlight);
	self.bevelInner			:=	0;
	self.bevelInnerWidth	:=	0;
	self.bevelOuter			:=	1;
	self.bevelOuterWidth	:=	1;
	self.bevelShadowColor	:=	self.getSystemColor(Color_3DDkShadow);
	self.boundaryBrush		:=	0;
	self.boundaryWidth		:=	0;
	self.boundaryColor		:=	self.getSystemColor(Color_3DFace);
	self.show3D				:=	Control.Show3D_Use3D;
end;</source>
    </JadeMethod>
    <JadeMethod name="height" id="fb305780-0b9e-41e6-b5f3-839e2eddd453">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>height(set: Boolean; value: Real io) updating, mapping;
// --------------------------------------------------------------------------------
// Created:		13 February 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (set) then
		value	:=	self.DEFAULT_HEIGHT;
		inheritMethod(set, value);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="move" id="a58304e7-cc29-45cb-939e-1c770d85c3d4">
        <source>move(x: Real; y: Real; width: Real; height: Real);
// --------------------------------------------------------------------------------
// Created:		13 February 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(x, y, width, self.DEFAULT_HEIGHT);
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="width" type="Real"/>
        <Parameter name="height" type="Real"/>
    </JadeMethod>
