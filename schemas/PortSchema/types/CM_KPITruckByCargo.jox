<Class name="CM_KPITruckByCargo" id="1bcd6711-140f-41e4-8e63-575a5bb6eb22">
    <superclass name="CM_KPITruckByCarrierDay"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>


One object for each cargo summary code for each day.

summary codes as used on the summary planning query on the load list e.g.

 20 GEN
 40 INT
 40 INT HC

</text>
    <DbClassMap file="statistic"/>
    <ImplicitInverseRef name="allCargo" id="0359c8a0-2796-472e-96b5-21cc94698e81">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="allKPIDetailsCargo" id="5bf42fb1-ba76-4076-901f-e86b4566aa23">
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_KPIByTypeCodeTS"/>
        <access>readonly</access>
        <Inverse name="CM_KPITruckDetail::myKPITruckCargo"/>
    </ExplicitInverseRef>
    <JadeMethod name="accumulate" id="e393f13f-2742-48b1-ba77-00ddda54c014">
        <updating/>
        <source>accumulate(kpi: CM_KPITruckByCargo; includeDetail: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Nov 2025	navbs1	Initial creation Story MTN-36661: MTN | KPI REST API - Truck Turn Around

*/

vars
	cargo 			: CM_TrackedItem;
	invalidObject	:	Boolean;
begin
	inheritMethod(kpi, includeDetail);
	on Exception do app.handleDeletedObject(exception, cargo, invalidObject);
	if includeDetail then 
		 foreach cargo in kpi.allCargo do 
			cargo.edition;
			if invalidObject then
				invalidObject := false;
				continue;
			endif;
			self.allCargo.tryAdd(cargo);
		 endforeach;	
	endif;
	on Exception do null;

epilog

end;</source>
        <Parameter name="kpi" type="CM_KPITruckByCargo"/>
        <Parameter name="includeDetail" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addTI" id="20dfd76f-811d-4a1f-a8ef-d335c854dd7e">
        <source>addTI(_ti : CM_TrackedItem );
// ---------------------------------------------------------------------------
// Created:		14 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.allCargo.addNoDuplicates(_ti, false);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
