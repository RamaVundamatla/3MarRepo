    <JadeMethod name="trxTestMessageUpdate" id="e3d902b6-de19-4cea-83bc-e7bcd6e00f0b">
        <updating/>
        <source>trxTestMessageUpdate(pTestMessageToUpdate:CnEcWebTestMessage input;
