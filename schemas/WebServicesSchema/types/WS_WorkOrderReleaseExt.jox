<Class name="WS_WorkOrderReleaseExt" id="95c31a0a-e180-46a3-a854-788ef53fcfa3">
    <superclass name="WS_WorkOrderDetail"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="releaseRequestNum" id="6c603926-7a87-4f17-831e-4c5cbfdccdd5">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="releaseRequestOid" id="08ef0c7f-627d-4112-b4eb-b20e13579b09">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="releaseWorkOrderOid" id="9c83b8bf-b66e-4559-9843-f46b6668a5f2">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="createProxyWorkOrder" id="62207aa4-8f62-4b2b-b3c5-cb92bf499d93">
        <source>createProxyWorkOrder(): CM_WorkOrderDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2019	jlgndl1	Initial creation	TFS 43405

*/

vars

	pxyWorkOrder : CM_WodReleaseExtension;

begin

	create pxyWorkOrder transient;
		
	return pxyWorkOrder;
	
epilog

end;</source>
        <ReturnType type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="abd563f8-120e-4156-bd6b-ffd53b57c7d1">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodReleaseExtension) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2019	jlgndl1	Initial creation	TFS 43405

*/

vars

begin
	inheritMethod(_object);
	if _object.getMyReleaseRequest &lt;&gt; null then
		self.releaseRequestOid := _object.getMyReleaseRequest.getOidAsString;
		self.releaseRequestNum := _object.getMyReleaseRequest.code;
	endif;
	if _object.myReleaseWorkOrder &lt;&gt; null then
		self.releaseWorkOrderOid := _object.myReleaseWorkOrder.getOidAsString;
	endif;
	
	self.setProxyToDoTasks(_object);
	
	
epilog

end;</source>
        <Parameter name="_object" type="CM_WodReleaseExtension"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="5a7a32bc-5af0-407b-8761-4b64f8e36c6e">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WorkOrderTIDtl input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2019	jlgndl1	Initial creation	TFS 43405

*/

vars

	workOrder : CM_WorkOrder;
	workOrderRelease  : CM_WodRelease;
	
begin

	inheritMethod(_pxyWorkOrder);
	workOrder := app.myPassport.getObjectOfTypeFromOid(self.releaseWorkOrderOid,CM_WorkOrder).CM_WorkOrder;
	if workOrder &lt;&gt; null then
		if workOrder.isWorkOrderForRelease then
			workOrderRelease := workOrder.allWoDtls.first.CM_WodRelease;
		endif;
		if workOrderRelease &lt;&gt; null then
			_pxyWorkOrder.CM_WodReleaseExtension.setProxyWodReleaseExt(workOrderRelease);
		endif;
	endif;
	
	self.updateProxyToDoTasks(_pxyWorkOrder);

		
epilog

end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrderTIDtl" usage="input"/>
    </JadeMethod>
</Class>
