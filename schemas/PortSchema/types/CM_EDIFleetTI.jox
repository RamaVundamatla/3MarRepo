    <JadeMethod name="verifyCargoTypeDescr" id="b14ca5fd-b893-472f-9ad5-1ff722efd1a3">
        <updating/>
        <source>verifyCargoTypeDescr() updating;

/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
04 August 2008	cnwrd1	Initial creation
10/9/09         JMH     MES / PAR21198  Don't want to have to rely on user using hook code.
*/

vars
	cargoTypeDict		: CM_CargoTypesByIdDict;
	cargoTypeObj		: CM_CargoType;
	loopCargoType		: CM_CargoType;
	fleetDesc  			: String;
	
begin
	cargoTypeDict := app.myRoot.allCargoTypesById;

	if self.cargoType &lt;&gt; null then 							// if they specify a cargo type it must be valid. This may have been populated from some hook code.
		cargoTypeObj := cargoTypeDict[self.cargoType];		// will default to a trailer if null
		if 	cargoTypeObj = null then 
			app.raiseCMException2(ERR_CARGO_FIELD, self.cargoTypeDescr, 'cargo type description', ETRow_CargoTypeDescr, self);
		endif;
		self.cargoTypeDescr 	:= cargoTypeObj.description;
	else	
		fleetDesc := self.cargoTypeDescr.toUpper;
		if fleetDesc = null then
			fleetDesc := self.description.toUpper;
		endif;
		if  fleetDesc.toUpper.cnContains('CONTAINER') then//special case - phuzzy lojic
			cargoTypeObj := cargoTypeDict[TI_CargoType_Container];
			self.cargoType 				:= cargoTypeObj.type;
			self.cargoTypeDescr 	:= cargoTypeObj.description;
			
		elseif fleetDesc &lt;&gt; null then 
			foreach loopCargoType in cargoTypeDict do
				if loopCargoType.description.toUpper.cnContains(fleetDesc) or
				   loopCargoType.abbreviation.toUpper.cnContains(fleetDesc) then
					self.cargoType 				:= loopCargoType.type;
					self.cargoTypeDescr 	:= loopCargoType.description;
					cargoTypeObj 				:= loopCargoType;
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	if cargoTypeObj &lt;&gt; null and cargoTypeObj.isNotAvailableForEntry then  //PAR 21733
		app.raiseCMException1(Cargo_type_marked_not_availabl, self.cargoTypeDescr, ETRow_CargoTypeDescr, self);
	endif;
	
epilog
	
end;</source>
    </JadeMethod>
