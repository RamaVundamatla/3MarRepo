    <JadeMethod name="doDelete" id="696d546d-3ff3-49bc-960d-bfe9f068f907">
        <updating/>
        <source>doDelete(pObj: CM_Object io) updating;
// ---------------------------------------------------------------------------
// Created:     17 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.myTrxDA.trxDeleteDataAccessController(pObj.CM_DataAccessController, app.myPassport);

end;</source>
        <Parameter name="pObj" type="CM_Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="218522f0-c93e-40ea-8a15-3cf707e354bf">
        <updating/>
        <source>doSave(): Boolean updating;

vars
	proxyDataAccess	: CM_DataAccessController;
	errObj		: CM_Error;
	idx			: Integer;
	tmpListBox	: ListBox;
	ignoreWarnings,
	rtnValue	: Boolean;
	
	theName		: String;
	includeNull,
	theNotInclude	: Boolean;
	theSet		: CM_ObjectSetActual;
	theForm : SOP_TableMaintForm;
begin
  theForm := self.myForm; 
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DataAccessController transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	proxyDataAccess := theForm.myProxyObject.CM_DataAccessController;
	
//	ignoreWarnings := tblInput1.getValueByName('ignoreWarnings').Boolean;

	theName 		:= theForm.txtName.text;
	theNotInclude	:= theForm.optDisallow.value;

	create theSet transient;
	theForm.mulSelect1.getSelected(theSet);
   
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateDataAccessController(theName, 
												theForm.myDataAccessClass, 
												theSet, 
												theNotInclude,
												theForm.chkIncludeNotSet.value, 
												theForm.myCurrentObject,
												app.myPassport);
												
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateDataAccessController(theForm.myCurrentObject.CM_DataAccessController, 
													theSet, 
													theNotInclude, 
													theForm.chkIncludeNotSet.value,
													app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return	app.myPassport.trxCompletedOK();

epilog
	delete theSet;	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
