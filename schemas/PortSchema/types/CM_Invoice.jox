    <JadeMethod name="setWebFields" id="3ea956e1-a989-49aa-bda0-9d2ab7d5caad">
        <updating/>
        <source>setWebFields(_extRef1: String; _dueDate: TimeStamp; _addressId: String; _alternateAddressId: String) updating;
/*

Purpose:

	A method to set the six external references for the TAS invoices

Parameters:			

	The string values the external references will be set to

Return Value:		

	None

Date		Who		Reason
06/06/2023	navcs2	ChangeRequest 56901: [58447]: TAS Invoicing Invoice Endpoint - JADE changes

*/

vars
	altAddress,
	billingAddress : CM_Address;
begin
	if _extRef1 &lt;&gt; null then 
		self.exportCurrencyCode := _extRef1;
	endif;
	
	self.dueDate := _dueDate;
	
	billingAddress := self.debtor.allAddressesByCode[_addressId];
	if billingAddress &lt;&gt; null then
		self.myBillingAddress := billingAddress;
	endif;
	
	altAddress := self.debtor.allAddressesByCode[_alternateAddressId];
	if altAddress &lt;&gt; null then
		self.myAlternativeAddress := altAddress;
	endif;
epilog

end;</source>
        <Parameter name="_extRef1" type="String"/>
        <Parameter name="_dueDate" type="TimeStamp"/>
        <Parameter name="_addressId" type="String"/>
        <Parameter name="_alternateAddressId" type="String"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="66d44d72-ef76-451b-95de-76c5ad8b8356">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// ---------------------------------------------------------------------------

vars
	propName	: String;

begin

	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName  = CM_Invoice::myVoyage.name or
		propName = CM_Invoice::exportedCount.name or
		propName = CM_Invoice::status.name or
		propName = CM_Invoice::myBillingAddress.name then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;



end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="transientInitialise" id="aeabf124-a683-48de-8583-3784497b7d06">
        <updating/>
        <source>transientInitialise(	_bank : CM_Bank;
						_invoiceType: CM_InvoiceDesc;
						_debtor : CM_Debtor;
						_paymentType : Integer 
						) updating;
// 14/04/2016   cnwjre1  from Milaha cash tests, create a separate transient invoice for transient invoice lines
vars
	dateTime					: TimeStamp;
begin
	self.bank := _bank;
	self.setMyInvoiceProcess( _bank.getMyInvoiceProcess ); // TFS 39618 PATCH 1
	self.sequenceNum := -1;			// keep out of range of real invoices
	self.debtor := _debtor;
	self.invoiceType := _invoiceType;
	
	self.paymentType := _paymentType; //10 Oct 2018	NDL	TFS 41281
	
	//self.status := CM_Invoice.INVOICE_OPEN;
	self.setStatus( CM_Invoice.INVOICE_OPEN );	//13 Jun 2018	NDL	TFS 39197
	dateTime := app.serverTimestampAtTrxStart;
	self.fromDT := dateTime;
	
epilog

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_paymentType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateCashRecSAP" id="4a9f0af0-2147-4e40-aa02-eea8e5493066">
        <source>updateCashRecSAP(_paymentStatus : Integer;_wsdl : String);

/*

Purpose:			
	
	WSDL 2.1 Pre-Billing: Update Pre-Invoice Status (Paid)
	PaymentType_PrePay
	
	WSDL 2.2: Post-Billing - Update Invoice Status (Paid)
	PaymentType_AutoCollection 
	PaymentType_PostPay
	
	37189.004 Send Release Hold and Debit for Auto-Collection Customer
	WSDL 1.2: Auto-Collection - Release Hold/Debit
	PaymentType_AutoCollection
		
Parameters:			

Return Value:		


Date		Who		Reason
04 October 2018	jlgma1	Bug 41186: PEL1 - SAP Integration - Unit Test issues
04 Dec     2018 cnwma1  Bug 42358: PEL1 -Estimation is not checking the Debtor payment type
03 Jan     2019 cnwma1  Bug 42441: PEL1 - Missing Estimation ID WSDL 1.2 - Autocollection
23 Jan     2019	cnwma1	ChangeRequest 42942: PEL1 - Container Services - SAP Process
*/


vars
	cashRec,
	pxyCashReceipt : CM_CashReceipt;
	cashRecMatched : ObjectArray;
	obj            : Object;
	msg            : String;
begin

	msg :=  method.qualifiedName    &amp; 
			' ' &amp; _wsdl 							  &amp;
			' ' &amp; "Update Cash Receipt Status :"      &amp; app.paymentStatusCashEnumToString(_paymentStatus).String &amp;
			' ' &amp; "Pre Invoice :"   				  &amp; self.exportCurrencyCode &amp;
			' ' &amp; "Payment Type:"   				  &amp; app.paymentTypeEnumToString(self.paymentType);
	app.writeLog(msg,LogINFO);
						
	if self.paymentType= PaymentType_None then
		return;
	endif;
	
	//23.01.2019 cnwma1 TFS #42942
	if self.paymentType = PaymentType_PrePay then
		if self.myCashReceipt &lt;&gt; null then
			cashRec := self.myCashReceipt;
			
			if cashRec.paymentStatus &lt;&gt; CM_CashReceipt.CREDIT_CHECK_APPROVED then
				return;
			endif;
			
			if _wsdl = BGP_SAPWSRequest.WSDL21 then
				if cashRec.paymentStatus = CM_CashReceipt.PAID then 					//Already Paid
					return;
				endif;
			elseif _wsdl = BGP_SAPWSRequest.WSDL111 then          
				if cashRec.paymentStatus = CM_CashReceipt.CREDIT_CANCEL_APPROVED then  //Already Cancelled
					return;
				endif;
			endif;
			
			msg := method.qualifiedName &amp; 
					' ' &amp; _wsdl 				   &amp;
					' ' &amp; "Update Payment Status"  &amp;
					' ' &amp; "CashReceipt :"   	   &amp; cashRec.externalInvoiceNumber &amp;
					' ' &amp; "Pre Invoice :"   	   &amp; self.exportCurrencyCode ;
			app.writeLog(msg,LogINFO);
			
			pxyCashReceipt := app.createUpdateProxy(cashRec).CM_CashReceipt;
			app.myTrxUA.trxUpdateCashRecPaymentStatus(pxyCashReceipt ,_paymentStatus,app.myPassport);
			
			if app.myPassport.hasErrors then
				msg :=  method.qualifiedName &amp; 
						' ' &amp; _wsdl 			&amp;
						' ' &amp; "CashReceipt :"   &amp; cashRec.externalInvoiceNumber &amp;
						' ' &amp; "ERRORS : "       &amp; app.myPassport.getErrorsAndWarningsAsString;
				app.writeLog(msg,LogINFO);
			endif;
		endif;
	else
		//03.01.2019 Bug #42441
		create cashRecMatched transient;
		self.findCashReceipts(cashRecMatched);
		if cashRecMatched.size &gt; 0 then
			foreach obj in cashRecMatched discreteLock do
				cashRec := obj.CM_CashReceipt;
				
				if cashRec.paymentStatus &lt;&gt; CM_CashReceipt.CREDIT_CHECK_APPROVED then
					continue;
				endif;
				
				if cashRec.paymentStatus &lt;&gt; CM_CashReceipt.PAID then
					msg :=  method.qualifiedName &amp; 
							' ' &amp; _wsdl 				   &amp;
							' ' &amp; "Update Payment Status"  &amp;
							' ' &amp; "CashReceipt :"   	   &amp; cashRec.externalInvoiceNumber &amp;
							' ' &amp; "Pre Invoice :"   	   &amp; self.exportCurrencyCode;
					app.writeLog(msg,LogINFO);
					
					pxyCashReceipt := app.createUpdateProxy(cashRec).CM_CashReceipt;
					app.myTrxUA.trxUpdateCashRecPaymentStatus(pxyCashReceipt ,_paymentStatus,app.myPassport);
					
					if app.myPassport.hasErrors then
						msg := method.qualifiedName &amp; 
						' ' &amp; _wsdl 			&amp;
						' ' &amp; "CashReceipt :"   &amp; cashRec.externalInvoiceNumber &amp;
						' ' &amp; "ERRORS : "       &amp; app.myPassport.getErrorsAndWarningsAsString ;
						
						app.writeLog(msg,LogINFO);
					endif;
				endif;
			endforeach;
		
		endif;
	endif;
epilog
	delete pxyCashReceipt;
	delete cashRecMatched;
end;</source>
        <Parameter name="_paymentStatus" type="Integer"/>
        <Parameter name="_wsdl" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateCashRecSAPDirect" id="6e8be696-1476-40b3-86a7-a4d1099a222c">
        <source>updateCashRecSAPDirect( _paymentStatus : Integer; _wsdl : String; _msgArray : String200Array input; _passport : CM_Passport input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2019	jlgndl1	Initial creation	TFS 45312 - a version to be called directly from a 'trx'

*/

vars
	
	cashRec	: CM_CashReceipt;
	cashRecMatched : ObjectArray;
	obj : Object;
	msg : String;

begin

	msg :=  method.qualifiedName    &amp; 
			' ' &amp; _wsdl 							  &amp;
			' ' &amp; "Update Cash Receipt Status :"      &amp; app.paymentStatusCashEnumToString(_paymentStatus).String &amp;
			' ' &amp; "Pre Invoice :"   				  &amp; self.exportCurrencyCode &amp;
			' ' &amp; "Payment Type:"   				  &amp; app.paymentTypeEnumToString(self.paymentType);
	_msgArray.add( msg );
						
	if self.paymentType= PaymentType_None then
		return;
	endif;
	
	//23.01.2019 cnwma1 TFS #42942
	if self.paymentType = PaymentType_PrePay then
		if self.myCashReceipt &lt;&gt; null then
			
			if self.myCashReceipt.paymentStatus &lt;&gt; CM_CashReceipt.CREDIT_CHECK_APPROVED then
				return;
			endif;
			
			if _wsdl = BGP_SAPWSRequest.WSDL21 then
				if self.myCashReceipt.paymentStatus = CM_CashReceipt.PAID then 					//Already Paid
					return;
				endif;
			elseif _wsdl = BGP_SAPWSRequest.WSDL111 then          
				if self.myCashReceipt.paymentStatus = CM_CashReceipt.CREDIT_CANCEL_APPROVED then  //Already Cancelled
					return;
				endif;
			endif;
			
			app.myUtilityUA.utlUpdateRealCashRecPayStatus( self.myCashReceipt, _paymentStatus, _passport );
			
			if app.myPassport.hasErrors then
				msg :=  method.qualifiedName &amp; 
						' ' &amp; _wsdl 			&amp;
						' ' &amp; "CashReceipt :"   &amp; self.myCashReceipt.externalInvoiceNumber &amp;
						' ' &amp; "ERRORS : "       &amp; app.myPassport.getErrorsAndWarningsAsString;
				_msgArray.add( msg );
			else
				msg := method.qualifiedName &amp; 
						' ' &amp; _wsdl 				   &amp;
						' ' &amp; "Update Payment Status"  &amp;
						' ' &amp; "CashReceipt :"   	   &amp; self.myCashReceipt.externalInvoiceNumber &amp;
						' ' &amp; "Pre Invoice :"   	   &amp; self.exportCurrencyCode ;
				_msgArray.add( msg );
				endif;
		endif;
	else
		//03.01.2019 Bug #42441
		create cashRecMatched transient;
		self.findCashReceipts(cashRecMatched);
		if cashRecMatched.size &gt; 0 then
			foreach obj in cashRecMatched discreteLock do
				cashRec := obj.CM_CashReceipt;
				
				if cashRec.paymentStatus &lt;&gt; CM_CashReceipt.CREDIT_CHECK_APPROVED then
					continue;
				endif;
				
				if cashRec.paymentStatus &lt;&gt; CM_CashReceipt.PAID then
					
					
					app.myUtilityUA.utlUpdateRealCashRecPayStatus( cashRec, _paymentStatus, _passport );
					
					if app.myPassport.hasErrors then
						msg := method.qualifiedName &amp; 
							' ' &amp; _wsdl 			&amp;
							' ' &amp; "CashReceipt :"   &amp; cashRec.externalInvoiceNumber &amp;
							' ' &amp; "ERRORS : "       &amp; app.myPassport.getErrorsAndWarningsAsString ;
						
						_msgArray.add( msg );
					else
						msg :=  method.qualifiedName &amp; 
							' ' &amp; _wsdl 				   &amp;
							' ' &amp; "Update Payment Status"  &amp;
							' ' &amp; "CashReceipt :"   	   &amp; cashRec.externalInvoiceNumber &amp;
							' ' &amp; "Pre Invoice :"   	   &amp; self.exportCurrencyCode;
						_msgArray.add( msg );
					endif;
				endif;
			endforeach;
		
		endif;
	endif;

epilog

	delete cashRecMatched;

end;</source>
        <Parameter name="_paymentStatus" type="Integer"/>
        <Parameter name="_wsdl" type="String"/>
        <Parameter name="_msgArray" type="String200Array" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateDebtorInvoiceLines" id="578490c5-100a-42d7-a07f-0cbae5c980e8">
        <source>updateDebtorInvoiceLines();
/*
Purpose:			

Date		Who		Reason
22 June 2023	navab1	 BUG 58791
*/

vars
	invLine : CM_InvoiceLine;
begin
	/* // ### JIRA 33005 03OCT2024 NAVAB1
