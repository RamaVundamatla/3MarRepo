____________________________________________________________________________
Specifies the definition of a drop-down menu (combobox).</text>
    <DbClassMap file="basehtml"/>
    <ExplicitInverseRef name="allOptions" id="3517cc51-6312-4303-ade5-67f81700e671">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="CnEcHtmlOptionTagArray"/>
        <access>readonly</access>
        <text>Contains a set of all Option Tag objects for this select tag.  Note that
option tags may also be created independantly of a select tag, which
therefore will not have a reference to any select tag object.</text>
        <Inverse name="CnEcHtmlOptionTag::mySelectTag"/>
    </ExplicitInverseRef>
    <PrimAttribute name="selectIsMultiple" id="44df62e9-262c-4056-ad88-8fbead4e5bd4">
        <embedded/>
        <type name="Boolean"/>
        <text>If true, specifies that multiple items can be selected in the menu, and
also displays the menu as a listbox rather than as a drop-down combobox.</text>
    </PrimAttribute>
    <PrimAttribute name="selectName" id="497f4586-47d5-4f3c-a5b5-1c972cfcf786">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Specifies the name of the select menu (combobox).</text>
    </PrimAttribute>
    <PrimAttribute name="selectSize" id="12262fd9-13bd-4dd2-9f00-c3504570511c">
        <embedded/>
        <type name="Integer"/>
        <text>Specifies the height (in rows) of the menu.</text>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="41d83513-5739-4ff2-8e11-a711af61f4b3">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString		: String;
	optionTagObj	: CnEcHtmlOptionTag;

begin
	htmlString	:=	'NAME="' &amp; selectName &amp; '" SIZE="' &amp; selectSize.String &amp; '"';

	if self.selectIsMultiple then
		htmlString	:=	htmlString &amp; ' MULTIPLE';
	endif;

	htmlString	:=	htmlString &amp; inheritMethod() &amp; '&gt;';

	foreach optionTagObj in self.allOptions do
		htmlString	:=	htmlString &amp; optionTagObj.getHtml();
	endforeach;

	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="clearOptions" id="4cfe0e5e-2863-4386-9fcd-52fd01443999">
        <updating/>
        <source>clearOptions() updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2000 by cnwdad2
//
// Purpose:		Delete all of the receiver's select option tag objects.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allOptions.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="createOption" id="b4b65396-a3e0-4490-9f1b-ac76bec9fa0d">
        <source>createOption():CnEcHtmlOptionTag;
// --------------------------------------------------------------------------------
// Created:		30 April 2000 by cnwdad1
//
// Purpose:		Create a new select option tag object.
//
// Parameters:	None
//
// Returns:		The newly created select option tag object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	optionTagObj	: CnEcHtmlOptionTag;

begin
	create optionTagObj transient;
	optionTagObj.setSelectTag(self);
	
	return optionTagObj;
end;</source>
        <ReturnType type="CnEcHtmlOptionTag"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="458aa3ee-9508-4911-996a-e005db4b88ea">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		28 April 2000 by cnwdad2
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;SELECT ' &amp; self.buildTagBody() &amp; '&lt;/SELECT&gt;' &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
