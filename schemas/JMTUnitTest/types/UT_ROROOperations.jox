    <JadeMethod name="tReturnToYardContextMenu" id="34f6c21a-0809-47a2-81be-564498368d6f">
        <updating/>
        <source>tReturnToYardContextMenu() updating;
// cnwmp6
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2012	cnwmc5	Initial creation

*/

vars
	voyage 	: CM_Voyage;
	tiArray	: CM_TIArray;
	
begin
	create tiArray transient;
	
	voyage 	:= self.createVesselVoyage("UTMCVES1", "UTMCVOY1", null);
	createCargoOnVoyage(tiArray, voyage);
	createReturnCargoToYardData(tiArray, voyage);
	
epilog
	delete tiArray;
end;</source>
