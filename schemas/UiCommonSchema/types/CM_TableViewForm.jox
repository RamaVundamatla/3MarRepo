    <JadeMethod name="initFromUserWindow" id="9ab1b13a-1027-487b-bff4-403e11ecc4f9">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

vars
	str, tmpStr	: String;
begin

	inheritMethod(_userWindow);

	str := _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_Splitter &amp; ' name="sptMain"');
	
	if str &lt;&gt; null then
		tmpStr := str.cnEcGetTagValueOfName(XMLTag_Ratio);
		
		if tmpStr &lt;&gt; null then
			self.sptMainRatioSaved := tmpStr.Integer;
		endif;
	endif;
	
	self.getTblDataXML(_userWindow);
	
	tmpStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_TblThumbVisible);
	
	if tmpStr &lt;&gt; null and (not tmpStr.Boolean) and (not self.amInitialisingWithObject) then
		self.hideShowThumbnail();
	endif;
	
	if self.allowHideThumbnailEmpty then
		self.isHideThumbnailEmtpy:=_userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_ThumbnailShowEmptyRow).Boolean;
		self.mnuHideThumbnailEmtpy.checked:=self.isHideThumbnailEmtpy;
	endif;
	
	tmpStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_DockSearcher);

	if tmpStr &lt;&gt; null then
		self.useFloatingFilter := tmpStr.Boolean;
	endif;
	
	self.widthUsingTblData 		:= _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_FormWidth1).Integer;
	self.widthNotUsingTblData	:= _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_FormWidth2).Integer;

	if self.useTblData and self.widthUsingTblData &lt;&gt; 0 then
		self.width := self.widthUsingTblData;
	elseif (not self.useTblData) and self.widthNotUsingTblData &lt;&gt; 0 then
		self.width := self.widthNotUsingTblData;
	endif;
	
	if self.allowSearch then
		self.showFilterOnStartup := _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_ShowFilter).Boolean;
	else
		self.showFilterOnStartup := false;
	endif;
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
