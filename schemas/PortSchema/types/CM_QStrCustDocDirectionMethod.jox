<Class name="CM_QStrCustDocDirectionMethod" id="dedbfe5f-fc98-4b1a-b8b5-65d6a3f44af7">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="4d7ecbd7-ec84-4e85-ac90-94d4423fec24">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	operator	: CM_QStringIsOneOf;
begin
	if self.isTransient() then
		return;
	endif;
	
	create operator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(operator);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="09b27a40-0736-415c-82c4-b660abc53d2c">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars

begin
	
	if CM_QReferenceLookup.hasInstance(_operator) then
		return 'cmbCustDocDirection';
	endif;

epilog

end;</source>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="6cafc41d-58bf-4e67-bd32-0777836a5f8a">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	intArray	: IntegerArray;
	int			: Integer;
begin
	
	create intArray transient;
	
	_combo.clear();
	
	intArray.add(CM_CustomDocumentType.CustDocTypeDir_Inward);
	intArray.add(CM_CustomDocumentType.CustDocTypeDir_Outward);
	
	foreach int in intArray do
		_combo.addItem(CM_CustomDocumentType@getDirectStrFromInt(int));
	endforeach;
epilog
	delete intArray;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="e4441dc9-621c-4181-bdfb-53e7373a1a29">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	idx : Integer;
	int	: Integer;
	intArray	: IntegerArray;
	selectionValue : Integer;
	strObj	: CM_String;
begin
	_tbl.purgeTableObjects();
	_tbl.clear();
	_tbl.rows := 0;
	
	create intArray transient;
	
	intArray.add(CM_CustomDocumentType.CustDocTypeDir_Inward);
	intArray.add(CM_CustomDocumentType.CustDocTypeDir_Outward);
	
	foreach int in intArray do
		selectionValue := 0;
		
		if _operator &lt;&gt; null then
			if _operator.CM_QStringIsOneOf.allSelectionValues.includes(CM_CustomDocumentType@getDirectStrFromInt(int)) then
				selectionValue := 1;
			endif;
		endif;
		
		create strObj transient;
		strObj.string := CM_CustomDocumentType@getDirectStrFromInt(int);
		
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; CM_CustomDocumentType@getDirectStrFromInt(int));
		_tbl.accessRow(idx).itemObject := strObj;
		_tbl.row := idx;
		_tbl.change(_tbl);
	
	endforeach;
	
epilog
	delete intArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="0aa328f6-3796-4a0e-ab14-847531edcd88">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	strObj			: CM_String;
	stringArray		: StringArray;
	numRows,
	index			: Integer;
	string			: String;
begin
	create stringArray transient;

	numRows := _tbl.rows;
	
	foreach index in (_tbl.fixedRows + 1) to numRows do
		string := _tbl.accessCell(index, 1).text;
		
		if string = TableCheckBox_Selected then
			strObj := _tbl.accessRow(index).itemObject.CM_String;
			stringArray.add(strObj.string);
		endif;
	endforeach;
	
	_op.setSearchValue(stringArray);

epilog
	delete stringArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="73892e32-4810-4261-a13b-a7049c680180">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars

begin
	if _value.isKindOf(CM_String) then
		if _value &lt;&gt; null then
			return _value.CM_String.string;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="da59d46b-778a-4717-b758-e64b5c9b2d34">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	invalidObj 	: Boolean;
	object 		: CM_String;
	returnVal 	: String;
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;
		
		if _value.isKindOf(CM_String) then
			return _value.CM_String.string;
		endif;
	endif;
	
	return _value;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
