    <JadeMethod name="doOpenBoom" id="16ec8f28-f2a0-4403-abb9-493a0c54dac4">
        <updating/>
        <source>doOpenBoom(_gateLane : CM_LaneController; _channel : Integer) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		25 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/* 	The channel parameter describes which command the dll is going to send. 
	There are two sends. The first is to set the byte to 1 and the second to close with a 0
	You can send commands to all channels at the same time.
	What we are doing here is only sending an open and a close command to one channel at a time.
*/
constants
	ConnectionTimeOut = 2000;
	SendTimeOut = 2000;
	ReceiveTimeOut = 2000;
	Module  = 6060;
vars

	byte 		: Binary;
	result 		: Integer;
	boomNumber	: Integer; //0 -5;
	ipAddress	: String;
	ipPort,
	channel		: Integer;
	boom 		: CM_Boom;
begin

	// Get the device tcpip information
	//epr par 22695 11/3/09
	boom:=_gateLane.getBoom(true);
	if boom = null then
		boom:=_gateLane.getBoom(false);
	endif;
	if  boom = null then 
		return false;
	endif;
	ipAddress:=boom.ipAddress;
	ipPort:=boom.portNumber;
	
	if ipAddress = null or ipPort = null then
		return false;
	endif;
		
	// Set the command
	channel := _channel;
	
	// Set first byte to true. Only one channel
	byte[1]:=1;
		
	result := call adamTcp_Open;	
	if result &lt;&gt; 0 then
		return false;
	endif;
	
	result := call adamTcp_Connect(ipAddress,ipPort,ConnectionTimeOut,SendTimeOut,ReceiveTimeOut);
	//write result;
	if result &lt;&gt; 0 then
		return false;
	endif;
	
	// Push the button
	call adamTcp_Write6KDO(ipAddress,Module,1,channel,1,byte);
	
		
	if result &lt;&gt; 0 then
		return false;
	endif;
	
	// Wait a little bit.
	process.sleep(500);
	
	// Set first byte to false. Only one channel
	byte[1]:=0;
	
	// Take finger of button.
	call adamTcp_Write6KDO(ipAddress,Module,1,channel,1,byte);
	
	if result &lt;&gt; 0 then
		return false;
	endif;
	
	call adamTcp_Disconnect();
	call adamTcp_Close;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_gateLane" type="CM_LaneController"/>
        <Parameter name="_channel" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="finish" id="48e90b0d-8d4b-4db0-8d6d-26b5b89aa264">
        <updating/>
        <source>finish() updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
15 Jul 2008	cnwkpd1	PAR #17543 - Prevent 1090 exceptions during shutdown

*/

vars

begin
	inheritMethod();
	if app.myRFIDListenAgent &lt;&gt; null then			// PAR #17543
		app.myRFIDListenAgent.finish();
	endif;
	
end;


</source>
    </JadeMethod>
