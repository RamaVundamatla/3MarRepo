	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realAudit, true);
	endif;
	
	if _passport.noErrors then
		realAudit.setForUpdate(pProxyAudit,_financialObject,_passport);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realAudit, false);
	endif;

epilog
	
	
