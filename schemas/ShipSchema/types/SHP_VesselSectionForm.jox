    <JadeMethod name="getChildTypeName" id="de43b578-1290-46b5-9fb1-c41916aeced8">
        <source>getChildTypeName(): String protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if self.myParent.isKindOf(CM_VesselStructuralElements) then	 //cnwrd1 par 31874
		return app.getErrorString(Vessel_section) ;
	else
		return app.getErrorString(Voyage_section);
	endif;
epilog

end;

</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstChildObject" id="d911b5f8-e48c-4cd9-86ab-99d172c3eb93">
        <source>getFirstChildObject(_parent: CM_Object): CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin

	//cnwrd1 par 31974
	if self.myParent.isKindOf(CM_VesselStructuralElements) then	
		return _parent.CM_VesselStructuralElements.allSections.first.CM_VesselSectionVessel;
	else
		return _parent.CM_VoyageStructuralElements.allSections.first.CM_VesselSectionVoyage;
	endif;

epilog

end;</source>
        <Parameter name="_parent" type="CM_Object"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="loadChildCombo" id="f2463395-1577-4d8c-9e55-586da05a89d3">
        <updating/>
        <source>loadChildCombo(_child: CM_Object) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin

	if self.myParent = null then
		return;
	endif;
	
	self.myAssistant.comboBoxVesselSections(self.cmbChild,self.myParent,_child.CM_VesselSection);
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_child" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="loadChildFields" id="34d48ce3-ce6c-4752-b9d3-680227f34c63">
        <source>loadChildFields(_child: CM_Object);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	vesselSection : CM_VesselSection; 
begin
	
	vesselSection :=_child.CM_VesselSection;
	self.txtCode.text:=vesselSection.code;
	self.txtRemarks.text:=vesselSection.remarks;
	self.txtPosition.text:=vesselSection.position.asStringJMT;

epilog

end;</source>
        <Parameter name="_child" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="loadParentCombo" id="55374231-f1ee-4fa5-8f44-f2426d1f15db">
        <source>loadParentCombo(_parent: CM_Object) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	
	if _parent.isKindOf(CM_VesselStructuralElements) then
		self.myAssistant.comboBoxROROVesselStructure(self.cmbParent,null);		
	elseif _parent.isKindOf(CM_VoyageStructuralElements) then
		self.myAssistant.comboBoxCellularVoyages(self.cmbParent,self.myTerminal);
	endif;
	
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_parent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="c9d5b639-32f2-4f13-8ad8-3e592f091bc7">
        <updating/>
        <source>setProxy() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	code,
	remarks  :String;
	position : Decimal[12,2];
	proxySection : CM_VesselSection;
begin
	if self.mode = self.Mode_New then
		if self.myParent.isKindOf(CM_VesselStructuralElements) then  //cnwrd1 par 31874
			create self.myProxyChild as CM_VesselSectionVessel transient;
		elseif self.myParent.isKindOf(CM_VoyageStructuralElements) then  //cnwrd1 par 31874
			create self.myProxyChild as CM_VesselSectionVoyage transient;
		endif;
	endif;
	
	proxySection:=self.myProxyChild.CM_VesselSection;
	
	code:=self.txtCode.text;
	remarks:=self.txtRemarks.text;
	position :=self.txtPosition.text.asDecimalJMT;
	proxySection.setProxy(code,position,remarks);
	
	if self.myProxyChild.isKindOf(CM_VesselSectionVessel) then
		proxySection.CM_VesselSectionVessel.setMyVesselStructure(self.myParent.CM_VesselStructuralElements); //cnwrd1 par 31874
	elseif self.myProxyChild.isKindOf(CM_VesselSectionVoyage) then
		proxySection.CM_VesselSectionVoyage.setMyVoyageStructure(self.myParent.CM_VoyageStructuralElements); //cnwrd1 par 31874
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b479f1d0-ff6a-4639-af06-ce48faf83bd8">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	inheritMethod();

	self.lblChild.caption:=app.getErrorString(Section);
	self.lblParent.caption:=app.getErrorString(CM_Vessel_GC);
	
	self.btnDeleteChild.bubbleHelp := app.getErrorString(Delete).cnEcFirstToUpper &amp; " " &amp; app.getErrorString(Section);
	self.btnEditChild.bubbleHelp := app.getErrorString(Edit) &amp; " " &amp; app.getErrorString(Section);
	self.btnNewChild.bubbleHelp := app.getErrorString(New) &amp; " " &amp; app.getErrorString(Section);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d60189ef-aa7c-47ce-b5a3-4bedffbf1a21">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 August 2018 11:51:22.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022878, locale);
	lblCode.translateCaption(Xlat_0015737, locale);
	lblPosition.translateCaption(Xlat_0015738, locale);
	lblRemarks.translateCaption(Xlat_0015739, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="a61720f5-1eca-4afe-8055-ae93372e7b62">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
Date		    Who			Reason
06 May 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	if self.myCurrentChild &lt;&gt; null then
		if self.myCurrentChild.isTransient() then
			delete self.myCurrentChild;
		endif;
	endif;	
	
	if self.myParent &lt;&gt; null then
		if self.myParent.isTransient() then
			delete self.myParent;
		endif;
	endif;	
	
	if self.myProxyChild &lt;&gt; null then
		if self.myProxyChild.isTransient() then
			delete self.myProxyChild;
		endif;
	endif;
	
	inheritMethod();
epilog

end;</source>
    </JadeMethod>
</GUIClass>
