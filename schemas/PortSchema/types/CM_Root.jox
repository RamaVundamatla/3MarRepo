    <JadeMethod name="createDebtorTypes" id="400b9f2d-518d-4a86-95d6-b60f58b0cf2e">
        <source>createDebtorTypes();
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 20 December 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
// 17/04/2013	cnwmh5		#31440 - Change to be hard coded as translations don't exist at the point when this is run
// 02 Oct 2020  cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores//02.10.2020 cnwma1 TFS #50112
//----------------------------------------------------------------------

constants 
	SDT = 'SDT';
vars
	aDT 			: CM_DebtorType;
	debtorTypeCode  : String;
	message 		: String;
	idx 			: Integer;
begin
	
	foreach idx in 0 to CM_DebtorType.DT_MAX do
		
		debtorTypeCode := SDT &amp;idx.String;
		
		if self.allDebtorTypes[debtorTypeCode] &lt;&gt; null then
			continue;
		endif;
		
		create aDT;
		aDT.setForCreateParam(debtorTypeCode, app.getDebtorTypeDesc(debtorTypeCode));
		message := "Creating " &amp; aDT.code &amp; " " &amp; aDT.description.trimBlanks ;
		app.writeStatement(message);
	endforeach;
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="createDefaultLocale" id="0dc198d6-53f3-49b4-a5c0-db92d89625fe">
        <source>createDefaultLocale() : CM_Locale;
// ---------------------------------------------------------------------------
// Created:     01 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	jmtLocale	: CM_Locale;
	localTrx	: Boolean;
begin

	localTrx := (not process.isInTransactionState);
	exclusiveLock(self);
	
	jmtLocale := self.allLocales[StandardTextLocaleStr];
	if jmtLocale = null then
		if localTrx then
			beginTransaction;
		endif;
		create jmtLocale persistent;
		jmtLocale.setForCreate(StandardTextLocale.padLeadingWith("0", 4), null, false, self);
		if localTrx then
			commitTransaction;
		endif;
	endif;
	
	return jmtLocale;

epilog
	if localTrx then
		// do this regardless to clear any locks
		abortTransaction;
	endif;
end;</source>
        <ReturnType type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="createDefaultNavObjectGroups" id="40b1b610-2702-4fe6-bf43-e976b5d69ed8">
        <source>createDefaultNavObjectGroups(_localTransaction : Boolean);
// ---------------------------------------------------------------------------
// Created:     31 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	navObjGrp	: CM_NavObjectGroup;
	sa			: StringArray;
	
begin

	create sa transient;

	if _localTransaction then
		beginTransaction;
	endif;
	
	self.allNavObjectGroups.purge;


	// Create the Terminal group 
	sa.clear;
	sa.add(NavObj_DocketMaint);
	sa.add(NavObj_ReportAdmin);   // leave them here please
	sa.add(NavObj_ReportRunner);   // leave them here please
	sa.add(NavObj_ReportBuilder);  // leave them here please
	sa.add(NavObj_AS400FileLoad);
	sa.add(NavObj_GateFunctions);
	sa.add(NavObj_YardFunctions);
	sa.add(NavObj_SysOpsFunctions);
	sa.add(NavObj_ShipFunctions);
	sa.add(NavObj_LogFunctions);
	sa.add(NavObj_WarehouseFunctions);
	sa.add(NavObj_EDIFunctions);
	sa.add(NavObj_Transfer);
	create navObjGrp persistent;
	navObjGrp.set('TerminalFunctions', sa, self);


	// Create the Gate group	
	sa.clear;
	sa.add(NavObj_GTE_BookingRef);
	sa.add(NavObj_ContEnq);
	sa.add(NavObj_GTE_ReleaseById);
	sa.add(NavObj_GTE_ReleaseByType);
	sa.add(NavObj_GTE_PreNote);
	sa.add(NavObj_GTE_InOut);
	sa.add(NavObj_GTE_RoadExit);
	
	create navObjGrp persistent;
	navObjGrp.set(NavObj_GateFunctions, sa, self);


	// Create the ShipOps group	
	sa.clear;
	sa.add(NavObj_SHP_ShipDefinition);
	create navObjGrp persistent;
	navObjGrp.set(NavObj_ShipFunctions, sa, self);

	// Create the SysOps group	
	sa.clear;
	sa.add(NavObj_SOP_CodeGrps);
	sa.add(NavObj_SOP_ReportDesigner);
	sa.add(NavObj_SOP_SecurityRoles);
	sa.add(NavObj_SOP_TableMaint);
	sa.add(NavObj_SOP_TerminalAreaDef);
	sa.add(NavObj_SOP_VoyageMaint);
	sa.add(NavObj_SOP_Background);
	sa.add(NavObj_SOP_UserNodes);

	
	create navObjGrp persistent;
	navObjGrp.set(NavObj_SysOpsFunctions, sa, self);


	// Create the Yard group	
	sa.clear;
	sa.add(NavObj_YRD_RailOps);
	sa.add(NavObj_YRD_Restrictions);
	sa.add(NavObj_YRD_RoadOps);
	sa.add(NavObj_YRD_Queues); // Radio Telemetry Queues
	sa.add(NavObj_RAP_Monitoring);
	sa.add(NavObj_YRD_SystemAlerts);
	sa.add(NavObj_YRD_GridArea); // Yard Areas -  Straddle, Fork Lift etc
	sa.add(NavObj_YRD_LogArea); // Yard Areas - Logs
	
	create navObjGrp persistent;
	navObjGrp.set(NavObj_YardFunctions, sa, self);

	// Create the Log group
	sa.clear;
	sa.add(NavObj_LOG_DocketReconcile);
	sa.add(NavObj_LOG_Disassembly);
	sa.add(NavObj_LOG_Regrading);
	sa.add(NavObj_LOG_Rejections);
	sa.add(NavObj_LOG_Transfers);
	sa.add(NavObj_LOG_TransitTransfer);
	sa.add(NavObj_LOG_RowMaintDemo);	
	sa.add(NavObj_LOG_VoyageOps);
	sa.add(NavObj_LOG_LoadOut);	
	sa.add(NavObj_LOG_LoadOutRecon);
	sa.add(NavObj_LOG_NNRecon);	
	sa.add(NavObj_LOG_Offload);

		
	create navObjGrp persistent;
	navObjGrp.set(NavObj_LogFunctions, sa, self);

/*
	// Create the GateInOut group 
	sa.clear;
	sa.add(NavObj_GTE_In_Parent);
	sa.add(NavObj_GTE_Out_Parent);
	
	create navObjGrp persistent;
	navObjGrp.set('GateInOut', sa, self);
*/	
	// Create the warehouse group	
	sa.clear;
	
	sa.add(NavObj_WH_ProductMaint);	
	sa.add(NavObj_WH_InterimLoadout);
	sa.add(NavObj_WH_FinalLoadout);
	create navObjGrp persistent;
	navObjGrp.set(NavObj_WarehouseFunctions, sa, self);
	
	// Create the EDI group.
	sa.clear;
	sa.add(NavObj_EDI_FileLoad);
	sa.add(NavObj_EDI_LoadedDataEdit);
	create navObjGrp persistent;
	navObjGrp.set(NavObj_EDIFunctions, sa, self);
	
	
	

	if _localTransaction then
		commitTransaction;
	endif;

epilog
	delete sa;
end;</source>
        <Parameter name="_localTransaction" type="Boolean"/>
    </JadeMethod>
