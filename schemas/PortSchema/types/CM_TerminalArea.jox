    <JadeMethod name="testAreWeTogether" id="82670d6b-e03c-4e64-a856-259c3468123b">
        <source>testAreWeTogether(pLCArray : CM_LCArray) : Boolean;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		To make sure that all of the controllers being passed in are contiguous
//				Each controller asks the previous controller 'areYouNextToMe', if it is 
//				it gets added to a transient collection of controllers that are touching each other
//				This transient set is used to check the next controller in the passed in set.
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lAlreadyTested, lControllerBad,lController,lLastTested	: CM_LocationsController;
	lControllerArrayGood, lControllerArrayBad, lControllerArrayRemove : CM_LCArray;
	lFirst, lTogether : Boolean;
begin

	create lControllerArrayGood transient;
	create lControllerArrayBad transient;
	create lControllerArrayRemove transient;

	lFirst := true;
	lTogether := true;
	foreach lController in pLCArray do : oUTERLOOP
		if lFirst then
			lControllerArrayGood.add(lController);
			lLastTested := lController;
			lFirst := false;
		else
			// Ask if the current controller is next to the last controller
			// if it is then add it to the collection of previous controllers that we know are touching each other
			if lLastTested.testAreYouNextToMe(lController) then
				lControllerArrayGood.add(lController);
				lLastTested := lController;
				continue oUTERLOOP;
			// if it is not next to us then go through all of our collection of previously tested controller to see if it is next to any of those
			else
				foreach lAlreadyTested in lControllerArrayGood do
					// if it is next to any of these  then add it to the collection and go onto the next one
					if lAlreadyTested.testAreYouNextToMe(lController) then
						lControllerArrayGood.add(lController);
						lLastTested := lController; 
						continue oUTERLOOP;
					endif;
				endforeach;
				// if this controller is not next to any of the previously tested controllers then  we are not together
				lControllerArrayBad.add(lController);
			endif;
		endif;
	endforeach; // oUTERLOOP

	// now the ones that are in the bad test again whether each is actually next any of the good. 
	// if it is then move the bad into the good
	// IN REVERSED
	foreach lControllerBad in lControllerArrayBad reversed do : bADLOOP
		foreach lController in lControllerArrayGood do
			if lController.testAreYouNextToMe(lControllerBad) then
				lControllerArrayGood.add(lControllerBad);
				lControllerArrayRemove.add(lControllerBad);
				continue bADLOOP;
			endif;
		endforeach;
	endforeach;
	if lControllerArrayBad.isEmpty = false then
		foreach lControllerBad in lControllerArrayRemove do 
			if lControllerArrayBad.includes(lControllerBad) then
				lControllerArrayBad.remove(lControllerBad);
			endif;
		endforeach;
	endif;

	// now the ones that are still  in the bad test again whether each is actually next any of the good. 
	// if it is then move the bad into the good
	// IN FORWARD
	foreach lControllerBad in lControllerArrayBad do : bADLOOP2
		foreach lController in lControllerArrayGood do
			if lController.testAreYouNextToMe(lControllerBad) then
				lControllerArrayGood.add(lControllerBad);
				lControllerArrayRemove.add(lControllerBad);
				continue bADLOOP2;
			endif;
		endforeach;
	endforeach;
	if lControllerArrayBad.isEmpty = false then
		foreach lControllerBad in lControllerArrayRemove do 
			if lControllerArrayBad.includes(lControllerBad) then
				lControllerArrayBad.remove(lControllerBad);
			endif;
		endforeach;
	endif;
	
	if lControllerArrayBad.isEmpty then
		return true;
	else
		return false;
	endif;
	
epilog
	delete lControllerArrayBad;
	delete lControllerArrayGood;
	delete lControllerArrayRemove;

end;</source>
        <Parameter name="pLCArray" type="CM_LCArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
