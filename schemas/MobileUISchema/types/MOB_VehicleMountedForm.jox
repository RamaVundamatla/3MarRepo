    <JadeMethod name="getMoveWeight" id="3f21ffd2-eba7-4eb6-aa71-4b39ffbcb091">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::getMoveWeight"/>
        </interfaceImplements>
        <source>getMoveWeight() : Decimal;
/*

Date		Who		Reason
21 March 2014	cnwer1	Initial creation CCMS 1366

*/

vars
	amount,density : Decimal[14,4]; //could be volume or weight
	workingEntry : DTO_RTQueueEntry;
begin
	if not  self.myMoveTableDetails.isEntRowNameVisible(ETRow_TotalQuantity) then
		return null;
	endif;
		
	amount := self.tblWeight.getConvertedValue;
	if self.tblWeight.measurementType = Type_Volume then
	//	ti:=self.getCargoID
		workingEntry:=self.getWorkingDTOEntry;
		if workingEntry &lt;&gt; null then
			density:=workingEntry.myRealQueueEntry.CM_RTQueueEntry.myWorkListEntry.getDensity();
		endif;
	
		return amount*density;
		
	else
		return amount;
	endif;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
