    <JadeMethod name="getBerthToBerthDescription" id="9c61bccc-c889-4caa-90f8-1215da5d98a7">
        <source>getBerthToBerthDescription() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/09/2012	cnwdap1	Initial creation PAR #30146
10/09/2012	cnwdap1	PAR #30312 Avoid 1090s
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
*/
vars
	berth	: HMS_Berth;
	region	: HMS_HarbourRegion;
	str		: String;

begin
	str := "&lt;unknown&gt;";
	// from region
	berth := self.getMyBerthPrevious();
	if berth = null then
		region := app.myRoot.getSeaHarbourRegion;
	else
		region := berth.myHarbourRegion;
	endif;
	
	if berth &lt;&gt; null then
		//if berth.myWharf.isLogicalWharf then							// PAR #30312
		if berth.myWharf &lt;&gt; null and berth.myWharf.isLogicalWharf then	// PAR #30312
			str := berth.code;
		else
			str := "Berth " &amp; berth.code;
		endif;
	elseif region &lt;&gt; null then
		str := region.code;
	endif;
	str := str &amp; " to ";
	
	// to region
	berth := self.getMyBerth();
	if berth = null then
		str := str &amp; "&lt;unknown&gt;";
	else
		//if berth.myWharf.isLogicalWharf then							// PAR #30312
		if berth.myWharf &lt;&gt; null and berth.myWharf.isLogicalWharf then	// PAR #30312
			if not berth.myWharf.isLogicalWharf then
				str := str &amp; "berth ";
			endif;
		endif;
		str := str &amp; berth.code;
	endif;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
