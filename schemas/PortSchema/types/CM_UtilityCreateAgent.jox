    <JadeMethod name="utlCreateInstantMoveHistory" id="1e839f01-aa8b-4046-a4ea-634e0e3d46fd">
        <source>utlCreateInstantMoveHistory(_machine : CM_Machine;_source : String;_target:String;_ti : CM_TrackedItem;_moveController : CMIF_MoveController input;_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 January 2015	cnwma1	Initial creation

*/

vars
	histEntry 	: CM_MachineMoveHistory;
	machine		: CM_Machine;
	moveTrans	: CM_Move;
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);
	
	machine :=_machine;
	histEntry :=machine.addMoveToHistoryLoc(_source,_target,_ti);
	
	// 23/02/2015 cnwar2 #35729
	histEntry.setMoveTrnsFromController(_moveController);
	moveTrans := histEntry.myMoveTransaction;
	if moveTrans &lt;&gt; null then
		if moveTrans.totalQuantity &gt; 0 then
			histEntry.setQuantity( moveTrans.totalQuantity );
		endif;		
		if moveTrans.totalWeight &gt; 0 then
			histEntry.setWeight( moveTrans.totalWeight );
		endif;
	endif;

	if not _passport.noErrors then
		return;
	endif;
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_source" type="String"/>
        <Parameter name="_target" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateInstructionIssued" id="9ca2af3f-2bd2-4735-9424-85a382f7be20">
        <source>utlCreateInstructionIssued(_pxyInstructionIssued : CM_InstructionsIssued input;
						_realInstructionIssued : CM_InstructionsIssued output;
						_passport : CM_Passport input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/
vars
	terminal : CM_Terminal;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyInstructionIssued, 'Instruction Type Proxy');
	_pxyInstructionIssued.validateForCreate();
	
	create _realInstructionIssued persistent;
	_realInstructionIssued.setForCreate(_pxyInstructionIssued);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_realInstructionIssued);
	endif;
	
	if _passport.noErrors and _passport.myTerminal &lt;&gt; null then
		if _realInstructionIssued.myParent &lt;&gt; null then
			self.updateObjectEdition(_realInstructionIssued.myParent);	
			if _realInstructionIssued.myParent.isKindOf(CM_WorkOrder) then
				//jlier1 29/5/25 MTN-34591 
				terminal:=_realInstructionIssued.myParent.getMyTerminal;
				if terminal &lt;&gt; null then
					app.myEventManager.createSingleObjInfoNoteEvt(_realInstructionIssued.myParent, terminal.getTerminalEvent(Event_WorkOrder_Update),  _realInstructionIssued.myParent);
				endif;
			endif;
		endif;	
	endif;
epilog

end;</source>
        <Parameter name="_pxyInstructionIssued" type="CM_InstructionsIssued" usage="input"/>
        <Parameter name="_realInstructionIssued" type="CM_InstructionsIssued" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
