    <JadeMethod name="btnClose_click" id="0738a3e5-3860-43ea-9d20-3be8072dbaeb">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(jadeMask: JadeMask input) updating;

begin
	self.closeForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="closeForm" id="e1306b44-8cbd-4980-9097-ff6dcbbe70cc">
        <updating/>
        <source>closeForm() updating;

begin
	self.unloadForm();
end;</source>
    </JadeMethod>
    <JadeMethod name="fileVisibility" id="49fcd0f0-bc52-40bd-80a9-d29602dc23d2">
        <source>fileVisibility();

begin
	if CnEcBaseRoot.firstInstance.myBuyLineMgr &lt;&gt; null then
		mnuTestMess.enabled := true;
		mnuMgr.enabled := true;
	else
		mnuTestMess.enabled := false;
		mnuMgr.enabled := true;		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="cb52719b-9439-4351-8ceb-e828f13fe32b">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	inheritMethod();
	self.loadForm();
end;</source>
    </JadeMethod>
    <JadeMethod name="loadForm" id="456df850-ac43-43c8-a6e5-c5372afaaf43">
        <updating/>
        <source>loadForm() updating;

begin
	self.centreWindow();
	self.fileVisibility();
end;</source>
    </JadeMethod>
    <JadeMethod name="mnuMgr_click" id="b93d5df3-86e5-4e2e-969a-3de6e0b80ff9">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuMgr_click(menuItem: MenuItem input) updating;

vars
	formObj	: CnEcBuyLineMgrMaintForm;
	
begin
	create formObj;
	formObj.showModal();
	delete formObj;
	self.fileVisibility();
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuTestMess_click" id="7955a1d9-961c-4180-aef5-d7e7f178a29e">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuTestMess_click(menuItem: MenuItem input) updating;

vars
	formObj	: CnEcBuyLineMessageForm;
	
begin
	create formObj;
	formObj.showModal();
	delete formObj;
	self.fileVisibility();
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unload" id="e41d3dfd-237b-42cd-a06a-20d35ddc198e">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

begin
	self.closeForm();
end;</source>
