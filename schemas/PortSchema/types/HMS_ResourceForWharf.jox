<Class name="HMS_ResourceForWharf" id="93ef8bc7-ebaf-4c30-bdc2-b02975a9a250">
    <superclass name="HMS_ResourceForObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>***** this ResourceForObject is slightly different. *****
There are two resources for each movements for the HMS_Wharf object
The collection for these objects is by harbour, wharf and by order. 
Order is an interger value. Two constants are on this object to represent
First resouce and theh Second Resource.</text>
    <DbClassMap file="harbour"/>
    <Constant name="First_Resource" id="99d3614c-cd52-4e53-b2c1-fc6c7d188a3c">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="Second_Resource" id="cfb9ba0e-8d08-4775-aa15-06988a03e4dd">
        <source>2</source>
        <type name="Integer"/>
    </Constant>
    <ExplicitInverseRef name="allWharfs" id="a7eda1e7-b50d-42f0-bfa1-88589c59b992">
        <updateMode>manual</updateMode>
        <type name="HMS_WharfByCodeDict"/>
        <access>readonly</access>
        <Inverse name="HMS_Wharf::allResourcesForWharf"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myWharf" id="724a834b-1bfa-424a-badd-7b7df7623a48">
        <embedded/>
        <type name="HMS_Wharf"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="order" id="76845f18-566d-47eb-b516-e6f0d6d37d28">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getObjectDescription" id="f7f68785-fd90-4693-b77c-78b567e0978c">
        <source>getObjectDescription(): String;
// ---------------------------------------------------------------------------
// Created:     22 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	return 	self.myWharf.getDisplayString;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="41548116-b33d-4c0d-b01b-451dcc1f7176">
        <updating/>
        <source>setProxy(_obj: HMS_Object; _harbour: HMS_Harbour; _arrivalResource: HMS_Resource; _departResource: HMS_Resource; _shiftResource: HMS_Resource) updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	wharf : HMS_Wharf;
begin
	inheritMethod(_obj, _harbour, _arrivalResource, _departResource, _shiftResource);

	wharf := _obj.HMS_Wharf;
	
//	self.order := _order;
	self.myWharf := wharf ;
	self.myHMSObject := wharf ;
	
	if wharf  &lt;&gt; null and not self.allWharfs.includes(wharf) then 
		self.allWharfs.add(wharf);
	endif;
end;</source>
        <Parameter name="_obj" type="HMS_Object"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_arrivalResource" type="HMS_Resource"/>
        <Parameter name="_departResource" type="HMS_Resource"/>
        <Parameter name="_shiftResource" type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="setResourceOrder" id="619ea58f-f879-41a8-8fda-822b8f35cdfc">
        <updating/>
        <source>setResourceOrder(_order : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     12 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	self.order := _order;
end;</source>
        <Parameter name="_order" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setWharf" id="72bc6ca2-0731-4c4f-9390-3d77f5117ed6">
        <updating/>
        <source>setWharf(_wharf	: HMS_Wharf)updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myWharf := _wharf;
	self.myHMSObject := _wharf;
	
	if _wharf &lt;&gt; null and not self.allWharfs.includes(_wharf) then 
		self.allWharfs.add(_wharf);
	endif;
end;</source>
        <Parameter name="_wharf" type="HMS_Wharf"/>
    </JadeMethod>
    <JadeMethod name="theOrder" id="240e0264-6faa-4b6c-87e4-23c0da6ffaf2">
        <source>theOrder() : Integer;
// cnwrs1 may 2006 SQL has order as reserved word so must extract order as othername
vars

begin
	return self.order;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
