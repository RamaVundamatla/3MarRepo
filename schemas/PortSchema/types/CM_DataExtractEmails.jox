    <JadeMethod name="initDataExtractFields" id="659c5bcf-2cac-4092-bf5f-1fa68563b8eb">
        <source>initDataExtractFields(_fields: CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2011	#cnwdz2	 

*/

vars
	fieldName    : String;
begin
	self.extractOrder.clear();
	
	fieldName := CM_EmailAddress2::name.name;	
	self.initDataExtractField(_fields, CM_EmailAddress2.name, null, fieldName, STRING, "Title", "Title", STRING, "No more than 30 Characters and/or digits");
	
	fieldName := CM_EmailAddress2::getEmailAddress.name;	
	self.initDataExtractField(_fields, CM_EmailAddress2.name, null, fieldName, STRING, "Email Address", "Email address", STRING, "Valid email address");
	
	fieldName := CM_EmailAddress2::businessPhone.name;	
	self.initDataExtractField(_fields, CM_EmailAddress2.name, null, fieldName, STRING, "Business Phone", "Business phone number", STRING, 'Valid phone number');
	
	fieldName := CM_EmailAddress2::mobilePhone.name;	
	self.initDataExtractField(_fields, CM_EmailAddress2.name, null, fieldName, STRING, "Mobile Phone", "Mobile phone number", STRING, "Valid mobile nubmer");
	
	fieldName := CM_EmailAddress2::homePhone.name;	
	self.initDataExtractField(_fields, CM_EmailAddress2.name, null, fieldName, STRING, "Home Phone", "Home phone number", STRING, "Valid phone number");

	fieldName := CM_EmailAddress2::faxNumber.name;	
	self.initDataExtractField(_fields, CM_EmailAddress2.name, null, fieldName, STRING, "Fax Number", "Fax umber", STRING, "Valid fax number");
 
	fieldName := CM_EmailAddress2::address.name;	
	self.initDataExtractField(_fields, CM_EmailAddress2.name, null, fieldName, STRING, "Postal Address", "Postal and/or physical address of the contact", STRING, "Valid address");
	
epilog

end;</source>
        <Parameter name="_fields" type="CM_DataExtractFieldSet" usage="input"/>
    </JadeMethod>
</Class>
