        <source>utlUpdateTidalClass(_pxyTidalClass : HMS_TidalClass; _conflictManager : CMIF_HMS_ConflictsManager output;_passport : CM_Passport input) updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars
	realTidalClass : HMS_TidalClass;
	expectedEdition : Integer;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	_pxyTidalClass.raiseExceptionIfNotProxy(method);
	_pxyTidalClass.validate(_conflictManager, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	_pxyTidalClass.pxyGetRealObjectAndEdition(realTidalClass, expectedEdition);
	app.setContinueCMExceptions(true);

	if realTidalClass = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _pxyTidalClass.code, null, null);
		return;
	endif;
	
	exclusiveLock(realTidalClass);

	if _passport.noErrors and realTidalClass.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'TidalClass', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTidalClass, true);
	endif;
	
	if _passport.noErrors then
		realTidalClass.setForUpdate(_pxyTidalClass, _passport);
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTidalClass, false);
	endif;
	
end;</source>
