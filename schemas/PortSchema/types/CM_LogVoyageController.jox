    <JadeMethod name="myVoyage" id="74e8d1db-5a2b-45d8-ae36-a88b1d443cb3">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myVoyage(set: Boolean; _value: CM_Voyage io) mapping, updating;

vars

begin

	if set then
		self.myVoyage	:= _value.CM_Voyage;
		if _value &lt;&gt; null then 
			self.myLogVoyageStructure := _value.myLogVoyageStructure;
		endif;
//		self.myLogVoyage	:= _value.CM_LogVoyage;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Voyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="9536c05c-989d-46f3-88b9-a0a180d50ec6">
        <updating/>
        <source>setForCreate(_proxyVoyageController: CM_LogVoyageController) updating;
//--------------------------------------------------------------
//Created: 19 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_proxyVoyageController);
	self.myLogLot		:= _proxyVoyageController.myLogLot;
	self.hatch 			:= _proxyVoyageController.hatch;
	self.place 			:= _proxyVoyageController.place;

end;</source>
        <Parameter name="_proxyVoyageController" type="CM_LogVoyageController"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="78666f9d-cdd3-4415-a459-c7269f60b648">
        <updating/>
        <source>setProxy(_logLot : CM_LogLot; _logVoyage : CM_LogVoyageStructure; _hatch, _place : Integer) updating;
//--------------------------------------------------------------
//Created: 19 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.hatch 		:= _hatch;
	self.place 		:= _place;
	self.myLogLot 	:= _logLot;
	
	self.setProxyVoyageController(_logVoyage.myVoyage);
end;</source>
        <Parameter name="_logLot" type="CM_LogLot"/>
        <Parameter name="_logVoyage" type="CM_LogVoyageStructure"/>
        <Parameter name="_hatch" type="Integer"/>
        <Parameter name="_place" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validate" id="2a1e85d4-28ef-4462-abbd-b3ebe903e8e6">
        <source>validate(_passport : CM_Passport input) protected;
//--------------------------------------------------------------
//Created: 19 August 2002 By: cnwgd1
//23/06/2022 		NAVDS20 			TFS 53760  DuplicateItem not Translatable
//--------------------------------------------------------------
vars
	tmpVoyCntrl : CM_LogVoyageController;
begin
	if self.hatch = null then
		//app.raiseCMException1(REQUIRED_FIELD, 'hatch', ETRow_Hatch, null);
		app.raiseCMException(Input_required_field_hatch, ETRow_Hatch, null); // cnwdb2	PAR 35364
	endif;
	if self.myLogLot = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Log Lot', ETRow_Lot, null);
		app.raiseCMException(Input_required_field_logLot, ETRow_Lot, null); // cnwdb2	PAR 35364


	endif;	
//	if self.myLogVoyage = null then
	if self.myLogVoyageStructure  = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Log Voyage', ETRow_Voyage, null);
		app.raiseCMException(Input_required_field_logVoyage, ETRow_Voyage, null); // cnwdb2	PAR 35364


	endif;
	if self.place = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Place', ETRow_Place, null);
		app.raiseCMException(Input_required_field_place, ETRow_Place, null);// cnwdb2	PAR 35364


	endif;
	
	if _passport.noErrors then
		tmpVoyCntrl := self.myVoyage.myLogVoyageStructure.getLogVoyController(self.myLogLot.lotNo, self.hatch, self.place);
		if tmpVoyCntrl &lt;&gt; null and tmpVoyCntrl &lt;&gt; self.pxyGetRealObject then
			//app.raiseCMException2(DuplicateItem, 'Log Voyage Controller', 'Lot' &amp; self.myLogLot.lotNo &amp; ' Hatch ' &amp; self.hatch.String &amp; ' Place ' &amp; app.vesselPlaceEnumToStr(self.place),ETRow_Place, null);	//23/06/2022 NAVDS20 TFS 53760
			//Log Voyage Controller already exists for Lot %1 Hatch %2 Place %3 : Voyag_contr_alrea_exist_hatch_
			app.raiseCMException3(Voyag_contr_alrea_exist_hatch_,  self.myLogLot.lotNo, self.hatch.String, app.vesselPlaceEnumToStr(self.place), ETRow_Place, null);	//23/06/2022 NAVDS20 TFS 53760
			
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
