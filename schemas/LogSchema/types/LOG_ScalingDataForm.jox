    <JadeMethod name="doCancel" id="70ab81df-04fa-4ab5-b968-c8051344dc80">
        <updating/>
        <source>doCancel() updating;
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwth2
//
// Purpose:     
