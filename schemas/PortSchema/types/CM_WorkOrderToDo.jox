    <JadeMethod name="pxyCreateUpdateProxy" id="3eefb542-f282-455c-aecc-e79777d8a8c6">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 December 2022	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen

*/

vars
	pxy 		 : SelfType;
	completedOK  : Boolean;
begin
	pxy := inheritMethod();
	
	completedOK := true;
	return pxy;

epilog
	
	if not completedOK then			
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setApproved" id="f103da1f-27ed-4063-8ed2-ae33b118cd32">
        <updating/>
        <source>setApproved(_approvedBy: String; _approvedBtDT: TimeStamp; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 September 2022   navcs2	ChangeRequest 54344:[54263] EUP - [Framework] - VAS Work Orders - Jobs
2/12/2022			navcs2  ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
18/01/2023 			navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions
12 Apr 2023 		navma1  ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
*/

vars
	wod 	   : CM_WorkOrderDtl;
	woActionIF : CMIF_WorkOrderAction;
	realJob	   : CM_Job;
	term	   : CM_Terminal;
	useYardJob : Boolean;
begin
	inheritMethod(_approvedBy, _approvedBtDT, _passport);
	
	// 17/10/2022 navcs2 54344:[54263]
	foreach wod in self.allWoDtls do
		wod.createWOTransaction(wod.TRANS_UPDATED, null, null); // 18.01.2023 navcs2 #56633:[56211]
		wod.setStatus(WO_STATUS_APPROVED);
	endforeach;
	// 2/12/2022 navcs2 ChangeRequest 56840:[54265]
	
	term 		:= self.myTerminal;
	
	if term.getConfig(AllowAutoActionToDoWO).Boolean then

		foreach wod in self.allWoDtls do
			create woActionIF transient;
			woActionIF.myWorkOrderDtl		 := wod;
			
			//wodtl.actionItems( woActionIF,	_passport);			//12.04.2023 navma1 #57569:[57570]
			wod.doActionTask(woActionIF,realJob,_passport);			//12.04.2023 navma1 #57569:[57570]
			delete woActionIF;
		endforeach;
	endif;
	
	self.setTaskStatus( WO_STATUS_APPROVED);
epilog
	delete woActionIF;
end;</source>
        <Parameter name="_approvedBy" type="String"/>
        <Parameter name="_approvedBtDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
