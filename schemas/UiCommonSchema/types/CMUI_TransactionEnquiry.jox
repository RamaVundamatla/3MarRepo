    <JadeMethod name="displaySelectorResults" id="b5baeeff-ca57-4eca-9fa0-10b9ab664afa">
        <updating/>
        <source>displaySelectorResults(_resultCollection : Collection; _mode : Integer) updating;
// Feb 2012 CCMS 1262 Transaction Enquiry called from selector to display the results
// 22 Dec 2022  navhl20 ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
vars
	numItems			: Integer;
	atLimit				: Boolean;
	tableName			: String;
	obj					: Object;
	thisObjTerminal		: CM_Terminal;
	invalidObject		: Boolean;
	entTableDef			: EntTableDef;
	iter				: Iterator;
	user				: CM_User;
	term				: CM_Terminal;
begin

	self.tblTransactions.clearAllData();
	self.allTransactions.clear();
	self.numItemsShown := 0;

	self.mode    := _mode;
	self.modeStr := _mode.String;
	
	if self.mode = self.Mode_CargoItem_Enquiry then
		self.frmTableFilter.setupControl(self.tblTrans, null); //05/06/2024	navkc1 CR 63736 Task 63770
	else
		self.frmTableFilter.setupControl(self.tblTransactions, null); //05/06/2024	navkc1 CR 63736 Task 63770
	endif;
	
	user 		 := app.getMyUser();
	term		 := self.myTerminal;
	
	on Exception do app.handleDeletedObject(exception, obj, invalidObject);

	iter := _resultCollection.createIterator;
	
	while iter.next(obj) do
		invalidObject   := false;
		thisObjTerminal := null;
		
		if obj.isKindOf(CM_TITransaction) then
			thisObjTerminal := obj.CM_TITransaction.myTerminal;
		elseif obj.isKindOf(CM_EventTransaction) then
			thisObjTerminal := obj.CM_EventTransaction.myTerminal;
		elseif obj.isKindOf(HMS_Transaction) then
			thisObjTerminal := obj.HMS_Transaction.myTerminal;
		elseif obj.isKindOf(CM_BOLTransaction) then
			thisObjTerminal := obj.CM_BOLTransaction.myTerminal;
		elseif obj.isKindOf(CM_WOTransaction) then				//26.12.2022 navhl20 #54350[54269]
			thisObjTerminal := obj.CM_WOTransaction.myTerminal;	//26.12.2022 navhl20 #54350[54269]
		endif;
		
		// Skip any invalid objects
		if invalidObject then
			continue;
		endif;
		
		// Skip any from other than the first terminal
		if term &lt;&gt; null and thisObjTerminal &lt;&gt; term then
			continue;
		endif;
		
		// Otherwise, add it to the table
		atLimit := self.addObjectToCollection(obj.CM_Transaction, user);
		if atLimit then
			break;
		endif;

	endwhile;
		
	// set up transaction table and display transactions
	if not self.tableInitialised then
		self.initTblTransactions();
	endif;
	//29 Mar 2016	NDL	TFS 1717 - allow for 'CM_QueryDefinition' constants being used.
	if self.mode = self.Mode_Cargo_Transaction_Enquiry 	 	or self.mode = CM_QueryDefinition.CargoTransaction_Query_Mode then
		tableName := ETDef_TransactionCargoEnquiry;
	elseif self.mode = self.Mode_Event_Transaction_Enquiry  or self.mode = CM_QueryDefinition.EventTransaction_Query_Mode then
		tableName := ETDef_TransactionEventEnquiry;
	elseif self.mode = self.Mode_HMS_Transaction_Enquiry 	or self.mode = CM_QueryDefinition.HMSTransaction_Query_Mode then
		tableName := ETDef_TransactionHMSEnquiry;
	elseif self.mode = self.Mode_BOL_Transaction_Enquiry 	or self.mode = CM_QueryDefinition.BOLTransaction_Query_Mode then	//04 Nov 2019	NDL	TFS 47100
		tableName := ETDef_TransactionBOLEnquiry;
	elseif self.mode = self.Mode_WO_Transaction_Enquiry		or self.mode = CM_QueryDefinition.WorkOrderTrans_Query_Mode then	//22.12.2022 navhl20 #54350[54269]
		tableName := ETDef_TransactionWOEnquiry;																				//22.12.2022 navhl20 #54350[54269]
	endif;

	entTableDef := app.myController.getEntTableDef(tableName);
	self.tblTransactions.setTblDataEntRowsFromDef(entTableDef);
	
	self.lblSearchCrit.caption := self.displayText;
	
	self.populateTransactionTable();
	self.showNumRowsShown();

epilog
	delete iter;
end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
