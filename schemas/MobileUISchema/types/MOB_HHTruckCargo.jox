    <JadeMethod name="getLockDownExclusions" id="734ee12e-7e07-46b9-a1bf-3b39b2043366">
        <source>getLockDownExclusions( _attrArray : StringArray io ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2013	cnwndl1	Initial creation	Par 32368

*/

vars

	measureType : CM_MeasurementType;

begin

	
	
	if self.myTrackedItem &lt;&gt; null then
		if self.myTrackedItem.isBulkByWeight then
			_attrArray.add( ETRow_TotalWeight );
			measureType := self.myTrackedItem.myCargoType.getMeasurementTypeFor(Type_Weight,true);
			_attrArray.add( Prefix_Weight &amp; ETRow_TotalWeight &amp; "_" &amp; measureType.shortName );
			return;
		elseif self.myTrackedItem.isBulkByVolume then
			_attrArray.add( ETRow_TotalVolume );
			measureType := self.myTrackedItem.myCargoType.getMeasurementTypeFor(Type_Volume,true);
			_attrArray.add( Prefix_Volume &amp; ETRow_TotalVolume &amp; "_" &amp; measureType.shortName );
			return;
		endif;
	endif;
	
	_attrArray.add( ETRow_NumItems );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_attrArray" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getProductForMeasurementType" id="19af117e-ee8e-4626-ad18-57f6c7ef7df5">
        <source>getProductForMeasurementType(): CM_Product protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2013	cnwndl1	Initial creation	Par 32368

*/

vars

	cargoType : CM_CargoType;
	product : CM_Product;
	row : Integer;

begin

	if self.myTrackedItem &lt;&gt; null then
		if self.myTrackedItem.myProduct &lt;&gt; null then
			return self.myTrackedItem.myProduct;
		elseif self.myTrackedItem.myCargoType &lt;&gt; null then
			cargoType := self.myTrackedItem.myCargoType;
		endif;
	endif;
	
	row := self.tblCargo.getRow(ETRow_SubCargoType);
	if row &gt; self.tblCargo.fixedRows and row &lt;= self.tblCargo.rows then
		if self.tblCargo.accessRow( row ).visible then
			product :=  self.cmbSubCargo.listObject.CM_Product;
		endif;
	endif;
	if product &lt;&gt; null then
		return product;
	endif;
	
	if cargoType = null then
		cargoType := self.cmbType.listObject.CM_CargoType;
	endif;
	
	if cargoType &lt;&gt; null then
		if not cargoType.allProducts.isEmpty then
			return cargoType.allProducts.first;
		elseif cargoType.mySystemProductType &lt;&gt; null then
			return cargoType.mySystemProductType;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="getStringValueFromTable" id="5304e9a9-ef82-4c33-b7d5-0343e54cfb86">
        <source>getStringValueFromTable( _attrName : String ):String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	row : Integer;
	aCellControl : Control;
begin
	row := self.tblCargo.getRow( _attrName );
	if row &gt; 0 then
	
		//09 Sep 2013	NDL	Par 32413
		aCellControl := self.tblCargo.accessCell( row, 2 ).cellControl;
		if aCellControl &lt;&gt; null and aCellControl.isKindOf(CMUI_MeasurementTable) then
			return aCellControl.CMUI_MeasurementTable.getConvertedValue().String;
		endif;
		
		return self.tblCargo.getCellText(row,2).String.trimBlanks;
	endif;
	
	if _attrName = ETRow_CarriageTempC
	or _attrName = ETRow_CarriageTempF
	or _attrName = ETRow_PackTempC
	or _attrName = ETRow_PackTempF
	then
		return NULL_TEMPERATURE.String;
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="597071d6-6286-4237-84d2-9ebc17d3667e">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	//User pressed save 
	
	if saveChanges( false ) then
		self.myMobileGenericAgent.setTruck( self.myMobileGenericAgent.myTruck );	// force reload of data.
		self.myMobileGenericAgent.setDoingReversal( false );	//16 Nov 2010	NDL Par 26055
		self.myMobileGenericAgent.setStringField1(null);	//03 Sep 2013	NDL	Par 32368 / 32407
		self.myMobileGenericAgent.setDecimalField1(0.00);
		self.doBackButtonClick();
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnThree" id="3f29cead-f129-4459-b9cf-cfb7f655e5a8">
        <updating/>
        <source>handleBtnThree() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	self.myMobileGenericAgent.setTruck( self.myMobileGenericAgent.myTruck );	// force reload of data.
	self.myMobileGenericAgent.setDoingReversal( false );	//16 Nov 2010	NDL Par 26055
	self.myMobileGenericAgent.setMyWle( null );	//15 Jun 2016	NDL	TFS 1593
