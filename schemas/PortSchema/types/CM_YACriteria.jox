    <JadeMethod name="calculateInvoicePriority" id="153d4d3c-fe42-405c-ad79-cb2b94f90bfe">
        <updating/>
        <source>calculateInvoicePriority() : Real updating;
// ORIGINAL return 0 if a criteria value is present otherwise 1, scaled by the criteria priority
// return 1 if a criteria value is present otherwise 0, scaled by the criteria priority
vars
	priority	: Real;	//26 Feb 2020	NDL	TFS 48689 change from Integer to Real
	obj			: Object;
	yad			: CM_YAData;
begin
	yad := self.myYAData;
	priority := 0;
	if yad.isPrimitiveValue() then
		if yad.getDataValue() &lt;&gt; null then
			priority := 1;
		endif;
	else
		if yad.isKindOf(CM_YADataPattern) then
			if yad.CM_YADataPattern.pattern &lt;&gt; null then
				priority := 1;
			endif;
		else
			if yad.CM_YADataObjects.allObjects.size &gt; 0 then
				priority := 1;
			endif;
		endif;
	endif;
	
	priority := (priority * self.priorityValue);
	return priority;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="calculatePriority" id="5c5dd644-dc5c-4c64-aa48-2c2a068a972e">
        <updating/>
        <source>calculatePriority():Real updating;
// --------------------------------------------------------------------------------
// Created:		04 May 2005 by cnwdad1
//
// Purpose:		Compares the configuration of the receiver against priorities of the
//				same type, for the Yard Allocation's terminal, and returns a priority
//				value - this value is then set on the receiver.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	criteriaTypeObj	: CM_YACriteriaType;
	yardAllocObj	: CM_YardAllocation;
	terminalObj		: CM_Terminal;
	
begin
	criteriaTypeObj	:=	self.myYACriteriaType;
	
	if criteriaTypeObj = null then
		app.raiseUnexpectedProgramError(self.class.name, method.name, "Receiver object is missing a reference to its YA Criteria Type.");
	endif;
	
	yardAllocObj	:=	self.myYardAllocation;
	
	if yardAllocObj = null then
		// For auto allocations
		terminalObj := app.getMyTerminalDO_NOT_USE();
	else
		terminalObj	:=	yardAllocObj.myTerminal;
	endif;
			
	if terminalObj = null then
		self.priorityValue := 0;
	else
		self.priorityValue := criteriaTypeObj.getYAPriorityValueForCriteria(self, terminalObj);
	endif;
	
epilog
	return self.priorityValue;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cloneForCopy" id="ac3acfb9-55b3-411f-92dc-28a9e945c783">
        <source>cloneForCopy(_transient : Boolean) : SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/01/2023	navkc1 Bug 61578: EUP | FR 54089 - Invoice Contracts - Copy function extended

*/

vars
	cloned		: SelfType;
begin
	cloned := cloneSelf(_transient);
	
	cloned.myYACriteriaType := self.myYACriteriaType;
	cloned.myYAData := self.myYAData;
	cloned.myYardAllocation := self.myYardAllocation;
	
	return cloned;
	
epilog

end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="43240b1d-f42e-4e96-93dd-4eef7f4bda0d">
        <source>getDescription() : String;
// -------------------------------------------
// Created 05 May 2005 by cnwdvb1
// -------------------------------------------
vars

	str	: String;

begin

	on Exception do self.xHandler(exception, false); 
	
	str := self.myYACriteriaType.getDataDisplay(self.myYAData);

	if str.length &gt; 200 then
		str := str[1:200] &amp; ' ...';
	endif;
	return self.myYACriteriaType.description &amp; ' ' &amp;  str;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
