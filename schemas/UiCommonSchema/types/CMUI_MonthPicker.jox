    <JadeMethod name="buildSelf" id="8eb0987c-5b14-4f5a-bd61-221d98212129">
        <updating/>
        <source>buildSelf() updating;
/*

Date		    Who			Reason
26 October 2010	cnwas3	 ccms 1108

*/

vars

begin	
	
	self.transparent := true;
	self.borderStyle := 0;
	self.height := 20;
	self.bevelInner := 0;
	self.bevelInnerWidth := 0;
	self.bevelOuter := 0;
	self.bevelOuterWidth := 0;
	self.boundaryBrush := 0;
	self.boundaryWidth := 0;	
	self.lockRight := false;

	// Create the month label
	if self.myMonthLabel = null then
		create self.myMonthLabel transient;
		self.myMonthLabel.parent := self;
		form.addControl(self.myMonthLabel);	
		
		self.myMonthLabel.visible := true;
		self.myMonthLabel.readOnly := true;		
		self.myMonthLabel.alignment := 2;		
		self.myMonthLabel.zOrder(1);
		self.myMonthLabel.tabIndex := 1;
	endif;	
	
	// Create the buttons	

	if self.myPreviousMonthBtn = null then
		create self.myPreviousMonthBtn transient;
		self.myPreviousMonthBtn.parent := self;
		form.addControl(self.myPreviousMonthBtn);		
		self.myPreviousMonthBtn.width := 20;
		self.myPreviousMonthBtn.caption := 215.Character; 
		self.myPreviousMonthBtn.fontName := "Wingdings";
		self.myPreviousMonthBtn.fontSize := 8;
		self.myPreviousMonthBtn.visible := true;
		self.myPreviousMonthBtn.tabIndex := 2;
	endif;	
	
	if self.myNextMonthBtn = null then
		create self.myNextMonthBtn transient;
		self.myNextMonthBtn.parent := self;
		form.addControl(self.myNextMonthBtn);		
		self.myNextMonthBtn.width := 20;
		self.myNextMonthBtn.caption := 216.Character; 
		self.myNextMonthBtn.fontName := "Wingdings";
		self.myNextMonthBtn.fontSize := 8;
		self.myNextMonthBtn.visible := true;
		self.myNextMonthBtn.tabIndex := 3;
	endif;	

	if self.myYearTextBox = null then
		create self.myYearTextBox transient;
		self.myYearTextBox.parent := self;
		form.addControl(self.myYearTextBox);	
		
		self.myYearTextBox.visible := true;
		self.myYearTextBox.maxLength := 4;
		self.myYearTextBox.dataType := 1;
		self.myYearTextBox.alignment := 2;
		//self.myYearTextBox.text := "9999";
		self.myYearTextBox.tabIndex := 4;
	endif;

	if self.myPreviousYearBtn = null then
		create self.myPreviousYearBtn transient;
		self.myPreviousYearBtn.parent := self;
		form.addControl(self.myPreviousYearBtn);		
		self.myPreviousYearBtn.width := 20;
		self.myPreviousYearBtn.caption := 215.Character; 
		self.myPreviousYearBtn.fontName := "Wingdings";
		self.myPreviousYearBtn.fontSize := 8;
		self.myPreviousYearBtn.visible := true;
		self.myPreviousYearBtn.tabIndex := 5;
	endif;	
	
	if self.myNextYearBtn = null then
		create self.myNextYearBtn transient;
		self.myNextYearBtn.parent := self;
		form.addControl(self.myNextYearBtn);		
		self.myNextYearBtn.width := 20;
		self.myNextYearBtn.caption := 216.Character; 
		self.myNextYearBtn.fontName := "Wingdings";
		self.myNextYearBtn.fontSize := 8;
		self.myNextYearBtn.visible := true;
		self.myYearTextBox.zOrder(1);
		self.myNextYearBtn.tabIndex := 6;
	endif;	
	
	self.cnEcResizeContents();
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcResizeContents" id="920b655b-bba6-48dc-85e7-d1b7498be2ec">
        <updating/>
        <source>cnEcResizeContents() updating;
/*

Date		    Who			Reason
28 October 2010	cnwas3	  Initial creation

*/

constants
	TopMargin		: Integer = 6;
	SideMargin		: Integer = 1;
	BottomMargin	: Integer = 3;
	
	VertSpacing		: Integer = 3;
	HorSpacing		: Integer = 3;
vars
	btnLeftPos,
	btnHeight,
	btnWidth,
	lstBoxWidth,
	topPos,
	totWidth,
	totHeight,
	leftMargin		: Real;
	availLstBox,
	selectLstBox	: CMUI_ListBox;
	smallLabelWidth,bigLabelWidth : Real;
begin
	
	if not self.isBuilt then
		return;
	endif;
	
	inheritMethod();
	
	totWidth 	:= self.clientWidth;
	totHeight	:= 20;
	btnWidth 	:= 20;
	smallLabelWidth := btnWidth * 2;
	bigLabelWidth 	:= totWidth - 7 * btnWidth;	
	
	leftMargin := SideMargin;
	
	self.height := totHeight + 5;	
	
	self.myMonthLabel.move(leftMargin,TopMargin,bigLabelWidth,totHeight);
	
	leftMargin := leftMargin + bigLabelWidth + btnWidth/10;
	self.myPreviousMonthBtn.move(leftMargin,TopMargin,btnWidth,totHeight);
	
	leftMargin := leftMargin + btnWidth;
	self.myNextMonthBtn.move(leftMargin,TopMargin,btnWidth,totHeight);
	
	leftMargin := leftMargin + btnWidth*5/4;
	self.myYearTextBox.move(leftMargin,TopMargin,smallLabelWidth,totHeight);
	
	leftMargin := leftMargin + smallLabelWidth + btnWidth/10;
	self.myPreviousYearBtn.move(leftMargin,TopMargin,btnWidth,totHeight);
	
	leftMargin := leftMargin + btnWidth;
	self.myNextYearBtn.move(leftMargin,TopMargin,btnWidth,totHeight);	
	
epilog

end;</source>
    </JadeMethod>
