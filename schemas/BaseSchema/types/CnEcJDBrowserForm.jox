    </JadeMethod>
    <JadeMethod name="findListParent" id="c94031bc-f1dc-4b30-8d44-7f86f08b41a1">
        <source>findListParent(pListbox:ListBox; pStartIndex:Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		27 January 1999 by cnwdad1
//
// Purpose:		Searches backwards through the listbox, and returns the parent list item
//				in the list hierarchy.
//
// Parameters:	pListbox (ListBox) - The listbox control to search.
//				pStartIndex (Integer) - The index position of the parent list item.
// Returns:		pStartIndex (Integer) - The index of the list item whose parent to find.
//				If this is 0 or 1, then a zero value will be returned.  Likewise, if a
//				parent is not found, then a zero value will be returned.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	index		: Integer;	// Current list item index.
	level		: Integer;	// Current list item level.
	childLevel	: Integer;	// Item Level of the child list item.

begin
	if (pStartIndex = 0) or (pStartIndex = 1) or (pListbox.listCount = 0) then
		return 0;
	endif;

	childLevel	:=	pListbox.itemLevel[pStartIndex];
	index		:=	pStartIndex - 1;

	while (index &gt; 0) do
		if (not level &gt; pListbox.listCount) then
			level		:=	pListbox.itemLevel[index];

			if (level = (childLevel - 1)) then
				// The parent item level should be 1 less than that of it's child.
				return index;
			endif;
		endif;

		index	:=	index - 1;	// We're stepping backwards through the list.
	endwhile;

	return 0;
end;</source>
        <Parameter name="pListbox" type="ListBox"/>
        <Parameter name="pStartIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
