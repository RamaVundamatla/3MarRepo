    <JadeMethod name="doMnuLcnPadHeights" id="70163a62-027c-4b29-aa0d-34938edefe8b">
        <updating/>
        <source>doMnuLcnPadHeights(_gridController : CM_GridController;_theMode, _theValue : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		We allow the user to paint power good, power bad, locations avail or unavail
//				Plus height restrictions. We store each of these as a seperate set of updates to the location controller
//				When they click the height save button we pass the array of CMIF objects to the TRX
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
//	aPoint : CMUI_GridPoint;
	anInterfaceObject : CMIF_GridTARegion;
//	theFrame : CMUI_GridAreaFrame;
	theStackController : CM_StackController;
	theInterfaceObjects : ObjectArray;
	aGridArea : CM_GridArea;
	result : Integer;
begin
	if not _gridController.isKindOf(CM_StackController) then
		return;
	endif;
	theStackController := _gridController.CM_StackController;
	aGridArea :=  theStackController.myTerminalArea.CM_GridArea;
	
	create anInterfaceObject transient;
	
//	theFrame := self.frmGridArea;
	anInterfaceObject.updateMode := _theMode;
	anInterfaceObject.myGridArea :=aGridArea;
	anInterfaceObject.allLocationControllers.add(theStackController);

	// ### HEIGHTS, Availability etc
	if _theMode &lt;&gt; CMIF_GridTARegion.UpdateMode_PowerGood
	and _theMode &lt;&gt; CMIF_GridTARegion.UpdateMode_PowerDamaged then
		anInterfaceObject.oldAvailability := theStackController.availability;
		anInterfaceObject.availability := _theValue;
	// ### POWER GOOD OR BAD
	else
		if theStackController.power then
			if _theMode = CMIF_GridTARegion.UpdateMode_PowerGood then
				anInterfaceObject.oldPowerDamaged := theStackController.powerDamaged;
			endif;
			// only do this if the point has a power ability
			if _theMode = CMIF_GridTARegion.UpdateMode_PowerDamaged and theStackController.power then 
				anInterfaceObject.oldPowerDamaged := theStackController.powerDamaged;
			endif;
		endif;
	endif;

	create theInterfaceObjects transient;
	theInterfaceObjects.add(anInterfaceObject);

	while true do
		app.myTrxUA.trxUpdateGridControllers(theInterfaceObjects,aGridArea,app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(theStackController.getFullId &amp; ' Pad Edit', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	delete anInterfaceObject;
	delete theInterfaceObjects;
	
end;</source>
        <Parameter name="_gridController" type="CM_GridController"/>
        <Parameter name="_theMode" type="Integer"/>
        <Parameter name="_theValue" type="Integer"/>
    </JadeMethod>
