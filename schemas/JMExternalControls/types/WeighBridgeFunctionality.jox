    <DbClassMap file="JMExternalControls"/>
    <ImplicitInverseRef name="myWeighBridgeCommunication" id="f5f84b63-0ab7-4335-aacb-833bba5b0412">
        <embedded/>
        <type name="ClassKomunikacja"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="confirmError" id="8bc03a4a-a07f-4247-b07c-b98e658bf8bd">
        <source>confirmError(_int : Integer io);

vars

begin

	if not self.isInitialised() then
		return;
	endif;
	
	self.myWeighBridgeCommunication.potwierdzenieBledu(_int);

end;
</source>
        <Parameter name="_int" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getStatus" id="d769a0fb-5489-4a81-8e98-5bd2659c63b5">
        <source>getStatus(_channel : Real io) : String;

vars

begin

	if not self.isInitialised() then
		return 'XXXX';
	endif;
	
	return self.myWeighBridgeCommunication.pobierzStatus(_channel);

end;
</source>
        <Parameter name="_channel" type="Real" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWeight" id="45d90bf2-6c7d-4cee-90b5-8934bd2167d2">
        <source>getWeight(_channel : Real io) : String;

vars

begin

	if not self.isInitialised() then
		return 'XXXX';
	endif;
	
	return self.myWeighBridgeCommunication.pobierzWage(_channel);

end;
</source>
        <Parameter name="_channel" type="Real" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initWeighBridgeCommunication" id="d9618596-bdd4-44be-8e68-03236aa9380a">
        <updating/>
        <source>initWeighBridgeCommunication(_iniFilePath : String) updating;

vars

	str		: String;
	r		: Real;

begin


	//vbNormal: 0 (default) Normal: vbMinimized: 1: Minimized (minimized to an icon) vbMaximized: 2: Maximized (enlarged to maximum size)

	create self.myWeighBridgeCommunication transient;
	
	str := _iniFilePath;
	//str := "C:\PortGdanskTest\waga.ini";
	
	// Initialise ini file path.
	self.myWeighBridgeCommunication.myIniPath(str);
	
	// Set format of returned weight.
	str := "#0.00";
	self.myWeighBridgeCommunication.ustawFormatWskazania(str);
		
	//self.myWeighBridgeCommunication.statusOkna(r);
	//self.myWeighBridgeCommunication.pokazOkno();
	
end;
</source>
        <Parameter name="_iniFilePath" type="String"/>
    </JadeMethod>
    <JadeMethod name="isInitialised" id="6929ddd2-ec45-46c8-9363-b92a4c174b85">
        <source>isInitialised() : Boolean protected;

vars

begin

	if self.myWeighBridgeCommunication = null then
		return false;
	endif;

end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reset" id="64729f38-ef5f-4e14-9ec5-a7f43b3b3854">
        <source>reset(_int : Integer io);

vars

begin

	if not self.isInitialised() then
		return;
	endif;
	
	self.myWeighBridgeCommunication.zerowanieWagi(_int);

end;
</source>
        <Parameter name="_int" type="Integer" usage="io"/>
    </JadeMethod>
</Class>
