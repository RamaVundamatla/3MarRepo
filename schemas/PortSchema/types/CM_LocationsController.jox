    <JadeMethod name="getMinMaxForFirstTI" id="c9be5a8e-0a65-491a-b9c1-0163f55785b5">
        <source>getMinMaxForFirstTI() : CM_TerminalAreaProductMinMax;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2016	cnwndl1	Initial creation

*/

vars

	firstTi : CM_TrackedItem;
	array : CM_TIArray;
	ct : CM_CargoType;
	ta : CM_TerminalArea;
	minMax : CM_TerminalAreaProductMinMax;

begin

	create array transient;
	self.getTIs(array,REAL_MODE, true);
	
	if not array.isEmpty then
		firstTi := array.first;
		if firstTi &lt;&gt; null then
			ct := firstTi.myCargoType;
			ta := self.getMyTerminalArea;
			if ta &lt;&gt; null and ct &lt;&gt; null then
				minMax := self.getProductMinMaxObject( ct, firstTi.myProduct );	//29 Mar 2021	NDL TFS 49912
				if minMax &lt;&gt; null then
					return minMax;
				else
					return ta.getProductMinMaxObject( ct, firstTi.myProduct );
				endif;
			endif;
		endif;
	elseif array.isEmpty then
		//24/3/22 52052 jlier1
		if self.isKindOf(CM_GeneralCargoAllocController) then
			return null;
		endif;
		
		ta := self.getMyTerminalArea;
		if ta &lt;&gt; null and ta.allProductMinMax.size = 1 then
			return ta.allProductMinMax.first;
		endif;
	endif;
	
	return null;

epilog

	delete array;

end;</source>
        <ReturnType type="CM_TerminalAreaProductMinMax"/>
    </JadeMethod>
