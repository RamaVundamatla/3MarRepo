    <JadeMethod name="validateForUpdate" id="ee3eb74b-da6d-47ca-8181-dcd9421eae36">
        <source>validateForUpdate(_realDefinitionObj:SelfType; _passportObj:CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
