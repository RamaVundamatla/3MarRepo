    <JadeMethod name="hasErrorsIgnored" id="751a53fe-e180-44fe-9b25-6e274ae1b047">
        <source>hasErrorsIgnored() : Boolean;
// ---------------------------------------------------------------------------
// Created:     Sept 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	error : CM_Error;
begin
	if self.allErrors.isEmpty() then
		return false;
	endif;
	if self.errorsToIgnore.isEmpty then
		return true;
	endif;
	
	foreach error in self.allErrors do
		if not self.errorsToIgnore.includes(error.errorCode) then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasErrorsOrNonIgnoredWarnings" id="bc294864-742a-43a3-af8e-a183981c1262">
        <source>hasErrorsOrNonIgnoredWarnings() : Boolean;

/*

Purpose:			Determine whether there are any errors or non-ignored warnings

Parameters:			None

Return Value:		True if there are any errors
					True if there are warnings and we're not ignoring them
					False otherwise


Date		Who		Reason
27 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars

begin
	if self.hasErrors() then
		return true;
	endif;
	
	if not self.warningsIgnored and self.hasWarnings then
		return true;
	endif;
	
	return false;
	

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
