    <JadeMethod name="utlUpdateMarineTimings" id="0cf910bd-31f3-4d28-86fa-b9102d050800">
        <updating/>
        <source>utlUpdateMarineTimings( _proxy : HMS_MarineServicesTimings input; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 June 2018	jlgndl1	Initial creation	TFS 39215
9 Dec 2025		navlw1	JIRA-36117: ATD | Marine Service Audits - unit tests

*/

vars

	realMovement : HMS_Movement;
	expectedEdition : Integer;
	realTiming : HMS_MarineServicesTimings;
	
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	realMovement := _proxy.myMovement;
	
	if realMovement = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, 'Voyage Movement', null, null);
		return;
	endif;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realMovement);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMovement, true);
	endif;
	
	if _passport.noErrors then
		if realMovement.myMarineServiceTimings = null then 
			create realTiming persistent; 
		else 
			realTiming := realMovement.myMarineServiceTimings;
		endif; 
		realTiming.setMyVoyageMovement(realMovement);
		realTiming.setForUpdate(_proxy, _passport);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMovement, false);
	endif;

end;</source>
        <Parameter name="_proxy" type="HMS_MarineServicesTimings" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateMeasurementType" id="089299e5-f61a-4789-a8e6-88a194e95773">
        <source>utlUpdateMeasurementType(	_proxyMeasurement : CM_MeasurementType;
							_passport : CM_Passport input	);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	cancelSave 		: Boolean;
	realMeasurement	: CM_MeasurementType;
	expectedEdition	: Integer;
	eventStr 		: String;
	codeChanged		: Boolean;
	terminal 		: CM_Terminal;
	
begin
	self.initialiseActivity();

	_proxyMeasurement.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);
	_proxyMeasurement.pxyGetRealObjectAndEdition(realMeasurement, expectedEdition);
	
	if realMeasurement = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_MeasurementType.name, null, null);
		return;
	endif;

	app.myValUA.valMeasurementType(realMeasurement, _proxyMeasurement);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;
	app.setContinueCMExceptions(false);

	exclusiveLock(realMeasurement);

	if _passport.noErrors and realMeasurement.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Measurement Type', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMeasurement, true);
	endif;
	
	if _passport.noErrors then
		realMeasurement.setForUpdate(_proxyMeasurement);
	endif;
	
	if _passport.noErrors then
		realMeasurement.checkForDefault;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMeasurement, false);
	endif;
	//navsp1 01Jun2022 TFS#53104
	if _passport.noErrors then
		if _passport.isOpsViewEnabled(null) then
			realMeasurement.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE, BGP_OpsViewWSRequest.OPS_TYPE_MEASUREMENTTYPE, realMeasurement);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_proxyMeasurement" type="CM_MeasurementType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateMediatorResponseValue" id="97524025-29c6-4189-b34a-d32dda7b395a">
        <source>utlUpdateMediatorResponseValue(_mediator : CM_RadioTelemetryMediator input;
							   _index : Integer;
							   _response : String;
							   _passport : CM_Passport input);

/*

Purpose:			Set the mediator response value at the index passed in to the value passed in.
					If this is the final pending response, then create the fault responses for
					the receiver machine, and set the "outstanding question flag to false.

Parameters:			Mediator to update
					Index into fault question array
					Response from driver (Yes/No)

Return Value:		None


Date		Who		Reason
26 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	responseStr		: String;
	faultQuestion	: CM_FaultQuestion;
	faultResponse	: CM_FaultResponse;
	faultArray		: CM_FaultResponseArray;
	index			: Integer;
	stillOutstanding	: Boolean;
	now				: TimeStamp;
	invalidFault	: Boolean;
	
begin
	// Validate index first
	if _index &lt; 1 or _index &gt; _mediator.allFaultResponses.size then
		app.raiseCMException(ERR_MACH_INVALIDQUESTIONID, null, null);
	endif;
	
	// Validate response
	if _response &lt;&gt; AuditStringValue_Yes and _response &lt;&gt; AuditStringValue_No then
		app.raiseCMException1(ERR_MACH_INVALIDFAULTRESP, _response, null, null);
	endif;
	
	// Set the response from the input
	_mediator.allFaultResponses[_index] := _response;
	
	// If we have just set the last response, then create the persistent fault(s) required
	if _mediator.isFaultQuestionOutstanding then
	
		now := app.actualTimeServer;
	
		on Exception do app.handleDeletedObject(exception, faultQuestion, invalidFault);
		
		create faultArray transient;
		foreach index in 1 to _mediator.allFaultQuestions.size do
			faultQuestion := _mediator.allFaultQuestions[index];
			responseStr := _mediator.allFaultResponses[index];
			
			// Have we still got at least one unanswered question?
			if responseStr = null then
				stillOutstanding := true;
				break;
			endif;
			
			invalidFault := false;
			
			// Create proxy ready for fault create if required
			create faultResponse transient;
			faultResponse.setProxy(_mediator.machine,				// _machine : CM_Machine;
								   _mediator.user,					// _reportedUser : CM_User;		
								   null,							// _previousUser : String;
								   faultQuestion,					// _faultQuestion : CM_FaultQuestion;
								   faultQuestion.description,		// _question :String;
								   now,								// _reportedTS : TimeStamp;
								   responseStr);					// _response : String) updating;

			// If a question has been deleted, then just ignore it
			if invalidFault then
				delete faultResponse;
			else
				faultArray.add(faultResponse);
			endif;
		endforeach;
		
		// If we now have all the responses, then create any faults
		if not stillOutstanding then
			app.myUtilityCA.utlCreateFaultResponses(faultArray,
													app.getMyTerminalDO_NOT_USE(),
													_passport);
			
			// And set the outstanding question flag 
			_mediator.setIsFaultQuestionOutstanding(false);
		endif;
		
	endif;
	
	
epilog
	if faultArray &lt;&gt; null then
		faultArray.purge();
		delete faultArray;
	endif;
	
end;
</source>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_response" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateMenuToolbarAdd" id="74068424-cf1c-4623-b490-4dd8414446d8">
        <source>utlUpdateMenuToolbarAdd(_theRealUserTerminal : CM_UserTerminal input;
						_theProxyMenuItem :CM_MenuUserDtl input;
						_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	realMenuUserDtl:CM_MenuUserDtl;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	_theProxyMenuItem.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_theProxyMenuItem.pxyGetRealObjectAndEdition(realMenuUserDtl, expectedEdition);
	
	if realMenuUserDtl = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_MenuUserDtl.name, null, null);
		return;
	endif;

	app.myValUA.valMenuToolbarAdd(_theProxyMenuItem);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realMenuUserDtl);

	if _passport.noErrors and realMenuUserDtl.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'MenuUserDtl', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMenuUserDtl, true);
	endif;
	
	if _passport.noErrors then
		realMenuUserDtl.setForUpdateToolbarAdd(_theRealUserTerminal);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMenuUserDtl, false);
	endif;

end;</source>
