        <Parameter name="dwCharSet" type="Integer"/>
        <Parameter name="dwOutputPrecision" type="Integer"/>
        <Parameter name="dwClipPrecision" type="Integer"/>
        <Parameter name="dwQuality" type="Integer"/>
        <Parameter name="dwPitchAndFamily" type="Integer"/>
        <Parameter name="lpszFace" type="String"/>
        <ReturnType type="Integer"/>
    </Function>
