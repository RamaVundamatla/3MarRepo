    <JadeMethod name="delete" id="4aaf5e12-68f5-4961-8f7e-b5260dbec867">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2014	cnwmc5	Initial creation

*/

vars

begin
	if self.allTicketSequences &lt;&gt; null and not self.allTicketSequences.isEmpty() then
		self.allTicketSequences.purge();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setLogDocketProxy" id="52795947-82f3-4a2a-9564-b9fd29f8b143">
        <source>setLogDocketProxy(logDocket : CM_LogDocketData io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 March 2014	cnwmc5	Initial creation

*/

vars
	ticketSequenceData,
	pxyTicketSequenceData	: CM_TicketSequenceData;
	
	wsTicketSequence		: WS_TicketSequence;
	
	obj 					: Object;
	
	load					: Boolean;
	
begin
	logDocket.setProxy(	self.backload,
						self.carrierCode,
						self.chhSupplier,
						self.compartment,
						self.consignorCode,
						self.customer,
						self.docketError,
						self.docketNumber,
						self.driverId,
						self.driversPieceCountError,
						self.fellingDate.asDateFromWebInterface,			//cnwmc5 - 26 Jan 2016 - PAR 37326
						self.forest,
						self.fsc,
						self.gangNumber,
						self.grade,
						self.jasScaled,
						self.length,
						self.loaderNumber,
						self.loadingContractor,
						self.logType,
						self.loggingContractor,
						self.loggingOperation,
						self.loggingOrganisation,
						self.nightshift,
						self.numItems,
						self.numberOfLifts,
						self.operatorCode,
						self.opid,
						self.percentScaled,
						self.pickupPoint,
						self.pieceCountError,
						self.receiptRequired,
						self.remarks,
						self.scalerCode,
						self.species,
						self.stand,
						self.ticketedAll,
						self.trailerNumber,
						self.treatment,
						self.truckCategory,
						self.truckNumber,
						self.unloadPoint,
						self.vehicleID,
						self.weighbridge,
						self.weightGross,
						self.weightNet,
						self.weightTare,
						self.yardLocation,
						app.getMyTerminalDO_NOT_USE);
	
	foreach wsTicketSequence in self.allTicketSequences do
		obj := wsTicketSequence.cmObjectId.asObject;
		if obj &lt;&gt; null and obj.isKindOf(CM_TicketSequenceData) and app.isValidObject(obj) then
			ticketSequenceData := obj.CM_TicketSequenceData;
			app.cmsBeginLoad(load);
			pxyTicketSequenceData := ticketSequenceData.pxyCreateUpdateProxy();
			app.cmsEndLoad(load);
		else
			create pxyTicketSequenceData transient;
		endif;
		
		pxyTicketSequenceData.setProxy(	wsTicketSequence.fromId,
										wsTicketSequence.toId,
										wsTicketSequence.scale,
										logDocket);
	endforeach;
	
epilog
	app.cmsEndLoad(load);
end;</source>
        <Parameter name="logDocket" type="CM_LogDocketData" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setLogDocketUpdateProxy" id="e3445827-c14e-4264-9e4b-d64b9cc1a1e5">
        <source>setLogDocketUpdateProxy(logDocket : CM_LogDocketData io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2014	cnwmc5	Initial creation

*/

vars

begin
	logDocket.setProxyDocketNumberWeigh(self.cmObjectId);
	
	self.setLogDocketProxy(logDocket);
	
epilog

end;</source>
        <Parameter name="logDocket" type="CM_LogDocketData" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="4531d01f-9396-468c-9655-ce98301063f0">
        <updating/>
        <source>setProxyFromObject(_logDocket: CM_LogDocketData) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2014	cnwmc5	Initial creation

*/

vars
	ticketSequence		: CM_TicketSequenceData;
	
	wsTicketSequence	: WS_TicketSequence;
	
begin
	inheritMethod(_logDocket);
	
	foreach ticketSequence in _logDocket.allTicketSequenceData do
		create wsTicketSequence transient;
		wsTicketSequence.setProxyFromObject(ticketSequence);
		self.allTicketSequences.add(wsTicketSequence);
	endforeach;
	
	self.backload 				:= _logDocket.backload;
	self.carrierCode 			:= _logDocket.carrierCode;
	self.chhSupplier 			:= _logDocket.chhSupplier;
	self.compartment 			:= _logDocket.compartment;
	self.consignorCode 			:= _logDocket.consignorCode;
	self.customer 				:= _logDocket.customer;
	self.docketError 			:= _logDocket.docketError;
	self.docketNumber 			:= _logDocket.docketNumber;
	self.driverId 				:= _logDocket.driverId;
	self.driversPieceCountError	:= _logDocket.driversPieceCountError;
	self.fellingDate			:= _logDocket.date.asStringForWebInterface;			//cnwmc5 - 26 Jan 2016 - PAR 37326
	self.forest 				:= _logDocket.forest;
	self.fsc					:= _logDocket.isFSC;
	self.gangNumber				:= _logDocket.loggingGang;
	self.grade					:= _logDocket.logGradeCode;
	self.jasScaled				:= _logDocket.jasScaled;
	self.length					:= _logDocket.lengthRandom;
	self.loaderNumber			:= _logDocket.loaderNumber;
	self.loadingContractor		:= _logDocket.loadingContractor;
	self.logType				:= _logDocket.logTypeCode;
	self.loggingContractor		:= _logDocket.loggingContractor;
	self.loggingOperation		:= _logDocket.loggingOperation;
	self.loggingOrganisation	:= _logDocket.loggingOrganisation;
	self.nightshift				:= _logDocket.nightshift;
	self.numItems				:= _logDocket.numPieces;
	self.numberOfLifts			:= _logDocket.numberOfLifts;
	self.operatorCode			:= _logDocket.operatorCode;
	self.opid					:= _logDocket.opid;
	self.percentScaled			:= _logDocket.percentScaled;
	self.pickupPoint			:= _logDocket.pickupPoint;
	self.pieceCountError		:= _logDocket.pieceCountError;
	self.receiptRequired		:= _logDocket.receiptRequired;
	self.remarks				:= _logDocket.remarks;
	self.scalerCode				:= _logDocket.scalerCode;
	self.species 				:= _logDocket.logSpeciesCode;
	self.stand					:= _logDocket.stand;
	self.ticketedAll			:= _logDocket.ticketedAll;
	self.trailerNumber			:= _logDocket.trailerNumber;
	self.treatment				:= _logDocket.logTreatmentCode;
	self.truckCategory			:= _logDocket.truckCategory;
	self.truckNumber			:= _logDocket.truckId;
	self.unloadPoint			:= _logDocket.unloadPoint;
	self.vehicleID				:= _logDocket.regNo;
	self.weighbridge			:= _logDocket.weighbridge;
	self.weightGross			:= _logDocket.weightGross.Integer;
	self.weightNet				:= _logDocket.weightNett.Integer;
	self.weightTare				:= _logDocket.weightTare.Integer;
	self.yardLocation			:= _logDocket.yardLocation;
	
epilog

end;</source>
        <Parameter name="_logDocket" type="CM_LogDocketData"/>
    </JadeMethod>
</Class>
