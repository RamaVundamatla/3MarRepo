    <JadeMethod name="calculate" id="2c12748d-2d60-4361-b124-785298e50c01">
        <updating/>
        <source>calculate( _load : Boolean; _fromControl : Control ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2014	cnwndl1	Initial creation		Par 33268

*/

vars

	scaleWeight : Decimal [23,10];
	truckTare : Decimal [23,10];
	chassisTare : Decimal [23,10];
	gennyTare : Decimal [23,10];
	machineTare : Decimal [23,10];
	adjustment : Decimal [23,10];
	cargoTotalWeight : Decimal [23,10];
	
	weightType : CM_MeasurementType;
	hasCargo : Boolean;
	needsToCalculate : Boolean;
	
	obj : Object;

begin
	//epr TFS 44965 3/7/19
	if self.myWeighBridge &lt;&gt; null and self.myWeighBridge.isTwoReadings then
		return;
	endif;
	
	
	app.mousePointer :=	Busy;

	if _load then
		self.setTareWeights();
	endif;

	scaleWeight := self.tblScaleWeight.getConvertedValue;
	adjustment := self.tblAdjustmentW.getConvertedValue;
	truckTare := self.tblTruckTareW.getConvertedValue;
	chassisTare := self.tblChassisTareW.getConvertedValue;
	gennyTare := self.tblGennyTareW.getConvertedValue;
	machineTare := self.tblMachineTareW.getConvertedValue;
	self.btnUpdate.visible := false;
	self.btnUpdCargo.visible := false;
	self.btnUpdTruck.visible := false;
	self.btnUpdChassis.visible := false;
	self.btnUpdGenny.visible := false;
	self.btnUpdMachine.visible := false;
	
	if self.txtPlusMinus.text = "+" then
		needsToCalculate := ( scaleWeight + adjustment ) &lt;&gt; 0;
	else
		needsToCalculate := ( scaleWeight - adjustment ) &lt;&gt; 0;
	endif;
	
	
	if self.myTruck &lt;&gt; null then
		self.btnUpdTruck.bubbleHelp := app.getErrorString1( Update_tare_weight, self.myTruck.regNumber );
	endif;
	self.btnUpdChassis.bubbleHelp := app.getErrorString1( Update_tare_weight, self.cmbChassis.text );
	if self.myGenerator &lt;&gt; null then
		self.btnUpdGenny.bubbleHelp := app.getErrorString1( Update_generat_total_weight, self.myGenerator.id );
	elseif cmbGenny.listObject &lt;&gt; null and cmbGenny.listObject.isKindOf( CM_GeneratorType ) then
		self.btnUpdGenny.bubbleHelp := app.getErrorString1( Update_default_weight, self.cmbGenny.text );
	elseif cmbGenny.listObject &lt;&gt; null and cmbGenny.listObject.isKindOf( CM_ISOType ) then
		self.btnUpdGenny.bubbleHelp := app.getErrorString1( Update_tare_weight, self.cmbGenny.text );
	endif;
	if self.myMachine &lt;&gt; null then
		self.btnUpdMachine.bubbleHelp := app.getErrorString1( Update_tare_weight, self.myMachine.id );
	endif;
	
	hasCargo := self.myTrackedItem &lt;&gt; null or ( self.tiId &lt;&gt; null and ( self.myCargoType &lt;&gt; null or self.myCargoType &lt;&gt; null ) );
	
	if hasCargo and needsToCalculate then
	
		if self.myTrackedItem &lt;&gt; null then
			weightType := self.myTrackedItem.myCargoType.getDefaultMeasurementForType(Type_Weight);
		elseif self.myCargoType &lt;&gt; null then
			weightType := self.myCargoType.getDefaultMeasurementForType(Type_Weight);
		elseif self.myProduct &lt;&gt; null then
			weightType := self.myProduct.getDefaultMeasurementForType(Type_Weight);
		endif;
	
		if txtPlusMinus.text = self.SubtractingWeight then
			cargoTotalWeight := ( scaleWeight - adjustment ) - (truckTare + chassisTare + gennyTare + machineTare );
		else
			cargoTotalWeight := ( scaleWeight + adjustment ) - (truckTare + chassisTare + gennyTare + machineTare );
		endif;
		if cargoTotalWeight &lt; 0 then
			cargoTotalWeight := 0;
		endif;
		if _load or _fromControl &lt;&gt; self.tblCargoTotalW then
			self.tblCargoTotalW.setValues(app.convertMeasurementForDisplay(weightType.shortName, cargoTotalWeight) &amp; Space &amp; weightType.shortName);
		endif;
		if  cargoTotalWeight &lt;&gt; 0 then
			//if self.myTrackedItem &lt;&gt; null and ( (self.myTrackedItem.totalWeight &lt;&gt; cargoTotalWeight) or (self.chkCertified.value &lt;&gt; self.myTrackedItem.isWeightCertified) )then
			//	self.btnUpdCargo.visible := true;
			if self.myTrackedItem &lt;&gt; null then
				self.makeBtnVisibleIfUpdatable( self.btnUpdCargo, (self.chkCertified.value &lt;&gt; self.myTrackedItem.isWeightCertified), self.myTrackedItem.totalWeight, cargoTotalWeight, self.tblCargoTotalW );
			elseif self.myParentForm.isKindOf( CMUI_ReceiveCargoForm ) then
				//self.btnUpdCargo.visible := true;
				self.makeBtnVisibleIfUpdatable( self.btnUpdCargo, true, 0, cargoTotalWeight, self.tblCargoTotalW );
			endif;
		endif;
		
		//Allow updting of values set manually or by default.
		if self.grpTruck.visible then
			if truckTare &lt;&gt; 0 then
				//self.btnUpdTruck.visible := self.myTruck.tareKilos &lt;&gt; truckTare and truckTare &lt;&gt; 0;
				self.makeBtnVisibleIfUpdatable( self.btnUpdTruck, false, self.myTruck.tareKilos, truckTare, self.tblTruckTareW );
			endif;
			if chassisTare &lt;&gt; 0 then
				if self.myChassis &lt;&gt; null then
					//self.btnUpdChassis.visible := ( self.myChassis.weightTare &lt;&gt; chassisTare and chassisTare &lt;&gt; 0 );
					self.makeBtnVisibleIfUpdatable( self.btnUpdChassis, false, self.myChassis.weightTare, chassisTare, self.tblChassisTareW );
				elseif self.cmbChassis.listObject &lt;&gt; null then
					//self.btnUpdChassis.visible := ( self.cmbChassis.listObject.CM_TILCType.tareWeight &lt;&gt; chassisTare and chassisTare &lt;&gt; 0);
					self.makeBtnVisibleIfUpdatable( self.btnUpdChassis, false, self.cmbChassis.listObject.CM_TILCType.tareWeight, chassisTare, self.tblChassisTareW );
				endif;
			endif;
			if gennyTare &lt;&gt; 0 then
				if self.myGenerator &lt;&gt; null then
					//self.btnUpdGenny.visible := self.myGenerator.weightTare &lt;&gt; gennyTare and gennyTare &lt;&gt; 0;
					self.makeBtnVisibleIfUpdatable( self.btnUpdGenny, false, self.myGenerator.weightTare, gennyTare, self.tblGennyTareW );
				elseif self.cmbGenny.listObject &lt;&gt; null then
					obj := self.cmbGenny.listObject;
					if obj.isKindOf( CM_GeneratorType ) then
						//self.btnUpdGenny.visible := self.cmbGenny.listObject.CM_GeneratorType.defaultWeight &lt;&gt; gennyTare and gennyTare &lt;&gt; 0;
						self.makeBtnVisibleIfUpdatable( self.btnUpdGenny, false, self.cmbGenny.listObject.CM_GeneratorType.defaultWeight, gennyTare, self.tblGennyTareW );
					elseif obj.isKindOf( CM_ISOType ) then
						//self.btnUpdGenny.visible := self.cmbGenny.listObject.CM_ISOType.tareKilos &lt;&gt; gennyTare and gennyTare &lt;&gt; 0;
						self.makeBtnVisibleIfUpdatable( self.btnUpdGenny, false, self.cmbGenny.listObject.CM_ISOType.tareKilos, gennyTare, self.tblGennyTareW );
					endif;
				endif;
			endif;
		elseif self.grpMachine.visible then
			if self.myMachine &lt;&gt; null then
				//self.btnUpdMachine.visible := self.myMachine.tareWeight &lt;&gt; machineTare and machineTare &lt;&gt; 0;
				self.makeBtnVisibleIfUpdatable( self.btnUpdMachine, false, self.myMachine.tareWeight, machineTare, self.tblMachineTareW );
			endif;
		endif;
	
	elseif not _load and not needsToCalculate then
		// No Scale Weight or Adjustment, only show the buttons if the user has updated the weight value.
		
		if self.grpMachine.visible then
		
			if self.myMachine &lt;&gt; null then
				//machine tare weight
				machineTare := self.tblMachineTareW.getConvertedValue;
				self.makeBtnVisibleIfUpdatable( self.btnUpdMachine, false, self.myMachine.tareWeight, machineTare, self.tblMachineTareW );
			endif;
	
		elseif grpTruck.visible then
		
			//generator tare weight
			if self.myGenerator &lt;&gt; null then
				self.makeBtnVisibleIfUpdatable( self.btnUpdGenny, false, self.myGenerator.totalWeight, gennyTare, self.tblGennyTareW );
				
			elseif self.cmbGenny.listObject &lt;&gt; null then
				obj := self.cmbGenny.listObject;
				if obj.isKindOf( CM_GeneratorType ) then
					//generator type tare
					self.makeBtnVisibleIfUpdatable( self.btnUpdGenny, false, self.cmbGenny.listObject.CM_GeneratorType.defaultWeight, gennyTare, self.tblGennyTareW );
				elseif obj.isKindOf( CM_ISOType ) then
					//iso type tare
					self.makeBtnVisibleIfUpdatable( self.btnUpdGenny, false, self.cmbGenny.listObject.CM_ISOType.tareKilos, gennyTare, self.tblGennyTareW );
				endif;
			
			elseif self.myChassis &lt;&gt; null then
				// chassis tare
				self.makeBtnVisibleIfUpdatable( self.btnUpdChassis, false, self.myChassis.weightTare, chassisTare, self.tblChassisTareW );
				
			elseif self.cmbChassis.listObject &lt;&gt; null then
				//chassis type tare
				self.makeBtnVisibleIfUpdatable( self.btnUpdChassis, false, self.cmbChassis.listObject.CM_TILCType.tareWeight, chassisTare, self.tblChassisTareW );
				
			elseif self.myTruck &lt;&gt; null then
				//truck tare
				self.makeBtnVisibleIfUpdatable( self.btnUpdTruck, false, self.myTruck.tareKilos, truckTare, self.tblTruckTareW );
				
			endif;
		
		endif;
	
	elseif not _load then
		
		weightType := app.getDefaultMeasurementForType(Type_Weight);
		
		//process in reverse order
		
		if self.grpMachine.visible then
		
			if self.myMachine &lt;&gt; null then
				//machine tare weight
				if txtPlusMinus.text = self.SubtractingWeight then
					machineTare := ( scaleWeight - adjustment );
				else
					machineTare := ( scaleWeight + adjustment );
				endif;
				if machineTare &lt; 0 then
					machineTare := 0;
				endif;
				if _fromControl &lt;&gt; self.tblMachineTareW then
					self.tblMachineTareW.setValues(app.convertMeasurementForDisplay(weightType.shortName, machineTare) &amp; Space &amp; weightType.shortName);
				endif;
				//self.btnUpdMachine.visible := self.myMachine.tareWeight &lt;&gt; machineTare and machineTare &lt;&gt; 0;
				self.makeBtnVisibleIfUpdatable( self.btnUpdMachine, false, self.myMachine.tareWeight, machineTare, self.tblMachineTareW );
				
			endif;
			
		elseif grpTruck.visible then
			
			if self.myGenerator &lt;&gt; null then
				//generator tare weight
				if txtPlusMinus.text = self.SubtractingWeight then
					gennyTare := ( scaleWeight - adjustment ) - ( truckTare + chassisTare );
				else
					gennyTare := ( scaleWeight + adjustment ) - ( truckTare + chassisTare );
				endif;
				if gennyTare &lt; 0 then
					gennyTare := 0;
				endif;
				if _fromControl &lt;&gt; self.tblGennyTareW then
					self.tblGennyTareW.setValues(app.convertMeasurementForDisplay(weightType.shortName, gennyTare) &amp; Space &amp; weightType.shortName);
				endif;
				//self.btnUpdGenny.visible := self.myGenerator.totalWeight &lt;&gt; gennyTare and gennyTare &lt;&gt; 0;
				self.makeBtnVisibleIfUpdatable( self.btnUpdGenny, false, self.myGenerator.totalWeight, gennyTare, self.tblGennyTareW );
				
			elseif self.cmbGenny.listObject &lt;&gt; null then
				obj := self.cmbGenny.listObject;
				if obj.isKindOf( CM_GeneratorType ) then
					//generator type tare
					if txtPlusMinus.text = self.SubtractingWeight then
						gennyTare := ( scaleWeight - adjustment ) - ( truckTare + chassisTare );
					else
						gennyTare := ( scaleWeight + adjustment ) - ( truckTare + chassisTare );
					endif;
					if gennyTare &lt; 0 then
						gennyTare := 0;
					endif;
					if _fromControl &lt;&gt; self.tblGennyTareW then
						self.tblGennyTareW.setValues(app.convertMeasurementForDisplay(weightType.shortName, gennyTare) &amp; Space &amp; weightType.shortName);
					endif;
					//self.btnUpdGenny.visible := self.cmbGenny.listObject.CM_GeneratorType.defaultWeight &lt;&gt; gennyTare and gennyTare &lt;&gt; 0;
					self.makeBtnVisibleIfUpdatable( self.btnUpdGenny, false, self.cmbGenny.listObject.CM_GeneratorType.defaultWeight, gennyTare, self.tblGennyTareW );
					
				elseif obj.isKindOf( CM_ISOType ) then
					//iso type tare
					if txtPlusMinus.text = self.SubtractingWeight then
						gennyTare := ( scaleWeight - adjustment ) - ( truckTare + chassisTare );
					else
						gennyTare := ( scaleWeight + adjustment ) - ( truckTare + chassisTare );
					endif;
					if gennyTare &lt; 0 then
						gennyTare := 0;
					endif;
					if _fromControl &lt;&gt; self.tblGennyTareW then
						self.tblGennyTareW.setValues(app.convertMeasurementForDisplay(weightType.shortName, gennyTare) &amp; Space &amp; weightType.shortName);
					endif;
					//self.btnUpdGenny.visible := self.cmbGenny.listObject.CM_ISOType.tareKilos &lt;&gt; gennyTare and gennyTare &lt;&gt; 0;
					self.makeBtnVisibleIfUpdatable( self.btnUpdGenny, false, self.cmbGenny.listObject.CM_ISOType.tareKilos, gennyTare, self.tblGennyTareW );
					
				endif;
			
			elseif self.myChassis &lt;&gt; null then
				// chassis tare
				if txtPlusMinus.text = self.SubtractingWeight then
					chassisTare := ( scaleWeight - adjustment ) - truckTare;
				else
					chassisTare := ( scaleWeight + adjustment ) - truckTare;
				endif;
				if chassisTare &lt; 0 then
					chassisTare := 0;
				endif;
				if _fromControl &lt;&gt; self.tblChassisTareW then
					self.tblChassisTareW.setValues(app.convertMeasurementForDisplay(weightType.shortName, chassisTare) &amp; Space &amp; weightType.shortName);
				endif;
				//self.btnUpdChassis.visible := self.myChassis.weightTare &lt;&gt; chassisTare and chassisTare &lt;&gt; 0;
				self.makeBtnVisibleIfUpdatable( self.btnUpdChassis, false, self.myChassis.weightTare, chassisTare, self.tblChassisTareW );
				
			elseif self.cmbChassis.listObject &lt;&gt; null then
				//chassis type tare
				if txtPlusMinus.text = self.SubtractingWeight then
					chassisTare := ( scaleWeight - adjustment ) - truckTare;
				else
					chassisTare := ( scaleWeight + adjustment ) - truckTare;
				endif;
				if chassisTare &lt; 0 then
					chassisTare := 0;
				endif;
				if _fromControl &lt;&gt; self.tblChassisTareW then
					self.tblChassisTareW.setValues(app.convertMeasurementForDisplay(weightType.shortName, chassisTare) &amp; Space &amp; weightType.shortName);
				endif;
				//self.btnUpdChassis.visible := self.cmbChassis.listObject.CM_TILCType.tareWeight &lt;&gt; chassisTare and chassisTare &lt;&gt; 0;
				self.makeBtnVisibleIfUpdatable( self.btnUpdChassis, false, self.cmbChassis.listObject.CM_TILCType.tareWeight, chassisTare, self.tblChassisTareW );
				
			elseif self.myTruck &lt;&gt; null then
				//truck tare
				if txtPlusMinus.text = self.SubtractingWeight then
					truckTare := ( scaleWeight - adjustment );
				else
					truckTare := ( scaleWeight + adjustment );
				endif;
				if truckTare &lt; 0 then
					truckTare := 0;
				endif;
				if _fromControl &lt;&gt; self.tblTruckTareW then
					self.tblTruckTareW.setValues(app.convertMeasurementForDisplay(weightType.shortName, truckTare) &amp; Space &amp; weightType.shortName);
				endif;
				//self.btnUpdTruck.visible := self.myTruck.tareKilos &lt;&gt; truckTare and truckTare &lt;&gt; 0;
				self.makeBtnVisibleIfUpdatable( self.btnUpdTruck, false, self.myTruck.tareKilos, truckTare, self.tblTruckTareW );
				
			endif;
			
		endif;
		
	endif;
		
epilog
	
	app.mousePointer :=	Idle;

end;</source>
