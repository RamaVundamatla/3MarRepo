    <JadeMethod name="delete" id="e0952003-ed62-41ce-baa8-b0805906a6f2">
        <updating/>
        <source>delete() updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 September 2004 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myObjectValue &lt;&gt; null and global.isValidObject(self.myObjectValue) then
		self.myObjectValue.cnEcReportPVDestructor();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayTab" id="8c94b3e6-0d44-4a7b-a3dc-8502de22d080">
        <source>displayTab():String;
// --------------------------------------------------------------------------------
// Created:		24 July 2000 by cnwdad1
//
// Purpose:		Returns a string for displaying the parameter value details in a
//				table control.
//
// Parameters:	None
//
// Returns:		The tab-delimited display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowString	: String;

begin
	rowString	:=	self.myReportParameter.displayValue &amp; Tab &amp; Tab &amp; self.myReportParameter.parameterType &amp; Tab;

	if (self.myObjectValue = null) then
		rowString	:=	rowString &amp; self.stringValue;
	else
		rowString	:=	rowString &amp; self.myObjectValue.cnEcReportDisplay();
	endif;

	rowString	:=	rowString &amp; Tab &amp; self.myReportParameter.sequence.String;
epilog
	return rowString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="1ce07c9b-546a-4db5-9c38-6170154335c0">
        <updating/>
        <source>initializeMe(	pQueueEntry:CnEcReportQueueEntry;
				pReportParameter:CnEcReportParameter;
				pObjectValue:Object;
				pStringValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Initializes the receiver's property values.
//
// Parameters:	Matching property parameters.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// First, set any properties...

	self.myObjectValue		:=	pObjectValue;
	self.stringValue		:=	pStringValue;

	// Next, set any key properties...

	self.myReportParameter	:=	pReportParameter;

	// Finally, set any references...

	self.myReportQueueEntry	:=	pQueueEntry;
end;</source>
        <Parameter name="pQueueEntry" type="CnEcReportQueueEntry"/>
        <Parameter name="pReportParameter" type="CnEcReportParameter"/>
        <Parameter name="pObjectValue" type="Object"/>
        <Parameter name="pStringValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="0d3dae1c-9530-421a-a3aa-39f75535dcca">
        <updating/>
        <source>updateMe(	pQueueEntry:CnEcReportQueueEntry;
			pReportParameter:CnEcReportParameter;
			pObjectValue:Object;
			pStringValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Updates the receiver's property values.
//
// Parameters:	Matching property parameters.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// First, set any properties...

	self.myObjectValue		:=	pObjectValue;
	self.stringValue		:=	pStringValue;

	// Next, set any key properties...

	self.myReportParameter	:=	pReportParameter;

	// Finally, set any references...

	self.myReportQueueEntry	:=	pQueueEntry;
end;</source>
        <Parameter name="pQueueEntry" type="CnEcReportQueueEntry"/>
        <Parameter name="pReportParameter" type="CnEcReportParameter"/>
        <Parameter name="pObjectValue" type="Object"/>
        <Parameter name="pStringValue" type="String"/>
    </JadeMethod>
