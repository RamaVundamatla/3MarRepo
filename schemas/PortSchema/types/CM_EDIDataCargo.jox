    <JadeMethod name="shouldAuditProperty" id="313bdb34-16c2-4b90-82c3-8774d30a0c62">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
//
// 11 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	propName : String;
begin
	if _property = null then
		return false;
	endif;
	propName := _property.name;
	if propName = CM_EDIDataCargo::createReceivalTrans.name or
	   propName = CM_EDIDataCargo::createToSite.name or
	   propName = CM_EDIDataCargo::myTerminalArea.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIData" id="9d4d3b7c-ff73-4a95-9c51-b5311128ff76">
        <updating/>
        <source>verifyEDIData(): Integer updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	site 	:	Integer;
begin

	on Exception do validationExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	
	if self.createToSite &lt;= TI_SITE_UNDEFINED or self.createToSite &gt; TI_SITE_MAX then
		app.raiseCMException2(ERR_SITE_FIELD,app.siteEnumToString(self.createToSite), 'site', self.createToSite.String, null);
	endif;


epilog	
	return app.myPassport.allErrorWarnings.size;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="5c426630-bf14-4a40-bb40-7be6f043cf98">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
30 Jan 2012	cnwrs1	Par 29024
// 08 Dec 2016	cnwrs1	TFS 3069 Par 38428 create an error is the action is not add
// 08 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
// 21 May 2018	jlgrh7 TFS 38656 POE - User Defined EDI Failure-URGENT
*/
vars
	ediTI			: CM_EDITrackedItem;	
	ediUserTI		: CM_EDICargoTI;
	ediSealTi		: CM_EDISealTI;
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(true);
	
	if self.createToSite &lt; TI_SITE_UNDEFINED or self.createToSite &gt; TI_SITE_MAX then
		app.raiseCMException2(ERR_SITE_FIELD,app.siteEnumToString(self.createToSite), 'site', self.createToSite.String, null);
	endif;
	
	beginTransaction;
	
	foreach ediTI in self.allEDITrackedItems discreteLock do												// We only need to check CM_EDICargoTI 	+TFS38656
		if ediTI.isKindOf(CM_EDICargoTI) then
			ediUserTI := ediTI.CM_EDICargoTI;
			if ediUserTI.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD then
				app.raiseCMException(Invalid_action_must, null, ediUserTI);
			endif;	
			ediUserTI.verifySelf();	//30 Jan 2012	cnwrs1	Par 29024
		endif;
	endforeach;
	
	app.cmsCommitTransaction(app.myPassport);
		
	return app.myPassport.allErrorWarnings.size;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
