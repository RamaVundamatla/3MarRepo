    <Function name="winGetDiskFreeSpaceExA" id="9ab7735a-36dc-4d55-b449-fa812605db88">
        <entrypoint>GetDiskFreeSpaceExA</entrypoint>
        <executionLocation>presentationClient</executionLocation>
        <library name="kernel32"/>
        <source>winGetDiskFreeSpaceExA
(
	path                   : String [256]; 
	userFreeBytesAvailable : Binary [8] io;
	totalNumberOfBytes     : Binary [8] io;
	totalNumberOfFreeBytes : Binary [8] io
)
is GetDiskFreeSpaceExA in kernel32;</source>
        <Parameter name="path" type="String" length="256"/>
        <Parameter name="userFreeBytesAvailable" type="Binary" length="8" usage="io"/>
        <Parameter name="totalNumberOfBytes" type="Binary" length="8" usage="io"/>
        <Parameter name="totalNumberOfFreeBytes" type="Binary" length="8" usage="io"/>
    </Function>
