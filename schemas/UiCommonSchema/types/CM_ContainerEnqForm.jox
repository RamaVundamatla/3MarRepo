    <JadeMethod name="getBOLDictForTable" id="426b4824-481f-42f1-8653-6fc749af553f">
        <updating/>
        <source>getBOLDictForTable(_numItems : Integer io; _bolSet : CM_BOLSet io) updating;
//--------------------------------------------------------------
//Created: 31 May 2002 By: cnwgd1
//14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
//--------------------------------------------------------------
vars
	lc				: CM_LocationsController;
	lcSet 			: CM_LCSet;
	ti 				: CM_TrackedItem;
	iter 			: Iterator;
	sohLocn 		: CM_SOHLocation;
	breakOut		: Boolean;
	bolKey,
	lastKey			: CM_BOL;

begin
	
	if self.filterOperator = null and self.filterTerminalArea = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 
							  'Filtering by BOL type. Operator and Location are both null.', null, null);
		return;
	endif;	
	
	//Filter by yard location controller (site/state ignored)
	if self.filterYardLocation &lt;&gt; null then
		foreach sohLocn in self.filterYardLocation.allProductLocations do
			iter := sohLocn.allTrackedItemsByReceivalBOL.createIterator;
			while iter.next(ti) do
				iter.getCurrentKeys(bolKey); //MTN-35226
				if bolKey = null or bolKey = lastKey then
					continue;
				endif;
				lastKey := bolKey;
				if _bolSet.includes(bolKey) then	//26 Jan 2015	NDL	Par 33111
					continue;
				endif;
				if self.includeObjectBOL(bolKey, _numItems, breakOut) then
					self.addObjectToTable(bolKey, _numItems, breakOut);
					_bolSet.add(bolKey);
				endif;
				if breakOut then
					break;
				endif;
			endwhile;
			delete iter;
			if breakOut then
				break;
			endif;

		endforeach;
	//Filter by terminal area (site/state ignored)		
	elseif self.filterTerminalArea &lt;&gt; null then
		lcSet := self.filterTerminalArea.allLocationsControllers;
		if lcSet &lt;&gt; null then
			foreach lc in lcSet do
				foreach sohLocn in lc.allProductLocations do
					iter := sohLocn.allTrackedItemsByReceivalBOL.createIterator;
					while iter.next(ti) do
						iter.getCurrentKeys(bolKey);  //MTN-35226
						if bolKey = null or bolKey = lastKey then
							continue;
						endif;
						lastKey := bolKey;
						if _bolSet.includes(bolKey) then	//26 Jan 2015	NDL	Par 33111
							continue;
						endif;
						if self.includeObjectBOL(bolKey, _numItems, breakOut) then
							self.addObjectToTable(bolKey, _numItems, breakOut);
							_bolSet.add(bolKey);
						endif;
					endwhile;
					delete iter;
					if breakOut then
						break;
					endif;
				endforeach;
				if breakOut then
					break;
				endif;
			endforeach;
		endif;
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
        <Parameter name="_bolSet" type="CM_BOLSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getBOLsForTable" id="7c09401c-4969-4b3d-8eb9-7cede902ed9c">
        <updating/>
        <source>getBOLsForTable(_numItems : Integer io; _filterID : String; _bolSet : CM_BOLSet io) updating;
//--------------------------------------------------------------
//Created: 31 May 2002 By: cnwgd1
//--------------------------------------------------------------
// cnwrd1 par 24107 10.5.2010 _filterID param
vars
	haveId,
	breakOut		: Boolean;
	tmpId 			: String;
	iter 			: Iterator;
	bol 			: CM_BOL;
	bolTerminal		: CM_BOLTerminal;
	tmpOperator		: CM_Operator;
	tmpCargoType	: Integer;
	tmpVoyage 		: CM_Voyage;
	row				: Integer; //cnwrd1 par 24107 10.05.2010
begin

	haveId := (_filterID &lt;&gt; null); //cnwrd1  10.5.2010 never have an ID here not in search!?!?!
	tmpCargoType := self.filterCargoTypeId;
	tmpOperator	:= self.filterOperator;
	tmpVoyage := self.filterVoyage;
	
	if self.filterTerminalArea &lt;&gt; null then
		self.getBOLDictForTable(_numItems, _bolSet);
		return;
	elseif self.filterState = TI_STATE_ONSHIP then
		iter := self.myTerminal.allBOLsReleasedByTypeNumberDT.createIterator;
		tmpId := _filterID; // cnwrd1 par 24107 10.5.2010 changed from self.filterid
		self.myTerminal.allBOLsReleasedByTypeNumberDT.startKeyGeq(tmpCargoType, tmpId, null, iter);
		while iter.next(bol) do
			if bol.bolType &lt;&gt; tmpCargoType then
				break;
			endif;
			if haveId and 
			   (not bol.number.startsWith(tmpId)) then
				break;
			endif;
			if tmpOperator &lt;&gt; null and 
			   bol.myOperator &lt;&gt; tmpOperator then
				break;
			endif;
			if tmpVoyage &lt;&gt; null and
			   bol.getMyVoyage() &lt;&gt; tmpVoyage then
				break;
			endif;
			if _bolSet.includes(bol) then		//26 Jan 2015	NDL	Par 33111
				continue;
			endif;
			if self.includeObjectBOL(bol, _numItems, breakOut) then
				self.addObjectToTable(bol, _numItems, breakOut);
				_bolSet.add(bol);	//26 Jan 2015	NDL	Par 33111
			endif;
			if breakOut then
				break;
			endif;
		endwhile;
		return;
	elseif tmpOperator &lt;&gt; null then
		iter := self.myTerminal.allBOLTermsByTypeOpNum.createIterator;
		tmpId := _filterID; // cnwrd1 par 24107 10.5.2010 changed from self.filterid
		self.myTerminal.allBOLTermsByTypeOpNum.startKeyGeq(tmpCargoType, tmpOperator, tmpId, iter);
	else
		iter := self.myTerminal.allBOLTermsByTypeNum.createIterator;
		tmpId := _filterID; // cnwrd1 par 24107 10.5.2010 changed from self.filterid
		//if haveId then //cnth2 - doesn't matter is its null - we need start key at correct cargo type regardless!
		self.myTerminal.allBOLTermsByTypeNum.startKeyGeq(tmpCargoType, tmpId, iter);
		//endif;
	endif;
	
	while iter.next(bolTerminal) do
		bol := bolTerminal.myBOL;
		if bol.bolType &lt;&gt; tmpCargoType then
			break;
		endif;
		if haveId and 
		   (not bol.number.startsWith(tmpId)) then
			break;
		endif;
		if tmpOperator &lt;&gt; null and 
		   bol.myOperator &lt;&gt; tmpOperator then
			continue; //epr TFS 47132 16/12/19
		endif;
		if tmpVoyage &lt;&gt; null and
		   bol.getMyVoyage() &lt;&gt; tmpVoyage then
			continue; //epr TFS 47132 16/12/19
		endif;
		if _bolSet.includes(bol) then		//26 Jan 2015	NDL	Par 33111
			continue;
		endif;
		
		if self.includeObjectBOL(bol, _numItems, breakOut) then //cnwrd1 par 24107 10.05.2010
		
			//if self.myFilterIDList.size &gt; 1 then	 //cnwrd1 par 24107 10.05.2010		
			//	if 	tblData.findObjectInRow( bol, row) then //cnwrd1 par 24107 10.05.2010 this may be slow!
					//already have thsi bol
			//	else
			//		self.addObjectToTable(bol, _numItems, breakOut);
			//	endif;
			//else
				self.addObjectToTable(bol, _numItems, breakOut);
				_bolSet.add(bol);	//26 Jan 2015	NDL	Par 33111
			//endif;
		endif;
		
		if breakOut then
			break;
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
        <Parameter name="_filterID" type="String"/>
        <Parameter name="_bolSet" type="CM_BOLSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCargoBOLTypeOfObject" id="a38297ad-2c1c-4187-bc55-5b5b4b989044">
        <source>getCargoBOLTypeOfObject(_obj : CM_Object) : CM_CargoBOLType protected;
// ---------------------------------------------------------------------------
// Created:     30 January 2003		cnwth2	
//
// Purpose:     
// 08 Jan 2026	navma1 		MTN-36897 PEN - Transient File Growth in PEN Production Environment 		 
// ----------   ----------  --------------------------------------------------
vars
	invalid : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, _obj, invalid); 
	
	if _obj = null then
		return null;
	endif;
	
	_obj.edition;
	
	if invalid then		//08.01.2026 navma1 #MTN-36897
		return null;
	endif;
	
	if _obj.isKindOf(CM_TrackedItem) then
		return _obj.CM_TrackedItem.myCargoType;
	elseif _obj.isKindOf(CM_BOL) then
		return app.myRoot.getCargoBOLTypeForId(_obj.CM_BOL.bolType);
	elseif _obj.isKindOf(CM_SOHLocation) then
		return _obj.CM_SOHLocation.getCargoBOLType();		
	endif;

	return null;


end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="getColHeadingForQueryProperty" id="2fd10550-f2e9-4f35-8435-2d25545b002d">
        <source>getColHeadingForQueryProperty(_propName : String) : String ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Nov 2019	jlger1	Initial creation  47132 
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	entRowName : String;
	entTableRow : EntTableRow;
begin

	if _propName = CM_TrackedItem::getTAType.name then
		entRowName:=ETRow_FilterTAType;
	elseif _propName = CM_TrackedItem::myTerminalArea.name then
		entRowName:=ETRow_FilterTerminalArea;		
	elseif _propName = CM_TrackedItem::getMyUnpackedFromContainerId.name then
		entRowName:=ETRow_FilterUnpackedFrom;
	elseif _propName =CM_TrackedItem::id.name then
		entRowName:=ETRow_FilterId;
	elseif _propName =CM_TrackedItem::myProduct.name then
		entRowName:=ETRow_FilterProduct;
	elseif _propName =CM_Container::isoType.name then
		entRowName:=ETRow_FilterISOType;
	elseif _propName = CM_TrackedItem::cargoType.name then
		entRowName:=ETRow_FilterTiType;
	elseif _propName =CM_TrackedItem::getMyTILCType.name then
			entRowName:=ETRow_FilterTrailerType;
	elseif _propName =CM_TrackedItem::alternativeId.name then
			entRowName:=ETRow_FilterAlternateId;
	elseif _propName =CM_TrackedItem::eirNumber.name then
			entRowName:=ETRow_FilterEIR;
	elseif _propName =CM_TrackedItem::imexStatus.name then
		entRowName:=ETRow_FilterIMEX;
	elseif _propName =CM_TrackedItem::operatorCode.name then
		entRowName:=ETRow_FilterOperator;
	elseif _propName =CM_TrackedItem::voyageCode.name then
		entRowName:=ETRow_FilterVoyage;
		return app.getErrorString(Active_Voyages);
	elseif _propName =CM_TrackedItem::myPrimaryActualLocation.name then
		entRowName:=ETRow_FilterYardLocation;
	elseif _propName =CM_TrackedItem::bookingReference.name then	
		entRowName:=ETRow_FilterBookingRef;
	elseif _propName =CM_TrackedItem::customsReference.name then
		entRowName:=ETRow_FilterCustomsReference;
	elseif _propName =CM_TrackedItem::billOfLading.name or _propName =CM_BOL::number.name then
		entRowName:=ETRow_FilterBOL;
	elseif _propName =CM_TrackedItem::mySubTerminal.name then
		entRowName:=ETRow_MySubTermFilter;
	elseif _propName =CM_TrackedItem::mark.name then
		entRowName:=ETRow_FilterMark;
	elseif _propName =CM_TrackedItem::stevedoreCodeRecieve.name then //02.10.2020 cnwma1 TFS #50112
		entRowName:=ETRow_ReceiveStevedore;	
	elseif _propName =CM_TrackedItem::stevedoreCodeRelease.name  then 
		entRowName:=ETRow_ReleaseStevedore;
	else
		entRowName:=_propName;
	endif;
	
	entTableRow:=self.tblSearch.myEntTableDef.myEntTableGroup.allEntTableRowsByName[entRowName];
	if entTableRow &lt;&gt; null then
		return entTableRow.getHeading(self.getFilterCargoType,self.myTerminal, app.myCurrentLocale);
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultTiType" id="22cd6d8f-d781-4e8c-ae2c-92ad4fe4b5e7">
        <source>getDefaultTiType(_cargoBOLType : CM_CargoBOLType output) : Integer;
// ---------------------------------------------------------------------------
// Created:     12 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if self.myCurrentCargoBOLType &lt;&gt; null then					// ### TFS 52923 22Mar2022 NAVPW1
		_cargoBOLType := self.myCurrentCargoBOLType; 			// ### TFS 52923 22Mar2022 NAVPW1
	else 														// ### TFS 52923 22Mar2022 NAVPW1
		_cargoBOLType := app.myPassport.getDefaultCargoBOLType();
	endif; 														// ### TFS 52923 22Mar2022 NAVPW1
	
	if _cargoBOLType &lt;&gt; null then
		return _cargoBOLType.id;
	endif;
	
end;</source>
        <Parameter name="_cargoBOLType" type="CM_CargoBOLType" usage="output"/>
        <ReturnType type="Integer"/>
