    <JadeMethod name="cmbLogLocation_displayEntry" id="13b7f738-dbb6-46e1-8efc-221680121495">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbLogLocation_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
// -----------------------------------------------------------------------------
// Created:		12 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return self.myAssistant.displayEntryLocationController(obj.CM_LocationsController); //epr TFS 4157 can be a wagon controller and would get a 1086
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cmbLogLocation_gotFocus" id="cd1f3274-a7a2-48db-9ee5-1a251611b6f1">
        <controlMethod name="ComboBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbLogLocation_gotFocus(combobox: ComboBox input) updating;
//--------------------------------------------------------------
//Created: 01 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpLCSearch	: CMIF_SearchTypes;
	selectedObj	: Object;
	bol			: CM_BOLIn;

begin
/*	if (not self.hasLocationRestricted) then
		create tmpLCSearch transient;
//		tmpLCSearch.myOperator 	:= self.cmbSupplier.listObject.CM_Operator;
		tmpLCSearch.myOperator 	:= self.cmbSupplier.myObject.CM_Operator;
//		tmpLCSearch.mySpecies 	:= self.cmbLogSpecies.listObject.CM_LogSpecies;
		tmpLCSearch.mySpecies 	:= self.cmbLogSpecies.myObject.CM_LogSpecies;
//		tmpLCSearch.myGrade 	:= self.cmbLogGrade.listObject.CM_LogGrade;
		tmpLCSearch.myGrade 	:= self.cmbLogGrade.myObject.CM_LogGrade;
//		tmpLCSearch.myType 		:= self.cmbLogType.listObject.CM_LogType;
		tmpLCSearch.myType 		:= self.cmbLogType.myObject.CM_LogType;
//		tmpLCSearch.myTreatment	:= self.cmbTreatment.listObject.CM_LogTreatment;
		tmpLCSearch.myTreatment	:= self.cmbTreatment.myObject.CM_LogTreatment;
//		tmpLCSearch.myLength	:= self.cmbLogLength.listObject.CM_LogLength;
		tmpLCSearch.myLength	:= self.cmbLogLength.myObject.CM_LogLength;
		self.myTerminal.availableLocationsForType(tmpLCSearch, self.allLogLocations, TA_TYPE_LOGAREA);		
		self.myAssistant.comboBoxLocationControllers(combobox, self.allLogLocations, true);
		combobox.sorted := true;
	endif;*/

	if self.myProxyObject &lt;&gt; null and self.myProxyObject.isKindOf( CM_BOLIn ) then
		bol := self.myProxyObject.CM_BOLIn;
	endif;
	
	if not self.hasLocationRestricted 
		or ( bol &lt;&gt; null and bol.isMatchedTodayForDocketCorrect() )	//ccms1089 - Docket Correction. Location can be edited the same day.
	then
		selectedObj := combobox.listObject;
//		selectedObj := self.cmbLogLocation.myObject.CM_LogController;

		// ccms1089. Docket Correction, when BOL has been matched today. We can edit it today still.
		// However, in this case BOL.myPlannedLocation = null and combobox.listObject = null
		if selectedObj = null then
			if bol &lt;&gt; null and bol.isMatchedTodayForDocketCorrect() then
				selectedObj := self.getLocationById( bol. origLocationControllerId );
			endif;
		endif;

		create tmpLCSearch transient;
		tmpLCSearch.myOperator 	:= self.cmbSupplier.myObject.CM_Operator;
		tmpLCSearch.mySpecies 	:= self.cmbLogSpecies.myObject.CM_LogSpecies;
		tmpLCSearch.myGrade 	:= self.cmbLogGrade.myObject.CM_LogGrade;
		tmpLCSearch.myType 		:= self.cmbLogType.myObject.CM_LogType;
		tmpLCSearch.myTreatment	:= self.cmbTreatment.myObject.CM_LogTreatment;
		tmpLCSearch.myLength	:= self.cmbLogLength.myObject.CM_LogLength;
		self.myTerminal.availableLocationsForType(tmpLCSearch, self.allLogLocations, TA_TYPE_LOGAREA);		
		self.myAssistant.comboBoxLocationControllers(combobox, self.allLogLocations, true);
		combobox.sorted := true;

		if selectedObj &lt;&gt; null
			and self.allLogLocations.includes(selectedObj.CM_LocationsController) then
			combobox.listObject := selectedObj;
			combobox.text := self.myAssistant.displayEntryLocationController(selectedObj.CM_LocationsController);
		endif;
		
	endif;
	
epilog
	delete tmpLCSearch;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
