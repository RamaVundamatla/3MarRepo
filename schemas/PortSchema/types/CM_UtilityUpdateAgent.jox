    <JadeMethod name="utlUpdateWorkOrderTask" id="bdd3b712-05e7-4301-9e52-8d2c4a2029d4">
        <updating/>
        <source>utlUpdateWorkOrderTask(_pxyWorkOrderDtl : CM_WorkOrderDtl input; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Aug 2009	cnwmd1	Initial creation
30 Jan 2019 jlger1  workOrderDetails don't store audits so no point in doing it and it wipes
					the audit before if this is called from  a util that has already started the auditing
15 Oct 2021 jlier1	TFS 52195 
18/01/2023	navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions
*/

vars
	realWorkOrderDtl : CM_WorkOrderDtl;
	expectedEdition : Integer;
	wotran : CM_WOTransaction;
begin
	self.initialiseActivity();

	_pxyWorkOrderDtl.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyWorkOrderDtl.pxyGetRealObjectAndEdition(realWorkOrderDtl, expectedEdition);
	
	if realWorkOrderDtl = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WorkOrderDtl.name, null, null);
		return;
	endif;

	app.myValUA.valWorkOrderTask(_pxyWorkOrderDtl);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

		
	app.setContinueCMExceptions(false);

	exclusiveLock(realWorkOrderDtl);

	if _passport.noErrors and realWorkOrderDtl.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Work Order Task', null, null);
		return;
	endif;

	realWorkOrderDtl.setForUpdate(_pxyWorkOrderDtl);
	
	wotran := realWorkOrderDtl.createWOTransaction(realWorkOrderDtl.TRANS_UPDATED, null, null); // 18.01.2023 navcs2 #56633:[56211]
	
	//jlier1 29/5/25 MTN-34591 
	realWorkOrderDtl.causeTerminalEvent(Event_WODtl_Update);
	
	/*// ### TFS DEFECT 59150 17JUL2023 NAVAB1
	// ### TFS BUG58790 23JUN2023 NAVAB1
	if wotran &lt;&gt; null then
		wotran.createCharge();
	endif;
	*/
	// TFS 40029 if the work order is for a voyage request we need to update the voyage
/*	if  _passport.noErrors then
		if realWorkOrderDtl.isWorkOrderVoyageRequest() then
			realWodVoyageRequest := realWorkOrderDtl.CM_WodVoyageRequest;
		endif;
		
		if realWodVoyageRequest &lt;&gt; null then
			voyage := realWodVoyageRequest.getMyVoyageObject();
			
			if voyage &lt;&gt; null then
				pxyVoyage := app.createUpdateProxy(voyage).CM_Voyage;
				if voyage.vesselCode &lt;&gt; realWodVoyageRequest.vesselCode then
					newVessel:=app.myRoot.allVessels[realWodVoyageRequest.vesselCode];
					if newVessel &lt;&gt; null then
						//need to set the pxyVoyage based on the new vessel
						newVessel.updateProxyVoyageRequest(pxyVoyage);			
					endif;
				endif;
				pxyVoyage.setProxyFromWodVoyageRequest(realWodVoyageRequest);
				// jlier1 TFS 51963 - only create the structure if approved or complete
				createStructure := pxyVoyage.myCellularVoyageStructure &lt;&gt; null;		
				app.myUtilityUA.utlUpdateVoyage(createStructure,false,pxyVoyage,conflictManager,false,app.myPassport);
				
			endif;
		endif;
	endif;		
	*/
	
epilog

end;</source>
        <Parameter name="_pxyWorkOrderDtl" type="CM_WorkOrderDtl" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWorkOrderTaskPosition" id="6b66f15c-c402-41f2-8afa-7e50c349174a">
        <updating/>
        <source>utlUpdateWorkOrderTaskPosition(_pxyWorkOrder : CM_WorkOrder  input; _passport : CM_Passport input)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2009	cnwmd1	Initial creation
30 Jan 2019 jlger1  workOrderDetails don't store audits so no point in doing it and it wipes
					the audit before if this is called from  trx that has already started the auditing
*/

vars
	realWorkOrder : CM_WorkOrder;
	expectedEdition : Integer;
begin
	self.initialiseActivity();

	_pxyWorkOrder.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyWorkOrder.pxyGetRealObjectAndEdition(realWorkOrder, expectedEdition);
	
	if realWorkOrder = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WorkOrder.name, null, null);
		return;
	endif;

	app.myValUA.valWorkOrderPosition(_pxyWorkOrder);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	
	app.setContinueCMExceptions(false);

	exclusiveLock(realWorkOrder);

	if _passport.noErrors and realWorkOrder.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Work Order', null, null);
		return;
	endif;

	realWorkOrder.updateTaskOrderPosition(_pxyWorkOrder);
	
	
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWorkPoint" id="005377b0-6def-4ea1-a143-aa3ff35f9f76">
        <source>utlUpdateWorkPoint(_pxyWorkPoint : CM_WorkPoint input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	realWorkPoint : CM_WorkPoint;
	beforeAuditText, 
	afterAuditText: String;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyWorkPoint, " Proxy is Null" );
	
	realWorkPoint:=_pxyWorkPoint.pxyGetRealObject.CM_WorkPoint;
	if realWorkPoint = null then
		self.raiseExceptionIfNull(_pxyWorkPoint, " Real Deck is Null" );
	endif;

	app.setContinueCMExceptions(true);
	
	app.myValUA.valCM_Object(_pxyWorkPoint, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.hasErrors then
		return;
	endif;
	
	beforeAuditText:=realWorkPoint.getAuditText();
	
	realWorkPoint.setForUpdate(_pxyWorkPoint,_passport);
	
	afterAuditText:=realWorkPoint.getAuditText();
	app.myAA.auditUpdateTrx(realWorkPoint, beforeAuditText, afterAuditText);
	//navsp1 03Jun2022 TFS#53104
	if _passport.isOpsViewEnabled(realWorkPoint.getMyTerminal()) then
		realWorkPoint.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,
								 BGP_OpsViewWSRequest.OPS_TYPE_MACHINE,
								 realWorkPoint);
	endif;
epilog

end;</source>
        <Parameter name="_pxyWorkPoint" type="CM_WorkPoint" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWorkPointJobSheet" id="2868ef64-78e8-437f-9519-1611732ea2b3">
        <updating/>
        <source>utlUpdateWorkPointJobSheet(_pxyJobSheet	: CM_WorkPointJobSheet io;
						   _passport 	: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	realJobSheet		: CM_WorkPointJobSheet;
	expectedEdition 	: Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyJobSheet, 'Work Point Type proxy');
	
	_pxyJobSheet.pxyGetRealObjectAndEdition(realJobSheet, expectedEdition);
	self.raiseExceptionIfNull(realJobSheet, 'Work Point Type');
	
	_pxyJobSheet.validateForUpdate();
	
	if not _passport.noErrors then
		return;
	endif;

	realJobSheet.setForUpdate(_pxyJobSheet);
	realJobSheet.setMyShift(_pxyJobSheet,_passport);

	if _passport.noErrors then
		realJobSheet.causeEvent(realJobSheet.myTerminal.getTerminalEvent(Event_JobSheet_WP_Update), false, null);
	endif;
epilog

end;</source>
        <Parameter name="_pxyJobSheet" type="CM_WorkPointJobSheet" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWorkPointRate" id="5f881ffb-3bdd-4338-b950-e5bdb54c6ae9">
        <source>utlUpdateWorkPointRate(_pxyWorkPointRate : CM_WorkPointCargoRates input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation	TFS 37437

*/

vars

	realWorkPointRate : CM_WorkPointCargoRates;
	beforeAuditText : String;
	afterAuditText : String;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyWorkPointRate, " Proxy is Null" );
	
	realWorkPointRate := _pxyWorkPointRate.pxyGetRealObject.CM_WorkPointCargoRates;
	if realWorkPointRate = null then
		self.raiseExceptionIfNull(realWorkPointRate, " Real Work Point Rate is Null" );
	endif;

	app.setContinueCMExceptions(true);
	
	app.myValUA.valCM_Object( _pxyWorkPointRate, _passport );

	if not self.checkValidationWithPassport( _passport ) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.hasErrors then
		return;
	endif;
	
	beforeAuditText := realWorkPointRate.getAuditText();
	
	realWorkPointRate.setForUpdate( _pxyWorkPointRate, _passport );
	
	afterAuditText := realWorkPointRate.getAuditText();
	
	app.myAA.auditUpdateTrx( realWorkPointRate, beforeAuditText, afterAuditText );

epilog

end;</source>
        <Parameter name="_pxyWorkPointRate" type="CM_WorkPointCargoRates" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWorkPointType" id="59b6ffc2-1b9e-49a4-9c3c-5110178cb799">
        <updating/>
        <source>utlUpdateWorkPointType(_pxyWPT 		: CM_WorkPointType io;
						_passport 	: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Apr 2023 navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars
	realWPT				: CM_WorkPointType;
	expectedEdition 	: Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyWPT, 'Work Point Type proxy');
	
	_pxyWPT.pxyGetRealObjectAndEdition(realWPT, expectedEdition);
	self.raiseExceptionIfNull(realWPT, 'Work Point Type');
	
	_pxyWPT.validateUpdate(_passport);
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWPT, true);
	endif;
	
	realWPT.setForUpdate(_pxyWPT);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWPT, false);
	endif;
epilog

end;</source>
        <Parameter name="_pxyWPT" type="CM_WorkPointType" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWpOperatingHrs" id="dd1568be-869f-41dc-83e2-1c9737d68b1a">
        <updating/>
        <source>utlUpdateWpOperatingHrs( _pxyWpOperatingHrs : CM_WorkPointOperatingHours input; _passport : CM_Passport input ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	realWPOpHrs : CM_WorkPointOperatingHours;
	expectedEdition  :Integer;
	voyage : CM_Voyage;
	term : CM_Terminal;
	
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValUA.valWpOperatingHrs( _pxyWpOperatingHrs, _passport );
	
	if not self.checkValidationWithPassport( _passport ) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	_pxyWpOperatingHrs.pxyGetRealObjectAndEdition( realWPOpHrs, expectedEdition );
	
	if realWPOpHrs = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Job.name, null, null);
		return;
	endif;

	exclusiveLock( realWPOpHrs );

	if _passport.noErrors and realWPOpHrs.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Work Point Operating Hrs', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric( realWPOpHrs, true );
	endif;
	
	if _passport.noErrors then
		realWPOpHrs.setForUpdate( _pxyWpOperatingHrs, _passport );
	endif;

	if _passport.noErrors then
		voyage := realWPOpHrs.myVoyage;
		term := voyage.getMyTerminal;
		if voyage &lt;&gt; null and term &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(voyage, term.getTerminalEvent(Voyage_Update_Event), voyage); 
		endif;
	endif;

end;</source>
        <Parameter name="_pxyWpOperatingHrs" type="CM_WorkPointOperatingHours" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateXTABMapping" id="77288846-ae0b-41a3-8f8f-786a74b49a1b">
        <source>utlUpdateXTABMapping(_proxy :CM_XTABMapping; _passport :CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     25 November 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	mapping			:CM_XTABMapping;
	expectedEdition	:Integer;
begin
	self.initialiseActivity();
	
	_proxy.raiseExceptionIfNotProxy(method);
	
	_proxy.pxyGetRealObjectAndEdition(mapping, expectedEdition);
		
	if mapping = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Gate.name, null, null);
		return;
	endif;

	if expectedEdition &lt; 1 then
		app.raiseCMException2(ExpectedEditionInvalid, expectedEdition.String, method.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	
	app.myValUA.valXTABMapping(_proxy); 

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	exclusiveLock(mapping);

	if _passport.noErrors then
		if expectedEdition &lt;&gt; mapping.edition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, CM_Gate.name, null, null);
			return;
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(mapping, true);
	endif;
	
	if _passport.noErrors then
		mapping.setForUpdate(_proxy);
	
		if _passport.noErrors then
			// if any notifications are required they go here
		endif; 
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(mapping, false);
	endif;	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_XTABMapping"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateXlation" id="cfc7e082-45c2-47bc-93ed-d5ea56577bf7">
        <source>utlUpdateXlation(_proxy :CM_XlationTable; _passport : CM_Passport input);
/*
Date		Who		Reason
12 Dec 2008	conks1	Initial creation
25 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259
05 May 2013	cnwrs1	create/update auiting for xlations
27 May 2013	cnwcs5	par 31259 - fix bug introducted in above change
13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
18 Oct 2024	navdap1	MTN-33147 NSW | FR - OnePort - Unable to Create Terminal Operator EDI Data Translations
*/

vars
	pxyXlationIn, realXlationIn, xlationIn		: CM_Xlation_In;
	pxyXlationOut, xlationOut		: CM_Xlation_Out;
	xlationTable					: CM_XlationTable;
	opTerm, pxyOpTerm				: CM_OperatorTerminal;
	expectedEdition					: Integer;	
begin
	_proxy.raiseExceptionIfNotTransient(method);
	// xlationTable may also have an inward and outward translation to be maintained
	if _proxy.allInwardTranslations.size &gt; 1 then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Too may inward translations');
	endif;

	if _proxy.allOutwardTranslations.size &gt; 1 then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Too may outward translations');
	endif;
	
	pxyXlationIn 	:= _proxy.allInwardTranslations.first;
	pxyXlationOut	:= _proxy.allOutwardTranslations.first;
	
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	if _proxy.isSystemXlationTable then
		xlationTable := app.myRoot.allXlationTables[_proxy.type, null, null, null];
	
	elseif CM_XlationTable@isOperatorTerminalXlation( _proxy.type ) then //jlier1 TFS 54846 5/10/22
		opTerm := _proxy.myOperatorTerminal;
		
		if opTerm.isTransient then
			pxyOpTerm := opTerm;
			// avoid timing hole if opTerm created since we created the proxy
			opTerm := pxyOpTerm.myOperator.allOperatorTerminals[pxyOpTerm.myTerminal];
			
			if opTerm = null then
				// need to create one
				xlationTable := null;
			else
				xlationTable := opTerm.allXlationTables[_proxy.type, null];
			endif;					
		else	
			xlationTable := opTerm.allXlationTables[_proxy.type, null];
		endif;
	elseif _proxy.type = XLATION_TYPE_WORKPOINT then  //epr TFS  42095 22/11/18
		xlationTable :=_proxy.myTerminal.allXlationTables[XLATION_TYPE_WORKPOINT,null];
	else
		xlationTable := _proxy.myOperator.allXlationTables[_proxy.type, _proxy.myCargoType];
	endif;
		
	if pxyXlationIn &lt;&gt; null then
		if pxyXlationIn.pxyIsProxy then
			pxyXlationIn.pxyGetRealObjectAndEdition(realXlationIn, expectedEdition);
			
			if realXlationIn = null then	
				app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Xlation_In.name, null, null);
				return;
			endif;
			
			self.exclusiveLock(realXlationIn);

			if _passport.noErrors and realXlationIn.edition &lt;&gt; expectedEdition then
				app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Xlation In', null, null);
				return;
			endif;
			
		endif;

		app.myValUA.valXlation(pxyXlationIn);
	endif;
		
	if (not self.checkValidationWithPassport(_passport)) then
		return;		
	endif;

	if pxyXlationOut &lt;&gt; null then
		if pxyXlationOut.pxyIsProxy then
			pxyXlationOut.pxyGetRealObjectAndEdition (xlationOut, expectedEdition);
			
			if xlationOut = null then	
				app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Xlation_Out.name, null, null);
				return;
			endif;
			
			self.exclusiveLock(xlationOut);
		
			if _passport.noErrors and xlationOut.edition &lt;&gt; expectedEdition then
				app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Xlation Out', null, null);
				return;
			endif;
			
			if xlationOut.systemCode &lt;&gt; pxyXlationOut.systemCode or
				xlationOut.foreignCode &lt;&gt; pxyXlationOut.foreignCode then
				// only validate if something has changed
				app.myValUA.valXlation(pxyXlationOut);
			endif;
		else
			app.myValCA.valXlation(pxyXlationOut);
		endif;
	endif;
		
	if (not self.checkValidationWithPassport(_passport)) then
		return;		
	endif;
	
	app.setContinueCMExceptions(false);

	if xlationTable = null then
		create xlationTable persistent;
		
		xlationTable.setForCreate(_proxy);
		
		if  (_proxy.type = XLATION_TYPE_VOYAGETERMINAL or
			_proxy.type = XLATION_TYPE_INSTRUCTTERMINAL or
			_proxy.type = XLATION_TYPE_COUNTRYTERMINAL or		//11.Dec.2023 navsp1 TFS 61710
			_proxy.type = XLATION_TYPE_OPERATOR_BYTERM) and		// MTN-33147
			opTerm = null then
			
			create opTerm persistent;
			
			opTerm.setMyOperator (pxyOpTerm.myOperator);
			opTerm.setMyTerminal (pxyOpTerm.myTerminal);
			
			xlationTable.setMyOperatorTerminal (opTerm);
		endif;
	endif;
	

	if _passport.noErrors then
		if pxyXlationIn &lt;&gt; null then
			if realXlationIn = null then
				create realXlationIn persistent;
				
				realXlationIn.setForCreate (pxyXlationIn, xlationTable); 
				
				if _passport.noErrors then
					app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(pxyXlationIn);
				endif;		
			else
				if _passport.noErrors then
					// This is only required if the class is being auditted
					self.myUpdateAuditAgent.audUpdateGeneric(pxyXlationIn, true);
				endif;
				
				realXlationIn.setForUpdate(pxyXlationIn);
				
				if _passport.noErrors then
					// This is only required if the class is being auditted
					self.myUpdateAuditAgent.audUpdateGeneric(pxyXlationIn, false);
				endif;
			endif;
		endif;
	endif;
	
	if _passport.noErrors then
		if pxyXlationOut &lt;&gt; null then
			if xlationOut = null then
				create xlationOut persistent;
				
				xlationOut.setForCreate (pxyXlationOut, xlationTable); 
				
				if _passport.noErrors then
					app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(xlationOut);
				endif;		
			else
				if _passport.noErrors then
					// This is only required if the class is being auditted
					self.myUpdateAuditAgent.audUpdateGeneric(xlationOut, true);
				endif;
				
				xlationOut.setForUpdate(pxyXlationOut);
				
				if _passport.noErrors then
					// This is only required if the class is being auditted
					self.myUpdateAuditAgent.audUpdateGeneric(xlationOut, false);
				endif;
			endif;
		endif;
	endif;
	
	if xlationOut &lt;&gt; null then
		foreach xlationIn in xlationOut.myXlationTable.allInwardTranslations do
			if xlationIn.systemCode = xlationOut.systemCode and xlationIn &lt;&gt; realXlationIn then
				// there is a 1:m between out and in translations so
				// we want each inward to cause a notification event
				self.updateObjectEdition (xlationIn);
			endif;
		endforeach;
	endif;
epilog
	
	
end;</source>
        <Parameter name="_proxy" type="CM_XlationTable"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateYABlock" id="622fc55f-2dcb-47ac-93f6-2664c9c44656">
        <updating/>
        <source>utlUpdateYABlock(_proxyYABlock: CM_YABlock;
						_yaBlock : CM_YABlock io;
						_passport : CM_Passport input) updating;
vars
	ya: CM_YardAllocation;
	deckingOptions: CM_YADeckingOptionsBlock;
	
begin
	// Always initialize the activity first
	self.initialiseActivity();

	_proxyYABlock.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	
	app.myValUA.valYABlock(_yaBlock, _proxyYABlock);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(_yaBlock);

	// ====================================================
	// now do the update
	app.setContinueCMExceptions(false);
	
	ya := _proxyYABlock.myYardAllocationIn;
	if _passport.noErrors() then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(ya, true);
	endif;

	if _passport.noErrors() then
		// delete decking options thus triggering their rebuild (which is how yard allocation maintenance does it) - SLW 29/08/2008
		deckingOptions := _yaBlock.myDeckingOptions;
		delete deckingOptions;
	endif;

	if _passport.noErrors() then
		_yaBlock.setForUpdate(_proxyYABlock);
	endif;
	
	if _passport.noErrors() then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(ya, false);

		// ### NOTES
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_YardAllocationUpdate), false, _yaBlock.myYardAllocationIn);
	endif;

end;</source>
        <Parameter name="_proxyYABlock" type="CM_YABlock"/>
        <Parameter name="_yaBlock" type="CM_YABlock" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
