    <JadeMethod name="reattachSubProxies" id="082384f3-87d9-46d1-a9a7-c57287282026">
        <source>reattachSubProxies();
/*
Purpose - 	
Who - NAVAB1
Date - 04SEP2023
ADO - CR 59942 TASK 59943 
*/

vars
	pxyCustDetail, subPxyDetail : CM_CustomDocumentDetail;
	subTI, ti : CM_TrackedItem;
	cgTI : CM_CargoGroup;
	proxies : CM_CustomDocumentDetailSet;
begin
	proxies:= self.allSubProxyCustDocDetails;
	foreach pxyCustDetail in self.allProxyDetailsForCreate discreteLock do
		if pxyCustDetail.myTrackedItem.isCargoGroupItem then
			cgTI := pxyCustDetail.myTrackedItem.CM_CargoGroup;
			foreach subPxyDetail in proxies do : cgloop
				if subPxyDetail.myTrackedItem = cgTI then
					subPxyDetail.setMyCustomDocument(null);
					break cgloop;
				endif;
			endforeach;
			
			
			foreach subTI in cgTI.allAssignedTrackedItems discreteLock do : innerloop
				foreach subPxyDetail in proxies do
					if subPxyDetail.myTrackedItem = subTI then
						subPxyDetail.setProxyParentDetail(pxyCustDetail);
						continue innerloop;
					endif;
				endforeach;
			
			endforeach;
		else
			ti := pxyCustDetail.myTrackedItem;
			foreach subPxyDetail in proxies do : tiloop
				if subPxyDetail.myTrackedItem = ti then
					subPxyDetail.setMyCustomDocument(null);
					break tiloop;
				endif;
			endforeach;
			
		
		endif;
	
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetCustDocClearedAmounts" id="8136b573-924b-4f36-b557-21e90eac4ed9">
        <updating/>
        <source>resetCustDocClearedAmounts(_custDocDetail : CM_CustomDocumentDetail input) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 05SEP2023
ADO - CR 59942 TASK 59943 
*/

vars
	subDetail : CM_CustomDocumentDetail;
	clearedVolume, clearedWeight : Decimal[23,4];
	clearedQuantity : Integer;
begin

	if _custDocDetail.allSubDetails.isNotEmpty() then // if they have un included any sub details re set the main detail (cargo group)
		_custDocDetail.setProxyTransfers(0,0,0,_custDocDetail.included);
		foreach subDetail in _custDocDetail.allSubDetails discreteLock do
			if subDetail.isIncluded() then
				clearedVolume := clearedVolume + subDetail.clearedVolume;
				clearedWeight := clearedWeight + subDetail.clearedWeight;
				clearedQuantity := clearedQuantity + subDetail.clearedQuantity;
			endif;
		
		endforeach;
		_custDocDetail.setProxyTransfers(clearedWeight,clearedVolume,clearedQuantity,_custDocDetail.included);
	endif;
	
epilog

end;</source>
        <Parameter name="_custDocDetail" type="CM_CustomDocumentDetail" usage="input"/>
    </JadeMethod>
    <JadeMethod name="saveSelectedTrackedItems" id="2ad4699e-f115-4668-8d6c-4045faac412c">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_TrackedItems::saveSelectedTrackedItems"/>
        </interfaceImplements>
        <source>saveSelectedTrackedItems(_allTIs : CM_TIArray) : Boolean;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements for the IF_CMUI_TrackedItems interface 
	*/
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars
	pxyCustDocDetail : CM_CustomDocumentDetail;
	ti, myTrackedItem : CM_TrackedItem;
	cmifCustDocDetail : CMIF_CustomDocumentDetail;
	detailSet : CM_CustomDocumentDetailSet;
	prevCustDoc : CM_CustomDocument;
	theReturn : Integer;
	storageDetail : CM_StorageDetail;
	totalWeight,
	totalVolume : Decimal[14,4]; 
	totalQuantity : Integer; 
begin
	if _allTIs = null or _allTIs.isEmpty then
		return true;
	endif;
	
	create cmifCustDocDetail transient;
	create detailSet transient;
	
	foreach ti in _allTIs do
		create pxyCustDocDetail transient;
		totalWeight := ti.totalWeight;
		totalVolume := ti.totalVolume;
		totalQuantity := ti.totalQuantity;
		pxyCustDocDetail.setProxy(totalQuantity,totalWeight,totalVolume,true,ti,self.myCustomDocument, null);

		detailSet.add(pxyCustDocDetail);
	endforeach;
	
	detailSet.copy(cmifCustDocDetail.allProxyCustDocDetails);
	
	
	if self.myCustomDocument.allCustomDocumentDetails.isEmpty
	and self.myCustomDocument.sequence &lt;= 1 then
		if ti &lt;&gt; null then
			prevCustDoc := ti.allCustomDocuments.getLastActive(); // ### TFS CR 60425 TASK 60828 13NOV2023 NAVAB1
			if prevCustDoc &lt;&gt; null then
				beginTransaction;
				self.myCustomDocument.setPropertyValue("sequence", prevCustDoc.sequence + 1);
				commitTransaction;
			endif;
		endif;
	endif;
	
	while true do
		app.myTrxCA.trxCreateCustDocDetails(cmifCustDocDetail,app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Custom Document Detail", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				  theReturn = IDOK then
				  // there must have just been warnings that the user has acknoledged so ..
				  app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
			
		break;
	endwhile;

	self.displayStatus();
	return true;

epilog
	delete cmifCustDocDetail;
	delete detailSet;
end;</source>
        <Parameter name="_allTIs" type="CM_TIArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyCustomDocument" id="e02bf452-95f5-4855-beca-91683cafbffb">
        <updating/>
        <source>setMyCustomDocument(_custDoc: CM_CustomDocument)updating;
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars

begin
