    <JadeMethod name="getCurrencyStringAsDecimal" id="e8572406-f863-4581-b5d5-1da107cf8581">
        <source>getCurrencyStringAsDecimal():Decimal;
/*

Purpose:	Use where the text is a JMT formatted currency value		

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	rawString : String;
	pos : Integer;
	isNegative : Boolean;
	charString : String;
	outString : String;
	real : Real;

begin

	rawString := self.text.trimBlanks;
	
	foreach pos in 1 to rawString.length do
		charString := rawString[pos];
		if charString = "-" then
			isNegative := true;
		elseif ( charString.isInteger or charString = "." ) then
			outString := outString &amp; charString;
		endif;
	endforeach;
	
	if outString = null then
		return 0;
	else
		real := outString.Decimal;
		if isNegative then
			real := real * -1;
		endif;
		return real.Decimal;
	endif;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="9cac3dd8-30b5-4e89-ae6f-8d2ddb51bc1b">
        <updating/>
        <source>repositionAfterResize() updating;
// -----------------------------------------------------------------------------
// Created:		26 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
 	newLeft, newTop, newWidth, newHeight,
   	parentWidth,
   	parentHeight	: Real;

begin

	newLeft 	:= self.left;
	newTop 		:= self.top;
	newWidth 	:= self.width;
	newHeight	:= self.height;
	
	if self.parent.isKindOf(Form) then
		parentWidth  := self.parent.Form.clientWidth;
		parentHeight := self.parent.Form.clientHeight;
	elseif self.parent.isKindOf(Control) then
		parentWidth  := self.parent.Control.clientWidth;
		parentHeight := self.parent.Control.clientHeight;
	else
		parentWidth  := self.parent.width;
		parentHeight := self.parent.height;
	endif;

	if self.stretchToParent then
		self.move(0, 0, parentWidth, parentHeight);
		return;
	endif;

	if lockRight then
		newLeft := (parentWidth - newWidth - self.distanceFromRight).max(0);
	endif;
	if lockBottom then
		newTop := (parentHeight - newHeight - self.distanceFromBottom).max(0);
	endif;
	if stretchWidth then
		newWidth := (parentWidth - newLeft - distanceFromRight).max(0);
	endif;
	if stretchHeight then
		newHeight := (parentHeight - newTop - distanceFromBottom).max(0);
	endif;

	if newLeft &lt;&gt; self.left or newTop &lt;&gt; self.top or newWidth &lt;&gt; self.width or newHeight &lt;&gt; self.height then
		self.move(newLeft, newTop, newWidth, newHeight);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="selectAll" id="d83e2243-1dd5-4c92-940c-3e4407a86724">
