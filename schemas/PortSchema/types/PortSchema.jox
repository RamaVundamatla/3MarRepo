    <JadeMethod name="getMoveTypeDescription" id="c0e70650-95a6-4498-b6a5-4d4172d80e23">
        <source>getMoveTypeDescription(_moveType : String) : String;
// ---------------------------------------------------------------------------
// Created:     17 January 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _moveType = HMSMovementTypeArrival then
		return "Arrival";
	elseif _moveType = HMSMovementTypeDeparture then
		return "Departure";
	elseif _moveType = HMSMovementTypeEntering then
		return "Entering";
	elseif _moveType = HMSMovementTypeLeaving then
		return "Leaving";
	elseif _moveType = HMSMovementTypePassageDepart then
		return "Passage Departure";
	elseif _moveType = HMSMovementTypeShift then
		return "Shift";
	elseif _moveType = HMSMovementTypeShiftArrival then
		return "Shift Arrival";
	elseif _moveType = HMSMovementTypeShiftDeparture then
		return "Shift Departure";
	else
		return _moveType; 	//19 Nov 2018	NDL	TFS 42043 - Its already a string....
	endif;
	
	return 'Unknown';
	
end;</source>
        <Parameter name="_moveType" type="String"/>
        <ReturnType type="String"/>
