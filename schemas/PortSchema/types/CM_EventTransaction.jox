    <JadeMethod name="setDetails" id="2d7f1886-031d-48e6-8117-6ce33a372176">
        <updating/>
        <source>setDetails(_eventType 	: CM_EventType;
			_dateTime 	: TimeStamp;
			_terminal 	: CM_Terminal;
			_userCode	: String;
			_noCharge	: Boolean;	//05 Nov 2009	NDL Par 21519
			_amount : Decimal
			) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 February 2007 By cnwth2

Purpose:	N.B Either the root or terminal should be populated, not both.
			If terminal is not known at time of creation, then null passed in a root set automatically.
			This is validated in validateForUpdate

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
// ### TFS CR 63938 TASK 63942 02MAY2024 NAVAB1 - deferred updates
*/
vars

begin
	
	self.dateTime 		:= _dateTime;
	self.myEventType 	:= _eventType;
	if self.myEventType &lt;&gt; null then
		self.type := self.myEventType.type;
	endif;
	self.userCode		:= _userCode;
	self.noCharge		:= _noCharge;
	self.amount:=_amount; //epr par 36902 14/9/15
	
	//30/05/2025	navkc1 JIRA MTN 34639 - Don't bother setting the terminal if it's transient. It's being handled in the TRX defered update
	if not self.isTransient() then
		app.myPassport.addEventTransactionForDeferUpd(self, _terminal); // ### TFS CR 63938 TASK 63942 02MAY2024 NAVAB1 moved setting termina and root to passport
	endif;
	
	self.setContextInfo();
end;

</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="_amount" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromCMIF" id="62d64cbf-913e-40a0-be9a-744ddcb345b2">
        <updating/>
        <source>setDetailsFromCMIF(_eventType : CM_EventType; _cmifEventTrx : CMIF_EventTransactionCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor

*/

vars

begin
	
	self.myEventType 	:= _eventType;
	self.dateTime 		:= _cmifEventTrx.dateTime;
	//self.myTerminal 	:= _cmifEventTrx.myTerminal; //16/04/2025 navkc1	JIRA Bug MTN-34680 Set terminal in defered update method
	self.noCharge 		:= _cmifEventTrx.noCharge;
	self.type 			:= _cmifEventTrx.type;	
	self.amount 		:= _cmifEventTrx.amount;
	self.userCode		:= _cmifEventTrx.userCode;
	
	app.myPassport.addEventTransactionForDeferUpd(self, _cmifEventTrx.myTerminal);
	
	self.setContextInfo();
	
epilog

end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_cmifEventTrx" type="CMIF_EventTransactionCtrl"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2f2298b9-c4e9-4d98-8122-20413d6a7fef">
        <updating/>
        <source>setForCreate(_pxyEvent : CM_EventTransaction) updating;
/*
----------   ----------  --------------------------------------------------
Created:	14 February 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	
	self.setForUpdate(_pxyEvent);
end;


</source>
        <Parameter name="_pxyEvent" type="CM_EventTransaction"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="042496c6-2600-439e-82e7-ac3cfaacc0c9">
        <updating/>
        <source>setForUpdate(_pxyEvent : CM_EventTransaction) updating;
/*
----------   ----------  --------------------------------------------------
Created:	14 February 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
03 May 2016 cnwma1	PAR #37813 TFS 1941 Voyage event issue
*/
vars
	controller : CMIF_TiTransactionResync;
begin
	self.dateTime 		:= _pxyEvent.dateTime;
// ### TFS BUG 64545 10JUNE024 NAVAB1	self.setCAMSTimeStamp(app.actualTimeServer);	
	self.type 			:= _pxyEvent.type;
	self.myEventType 	:= _pxyEvent.myEventType;
	self.userCode		:= _pxyEvent.userCode;
	self.noCharge		:= _pxyEvent.noCharge;	//05 Nov 2009	NDL	Par 21519
	self.amount			:= _pxyEvent.amount;    //epr par36902 14/9/15
	
	/* // ### TFS BUG 64545 10JUNE024 NAVAB1
	if _pxyEvent.myTerminal &lt;&gt; null then
		self.myTerminal 	:= _pxyEvent.myTerminal;
		self.myRoot 		:= null;
		self.myTerminal.causeEvent(self.myTerminal.getTerminalEvent(EVENT_EVENT_TRANSACTION), false, self);
	else
		self.myTerminal 	:= null;
		self.myRoot 		:= app.myRoot;
		//no terminal so cause event on event type.
		self.myEventType.causeEvent(EVENT_EVENT_TRANSACTION, false, self);
	endif;
	*/
	
	// ### TFS BUG 64545 10JUNE024 NAVAB1 moved setting terminal and root to passport
	app.myPassport.addEventTransactionForDeferUpd(self, _pxyEvent.myTerminal); 
	
	if _pxyEvent.pxyGetRealObject = null then     //03/05/2016  cnwma1 PAR #37813 TFS #1941
		return;
	endif;	
		
	create controller transient;
	controller.allTransactions.add(self);
	self.setForUpdateResync( controller, app.myPassport );
	
epilog
	delete controller;
end;


</source>
        <Parameter name="_pxyEvent" type="CM_EventTransaction"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateResync" id="51cd827e-716b-43d2-a95a-265179d58edc">
        <updating/>
        <source>setForUpdateResync(_controller:CMIF_TiTransactionResync; _passport : CM_Passport input) updating;
// Date			Who		Reason
// Feb 2012		CCMS 	1262 Transaction Enquiry, do event transaction resync
// 23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	bu : CM_Bank;
begin
	
	bu := self.getBank();
	
	if bu = null then
		app.invLog("No business unit, no charge", LogINFO.String);
		return;
	endif;
	
	 // ### JIRA 35228 11JUL2025 NAVAB1
	if self.myTerminal &lt;&gt; null
	and not self.myTerminal.getConfig(FinancialsEnabled).Boolean then
			app.invLog("Financials Are Not Enabled, No Charging Will Occur",LogTRACE.String); // navlw1 #JIRA-33692  
		return;
	endif;

	bu.createChargeEventResync(self);
end;</source>
        <Parameter name="_controller" type="CMIF_TiTransactionResync"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
