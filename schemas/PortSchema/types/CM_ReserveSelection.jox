    <JadeMethod name="getISOGroupFromType" id="aebdb2e0-e459-4e91-8602-a929fe69eac3">
        <source>getISOGroupFromType(): CM_ISOTypeGroup;

/*
Date			Who		Reason
18 March 2010	cnwar2	#22475 - if ISO Type is specified, return the associated ISO Group

*/
vars
	isoGroup : CM_ISOTypeGroup;
	
begin
	if self.myISOType &lt;&gt; null then
		isoGroup := self.myISOType.myISOTypeGroup;
	else
		isoGroup := self.myISOGroup;
	endif;

	return isoGroup;
end;</source>
