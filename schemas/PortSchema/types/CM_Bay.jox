    <JadeMethod name="setOutboardSlots" id="2532e57a-e2b6-429c-b358-153ddaf41664">
        <updating/>
        <source>setOutboardSlots() updating;
/*
------------------------------------------------------------------------
Created:			04 February 2003 by cnwdwq1
Purpose:   		Used by hatchlid update to reset the outboard slots
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	slotDefn : CM_SlotDefn;
begin
	foreach slotDefn in self.allSlotsOnDeck do
		slotDefn.setOutboard();
	endforeach;
end;</source>
