epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="translateVesselVoyage" id="6399c21b-ea34-410f-9876-85972cfac805">
        <updating/>
        <source>translateVesselVoyage(_xlationOperator: CM_Operator) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2019	jlgndl1	Initial creation	TFS 46552

*/

vars

	foundMatch : Boolean;
	processedValue : String;

begin

	inheritMethod(_xlationOperator);
	
	if self.shippingLineCode &lt;&gt; null then
		processedValue := app.myRoot.getXlationSystemCode( self.shippingLineCode, XLATION_TYPE_SHIPPINGLINE, foundMatch );
		if foundMatch and processedValue &lt;&gt; self.shippingLineCode then
			self.shippingLineCode := processedValue;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
</Class>
