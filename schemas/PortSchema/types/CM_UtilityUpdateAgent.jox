    <JadeMethod name="utlUpdateVoyJobTfrType" id="e47e41fd-6b29-4378-92f9-a23ed5648ad8">
        <source>utlUpdateVoyJobTfrType(_proxy : CM_VoyageJobTransferType input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2018	jlgndl1	Initial creation

*/

vars

	real : CM_VoyageJobTransferType;
	beforeAuditText, 
	afterAuditText: String;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_proxy, " Proxy is Null" );
	
	real := _proxy.pxyGetRealObject.CM_VoyageJobTransferType;
	if real = null then
		self.raiseExceptionIfNull(_proxy, " Real is Null" );
	endif;

	app.setContinueCMExceptions(true);
	
	app.myValUA.valCM_Object(_proxy, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.hasErrors then
		return;
	endif;
	
	beforeAuditText := real.getAuditText();
	
	real.setForUpdate(_proxy,_passport);
	
	afterAuditText := real.getAuditText();
	app.myAA.auditUpdateTrx(real, beforeAuditText, afterAuditText);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_VoyageJobTransferType" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyStageForOpAndVoy" id="7ff78393-f8c4-40d3-830a-279ebe33ffe6">
        <source>utlUpdateVoyStageForOpAndVoy(_pxyVoyageStage : CM_VoyageStage ; _passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024

*/

vars
	realVoyageStage : CM_VoyageStage;
	expectedEdition : Integer;
	voyage : CM_Voyage;
	theTerminal : CM_Terminal;
begin
	self.initialiseActivity();

	_pxyVoyageStage.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyVoyageStage.pxyGetRealObjectAndEdition(realVoyageStage, expectedEdition);
	
	if realVoyageStage = null then	
		app.raiseCMException(ProxyMgrCannotLocateReal, CM_VoyageStage.name, null);
		return;
	endif;
	
	exclusiveLock(realVoyageStage);
	
	realVoyageStage.setForUpdate(_pxyVoyageStage);
	
	// ### TFS CR 64612 TASK 64659 18JUL2024 NAVAB1
	if _passport.noErrors then
		theTerminal := _passport.myTerminal;
		voyage := realVoyageStage.getMyVoyageObject();
		app.myEventManager.createSingleObjInfoNoteEvt(voyage,theTerminal.getTerminalEvent(Event_VoyageStageUpdate),realVoyageStage);	
	endif;
epilog

end;</source>
        <Parameter name="_pxyVoyageStage" type="CM_VoyageStage"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyage" id="61d04015-20e2-4c6b-90ad-b8a33faf256a">
        <source>utlUpdateVoyage(_hasStructure, _includeStructure : Boolean;
				_proxyVoyage : CM_Voyage; conflictManager : CMIF_HMS_ConflictsManager output;
				_changeCargoPorts : Boolean;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
// 07/07/2011	cnwcs5	CCMS MES 2084/par 27317 - if vessel changes then delete and re-create the structure
// 21 Sep 2020  cnwma1  ChangeRequest 49906: MTN - Ops View External Webservice
vars
	realBay			: CM_BayVoyage;
	cellVoyage		: CM_CellularVoyageStructure;
	realVoyage		: CM_Voyage;
	expectedEdition	: Integer;
	realVoyGlobalArr,
	realVoyGlobalDep 	: CM_VoyageGlobal;
	deleteStructure, vesselChanged, 		// cnwcs5 par 27317
	berthingChanged 	: Boolean;
	codeChanged 		: Boolean;
	eventStr 			: String;
	realJS 				: CM_VoyageJobSheet;
	cvs 				: CM_CellularVoyageStructure;
	workPointObj 	: CM_Object;
	preUpdateStaus : Integer;		// 17 Jan 2017	NDL	TFS 3191/2876
	departingThisTrx : Boolean;	// 17 Jan 2017	NDL	TFS 3191/2876
	movement : HMS_VoyageMovement; //09 May 2022 navlw1 tfs# 53330 
begin

	self.initialiseActivity();

	_proxyVoyage.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyVoyage.pxyGetRealObjectAndEdition(realVoyage, expectedEdition);
	
	if realVoyage = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Voyage.name, null, null);
		return;
	endif;
	
	app.myValUA.valVoyage(realVoyage, _proxyVoyage, _passport,_includeStructure);

	if realVoyage.myHMSVoyageData &lt;&gt; null then
		//look at improving this at some point
		//navlw1 02 may 2022 TFS 53330 if vessel has changed, hack the movement data to fit the new vessel 
		if  _proxyVoyage.vesselName &lt;&gt; realVoyage.vesselName then
			foreach movement in realVoyage.myHMSVoyageData.allVoyageMovements do
				if _proxyVoyage.myHMSVoyageData &lt;&gt; null then
					if movement.bowMarkTo &gt; movement.sternMarkTo then
						movement.setSternMarkToValue(movement.bowMarkTo - _proxyVoyage.myHMSVoyageData.dim_LengthOverall);
					else
						movement.setSternMarkToValue(movement.bowMarkTo + _proxyVoyage.myHMSVoyageData.dim_LengthOverall);
					endif;
				endif;
			endforeach;
		endif;
		// TSF 53330 end
		// check for movement conflicts
		realVoyage.myHMSVoyageData.validateConflictsBeforeUpdate(conflictManager, _proxyVoyage.myHMSVoyageData);
	endif;
	
	// CCMS 1009 see if structure needs deleteing
	if (not _hasStructure) then 
		if realVoyage &lt;&gt; null and realVoyage.myCellularVoyageStructure &lt;&gt; null then
			cellVoyage := realVoyage.myCellularVoyageStructure;
			if cellVoyage.allBayVoyagesByOrdinal.size &gt; 0 then
				deleteStructure := true;
			endif;	
		endif;
	endif;
	
	// CCMS MES 2084 - check of change of vessel
	if _proxyVoyage.vesselName &lt;&gt; realVoyage.vesselName then
		vesselChanged := true;
	endif;
	
	// Validate structure can be deleted
	if (vesselChanged or deleteStructure) and 	// cnwcs5 par 27317
		cellVoyage &lt;&gt; null and 
		_passport.noErrors then		
		foreach realBay in cellVoyage.allBayVoyagesByOrdinal do
			realBay.validateForDelete();
		endforeach;	
	endif;
		
	if not self.checkValidationWithPassport(_passport)then
		return;
	endif;

	
	app.setContinueCMExceptions(false);

	exclusiveLock(realVoyage);
	
	preUpdateStaus := realVoyage.status;	// 17 Jan 2017	NDL	TFS 3191/2876

	if _passport.noErrors and realVoyage.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Voyage', null, null);
		return;
	endif;
	
	if _proxyVoyage.myVoyageGlobalArrival &lt;&gt; null then
		if not _proxyVoyage.myVoyageGlobalArrival.isTransient then
			realVoyGlobalArr :=  _proxyVoyage.myVoyageGlobalArrival;
		endif;
	endif;
	
	if _proxyVoyage.myVoyageGlobalDeparture &lt;&gt; null then
		if not _proxyVoyage.myVoyageGlobalDeparture.isTransient then
			realVoyGlobalDep :=  _proxyVoyage.myVoyageGlobalDeparture;
		endif;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyage, true);
	endif;
	
	if _passport.noErrors then
		if realVoyage.starboardBerthed &lt;&gt; _proxyVoyage.starboardBerthed then
			berthingChanged := true;
		endif;
		if realVoyage.code &lt;&gt; _proxyVoyage.code or realVoyage.colour &lt;&gt; _proxyVoyage.colour then
			codeChanged := true;
		endif;
		//If the (new exchange date/time) &gt; (the crane start date/time) then the start date/time will be updatet with the new exchange date/time.
		//realVoyage.setOOWVoyageDetails(_proxyVoyage.shipExchangeDate, realVoyage.starboardBerthed);		//cnwmc5 - 16 Oct 2013 - PAR 32793
		realVoyage.setShipExchangeDate(_proxyVoyage.shipExchangeDate);										//cnwmc5 - 16 Oct 2013 - PAR 32793
		
		if vesselChanged then									// cnwcs5 par 27317
			// should only happen from EDI
			// proxy will have new vessel structure - delete real structure here B4 we create the new structure
			realVoyage.setForUpdateStructure(deleteStructure);	// cnwcs5 par 27317
		endif;													// cnwcs5 par 27317
		
		realVoyage.setForUpdate(_hasStructure,_proxyVoyage, realVoyGlobalArr, realVoyGlobalDep, _passport);

		// if we are going to get rid of the structure do it now - what about GC
		if _includeStructure or deleteStructure then			
			// will delete the structure 
			realVoyage.setForUpdateStructure(deleteStructure);	
		endif;																	

		// PAR 26885 (ensure movements are linked correctly) RJS 6 Feb 2011
		if _passport.noErrors then
			realVoyage.maintainMovementLinkedList();
		endif;
	endif;

	if _passport.noErrors and _changeCargoPorts then	
		realVoyage.fixCargoDischargePorts();
	endif;
	
	//epr par 30725 19/11/12 
	if _passport.noErrors then
		realVoyage.createVoyageInlandTerminals();
	endif;
	
	// 17 Jan 2017	NDL	TFS 3191/2876
	if preUpdateStaus &lt;&gt; Voyage_Status_Departed then
		if realVoyage.status = Voyage_Status_Departed then
			departingThisTrx := true;
		endif;
		if departingThisTrx and realVoyage.myTerminal.getConfig(CloseShipReqsOnDepart).Boolean then
			realVoyage.closeShipRequests( _passport );
		endif;
	endif;
	
	if  _passport.noErrors then
		if berthingChanged then
			realVoyage.causeEvent(realVoyage.myTerminal.getTerminalEvent(EVENT_VOYAGE_BERTHING_CHANGED), false, realVoyage);
		endif;
		if codeChanged then
			eventStr := "&lt;" &amp; GridXML_ColourCode &amp; "&gt;" &amp; realVoyage.code  &amp; "&lt;/" &amp; GridXML_ColourCode &amp; "&gt;" &amp;
						"&lt;" &amp; GridXML_Colour &amp; "&gt;" &amp; realVoyage.colour.String  &amp; "&lt;/" &amp; GridXML_Colour &amp; "&gt;";
			realVoyage.causeEvent(EVENT_CODE_COLOUR_CHANGE, false, eventStr);
		endif;
		app.myEventManager.createSingleObjInfoNoteEvt(realVoyage, realVoyage.myTerminal.getTerminalEvent(Voyage_Update_Event), realVoyage);
	
		realVoyage.causeEvent(realVoyage.myTerminal.getTerminalEvent(EVENT_OOWVOYAGE_UPDATE), false, realVoyage);
		
		cvs := realVoyage.myCellularVoyageStructure;
		if cvs &lt;&gt; null then
			foreach realJS in realVoyage.allJobSheets do
				workPointObj:= realJS.getMyWorkPointObject();
				if workPointObj &lt;&gt; null then
					cvs.causeEvent(cvs.myVoyage.myTerminal.getTerminalEvent(EVENT_CRANE_UPDATE), false, workPointObj);
				endif;
			endforeach;
		endif;
		self.myUpdateAuditAgent.audUpdateGeneric(realVoyage, false);
		
		//21.09.2020 cnwma1 TFS #49906
		if _passport.isOpsViewEnabled(realVoyage.getMyTerminal()) then
			realVoyage.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,
											   BGP_OpsViewWSRequest.OPS_TYPE_VOYAGE,
											   realVoyage);
		endif;
		//21.09.2020 cnwma1 TFS #49906
	endif;

end;</source>
        <Parameter name="_hasStructure" type="Boolean"/>
        <Parameter name="_includeStructure" type="Boolean"/>
        <Parameter name="_proxyVoyage" type="CM_Voyage"/>
        <Parameter name="conflictManager" type="CMIF_HMS_ConflictsManager" usage="output"/>
        <Parameter name="_changeCargoPorts" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageAlloc" id="618e9231-98fa-4efa-9fd4-539423a9f203">
        <source>utlUpdateVoyageAlloc(_update : Boolean;					
					 _voyage : CM_Voyage; 
					 _voyageAllocTemplate : CM_VoyageAllocation input;
					 _realAlloc : CM_VoyageAllocation io;
					 _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 Dec 2009	cnwas3	Initial creation
02 Apr 2012	cnwrs1	Par 29077 - EDI RORO Stowage Advice errors
09 Jan 2013	cnwkpd1	PAR #30964 - Add new event for Voyage Allocation maintenance

*/
vars
	expectedEdition, eventUpdateVoyageArea		: Integer;
	colourChange				: Boolean;
	slot : CM_SlotController;
	slotReq : CM_SlotRequest;
	slotReqRORO : CM_VoyageRequest;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);	//02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors

	self.raiseExceptionIfNull(_voyageAllocTemplate, 'Voyage Allocation Template');
	self.raiseExceptionIfNull(_voyage, 'Voyage');	
	
	app.setContinueCMExceptions(true);
	app.myValUA.valVoyageAlloc(_voyage, _voyageAllocTemplate, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
//	app.setContinueCMExceptions(false);	//30 Mar 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
	if _update then
		colourChange := (_voyageAllocTemplate.color &lt;&gt; _realAlloc.color);
	endif;

	_voyage.setVoyageAllocation(_update,_voyageAllocTemplate,_realAlloc, _passport);
	
	
	if not _passport.hasErrorsOrWarnings() then
		app.myEventManager.createSingleObjInfoNoteEvt(_voyage,_passport.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE),_realAlloc);
		app.myEventManager.createSingleObjInfoNoteEvt(_voyage,_passport.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_MAINT),_realAlloc);	// PAR #30964

		if colourChange then
			eventUpdateVoyageArea := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);
			foreach	slotReq in _realAlloc.allSlotRequests do
				_voyage.causeEvent(eventUpdateVoyageArea, false, slotReq.mySlotController);
			endforeach;
			foreach	slotReqRORO in _realAlloc.allRequests do
				_voyage.causeEvent(eventUpdateVoyageArea, false, slotReqRORO.getMyLC());
			endforeach;
		endif;
	endif;

end;</source>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_voyageAllocTemplate" type="CM_VoyageAllocation" usage="input"/>
        <Parameter name="_realAlloc" type="CM_VoyageAllocation" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVoyageAllocEvents" id="788f6bd1-c2a4-49d8-ba46-ad8d8e3b0183">
        <source>utlUpdateVoyageAllocEvents(_voyage : CM_Voyage input; 
							_voyageEventTypes : CM_EventTypesArray input;
