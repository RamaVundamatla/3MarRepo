epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setBaseDataFromBGP" id="624f6e40-82dd-433e-a9e8-4ffa6f86a6bc">
        <updating/>
        <source>setBaseDataFromBGP( _bgpTask : BGP_LocationActivityBalance ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin
	
	if _bgpTask = null or _bgpTask.myTerminal = null then
		return;
	endif;
	
	self.recalculateOnly := _bgpTask.recalculateOnly;
	
	self.myTerminal := _bgpTask.myTerminal;
	
	self.setDatesBGP(); // ### TFS 51515 20JUL2021 NAVAB1
	
epilog

end;</source>
        <Parameter name="_bgpTask" type="BGP_LocationActivityBalance"/>
    </JadeMethod>
    <JadeMethod name="setBaseDataFromForm" id="0752e7c7-7061-4a63-828e-33a47f9de1b2">
        <updating/>
        <source>setBaseDataFromForm( 	_myTerminal : CM_Terminal;
						_myTerminalArea : CM_TerminalArea;
						_myLocation : CM_LocationsController;
						_myCargoType : CM_CargoType;
						_myOperator : CM_Operator
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2021	navndl1	Initial creation	TFS 50906 

*/

vars

begin
	
	self.recalculateOnly := true;
	
	self.myTerminal := _myTerminal;
	self.myTerminalArea := _myTerminalArea;
	self.myLocation := _myLocation; // ### TFS 51515 20JUL2021 NAVAB1 added missing '_' to variables
	self.myCargoType := _myCargoType; // ### TFS 51515 20JUL2021 NAVAB1 added missing '_' to variables
	self.myOperator := _myOperator; // ### TFS 51515 20JUL2021 NAVAB1 added missing '_' to variables
	
	self.setDatesForm(); // ### TFS 51515 20JUL2021 NAVAB1

epilog

end;</source>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
        <Parameter name="_myTerminalArea" type="CM_TerminalArea"/>
        <Parameter name="_myLocation" type="CM_LocationsController"/>
        <Parameter name="_myCargoType" type="CM_CargoType"/>
        <Parameter name="_myOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setDates" id="d6dbefe9-65c7-43bf-b57b-132d1cc43b7a">
        <updating/>
        <source>setDates() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2021	navndl1	Initial creation	TFS	50906 

*/




// NOT USED






vars

	now : TimeStamp;
	localTime : TimeStamp;
	daysInArrears : Integer;

begin

	nomalStartTime.setTime( 0, 0, 0, 0 );
	nomalEndTime.setTime( 23, 59, 59, 999 );
	
	now := app.actualTimeServer;
	localTime := now.systemToLocalTimeUsingObject( self );
	
	if process.isJLGAB1 then
		latestRecalcTS := localTime; 
	
	else
		latestRecalcTS := localTime.cnEcAddDays( -1 ); 
	endif;
	latestRecalcTS.setTime( nomalEndTime );  //One Millisecond before Midnight Yesterday. //Only times up to this are fair game for re-calculation (Normal processing for these wont have happened yet.) 
	
	latestCurrentTS := localTime.cnEcAddDays( -1 ); 
	latestCurrentTS.setTime( nomalEndTime );  //One millisecond before Midnight Today. //Only times later than or equal to "latestRecalcTS" and less than or equal to "latestCurrentTS" are fair game for Normal processing. 

	daysInArrears := ( self.myTerminal.getLocationActivityMaxDays() + 1 ) * -1;
	earliestRecalcTS := localTime.cnEcAddDays( daysInArrears ); //Oldest date time that they are allowed to have re-calculations for
	earliestRecalcTS.setTime( nomalStartTime );
	
	
	earliestRecalcTSServer := earliestRecalcTS.localToSystemTimeUsingObject( self );
	latestCurrentTSServer := latestCurrentTS.localToSystemTimeUsingObject( self );
	latestRecalcTSServer := latestRecalcTS.localToSystemTimeUsingObject( self );

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDatesBGP" id="c4fa477d-f5b3-4b17-a161-17992d708e5b">
        <updating/>
        <source>setDatesBGP() updating, protected;
/*
Purpose:			

Date		Who		Reason
20JUL2021	NAVAB1	TFS 51515
*/

vars

	now : TimeStamp;
	localTime : TimeStamp;
	daysInArrears : Integer;
	locact : CMEVT_LocationActivity;
begin

	nomalStartTime.setTime( 0, 0, 0, 0 );
	nomalEndTime.setTime( 23, 59, 59, 999 );
	
	now := app.actualTimeServer;
	localTime := now.systemToLocalTimeUsingObject( self );
	
	latestRecalcTS := localTime.cnEcAddDays( -1 ); 
	latestRecalcTS.setTime( nomalEndTime );  //One Millisecond before Midnight Yesterday. //Only times up to this are fair game for re-calculation (Normal processing for these wont have happened yet.) 
	
	latestCurrentTS := localTime.cnEcAddDays( -1 ); 
	latestCurrentTS.setTime( nomalEndTime );  //One millisecond before Midnight Today. //Only times later than or equal to "latestRecalcTS" and less than or equal to "latestCurrentTS" are fair game for Normal processing. 


	// get the earliest BALANCE that needs recalc using a null date
	locact := self.myTerminal.allLocationActivityReCalc.getAtKeyGeq(EVT_LocationBalance, true, null);
	if locact &lt;&gt; null 
	and locact.isLocationBalance
	and locact.needsRecalculation then
		earliestRecalcTS := locact.dateTime;
		earliestRecalcTS.cnEcAddDays(-1);
		earliestRecalcTS.setTime( nomalStartTime );
	
	else
		daysInArrears := ( self.myTerminal.getLocationActivityMaxDays() + 1 ) * -1;
		earliestRecalcTS := localTime.cnEcAddDays( daysInArrears ); //Oldest date time that they are allowed to have re-calculations for
		earliestRecalcTS.setTime( nomalStartTime );
	
	endif;
	
	earliestRecalcTSServer := earliestRecalcTS.localToSystemTimeUsingObject( self );
	latestCurrentTSServer := latestCurrentTS.localToSystemTimeUsingObject( self );
	latestRecalcTSServer := latestRecalcTS.localToSystemTimeUsingObject( self );

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDatesForm" id="d3e05ec8-0e93-4e9d-b4e5-0cea9ea53f37">
        <updating/>
        <source>setDatesForm() updating, protected;
/*
Purpose:			

Date		Who		Reason
20JUL2021	NAVAB1	TFS 51515
*/

vars

	now : TimeStamp;
	localTime : TimeStamp;
	daysInArrears : Integer;
	locact : CMEVT_LocationActivity;
begin

	nomalStartTime.setTime( 0, 0, 0, 0 );
	nomalEndTime.setTime( 23, 59, 59, 999 );
	
	now := app.actualTimeServer;
	localTime := now.systemToLocalTimeUsingObject( self );
	
	if process.isJLGAB1 then
		latestRecalcTS := localTime; 
	
	else
		latestRecalcTS := localTime.cnEcAddDays( -1 ); 
	endif;
	latestRecalcTS.setTime( nomalEndTime );  //One Millisecond before Midnight Yesterday. //Only times up to this are fair game for re-calculation (Normal processing for these wont have happened yet.) 
	
	latestCurrentTS := localTime.cnEcAddDays( -1 ); 
	latestCurrentTS.setTime( nomalEndTime );  //One millisecond before Midnight Today. //Only times later than or equal to "latestRecalcTS" and less than or equal to "latestCurrentTS" are fair game for Normal processing. 


	// get the earliest BALANCE that needs recalc using a null date
	earliestRecalcTS := self.setEarliestDateForm();

	earliestRecalcTSServer := earliestRecalcTS.localToSystemTimeUsingObject( self );
	latestCurrentTSServer := latestCurrentTS.localToSystemTimeUsingObject( self );
	latestRecalcTSServer := latestRecalcTS.localToSystemTimeUsingObject( self );

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setEarliestDateForm" id="de0fec93-f994-41f7-be1e-24ae53a76257">
        <updating/>
        <source>setEarliestDateForm() : TimeStamp updating;
/*
Purpose:			

Date		Who		Reason
20 July 2021	navab1	TFS 51515
*/

vars
	locactbal, locactmove : CMEVT_LocationActivity;
	nomalStartTime : Time;
	earliestBal, earlietMov : TimeStamp;
begin
	// get the earliest BALANCE that needs recalc using a null date
	nomalStartTime.setTime( 0, 0, 0, 0 );

	locactbal := self.myTerminalArea.allLocationActivityReCalc.getAtKeyGeq(EVT_LocationBalance, self.myCargoType, self.myOperator, true, null);
	locactmove := self.myTerminalArea.allLocationActivityReCalc.getAtKeyGeq(EVT_LocationMove, self.myCargoType, self.myOperator, true, null);
	
	earliestBal := app.actualTimeServer;
	earlietMov := app.actualTimeServer;
	
	if locactbal &lt;&gt; null 
	and locactbal.isLocationBalance
	and locactbal.needsRecalculation 
	and locactbal.getCargoType() = self.myCargoType
	and locactbal.getOperator() = self.myOperator	then
		earliestBal := locactbal.dateTime;
	endif;
	
	if locactmove &lt;&gt; null 
	and locactmove.isLocationMove
	and locactmove.needsRecalculation 
	and locactmove.getCargoType() = self.myCargoType
	and locactmove.getOperator() = self.myOperator	then
		earlietMov := locactmove.dateTime;
	endif;
	
	if earliestBal &lt; earlietMov then
		earliestRecalcTS := earliestBal;
	else
		earliestRecalcTS := earlietMov;
	endif;	
	
	earliestRecalcTS.setTime( nomalStartTime );
	
	return earliestRecalcTS;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
</Class>
