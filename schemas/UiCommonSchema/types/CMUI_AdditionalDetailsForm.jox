    <JadeMethod name="cmbSpecialLift_doAlignCtrls" id="1eb79c8a-4b59-41bd-ac3c-e3fe812fb129">
        <controlMethod name="CMUI_FieldGeneric::doAlignCtrls"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSpecialLift_doAlignCtrls(_fieldGeneric: CMUI_FieldGeneric input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2009	cnwdap1	Initial creation
*/
vars

begin
	txtSpecialLift.move(self.widestCaptionExtent + _fieldGeneric.HORIZONTAL_SPACING, 0, 200, cmbSpecialLift.height);
	txtSpecialLift.tabIndex := _fieldGeneric.tabIndex + 1;
	
	// list box invisible for now
	lstSpecialLift.visible := false;
epilog

end;</source>
        <Parameter name="_fieldGeneric" type="CMUI_FieldGeneric" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbSpecialLift_doTabOrder" id="2b34d62c-c2a9-4631-b541-93a6972c8b06">
        <controlMethod name="CMUI_FieldGeneric::doTabOrder"/>
        <methodInvocation>event</methodInvocation>
        <source>cmbSpecialLift_doTabOrder(_startTab: Integer):Integer protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2009	cnwdap1	Initial creation
*/
vars
	tabOrder	: Integer;

begin
	tabOrder					:= _startTab;
	tabOrder 					:= tabOrder + 1;
	lstSpecialLift.tabIndex 	:= tabOrder;
	tabOrder 					:= tabOrder + 1;
	txtSpecialLift.tabIndex 	:= tabOrder;
	return tabOrder;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_startTab" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cmbSpecialLift_doUpdateValue" id="38db6a69-60dc-4d61-981b-3ab0c455aa19">
        <controlMethod name="CMUI_FieldGeneric::doUpdateValue"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSpecialLift_doUpdateValue(_value: Any) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2009	cnwdap1	Initial creation
*/
vars

begin
	if _value = null then
		self.txtSpecialLift.text := null;
		self.lstSpecialLift.clearAllSelected;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="cmbSpecialLift_hasGotFocus" id="0a6fe342-86c2-43e6-b897-f8c90bbdff6d">
        <controlMethod name="CMUI_FieldFrame::hasGotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSpecialLift_hasGotFocus(_fieldFrame: CMUI_FieldFrame input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2009	cnwdap1	Initial creation
*/
vars

begin
	// make list box bigger, and place it over the textbox
	self.lstSpecialLift.move(self.txtSpecialLift.getFormLeft, self.txtSpecialLift.getFormTop, self.txtSpecialLift.width, 70);	//cnwmc5 - PAR 31609
	self.lstSpecialLift.visible := true;
	self.lstSpecialLift.parent := self;
	self.txtSpecialLift.visible := false;
	self.lstSpecialLift.setFocus;
epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbSpecialLift_hasLostFocus" id="a442da90-5ddf-49e5-8cde-1533a29d259c">
        <controlMethod name="CMUI_FieldFrame::hasLostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSpecialLift_hasLostFocus(_fieldFrame: CMUI_FieldFrame input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2009	cnwdap1	Initial creation
*/
vars
	str 	: String;

begin
	// get codes from list box, display in text box and disappear the list box
	str := self.lstSpecialLift.getSelectedString('code');
	if str.length &gt; 30 then
		self.txtSpecialLift.text := str[1:29]&amp; '...';
	else
		self.txtSpecialLift.text := str;
	endif;
	self.txtSpecialLift.visible := true;
	self.lstSpecialLift.visible := false;
	self.lstSpecialLift.parent := _fieldFrame;
epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
    </JadeMethod>
