    <JadeMethod name="saveFormat" id="f115a05f-103b-4d69-8074-08d416051aa4">
        <updating/>
        <source>saveFormat() updating;
//----------------------------------------------------------------
//	Created:	08 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	itemField	: CM_EDIItemField;
	rtnStr,
	constantStr,
	str			: String;
	fieldParent,
	csvElem,
	xmlElem		: JadeXMLElement;
	xmlDoc		: JadeXMLDocument;
	rootElem	: JadeXMLElement;
	const		: Constant;
	cat			: ConstantCategory;
	intRow,
	result		: Integer;
	ediDataType : Integer;
begin
	
	create xmlDoc transient;
	rootElem := xmlDoc.addElement('EDIFileFormat');
	//add some fileFormat tags
	
	xmlElem := rootElem.addElement('FormatName');
	xmlElem.setText(self.txtFormatName.text);
	
	xmlElem := rootElem.addElement('EDIDataType');
	ediDataType := self.cmbEDIDataType.listIndex;
	if ediDataType =  7 then	//cnwrs1 10 dec 2010 ccms 1976
		ediDataType := EDIDataType_Pack;
	endif;
	xmlElem.setText(ediDataType.String);
	
	xmlElem := rootElem.addElement('EDIFileType');
	if self.fileType = FileTypeXML then
		xmlElem.setText(EDIFileType_XML.String);
	elseif self.fileType = FileTypeCSV then
		xmlElem.setText(EDIFileType_CSV.String);
	else
		xmlElem.setText(EDIFileType_Unknown.String);
	endif;
	xmlElem := rootElem.addElement('XlationOperator');
	xmlElem.setText(self.txtXlationOper.text.trimBlanks);
		
	fieldParent := rootElem.addElement('FormatFields');
	
	foreach itemField in self.allMatchedFileFields do
		
		xmlElem := fieldParent.addElement('FormatField');
		itemField.setXMLElement(xmlElem);
	endforeach;
	
	if self.fileType = FileTypeXML then
		xmlElem := rootElem.addElement('RootTag');
		xmlElem.setText(self.fileRootTagName);
		
		xmlElem := rootElem.addElement('MessageTag');
		xmlElem.setText(self.msgRootTagName);
		
		xmlElem := rootElem.addElement('TITag');
		xmlElem.setText(self.tiRootTagName);
	
		xmlElem := rootElem.addElement('OriginalXML');
		xmlElem.setText(self.myXMLDoc.writeToString());
	endif;
	
	if self.fileType = FileTypeCSV then
		xmlElem := rootElem.addElement('OriginalCSV');
		if self.csvHeadingsColumn &lt; 1 then
			self.csvHeadingsColumn := 1;
		endif;
		foreach intRow in 2 to self.tblCSVDisplay.rows do
			csvElem := xmlElem.addElement('CSVHeader');
			csvElem.addAttribute('index', self.tblCSVDisplay.accessCell(intRow, 1).text);
			csvElem.setText(self.tblCSVDisplay.accessCell(intRow, self.csvHeadingsColumn).text.removeEDIInvalidChars);
		endforeach;
	endif;
	
	if self.txtFormatName.text = null or
	self.txtFormatName.text = self.cmbFileFormats.text then
		//attemp an update
		if self.cmbFileFormats.text = null then
			//nothing to update
			app.raiseUnexpectedProgramError(class.name, method.name, 'no name specified - need a name');	
		else
			//update self.cmbFileFormats.listObject
			const := self.cmbFileFormats.listObject.Constant;
			beginTransaction;
				const.setPropertyValue('text', xmlDoc.rootElement.writeToString());
			commitTransaction;
		endif;
	else
		//make new
		self.maxConstValue := self.maxConstValue+1;
		constantStr := self.txtFormatName.text &amp; ':' &amp; Tab &amp; "Integer = " &amp; self.maxConstValue.String &amp; ";" &amp; CrLf &amp;
		Tab &amp; 'documentationText' &amp; CrLf &amp;
		'`' &amp;  xmlDoc.rootElement.writeToString() &amp; '`' &amp; CrLf &amp; CrLf;

		result := global.addConstantsServer('EDIFileFormats', constantStr, rtnStr);
		
		app.writeStatement( "return = " &amp; result.String &amp; ".  rtnStr = " &amp; rtnStr);

	endif;
	

	
epilog
	delete xmlElem;	
	delete xmlDoc;	
end;</source>
    </JadeMethod>
    <JadeMethod name="selectFileFormat" id="f463523b-9ce4-444c-b70c-8dca1d37501a">
        <updating/>
        <source>selectFileFormat() updating;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	const			: Constant;
	constXML		: CM_XMLDocument;
	xmlElem			: JadeXMLElement;
	listIndex		: Integer;
	xmlFFElemArray	: JadeXMLElementArray;
begin	

	self.resetControls();
	
	const := self.cmbFileFormats.listObject.Constant;
	create constXML;
	constXML.parseString(const.text);

	self.txtFormatName.text := const.name;

	xmlElem := constXML.getElementByTagName('EDIFileType');
	if xmlElem.textData = EDIFileType_XML.String then
		self.fileType := FileTypeXML;
	elseif xmlElem.textData = EDIFileType_CSV.String then
		self.fileType := FileTypeCSV;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'this type not supported ' &amp; xmlElem.textData);
	endif;
//	display the format of the original file	
	delete self.myXMLDoc;
	if self.fileType = FileTypeXML then
		
		//set the myXMLDoc ref
		xmlElem := constXML.getElementByTagName('OriginalXML');
		create self.myXMLDoc;
		self.myXMLDoc.parseString(xmlElem.textData);
		self.loadXMLDoc();
		
		xmlElem := constXML.getElementByTagName('RootTag');
		if xmlElem &lt;&gt; null then
			self.fileRootTagName := xmlElem.textData;
		endif;
			
		xmlElem := constXML.getElementByTagName('MessageTag');
		if xmlElem &lt;&gt; null then
			self.msgRootTagName := xmlElem.textData;
		endif;
		
		xmlElem := constXML.getElementByTagName('TITag');
		if xmlElem &lt;&gt; null then
			self.tiRootTagName := xmlElem.textData;
		endif;
		
	elseif self.fileType = FileTypeCSV then
		xmlElem := constXML.getElementByTagName('OriginalCSV');
		self.loadCSVFromConstantXML(xmlElem);
	endif;
	
	xmlElem := null;
//	show the data type and saved matches	
	self.txtXlationOper.text := constXML.getElementByTagName('XlationOperator').textData;
	
	listIndex := constXML.getElementByTagName('EDIDataType').textData.Integer;
	if listIndex = EDIDataType_Pack then	//cnwrs1 10 dec 2010 ccms 1976
		listIndex := 7;
	endif;
	self.cmbEDIDataType.listIndex := listIndex;
	//load in the relevant itemFields
	self.doCmbEDIDataClick();
		
	create xmlFFElemArray transient;
	
	constXML.getElementsByTagName('FormatField', xmlFFElemArray);

	if self.fileType = FileTypeXML then
		self.showMatchedFieldsXML(xmlFFElemArray);
		self.doRootTagsForFormat();
	elseif self.fileType = FileTypeCSV then
		self.showMatchedFieldsCSV(xmlFFElemArray);
	endif;

epilog
	self.updateMatchedDisplay();	
	delete constXML;
	delete xmlFFElemArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="setFileRootTag" id="e4759ab8-d0df-4a0a-bad7-f09adfedaf2f">
        <updating/>
        <source>setFileRootTag() updating;
//----------------------------------------------------------------
//	Created:	18 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	theName			: String;
	idx				: Integer;
begin

	theName := self.getCurrentXMLTagName();
	
	if theName = null then
		return;
	endif;

	//erase file root colour from exist lines
	foreach	idx in 1 to self.lstXMLDisplay.listCount do
		if self.lstXMLDisplay.itemBackColor[idx] = CM_BaseForm.ColourYellowDark then
			self.lstXMLDisplay.itemBackColor[idx] := White;
		endif;
	endforeach;

	if self.chkRootTag.value = true then
		//was false, changing to true
		self.fileRootTagName := theName;
		self.lstXMLDisplay.itemBackColor[self.lstXMLDisplay.listIndex] := CM_BaseForm.ColourYellowDark;
	else
		//true, changing to false
		self.fileRootTagName := "";
	endif;
	
	self.chkMsgTag.value := false;
	if self.msgRootTagName = theName then
		self.msgRootTagName := "";
	endif;
	
	self.chkTITag.value := false;
	if self.tiRootTagName = theName then
		self.tiRootTagName := "";
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCSV" id="431e241d-4336-4cff-bc31-1485129696b0">
        <source>setForCSV();
//----------------------------------------------------------------
