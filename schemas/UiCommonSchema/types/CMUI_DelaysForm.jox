/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2016	cnwma1	Initial creation TFS #2666

*/

vars

begin
	if self.myTerminal &lt;&gt; null and self.myTerminal.getConfig(DelayDefaultEstimateEnd).Boolean then   //14/09/2016 cnwma1 TFS #2666 PAR #38198
		if self.txtEstDate.text.asDateJMT().isValid() then
			self.txtEndDate.text :=self.txtEstDate.text;
		endif;
	endif;
epilog

end;</source>
