    <JadeMethod name="doBtnEditClick" id="2347e852-27f9-40b0-baad-ec6da6f855da">
        <updating/>
        <source>doBtnEditClick() updating;
// ---------------------------------------------------------------------------
// Created:     24 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	entVeiw		: 	String;
begin
	self.doLstDataClick(self.lstData);
	
	self.setUpdateMode(self.UpdateMode_Update);
	if self.myCurrentDate &lt;&gt; null then
		self.modePropertyNew := self.MODEPROPERTY_DATE;
		entVeiw := 'DateEntry';
	elseif self.myCurrentYear &lt;&gt; null then 
		self.modePropertyNew := self.MODEPROPERTY_YEAR;
		entVeiw := 'YearEntry';
	elseif self.myCurrentCalendar &lt;&gt; null then
		self.modePropertyNew := self.MODEPROPERTY_CALENDAR;
		entVeiw := 'CalendarEntry';
	else
		global.beep;
		return;
	endif;
	self.showPropertyFrame(entVeiw, null,PROPHEIGHT);

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnNewCalendarClick" id="059ec6c8-8c9e-4359-b1a9-799f17d77cdf">
