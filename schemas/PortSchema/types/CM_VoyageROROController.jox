    <JadeMethod name="setAltSlotDLRALT" id="bd15c0f5-b892-4182-9ac9-cf5d0608311e">
        <updating/>
        <source>setAltSlotDLRALT(_altDischSlot : CM_VoyageController; _moveType : Integer) updating;
/*
Purpose:	// PAR 28968	I am the ALT	LOAD
Date		Who		Reason
02 April 2012	cnwab1	Initial creation
*/

vars
	tmpSlotAlt, aftLC : CM_VoyageROROController;
	aSlotReqLoad,pxySR, aftRequest : CM_RORORequest;
	aSlotReqDisch : CM_Request;
	tmpTI : CM_TrackedItem;
	loadAlloc : CM_VoyageAllocation;
	needAftRequest : Boolean;
	qty : Integer;
begin
	tmpSlotAlt := self;
	aSlotReqLoad := tmpSlotAlt.myRORORequestLoad;
	
	aSlotReqDisch := _altDischSlot.getRequest(false);
	
	qty := _altDischSlot.allTrackedItems.size;
				
	if aSlotReqLoad = null then
	
		// create Load CC from Discharge CC
		if aSlotReqDisch.isLOLO() then
			create pxySR as CM_ROROSlotRequest transient;
		else
			create pxySR as aSlotReqDisch.class transient;
		endif;
		
		pxySR.setProxyForCreate(tmpSlotAlt, LOAD_MOVETYPE, true, qty); // cargo type set later on
		app.myUtilityCA.utlCreateSlotRequestRORO(pxySR, aSlotReqLoad, app.myPassport);
		if app.myPassport.hasErrors then
			return;
		endif;

		delete pxySR;
		tmpTI := aSlotReqDisch.getTrackedItem();
		aSlotReqLoad.setFromTI(tmpTI); // AND ALLOCATION !!!
		loadAlloc := aSlotReqLoad.allAllocations.first().CM_VoyageAllocation;
		aSlotReqLoad.setColourFromAllocation(loadAlloc, qty);
		
		// #### AFT FOR 40s
		
		if loadAlloc &lt;&gt; null then
			needAftRequest := loadAlloc.needsAftRequest();
			
			if app.myPassport.noErrors 
			and needAftRequest 
			and aSlotReqLoad.CM_ROROSlotRequest.mySlotRequestAft = null 	
			and aSlotReqLoad.CM_ROROSlotRequest.mySlotRequestForward = null then	
				aftLC := tmpSlotAlt.getAftLC();
				if aftLC &lt;&gt; null then
					aftRequest := aftLC.createUpdateRORORequest(true, loadAlloc, qty ,LOAD_MOVETYPE,tmpSlotAlt, app.myPassport); // PAR 28585
				
					if aftRequest &lt;&gt; null then		// newRequest not created if fails validation
						aftRequest.setForwardSlotRequest(aSlotReqLoad);
					endif;			
				endif;
			endif;
		endif;
		
	endif;


	tmpSlotAlt.updateSlotRequestDLRSOB(true, _moveType, app.myPassport);
	if app.myPassport.hasErrors then
		return;
	endif;

	// PAR 21746 if otherRequest.fortyBack then // never link to a 40 backend
	if aSlotReqDisch.isBackEndRequest() then // never link to a 40 backend// PAR 21746

		app.raiseCMException1(SlotRequestUpdateFromBack, _altDischSlot.getFullId(), null, null);
		return;
	endif;
	
	
	if aSlotReqDisch.isLinked() then
		app.raiseCMException1(ErrSlotRequestAlreadyLinked, _altDischSlot.getID, null, null);
		return;
	endif;

	if aSlotReqDisch &lt;&gt; null and aSlotReqLoad &lt;&gt; null then
		aSlotReqDisch.setLinkedRequest(aSlotReqLoad);
	endif;

epilog

end;</source>
        <Parameter name="_altDischSlot" type="CM_VoyageController"/>
        <Parameter name="_moveType" type="Integer"/>
    </JadeMethod>
