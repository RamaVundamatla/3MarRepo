    <JadeMethod name="showDocketMaintForm" id="b8f8aef5-dc0e-4fab-8cf9-1cff8f4cc12b">
        <source>showDocketMaintForm(_realBOL : CM_BOL; _masterMenuAction : CMUI_MenuAction;
					_thumbnailOnly, _doEdit : Boolean);
//--------------------------------------------------------------
//Created: 30 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	docketForm : CMUI_DocketForm;
	menuAction : CMUI_MenuAction;
begin

	if _realBOL = null or
	   (not _realBOL.isKindOf(CM_BOLIn)) then
		return;
	endif;

	menuAction := app.myController.createMenuAction(PmAdmDocketView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	docketForm := menuAction.goToObject(null, null, false, null).CMUI_DocketForm;
	if docketForm = null then
		return;
	endif;
	
	docketForm.showWithObject(_realBOL, _thumbnailOnly, _doEdit);

end;</source>
        <Parameter name="_realBOL" type="CM_BOL"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
