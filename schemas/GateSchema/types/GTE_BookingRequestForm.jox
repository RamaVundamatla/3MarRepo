    <JadeMethod name="checkFlags" id="22245b8d-6d4e-4190-8abb-0bec970e2134">
        <source>checkFlags(checkbox : CheckBox input ):Boolean;

vars

begin
	if self.chkNoEmptiesOut.value 
	and self.chkNoFullsIn.value then
		checkbox.value := false;
		app.msgBox("A booking cannot have both 'No Empties Out' and 'No Fulls In' checked.", "Warning", MsgBox_OK_Only);
		return false;
	endif;
	return true;
end;
</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkHasChanged" id="103e1802-c8eb-4c88-a34a-5bf01364d0a4">
        <source>checkHasChanged(_changedProperties : PropertySet io) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2008	cnwer1	Initial creation

*/

vars
	versionChecker : CM_DisplayVersionChecker;
	tempBookingRef : CM_BookingRef;
	tempBulkRelease : CM_BulkRelease;
begin

	if self.hasBookingRefItemChanged or self.hasReserveDetailsChanged then
		return true;
	endif;

	create versionChecker transient;
	
	create tempBookingRef transient;
	self.saveDataToProxyBookingRef(tempBookingRef);
	
	versionChecker.init(self.myProxyBookingRef,tempBookingRef);
	if versionChecker.allChangedProperties.size &gt; 0 then
		if _changedProperties &lt;&gt; null then
			versionChecker.getAllChangedProperties(_changedProperties);
		endif;
		if app.isSpecial then
			versionChecker.writeChangedProperties();
		endif;
		if _changedProperties &lt;&gt; null then
			if (_changedProperties.size = 1 and _changedProperties.includes(CM_BookingRef::bookingReference)) then
			//oops have to still check bulk release if only the booking ref has changed as if from enquiry we expect this has changed
			else
				return true;
			endif;
		else
			return true;
		endif;
	endif;
	//check bulk releases
	create tempBulkRelease transient;
	self.saveDataToProxyBulkRelease(tempBulkRelease,tempBookingRef);
	versionChecker.init(self.myProxyBookingRef.allReleaseRequests.first,tempBulkRelease);
	if versionChecker.allChangedProperties.size &gt; 0 then
		if _changedProperties &lt;&gt; null then
			versionChecker.getAllChangedProperties(_changedProperties);
		endif;
		if app.isSpecial then
			versionChecker.writeChangedProperties();
		endif;
		return true;
	endif;
	
	return false;
epilog
	if versionChecker &lt;&gt; null then
		delete versionChecker;
		delete tempBookingRef;
	endif;
	//bulk release will be deleted by deleting booking ref
end;</source>
        <Parameter name="_changedProperties" type="PropertySet" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
