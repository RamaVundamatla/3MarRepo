    <JadeMethod name="setComboValues" id="65924b8e-645a-4102-a144-6078d9b9f42e">
        <source>setComboValues(comboBox 				: ComboBox input; 
			   queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder; 
			   queryOperator			: CM_QueryOperator; 
			   passport					: CM_Passport);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 22 August 2018
TFS#		: 40200
Function	: Populate comboBox List.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	destination				: CM_Terminal;
	terminal				: CM_Terminal;
	object					: Object;
	objectSet				: ObjectSet;
	selectStr				: String;
	terminalCriteriaLine	: CM_SelectorCriteriaLine;
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	storeIdx				: Integer;
	idx						: Integer;
	multiTerminal			: Boolean;
begin
	comboBox.clear();	
	
	if CM_QStringLookup.hasInstance(queryOperator) then
		selectStr := queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(queryOperator) then
		selectStr := queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;
	
	create objectSet transient;
	
	foreach selectorCriteriaLine in queryCriteriaLineHolder.allCriteriaByPropertyName do
		if selectorCriteriaLine.propName = "myTerminal" then
			terminalCriteriaLine := selectorCriteriaLine;
			break;
		endif;
	endforeach;	
	
	if terminalCriteriaLine &lt;&gt; null then
		terminalCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objectSet);
	else
		app.myRoot.allTerminals.copy(objectSet);
	endif;
	
	multiTerminal := (objectSet.size &gt; 1);
	
	foreach object in objectSet do
		terminal := object.CM_Terminal;
		
		foreach destination in terminal.allTerminalsForRelease do
			if multiTerminal then
				idx := comboBox.addItem(destination.code &amp; Tab &amp; ' (' &amp; destination.name.toUpper() &amp; ')' &amp; Tab &amp; "- " &amp; terminal.code);
			else
				idx := comboBox.addItem(destination.code &amp; Tab &amp; ' (' &amp; destination.name.toUpper() &amp; ')');
			endif;
			comboBox.itemObject[idx] := destination;
						
			if destination.code = selectStr then
				storeIdx := idx;
			endif;
			
		endforeach;
		
	endforeach;
	
	if storeIdx &gt; 0 and storeIdx &lt; comboBox.listCount then
		comboBox.listIndex := storeIdx;
	endif;
epilog
	delete objectSet;
end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="0a5b1022-46ce-46f1-a12e-64932b63affa">
        <source>setListValues(table						: Table input; 
			  queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder;
			  queryOperator				: CM_QueryOperator; 
			  passport					: CM_Passport);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 23 August 2018
TFS#		: 40200
Function	: Populate Selection List.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	destination				: CM_Terminal;
	terminal				: CM_Terminal;
	object					: Object;
	objectSet				: ObjectSet;
	selectionValue			: Integer;
	idx						: Integer;
	array					: ObjectArray;
	terminalCriteriaLine	: CM_SelectorCriteriaLine;
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	multiTerminal			: Boolean;
begin
	
	table.rows := table.fixedRows;
	table.sortColumn[1] := 2;
	table.sortAsc[1] := true;
	
	array := table.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	create objectSet transient;
	
	foreach selectorCriteriaLine in queryCriteriaLineHolder.allCriteriaByPropertyName do
		if selectorCriteriaLine.propName = "myTerminal" then
			terminalCriteriaLine := selectorCriteriaLine;
			break;
		endif;
	endforeach;	
	
	if terminalCriteriaLine &lt;&gt; null then
		terminalCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objectSet);
	else
		app.myRoot.allTerminals.copy(objectSet);
	endif;
	
	multiTerminal := (objectSet.size &gt; 1);
	
	foreach object in objectSet do
		terminal := object.CM_Terminal;
		
		foreach destination in terminal.allTerminalsForRelease do	
		
			selectionValue := 0;
			if queryOperator &lt;&gt; null and  queryOperator.CM_QStringIsOneOf.allSelectionValues.includes(destination.code) then
				selectionValue := 1;
				array.add(destination);
			endif;
			if multiTerminal then	
				idx := table.addItem(selectionValue.String &amp; Tab  &amp; destination.code &amp; Tab &amp; ' (' &amp; destination.name.toUpper() &amp; ')' &amp; "- " &amp; terminal.code);
			else
				idx := table.addItem(selectionValue.String &amp; Tab  &amp; destination.code &amp; Tab &amp; ' (' &amp; destination.name.toUpper() &amp; ')');
			endif;
			table.accessRow(idx).itemObject := destination;
		endforeach;
	endforeach;	
epilog
	delete objectSet;	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="66fc81b7-35cd-4e75-94e9-ed8cc5038bad">
        <source>setValuesFromList(table: Table input; queryOperator: CM_QueryOperator input);

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 22 August 2018
TFS#		: 40200

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	destination	: CM_Terminal;
	str			: String;
	numRows		: Integer;
	idx			: Integer;
	strArray	: StringArray;

begin

	create strArray transient;
	
	numRows := table.rows;
	foreach idx in (table.fixedRows + 1) to numRows do
		str := table.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			destination := table.accessRow(idx).itemObject.CM_Terminal;
			strArray.add(destination.code);
		endif;
	endforeach;
	
	queryOperator.setSearchValue(strArray);

epilog
	delete strArray;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryOperator" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="1b9587fc-5eb6-4907-9860-37591f35d820">
        <source>translateToDisplayValue(_value: Any): String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 22 August 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _value.isKindOf(CM_Terminal) then
		if _value &lt;&gt; null then
			return _value.CM_Terminal.code;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;
	
	return null;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="4b2d04fd-fcc0-4a36-9806-01e35eb4e2e9">
        <source>translateToSearchValue(value : Any) : Any;

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 22 August 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	invalidObj 	: Boolean;
	terminal	: CM_Terminal;
	returnVal	: String;
	
begin
	if value &lt;&gt; null then
		if value.isKindOf(Collection) then			
			return value;
		endif;

		if value.isKindOf(CM_Terminal) then
			terminal := value.CM_Terminal;
		endif;
	endif;
	
	if terminal &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, terminal, invalidObj);
		
		returnVal := terminal.code;
	endif;
	
	return returnVal;	
end;
</source>
        <Parameter name="value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="cdfb05d3-00d5-445a-bf70-63e093baa81e">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Poprtal selector query parameters
//
vars
	terminal : CM_Terminal;
	str, returnVal : String;
	strArray, coll : StringArray;

begin
	if _value.isKindOf(CM_Terminal) then
		terminal := _value.CM_Terminal;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			str := _value.String;
			create strArray transient;
			create coll transient;
			str.getTokensForDelimiter("|", strArray);
			foreach str in strArray do
				terminal := str.asOid.CM_Terminal;
				if terminal &lt;&gt; null then
					coll.add(terminal.code);
				endif;
			endforeach;
			return coll;
		endif;
		
		terminal := _value.String.asOid.CM_Terminal;
		if terminal = null then
			terminal := app.myRoot.allTerminals[_value.String];
		endif;
		
	elseif _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			terminal := app.myRoot.allTerminals[str];
			if terminal &lt;&gt; null then
				returnVal := returnVal &amp; terminal.getOidString &amp; CNEC_COMMA &amp; Space;
			endif;
		endforeach;
		returnVal := returnVal[1:returnVal.length-2];
		return returnVal;
		
	endif;
	
	if terminal &lt;&gt; null then
		if not _sending then
			return terminal.code;
		endif;
		return terminal.getOidString;
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
