    <JadeMethod name="setProxyFromObject" id="26832833-c46e-4226-a2d1-ed749284e783">
        <updating/>
        <source>setProxyFromObject(_hazard : CM_TIHazard) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2023	navpw1	Initial creation TFS: 56850 (56871)

*/

begin
	self.id						:= _hazard.code;
	self.acidBase				:= _hazard.acidsBases;
	self.flashpointTemperature	:= _hazard.flashpointTemperature;
	self.limitedQuantity		:= _hazard.limitedQuantity;
	self.marinePollutant		:= _hazard.isMarinePollutant;
	self.packingGroupId			:= _hazard.packingGroup;
	self.undgNumber				:= _hazard.undgCodes;
	
end;</source>
        <Parameter name="_hazard" type="CM_TIHazard"/>
    </JadeMethod>
</Class>
