    <JadeMethod name="logicallyDeleteMe" id="3164829f-bf14-497d-99a9-f65209b6aa4f">
        <updating/>
        <source>logicallyDeleteMe() updating;
// -------------------------------------------
// Created 07 March 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.myRoot := null;
	
	//20 Jul 2009	NDL	CCMS 1067
	if hookType = HookType_WagonClass then
		self.setLinkObject(null);
	endif;
	
	//10 Nov 2010	NDL	Par 25530
	if hookType = HookType_CalendarDay then
		self.setLinkObject(null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="6b91088e-3257-4f3e-8506-cb7bb50a1f45">
        <source>pxyCreateUpdateProxy(): SelfType;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	pxyLink	: CM_HookLink;
	completedOK		: Boolean;
	
begin

	pxyLink := inheritMethod();
	pxyLink.myRoot := self.myRoot;
	
	pxyLink.myLinkObject := self.myLinkObject;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyLink;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyLink;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="cb8e7ed3-b60b-4013-b629-9e23d1074dc7">
        <updating/>
        <source>setForCreate(_pxyLink : CM_HookLink; _realHookCode : CM_HookCode) updating;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.setForUpdate(_pxyLink);
	self.myHookCode := _realHookCode;
	self.myRoot := _pxyLink.myRoot;


end;</source>
        <Parameter name="_pxyLink" type="CM_HookLink"/>
        <Parameter name="_realHookCode" type="CM_HookCode"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="6f2b3bfc-e060-4d59-9475-b6cec36d1f17">
        <updating/>
        <source>setForProxy(_hookType : Integer; _linkObject: CM_Object; _hookCode : CM_HookCode) updating;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.hookType 		:= _hookType;
	self.myLinkObject	:= _linkObject;
	self.myHookCode		:= _hookCode;
	self.myRoot			:= _hookCode.myRoot;

end;</source>
        <Parameter name="_hookType" type="Integer"/>
        <Parameter name="_linkObject" type="CM_Object"/>
        <Parameter name="_hookCode" type="CM_HookCode"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7d60022b-37a1-4a12-9ca2-fd33b3816146">
        <updating/>
        <source>setForUpdate(_pxyLink : CM_HookLink) updating;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.hookType 		:= _pxyLink.hookType;
	self.myLinkObject	:= _pxyLink.myLinkObject;

end;</source>
        <Parameter name="_pxyLink" type="CM_HookLink"/>
    </JadeMethod>
    <JadeMethod name="setLinkObject" id="7b0443b3-75a2-408d-a5ab-d1be89b3ba6f">
        <updating/>
        <source>setLinkObject(_object : CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:     16 January 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myLinkObject := _object;
end;</source>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setMyHookCode" id="a8871dbc-5571-43c9-815e-32591935797b">
        <updating/>
        <source>setMyHookCode(_hookCode : CM_HookCode) updating;
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.myHookCode :=_hookCode;


end;</source>
        <Parameter name="_hookCode" type="CM_HookCode"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="252cf986-7117-4168-8181-15391552de05">
        <source>validateForCreate();
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.myRoot.allHookLinks[self.hookType, self.myLinkObject] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.myLinkObject.getDisplayDetails(false), null, null);
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="a4175d21-d4b0-4f29-a416-3a42d0640941">
        <source>validateForUpdate();
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

	realObjForProxy,
	realObjFound : CM_HookLink;
	

begin

	realObjFound	:= self.myRoot.allHookLinks[self.hookType, self.myLinkObject];
	realObjForProxy	:= self.pxyGetRealObject;
	if realObjFound &lt;&gt; null and realObjFound &lt;&gt; realObjForProxy then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.myLinkObject.getDisplayDetails(false), null, null);
	endif;

end;</source>
    </JadeMethod>
</Class>
