    <JadeMethod name="mnuWorkRemarks1_click" id="8f0457d4-b339-4634-97ec-055405cad467">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuWorkRemarks1_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	remarksFrm	: CMUI_Remarks;
	anObject : CM_Object;
begin

	// Update the navigator
	create remarksFrm;
	self.setNavigatorHeading(remarksFrm.caption); 
	remarksFrm.centreWindow;
	remarksFrm.myCurrentObject := self.myCurrentVoyage;
	remarksFrm.setMyTerminal(self.myTerminal);
	// cnwsb1 14 May 2003 - CM_BaseForm::showModal() now sets isModal:
	// remarksFrm.isModal := true;
	remarksFrm.showModal;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuWorkRemarks2_click" id="f874ce51-ad8e-4771-a620-e593004f60a1">
