<Class name="YRD_GridRow" id="f58341bb-cd1a-448a-a1ad-b946ccdd7c6d">
    <superclass name="CMUI_GridRow"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="Yard"/>
    <PrimAttribute name="maxHeight" id="aeb3cde2-482c-4264-a6bd-c5a5fc7de9c8">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="drawSelf" id="6a35b645-55ad-4e8c-8297-f0ca5b29e1ad">
        <updating/>
        <source>drawSelf(pFrame: CMUI_Frame) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	LeftTextMargin	: Integer = 5;

vars
	lX 		: Real;
	lY 		: Real;
	caption : String;
begin
	if self.label[1:1] &lt;&gt; "_" then
		caption := self.label;
	endif;
	lX := (pFrame.width / 2) - ((self.label.length * 7) / 2);
	lY := (self.y1 + ((self.y2 - self.y1) / 2)) - 10; // the 10 is half the height of the text in pixels
	pFrame.drawTextAt(caption, lX + 1, lY + 1, White);
	pFrame.drawTextAt(caption, lX, lY, Black);
end;</source>
        <Parameter name="pFrame" type="CMUI_Frame"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="9d6474bf-452c-454b-bf75-18a726ee9335">
        <updating/>
        <source>setForCreate(pGridRow : CM_GridRow; pGridArea : YRD_GridArea) updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.label		:= pGridRow.getLabel;
	self.row		:= pGridRow.row;
	self.maxHeight	:= pGridRow.myGridArea.heightOfStack;

	self.myGridArea	:= pGridArea;

end;</source>
        <Parameter name="pGridRow" type="CM_GridRow"/>
        <Parameter name="pGridArea" type="YRD_GridArea"/>
    </JadeMethod>
    <JadeMethod name="setForCreateArray" id="186f9a69-73d5-457a-a9f7-9517f34839f9">
        <updating/>
        <source>setForCreateArray(_array : StringArray; _theGridArea : YRD_GridArea) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.row		:= _array[2].Integer;
	self.label		:= _array[3];
	self.maxHeight	:= _array[4].Integer;

	self.myGridArea	:= _theGridArea;

end;</source>
        <Parameter name="_array" type="StringArray"/>
        <Parameter name="_theGridArea" type="YRD_GridArea"/>
    </JadeMethod>
    <JadeMethod name="setForCreateXML" id="51296850-73ca-4095-8d29-3572772b1f06">
        <updating/>
        <source>setForCreateXML(_theGridArea : YRD_GridArea; _label : String; _row : Integer; _maxHeight : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.label	:= _label;
	self.row		:= _row;
	self.maxHeight	:= _maxHeight;
	self.myGridArea	:= _theGridArea;

end;</source>
        <Parameter name="_theGridArea" type="YRD_GridArea"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_maxHeight" type="Integer"/>
    </JadeMethod>
</Class>
