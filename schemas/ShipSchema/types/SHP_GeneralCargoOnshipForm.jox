    <JadeMethod name="btnShowBOL_click" id="dd3e618d-0f49-403f-882a-d748de188c10">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnShowBOL_click(btn: Button input) updating;
// 23144 handle cargo linked to BOL but not BOL detail
// 30787 22 Nov 2012 	PJS		PAR #30887 - Voyage Rationalisation
vars

begin
	if self.isBOLDetailMode() then
		btn.bubbleHelp := app.getErrorString(Show_BOL);  //'Show BOL';
		btn.caption := app.getErrorString(Show_BOL);	//27 May 2016	NDL	TFS 2049
		lblBOL.caption  :=  app.getErrorString(Bills_lading_details);
	else
		btn.bubbleHelp := app.getErrorString(Show_BOL_details); 	//'Show BOL Details';
		btn.caption := app.getErrorString(Show_BOL_details);	//27 May 2016	NDL	TFS 2049
		lblBOL.caption  :=  app.getErrorString(Bills_lading);
	endif;
	self.initBOLTable(); //epr par 31274 12/3/13 col organiser didn't remember when switching type of table
	resetBOLFilters;	//30787
	displaySearchSelection; //30787
	hideSearch();
	self.showBOLsForVoyage();
	self.showCargoOnBoard();		// cnwmc5 - 16 April 2014 - CCMS 2352
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
