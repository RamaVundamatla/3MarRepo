    <JadeMethod name="navsh31" id="dc990e33-a31f-472f-9b60-78c67fe5c24f">
        <source>navsh31();
//Date		Who		Reason
//31 March 2021	navsh3	Initial creation


vars
	voyage 		: CM_Voyage;
	fileOut 	: File;
	fileFolder 	: FileFolder;
	file 		: File;
	folderName 	: String;
	voyageDetail: String;
begin
	create file transient;
	file.fileName := 'C:\temp\voyages.csv';
	file.open;
	foreach voyage in CM_Voyage.instances where voyage.displayOption &lt;&gt; 0 do
		voyageDetail :=  voyage.code &amp; ',' &amp; voyage.vesselName &amp; ',' &amp; voyage.departedDT.String;
		file.writeLine(voyageDetail);
		voyageDetail := "";
	endforeach;
	
	file.close;
epilog
	delete file;
end;
</source>
