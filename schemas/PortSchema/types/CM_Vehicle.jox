    <JadeMethod name="getAllWLE" id="e3207d2b-fd47-4a38-9d5e-87a4e8f9c4e1">
        <source>getAllWLE(wleSet : CM_WLEArray input);
//--------------------------------------------------------------
//Created: 22 February 2002 By: cnwgd1
// 14/06/2022 	navcs2 		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
// 06 Mar 2025  navma1 		MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
//--------------------------------------------------------------
vars
	job		: CM_Job;
	wle, relatedWle	: CM_WorkListEntry;
begin


	foreach job in self.allRoadJobs discreteLock do				//06.03.2025 navma1 #MTN-34179
		foreach wle in job.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
			//To get the order correct, skip the toDo we get it later
			if wle.isKindOf(CM_WOToDoWLE) then 					// navcs2 ChangeRequest 53038
				continue;
			endif;
			//Now get the related toDo
			relatedWle := wle.getRelatedWLE();
			if relatedWle &lt;&gt; null then
				wleSet.add(relatedWle);
			endif;
			wleSet.add(wle);					
		endforeach;
	endforeach;
end;</source>
        <Parameter name="wleSet" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEs" id="e262ab68-cd4c-4a7c-a5af-a6bf15ad757d">
        <source>getAllWLEs(_wleArray: CM_WLEArray input);
//--------------------------------------------------------------
//Created: 10 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	job	: CM_Job;
begin
	foreach job in self.allRoadJobs discreteLock do
		if (job.status = JOB_UNVERIFIED or job.status = JOB_TROUBLE) then
			continue;
		endif;
		job.workListEntries.copy(_wleArray);
	endforeach;
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEs_count" id="c212f3f5-faa1-4183-a51c-6b686580073c">
        <source>getAllWLEs_count(_rec, _rel :Integer io);
// ---------------------------------------------------------------------------
// Created:     13 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06 Mar 2025  navma1 		MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
// ---------------------------------------------------------------------------
vars
	job		: CM_Job;
	wle		: CM_WorkListEntry;
	badWLE,
	badJob	: Boolean;
	ed 		: Integer;
begin

	on Exception do app.handleDeletedObject(exception, job, badJob);  //cnwrd1 par 287916.12.2011
	on Exception do app.handleDeletedObject(exception, wle, badWLE); //cnwrd1 par 287916.12.2011
	
	foreach job in self.allRoadJobs discreteLock do		
	
		badJob := false;		
		
		if job.status = JOB_UNVERIFIED or 
			job.status = JOB_TROUBLE then
			continue;
		endif;

		if badJob then
			continue;
		endif;

		foreach wle in job.workListEntries discreteLock do 		//06.03.2025 navma1 #MTN-34179
			badWLE := false;
			
			if wle.isReceipt then
				if badWLE then		
					continue;
				endif;		
				_rec := _rec + 1;
			else
				if badWLE then		
					continue;
				endif;	
				_rel := _rel + 1;
			endif;			
			
		endforeach;
	endforeach;	
epilog

end;</source>
        <Parameter name="_rec" type="Integer" usage="io"/>
        <Parameter name="_rel" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getConsignee" id="5fefda95-ad55-4c9e-8b5b-0035c14edcb0">
        <source>getConsignee(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 August 2023	navpw1	Initial creation TFS: 58755 (59759)

*/

vars
	roadJobs		: CM_JobSet;
	allRequests		: CM_RequestSet;
	roadJob			: CM_RoadJob;
	request			: CM_Request;
	consignee		: CM_ConsigneeConsignor;
	consigneeSet	: CM_ConsigneeConsignorSet;
	returnStr		: String;
	
begin
	create consigneeSet transient;
	
	roadJobs := self.allRoadJobs;
	
	if roadJobs.isEmpty then
		return null;
	endif;
	
	foreach roadJob in roadJobs as CM_RoadJob do
		allRequests := roadJob.allRequests;
		
		if allRequests.isEmpty then
			continue;
		endif;
		
		foreach request in allRequests do
			consignee := request.getConsignee();
			
			if consigneeSet.includes(consignee) or consignee = null then
				continue;
			endif;
			
			consigneeSet.add(consignee);
			
		endforeach;
	endforeach;
	
	if consigneeSet.isEmpty then
		return null;
	endif;
	
	foreach consignee in consigneeSet do
		returnStr &amp;= consignee.description &amp; Comma;
		
	endforeach;
	
	return returnStr.stripTrailingChar(Comma);
	
epilog
	delete consigneeSet;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCurrentRoadJob" id="a9029f0d-914d-4a5d-b5c5-2fbf848f6027">
        <source>getCurrentRoadJob() : CM_RoadJob;
/*

Date		Who		Reason
21 September 2015	cnwer1	Initial creation PAR 36908

*/

vars
	vvr : CM_VehicleVisitRecord;
	roadJob : CM_RoadJob;
begin

	
	
	if roadJob = null then
		roadJob :=self.allRoadJobs.first.CM_RoadJob;
	endif;
	
	if roadJob = null then
		vvr := self.getCurrentVisit;
		if vvr &lt;&gt; null then
			roadJob:= vvr.myRoadJob;
		endif;
	endif;
	
	
	return roadJob;
end;</source>
        <ReturnType type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="getCurrentStageType" id="ae3812d0-2cce-4bc5-82f7-2c96599d20ca">
        <source>getCurrentStageType() : Integer;
/*
Purpose:			

Date		Who		Reason
01 March 2022	navab1	TFS 52914
*/

vars
	lc : CM_YardController;
	type : Integer;
begin

	lc := self.myPrimaryActualLocation;
	
	if lc = null then
		return null;
	endif;
	
	type := VisitRecord_Yard; // DEFAULT;
	
	if lc.isAGateLane then
		type := VisitRecord_Arrive_AGate;
		
	elseif lc.isPGateLane then
		if lc.CM_GateAreaLaneController.isIn then
			type := VisitRecord_Arrive_PGate_In;
		elseif lc.CM_GateAreaLaneController.isOut then
			type := VisitRecord_Arrive_PGate_Out;
		endif;	
		
	elseif lc.isTroubleLane then
		type := VisitRecord_Trouble;
	elseif lc.isInsideYard then
		type := VisitRecord_Yard;
	elseif CM_BlockController.hasInstance (lc) and lc.CM_BlockController.isInTransitTo then
		if lc.isYardInterchangeAreaLocation then
			type := VisitRecord_Yard;
		elseif lc.myTerminalArea &lt;&gt; null and lc.myTerminalArea.type = TA_TYPE_GATE_ROAD then
			type := VisitRecord_Arrive_AGate;
		
		endif;
	elseif CM_BlockController.hasInstance (lc) and lc.CM_BlockController.isInTransitFrom then
		if lc.isYardInterchangeAreaLocation then
			type := VisitRecord_Yard;
		endif;
	endif;
	
	
	return type;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCurrentVisit" id="fcbf9286-c926-4d86-af2c-efa827a8169f">
        <source>getCurrentVisit(): CM_VehicleVisitRecord;
//21 August 2009	cnwdw1	
//
vars
	roadJob : CM_RoadJob;
	vvr 	: CM_VehicleVisitRecord;
	term	: CM_Terminal;
begin

	term := app.myPassport.myTerminal;
	
	//19 Oct 2020	NDL	TFS 49189
	if term &lt;&gt; null and term.roadProcessIsASPA then
		return null;
	endif;

	//epr TFS 45705 24/7/19
	roadJob :=self.allRoadJobs.first.CM_RoadJob;
	if roadJob &lt;&gt; null then
		vvr := roadJob.myVehicleVisit;
	endif;
	
	if vvr &lt;&gt; null then
		return vvr;
	endif;
	
	return self.visitRecords.last;
	
end;</source>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="getCustomStatus" id="54faeed7-f3a4-4de5-a9aa-ad1ff10510cc">
        <source>getCustomStatus() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2023	navkc1	CR 60428 Task 60701: UI - Customs Status on Transport UI

*/

vars
	vvr		: CM_VehicleVisitRecord;
	ti		: CM_TrackedItem;
	messStr,
	str		: String;
begin
	
	foreach vvr in self.visitRecords discreteLock do
		str := vvr.getCustomStatus();
		
		if str = null then
			continue;
		endif;
		
		/*
		if messStr = null then
			messStr := str;
		elseif messStr.pos(str, 1) = 0 then
			messStr := messStr &amp; "," &amp; str;
		endif;
		*/
		
		messStr.addStringToList(str, ",");//04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	
	return messStr;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="5ef5da18-3666-4d16-bdab-65263b373979">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	
begin

	if _short then
		if self.state = null then
			return self.regNumber.String;
		else
			return self.regNumber.String &amp; ' (' &amp; self.state.String &amp; ')';
		endif;
	else
		if self.state = null then		
			return '('&amp;self.regNumber.String&amp;')  '&amp;self.carrierCode;
		else
			return '('&amp; self.regNumber.String &amp; ' (' &amp; self.state.String &amp; ')' &amp; ')  '&amp;self.carrierCode;
		endif;
	endif;

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="7fdbe221-c481-4ec2-94b4-f47fc9c225fd">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		06 2006 By Yi Liu cnwyl1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/02/2010	cnwcs5		par 22619 - visit number
// 01/04/2010	cnwcs5		par 22139 - display lane number for interchange areas
// 24/06/2014	cnwdap1		PAR #34313 Allow for Move Amount and return null
// 10/03/2022	navak20		TFS #53013 - Column Organiser - Booking 
// 18/03/2022	navtnr20	TFS #53014 - MTN - Truck Visit Display
// 29/06/2022	navdap1		TFS 53987 MTN Road Operations - Invalid Property
// 29/06/2022	navdap1		TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
// 21/02/2022   navma1		ChangeRequest 56414[56415]: FR | 53401 - Sub Carrier in Cargo enquiry and selector queries
// 07/03/2023	navdap1		TFS 57001 FR | 53667 - EUP - Inspection App checks - New Fields in Column Organiser
// 27/09/2023	navkc1		CR 60428 Task 60701: UI - Customs Status on Transport UI
// 13/06/2025   navsp1      JIRA-35019 FR 34962.012 Discharge Port field in Road Operations Screen
// 06 Aug 2025	navbs1		Story MTN-35549: TPT | Source Location for RT Moves on the Road Ops Screen - Dev
// 13 Aug 2025	naviv1		MTN-35708 : Invalid Property Value exception if the Release Number column is selected on the Gate Lanes In table
// ---------------------------------------------------------------------------

vars
	area	 : CM_TerminalArea;
	type 	 : String;					
	str		 : String;					
	vvr 	 : CM_VehicleVisitRecord;
	iCarrier : CM_Carrier;
	subCarr  : CM_Carrier;
	root	 : CM_Root;
	lc       : CM_LocationsController;
	roadJob : CM_RoadJob;
begin

	if  _attrName = ETRow_BatNumber then
		return self.batNumber;
	elseif _attrName = ETRow_Carrier or	_attrName = ETRow_CarrierId then
		//TFS#53362 navsp1 20Jun2022
		root := app.myRoot;
		if root.getConfig(CarrierCmbOrdDescr).Boolean then  
			iCarrier := root.allCarriers[self.carrierCode];
			if iCarrier &lt;&gt; null then
				return iCarrier.description;
			endif;
		endif;
		return self.carrierCode;
	
	elseif _attrName = ETRow_IsNotAvailableForEntry then
		return self.isNotAvailableForEntry.String;

	elseif _attrName = ETRow_RegNumber then
		if self.state = null then
			return self.regNumber;
		else
			return self.regNumber &amp; ' (' &amp; self.state &amp; ')';
		endif;
	elseif _attrName = ETRow_ReleaseNumber then		//13-Aug-2025 naviv1 MTN-35708
		roadJob := self.getCurrentRoadJob();
		if roadJob &lt;&gt; null then
			return roadJob.getDisplayStringForAttribute(_attrName,false);
		endif;
		return null;
	elseif _attrName = ETRow_State then
		return self.state;
	elseif _attrName = ETRow_TareWeight then
		return self.tareKilos.String; 
	elseif _attrName = ETRow_TareKilos then
		return self.tareKilos.String; 
	elseif _attrName = ETRow_GateLane then
		lc := self.myPrimaryActualLocation;
		
		if lc &lt;&gt; null and lc.isKindOf (CM_LaneController) then				// 01/04/2010 cnwcs5 par 22139
			if lc.CM_LaneController.isDefaultLane then						// 01/04/2010 cnwcs5 par 22139
				return null;
			else
				return lc.CM_LaneController.getLaneNumber.String;			// 01/04/2010 cnwcs5 par 22139
			endif;
		endif;
		return null;

	elseif _attrName = ETRow_ElapsedTime then
		vvr := self.visitRecords.last;
		if vvr &lt;&gt; null then
			return vvr.getElapsedTime.asStringJMT();						// PAR 16390
		endif;
		return null;
		
	elseif _attrName = ETRow_ElapsedTimeArea then
		vvr := self.visitRecords.last;
		if vvr &lt;&gt; null then
			return vvr.getElapsedMinsCurrentStage.String;
		endif;
		return null;
		

	elseif _attrName = ETRow_Terminal then
		return null;
	elseif _attrName = ETRow_TerminalAreaOid then
		// ccms 1016 - new road ops form groups by terminal area
		area := self.getTerminalAreaForCurrentLocn;
		if area &lt;&gt; null then
			return area.getOidStringForObject (area);
		endif;
		return app.getErrorString (Unknown);
		
	elseif _attrName = ETRow_TransactionNum or
			_attrName = ETRow_GateInCheckStatus or _attrName = ETRow_GateInCheckTS or 		// TFS 57001
			_attrName = ETRow_GateOutCheckStatus or _attrName = ETRow_GateOutCheckTS then	// TFS 57001
		vvr := self.visitRecords.last;
		if vvr &lt;&gt; null then							
			return self.visitRecords.last.getDisplayStringForAttribute (_attrName, _short);	
		endif;			
		return null;
		
	elseif _attrName = ETRow_NumberOfVisits then	//01 Nov 2017	NDL	TFS 7216
		return self.visitRecords.size.String;
		
	elseif _attrName = ETRow_LatestVisitDate then	//01 Nov 2017	NDL	TFS 7216
		vvr := self.visitRecords.last;
		if vvr &lt;&gt; null then
			return vvr.createdTime.Date.asStringJMT;
		endif;
		return null;
		
	
	elseif _attrName = ETRow_Stevedore then   //02.10.2020 cnwma1 TFS #50112
		
		vvr := self.visitRecords.last ;
		if vvr &lt;&gt; null and  vvr.myStevedore &lt;&gt; null then
			if app.myRoot.getConfig(ComboByNameStevedore).Boolean then	// TFS 53362
				return vvr.myStevedore.description;						// TFS 53362
			endif;														// TFS 53362
			return vvr.myStevedore.code;
		endif;
		return null;
		
	elseif _attrName = ETRow_SubCarrierCodeDesc then						// TFS 53987	// 21.02.2022 navma2 #56414[56415]
		vvr := self.visitRecords.last;
		lc  := self.myPrimaryActualLocation;
		if vvr &lt;&gt; null then
			subCarr:= vvr.getSubCarrier();									// TFS 53987
		endif;
		
		if subCarr &lt;&gt; null and lc &lt;&gt; null and lc.isKindOf(CM_GateAreaLaneController) then
		  return subCarr.code &amp; Hyphen &amp; subCarr.description;
		endif;
		
		return null;
		
	elseif _attrName = ETRow_Booking 	   or 			 //TFS 53013
		   _attrName = ETRow_Mark		   or            //TFS 45590
		   _attrName = ETRow_MarkNumber    or 			 //TFS 45590
		   _attrName = ETRow_Colour	 	   or 			 //TFS 45590
		   _attrName = ETRow_IsoType	   or
		   _attrName = ETRow_MyOperator    or 
		   _attrName = ETRow_VoyageCode    or 
		   _attrName = ETRow_IsHazardous   or 
		   _attrName = ETRow_Id			   or 
		   _attrName = ETRow_TotalQuantity or
		   _attrName = ETRow_Commodity     or
		   _attrName = ETRow_LocationId    or
		   _attrName = ETRow_QueuedLocnId  or
		   _attrName = ETRow_PlannedLocnId or
		   _attrName = ETRow_MachineId     or
		   _attrName = ETRow_ImexStatus    or
		   _attrName = ETRow_CargoTypeDescr or
		   _attrName = ETRow_MoveAmount     or
		   _attrName = ETRow_CargoSubType   or			//TFS 53014
           _attrName = ETRow_DischargePort then         //JIRA-35019
		return null;									//TFS 53013
	// ### TFS 58755 (59759) 28Aug2023 NAVPW1
	elseif _attrName = ETRow_Consignee then
		return self.getConsignee();
	// ### TFS 58755 (59759) 28Aug2023 NAVPW1
	
	elseif _attrName = ETRow_CustomStatus then
		return self.getCustomStatus(); //27/09/2023	navkc1	CR 60428 Task 60701
	elseif _attrName.isMeasurementType then											
		_attrName.getRowNameMeasureType(str, type);									
		return self.getMeasurementStringForAttrib(str, type, _short);
	
	elseif _attrName = ETRow_SourceLocQueued then 									//06.08.2025 navbs1 #35549
		return getQueuedLocFromReq();
	else
		
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="cf15e0bc-5c42-4dbc-b9a5-bfb214fe6c3c">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;

vars
	block : CM_DataContainerBlock;

	jobId,
	releaseNum	: String;
	job		: CM_Job;
	req		: CM_Request;
	ti		: CM_TrackedItem;
begin

	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Vehicle_ID), DC_Label, 1, self);
	block.addNewItem(self.regNumber, DC_Data, 1, self);

	if self.carrier &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Carrier), DC_Label, 1, self.carrier);
		block.addNewItem(self.carrier.description, DC_Data, 1, self.carrier);
	endif;

	if self.batNumber &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Bat_Number), DC_Label, 1, self);
		block.addNewItem(self.batNumber, DC_Data, 1, self);
	endif;
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Number_Of_Jobs), DC_Label, 1, self);
	block.addNewItem(self.allRoadJobs.size.String, DC_Data, 1, self);
	
	foreach job in self.allRoadJobs do
	//	if job.CM_RoadJob.isRelease then
			job.getExtraInfo(_dataContainer);
	//	endif;
	endforeach;

	if app.isDevelopmentSystem or app.isSpecial then
		if self.myPrimaryActualLocation &lt;&gt; null then
			block.addNewItem(app.getErrorString(CM_Location),DC_Label,1,self);
			block.addNewItem(self.myPrimaryActualLocation.getID,DC_Data,1,self);
		endif;
	endif;

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getGateIn" id="e0646a53-78b3-4d23-a861-18c0876ee092">
        <source>getGateIn(): CM_Gate;
//21 August 2009	cnwdw1	
//
vars
	vvr	: CM_VehicleVisitRecord;
begin
	vvr := self.getCurrentVisit();
	if vvr &lt;&gt; null then
		return vvr.myGateIn;
	endif;
	
	return null;
	
end;</source>
        <ReturnType type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="getInTransitFromYardLocation" id="caa96f60-2e43-42cb-baf3-f7149a57fe3e">
        <source>getInTransitFromYardLocation():CM_YardController;
// ---------------------------------------------------------------------------
// Created:     17 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     The default location for vehicle leaving the yard
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc		:CM_YardController;
	icArea	:CM_InterchangeArea;
	job		:CM_RoadJob;
	gate	:CM_Gate;
begin
	// first try the in transit from location for the interchange areas
	// associated with the current vehcile location
	lc 		:= self.myPrimaryActualLocation;
	icArea	:= lc.myAssociatedInterchangeArea;
	
	if icArea &lt;&gt; null then	
		return icArea.myInTransitFromLocation;
	endif;
	
	// next try the in transit out location for the default interchange area for
	// the default out gate for the terminal
	gate	:= self.myTerminal.getDefaultGate_OUT;
	icArea 	:= gate.myDefaultInterchangeArea;
	
	if icArea &lt;&gt; null then	
		return icArea.myInTransitFromLocation;
	endif;
	
	// next try the default interchange area for the gate through which the vehicle 
	// entered the terminal
	job		:= self.allRoadJobs.first.CM_RoadJob;
	
	if job = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "No Road Job For Vehicle");
	endif;
	
	gate 	:= job.getGateIn;
	
	if gate = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "No Gate for Road Job");
	endif;
	
	icArea := gate.myDefaultInterchangeArea;
	
	if icArea &lt;&gt; null then
		return icArea.myInTransitFromLocation;
	endif;
	
	app.raiseUnexpectedProgramError (self.class.name, method.name, "Unable to find in transit from location for vehicle");
epilog

end;</source>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="getInTransitToYardLocation" id="44fca652-e70f-492e-95d2-874caf242c2e">
        <source>getInTransitToYardLocation():CM_YardController;
// ---------------------------------------------------------------------------
// Created:     17 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     The location to move the vehicle to when goiing into the yard
//				Despite the name of this method it could be an in-transit-to location
//				or it could be a lane.  The terminal area will be an Interchange Area
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/06/2010 	cnwcs5		par 24418 - removed code relating to pre 7.7.3 jobs
// ---------------------------------------------------------------------------
vars
	job		:CM_RoadJob;
	gate	:CM_Gate;
	lc		:CM_YardController;
begin
	job		:= self.allRoadJobs.first.CM_RoadJob;
	gate	:= job.getGateIn;
	//jlier1 58617 19/6/23
	if gate = null then
		gate :=job.myGate;
	endif;
	if gate &lt;&gt; null then
		lc := gate.getDefaultYardLocation_IN (self);

		if lc &lt;&gt; null then
			return lc;	// should have value
		endif;
	endif;
	
	app.raiseUnexpectedProgramError (self.class.name, method.name, "No Gate for Road Job");	
epilog

end;</source>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="getInterTerminalJob" id="b78a9e9e-2b81-4bbf-b161-7434a256163a">
