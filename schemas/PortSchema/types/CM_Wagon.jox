    <JadeMethod name="isInTransit" id="ddbf9d52-ca72-4700-a2eb-177ac7a98725">
        <source>isInTransit() : Boolean;
// ---------------------------------------------------------------------------
// Created:     27 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
begin
	create tiArray transient;
	self.getAllTrackedItems(true, tiArray, false);
	
	foreach ti in tiArray discreteLock do
		if ti.isInTransitOnShip then
		//if ti.getImExStatus() = TI_IMEX_STATUS_TRANSIT then
			return true;
		endif;
	endforeach;
	
	return false;
epilog
	delete tiArray;

end;</source>
