        <source>auditClass(): Class typeMethod;
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
vars

begin
	return CM_CustomDocumentDetail;

epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="auditId" id="bbd73f40-6324-4d53-8a30-fe039541d1a3">
        <source>auditId(): String;
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
vars
	header : CM_CustomDocument;
begin
	header := self.getCustomDocumentHeader();// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
	
	if header = null then  // ### TFS CR 60052 TASK 60053 25AUG2023 NAVAB1
		return "Detail";
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		return header.code &amp; "/" &amp; self.myTrackedItem.id;
	else
		return header.code &amp; "/ Detail";
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
