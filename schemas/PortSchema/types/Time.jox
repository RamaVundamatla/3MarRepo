    <JadeMethod name="truncateTo10Millisecs" id="c451673a-5d40-42d5-b644-18438f47fb8f">
        <source>truncateTo10Millisecs(): Time;
// ---------------------------------------------------------------------------
// Created:     09 dec 2009 cnwrs1 par21887
// ---------------------------------------------------------------------------
vars
	timeToMinute : Time;

begin
	timeToMinute.setTime(self.hour, self.minute, self.second, ((self.milliSecond/10).Integer*10).Integer);
	return timeToMinute;
end;
</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="truncateToMinute" id="35f0d4b2-d2c9-47aa-98dd-c2ed95a61d02">
        <source>truncateToMinute() : Time;
// ---------------------------------------------------------------------------
// Created:     14 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	timeToMinute : Time;

begin
	timeToMinute.setTime(self.hour, self.minute, 0, 0);
	return timeToMinute;
end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="truncateToSecond" id="57d51860-1ed5-4605-a1d6-9211e751d91d">
        <source>truncateToSecond(): Time;
// ---------------------------------------------------------------------------
// 
// ---------------------------------------------------------------------------
vars
	timeToSecond : Time;

begin
	timeToSecond.setTime(self.hour, self.minute, self.second, 0);
	return timeToSecond;
end;
</source>
        <ReturnType type="Time"/>
