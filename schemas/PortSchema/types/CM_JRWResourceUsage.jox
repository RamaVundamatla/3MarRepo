    <JadeMethod name="getEndDateLocalTZ" id="ff95ce32-faac-4b37-a472-67d614336668">
        <source>getEndDateLocalTZ(): Date;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
03 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars
	ts: TimeStamp;
begin
	ts.setDate(self.endDate);
	ts.setTime(TimeEndOfDay);
	return self.systemToLocalTime(ts).Date;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getStartDateLocalTZ" id="f816515c-281e-4131-8ffa-8296854db69d">
        <source>getStartDateLocalTZ(): Date;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
03 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars
	ts: TimeStamp;
begin
	ts.setDate(self.startDate);
	ts.setTime(TimeStartOfDay);
	return self.systemToLocalTime(ts).Date;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getTaskList" id="cb483e92-8f98-438d-b436-b47f471b7e68">
        <source>getTaskList():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 October 2010	cnwndl1	Initial creation	Par 23800

*/

vars
	toDoTaskDesc : CM_ToDoTaskDesc;
	str : String;
begin

	if not self.allToDoTaskDescs.isEmpty then
		foreach toDoTaskDesc in self.allToDoTaskDescs do
			if str = null then
				str := toDoTaskDesc.description;
			else
				str := str &amp; ", " &amp; toDoTaskDesc.description;
			endif;
		endforeach;
		return str;
	endif;

	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="ddaa94a8-ddad-4d35-b379-b299ee1630b7">
        <source>noOutputReturned(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

begin
	if self.allResourceUsages.isEmpty() then
		return true;
	endif;
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setResourceTypeUsageSumSet" id="11881dcd-c295-47eb-a8d4-8f742919da1c">
        <source>setResourceTypeUsageSumSet();

/*

Purpose:
			
		Builds the summary information for the report writer report
		CM_CompletedTrxResourcesSum...
		that effectively runs as teh final page of the 
		CM_CompletedTrxResources report.
		
Parameters:			

Return Value:		


Date		Who		Reason
19 October 2010	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	resourceUsage : CM_ResourceTypeUsage;
	resType : CM_ResourceType;
	resTypeArray : CM_ObjectArray;
	decimalArray : DecimalArray;
	pos : Integer;
	quantity : Decimal[12,4];
	
begin

	if not self.allResourceUsageSums.isEmpty then
		self.allResourceUsageSums.purge;
	endif;
	
	if allResourceUsages.isEmpty then
		return;
	endif;

	create resTypeArray transient;
	create decimalArray transient;
	iter := allResourceUsages.createIterator;
	
	while iter.next( resourceUsage ) do
		resType := resourceUsage.myResourceType;
		if resType = null then
			continue;
		endif;
		pos := resTypeArray.indexOf(resType);
		if pos &lt; 1 then
			resTypeArray.add(resType);
			pos := resTypeArray.size;
			decimalArray[pos] := resourceUsage.quantity;
		else
			decimalArray[pos] := decimalArray[pos] + resourceUsage.quantity;
		endif;
	endwhile;
	
	foreach pos in 1 to resTypeArray.size do
		resType := resTypeArray[pos].CM_ResourceType;
		quantity := decimalArray[pos];
		create resourceUsage transient;
		allResourceUsageSums.add(resourceUsage);
		resourceUsage.setProxy(	resType,	//_resourceType : CM_ResourceType;
								null,	//_transaction : CM_TITransaction;
								true,	//_noCharge : Boolean;
								quantity,	//_quantity : Decimal;
								null,	//_remarks : String;
								1,	//_status : Integer
								null,		//cnwmc5 - 22 Sep 2015 - PAR 36920
								null,		//cnwmc5 - 22 Sep 2015 - PAR 36920
								null,
								null,
								null
								);
	endforeach;

epilog

	delete iter;
	delete resTypeArray;
	delete decimalArray;

end;</source>
    </JadeMethod>
</Class>
