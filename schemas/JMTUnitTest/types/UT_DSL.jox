    <JadeMethod name="addCamProtocol" id="1de7b291-d5dd-40fe-8690-b2dd0347a6e7">
        <source>addCamProtocol(_code,
			_description : String;
			_allCoarriExportPorts : CM_PortByCodeDict;
			_camGroup : CM_CamGroup;
			_camISOPortDesc : String;
			_emailAddress : CM_EmailEntity;
			_emailCopy : Boolean;
			_emailCopyAddresses : CM_EmailEntityByTypeNameDict;
			_emailFileImbedded : Boolean;
			_emailMessage,
			_emailSubject : String;
			_firstRunDateTime,
			_lastRunDateTime : TimeStamp;
			_specialFileName: Boolean;
			_filePrefix, _fileSuffix : String;
			_operatorXlationCode : String;
			_packOperators : CM_OperatorByCodeDict;
			_packExportConsignees : CM_ConsignByCodeDict;
			_packConsignor : String;
			_protocolDesc : CM_CamProtocolDesc;
			_registeredTransactions : StringArray;
			_sendMtFiles : Boolean;
			_sendType : Integer;
			_useVoyageOp: Boolean;
			_scheduleTimes : TimeArray;
			_x12UseClientRefAsBooking,
			_spare1,
			_gateInForNullVoyageChange,
			_gateInForNullOperatorChange : Boolean;
			_spare2,
			_spare3,
			_special_MSCForNZPOE,
			_daysToLookBack : Boolean;
			_tempLeadingZerosNoDecimal,
			_supressSealNumbers,
			_singleContainerPerBGM,
			_singleTransactionPerFile : Boolean;
			_reprocessOnIdChange,
			_sendCancellationMsg,
			_sendUpdateMsg,
			_debug : Boolean;
			_useContainerOperator_NAD_CF,
			_sendCarrier_RFF_CN,
			_useCarrierForBooking : Boolean;
			_isIncludeChild : Boolean;
			_isEmailEnabled,
			_isSingleTransPerFile,
			_isFileTransferEnabled,
			_anyEditTriggerField : Boolean;
			_outputFileRollOver,
			_outputFileSeqLength,
			_outputFileStartSeq,
			_lastSequenceNumberUsed : Integer;
			_outputFileFormat,
			_destinationFilePath,
			_jRWReportName : String;
			_camEditTriggerFields : CM_CamEditTriggerFieldDict;
			_camTrainEventTypes : CM_EventTypeByNameDict;
			_qFCamTransaction : CMQF_CamTransactionTemplate;
			_noCrLf : Boolean;
			_status : Integer;
			_terminal : CM_Terminal;
			_terminalActivity,
			_depotActivity,
			_useSubTerminals : Boolean;
			_packGateInFull,
			_packGateOutMT,
			_unpackGateInMT,
			_unpackGateOutFull,
			_prcNullVoyageTransaction,
			_useTiOperator : Boolean;
			_allPackAreas : CM_TAByIdDict;
			_myConsignee : CM_ConsigneeConsignor;
			_myFTPEntity : CM_FTPEntity;
			_registeredCargoTypes : IntegerArray) : CM_CamProtocol;
/* Changes

Date		Name	TFS#		Description
============================================================================
15 May 2014	cnwrs1	Par 34159 	include Chassis in Codeco
20 Sep 2017	jlgrs1	TFS 6957 	Codeco/Coarri VGM extra details
12 Mar 2018 jlgka1	TFS 41641	Add Relaxed Id Checking.
24 Apr 2019 jlgka1	TFS 43785	Add useCodecoForNonStrucVoy field.
05 Map 2023	navmd1	TFS 57678	Added External Web Service Def support
============================================================================*/
vars
	proxyCamProtocol : CM_CamProtocol;
	realCamProtocol  : CM_CamProtocol;
	noCrLf 			 : Boolean;
	delayMinutes 	 : Integer;	//08 Sep 2015	NDL	)ar 36876
	changeCOARRIBGM  : Boolean;
	changeCOARRIBGM4446 : Boolean; //27Jan2023 navsp1 TFS 56282
	changeVermasNAD  : Boolean;
	includeExtraVGM  : Boolean;
	includeRFFBM162 : Boolean;	//26 Jan 2021	NDL	TFS 50708
	extWebDef		: CM_APIEndpointServiceDef;
begin

	delayMinutes := 0;
	if self.opts.includesKey("DelayMins") then
		delayMinutes := self.opts.int("DelayMins");
	endif;
	
	//cnwmc5 - 11 Feb 2016 - PAR 37503
	changeCOARRIBGM := false;
	if self.opts.includesKey(CM_CamProtocol::changeCOARRIBGM.name) then
		changeCOARRIBGM := self.opts.bool(CM_CamProtocol::changeCOARRIBGM.name);
	endif;
	
	//27Jan2023 navsp1 TFS 56282
	changeCOARRIBGM4446 := false;
	if self.opts.includesKey(CM_CamProtocol::changeCOARRIBGM4446.name) then
		changeCOARRIBGM4446 := self.opts.bool(CM_CamProtocol::changeCOARRIBGM4446.name);
	endif;
	
	includeExtraVGM := false;
	if self.opts.includesKey(CM_CamProtocol::setIncludeExtraVGM.name) then
		includeExtraVGM := self.opts.bool(CM_CamProtocol::setIncludeExtraVGM.name);
	endif;
	
	//26 Jan 2021	NDL	TFS 50708
	if self.opts.includesKey('includeRFFBM162') then
		includeRFFBM162 :=  self.opts.bool('includeRFFBM162');
	endif;
	
	extWebDef := self.opts.obj(CM_CamProtocol::myExternalWebServiceDef.name).CM_APIEndpointServiceDef;

	noCrLf := _noCrLf;
//	noCrLf := false;
	create proxyCamProtocol transient;
	proxyCamProtocol.setProxy(	_code,
								_description,
								_allCoarriExportPorts,
								_camGroup,
								_camISOPortDesc,
								_emailAddress,
								_emailCopy,
								_emailCopyAddresses,
								_emailFileImbedded,
								_emailMessage,
								_emailSubject,
								_firstRunDateTime,
								_lastRunDateTime,
								_specialFileName,
								_filePrefix,
								_fileSuffix,
								_operatorXlationCode,
								_packOperators,
								_packExportConsignees,
								_packConsignor,
								_protocolDesc,
								_registeredTransactions,
								//lRegisteredTransactionClasses,
								_sendMtFiles,
								_sendType,
								_useVoyageOp,
								_scheduleTimes,
								_x12UseClientRefAsBooking,
								_spare1,
								_gateInForNullVoyageChange,
								_gateInForNullOperatorChange,
								_spare2,
								_spare3,
								_special_MSCForNZPOE,
								_daysToLookBack,
								_tempLeadingZerosNoDecimal,
								_supressSealNumbers,
								_singleContainerPerBGM,
								_singleTransactionPerFile,
								_reprocessOnIdChange,
								_sendCancellationMsg,
								_sendUpdateMsg,
								_debug,
								_useContainerOperator_NAD_CF,
								_sendCarrier_RFF_CN,
								_useCarrierForBooking,
								_isIncludeChild,
								_isEmailEnabled,
								_isSingleTransPerFile,
								_isFileTransferEnabled,
								_anyEditTriggerField,
								_outputFileRollOver,
								_outputFileSeqLength,
								_outputFileStartSeq,
								_lastSequenceNumberUsed,	 // ccms 1011
								_outputFileFormat,
								_destinationFilePath,
								_jRWReportName,
								_camEditTriggerFields,
								_camTrainEventTypes,	// PAR 21905 CCMS MES 1008 - PHB
								_qFCamTransaction,
								noCrLf,
								_status,
								self.getTerminal,
								_terminalActivity,
								_depotActivity,
								_useSubTerminals,
								_packGateInFull,
								_packGateOutMT,
								_unpackGateInMT,
								_unpackGateOutFull,
								_prcNullVoyageTransaction,
								_useTiOperator,
								_allPackAreas,
								_myConsignee,
								_myFTPEntity,
								null, null, null, null, null,	// CCMS 1143 cnwrs1 10 Aug 2010
								_registeredCargoTypes,
								null,
								delayMinutes,
								changeCOARRIBGM	,		//cnwmc5 - 11 Feb 2016 - PAR 37503
								changeCOARRIBGM4446,	//27Jan2023 navsp1 TFS 56282
								null,
								null,					// jlgka1 TFS 41641 - relaxed id checking
								null,					// jlgka1 TFS 43785
								null					//JIRA-20814
								);
	proxyCamProtocol.setLogExcludedTransactions(true);
	proxyCamProtocol.setLogIncludedTransactions(true);
	proxyCamProtocol.setIncludeRFFBM162( includeRFFBM162 );	//26 Jan 2021	NDL	TFS 50708
	proxyCamProtocol.setMyWebServiceDef(extWebDef);
	app.myTrxCA.trxCreateCamProtocol(proxyCamProtocol, realCamProtocol, app.myPassport);
	self.assertTrueMsg( realCamProtocol &lt;&gt; null, "Failed to create Cam Protocol " &amp; _code &amp; " - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	beginTransaction;
	realCamProtocol.setIncludeExtraVGM(includeExtraVGM);
	commitTransaction;
	return realCamProtocol;
epilog
	delete proxyCamProtocol;
end;
</source>
