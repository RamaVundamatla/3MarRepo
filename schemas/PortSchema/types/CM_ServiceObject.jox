    <JadeMethod name="validateForUpdate" id="5134e97e-5eb7-4da6-9cff-cbc050173e1b">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/12/2014   cnwdb2	PAR #35364

vars
	realMe : SelfType;
	taxChanged : Boolean;
begin
	realMe := self.pxyGetRealObject();
	if realMe &lt;&gt; null then
		// ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1
		taxChanged := self.myTaxCode &lt;&gt; realMe.myTaxCode; // ### TFS CR 62992 TASK 62994 02APR2024 NAVAB1
		if taxChanged then
			app.raiseCMWarning1(Chang_code_will_only_effec_inv,self.name,"",null,null);
		endif;
		
		
		if realMe.name &lt;&gt; self.name then
			if self.genLCode &lt;&gt; null then
				if self.genLCode.services[self.name] &lt;&gt; null then
				//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Service",self.name,"GL Code " &amp; self.genLCode.code &amp; " Already used this service",null,null);
					app.raiseCMException2(Already_exists_service_glCode,self.name,self.genLCode.code,null,null); //cnwdb2	PAR 35364
				endif;
			endif;
			self.validateDuplicates();
		endif;
	endif;
end;</source>
    </JadeMethod>
</Class>
