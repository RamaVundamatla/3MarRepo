    <JadeMethod name="tInvoiceLineQuery" id="eb9a7202-cd78-4845-9093-a625fc5b60a1">
        <source>tInvoiceLineQuery();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

	qDef : CM_QueryDefinition;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	myEnqController : CM_EnqControllerInvoiceLine;
	invoiceLine : CM_InvoiceLine;
	aBank : CM_Bank;
	bank : CM_Bank;
	

begin

	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Invoicing_Query_Type,CM_QueryDefinition.InvoiceLine_Query_Mode];
	
	//create the selector query object.
	create myEnqController;
	create myEnqController.allObjects as  CM_InvoiceLineBySeqNumDict transient;
	create criteriaHolder transient;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	// Add some basic criteria
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_InvoiceLine::getTerminal.name, CM_QReferenceLookup.Operator_Equal, self.getTerminal);
	
	foreach aBank in self.getTerminal.companies do
		if not aBank.invoiceLines.isEmpty then
			bank := aBank;
			break;
		endif;
	endforeach;
	self.assertTrueMsg( bank &lt;&gt; null, "No bank found! pre-test" );
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_InvoiceLine::bank.name, CM_QReferenceLookup.Operator_Equal, bank);

	
	// call the query
	myEnqController.doQuery( qDef );
	
	//check we found some.
	self.assertTrueMsg( not myEnqController.allObjects.CM_InvoiceLineBySeqNumDict.isEmpty, "Did not find any InvoiceLines. Possible error.");
	
	//check each of the ones we got is correct
	foreach invoiceLine in myEnqController.allObjects.CM_InvoiceLineBySeqNumDict do
		if invoiceLine.getTerminal &lt;&gt; self.getTerminal then
			self.assertTrueMsg( false, "InvoiceLine " &amp; invoiceLine.sequenceNum.String &amp;  " terminal not " &amp; self.getTerminal.code );
		endif;
		if invoiceLine.bank &lt;&gt; bank then
			self.assertTrueMsg( false, "InvoiceLine " &amp; invoiceLine.sequenceNum.String &amp;  " bank not " &amp; bank.code.String );
		endif;
	endforeach;
	
	//check we got all we should have.
	foreach invoiceLine in bank.invoiceLines do
		if invoiceLine.bank &lt;&gt; bank then
			continue;
		endif;
		if invoiceLine.getTerminal &lt;&gt; self.getTerminal then
			continue;
		endif;
		if not myEnqController.allObjects.CM_InvoiceLineBySeqNumDict.includes( invoiceLine ) then
			self.assertTrueMsg( false, "Invoice " &amp; invoiceLine.sequenceNum.String &amp;  " should have been in the query results." );
		endif;
	endforeach;
	

epilog

	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	delete myEnqController;

end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoiceQuery" id="edcdd7d0-9cb7-4ef2-ba1c-8e10619377e7">
        <source>tInvoiceQuery();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

	qDef : CM_QueryDefinition;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	myEnqController : CM_EnqControllerInvoice;
	dtFrom : Date;
	dtTo : Date;
	dateArray : DateArray;
	now : Date;
	invoice : CM_Invoice;
	status : Integer;
	bank : CM_Bank;
	

begin

	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Invoicing_Query_Type,CM_QueryDefinition.Invoice_Query_Mode];
	
	//create the selector query object.
	create myEnqController;
	create myEnqController.allObjects as  CM_InvoiceBySeqNumDict transient;
	create criteriaHolder transient;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	// Add some basic criteria
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::myTerminal.name, CM_QReferenceLookup.Operator_Equal, self.getTerminal);
	
	dtFrom := now.cnEcAddDays( - 7);
	dtTo := now;
	create dateArray transient; dateArray.add( dtFrom ); dateArray.add( dtTo );
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::fromDT.name, CM_QDateRange.Operator_Between, dateArray);
	
	status := 0;
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getInvStatus.name, CM_QIntegerLookupEqual.Operator_Equal, status);
	
	// call the query
	myEnqController.doQuery( qDef );
	
	//check we found some.
	self.assertTrueMsg( not myEnqController.allObjects.CM_InvoiceBySeqNumDict.isEmpty, "Did not find any Invoices. Possible error.");
	
	//check each of the ones we got is correct
	foreach invoice in myEnqController.allObjects.CM_InvoiceBySeqNumDict do
		if invoice.myTerminal &lt;&gt; self.getTerminal then
			self.assertTrueMsg( false, "Invoice " &amp; invoice.sequenceNum.String &amp;  " terminal not " &amp; self.getTerminal.code );
		endif;
		if invoice.fromDT.Date &lt;  dtFrom then
			self.assertTrueMsg( false, "Invoice " &amp; invoice.sequenceNum.String &amp;  " fromDt earlier than " &amp; dtFrom.String );
		endif;
		if invoice.fromDT.Date &gt;  dtTo then
			self.assertTrueMsg( false, "Invoice " &amp; invoice.sequenceNum.String &amp;  " fromDt after " &amp; dtTo.String );
		endif;
		if invoice.status &lt;&gt; status then
			self.assertTrueMsg( false, "Invoice " &amp; invoice.sequenceNum.String &amp;  " status not equal " &amp; status.String );
		endif;
	endforeach;
	
	//check we got all we should have.
	foreach bank in self.getTerminal.companies where bank.isBusinessUnit do
		foreach invoice in bank.allInvoices do
			if invoice.status &lt;&gt; status then
				continue;
			endif;
			if invoice.myTerminal &lt;&gt; self.getTerminal then
				continue;
			endif;
			if invoice.fromDT.Date &lt;  dtFrom then
				continue;
			endif;
			if invoice.fromDT.Date &gt;  dtTo then
				continue;
			endif;
			if not myEnqController.allObjects.CM_InvoiceBySeqNumDict.includes( invoice ) then
				self.assertTrueMsg( false, "Invoice " &amp; invoice.sequenceNum.String &amp;  " should have been in the query results." );
			endif;
		endforeach;
	endforeach;

epilog

	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	delete myEnqController;

	delete dateArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tLocationActivity" id="a1bc6f5b-47dc-47ec-a84d-cfbd37d3fd63">
        <source>tLocationActivity();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 April 2021	navndl1	Initial creation	TFS 50906

*/

constants
	
vars

	qDef : CM_QueryDefinition;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	myEnqController : CM_EnqControllerLocationAct;
	now : TimeStamp;
	cargoType : CM_CargoType;
	
begin

	//Relies on UT_LocationAcitivity::tBaseTests having been run

	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Transaction_Query_Type,CM_QueryDefinition.Location_Activity_Query_Mode];
	
	//create the selector query object.
	create myEnqController;
	create myEnqController.allObjects as  CMEVT_LocationActivitySet transient;
	create criteriaHolder transient;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	// Add some basic criteria to the query
	self.doCreateCriteriaLine(qDef, criteriaHolder, CMEVT_LocationActivity::myTerminal.name, CM_QueryOperator.Operator_Equal, self.getTerminal);
	self.doCreateCriteriaLine(qDef, criteriaHolder, CMEVT_LocationActivity::dateTime.name, CM_QueryOperator.Operator_GreaterThan, now.cnEcAddDays(-2) );
		
	// run the query
	myEnqController.doQuery( qDef );
	
	//check we found some.
	self.assertTrueMsg( not myEnqController.allObjects.CMEVT_LocationActivitySet.isEmpty, "Did not find any Location Activity Objects. Has UT_LocationAcitivity::tBaseTests run correctly?");
		
	
epilog

	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	
	delete myEnqController;

end;</source>
    </JadeMethod>
    <JadeMethod name="tQueryWithTwoLines" id="a93092ba-2e92-4d2f-a6f4-6e75195c068c">
        <source>tQueryWithTwoLines();
// cnwndl1
//28 August 2009	cnwml2


//
vars
	agent : CM_QueryBuilderAgent;
	ti, ti2: CM_TrackedItem;
	results: CM_TISet;
	bs : CM_BlockStack;
	
begin

	bs := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	
	self.deleteContainer("UUT00000001");
	ti := self.addContainer("UUT00000001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti, bs);
	
	create agent transient;
	create results transient;
	agent.setResultArray(results);
	agent.setQueryMode(null);
	agent.addCriteria('myTerminal', 'equal to', getTerminal);
	agent.addCriteria('id', 'contains', "UUT");
	agent.addCriteria('operatorCode', 'equal to', self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	agent.doQuery();
	
	assertTrue(agent.allObjects.size &gt; 0);
	assertTrue(agent.allObjects.includes(ti));
	
epilog
	delete agent;
	delete results;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
