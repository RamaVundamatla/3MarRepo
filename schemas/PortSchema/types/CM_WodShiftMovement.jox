    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="1ed70429-223b-4575-84b1-1e17b01148be">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/05/2018	jlgndl1	Initial creation	TFS 38560
16/07/2018	jlgdap1	TFS 39717 PEL1 WO Shift Stern Mark Issue
*/

vars

	hmsMovement : HMS_VoyageMovement;
	tmpInfo	: String;

begin

	inheritMethod();
	
	if self.myFromBerth = null then
		app.raiseCMException(Input_requir_from_berth_field, null, null);
		return;
	endif;
	
	if self.myToBerth = null then
		app.raiseCMException(Input_required_field_toBerth, null, null);
		return;
	endif;
	//we they action this it will validate to create the actual movement so ignoring here
	//causes issues at inaportnet because it never knows this stuff
/*	//if self.
	if not self.myToBerth.isLogicalBerth() then
		if self.bowMarkTo &lt;= 0 then
			app.raiseCMException(Input_required_bow_mark, null, null);
		endif;
		
		//if self.sternMarkTo &lt;= 0 then										// TFS 39717
		//	app.raiseCMException(Input_require_stern_mark, null, null);		// TFS 39717
		//endif;															// TFS 39717
	endif;
	
	if self.draftAft &lt;= 0 then
		app.raiseCMException(Input_required_aft_draft, null, null);
	endif;
	
	if self.draftFwd &lt;= 0 then
		app.raiseCMException(Input_required_fwd_draft, null, null);
	endif;*/
	
	if not self.occursOnDT.date.isValid then
		app.raiseCMException(MSGBOX_MoveDTInvalidTitle, null, null);
	endif;
	
	//22 Jun 2018	NDL	TFS 39248
//	if self.myTowingVoyage &lt;&gt; null and self.myTowingVoyage = self.getMyVoyageObject() then
//		app.raiseCMException(Voyage_not_itself, null, null);
//	endif;
	self.validateTowingVoyage();	//05 Feb 2019	NDL	TFS 43245
	
	/*if app.myPassport.noErrors then
		//to do the proper berth overlap checking etc.
		create hmsMovement transient;
		hmsMovement.populateFromWodShiftMovement( self );
		hmsMovement.validateMe( app.myPassport );
	endif;*/

epilog

	delete hmsMovement;

end;</source>
    </JadeMethod>
