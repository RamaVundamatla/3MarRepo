    <JadeMethod name="btnGroupMove_click" id="1a9868e5-92df-4cfb-beb2-5d7ae956e13f">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnGroupMove_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60764: UI - Cargo Review Cust Doc Summary

*/

vars
	jdo : JadeDynamicObject;
	index : Integer;
	type : Type;
	value : Any;
	tiArray : CM_TIArray;
begin
	jdo:=self.tblCargoGrouped.allSelectedObjects.first.JadeDynamicObject;
	if jdo =null then
		return;
	endif;
	if jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then
		
		create tiArray transient;
		value.CM_TIByCargoTypeIdDict.copy(tiArray);
		self.myAssistant.showMoveItForm( tiArray,REAL_MODE);
		
	endif;
	
epilog

end;</source>
