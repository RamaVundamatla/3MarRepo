    <JadeMethod name="getLocationsForType" id="8108b483-ac6f-4e2a-a400-30237e7474ff">
        <source>getLocationsForType(_terminalAreaType : Integer; _includeArchived : Boolean; _lcArray : Collection input);
// ---------------------------------------------------------------------------
// Created:     08 November 2002		cnwth2	
//
// Purpose:     Grabs all the locations controllers of a particular terminal area type
//				into the collection passed in - including from archived locations controllers. 
//				Log areas type gets special treatment because
//				of the CM_LogArea::allEmptyRows collections
// ----------   ----------  --------------------------------------------------
vars
	ta			: CM_TerminalArea;
	lc			: CM_LocationsController;
begin
	if _lcArray = null then
		return;
	endif;
	
	foreach ta in self.allTerminalAreas do
		if ta.type = _terminalAreaType then
			foreach lc in ta.allLocationsControllers do
				if not _lcArray.includes(lc) then
					_lcArray.add(lc);
				endif;
			endforeach;	
			//get archived locations controllers also
			if _includeArchived then
				foreach lc in ta.allLCsArchived do
					if not _lcArray.includes(lc) then
						_lcArray.add(lc);
					endif;
				endforeach;
			endif;
			//if log area get all the empty and archived locations controllers as well.
			if _terminalAreaType = TA_TYPE_LOGAREA then
				foreach lc in ta.CM_LogArea.allEmptyLogControllers do
					if not _lcArray.includes(lc) then
						_lcArray.add(lc);
					endif;
				endforeach;
			endif;
		endif;
	endforeach;

end;</source>
        <Parameter name="_terminalAreaType" type="Integer"/>
        <Parameter name="_includeArchived" type="Boolean"/>
        <Parameter name="_lcArray" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getLogScalingHdr" id="b885a0f7-0485-410b-a444-6c73ce3b75a5">
        <source>getLogScalingHdr(_bolNum, _operatorCode : String; _numLogs : Integer) : CM_LogScalingHdr;
// -------------------------------------------
// Created 22 March 2004 by cnwdvb1
// -------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	iter 			: Iterator;
	hdr 			: CM_LogScalingHdr;
	opCode,
	bolNum			: String;
	keyTS			: TimeStamp;

begin

	iter := self.allLogScalingHdrsUnmatched.createIterator();
	self.allLogScalingHdrsUnmatched.startKeyGeq(_operatorCode, _bolNum, null, iter);
	while iter.next(hdr) do
		self.allLogScalingHdrsUnmatched.getIteratorKeys(opCode, bolNum, keyTS, iter);
		if bolNum &lt;&gt; _bolNum then
			break;
		endif;
			
		if	opCode = _operatorCode then
			
			if hdr.allLogScalingDtls.size = _numLogs then
				return hdr;
			endif;
		endif;
	endwhile;
	return null;

epilog
	delete iter;
end;</source>
        <Parameter name="_bolNum" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_numLogs" type="Integer"/>
        <ReturnType type="CM_LogScalingHdr"/>
    </JadeMethod>
    <JadeMethod name="getMatchingIMEXTransition" id="0ec2e22d-33e6-4881-ab29-71c69add1589">
        <source>getMatchingIMEXTransition(_ti : CM_TrackedItem; _matched : Boolean output) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 Apr 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status
06 Aug 2024	jlier1 TFS 65459 
*/

vars
	criteria : CM_IMEXTransitionCriteria;
begin
	_matched:=false;
	foreach criteria in self.allIMEXTransitionCriteria do
		if criteria.matches(_ti) then
			_matched:=true;
			return criteria.transitionIMEX;
		endif;
	endforeach;
	return _ti.getImExStatus;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_matched" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMatchingVoyages" id="2c89d339-3f76-48d5-8b35-a07b9a89c5e0">
        <source>getMatchingVoyages(_searcher : CMIF_HMSVoyageSearcher input);
// -------------------------------------------
// Created 12 May 2004 by cnwdvb1
// -------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	iter				: Iterator;
	voyage				: CM_Voyage;
	isLastVoyageInRange	: Boolean;
	vessel				: CM_Vessel;
begin

	iter := self.allVoyagesByArrivalDTCode.createIterator();
	self.allVoyagesByArrivalDTCode.startKeyGeq(_searcher.searchStartDT, null, iter);

	while iter.next(voyage) do
		if voyage.myHMSVoyageData = null then
			continue;
		endif;

		// Build list of voyages
		if not voyage.arrivedDT &lt;= _searcher.searchFinishDT then
			break;
		endif;

		vessel := voyage.getMyVessel();
		if vessel = null then 
			continue;
		endif;

						
 		// Check 'Ship Name' Criteria
 		if _searcher.mySelectedShip &lt;&gt; null then
			if vessel &lt;&gt; _searcher.mySelectedShip then
 				continue;
 			endif;
 		endif;

 		// Check 'Ship Type' Criteria
 		if _searcher.mySelectedShipType &lt;&gt; null then
 			if vessel.myHMSVesselData = null then
 				continue;
 			endif;
 			if vessel.myHMSVesselData.myVesselType &lt;&gt; _searcher.mySelectedShipType then
				continue;
			endif;
 		endif;

 		// Check 'Ship Line Co' Criteria
 		if _searcher.mySelectedShipLinesCo &lt;&gt; null then
 			if voyage.myShippingLine &lt;&gt; _searcher.mySelectedShipLinesCo then
 				continue;
 			endif;
 		endif;
 		_searcher.allVoyagesFound.add(voyage);
	endwhile;
epilog	

	delete iter;
end;</source>
        <Parameter name="_searcher" type="CMIF_HMSVoyageSearcher" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMaxDepartDateForVessel" id="f457bd4b-9267-4a0b-a849-1e6cff784154">
        <source>getMaxDepartDateForVessel(_vessel : CM_Vessel) : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     14 January 2005 by cnwrs2
//
// Purpose:     Returns the max departure date for a voyage for the passed
//				in vessel
// ---------------------------------------------------------------------------
vars
	tmpVoyage	: CM_Voyage;
	tmpDepartDT	: TimeStamp;
	tmpCode		: String;
begin

	tmpCode := _vessel.code;
	
	foreach tmpVoyage in self.allVoyagesByDepartDTCode reversed 
			where tmpVoyage.vesselCode = tmpCode and
				  tmpVoyage.departedDT.isValid do
		tmpDepartDT := tmpVoyage.departedDT;
		break;
	endforeach;

	return tmpDepartDT;

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getMyAutoIdGenerator" id="1051f00f-759b-4159-b152-6e28636aa5d8">
        <source>getMyAutoIdGenerator( class : Class ):CM_AutoIdGenerator;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2014	cnwndl1	Initial creation	Par 34660
29/08/2023		navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id
*/

vars

	keyType : Integer;

begin
	
	if class = CM_AutoBookingIdGen then
		keyType := CM_AutoIdGenerator.BookingIdType;
	elseif class = CM_AutoCargoIdGen then
		keyType := CM_AutoIdGenerator.CargoIdType;
	elseif class = CM_AutoReleaseIdGen then
		keyType := CM_AutoIdGenerator.ReleaseIdType;
	elseif class = CM_AutoVehicleBookingIdGen then
		keyType := CM_AutoIdGenerator.VehicleBookingIdType;
	elseif class = CM_AutoEIRNumberGen then //epr CCMS 1409 par 35553 21/1/15
		keyType := CM_AutoIdGenerator.EIRNumberType;
	elseif class = CM_AutoIdWOIdGen then //12 Jun 2018	NDL	TFS 39142
		keyType := CM_AutoIdGenerator.WorkOrderIdType;
	elseif class = CM_AutoIdVoyWOIdGen then //17 Aug 2018	NDL	TFS 40249
		keyType := CM_AutoIdGenerator.VoyWorkOrderIdType;
	elseif class = CM_AutoPaymentIdGen then //13 Jun 2018	NDL	TFS 39197
		// NOT USED against Terminal, just here for completeness...
		//Used against  CM_ExtFinanceIO
		keyType := CM_AutoIdGenerator.PaymentIdType;
	elseif class = CM_AutoTaxNumberGen then //13 Jun 2018	NDL	TFS 39197
		keyType := CM_AutoIdGenerator.TaxNumberType;
	elseif class = CM_AutoExternalNumberGen then //13 Jun 2018	NDL	TFS 39197
		// NOT USED against Terminal, just here for completeness...
		//Used against  CM_ExtFinanceIO
		keyType := CM_AutoIdGenerator.ExternalNumberType;
	elseif class = CM_AutoExternalReceiptGen then //01.11.2018 cnwma1 TFS #41688
		keyType := CM_AutoIdGenerator.ExternalReceiptNumberType;
	elseif class = CM_AutoServiceOrderGen then	//14 Oct 2020	NDL;	TFS 49189
		keyType := CM_AutoIdGenerator.RoadServiceOrderNumberType;
	elseif class = CM_AutoIdCustomDocs then //29/08/2023	navkc1	CR 59556  Task 59557
		keyType := CM_AutoIdCustomDocs.CustDocNumberType;
	endif;
	
	return self.allAutoIdGenerators.getAtKey( keyType );
	
epilog

end;</source>
        <Parameter name="class" type="Class"/>
        <ReturnType type="CM_AutoIdGenerator"/>
    </JadeMethod>
    <JadeMethod name="getMyHolidayCalendar" id="ba6399c3-3c57-4497-9f61-0355becbc801">
        <source>getMyHolidayCalendar():CM_Calendar;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 October 2010	cnwndl1	Initial creation

*/

vars

	calendar : CM_Calendar;
	invalidObject : Boolean;
	str : String;

begin

	on Exception do app.handleDeletedObject( exception, calendar, invalidObject ); 
	
	calendar := self.myCalendar;
	
	if calendar = null then
		return null;
	endif;
	
	str := calendar.code;
	
	if invalidObject then
		return null;
	endif;
	
	return calendar;

epilog

end;</source>
        <ReturnType type="CM_Calendar"/>
    </JadeMethod>
    <JadeMethod name="getMyRoadProcess" id="da6b93b1-73b2-49e3-97a2-eb2f0412334c">
        <source>getMyRoadProcess():CM_RoadProcess;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	roadProcess : CM_RoadProcess;

begin

	
	if self.myRoadProcess &lt;&gt; null then
		return self.myRoadProcess;
	else
		foreach roadProcess in CM_RoadProcess.instances do
			if roadProcess.isDefault then
				return roadProcess;
			endif;
		endforeach;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_RoadProcess"/>
