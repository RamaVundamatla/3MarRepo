    <JadeMethod name="validateCriteria" id="dc53eb8b-4ee3-4479-862d-2a71bb5f86ec">
        <source>validateCriteria();
/* ---------------------------------------------------------------------------
Created:	15 September 2010	by cnwvu1

Purpose:	MES CCMS 1080
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	criteriaTypeColl	: ObjectSet;
	criteria			: CM_YARTVConfigCriteria;
	criteriaType		: CM_YACriteriaType;

begin
	//  Ensure there is only one criteria object for any criteria type
	create criteriaTypeColl transient;
	
	foreach criteria in self.allCriteria do
		criteriaType := criteria.myYACriteriaType;
		if criteriaTypeColl.includes(criteriaType) then
			app.raiseCMException1(Err_YA_CriteriaWithSameType, criteriaType.description, null, null);
		else
			criteriaTypeColl.add(criteriaType);
		endif;
	endforeach;

epilog
	delete criteriaTypeColl;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="9b958dc8-df5a-4a5c-8d34-300a31cdcc16">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Date		Who		Reason
02 Mar 2015	cnwer1	Initial creation PAR 35664
18 Sep 2020	jlgdap1	TFS 49316 MTN Machine Idle Time
*/

vars

begin
/* // ### JIRA 33504 11DEC2024 NAVAB1
	if self.myVisibleDirectorFields = null or self.myVisibleDirectorFields.allEntTableRows.size = 0 then
		app.raiseCMException(Required_director_fields,null,null);
	endif;
	
	if self.myVisibleTaskFields = null or self.myVisibleTaskFields.allEntTableRows.size = 0 then
		app.raiseCMException(Required_entry_fields,null,null);
	endif;
	*/

	if self.allowCargoSearch and (self.myVisibleCargoFields = null or  self.myVisibleCargoFields.allEntTableRows.size = 0) then	
		app.raiseCMException(Required_enquiry_fields,null,null);
	endif;
	
	if self.idleTimeUntilAlert &lt; self.idleTimeAllowable then	// TFS 49316
		app.raiseCMException(Idle_time_error, null, null);		// TFS 49316
	endif;														// TFS 49316
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
