        <source>addReleaseRequestByIdDetails();

vars

begin

end;
</source>
    </JadeMethod>
    <JadeMethod name="addReleaseRequestByTypeLine" id="7bcfad72-d974-4f28-a720-e50215d4c7d7">
        <source>addReleaseRequestByTypeLine(_releaseNumber : String; _cargoType : Integer; _isoType, _isoTypeGrp : String; _totalReqd : Integer; _pxyReleaseRequest : CM_BulkRelease io);
/*

Purpose:	Create a Release Request by Type Line		

Date		Who		Reason
15/11/2017	jlgmh5	Initial creation	
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request	
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight																
*/
vars

	pxyReserveSelection			: CM_ReserveSelection;
	grade 						: CM_MTGrade;	
	ta							: CM_TerminalArea;
	matchYACriteria 			: CM_ReleaseByTypeCriteria;
	measurementType 			: CM_MeasurementType;
	isoType						: CM_ISOType;
	isoTypeGroup				: CM_ISOTypeGroup;
	
	allTermAreaDict				: CM_TAByIdDict;
	availGrades 				: IntegerArray;
	tokens						: StringArray;

	weightSelection 			: Decimal[14,4];
	doDelete					: Boolean;
	tempStr						: String;
	product						: CM_Product;
	productObj					: Any;
	
begin

	doDelete := true;
	if opts.includesKey("NoDelete") then
		doDelete := not self.opts.bool("NoDelete");
	endif;
	if doDelete then
		self.deleteReleaseRequest(_releaseNumber);
	endif;
	
	// OK for the moment but should be rewritten to allow for multiple grades to be passed
	grade := self.opts.obj("Grade").CM_MTGrade;
	if grade &lt;&gt; null then
		create availGrades transient;
		availGrades.add(grade.code);
	endif;

	// OK for the moment but should be rewritten to allow for multiple grades to be passed
	///ta := self.opts.obj("TerminalAreas").CM_TerminalArea;
	///create allTermAreaDict transient;
	///if ta &lt;&gt; null then
	///	allTermAreaDict.add(ta);
	///endif;
	tempStr := self.opts.str("TerminalAreas");
	if tempStr &lt;&gt; null then
		create allTermAreaDict transient;
		create tokens transient;
		tempStr.getTokensForDelimiter(";", tokens);
		foreach tempStr in tokens do
			ta := self.getTerminalArea(tempStr);
			if ta &lt;&gt; null then
				allTermAreaDict.add(ta);
			endif;
		endforeach;	
	endif;
	
	
	isoType := app.myRoot.allISOTypes[_isoType].CM_ISOType;
	isoTypeGroup := app.myRoot.allISOTypeGroups[_isoTypeGrp].CM_ISOTypeGroup;
	if isoTypeGroup &lt;&gt; null then															
		_pxyReleaseRequest.setPropertyValue(CM_BulkRelease::myISOGroup.name, isoTypeGroup);	
	endif;																				
	
	if self.opts.includesKey("WeightSelection") then						
		weightSelection := self.opts.dec("WeightSelection");
	endif;
	
	if self.opts.includesKey("MeasurementType")then							
		measurementType := self.opts.obj("MeasurementType").CM_MeasurementType;
		weightSelection := app.convertMeasurementForStorage(measurementType.shortName, weightSelection);
	endif;
	
	if opts.includesKey(ETRow_SetCriteria) then
		matchYACriteria := self.opts.obj(ETRow_SetCriteria).CM_ReleaseByTypeCriteria;
	endif;
	
	create pxyReserveSelection transient;
	//pxyReserveSelection.setMyHeader(_pxyReleaseRequest);
	pxyReserveSelection.setPxyDefaults();
	
	// 13/03/2018 jlgmh5
	product := self.opts.obj("Product").CM_Product;
	if self.opts.includesKey("ProductStr") then
		product := app.myRoot.allCargoTypesById[_cargoType].getProductFromCode(self.opts.str("ProductStr"));
	endif;

	pxyReserveSelection.setProxy(0, 
								app.myRoot.allCargoTypesById[_cargoType],
								self.opts.obj("BookingItem").CM_BookingRefItem,
								isoType,
								isoTypeGroup,
								product,
								null,
								null,
								_totalReqd,
								availGrades, //avail grades
								null,//clean
								null, //iso check
								false, //heavy rated
								null, //mask ids
								0,
								self.opts.str("Colour"),
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								weightSelection,					// 18/03/2016 cnwmh5  null,
								null,
								self.opts.str("Mark"),
								null,
								null,
								//ta,					// 01/07/2015 cnwma1 PAR #36555
								allTermAreaDict,		 // 01/07/2015 cnwma1 PAR #36555
								self.opts.obj("BOL").CM_BOLIn,
								self.opts.bool("BestPick"),
								null,
								null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
								null,	// ### TFS 53953 11July2022 NAVPW1
								null,null,  //12-07-2022 navtnr20 53974
								null, //28/06/2023 navmv20 CR 58410 Task 58411
								false, // 6/12/2023 navcs2 ChangeRequest 57537
								false, //19/02/2023	navkc1 CR 60078 Task 62450
								null,	//24/04/2025	navrv30	MTN 34319
								null);
								
	//18 Jun 2015	NDL	Par 36338
	if matchYACriteria &lt;&gt; null then
		matchYACriteria.setProxyBaseData(pxyReserveSelection);
	endif;
	
	pxyReserveSelection.setMyHeader(_pxyReleaseRequest);
	
	app.myTrxUA.trxUpdateBulkRelease(_pxyReleaseRequest, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete availGrades;
	delete allTermAreaDict;
	delete tokens;

end;
</source>
        <Parameter name="_releaseNumber" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_isoTypeGrp" type="String"/>
        <Parameter name="_totalReqd" type="Integer"/>
        <Parameter name="_pxyReleaseRequest" type="CM_BulkRelease" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addReleaseTransArea" id="5d78f8d7-420d-4f5e-9e2c-fd66a9a48eb2">
        <source>addReleaseTransArea(_name: String; _max: Integer; _icArea :Any): CM_BlockStack;
/*

Purpose:		Create Release Transfer Area

Date			Who		Reason
25/06/2015		cnwmh5	Initial creation

*/

vars
	pxyBlockStack	: CM_BlockStack;
	realTA 			: CM_TerminalAreaMaster;
	pDO				: CM_YADeckingOptionsTA;
	icArray 		: CM_InterchangeAreaArray;
	
begin
	self.deleteTerminalArea(_name);
	if _icArea &lt;&gt; null  then
		create icArray transient;
		if _icArea.isKindOf (CM_InterchangeArea) then
			icArray.add(_icArea.CM_InterchangeArea);
		elseif _icArea.isKindOf (ObjectArray) then
			_icArea.ObjectArray.copy (icArray);
		endif;
	endif;
	create pxyBlockStack transient;
	pxyBlockStack.setProxy(_name, 
					"",
					TA_TYPE_RELTRANS, 
					_max,
					5,
					5,
					false,
					"", 
					_max,
					true, 
					null,
					self.getTerminal,
					false,
					false,
					false,
					false,
					false,
					icArray,
					null,
					false
					);
	create pDO transient;
	pDO.setProxy(false, true, pxyBlockStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);

	if self.opts.includesKey("ActAsReleasePoint") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::actAsReleasePoint.name, self.opts.int("ActAsReleasePoint"));
	endif;
	
	if self.opts.includesKey("StockControlled") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::isStockControlled.name, self.opts.bool("StockControlled"));
	endif;
	
	if self.opts.includesKey("Comment") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::comment.name, self.opts.str("Comment"));
	endif;
	
	if self.opts.includesKey("DefaultYIC") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::myDefaultInterchangeArea.name, self.opts.obj("DefaultYIC").CM_YardInterchangeArea);
	endif;
	
	app.myTrxCA.trxCreateTerminalArea(pxyBlockStack, realTA, app.myPassport);
	if not self.opts.includesKey("ExpectErrors") then
		self.assertNoTrxErrorsOrWarnings();
	endif;

	if realTA = null then
		return null;
	else
		return realTA.CM_BlockStack;
	endif;
epilog
	delete pxyBlockStack;		//+cnwml2 MSL CCMS 1012  pDo gets deleted when deleting pxyBlockStack
	//delete pDO;
	delete icArray;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_max" type="Integer"/>
        <Parameter name="_icArea" type="Any"/>
        <ReturnType type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="addReserveSelectionOpts" id="bc3d58cb-1073-43d8-b069-1e74baa9f1a3">
        <source>addReserveSelectionOpts(	_bulkRelease: CM_BulkRelease input; 
							_packType	: Integer; // = CM_ReserveDetail.PackType_Parent, or CM_ReserveDetail.PackType_Child for packing children
							_cargoType	: Integer);
//12 January 2011	cnwvu1
//09 Sep 2014	cnwrs1	CCMS 2351 att Sequence to Release request 
//01/07/2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level	
//28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request			
// 6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight													
vars
	pxyBulkRelease		: CM_BulkRelease;
	pxyReserveSelection,
	realReserveSelection: CM_ReserveSelection;
	voyage				: CM_Voyage;
	voyageCode			: String;
	ta: CM_TerminalArea;
	tas: CM_TAByIdDict;
	matchYACriteria : CM_ReleaseByTypeCriteria;
	volume : Decimal [16,4];
	weight : Decimal [16,4];
	measurementType 	: CM_MeasurementType;
begin

	voyage := self.opts.obj("Voyage").CM_Voyage;
	if voyage &lt;&gt; null then
		voyageCode := voyage.code;
	endif;

	ta := opts.obj("TerminalArea").CM_TerminalArea;
	create tas transient;
	if ta &lt;&gt; null then
		tas.add(ta);
	endif;
	
	pxyBulkRelease := app.createUpdateProxy(_bulkRelease).CM_BulkRelease;
	//pxyBulkRelease := _bulkRelease.pxyCreateUpdateProxy();
	
	if opts.includesKey(UTTI_Volume) then
		volume := self.opts.dec(UTTI_Volume);
	endif;
	if opts.includesKey(UTTI_TotalWeight) then
		weight := self.opts.dec(UTTI_TotalWeight);
	endif;
	
	if self.opts.includesKey("MeasurementType") then						// 18/03/2016 cnwmh5
		measurementType := self.opts.obj("MeasurementType").CM_MeasurementType;
		weight := app.convertMeasurementForStorage(measurementType.shortName, weight);
	endif;
	
	create pxyReserveSelection transient;

	//pxyReserveSelection.setMyHeader(pxyReleaseRequest); moved below
	pxyReserveSelection.setPxyDefaults();
	
	pxyReserveSelection.setProxy(_packType, 
								app.myRoot.allCargoTypesById[_cargoType],
								opts.obj("BookingItem").CM_BookingRefItem,
								app.myRoot.allISOTypes[opts.str("ISOType")],
								app.myRoot.allISOTypeGroups[opts.str("ISOGroup")],
								opts.obj("Product").CM_Product,
								null,
								null,
								opts.int("Number"),
								null, //avail grades
								null,//clean
								null, //iso check
								false, //heavy rated
								null, //mask ids
								0,	//_maxToRelease
								null,	//_color
								null,	//_descriptionSelection
								null,	//_heightSelection
								null,	//_lengthSelection
								null,	//_markNumber
								null,	//_quantitySelection
								null,	//_remarksSelection
								volume,	//_volumeSelection : Decimal;
								weight,	//_weightSelection : Decimal;
								null,	//_widthSelection
								null,	//_markSelection
								null,	//_densitySelection
								null,	//_typeSelection
								//opts.obj("TerminalArea").CM_TerminalArea,  // 01/07/2015 cnwma1 PAR #36555
								tas,     // 01/07/2015 cnwma1 PAR #36555
								opts.obj("BOL").CM_BOLIn,
								opts.bool("BestPick"),
								null,	//_sequence
								null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
								null,	// ### TFS 53953 11July2022 NAVPW1
								null,null,  //12-07-2022 navtnr20 53974
								null, //28/06/2023 navmv20 CR 58410 Task 58411
								false,	// 6/12/2023 navcs2 ChangeRequest 57537
								false, //19/02/2023	navkc1 CR 60078 Task 62450
								null, //24/04/2025	navrv30	MTN 34319
								null);
								
	if opts.includesKey(ETRow_SetCriteria) then
		matchYACriteria := self.opts.obj(ETRow_SetCriteria).CM_ReleaseByTypeCriteria;
		if matchYACriteria &lt;&gt; null then
			matchYACriteria.setProxyBaseData(pxyReserveSelection);
		endif;
	endif;

	pxyReserveSelection.setMyHeader(pxyBulkRelease);

	app.myTrxUA.trxUpdateBulkRelease(pxyBulkRelease, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
epilog
	delete pxyBulkRelease;
	delete tas;
	
end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_packType" type="Integer"/>
        <Parameter name="_cargoType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addSealOperatorConfig" id="f399a8b2-f5b2-4d43-8811-3671e7b0cdc0">
        <source>addSealOperatorConfig(_operator : CM_Operator io; _sealShipRec : Integer; _sealShipRel : Integer; _sealRailRec : Integer; _sealRailRel : Integer; _sealRoadRec : Integer; _sealRoadRel : Integer);
//26 August 2010	cnwml2
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	pxyOperator : CM_Operator;
	tmpConfig : CMIF_ConfigOperator;
begin
	if _operator = null then		
		return;
	endif;
	
	beginLoad;
	pxyOperator := _operator.pxyCreateUpdateProxy();
	endLoad;
	pxyOperator.setSealCheckProxy(_sealShipRec, _sealShipRel, _sealRailRec, _sealRailRel, _sealRoadRec, _sealRoadRel);
	
	create tmpConfig transient;
	tmpConfig.setFromPersistentData(_operator);
	
	app.myTrxUA.trxUpdateOperator(pxyOperator, tmpConfig, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete pxyOperator;
	delete tmpConfig;
end;</source>
        <Parameter name="_operator" type="CM_Operator" usage="io"/>
        <Parameter name="_sealShipRec" type="Integer"/>
        <Parameter name="_sealShipRel" type="Integer"/>
        <Parameter name="_sealRailRec" type="Integer"/>
        <Parameter name="_sealRailRel" type="Integer"/>
        <Parameter name="_sealRoadRec" type="Integer"/>
        <Parameter name="_sealRoadRel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addSealTI" id="8d3543c6-9bd6-416e-8b4e-57fb92637c94">
        <source>addSealTI(_allSealNums : HugeStringArray; _myTrackedItem : CM_TrackedItem input; _sealType : String): CM_TrackedItem;
//20 August 2010	cnwml2
/* Changes

Date		Name	TFS#		Description
============================================================================
08/04/2011	cnwmh5	PAR #27347  Add cmsEndLoad or endLoad to epilog so that 
								if error occurs it will not leave it in beginLoad state.
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.							
============================================================================*/
vars
	pxySealTI 			: CM_SealTI;
	pxyTI 				: CM_TrackedItem;
	extraParams			: CMIF_TIUpdateExtraParams;
	txnControllerDict	: CMIF_TITxnContrlrByTypeDTDict;
	_strValue,
	str, 
	strSeal 			: String;
	seal				: CM_SealTI;
	foundSeal 			: Boolean;

begin

	create extraParams transient;	
	create txnControllerDict transient;
	beginLoad;
	pxyTI := _myTrackedItem.pxyCreateUpdateProxy();
	endLoad;
		
	if _myTrackedItem.allSeals.size &gt; 0 then
		foreach seal in pxyTI.allSeals do
			if pxyTI.allSeals.includesKey(_sealType) then					//found existing seal in ti
				foreach str in _allSealNums do
					if _strValue &lt;&gt; null then
						_strValue:= _strValue&amp; ", " &amp; str;
					else
						_strValue := str;
					endif;
				endforeach;
				foreach str in seal.allSealNums do
					if strSeal &lt;&gt; null then
						strSeal := strSeal &amp; ", " &amp; str;
					else
						strSeal := str;
					endif;
				endforeach;
				if _strValue &lt;&gt; strSeal then
					seal.setPreviousSeal(strSeal);
				endif;
				
				seal.allSealNums.clear();
				seal.allSealNums.add(_strValue);
				foundSeal := true;
				break;
			else
				create pxySealTI transient;
				_allSealNums.copy(pxySealTI.allSealNums);
				pxySealTI.setMyTrackedItem(pxyTI);
				pxySealTI.setSealType(_sealType);
			endif;
		endforeach;
	else
		create pxySealTI transient;
		_allSealNums.copy(pxySealTI.allSealNums);
		pxySealTI.setMyTrackedItem(pxyTI);
		pxySealTI.setSealType(_sealType);
	endif;
	
	app.myTrxUA.trxUpdateTIandExtraInfo(pxyTI, TI_UPDMODE_NORMAL, extraParams, txnControllerDict, null, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return _myTrackedItem;

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete pxySealTI;
	delete pxyTI;
	delete extraParams;
	delete txnControllerDict;
	
end;</source>
        <Parameter name="_allSealNums" type="HugeStringArray"/>
        <Parameter name="_myTrackedItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_sealType" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addSealTerminalConfig" id="ad38cd83-d500-473e-b95b-02956ef12842">
        <source>addSealTerminalConfig(	_terminal : CM_Terminal io;
						_sealShipRec : Integer;
						_sealShipRel : Integer;
						_sealRailRec : Integer;
						_sealRailRel : Integer;
						_sealRoadRec : Integer;
						_sealRoadRel : Integer;
						_sealPack : Integer;
						_sealUnpack : Integer;
						_sealWagonLoad : Integer;
						_sealWagonDischarge : Integer;
						_sealTruckLoad : Integer;
						_sealTruckDischarge : Integer
						);
//26 August 2010	cnwml2
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	pxyTerminal : CM_Terminal;
	tmpConfig : CMIF_ConfigTerminal;
begin
	if _terminal = null then		
		return;
	endif;
	
	beginLoad;
	pxyTerminal := _terminal.pxyCreateUpdateProxy();
	endLoad;
	pxyTerminal.setSealCheckProxy(_sealShipRec, _sealShipRel, _sealRailRec, _sealRailRel, _sealRoadRec, _sealRoadRel, _sealPack, _sealUnpack, _sealWagonLoad, _sealWagonDischarge, _sealTruckLoad, _sealTruckDischarge);
	
	create tmpConfig transient;
	tmpConfig.setFromPersistentData(_terminal);
	
	app.myTrxUA.trxUpdateTerminal(pxyTerminal, tmpConfig, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete pxyTerminal;
	delete tmpConfig;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="io"/>
        <Parameter name="_sealShipRec" type="Integer"/>
        <Parameter name="_sealShipRel" type="Integer"/>
        <Parameter name="_sealRailRec" type="Integer"/>
        <Parameter name="_sealRailRel" type="Integer"/>
        <Parameter name="_sealRoadRec" type="Integer"/>
        <Parameter name="_sealRoadRel" type="Integer"/>
        <Parameter name="_sealPack" type="Integer"/>
        <Parameter name="_sealUnpack" type="Integer"/>
        <Parameter name="_sealWagonLoad" type="Integer"/>
        <Parameter name="_sealWagonDischarge" type="Integer"/>
        <Parameter name="_sealTruckLoad" type="Integer"/>
        <Parameter name="_sealTruckDischarge" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addSealType" id="322bec85-707d-4d72-b2e0-bd28682bd09b">
        <source>addSealType(_code: String; _description: String; _cargoTypes: Any; _allowMultipleSealNums: Boolean; _showSealOnCheck: Boolean; _useForTrucks : Boolean) : CM_SealType;
// cnwdw1	 
// Add a seal type
vars
	proxy, 
	sealType   : CM_SealType;
	cargoTypes: CM_CargoTypeSet;
begin
	
	create cargoTypes transient;
	if _cargoTypes.isKindOf(String) then
		cargoTypes.add(self.getCargoType(_cargoTypes.String));
	else	
		if _cargoTypes &lt;&gt; null then
			_cargoTypes.CM_CargoTypeSet.copy(cargoTypes);
		endif;
	endif;
	
	create proxy transient;
	proxy.setProxy(_code, _description, cargoTypes, _allowMultipleSealNums, false,  _showSealOnCheck, false, _useForTrucks);
	
	app.myTrxCA.trxCreateSealType(proxy, sealType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return sealType;
epilog
	delete proxy;
	delete cargoTypes;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_cargoTypes" type="Any"/>
        <Parameter name="_allowMultipleSealNums" type="Boolean"/>
        <Parameter name="_showSealOnCheck" type="Boolean"/>
        <Parameter name="_useForTrucks" type="Boolean"/>
        <ReturnType type="CM_SealType"/>
    </JadeMethod>
    <JadeMethod name="addSecurityRole" id="cee92a1f-cbdf-45ec-a21b-8c24e0aeeb76">
        <source>addSecurityRole(_systemRole : Boolean; _name : String) : CM_SecurityRole;

/*

Purpose:		Add / Create a security role

Date			Who		Reason
10/02/2014		cnwmh5	Initial creation
22/03/2018		jlgdap1	TFS 37445 PEL1 Voyage Status Security
02/11/2022 		navds20 ChangeRequest 54253: EUP - VAS Work Orders
*/

vars

	securityRole					: CM_SecurityRole;
	parentRole						: CM_SecurityRole;
	pxyRole							: CM_SecurityRole;
	permissionAgent					: CM_PermissionAgent;
	
	permissions						: BooleanArray;
	permissionsToSet				: StringArray;

begin

	self.deleteSecurityRole(_name);

	create permissions transient;
	create permissionAgent transient;
	create permissionsToSet transient;
	
	if _systemRole then
		create pxyRole as CM_SecurityRoleSystem transient;
		parentRole := CM_SecurityRoleSystemRoot.firstInstance;
		permissionAgent.populatePermissionDict(true, true, 0);
		permissionAgent.setAllPermissionValues(true);
		permissionAgent.getPermissionValues(permissions, true, true);
	else
		create pxyRole as CM_SecurityRoleTerminal transient;
		parentRole := CM_SecurityRoleTerminalRoot.firstInstance;
		permissionAgent.getPermissionValues(permissions, false, true);
	endif;
	
	if self.opts.includesKey("PermissionsToSet") then
		self.opts.obj("PermissionsToSet").StringArray.copy(permissionsToSet);
	endif;
	
	if _systemRole then
		create pxyRole as CM_SecurityRoleSystem transient;
		parentRole := CM_SecurityRoleSystemRoot.firstInstance;
		//permissionAgent.populatePermissionDict(true, true);		// 07/02/2018 jlgmh5 moved outside of here as needed for both sys and term
		//permissionAgent.setAllPermissionValues(true);				// 70/02/2018 jlgmh5 removed as setting stuff not valid for view only	
		permissionAgent.getPermissionValuesAndSetIfReqd(permissions, true, true, permissionsToSet);
	else
		create pxyRole as CM_SecurityRoleTerminal transient;
		parentRole := CM_SecurityRoleTerminalRoot.firstInstance;
		permissionAgent.getPermissionValuesAndSetIfReqd(permissions, false, true, permissionsToSet);
	endif;
	
	if self.opts.includesKey("ParentRole") then					// 03/02/2016 cnwmh5
		parentRole := self.opts.obj("ParentRole").CM_SecurityRole;
	endif;
	
	pxyRole.setProxy(_name,
		parentRole,
		permissions,
		true,
		app.myRoot,
		null,
		null,
		null,
		null,
		null,
		null,
		null,
		null,	// TFS 39618		
		null,					// TFS 37445
		null,
		null,	//09 Mar 2020	NDL	TFS 48784
		null	//02/11/2022 navds20 TFS 54253
		);
	
	app.myTrxCA.trxCreateSecurityRole(pxyRole, permissionAgent, securityRole, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	
	return securityRole;

epilog

	delete pxyRole;
	delete permissions;
	delete permissionAgent;
	delete permissionsToSet;
	
end;</source>
        <Parameter name="_systemRole" type="Boolean"/>
        <Parameter name="_name" type="String"/>
        <ReturnType type="CM_SecurityRole"/>
    </JadeMethod>
