    <JadeMethod name="addNewResult" id="e2e7a0f1-ff4d-49d0-9769-81c12c16c41e">
        <updating/>
        <source>addNewResult(pObject:Object; pResultPos:Integer; pIsText:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		09 December 2008 by cnwdad1
//
// Purpose:		Updates the receiver's properties.
//
// Parameters:	pObject - A reference to the object which yielded the search result.
//				pResultPos - The position at which the result was founf.
//				pIsText - True if the receiver's text is where the result was found.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	resultObj	: CnEcJadeSearchResult;
	
begin
	create resultObj transient;
	resultObj.updateMe(pObject, pResultPos, pIsText);
	self.allSearchResults.add(resultObj);
end;</source>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pResultPos" type="Integer"/>
        <Parameter name="pIsText" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="0dc7b862-8956-4d29-b7bc-8072e86d4dae">
        <updating/>
        <source>delete() updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 December 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allSearchResults.purge();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSearch" id="a20fd4dc-6591-4a98-bf9f-cf01f4daaa57">
        <updating/>
        <source>doSearch():Boolean updating;
// --------------------------------------------------------------------------------
// Created:		09 December 2008 by cnwdad1
//
// Purpose:		Searches the specified Schemas.
//
// Parameters:	None
//
// Returns:		True if the search was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	searchObj		: CnEcWildcardSearch;
	metaphoneObj	: CnEcMetaphone;
	soundexObj		: CnEcSoundex;
	schemaObj		: Schema;
	
begin
	self.allSearchResults.purge();
	
	if self.isWildcards then
		create searchObj transient;
		searchObj.parseWildcards(self.searchFor, self.isCaseSensitive);
		
	elseif self.isMetaphone then
		create metaphoneObj transient;
		metaphoneObj.updateMe(self.searchFor);
		self.metaphoneValue	:=	metaphoneObj.getTransform(0);
		
	elseif self.isSoundex then
		create soundexObj transient;
		soundexObj.updateMe(self.searchFor);
		self.soundexValue	:=	soundexObj.getTransform(0);
		
	endif;
	
	foreach schemaObj in self.allSchemas do
		self.searchSchema(schemaObj, searchObj, metaphoneObj, soundexObj);
	endforeach;
	
	return true;
epilog
	delete searchObj;
	delete metaphoneObj;
	delete soundexObj;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStringMatch" id="fa7f2654-97b3-4473-9083-fd417ab724f7">
        <updating/>
        <source>isStringMatch(	pSearchString:String;
				pMetaphoneObj:CnEcMetaphone input;
				pSoundexObj:CnEcSoundex input;
				pFindPos:Integer output):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 December 2008 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	findPos		: Integer;
	
begin
	if self.isWholeWord then
		if self.isWholeWordMatch(pSearchString, pMetaphoneObj, pSoundexObj, pFindPos) then
			return true;
		endif;
	else
		findPos	:=	pSearchString.pos(self.searchFor, 1);
		
		if findPos &gt; 0 then
			pFindPos	:=	findPos;
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pSearchString" type="String"/>
        <Parameter name="pMetaphoneObj" type="CnEcMetaphone" usage="input"/>
        <Parameter name="pSoundexObj" type="CnEcSoundex" usage="input"/>
        <Parameter name="pFindPos" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWholeWordMatch" id="7d577360-efb0-4e32-808e-36654d4edd2b">
        <source>isWholeWordMatch(	pSearchString:String;
					pMetaphoneObj:CnEcMetaphone input;
					pSoundexObj:CnEcSoundex input;
					pFindPos:Integer output):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		09 December 2008 by cnwdad1
//
// Purpose:		Assuming that the "searchFor" value is a whole word, this method
//				will compare it to the specified string of words.
//
// Parameters:	pSearchString - The string of words to search.
//				pMetaphoneObj - A reference to the Metaphone agent.
//				pSoundexObj - A reference to the Soundex agent.
//				pFindPos - The position at which the match was found.
//
// Returns:		True if the word seach finds a match, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	compareValue	: String;
	nextWord		: String;
	wordPos			: Integer;
	
begin
	if self.isMetaphone then
		compareValue	:=	self.metaphoneValue;
	elseif self.isSoundex then
		compareValue	:=	self.soundexValue;
	else
		compareValue	:=	self.searchFor;
	endif;
	
	wordPos	:=	0;
	
	while true do
		nextWord	:=	pSearchString.cnEcGetNextWord(wordPos);
		
		if nextWord = null then
			break;
		else
			if self.isMetaphone then
				pMetaphoneObj.updateMe(nextWord);
				
				if pMetaphoneObj.getTransform(0) = compareValue then
					pFindPos	:=	wordPos;
					return true;
				endif;
				
			elseif self.isSoundex then
				pSoundexObj.updateMe(nextWord);
				
				if pSoundexObj.getTransform(0) = compareValue then
					pFindPos	:=	wordPos;
					return true;
				endif;
				
			elseif self.isCaseSensitive then
				if nextWord = self.searchFor then
					pFindPos	:=	wordPos;
					return true;
				endif;
			else
				if nextWord.toLower() = self.searchFor then
					pFindPos	:=	wordPos;
					return true;
				endif;
			endif;
		endif;
	endwhile;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pSearchString" type="String"/>
        <Parameter name="pMetaphoneObj" type="CnEcMetaphone" usage="input"/>
        <Parameter name="pSoundexObj" type="CnEcSoundex" usage="input"/>
        <Parameter name="pFindPos" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="makeSearchResult" id="80b021dc-667c-4f77-a2d9-21e206dbe086">
        <source>makeSearchResult(pObject:Object; pResultPos:Integer; pIsText:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2009 by cnwdad1
//
// Purpose:		Records a successful search result.
//
// Parameters:	pObject - A reference to the object on which the result occurred.
//				pResultPos - The position of the search result.
//				pIsText - True if the result was in the object's text.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	resultObj	: CnEcJadeSearchResult;
	
begin
	create resultObj transient;
	resultObj.updateMe(pObject, pResultPos, pIsText);
	self.allSearchResults.add(resultObj);
end;</source>
        <access>protected</access>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pResultPos" type="Integer"/>
        <Parameter name="pIsText" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchClass" id="2ace65ff-20be-4714-ba4f-5a6189facf32">
        <updating/>
        <source>searchClass(	pClassObj:Class;
				pSearchObj:CnEcWildcardSearch input;
				pMetaphoneObj:CnEcMetaphone io;
				pSoundexObj:CnEcSoundex input) updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 December 2008 by cnwdad1
//
// Purpose:		Searches the specified Class.
//
// Parameters:	pClassObj - A reference to the Class to search.
//				pSearchObj - A reference to the searcher.
//				pMetaphoneObj - A reference to the Metaphone searcher.
//				pSoundexObj - A reference to the Soundex searcher.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allConstants		: ConstantNDict;
	constantObj			: Constant;
	methodObj			: Method;
	allMethods			: MethodSet;
	propertyObj			: Property;
	allProperties		: PropertyColl;
	findPos				: Integer;

begin
	if self.isWildcards then
		if pSearchObj.doSearch(pClassObj.name) then
			findPos	:=	pSearchObj.foundPos;
			self.makeSearchResult(pClassObj, findPos, false);
			
		elseif pSearchObj.doSearch(pClassObj.text.trimBlanks()) then
			findPos	:=	pSearchObj.foundPos;
			self.makeSearchResult(pClassObj, findPos, true);
		endif;
		
	elseif self.isStringMatch(pClassObj.name, pMetaphoneObj, pSoundexObj, findPos) then
		self.makeSearchResult(pClassObj, findPos, false);
		
	elseif self.isStringMatch(pClassObj.text.trimBlanks(), pMetaphoneObj, pSoundexObj, findPos) then
		self.makeSearchResult(pClassObj, findPos, true);
	endif;
	
	if self.isClassConstants then
		create allConstants transient;
		pClassObj.getConstants(allConstants);
		
		foreach constantObj in allConstants do
			self.searchConstant(constantObj, pSearchObj, pMetaphoneObj, pSoundexObj);
		endforeach;
	endif;
	
	create allMethods transient;
	pClassObj.allMethods(allMethods);
	
	foreach methodObj in allMethods do
		self.searchMethod(methodObj, pSearchObj, pMetaphoneObj, pSoundexObj);
	endforeach;
	
	allProperties	:=	pClassObj.allProperties();
	
	foreach propertyObj in allProperties do
		self.searchProperty(propertyObj, pSearchObj, pMetaphoneObj, pSoundexObj);
	endforeach;
epilog
	delete allConstants;
	delete allMethods;
end;</source>
        <access>protected</access>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pSearchObj" type="CnEcWildcardSearch" usage="input"/>
        <Parameter name="pMetaphoneObj" type="CnEcMetaphone" usage="io"/>
        <Parameter name="pSoundexObj" type="CnEcSoundex" usage="input"/>
    </JadeMethod>
    <JadeMethod name="searchConstant" id="a1a21bb2-7fa2-4da2-bee3-ef8ffddf2287">
        <updating/>
        <source>searchConstant(	pConstantObj:Constant;
				pSearchObj:CnEcWildcardSearch input;
				pMetaphoneObj:CnEcMetaphone io;
				pSoundexObj:CnEcSoundex input) updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 December 2008 by cnwdad1
//
// Purpose:		Searches the specified Constant.
//
// Parameters:	pConstantObj - A reference to the Constant to search.
//				pSearchObj - A reference to the searcher.
//				pMetaphoneObj - A reference to the Metaphone searcher.
//				pSoundexObj - A reference to the Soundex searcher.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	findPos				: Integer;

begin
	if self.isWildcards then
		if pSearchObj.doSearch(pConstantObj.name) then
			findPos	:=	pSearchObj.foundPos;
			self.makeSearchResult(pConstantObj, findPos, false);
			return;
			
		elseif pSearchObj.doSearch(pConstantObj.getSource()) then
			findPos	:=	pSearchObj.foundPos;
			self.makeSearchResult(pConstantObj, findPos, true);
			return;
			
		elseif pSearchObj.doSearch(pConstantObj.text.trimBlanks()) then
			findPos	:=	pSearchObj.foundPos;
			self.makeSearchResult(pConstantObj, findPos, true);
			return;
		endif;
		
	elseif self.isStringMatch(pConstantObj.name, pMetaphoneObj, pSoundexObj, findPos) then
		self.makeSearchResult(pConstantObj, findPos, false);
		return;
		
	elseif self.isStringMatch(pConstantObj.getSource(), pMetaphoneObj, pSoundexObj, findPos) then
		self.makeSearchResult(pConstantObj, findPos, true);
		return;
		
	elseif self.isStringMatch(pConstantObj.text.trimBlanks(), pMetaphoneObj, pSoundexObj, findPos) then
		self.makeSearchResult(pConstantObj, findPos, true);
		return;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pConstantObj" type="Constant"/>
        <Parameter name="pSearchObj" type="CnEcWildcardSearch" usage="input"/>
        <Parameter name="pMetaphoneObj" type="CnEcMetaphone" usage="io"/>
        <Parameter name="pSoundexObj" type="CnEcSoundex" usage="input"/>
    </JadeMethod>
    <JadeMethod name="searchGlobalConstants" id="401c3aef-71e1-4224-b19e-06057f417737">
        <updating/>
        <source>searchGlobalConstants(	pSchemaObj:Schema;
						pSearchObj:CnEcWildcardSearch input;
						pMetaphoneObj:CnEcMetaphone io;
						pSoundexObj:CnEcSoundex input) updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 December 2008 by cnwdad1
//
// Purpose:		Searches the specified schema's Global Constants.
//
// Parameters:	pSchemaObj - A reference to the schema to search.
//				pSearchObj - A reference to the searcher.
//				pMetaphoneObj - A reference to the Metaphone searcher.
//				pSoundexObj - A reference to the Soundex searcher.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	categoryObj			: ConstantCategory;
	allConstants		: ConstantNDict;
	constantObj			: Constant;
	findPos				: Integer;

begin
	foreach categoryObj in ConstantCategory.instances do
		if categoryObj.cnEcGetSchema() &lt;&gt; pSchemaObj then
			continue;
		endif;
		
		allConstants	:=	categoryObj.cnEcGetConstants();
		
		foreach constantObj in allConstants do
			if constantObj.cnEcIsGlobal() then
				self.searchConstant(constantObj, pSearchObj, pMetaphoneObj, pSoundexObj);
			endif;
		endforeach;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pSchemaObj" type="Schema"/>
        <Parameter name="pSearchObj" type="CnEcWildcardSearch" usage="input"/>
        <Parameter name="pMetaphoneObj" type="CnEcMetaphone" usage="io"/>
        <Parameter name="pSoundexObj" type="CnEcSoundex" usage="input"/>
    </JadeMethod>
    <JadeMethod name="searchMethod" id="f6c838a3-9b7f-4bab-a0ff-350705afbe5c">
        <updating/>
        <source>searchMethod(	pMethodObj:Method;
				pSearchObj:CnEcWildcardSearch input;
				pMetaphoneObj:CnEcMetaphone io;
				pSoundexObj:CnEcSoundex input) updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 December 2008 by cnwdad1
//
// Purpose:		Searches the specified Method.
//
// Parameters:	pMethodObj - A reference to the Method to search.
//				pSearchObj - A reference to the searcher.
//				pMetaphoneObj - A reference to the Metaphone searcher.
//				pSoundexObj - A reference to the Soundex searcher.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	findPos				: Integer;

begin
	if self.isWildcards then
		if pSearchObj.doSearch(pMethodObj.name) then
			findPos	:=	pSearchObj.foundPos;
			self.makeSearchResult(pMethodObj, findPos, false);
			return;
			
		elseif pSearchObj.doSearch(pMethodObj.getSource()) then
			findPos	:=	pSearchObj.foundPos;
			self.makeSearchResult(pMethodObj, findPos, false);
			return;
		endif;
		
	else
		if self.isStringMatch(pMethodObj.name, pMetaphoneObj, pSoundexObj, findPos) then
			self.makeSearchResult(pMethodObj, findPos, false);
			return;
			
		elseif self.isStringMatch(pMethodObj.getSource(), pMetaphoneObj, pSoundexObj, findPos) then
			self.makeSearchResult(pMethodObj, findPos, false);
			return;
		endif;
	endif;
	
	if self.isMethodText then
		if self.isWildcards then
			if pSearchObj.doSearch(pMethodObj.text.trimBlanks()) then
				findPos	:=	pSearchObj.foundPos;
				self.makeSearchResult(pMethodObj, findPos, true);
				return;
			endif;
			
		else
			if self.isStringMatch(pMethodObj.text.trimBlanks(), pMetaphoneObj, pSoundexObj, findPos) then
				self.makeSearchResult(pMethodObj, findPos, true);
				return;
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pMethodObj" type="Method"/>
        <Parameter name="pSearchObj" type="CnEcWildcardSearch" usage="input"/>
        <Parameter name="pMetaphoneObj" type="CnEcMetaphone" usage="io"/>
        <Parameter name="pSoundexObj" type="CnEcSoundex" usage="input"/>
    </JadeMethod>
    <JadeMethod name="searchPrimitive" id="8e5b8e94-343b-47ee-840b-ad1e5ad0328f">
        <updating/>
        <source>searchPrimitive(pPrimTypeObj:PrimType;
				pSearchObj:CnEcWildcardSearch input;
				pMetaphoneObj:CnEcMetaphone io;
				pSoundexObj:CnEcSoundex input) updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 December 2008 by cnwdad1
//
// Purpose:		Searches the specified Primitive Type.
//
// Parameters:	pPrimTypeObj - A reference to the Primitive Type to search.
//				pSearchObj - A reference to the searcher.
//				pMetaphoneObj - A reference to the Metaphone searcher.
//				pSoundexObj - A reference to the Soundex searcher.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allConstants		: ConstantNDict;
	constantObj			: Constant;
	methodObj			: Method;
	allMethods			: MethodSet;
	propertyObj			: Property;
	allProperties		: PropertyColl;
	findPos				: Integer;

begin
	if self.isWildcards then
		if pSearchObj.doSearch(pPrimTypeObj.name) then
			findPos	:=	pSearchObj.foundPos;
			self.makeSearchResult(pPrimTypeObj, findPos, false);
			
		elseif pSearchObj.doSearch(pPrimTypeObj.text.trimBlanks()) then
			findPos	:=	pSearchObj.foundPos;
			self.makeSearchResult(pPrimTypeObj, findPos, true);
		endif;
		
	else
		if self.isStringMatch(pPrimTypeObj.name, pMetaphoneObj, pSoundexObj, findPos) then
			self.makeSearchResult(pPrimTypeObj, findPos, false);
			
		elseif self.isStringMatch(pPrimTypeObj.text.trimBlanks(), pMetaphoneObj, pSoundexObj, findPos) then
			self.makeSearchResult(pPrimTypeObj, findPos, true);
		endif;
	endif;
	
	if self.isClassConstants then
		create allConstants transient;
		pPrimTypeObj.getConstants(allConstants);
		
		foreach constantObj in allConstants do
			self.searchConstant(constantObj, pSearchObj, pMetaphoneObj, pSoundexObj);
		endforeach;
	endif;
	
	create allMethods transient;
	pPrimTypeObj.allMethods(allMethods);
	
	foreach methodObj in allMethods do
		self.searchMethod(methodObj, pSearchObj, pMetaphoneObj, pSoundexObj);
	endforeach;
epilog
	delete allConstants;
	delete allMethods;
end;</source>
        <access>protected</access>
        <Parameter name="pPrimTypeObj" type="PrimType"/>
        <Parameter name="pSearchObj" type="CnEcWildcardSearch" usage="input"/>
        <Parameter name="pMetaphoneObj" type="CnEcMetaphone" usage="io"/>
        <Parameter name="pSoundexObj" type="CnEcSoundex" usage="input"/>
    </JadeMethod>
    <JadeMethod name="searchProperty" id="5cf25d9e-92f1-4142-a18d-89c0a90449d1">
        <updating/>
        <source>searchProperty(	pPropertyObj:Property;
				pSearchObj:CnEcWildcardSearch input;
				pMetaphoneObj:CnEcMetaphone io;
				pSoundexObj:CnEcSoundex input) updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 December 2008 by cnwdad1
//
// Purpose:		Searches the specified Property.
//
// Parameters:	pPropertyObj - A reference to the Property to search.
//				pSearchObj - A reference to the searcher.
//				pMetaphoneObj - A reference to the Metaphone searcher.
//				pSoundexObj - A reference to the Soundex searcher.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	findPos				: Integer;

begin
	if self.isPropertyText then
		if self.isWildcards then
			if pSearchObj.doSearch(pPropertyObj.name) then
				findPos	:=	pSearchObj.foundPos;
				self.makeSearchResult(pPropertyObj, findPos, false);
				
			elseif pSearchObj.doSearch(pPropertyObj.text.trimBlanks()) then
				findPos	:=	pSearchObj.foundPos;
				self.makeSearchResult(pPropertyObj, findPos, true);
			endif;
			
		else
			if self.isStringMatch(pPropertyObj.name, pMetaphoneObj, pSoundexObj, findPos) then
				self.makeSearchResult(pPropertyObj, findPos, false);
			elseif self.isStringMatch(pPropertyObj.text.trimBlanks(), pMetaphoneObj, pSoundexObj, findPos) then
				self.makeSearchResult(pPropertyObj, findPos, true);
			endif;
		endif;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="pPropertyObj" type="Property"/>
        <Parameter name="pSearchObj" type="CnEcWildcardSearch" usage="input"/>
        <Parameter name="pMetaphoneObj" type="CnEcMetaphone" usage="io"/>
        <Parameter name="pSoundexObj" type="CnEcSoundex" usage="input"/>
    </JadeMethod>
    <JadeMethod name="searchSchema" id="d36b2ae8-b93c-4bcb-a1ff-80e7a8d0f06c">
        <updating/>
        <source>searchSchema(	pSchemaObj:Schema;
				pSearchObj:CnEcWildcardSearch input;
				pMetaphoneObj:CnEcMetaphone io;
				pSoundexObj:CnEcSoundex input) updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 December 2008 by cnwdad1
//
// Purpose:		Searches the specified Schema.
//
// Parameters:	pSchemaObj - A reference to the schema to search.
//				pSearchObj - A reference to the searcher.
//				pMetaphoneObj - A reference to the Metaphone searcher.
//				pSoundexObj - A reference to the Soundex searcher.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allClassesObj	: ClassColl;
	classObj		: Class;
	searchClassObj	: Class;
	primitiveObj	: PrimType;
	findPos			: Integer;
	
begin
	if self.isGlobalConstants then
		self.searchGlobalConstants(pSchemaObj, pSearchObj, pMetaphoneObj, pSoundexObj);
	endif;
	
	if self.isTranslatables then
		self.searchTranslatables(pSchemaObj, pSearchObj, pMetaphoneObj, pSoundexObj);
	endif;
	
	if self.isWildcards then
		if pSearchObj.doSearch(pSchemaObj.name) then
			findPos	:=	pSearchObj.foundPos;
			self.makeSearchResult(pSchemaObj, findPos, false);
		endif;
		
	elseif self.isStringMatch(pSchemaObj.name, pMetaphoneObj, pSoundexObj, findPos) then
		self.makeSearchResult(pSchemaObj, findPos, false);
	endif;
	
	if self.isSchemaText then
		if self.isWildcards then
			if pSearchObj.doSearch(pSchemaObj.text.trimBlanks()) then
				findPos	:=	pSearchObj.foundPos;
				self.makeSearchResult(pSchemaObj, findPos, true);
			endif;
			
		elseif self.isStringMatch(pSchemaObj.text.trimBlanks(), pMetaphoneObj, pSoundexObj, findPos) then
			self.makeSearchResult(pSchemaObj, findPos, true);
		endif;
	endif;
	
	if self.isPrimitives then
		foreach primitiveObj in PrimType.instances do
			if primitiveObj.schema = pSchemaObj then
				self.searchPrimitive(primitiveObj, pSearchObj, pMetaphoneObj, pSoundexObj);
			endif;
		endforeach;
	endif;
	
	// Now search the schema's classes.
	
	allClassesObj	:=	pSchemaObj.allClasses();
	
	foreach classObj in allClassesObj do
		if classObj.rootType.schema = pSchemaObj then
			self.searchClass(classObj, pSearchObj, pMetaphoneObj, pSoundexObj);
		endif;
	endforeach;
epilog
//	delete allClassesObj;
end;</source>
        <access>protected</access>
        <Parameter name="pSchemaObj" type="Schema"/>
        <Parameter name="pSearchObj" type="CnEcWildcardSearch" usage="input"/>
        <Parameter name="pMetaphoneObj" type="CnEcMetaphone" usage="io"/>
        <Parameter name="pSoundexObj" type="CnEcSoundex" usage="input"/>
    </JadeMethod>
    <JadeMethod name="searchTranslatables" id="b3770de9-81f0-4cb7-bf2f-b044cd6c676f">
        <updating/>
        <source>searchTranslatables(pSchemaObj:Schema;
					pSearchObj:CnEcWildcardSearch input;
					pMetaphoneObj:CnEcMetaphone io;
					pSoundexObj:CnEcSoundex input) updating, protected;
// --------------------------------------------------------------------------------
// Created:		09 December 2008 by cnwdad1
//
// Purpose:		Searches the specified schema's Translatable String.
//
// Parameters:	pSchemaObj - A reference to the schema to search.
//				pSearchObj - A reference to the searcher.
//				pMetaphoneObj - A reference to the Metaphone searcher.
//				pSoundexObj - A reference to the Soundex searcher.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	translatableObj		: TranslatableString;
	findPos				: Integer;

begin
	foreach translatableObj in TranslatableString.instances do
		if translatableObj.locale.cnEcGetSchema() &lt;&gt; pSchemaObj then
			continue;
		endif;
		
		self.searchConstant(translatableObj, pSearchObj, pMetaphoneObj, pSoundexObj);
	endforeach;
end;
</source>
        <access>protected</access>
        <Parameter name="pSchemaObj" type="Schema"/>
        <Parameter name="pSearchObj" type="CnEcWildcardSearch" usage="input"/>
        <Parameter name="pMetaphoneObj" type="CnEcMetaphone" usage="io"/>
        <Parameter name="pSoundexObj" type="CnEcSoundex" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setOptions" id="45c00e6a-62e6-4a1a-a220-a1674f8cc574">
        <updating/>
        <source>setOptions(	pSearchFor:String;
			pAllSchemasObj:SchemaColl;
			pIsWholeWord:Boolean;
			pIsCaseSensitive:Boolean;
			pIsWildcards:Boolean;
			pIsSoundsLike:Boolean;
			pIsMetaphone:Boolean;
			pIsSoundex:Boolean;
			pIsSchemaText:Boolean;
			pIsTranslatables:Boolean;
			pIsPrimitives:Boolean;
			pIsGlobalConstants:Boolean;
			pIsClassText:Boolean;
			pIsMethodText:Boolean;
			pIsPropertyText:Boolean;
			pIsClassConstants:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		09 December 2008 by cnwdad1
//
// Purpose:		Sets the receiver's search options.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allSearchResults.purge();
	self.searchFor			:=	pSearchFor;
	self.allSchemas.clear();
	pAllSchemasObj.copy(self.allSchemas);
	self.isWholeWord		:=	pIsWholeWord;
	self.isCaseSensitive	:=	pIsCaseSensitive;
	self.isWildcards		:=	pIsWildcards;
	self.isSoundsLike		:=	pIsSoundsLike;
	self.isMetaphone		:=	pIsMetaphone;
	self.isSoundex			:=	pIsSoundex;
	self.isSchemaText		:=	pIsSchemaText;
	self.isTranslatables	:=	pIsTranslatables;
	self.isPrimitives		:=	pIsPrimitives;
	self.isGlobalConstants	:=	pIsGlobalConstants;
	self.isClassText		:=	pIsClassText;
	self.isMethodText		:=	pIsMethodText;
	self.isPropertyText		:=	pIsPropertyText;
	self.isClassConstants	:=	pIsClassConstants;
end;</source>
        <Parameter name="pSearchFor" type="String"/>
        <Parameter name="pAllSchemasObj" type="SchemaColl"/>
        <Parameter name="pIsWholeWord" type="Boolean"/>
        <Parameter name="pIsCaseSensitive" type="Boolean"/>
        <Parameter name="pIsWildcards" type="Boolean"/>
        <Parameter name="pIsSoundsLike" type="Boolean"/>
        <Parameter name="pIsMetaphone" type="Boolean"/>
        <Parameter name="pIsSoundex" type="Boolean"/>
        <Parameter name="pIsSchemaText" type="Boolean"/>
        <Parameter name="pIsTranslatables" type="Boolean"/>
        <Parameter name="pIsPrimitives" type="Boolean"/>
        <Parameter name="pIsGlobalConstants" type="Boolean"/>
        <Parameter name="pIsClassText" type="Boolean"/>
        <Parameter name="pIsMethodText" type="Boolean"/>
        <Parameter name="pIsPropertyText" type="Boolean"/>
        <Parameter name="pIsClassConstants" type="Boolean"/>
    </JadeMethod>
</Class>
