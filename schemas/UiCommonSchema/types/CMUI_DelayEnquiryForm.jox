    <JadeMethod name="setupForm" id="3f90608b-fa1c-45c5-93de-f6834fb2206e">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	14 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
31/05/2011	cnwcs5		par 27612 - if form not loaded with collection of voyages
									then use collection on terminal.  Also fixed problem
									where navigator not being updated
16/12/2015   cnwma1      PAR # 37329 System is not saving ship delays and we have a ship in and working
*/
vars
	voyage	:CM_Voyage;
begin
	self.staStatusBar.visible	:= true;
	
	
	// allow query if we have not shown the form with a specific voyage
	if self.myFilterVoyage &lt;&gt; null then
		self.usesQueryFrame 	:= false;
	else
		self.usesQueryFrame 	:= true;
	endif;
	
	if self.allCurrentVoyages.isEmpty then											
		self.myTerminal.getAllCurrentCellularVoyages(self.allCurrentVoyages,true,false);	// epr CCMS 1033 don't want all voyages or the null voyage
	endif;																			// par 27612 cnwcs5 31/05/2010
	
	self.toolbarStyle 			:= self.ToolbarStyle_ShowNoHide;	
	self.showToolbar 			:= true;
	self.useTableInfo 			:= false;
	self.useTableSorting 		:= true;

	inheritMethod();
	
	self.initTableData(ETDef_DelaysEnquiryTbl);
	
	self.btnAddDelay.enabled	:= true;
	
	voyage := self.myFilterVoyage.CM_Voyage;
	
	if voyage &lt;&gt; null then
		self.caption := self.caption &amp; ' (' &amp; voyage.code &amp; ')'; 

	endif;
	
	self.setNavigatorHeading (self.caption);										// par 27612 cnwcs5 31/05/2010
	
	// Not very many delays so can use sys notes as Mo has already started doing.
	// Deletes registered for delays that are added to table
	self.beginClassNotification(CM_Delay, false, Object_Create_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_Delay, false, Object_Update_Event, Response_Continuous, 0);
	if voyage &lt;&gt; null then																 // 16/12/2015 cnwma1	 PAR #37329       
		self.doRefresh();     															 // 16/12/2015 cnwma1	 PAR #37329                                                           
	endif;
	
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditItem.enabled:= false;
	endif;

end;
</source>
    </JadeMethod>
