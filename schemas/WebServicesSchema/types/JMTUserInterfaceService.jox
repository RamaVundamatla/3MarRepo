    <JadeWebServicesMethod name="getVoyageJobTransferTypes" id="b3a6d7c0-54a4-4494-b460-17e197f976e1">
        <source>getVoyageJobTransferTypes() : WS_VoyageJobTranTypesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 March 2018	jlger1	Initial creation tfs 37664 pelindo cargo request need this

*/

vars
	response 	: WS_VoyageJobTranTypesResponse;
	voyageTransferType : CM_VoyageJobTransferType;
	wsProxy		: WS_VoyageJobTransferType;
	completedOK : Boolean;
	iter		 : Iterator;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	//PmAdmVoyJobTfrView
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;

	
	iter:=app.myRoot.allVoyageJobTransferTypes.createIterator;
	while iter.next(voyageTransferType) do
		if voyageTransferType.id = VESSEL_TYPE_LOLO then
			continue;
		endif;
		
		create wsProxy transient;
		wsProxy.setProxyFromObject(voyageTransferType);
		response.allVoyageJobTransferTypes.add(wsProxy);
	endwhile;

	completedOK := true;		
	return response;

epilog
	delete iter;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	cnEndTransaction;

end;</source>
