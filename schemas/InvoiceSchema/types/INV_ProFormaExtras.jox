    <JadeMethod name="changeOption" id="4cc54e98-63ff-40fd-8f31-613fc61bdaae">
        <source>changeOption( _clear : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2019	jlgndl1	Initial creation	TFS 42940

*/

vars

begin

	if self.optFinancial.value then
		self.txtFinancial.enabled := true;
		self.txtQtyManual.enabled := false;
		if _clear then
			self.txtQtyManual.text := "1";
		endif;
	else
		self.txtFinancial.enabled := false;
		if _clear then
			self.txtFinancial.text := null;
		endif;
		self.txtQtyManual.enabled := true;
	endif;

epilog

end;</source>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
