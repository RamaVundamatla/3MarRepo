    <JadeMethod name="setControlsForAddEdit" id="e9fc8320-4dcf-4e3b-841b-070ba0da35c0">
        <updating/>
        <source>setControlsForAddEdit() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2010	cnwmd1	Initial creation

*/

vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled 	:= true;
	theForm.tblData4.enabled 			:= false;		
	theForm.mulSelect1.userInputEnabled := true;
	theForm.btnAddNew.enabled 			:= true;
	theForm.txtName.enabled 			:= true;
	theForm.txtName.readOnly			:= false;
	theForm.txtEmailName.enabled 		:= true;
	theForm.txtEmailName.readOnly		:= false;
	
	/*if theForm.mode = theForm.Mode_Add then
	 	theForm.tblData4.clearAllData();
		theForm.tblInput1.clearValues;
		
		theForm.shtMultiSelect1.caption := 'Email Addresses (' &amp; 0.String &amp; ')';
		
		theForm.tblInput1.cnEcResizeContents;
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);	// sets case etc.
		theForm.fldInput.initSheetBackColors(); 
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_SystemAlertType);
		
		//theForm.tblInput1.enableRowByName(ETRow_Code);
		
	endif;
	*/
	
	//Note, only editing of certain fields is permitted.
	//Note2, no adding of new system alert types is permitted
	
	// refresh the data from the newly created proxy
	self.showThumbnail(theForm.myProxyObject.CM_SystemAlertType);
		
	theForm.tblInput1.disableRowByName(ETRow_Area);
	theForm.tblInput1.disableRowByName(ETRow_Name);
	theForm.tblInput1.disableRowByName(ETRow_Type);
	
epilog

end;</source>
    </JadeMethod>
