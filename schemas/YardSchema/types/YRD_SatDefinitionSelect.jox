    <JadeMethod name="setupForm" id="a8a670fa-e147-4f5b-aba2-da6ab984c5e1">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16/11/2010	cnwer1	Initial creation
19/09/2011	cnwdap1	PAR #27814 set focus to terminal view list box
*/

vars

begin
	inheritMethod();

	self.loadTerminalViews();
	self.lstTAViews.setFocus();		// PAR #27814
	self.doSecurity(); 		//cnwrd1 par 28498 20.10.2011
epilog

end;</source>
