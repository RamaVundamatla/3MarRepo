    <JadeMethod name="rfcAttributes" id="abb7c75c-ccb6-42da-ae22-5efe0c16d3a7">
        <source>rfcAttributes(_container : CM_TrackedItem/*CM_Container*/) : String protected;

// cnwdvb1 29 April 2003 
// 14/12/2009	cnwdap1	Initial creation CCMS MES 1007 Any tracked item can now be a reefer

vars
	message			: String;
	tCommodity		: CM_Commodity;
	tempMin,tempMax	: Real;
	terminal		: CM_Terminal;
	sizeType		: String;		// CCMS 1007
begin

	terminal := app.getMyTerminalDO_NOT_USE();
	tCommodity := app.myRoot.allCommodities[_container.commodity];
	if tCommodity &lt;&gt; null then
		tempMin := tCommodity.minTemp;
		tempMax := tCommodity.maxTemp;
	endif;
	
	if CM_Container.hasInstance(_container) then					// CCMS 1007
		sizeType := self.sizeTypeString(_container.CM_Container);	// CCMS 1007
	endif;															// CCMS 1007

	message := self.tempString(_container.getTemperature)&amp;
		"         "&amp;//self.tempString(0)&amp;	
		"         "&amp;//self.tempString(0)&amp;	
		"         "&amp;//self.tempString(0)&amp;	
		self.tempString(tempMin)&amp;	
		self.tempString(tempMax)&amp;	
		"         "&amp;//self.rfcHMCString(0)&amp;
		self.ventString(_container.getVentilation)&amp;
		" "&amp;
		" "&amp;
		" "&amp;
		"         "&amp;//self.tempString(0)&amp;
		self.rfcIntervalString(0)&amp;
		_container.operatorCode[1:3]&amp;
		//self.sizeTypeString(_container)&amp;					// CCMS 1007
		sizeType&amp;											// CCMS 1007
		" "&amp;	//FAC_TYPE
		"Y"&amp;	//COM_MODE
		" "&amp;	//ALARM
		_container.remarks.padBlanks(80)[1:80];

//		"N"&amp;	//ALARM	for debug
//		"abcdefghijklmnopqrstuvwxyz0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZzyxwvutsrqponmlkji";	//remarks for debug
	return message;

end;</source>
        <access>protected</access>
        <Parameter name="_container" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="rfcCarrierInfo" id="82084549-63f4-44d5-b07d-704e7b35bcbc">
        <source>rfcCarrierInfo(_container : CM_TrackedItem/*CM_Container*/) : String protected;
// cnwdvb1 29 April 2003 
// 14/12/2009	cnwdap1	Initial creation CCMS MES 1007 Any tracked item can now be a reefer
vars

	message		: String;
	tCommodity	: CM_Commodity;

begin

	message[1:12] := _container.myVoyage.inwardCode;
	message[13:12] := _container.myVoyage.code;
	tCommodity := app.myRoot.allCommodities[_container.commodity];
	if tCommodity &lt;&gt; null then
		message[25:35] := tCommodity.description[1:35];
		//message[25:35] := "com0com1com2com3com4com5com6com7com";		//debug version
	endif;
	return message;

end;</source>
        <access>protected</access>
        <Parameter name="_container" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="rfcHMCString" id="a861d4f9-b162-4cf0-a3fa-a4cf3286e69c">
        <source>rfcHMCString(_hmc:Real) :String protected;

vars
	message: String;
begin

	//message := (_hmc.userNumberFormat($CM_Temperature)&amp;"%").String.padLeftBlanks(9);
	// AER par 14632
	
	message := (_hmc.asStringJMTWithPrecision(PRECISION_TEMPERATURE, false)&amp;"%").String.padLeftBlanks(9);
	return message[1:9];
end;</source>
        <access>protected</access>
