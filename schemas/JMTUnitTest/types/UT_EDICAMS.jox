    <JadeMethod name="tCoarri_PIL" id="e76bb3a3-ba0a-461d-964e-c072c8f77388">
        <updating/>
        <source>tCoarri_PIL()updating;
// cnwrs1
// ---------------------------------------------------------------------------
// Created:     cnwmc5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	VoyageName		= 'UT_VOYAGE';				
	BoatName		= 'UT_VESSEL';
	PortName		= "NZAKL";
	ContainerName1	= 'UTMJ000001';
	ContainerName2	= 'UTMJ000002';
	ContainerName3	= 'UTMJ000003';
	ContainerName4	= 'UTMJ000004';
	ContainerName5	= 'UTMJ000005';
	BlockStackName	= 'BSMC02';
	CamGroup 		= "UT-PIL1";
	CamProtocol 	= "UT_PIL_COARRI";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
vars
	runDateTime : TimeStamp;
	tempStr		: String;
	idx 		: Integer;
	container1, container2, container3, container4, container5 : CM_Container;
	operator, defaultOperator 	: CM_Operator;
	voyage, defaultVoyage 		: CM_Voyage;
	passport 	: CM_Passport;
	bs 			: CM_BlockStack;
	startDateTime 	: TimeStamp;
	endDateTime 	: TimeStamp;
	camGroup 		: CM_CamGroup;
	camProtocol 	: CM_CamProtocol;
	camTaskHistory 	: CM_CamTaskHistory;
	operatorDict 	: CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
//	time 			: Time;
	port 			: CM_Port;
	theSlot 		: CM_LocationsController;
	strs 			: StringArray;
	crane			: CM_Machine;
	timeStamp		: TimeStamp;
	formatedTS		: String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	voyage := self.createVesselVoyage (VoyageName,BoatName,  operator);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((container3.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container3.setLoadPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage.findLocation(strs, false, theSlot, idx);
	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((container4.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container4.setLoadPort ("NZLYT");
	commitTransaction;
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull (port);

	// ### 20 MT
	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	beginTransaction;
	container1.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings ();
	
	self.createVoyageDischargeJobs (voyage, crane.id);
	self.createVoyageLoadJobs (voyage, PortName, crane.id);
	self.planLoadItems (voyage, crane.id);
	self.loadAllJobsToOps(voyage, true);
	self.planDischargeItems(voyage, bs, crane.id);
	self.moveAllCargo (voyage);
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocol		:= self.createCamProtocolCoarri (CamProtocol, camGroup,"PIL Coarri", "NZCHC",operator.code);
	
	beginTransaction;
	camProtocol.setPropertyValue('specialFileName', true);
	commitTransaction;
	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	timeStamp := camTaskHistory.runDateTime.localToUTCTime();
	formatedTS := timeStamp.date.longYearEDI() &amp; timeStamp.time.formatAsHHMMSS();
	
	self.zCheckOutput (camProtocol, camTaskHistory, self.zCoarri_PIL(formatedTS));
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
	delete strs;
	app.setIsBackGroundApp (false);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCoarri_SMDG213Transship" id="b8cab341-f799-433f-8ac3-0ddae0ea732c">
        <updating/>
        <source>tCoarri_SMDG213Transship() updating;
// jlgdap1
/*		Same as tCoarri_StandardTransship except for protocol &amp; output

Date		Name	TFS#		Description
============================================================================
27 Sep 2019	jlgsl4	46608		SNO - tranship details -&gt; segment group 12, with NAD
18 Nov 2019 jlgsl4	47450		SNO - Missing unknown seal in CoarriSMDG213
13 Oct 2020 cnwma1  50021		GPHA -- Extract of segment RFF+BM into a COARRI message
============================================================================*/
constants
	VoyageName1				= 'UT_VOYAGE';				
	ForeignVoyageCodeMSK1 	= 'MSK_VOYAGE';
	ForeignVoyageCodeUTOP1 	= 'UTOP_VOYAGE';
	VoyageName2				= 'UT_VOYAGE2';				
	ForeignVoyageCodeMSK2 	= 'MSK_VOYAGE2';
	ForeignVoyageCodeUTOP2 	= 'UTOP_VOYAGE2';
	BoatName				= 'UT_VESSEL';
	PortName				= "NZAKL";
	Bol1                    = 'BOLUTXT000001';
	Bol2                    = 'BOLUTXT000002';
	Bol3                    = 'BOLUTXT000003';
	Bol4                    = 'BOLUTXT000004';
	ContainerName1			= 'UTXT000001';
	ContainerName2			= 'UTXT000002';
	ContainerName3			= 'UTXT000003';
	ContainerName4			= 'UTXT000004';
	ContainerName5			= 'UTXT000005';
	BlockStackName			= 'BS26728';
	CamGroup 				= "UT-STD";
	CamProtocol 			= "UT_STD_COARRI";
	CamProtocol2 			= "UT_STD_COARRI2";
	SenderCode 				= "UT_SENDER";
	SenderCodeDepot	 		= "UT_SENDERDEPOT";
	ShipperCode 			= "UT_SHIPPER";
	FacilityCode 			= "UT_FACILITY";
	RecipientCode 			= "UT_RECIPIENT";
vars
	runDateTime 		: TimeStamp;
	tempStr				: String;
	idx 				: Integer;
	container1, 
	container2, 
	container3, 
	container4, 
	container5 			: CM_Container;
	operator 			: CM_Operator;
	operatorMSK 		: CM_Operator;
	voyage1 			: CM_Voyage;
	voyage2 			: CM_Voyage;
	defaultVoyage 		: CM_Voyage;
	passport 			: CM_Passport;
	bs 					: CM_BlockStack;
	startDateTime 		: TimeStamp;
	endDateTime 		: TimeStamp;
	camGroup 			: CM_CamGroup;
	camProtocol 		: CM_CamProtocol;
	camTaskHistory 		: CM_CamTaskHistory;
	operatorDict 		: CM_OperatorByCodeDict;
	freightForwarders 	: CM_ConsigneeConsignorSet;
	port 				: CM_Port;
	theSlot 			: CM_LocationsController;
	strs 				: StringArray;
	crane				: CM_Machine;
	strArray 			: HugeStringArray; //jlgka1 TFS 44020
	controller 			: CMIF_TranshipTIController;
	isDoClearanceCheck : Boolean;
	voyageNames : StringArray;
	voyageArray : CM_VoyageArray;
	tiHazard : CM_TIHazard;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	operatorMSK := self.getOperator('MSK');
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	self.deleteEDIInwardXlation(ForeignVoyageCodeUTOP1, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(ForeignVoyageCodeMSK1, XLATION_TYPE_VOYAGETERMINAL, operatorMSK, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, operator, null);

//	self.deleteVoyage(VoyageName1);
//	voyage1 := self.getVoyage(VoyageName1);
//	self.assertIsDeleted(voyage1);
//	voyage1 := self.createVesselVoyage(BoatName, VoyageName1, operatorMSK);
	
	create voyageNames transient;
	voyageNames.add(VoyageName1);
	voyageNames.add(VoyageName2);
	create voyageArray transient;
	self.createVesselVoyages( BoatName, voyageNames, operatorMSK, voyageArray );
	voyage1 := voyageArray[1];
	voyage2 := voyageArray[2];

	self.createEDIXlation(ForeignVoyageCodeUTOP1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	self.createEDIXlation(ForeignVoyageCodeUTOP1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);

	self.createEDIXlation(ForeignVoyageCodeMSK1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operatorMSK, null );	
	self.createEDIXlation(ForeignVoyageCodeMSK1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, false, operatorMSK, null);

	self.deleteEDIInwardXlation(ForeignVoyageCodeUTOP2, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName2, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(ForeignVoyageCodeMSK2, XLATION_TYPE_VOYAGETERMINAL, operatorMSK, null);
	self.deleteEDIOutwardXlation(VoyageName2, XLATION_TYPE_VOYAGETERMINAL, operator, null);

//	self.deleteVoyage(VoyageName2);
//	voyage2 := self.getVoyage(VoyageName2);
//	self.assertIsDeleted(voyage2);
//	voyage2 := self.createVesselVoyage(BoatName, VoyageName2, operatorMSK);

	self.createEDIXlation(ForeignVoyageCodeUTOP2, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	self.createEDIXlation(ForeignVoyageCodeUTOP2, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);

	self.createEDIXlation(ForeignVoyageCodeMSK2, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, true, operatorMSK, null );	
	self.createEDIXlation(ForeignVoyageCodeMSK2, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, false, operatorMSK, null);

	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage1.findLocation(strs, false, theSlot, idx);
	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage1);
	self.assertTrueMsg((container3.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container3.setLoadPort ("NZWEL");
	container3.setSealNumCustoms("CUST003");
	container3.setSealNumOperators("OPER003");
	container3.setSealNumShippers("SHIP003");
	container3.setSealNumVent("VENT003");
	container3.setBOL(Bol3);
	commitTransaction;
	create strArray transient;
	strArray.add("USER1003");
	strArray.add("USER2003");
	strArray.add("USER3003");
	self.addSealTI(strArray, container3, "MATSEAL");
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage1.findLocation(strs, false, theSlot, idx);
	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_REMAINONBOARD, theSlot, port, voyage1);
	self.assertTrueMsg((container4.getImExStatus() =TI_IMEX_STATUS_REMAINONBOARD), "ImEx on Imports is wrong" );
	beginTransaction;
	container4.setLoadPort ("NZLYT");
	container4.setSealNumCustoms("CUST004");
	container4.setSealNumOperators("OPER004");
	container4.setSealNumShippers("SHIP004");
	container4.setSealNumVent("VENT004");
	container4.setBOL(Bol4);
	commitTransaction;
	
	//07 May 2020	NDL	TFS 49211 - Add multiple hazards with multiple dangerous goods codes to check for
	self.addTIHazard ( container4, '3', false );
	tiHazard := container4.allTIHazards.last.CM_TIHazard;
	beginTransaction;
		tiHazard.allUNDGCodes.add ('1169');
		tiHazard.allUNDGCodes.add ('1170');
		tiHazard.allUNDGCodes.add ('1993');
	commitTransaction;
	self.addTIHazard ( container4, '8', false );
	tiHazard := container4.allTIHazards.last.CM_TIHazard;
	beginTransaction;
		tiHazard.allUNDGCodes.add ('1824');
		tiHazard.allUNDGCodes.add ('3265');
		tiHazard.allUNDGCodes.add ('2491');
		tiHazard.allUNDGCodes.add ('3253');
		tiHazard.allUNDGCodes.add ('1791');
		tiHazard.allUNDGCodes.add ('1760');
		tiHazard.allUNDGCodes.add ('3267');
		tiHazard.allUNDGCodes.add ('3262');
		tiHazard.allUNDGCodes.add ('1823');
		tiHazard.allUNDGCodes.add ('2922');
	commitTransaction;
	self.addTIHazard ( container4, '9', false );
	tiHazard := container4.allTIHazards.last.CM_TIHazard;
	beginTransaction;
		tiHazard.allUNDGCodes.add ('3083');
	commitTransaction;
	self.assertTrueMsg( not container4.allTIHazards.isEmpty, "Container does not have hazards");
	
	strArray.clear;
	strArray.add("USER1004");
	strArray.add("USER2004");
	strArray.add("USER3004");
	self.addSealTI(strArray, container4, "MATSEAL");
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull(port);

	//
	// Make the Containers tranship
	//
	create controller transient;

//	container4 := self.getTrackedItemOnVoy(ContainerID4, VoyageName1);
	self.assertNotNull(container4);
	controller.allTrackedItems.add(container4);
	controller.myExportDestPort := app.myRoot.allPorts['NZAKA'];
	controller.myExportDisPort := app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage := voyage2;
	controller.remarks := "UT Tranship";
	// controller.removeStops := true; // TFS 47222 jlgzm1 20/11/2019
	self.makeTrackedItemTranship(controller);
	
	self.assertEqualMsg(container4.getImExStatus, TI_IMEX_STATUS_TRANSHIP, "Tracked item:" &amp; container4.id &amp; " is not Tranship");
	self.assertEqualMsg(container4.myExportVoyage, voyage2, "TI:" &amp; container4.id &amp; " has wrong export voyage");
	self.assertEqualMsg(container4.myImportVoyage, voyage1, "TI:" &amp; container4.id &amp; " has wrong import voyage");
	self.assertEqualMsg(container4.myVoyage, voyage1, "TI:" &amp; container4.id &amp; " myVoyage reference is not the import voyage");

	// ### 20 MT
	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage1);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	beginTransaction;
	container1.setDestinationPort ("NZWEL");
	container1.setBOL(Bol1);
	commitTransaction;
	// ### 20 REEFERS
	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage1);
	beginTransaction;
	container2.setBOL(Bol2);
	commitTransaction;
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage1.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.createVoyageDischargeJobs (voyage1, crane.id);
	self.createVoyageLoadJobs(voyage1, PortName, crane.id);
	self.planLoadItems(voyage1, crane.id);
	self.loadAllJobsToOps(voyage1, true);
	self.planDischargeItems(voyage1, bs, crane.id);
		
	self.moveAllCargo(voyage1);
	beginTransaction; // --&gt; TFS 47450 - add this seal *after* discharge/Receive-Ship - shouldn't be in output...
	container4.setSealNumVent("VENT999");
	commitTransaction; // &lt;-- TFS 47450
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operatorMSK);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	self.opts.addAssoc("useVoyageOp", true);
	camProtocol	:= self.createCamProtocolCoarri (CamProtocol, camGroup, "STANDARD COARRI SMDG213", "NZCHC", operator.code);
	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput (camProtocol, camTaskHistory, self.zCoarri_SMDG213TRANSHIP);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
	delete strs;
	app.setIsBackGroundApp (false);
	delete strArray;
	delete controller;
	delete voyageNames;
	delete voyageArray;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCoarri_Standard" id="ef1f49cb-ba3f-43ff-894b-be621cb6f564">
        <updating/>
        <source>tCoarri_Standard() updating;
// cnwrs1
/* Changes

Date		Name	TFS#		Description
============================================================================
25 May 2017	cnwrs1	TFS 4470
11 Oct 2017	jlgrs1	TFS 7355 SNO muliple seal numbers
05 Jun 2018	jlgsl4	TFS 38884 - SNO - no CAMS output for TIs in Logical Delete areas
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
// 10 Sep 2019	cnwrs1	TFS 46030
============================================================================*/
constants
	VoyageName1				= 'UT_VOYAGE';				
	ForeignVoyageCodeMSK1 	= 'MSK_VOYAGE';
	ForeignVoyageCodeUTOP1 	= 'UTOP_VOYAGE';
	BoatName				= 'UT_VESSEL';
	PortName				= "NZAKL";
	ContainerName1			= 'UTXT000001';
	ContainerName2			= 'UTXT000002';
	ContainerName3			= 'UTXT000003';
	ContainerName4			= 'UTXT000004';
	ContainerName5			= 'UTXT000005';
	BlockStackName			= 'BS26728';
	CamGroup 				= "UT-STD";
	CamProtocol 			= "UT_STD_COARRI";
	CamProtocol2 			= "UT_STD_COARRI2";
	SenderCode 				= "UT_SENDER";
	SenderCodeDepot 		= "UT_SENDERDEPOT";
	ShipperCode 			= "UT_SHIPPER";
	FacilityCode 			= "UT_FACILITY";
	RecipientCode 			= "UT_RECIPIENT";
vars
	runDateTime 		: TimeStamp;
	tempStr				: String;
	idx 				: Integer;
	container1, 
	container2, 
	container3, 
	container4, 
	container5 			: CM_Container;
	operator 			: CM_Operator;
	operatorMSK 		: CM_Operator;
	voyage1 			: CM_Voyage;
	defaultVoyage 		: CM_Voyage;
	passport 			: CM_Passport;
	bs 					: CM_BlockStack;
	startDateTime 		: TimeStamp;
	endDateTime 		: TimeStamp;
	camGroup 			: CM_CamGroup;
	camProtocol 		: CM_CamProtocol;
	camTaskHistory 		: CM_CamTaskHistory;
	operatorDict 		: CM_OperatorByCodeDict;
	freightForwarders 	: CM_ConsigneeConsignorSet;
	port 				: CM_Port;
	theSlot 			: CM_LocationsController;
	strs 				: StringArray;
	crane				: CM_Machine;
	strArray 			: HugeStringArray; //jlgka1 TFS 44020
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	operatorMSK := self.getOperator('MSK');
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	self.deleteEDIInwardXlation(ForeignVoyageCodeUTOP1, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(ForeignVoyageCodeMSK1, XLATION_TYPE_VOYAGETERMINAL, operatorMSK, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, operator, null);

	self.deleteVoyage(VoyageName1);
	voyage1 := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage1);
	voyage1 := self.createVesselVoyage( VoyageName1,BoatName, operatorMSK);

	self.createEDIXlation(ForeignVoyageCodeUTOP1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	self.createEDIXlation(ForeignVoyageCodeUTOP1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);

	self.createEDIXlation(ForeignVoyageCodeMSK1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operatorMSK, null );	
	self.createEDIXlation(ForeignVoyageCodeMSK1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, false, operatorMSK, null);

//	self.createEDIXlation(ForeignVoyageCodeUTOP, VoyageName, XLATION_TYPE_VOYAGETERMINAL, true, operator, null);
//	self.createEDIXlation(ForeignVoyageCodeMSK, VoyageName, XLATION_TYPE_VOYAGETERMINAL, true, operatorMSK, null);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage1.findLocation(strs, false, theSlot, idx);
	self.opts.purge();	//26 Jan 2021	NDL	TFS 50708
	self.opts.addAssoc( UTTI_BOL, "20940687");		//26 Jan 2021	NDL	TFS 50708
	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage1);
	self.assertTrueMsg((container3.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container3.setLoadPort ("NZWEL");
	container3.setSealNumCustoms("CUST003");
	container3.setSealNumOperators("OPER003,OPER103");
	container3.setSealNumShippers("SHIP003,SHIP103,SHIP203");
	container3.setSealNumVent("VENT003");
	commitTransaction;
	create strArray transient;
	strArray.add("USER1003");
	strArray.add("USER2003");
	strArray.add("USER3003");
	self.addSealTI(strArray, container3, "MATSEAL");
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage1.findLocation(strs, false, theSlot, idx);
	self.opts.purge();	//26 Jan 2021	NDL	TFS 50708
	self.opts.addAssoc( UTTI_BOL, "20940688");	//26 Jan 2021	NDL	TFS 50708
	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage1);
	self.assertTrueMsg((container4.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container4.setLoadPort ("NZLYT");
	container4.setSealNumCustoms("CUST004");
	container4.setSealNumOperators("OPER004");
	container4.setSealNumShippers("SHIP004");
	container4.setSealNumVent("VENT004");
	commitTransaction;
	strArray.clear;
	strArray.add("USER1004");
	strArray.add("USER2004");
	strArray.add("USER3004");
	self.addSealTI(strArray, container4, "MATSEAL");
	
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull(port);

	// ### 20 MT
	self.opts.purge();		//26 Jan 2021	NDL	TFS 50708
	self.opts.addAssoc( UTTI_BOL, "20940685");		//26 Jan 2021	NDL	TFS 50708
	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage1);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	beginTransaction;
	container1.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	self.opts.purge();		//26 Jan 2021	NDL	TFS 50708
	self.opts.addAssoc( UTTI_BOL, "20940686");	//26 Jan 2021	NDL	TFS 50708
	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage1);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage1.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.createVoyageDischargeJobs (voyage1, crane.id);
	self.createVoyageLoadJobs(voyage1, PortName, crane.id);
	self.planLoadItems(voyage1, crane.id);
	self.loadAllJobsToOps(voyage1, true);
	self.planDischargeItems(voyage1, bs, crane.id);
	self.moveAllCargo(voyage1);
	
	beginTransaction; // TFS 38884 - set ctr to Deleted, shouldn't appear in output...
		container4.changeState(TI_STATE_DELETED, passport); // TFS 38884
	commitTransaction; // TFS 38884
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operatorMSK);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	self.opts.addAssoc("useVoyageOp", true);
	self.opts.addAssoc('includeRFFBM162', true);	//26 Jan 2021	NDL	TFS 50708
	camProtocol	:= self.createCamProtocolCoarri (CamProtocol, camGroup, "STANDARD COARRI SMDG162", "NZCHC", operator.code);
	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput (camProtocol, camTaskHistory, self.zCoarri_STANDARD);	// par 29517
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
	delete strs;
	app.setIsBackGroundApp (false);
	delete strArray;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCoarri_StandardEvent" id="776128a6-e09e-4cfa-8b56-ef67fac90f0e">
        <updating/>
        <source>tCoarri_StandardEvent() updating;
// cnwrs1
/* Changes

Date		Name	TFS#		Description
============================================================================
06 Jun 2017	cnwrs1	4470 Coarri Event driven
11 Oct 2017	jlgrs1	TFS 7355 SNO muliple seal numbers
06 Jun 2018	jlgsl4	TFS 38884 - SNO - no CAMS output for TIs in Logical Delete areas
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
// 10 Sep 2019	cnwrs1	TFS 46030
============================================================================*/
constants
	VoyageName1				= 'UT_VOYAGE';				
	ForeignVoyageCodeMSK1 	= 'MSK_VOYAGE';
	ForeignVoyageCodeUTOP1 	= 'UTOP_VOYAGE';
	BoatName				= 'UT_VESSEL';
	PortName				= "NZAKL";
	ContainerName1			= 'UTXT000001';
	ContainerName2			= 'UTXT000002';
	ContainerName3			= 'UTXT000003';
	ContainerName4			= 'UTXT000004';
	ContainerName5			= 'UTXT000005';
	BlockStackName			= 'BS26728';
	CamGroup 				= "UT-STD";
	CamProtocol 			= "UT_STD_COARRI";
	CamProtocol2 			= "UT_STD_COARRI2";
	SenderCode 				= "UT_SENDER";
	SenderCodeDepot 		= "UT_SENDERDEPOT";
	ShipperCode 			= "UT_SHIPPER";
	FacilityCode 			= "UT_FACILITY";
	RecipientCode 			= "UT_RECIPIENT";
vars
	runDateTime 		: TimeStamp;
	tempStr				: String;
	idx 				: Integer;
	container1, 
	container2, 
	container3, 
	container4, 
	container5 			: CM_Container;
	operator 			: CM_Operator;
	operatorMSK 		: CM_Operator;
	voyage1 			: CM_Voyage;
	defaultVoyage 		: CM_Voyage;
	passport 			: CM_Passport;
	bs 					: CM_BlockStack;
	startDateTime 		: TimeStamp;
	endDateTime 		: TimeStamp;
	camGroup 			: CM_CamGroup;
	camProtocol 		: CM_CamProtocol;
	camTaskHistory 		: CM_CamTaskHistory;
	operatorDict 		: CM_OperatorByCodeDict;
	freightForwarders 	: CM_ConsigneeConsignorSet;
	port 				: CM_Port;
	theSlot 			: CM_LocationsController;
	strs 				: StringArray;
	crane				: CM_Machine;
	strArray 			: HugeStringArray;	//jlgka1 TFS 44020
	et 					: CM_EventTransaction;
	isDoClearanceCheck : Boolean;
	cmifEventCtrl 		: CMIF_VoyageEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	operatorMSK := self.getOperator('MSK');
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	self.deleteEDIInwardXlation(ForeignVoyageCodeUTOP1, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(ForeignVoyageCodeMSK1, XLATION_TYPE_VOYAGETERMINAL, operatorMSK, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, operator, null);

	self.deleteVoyage(VoyageName1);
	voyage1 := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage1);
	voyage1 := self.createVesselVoyage( VoyageName1,BoatName, operatorMSK);

	self.createEDIXlation(ForeignVoyageCodeUTOP1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	self.createEDIXlation(ForeignVoyageCodeUTOP1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);

	self.createEDIXlation(ForeignVoyageCodeMSK1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operatorMSK, null );	
	self.createEDIXlation(ForeignVoyageCodeMSK1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, false, operatorMSK, null);

//	self.createEDIXlation(ForeignVoyageCodeUTOP, VoyageName, XLATION_TYPE_VOYAGETERMINAL, true, operator, null);
//	self.createEDIXlation(ForeignVoyageCodeMSK, VoyageName, XLATION_TYPE_VOYAGETERMINAL, true, operatorMSK, null);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage1.findLocation(strs, false, theSlot, idx);
	self.opts.purge();	//26 Jan 2021	NDL	TFS 50708
	self.opts.addAssoc( UTTI_BOL, "20940687");		//26 Jan 2021	NDL	TFS 50708
	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage1);
	self.assertTrueMsg((container3.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container3.setLoadPort ("NZWEL");
	container3.setSealNumCustoms("CUST003");
	container3.setSealNumOperators("OPER003,OPER103");
	container3.setSealNumShippers("SHIP003,SHIP103,SHIP203");
	container3.setSealNumVent("VENT003");
	commitTransaction;
	create strArray transient;
	strArray.add("USER1003");
	strArray.add("USER2003");
	strArray.add("USER3003");
	self.addSealTI(strArray, container3, "MATSEAL");
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage1.findLocation(strs, false, theSlot, idx);
	self.opts.purge();	//26 Jan 2021	NDL	TFS 50708
	self.opts.addAssoc( UTTI_BOL, "20940688");	//26 Jan 2021	NDL	TFS 50708
	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage1);
	self.assertTrueMsg((container4.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container4.setLoadPort ("NZLYT");
	container4.setSealNumCustoms("CUST004");
	container4.setSealNumOperators("OPER004");
	container4.setSealNumShippers("SHIP004");
	container4.setSealNumVent("VENT004");
	commitTransaction;
	strArray.clear;
	strArray.add("USER1004");
	strArray.add("USER2004");
	strArray.add("USER3004");
	self.addSealTI(strArray, container4, "MATSEAL");
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull(port);

	// ### 20 MT
	self.opts.purge();		//26 Jan 2021	NDL	TFS 50708
	self.opts.addAssoc( UTTI_BOL, "20940685");		//26 Jan 2021	NDL	TFS 50708
	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage1);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	beginTransaction;
	container1.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	self.opts.purge();		//26 Jan 2021	NDL	TFS 50708
	self.opts.addAssoc( UTTI_BOL, "20940686");	//26 Jan 2021	NDL	TFS 50708
	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage1);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage1.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.createVoyageDischargeJobs (voyage1, crane.id);
	self.createVoyageLoadJobs(voyage1, PortName, crane.id);
	self.planLoadItems(voyage1, crane.id);
	self.loadAllJobsToOps(voyage1, true);
	self.planDischargeItems(voyage1, bs, crane.id);
	self.moveAllCargo(voyage1);
	
	beginTransaction;
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	et := app.createEvent(EVT_VoyageDeparture, app.actualTimeServer, self.getTerminal(), app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
	et.CMEVT_VoyageEvent.setMyVoyage(voyage1);
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	create cmifEventCtrl transient;
	cmifEventCtrl.type := EVT_VoyageDeparture;
	cmifEventCtrl.dateTime := app.actualTimeServer();
	cmifEventCtrl.myTerminal := self.getTerminal();
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVoyage := voyage1;
	
	et := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
	voyage1.setPropertyValue(CM_Voyage::status.name, Voyage_Status_Departed);
	commitTransaction;

	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operatorMSK);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	self.opts.addAssoc("useVoyageOp", true);
	self.opts.addAssoc('includeRFFBM162', true);	//26 Jan 2021	NDL	TFS 50708
	camProtocol	:= self.createCamProtocolCoarri(CamProtocol, camGroup, "STANDARD COARRI SMDG162", "NZCHC", operator.code);
	beginTransaction;
	camProtocol.allTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_VoyageDeparture]);
	commitTransaction;

	beginTransaction; // TFS 38884 - set ctr to Deleted, shouldn't appear in output...
		container4.changeState(TI_STATE_DELETED, passport); // TFS 38884
	commitTransaction; // TFS 38884
	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput (camProtocol, camTaskHistory, self.zCoarri_STANDARD);	// par 29517
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
	delete strs;
	app.setIsBackGroundApp (false);
	delete strArray;
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCoarri_StandardTransship" id="61d74de0-a1cd-4c72-a707-e1e69e30334e">
        <updating/>
        <source>tCoarri_StandardTransship() updating;
// cnwrs1
/* Changes

Date		Name	TFS#		Description
============================================================================
25 May 2017	cnwrs1	TFS 4470
30 Nov 2017 cnwma1  TFS #7780 	SNO - Tranship Discharge needs to use the incoming voyage info
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
// 10 Sep 2019	cnwrs1	TFS 46030
============================================================================*/
constants
	VoyageName1				= 'UT_VOYAGE';				
	ForeignVoyageCodeMSK1 	= 'MSK_VOYAGE';
	ForeignVoyageCodeUTOP1 	= 'UTOP_VOYAGE';
	VoyageName2				= 'UT_VOYAGE2';				
	ForeignVoyageCodeMSK2 	= 'MSK_VOYAGE2';
	ForeignVoyageCodeUTOP2 	= 'UTOP_VOYAGE2';
	BoatName				= 'UT_VESSEL_LONG_NAME_TESTX';  // max 25 chars - TFS 49370
	PortName				= "NZAKL";
	ContainerName1			= 'UTXT000001';
	ContainerName2			= 'UTXT000002';
	ContainerName3			= 'UTXT000003';
	ContainerName4			= 'UTXT000004';
	ContainerName5			= 'UTXT000005';
	BlockStackName			= 'BS26728';
	CamGroup 				= "UT-STD";
	CamProtocol 			= "UT_STD_COARRI";
	CamProtocol2 			= "UT_STD_COARRI2";
	SenderCode 				= "UT_SENDER";
	SenderCodeDepot	 		= "UT_SENDERDEPOT";
	ShipperCode 			= "UT_SHIPPER";
	FacilityCode 			= "UT_FACILITY";
	RecipientCode 			= "UT_RECIPIENT";
vars
	runDateTime 		: TimeStamp;
	tempStr				: String;
	idx 				: Integer;
	container1, 
	container2, 
	container3, 
	container4, 
	container5 			: CM_Container;
	operator 			: CM_Operator;
	operatorMSK 		: CM_Operator;
	voyage1 			: CM_Voyage;
	voyage2 			: CM_Voyage;
	defaultVoyage 		: CM_Voyage;
	passport 			: CM_Passport;
	bs 					: CM_BlockStack;
	startDateTime 		: TimeStamp;
	endDateTime 		: TimeStamp;
	camGroup 			: CM_CamGroup;
	camProtocol 		: CM_CamProtocol;
	camTaskHistory 		: CM_CamTaskHistory;
	operatorDict 		: CM_OperatorByCodeDict;
	freightForwarders 	: CM_ConsigneeConsignorSet;
	port 				: CM_Port;
	theSlot 			: CM_LocationsController;
	strs 				: StringArray;
	crane				: CM_Machine;
	strArray 			: HugeStringArray; //jlgka1 TFS 44020
	controller 			: CMIF_TranshipTIController;
	isDoClearanceCheck : Boolean;
	voyageNames : StringArray;
	voyageArray : CM_VoyageArray;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	operatorMSK := self.getOperator('MSK');
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	self.deleteEDIInwardXlation(ForeignVoyageCodeUTOP1, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(ForeignVoyageCodeMSK1, XLATION_TYPE_VOYAGETERMINAL, operatorMSK, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, operator, null);

//	self.deleteVoyage(VoyageName1);
//	voyage1 := self.getVoyage(VoyageName1);
//	self.assertIsDeleted(voyage1);
//	voyage1 := self.createVesselVoyage(BoatName, VoyageName1, operatorMSK);
	
	create voyageNames transient;
	voyageNames.add(VoyageName1);
	voyageNames.add(VoyageName2);
	create voyageArray transient;
	self.createVesselVoyages( BoatName, voyageNames, operatorMSK, voyageArray );
	voyage1 := voyageArray[1];
	voyage2 := voyageArray[2];

	self.createEDIXlation(ForeignVoyageCodeUTOP1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	self.createEDIXlation(ForeignVoyageCodeUTOP1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);

	self.createEDIXlation(ForeignVoyageCodeMSK1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operatorMSK, null );	
	self.createEDIXlation(ForeignVoyageCodeMSK1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, false, operatorMSK, null);

	self.deleteEDIInwardXlation(ForeignVoyageCodeUTOP2, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName2, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(ForeignVoyageCodeMSK2, XLATION_TYPE_VOYAGETERMINAL, operatorMSK, null);
	self.deleteEDIOutwardXlation(VoyageName2, XLATION_TYPE_VOYAGETERMINAL, operator, null);

//	self.deleteVoyage(VoyageName2);
//	voyage2 := self.getVoyage(VoyageName2);
//	self.assertIsDeleted(voyage2);
//	voyage2 := self.createVesselVoyage(BoatName, VoyageName2, operatorMSK);

	self.createEDIXlation(ForeignVoyageCodeUTOP2, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	self.createEDIXlation(ForeignVoyageCodeUTOP2, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);

	self.createEDIXlation(ForeignVoyageCodeMSK2, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, true, operatorMSK, null );	
	self.createEDIXlation(ForeignVoyageCodeMSK2, VoyageName2, XLATION_TYPE_VOYAGETERMINAL, false, operatorMSK, null);
//	self.createEDIXlation(ForeignVoyageCodeUTOP, VoyageName, XLATION_TYPE_VOYAGETERMINAL, true, operator, null);
//	self.createEDIXlation(ForeignVoyageCodeMSK, VoyageName, XLATION_TYPE_VOYAGETERMINAL, true, operatorMSK, null);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage1.findLocation(strs, false, theSlot, idx);
	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage1);
	self.assertTrueMsg((container3.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container3.setLoadPort ("NZWEL");
	container3.setSealNumCustoms("CUST003");
	container3.setSealNumOperators("OPER003");
	container3.setSealNumShippers("SHIP003");
	container3.setSealNumVent("VENT003");
	commitTransaction;
	create strArray transient;
	strArray.add("USER1003");
	strArray.add("USER2003");
	strArray.add("USER3003");
	self.addSealTI(strArray, container3, "MATSEAL");
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage1.findLocation(strs, false, theSlot, idx);
	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_REMAINONBOARD, theSlot, port, voyage1);
	self.assertTrueMsg((container4.getImExStatus() =TI_IMEX_STATUS_REMAINONBOARD), "ImEx on Imports is wrong" );
	beginTransaction;
	container4.setLoadPort ("NZLYT");
	container4.setSealNumCustoms("CUST004");
	container4.setSealNumOperators("OPER004");
	container4.setSealNumShippers("SHIP004");
	container4.setSealNumVent("VENT004");
	commitTransaction;
	strArray.clear;
	strArray.add("USER1004");
	strArray.add("USER2004");
	strArray.add("USER3004");
	self.addSealTI(strArray, container4, "MATSEAL");
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull(port);

	//
	// Make the Containers tranship
	//
	create controller transient;

//	container4 := self.getTrackedItemOnVoy(ContainerID4, VoyageName1);
	self.assertNotNull(container4);
	controller.allTrackedItems.add(container4);
	controller.myExportDestPort := app.myRoot.allPorts['NZAKA'];
	controller.myExportDisPort := app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage := voyage2;
	controller.remarks := "UT Tranship";
	//controller.removeStops := true; // TFS 47222 jlgzm1 20/11/2019
	self.makeTrackedItemTranship(controller);
	
	self.assertEqualMsg(container4.getImExStatus, TI_IMEX_STATUS_TRANSHIP, "Tracked item:" &amp; container4.id &amp; " is not Tranship");
	self.assertEqualMsg(container4.myExportVoyage, voyage2, "TI:" &amp; container4.id &amp; " has wrong export voyage");
	self.assertEqualMsg(container4.myImportVoyage, voyage1, "TI:" &amp; container4.id &amp; " has wrong import voyage");
	self.assertEqualMsg(container4.myVoyage, voyage1, "TI:" &amp; container4.id &amp; " myVoyage reference is not the import voyage");

	//09 Jun 2020	NDL	TFS 49402
	beginTransaction;
	container4.myTranshipDetail.setPropertyValue(CM_TranshipDetail::importBookingReference.name,"BOOKINWARD");
	commitTransaction;

	// ### 20 MT
	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage1);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	beginTransaction;
	container1.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage1);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage1.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.createVoyageDischargeJobs (voyage1, crane.id);
	self.createVoyageLoadJobs(voyage1, PortName, crane.id);
	self.planLoadItems(voyage1, crane.id);
	self.loadAllJobsToOps(voyage1, true);
	self.planDischargeItems(voyage1, bs, crane.id);
	self.moveAllCargo(voyage1);
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operatorMSK);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	self.opts.addAssoc("useVoyageOp", true);
	camProtocol	:= self.createCamProtocolCoarri (CamProtocol, camGroup, "STANDARD COARRI SMDG162", "NZCHC", operator.code);
	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput (camProtocol, camTaskHistory, self.zCoarri_STANDARDTRANSHIP);	// par 29517
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
	delete strs;
	app.setIsBackGroundApp (false);
	delete strArray;
	delete controller;
	delete voyageNames;
	delete voyageArray;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCoarri_TranshipOperators" id="81346a76-5c30-4aa9-a11a-45c7cd8fb0f5">
        <updating/>
        <source>tCoarri_TranshipOperators() updating;
//
// Purpose:			If a COAARI protocol has Use Voyage Operator, Tranship containers should
//					still show on the Import voyage's COARRI even when the Tranship container
// 					has been taken off the import vessel and the export vessel has an operator
//					that isn't in the operator group for the COARRI protocol
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/04/2020	jlgdap1		Initial creation TFS 49125 SNO COARRI Issue
//
constants
	ImportVoyage = "UT_IMPVOY";
	ExportVoyage = "UT_EXPVOY";
	BoatNameImport = "UT_VESSEL";
	BoatNameExport = "UT_VOYDEPART";
	PortName = "NZAKL";
	ContainerName1 = "UTTS0654321";
	ContainerName2 = "UTTS0654322";
	BlockStackName = 'BS26728';
	CamGroup = "UT_TS";
	CamProtocol = "UT_TSHIP_COARRI";
	SenderCode = "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode = "UT_SHIPPER";
	FacilityCode = "UT_FACILITY";
	RecipientCode = "UT_RECIPIENT";
	
vars
	isDoClearanceCheck : Boolean;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	runDateTime : TimeStamp;
	passport : CM_Passport;
	operatorMSK, operatorANL : CM_Operator;
	crane : CM_Machine;
	bs : CM_BlockStack;
	port : CM_Port;
	importVoyage, exportVoyage : CM_Voyage;
	strs : StringArray;
	container1, container2 : CM_Container;
	theSlot : CM_LocationsController;
	idx : Integer;
	controller: CMIF_TranshipTIController;
	camProtocol : CM_CamProtocol;
	camGroup : CM_CamGroup;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
	et : CM_EventTransaction;
	camTaskHistory : CM_CamTaskHistory;
	cmifEventCtrl : CMIF_VoyageEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operatorMSK := self.getOperator('MSK');
	operatorANL := self.getOperator('ANL');
	self.assertNotNullMsg(operatorMSK, 'Failed to get operator MSK');
	self.assertNotNullMsg(operatorANL, 'Failed to get operator ANL');
	
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// delete and recreate the 2 voyages
	self.deleteVoyage(ImportVoyage);
	importVoyage := self.getVoyage(ImportVoyage);
	self.assertIsDeleted(importVoyage);
	importVoyage := self.createVesselVoyage(ImportVoyage, BoatNameImport, operatorANL);
	
	self.deleteVoyage(ExportVoyage);
	exportVoyage := self.getVoyage(ExportVoyage);
	self.assertIsDeleted(exportVoyage);
	exportVoyage := self.createVesselVoyage(ExportVoyage, BoatNameExport,  operatorMSK);
	self.assertTrueMsg(importVoyage.myOperator = operatorANL, "Import Voyage operator is not ANL");
	self.assertTrueMsg(exportVoyage.myOperator = operatorMSK, "Import Voyage operator is not MSK");
	
	// add ANL as an operator for the export voyage
	beginTransaction;
	exportVoyage.allOperators.add(operatorANL);
	commitTransaction;
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	importVoyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc("operator", operatorANL);
	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, importVoyage);
	self.assertTrueMsg((container1.getImExStatus = TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong");
	self.assertTrueMsg((container1.operatorCode = operatorANL.code), "Operator on Imports is wrong");
	beginTransaction;
	container1.setLoadPort ("NZWEL");
	container1.setSealNumCustoms("CUST003");
	commitTransaction;
	strs.clear;
	strs.add("030684");
	importVoyage.findLocation(strs, false, theSlot, idx);
	container2 := self.addContainerAtLocnDisch(ContainerName2, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, importVoyage);
	self.assertTrueMsg((container1.getImExStatus = TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong");
	self.assertTrueMsg((container1.operatorCode = operatorANL.code), "Operator on Imports is wrong");
	beginTransaction;
	container2.setLoadPort ("NZWEL");
	container2.setSealNumCustoms("CUST003");
	commitTransaction;
	
	// make container 2 a Tranship to the export voyage
	create controller transient;
	controller.allTrackedItems.add(container1);
	controller.myExportDestPort := app.myRoot.allPorts['DEBRE'];
	controller.myExportDisPort := app.myRoot.allPorts['DEBRE'];
	controller.myExportVoyage := exportVoyage;
	controller.remarks := "UT Tranship";
	self.makeTrackedItemTranship(controller);
	self.assertTrueMsg(container1.getImExStatus = TI_IMEX_STATUS_TRANSHIP, "Container 2 is not Tranship");
	
	// discharge colour coding and discharge containers
	app.myTrxUA.trxSetDfltDischargeColourCode(importVoyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.createVoyageDischargeJobs (importVoyage, crane.id);
	self.loadAllJobsToOps(importVoyage, true);
	self.planDischargeItems(importVoyage, bs, crane.id);
	self.moveAllCargo(importVoyage);
	
	// Depart the voyage
	beginTransaction;
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	et := app.createEvent(EVT_VoyageDeparture, app.actualTimeServer, self.getTerminal(), app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
	et.CMEVT_VoyageEvent.setMyVoyage(importVoyage);
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	create cmifEventCtrl transient;
	cmifEventCtrl.type := EVT_VoyageDeparture;
	cmifEventCtrl.dateTime := app.actualTimeServer();
	cmifEventCtrl.myTerminal := self.getTerminal();
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVoyage := importVoyage;
	
	et := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
	importVoyage.setPropertyValue(CM_Voyage::status.name, Voyage_Status_Departed);
	commitTransaction;
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operatorANL);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	self.opts.addAssoc("useVoyageOp", true);
	camProtocol	:= self.createCamProtocolCoarri(CamProtocol, camGroup, "STANDARD COARRI SMDG162", "NZCHC", null);
	beginTransaction;
	camProtocol.allTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_VoyageDeparture]);
	camProtocol.setTranshipImportsVoyageOp(false);
	camProtocol.setPropertyValue(CM_CamProtocol::useTiOperator.name, false);
	commitTransaction;
	
	// run CAMS
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	// check output - should be one container only (the import container)
	self.zCheckOutput(camProtocol, camTaskHistory, self.zCoarri_Tranship_Off);
	
	// now turn on "Include Tranship Imports for Voyage Operator"
	beginTransaction;
	camProtocol.setTranshipImportsVoyageOp(true);
	commitTransaction;
	
	// and run CAMS again 
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	// check output - should include both containers
	self.zCheckOutput(camProtocol, camTaskHistory, self.zCoarri_Tranship_On);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
	delete strs;
	delete controller;
	app.setIsBackGroundApp (false);
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
    </JadeMethod>
    <JadeMethod name="tCodecoMskVGM" id="49624278-7a75-4233-bdd8-cb22de7759b9">
        <source>tCodecoMskVGM();
/*

Date		Who		Reason
19/02/2016	cnwer1	Initial creation PAR
07/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
*/
constants
	CamCodecoTerm	 	= "UT_MSK_CODECO_VGM";
	CamGroup 		= "UT_VGM";
	BS1 			= "BS_VGM";
	Cargo1 			= "VGMEDI0001";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
vars
	strs 			: StringArray;
	
	camProtocol 	: CM_CamProtocol;
	camGroup 		: CM_CamGroup;
	bs : CM_BlockStack;
	operator : CM_Operator;
	 ti : CM_TrackedItem;
	 operators : CM_OperatorByCodeDict;	freightForwarders : CM_ConsigneeConsignorSet;
	 startDateTime 		: TimeStamp;
	endDateTime 		: TimeStamp;
	runDateTime : TimeStamp;
	camTaskHistory		: CM_CamTaskHistory;
	comma : Character;
	expected,
	actual,
	str : String;
	idx : Integer;
begin
	
	self.deleteCamProtocol(CamCodecoTerm);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	operator := app.myRoot.allOperators["MSK"];
	
	create operators transient;
	operators.add(operator);
	create freightForwarders transient;
	
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operators, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	
	// now run CODECO for Teminal
	create strs transient;
	strs.clear;
	strs.add(global.getTiTxnTypeForClass(CM_Weighed).asStringJMT);

	camProtocol		:= self.createCamProtocolCodeco (CamCodecoTerm, camGroup, "Maersk Codeco", "NZCHC", "MSK", strs, true, false);
	self.assertNotNullMsg(camProtocol, 'Failed to create camProtocol');
	

	beginTransaction;
	camProtocol.setPropertyValue("useVGM",true);
	commitTransaction;
	
	//create Ti onsite and weigh the sucker
	
	bs:=self.addBlockStack(BS1,999,null);
	self.assertNotNull(bs);
	
	
	
	ti:=self.addContainerAtLocation(Cargo1,operator,"2200","GENL",TI_IMEX_STATUS_IMPORT,bs);
	
	self.assertNotNull(ti);
	
	self.updateTIWeightToDoTask(ti,null,18000,true,false);
	
	startDateTime.addMinutes(-1);
	
	self.runCamsAdhoc(startDateTime, app.actualTimeServer, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	expected:="UNB+UNOA:2+UT_SENDER+UT_RECIPIENT+160222:1024+0'
UNH+1+CODECO:D:95B:UN:SMDG16'
BGM+VGM+1+9'
TDT+20++1+++++:146::'
LOC+9+DUN:139:6'
NAD+CF+UT_SHIPPER:160:20'
NAD+SLS+NZCHC:172:20'
EQD+CN+VGMEDI0001+0022:102:5++3+5'
DTM+7:201602221024:203'
LOC+165+DUN:160:20'
MEA+AAE+VGM+KGM:18000'
CNT+16:1'
UNT+12+1'
UNZ+1+0'";
	
	self.zCheckOutput(camProtocol,camTaskHistory,expected);
	
epilog
	delete strs;
	delete operators;
	delete freightForwarders;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCodeco_AllFormats_VGM" id="6a9f20fd-7031-4fcf-bd34-b05780dfecaf">
        <updating/>
        <source>tCodeco_AllFormats_VGM() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 31/05/2016	cnwdap1		Initial creation TFS #2061 COARRI/CODECO/COPARN/EDI VGM Updates
// 30/06/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
// 20 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
// 20 Sep 2017	jlgrs1	TFS 7033 Standard CODECO Corrections
//8/04/2019 	JLGNS1	ChangeRequest 39725: JMT - CODECO 00B
// 11 Jun 2019	jlgsl4		TFS 41215 - add pre-road-receive seal to Codeco
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	VoyageName		= 'UT_VOYAGE_VGM';				
	BoatName		= 'UT_VESSEL_VGM';
	DestPort		= "NZZQN";
	DischPort		= "NZAKL";
	ContainerName1	= 'UTUTVGM001';
	ContainerName2	= 'UTUTVGM002';
	ContainerName3	= 'UTUTVGM003';
	ContainerName4	= 'UTUTVGM004';
	BlockStackName	= 'BSVGM';
	CamGroup 		= "UT_GRP";
	CamProtocol 	= "UT_CODECO_2058";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	
	TRUCK	= 'UT_TRUCK';
	DRIVER	= 'UT_DRIVER';
	
vars
	tempStr			: String;
	idx 			: Integer;
	container1, 
	container2, 
	container3, 
	container4 		: CM_Container;
	operator 		: CM_Operator;
	voyage 			: CM_Voyage;
	passport 		: CM_Passport;
	bs 				: CM_BlockStack;
	startDateTime 	: TimeStamp;
	endDateTime 	: TimeStamp;
	camGroup 		: CM_CamGroup;
	camProtocol 	: CM_CamProtocol;
	camTaskHistory 	: CM_CamTaskHistory;
	operatorDict 	: CM_OperatorByCodeDict;
	freightFwdrs 	: CM_ConsigneeConsignorSet;
	port 			: CM_Port;
	theSlot 		: CM_LocationsController;
	strs 			: StringArray;
	crane			: CM_Machine;
	gate			: CM_Gate;
	booking			: CM_BookingRef;
	oldValue,
	autoBol			: Boolean;
	isDoClearanceCheck : Boolean;
begin
	self.setTerminalConfig(ReeferBookingReqsTemp, false);
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.opts.purge();
	self.deleteStopsTable(981);
	self.deleteStopsTable(983);
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	autoBol := self.setTerminalConfig(GateInAutoBOLNumber, false).Boolean;

	beginTransaction;
	oldValue := operator.getConfig (RequiresImportOperatorPIN).Boolean;
	operator.setConfig (RequiresImportOperatorPIN, false);
	commitTransaction;
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	
	self.deleteVehicle (TRUCK);
	
	voyage := self.createVesselVoyage (VoyageName,BoatName,  operator);
	
	// make sure translations don't stuff us up
	self.deleteEDIOutwardXlation (DestPort, XLATION_TYPE_PORT_BYOP, operator, null);
	self.deleteEDIOutwardXlation (DischPort, XLATION_TYPE_PORT_BYOP, operator, null);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	gate := self.getSingleGate;
	self.assertNotNull (gate);

	container1 := self.receiveContainerIntoYard_Road (TRUCK, bs, gate, ContainerName1, operator, "2200", "GENL", voyage, DestPort, DischPort, TI_IMEX_STATUS_EXPORT, null); // TFS 41215
	container2 := self.receiveContainerIntoYard_Road (TRUCK, bs, gate, ContainerName2, operator, "2232", "REEF", voyage, DestPort, DischPort, TI_IMEX_STATUS_EXPORT, null); // TFS 41215
		
	container3 := self.releaseContainerByID_Road (TRUCK, DRIVER, bs, gate, ContainerName3, operator, "2200", "BISC", voyage.code);
	container4 := self.releaseContainerByID_Road (TRUCK, DRIVER, bs, gate, ContainerName4, operator, "4300", "APPL", voyage.code);
	
	beginTransaction;
	container1.setPropertyValue (CM_TrackedItem::totalWeight.name, 12345.Decimal);
	container1.setPropertyValue (CM_TrackedItem::isWeightCertified.name, true);
	//container1.setPropertyValue (CM_TrackedItem::weightCertifiedName.name, "John Weigher");					// TFS 4492
	//container1.setPropertyValue (CM_TrackedItem::weightCertifiedReference.name, "Certified Weighing Ltd");	// TFS 4492
	container1.setMyVGMDetails(	"Certified Weighing Ltd".toUpper, "John Weigher".toUpper, 						// TFS 4492
								null, "SM1", "SM1-DOC-DETAILS", null, null, null, 								// TFS 4492
								null, null, null, 																// TFS 4492
								"25/07/2017 15:30".TimeStamp, "25/07/2017 11:00".TimeStamp, null	); 			// TFS 4492
	
	container3.setPropertyValue (CM_TrackedItem::totalWeight.name, 4000.Decimal);
	container3.setPropertyValue (CM_TrackedItem::isWeightCertified.name, true);
	//container3.setPropertyValue (CM_TrackedItem::weightCertifiedName.name, "Bob Weigher");					// TFS 4492
	//container3.setPropertyValue (CM_TrackedItem::weightCertifiedReference.name, "SOLAS Certified Weighing Ltd");	// TFS 4492
	container3.setMyVGMDetails(	"SOLAS Certified Weighing Ltd".toUpper, "Bob Weigher".toUpper, 					// TFS 4492
								null, "SM2", "SM2-DOC-DETAILS", null, null, null, 								// TFS 4492
								null, null, null, 																// TFS 4492
								"15/07/2017 18:30".TimeStamp, "15/07/2017 08:45".TimeStamp, null	); 			// TFS 4492
	commitTransaction;	

	// create cam group and protocols
	camGroup := self.getCamGroup(CamGroup);
	if camGroup &lt;&gt; null then
		foreach camProtocol in camGroup.protocols do
			self.deleteCamProtocol(camProtocol.code);
		endforeach;
	endif;
	
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightFwdrs transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightFwdrs, 16, ShipperCode);
	self.assertNotNull(camGroup);

	self.opts.addAssoc(CM_CamProtocol::setIncludeExtraVGM.name, true);
	// RUNS CAMS
	self.zRunCAMS (CamProtocol&amp; "_UN", camGroup, "UN/EDIFACT Codeco", operator, self.zCodeco_UN_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_UN+", camGroup, "UN/EDIFACT Codeco", operator, self.zCodeco_UN_plus_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_UN2", camGroup, "UN/EDIFACT Codeco", operator, self.zCodeco_UN2_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_ECN", camGroup, "MOT-ECN CODECO", operator, self.zCodeco_ECN_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_ANL", camGroup, "ANL Codeco", operator, self.zCodeco_ANL_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_CMA", camGroup, "CMA Codeco", operator, self.zCodeco_CMA_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_COL", camGroup, "Columbus Codeco", operator, self.zCodeco_COL_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_CON", camGroup, "ContShip Codeco", operator, self.zCodeco_CON_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_COS", camGroup, "Cosco Codeco", operator, self.zCodeco_COS_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_EUR", camGroup, "UN/EDIFACT Codeco Europe", operator, self.zCodeco_EUR_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_EUR2", camGroup, "UN/EDIFACT Codeco Europe", operator, self.zCodeco_EUR2_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_EUR3", camGroup, "UN/EDIFACT Codeco Europe", operator, self.zCodeco_EUR3_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_HLC", camGroup, "Hapag CODECO", operator, self.zCodeco_HLC_VGM, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_HSD", camGroup, "HSD Codeco", operator, self.zCodeco_HSD_VGM, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_MSC", camGroup, "MSC Codeco", operator, self.zCodeco_MSC_VGM, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_MSK", camGroup, "Maersk Codeco", operator, self.zCodeco_MSK_VGM, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_NYK", camGroup, "NYK Codeco", operator, self.zCodeco_NYK_VGM, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_OOCL", camGroup, "OOCL Codeco", operator, self.zCodeco_OOCL_VGM, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_SWIRE", camGroup, "Swires Codeco", operator, self.zCodeco_SWIRE_VGM, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_ZIM", camGroup, "UN/EDIFACT Codeco Zim", operator, self.zCodeco_ZIM_VGM, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_SNO", camGroup, "STANDARD CODECO SMDG162", operator, self.zCodeco_SNO_VGM, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_213", camGroup, "STANDARD CODECO SMDG213", operator, self.zCodeco_STD213_VGM, false, container1, container2, container3, container4, true );	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	beginTransaction;
	operator.setConfig (RequiresImportOperatorPIN, oldValue);
	commitTransaction;
	self.setTerminalConfig(GateInAutoBOLNumber, autoBol);

	delete operatorDict;
	delete freightFwdrs;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCodeco_AllFormats_VGM2" id="2ebb6b65-4cdf-4efa-b680-2253824f9081">
        <updating/>
        <source>tCodeco_AllFormats_VGM2() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 31/05/2016	cnwdap1		Initial creation TFS #2061 COARRI/CODECO/COPARN/EDI VGM Updates
// 30/06/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
// 20 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
// 20 Sep 2017	jlgrs1	TFS 7033 Standard CODECO Corrections
//8/04/2019 	JLGNS1	ChangeRequest 39725: JMT - CODECO 00B
// 11 Jun 2019	jlgsl4		TFS 41215 - add pre-road-receive seal to Codeco

constants
	VoyageName		= 'UT_VOYAGE_VGM';				
	BoatName		= 'UT_VESSEL_VGM';
	DestPort		= "NZZQN";
	DischPort		= "NZAKL";
	ContainerName1	= 'UTUTVGM001';
	ContainerName2	= 'UTUTVGM002';
	ContainerName3	= 'UTUTVGM003';
	ContainerName4	= 'UTUTVGM004';
	BlockStackName	= 'BSVGM';
	CamGroup 		= "UT_GRP";
	CamProtocol 	= "UT_CODECO_2058";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	
	TRUCK	= 'UT_TRUCK';
	DRIVER	= 'UT_DRIVER';
	
vars
	tempStr			: String;
	idx 			: Integer;
	container1, 
	container2, 
	container3, 
	container4 		: CM_Container;
	operator 		: CM_Operator;
	voyage 			: CM_Voyage;
	passport 		: CM_Passport;
	bs 				: CM_BlockStack;
	startDateTime 	: TimeStamp;
	endDateTime 	: TimeStamp;
	camGroup 		: CM_CamGroup;
	camProtocol 	: CM_CamProtocol;
	camTaskHistory 	: CM_CamTaskHistory;
	operatorDict 	: CM_OperatorByCodeDict;
	freightFwdrs 	: CM_ConsigneeConsignorSet;
	port 			: CM_Port;
	theSlot 		: CM_LocationsController;
	strs 			: StringArray;
	crane			: CM_Machine;
	gate			: CM_Gate;
	booking			: CM_BookingRef;
	oldValue,
	autoBol			: Boolean;
	
begin
	self.setTerminalConfig(ReeferBookingReqsTemp, false);
	self.opts.purge();
	self.deleteStopsTable(981);
	self.deleteStopsTable(983);
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	autoBol := self.setTerminalConfig(GateInAutoBOLNumber, false).Boolean;

	beginTransaction;
	oldValue := operator.getConfig (RequiresImportOperatorPIN).Boolean;
	operator.setConfig (RequiresImportOperatorPIN, false);
	commitTransaction;
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	
	self.deleteVehicle (TRUCK);
	
	voyage := self.createVesselVoyage ( VoyageName, BoatName,operator);
	
	// make sure translations don't stuff us up
	self.deleteEDIOutwardXlation (DestPort, XLATION_TYPE_PORT_BYOP, operator, null);
	self.deleteEDIOutwardXlation (DischPort, XLATION_TYPE_PORT_BYOP, operator, null);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	gate := self.getSingleGate;
	self.assertNotNull (gate);

	container1 := self.receiveContainerIntoYard_Road (TRUCK, bs, gate, ContainerName1, operator, "2200", "GENL", voyage, DestPort, DischPort, TI_IMEX_STATUS_EXPORT, null); // TFS 41215
	container2 := self.receiveContainerIntoYard_Road (TRUCK, bs, gate, ContainerName2, operator, "2232", "REEF", voyage, DestPort, DischPort, TI_IMEX_STATUS_EXPORT, null); // TFS 41215
		
	container3 := self.releaseContainerByID_Road (TRUCK, DRIVER, bs, gate, ContainerName3, operator, "2200", "BISC", voyage.code);
	container4 := self.releaseContainerByID_Road (TRUCK, DRIVER, bs, gate, ContainerName4, operator, "4300", "APPL", voyage.code);
	
	beginTransaction;
	container1.setPropertyValue (CM_TrackedItem::totalWeight.name, 12345.Decimal);
	container1.setPropertyValue (CM_TrackedItem::isWeightCertified.name, true);
	//container1.setPropertyValue (CM_TrackedItem::weightCertifiedName.name, "John Weigher");					// TFS 4492
	//container1.setPropertyValue (CM_TrackedItem::weightCertifiedReference.name, "Certified Weighing Ltd");	// TFS 4492
	container1.setMyVGMDetails(	"Certified Weighing Ltd".toUpper, "John Weigher".toUpper, 						// TFS 4492
								null, "SM1", "SM1-DOC-DETAILS", null, null, null, 								// TFS 4492
								null, null, null, 																// TFS 4492
								"25/07/2017 15:30".TimeStamp, "25/07/2017 11:00".TimeStamp, null	); 			// TFS 4492
	
	container3.setPropertyValue (CM_TrackedItem::totalWeight.name, 4000.Decimal);
	container3.setPropertyValue (CM_TrackedItem::isWeightCertified.name, true);
	//container3.setPropertyValue (CM_TrackedItem::weightCertifiedName.name, "Bob Weigher");					// TFS 4492
	//container3.setPropertyValue (CM_TrackedItem::weightCertifiedReference.name, "SOLAS Certified Weighing Ltd");	// TFS 4492
	container3.setMyVGMDetails(	"SOLAS Certified Weighing Ltd".toUpper, "Bob Weigher".toUpper, 					// TFS 4492
								null, "SM2", "SM2-DOC-DETAILS", null, null, null, 								// TFS 4492
								null, null, null, 																// TFS 4492
								"15/07/2017 18:30".TimeStamp, "15/07/2017 08:45".TimeStamp, null	); 			// TFS 4492
	commitTransaction;	

	// create cam group and protocols
	camGroup := self.getCamGroup(CamGroup);
	if camGroup &lt;&gt; null then
		foreach camProtocol in camGroup.protocols do
			self.deleteCamProtocol(camProtocol.code);
		endforeach;
	endif;
	
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightFwdrs transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightFwdrs, 16, ShipperCode);
	self.assertNotNull(camGroup);

	self.opts.addAssoc(CM_CamProtocol::setIncludeExtraVGM.name, false);
	// RUNS CAMS
	self.zRunCAMS (CamProtocol&amp; "_UN", camGroup, "UN/EDIFACT Codeco", operator, self.zCodeco_UN_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_UN+", camGroup, "UN/EDIFACT Codeco", operator, self.zCodeco_UN_plus_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_UN2", camGroup, "UN/EDIFACT Codeco", operator, self.zCodeco_UN2_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_ECN", camGroup, "MOT-ECN CODECO", operator, self.zCodeco_ECN_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_ANL", camGroup, "ANL Codeco", operator, self.zCodeco_ANL_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_CMA", camGroup, "CMA Codeco", operator, self.zCodeco_CMA_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_COL", camGroup, "Columbus Codeco", operator, self.zCodeco_COL_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_CON", camGroup, "ContShip Codeco", operator, self.zCodeco_CON_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_COS", camGroup, "Cosco Codeco", operator, self.zCodeco_COS_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_EUR", camGroup, "UN/EDIFACT Codeco Europe", operator, self.zCodeco_EUR_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_EUR2", camGroup, "UN/EDIFACT Codeco Europe", operator, self.zCodeco_EUR2_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_EUR3", camGroup, "UN/EDIFACT Codeco Europe", operator, self.zCodeco_EUR3_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_HLC", camGroup, "Hapag CODECO", operator, self.zCodeco_HLC_VGM2, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_HSD", camGroup, "HSD Codeco", operator, self.zCodeco_HSD_VGM2, false, container1, container2, container3, container4, true );
	self.zRunCAMS (CamProtocol&amp; "_MSC", camGroup, "MSC Codeco", operator, self.zCodeco_MSC_VGM2, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_MSK", camGroup, "Maersk Codeco", operator, self.zCodeco_MSK_VGM2, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_NYK", camGroup, "NYK Codeco", operator, self.zCodeco_NYK_VGM2, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_OOCL", camGroup, "OOCL Codeco", operator, self.zCodeco_OOCL_VGM2, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_SWIRE", camGroup, "Swires Codeco", operator, self.zCodeco_SWIRE_VGM2, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_ZIM", camGroup, "UN/EDIFACT Codeco Zim", operator, self.zCodeco_ZIM_VGM2, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_SNO", camGroup, "STANDARD CODECO SMDG162", operator, self.zCodeco_SNO_VGM2, false, container1, container2, container3, container4, true );	
	self.zRunCAMS (CamProtocol&amp; "_213", camGroup, "STANDARD CODECO SMDG213", operator, self.zCodeco_STD213_VGM2, false, container1, container2, container3, container4, true );	

epilog
	beginTransaction;
	operator.setConfig (RequiresImportOperatorPIN, oldValue);
	commitTransaction;
	self.setTerminalConfig(GateInAutoBOLNumber, autoBol);

	delete operatorDict;
	delete freightFwdrs;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCodeco_Barge_Exclusions" id="277a0734-b367-4de7-bcd6-aff7be464cce">
        <updating/>
        <source>tCodeco_Barge_Exclusions() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 14 December 2018
TFS#		: 37102
Function	: 

*** Changes ***
Date			Name		TFS#		Description
8/04/2019 	JLGNS1	ChangeRequest 39725: JMT - CODECO 00B
****************************************************/
constants
	VoyageNameImport 	= 'VOY01TSHIP';
	VoyageNameExport 	= 'VOY02TSHIP';
	ShipNameImport 		= 'IMPSHIP';
	ShipNameExport 		= 'EXPSHIP';
	TestOperator 		= 'MSK';
	UserDefinedTranship	= 'Unit Test Tranship';
	ContainerID1 		= "UTTR0000001";
	ContainerID2 		= "UTTR0000002";
	CamProtocol 		= "UT_STD_CODECO";
	CamProtocol2 		= "UT_STD_CODECO2";
	CamGroup 			= "UT-STD";
	SenderCode 			= "UT_SENDER";
	SenderCodeDepot 	= "UT_SENDERDEPOT";
	ShipperCode 		= "UT_SHIPPER";
	FacilityCode 		= "UT_FACILITY";
	RecipientCode 		= "UT_RECIPIENT";
	ForeignVoyCodeMSK	= 'MSK_VOYAGE';
vars
	voyageImport 		: CM_Voyage;
	voyageExport 		: CM_Voyage;
	vessel 				: CM_Vessel;
	pxyTI, ti			: CM_TrackedItem;
	controller			: CMIF_TranshipTIController;
	locations 			: CM_LCArray;
	ya					: CM_YardAllocation;
	location			: CM_LocationsController;
	ta					: CM_GridArea;
	slots 				: CM_SlotControllerArray;
	tmpLoadCC			: CMIF_LoadColorCode;
	voyageJob 			: CM_VoyageJob;
	tis					: CM_TIArray;
	wlesToMove			: CM_WLEArray;
	wlesWithWarning	 	: CM_WLEArray;
	completedDate 		: TimeStamp;
	job					: CM_Job;
	wle					: CM_WorkListEntry;
	trxn				: CM_TITransaction;
	allowRTS			: Boolean;
	camGroup 			: CM_CamGroup;
	camProtocol 		: CM_CamProtocol;
	camTaskHistory 		: CM_CamTaskHistory;
	operatorDict 		: CM_OperatorByCodeDict;
	freightForwarders 	: CM_ConsigneeConsignorSet;
	operator 			: CM_Operator;
	requiresImportPin	: Boolean;
	startDateTime 		: TimeStamp;
	endDateTime 		: TimeStamp;
	runDateTime 		: TimeStamp;
begin
	startDateTime 	:= app.actualTimeServer;
		
	operator := self.getOperator(TestOperator);
	
	allowRTS := self.setTerminalConfig(AllowRTSwithoutVGM, true).Boolean;
	
	self.deleteEDIInwardXlation(ForeignVoyCodeMSK, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(ForeignVoyCodeMSK, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(VoyageNameImport, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageNameImport, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(VoyageNameExport, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageNameExport, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	
	
	self.deleteVoyage(VoyageNameImport);
	voyageImport := self.getVoyage(VoyageNameImport);
	self.assertIsDeleted(voyageImport);
	
	self.deleteVoyage(VoyageNameExport);
	voyageExport := self.getVoyage(VoyageNameExport);
	self.assertIsDeleted(voyageExport);
	
	self.deleteVessel(ShipNameImport);
	vessel := self.getVessel(ShipNameImport);
	self.assertIsDeleted(vessel);
	
	self.deleteVessel(ShipNameExport);
	vessel := self.getVessel(ShipNameExport);
	self.assertIsDeleted(vessel);
	
	// Create import voyage
	vessel := self.addVesselCellular(ShipNameImport, self.getOperator(TestOperator));
	
	self.assertNotNullMsg(vessel, 'Add import vessel failed');

	// Note: This picks up the profile system Trade eg "Unit Test Trade"
	voyageImport := self.addVoyageWithContainerStructur(VoyageNameImport,
														ShipNameImport,
														TestOperator, 
														self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg(voyageImport, 'Add import voyage failed');
	voyageImport := self.getVoyage(VoyageNameImport);
	self.assertNotNull(voyageImport);

	// Create Export voyage
	vessel := self.addVesselCellular(ShipNameExport, self.getOperator(TestOperator));
	
	self.assertNotNullMsg(vessel, 'Add export vessel failed');

	voyageExport := self.addVoyageWithContainerStructur(VoyageNameExport,
														ShipNameExport,
														TestOperator, 
														self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg(voyageExport, 'Add export voyage failed');
	voyageExport := self.getVoyage(VoyageNameExport);
	self.assertNotNull(voyageExport);
		
	self.createEDIXlation(ForeignVoyCodeMSK, VoyageNameImport, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	self.createEDIXlation(ForeignVoyCodeMSK, VoyageNameImport, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);
	self.createEDIXlation(ForeignVoyCodeMSK, VoyageNameExport, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	self.createEDIXlation(ForeignVoyCodeMSK, VoyageNameExport, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);
	
	
	// create container on import voyage
	self.deleteContainerOnVoyage(ContainerID1, VoyageNameImport);
	
	pxyTI := self.createContainer(ContainerID1, "2010", "FOIL", app.myRoot.allOperators[TestOperator], true);
	pxyTI.setTotalWeight(12000, null, null);
	pxyTI.setWeightTare(2000);
	pxyTI.setDischargePort('NZPOE');
	pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_REMAINONBOARD);
	pxyTI.setMyVoyage(voyageImport, app.myPassport);
	pxyTI.changeState(TI_STATE_ONSHIP, app.myPassport);
	ti := self.addContainerFromProxyToLC(pxyTI, VoyageNameImport&amp;' 010682');
	
	// now make it a tranship
	create controller transient;
	controller.allTrackedItems.add(ti);
	controller.myExportDestPort 	:= app.myRoot.allPorts['NZAKA'];
	controller.myExportDisPort 		:= app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage 		:= voyageExport;
	controller.remarks 				:= "UT Tranship";
	//controller.removeStops 			:= true; // TFS 47222 jlgzm1 20/11/2019
	self.makeTrackedItemTranship(controller);
		
	// test planning the tranship to the export voyage
	// create export voyage job and slots
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType := true;
	tmpLoadCC.myDischargePort := app.myRoot.allPorts["NZAKL"];
	self.getJobSlotControllers(voyageExport.code, "01", DeckOnDeck, 1, 1, 1, slots);
	self.markSlotsAsLoadJob(slots, tmpLoadCC);
	voyageJob := self.addVoyageJob(voyageExport, "CRN1", slots, false);
	assertTrue(voyageJob &lt;&gt; null);
	// plan item
	self.planLoadItem(voyageExport, "CRN1");
	// check voyage is still the import voyage
	assertTrueMsg(ti.myVoyage = ti.myImportVoyage, "planning TI to export voyage - has wrong voyage");
	// unplan the TI
	self.unplanTI(ti);
	// end of planning and unplanning to export voyage
	
	// now plan and move the TI to the yard
	deleteTerminalArea("UTSTRD");
	ta := addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");
	
	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, TestOperator, locations);
	
	location := app.autoPlanTiYA(self.getTerminal, ta, ti);
	self.assertEqualMsg(location, locations.first, "Did not autoplan ti");
	self.opts.purge();																					
	self.opts.addAssoc('isForcedMove', true);															
	self.move(ti, location);
	self.assertEqualMsg(ti.myPrimaryActualLocation, location, "Did not move ti");
	self.assertEqualMsg(ti.myVoyage, voyageExport, "TI myVoyage reference is not the export voyage");
	self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_TRANSHIP, "Tracked item is not Tranship after plan/move off import voyage");
	self.assertEqualMsg(ti.myExportVoyage, voyageExport, "TI has wrong export voyage:2");
	self.assertEqualMsg(ti.myImportVoyage, voyageImport, "TI has wrong import voyage:2");
	self.assertEqualMsg(ti.myVoyageTranshipExport, voyageExport, "TI has wrong myVoyageTranshipExport:2");
	self.assertEqualMsg(ti.myVoyageTranshipImport, voyageImport, "TI has wrong myVoyageTranshipImport:2");
	self.opts.purge();																					
	
	// now plan and move the TI to the export voyage
	// remove stops
	opts.addAssoc("CENum", "123");
	self.deleteStops(ti);
	// mark as ready to ship
	create tis transient;
	voyageExport.allOnsiteTIsByCargoTypeId.copy(tis);
	app.myTrxUA.trxUpdateTIsReadyToShip(tis, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), app.myPassport.getAllErrorsWarningsAsString());
	// plan item
	self.planLoadItem(voyageExport, "CRN1");
	// now move it
	create wlesToMove transient;
	create wlesWithWarning transient;
	foreach job in voyageExport.allVoyageJobs discreteLock do
		if job.CM_VoyageJob.isHatchLidJob() then
			continue;
		endif;
		foreach wle in job.workListEntries discreteLock do
			wlesToMove.clear();
			wlesWithWarning.clear();
			wlesToMove.add(wle);
			app.myTrxUA.trxUpdateWLEsDoMove(wlesToMove, wlesWithWarning, REAL_MODE, true, null,app.myPassport);

			self.assertTrueMsg(wlesWithWarning.isEmpty(), "Not all jobs completed &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
			process.sleep(5000);
		endforeach;
		beginTransaction;
		job.CM_VoyageJob.updateActualAndEndTs(completedDate);
		commitTransaction;
	endforeach;
	self.assertEqualMsg(ti.myVoyage, voyageExport, "TI myVoyage reference is not the export voyage after move to export voyage");
	self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_TRANSHIP, "Tracked item is not Tranship after plan/move on to export voyage");
	self.assertEqualMsg(ti.myExportVoyage, voyageExport, "TI has wrong export voyage:3");
	self.assertEqualMsg(ti.myImportVoyage, voyageImport, "TI has wrong import voyage:3");
	self.assertEqualMsg(ti.myVoyageTranshipExport, voyageExport, "TI has wrong myVoyageTranshipExport:3");
	self.assertEqualMsg(ti.myVoyageTranshipImport, voyageImport, "TI has wrong myVoyageTranshipImport:3");
	
	self.assertEqualMsg(countTransactionsOfType(ti, TRANS_TYPE_REL_SHIP), 1, "No ReleaseShip transaction");		
	foreach trxn in ti.allTransactions do
		if trxn.isKindOf(CM_ReleaseShip) then
			self.assertEqual(trxn.getMyVoyage(), voyageExport);
			self.assertEqual(trxn.voyageCode, voyageExport.code);
		endif;
	endforeach;

	beginTransaction;
	requiresImportPin := operator.getConfig(RequiresImportOperatorPIN).Boolean;
	operator.setConfig(RequiresImportOperatorPIN, false);
	commitTransaction;
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocol := self.createCamProtocolCodecoBarge(CamProtocol, camGroup, "STANDARD CODECO SMDG162", "NZCHC", operator.code, null, true, false);
		
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput(camProtocol, camTaskHistory, self.zCodeco_Barge_Exclusions()); 
epilog
	beginTransaction;
	operator.setConfig(RequiresImportOperatorPIN, requiresImportPin);
	commitTransaction;
	
	delete controller;
	delete locations;
	delete slots;
	delete tmpLoadCC;
	delete tis;
	delete wlesToMove;
	delete wlesWithWarning;
	self.setTerminalConfig(AllowRTSwithoutVGM, allowRTS);
	delete operatorDict;
	delete freightForwarders;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCodeco_Barge_Standard" id="b5a4135e-1043-4f34-9485-165fc6ecc78d">
        <updating/>
        <source>tCodeco_Barge_Standard() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 14 December 2018
TFS#		: 37102
Function	: Standard CODECO that includes barges in 
			  the EDI file.

*** Changes ***
Date			Name		TFS#		Description
8/04/2019 	JLGNS1	ChangeRequest 39725: JMT - CODECO 00B
// 10 Sep 2019	cnwrs1	TFS 46030
****************************************************/
constants
	VoyageNameImport 	= 'VOY01TSHIP';
	VoyageNameExport 	= 'VOY02TSHIP';
	ShipNameImport 		= 'IMPSHIP';
	ShipNameExport 		= 'EXPSHIP';
	TestOperator 		= 'MSK';
	UserDefinedTranship	= 'Unit Test Tranship';
	ContainerID1 		= "UTTR0000001";
	ContainerID2 		= "UTTR0000002";
	CamProtocol 		= "UT_STD_CODECO";
	CamProtocol2 		= "UT_STD_CODECO2";
	CamGroup 			= "UT-STD";
	SenderCode 			= "UT_SENDER";
	SenderCodeDepot 	= "UT_SENDERDEPOT";
	ShipperCode 		= "UT_SHIPPER";
	FacilityCode 		= "UT_FACILITY";
	RecipientCode 		= "UT_RECIPIENT";
	ForeignVoyCodeMSK	= 'MSK_VOYAGE';
vars
	voyageImport 		: CM_Voyage;
	voyageExport 		: CM_Voyage;
	vessel 				: CM_Vessel;
	pxyTI, ti			: CM_TrackedItem;
	controller			: CMIF_TranshipTIController;
	locations 			: CM_LCArray;
	ya					: CM_YardAllocation;
	location			: CM_LocationsController;
	ta					: CM_GridArea;
	slots 				: CM_SlotControllerArray;
	tmpLoadCC			: CMIF_LoadColorCode;
	voyageJob 			: CM_VoyageJob;
	tis					: CM_TIArray;
	wlesToMove			: CM_WLEArray;
	wlesWithWarning	 	: CM_WLEArray;
	completedDate 		: TimeStamp;
	job					: CM_Job;
	wle					: CM_WorkListEntry;
	trxn				: CM_TITransaction;
	allowRTS			: Boolean;
	camGroup 			: CM_CamGroup;
	camProtocol 		: CM_CamProtocol;
	camTaskHistory 		: CM_CamTaskHistory;
	operatorDict 		: CM_OperatorByCodeDict;
	freightForwarders 	: CM_ConsigneeConsignorSet;
	operator 			: CM_Operator;
	requiresImportPin	: Boolean;
	startDateTime 		: TimeStamp;
	endDateTime 		: TimeStamp;
	runDateTime 		: TimeStamp;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	startDateTime 	:= app.actualTimeServer;
		
	operator := self.getOperator(TestOperator);
	
	allowRTS := self.setTerminalConfig(AllowRTSwithoutVGM, true).Boolean;
	
	self.deleteEDIInwardXlation(ForeignVoyCodeMSK, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(ForeignVoyCodeMSK, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(VoyageNameImport, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageNameImport, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(VoyageNameExport, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageNameExport, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	
	
	self.deleteVoyage(VoyageNameImport);
	voyageImport := self.getVoyage(VoyageNameImport);
	self.assertIsDeleted(voyageImport);
	
	self.deleteVoyage(VoyageNameExport);
	voyageExport := self.getVoyage(VoyageNameExport);
	self.assertIsDeleted(voyageExport);
	
	self.deleteVessel(ShipNameImport);
	vessel := self.getVessel(ShipNameImport);
	self.assertIsDeleted(vessel);
	
	self.deleteVessel(ShipNameExport);
	vessel := self.getVessel(ShipNameExport);
	self.assertIsDeleted(vessel);
	
	// Create import voyage
	vessel := self.addVesselCellular(ShipNameImport, self.getOperator(TestOperator));
	
	self.assertNotNullMsg(vessel, 'Add import vessel failed');

	// Note: This picks up the profile system Trade eg "Unit Test Trade"
	voyageImport := self.addVoyageWithContainerStructur(VoyageNameImport,
														ShipNameImport,
														TestOperator, 
														self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg(voyageImport, 'Add import voyage failed');
	voyageImport := self.getVoyage(VoyageNameImport);
	self.assertNotNull(voyageImport);

	// Create Export voyage
	vessel := self.addVesselCellular(ShipNameExport, self.getOperator(TestOperator));
	
	self.assertNotNullMsg(vessel, 'Add export vessel failed');

	voyageExport := self.addVoyageWithContainerStructur(VoyageNameExport,
														ShipNameExport,
														TestOperator, 
														self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg(voyageExport, 'Add export voyage failed');
	voyageExport := self.getVoyage(VoyageNameExport);
	self.assertNotNull(voyageExport);
	beginTransaction;
	voyageExport.isBarge := true;
	commitTransaction;
	
	self.createEDIXlation(ForeignVoyCodeMSK, VoyageNameImport, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	self.createEDIXlation(ForeignVoyCodeMSK, VoyageNameImport, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);
	self.createEDIXlation(ForeignVoyCodeMSK, VoyageNameExport, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	self.createEDIXlation(ForeignVoyCodeMSK, VoyageNameExport, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);
	
	
	// create container on import voyage
	self.deleteContainerOnVoyage(ContainerID1, VoyageNameImport);
	
	pxyTI := self.createContainer(ContainerID1, "2010", "FOIL", app.myRoot.allOperators[TestOperator], true);
	pxyTI.setTotalWeight(12000, null, null);
	pxyTI.setWeightTare(2000);
	pxyTI.setDischargePort('NZPOE');
	pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_REMAINONBOARD);
	pxyTI.setMyVoyage(voyageImport, app.myPassport);
	pxyTI.changeState(TI_STATE_ONSHIP, app.myPassport);
	ti := self.addContainerFromProxyToLC(pxyTI, VoyageNameImport&amp;' 010682');
	
	// now make it a tranship
	create controller transient;
	controller.allTrackedItems.add(ti);
	controller.myExportDestPort 	:= app.myRoot.allPorts['NZAKA'];
	controller.myExportDisPort 		:= app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage 		:= voyageExport;
	controller.remarks 				:= "UT Tranship";
	//controller.removeStops 			:= true; // TFS 47222 jlgzm1 20/11/2019
	self.makeTrackedItemTranship(controller);
		
	// test planning the tranship to the export voyage
	// create export voyage job and slots
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType := true;
	tmpLoadCC.myDischargePort := app.myRoot.allPorts["NZAKL"];
	self.getJobSlotControllers(voyageExport.code, "01", DeckOnDeck, 1, 1, 1, slots);
	self.markSlotsAsLoadJob(slots, tmpLoadCC);
	voyageJob := self.addVoyageJob(voyageExport, "CRN1", slots, false);
	assertTrue(voyageJob &lt;&gt; null);
	// plan item
	self.planLoadItem(voyageExport, "CRN1");
	// check voyage is still the import voyage
	assertTrueMsg(ti.myVoyage = ti.myImportVoyage, "planning TI to export voyage - has wrong voyage");
	// unplan the TI
	self.unplanTI(ti);
	// end of planning and unplanning to export voyage
	
	// now plan and move the TI to the yard
	deleteTerminalArea("UTSTRD");
	ta := addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");
	
	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, TestOperator, locations);
	
	location := app.autoPlanTiYA(self.getTerminal, ta, ti);
	self.assertEqualMsg(location, locations.first, "Did not autoplan ti");
	self.opts.purge();																					
	self.opts.addAssoc('isForcedMove', true);															
	self.move(ti, location);
	self.assertEqualMsg(ti.myPrimaryActualLocation, location, "Did not move ti");
	self.assertEqualMsg(ti.myVoyage, voyageExport, "TI myVoyage reference is not the export voyage");
	self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_TRANSHIP, "Tracked item is not Tranship after plan/move off import voyage");
	self.assertEqualMsg(ti.myExportVoyage, voyageExport, "TI has wrong export voyage:2");
	self.assertEqualMsg(ti.myImportVoyage, voyageImport, "TI has wrong import voyage:2");
	self.assertEqualMsg(ti.myVoyageTranshipExport, voyageExport, "TI has wrong myVoyageTranshipExport:2");
	self.assertEqualMsg(ti.myVoyageTranshipImport, voyageImport, "TI has wrong myVoyageTranshipImport:2");
	self.opts.purge();																					
	
	// now plan and move the TI to the export voyage
	// remove stops
	opts.addAssoc("CENum", "123");
	self.deleteStops(ti);
	// mark as ready to ship
	create tis transient;
	voyageExport.allOnsiteTIsByCargoTypeId.copy(tis);
	app.myTrxUA.trxUpdateTIsReadyToShip(tis, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), app.myPassport.getAllErrorsWarningsAsString());
	// plan item
	self.planLoadItem(voyageExport, "CRN1");
	// now move it
	create wlesToMove transient;
	create wlesWithWarning transient;
	foreach job in voyageExport.allVoyageJobs discreteLock do
		if job.CM_VoyageJob.isHatchLidJob() then
			continue;
		endif;
		foreach wle in job.workListEntries discreteLock do
			wlesToMove.clear();
			wlesWithWarning.clear();
			wlesToMove.add(wle);
			app.myTrxUA.trxUpdateWLEsDoMove(wlesToMove, wlesWithWarning, REAL_MODE, true, null,app.myPassport);

			self.assertTrueMsg(wlesWithWarning.isEmpty(), "Not all jobs completed &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
			process.sleep(5000);
		endforeach;
		beginTransaction;
		job.CM_VoyageJob.updateActualAndEndTs(completedDate);
		commitTransaction;
	endforeach;
	self.assertEqualMsg(ti.myVoyage, voyageExport, "TI myVoyage reference is not the export voyage after move to export voyage");
	self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_TRANSHIP, "Tracked item is not Tranship after plan/move on to export voyage");
	self.assertEqualMsg(ti.myExportVoyage, voyageExport, "TI has wrong export voyage:3");
	self.assertEqualMsg(ti.myImportVoyage, voyageImport, "TI has wrong import voyage:3");
	self.assertEqualMsg(ti.myVoyageTranshipExport, voyageExport, "TI has wrong myVoyageTranshipExport:3");
	self.assertEqualMsg(ti.myVoyageTranshipImport, voyageImport, "TI has wrong myVoyageTranshipImport:3");
	
	self.assertEqualMsg(countTransactionsOfType(ti, TRANS_TYPE_REL_SHIP), 1, "No ReleaseShip transaction");		
	foreach trxn in ti.allTransactions do
		if trxn.isKindOf(CM_ReleaseShip) then
			self.assertEqual(trxn.getMyVoyage(), voyageExport);
			self.assertEqual(trxn.voyageCode, voyageExport.code);
		endif;
	endforeach;

	beginTransaction;
	requiresImportPin := operator.getConfig(RequiresImportOperatorPIN).Boolean;
	operator.setConfig(RequiresImportOperatorPIN, false);
	commitTransaction;
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocol := self.createCamProtocolCodecoBarge(CamProtocol, camGroup, "STANDARD CODECO SMDG162", "NZCHC", operator.code, null, true, false);
		
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput(camProtocol, camTaskHistory, self.zCodeco_Barge_Standard()); 
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	beginTransaction;
	operator.setConfig(RequiresImportOperatorPIN, requiresImportPin);
	commitTransaction;
	
	delete controller;
	delete locations;
	delete slots;
	delete tmpLoadCC;
	delete tis;
	delete wlesToMove;
	delete wlesWithWarning;
	self.setTerminalConfig(AllowRTSwithoutVGM, allowRTS);
	delete operatorDict;
	delete freightForwarders;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCodeco_BulkXlation" id="811aa944-1f1e-4606-b97d-f3b590677368">
        <updating/>
        <source>tCodeco_BulkXlation()updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 11 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
constants
	LocalVoyageCode 	= "UT_VOYXLATION";
	LocalVesselCode 	= "UTSTRA";
	ForeignCode			= "12022022";
	ManifestCode		= "UTMANIFEST";
	ContainerName1		= 'UTOP000001';
	ContainerName2		= 'UTOP000002';
	ContainerName3		= 'UTOP000003';
	ContainerName4		= 'UTOP000004';
	TRUCK				= 'UT_TRUCK';
	BlockStackName		= 'BS53181';
	DestPort			= "NZZQN";
	DischPort			= "NZAKL";
	DRIVER				= 'UT_DRIVER';
	CamGroup 			= "UT-STD";
	CamProtocol 		= "UT_STD_CODECO_BULK";
	SenderCode 			= "UT_SENDER";
	SenderCodeDepot 	= "UT_SENDERDEPOT";
	ShipperCode 		= "UT_SHIPPER";
	FacilityCode 		= "UT_FACILITY";
	RecipientCode 		= "UT_RECIPIENT";
vars
	runDateTime 		: TimeStamp;
	voyage 				: CM_Voyage;
	vessel 				: CM_Vessel;	
	isDoClearanceCheck 	: Boolean;
	bs 					: CM_BlockStack;
	startDateTime 		: TimeStamp;
	endDateTime 		: TimeStamp;
	passport 			: CM_Passport;
	crane				: CM_Machine;
	container1 			: CM_Container;
	container2 			: CM_Container;
	container3 			: CM_Container;
	container4 			: CM_Container;
	port 				: CM_Port;
	gate				: CM_Gate;
	operator			: CM_Operator;	
	camGroup 			: CM_CamGroup;
	camProtocol 		: CM_CamProtocol;
	operatorDict 		: CM_OperatorByCodeDict;
	freightForwarders 	: CM_ConsigneeConsignorSet;
	camTaskHistory 		: CM_CamTaskHistory;
	operatorCount		: Integer;		
begin
	self.setTerminalConfig(ReeferBookingReqsTemp, false);
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
		
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;	
	
	self.createVoyageVessel(LocalVoyageCode, LocalVesselCode, voyage, vessel);
	
	operator := voyage.allOperators.first;	
	operatorCount := voyage.allOperators.size;
	
	self.assertNotNullMsg(operator, 'Voyage Operator is empty ');
	
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);

	self.deleteVehicle(TRUCK);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	
	//Create Bulk Translations for Voyage
	self.createVoyBulkXlation(ForeignCode, ManifestCode, voyage);
	// it should be x2 as the count for both in and out xlations
	assertEqualMsg(voyage.allXlations.size, operatorCount * 2, "Creating translations per operator failed");
	
	// create terminal area
	bs := self.addBlockStack(BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull(port);
	
	gate := self.getSingleGate;
	self.assertNotNull(gate);
	
	//Create containers
	self.opts.purge();		
	self.opts.addAssoc( UTTI_BOL, "20940705");	
	container1 := self.receiveContainerIntoYard_Road(TRUCK, bs, gate, ContainerName1, operator, "2200", "GENL", voyage, DestPort, DischPort, TI_IMEX_STATUS_EXPORT, "SH01234");
	
	self.opts.purge();		
	self.opts.addAssoc( UTTI_BOL, "20940706");		
	self.receiveContainerIntoYard_Road(TRUCK, bs, gate, ContainerName2, operator, "2232", "REEF", voyage, DestPort, DischPort, TI_IMEX_STATUS_EXPORT, null); 

	self.opts.purge();		
	self.opts.addAssoc( UTTI_BOL, "20940707");	
	self.opts.addAssoc ("DestinationPort", DestPort);
	self.opts.addAssoc ("DischargePort", DischPort);
	container3 := self.releaseContainerByID_Road(TRUCK, DRIVER, bs, gate, ContainerName3, operator, "2200", "BEER", voyage.code);
	
	self.opts.purge();
	self.opts.addAssoc( UTTI_BOL, "20940708");	
	self.opts.addAssoc ("DestinationPort", DestPort);	
	self.opts.addAssoc ("DischargePort", DischPort);	
	container4 := self.releaseContainerByID_Road(TRUCK, DRIVER, bs, gate, ContainerName4, operator, "4300", "MT", voyage.code);
		
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);	
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	 
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocol := self.createCamProtocolCodeco(CamProtocol, camGroup, "STANDARD CODECO SMDG162", "NZCHC", operator.code, null, true, false);
		
	// Standard translations run cams
	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput(camProtocol, camTaskHistory, self.zCodeco_BulkXlation); 	
	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCodeco_BulkXlation213" id="c0e4b797-859c-413d-9147-c74e2976f9b6">
        <updating/>
        <source>tCodeco_BulkXlation213()updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 11 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
constants
	LocalVoyageCode 	= "UT_VOYXLATION";
	LocalVesselCode 	= "UTSTRA";
	ForeignCode			= "12022022";
	ManifestCode		= "UTMANIFEST";
	ContainerName1		= 'UTOP000001';
	ContainerName2		= 'UTOP000002';
	ContainerName3		= 'UTOP000003';
	ContainerName4		= 'UTOP000004';
	TRUCK				= 'UT_TRUCK';
	BlockStackName		= 'BS53181';
	DestPort			= "NZZQN";
	DischPort			= "NZAKL";
	DRIVER				= 'UT_DRIVER';
	CamGroup 			= "UT-STD";
	CamProtocol 		= "UT_STD_CODECO_BULK";
	SenderCode 			= "UT_SENDER";
	SenderCodeDepot 	= "UT_SENDERDEPOT";
	ShipperCode 		= "UT_SHIPPER";
	FacilityCode 		= "UT_FACILITY";
	RecipientCode 		= "UT_RECIPIENT";
vars
	runDateTime 		: TimeStamp;
	voyage 				: CM_Voyage;
	vessel 				: CM_Vessel;	
	isDoClearanceCheck 	: Boolean;
	bs 					: CM_BlockStack;
	startDateTime 		: TimeStamp;
	endDateTime 		: TimeStamp;
	passport 			: CM_Passport;
	crane				: CM_Machine;
	container1 			: CM_Container;
	container2 			: CM_Container;
	container3 			: CM_Container;
	container4 			: CM_Container;
	port 				: CM_Port;
	gate				: CM_Gate;
	operator			: CM_Operator;	
	camGroup 			: CM_CamGroup;
	camProtocol 		: CM_CamProtocol;
	operatorDict 		: CM_OperatorByCodeDict;
	freightForwarders 	: CM_ConsigneeConsignorSet;
	camTaskHistory 		: CM_CamTaskHistory;
	operatorCount		: Integer;		
begin
	self.setTerminalConfig(ReeferBookingReqsTemp, false);
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
		
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;	
	
	self.createVoyageVessel(LocalVoyageCode, LocalVesselCode, voyage, vessel);
	
	operator := voyage.allOperators.first;	
	operatorCount := voyage.allOperators.size;
	
	self.assertNotNullMsg(operator, 'Voyage Operator is empty ');
	
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);

	self.deleteVehicle(TRUCK);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	
	//Create Bulk Translations for Voyage
	self.createVoyBulkXlation(ForeignCode, ManifestCode, voyage);
	// it should be x2 as the count for both in and out xlations
	assertEqualMsg(voyage.allXlations.size, operatorCount * 2, "Creating translations per operator failed");
	
	// create terminal area
	bs := self.addBlockStack(BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull(port);
	
	gate := self.getSingleGate;
	self.assertNotNull(gate);
	
	//Create containers
	self.opts.purge();		
	self.opts.addAssoc( UTTI_BOL, "20940705");	
	container1 := self.receiveContainerIntoYard_Road(TRUCK, bs, gate, ContainerName1, operator, "2200", "GENL", voyage, DestPort, DischPort, TI_IMEX_STATUS_EXPORT, "SH01234");
	
	self.opts.purge();		
	self.opts.addAssoc( UTTI_BOL, "20940706");		
	self.receiveContainerIntoYard_Road(TRUCK, bs, gate, ContainerName2, operator, "2232", "REEF", voyage, DestPort, DischPort, TI_IMEX_STATUS_EXPORT, null); 

	self.opts.purge();		
	self.opts.addAssoc( UTTI_BOL, "20940707");	
	self.opts.addAssoc ("DestinationPort", DestPort);
	self.opts.addAssoc ("DischargePort", DischPort);
	container3 := self.releaseContainerByID_Road(TRUCK, DRIVER, bs, gate, ContainerName3, operator, "2200", "BEER", voyage.code);
	
	self.opts.purge();
	self.opts.addAssoc( UTTI_BOL, "20940708");	
	self.opts.addAssoc ("DestinationPort", DestPort);	
	self.opts.addAssoc ("DischargePort", DischPort);	
	container4 := self.releaseContainerByID_Road(TRUCK, DRIVER, bs, gate, ContainerName4, operator, "4300", "MT", voyage.code);
		
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);	
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	 
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocol := self.createCamProtocolCodeco(CamProtocol, camGroup, "STANDARD CODECO SMDG213", "NZCHC", operator.code, null, true, false);
		
	// Standard translations run cams
	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput(camProtocol, camTaskHistory, self.zCodeco_BulkXlation213); 	
	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete operatorDict;
	delete freightForwarders;
end;
</source>
