    <JadeMethod name="cmbContainers_change" id="29685fb3-b353-4b7a-81ad-3a242af37849">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbContainers_change(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.tblEntry.setValueByControlName(combobox.name,combobox.text);
	self.myCurrentTrackedItem := combobox.itemObject[combobox.listIndex].CM_TrackedItem;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbContainers_click" id="7a9f600f-e5a0-4e13-8a73-97881be0fe62">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbContainers_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.isForCargoEdit then
		return; //row should be disabled but double check
	endif;
	
	self.tblEntry.setValueByControlName(combobox.name,combobox.text);
	self.myCurrentTrackedItem := combobox.itemObject[combobox.listIndex].CM_TrackedItem;

	// Update the navigator
	self.setNavigatorHeading(self.myCurrentTrackedItem.id &amp; "'s Transactions"); 
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
