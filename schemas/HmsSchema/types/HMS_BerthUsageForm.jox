//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.permissionMaint := PmHMSBerthUsageView;
// TFS 2734		self.permissionView := PmHMSBerthUsageView;	
		self.permissionView := PmHMSBerthUsageMaint;
		
