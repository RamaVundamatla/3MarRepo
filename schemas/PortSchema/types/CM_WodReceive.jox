    <JadeMethod name="doActionTaskKnown" id="06ef2ea0-cb3a-4236-9f0c-f63abc763a6a">
        <updating/>
        <source>doActionTaskKnown(_woActionIF: CMIF_WorkOrderAction; _realJob: CM_Job io; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1  ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	ti : CM_TrackedItem;
begin
	inheritMethod(_woActionIF, _realJob, _passport);
	
	if _passport.noErrors then
		
		if self.customExportEntryNumber &lt;&gt; null then
			foreach ti in self.allAvailableTIs discreteLock do	//28.05.2024 navma1 #64224
				app.myUtilityUA.utlUpdateTICEDO (ti, self.customExportEntryNumber, null, true, _passport);
			endforeach;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAdvWOTransactionType" id="1e3c5375-e30d-4c3a-91d9-1d9f0d2fb464">
        <source>getAdvWOTransactionType(transType : Integer): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 October 2022		navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions

*/

vars

begin
	if transType = TRANS_CREATED then
		return TRANS_TYPE_WO_TIREC_CREATED;
	elseif transType = TRANS_UPDATED then
		return TRANS_TYPE_WO_TIREC_UPDATED;
	else
		return TRANS_TYPE_WO_TIREC_COMPLET;
	endif;
epilog

end;</source>
        <Parameter name="transType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
