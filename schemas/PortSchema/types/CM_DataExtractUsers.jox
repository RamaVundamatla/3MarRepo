    <JadeMethod name="initDataExtractFields" id="e30d636f-d276-4f97-954a-14f510b1613b">
        <source>initDataExtractFields(_fields: CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2011	#cnwdz2	 

*/

vars
	fieldName    : String;
begin
	self.extractOrder.clear();
	
	fieldName := CM_User::code.name;	
	self.initDataExtractField(_fields, CM_User.name, null, fieldName, STRING, "User ID", "Unique identification number of JMT user", STRING, "No more than 10 characters and/or digits");
	
	fieldName := CM_User::userName.name;	
	self.initDataExtractField(_fields, CM_User.name, null, fieldName, STRING, "Name", "User name", STRING, "No more than 30 characters and/or digits");
	
	fieldName := CM_User::getStatusDesc.name;	
	self.initDataExtractField(_fields, CM_User.name, null, fieldName, STRING, "Status", "User status", STRING, '"New User", "Enabled Normal", "Suspended - Bad password count exceeded", "Disabled by Administrator"');
	
	fieldName := CM_User::getEmailAddress.name;	
	self.initDataExtractField(_fields, CM_User.name, null, fieldName, STRING, "Email Address", "User's email address", STRING, "Valid email address");
	
	fieldName := CM_User::getOrganisationDesc.name;	
	self.initDataExtractField(_fields, CM_User.name, null, fieldName, STRING, "Organisation Name", "User's organisation name", STRING, "No more than 80 characters and/or digits");

	fieldName := CM_User::getSystemSecurityRoleDesc.name;	
	self.initDataExtractField(_fields, CM_User.name, null, fieldName, STRING, "System Security Role", "User's system security role", STRING, "No more than 30 characters and/or digits");
	
	fieldName := CM_User::getDataAccessCarrierDesc.name;	
	self.initDataExtractField(_fields, CM_User.name, null, fieldName, STRING, "Carrier Data Access", "User's assigned carrier data access", STRING, "No more than 50 characters and/or digits");
	
	fieldName := CM_User::getDataAccessConsigneeDesc.name;	
	self.initDataExtractField(_fields, CM_User.name, null, fieldName, STRING, "Consignee Data Access", "User's assigned consignee consignor data access", STRING, "No more than 50 characters and/or digits");
	
	fieldName := CM_User::getDataAccessOperatorDesc.name;	
	self.initDataExtractField(_fields, CM_User.name, null, fieldName, STRING, "Operator Data Access", "User's assigned operator data access", STRING, "No more than 50 characters and/or digits");
	
	fieldName := CM_User::getDataAccessOrganisationDesc.name;	
	self.initDataExtractField(_fields, CM_User.name, null, fieldName, STRING, "Organisation Data Access", "User's assigned organisation data access", STRING, "No more than 50 characters and/or digits");
	
	
epilog

end;</source>
        <Parameter name="_fields" type="CM_DataExtractFieldSet" usage="input"/>
    </JadeMethod>
</Class>
