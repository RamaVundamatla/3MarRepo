    <JadeMethod name="detectFirstPoint" id="3a64f06c-d776-4c4b-9f06-e347928f5ce9">
        <source>detectFirstPoint(x,y : Real) : Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	xLess, xGreater, yLess, yGreater : Integer;
begin
	
	xLess := self.firstPoint.x - 3;
	xGreater := self.firstPoint.x + 3;
	yLess := self.firstPoint.y - 3;
	yGreater := self.firstPoint.y + 3;
	
	if x.Integer &gt;= xLess and x.Integer &lt;= xGreater
	and y.Integer &gt;= yLess and y.Integer &lt;= yGreater then
		self.frmPoint.mousePointer := Window.MousePointer_Cross;
		return true;
	else
		self.frmPoint.mousePointer := Window.MousePointer_Arrow;
	endif;

	return false;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="detectOtherPoint" id="c7d9ce3c-5e4a-4267-b647-3cad889138b5">
        <updating/>
        <source>detectOtherPoint(x,y : Real) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	idx, xLess, xGreater, yLess, yGreater : Integer;
	thePoint : Point;
	theObject : Object;
	thePointArray : PointArray;
begin
	self.dragPoint1 := null;
	self.dragPoint2 := null;
	self.dragPoint3 := null;
	self.dragPoint1Index := null;
	self.dragPoint2Index := null;
	self.dragPoint3Index := null;
	
	foreach theObject in self.allPoints do : outerLoop
		thePointArray := theObject.CM_LayoutGraphic.pointsPolygon;
		idx := 0;
		foreach thePoint in thePointArray do : innerLoop
			idx := idx + 1;
			if idx mod 2 = 0 then
				xLess := thePoint.x - 3;
				xGreater := thePoint.x + 3;
				yLess := thePoint.y - 3;
				yGreater := thePoint.y + 3;
				
				if x.Integer &gt;= xLess and x.Integer &lt;= xGreater
				and y.Integer &gt;= yLess and y.Integer &lt;= yGreater then
					self.frmPoint.mousePointer := Window.MousePointer_Size;
					self.dragging := true;
					self.theGraphic := theObject.CM_LayoutGraphic;
					if idx - 1 &lt; 1 then					
						self.dragPoint1Index := thePointArray.size - 1;
					else
						self.dragPoint1Index := idx - 1;
					endif;
					self.dragPoint2Index := idx;
					
					if idx = thePointArray.size then
						self.dragPoint3Index := 2;
					elseif idx + 2 &gt;  thePointArray.size then
						self.dragPoint3Index := 1;
					else
						self.dragPoint3Index := idx + 2;
					endif;

					self.dragPoint1 := thePointArray[self.dragPoint1Index];
					self.dragPoint2 := thePointArray[self.dragPoint2Index];
					self.dragPoint3 := thePointArray[self.dragPoint3Index];
					break outerLoop;
				else
					self.frmPoint.mousePointer := Window.MousePointer_Arrow;
				endif;
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseDown" id="e23c6fb4-021c-4323-bf50-a36f5c054202">
        <updating/>
        <source>doFrameMouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpPoints : PointArray;
begin

	self.dragButton := button;
	create tmpPoints transient;
	if self.lastPoint = null and self.frmPoint.mousePointer = Window.MousePointer_Arrow then
		self.firstPoint.set(x.Integer,y.Integer);
		self.lastPoint.set(x.Integer,y.Integer);
		self.frmPoint.drawLine(x,y,x,y,Black);
		create self.theGraphic transient;
	else
		if self.frmPoint.mousePointer = Window.MousePointer_Cross then
			self.frmPoint.dragMode := Window.DragMode_None;
			self.frmPoint.drawLine(self.lastPoint.x,self.lastPoint.y,self.drawLastPoint.x,self.drawLastPoint.y,self.frmPoint.backColor);
			self.frmPoint.drawLine(self.lastPoint.x,self.lastPoint.y,self.firstPoint.x,self.firstPoint.y,Black);
			
			self.theGraphic.pointsPolygon.add(self.lastPoint);
			self.theGraphic.pointsPolygon.add(self.firstPoint);
//			self.thePoints.add(self.lastPoint);
//			self.thePoints.add(self.firstPoint);

			self.allPoints.add(self.theGraphic);
			
			self.theGraphic := null;
			self.lastPoint := null;
			self.firstPoint := null;
		elseif self.frmPoint.mousePointer = Window.MousePointer_Size then
			self.frmPoint.dragMode := Window.DragMode_Drag	;
			if button = Window.MouseButton_Left then
				self.frmPoint.dragCursor := self.picCursor.picture;
			elseif button = Window.MouseButton_Right then
				self.frmPoint.dragCursor := self.picRotate.picture;
			endif;
		elseif self.frmPoint.mousePointer = Window.MousePointer_Arrow then
			self.frmPoint.dragMode := Window.DragMode_None;
			self.frmPoint.drawLine(self.lastPoint.x,self.lastPoint.y,x,y,Black);
//			self.thePoints.add(self.lastPoint);
			self.theGraphic.pointsPolygon.add(self.lastPoint);
			self.lastPoint.set(x.Integer,y.Integer);
//			self.thePoints.add(self.lastPoint);
			self.theGraphic.pointsPolygon.add(self.lastPoint);
		endif;
	endif;
epilog 
	delete tmpPoints;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseDragOver" id="f3b1217b-8a34-4e96-bae7-1af6ecaba251">
        <updating/>
        <source>doFrameMouseDragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	thePoint, fromPoint, toPoint : Point;
	idx : Integer;
	theObject : Object;
	thePointArray,thePointArray2 : PointArray;
	tmpX, tmpY,degree : Real;
begin
	if self.dragButton = Window.MouseButton_Left then
		self.frmPoint.drawLine(self.dragPoint1.x,self.dragPoint1.y,self.dragLastPoint.x,self.dragLastPoint.y,self.frmPoint.backColor);
		self.frmPoint.drawLine(self.dragLastPoint.x,self.dragLastPoint.y,self.dragPoint3.x,self.dragPoint3.y,self.frmPoint.backColor);
		self.drawPoints(self.frmPoint);
		self.frmPoint.drawLine(self.dragPoint1.x,self.dragPoint1.y,x,y,Black);
		self.frmPoint.drawLine(x,y,self.dragPoint3.x,self.dragPoint3.y,Black);
		self.dragLastPoint.set(x.Integer,y.Integer);
	else
		create thePointArray2 transient;
		foreach theObject in self.allPoints do
			thePointArray := theObject.CM_LayoutGraphic.pointsPolygon;
			idx := 0;
			thePointArray2.clear;
			foreach thePoint in thePointArray do
				idx := idx + 1;
				if idx mod 2 = 0 then
					degree := 1;
				else
					degree := -1;
				endif;
				self.rotatePoint(thePoint.x,thePoint.y,tmpX,tmpY,degree.cos(),degree.sin());
								
				thePoint.set(tmpX.Integer,tmpY.Integer);
				thePointArray2.add(thePoint);
			endforeach;
			thePointArray.clear;
			thePointArray2.copy(thePointArray);
		endforeach;
		self.drawPoints(self.frmPoint);
	endif;
epilog 
	delete thePointArray2;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseMove" id="e0978018-1409-4d3c-865e-225cdc4033ee">
        <updating/>
        <source>doFrameMouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if not self.detectFirstPoint(x,y) then
		self.detectOtherPoint(x,y);
	endif;
	
	if self.lastPoint = null then
		self.frmPoint.drawLine(x,y,x,y,Black);
	else
		self.frmPoint.drawLine(self.lastPoint.x,self.lastPoint.y,self.drawLastPoint.x,self.drawLastPoint.y,self.frmPoint.backColor);
		self.drawPoints(self.frmPoint);
		self.frmPoint.drawLine(self.lastPoint.x,self.lastPoint.y,x,y,Black);
		self.drawLastPoint.set(x.Integer,y.Integer);
	endif;


end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFrameMouseUp" id="1def3355-9a76-4582-ac79-b557dd225cfa">
        <updating/>
        <source>doFrameMouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	thePoint : Point;
begin
	if not self.dragging then
		return;
	endif;

	self.dragging := false;
	if button = Window.MouseButton_Right then
/*
		self.theGraphic.pointsPolygon[self.dragPoint1Index] := self.dragPoint1;
		self.theGraphic.pointsPolygon[self.dragPoint2Index] := self.dragPoint2;
		self.theGraphic.pointsPolygon[self.dragPoint3Index] := self.dragPoint3;
		self.frmPoint.clearGraphics();
		self.drawPoints(self.frmPoint);
*/
	elseif button = Window.MouseButton_Left then
		if self.theGraphic = null then
			return;
		endif;
		if self.theGraphic.pointsPolygon.size = 0 then
			return;
		endif;
		thePoint.set(x.Integer, y.Integer);
		// ##############
		// Make an UNDO copy
		self.thePoints.clear;
		self.theGraphic.pointsPolygon.copy(self.thePoints);
		
//		self.theGraphic.pointsPolygon[self.dragPoint1Index] := self.dragPoint1;
		self.theGraphic.pointsPolygon[self.dragPoint2Index] := thePoint;
		if (self.dragPoint2Index + 1) &gt; self.theGraphic.pointsPolygon.size then
			self.theGraphic.pointsPolygon[1] := thePoint;
		else
			self.theGraphic.pointsPolygon[self.dragPoint2Index + 1] := thePoint;
		endif;
//		self.theGraphic.pointsPolygon[self.dragPoint3Index] := self.dragPoint3;
/*
		self.dragPoint1 := null;
		self.dragPoint2 := null;
		self.dragPoint3 := null;
		self.dragPoint1Index := null;
		self.dragPoint2Index := null;
		self.dragPoint3Index := null;
		self.theGraphic := null;
*/
		self.frmPoint.clearGraphics();
		self.drawPoints(self.frmPoint);
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawPoints" id="e5191a4f-a46e-4121-a2ef-cbbb583d9022">
        <updating/>
        <source>drawPoints(_theFrame : Frame input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	thePoint, fromPoint, toPoint : Point;
	idx : Integer;
	theObject : Object;
	thePointArray : PointArray;
begin
	foreach theObject in self.allPoints do
//		thePointArray := theObject.PointArray;
		thePointArray := theObject.CM_LayoutGraphic.pointsPolygon;
		idx := 0;
		foreach thePoint in thePointArray do
			idx := idx + 1;
			if idx mod 2 = 0 then
				toPoint := thePoint;

				_theFrame.drawLine(fromPoint.x,fromPoint.y,toPoint.x,toPoint.y,Black);
			else
				fromPoint := thePoint;
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="_theFrame" type="Frame" usage="input"/>
    </JadeMethod>
