        <access>readonly</access>
    </CompAttribute>
    <JadeMethod name="assignValueSpecial" id="868268b5-04a1-4b84-9141-7ed34cfeb661">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
//11 August 2017	jlgrs1	TFS 5457 Make JMTInternal XML work
//
vars

begin
	if _propName = ETRow_CargoIds or _propName = CM_EDICargoGroupAssign::allCargoIds.name then
		self.setCargoIdsFromString(_processedValue);
		return true;
	else
		return inheritMethod(_propName, _processedValue, _xlationOperator);
	endif;
epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createProxy" id="9205f5e4-ec54-4b6e-a1cf-74f2330f9c39">
        <source>createProxy() : CM_CargoGroupAssignment;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	pxyCgAssign : CM_CargoGroupAssignment;

	obj : Object;
	ediCargoGrpNotified : CM_EDICargoGroupNotified;
//	pxyNotifyCargoGroup : CM_NotifiedCargoGroup;
	pxyCargoGroup : CM_CargoGroup;

begin

	create pxyCgAssign transient;
	pxyCgAssign.setProxy(	self.id,	//_id : String;
							self.allCargoIds,	//_allCargoIds : StringArray;
							self.getMyTerminal	//_myTerminal : CM_Terminal
							);

	foreach obj in self.myAttachedItems do
		ediCargoGrpNotified := obj.CM_EDICargoGroupNotified;
	//	pxyNotifyCargoGroup := ediCargoGrpNotified.createProxy( pxyCgAssign );
		pxyCargoGroup := ediCargoGrpNotified.createProxyCG( pxyCgAssign );
	endforeach;
	
	return pxyCgAssign;

epilog

end;</source>
        <ReturnType type="CM_CargoGroupAssignment"/>
    </JadeMethod>
    <JadeMethod name="delete" id="2d23233a-c5ec-4f92-86bb-15c864448f17">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2015	cnwndl1	Initial creation

*/

vars

begin

	if not self.myAttachedItems.isEmpty then
		self.myAttachedItems.purge();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="e483dfbd-8e5f-454d-912a-ed87e4c15f93">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	str : String;
	retStr : String;
	
begin

	if _attrName = ETRow_CargoIds then
		foreach str in self.allCargoIds do
			if retStr &lt;&gt; null then
				retStr := retStr &amp; ",";
			endif;
			retStr := retStr &amp; str;
		endforeach;
		return retStr;
		
	elseif _attrName = ETRow_Action then
		return self.messageMode;
		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTIDisplayDefName" id="c2cc0ee0-d3aa-43b2-80ab-bac3a96e3223">
        <source>getMyTIDisplayDefName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2015	cnwndl1	Initial creation	Par 36608

*/

vars

begin

	return ETDef_EDIDATACargoGrpAssign;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="4c14cac8-dd92-4554-a43a-0b1c61fe5e0d">
        <source>loadDB(_validateOnly: Boolean; _passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars
	cgAssign,
	pxyCgAssign : CM_CargoGroupAssignment;
	term : CM_Terminal;
	cmObj: CM_Object;
//	localDict : CM_NotifiedCargoGroupByIdDict;
//	pxyNCG : CM_NotifiedCargoGroup;
//	realNCG : CM_NotifiedCargoGroup;
	localCGDict : CM_TIByIdCargoTypeDict;
	pxyCG : CM_TrackedItem;
	realCG : CM_TrackedItem;
begin

	term := self.getMyTerminal;
	self.verifySelf();
	
	if _validateOnly then
		return;
	endif;

	if self.messageMode = self.EDI_ACTION_ADD then
		pxyCgAssign := self.createProxy();
		app.myUtilityCA.utlCreateCGAssignment( pxyCgAssign, cgAssign, _passport);
	
	elseif self.messageMode = self.EDI_ACTION_DELETE then
		if term &lt;&gt; null then
			cgAssign := term.findCargoGroupAssignment( self.id );
			if cgAssign &lt;&gt; null then
				cmObj := cgAssign;
				app.myUtilityDA.utlDeleteCMObject( cmObj, _passport );
			endif;
		endif;
		
	elseif self.messageMode = self.EDI_ACTION_MODIFY then
		if term &lt;&gt; null then
			pxyCgAssign := self.createProxy();
			cgAssign := term.findCargoGroupAssignment( self.id );
			if cgAssign &lt;&gt; null and not cgAssign.isCompleted then
			/*	create localDict transient;
				pxyCgAssign.allNotifiedCargoGroupByIdDict.copy( localDict );
				foreach pxyNCG in localDict do
					pxyNCG.setMyCargoGroupAssignment(cgAssign);
					app.myUtilityCA.utlCreateNotifiedCargoGroup( pxyNCG, realNCG, _passport );
				endforeach; */
				create localCGDict transient;
				pxyCgAssign.getAllCargoGroupsByIdDict( localCGDict );
				foreach pxyCG in localCGDict do
					app.myUtilityCA.utlCreateTrackedItem( pxyCG, realCG, _passport );
					realCG.CM_CargoGroup.setMyCargoGroupAssignment( cgAssign );
				endforeach;
			else
				app.raiseCMException( Exist_cargo_group_assig_modif, null, null );
			endif;
		endif;
		
	endif;
	
epilog

	delete pxyCgAssign;
//	if localDict &lt;&gt; null and not localDict.isEmpty then
//		localDict.purge();
//	endif;
//	delete localDict;
	if localCGDict &lt;&gt; null and not localCGDict.isEmpty then
		localCGDict.purge();
	endif;	
	delete localCGDict;

end;</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCargoIdsFromString" id="45979e2d-f91a-47e9-a3ce-048d47916ad1">
        <updating/>
        <source>setCargoIdsFromString( _str : String )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	strArray : StringArray;

begin

	self.allCargoIds.clear();

	strArray := _str.getTokens();
	if strArray &lt;&gt; null and not strArray.isEmpty then
		strArray.copy( self.allCargoIds );
	endif;

epilog

	delete strArray;

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0d287865-b816-4a49-9d72-b16b696a467b">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2015	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod(_proxyEDITI);
	
	self.allCargoIds.clear();
	if not _proxyEDITI.allCargoIds.isEmpty then
		_proxyEDITI.allCargoIds.copy( self.allCargoIds );
	endif;

epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="a932f124-af51-4455-a120-c9982168c193">
        <source>verifySelf();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	isSelectable : Boolean;
	ediTi : CM_EDITrackedItem;
	edicgn : CM_EDICargoGroupNotified;

begin

	if messageMode &lt;&gt; CM_EDICargoGroupAssign.EDI_ACTION_ADD
	and messageMode &lt;&gt; CM_EDICargoGroupAssign.EDI_ACTION_DELETE
	and messageMode &lt;&gt; CM_EDICargoGroupAssign.EDI_ACTION_MODIFY
	then
		app.raiseCMException1( EDI_Action_Is_Invalid, messageMode, null, null );
		return;
	endif;
	
	if id = null then
		app.raiseCMException( ERR_INVALID_TI_ID, null, null );
		return;
	endif;
	
	//03 Oct 2018	NDL	TFS 39186
	//Not allowed to mix preassigned with selectable in teh same cargo group assignment
	isSelectable := not self.allCargoIds.isEmpty;
	if isSelectable then
		foreach ediTi in self.myAttachedItems do
			edicgn := ediTi.CM_EDICargoGroupNotified;
			if edicgn.isPreAssigned then
				app.raiseCMException1( Not_have_preas_selec_cargo_gro, self.id, null, null );
				return;
			endif;
		endforeach;
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
