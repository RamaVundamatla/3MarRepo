    <JadeMethod name="tblDataShowDataSpecial" id="3b8f0270-2478-4745-9df9-a45c467d7437">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//--------------------------------------------------
// Created:	16 June 2004 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------------
// 19/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
vars
	cargoType : CM_CargoType;	
begin
	inheritMethod(_idxRow, _obj);
	cargoType := _obj.CM_CargoType;
	//if cargoType.id &lt; TI_CargoType_Max then					// PAR #33606
	if cargoType.isSystemCargoBOLType then						// PAR #33606
		self.tblData.accessRow(_idxRow).backColor := CM_DataTable.Color_SystemPink;
	endif;
	
end;</source>
        <Parameter name="_idxRow" type="Integer"/>
