    <JadeMethod name="hasStockMovementsOtherThanMe" id="2d144d80-3e93-444e-a89d-687e723ef74e">
        <source>hasStockMovementsOtherThanMe(_stockMovementBeingDeleted: CM_StockMovement input): Boolean;
// Created by cnwdvb1 on 26 July 2006

vars

begin

	if (self.myStockMovementIn &lt;&gt; null and (self.myStockMovementIn &lt;&gt; _stockMovementBeingDeleted)) or
	   (self.myStockMovementOut &lt;&gt; null and (self.myStockMovementOut &lt;&gt; _stockMovementBeingDeleted)) then
	   	return true;
	endif;
	
	return inheritMethod(_stockMovementBeingDeleted);

end;</source>
        <Parameter name="_stockMovementBeingDeleted" type="CM_StockMovement" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
