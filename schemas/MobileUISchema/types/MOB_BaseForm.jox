    <JadeMethod name="setVehicleMountedScreenSize" id="46f76d5a-bc87-4dc6-8529-e2659ab78785">
        <updating/>
        <source>setVehicleMountedScreenSize() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation
07 OCt 2010 cnwer1  par 25955
*/

vars

begin
	if app.myVMAgent &lt;&gt; null then
		self.allowClose:=false;
	endif;
	if app.isOnDevice() then
		self.maxButton := false;
		self.minButton := false;
		//self.windowState := self.WindowState_Maximized;			// 20/09/2011 cnwmh5 #28217
		// epr par 25955
		if app.myVMAgent &lt;&gt; null then
			self.borderStyle:=BorderStyle_None;
		endif;
	else
		self.maxButton := false;
		self.minButton := true;
		self.borderStyle := BorderStyle_Sizable;
	
		if not self.modal then
			self.getSessionAgent().getLastScreenPosition( left, top, width, height );
			if width &lt;&gt; 0 and height &lt;&gt; 0 then
				self.move( left, top, width, height);
			else
				self.width:=600;
				self.height:=400;
				self.centreWindow;
			endif;
		endif;
		if app.openMaximised then				// 20/09/2011 cnwmh5 #28217
			self.windowState := self.WindowState_Maximized;
		endif;
		self.resize;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setdownForm" id="14e7a0b6-f466-405f-ac31-0ca361381561">
        <updating/>
        <source>setdownForm() updating, protected;
begin
	delete self.myMobileDataAgent;
	
	if not modal then
		app.myMobileGUIAgent.loadPrevForm(self.class);
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupControlFromParent" id="51a53fdc-d5a6-40a6-b64f-e0ff6d1c16e3">
        <source>setupControlFromParent(	_frm: Control input;
						_parentFrame: Window input;
						_topOffset,
						_leftOffset  : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation

*/

vars

begin
	_frm.left:=_leftOffset;
	_frm.top:=_topOffset;
	if _parentFrame.isKindOf(Control) then
		_frm.width:=_parentFrame.Control.clientWidth;
		_frm.height:=_parentFrame.Control.clientHeight - _topOffset;

	elseif _parentFrame.isKindOf(Form) then
		_frm.width:=_parentFrame.Form.clientWidth;
		_frm.height:=_parentFrame.Form.clientHeight -_topOffset;
	endif;
	_frm.parentAspect:=Control.ParentAspect_StretchBoth;
	_frm.borderStyle:=Control.BorderStyle_None;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_frm" type="Control" usage="input"/>
        <Parameter name="_parentFrame" type="Window" usage="input"/>
        <Parameter name="_topOffset" type="Integer"/>
        <Parameter name="_leftOffset" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupControlFromParentHeight" id="308169f0-992e-469e-9856-4799094cc899">
        <source>setupControlFromParentHeight(	_frm: Control input;
						_parentFrame: Window input;
						_topOffset,
						_leftOffset  : Integer;
						_height : Real) protected;
// ---------------------------------------------------------------------------
// Created:     SEPT 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	_frm.left:=_leftOffset;
	_frm.top:=_topOffset;
	if _parentFrame.isKindOf(Control) then
		_frm.width:=_parentFrame.Control.clientWidth;
		_frm.height:=_height;

	elseif _parentFrame.isKindOf(Form) then
		_frm.width:=_parentFrame.Form.clientWidth;
		_frm.height:=_height;
	endif;
	_frm.parentAspect:=Control.ParentAspect_StretchRight;
	_frm.borderStyle:=Control.BorderStyle_None;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_frm" type="Control" usage="input"/>
        <Parameter name="_parentFrame" type="Window" usage="input"/>
        <Parameter name="_topOffset" type="Integer"/>
        <Parameter name="_leftOffset" type="Integer"/>
        <Parameter name="_height" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setupF1Help" id="e40c214b-3c76-486d-9b8d-89fb19c06557">
        <updating/>
        <source>setupF1Help(_margin : Integer) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 June 2010	cnwer1	Initial creation

*/
constants
	Margin = 5;
vars
	theHeight,theWidth : Integer;
	tableDecorator : CMIF_EntTableLikeFormDecorator;
	entTableDef : EntTableDef;
begin
	self.frmF1Help.parentAspect:=Control.ParentAspect_CenterHorz;
	if self.clientWidth &lt; 400 then
		theWidth:=self.clientWidth;
	else
		theWidth:=400;
	endif;
	
	self.frmF1Help.move(0,_margin,theWidth,self.clientHeight - (_margin*2));
	self.frmF1Help.zOrder(1);
	self.btnF1Help.caption:=app.getErrorString(CM_OK);
	
	
	
	theHeight:=self.btnF1Help.getTextHeight(self.btnF1Help.caption);
	theHeight:= theHeight + (Margin *2);
	self.btnF1Help.height:=theHeight;
	self.btnF1Help.parentAspect:=Control.ParentAspect_CenterHorz;//  + Control.ParentAspect_AnchorBottom;
	self.btnF1Help.top:=self.frmF1Help.clientHeight - theHeight - Margin;
	
	self.tblF1Help.move(0,0,self.frmF1Help.clientWidth,self.frmF1Help.clientHeight - self.btnF1Help.clientHeight -Margin);
	
	create tableDecorator transient;
	entTableDef:= app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RTShortcutKeys];
	tableDecorator.initDecorator(null,self.tblF1Help,entTableDef);
	tableDecorator.initTable;
	
	self.tblF1Help.wordWrap:=true;
	self.tblF1Help.autoSize:=Table.AutoSize_Row;
	self.tblF1Help.accessColumn(1).width:=10;
	self.tblF1Help.accessColumn(2).width:=((theWidth-20)*.15).Integer;
	self.tblF1Help.accessColumn(3).width:=((theWidth-20)*.80).Integer;
	self.tblF1Help.accessColumn(4).width:=10;
epilog
	delete tableDecorator;
end;</source>
        <access>protected</access>
        <Parameter name="_margin" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="43ca3d1f-a1ac-4792-97e0-ead6737318de">
        <updating/>
        <source>setupForm() updating, protected;

vars

begin
	self.registerKeyCodes();
	self.setMyMobileDataAgent();	
	self.doApplyScreenColors();
	
	
	if self.doNotCentreWindow then
		//do nothing
	else
		self.centreWindow();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showErrorMessage" id="f2e8130d-97f9-4b8f-87cb-33a16ab08135">
        <source>showErrorMessage(message : String; isError : Boolean) : Boolean;
// Show the message, If the message is not an error (ie it is a warnming),
// then ask user if they want to continue.
// If the user wants to continue, true is returned, otherwise false
begin

	if message = null then
		return false;
	endif;

	if isError then
		app.msgBox(message, app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
	else
		if app.msgBox(message &amp; CrLf &amp; app.getErrorString(DoYouWantToContinue),	app.getErrorString(Warning),
						MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			return true;
		endif;
	endif;
	
	return false;
end;
</source>
        <Parameter name="message" type="String"/>
        <Parameter name="isError" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showF1Help" id="2f36e4a5-3816-4176-9c0e-ef367166683d">
        <updating/>
        <source>showF1Help() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 June 2010	cnwer1	Initial creation

*/

vars
	action : Integer;
	actionDesc : String;
	tableDecorator : CMIF_EntTableLikeFormDecorator;
	entTableDef : EntTableDef;
begin

	self.setupF1Help(30); //cnwrd1 par 24940 9.7.2010 - do resize , again, in case.

	create tableDecorator transient;
	entTableDef:= app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RTShortcutKeys];
	tableDecorator.initDecorator(null,self.tblF1Help,entTableDef);
	tableDecorator.initTable;
	self.addF1HelpAction(tableDecorator,J_key_F1,ETRow_F1);
	self.addF1HelpAction(tableDecorator,J_key_F2,ETRow_F2);
	self.addF1HelpAction(tableDecorator,J_key_F3,ETRow_F3);
	self.addF1HelpAction(tableDecorator,J_key_F4,ETRow_F4);
	self.addF1HelpAction(tableDecorator,J_key_F5,ETRow_F5);
	self.addF1HelpAction(tableDecorator,J_key_F6,ETRow_F6);
	self.addF1HelpAction(tableDecorator,J_key_F7,ETRow_F7);
	self.addF1HelpAction(tableDecorator,J_key_F8,ETRow_F8);
	self.addF1HelpAction(tableDecorator,J_key_F9,ETRow_F9);
	self.addF1HelpAction(tableDecorator,J_key_F10,ETRow_F10);
	
	
	
	//self.enabled := false; //cnwrd1 par 24940 9.7.2010

	self.disableAllControls();
	
	self.frmF1Help.visible:=true;
	self.frmF1Help.enabled := true; //cnwrd1 par 24940 9.7.2010
	self.btnF1Help.enabled := true; //cnwrd1 par 24940 9.7.2010
	self.tblF1Help.enabled := true; //cnwrd1 par 24940 9.7.2010
	self.btnF1Help.setFocus(); //cnwrd1 par 24940 9.7.2010
	
epilog
	delete tableDecorator;
end;</source>
        <access>protected</access>
    </JadeMethod>
