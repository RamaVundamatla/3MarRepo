// ---------------------------------------------------------------------------
// Created:     28 June 2002 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result : Integer;

begin
	if app.isSpecial then
		result := app.msgBox('Do you wish to use test level', null, MsgBox_Yes_No + MsgBox_Question_Mark_Icon);

		if result = MsgBox_Return_Yes then
			app.testLevelLogout();
			return;
		endif;
	endif;
	
	self.doLogoutLogin();
end;
</source>
