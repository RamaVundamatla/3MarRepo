    <JadeMethod name="updateInvCurrencyType" id="e13144d1-3c60-48cb-b0fc-19c6e4af65bf">
        <updating/>
        <source>updateInvCurrencyType(_invoice : CM_Invoice input; _currencyType:CM_CurrencyType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2024	navra1	Initial creation for TFS 57933 Invoice and Invoice Line details that need to be static &lt;&lt;54090&gt;&gt;

*/

vars
	pxyInvoice : CM_Invoice;	
	termsOfTrade:CM_InvoiceTermsOfTrade;
begin

	termsOfTrade := app.myRoot.myRootCompany.allInvoiceTermsOfTrade[_invoice.termsOfTradeCode];

	pxyInvoice := app.createUpdateProxy(_invoice).CM_Invoice;
	
	pxyInvoice.setProxyForCreate(_invoice.bank,
								_invoice.debtor,
								_invoice.getBillingAddress(),
								_invoice.myVoyage,
								_invoice.getInvoiceType(),								
								_invoice.status,
								_invoice.isManual,
								_invoice.myTrackedItem,
								_invoice.myBOL,
								_invoice.myBookingRef,
								_invoice.myCargoGroup,
								_invoice.myReleaseRequest,
								_invoice.category,
								_invoice.purchaseOrderNumber, 
								_invoice.myInvoiceProcess,
								_invoice.allWorkOrders,
								_invoice.narration,
								termsOfTrade,
								_invoice.debtorReference,
								_currencyType,
								_invoice.myLocale,
								_invoice.myAlternativeAddress
								);
								
	app.myTrxUA.trxUpdateInvoice(pxyInvoice, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete pxyInvoice;
end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_currencyType" type="CM_CurrencyType"/>
    </JadeMethod>
