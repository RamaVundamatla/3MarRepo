    <JadeMethod name="getAreaInSquareMetres" id="c2fd2130-1ac7-4c41-801a-4252e9876881">
        <source>getAreaInSquareMetres() : Decimal;
/*
Purpose:			
Date		Who		Reason
22 June 2011	cnwab1	Initial creation
*/

vars
	area : Decimal[12,2];
begin
	if self.areaM2 &lt;&gt; 0 then
		area := self.getAreaOfCoveredPolys(DeckItemLayoutType_Pillar);
		return self.areaM2 - area;
	endif;
	
	if self.myPolygonPixels = null then
		return null;
	else
		return self.myPolygonPixels.calculateArea() / (ROROStructurePixelsPerMetre * ROROStructurePixelsPerMetre);
	endif;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getAreaInSquareMetresDisplay" id="3787c576-b0ea-4fd2-8bc7-7722f92111fc">
        <source>getAreaInSquareMetresDisplay() : String;
/*

Date		Who		Reason
29 November 2013	cnwer1	Initial creation PAR 33065

*/

vars

begin
	return app.getErrorString(Math_Area) &amp; " (m2) " &amp; self.getAreaInSquareMetres().asStringJMTWithPrecision(0,true) &amp;  "";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAreaOfCoveredPolys" id="891dd1e4-4a68-47ba-ad27-6b6120b29e62">
        <source>getAreaOfCoveredPolys(_type : Integer) : Decimal;
/*
Purpose:			
Date		Who		Reason
24 August 2011	cnwab1	Initial creation
*/

vars
	item  : CM_Graphic;
	area : Decimal[12,2];
begin

	foreach item in self.allCoveredPolygons discreteLock do
		if item.CM_DeckItemLayout.type = _type then
			area := area + item.CM_DeckItemLayout.areaM2;
		endif;
	endforeach;
	return area;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getCoveredBy" id="c0d1c318-3092-4721-9891-8c1e3dc20360">
        <source>getCoveredBy(_type : Integer; _checkVisible : Boolean) : CM_DeckItemLayout;
/*
Purpose:			
Date		Who		Reason
07 September 2011	cnwab1	Initial creation
*/

vars
	deckItemlayout : CM_DeckItemLayout;
begin
	deckItemlayout:=self.allCoveringPolygons[_type];
	
	if deckItemlayout = null then
		return null;
	endif;
	
	//epr par 29079 need to check that layoutItem isVisible 
	// In actual mode when the discharge OOTL is complete will set the deckItemLayout visible to false
	if  _checkVisible and not deckItemlayout.isVisible then
		return null;
	endif;
	
	return deckItemlayout;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_checkVisible" type="Boolean"/>
        <ReturnType type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="getCoveredByOOTL" id="6db4851b-b4f1-48ae-860c-074e2ca97c11">
        <source>getCoveredByOOTL(_type : Integer) : CM_DeckItemLayout;
/*
Purpose:		29178	
Date				Who			Reason
MARCH 2012		CNWAB1		Initial creation
*/


vars
	coveringItem : CM_DeckItemLayout;
begin
	coveringItem := self.allCoveringPolygons[_type];
	
	if coveringItem = null then
		return null;
	endif;
	
	if coveringItem.myDeckItem = null then
		return null;
	endif;
	
	if coveringItem.myDeckItem.isOOTL() then
		return coveringItem;
	endif;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_DeckItemLayout"/>
    </JadeMethod>
