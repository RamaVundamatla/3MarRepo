    <JadeMethod name="eraseForStockMovement" id="84098ea2-47f7-43df-997c-12b3ff4a1a1f">
        <updating/>
        <source>eraseForStockMovement(_stockMovementBeingDeleted : CM_StockMovement input; eraseLevel: Integer) updating;

// Created by cnwdvb1 on 26 July 2006

vars

begin

	if (self.myTrackedItem = null and self.myVoyageRelivant = null) and 
		not self.hasStockMovementsOtherThanMe(_stockMovementBeingDeleted) then
		// This has been removed from the tracked item already so safe to delete
		self.erase(eraseLevel);
	endif;

end;</source>
        <Parameter name="_stockMovementBeingDeleted" type="CM_StockMovement" usage="input"/>
        <Parameter name="eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="eraseForTrackedItem" id="5609c047-849f-40ca-bfeb-31081759d10f">
        <updating/>
        <source>eraseForTrackedItem(eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2002 by cnwrs2
//
// Purpose:     If this is a 
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myVoyageRelivant = null  and
	   (not self.hasStockMovements) then
		// This has been removed from the voyage item already so safe to delete
		self.erase(eraseLevel);
	endif;

end;</source>
        <Parameter name="eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="eraseForVoyage" id="85b78d0e-b09e-4664-a3a0-b865630af654">
        <updating/>
        <source>eraseForVoyage(eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2002 by cnwrs2
//
// Purpose:     If this is a 
