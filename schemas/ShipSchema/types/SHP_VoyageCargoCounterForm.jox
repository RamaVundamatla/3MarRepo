    <JadeMethod name="translateForm" id="65463f9e-e752-4235-96bd-3ef1c20de565">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 01 November 2021 10:59:12.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016802, locale);
	btnCargoEnquiry.translateBubbleHelp(Xlat_0016803, locale);
	btnCargoEnquiry.translateCaption(Xlat_0016804, locale);
	btnColorCancel.translateCaption(Xlat_0016805, locale);
	btnColorSave.translateCaption(Xlat_0016806, locale);
	btnRefresh.translateCaption(Xlat_0016807, locale);
	btnSummariseAll.translateBubbleHelp(Xlat_0016808, locale);
	btnSummariseAll.translateCaption(Xlat_0016809, locale);
	btnUserColours.translateBubbleHelp(Xlat_0016810, locale);
	btnUserColours.translateCaption(Xlat_0024548, locale);
	chkArea.translateCaption(Xlat_0016811, locale);
	chkContainerTEU.translateCaption(Xlat_0016812, locale);
	chkContainerTI.translateCaption(Xlat_0016813, locale);
	chkGCCount.translateCaption(Xlat_0016814, locale);
	chkLM.translateCaption(Xlat_0016815, locale);
	chkQty.translateCaption(Xlat_0016816, locale);
	chkVolume.translateCaption(Xlat_0016817, locale);
	chkWeight.translateCaption(Xlat_0016818, locale);
	clrAltRowColour.translateBubbleHelp(Xlat_0016819, locale);
	clrCargoType.translateBubbleHelp(Xlat_0016820, locale);
	clrRowColour.translateBubbleHelp(Xlat_0016821, locale);
	clrTotals.translateBubbleHelp(Xlat_0016822, locale);
	grpContainer.translateCaption(Xlat_0016823, locale);
	grpGeneralCargo.translateCaption(Xlat_0016824, locale);
	grpVoyage.translateCaption(Xlat_0016825, locale);
	lblAltRowColour.translateCaption(Xlat_0016826, locale);
	lblCargoGrouping.translateCaption(Xlat_0016827, locale);
	lblRowColour.translateCaption(Xlat_0016828, locale);
	lblTotals.translateCaption(Xlat_0016829, locale);
	lblUserPref.translateCaption(Xlat_0016830, locale);
	mnuCargoEnqAll.translateCaption(Xlat_0016831, locale);
	mnuCargoEnqSelected.translateCaption(Xlat_0016832, locale);
	mnuSummariseAll2.translateCaption(Xlat_0016833, locale);
