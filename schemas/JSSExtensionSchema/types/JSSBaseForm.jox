    <Constant name="ERROR_TITLE" id="83d5ba67-2fef-4a86-a687-04a51598a76d">
        <source>"Error"</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="aError" id="d9d84435-61b0-40c3-8ab6-db368ddd4082">
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="aObjectEdition" id="a08ac7c4-0baa-48a5-9a44-8a626fadd466">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="displayError" id="30d6a6db-fe36-494a-be11-e5b7c48036ee">
        <updating/>
        <source>displayError() : Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		12 November 2001 by cnwdad1
//
// Purpose:		This method should be invoked after a transaction agent method has
//				been called, preferably from the epilog of the doFormUpdate()
//				method.
//
//				If an error has occurred, then this method will show a message box
//				with the error message, and then reset the form's error property.
//				Note that the form's error property should have been set by the
//				return value of the transaction agent method called that was by
//				the doFormUpdate() method.
//
//				A simple way to use this method would be to inherit the doFormUpdate()
//				method from the epilog of its subclass reimplementation.
//
// Parameters:	None
//
// Returns:		True if there was no error, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aError = null then
		return true;
	else
		app.msgBox(self.aError, self.ERROR_TITLE, MsgBox_Stop_Icon + MsgBox_OK_Only);
		self.aError	:=	null;
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEnableControls" id="c4877d15-5cee-4da1-8af6-abb2f2d0386d">
        <source>doEnableControls() protected;
// --------------------------------------------------------------------------------
// Created:		27 May 2002 by cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormInitialize" id="29dde13c-c971-4a9e-9076-8e2c4de76473">
        <updating/>
        <source>doFormInitialize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		21 November 2001 by cnwdad1
//
// Purpose:		This method should be reimplemented on subclass forms to perform
//				actions that may be performed any number of times during the lifetime
//				of the form instance.  A typical example of this would be to populate
//				or initialize the form's controls, and to synchronize the object(s)
//				being dealt with and store off it's OID.
//
//				Note that this method is already invoked by the "load" event method
//				of this base form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doEnableControls();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="6acc023a-b3b2-419e-a9d6-4421c9e5f1df">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		06 October 2001 by cnwdad1
//
// Purpose:		This method should be reimplemented on subclass forms to perform
//				actions that should only be performed once during the lifetime of
//				the form instance.
//
//				Note that this method is already invoked by the "load" event method
//				of this base form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUnload" id="d06ba479-eabc-497b-ba22-007ef786276a">
        <updating/>
        <source>doFormUnload() updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 November 2001 by cnwdad1
//
// Purpose:		This method should be reimplemented on subclass forms to perform
//				actions that should only be performed when form instance is being
//				unloaded.
//
//				Note that this method is already invoked by the "unload" event method
//				of this base form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.endNotificationForSubscriber(self);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="ad2049c6-71ec-4170-ab7a-ff4ecdcae5cf">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		06 October 2001 by cnwdad1
//
// Purpose:		This method should be reimplemented on subclass forms to call
//				transaction agent methods.
//
//				The epilog of the reimplemented update method should either:
//
//					a) Return the value of the "displayError() method; or
//					b) Inherit the behaviour of this method.
//
// Parameters:	None
//
// Returns:		True if the update was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue	: Boolean;
	
begin
	returnValue	:=	self.displayError();
	
	if returnValue then
		self.doFormInitialize();
	endif;
	
	return returnValue;
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFormValidate" id="906518c8-cb08-430f-ac9e-7a9f46728dd1">
        <updating/>
        <source>doFormValidate(pIsDelete:Boolean):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		06 October 2001 by cnwdad1
//
// Purpose:		This method should be reimplemented on subclass forms to validate
//				the form's contents, typically prior to calling a transaction agent
//				method from the doFormUpdate() method.
//
//				Note that the reimplementation of this method should not contain
//				buisiness rules pertaining to the persistence of data (such rules
//				should be implemented at the model level).
//
// Parameters:	None
//
// Returns:		True if the form's contents are valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRegisterForNotifications" id="a7ee6151-7471-4e62-90e1-b37aeaed4789">
        <source>doRegisterForNotifications() protected;
// --------------------------------------------------------------------------------
// Created:		25 November 2001 by cnwdad1
//
// Purpose:		This method should be reimplemented on subclass forms to register
//				the executing node for notifications of changes to any object(s)
//				that are of interest to the form.
//
//				Note that this method is already invoked by the "load" event method
//				of this base form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowForm" id="e8c882b9-e31c-4673-867a-8c68e8deb75a">
        <source>doShowForm(pTheNewForm:GUIClass input):Form protected;
// --------------------------------------------------------------------------------
// Created:		15 November 2001 by cnwdad1
//
// Purpose:		Use this method to load and display a form.  The method will first
//				check whether an instance of the form already exists, and if so,
//				that instance will be given focus, otherwise a new instance will
//				be created.
//
// Parameters:	pTheNewForm - The Type of the form class to load and display.
//
// Returns:		The existing form instance if one exists, otherwise the newly
//				instantiated form object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theExistingForm	: Form;
	theNewForm		: Form;
	
begin
	theExistingForm	:=	app.getForm(pTheNewForm.name);
	
	if theExistingForm = null then
		create theNewForm as pTheNewForm;
		theExistingForm	:=	theNewForm;
		theNewForm.show();
	else
		theExistingForm.setFocus();
	endif;
	
	return theExistingForm;
end;</source>
        <access>protected</access>
        <Parameter name="pTheNewForm" type="GUIClass" usage="input"/>
        <ReturnType type="Form"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="9c16654c-3fa1-4435-9520-f5d4bc211727">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		19 November 2001 by cnwdad1
//
// Purpose:		This method will print the receiver if the CTRL-P key combination
//				are pressed.
//
// Parameters:	JADE signature.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if shift = 2 then
		if keyCode = J_key_P then
			self.printMe(true);
		endif;
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="248a14d3-ca7b-4dc1-8f7e-d51c539663eb">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		06 October 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doFormLoad();
	self.doFormInitialize();
	self.doRegisterForNotifications();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="printMe" id="d321f0a0-13ab-4779-ab9d-8fe82a2a590b">
        <updating/>
        <source>printMe(pIsLandscape:Boolean) updating;
// -----------------------------------------------------------------------------
// Created:		04 November 2001 by cnwdad1
//
// Purpose:		Prints the receiver form or control, in landscape.
//
// Parameters:	pIsLandScape - A flag to indicate whether to print in landscape.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if pIsLandscape then
		app.printer.setMargins(Print_Landscape, 1, 1, 1, 1);
	else
		app.printer.setMargins(Print_Portrait, 1, 1, 1, 1);
	endif;
	
	app.printer.printActive(self);
	app.printer.close();
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="pIsLandscape" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resynchObjectAndSetEdition" id="fcf9d128-c3fb-4572-83d1-a0592850a319">
        <updating/>
        <source>resynchObjectAndSetEdition(pTheObject:Object) updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 August 2001 by cnwdad2
//
// Purpose:		Resynchronizes the target object and stores its edition
//
// Parameters:	theObject - The object for which to resynch and store the edition
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// --------------------------------------------------------------------------------
/*
	Use of "resynchObject" is preferable to "resynch" as it uses an object that
	is already	resident in cache (self) to resynchronize another object.  This
	is preferable to sending resynch to the object to be resynchronized, as if
	it is not in cache, it will have to be fetched from the server to dispatch
	the resynch method, whereupon it will be marked as obsolete.  If the object
	passed to resynchObject is not in cache, it does nothing.
*/
begin
	if pTheObject = null then
		self.aObjectEdition	:=	0;
	else
		self.aObjectEdition	:=	pTheObject.edition();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="unload" id="aecf10fa-ae63-4afd-a4ab-31b1802de589">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// --------------------------------------------------------------------------------
// Created:		24 November 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doFormUnload();
end;</source>
    </JadeMethod>
</GUIClass>
