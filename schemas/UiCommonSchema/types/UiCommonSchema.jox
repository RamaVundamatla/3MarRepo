    <JadeMethod name="getSelectorForm" id="75dc94bb-2dc5-4204-bd91-11c13b4cef1f">
        <source>getSelectorForm(_launchingForm : CM_BaseForm;
				_menuAction : CMUI_MenuAction input) : CMUI_Selector;
// ---------------------------------------------------------------------------
// Created:     09 March 2004	cnwth2
//
// Purpose:     Should be one selector instance per screen at this point
//				**May need to change to one selector per screen TYPE later??
//			 
// ----------   ----------  --------------------------------------------------
/*
01 Mar 2024 navrv30	Bug 59712: EUP Change of Ownership Other - Data Extract - Unable to extract CM_TrackedItem
*/
vars

	theSelector				: CMUI_Selector;
	userTerminal	        : CM_Terminal;
	
begin
	theSelector := _launchingForm.mySelectorForm;
	if _menuAction &lt;&gt; null then
		_menuAction.setPropertyValue('attr1', null);
		_menuAction.setPropertyValue('param1', null);
	endif;
	
	if theSelector = null then
		if _launchingForm.myTerminal = null then                //01 Mar 2024 navrv30	Bug 59712			
			userTerminal := app.getMyUser().getFirstTerminal(); //01 Mar 2024 navrv30	Bug 59712			
			if userTerminal &lt;&gt; null then
				theSelector := app.loadForm(CMUI_Selector, null, false, false, false, userTerminal, _menuAction).CMUI_Selector;		
			endif;
		else 
			// PAR 21148 theSelector := app.loadForm(CMUI_Selector, null, false, false, false, null, _menuAction).CMUI_Selector;
			theSelector := app.loadForm(CMUI_Selector, null, false, false, false, _launchingForm.myTerminal, _menuAction).CMUI_Selector;
		endif;
		if theSelector = null then
			return null;
		endif;
	endif;
	
	theSelector.myParent := _launchingForm;
	return theSelector;
	
end;</source>
        <Parameter name="_launchingForm" type="CM_BaseForm"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction" usage="input"/>
        <ReturnType type="CMUI_Selector"/>
    </JadeMethod>
    <JadeMethod name="getUserWindow" id="f16c24ad-b2a2-4574-afe1-7e9bad9defeb">
        <source>getUserWindow(_windowName : String; _createIfAbsent : Boolean) : CM_UserWindowForOpen;
// ---------------------------------------------------------------------------
// Created:     06 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// ***************************************************************************
// This is similar to method MobileUISchema::MobileUISchema::getUserWindow.  
// Changes to this method may also need to be done in that method
// ***************************************************************************

vars
	user			: CM_User;
	transUserWindow,
	realUserWindow	: CM_UserWindowForOpen;
begin

	transUserWindow := self.allUserWindows[_windowName].CM_UserWindowForOpen;
	if transUserWindow &lt;&gt; null then
		return transUserWindow;
	endif;
	
	user := self.getMyUser();
	if user = null then
		return null;
	endif;
	
	realUserWindow := user.allUserWindowsForOpen[_windowName];
	if realUserWindow = null then
		if _createIfAbsent then
			create transUserWindow as CM_UserWindowForOpen transient;
			transUserWindow.setProxy(user, 
								_windowName,
								null, null, null, null, null, null);
		else
			return null;
		endif;
	else
		transUserWindow := realUserWindow.cloneSelf(true);
	endif;
	
	self.allUserWindows.add(transUserWindow);
	
	return transUserWindow;
	
end;</source>
        <Parameter name="_windowName" type="String"/>
        <Parameter name="_createIfAbsent" type="Boolean"/>
        <ReturnType type="CM_UserWindowForOpen"/>
    </JadeMethod>
