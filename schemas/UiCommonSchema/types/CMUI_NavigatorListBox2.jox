    </JadeMethod>
    <JadeMethod name="canDo" id="e5cf2c5f-f23e-4a4c-9a0b-9801ddf54cbe">
        <source>canDo(_doWhat : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     10 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	user			: CM_User;
	terminal		: CM_Terminal;
begin
	user := app.getMyUser();
	terminal := self.getTeminalOfCurrentEntity();
	
	if terminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name,'Terminal object is null');
		return false;
	endif;
	
	if not user.canDo(terminal, _doWhat) then
		app.msgBox('You do not have sufficient permission to perform this task','No permission',0);
		return false;
	endif;

	return true;
end;</source>
        <Parameter name="_doWhat" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="9e630710-1b98-44c7-a5e1-61ecfe8b2836">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     07 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.hasPlusMinus := true;
