    <JadeMethod name="getHeightDirections" id="16a61da8-dbc1-4fbf-a6d5-3c28e04081c1">
        <source>getHeightDirections(_dirArray: IntegerArray input);
//----------------------------------------------------------------
//	Created:	19 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	rule				: CM_YADeckingRule;
	idx					: Integer;
	dir					: Integer;
	topHeightForRule	: Boolean;
begin

	if _dirArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'direction array is null');
		return;
	endif;
	
	_dirArray.clear;
	
	foreach idx in 1 to self.getGridArea.heightOfStack do
		//get the relevant rule
		rule := null;
		rule := self.allDeckingRulesIn.getAtKeyLeq(idx);
		topHeightForRule := (idx = rule.heightTo);
		dir := rule.getDirection(topHeightForRule);
		if dir = null then
		//	rule := self.getNextLevelRule(idx, true);
		//	if rule &lt;&gt; null then
		//		topHeightForRule := (idx = rule.heightTo);
		//		_dirArray.add(rule.getDirection(topHeightForRule));
		//	else
				_dirArray.add(null);
		//	endif;
		else
			_dirArray.add(dir);
		endif;
	endforeach;
				
end;</source>
        <Parameter name="_dirArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getLocationCellArray" id="3b8ba053-c56c-4821-96be-e878184e460c">
        <source>getLocationCellArray(_in: Boolean): CM_YALocationCellArray;
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _in then
		return self.allYALocationCellsIn;
	else
		return self.allYALocationCellsOut;
	endif;
end;</source>
        <Parameter name="_in" type="Boolean"/>
        <ReturnType type="CM_YALocationCellArray"/>
    </JadeMethod>
    <JadeMethod name="getNextLevelRule" id="28a59c86-2ebd-4adf-b50d-463631714baf">
        <source>getNextLevelRule(_fromHeight: Integer; _isInRule: Boolean): CM_YADeckingRule;
//----------------------------------------------------------------
//	Created:	18 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridArea	: CM_GridArea;
	rule		: CM_YADeckingRule;
begin

	gridArea := self.getGridArea();
	
	if gridArea = null then
		return null;
	endif;
	
	if gridArea.myYADeckingOptions &lt;&gt; null then
		if _isInRule then
			foreach rule in gridArea.myYADeckingOptions.allDeckingRulesIn do
				if _fromHeight &gt;= rule.heightFrom 
				and _fromHeight &lt;= rule.heightTo then
					return rule;
				endif;
			endforeach;
		else
			foreach rule in gridArea.myYADeckingOptions.allDeckingRulesOut do
				if _fromHeight &gt;= rule.heightFrom 
				and _fromHeight &lt;= rule.heightTo then
					return rule;
				endif;
			endforeach;
		endif;
	endif;
	
	return null;
end;</source>
        <Parameter name="_fromHeight" type="Integer"/>
        <Parameter name="_isInRule" type="Boolean"/>
        <ReturnType type="CM_YADeckingRule"/>
    </JadeMethod>
