    <JadeMethod name="processAttributeDependencies" id="2dbeae71-5629-48f9-a263-17ef494fa548">
        <updating/>
        <source>processAttributeDependencies(_ediUserDefinedAssist : CMIF_EDIUserDefinedAssist input; _strIdentifier : String; _reset : Boolean; _xlationOperator :CM_Operator) updating;
//
// cnwrs1 15 Feb 2010 par 21329 This is called after fieldMapping.assignValue for each user defined attribute
//                              this is used to link attributes together that have a dependancy,
//								it is called after all attributes have been setup
//
// this will normally be overriden by each EDI data as needed,
// when inheriting leave in the inheritMethod as this may end up with some code
// Date				Who		Reason
// 28 Apr 2011		cnwrs1	ccms 2044 - added strIdentifier
// 03 Apr 2013	 	cnwcs5	CCMS POL 2097 / par 31259 - COMMODITY XLATIONS
//20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
//25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
vars
	xlationOperator	:CM_Operator;
begin	
/*	if _reset then 
	else
		if _xlationOperator &lt;&gt; null then
			xlationOperator := _xlationOperator;
			
		elseif self.myEDIData.operatorCode &lt;&gt; null then
			xlationOperator := app.myRoot.allOperators[self.myEDIData.operatorCode];
		endif;
		
		if xlationOperator &lt;&gt; null then
//			self.translateCommodity (xlationOperator);
//			self.translateVesselVoyage (xlationOperator);
		endif;
		
		// make sure the manual collection on CM_EDIConfig gets maintained
		self.setVoyageCode(self.getVoyageCode());	// cnwrl1 14/06/2010 PAR 24299
	endif;*/
end;
</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <Parameter name="_strIdentifier" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="processHazards" id="479a1889-0d75-4472-8c3f-22d9461788f4">
        <source>processHazards(_strHaz : String; _imCodes : StringArray input);
//
//05 Apr 2012	cnwrs1		Par 29391 - EDI RORO Stowage Advice hazard codes
//30 May 2013	cnwcs5		par 31626 - changed parameter usage
//
vars
	imCode, str, code 	: String;
	strArray 			: StringArray;
	isUNDGCode 			: Boolean;
	strHaz 				: String;
begin
	create strArray transient;
	
	strHaz := _strHaz;

	strHaz.cnReplaceString(' ,', ',');
	strHaz.cnReplaceString(',', ', ');
	strHaz.cnReplaceString('(', ' (');
	strHaz.cnReplaceString('  ', ' ');
	strHaz.getTokensForDelimiter(' ', strArray);
	
	foreach code in strArray do
		code.cnReplaceChar(',', null);
		
		if code.pos('(', 1) &gt; 0 or code.pos(')', 1) &gt; 0 then
			if code.pos('(', 1) &gt; 0 then
				isUNDGCode := true;
				
				if code.pos(')', 1) &gt; 0 then
					str := imCode&amp;':+'&amp;code[2:code.length-2];
					imCode := null;
					isUNDGCode := false;
				else
					str := imCode&amp;':+'&amp;code[2:code.length];
				endif;
				
				_imCodes.add(str);
			elseif code.pos(')', 1) &gt; 0 then
				str := imCode&amp;':+'&amp;code[1:code.length-1];
				
				if not _imCodes.includes(str) then
					_imCodes.add(str);
				endif;
				
				imCode 		:= null;
				isUNDGCode 	:= false;
			endif;
		else
			if imCode &lt;&gt; null then
				if isUNDGCode then
					str := imCode&amp;':+'&amp;code;
				else
					str := imCode;
				endif;
				if not _imCodes.includes(str) then
					_imCodes.add(str);
				endif;
			endif;
			
			if not isUNDGCode then
				imCode := code;
			endif;
		endif;
	endforeach;
	
	if imCode &lt;&gt; null then
		if not _imCodes.includes(imCode) then						// 14/03/2014 cnwmh5 #33648
			_imCodes.add(imCode);
		endif;
	endif;
epilog
	delete strArray;
end;
</source>
        <Parameter name="_strHaz" type="String"/>
        <Parameter name="_imCodes" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processTIHazards" id="884af2ec-f717-4d17-9bdd-0d03ffe29d6b">
        <source>processTIHazards(_allTIHazards : CM_HazardByCodeDict; _imCodes : StringArray io);
//
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
//
vars
	haz	: CM_Hazard;
	tiHaz : CM_TIHazard;
	str : String;
begin
    if _allTIHazards.size &gt; 0 then
        foreach haz in _allTIHazards do
        	tiHaz := haz.CM_TIHazard;
        	if tiHaz.allUNDGCodes.isEmpty then
        		_imCodes.add(tiHaz.code);// &amp; ":+");
    		else
	        	foreach str in tiHaz.allUNDGCodes do
 		        	_imCodes.add(tiHaz.code &amp; ":+" &amp; str.trimRight);
    			endforeach;
    		endif;
       	endforeach;
    endif;

end;
</source>
        <Parameter name="_allTIHazards" type="CM_HazardByCodeDict"/>
        <Parameter name="_imCodes" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="propertyNotVerified" id="437ad039-9eae-4be7-ab2f-80272aa9bfb4">
        <source>propertyNotVerified(_propName : String): Boolean;
//----------------------------------------------------------------
//	Created:	06 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//03 May 2018	NDL	TFS 37795
//21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
//12 Jan 2023 	navvt20	TFS CR 55625 Task 55658: Jade - Contract Id TRX 
vars

begin
	if _propName = CM_EDITrackedItem::description.name then
		return true;
	elseif _propName = CM_EDITrackedItem::fileDateTime.name then
		return true;
	elseif _propName = CM_EDITrackedItem::directDelivery.name then // PAR 35308
		return true;
	elseif _propName = CM_EDITrackedItem::packDetails.name then
		return true;
	elseif _propName = CM_EDITrackedItem::allCustomsSeals.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::billOfLading.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::consignee.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::consignor.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::customsAgent.name then
		return true;
//	elseif _propName = 'deliveryOrderCode' then			// this field no longer exists
//		return true;
	elseif _propName = CM_EDICustomStopTI::mafInstructions.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::myEDIFile.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::myTrackedItem.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::myUnprocEDIData.name then
		return true;
//	elseif _propName = CM_EDICustomStopTI::myVoyage.name then
//		return true;
//	elseif _propName = CM_EDICustomStopTI::packCount.name then //cnwrs1 Sept 2007 par14900
//		return true;
	elseif _propName = CM_EDICustomStopTI::quarantineInstructions.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::sequenceNum.name then
		return true;
//	elseif _propName = CM_EDITrackedItem::cargoTypeDescription.name then // cnwrd1 6.10.08 par 18103	// cnwrl1 25/11/2009 PAR 21713 - what it was
//		return true;			// cnwrl1 25/11/2009 PAR 21713 - what it was
//	elseif _propName = CM_EDITrackedItem::cargoTypeDescr.name then // cnwrd1 6.10.08 par 18103		// cnwrl1 25/11/2009 PAR 21713 - what it was
//		return true;			// cnwrl1 25/11/2009 PAR 21713 - what it was
	elseif _propName = CM_EDITrackedItem::cargoType.name then			// cnwrl1 25/11/2009 PAR 21713
		return true;													// cnwrl1 25/11/2009 PAR 21713
	elseif _propName = CM_EDITrackedItem::temperatureAbsolute.name then
		return true;
	elseif _propName = CM_EDITrackedItem::temperatureSign.name then
		return true;
//	elseif _propName = 'messageNum' then	// cnwrl1 25/11/2009 PAR 21713 - what it was
	elseif _propName = CM_EDITrackedItem::messageNum.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::userNotes.name then
		return true;
	elseif _propName = CM_EDITrackedItem::ediFileIssueDateTime.name then //cnwrs1 Par18495 mar 2009
		return true;
	elseif _propName = CM_EDITrackedItem::processedDateTime.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::allTrackedItems.name then
		return true;
	elseif _propName = CM_EDITrackedItem::allAuditObjects.name then
		return true;
	elseif _propName = CM_EDITrackedItem::allAuditObjectsForClass.name then	//21 Jan 2021	NDL	TFS 50251
		return true;
	elseif _propName = CM_EDITrackedItem::allExtraData.name then
		return true;
	elseif _propName = CM_EDITrackedItem::rawEDIData.name then 				//ccms1845
		return true;
	elseif _propName = CM_EDITrackedItem::rawEDIDataArray.name then 		 //ccms1845
		return true;
	elseif _propName = CM_EDITrackedItem::myEDIConfig.name then  			//cnwrs1 par 24210 13 may 2010
		return true;
	elseif _propName = CM_EDITrackedItem::specialStowage.name then  		//07 Jun 2017	NDL TFS 4454
		return true;
	elseif _propName = CM_EDITrackedItem::remarksAdditional1.name then		//04 May 2018	NDL	TFS 37795
		return true;
	elseif _propName = CM_EDITrackedItem::remarksAdditional2.name then		//04 May 2018	NDL	TFS 37795
		return true;
	elseif _propName = CM_EDITrackedItem::countryOfOriginCode.name then
		return true;														// 5/10/22 jlier1 TFS 54846 
	elseif _propName = CM_EDITrackedItem::rawDataCommodity.name then		//21.11.2022 navma1 #55424
		return true;
	elseif _propName = CM_EDITrackedItem::rawDataVoyageCode.name then		//21.11.2022 navma1 #55424
		return true;
	elseif _propName = CM_EDITrackedItem::hsCode.name then	// 28/11/2022 jlizm1 TFS 55280
		return true;
	elseif _propName = CM_EDITrackedItem::contractIdForTIstring.name then	// TFS CR 55625 TASK 55658
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="9140d3aa-16a9-40d1-b674-30e14a0b1042">
        <source>pxyCreateUpdateProxy(): SelfType;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		08 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// 8/3/2010 	cnwsh3		PAR22993 - Want to use the EDI header if we need it in some cases but 
//   						should be standard for all EDI Tracked Item updates.
//----------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 19 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	pxy : SelfType;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();
	
	pxy.myEDIData := self.myEDIData;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
