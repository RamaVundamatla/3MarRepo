    <JadeMethod name="setDensityFromCargoTypeDef" id="cee3985e-da71-41b9-bf54-78054eade908">
        <updating/>
        <source>setDensityFromCargoTypeDef() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 12 June 2019
TFS#		: 44416
Function	: This method will check if the current measurement(/s) field are null
			  if null and Cargo Sub Type exist use the the Cargo Sub Type
			  Measurement Defaults value. If this is null then use the 
			  Cargo Type Measurement Default value.
			  If Cargo Sub Type is null then use Cargo Type Measurement Default value.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	cargoSubType : CM_Product;
	cargoType	 : CM_CargoType;	
begin	
	if self.cargoType &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById[self.cargoType];
	endif;
	
	if cargoType = null then
		return;
	endif;
	
	cargoSubType := self.myProduct;
	
	if cargoType.mySystemProductType &lt;&gt; null and cargoSubType = null then	
		cargoSubType := cargoType.mySystemProductType;
	endif;
	
	if self.density = null then		
		if cargoSubType &lt;&gt; null then
			self.density := cargoSubType.getDensityValue();
		endif;			
		// if it is still null get from Cargo Type Defaults
		if self.density = null then			
			self.density := cargoType.defaultDensity;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEmailDefaults" id="762bc086-6c6d-4b8b-82f6-faa0d86eab98">
        <updating/>
        <source>setEmailDefaults() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2017	jlger1	Initial creation refactored for webportal

*/

vars
	defaultEmailType	: Integer;
	termEmailDefaults	: CM_PINObjectDefaultEmail;
	carrier 			: CM_Carrier;
	consignee			: CM_ConsigneeConsignor;
begin
	if self.transportMode.trimBlanks &lt;&gt; TI_TRANSMODE_ROAD_STR then
		return;
	endif;
	
	if self.myOriginalProxyTI &lt;&gt; null then
		return;
	endif;
	
	if self.hasCSIStop then
		defaultEmailType	:= PINEmail_PrenoteCustomsInspect;
	else
		defaultEmailType	:= PINEmail_Prenote;
	endif;
	termEmailDefaults	:= self.myTerminal.getEmailDefaultsSettings( defaultEmailType );
	if termEmailDefaults = null then
		return;
	endif;
	self.myEmailDefaults := termEmailDefaults.cloneSelf(true).CM_PINObjectDefaultEmail;
	
	carrier:=app.myRoot.allCarriers[self.carrier];
	consignee:=app.myRoot.allConsigneeConsignors[self.consigneeCode];
	
	self.myEmailDefaults.CM_PINObjectDefaultEmail.setAddresses( self.myTerminal, carrier, consignee, defaultEmailType ); //+ cnwmd1 Par 24232
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setExpectedFromTI" id="255261f5-0284-4bc9-b24b-720cead46998">
        <updating/>
        <source>setExpectedFromTI(_ti: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2012	cnwmc5	Initial creation par 29728

*/

vars

begin
