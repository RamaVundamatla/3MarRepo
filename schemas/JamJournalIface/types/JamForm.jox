    <JadeMethod name="bnCloseSession_click" id="1d1a6a93-6bbc-4e5e-95ab-e8322425ec2c">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>bnCloseSession_click(btn: Button input) updating;

begin
	delete jjAccess;
	
	bnOpenSession.enabled := true;
	bnCloseSession.enabled := false;
	bnNextJournal.enabled := false;
	bnRegisterClass.enabled := false;
	bnClearClasses.enabled := false;
	bnLoadRemaps.enabled := false;
	bnClearRemaps.enabled := false;
	bnFindNext.enabled := false;
	bnNextRecord.enabled := false;
	bnBeforeImage.enabled := false;
	bnAfterImage.enabled := false;
	bnDeltaObject.enabled := false;

	postMsg("Session closed");
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
