<Class name="CM_WOExportReturnedRequest" id="0361480e-42ab-4ddc-b3e7-7a8f25c26ec4">
    <superclass name="CM_WORequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="createWLE" id="31968d14-e7db-4e55-932c-0e7c17d38343">
        <source>createWLE() : CM_WorkListEntry;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/

vars

	wle	: CM_WOExportReturnedWLE;

begin

	create wle;
	wle.setForCreate(self.myJob, self);
	wle.causeEvent(wle.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, wle);	

	return wle;
epilog

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="ef4dc6be-5955-46cc-97a4-fec7a326f3e7">
        <updating/>
        <source>createWLEs() updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/

vars

	i,
	numReq,
	numTIs		:	Integer;
	aWLE		:	CM_WorkListEntry;
	theTI		: 	CM_TrackedItem;
	iter		: 	Iterator;
begin
	//------------
	//Create the appropriate WLEs
	// 1 for each ti on the job and extra up to totalRequested
	//------------
	
	numTIs := self.myJob.CM_WOExportReturnedJob.allTrackedItems.size;
	
	numReq := self.totalRequested;
	i := 1;		
	
	if numReq &lt; numTIs then
		numReq := numTIs;
	endif;
	
	iter := self.myJob.CM_WOExportReturnedJob.allTrackedItems.createIterator;

	// step through all real ti's on the job 
	//then continue untill we have all we need
	
	while iter.next(theTI) do
	// create WLE , create pack  on ti link that to the wle			
		aWLE := self.createWLE();
		aWLE.setMyTrackedItem( theTI); // set the tracked item
		i := i+1;	
	endwhile;
		
	while true do
		if i &gt; numReq then
			//If total requested = 0 then we always create 1
			break;
		endif;

		//create 'empty' WLE's will fill them later
		aWLE := self.createWLE();
		i := i+1;		
	endwhile;

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="typeString" id="f374e5ab-4ccb-486c-b9a4-2a907f196443">
        <source>typeString(): String;

/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/

vars

begin
	return 'Export Returned';

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
