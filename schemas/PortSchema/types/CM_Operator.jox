    <JadeMethod name="getDisplayStringForAttribute" id="b7864280-cf89-4f99-99a9-5d7622e9e992">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     16 April 2014 by cnwdb2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14 Apr 2014	cnwdb2		PAR #33977  
// ---------------------------------------------------------------------------

vars
	opGroup	: CM_OperatorGroup;
	tmpStr	: String;
	
begin

	if _attrName = ETRow_MyDebtor then
		if self.debtor &lt;&gt; null then
			return self.debtor.name ;
		else
			return null;		// from 34302
		endif;
		
	elseif _attrName = ETRow_MyOperatorGroup then
		foreach opGroup in self.allOperatorGroups do
			if tmpStr = null then
				tmpStr := opGroup.code;
			else
				tmpStr := tmpStr &amp; ', ' &amp; opGroup.code;
			endif;
		endforeach;
		
		return tmpStr;
	elseif _attrName = ETRow_ReeferWashExpiry then	
		return self.washExpiryReefer.String ; 
		
	elseif _attrName = ETRow_FinancialId then	//04.Mar.24 navsp1 TFS 57177
		if self.debtor &lt;&gt; null then
			return self.debtor.code;
		endif;
		return null;
	endif;	

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
