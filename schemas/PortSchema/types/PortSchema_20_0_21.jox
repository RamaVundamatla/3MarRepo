    <JadeMethod name="updateCargoTypeEntTables" id="0f135414-e8ca-4d54-b4b3-19463d3a5880">
        <source>updateCargoTypeEntTables(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2023 CR 58250 Task 58253: UI - Cargo Enquiry New Sheet

*/

vars
	iter : Iterator;
	cargoType : CM_CargoType;
	root : CM_Root;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Updating Storage Expiry detail ent table defintions", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Updating Storage Expiry detail ent table defintions") ;	
	endif;
	root := CM_Root.firstInstance;
	
	iter:=root.allCargoTypesById.createIterator;
	
	app.writeLog ('Updating Cargo Types ent table defs', LogINFO);
	
	beginTransaction;
	while iter.next(cargoType) do
		if cargoType.allEnquiryEntTableDefs.indexOf(ETDef_StorageExpDetails) = 0 then
			cargoType.allEnquiryEntTableDefs.add(ETDef_StorageExpDetails);
		endif;
	endwhile;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Updating Storage Expiry detail ent table defintions complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Updating Storage Expiry detail ent table defintions complete") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete iter;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateContractUniqueIds" id="69525ef8-3c35-4e5e-863d-19ef6f1beb6e">
        <source>updateContractUniqueIds(_controller : CnEcReleaseController);
/*
Purpose:			

Date		Who		Reason
24JAN2023	NAVAB1	CR 55624 TASK 55700 
*/

vars
	detail : CM_InvoiceContractDetails;
	rate : CM_InvoiceContractRate;
	entry : CM_InvoiceContractRateEntry;
	oArray : ObjectArray; 
	message : String;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	message := "Setting unique Id on contract objects";
	app.writeLog(method.qualifiedName &amp; message, LogINFO); 
	if _controller &lt;&gt; null then
		_controller.logEntry(message) ;	
	endif;
	
	create oArray transient;
	CM_InvoiceContractRateEntry.allInstances(oArray,0,false);
	
	beginTransaction;
	
	foreach entry in oArray as CM_InvoiceContractRateEntry discreteLock do
		if entry.id = 0 then
		entry.setPropertyValue(CM_InvoiceContractRateEntry::id.name, entry.cnGetInstanceId(entry));
		endif;
	endforeach;
	
	oArray.clear();
	CM_InvoiceContractRate.allInstances(oArray,0,false);
	foreach rate in oArray as CM_InvoiceContractRate discreteLock do
		if rate.id = 0 then
		rate.setPropertyValue(CM_InvoiceContractRate::id.name, rate.cnGetInstanceId(rate));
		endif;
	endforeach;
	
	oArray.clear();
	CM_InvoiceContractDetails.allInstances(oArray,0,true);
	foreach detail in oArray as CM_InvoiceContractDetails discreteLock do
		if detail.id = 0 then
		detail.setPropertyValue(CM_InvoiceContractDetails::id.name, detail.cnGetInstanceId(detail));
		endif;
	endforeach;
	

	delete oArray;
	commitTransaction;
	
	
	app.writeLog(method.qualifiedName &amp; message &amp;  " Complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(message &amp; " Complete");
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete oArray;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateEmailArchitectConfig" id="32d55b65-919e-4f43-942f-9a9d95967cb4">
        <source>updateEmailArchitectConfig( _controller : CnEcReleaseController );
/*

Purpose:			Upgrades from the old version of Email Architect to the new version

Parameters:			_controller	CnEcReleaseController	Upgrade controller used to process changes

Return Value:		NONE

Date		Who		Reason
28 February 2022	navpw1	Initial creation TFS: 51526

*/

vars
	currentEmailSoftware,
	currentEmailLicense 	: Integer;
	terminal				: CM_Terminal;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog( method.qualifiedName &amp; 'Migrating to new version of Email Architect ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Migrating to new version of Email Architect") ;	
	endif;
	
	//SYSTEM Configuration Send Mail
	currentEmailSoftware 	:= app.myRoot.getConfig(AutoEmailSoftware).Integer;
	currentEmailLicense 	:= app.myRoot.getConfig(EmailLicenseType).Integer;
	
	beginTransaction;
	
	if currentEmailSoftware = BGP_EmailSendRequest.EMAIL_EMAILARCHITECT and currentEmailLicense &lt;&gt; EmailLicenseType_3 then
		app.myRoot.setConfig(EmailLicenseType, EmailLicenseType_3, false);
	endif;
	
	//TERMINAL Configuration Get Mail
	foreach terminal in app.myRoot.allTerminals do
		currentEmailSoftware 	:= terminal.getConfig(AutoEmailSoftware).Integer;
		currentEmailLicense 	:= terminal.getConfig(EmailLicenseType).Integer;
		
		if currentEmailSoftware = BGP_EmailSendRequest.EMAIL_EMAILARCHITECT and currentEmailLicense &lt;&gt; EmailLicenseType_3 then
			terminal.setConfig(EmailLicenseType, EmailLicenseType_3);
		endif;
		
	endforeach;

	commitTransaction;
	
	app.writeLog( method.qualifiedName &amp; 'Completed Migration to new version of Email Architect ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry('Completed Migration to new version of Email Architect') ;	
	endif;
	
	self.addScriptRun(method.name);

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateIMVVehicleConfig" id="90d37c93-9feb-454a-80f1-782704365b8e">
        <source>updateIMVVehicleConfig(_controller : CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2022	jlier1	Initial creation 52741

*/

vars
rtConfig : CM_RTVehicleConfig;
	defaultPrimary : Boolean;	
	theEntDef : EntTableDef;
	theEntView : EntTableView;
	theName : String;
begin
	//not doing script been run at all because will only update imv configs with no primary task fields
	//if self.hasScriptBeenRunAtAll(method.name, _controller) then
	//	return;
	//endif;

	app.writeLog( method.qualifiedName &amp; 'Converting IMV rt configs to have weight and O/D in the primary task fields ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Converting IMV rt configs to have weight and O/D in the primary task fields ") ;	
	endif;
	theEntDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_VehicleAppFields];
	
	foreach rtConfig in CM_RTVehicleConfig.instances discreteLock do
		defaultPrimary:=false;
		if rtConfig.myPrimaryTaskFields &lt;&gt; null and rtConfig.myPrimaryTaskFields.allEntTableRows.size &gt; 0 then
			continue;
		endif;
		if rtConfig.myMachine &lt;&gt; null then
			if rtConfig.myMachine.machineType = MACHINETYPE_IMV then
				defaultPrimary:=true;
			else
				continue;
			endif;
		endif;
		
		if rtConfig.myTerminalMachineType &lt;&gt; null and rtConfig.myTerminalMachineType.myMachineType &lt;&gt; null and rtConfig.myTerminalMachineType.myMachineType.type = MACHINETYPE_IMV then
			defaultPrimary:=true;
		endif;
		
		if defaultPrimary then
			beginTransaction;
			if rtConfig.myPrimaryTaskFields = null then
				create theEntView persistent;
				rtConfig.setPropertyValue(CM_RTVehicleConfig::myPrimaryTaskFields.name,theEntView);
				theName:=rtConfig.getUniqueViewName&amp; "primary tasks";
				rtConfig.myPrimaryTaskFields.set(theName,theName,theEntDef);
			endif;
			
			rtConfig.myPrimaryTaskFields.addRowByName(ETRow_Weight);
			rtConfig.myPrimaryTaskFields.addRowByName(ETRow_IsOverDimension);
			commitTransaction;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateInvoiceProcessPelindo" id="b1ad070f-3a76-4958-b8c9-9a2823048be2">
        <source>updateInvoiceProcessPelindo( _controller : CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2021	navpw1	Initial creation TFS: 52047

*/

vars

	invoiceProcess : CM_InvoiceProcess;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog( method.qualifiedName &amp; 'Renaming Invoice Process Description Pelindo ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Renaming Invoice Process Description Pelindo") ;	
	endif;
	
	beginTransaction;
	
	foreach invoiceProcess in app.myRoot.allInvoiceProcesses where invoiceProcess.isPelindo1Process do
		invoiceProcess.setPropertyValue(CM_InvoiceProcess::description.name, "MTN Work Orders");
	endforeach;
	
	commitTransaction;
	
	app.writeLog( method.qualifiedName &amp; 'Completed Renaming Invoice Process Description Pelindo ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry('Completed Renaming Invoice Process Description Pelindo') ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

end;</source>
