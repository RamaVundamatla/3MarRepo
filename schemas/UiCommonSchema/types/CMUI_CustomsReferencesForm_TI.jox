    <JadeMethod name="unloadFormWithMessage" id="c8775173-4f8e-4508-acf7-5f63591cbc53">
        <updating/>
        <source>unloadFormWithMessage() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2022	navpw1	Initial creation TFS: 55215

*/

begin
	// display message and close form
	app.msgBox(app.getErrorString1(DeletedByAnotherUser, app.getErrorString (Item)), self.caption, MsgBox_OK_Only);	
	
	self.resetFirstChange;
	self.unloadForm;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateItem" id="eae488c2-3ffb-48ba-ac5a-0b779930cd3f">
        <updating/>
        <source>updateItem()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2024	navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable
08 April 2024	navlw1  Bug 63566: CUX - Code 75755 when adding a Customs Reference with Cargo Item in Edit Mode
*/

vars
	customesReference 	: CM_CustomsReference;
	referenceType,
	referenceNum,
	objectName,
	customsControl,
	status				: String;
	positionNum,
	remPackages,
	totalPackages		: Integer;
	retentionPeriod		: Date;
begin

	// check that we have a selected item
	if self.mySelectedItem = null then
		app.msgBox('Please Select a Custom Reference Entry', 'Select Item', 0);
		return;
	endif;
	
	customesReference 	:= self.mySelectedItem;
	referenceType 		:= self.txtRefType.text;
	referenceNum		:= self.txtRefNum.text;
	positionNum			:= self.txtPosNum.text.asIntegerJMT;
	objectName			:= self.txtObjectName.text;
	customsControl 		:= self.txtCustomsControl.text;
	status				:= self.txtStatus.text;
	remPackages 		:= self.txtRemPackages.text.asIntegerJMT;
	totalPackages		:= self.txtTotPackages.text.asIntegerJMT;
	retentionPeriod		:= self.dtRententionPeriod.getDate();
		
	self.isFormChanged := false;
		
	customesReference.setProxy(referenceType, referenceNum, positionNum, status, objectName, totalPackages, remPackages, customsControl, retentionPeriod);
	customesReference.setTrackedItem(myTrackedItem);

	//Update the entry in the data table.
	self.tblData.updateItemObject(customesReference, self.colorRow1, self.colorRow2, app.myPassport);
epilog

end;</source>
    </JadeMethod>
</GUIClass>
