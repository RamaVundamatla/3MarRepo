    <JadeMethod name="click" id="17e9ebf2-9f31-401d-aabe-ca2a5354c5cd">
        <updating/>
        <source>click(table: CnEcAppGridTable input) updating;

vars

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;
	appGrid.click(appGrid);	
end;</source>
        <Parameter name="table" type="CnEcAppGridTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="5829744e-c05d-4f03-bbf3-de395d6cb3bb">
        <updating/>
        <source>create() updating;

begin
	borderStyle := Window.BorderStyle_None;
	readOnly := true;
	tabStop := false;
	allowResize := 3; // None
	relativeWidth := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="dblClick" id="fcd575b7-73fb-474f-b972-1201d394b20e">
