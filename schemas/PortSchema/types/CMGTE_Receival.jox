    <JadeMethod name="setForCreateUpdateCommon" id="6b7196fb-680c-4489-bc5e-a9487ae7f95b">
        <updating/>
        <source>setForCreateUpdateCommon(_pxyGTEEntity: CMGTE_Receival) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 September 2010	cnwndl1	Initial creation	par 25608

*/

vars

	pxySealTI : CM_SealTI;
	realSealTI : CM_SealTI;

begin

	inheritMethod(_pxyGTEEntity);
	
//	self.createProxySeals( _pxyGTEEntity.allSeals );

	self.allSeals.purge();
	foreach pxySealTI in _pxyGTEEntity.allSeals do
		create realSealTI persistent;
		realSealTI.setForCreate(pxySealTI);
		realSealTI.setMyTrackedItem(null);
		self.allSeals.add(realSealTI);
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pxyGTEEntity" type="CMGTE_Receival"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="89e05828-f13a-4eab-9de1-1af6c3b779b6">
        <updating/>
        <source>setForUpdate(_pxyGTEEntity: CMGTE_Receival; _realVVR : CM_VehicleVisitRecord ) updating;
// ---------------------------------------------------------------------------
// Created:     23 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 03/12/2009		cnwdap1			CCMS MES 1007 Moved reefer property upadtes from CMGTE_Container::setForCreateUpdateCommon
// 16/01/2013		cnwdap1			PAR #31018 CCMS POL 2223 Added on power in transit attributes
// 05/03/2014		cnwdap1			PAR #33193 CCMS DPH 2285 Added Purchase Order and Service Order fields
// 29/04/2015		cnwdap1			PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
// 07/07/2015		cnwdap1			PAR #36421 Hazardous Materials handling
// 25/11/2015	    cnwma1          PAR #36943 Shipping Reference error during extract
// 02/10/2020       cnwma1          ChangeRequest 50112: ASPA - GCI Stevedores
// 19/05/2022		jlika1			TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
// 14/06/2022		navak20			ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
// 16/08/2022		navak20			TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
// 06/04/2023		navkc1			CR# 56431 Task 56438: UI - Cargo Enquiry
// 26/05/2023		jlika1			TFS 56398 - EUP - OUT - Overlanded Cargo Handling - Web
// 14/11/2023		jlika1			TFS 61131 61013 CUX | Cargo Priority - Prenotes and Add Cargo Forms
// 02/10/2025		navdap1			MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
// ---------------------------------------------------------------------------

vars
	oldIMEX : Integer;
	oldId : String;
	hazCode : String;							// PAR #36421
	realTI : CM_TrackedItem;
	invalidObj : Boolean;
	pxyTI : CM_TrackedItem;
	cargoGroupID : String;
	pxyGTEEntity:  CMGTE_Receival;
	cargoGroup : CM_CargoGroup;
begin
	oldId :=self.id;	
	oldIMEX := self.imexStatus;
	inheritMethod(_pxyGTEEntity, _realVVR);

	self.myTranshipToPort				:= _pxyGTEEntity.myTranshipToPort;		// cnwjk3 PAR 23390 24/03/2010
	self.tiEdition						:= _pxyGTEEntity.tiEdition;
	self.billOfLading 					:= _pxyGTEEntity.billOfLading;
	self.bookingRefRequired 			:= _pxyGTEEntity.bookingRefRequired;
	self.bookingReference 				:= _pxyGTEEntity.bookingReference;
	self.bookingReferenceItem 			:= _pxyGTEEntity.bookingReferenceItem;
	self.cargoType 						:= _pxyGTEEntity.cargoType;
	self.carrier 						:= _pxyGTEEntity.carrier;
	self.commodity 						:= _pxyGTEEntity.commodity;
	if not _pxyGTEEntity.allTIHazards.isEmpty and _pxyGTEEntity.myTerminal.getConfig(UseDetailedHazEntry).Boolean then	// PAR #36421
		hazCode 						:= self.myTerminal.getConfig(DefHazCommodity).String;							// PAR #36421
		if self.commodity &lt;&gt; hazCode then																				// PAR #36421
			self.commodity 				:= hazCode;																		// PAR #36421
		endif;																											// PAR #36421
	endif;																												// PAR #36421
	self.consigneeCode 					:= _pxyGTEEntity.consigneeCode;
	self.consignorCode 					:= _pxyGTEEntity.consignorCode;
	self.consignorVoyageCode 			:= _pxyGTEEntity.consignorVoyageCode;
	self.customExportEntryNumber 		:= _pxyGTEEntity.customExportEntryNumber;
	self.customsAgentCode 				:= _pxyGTEEntity.customsAgentCode;
	self.damaged 						:= _pxyGTEEntity.damaged;
	self.density 						:= _pxyGTEEntity.density;
	self.destinationPort 				:= _pxyGTEEntity.destinationPort;
	self.directDelivery 				:= _pxyGTEEntity.directDelivery;	//30 Jan 2013	NDL	Par 31102
	self.dischargePort 					:= _pxyGTEEntity.dischargePort;
	self.doSetStops 					:= _pxyGTEEntity.doSetStops;
	self.doSetToDoTasks 				:= _pxyGTEEntity.doSetToDoTasks;
	self.imExStatus 					:= _pxyGTEEntity.imExStatus;
	self.imexStatus 					:= _pxyGTEEntity.imexStatus;
	self.inspected 						:= _pxyGTEEntity.inspected;
	self.isFromPrenote 					:= _pxyGTEEntity.isFromPrenote;
	self.isToBeInspected 				:= _pxyGTEEntity.isToBeInspected;
	self.lengthString 					:= _pxyGTEEntity.lengthString;
	self.loadPort 						:= _pxyGTEEntity.loadPort;
	self.preservePrenoteData 			:= _pxyGTEEntity.preservePrenoteData;
	self.purchaseOrder 					:= _pxyGTEEntity.purchaseOrder;
	self.serviceOrder					:= _pxyGTEEntity.serviceOrder;							// PAR #33193
	self.shippingReference				:= _pxyGTEEntity.shippingReference;   					//25/11/2015 cnwma1 PAR #36943
	self.remarks 						:= _pxyGTEEntity.remarks;
	self.statusString 					:= _pxyGTEEntity.statusString;
	self.tiEdition 						:= _pxyGTEEntity.tiEdition;
//	self.volume 						:= _pxyGTEEntity.volume;
	self.totalQuantity					:= _pxyGTEEntity.totalQuantity;
	self.setMyVolume(_pxyGTEEntity.getMyVolume);	//18 Jul 2011	NDL	Par 27868
	self.weightTotal 					:= _pxyGTEEntity.weightTotal;
	self.weightCargo 					:= _pxyGTEEntity.weightCargo;	// 19/02/2010 cnwar2 #22339
	self.weightTare 					:= _pxyGTEEntity.weightTare;	// 19/02/2010 cnwar2 #22339
	self.isWeightCertified				:= _pxyGTEEntity.isWeightCertified; //epr TFS 2011 8/6/16
	self.weightCertifiedName			:= _pxyGTEEntity.weightCertifiedName;  //epr TFS 2011 8/6/16
	self.weightCertifiedReference		:= _pxyGTEEntity.weightCertifiedReference;  //epr TFS 2011 8/6/16
	self.wet 							:= _pxyGTEEntity.wet;
	self.widthString					:= _pxyGTEEntity.widthString;
	self.operatorExportReleaseNumber	:= _pxyGTEEntity.operatorExportReleaseNumber;
	self.myBusinessUnit 				:= _pxyGTEEntity.myBusinessUnit;
	self.myTrackedItem 					:= _pxyGTEEntity.myTrackedItem;

	self.dimLenFront 					:= _pxyGTEEntity.dimLenFront;
	self.dimLenRear 					:= _pxyGTEEntity.dimLenRear;
	self.dimWidthLeft 					:= _pxyGTEEntity.dimWidthLeft;
	self.dimWidthRight 					:= _pxyGTEEntity.dimWidthRight;
	self.isOverDimensions				:= _pxyGTEEntity.isOverDimensions;
	if _pxyGTEEntity.dimLenFront &lt;&gt; null or _pxyGTEEntity.dimLenRear &lt;&gt; null then
		self.length						:= _pxyGTEEntity.dimLenFront + _pxyGTEEntity.dimLenRear;
	endif;
	if _pxyGTEEntity.dimWidthLeft &lt;&gt; null or _pxyGTEEntity.dimWidthRight &lt;&gt; null then
		self.width						:= _pxyGTEEntity.dimWidthLeft + _pxyGTEEntity.dimWidthRight;
	endif;

//	self.volumeTotal 					:= _pxyGTEEntity.volumeTotal;
	self.setMyCargoVolume( _pxyGTEEntity.getMyCargoVolume );	//18 Jul 2011	NDL	Par 27868
	
	self.alternativeId					:= _pxyGTEEntity.alternativeId;
	self.colour							:= _pxyGTEEntity.colour;
	self.operatorExportReleaseNumber	:= _pxyGTEEntity.operatorExportReleaseNumber;
	self.specialStow					:= _pxyGTEEntity.specialStow;
	self.moveToTruckOnly				:= _pxyGTEEntity.moveToTruckOnly;	//08 Jun 2010	NDL	Par 23903
	
	self.allDischargePorts.clear();
	_pxyGTEEntity.allDischargePorts.copy(self.allDischargePorts);
	//self.allHazards.clear();
	//_pxyGTEEntity.allHazards.copy(self.allHazards);
	self.setHazards(_pxyGTEEntity.allTIHazards);
	
	self.allStops.clear();
	_pxyGTEEntity.allStops.copy(self.allStops);
	
	self.allToDoTasks.clear();
	_pxyGTEEntity.allToDoTasks.copy(self.allToDoTasks);
	self.doSetToDoTasks := true;	//19 Feb 2016	NDL	Par 37538
	
	self.allSpecialLifts.clear();
	_pxyGTEEntity.allSpecialLifts.copy(self.allSpecialLifts);
	
	// CSMS 1007
	self.allowableTimeOffPower 		:= _pxyGTEEntity.allowableTimeOffPower;
	self.setCarbonDioxide( _pxyGTEEntity.getCarbonDioxide );
	self.carriageTempC 				:= _pxyGTEEntity.carriageTempC;
	self.carriageTempF 				:= _pxyGTEEntity.carriageTempF;
	self.coolingType 				:= _pxyGTEEntity.coolingType;
	self.curtainsIn 				:= _pxyGTEEntity.curtainsIn;
	self.hasCoolingWaterConnection 	:= _pxyGTEEntity.hasCoolingWaterConnection;
	self.setHumidity( _pxyGTEEntity.getHumidity );
	self.setOxygen( _pxyGTEEntity.getOxygen );
	self.packDate					:= _pxyGTEEntity.packDate;
	self.packTempC					:= _pxyGTEEntity.packTempC;
	self.packTempF					:= _pxyGTEEntity.packTempF;
	self.packTime					:= _pxyGTEEntity.packTime;
	self.reeferRemarks 				:= _pxyGTEEntity.reeferRemarks;
	self.ventilation 				:= _pxyGTEEntity.ventilation;
	self.voltageType 				:= _pxyGTEEntity.voltageType;
	
	// PAR #31018 CCMS POL 2223
	self.onPowerDuringTransit		:= _pxyGTEEntity.onPowerDuringTransit;		// PAR #31018
	self.transitOnPowerDate			:= _pxyGTEEntity.transitOnPowerDate;		// PAR #31018
	self.transitOnPowerTime			:= _pxyGTEEntity.transitOnPowerTime;		// PAR #31018
	self.transitOnPowerRemarks		:= _pxyGTEEntity.transitOnPowerRemarks;		// PAR #31018
	self.remainingTimeOffPower		:= _pxyGTEEntity.remainingTimeOffPower;		// PAR #31018
	
	self.expiryDate					:= _pxyGTEEntity.expiryDate;				// PAR #36094
	self.receivalTemperature		:= _pxyGTEEntity.receivalTemperature;		// PAR #36094
	self.isExternallyMonitored		:= _pxyGTEEntity.isExternallyMonitored;  	//epr TFS 3581
	self.stevedoreCode              := _pxyGTEEntity.stevedoreCode;             //02.10.2020 cnwma1 TFS #50112
	// jlika1 TFS 53316 --&gt;
	self.diameter				:= _pxyGTEEntity.diameter;
	self.grade					:= _pxyGTEEntity.grade;
	self.grammage				:= _pxyGTEEntity.grammage;
	self.rollingLength			:= _pxyGTEEntity.rollingLength;
	// jlika1 TFS 53316 &lt;--
	self.createROBReleaseGTE(_realVVR,oldId,oldIMEX);
	//jlier1 TFS 53515 25/5/22
	
	self.shippingLineCode := _pxyGTEEntity.shippingLineCode;	// 14 June 2022 navak20 53195
	self.countryOfOriginCode := _pxyGTEEntity.countryOfOriginCode;		// 16.08.2022 navak20 TFS 54441
	self.invoiceContractId	:= _pxyGTEEntity.invoiceContractId;//21.02.2023 navtnr20 TFS CR 55648 Task 55663
	
	cargoGroup := _pxyGTEEntity.myCargoGroup;	
	if cargoGroup &lt;&gt; null and cargoGroup.isTransient then
		cargoGroupID:=cargoGroup.id;
		
		pxyTI := cargoGroup;
		self.exclusiveLock(self.myTerminal.allCargoGroupsByCargoTypeId);
		self.exclusiveLock(self.myTerminal.allCargoGroupsByIdCargoType);
		on Exception do app.handleDeletedObject( exception, pxyTI, invalidObj );
			
		app.myUtilityCA.utlCreateTrackedItem( pxyTI, realTI, app.myPassport );
		self.myCargoGroup:=realTI.CM_CargoGroup;
		//pxy cargo group always gets deleted so recreated it
		pxyGTEEntity:=_pxyGTEEntity;
		pxyGTEEntity.setPxyCargoGroup(cargoGroupID);
		
	else
		self.myCargoGroup:=cargoGroup;
	endif;
	
	self.attributeisOverlanded := _pxyGTEEntity.attributeisOverlanded; //06/04/2023	navkc1	CR# 56431 Task 56438
	
	// ### TFS 57812 (58439) 15Jun2023 NAVPW1
	self.itemised := _pxyGTEEntity.itemised;
	self.secondaryBarcodeId := _pxyGTEEntity.secondaryBarcodeId;
	self.mySortingMethod := _pxyGTEEntity.mySortingMethod;
	// ### TFS 57812 (58439) 15Jun2023 NAVPW1
	
	self.myCustomerPriority := _pxyGTEEntity.myCustomerPriority;
	
	self.cargoTypeContents := _pxyGTEEntity.cargoTypeContents;		// MTN-36141
	
epilog
	
end;</source>
        <Parameter name="_pxyGTEEntity" type="CMGTE_Receival"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setHazards" id="4ace320a-8cfb-4d89-85de-0076dde20104">
        <updating/>
        <source>setHazards(_tmpHazards: CM_HazardByCodeDict) updating;
/*
	Created on 11 January 2008
	
	by Debby Hutchison
	
	Purpose: Copied from CM_BookingRef for CCMS 1618
*/
	
/* Changes

Date		Name	TFS#		Description
============================================================================
24/05/2019	jlgka1	TFS 43346	LNX - Multiple Hazardous Details with same Hazardous Class.
============================================================================*/
vars
	haz		: CM_Hazard;
	tiHaz	: CM_TIHazard;
begin
	
	self.raiseExceptionIfTransient(method);
	
	self.allTIHazards.purge;

	if _tmpHazards.isEmpty then
		return;
	endif;
	
	foreach haz in _tmpHazards do				
		create tiHaz persistent;
		tiHaz.setForCreate(haz, null, app.myPassport);
		self.allTIHazards.add(tiHaz);
	endforeach;
	
end;</source>
        <Parameter name="_tmpHazards" type="CM_HazardByCodeDict"/>
    </JadeMethod>
