    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="32134fc9-39b6-4492-aaa4-9e5f98aff01c">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		29 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Date			Changed By		Reason
// 31/05/2019	jlgzm1			TFS 42840 MSL - Direct Delivery Between LOLO RORO Voyages and Rail
// ---------------------------------------------------------------------------
vars
	wle : CM_WorkListEntry;
	js : CM_VoyageJobSheet;
	request : CM_VoyageRequest;
	voy : CM_Voyage;
	iter : Iterator;
	ti : CM_TrackedItem;
	secondSpaceIdx, firstSpaceIdx : Integer;
	position : String;
begin
	inheritMethod(_tiTransCntrl, _passport);

	self.transferType := _tiTransCntrl.transferType;

	// ### KPI Stuff
	wle := _tiTransCntrl.getWLE();
	self.setJSFromWLE(wle);
	
	if wle = null then
		self.locationYard := _tiTransCntrl.myTrackedItem.priorLocation;
		// 26/03/2015 cnwjre1 from unit test - check myPrimaryLocation is not null
		if _tiTransCntrl.myTrackedItem &lt;&gt; null
		and _tiTransCntrl.myTrackedItem.myPrimaryActualLocation &lt;&gt; null then // PAR 36019
			self.locationShip := _tiTransCntrl.myTrackedItem.myPrimaryActualLocation.getFullId(); // PAR 36019
			position := _tiTransCntrl.myTrackedItem.myPrimaryActualLocation.getLocationOrdinal(); // PAR 36019
		endif;
		self.craneID := position;
	endif;
	
	// tfs42840
	if _tiTransCntrl.isKindOf(CMIF_MoveTransactionController) then
		self.isDirectReleaseMove := _tiTransCntrl.CMIF_MoveTransactionController.isDirectReleaseMove;
		//11 Mar 2020	NDL	TFS 48774
		if self.myJobSheet &lt;&gt; null then
			voy := self.myJobSheet.myVoyage;
		endif;
		if voy &lt;&gt; null then
			self.myVoyageRelivant := voy;
			self.voyage := voy;	//12 Mar 2020	NDL	TFS 48774
			self.voyageCode := voy.code;	//12 Mar 2020	NDL	TFS 48774
		endif;
		
	endif;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setJSFromJob" id="acfea3d9-7318-4be3-8b0d-646299ec367e">
        <updating/>
        <source>setJSFromJob(_job : CM_VoyageJob) updating;
// ---------------------------------------------------------------------------
// Created:		19 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	js : CM_VoyageJobSheet;
	bay1, bay2, theBay : CM_Bay;
begin
	if self.myJob &lt;&gt; null then
		return;
	endif;
	
	if _job &lt;&gt; null then
		self.myJob := _job;
		if self.myJob &lt;&gt; null then
			if _job.myShift &lt;&gt; null then // TFS 3215
				self.shiftCode := _job.myShift.code; // TFS 3215
				self.shiftStart := _job.myShift.startDateTime; // TFS 3215
				self.shiftEnd := _job.myShift.endDateTime; // TFS 3215
			endif;
			
			_job.getBays(bay1, bay2);
			self.myBay := null;
			self.myBay := bay1.CM_BayVoyage;
			
			
			js := self.myJob.myJobSheet.CM_VoyageJobSheet;
			if js &lt;&gt; null then
				self.myJobSheet := js;
				self.craneID := js.crane;
			endif;
			self.transferType := _job.getTransferType;	//12 Mar 2018	NDL	TFS 37444
		endif;
	endif;

end;
</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="setJSFromWLE" id="44122103-0e08-4c96-b209-c521ea6b0973">
        <updating/>
        <source>setJSFromWLE(_wle : CM_WorkListEntry) updating;
// ---------------------------------------------------------------------------
// Created:		19 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 07/12/2010	cnwcs5	par 23714/ccms 1132 - record machine history
// 16 Jan 2023 	navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
vars
	js : CM_VoyageJobSheet;
	slotReq : CM_SlotRequest;
	starboard : Boolean;
	localWle : CM_WorkListEntry;
	voyageWle : CM_VoyageWLE;
	otherDDWle : CM_WorkListEntry;
	drVoyageWle : CM_WorkListEntry;
	job			: CM_Job;
	voyJobArr	: CM_JobArray;
	voyJob		: CM_VoyageWorkPointJob;
begin

	localWle := _wle;
	
	//07 Feb 2012	NDL	Par 31102
	if localWle &lt;&gt; null then
		if localWle.isKindOf(CM_VoyageWLE) then
			voyageWle := localWle.CM_VoyageWLE;
			
			//11 Mar 2020	NDL	TFS 48774
			if voyageWle &lt;&gt; null then
				drVoyageWle := voyageWle.getDRLinkedWLE();
				if drVoyageWle &lt;&gt; null and drVoyageWle.isKindOf( CM_VoyageWLE ) and not drVoyageWle.isReceipt then
					voyageWle := drVoyageWle.CM_VoyageWLE;
				endif;
			endif;
			
		elseif localWle.myTrackedItem &lt;&gt; null and localWle.myTrackedItem.directDelivery then
			otherDDWle := localWle.myTrackedItem.getDirectDeliverySourceWle(localWle);
			if otherDDWle = null or otherDDWle = localWle or not otherDDWle.isKindOf(CM_VoyageWLE) then
				otherDDWle := localWle.myTrackedItem.getDirectDeliveryTargetWle(localWle);
			endif;
			if otherDDWle &lt;&gt; null and otherDDWle.isKindOf(CM_VoyageWLE) then
				voyageWle := otherDDWle.CM_VoyageWLE;
			endif;
			
		endif;
		
	endif;
	
	if voyageWle &lt;&gt; null then
		//self.locationShip := _wle.locationTarget;
		//self.locationYard := _wle.locationSource;	
		self.locationShip := voyageWle.locationTarget;		//25 Jun 2020	NDL	TFS 49495
		self.locationYard := voyageWle.locationSource;		//25 Jun 2020	NDL	TFS 49495
		
		if  voyageWle.myRequest.isKindOf(CM_SlotRequest) then
		//	slotReq := _wle.myRequest.CM_SlotRequest;
			slotReq := voyageWle.myRequest.CM_SlotRequest;	//25 Jun 2020	NDL	TFS 49495
		elseif voyageWle.myRequest.isKindOf(CM_RORORequest) then
		//	self.myDeck:=_wle.myRequest.CM_RORORequest.getDeck();
			self.myDeck:=voyageWle.myRequest.CM_RORORequest.getDeck();	//25 Jun 2020	NDL	TFS 49495
		endif;
		
		if slotReq &lt;&gt; null then
			self.myBay := slotReq.myBay;
			starboard := true;
			if self.myBay.isKindOf(CM_BayVoyage) then
				starboard := not self.myBay.CM_BayVoyage.myCellularVoyageStructure.myVoyage.starboardBerthed;
			endif;
			self.isTwinLift := slotReq.isTwinLift(starboard);
		endif;
		
	//	self.myJob := _wle.job.CM_VoyageJob;
		self.myJob := voyageWle.job.CM_VoyageJob;	//11 Mar 2020	NDL	TFS 48847
		if self.myJob &lt;&gt; null then
			if self.myJob.myShift &lt;&gt; null then // TFS 2315
				self.shiftCode := self.myJob.myShift.code; // TFS 2315
				self.shiftStart := self.myJob.myShift.startDateTime; // TFS 2315
				self.shiftEnd := self.myJob.myShift.endDateTime; // TFS 2315
			endif;
			js := self.myJob.myJobSheet.CM_VoyageJobSheet;
			if js &lt;&gt; null then
				self.myJobSheet := js;
				self.craneID := js.crane;
				self.createKPIController();
				self.addReleaseToHistory (voyageWle);	// 06/12/2010 cnwcs5 par 23714/ccms 1132
			endif;
			self.transferType := self.myJob.getTransferType;	//12 Mar 2018	NDL	TFS 37444
		endif;
	endif;
	
	if localWle.isKindOf(CM_WOWLE) then							//16.01.2023 navhl20 #62066
		job := localWle.job;
		voyJobArr := job.getAllVoyJobs();
		foreach voyJob in voyJobArr as CM_VoyageWorkPointJob do
			//if voyJob.plannedLocations &lt;&gt; null then
			if voyJob.plannedLocation &lt;&gt; null then //26/08/2024	navkc1 CR 63588 Task 63589
				self.myJob := voyJob;
			endif;
		endforeach;
		if self.myJob &lt;&gt; null then
			if self.myJob.myJobSheetForWorkPoint &lt;&gt; null and self.myJob.myJobSheetForWorkPoint.myShift &lt;&gt; null then
				self.shiftCode := self.myJob.myJobSheetForWorkPoint.myShift.code;
				self.shiftStart := self.myJob.myJobSheetForWorkPoint.myShift.startDateTime;
				self.shiftEnd := self.myJob.myJobSheetForWorkPoint.myShift.endDateTime;
			endif;
			js := self.myJob.myJobSheet.CM_VoyageJobSheet;
			if js &lt;&gt; null then
				self.myJobSheet := js;
				self.craneID := js.crane;
				self.createKPIController();
			endif;
			self.transferType := self.myJob.getTransferType;
		endif;
	endif;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="setLocationYard" id="2cb7cd15-f1b7-4749-bafc-f77abc04666b">
        <updating/>
        <source>setLocationYard(_locationID : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2025	jlier1	Initial creation 36155

*/

vars

begin
	if _locationID &lt;&gt; null then
		self.locationYard:=_locationID;
	endif;
epilog

end;</source>
        <Parameter name="_locationID" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="e772a16e-5026-4f3e-8391-89b07c7824e5">
        <updating/>
        <source>setMyTrackedItem(pTI: CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Nov 2014	cnwndl1	Initial creation	Par 35015
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars

begin

	inheritMethod(pTI, _tiTransCntrl);
	
	// 37558 Feb 2016 tranship use the import voyage to get voyage invoicing right
	if self.imExStatus = TI_IMEX_STATUS_TRANSHIP then
	
		if app.myRoot.isClientDPH then	//23 Mar 2016	NDL	TFS	1697 - It would be normal to leave this as the export voyage... but apparently not for DPH.																														
		
			// I am a tranship. and being released
			if pTI.myVoyageTranshipImport &lt;&gt; null then
				self.voyage := pTI.myVoyageTranshipImport;	
				self.voyageCode := pTI.myVoyageTranshipImport.code;
				self.myVoyageRelivant := pTI.myVoyageTranshipImport;
			endif;
		
		endif;
	
	else
		self.stevedoreCode := pTI.getStevedoreCodeRelease();   //02.10.2020 cnwma1 TFS #50112
	endif;

epilog

end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
    <JadeMethod name="setTiReleasedTransportMode" id="fd14faf6-a792-4200-b791-655be27aa459">
        <source>setTiReleasedTransportMode(_ti:CM_TrackedItem input);
// ---------------------------------------------------------------------------
// Created:     24 May 2004 by cnwrs1
//
// Purpose:     PAR8243     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	_ti.setReleasedTransportMode(TI_TRANSMODE_SHIP);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="acab51e1-7e36-42eb-a66e-049d1378d2f4">
        <updating/>
        <source>updateTI(_passport: CM_Passport input) updating;

/*
Date				Who		Reason
04 November 2009	cnwar2	Initial creation #21489

*/
vars
	ti	: CM_TrackedItem;
	wle	: CM_WorkListEntry;
	
begin
	inheritMethod(_passport);
	
	ti := self.myTrackedItem;
	if ti = null then
		return;
	endif;

	foreach wle in ti.allWorklistEntries do
		wle.updateForRelease();
	endforeach;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
