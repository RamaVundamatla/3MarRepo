// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.myAssistant.YRD_Assistant.comboBoxRailLine(self.cmbRailRake, combobox.listObject.CM_Rail, null);	
