    <JadeMethod name="showThumbnailData" id="0997cf09-5419-4f42-91a3-f8986f65d539">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theGLCode,
	rootGLCode : CM_GLCode;
begin
	theGLCode := obj.CM_GLCode;
	rootGLCode := self.myCurrentBank.getRootGLCode();

	if theGLCode = null then
		self.btnDeleteTV.enabled := false;
		self.btnEditTV.enabled := false;
	else
		if theGLCode.charges.size = 0 and theGLCode.services.size = 0 and theGLCode &lt;&gt; rootGLCode then
			self.btnDeleteTV.enabled := true;
		else
			self.btnDeleteTV.enabled := false;
		endif;
		self.btnEditTV.enabled := true;
	endif;

	self.tblThumb.rows := 0;
	self.tblThumb.columns := 2;
	self.showThumbnailForDef(ETDef_InvMaintGL, theGLCode);

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="52ca768f-6006-4c41-80e4-a19e014f03e9">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			Filters the table once the user finishes typing

Parameters:			eventTag	Integer	The event tag triggered

Return Value:		NONE

Date				Who		Reason
14 September 2021	navpw1	Initial creation TFS: 51912

*/

begin
	if eventTag = self.Timer_TableData_Filter then
		self.doFilterTable();
	endif;

	inheritMethod(eventTag);
	
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="cb7823ac-e221-4274-af0d-1296de3b4a8f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006169, locale);
end;</source>
    </JadeMethod>
</GUIClass>
