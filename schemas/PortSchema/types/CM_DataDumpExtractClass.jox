        <Parameter name="_deleteSource" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupCommon" id="a1fca7f8-bf32-4ca1-8607-52c71055ec3c">
        <updating/>
        <source>setupCommon(_proxyClass: CM_DataDumpExtractClass) updating;
/*
Purpose:		Assign proxy values to self	

Parameters:		Proxy CM_DataDumpExtractClass

Return Value:		

Date			Who		Reason
22 April 2010	conkc1	Initial creation

*/
vars

begin
	self.extractedUpToDateTime       := _proxyClass.extractedUpToDateTime;
	self.deleteAction                := _proxyClass.deleteAction;
	self.deleteActionColumnName      := _proxyClass.deleteActionColumnName;
	self.deleteActionColumnPos       := _proxyClass.deleteActionColumnPos;
	self.exportedTimestampColumnName := _proxyClass.exportedTimestampColumnName;
	self.exportedTimestampColumnPos  := _proxyClass.exportedTimestampColumnPos;
	self.lastOperation               := _proxyClass.lastOperation;
	self.lastOperationColumnName     := _proxyClass.lastOperationColumnName;
	self.lastOperationColumnPos      := _proxyClass.lastOperationColumnPos;
	self.oidColumnPos                := _proxyClass.oidColumnPos;
	self.sqlTableName                := _proxyClass.sqlTableName;
	self.storedProcedureInsert       := _proxyClass.storedProcedureInsert;
	self.storedProcedureDelete       := _proxyClass.storedProcedureDelete;
	self.storedProcedureDrop         := _proxyClass.storedProcedureDrop;
	self.storedProcedureUpdate       := _proxyClass.storedProcedureUpdate;
	self.myDataDumpClass             := _proxyClass.myDataDumpClass;

epilog

end;</source>
        <Parameter name="_proxyClass" type="CM_DataDumpExtractClass"/>
    </JadeMethod>
    <JadeMethod name="updateSQLColumnsSameAsDict" id="9cc2b6ba-688b-49ff-8956-16b30d275623">
        <updating/>
        <source>updateSQLColumnsSameAsDict(_allDataDumpSQLColumns:CM_DataDumpSQLColumnDict)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 May 2010	#cnwdz2	 

*/

vars
	isIdentical : Boolean;
	member1, member2 : Object;
	itr1, itr2 : Iterator;
	numItems : Integer;
begin
	exclusiveLock(self.allDataDumpSQLColumns);
	sharedLock(_allDataDumpSQLColumns);
	numItems := self.allDataDumpSQLColumns.size();
	
	if numItems = _allDataDumpSQLColumns.size then
		isIdentical := true;
		
		if numItems &gt; 0 then
			itr1 := self.allDataDumpSQLColumns.createIterator;
			itr2 := _allDataDumpSQLColumns.createIterator;
			
			while itr1.next(member1) do
				if not itr2.next(member2) or
						member1 &lt;&gt; member2 then
					isIdentical := false;
					break;
				endif;
			endwhile;
		endif;
	endif;
	
	if not isIdentical then
		self.allDataDumpSQLColumns.clear;
		_allDataDumpSQLColumns.copy(self.allDataDumpSQLColumns);
	endif;
epilog
	delete itr1;
	delete itr2;
	unlock(self.allDataDumpSQLColumns);
	if _allDataDumpSQLColumns &lt;&gt; null then
		unlock(_allDataDumpSQLColumns);
	endif;
end;</source>
        <Parameter name="_allDataDumpSQLColumns" type="CM_DataDumpSQLColumnDict"/>
    </JadeMethod>
    <JadeMethod name="validateCommon" id="d4998bf3-0c35-4ad2-84d7-8ee6617c69e9">
        <source>validateCommon();
// ---------------------------------------------------------------------------
// Created:     27 May 2003 by cnwsb1
//13/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
// ---------------------------------------------------------------------------
vars
	realFeature : CM_DataDumpFeature;
	realFeatures : CM_DataDumpFeatureSet;
	sqlColumn    : CM_DataDumpSQLColumn;
begin
	if self.lastOperationColumnName &lt;&gt; null then
		if self.lastOperationColumnName.startsWith(self.lastOperationColumnName.truncatedAt(1).toUpper()) or 
		   not self.lastOperationColumnName.containsOnlyAlphaAndReal()  then
			app.raiseCMException1(Err_InvalidOpColumnFormat, self.lastOperationColumnName, null, null);
			return;
		endif;
	endif;
		
	if self.exportedTimestampColumnName &lt;&gt; null then
		if self.exportedTimestampColumnName.startsWith(self.exportedTimestampColumnName.truncatedAt(1).toUpper()) or 
		   not self.exportedTimestampColumnName.containsOnlyAlphaAndReal() then
			app.raiseCMException1(Err_InvalidExpDTColumnFormat, self.lastOperationColumnName, null, null);
			return;
		endif;
	endif;
	
	if self.deleteAction = self.DeleteOpt_UpdateFlag then
		if self.deleteActionColumnName = null then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(SQLNative_Delete_column), null, null);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(SQLNative_Delete_column), null, null); // cnwdb2	PAR 35364
			return;
		endif;
	endif;
	
	if self.deleteActionColumnName &lt;&gt; null then
		if self.deleteActionColumnName.startsWith(self.deleteActionColumnName.truncatedAt(1).toUpper()) or 
		   not self.deleteActionColumnName.containsOnlyAlphaAndReal then
			app.raiseCMException1(Err_InvalidDeleteColumnFormat, self.deleteActionColumnName, null, null);
			return;
		endif;
	endif;
	
	if self.myDataDumpExtractDef.extractFormat =  CM_DataDumpExtractDef.FmtSQLNative and self.sqlTableName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(SQLTableName), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(SQLTableName), null, null); // cnwdb2	PAR 35364


		return;
	endif;
	
	if self.allDataDumpFeatures.isEmpty then
	//	app.raiseCMException1(REQUIRED_FIELD, self.className &amp; ' - at least one feature must be added', null, null);
		//app.raiseCMException1(Input_required_field_Required, self.className &amp; ' - at least one feature must be added', null, null); // cnwdb2	PAR 35364
		app.raiseCMException1(ERR_NoFeatureAdded, self.className, null, null); // jlgmd1 27/04/2018 TFS 38242
		return;
	endif;
	
	if self.myDataDumpClass = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "DataDumpClass", null, null);
		app.raiseCMException1(Input_required_field_Required, "DataDumpClass", null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if self.extractedUpToDateTime &lt;&gt; null and
			not self.extractedUpToDateTime.isValid then
		app.raiseCMException(ERR_DATETIME_FORMAT, null, null);
		return;
	endif;
	
	foreach sqlColumn in self.allDataDumpSQLColumns do
		sqlColumn.validateCommon();
	endforeach;
	
	
	create realFeatures transient;
	
	foreach realFeature in self.allDataDumpFeatures do
		if realFeature.myDataDumpClass &lt;&gt; self.myDataDumpClass then
			//write method.qualifiedName;
			app.raiseCMException2(Err_InvalidAttrForClass, realFeature.featureName, self.myDataDumpClass.className, null, null);
		endif;
		if realFeatures.includes(realFeature) then
			//app.raiseCMException2(DuplicateItem, "Feature " &amp; realFeature.featureName, "ExtractClass " &amp; self.myDataDumpClass.className, null, null); //13.06.2022 navds20 53760
			//Feature %1 already exists for ExtractClass %2 : Feature_already_exists_extract
			app.raiseCMException2(Feature_already_exists_extract,realFeature.featureName,self.myDataDumpClass.className, null, null); //13.06.2022 navds20 53760
		else
			realFeatures.add(realFeature);
		endif;
	endforeach;
	
epilog
	delete realFeatures;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="ec8503b5-b35a-4024-aa05-06e7149b0a1b">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		07 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfTransient(method);
	
	//if self.allDataDumpSQLColumns.size &gt; 0 then
	//	app.raiseCMException2(ObjectStillHasEntries, "SQL Columns",
	//			"ExtractClass", null, null);
	//endif;
end;</source>
    </JadeMethod>
</Class>
