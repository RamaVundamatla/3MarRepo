    <JadeMethod name="cnEcSet" id="373bd2fb-0199-4168-a3db-43f7509cce5c">
        <updating/>
        <source>cnEcSet(pValue: String) updating;
// --------------------------------------------------------------------------------
// Created:		30 October 2002 by cnwdad1
//
// Purpose:		Overrides the TextBox class's implementation of this method to reset
//				the receiver's date.
//
// Parameters:	pValue - The string value to set the date to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pValue.Date.isValid() then
		self.setDate(pValue.Date);
	else
		self.setDate(null);
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
