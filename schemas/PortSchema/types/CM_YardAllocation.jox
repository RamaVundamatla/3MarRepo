    <JadeMethod name="isCriteriaIncluded" id="d059d8ad-2fdb-4d25-bd7b-c324e5d70606">
        <source>isCriteriaIncluded( _allTestCriteria : CMIF_Array ) : Boolean;

/*

Purpose:		Check if given criteria are included with this yard allocation

Parameters:			

Return Value:	Returns true when this yard allocation includes all of the given criteria values


Date			Who		Reason
13 August 2008	consw1	Initial creation

*/

vars
	tmpObj			: CMIF_Object;
	realCriteria,
	testCriteria	: CM_YACriteria;
	tmpFound		: Boolean;
	
begin

	foreach tmpObj in _allTestCriteria do
		testCriteria := tmpObj.CMIF_YACriteriaPriority.myProxy.CM_YACriteria;
		tmpFound := false;
		foreach realCriteria in self.allCriteria discreteLock do
			if realCriteria.myYACriteriaType = testCriteria.myYACriteriaType then
				tmpFound := true;
				if (not testCriteria.myYAData.doDataComparisonWithResolution(realCriteria.myYAData)) then
					// data is different
					return false;
				else
					break;
				endif;
			endif;
		endforeach;
		if (not tmpFound) then
			return false;
		endif;
	endforeach;

	return true;

end;
</source>
        <Parameter name="_allTestCriteria" type="CMIF_Array"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isExportAllocation" id="855204e8-9a4f-4653-9fe2-d9c24996c229">
        <source>isExportAllocation() : Boolean;
// ---------------------------------------------------------------------------
// Created:     11 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	criteria : CM_YACriteria;
	imex : CM_IMEXStatus;
begin

	criteria := self.getCriteriaOfTypeValue(YACriteriaType_ImexStatus);
	if criteria = null then
		return false;
	endif;
	
	imex :=  criteria.myYAData.CM_YADataObjects.allObjects.first.CM_IMEXStatus;
	if imex &lt;&gt; null then
		return (imex.code = TI_IMEX_STATUS_EXPORT);
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForGenCargoAllocationRow" id="6c82b845-3290-4a5e-afca-552051604c19">
        <source>isForGenCargoAllocationRow():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2021	navndl1	Initial creation	TFS 49912

*/

vars

	ta : CM_TerminalArea;

begin

	if not self.allTerminalAreas.isEmpty then
		ta := self.allTerminalAreas.first;
	endif;
	
	if ta = null or not ta.isKindOf( CM_GeneralCargoAllocRowArea ) then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForMTs" id="5ef13f9c-816f-4778-ab86-56de4e7680d7">
        <source>isForMTs() : Boolean;

/*

Purpose:			Returns true if the allocation is specificallt for MT
//cnwrd1 ccms 1303 14.11.2012
Parameters:			

Return Value:		


Date		Who		Reason
14 November 2012	cnwrd1	Initial creation

*/

vars
	yaCriteria : CM_YACriteria;
	mtCommodity : String;
	comm		: CM_Commodity;
begin

	yaCriteria := self.getCriteriaOfTypeValue(YACriteriaType_IsEmpty);
	
	if yaCriteria &lt;&gt; null then
		return yaCriteria.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE;
	endif;

	yaCriteria := null;
	
	yaCriteria := self.getCriteriaOfTypeValue(YACriteriaType_Commodity);
	
	if yaCriteria = null then
		return false; // no commodity so ok
	endif;
	
	mtCommodity := self.getTerminal.getDefaultEmptyCommodity();
	comm := app.myRoot.allCommodities[mtCommodity];
	
	if  yaCriteria.myYAData.CM_YADataObjects.allObjects.includes(comm) then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
