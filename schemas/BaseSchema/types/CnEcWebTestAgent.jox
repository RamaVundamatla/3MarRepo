// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Updates the last time a Web Test was run.
//
// Parameters:	The first parameter is the object to be updated.
//              If pRequiredEdition is greater than zero, the method will check that
//              the latest edition of the object is equal to pRequiredEdition. If not
//              then an ObjectOutOfDate error will be returned.
//
//              The remaining parameters are the object properties to update.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
/*
	Note that the timeStamp for the Last Run timestamp is not sent as a parameter
	because the the value will be gotten at the time this transaction is invoked
	(using a locally declared variable).
*/
vars
	timeRun	: TimeStamp;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers (local exception handlers which are
	// disarmed when the method returns).
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// If the object is invalid, we want our exception handler to return the specified error.
	self.agentRegisterObjectAndError(pWebTestToUpdate, "The Web Test being updated is either null or is not valid.");

	beginTransaction;

	// Exclusive transaction lock to obtain the latest edition of the object and
	// lock it. We need the latest edition to check it against requiredEdition.
	// This lock be released automatically at the next commit/abort transaction.
	// We obtain an exclusive lock (as opposed to a shared lock) as we're about
	// about to update the object, and JADE will automatically try to lock it
	// exclusively (if we don't already have it) before updating it. Getting an
	// exclusive lock up front avoids JADE having to upgrade the lock from shared
	// to exclusive at the point the object is updated.
	exclusiveLock(pWebTestToUpdate);

	// If the exclusiveLock gets an exception, our handler will resume to here.
	if self.lastError = null and pRequiredEdition &gt; 0 then
		// We obtained the lock, now check the edition.
		if pWebTestToUpdate.edition() &lt;&gt; pRequiredEdition then
			// The edition has changed, so the object on which the sender based
			// this update is out of date.
			self.agentSetError("The Web Test has been changed by another process.  Please refresh the Test and try again.");
		endif;
	endif;

	// If we're still error free, perform the operation.
	if self.lastError = null then
		pWebTestToUpdate.updateTimeLastRun(timeRun);
	endif;

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error code to the caller (which will be zero if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pWebTestToUpdate" type="CnEcWebTest" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxWebTestResultsPurge" id="365c7921-7949-4395-9ef7-3d9c3aca2a81">
        <updating/>
        <source>trxWebTestResultsPurge(pWebTestMessages:CnEcWebTestMessageDict):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Transaction method to purge the Test Results of each Test Message
//				in the supplied dictionary.
//              Allows multiple Test Messages to be processed in one transaction.
//
// Parameters:	The dictionary of Test Messages to be processed.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	testMessage		: CnEcWebTestMessage;

begin
	// Always initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Start the transaction.
	beginTransaction;

	// Process each Test Message.
	foreach testMessage in pWebTestMessages do
		// If an exception is raised during the "purge" method...
		testMessage.allTestResults.purge();

		// ...our exception handlers will resume to here.
		if self.lastError &lt;&gt; null then
			// We got an error so stop the operation.
			break;
		endif;
	endforeach;

	if self.lastError = null then
		// We finished the operations with no errors so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error to the caller (which will be null if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pWebTestMessages" type="CnEcWebTestMessageDict"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxWebTestTestMessageAdd" id="8a461da2-d0c4-4ac3-a0a5-5a3e400826a6">
        <updating/>
        <source>trxWebTestTestMessageAdd(pWebTest:CnEcWebTest io;
						pTestMessageToAdd:CnEcWebTestMessage;
						pRelativeIndex:Integer;
						pIsAbove:Boolean):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Transaction method to insert a Test Message into a Web Test's list
//				of Test Messages.
//
// Parameters:	The Web Test owner, the Test Message to insert, the Test Message
//				relative to which the message will be inseted, and a flag to
//				indicate whether to insert above or below thew relative message.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	messageIndex	: Integer;

begin
	// Always initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Start the transaction.
	beginTransaction;

	if pWebTest.allMessagesToTest.isEmpty() then
		// If this is the first member, then just add it to the collection.
		pWebTest.allMessagesToTest.add(pTestMessageToAdd);

	elseif pRelativeIndex = CNEC_NULL_INDEX then
		// The new member will be added to either the top or the end of the collection.

		if pIsAbove then
			// Add Test Message to the top of the array.
			pWebTest.allMessagesToTest.insert(1, pTestMessageToAdd);
		else
			// Add Test Message to the end of the array.
			pWebTest.allMessagesToTest.add(pTestMessageToAdd);
		endif;
	else
		// The new member is to be inserted relative to an existing member.

		if pIsAbove then
			messageIndex	:=	pRelativeIndex - 1;

			if messageIndex &lt; 1 then
				messageIndex	:=	1;
			endif;

			// Add Test Message immediately above the relative Test Message object.
			pWebTest.allMessagesToTest.insert(messageIndex, pTestMessageToAdd);
		else
			messageIndex	:=	pRelativeIndex + 1;

			if messageIndex &lt; 1 then
				messageIndex	:=	1;
			elseif messageIndex &gt; (pWebTest.allMessagesToTest.size() + 1) then
				messageIndex	:=	(pWebTest.allMessagesToTest.size() + 1);
			endif;

			// Add Test Message immediately below the relative Test Message object.
			pWebTest.allMessagesToTest.insert(messageIndex, pTestMessageToAdd);
		endif;
	endif;

	if self.lastError = null then
		// We finished the operations with no errors so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error to the caller (which will be null if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pWebTest" type="CnEcWebTest" usage="io"/>
        <Parameter name="pTestMessageToAdd" type="CnEcWebTestMessage"/>
        <Parameter name="pRelativeIndex" type="Integer"/>
        <Parameter name="pIsAbove" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxWebTestTestMessageRemove" id="cd86dfc3-5366-47a3-b918-85e0d9564141">
        <updating/>
        <source>trxWebTestTestMessageRemove(pWebTest:CnEcWebTest io;
							pTestMessageIndex:Integer):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Transaction method to insert a Test Message into a Web Test's list
//				of Test Messages.
//
// Parameters:	The Web Test owner, the Test Message to insert, the Test Message
//				relative to which the message will be inseted, and a flag to
//				indicate whether to insert above or below thew relative message.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	messageIndex	: Integer;

begin
	// Always initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Start the transaction.
	beginTransaction;

	pWebTest.allMessagesToTest.removeAt(pTestMessageIndex);

	if self.lastError = null then
		// We finished the operations with no errors so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error to the caller (which will be null if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pWebTest" type="CnEcWebTest" usage="io"/>
        <Parameter name="pTestMessageIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxWebTestUpdate" id="8e4959fa-1795-41ee-91b5-6be0746e04ac">
        <updating/>
        <source>trxWebTestUpdate(pWebTestToUpdate:CnEcWebTest input;
				pRequiredEdition:Integer;
				pTestCycles:Integer;
				pIsStopOnMessageFail:Boolean):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Update a Web Test.
//
// Parameters:	The first parameter is the object to be updated.
//              If pRequiredEdition is greater than zero, the method will check that
//              the latest edition of the object is equal to pRequiredEdition. If not
//              then an ObjectOutOfDate error will be returned.
//
//              The remaining parameters are the object properties to update.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers (local exception handlers which are
	// disarmed when the method returns).
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// If the object is invalid, we want our exception handler to return the specified error.
	self.agentRegisterObjectAndError(pWebTestToUpdate, "The Web Test being updated is either null or is not valid.");

	beginTransaction;

	// Exclusive transaction lock to obtain the latest edition of the object and
	// lock it. We need the latest edition to check it against requiredEdition.
	// This lock be released automatically at the next commit/abort transaction.
	// We obtain an exclusive lock (as opposed to a shared lock) as we're about
	// about to update the object, and JADE will automatically try to lock it
	// exclusively (if we don't already have it) before updating it. Getting an
	// exclusive lock up front avoids JADE having to upgrade the lock from shared
	// to exclusive at the point the object is updated.
	exclusiveLock(pWebTestToUpdate);

	// If the exclusiveLock gets an exception, our handler will resume to here.
	if self.lastError = null and pRequiredEdition &gt; 0 then
		// We obtained the lock, now check the edition.
		if pWebTestToUpdate.edition() &lt;&gt; pRequiredEdition then
			// The edition has changed, so the object on which the sender based
			// this update is out of date.
			self.agentSetError("The Web Test has been changed by another process.  Please refresh the Test and try again.");
		endif;
	endif;

	// If we're still error free, perform the operation.
	if self.lastError = null then
		pWebTestToUpdate.updateMe(pTestCycles, pIsStopOnMessageFail);
	endif;

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error code to the caller (which will be zero if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pWebTestToUpdate" type="CnEcWebTest" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pTestCycles" type="Integer"/>
        <Parameter name="pIsStopOnMessageFail" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="valCommonFieldCreate" id="a9bbf6de-dbfa-45a2-b19e-37a286adb6e9">
        <updating/>
        <source>valCommonFieldCreate(	pWebTest:CnEcWebTest;
						pFieldName:String;
						pDefaultValue:String;
						pIsValidateField:Boolean;
						pIsValidateTagValue:Boolean;
						pIsValidateEqualTo:Boolean):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Validation for creating a Test Common Field.
//
// Parameters:	The object's properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	trimmedName	: String;
	commonField	: CnEcWebTestCommonField;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if pWebTest = null then
		return self.agentSetError("Please select the Web Test to which the field will be added.");
	endif;

	trimmedName	:=	pFieldName.trimBlanks;
	if trimmedName = null then
		return self.agentSetError("The name of the Common Field cannot be null.");
	endif;

	// If the Web Test object is invalid, we want our exception handlers to return a message saying so.
	self.agentRegisterObjectAndError(pWebTest, "Please select the Web Test to which the field will be added.");

	commonField	:=	pWebTest.allCommonFields[trimmedName];
	// If the above operation gets an exception, our handler will resume to here.
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	if commonField &lt;&gt; null then
		return self.agentSetError("A Common Field already exists for Test '" &amp; pWebTest.testName &amp; "' with this name (" &amp; trimmedName &amp; ").");
	endif;

	return null;
end;</source>
        <Parameter name="pWebTest" type="CnEcWebTest"/>
        <Parameter name="pFieldName" type="String"/>
        <Parameter name="pDefaultValue" type="String"/>
        <Parameter name="pIsValidateField" type="Boolean"/>
        <Parameter name="pIsValidateTagValue" type="Boolean"/>
        <Parameter name="pIsValidateEqualTo" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="valCommonFieldUpdate" id="a59110fd-6100-44b7-9052-b89820644c2a">
        <updating/>
        <source>valCommonFieldUpdate(pCommonFieldToUpdate:CnEcWebTestCommonField;
					pDefaultValue:String;
					pIsValidateField:Boolean;
					pIsValidateTagValue:Boolean;
					pIsValidateEqualTo:Boolean):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Validation for updating a Test Common Field.
//
// Parameters:	The object's (changeable) properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	trimmedName	: String;
	commonField	: CnEcWebTestCommonField;
	webTest		: CnEcWebTest;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if pCommonFieldToUpdate = null then
		return self.agentSetError("The Common Field being updated is either null or is not valid.");
	endif;

// This test isn't required here since we don't allow the name to be changed.
//	trimmedName := name.trimBlanks;
//	if trimmedName = null then
//		return self.agentSetError("error message");
//	endif;

	// If object is invalid, we want our handlers to return an invalid object message.
	self.agentRegisterObjectAndError(pCommonFieldToUpdate, "The Common Field being updated is either null or is not valid.");

	sharedLock(pCommonFieldToUpdate);
	// If the above operation gets an exception, our handler will resume to here
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	webTest	:=	pCommonFieldToUpdate.myWebTest;
	if webTest = null then
		return self.agentSetError("Please select the Web Test to which the field will be added.");
	endif;

	// If BaseRoot is invalid, we want our exception handlers to return a message saying so.
	self.agentRegisterObjectAndError(webTest, "Please select the Web Test to which the field will be added.");

	commonField	:=	webTest.allCommonFields[pCommonFieldToUpdate.fieldName];
	// If the above operation gets an exception, our handler will resume to here.
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	if pCommonFieldToUpdate &lt;&gt; null and commonField &lt;&gt; pCommonFieldToUpdate then
		return self.agentSetError("A Common Field already exists for Test '" &amp; webTest.testName &amp; "' with this name (" &amp; trimmedName &amp; ").");
	endif;

	return null;
epilog
	// Release our locks in the epilog so that we'll release them even if we exit via an
	// exception. If we don't have an object locked, the unlock does nothing. If we're
	// in transaction state, transaction duration locks won't be released until the next
	// commit or abort transaction (even if we explicitly unlock them). That allows a
	// method to be well behaved and release its locks without having to be aware of the
	// transaction state of the process.
	if pCommonFieldToUpdate &lt;&gt; null then
		unlock(pCommonFieldToUpdate);
	endif;
end;</source>
        <Parameter name="pCommonFieldToUpdate" type="CnEcWebTestCommonField"/>
        <Parameter name="pDefaultValue" type="String"/>
        <Parameter name="pIsValidateField" type="Boolean"/>
        <Parameter name="pIsValidateTagValue" type="Boolean"/>
        <Parameter name="pIsValidateEqualTo" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="valTestMessageCreate" id="fb2257f2-11f0-492a-9659-a955ed7cf765">
        <updating/>
        <source>valTestMessageCreate(	pMessageName:String;
						pMessageData:String;
						pWebServerName:String;
						pWebServerUrl:String):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Validation for creating a Web Test Message.
//
// Parameters:	The object's properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	trimmedName	: String;
	testMessage	: CnEcWebTestMessage;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if app.myBaseRoot = null then
		return self.agentSetError("The BaseRoot object is missing or not set.");
	endif;

	trimmedName	:=	pMessageName.trimBlanks;
	if trimmedName = null then
		return self.agentSetError("The name of the Test cannot be null.");
	endif;

	// If BaseRoot is invalid, we want our exception handlers to return a message saying so.
	self.agentRegisterObjectAndError(app.myBaseRoot, "The BaseRoot object is missing or not set.");

	testMessage	:=	app.myBaseRoot.allWebTestMessages[trimmedName];
	// If the above operation gets an exception, our handler will resume to here.
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	if testMessage &lt;&gt; null then
		return self.agentSetError("A Web Test Message already exists with this name (" &amp; trimmedName &amp; ").");
	endif;

	if pWebServerName = null then
		return self.agentSetError("Please enter the name of the Server to which the message will be sent.");
	endif;

	return null;
end;</source>
        <Parameter name="pMessageName" type="String"/>
        <Parameter name="pMessageData" type="String"/>
        <Parameter name="pWebServerName" type="String"/>
        <Parameter name="pWebServerUrl" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="valTestMessageUpdate" id="c5814dd3-5952-43c1-8a91-4699fb030090">
        <updating/>
        <source>valTestMessageUpdate(pTestMessageToUpdate:CnEcWebTestMessage;
					pMessageData:String;
					pWebServerName:String;
					pWebServerUrl:String):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Validation for updating a Web Test Message.
//
// Parameters:	The object's (changeable) properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	trimmedName	: String;
	testMessage	: CnEcWebTestMessage;
	baseRoot	: CnEcBaseRoot;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if pTestMessageToUpdate = null then
		return self.agentSetError("The Web Test Message being updated is either null or is not valid.");
	endif;

// This test isn't required here since we don't allow the name to be changed.
//	trimmedName := name.trimBlanks;
//	if trimmedName = null then
//		return self.agentSetError("error message");
//	endif;

	// If object is invalid, we want our handlers to return an invalid object message.
	self.agentRegisterObjectAndError(pTestMessageToUpdate, "The Web Test Message being updated is either null or is not valid.");

	sharedLock(pTestMessageToUpdate);
	// If the above operation gets an exception, our handler will resume to here
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	baseRoot	:=	pTestMessageToUpdate.myBaseRoot;
	if baseRoot = null then
		return self.agentSetError("The BaseRoot object is missing or not set.");
	endif;

	// If BaseRoot is invalid, we want our exception handlers to return a message saying so.
	self.agentRegisterObjectAndError(baseRoot, "The BaseRoot object is missing or not set.");

	testMessage	:=	baseRoot.allWebTestMessages[pTestMessageToUpdate.messageName];
	// If the above operation gets an exception, our handler will resume to here.
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	if pTestMessageToUpdate &lt;&gt; null and testMessage &lt;&gt; pTestMessageToUpdate then
		return self.agentSetError("A Web Test Message already exists with this name (" &amp; trimmedName &amp; ").");
	endif;

	if pWebServerName = null then
		return self.agentSetError("Please enter the name of the Server to which the message will be sent.");
	endif;

	return null;
epilog
	// Release our locks in the epilog so that we'll release them even if we exit via an
	// exception. If we don't have an object locked, the unlock does nothing. If we're
	// in transaction state, transaction duration locks won't be released until the next
	// commit or abort transaction (even if we explicitly unlock them). That allows a
	// method to be well behaved and release its locks without having to be aware of the
	// transaction state of the process.
	if pTestMessageToUpdate &lt;&gt; null then
		unlock(pTestMessageToUpdate);
	endif;
end;</source>
        <Parameter name="pTestMessageToUpdate" type="CnEcWebTestMessage"/>
        <Parameter name="pMessageData" type="String"/>
        <Parameter name="pWebServerName" type="String"/>
        <Parameter name="pWebServerUrl" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="valTestResultCreate" id="efb1da66-e36d-4c32-b8bc-aac662d58941">
        <updating/>
        <source>valTestResultCreate(pTestMessage:CnEcWebTestMessage;
					pTimeRequested:TimeStamp;
					pTimeReceived:TimeStamp;
					pResponseData:String):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Validation for creating a Web Test Result.
//
// Parameters:	The object's properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	testResult	: CnEcWebTestResult;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if pTestMessage = null then
		return self.agentSetError("The Test Message object is missing or not set.");
	endif;

	if pTimeRequested = null then
		return self.agentSetError("The Requested TimeStamp of the Test Result cannot be null.");
	endif;

	if pTimeReceived = null then
		return self.agentSetError("The Requested TimeStamp of the Test Result cannot be null.");
	endif;

	// If BaseRoot is invalid, we want our exception handlers to return a message saying so.
	self.agentRegisterObjectAndError(pTestMessage, "The Test Message object is missing or not set.");

	testResult	:=	pTestMessage.allTestResults[pTimeRequested, pTimeReceived];
	// If the above operation gets an exception, our handler will resume to here.
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	if testResult &lt;&gt; null then
		return self.agentSetError("A Test Result already exists for this timestamp (" &amp; pTimeRequested.String &amp; "/" &amp; pTimeReceived.String &amp; ").");
	endif;

	return null;
end;</source>
        <Parameter name="pTestMessage" type="CnEcWebTestMessage"/>
        <Parameter name="pTimeRequested" type="TimeStamp"/>
        <Parameter name="pTimeReceived" type="TimeStamp"/>
        <Parameter name="pResponseData" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="valWebTestCreate" id="7ec58fa0-0f1e-47a1-b50f-eef124ef64ef">
        <updating/>
        <source>valWebTestCreate(pTestName:String;
				pTestCycles:Integer;
				pIsStopOnMessageFail:Boolean;
				pIsCloneFields:Boolean;
				pCommonFieldColl:CnEcWebTestCommonFieldDict):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Validation for creating a Web Test.
//
// Parameters:	The object's properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	trimmedName	: String;
	webTest		: CnEcWebTest;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if app.myBaseRoot = null then
		return self.agentSetError("The BaseRoot object is missing or not set.");
	endif;

	trimmedName	:=	pTestName.trimBlanks;
	if trimmedName = null then
		return self.agentSetError("The name of the Test cannot be null.");
	endif;

	// If BaseRoot is invalid, we want our exception handlers to return a message saying so.
	self.agentRegisterObjectAndError(app.myBaseRoot, "The BaseRoot object is missing or not set.");

	webTest	:=	app.myBaseRoot.allWebTests[trimmedName];
	// If the above operation gets an exception, our handler will resume to here.
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	if webTest &lt;&gt; null then
		return self.agentSetError("A Web Test already exists with this name (" &amp; trimmedName &amp; ").");
	endif;

	return null;
end;</source>
        <Parameter name="pTestName" type="String"/>
        <Parameter name="pTestCycles" type="Integer"/>
        <Parameter name="pIsStopOnMessageFail" type="Boolean"/>
        <Parameter name="pIsCloneFields" type="Boolean"/>
        <Parameter name="pCommonFieldColl" type="CnEcWebTestCommonFieldDict"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="valWebTestLastRunUpdate" id="21fca4e6-0bc9-466b-8b66-3f1c0da0721c">
        <updating/>
        <source>valWebTestLastRunUpdate(pWebTestToUpdate:CnEcWebTest):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Validation for updating the last time a Web Test was run.
//
// Parameters:	The object's (changeable) properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
/*
	Note that the timeStamp for the Last Run timestamp is not sent as a parameter
	because the update transaction method will get the value at the time it's
	invoked (using a locally declared variable).
*/
vars
	trimmedName	: String;
	webTest		: CnEcWebTest;
	baseRoot	: CnEcBaseRoot;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if pWebTestToUpdate = null then
		return self.agentSetError("The Web Test being updated is either null or is not valid.");
	endif;

	// If object is invalid, we want our handlers to return an invalid object message.
	self.agentRegisterObjectAndError(pWebTestToUpdate, "The Web Test being updated is either null or is not valid.");

	sharedLock(pWebTestToUpdate);
	// If the above operation gets an exception, our handler will resume to here
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	baseRoot	:=	pWebTestToUpdate.myBaseRoot;
	if baseRoot = null then
		return self.agentSetError("The BaseRoot object is missing or not set.");
	endif;

	// If BaseRoot is invalid, we want our exception handlers to return a message saying so.
	self.agentRegisterObjectAndError(baseRoot, "The BaseRoot object is missing or not set.");

	webTest	:=	baseRoot.allWebTests[pWebTestToUpdate.testName];
	// If the above operation gets an exception, our handler will resume to here.
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	if webTest &lt;&gt; null and webTest &lt;&gt; pWebTestToUpdate then
		return self.agentSetError("A Web Test already exists with this name (" &amp; trimmedName &amp; ").");
	endif;

	return null;
epilog
	// Release our locks in the epilog so that we'll release them even if we exit via an
	// exception. If we don't have an object locked, the unlock does nothing. If we're
	// in transaction state, transaction duration locks won't be released until the next
	// commit or abort transaction (even if we explicitly unlock them). That allows a
	// method to be well behaved and release its locks without having to be aware of the
	// transaction state of the process.
	if pWebTestToUpdate &lt;&gt; null then
		unlock(pWebTestToUpdate);
	endif;
end;</source>
        <Parameter name="pWebTestToUpdate" type="CnEcWebTest"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="valWebTestResultsPurge" id="d3f02920-3d9c-49c9-963c-bb21138a25f1">
        <updating/>
        <source>valWebTestResultsPurge(pWebTestMessages:CnEcWebTestMessageDict):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Validate each order in the supplied dictionary.
//              Allows multiple orders to be processed in one transaction.
//
// Parameters:	The dictionary of objects to be processed.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	validateResult	: String;
	testMessage		: CnEcWebTestMessage;

begin
	// Initialize the activity first
	self.agentInitializeActivity();

	// Arm our base exception handlers
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// If collection is invalid, we want our exception handler to return the specified error.
	self.agentRegisterObjectAndError(pWebTestMessages, "The collection of Web Test Messages is invalid.");

	// Validate each object to delete.
	foreach testMessage in pWebTestMessages do
		// If the Test Message is invalid, we want our handler to raise the specified error.
		self.agentRegisterObjectAndError(testMessage, "An invalid Test Message was encountered.");

		// Make sure we have the latest edition of the object.
		sharedLock(testMessage);
		// If the shared lock gets an exception, our handler will resume to here.
		if self.lastError &lt;&gt; null then
			return self.lastError;
		endif;

		// Validate the object.
//		validateResult	:=	testMessage.validate;
//		if validateResult &lt;&gt; null then
//			// We got an error
//			return self.agentSetError(validateResult);
//		endif;

		// Unlock the object.
		unlock(testMessage);

		// The object is valid, so unregister it.
		self.agentUnregisterObject(testMessage);
	endforeach;

	return null;
epilog
	// Release our locks in the epilog so that we'll release them even if we exit via an
	// exception. If we don't have an object locked, the unlock does nothing. If we're
	// in transaction state, transaction duration locks won't be released until the next
	// commit or abort transaction (even if we explicitly unlock them). That allows a
	// method to be well behaved and release its locks without having to be aware of the
	// transaction state of the process.
	if testMessage &lt;&gt; null then
		unlock(testMessage);
	endif;
end;</source>
        <Parameter name="pWebTestMessages" type="CnEcWebTestMessageDict"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="valWebTestTestMessageAdd" id="e3402224-9d03-4706-95a4-2a518c56bdd8">
        <updating/>
        <source>valWebTestTestMessageAdd(pWebTest:CnEcWebTest;
						pTestMessageToAdd:CnEcWebTestMessage;
						pRelativeIndex:Integer;
						pIsAbove:Boolean):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Validate method for inserting a Test Message into a Web Test's list
//				of Test Messages.
//
// Parameters:	The Web Test owner, the Test Message to insert, the Test Message
//				relative to which the message will be inseted, and a flag to
//				indicate whether to insert above or below thew relative message.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Initialize the activity first
	self.agentInitializeActivity();

	// Arm our base exception handlers
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// If Web Test is invalid, we want our exception handler to return the specified error.
	self.agentRegisterObjectAndError(pWebTest, "Please select the Web Test you wish to add the Message to.");

	// Make sure we have the latest edition of the object.
	sharedLock(pWebTest);
	// If the shared lock gets an exception, our handler will resume to here.
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	// Unlock the object.
	unlock(pWebTest);

	if pTestMessageToAdd = null then
		return self.agentSetError("Please select the Message that you wish to add to the Web Test.");
	endif;

	return null;
epilog
	// Release our locks in the epilog so that we'll release them even if we exit via an
	// exception. If we don't have an object locked, the unlock does nothing. If we're
	// in transaction state, transaction duration locks won't be released until the next
	// commit or abort transaction (even if we explicitly unlock them). That allows a
	// method to be well behaved and release its locks without having to be aware of the
	// transaction state of the process.
	if pWebTest &lt;&gt; null then
		unlock(pWebTest);
	endif;
end;</source>
        <Parameter name="pWebTest" type="CnEcWebTest"/>
        <Parameter name="pTestMessageToAdd" type="CnEcWebTestMessage"/>
        <Parameter name="pRelativeIndex" type="Integer"/>
        <Parameter name="pIsAbove" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="valWebTestTestMessageRemove" id="5b379a2d-6dbc-4b7b-bd6c-8291ef5fad77">
        <updating/>
        <source>valWebTestTestMessageRemove(pWebTest:CnEcWebTest;
							pTestMessageIndex:Integer):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Validate method for removing a Test Message from a Web Test's list
//				of Test Messages.
//
// Parameters:	The Web Test owner, the Test Message to insert, the Test Message
//				relative to which the message will be inseted, and a flag to
//				indicate whether to insert above or below thew relative message.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Initialize the activity first
	self.agentInitializeActivity();

	// Arm our base exception handlers
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// If Web Test is invalid, we want our exception handler to return the specified error.
	self.agentRegisterObjectAndError(pWebTest, "Please select the Web Test you wish to remove the Message from.");

	// Make sure we have the latest edition of the object.
	sharedLock(pWebTest);
	// If the shared lock gets an exception, our handler will resume to here.
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	// Unlock the object.
	unlock(pWebTest);

	if pTestMessageIndex = 0 then
		return self.agentSetError("Please select the Message that you wish to remove from the Web Test.");
	endif;

	return null;
epilog
	// Release our locks in the epilog so that we'll release them even if we exit via an
	// exception. If we don't have an object locked, the unlock does nothing. If we're
	// in transaction state, transaction duration locks won't be released until the next
	// commit or abort transaction (even if we explicitly unlock them). That allows a
	// method to be well behaved and release its locks without having to be aware of the
	// transaction state of the process.
	if pWebTest &lt;&gt; null then
		unlock(pWebTest);
	endif;
end;</source>
        <Parameter name="pWebTest" type="CnEcWebTest"/>
        <Parameter name="pTestMessageIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="valWebTestUpdate" id="bd9f5293-e9bd-4331-b2b2-e22a64b8b74e">
        <updating/>
        <source>valWebTestUpdate(pWebTestToUpdate:CnEcWebTest;
				pTestCycles:Integer;
				pIsStopOnMessageFail:Boolean):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Validation for updating a Web Test.
//
// Parameters:	The object's (changeable) properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	trimmedName	: String;
	webTest		: CnEcWebTest;
	baseRoot	: CnEcBaseRoot;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if pWebTestToUpdate = null then
		return self.agentSetError("The Web Test being updated is either null or is not valid.");
	endif;

// This test isn't required here since we don't allow the name to be changed.
//	trimmedName := name.trimBlanks;
//	if trimmedName = null then
//		return self.agentSetError("error message");
//	endif;

	// If object is invalid, we want our handlers to return an invalid object message.
	self.agentRegisterObjectAndError(pWebTestToUpdate, "The Web Test being updated is either null or is not valid.");

	sharedLock(pWebTestToUpdate);
	// If the above operation gets an exception, our handler will resume to here
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	baseRoot	:=	pWebTestToUpdate.myBaseRoot;
	if baseRoot = null then
		return self.agentSetError("The BaseRoot object is missing or not set.");
	endif;

	// If BaseRoot is invalid, we want our exception handlers to return a message saying so.
	self.agentRegisterObjectAndError(baseRoot, "The BaseRoot object is missing or not set.");

	webTest	:=	baseRoot.allWebTests[pWebTestToUpdate.testName];
	// If the above operation gets an exception, our handler will resume to here.
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	if webTest &lt;&gt; null and webTest &lt;&gt; pWebTestToUpdate then
		return self.agentSetError("A Web Test already exists with this name (" &amp; trimmedName &amp; ").");
	endif;

	return null;
epilog
	// Release our locks in the epilog so that we'll release them even if we exit via an
	// exception. If we don't have an object locked, the unlock does nothing. If we're
	// in transaction state, transaction duration locks won't be released until the next
	// commit or abort transaction (even if we explicitly unlock them). That allows a
	// method to be well behaved and release its locks without having to be aware of the
	// transaction state of the process.
	if pWebTestToUpdate &lt;&gt; null then
		unlock(pWebTestToUpdate);
	endif;
end;</source>
        <Parameter name="pWebTestToUpdate" type="CnEcWebTest"/>
        <Parameter name="pTestCycles" type="Integer"/>
        <Parameter name="pIsStopOnMessageFail" type="Boolean"/>
        <ReturnType type="String"/>
