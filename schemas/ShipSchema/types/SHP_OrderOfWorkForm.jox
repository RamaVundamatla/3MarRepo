    <JadeMethod name="loadDataForFirstTime" id="58ca33e1-e932-46f6-86be-5db505e5b249">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      03 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	tmpH	: Integer;
	regKeys : IntegerArray;
begin


	self.splMain.stretchHeight := true;
	
	self.splMain.parent := self.shtMain;

//	self.fldMain.move(0,self.frmToolbar.clientHeight,self.clientWidth,self.clientHeight); //30 Oct. 2008 cnwdz2 par 18339
	self.splMain.top := 0;
	self.splMain.height := self.shtMain.clientHeight;
	//30 Oct. 2008 cnwdz2 par 18339
//	tmpH := self.clientHeight - self.frmToolbar.clientHeight - 10;
//	self.fldMain.move(0,self.frmToolbar.clientHeight + 2,self.clientWidth,tmpH);
	
//	self.splMain.cnEcResizeContents();
//	self.fldMain.cnEcResizeContents();
	self.fldMain.useSheetBackColors := true;
//	self.fldMain.useSheetBackColors := true;
	self.fldMain.setDefaultSheetBackColors();
	self.fldMain.initSheetBackColors();


	self.doCmbVoyageBuild();
	self.setFormCaption(); // caption and navi

	create regKeys transient;
	regKeys.add(J_key_L);
	self.addRegisteredKeys(regKeys);

	self.doResize(); //30 Oct. 2008 cnwdz2 par 18339
	
epilog
	delete regKeys;
end;</source>
        <access>protected</access>
    </JadeMethod>
