    <JadeMethod name="setExtras" id="61adff96-6760-44f6-8f7f-29cb6041ddbe">
        <updating/>
        <source>setExtras(_authKey, 
			_clientKey,
			_clientSecret,
			_exportDetails,
			_scope,
			_subKeyName,
			_subKeyValue,
			_tenantId : String;
			_isForCams : Boolean;
			_baseAuthEndPoint : String;
			_oAuth2Version  : Integer;
			_resource : String;
			_customer : String;
			_terminal : CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15th July 2025	navra1	Initial creation for //navra1 - MTN-34782 - 15th July 2025
05 Sep 2025 navnk30 JIRA 35707: 4 - YARA | Create a new web service definition to use to send out AG Gateway messages

*/
vars

begin
	inheritMethod(_authKey, _clientKey,_clientSecret, _exportDetails, _scope, _subKeyName, _subKeyValue, _tenantId, _isForCams, _baseAuthEndPoint, _oAuth2Version ,	_resource ,_customer, _terminal);	//05SEP2025 navnk30 JIRA-35707
	
	self.myTerminal := _terminal;
	
epilog

end;</source>
        <Parameter name="_authKey" type="String"/>
        <Parameter name="_clientKey" type="String"/>
        <Parameter name="_clientSecret" type="String"/>
        <Parameter name="_exportDetails" type="String"/>
        <Parameter name="_scope" type="String"/>
        <Parameter name="_subKeyName" type="String"/>
        <Parameter name="_subKeyValue" type="String"/>
        <Parameter name="_tenantId" type="String"/>
        <Parameter name="_isForCams" type="Boolean"/>
        <Parameter name="_baseAuthEndPoint" type="String"/>
        <Parameter name="_oAuth2Version" type="Integer"/>
        <Parameter name="_resource" type="String"/>
        <Parameter name="_customer" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="62f801ca-e3f6-4302-aaae-316bf4f7754b">
        <updating/>
        <source>setForUpdate(_extWebService: CM_AgGatewayServiceDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
15th July 2025	navra1	Initial creation for //navra1 - MTN-34782 - 15th July 2025
05 Sep 2025		navnk30 JIRA 35707: 4 - YARA | Create a new web service definition to use to send out AG Gateway messages
22 Sep 2025		navnk30 JIRA 36092: AG Gateway External web service def should have oAuthVersion = 0, but it defaulted to 2 which is wrong

*/

vars

begin
	inheritMethod(_extWebService);
	
	self.myTerminal 			:= _extWebService.myTerminal;
	self.msgRetentionPeriod		:= _extWebService.msgRetentionPeriod;
	self.recordInboundEwsHistory := _extWebService.recordInboundEwsHistory;
	self.recordOutboundEwsHistory := _extWebService.recordOutboundEwsHistory;
	self.oAuth2Version			:= 0;														//22.09.2025 navnk30 MTN-36092

epilog

end;
</source>
        <Parameter name="_extWebService" type="CM_AgGatewayServiceDef"/>
    </JadeMethod>
    <JadeMethod name="setMsgRetentionPeriod" id="efa9b635-4d6d-48e1-9db0-4d5233ce389d">
        <updating/>
        <source>setMsgRetentionPeriod(_msgRetentionPreiod : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 September 2025	navnk30	JIRA 35707: 4 - YARA | Create a new web service definition to use to send out AG Gateway messages

*/

vars

begin
	self.msgRetentionPeriod := _msgRetentionPreiod;
epilog

end;</source>
        <Parameter name="_msgRetentionPreiod" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="c606499a-cdf4-4c56-a2bd-9b056e39623e">
        <source>validateMe() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Aug 2025	navra1	Initial creation for //navra1 - MTN-34782 - 15th July 2025
25 Aug 2025	navnk30	JIRA 35713: 5 - YARA | Create a external webservice history class(EWS) and agent for AgGateway
*/

vars

begin	
	
	if self.myTerminal = null then
		app.raiseCMException(Input_required_field_terminal, ETRow_Terminal, null);
	endif;
	
	if self.myTerminal &lt;&gt; null and self.myTerminal.myAgGatewayServiceDef &lt;&gt; null and 
		self.pxyGetRealObject() &lt;&gt; self.myTerminal.myAgGatewayServiceDef then			//25AUG2025 navnk30 JIRA-35713
		app.raiseCMException2(One_term_one_ag_gateway, self.myTerminal.code, self.myTerminal.myAgGatewayServiceDef.name, ETRow_Terminal, null);	
	elseif self.allEndpoints[ETRow_OrderResponseEndpoint] = null then
		app.raiseCMException(EP_OrderResponse_Required, null, null);
	elseif self.allEndpoints[ETRow_ShipNoticeEndpoint] = null then
		app.raiseCMException(EP_ShipNotice_Required, null, null);
	endif;
	
	inheritMethod();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
