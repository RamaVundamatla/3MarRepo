    <JadeMethod name="isSameVoyageGlobal" id="9d3204d4-757f-4d4f-9461-a970aa46cc13">
        <source>isSameVoyageGlobal(_movementObj : HMS_Movement) : Boolean;
// --------------------------------------------------------------------------------
// Created:		20 November 2007 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified Movement
//				is in the same Global Voyage as the receiver's.
//
// Parameters:	_movementObj - A reference to the Movement to check.
//
// Returns:		True if the specified Movement is in the same Global Voyage as the
//				receiver, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _movementObj = null then
		return false;
	endif;
	
	return (self.myVoyageGlobal = _movementObj.myVoyageGlobal);
end;</source>
        <Parameter name="_movementObj" type="HMS_Movement"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
