    <JadeMethod name="createCMIFDetails" id="59ac8eed-7849-4e00-97c2-e70e90c4d74f">
        <source>createCMIFDetails(_inCode, _outTruck : String) : CMIF_CompanyCustDocDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60917: JADE - Group Selected TIs by Transport

*/

vars
	cmifDetail : CMIF_CompanyCustDocDetail;
	
begin
	
	create cmifDetail transient;
	
	cmifDetail.inwardDocCode := _inCode;
	cmifDetail.releasedTruckID := _outTruck;
	
	self.allCompanyCustDocDetails.add(cmifDetail);
	
	return cmifDetail;
	
epilog

end;</source>
        <Parameter name="_inCode" type="String"/>
        <Parameter name="_outTruck" type="String"/>
        <ReturnType type="CMIF_CompanyCustDocDetail"/>
    </JadeMethod>
    <JadeMethod name="delete" id="f79ddd8b-bcdb-4217-8ca8-5c295f4e32c5">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60917: JADE - Group Selected TIs by Transport

*/

vars

begin
	self.allCompanyCustDocDetails.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doGenerate" id="afe87e58-c516-4f2f-a359-1cf1d8fd63b4">
        <updating/>
        <source>doGenerate() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60917: JADE - Group Selected TIs by Transport

*/

vars
	ti				: CM_TrackedItem;
	
	cmifDetail		: CMIF_CompanyCustDocDetail;
	
	inCode,
	relTransportCode: String;
	newCustDoc,
	tiCustDoc		: CM_CustomDocument;
	tiCustDocDtl	: CM_CustomDocumentDetail;
	trans			: CM_TITransaction;
	theReturn		: Integer;
	docCodes		: String;
begin
	
	if self.myCustomDocumentType = null then
		if not app.isJMTUnitTest() then
			app.msgBox("Please select a Custom Document Type", app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		endif;
		return false;
	endif;
	
	// Group the TIs
	foreach ti in self.allTIs do
		inCode := null;
		relTransportCode := null;
		
		if ti.releasedTransportMode = TI_TRANSMODE_ROAD then
			trans := ti.getLastTransOfType(TRANS_TYPE_REL_ROAD);
		elseif ti.releasedTransportMode = TI_TRANSMODE_SHIP then
			trans := ti.getLastTransOfType(TRANS_TYPE_REL_SHIP);
		elseif ti.releasedTransportMode = TI_TRANSMODE_RAIL then
			trans := ti.getLastTransOfType(TRANS_TYPE_REL_RAIL);
		else
			// Not released, skip this TI
			continue;
		endif;
		
		if trans &lt;&gt; null then
			relTransportCode :=	trans.CM_Release.getReleaseTransportCode();
		endif;
		
		// Shouldn't be null but if it is then something is not right
		if relTransportCode = null then
			continue;
		endif;
		
		// We only want the first Inward custom document
		foreach tiCustDocDtl in ti.allCustomDocDetails discreteLock where tiCustDocDtl.included do 
			tiCustDoc := tiCustDocDtl.getCustomDocumentHeader();
			// ### TFS CR 60425 TASK 60828 14NOV2023 NAVAB1
			if tiCustDoc.isCancelled() then
				continue;
			endif;
			
			if tiCustDoc.isInward() then
				inCode := tiCustDoc.code;
				break;
			endif;
		endforeach;
		
		// If Incode is null, there's something wrong, skip this
		if inCode = null then
			continue;
		endif;
		
		cmifDetail := self.allCompanyCustDocDetails[inCode, relTransportCode];
		
		if cmifDetail = null then
			cmifDetail := self.createCMIFDetails(inCode, relTransportCode);
		endif;
		
		cmifDetail.allTIs.add(ti);
	endforeach;
	
	while true do
		app.myTrxCA.trxCreateCompanyCustDocuments(self, app.myPassport);
		if app.myPassport.trxCompletedOK() then
			// Build string for newly created custom documents, display in the msgbox
			foreach newCustDoc in self.allNewCustDocsCreated do
				if docCodes &lt;&gt; null then
					docCodes &amp;= CrLf &amp; "- " &amp; newCustDoc.code;
				else
					docCodes := "- " &amp; newCustDoc.code;
				endif;
			endforeach;
			if not app.isJMTUnitTest() then
				app.msgBox("Following documents are created:" &amp; CrLf &amp; docCodes, app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_OK_Only);
			endif;
			return true;
		else
			theReturn := app.showErrorWarningDialog("Custom Doc", app.myPassport, 20);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="6f132acb-6dac-46f8-9255-7d47f8dc55ec">
        <updating/>
        <source>initialize(_tis : CM_TISet; _terminal : CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60917: JADE - Group Selected TIs by Transport

*/

vars

begin
	self.allCompanyCustDocDetails.purge();
	self.allNewCustDocsCreated.clear();
	self.myTerminal := _terminal;
	_tis.copy(self.allTIs);
	
	self.myCustomDocumentType := null;
	self.myCustomLicense := null;
	self.direction := null;
	self.description := null;
	self.docSequence := null;
	self.externalRef := null;
	self.lineNumber := null;
	self.myCustomDocAgent := null;
	self.myHSCode := null;
	self.remarks := null;
	self.startTS := null;
	
epilog

end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
