    <JadeMethod name="btnFile_click" id="e2abb1d3-5c1c-45c4-90aa-d69824bfd17c">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFile_click(btn: Button input) updating;

/*
Date			Who		Reason
28 July 2016	cnwar2	Initial creation

*/
vars
	myDlg : CMDFileSave;
	
begin
	create myDlg;
	myDlg.fileName := txtFileName.text;
	if myDlg.open = 0 then
		txtFileName.text := myDlg.fileName;
	endif;
epilog
	delete myDlg;
