    <JadeMethod name="cmbVoyage_click" id="791ca728-d3e6-4b92-b169-e935ec832263">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_click(combobox: ComboBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/01/2017	cnwdap1		Initial creation TFS 3219 LXN Voyage Operations Enhancements
// 28/09/2018 	JLGNS1		Bug 40500: STWO - Hold Planning(STWUJMT2)
// 19/08/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail
// 22/10/2024	navcs2		MTN-28961  EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	returnValue : Integer;
begin
	if self.myCurrentVoyage &lt;&gt; combobox.getCurrentItemObject().CM_Voyage then
		if self.mode = self.Mode_Add or self.mode = self.Mode_Update then
			if self.isFormChanged then
				returnValue := app.msgBox(app.getErrorString1(ConfirmCancel, app.getErrorString(Job) &amp; Space &amp; self.fldData.topSheet.caption), app.getErrorString(ConfirmCancelHeading), MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second);
				if returnValue = MsgBox_Return_No then
					return;
				endif;
			endif;
			self.mode := self.Mode_View;
			self.setControlsForView(); //epr 40322 30/8/18
			self.toldAboutShifts := false;	 // TFS 46628 JLGAB1
		endif;
	endif;
	
	if self.listeningForClassNotes then	// TFS 42872
		// stop listening for notifications of previous voyage
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Create_Event)); // TFS 42872
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Update_Event));	// TFS 42872
		self.endNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Delete_Event));	// TFS 42872
	endif;
	self.myCurrentVoyage := combobox.getCurrentItemObject().CM_Voyage;
	self.clearDetails();												//Bug 40500
	self.loadCurrentVoyage();
epilog
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
