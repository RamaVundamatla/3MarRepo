    <JadeMethod name="addToolbarControls" id="80ead7be-cab7-4ebc-8d8d-00588c4e7381">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
Date		    Who			Reason
30 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	toolbar			: CMUI_Toolbar;
begin
	toolbar := self.frmToolbar;
	inheritMethod();
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addUpAndDownArrows" id="afd8c229-128a-4437-ba3d-f1b21717c176">
        <updating/>
        <source>addUpAndDownArrows(_idx : Integer) updating;
/*
Date		    Who			Reason
30 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	theTable : CM_DataTable;
begin
	theTable := self.tblDecks;
		
	theTable.accessCell(_idx, TblCol_Up).text := 225.Character; 
	theTable.accessCell(_idx, TblCol_Up).fontName := "Wingdings";
	theTable.accessCell(_idx, TblCol_Up).fontSize := 8;
	theTable.accessCell(_idx, TblCol_Up).fontBold := false;
	
	theTable.accessCell(_idx, TblCol_Down).text := 226.Character; 
	theTable.accessCell(_idx, TblCol_Down).fontName := "Wingdings";
	theTable.accessCell(_idx, TblCol_Down).fontSize := 8;
	theTable.accessCell(_idx, TblCol_Down).fontBold := false;
epilog

end;</source>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
