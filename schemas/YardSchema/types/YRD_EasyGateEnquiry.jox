    <JadeMethod name="deleteInterTermMove" id="2424e91d-94fe-4839-a87d-df136cde3bea">
        <updating/>
        <source>deleteInterTermMove(_interTerminalMove : CM_InterTerminalMove io) : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 February 2010	conkc1	Initial creation

*/
vars

	interTermVehicleJob : CM_InterTermVehicleJob;
	result              : Integer;

begin
	
	interTermVehicleJob := _interTerminalMove.myInterTermVehicleJob;
	if interTermVehicleJob = null then
		result := app.msgBox( method.qualifiedName &amp; ' Dev message - Inter Term Vehicle Job missing', app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;

	if _interTerminalMove.status = ITT_LOADING or _interTerminalMove.status = ITT_UNLOADING then
	else
		result := app.msgBox( method.qualifiedName &amp; ' Dev Error Inter Term Status incorrect', app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;

	// delete the move and finish;
	while true do
		app.myTrxDA.trxDeleteInterTerminalMove(_interTerminalMove, app.myPassport );
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return true;
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog(app.getErrorString(Load), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;

		return false;

	endwhile;

epilog

end;</source>
        <Parameter name="_interTerminalMove" type="CM_InterTerminalMove" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayExtraInfoForObj" id="26ca12bc-d867-4800-bf81-219070c71b9f">
        <source>displayExtraInfoForObj(_obj : CM_Object);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwrd1	Initial creation

*/

vars
	wle 		: CM_WorkListEntry;
	strArray	: HugeStringArray;
	dataContainer : CM_DataContainer;
	useNew : Boolean;
begin

	self.tblInfo.clear();
	self.tblInfo.rows := 0;

	if (not CM_Object.hasInstance(_obj)) then
		return;
	endif;

	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
			
	if _obj &lt;&gt; null and _obj.isKindOf(CM_Object) then
		_obj.CM_Object.getExtraInfo(dataContainer);
		//self.getExtraInfoForObj(_obj.CM_Object, dataContainer);
		self.showExtraInformation(dataContainer, self.tblInfo, true, false, 4, 1, 1, 1, 1);
		self.doResizeColumnWidths(self.tblInfo, true);
	endif;

	
epilog
	if dataContainer &lt;&gt; null then
		delete dataContainer;
	endif;
	delete strArray;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="displayTable" id="c7b3f98a-ff99-461f-832d-1239cef94efc">
        <updating/>
        <source>displayTable()updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwrd1	Initial creation

*/


vars
	loadStateSet  : Boolean;
	theDataLine   : String;
	tbl           : CM_DataTable;
	objectSet     : CM_ObjectSetActual;
	object        : CM_Object;
	interTermMove : CM_InterTerminalMove;
	operator      : CM_Operator;
	cargoID       : String;
	vehicleID     : String;
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	
	tbl := self.tblData;
	
	tbl.rows := tbl.fixedRows;
	self.doNotableClear();
	cargoID   := self.txtCargoID.text.trimBlanks;
	vehicleID := self.txtVehicleID.text.trimBlanks;
	if cmbOperator.listIndex &lt; 2 then
		operator := null;
	else
		operator := cmbOperator.itemObject[cmbOperator.listIndex].CM_Operator;
	endif;
	
	create objectSet transient;

	app.cmsBeginLoad(loadStateSet);
	
	if chkIncIncoming.value = true then
		doGetIncoming(operator, cargoID, vehicleID, objectSet);
	endif;

	if chkIncOutgoing.value = true then
		doGetOutgoing(operator, cargoID, vehicleID, objectSet);
	endif;

	foreach object in objectSet do
		self.addRowToTable(object.CM_InterTerminalMove, tbl);
	endforeach;

epilog
	delete objectSet;
	app.cmsEndLoad(loadStateSet);
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doGetIncoming" id="dae37061-9b6e-438a-92fc-3796273cd106">
        <updating/>
        <source>doGetIncoming(_operator : CM_Operator; _cargoID : String; _vehicleID : String; _objectSet : CM_ObjectSetActual io) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 February 2010	conkc1	Initial creation

*/
vars
	iterator       : Iterator;
	interTermMove  : CM_InterTerminalMove;
	incomingTermMoveSDict : CM_InterTermMovesBySourceDict;
	startTimestamp : TimeStamp;
begin

//	startTimestamp.setDate(vFromDate);
//	startTimestamp.setTime('00:00:00.00'.Time);
	startTimestamp := self.localToSystemTime(vFromDate.TimeStamp);	// 5/5/16 cnwmp6 TFS 488 - Multi timezone support
	create incomingTermMoveSDict transient;
	self.myTerminal.allInterTerminalMovesIn.copy(incomingTermMoveSDict);
	interTermMove := incomingTermMoveSDict.getAtKeyGeq(startTimestamp, _cargoID, _vehicleID);
	iterator := incomingTermMoveSDict.createIterator;

	if interTermMove = null then
		return;
	endif;

	self.getResultSet(iterator, _operator, _cargoID, _vehicleID, startTimestamp, _objectSet, interTermMove );

epilog
	delete incomingTermMoveSDict;
	delete iterator;
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoID" type="String"/>
        <Parameter name="_vehicleID" type="String"/>
        <Parameter name="_objectSet" type="CM_ObjectSetActual" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doGetOutgoing" id="1cf88e98-bba4-4b67-8ec0-476074155721">
        <updating/>
        <source>doGetOutgoing(_operator : CM_Operator; _cargoID : String; _vehicleID : String; _objectSet : CM_ObjectSetActual io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	conkc1	Initial creation

*/

vars

	iterator       : Iterator;
	interTermMove  : CM_InterTerminalMove;
	outgoingTermMoveTDict : CM_InterTermMovesByTargetDict;
	startTimestamp : TimeStamp;
begin

//	startTimestamp.setDate(vFromDate);
//	startTimestamp.setTime('00:00:00.00'.Time);
	startTimestamp := self.localToSystemTime(vFromDate.TimeStamp);	// 5/5/16 cnwmp6 TFS 488 - Multi timezone support
	create outgoingTermMoveTDict transient;
	self.myTerminal.allInterTerminalMovesOut.copy(outgoingTermMoveTDict);

	interTermMove := outgoingTermMoveTDict.getAtKeyGeq(startTimestamp, _cargoID, _vehicleID);
	iterator := outgoingTermMoveTDict.createIterator;

	if interTermMove = null then
		return;
	endif;

	self.getResultSet(iterator, _operator, _cargoID, _vehicleID, startTimestamp, _objectSet, interTermMove );

epilog
	delete outgoingTermMoveTDict;
	delete iterator;
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoID" type="String"/>
        <Parameter name="_vehicleID" type="String"/>
        <Parameter name="_objectSet" type="CM_ObjectSetActual" usage="io"/>
    </JadeMethod>
