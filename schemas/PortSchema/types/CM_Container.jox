    <JadeMethod name="validateGenSet" id="38b84192-2337-4f2b-b275-f6b8dc37afe9">
        <source>validateGenSet( _control: CMIF_TIUpdateController) protected;
/* ---------------------------------------------------------------------------
Created:	03 April 2009	by cnwvu1

Purpose:	Par 18790
   
Change Date		Who		Reason
02/12/2009		cnwdap1	CCMS MES 1007 Move all reefer properties up to CM_TrackedItem level
------------------------------------------------------------------------------*/
vars
	task	: CM_ToDoTask;

begin
	// If there is a genset attached, the ISO Type should be reefer type.
	if not self.canHaveGeneratorAttached() then

		inheritMethod(_control);
		
		// should be no Attach / Detach GenSet to do tasks
		foreach task in self.allToDoTasksToDo discreteLock do
			if task.toDoTaskDesc &lt;&gt; null and task.toDoTaskDesc.isForGenSetAttachDetach() then
				app.raiseCMException1(ISOTypeNotValidGenSetTask, self.isoType, app.getErrorString(ISO_Type), _control.myUserObject);
				break;
			endif;
		endforeach;
		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_TIUpdateController"/>
    </JadeMethod>
