    <JadeMethod name="setForUpdate" id="0b8656d3-7a4e-4d9b-8665-b27be255eb4e">
        <updating/>
        <source>setForUpdate(_proxySelf: SelfType input; _passport: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2012	cnwndl1	Initial creation	Par 29369
25 September 2018	cnwma1	ChangeRequest 41080: PEL1 - Assigning Operators ID to Cranes/Work-Points
*/

vars

begin

	self.exchangeStart := _proxySelf.exchangeStart;
	self.exchangeEnd := _proxySelf.exchangeEnd;
	self.labourStart := _proxySelf.labourStart;
	self.labourEnd := _proxySelf.labourEnd;
	self.remarks := _proxySelf.remarks;
	self.myCrane := _proxySelf.myCrane;
	self.myWorkPoint := _proxySelf.myWorkPoint;
	self.myVoyage := _proxySelf.myVoyage;
	self.myUser   := _proxySelf.myUser;
epilog

end;</source>
        <Parameter name="_proxySelf" type="SelfType" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="52c700bf-9bc6-4c39-b54c-cae6adcc9d4b">
        <updating/>
        <source>setProxy(	_exchangeStart : TimeStamp;
			_exchangeEnd : TimeStamp;
			_labourStart : TimeStamp;
			_labourEnd : TimeStamp;
			_remarks : String;
			_myCrane : CM_Crane;
			_myWorkPoint : CM_WorkPoint;
			_myVoyage : CM_Voyage;
			_myUser	  : CM_User
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2012	cnwndl1	Initial creation	Par 29369
25 September 2018	cnwma1	ChangeRequest 41080: PEL1 - Assigning Operators ID to Cranes/Work-Points
*/

vars

begin

	self.exchangeStart := _exchangeStart;
	self.exchangeEnd := _exchangeEnd;
	self.labourStart := _labourStart;
	self.labourEnd := _labourEnd;
	self.remarks := _remarks;
	self.myCrane := _myCrane;
	self.myWorkPoint := _myWorkPoint;
	self.myVoyage := _myVoyage;
	self.myUser   := _myUser;			//25.09.2018 cnwma1 TFS #41080
epilog

end;</source>
        <Parameter name="_exchangeStart" type="TimeStamp"/>
        <Parameter name="_exchangeEnd" type="TimeStamp"/>
        <Parameter name="_labourStart" type="TimeStamp"/>
        <Parameter name="_labourEnd" type="TimeStamp"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_myCrane" type="CM_Crane"/>
        <Parameter name="_myWorkPoint" type="CM_WorkPoint"/>
        <Parameter name="_myVoyage" type="CM_Voyage"/>
        <Parameter name="_myUser" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="98c30803-5215-473d-9800-b37569c3d591">
        <source>validateCreate(_passport: CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2012	cnwndl1	Initial creation	Par 29369


*/

vars

begin

	//28 Aug 2012	NDL	Par 30279 - exchangeStart is a key to a dictionary with no duplicates...
	if not self.exchangeStart.Date.isValid then
		if self.myCrane &lt;&gt; null then
			if self.myCrane.allCraneOpHrsExchange.getAtKey(self.myVoyage,self.exchangeStart) &lt;&gt; null then
				//app.raiseCMException1( REQUIRED_FIELD, app.getErrorString(Exchange_start), null, null);
				app.raiseCMException( Only_one_with_no_ExchDate, null, null);
			endif;
		elseif self.myWorkPoint &lt;&gt; null then
			if self.myWorkPoint.allCraneOpHrsExchange.getAtKey(self.myVoyage,self.exchangeStart) &lt;&gt; null then
				//app.raiseCMException1( REQUIRED_FIELD, app.getErrorString(Exchange_start), null, null);
				app.raiseCMException( Only_one_with_no_ExchDate, null, null);
			endif;
		endif;
	endif;

	self.validateUpdate(_passport);

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
