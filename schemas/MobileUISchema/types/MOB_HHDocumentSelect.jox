    <JadeMethod name="clickMaintain" id="6df64aa6-54c2-40c9-82df-d5612e2a0c3a">
        <updating/>
        <source>clickMaintain() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2016	cnwndl1	Initial creation	TFS 2918

*/

vars

	docAction : CM_DocumentActions;
	
	reserveDetail : CM_ReserveDetail;
	resDetailSet : CM_ReserveDetailSet;
	bookingItem : CM_BookingRefItem;
	bookingItemSet : CM_BookingRefItemSet;
	parentHasDAs : Boolean;	//12 Dec 2016	NDL	TFS 3023/2001
	allowMaint : Boolean;	//12 Dec 2016	NDL	TFS 3023/2001

begin
	
	docAction := self.getSelectedDocumentAction( parentHasDAs, allowMaint );
	
	create resDetailSet transient;
	create bookingItemSet transient;
	
	if docAction = null then
		if self.optBooking.value then
			bookingItem := self.cmbBookingItems.listObject.CM_BookingRefItem;
			bookingItemSet.add( bookingItem );	
		elseif self.optRelease.value then
			reserveDetail := self.cmbReserveDetails.listObject.CM_ReserveDetail;
			resDetailSet.add( reserveDetail );
		endif;
	elseif docAction.isBookingItemAction then
		bookingItem := docAction.CM_BookingItemActions.myBookingItem;
		bookingItemSet.add( bookingItem );
	elseif docAction.isReserveDetailAction then
		reserveDetail := docAction.CM_ReserveDetailActions.myReserveDetail;
		resDetailSet.add( reserveDetail );
	endif;
	
	self.myMobileGenericAgent.setAllReserveDetails( resDetailSet );
	self.myMobileGenericAgent.setAllBookingRefItems( bookingItemSet );
	self.gotoForm( MOB_HHDocActionMaint, false );

epilog

	delete resDetailSet;
	delete bookingItemSet;

end;
</source>
    </JadeMethod>
    <JadeMethod name="clickOptions" id="bb7982ad-6477-4c1c-8560-203bc00a6f7a">
        <source>clickOptions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2655 / 2419

*/

vars

begin

	self.populateBookings( null, null );
	self.populateReleases( null, null );

	if self.optBooking.value then		
		self.cmbBookings.visible := true;
		self.cmbBookingItems.visible := true;
		self.cmbReleases.visible := false;
		self.cmbReserveDetails.visible := false;
	elseif self.optRelease.value then
		self.cmbBookings.visible := false;
		self.cmbBookingItems.visible := false;
		self.cmbReleases.visible := true;
		self.cmbReserveDetails.visible := true;
	endif;
	
	resetButtons();

epilog

end;</source>
    </JadeMethod>
