    <JadeMethod name="doDragOver" id="011cec59-039f-4081-9ff9-d658f987b6c4">
        <updating/>
        <source>doDragOver(control: Control input; win: Window input; x,y: Real; state: Integer)updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if control &lt;&gt; win and win.Control.parent &lt;&gt; control then
		// not a valid place to drop
		
		if state = self.DragOver_Enter then
			// set drag cursor and get rid of old 
			self.hideDraggingRectangle (); 
		endif;
		return;
	endif;
	
	if state = self.DragOver_Leave then
		// we don'r know where we are going
		self.hideDraggingRectangle; 
		return;
	endif;
	
	self.drawDraggingRectangle (control, win, x, y);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="control" type="Control" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
