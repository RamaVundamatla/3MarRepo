    <JadeMethod name="setMyProductAndExtension" id="5a66f974-e1ec-41cf-a3a4-47bb172428fb">
        <updating/>
        <source>setMyProductAndExtension( _bol : CM_BOLIn ) updating, protected;

vars
	ext	: CM_BOLExtLog;

begin

	if _bol.myExtension.isKindOf(CM_BOLExtLog) then
		ext := _bol.myExtension.CM_BOLExtLog;
	endif;
	
	self.myProduct := _bol.myProduct;		// this also sets self.productCode
	if ext &lt;&gt; null then
		self.gradeCode 		:= ext.logGradeCode;
		self.speciesCode 	:= ext.logSpeciesCode;
		self.typeCode 		:= ext.logTypeCode;
		self.treatmentCode	:= ext.logTreatmentCode;
		self.lengthCode		:= ext.lengthCode;
		self.fellDate		:= ext.fellDate;
	endif;
	
end;
</source>
