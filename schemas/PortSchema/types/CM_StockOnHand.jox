    <JadeMethod name="getSOHLevelsForDate" id="b1e4bbd8-a8d2-49a5-bded-8fe3dea113b6">
        <source>getSOHLevelsForDate(_date 			: Date; 
					_closingLevel 	: Boolean; 
					_totQty			: Integer io;
					_totVol			: Decimal io; 
					_totWeight 		: Decimal io);

// Created:     R Barr 8/11/2006 Comalco -- Refactor common code in referencing methods
					
vars
	stockMoveBucket	: CM_StockMoveBucket;
	
begin
	// get bucket for requested date for opening levels, or subsequent date if closing levels are required
	if _closingLevel then
		stockMoveBucket := self.allStockMovementsByDate.getAtKeyGtr(_date);
	else
		stockMoveBucket := self.allStockMovementsByDate.getAtKeyGeq(_date);
	endif;
	
	// ok not to check key here as we are after the stockMoveBucket greater
	// then today

	if stockMoveBucket = null then
		// can use current stock
		_totQty		:= _totQty		+ self.currentQuantity;
		_totVol		:= _totVol		+ self.currentVolume;
		_totWeight	:= _totWeight	+ self.currentWeightKgs;
	else
		_totQty		:= _totQty		+ stockMoveBucket.openingQuantity;
		_totVol		:= _totVol		+ stockMoveBucket.openingVolume;
		_totWeight 	:= _totWeight	+ stockMoveBucket.openingWeightKgs;
	endif;
end;
</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_closingLevel" type="Boolean"/>
        <Parameter name="_totQty" type="Integer" usage="io"/>
        <Parameter name="_totVol" type="Decimal" usage="io"/>
