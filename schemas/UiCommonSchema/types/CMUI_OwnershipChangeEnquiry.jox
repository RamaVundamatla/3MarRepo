    <JadeMethod name="setupForm" id="b7529629-2c87-451a-8fea-95259fe1478e">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2023 navtnr20	TFS CR 58224	Task 58225: UI - Change of Ownership Enquiry
30/11/2023	navkc1 ChangeRequest 58254 Task 58255: UI - New Permission
*/

vars

begin
	inheritMethod();
	
	// ### TFS BUG 59633 31AUG2023 NAVAB1 self.handleMenusForModalDisplay();
	self.setCargoType();
	self.setCargoSubType();
	self.setOperatoNew();
	self.setOperatorOrg();
	self.setCommodities();

	self.initTblCOOEnquiry(ETDef_OwnershipChangeEnq);

	setCaption(self.caption);
	self.startNotifications();
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnAdd.enabled := false;
	endif;
	
	//30/11/2023	navkc1 ChangeRequest 58254 Task 58255
	if not app.myCurrentUserCan(self.myTerminal, PmInvOwnershipChangeApprove) then
		self.btnApprove.enabled := false;
	endif;
	
	if not app.myCurrentUserCan(self.myTerminal, PmInvOwnershipChangeRemove) then
		self.btnRemove.enabled := false;
	endif;
	
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="startNotifications" id="c66298e7-211b-4a83-ad96-8cc39ed5d482">
        <source>startNotifications();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2023 navtnr20	TFS CR 58224 Task 58229: UI - Notifications
*/

vars

begin
	self.endNotificationForSubscriber(self);

	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(Event_COOCreate), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(Event_COOUpdate), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(Event_COODelete), Response_Continuous, null);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblData_change" id="9c0d2aa5-3e94-4e16-86ca-bdaf2815f695">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_change(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2023 navtnr20	TFS CR 58224	Task 58225: UI - Change of Ownership Enquiry
30/11/2023	navkc1 ChangeRequest 58254 Task 61099: UI - Ownership Change Approved
*/

vars

begin
	self.myOwnershipChange := self.tblData.accessRow(table.row).itemObject.CM_OwnershipChange;
	
	//30/11/2023	navkc1 ChangeRequest 58254 Task 61099
	self.btnApprove.enabled := app.myCurrentUserCan(self.getMyTerminal(), PmInvOwnershipChangeApprove);
	self.btnRemove.enabled := app.myCurrentUserCan(self.getMyTerminal(), PmInvOwnershipChangeRemove);
	
	if self.myOwnershipChange &lt;&gt; null then
		if self.myOwnershipChange.isApproved() then // ### TFS CR 64164 TASK 64733 20JUNE024 NAVAB1
			self.btnApprove.enabled := false;
			self.btnRemove.enabled := false;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_click" id="01635f29-f5f0-4aaf-9b15-2f0cb578a837">
