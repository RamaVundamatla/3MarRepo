    <JadeMethod name="createCustDoc" id="653f2e45-38e7-4a35-915f-6d1655f1bf98">
        <updating/>
        <source>createCustDoc()updating;
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
01/09/2023	navkc1	CR 59937 Task 59939: UI - Cust Doc Mandatory Fields
06 November 2023	navmv20	CR 60425 Task 60986: Jade - Cust Doc Permissions
*/

vars
	pxyCustDoc, realCustDoc 		: CM_CustomDocument;
	docType : CM_CustomDocumentType;
	custLic : CM_CustomLicense;
	custAgent : CM_CustomsAgent;
	hsCode : CM_HarmonizedSystem;
	direction, status : Integer;
	theReturn : Integer;
	terminal				: CM_Terminal;
	refNumber,remarks,condition : String;
	addFreeDays,ownershipFreeDays : Integer;
	scheduleTSstart 		: TimeStamp;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	terminal := self.getMyTerminal;

	if self.txtRefNumber &lt;&gt; null then
		refNumber := self.txtRefNumber.text.String;
	endif;
	scheduleTSstart.setDate(self.mskCOOFromStart.getDate());
	scheduleTSstart.setTime(self.mskCOOFromStartTime.getTime());
	scheduleTSstart := self.localToSystemTime(scheduleTSstart);
	
	docType := self.cmbDocType.listObject.CM_CustomDocumentType;
	custLic := self.cmbLicense.listObject.CM_CustomLicense;
	custAgent := self.cmbCustomsAgent.listObject.CM_CustomsAgent;
	hsCode := self.cmbHSCodes.listObject.CM_HarmonizedSystem;
	
	//01/09/2023	navkc1	CR 59937 Task 59939
	if self.cmbDirection.listIndex &lt;= 0 then
		direction := -1;
	else
		direction:= self.cmbDirection.listData;
	endif;
	
	if self.txtRemarks &lt;&gt; null then
		remarks := self.txtRemarks.text.String;
	endif;
	
	create pxyCustDoc transient;
	pxyCustDoc.setProxy(terminal,self.txtCode.text,self.txtDesc.text,self.txtExtRef.text,null,self.txtRemarks.text,
									scheduleTSstart,null,null,direction,self.txtRefNumber.text.Integer,docType, custLic,custAgent,hsCode, self.txtSequence.text.Integer);

	if mode = Cargo_Review_Mode then
		self.createCustDocDetail(pxyCustDoc);
	else
		while true do
			app.myTrxCA.trxCreateCustDocHeader(pxyCustDoc, realCustDoc, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				app.msgBox("Creation Successful", app.getErrorString(Confirmation),MsgBox_OK_Only);
				self.myCustomDocument := realCustDoc;
				if self.myCustomDocument &lt;&gt; null  then
					self.btnAddItems.enabled := true;
					//06/11/2023	navmv20	CR 60425 Task 60986 - start
					if app.myCurrentUserCan(self.myTerminal, PmInvCustomDocRemove) then
						self.btnRemove.enabled := true;
					endif;
					//self.btnRemove.enabled := true;
					//06/11/2023	navmv20	CR 60425 Task 60986 - end	
					self.btnUpdate.enabled := true;
					self.btnAttachment.enabled := true;
					self.btnApprove.enabled := true;
					self.btnAudits.enabled := true;
					self.btnAudit.enabled	:= true;    //11/07/2023 navrv30 #58391
					//self.txtFilterDocDetail.enabled := true; //25/06/2024	navkc1 CR 64823 Task 64824
				endif;
				self.updateMode := true;
				self.startNotifications();
				
				
				break;
			else
				theReturn := app.showErrorWarningDialog("Custom Doc", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
			endif;
			break;
		endwhile;
	endif;
epilog
	self.mousePointer := Window.MousePointer_Default;
	delete pxyCustDoc;
end;</source>
    </JadeMethod>
    <JadeMethod name="createCustDocDetail" id="ffa9610f-a08f-43e5-98da-60b0d4827307">
        <updating/>
        <source>createCustDocDetail(_pxyCustDoc : CM_CustomDocument input) updating;
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
06 November 2023	navmv20	CR 60425 Task 60986: Jade - Cust Doc Permissions
*/

vars
	realCustDoc 		 : CM_CustomDocument;
	cmifCustDocDetail : CMIF_CustomDocumentDetail;
	theReturn        : Integer;
	ti : CM_TrackedItem;
begin
	if self.mode &lt;&gt; Cargo_Review_Mode then
		return;
	endif;

	create cmifCustDocDetail transient;
	self.allProxyDetailsForCreate.copy(cmifCustDocDetail.allProxyCustDocDetails);
	self.allSubProxyCustDocDetails.copy(cmifCustDocDetail.allSubProxyCustDocDetails);
	
	while true do
		app.myTrxCA.trxCreateCustDocAndDetails(_pxyCustDoc,realCustDoc, cmifCustDocDetail, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.msgBox("Creation Successful", app.getErrorString(Confirmation),MsgBox_OK_Only);
			self.myCustomDocument := realCustDoc;
			if self.myCustomDocument &lt;&gt; null  then
				self.btnAddItems.enabled := true;
				//06/11/2023	navmv20	CR 60425 Task 60986 - start
				if app.myCurrentUserCan(self.myTerminal, PmInvCustomDocRemove) then
					self.btnRemove.enabled := true;
				endif;
				//self.btnRemove.enabled := true;
				//06/11/2023	navmv20	CR 60425 Task 60986 - end
				self.btnUpdate.enabled := true;
				self.btnAttachment.enabled := true;
				self.btnApprove.enabled := true;
				self.btnAudits.enabled := true;
				self.btnAudit.enabled	:= true;    //11/07/2023 navrv30 #58391
				//self.txtFilterDocDetail.enabled := true; //25/06/2024	navkc1 CR 64823 Task 64824
			endif;
			self.updateMode := true;
			self.mode := ""; // not cargo review mode any more
			self.allProxyDetailsForCreate.purge();// this has proxies if we came from the cargo review screen.
			self.allSubProxyCustDocDetails.purge();
			self.displayHeader();
			self.displayDetails();
			self.startNotifications();
			break;
		else
			theReturn := app.showErrorWarningDialog("Custom Document", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				cmifCustDocDetail.allRealCustDocDetails.clear;
				self.reattachSubProxies();
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			cmifCustDocDetail.allRealCustDocDetails.clear;
			self.reattachSubProxies();
		endif;
		break;
	endwhile;
epilog

end;</source>
        <Parameter name="_pxyCustDoc" type="CM_CustomDocument" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPxyDetailForUpdate" id="380170c4-0a10-49df-a213-ad0ebfa321cd">
        <source>createPxyDetailForUpdate();
/*
Purpose - 	
Who - NAVAB1
Date - 24JUNE2024
ADO -  CR 64285 TASK 64286
*/

vars
	row, col : Integer;
	includeIt : Boolean;
	realDtl, pxyDtl : CM_CustomDocumentDetail;
begin

	if self.mode &lt;&gt; self.Cargo_Review_Mode then
		self.allProxyDetailsForInclude.purge();
		foreach row in 2 to self.tblData.rows do
			realDtl := self.tblData.accessRow(row).itemObject.CM_CustomDocumentDetail;
			if realDtl = null then
				continue;		
			endif;
			pxyDtl := app.createUpdateProxy(realDtl).CM_CustomDocumentDetail;
			
			col := self.tblData.getColumnByRowName(ETRow_IncludeChk);
			self.tblData.accessCell(row,col);
			includeIt := self.tblData.accessedCell.text = true.cnEcGetTableCheckBoxValue;
			
			pxyDtl.setInclude(includeIt);
			
			self.allProxyDetailsForInclude.add(pxyDtl);
		endforeach;
		
		self.updateCustomDocumentDetails();
	else
		foreach row in 2 to self.tblData.rows do
			pxyDtl := self.tblData.accessRow(row).itemObject.CM_CustomDocumentDetail;
			if pxyDtl = null then
				continue;		
			endif;
			col := self.tblData.getColumnByRowName(ETRow_IncludeChk);
			self.tblData.accessCell(row,col);
			includeIt := self.tblData.accessedCell.text = true.cnEcGetTableCheckBoxValue;
			
			pxyDtl.setInclude(includeIt);
		endforeach;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createPxyDetails" id="7386da9a-e9e2-4461-bce7-d005d99e27d7">
        <source>createPxyDetails(); // ### TFS CR 60922 TASK 60980 06NOV2023 NAVAB1 _partialClearanceForSingleTI : Boolean);
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars
	subTI, ti : CM_TrackedItem;
	subPxyDetail, pxyCustDocDetail, cdd : CM_CustomDocumentDetail;
	myTrackedItem : CM_TrackedItem;
	cgti : CM_CargoGroup;
	storageDetail : CM_StorageDetail;
	totalWeight,
	totalVolume,
	clearedWeight,
	clearedVolume: Decimal[14,4];
	totalQuantity, clearedQty : Integer;
	partialClearanceForSingleTI : Boolean;
begin
		
	foreach ti in self.allTiSet do
		create pxyCustDocDetail transient;
		totalWeight := ti.totalWeight;
		totalVolume := ti.totalVolume;
		totalQuantity := ti.totalQuantity;

		 // ### TFS CR 60424 TASK 60549 09OCT2023 NAVAB1 - if partial clearance, us the current detail to.
		partialClearanceForSingleTI := ti.getCustDocIsPartiallyCleared(); // ### TFS CR 60922 TASK 60980 06NOV2023 NAVAB1
		if partialClearanceForSingleTI then // ### TFS CR 60922 TASK 60980 06NOV2023 NAVAB1 _partialClearanceForSingleTI then
			// ### TFS CR 60922 TASK 60980 06NOV2023 NAVAB1
			clearedQty := ti.getCustDocsClearedQuantity();
			if clearedQty &lt; ti.totalQuantity then 
				totalQuantity := ti.totalQuantity - clearedQty;
			endif;
			clearedWeight := ti.getCustDocsClearedWeight();
			if clearedWeight &lt; ti.totalWeight then 
				totalWeight := ti.totalWeight - clearedWeight;
			endif;
			clearedVolume := ti.getCustDocsClearedVolume();
			if clearedVolume &lt; ti.totalVolume then 
				totalVolume := ti.totalVolume - clearedVolume;
			endif;
		
			/* // ### TFS CR 60922 TASK 60980 02NOV2023 NAVAB1
			cdd := ti.allCustomDocDetails.last; // current detail
			if cdd &lt;&gt; null and cdd.clearedQuantity &lt; ti.totalQuantity then 
				totalWeight := ti.totalWeight - cdd.clearedWeight;
				totalVolume := ti.totalVolume - cdd.clearedVolume;
				totalQuantity := ti.totalQuantity - cdd.clearedQuantity;
			endif;
			*/
		endif;
		
		pxyCustDocDetail.setProxy(totalQuantity,totalWeight,totalVolume,true,ti, self.myCustomDocument,null);
		pxyCustDocDetail.setAmountsFromTI(); // ### TFS BUG 62187 14FEB2024 NAVAB1
		self.allProxyDetailsForCreate.add(pxyCustDocDetail);
		tblData.addObject(pxyCustDocDetail);
		
		if ti.isCargoGroupItem then
			cgti := ti.CM_CargoGroup;
			foreach subTI in cgti.allAssignedTrackedItems discreteLock do
			
				create subPxyDetail transient;
				totalWeight := subTI.totalWeight;
				totalVolume := subTI.totalVolume;
				totalQuantity := subTI.totalQuantity;
				
				subPxyDetail.setProxy(totalQuantity,totalWeight,totalVolume,true,subTI,null,pxyCustDocDetail);		
				subPxyDetail.setAmountsFromTI(); // ### TFS BUG 62187 14FEB2024 NAVAB1
				self.allSubProxyCustDocDetails.add(subPxyDetail);
			
			endforeach;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayDetails" id="3d23d7e9-a886-46cf-be75-dec11e1dcb82">
        <source>displayDetails();
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars
	tbl					: CM_DataTable;
	idx					: Integer;
	str 				: String;
	ownershipChangeDetail,
	subDetail			: CM_CustomDocumentDetail; 
	theDataLine : String;
begin
	tbl := self.tblData;
	tbl.rows := tbl.fixedRows;
	
	if self.myCustomDocument &lt;&gt; null then 
		foreach ownershipChangeDetail in self.myCustomDocument.allCustomDocumentDetails do
			if ownershipChangeDetail.myTrackedItem.isZombie() then
				continue;
			endif;
			
			str := ownershipChangeDetail.getAttributeStringForDefArray(tbl.allTblDataEntRows);
			idx := tbl.addItem(str);
			tbl.accessRow(idx).itemObject := ownershipChangeDetail;
			
			tbl.accessRow(idx).backColor := ColourBlue;
			if self.chkShowSubDtls.value then
				foreach subDetail in ownershipChangeDetail.allSubDetails do
					if subDetail.myTrackedItem.isZombie() then
						continue;
					endif;
					str := subDetail.getAttributeStringForDefArray(tbl.allTblDataEntRows);
					idx := tbl.addItem(str);
					tbl.accessRow(idx).itemObject := subDetail;
					tbl.accessRow(idx).enabled := false;
				endforeach;
			endif;
		endforeach;
	elseif self.allProxyDetailsForCreate.isNotEmpty and not self.updateMode then
		foreach ownershipChangeDetail in self.allProxyDetailsForCreate do
			str := ownershipChangeDetail.getAttributeStringForDefArray(tbl.allTblDataEntRows);
			idx := tbl.addItem(str);
			tbl.accessRow(idx).itemObject := ownershipChangeDetail;
			tbl.accessRow(idx).backColor := ColourBlue; 
			if self.chkShowSubDtls.value then
				foreach subDetail in ownershipChangeDetail.allSubDetails do
					str := subDetail.getAttributeStringForDefArray(tbl.allTblDataEntRows);
					idx := tbl.addItem(str);
					tbl.accessRow(idx).itemObject := subDetail;
					tbl.accessRow(idx).enabled := false;
				endforeach;
			endif;
		endforeach;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayHeader" id="f1d4b011-3b2b-4564-ad53-df7283a78827">
        <source>displayHeader();
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
29/08/2023	navkc1	CR 59556  Task 59593: UI - Cust Docs Auto Id
*/

vars
	localTS,storageEXp : TimeStamp;
	myTrackedItem, pxyTi : CM_TrackedItem;
	storageDetail : CM_StorageDetail;
	custDoc : CM_CustomDocument;
begin
	custDoc:= self.myCustomDocument;
	
	self.txtRefNumber.text	:= custDoc.itemNumber.String;
	localTS := self.systemToLocalTime(custDoc.dateTime);
	self.mskCOOFromStart.setDate(localTS.date);
	self.mskCOOFromStartTime.setTime(localTS.time);
	self.txtRemarks.text		:= custDoc.remarks;
	
	self.txtCode.text := custDoc.code;
	self.txtDesc.text := custDoc.description;
	self.txtExtRef.text := custDoc.externalRef1;
	self.cmbDocType.listObject := custDoc.myCustomDocumentType;
	self.cmbLicense.listObject := custDoc.myCustomLicense;
	self.cmbHSCodes.listObject := custDoc.myHSCode;
	self.cmbCustomsAgent.listObject := custDoc.myCustomsAgent;
	self.cmbDirection.setIndexForItemData(custDoc.direction);
	self.txtSequence.text := custDoc.sequence.String;
	
	//29/08/2023	navkc1	CR 59556  Task 59593
	if custDoc.myCustomDocumentType &lt;&gt; null and custDoc.myCustomDocumentType.hasAutoId then
		self.txtCode.enabled := false;
	endif;

	self.enableForCargoReview();// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="displayStatus" id="b7c9e0b7-9c76-43f0-b030-d2d95fde0027">
        <source>displayStatus();
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars
	custDocDetail : CM_CustomDocumentDetail;
	col, row , quantity,clearedQuantity : Integer;
	weight, volume,clearedweight, clearedvolume : Decimal [23,4];
	custDocDetailSet : CM_CustomDocumentDetailSet;
begin

	custDocDetailSet := self.allProxyDetailsForCreate ;
	if self.allProxyDetailsForInclude.isNotEmpty and self.updateMode then // ### TFS CR 64285 TASK 64286 24JUNE024 NAVAB1
		custDocDetailSet := self.allProxyDetailsForInclude ; // ### TFS CR 64285 TASK 64286 24JUNE024 NAVAB1
	elseif self.myCustomDocument &lt;&gt; null then 
		custDocDetailSet := self.myCustomDocument.allCustomDocumentDetails;
	elseif self.allProxyDetailsForCreate.isNotEmpty and not self.updateMode then
		custDocDetailSet := self.allProxyDetailsForCreate ;
	endif;
	
	foreach custDocDetail in custDocDetailSet do
		if custDocDetail.myTrackedItem &lt;&gt; null 
		and custDocDetail.isIncluded() then
			quantity := quantity + custDocDetail.myTrackedItem.totalQuantity;
			weight 	:= weight	 + custDocDetail.myTrackedItem.totalWeight;
			volume  := volume 	+ 	custDocDetail.myTrackedItem.totalVolume;
			clearedQuantity := clearedQuantity + custDocDetail.clearedQuantity;
			clearedweight 	:= clearedweight	 + custDocDetail.clearedWeight;
			clearedvolume  := clearedvolume 	+ 	custDocDetail.clearedVolume;
		endif;
	endforeach;
	
	self.statusBar.caption :=  " Current Quantity " &amp; quantity.String &amp;
		" Current Weight " &amp; app.getWeightForDefaultDisplay(weight) &amp; 
		" Current Volume " &amp; app.getVolumeForDefaultDisplay(volume) &amp; " | "&amp; 
		" Cleared Quantity " &amp; clearedQuantity.String &amp;
		" Cleared Weight " &amp;  app.getWeightForDefaultDisplay(clearedweight) &amp; 
		" Cleared Volume " &amp; app.getVolumeForDefaultDisplay(clearedvolume);
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAttachment" id="c7b912f6-172f-4c00-9b56-4a8b9d817f21">
        <source>doAttachment();
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars
	form : CMUI_FileAttachmentsFormModal;
begin

	form := app.loadForm(CMUI_FileAttachmentsFormModal, CMUI_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).CMUI_FileAttachmentsFormModal;
	if form = null then
		return;
	endif;
	
	form.setMyParent(self.myCustomDocument);
	
	form.showModal;
end;</source>
