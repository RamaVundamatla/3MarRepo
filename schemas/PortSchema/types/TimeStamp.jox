    <JadeMethod name="getNumeralString" id="4eaa2a86-9f18-4698-93b4-b0d7783e1675">
        <source>getNumeralString() : String;
/*
----------   ----------  --------------------------------------------------
Created:	09 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pos		: Integer;
	str		: String;
	
begin
	str := self.literalFormat;
	//handle null date
	if self.date = null then
		str := '00000000' &amp; str; 
	endif;
	//add three zeros if millisecond null
	if self.time.milliSecond = null then
		str := str &amp; '000'; 	
	endif;
	
	//strip ':' and '.'
	return str.replace(':', null).replace('.', null);
	
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSecondsInInterval" id="f2c8e918-092e-4116-927f-705ed69e92f0">
        <source>getSecondsInInterval(ts: TimeStamp): Integer;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	numberOfDays: Integer;
	numberOfMilliseconds: Integer;
	numberOfSeconds: Integer;
	
begin
	//This should handle negative values as well
	numberOfDays:= ts.date - self.date;
	numberOfSeconds:= numberOfDays * SecondsPerDay;
	numberOfMilliseconds:= ts.time - self.time;

	return numberOfSeconds + (numberOfMilliseconds div MillisecondsPerSecond);
end;</source>
        <Parameter name="ts" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getValidSQLTimeStamp2005" id="15c3e30f-d82e-4ffd-baf8-fd76656e0eb5">
        <source>getValidSQLTimeStamp2005() : TimeStamp;
/*
Purpose:			//10/09/2010 cnwdz2 25697
                    //28/10/2010 cnwdz2 26173

Parameters:			

Return Value:		


Date			Who		Reason
10 Sep 2010	cnwdz2	Initial creation

*/

vars
	timestamp : TimeStamp;
	selfDate     : Date;
	selfTime     : Time;
	
	ldate : Date;
	ltime : Time;
begin

	if self = null or not self.time.isValid() then
		return null;
	endif;
	
	selfTime := self.time;
	selfDate := self.date;
	
	timestamp.setTime(selfTime);
	timestamp.setDate(selfDate);
	
	if not selfDate.isValid() then
		timestamp.setDate(null);
	elseif selfDate &lt; "1901/01/01".Date then
		timestamp.setDate("1901/01/01".Date);
		timestamp.setTime(null);
	endif;
	
	return timestamp;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getValidSQLTimestamp" id="d22b162c-02c6-4c52-aa45-eadefcc6a777">
        <source>getValidSQLTimestamp() : String;
/*
Purpose:			Check that TimeStamp is valid before using
					it in SQL Bulk data extract
					 //28/10/2010 cnwdz2 26173
Parameters:			

Return Value:		


Date			Who		Reason
08 June 2010	conkc1	Initial creation

*/

vars
	timestamp : TimeStamp;
	returnDate     : Date;
	returnTime     : Time;
	returnVal	   : String;
begin
	timestamp := self.getValidSQLTimeStamp2005();
	if timestamp = null then
		return null;
	endif;
	
	returnDate := timestamp.date;
	returnTime := timestamp.time;
	
	if returnDate &lt;&gt; null then
		returnVal := returnDate.format('yyyy-MM-dd') &amp; ' ';
	endif;
	
	returnVal := returnVal &amp; returnTime.String &amp; '.' &amp; returnTime.milliSecond.padLeadingWith('0', 3);
	
	return returnVal;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isLessThanOrEqualTo" id="3deb15f7-191a-4784-b860-8e8ed265ac1c">
        <source>isLessThanOrEqualTo(_timeStamp: TimeStamp):Boolean;
//----------------------------------------------------------------
//	Created:	25 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	if self.date &lt; _timeStamp.date then
		return true;
	elseif self.date = _timeStamp.date and self.time &lt;= _timeStamp.time then
		return true;
	endif;
	return false;
	
end;</source>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
