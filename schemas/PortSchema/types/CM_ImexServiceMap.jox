    <JadeMethod name="replaceInvoiceLineTypes" id="803968f1-f17f-4175-a1e9-4a0cb644f1db">
        <source>replaceInvoiceLineTypes(_oldILD : CM_InvoiceLineDesc; _newILD : CM_InvoiceLineDesc) : Integer;
// 32311
vars
	count	: Integer;
	contentsMap		: CM_ContentsMap;
begin
	foreach contentsMap in self.contentsMaps do
		count := count + contentsMap.replaceInvoiceLineTypes(_oldILD, _newILD);
	endforeach;
	return count;
end;
</source>
        <Parameter name="_oldILD" type="CM_InvoiceLineDesc"/>
        <Parameter name="_newILD" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
