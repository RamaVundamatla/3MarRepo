<Class name="Class">
    <JadeMethod name="cnEcCount" id="21f8223c-743c-4ed9-bb22-e92162065c5d">
        <source>cnEcCount(pCondition:String; pIsSubclasses:Boolean):Integer;
// --------------------------------------------------------------------------------
// Created:		20 December 2002 by cnwdad1
//
// Purpose:		This method will return a count of all instances of the receiver,
//				optionally executing JADE code against each object, such as some
//				condition to include or exclude particular objects in the count.
//				Note that the JADE code must not be enclosed in begin/end statements.
//
//				For example:
//
//				write Customer.cnEcCount("self.balanceOwing &gt; 0", true);
//
// Parameters:	pCondition - JADE source code to execute against each instance.
//				pIsSubclasses - If true, instances of subclasses will also be counted.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	instanceObj		: Object;
	allObjects		: ObjectArray;
	sourceCode		: String;
	objectCount		: Integer;
	errorCode		: Integer;
	errorPos		: Integer;
	errorLength		: Integer;
	methodObj		: JadeMethod;
	exceptionObj	: SystemException;
	
begin
	if pCondition &lt;&gt; null then
		sourceCode	:=	"begin return " &amp; pCondition &amp; "; end;";
		methodObj	:=	process.createTransientMethod(	"cnEcObjectFilter",
														self,
														currentSchema,
														sourceCode,
														true,
														Boolean,
														errorCode,
														errorPos,
														errorLength);
		
		if errorCode &lt;&gt; 0 then
			create exceptionObj transient;
			
			exceptionObj.errorCode	:=	errorCode;
			exceptionObj.errorItem	:=	sourceCode[errorPos:errorLength + 1];
			
			if exceptionObj.text.pos("Undefined message number", 1) &gt; 0 then
				exceptionObj.extendedErrorText	:=	process.getErrorText(errorCode);
			endif;
			
			raise exceptionObj;
			
			return null;
		endif;
	endif;
	
	create allObjects transient;
	self.allInstances(allObjects, 0, pIsSubclasses);
	
	if pCondition = null then
		return allObjects.size();
	else
		foreach instanceObj in allObjects where process.executeTransientMethod(methodObj, instanceObj).Boolean do
			objectCount	:=	objectCount + 1;
		endforeach;
		
		return objectCount;
	endif;
epilog
	if methodObj &lt;&gt; null then
		process.deleteTransientMethod(methodObj);
	endif;
	
	delete allObjects;
end;</source>
        <Parameter name="pCondition" type="String"/>
        <Parameter name="pIsSubclasses" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcDocumentCollection" id="13a90862-026b-47cf-839e-a254e85609b9">
        <source>cnEcDocumentCollection(	pParameterObj:CnEcDocParameter;
						pHtmlFile:File io;
						pIsIncludeRootSchemaClasses:Boolean;
						pSchemaColl:SchemaColl;
						pPathToIndex:String) protected;
// --------------------------------------------------------------------------------
// Created:		13 October 2000 by cnwdad1
//
// Purpose:		This method is an abstraction for the subclass method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/02/2003	cnwdad1		Added the pTheParameter parameter so that hyperlinks
//							will not be generated to classes that are not included
//							in the documentation.
// --------------------------------------------------------------------------------
begin
end;</source>
        <access>protected</access>
        <Parameter name="pParameterObj" type="CnEcDocParameter"/>
        <Parameter name="pHtmlFile" type="File" usage="io"/>
        <Parameter name="pIsIncludeRootSchemaClasses" type="Boolean"/>
        <Parameter name="pSchemaColl" type="SchemaColl"/>
        <Parameter name="pPathToIndex" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcDocumentSelf" id="fc2894e0-e731-4dd8-a63e-9c947e82fda2">
        <source>cnEcDocumentSelf(	pParameterObj:CnEcDocParameter;
					pAlias:String;
					pSuperclassAlias:String;
					pAllDocProperties:CnEcDocModelPropertyByNameDict;
					pAllDocMethods:CnEcDocModelMethodByNameDict;
					pDirectory:String;
					pSchemaColl:SchemaColl;
					pPathToIndex:String);
// --------------------------------------------------------------------------------
// Created:		16 February 2000 by cnwdad1
//
// Purpose:		Generates an HTML documentation file for the receiver class.
//
// Parameters:	pParameterObj - The class documentation parameter object.
//				pAllDocProperties - A restricted collection of the properties to
//					document. If this collection is empty, then all properties will
//					be documented.
//				pAllDocMethods - A restricted collection of the methods to document.
//					If this collection is empty, then all methods will be documented.
//				pDirectory - The directory where the file will be created.
//				pSchemaColl (SchemaColl) - The collection (Array) of schemas that
//					are a valid list of schemas to be documented (used when including
//					hyperlinks from Class property references to the documentation
//					for the reference type Class).
//				pPathToIndex (String) - The file path of the documentation index file.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 22/08/2000	cnwdad1		Added ability to also document Property Text, and prevented
//							Jade RootSchema properties from being included.
// 11/10/2000	cnwdad1		Added an index feature, thus changed this method to
//							include a "Back to Index" link.
// 01/11/2002	cnwdad1		Added the pTheParameter and pAllDocProperties parameters.
//							The first new parameter replaces several common parameters.
//							If this second new parameter is not empty, then only those
//							properties will be documented.
// 28/11/2002	cnwdad1		Delete the thePropertyColl collection.
// 23/01/2003	cnwdad1		Added support for an alias of the receiver's name.
// 24/01/2003	cnwdad1		Added support for a restricted collection of methods to
//							document, the same as the properties collection.
// 24/01/2003	cnwdad1		Added the superclass to the heading of the HTML page.
// 07/02/2003	cnwdad1		Added support for the isIncludeClassText option on the
//							CnEcDocParameter class to control whether class text is
//							included in the documentation.
// 19/02/2003	cnwdad1		Added the pTheParameter parameter so that hyperlinks
//							will not be generated to classes that are not included
//							in the documentation.
// --------------------------------------------------------------------------------
vars
	fileName		: String;
	nameOfClass		: String;
	superclassName	: String;
	superclassObj	: Class;
	htmlFileObj		: File;
	methodSsetObj	: MethodSet;
	propertyCollObj	: PropertyColl;
	propertyObj		: Property;
	methodObj		: Method;
	pathDelimCount	: Integer;
	pathDelimIndex	: Integer;
	pathBackToIndex	: String;
	indexHyperlinks	: String;
	docPropertyObj	: CnEcDocModelProperty;
	docMethodObj	: CnEcDocModelMethod;

begin
	fileName		:=	pDirectory &amp; global.cnEcGetFileSeparator() &amp; self.name &amp; CNEC_CLASS_DOC_HTML_SUFFIX;
	
	// Get the URL for the superclass.
	
	pathDelimIndex	:=	pDirectory.pos(self.superclass.name, 1);
	
	if pathDelimIndex &gt; 0 then
		pathDelimIndex	:=	pathDelimIndex + self.superclass.name.length() - 1;
	endif;
	
	// Work out a relative file path back to the documentation index file.  This
	// is based upon working back up the directory tree, for example: "..\" will
	// move back up one directory level.
	
	pathDelimCount	:=	pPathToIndex.cnEcSubstringCount(global.cnEcGetFileSeparator());
	
	foreach pathDelimIndex in 1 to pathDelimCount do
		if pathBackToIndex = null then
			pathBackToIndex	:=	".." &amp; global.cnEcGetFileSeparator();
		else
			pathBackToIndex	:=	pathBackToIndex &amp; ".." &amp; global.cnEcGetFileSeparator();
		endif;
	endforeach;
	
	// Create the documentation file and write the heading details.
	
	if pAlias = null then
		nameOfClass	:=	self.name;
	else
		nameOfClass	:=	pAlias;
	endif;
	
	superclassObj	:=	self.superclass;
	
	if pSuperclassAlias = null then
		superclassName	:=	superclassObj.name;
	else
		superclassName	:=	pSuperclassAlias;
	endif;
	
	create htmlFileObj transient;
	htmlFileObj.openOutput(fileName);
	htmlFileObj.writeLine("&lt;HTML&gt;&lt;HEAD&gt;&lt;TITLE&gt;" &amp; nameOfClass &amp; " Class&lt;/TITLE&gt;&lt;/HEAD&gt;");
	htmlFileObj.writeLine("&lt;BODY&gt;&lt;BASEFONT FACE=" &amp; 34.Character &amp; "Arial" &amp; 34.Character &amp;  " SIZE=" &amp; 34.Character &amp; "2" &amp; 34.Character &amp; "&gt;");
	htmlFileObj.writeLine("&lt;H2&gt;&lt;P ALIGN=" &amp; 34.Character &amp; "center" &amp; 34.Character &amp; "&gt;&lt;STRONG&gt;" &amp; nameOfClass &amp; " Class&lt;/STRONG&gt;&lt;/H2&gt;&lt;/P&gt;");
	
	if superclassObj &lt;&gt; null then
		if pParameterObj.allClasses[superclassObj.name] = null then
			htmlFileObj.writeLine("&lt;P ALIGN=" &amp; 34.Character &amp; "center" &amp; 34.Character &amp; "&gt;&lt;STRONG&gt;Inherits from: " &amp; superclassName &amp; "&lt;/STRONG&gt;&lt;/P&gt;"); 
		else
//			htmlFileObj.writeLine("&lt;P ALIGN=" &amp; 34.Character &amp; "center" &amp; 34.Character &amp; "&gt;&lt;STRONG&gt;Inherits from: &lt;A HREF=" &amp; 34.Character &amp; superFileName &amp; 34.Character &amp; "&gt;" &amp; superclassName &amp; "&lt;/A&gt;&lt;/STRONG&gt;&lt;/P&gt;");
			htmlFileObj.writeLine("&lt;P ALIGN=" &amp; 34.Character &amp; "center" &amp; 34.Character &amp; "&gt;&lt;STRONG&gt;Inherits from: " &amp; superclassObj.cnEcDocumentGetClassHyperlink(pParameterObj, superclassObj.name, pParameterObj.isIncludeJadeClasses, pSchemaColl, pPathToIndex) &amp; "&lt;/STRONG&gt;&lt;/P&gt;");
		endif;
	endif;

	// Write some hyperlinks back to the index files.

	indexHyperlinks	:=	"&lt;P&gt;";
	indexHyperlinks	:=	"&lt;A HREF=" &amp; 34.Character &amp; pathBackToIndex &amp; CNEC_CLASS_DOC_MAIN_INDEX &amp; 34.Character &amp; "&gt;Main Index&lt;/A&gt;";
	indexHyperlinks	:=	indexHyperlinks &amp; "   &lt;A HREF=" &amp; 34.Character &amp; pathBackToIndex &amp; CNEC_CLASS_DOC_NAME_INDEX &amp; 34.Character &amp; "&gt;Class Name Index&lt;/A&gt;";
	indexHyperlinks	:=	indexHyperlinks &amp; "   &lt;A HREF=" &amp; 34.Character &amp; pathBackToIndex &amp; CNEC_CLASS_DOC_HIERARCHY_INDEX &amp; 34.Character &amp; "&gt;Class Hierarchy Index&lt;/A&gt;";
	indexHyperlinks	:=	indexHyperlinks &amp; "&lt;/P&gt;";
	htmlFileObj.writeLine(indexHyperlinks);
	
	// Next, write the class's text.
	
	if pParameterObj.isIncludeClassText then
		htmlFileObj.writeLine(self.text.cnEcAsHtml());
	endif;

	// Next, document the class's collection-specific details.

	self.cnEcDocumentCollection(pParameterObj, htmlFileObj, pParameterObj.isIncludeJadeClasses, pSchemaColl, pPathToIndex);

	// Next, document the class's attributes.

	htmlFileObj.writeLine("&lt;H2&gt;&lt;STRONG&gt;Attributes&lt;/STRONG&gt;&lt;/H2&gt;&lt;BR&gt;");
//	thePropertyColl	:=	self.allProperties;		// Find the attributes for this class
	htmlFileObj.writeLine("&lt;TABLE WIDTH=" &amp; 34.Character &amp; "100%" &amp; 34.Character &amp; "&gt;");
	htmlFileObj.writeLine("&lt;TR&gt;&lt;TD&gt;&lt;STRONG&gt;Attribute&lt;/STRONG&gt;&lt;/TD&gt;&lt;TD&gt;&lt;STRONG&gt;Type&lt;/STRONG&gt;&lt;/TD&gt;&lt;TD&gt;&lt;STRONG&gt;Length&lt;/STRONG&gt;&lt;/TD&gt;&lt;TD&gt;&lt;STRONG&gt;Access&lt;/STRONG&gt;&lt;/TD&gt;&lt;/TR&gt;");
	
	if pAllDocProperties &lt;&gt; null and pAllDocProperties.cnEcIsNotEmpty() then
		foreach docPropertyObj in pAllDocProperties do
			docPropertyObj.myProperty.cnEcDocumentSelf(	pParameterObj,
														docPropertyObj.alias,
														htmlFileObj,
														pParameterObj.isIncludeJadeClasses,
														pSchemaColl,
														pPathToIndex);
		endforeach;
	elseif pParameterObj.isDoAllWhenNoList then
		propertyCollObj	:=	self.allProperties;		// Find the attributes for this class
		
		foreach propertyObj in propertyCollObj do
			if pParameterObj.isIgnoreCollections and propertyObj.cnEcIsCollection() then
				continue;
			endif;
			
			propertyObj.cnEcDocumentSelf(pParameterObj, null, htmlFileObj, pParameterObj.isIncludeJadeClasses, pSchemaColl, pPathToIndex);
		endforeach;
	endif;

	htmlFileObj.writeLine("&lt;/TABLE&gt;&lt;BR&gt;");

	// Next, document the class's methods.

	htmlFileObj.writeLine("&lt;H2&gt;&lt;STRONG&gt;Methods&lt;/STRONG&gt;&lt;/H2&gt;&lt;BR&gt;");  
	
	if pAllDocMethods &lt;&gt; null and pAllDocMethods.cnEcIsNotEmpty() then
		foreach docMethodObj in pAllDocMethods do
			docMethodObj.myMethod.cnEcDocumentSelf(	docMethodObj.alias,
													htmlFileObj,
													pParameterObj.isIncludeSource);
		endforeach;
	elseif pParameterObj.isDoAllWhenNoList then
		create methodSsetObj transient;
		self.allMethods(methodSsetObj);			// Find the methods for this class.
	
		foreach methodObj in methodSsetObj do
			methodObj.cnEcDocumentSelf(null, htmlFileObj, pParameterObj.isIncludeSource);
		endforeach;
	endif;

	// Finally, write the closing HTML page tags.

	htmlFileObj.writeLine("&lt;/BODY&gt;&lt;/HTML&gt;");
epilog
	delete propertyCollObj;		// cnwdad1 28/11/2002.
	delete htmlFileObj;
	delete methodSsetObj;
end;</source>
        <Parameter name="pParameterObj" type="CnEcDocParameter"/>
        <Parameter name="pAlias" type="String"/>
        <Parameter name="pSuperclassAlias" type="String"/>
        <Parameter name="pAllDocProperties" type="CnEcDocModelPropertyByNameDict"/>
        <Parameter name="pAllDocMethods" type="CnEcDocModelMethodByNameDict"/>
        <Parameter name="pDirectory" type="String"/>
        <Parameter name="pSchemaColl" type="SchemaColl"/>
        <Parameter name="pPathToIndex" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetAllMethods" id="5139e91d-9270-4424-8c37-ecef2b373f75">
        <source>cnEcGetAllMethods(pAllMethods:MethodSet io);
// --------------------------------------------------------------------------------
// Created:		18 April 2003 by cnwdad1
//
// Purpose:		Populates the specified set with the receiver's methods, plus the
//				methods inherited from all superclasses.
//
// Parameters:	pAllMethods - The method set to populate.
//
// Returns:		The populated method set.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allMethods(pAllMethods);
	
	if self.superclass &lt;&gt; null then
		self.superclass.cnEcGetAllMethods(pAllMethods);
	endif;
end;</source>
        <Parameter name="pAllMethods" type="MethodSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetAllSuperclasses" id="c1c35eac-d6ae-49ec-887c-28e41db78d17">
        <source>cnEcGetAllSuperclasses(pAllClassesObj:ClassSet input);
// --------------------------------------------------------------------------------
// Created:		07 April 2005 by cnwdad1
//
// Purpose:		Populates a set of classes with all of the receiver's superclasses.
//
// Parameters:	pAllClassesObj - The set of classes to populate.
//
// Returns:		The populated set of classes.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.superclass &lt;&gt; null then
		pAllClassesObj.add(self.superclass);
		self.superclass.cnEcGetAllSuperclasses(pAllClassesObj);
	endif;
end;</source>
        <Parameter name="pAllClassesObj" type="ClassSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetBinaryPropertyLength" id="02281416-d72f-476c-9f22-19da14de2165">
        <source>cnEcGetBinaryPropertyLength(pPropertyName : String) : Integer;
// --------------------------------------------------------------------------------
// Created:		10 April 2001 by cnwdad1
//
// Purpose:		Returns the length (in character units) of the requested binary
//				property.  Returns zero if the property doesn't exist, or if the
//				property is not a binary attribute. Unbounded blobs will return
//				a negative length.
//
// Parameters:	The name of the property.
//
// Returns:		The length of the binary property.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	propertyObj	: Property;
	classObj	: Class;
	
begin
	classObj	:=	self;
	
	while classObj &lt;&gt; null do
		propertyObj	:=	classObj.rootType.properties[pPropertyName];
		
		if propertyObj &lt;&gt; null
		and Attribute.hasInstance(propertyObj)
		and propertyObj.type = Binary
		then
			if app.isUnicode() then
				return (propertyObj.getLength() div 2);// - 1;
			endif;
			
			return propertyObj.getLength();// - 1;
		endif;
		
		classObj	:=	classObj.superclass;
	endwhile;
	
	return 0;
end;</source>
        <Parameter name="pPropertyName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetClassTreeName" id="15975c52-d069-4415-95ca-808c344bc161">
        <source>cnEcGetClassTreeName():String;
// --------------------------------------------------------------------------------
// Created:		22 August 2000 by cnwdad1
//
// Purpose:		Returns a string with the name of the receiver's tree, in the
//				format of a DOS filename.
//
// Parameters:	None
//
// Returns:		The receiver's class hierarchy.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	classTree		: String;
	superClassObj	: Class;

begin
	superClassObj	:=	self;
	classTree		:=	self.name;

	while superClassObj &lt;&gt; null do
		superClassObj	:=	superClassObj.superclass;

		if superClassObj &lt;&gt; null then
			classTree	:=	superClassObj.name &amp; global.cnEcGetFileSeparator() &amp; classTree;
		endif;
	endwhile;

	return classTree;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetImplementationSchema" id="16db4046-d94f-4876-8205-45c1bd6a06c4">
        <source>cnEcGetImplementationSchema():Schema;
// --------------------------------------------------------------------------------
// Created:		10 July 1999 -  cnEcGetImplementationSchema
// By:			cnwdad1
//
// Purpose:		At runtime, a class that is inherited from a superschema may appear
//				to be in a subschema because JADE will make a copy of that class in
//				the lowest schema in which the inherited class has been subclassed
//				(down to the level of the currently executing application).
//
//				For example, if we have the following two schemas:
//
//				CardSchema
//					BaseSchema
//
//				...and CardSchema has a class called 'ClassA', and BaseSchema implements
//				a subclass of 'ClassA' called 'ClassB', then an application running in
//				BaseSchema will consider both 'ClassA' and 'ClassB' to be in BaseSchema.
//
//				The method will return the schema in which the class is truly implemented.
//
// Parameters:	None
// Returns:		Schema - The schema in which the Class is implemented.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27/03/2002	cnwdad1		Changed to use the Type::rootType() method.
// --------------------------------------------------------------------------------
//vars
//	schemaObject	: Schema;
//	subSchemas		: SchemaColl;
//	classObject		: Class;

begin
	return self.rootType().schema;
//	if (self._isSubschemaCopy) then				// Check whether this class has been copied into a subschema.
//		// Note that there's no point in checking for the class in RootSchema because that
//		// is the highest schema, therefore the class can't have been copied there.
//		create subSchemas transient;
//		rootSchema.allSubschemas(subSchemas);	// Get a collection of all subschemas of the RootSchema.
//
//		foreach schemaObject in subSchemas do
//			classObject	:=	schemaObject.getClass(self.name);	// Look for the class in this schema.
//
//			if (classObject &lt;&gt; null) then
//				break;							// Found it, let's get out of here.
//			endif;
//		endforeach;
//	else
//		// If the class hasn't been copied, then this is the schema in which it is implemented.
//		schemaObject	:=	self.schema;
//	endif;
//
//	return schemaObject;
epilog
//	delete subSchemas;
end;</source>
        <ReturnType type="Schema"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetObjectSize" id="d244c520-e092-429b-8491-a9da8034c097">
        <source>cnEcGetObjectSize(pLength:Integer output; pBlobCount:Integer output);
// --------------------------------------------------------------------------------
// Created:		16 August 2001 by cnwdad1
//
// Purpose:		Returns the size (length) of the receiver, and the number of blobs
//				(and/or slobs) found.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//	27 Nov 2014	cnwkpd1	PAR #35261 - Changes to prepare for JADE 7.1
// --------------------------------------------------------------------------------
constants
	NO_SUBID = 0.Integer;
	
vars
	propertyCollObj	: PropertyColl;
	propertyObj		: Property;
	objectSize		: Integer;
	propertyLength	: Integer;
	blobCount		: Integer;
	referenceLen	: Integer;
	
begin
	if app.getSystemVersion &gt; '7.1' then
		referenceLen := 12;
	else
		referenceLen := 10;
	endif;

	propertyCollObj	:=	self.allProperties();
	
	foreach propertyObj in propertyCollObj do
		
		if propertyObj.virtual then
			continue;
		endif;
		
		if propertyObj.isKindOf(Attribute) then
			if propertyObj.Attribute.length &lt;&gt; -1 and propertyObj.Attribute.length &lt; 541 then
				propertyLength	:=	propertyObj.Attribute.length;
			else
				propertyLength	:=	8;
				blobCount		:=	blobCount + 1;
			endif;
				
		elseif propertyObj.getPropertyValue('subId').Integer = NO_SUBID then
			propertyLength	:=	referenceLen;
		else
			// It must be a sub-object.
			propertyLength := 0;
		endif;
		
		objectSize	:=	objectSize + propertyLength;

	endforeach;
	
	pLength		:=	objectSize;
	pBlobCount	:=	blobCount;
	
epilog
	delete propertyCollObj;
	
end;</source>
        <Parameter name="pLength" type="Integer" usage="output"/>
        <Parameter name="pBlobCount" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetPropertiesByOrdinal" id="578292f1-521b-4c92-969b-137df73fd759">
        <source>cnEcGetPropertiesByOrdinal() : PropertyODict;
/*

Purpose:			Gets a collection of properties that is sorted by ordinal. As the collection is protected

Parameters:			NONE

Return Value:		PropertyODict	Containing the properties to return

Date		Who		Reason
17 June 2022	navpw1	Initial creation TFS: 53883

*/

begin
	return self.propertyOrder;
	
end;</source>
        <ReturnType type="PropertyODict"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetStringPropertyLength" id="724ab9ed-b117-44df-81bd-e1f06c1301cb">
        <source>cnEcGetStringPropertyLength(pPropertyName : String) : Integer;
// djc, 17 Aug 2000
// Returns the length (in character units) of the requested string property.
// Returns zero if the property doesn't exist, or if the property is not a
// string attribute. Unbounded slobs will return a negative length.
vars
	propertyObj	: Property;
	classObj	: Class;
	
begin
	classObj	:=	self;
	
	while classObj &lt;&gt; null do
		propertyObj	:=	classObj.rootType.properties[pPropertyName];
		
		if propertyObj &lt;&gt; null
		and propertyObj.isKindOf(Attribute)
		and propertyObj.type = String
		then
			if app.isUnicode() then
				return (propertyObj.getLength() div 2) - 1;
			else
				return propertyObj.getLength() - 1;
			endif;
		endif;
		
		classObj	:=	classObj.superclass;
	endwhile;
	
	return 0;
end;</source>
        <Parameter name="pPropertyName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetSystemType" id="6a40af30-4aef-4ec9-aadf-3c2b32fcd1c2">
        <source>cnEcGetSystemType():Class;
// --------------------------------------------------------------------------------
// Created:		17 December 2005 by cnwdad1
//
// Purpose:		Returns the JADE Type of the receiver.  If the receiver is already
//				a system type, then self will be returned, otherwise the superclass(es)
//				will be recursively called until a system type is found.
//
// Parameters:	None
//
// Returns:		A reference to the receiver's system type (superclass).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isSystemObject() then
		return self;
	else
		return self.superclass.cnEcGetSystemType();
	endif;
end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsGUI" id="258d9614-a634-4930-ba39-b354392a373a">
        <source>cnEcIsGUI():Boolean;
// --------------------------------------------------------------------------------
// Created:		07 March 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether or not the receiver is
//				a GUI class.
//
// Parameters:	None
//
// Returns:		True if the receiver is a GUI class, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.inheritsFrom(Window);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
