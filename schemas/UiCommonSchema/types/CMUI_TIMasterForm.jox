    <JadeMethod name="openTiMasterMaintForm" id="c1db7231-9c1f-4edc-b8b8-c46d0c3ccbe0">
        <updating/>
        <source>openTiMasterMaintForm(_isEdit : Boolean) protected, updating;
// -------------------------------------------
// Created 30 November 2005 by cnwdvb1
// 22/05/2024	navcs2	MTN-34843
// -------------------------------------------
vars

	form			: CM_BaseForm;
//	form			: CMUI_TIMasterMaintForm;
	tiEditMaster	: CM_TIMaster;
	wagonMaster		: CM_WagonMaster;

begin

	if self.isWagonMaster() then	// 06 Jul 2009	NDL	CCMS 1067
		wagonMaster := self.myCurrentWagonMaster.CM_WagonMaster;
		if wagonMaster = null and _isEdit then
			return;
		endif;
		form := app.loadForm(CMUI_WagonMasterMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_WagonMasterMaintForm;
		if form = null then
			return;
		endif;
		if _isEdit then
			form.CMUI_WagonMasterMaintForm.setAttributes(wagonMaster);
		endif;
		
		form.setParentForm(self);
		form.centreOverParent(0);
		form.show;
		return;
		
	elseif self.isTILC() then
		tiEditMaster := self.myCurrentTiMaster.CM_TIMasterTILC;
		if tiEditMaster = null and _isEdit then
			return;
		endif;
		form := app.loadForm(CMUI_TIMasterMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_TIMasterMaintForm;
		if form = null then
			return;
		endif;
		form.CMUI_TIMasterMaintForm.setAttributes(tiEditMaster.CM_TIMasterTILC, _isEdit);
		
	// 22/05/2024	navcs2	MTN-34843 Start	
	elseif self.isMAFI() then
		tiEditMaster := self.myCurrentTiMaster.CM_TIMasterTILC;
		if tiEditMaster = null and _isEdit then
			return;
		endif;
		form := app.loadForm(CMUI_TIMasterMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_TIMasterMaintForm;
		if form = null then
			return;
		endif;
		form.CMUI_TIMasterMaintForm.setAttributes(tiEditMaster.CM_TIMasterTILC, _isEdit);
	// 22/05/2024	navcs2	MTN-34843 End
	
	elseif self.isGenerator then
		tiEditMaster := self.myCurrentTiMaster.CM_TIMasterGenerator;
		if tiEditMaster = null and _isEdit then
			return;
		endif;
		form := app.loadForm(CMUI_MasterGeneratorMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_MasterGeneratorMaintForm;
		if form = null then
			return;
		endif;
		form.CMUI_MasterGeneratorMaintForm.setAttributes(tiEditMaster.CM_TIMasterGenerator, _isEdit);
		
	else
		tiEditMaster := self.myCurrentTiMaster.CM_TIMasterContainer;
		if tiEditMaster = null and _isEdit then
			return;
		endif;
		form := app.loadForm(CMUI_MasterContainerMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_MasterContainerMaintForm;
		if form = null then
			return;
		endif;
		
		if tblData.allSelectedObjects.size &gt; 1  then
				//range edit
				form.CMUI_MasterContainerMaintForm.setAttributes(tblData.allSelectedObjects[1].CM_TIMasterContainer, _isEdit, tblData.allSelectedObjects.last.CM_TIMasterContainer );
			else
				// single edit
				form.CMUI_MasterContainerMaintForm.setAttributes(tiEditMaster.CM_TIMasterContainer, _isEdit, null);
		endif;
		//app.raiseUnexpectedProgramError( class.name, method.name, 'under development - requires Master Maint form for container' );
	endif;

	form.setParentForm(self);
	form.centreWindow;
	form.centreOverParent(0);
	
	//form.setFormParent( self );
	form.show();
	//form.show();

end;</source>
        <access>protected</access>
        <Parameter name="_isEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveXMLStrForTblColumns" id="11742a2d-fd76-4836-981b-979f8107a4f2">
        <updating/>
        <source>saveXMLStrForTblColumns(_theTable: CM_DataTable input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2008	cnwrd1	Initial creation
30 Apr 2018	NDL	TFS 38313

*/

vars
	xmlStr : String;
begin

	xmlStr := self.tblData.getXmlStrForColumns(true);

	if self.modeStr = self.CargoType_Wagon.String then	//06 Jul 2009	NDL CCMS 1967
		self.xmlStrTblDataWagon := xmlStr;	
	elseif self.modeStr = self.CargoType_Trailer.String then
		self.xmlStrTblDataTrailer := xmlStr;	
	elseif self.modeStr = self.CargoType_Generator.String then
		self.xmlStrTblDataGen := xmlStr;	
	else
		self.xmlStrTblDataCont := xmlStr;	
	endif;
epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
