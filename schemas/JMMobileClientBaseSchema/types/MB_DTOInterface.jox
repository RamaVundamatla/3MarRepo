    <JadeMethod name="showError" id="0b89765e-ddd5-4426-b622-26f76daf29ff">
        <source>showError(pErrorMsg:String) protected;
// --------------------------------------------------------------------------------
// Created:		14 October 2005 by cnwdad1
//
// Purpose:		Displays an error message, generally ones that were received from
//				the remote database.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.mbRaiseException(pErrorMsg);
end;</source>
