    <JadeMethod name="verifyEDIDataTIs" id="19f76e8f-ad59-47b3-989c-affeac22d742">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
//----------   ----------  --------------------------------------------------
//Created:	09 Jan 2010 cnwrs1
//
//Purpose:	
//
//Changed On   Changed By  Reason
//	
//----------   ----------  --------------------------------------------------
//30 Jan 2012	cnwrs1	Par 29024
// 20/06/2012	cnwcs5	par 29747 - moved verify into trx/utl
// 15 Jan 2018	jlgrs1	TFS 36636 STW Cargo By Site to be partial loading
vars
	terminal 	: CM_Terminal;
	ediTI : CM_EDITrackedItem;
	allowPartialLoad : Boolean;
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	allowPartialLoad := self.getMyTerminal.getConfig(EdiCargoByAllowPartial).Boolean;
	app.setContinueCMExceptions(true);
		
	terminal := self.getMyTerminal();
	
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return _passport.allErrors.size;
	endif;
			
	if not allowPartialLoad then
		app.myTrxUA.trxProcessEDITIsCargo(self, true, _passport);
	else
		foreach ediTI in self.allEDITrackedItems do
			ediTI.verifySelf();
		endforeach;
	endif;
	return _passport.allErrors.size;	
epilog
end;
</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyUniqueness" id="21911291-120e-4ae7-8f6b-c11f3ba1da5e">
        <source>verifyUniqueness();
/*
Purpose:			

Date		Who		Reason
// ### TFS BUG 58101 22MAY2023 NAVAB1
19/06/2023	navdap1	TFS 58101 not all EDI tracked items are EDI Cargo TIs (could be seals or hazards)
*/

vars
	uniqueDict	: DynaDictionary;
	ediTI : CM_EDITrackedItem;
	ediCargo, otherCargo	: CM_EDICargoTI;
	cargotype : CM_CargoType;
	usesCGforUniqueness : Boolean;
begin
	// ### TFS BUG 58701 20JUN2023 NAVAB1 - only do this if cargo group is enabled
	if not app.isCargoGroupEnabled then
		return;
	endif;
	
	// ### TFS BUG 58701 20JUN2023 NAVAB1 - only do this if cargo group is configured for uniqueness
	foreach ediTI in self.allEDITrackedItems do
		if not ediTI.isEDICargo then
			continue;
		endif;
		
		cargotype := app.myRoot.allCargoTypesById[ediTI.cargoType];
		if cargotype &lt;&gt; null 
		and cargotype.useCargoGroupForUniqueness then
			usesCGforUniqueness := true;
			break;
		endif;
		
	endforeach;
		
	if usesCGforUniqueness then
		create uniqueDict transient;
		uniqueDict.setMembership(CM_EDICargoTI);
		uniqueDict.addMemberKey(CM_EDICargoTI::cargoType.name, false, false);
		uniqueDict.addMemberKey(CM_EDICargoTI::id.name, false, false);
		uniqueDict.addMemberKey(CM_EDICargoTI::locationId.name, false, false);
		uniqueDict.addMemberKey(CM_EDICargoTI::product.name, false, false);
		uniqueDict.addMemberKey(CM_EDICargoTI::cargoGroupId.name, false, false);
		uniqueDict.endKeys(true);

		foreach ediTI in self.allEDITrackedItems do
			if not ediTI.isEDICargo then
				continue;
			endif;
			
			// ### TFS BUG 58701 20JUN2023 NAVAB1
			if ediTI.messageMode = "D" then 
				continue;
			endif;
			
	//		write ediCargo.cargoType.String &amp; " " &amp; ediCargo.id &amp; " " &amp; ediCargo.locationId &amp; " " &amp; ediCargo.product &amp; " " &amp; ediCargo.cargoGroupId;
			ediCargo := ediTI.CM_EDICargoTI;
			otherCargo := uniqueDict.getAtKey(ediCargo.cargoType, ediCargo.id, ediCargo.locationId, ediCargo.product,ediCargo.cargoGroupId).CM_EDICargoTI;
			if otherCargo &lt;&gt; null then
				app.raiseCMException2(Onship_already_exists, ediCargo.id, ediCargo.getVoyageCode(), null, null);
			else
				uniqueDict.add(ediCargo); 
			endif;
		endforeach;
	endif;
epilog
	delete uniqueDict;
end;</source>
    </JadeMethod>
</Class>
