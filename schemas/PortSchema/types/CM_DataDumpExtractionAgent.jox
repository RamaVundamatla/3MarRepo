    <JadeMethod name="getXMLFilename" id="41c8d1e3-3d3c-4145-aa77-2d580ee022d6">
        <source>getXMLFilename(_transClass : CM_DataDumpTransSpecClass; _actionStr: String) : String protected;
// ---------------------------------------------------------------------------
// Created:     22 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	fileFolder: FileFolder;
begin
	create fileFolder transient;
	fileFolder.fileName := self.myExtractDef.fileFolderName &amp; "\";
	if not fileFolder.isAvailable then
		fileFolder.make();
	endif;
	return self.myExtractDef.fileFolderName &amp; "\" &amp;
			self.myExtractDef.description.replaceString(' ', '_') &amp;
			_transClass.getExtractSequence.String.padLeadingZeros(2) &amp;
			_transClass.getClassAlias &amp;
			self.extractToDateTime.fileNameFormat &amp;
			_actionStr &amp;
			self.FileExtensionXML;
epilog
	delete fileFolder;
end;</source>
        <access>protected</access>
        <Parameter name="_transClass" type="CM_DataDumpTransSpecClass"/>
        <Parameter name="_actionStr" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleExceptionFromTransientM" id="925602cb-3ace-4482-a2b7-df3dc6d1fd9d">
        <updating/>
        <source>handleExceptionFromTransientM(_exObject : Exception; _object : Object input; __errorCode : Integer output): Integer updating;
/*

Purpose:			Used to catch exceptions from the generated transient methods
					used to update the SQL database. Error are likely to be 
					1). object not found - could happen if object has gone
					2). invalid property - a generation error - check code
					3). invalid date, time etc.
					

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2010	conkc1	Initial creation
27 June 2012	cnwrs1	par 29826 - change the exception handler return to allow data extract to continue with the next class
*/
vars
	errorMessage : String;
	receiver     : Object;
	methodName   : String;
begin

	__errorCode   := _exObject.errorCode;
	errorMessage  := _exObject.errorCode.String;
	errorMessage  := errorMessage &amp; ", " &amp; _exObject.extendedErrorText;
	errorMessage  := errorMessage &amp; ", " &amp; _exObject.errorItem;
	
	if _exObject.currentMethodDesc &lt;&gt; null then
		methodName := _exObject.currentMethodDesc.getName;
		receiver   := _exObject.currentMethodDesc.getReceiver;
		if receiver &lt;&gt; null then
			methodName := methodName &amp; ", " &amp; receiver.String;
		endif;
	endif;
		
	if _object &lt;&gt; null then
		errorMessage := errorMessage &amp; ", " &amp; _object.String;
	endif;
	
	errorMessage := errorMessage &amp; ", " &amp; methodName;

	self.log("  ** Error - " &amp; errorMessage);

	self.createSQLNativeAlert(errorMessage);

//	return Ex_Abort_Action;
	return Ex_Pass_Back;	// 27 June 2012	cnwrs1	par 29826 
epilog

end;</source>
        <Parameter name="_exObject" type="Exception"/>
        <Parameter name="_object" type="Object" usage="input"/>
        <Parameter name="__errorCode" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="0edfa3a8-a105-415d-abfa-9abbc3d30c96">
        <updating/>
        <source>initialise(_singleClassAliasWhenTesting: String;
		_checkFeatureLengthWhenTesting: Boolean;
		_isBackGroundApp : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     04 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	result   : Boolean;
	xDBAgent : CM_ExternalDatabaseAgent;
begin
	self.extractFormat := null;
	app.setIsBackGroundApp(_isBackGroundApp);
	
	self.singleClassAlias := _singleClassAliasWhenTesting.trimBlanks;
	self.checkFeatureLength := _checkFeatureLengthWhenTesting;
		
	on Exception do self.dataDumpGlobalExceptionHandler(exception) global;
	
	delete self.myChangeTrackingInterface;
	create self.myChangeTrackingInterface transient;
	
	self.finaliseExternalDatabaseAgent;
	
	self.createLog(self.DataDumpLogName);
	self.log(CrLf &amp; CrLf &amp; "Change Tracker extract started");
	if app &lt;&gt; null then
		app.myDataDumpExtractionAgent := self;
	endif;
	
epilog

end;</source>
        <Parameter name="_singleClassAliasWhenTesting" type="String"/>
        <Parameter name="_checkFeatureLengthWhenTesting" type="Boolean"/>
        <Parameter name="_isBackGroundApp" type="Boolean"/>
    </JadeMethod>
