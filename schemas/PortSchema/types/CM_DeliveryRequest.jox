    <JadeMethod name="myTerminal" id="e5271ab0-34a8-4f27-85cb-d87877205b8a">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 January 2014	cnwndl1	Initial creation

*/

vars

begin

	if not set then
		if self.mySubTerminalSource &lt;&gt; null then
			_value := self.mySubTerminalSource.myTerminal;
		endif;
		
		if _value = null then
			inheritMethod(set, _value);
		endif;
		
	endif;
	
	
	inheritMethod(set, _value);

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Terminal" usage="io"/>
