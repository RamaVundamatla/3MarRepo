    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vehicleSchedule"/>
    <MemberKey>
        <property name="CM_VehicleBookingTimeTemplate::startTime"/>
