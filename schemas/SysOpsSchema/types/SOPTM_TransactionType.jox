    <JadeMethod name="doSave" id="b936bd25-bb76-44bc-86ce-a72690ba317f">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// 19/06/2013	cnwcs5	par 31657 - tidy up while fixing par

vars
	proxy	: CM_TransactionType;
	form 	: SOP_TableMaintForm;
	table	: CM_EntryTable;
	type 	: Integer;
begin
  	form 	:= self.myForm; 
  	table	:= form.tblInput1;
	proxy 	:= form.myProxyObject.CM_TransactionType;
  	
	if proxy = null then
		if form.mode = form.Mode_Add then
			create proxy transient;
			
			form.myProxyObject := proxy;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	type := app.transactionTypeStringToEnum(table.getValueByName(ETRow_TranTypeGroup).String); // ### TFS CR 60699 TASK 60700 28SEP2023 NAVAB1
	
	proxy.setProxy(table.getValueByName(ETRow_Description).String,
					table.getValueByName(ETRow_TrxType).Integer,
					type,
					table.getValueByName(ETRow_TranTypeClass).String, // ### TFS CR 60699 TASK 60700 28SEP2023 NAVAB1
					table.getValueByName(ETRow_CanCompleteToDoTask).Boolean,
					app.myRoot);

	if form.mode = form.Mode_Add then
		app.myTrxCA.trxCreateTransactionType(proxy, form.myCurrentObject, app.myPassport);
		
	elseif form.mode = form.Mode_Update then
		app.myTrxUA.trxUpdateTransactionType(proxy, app.myPassport);
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; form.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK();
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="56c1208f-b3bb-44fa-94df-15b5bf44549e">
        <source>getCollection(): Collection;
// ---------------------------------------------------------------------------
// Created:      12 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// 19/06/2013	cnwcs5	par 31657 - tidy up while fixing par

vars
	trxType : CM_TransactionType;
	class	: Class;
	coll	: CM_TransactionTypeByType;
begin
	coll := self.allTransactionTypes;
	
	coll.clear();
	
	foreach trxType in app.myRoot.allTransactionTypes do
		class := currentSchema.getClass(trxType.classNameToCreate);
		
		if class &lt;&gt; null and not class.abstract then
			coll.add(trxType);
		endif;
	endforeach;
	
	return coll;
end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
