    <JadeMethod name="initMulEventTypes" id="82c1ccc5-8fa1-4141-b07e-984a0334e4c0">
        <source>initMulEventTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2020	jlgndl1	Initial creation	TFS 48784

*/

vars

begin

	self.mulEventTypes.lockBottom 		:= false;
	self.mulEventTypes.lockRight		:= false;
	self.mulEventTypes.stretchHeight 	:= true;
	self.mulEventTypes.stretchWidth 	:= true;
	self.mulEventTypes.multiSelect 	:= ListBox.MultiSelect_Extended;
	self.mulEventTypes.top 			:= 10;
	self.mulEventTypes.left			:= 10;
	self.mulEventTypes.width 			:= self.mulEventTypes.parent.width - 10;
