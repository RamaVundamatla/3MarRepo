    <JadeMethod name="doSave" id="5fdfc94d-8052-4c49-86d9-26f9d9dbda08">
        <updating/>
        <source>doSave(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Aug 2009	cnwml2	Initial creation
19 Mar 2013 cnwer1 31290
16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
*/

vars

	roadJobObj		: CM_RoadJob;
	userResponse	: Integer;
	visit 			: CM_VehicleVisitRecord;
	cmifArray 		: CM_ObjectArray;
	result			: Integer;
	invalidJob,
	printReceipt : Boolean;
	preview : Boolean;
	copies, roadJobStatus : Integer;		
begin
	if not app.myCurrentUserCan(self.myTerminal, PmGteRoadExitUpdate) then
		app.msgBox(app.getErrorString(NoPermission2), app.getErrorString(Road_exit), MsgBox_OK_Only);
		return false;
	endif;
	
	//self.myCurrentObject := self.tblData.allSelectedObjects.last().CM_Object;
	roadJobObj	:=	self.myVisitRecord.myRoadJob;
	//cnwjo3 par 24747.  No problems.  printReceive
	printReceipt := self.myTerminal.getConfig(GateReceiptRequired).Boolean;
	copies := self.myTerminal.getConfig(GateReceiptCopies).Integer;
	preview := self.myTerminal.getConfig(PrintPreview).Boolean;
	
	if roadJobObj = null then
		return false;
	endif;
	
	on Exception do app.handleDeletedObject(exception,roadJobObj,invalidJob);
	
	roadJobStatus:=roadJobObj.status;
	if invalidJob then
		return false;
	endif;
	
	if not roadJobObj.status = JOB_COMPLETE then
		
		self.setTblWorkEntryCols();
		
		create cmifArray transient;
		self.getWorkEntriesToComplete(cmifArray);
		
		//CHECK WORK ENTRIES HAVE TIS, MOVE THEM IF NECESSARY AND THEN PROCESS EXIT
		while true do
				//GET THE VISIT OBJECT OF THE JOB BEFORE WE DELETE THE JOB IN THE TRX
				visit := self.myVisitRecord;
				
				app.myTrxUA.trxUpdateJobInstantComplete(roadJobObj, cmifArray, null, app.myPassport);
				if app.myPassport.trxCompletedOK then			
					if visit &lt;&gt; null and printReceipt then
						//visit.printReceipt(copies, preview, self.myTerminal, self.myTerminal.getRoadReceiptReport().String, null, null);
						//12 Dec 2013	NDL	Par 33184
						visit.printRoadReceipt(	copies,	//_copies : Integer;
												preview,	//_printPreview : Boolean;
												null
												);
					endif;
					return true;
				else
					result := app.showErrorWarningDialog(app.getErrorString(Road_exit), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and result = IDOK then
						app.myPassport.warningsAcknowledged := true;
						continue;
					endif;
				endif;
		
				return false;
		endwhile;
	else
		
		
		while true do
			//app.myTrxDA.trxRoadExit(roadJobObj, null, app.myPassport);		//16.02.2024 navnk30 #62414
			app.myTrxDA.trxRoadExit(roadJobObj, null, app.myPassport);			//16.02.2024 navnk30 #62414
			
			if not app.myPassport.trxCompletedOK() then
				userResponse:=app.showErrorWarningDialog( app.getErrorString(Road_exit), app.myPassport, ErrWarnMode_AddUpdate+ ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
					userResponse = IDOK then
					app.myPassport.warningsAcknowledged     := true;
					continue;
				else
					return false;
				endif;
			endif;
			break;
		endwhile;
		
		return app.myPassport.trxCompletedOK();
	endif;
	
epilog
	if cmifArray &lt;&gt; null then
		delete cmifArray;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblExtraInfo" id="be59029b-81ca-4c26-827c-bb4e77d56601">
        <updating/>
        <source>doTblExtraInfo(_obj : Object) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 09 August 2007
//
//----------------------------------------------------------------------

vars
	dataContainer	: CM_DataContainer;
	
begin
	// DISPLAY INFO
	self.tblExtraInfo.rows := 0;
	self.tblExtraInfo.userObject := null;
	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
	dataContainer.displayMode := DISPLAY_MODE_ACTUAL;
	
	if _obj.isKindOf(CM_WorkListEntry) then
		_obj.CM_WorkListEntry.getExtraInfo(dataContainer);
	else
		return;
	endif;
	
	self.tblExtraInfo.userObject := _obj; // this is used to redraw this info
	
	self.showExtraInformation(dataContainer, self.tblExtraInfo, false,false, 4, 1, 4, 1, 1);
	self.doResizeColumnWidths(self.tblExtraInfo, true);
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doTurnaroundAsRelease" id="11792cd8-eca6-42e5-af5e-836fd73e92db">
        <updating/>
        <source>doTurnaroundAsRelease() updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 27 June 2007
//
//----------------------------------------------------------------------

vars
	proxyWLE	: CM_WorkListEntry;
	result		: Integer;
	obj			: Object;
begin
	
	//Be sure the current one is a RECEIPT
	if self.myCurrentWLE = null then
		return;
	endif;
	
	self.myCurrentWLE.fetchLatest();
	
	mousePointer := MousePointer_HourGlass;

	
	while true do
		if self.tblReceivals.allSelectedObjects.size &gt; 1 then
			foreach obj in self.tblReceivals.allSelectedObjects do
				proxyWLE := app.createUpdateProxy(obj.CM_WorkListEntry).CM_WorkListEntry;
				app.myTrxUA.trxUpdateWLEConvertToRelease(proxyWLE, null, app.myPassport); // cnwrd1 par 22624 3.5.2010
			endforeach;
		else
			proxyWLE := app.createUpdateProxy(self.myCurrentWLE).CM_WorkListEntry;
			app.myTrxUA.trxUpdateWLEConvertToRelease(proxyWLE, null,  app.myPassport); // cnwrd1 par 22624 3.5.2010
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Turn Around as Release',
												 app.myPassport, 
												 ErrWarnMode_AddUpdate + 
												 ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			// copies errors to this form and shows in err/warnings window			
			self.setAllErrorWarnings(app.myPassport);	
		endif;
		break;
	endwhile;	

epilog
	delete proxyWLE;
	mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUnassignTI" id="bc43d167-03fc-4b91-89c9-2feddde10f14">
        <updating/>
        <source>doUnassignTI() updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 27 June 2007
//
//----------------------------------------------------------------------

vars
	wleSet : CM_WLESet;
	obj : Object;
	wle : CM_WorkListEntry;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	app.mousePointer := MousePointer_HourGlass;	
	
	if self.myCurrentWLE = null then
		return;
	endif;
	
	if self.myCurrentWLE.status &lt;&gt; WLE_UNACTIONED then
		return;
	endif;	
	
	create wleSet transient;
	
	if self.tblReleases.allSelectedObjects.size &gt; 1 then
		foreach obj in self.tblReleases.allSelectedObjects do
			wle := obj.CM_WorkListEntry;
			wleSet.add(wle);
		endforeach;
	else
		wleSet.add(self.myCurrentWLE);
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWLEsUnassignTI(wleSet, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Unassign Cargo', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog 
	app.mousePointer := MousePointer_Default;	
	delete wleSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="findVehicleVisitRecord" id="e4d405a3-6c3b-46e4-a4d5-73462d71cce3">
        <updating/>
        <source>findVehicleVisitRecord(_isfirstTime : Boolean; _isNext : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwml2	Initial creation

*/

vars

begin
	if _isfirstTime then
		if self.myVisitRecord &lt;&gt; null and self.myVisitRecord.myRoadJob &lt;&gt; null then
			if self.myVisitRecord &lt;&gt; null then
				self.populateData();
			endif;
		endif;
	elseif _isNext then
		if self.myVisitRecord &lt;&gt; null then
			self.populateData();
		endif;
	else
		//self.myVisitRecord := self.cmbVisitNo.listObject.CM_VehicleVisitRecord;
		if self.myVisitRecord &lt;&gt; null then
			self.populateData();
		endif;
	endif;
	


epilog

end;</source>
        <Parameter name="_isfirstTime" type="Boolean"/>
        <Parameter name="_isNext" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getWorkEntriesToComplete" id="54849f39-f8d5-4a43-b9b7-458a1bb06496">
        <updating/>
        <source>getWorkEntriesToComplete(_wleArray : CM_ObjectArray io) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 29 June 2007
//
//----------------------------------------------------------------------

vars
	tbl : CM_DataTable;
	rowIdx,
	rows	: Integer;
	wle : CM_WorkListEntry;
	str : String;
	ti	: CM_TrackedItem;
	cargoType : CM_CargoType;
	cmifWLE : CMIF_WorkEntry;
	comboBox : CMUI_ComboBox;
	exc : Exception;
begin
	//GET INCOMPLETE WLES.
	//THESE ARE ONES THAT HAVE NOT BEEN MOVED OFF THE TRUCK.
	tbl := self.tblReceivals;
	rows := tbl.rows;
	foreach rowIdx in (tbl.fixedRows + 1) to rows do
		wle := tbl.accessRow(rowIdx).itemObject.CM_WorkListEntry;
		if wle = null  or wle.status = WLE_COMPLETED then
			continue;
		endif;
		
		str := tbl.getCellText(rowIdx, self.locationColumn);
						
		create cmifWLE transient;
		cmifWLE.set(null, str, cargoType, wle, wle.myTrackedItem, self.myTerminal);
				
		_wleArray.add(cmifWLE);
	endforeach;

	//NOW CHECK FOR RELEASES THAT HAVE NOT BEEN LOADED OR ALLOCATED A TRACKED ITEM.
	tbl := self.tblReleases;
	rows := tbl.rows;
	//RESET STR AS IT MAY HAVE BEEN USED IN THE ABOVE INFO GATHERING.
	str := null;
	foreach rowIdx in 2 to rows do
		wle := tbl.accessRow(rowIdx).itemObject.CM_WorkListEntry;
		if wle = null  or wle.status = WLE_COMPLETED then
			continue;
		endif;
		
		if wle.myTrackedItem = null then
			str := tbl.getCellText(rowIdx, self.cargoIdColumnRelease);
		endif;
		
		comboBox := tbl.accessCell(rowIdx, self.cargoTypeColumnReleaseTable).cellControl.CMUI_ComboBox;
		if comboBox &lt;&gt; null and comboBox.listObject &lt;&gt; null then
			cargoType := comboBox.listObject.CM_CargoType;
		endif;
		
		create cmifWLE transient;
		cmifWLE.set(str, null, cargoType, wle, wle.myTrackedItem, self.myTerminal);
		
		_wleArray.add(cmifWLE);
	endforeach;

epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_wleArray" type="CM_ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="ed30597d-6e99-4951-9c1a-ac69f1cbab5b">
