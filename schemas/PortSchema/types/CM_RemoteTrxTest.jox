<Class name="CM_RemoteTrxTest" id="b77dd101-916a-46a8-97e0-0850c28f7dfb">
    <superclass name="CM_RemoteDataHdr"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="remoteDataProcessing"/>
    <ImplicitInverseRef name="myTrxTestObject" id="2d609c8e-8547-4a8f-bbfe-d41babe4689c">
        <embedded/>
        <type name="CM_TrxTestController"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="processInternal" id="fb99e50b-529f-45b5-9c1d-f6cf670c3d36">
        <updating/>
        <source>processInternal(_cmif: CMIF_Remote; _passport : CM_Passport input) : Boolean updating;

// cnwdvb1 18 November 2002 

vars

	realRemoteHdr : CM_RemoteDataHdr;

begin

	inheritMethod(_cmif, _passport);
	self.messageType		:= 'TrxTest';
	self.myTrxTestObject	:= _cmif.myTrxTestObject;
	app.myTrxCA.trxCreateRemoteData(self, realRemoteHdr, true, _passport);

	return _passport.trxCompletedOK;

end;</source>
        <Parameter name="_cmif" type="CMIF_Remote"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runProcess" id="faa9e80f-9849-47a6-a847-edcd7e04e745">
        <source>runProcess(_errorSet: CM_ErrorSet input; _isBackGround: Boolean): Boolean;

// cnwdvb1 18 November 2002 

vars

begin

//	app.myTrxUA.aTrxSample(self.myTrxTestObject, app.myPassport);
	_errorSet.copyErrors(app.myPassport.allErrorWarnings);
	return inheritMethod(_errorSet, _isBackGround);

end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_isBackGround" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c9616784-77d4-4dc1-900c-701787a2fdda">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteTrxTest) updating;

// cnwdvb1 18 November 2002 

begin

	inheritMethod(_proxy);
	self.myTrxTestObject := _proxy.myTrxTestObject.cloneSelf(false);
	self.myTrxTestObject.cloneReferences(_proxy.myTrxTestObject);

end;</source>
        <Parameter name="_proxy" type="CM_RemoteTrxTest"/>
    </JadeMethod>
</Class>
