    <JadeMethod name="updateProgress" id="624a2940-268d-4e64-9416-a8b12be0fda0">
        <source>updateProgress(	_progressTS : TimeStamp io;
				_progressStr : String;
				_partsInJob, _partsDone : Integer;
				_force : Boolean;
				_passport : CM_Passport input) : Boolean;
/*

Purpose:			Let anything that cares know about a change in our status

Parameters:			_force:	Overrides the Interval check and always updates our status.
							Intended for the first (0%) and last (100%) update.

Return Value:		boolean: True if the user has pressed the Cancel button on the Monitor form

Date		Who		Reason
19/10/2020	jlgmd1	Initial creation TFS 49971 - Moved common code from EDIData subclasses to here
29/05/2024	navhn30	Bug 64340: MSL - Error 4030 Division by zero when manually verifying EDI files
19 Nov 2025 navhl20 Bug MTN-36492: TPA - Overall System Slowness
*/

vars
	interval 		: TimeStampInterval;
	terminal 		: CM_Terminal;
	cmifMonitorObj	: CMIF_Monitor;
	isWebMessage	: Boolean;
	cancel			: Boolean;
	partsInJob,
	partsDone		: Integer;
begin

	// Make sure we are actually in a state to do the monitoring updates
	if not self.canPerformMonitoring( _passport ) then
		return false;
	endif;

	interval := app.actualTimeAppServer() - _progressTS;				//19.11.2025 navhl20 #36492
	
	if _force or interval.getMilliseconds() &gt;= CM_EDIData.PROGRESS_BAR_REFRESH then
		cmifMonitorObj := _passport.myCMIFMonitor;
		
		// Re-use existing values
		partsInJob := _partsInJob;
		if partsInJob = CMIF_Monitor.MonitorReusePartsInJob_Done then
			partsInJob := cmifMonitorObj.partsInJob;
		endif;
		
		partsDone := _partsDone;
		if partsDone = CMIF_Monitor.MonitorReusePartsInJob_Done then
			partsDone := cmifMonitorObj.partsDone;
		endif;
		
		cancel := not cmifMonitorObj.updateProgress(_progressStr, partsInJob, _partsDone);	// On false, set Cancel to true
		_progressTS	:=	app.actualTimeAppServer();						//19.11.2025 navhl20 #36492
		
		// Let JSM know we're still doing something
		app.sendHeartbeatIfRequired();
		
		// EDI Web Monitor notifications
		terminal := self.getMyTerminal();
		isWebMessage := self.myEDIFile.isWebMessage();
		
		if isWebMessage and terminal &lt;&gt; null then
			if self.myEDIFile.fileStatus = CM_EDIFile.EDI_STATUS_VERIFIED then
				self.myEDIFile.causeEvent(terminal.getTerminalEvent(EventDBLoading), true, "DBLoading");
			endif;
			if _partsInJob &gt;0 then			// 29.05.24		navhn30		TFS 64340
				self.myEDIFile.causeEvent(terminal.getTerminalEvent(EventEDIProgress), true, ((_partsDone / _partsInJob) * 100));
			endif;
		endif;
		
		// User has pressed Cancel. Most EDI aren't set up to allow this, so disabling for now
		/*if cancel then
			app.raiseCMException(VB_USER_CANCELED_TRANS, null, null);
		endif;*/
		
		// jlgmd1 - 30/10/2020 currently only used by CM_EDIDataBOLOutLog::readFile
		return cancel;
		
	endif;

	return false;
epilog

end;</source>
        <Parameter name="_progressTS" type="TimeStamp" usage="io"/>
        <Parameter name="_progressStr" type="String"/>
        <Parameter name="_partsInJob" type="Integer"/>
        <Parameter name="_partsDone" type="Integer"/>
        <Parameter name="_force" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
