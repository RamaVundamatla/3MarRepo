    <JadeMethod name="createDummy" id="505a119c-b49f-4f8a-9cb1-c5bfcd5f7321">
        <updating/>
        <source>createDummy(_bol :CM_BOLIn; _minusDays : Integer; _minusHours :Integer; _id :Integer; _desc : String) updating;
// ---------------------------------------------------------------------------
// Created:	27 September 2008 By Graeme Black cnwgb1
// Purpose:	
// ---------------------------------------------------------------------------
vars
	aTime : Time;
	aDate : Date;
begin
	self.myBOL := _bol;
	self.stopID := _id;
	self.stopDescription := _desc;
	aTime.setTime(22-_minusHours, 30, 0, 0 );
	aDate.setDate( 27-_minusDays, 9, 2008 );
	self.dateTime.setTime( aTime );
	self.dateTime.setDate( aDate );
	self.type := 2345; 
	self.userId := "EDIUSER";
	self.manual := false;
epilog
end;
</source>
        <Parameter name="_bol" type="CM_BOLIn"/>
        <Parameter name="_minusDays" type="Integer"/>
        <Parameter name="_minusHours" type="Integer"/>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_desc" type="String"/>
    </JadeMethod>
