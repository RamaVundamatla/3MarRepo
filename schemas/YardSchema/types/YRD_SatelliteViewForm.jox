    <JadeMethod name="tblYAM_dblClick" id="f2187c6d-ed22-4c74-ae69-141d8c89aefc">
        <controlMethod name="CM_YAMTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblYAM_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/07/2023	navkc1	Bug 59420: MTN - Satellite View Column Sort

*/

vars
	entDef		: EntTableDef;
	realTable	: CM_YAMTable;
	
	priorityCol : Integer;
begin
	
	realTable := table.CM_YAMTable;
	
	if realTable.row &gt; realTable.fixedRows then
		return;
	endif;
	
	// Get the "Priority" column
	entDef := realTable.myEntTableDef;
	priorityCol:= realTable.getColumnByRowName(ETRow_PriorityValue);
	
	// Only allow sorting for Name range &amp; Priority columns.
	// *Name range column is fixed at 2
	if realTable.column &lt;&gt; 2 and realTable.column &lt;&gt; priorityCol then
		return;
	endif;

	// Do sorting
	realTable.doYAMTableSort();
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblYAM_keyUp" id="087c9950-f9bc-4f5a-8b64-87f66ff8bf23">
