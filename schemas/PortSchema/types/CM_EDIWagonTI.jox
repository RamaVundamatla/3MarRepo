    <JadeMethod name="canUserSet" id="863b0f73-ce60-4232-a11b-6e3c88b475bd">
        <source>canUserSet(_propName: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 September 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
*/

vars

begin
	if _propName = CM_EDITrackedItem::id.name 
	or _propName = CM_EDITrackedItem::cargoTypeDescr.name then
//	or _propName = CM_EDIWagonTI::subTerminalCode.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="carrierCodeVerify" id="3d4c3d02-21ff-456b-9123-391a532e7a49">
        <updating/>
        <source>carrierCodeVerify(_terminal : CM_Terminal) : String updating, protected;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     

 Parameters:  None

 Returns:     Nothing

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 
 ---------------------------------------------------------------------------
*/

vars
	value: Integer;
	message: String;
begin
	value := VALID;
	
	if  carrierCode &lt;&gt; null and app.myRoot.allCarriers.getAtKey (carrierCode) = null then 
		message := app.getErrorString2 (CodeInvalid , 'Carrier',self.carrierCode);
		value := ERROR;
	endif;
	return value.String &amp; message;
end;
</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doUpdateWagonSeals" id="ece12384-aa0c-47d2-b6fe-1fb8ae14a19a">
        <source>doUpdateWagonSeals( _wagon : CM_Wagon input);
/*

Purpose:			

Parameters:			Multiple seals can be contained in the "wagonSeals"

					This method breaks out the individual values, and their types and applies the values.
					the format id &lt;one character delimiter&gt;&lt;Seal type&gt;=&lt;Seal value&gt;&lt;one character delimiter&gt;
					i.e. :OPER=123:
					
					So two in the same field would be:
					&lt;one character delimiter&gt;&lt;Seal type&gt;=&lt;Seal value&gt;&lt;one character delimiter&gt;&lt;Seal type&gt;=&lt;Seal value&gt;&lt;one character delimiter&gt;
					i.e. :OPER=123:VENT=456:
					
					If seal type is allowed mulitple values then i.e. in this case CUST seal  is multi value then
					:OPER=123:VENT=456:CUST=789:CUST=790:CUST=791:
					
Return Value:		

Date		Who		Reason
13 March 2015	cnwndl1	Initial creation	Par 35828
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	rawString : String;
	delimiter : Character;		// the user supplier delimiter that separates all of the seal type / value strings 
	
	sealDataStr : String;		// A single  &lt;type&gt;=&lt;value&gt; string
	sealDataArray : CnStringArray;	//the array of sealDataStr strings
	
	sealTypeStr : String;
	sealValueStr : String;
	sealType : CM_SealType;
	pos : Integer;
	
	sealTypeStrArray : StringArray;
	sealValueStrArray : HugeStringArray;  //1024 chars, thats a lot of seal data to type in correctly....
	index : Integer;
	workString : String;
	
	realWagonSeal : CM_WagonSeal;
	pxyWagonSeal : CM_WagonSeal;
	load : Boolean;
	now : TimeStamp;
	

begin

	if _wagon = null then
		return;
	endif;

	rawString := self.wagonSeals.trimBlanks;
	if rawString = null then
		return;
	endif;
	
	delimiter := rawString[1:1].Character;
	sealDataArray := rawString.cnGetTokens( delimiter );
	
	if sealDataArray = null or sealDataArray.isEmpty then
		return;
	endif;
	
	now := app.actualTimeServer;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	create sealTypeStrArray transient;
	create sealValueStrArray transient;
	
	// need to pre process so that we can combine up any multiple values for the same seal type.
	foreach sealDataStr in sealDataArray do
		if sealDataStr.trimBlanks = null then
			continue;
		endif;
		pos := sealDataStr.pos("=",1);
		if pos &lt; 2 then // can't be any type declared
			continue;
		endif;
		sealTypeStr := sealDataStr[1:pos-1]; // everything up to the "="
		if sealDataStr.length &gt; pos then
			//everything after the equals
			sealValueStr := sealDataStr[pos+1:end];
		else
			//there was no more
			sealValueStr := " ";
		endif;
		sealType := app.myRoot.allSealTypes.getAtKey( sealTypeStr );
		if sealType = null then
			//invalid seal type
			continue;
		endif;
		if not _wagon.allowsSealType( sealTypeStr) then
			// seal type not currently valid for this wagon
			continue;
		endif;
		
		index := sealTypeStrArray.indexOf(sealTypeStr);
		if index &gt; 0 then
			//adding another seal value for a multi value seal type
			workString := sealValueStrArray[index].trimBlanks;
			if workString &lt;&gt; null then
				sealValueStrArray[index] := workString &amp; "," &amp; sealValueStr;
			else
				sealValueStrArray[index] := sealValueStr;
			endif;
		else
			// a seal type we haven't seen before in this EDI value for this wagon
			sealTypeStrArray.add( sealTypeStr );
			sealValueStrArray.add( sealValueStr );
		endif;
		
	endforeach;
	
	//should now have a matched set of seal types, and values.
	
	if not sealTypeStrArray.isEmpty then
		index := 0;
		foreach sealTypeStr in sealTypeStrArray do
			index := index + 1;
			sealValueStr := sealValueStrArray[index].trimBlanks;
			
			realWagonSeal := _wagon.allWagonSeals.getAtKey( sealTypeStr );
			if realWagonSeal &lt;&gt; null then
				app.cmsBeginLoad(load);
				pxyWagonSeal := realWagonSeal.pxyCreateUpdateProxy();
				app.cmsEndLoad(load);
			else
				if sealValueStr = null then
					//huh trying to create a new one with a null value.
					continue;
				endif;
				create pxyWagonSeal transient;
				pxyWagonSeal.setSealType(sealTypeStr);
			endif;
			
			pxyWagonSeal.setSealValue(sealType,sealValueStr);
			pxyWagonSeal.setSealedDT(now);
			
			pxyWagonSeal.setMyWagonVisit( _wagon );
			
			app.myUtilityUA.utlUpdateWagonSeal( null, pxyWagonSeal, realWagonSeal, app.myPassport );
		
			if not app.myPassport.noErrors then
				return;
			endif;
		
			delete pxyWagonSeal;
			
		endforeach;
	endif;

epilog

	delete sealTypeStrArray;
	delete sealValueStrArray;
	delete sealDataArray;
	delete pxyWagonSeal;
	app.cmsEndLoad(load);

end;</source>
        <Parameter name="_wagon" type="CM_Wagon" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="0757f5d0-5f32-41c3-bc22-541010640800">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

begin

	if _attrName = ETRow_WagonSeals then
		return self.wagonSeals;
	
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
