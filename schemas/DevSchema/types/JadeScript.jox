    <JadeMethod name="sdlFindCashCrdDtlsApplied" id="ade4dda1-0cbb-4a25-b273-cff2915a851e">
        <source>sdlFindCashCrdDtlsApplied();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2019	jlgsl4	Initial creation

*/

vars
	creditDetail : CM_CashCreditDetail;
begin
	app.initialize;
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	foreach creditDetail in CM_CashCreditDetail.instances where  creditDetail.myDerivedFromCashCredit.myDebtorTerminal &lt;&gt; null and creditDetail.myDerivedFromCashCredit.myDerivedFromCashReceipt &lt;&gt; null do
		write "Its date is " &amp; creditDetail.getDateTimeLocalTZ().asStringJMT() &amp; ", its terminal is " &amp; creditDetail.myDerivedFromCashCredit.myDebtorTerminal.myTerminal.code &amp; ", it's bank is " &amp;
			creditDetail.myDerivedFromCashCredit.myBank.code &amp; ", its debtor is " &amp; creditDetail.myDerivedFromCashCredit.myDebtorTerminal.myDebtor.name;
	endforeach;
epilog

end;</source>
