<Class name="CM_CamUserDefJRWDesc" id="02da6586-c075-441f-a791-c6a9e5995d9a">
    <superclass name="CM_CamProtocolDesc"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <JadeMethod name="buildJRWFile" id="51895d4e-4006-4fe1-a727-f00c5b5a01cc">
        <updating/>
        <source>buildJRWFile(	_camProtocol 		: CM_CamProtocol input;
				_camAgent : CM_CamControllerAgent input;
				_unhSeqNumber 		: Integer io;
				_seqNumber 			: Integer; 
				_terminal 			: CM_Terminal;
				_folderName 		: String;
				_jrwTransient   	: CM_JRWCamTransaction
				) : Boolean  updating, protected;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     Create a CAM File, and run the JRW report for the protocol.
			  The transactions associated with the _jrwTransient will be included on the report
			  
			  Added at superclass in case other descs in future decide to use JRW's

 Parameters:  _camProtocol    	-  Cam Protocol
              _camTask			-  Transient Cam Task
			  _jrwTransient 	- the transient that is created by the Query. Has a collection on trans to be extracted in file by report

 Returns:     False if fails, true if okay
              Will have created a file on disk using the filename

Changed On	Changed By  Reason
----------	----------  --------------------------------------------------
14/12/09	P Bremmers  MES 1008 - Allow for Event Transactions
26/02/2010	cnwrl1		PAR 22387 - allow for "Single Transaction Per File"
11/05/2010	cnwcs5		par 23967 - record number of transactions in the file (also remove condition
									that causes processTransaction to only be called for email enabled
									protocols)
18 Jul 2012	cnwrs1		CCMS 1269 CAMS remove CM_CamTask
30 Jul 2012	cnwrs1		CCMS 1269 CAMS remove CM_CamTask
25 Jun 2013	cnwrs1		Par 31047 - add Enviroment Terminal and Protocol to Cams Alerts
06 Jul 2016	cnwrs1		Par 38021 - Review Cam logging
09 Jan 2020	jlgdap1		TFS 48016 SNO Deletio CODECO - change of signature for app.myTrxUA.trxSetupCamTaskHistory
11 July 20025 navsaa30 MTN-34576 POL - CAMS Protocol - SFTP Single Transaction per File
---------------------------------------------------------------------------
*/
vars
	camFile 		: CM_CamFile;	// cant make this CM_CamFileJRW cause get syntax error on processTransaction
	transaction 	: CM_TITransaction;
	camTaskHistory 	: CM_CamTaskHistory;
	allTrans		: CM_MemberKeyDictionary;
	fileName		: String;
	pos 			: Integer;
begin
	create camFile as CM_CamFileJRW transient;
	
	camFile.CM_CamFileJRW.setJRWCamTransaction(_jrwTransient);	// link file to the transient
	fileName := _camProtocol.constructFileName(_camAgent, _seqNumber);						//navsaa30 #34576 
	if _camProtocol.isSingleTransPerFile and _camProtocol.camGroup.useDailyFileName then
		pos := fileName.reversePos(".");
		if pos &gt; 0 then
			fileName := fileName[1:pos-1] &amp; '_' &amp; _seqNumber.String &amp; fileName[pos:end];
		else
			fileName := fileName &amp; '_' &amp; _seqNumber.String;
		endif;
	endif;
	camFile.CM_CamFileJRW.setJRWFilename(_folderName &amp; "\" &amp; fileName);
	
	foreach transaction in _jrwTransient.allTransactions do					// Note - will be empty if doing Event transactions
		self.processTransaction(transaction, _camProtocol, _camAgent, camFile);	// This may or may not do anything. Left here in case both using old syle email and report csv, this method may create cam messages
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' tr='&amp;transaction.String&amp;' ti='&amp;transaction.myTrackedItem.String&amp;' '&amp;transaction.myTrackedItem.id, LogDEBUG);
	endforeach;																// in future if non-user-defined reports also build reports.
	
	if self.buildJRWReport(_camProtocol, camFile.CM_CamFileJRW) then 	// this will create a report with the 'internal' cams file name.
		if camFile.CM_CamFileJRW.updateFileContentFromFile() then 	// this will read file created and store content on camFile so we can store on history; copy outputfile and send email.
																	// we don't do any of this unless all of the steps have worked
			if _jrwTransient.allTransactions.size() &gt; 0 then
				allTrans := _jrwTransient.allTransactions;
			else
				allTrans := _jrwTransient.allEventTransactions;
			endif;
			
			camFile.CM_CamFileJRW.setMessageCount(allTrans.size);	// par 23967 - start
			
			// this will call outfile to copy the file to the user directory
			//app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, _seqNumber, _terminal, allTrans, null); 		// TFS 48016
			app.myTrxUA.trxSetupCamTaskHistory(_camProtocol, _camAgent, camFile, _camAgent.runDateTime, camTaskHistory, _unhSeqNumber, _seqNumber, _terminal, allTrans, null, null); 	// TFS 48016
			if (not app.myPassport.trxCompletedOK) then
				_camAgent.writeCrashLogAlertAndEmail(app.myPassport);
				return false;
			endif;
			return true;																																	 // send the email etc
		endif;
	endif;
	
	return false;
epilog
	delete camFile;
end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_folderName" type="String"/>
        <Parameter name="_jrwTransient" type="CM_JRWCamTransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="buildJRWReport" id="af56869f-87af-49c5-b22c-7bdab335d06a">
        <source>buildJRWReport(_protocol: CM_CamProtocol; _camFile: CM_CamFileJRW io) : Boolean protected;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich   Aug 2009            

 Purpose:     MES1011 Create and run a JRW report . Have added at the superclass in case other descs change to use CSV files instead of emails

 Parameters:  Protocol 
              Cam File transient that has a reference to a _camFile.myJRWCamTransaction. This must  be the same transient that is on 
			  app.myQAFilter.allJRWTransients must be populated with the objects that are included in the reprot

 Returns:     A file will be created in the 'internal' cam protocol directoy. A later process (outputFile) will put it into the directory where the 
			  external system will pick it up from.

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
16 Mar 2010	consw1      PAR #22886 - Leaking report transients
21 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
13 Dec 2017	jlgkpd1	TFS #8294 - Initiate compact of transient file after running a report

*/

vars
	jrwManager			: JadeReportWriterManager;
	jrwReport			: JadeReportWriterReport;
	jadeReport			: JadeReport;
	outputDest 			: Integer;
	paramNameArray, 
	paramTypeArray 		: StringArray;
	isFileError 		: Boolean;
	errorInfo 			: String;
begin
	jrwManager := app.createReportWriterManager();
	
	create jadeReport transient;

	jrwReport := jrwManager.getReport(_protocol.jrwReportName);
	if jrwReport = null then	// Report Design NOT found
		app.writeLog(method.name &amp; " " &amp; _protocol.description &amp; "Invalid JRW Report name", LogINFO);
		app.raiseCMException1(Report_design_found,  _protocol.description &amp; " / " &amp; _protocol.jrwReportName, 'jrwReportName', null);	
		return false;
	endif;
	
	outputDest := _protocol.getJRWOutputDestination;
	jrwReport.setOutputDestination(outputDest);	// this sets CSV or XML
	jrwReport.setOutputFileTitle(_camFile.jrwFilename);	// this sets CSV or XML
	app.writeLog(class.name &amp; "::" &amp; method.name &amp; " _camFile.jrwFilename=" &amp; _camFile.jrwFilename, LogDEBUG);
	
	if _protocol.operatorXlationCode &lt;&gt; null then	// If the JRW has have a parameter of the correct name (hard coded) then we will set it
	
		jrwReport.getParameters(paramNameArray, paramTypeArray);	// the report has the parameter for translations then we will pass it. If not, don't try and pass
		if  paramNameArray.includes(OperatorXlation) then
			jrwReport.setParameter(OperatorXlation , _protocol.operatorXlationCode);
		endif;
	endif;
	
	if  outputDest = JadeReportWriterReport.XML then
		jrwReport.setXmlOptions(_protocol.getProtocolSubDirectoryName, // this is protocl names with invalid chs stripped and blanks
			'Transaction');
			//					  );	// ########## think about this, is used for detail tag on each transaction 
	endif;
	
	jadeReport.description := jrwReport.name;
	on FileException do self.xHandlerFile(exception, isFileError, errorInfo);
	isFileError	:=	false;
	jrwReport.run();
	process.initiateTransientCompact();		// TFS #8294
	if isFileError then
		app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
		app.writeLog(app.getErrorString2(ERR_CAMS_MAKEDIR, jrwReport.name, _protocol.code), LogINFO);
		return false;
	else
		on FileException do null;
	endif;
	app.writeLog(class.name &amp; "::" &amp; method.name &amp; " Report Run", LogDEBUG);
	return true;
epilog
	delete jrwReport;
	delete jrwManager;
	delete jadeReport;
end;
</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camFile" type="CM_CamFileJRW" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesMatchSelector" id="f211066c-f32d-476b-8186-dbca78ed6aa0">
        <source>doesMatchSelector(_camProtocol : CM_CamProtocol; _trans : CM_Object) : Boolean;
/*

Date		Who		Reason
18 December 2014	cnwer1	Initial creation PAR

*/

vars

	userQuery : CM_MenuUserQuery;
	criteriaHolder : CM_QueryCriteriaLineHolder;

begin

	if _camProtocol.mySelector = null then
		return true;
	endif;
	
	userQuery:=_camProtocol.mySelector;
	foreach criteriaHolder in userQuery.allCriteriaLineHolders do
		if not _trans.qrySelector(criteriaHolder)then
			return false;
		endif;
	endforeach;	
	
	return true;
epilog

end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_trans" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
