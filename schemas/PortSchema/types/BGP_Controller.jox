    <JadeMethod name="sysNotification" id="1d2670c1-843e-4ea8-8ed8-b9615bd820db">
        <updating/>
        <source>sysNotification(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;
//
// CCMS1150 cnwrs1 04 July 2011
//
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	request : BGP_Request;
	invalidProcess : Boolean;
	str : String;
	msg : String;
begin
	if _theObject &lt;&gt; null then
		if _theObject.isKindOf(BGP_Request) then
			request := _theObject.BGP_Request;
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' BGP_ActionRequest '&amp;_theObject.String, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			on Exception do app.handleDeletedObject(exception, _theObject, invalidProcess);			// 07/03/2011 cnwmh5 #27142
			str := _theObject.BGP_Request.processingStartTime.String;	// to test the handle deleted object
			if not invalidProcess then
				request := _theObject.BGP_Request;
			endif;
			if app.isSDSSecondaryDB() then
				if self.processRequest(request) and 
				   app.isDoWindowEventInterrupted then
					msg := 'Doing windows instance processing';
					app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
					self.doInstanceProcessing(false);
				endif;
			endif;
		elseif _theObject.isKindOf(BGP_GenericController) then
			if app.isSDSSecondaryDB and _theObject = self then
				if self.terminateSDSProcess then // CCMS1150 cnwrs1 04 July 2011
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Terminate Processing ', LogINFO);	//25 Nov 2019	NDL	TFS 47053
					self.sdsCauseEvent(BGP_Object.BGP_SDSSecondaryProcess, true, null);	// 11 July 2011	cmwrs1		CCMS1150 - backup sds notification
					self.terminateProcessing(app.myPassport.userCode);
				endif;
				if self.mySDSSecondaryProcess &lt;&gt; null then
					on Exception do app.handleDeletedObject(exception, self.mySDSSecondaryProcess, invalidProcess);			// 07/03/2011 cnwmh5 #27142
					str := self.mySDSSecondaryProcess.signOnTime.String;	// to test the handle deleted object
					if invalidProcess then
						app.writeLog(class.name&amp;'::'&amp;method.name&amp;' set BGP_SDSSecondaryProcess to null ', LogINFO);	//25 Nov 2019	NDL	TFS 47053
						self.sdsCauseEvent(BGP_Object.BGP_SDSSecondaryProcess, true, null);	// 11 July 2011	cmwrs1		CCMS1150 - backup sds notification
					endif;
				endif;
			endif;
		endif;
	endif;
end;

</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="terminateProcessing" id="af5c44fe-ab14-4b4d-8620-ed7e86c6cde9">
        <updating/>
        <source>terminateProcessing(_userCode : String) updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19 Oct 2012	cnwrs1	Par 28593
// 27 Sep 2018	jlgmd1	TFS 41133 Fix typo preventing correct username logging when terminating
// ---------------------------------------------------------------------------
vars

	description	: String;
	
begin
	app.writeLog(class.name&amp;'::'&amp;method.name, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	on Exception do self.timerExceptionHandler(exception);

	description := app.getErrorString2(Stopping_BGPProcess, self.displayString[1:20] &amp; '... ', _userCode);
	app.createActivityHistory(ActivityHistoryGeneral, null, self, description, false, false);
	
	inheritMethod(_userCode);
	
	self.beginTimer(BGP_Object.BGP_TerminateBuffer, Timer_OneShot, KillProcessing_Event_Tag);
	
	app.createActivityHistory(ActivityHistoryGeneral, null, self, _userCode&amp;" has stopped the BGP "&amp;self.name&amp;' Controller.' , false, false);
	app.writeLog(_userCode&amp;" has stopped the BGP "&amp;self.name&amp;' Controller.', LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	if not app.isSDSSecondaryDB then
		app.myTrxUA.trxUpdateBGPControllerSDSTerm(self, true);
	else
		self.sdsCauseEvent(BGP_Object.BGP_SDSSecondaryProcess, true, null);	// 19 Oct 2012	cmwrs1		SDS Backup now terminated
	endif;
	
	self.causeEvent(BGP_Object.BGP_DisplayUpdate, false, null);
end;</source>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="ef095be4-2a90-4edd-ad58-606edc1832ce">
        <updating/>
        <source>timerEvent(_eventTag: Integer) updating;
// -------------------------------------------
// Created 11 November 2003 by cnwdvb1
// -------------------------------------------
//26 June 2012	cnwrs1	Par 29858 - BGP Request not being deleted after an exception
//06 Nov 2012	cnwrs1		Par 28355 - Hand Shake with SDS
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
//03 Jun 2014	cnwrs1	Par xxxx exception if process already gone
vars
	request : BGP_Request;
	lastSDSUpdate : TimeStampInterval;
	edition	: Integer;
	gotException : Boolean;
begin
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' _eventTag='&amp;_eventTag.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053

	if _eventTag = KillProcessing_Event_Tag then
		if self.isRunning() then
			self.endTimer(KillProcessing_Event_Tag);
			// cnwjre1 25/07/2014 from testing, more explicit invalid object protection
			on Exception do self.serverMethodAbortedHandler(exception);
			if app.isSDSSecondaryDB then	// CCMS1150 cnwrs1 16 June 2011
				on Exception do app.handleDeletedObject(exception, self.mySDSSecondaryProcess, gotException);
				edition := self.mySDSSecondaryProcess.edition;		// cnwjre1 25/07/2014 from testing, more explicit invalid object protection
				if not gotException then
					system.forceOffUser(self.mySDSSecondaryProcess.node, self.mySDSSecondaryProcess);
				endif;
			else
				on Exception do app.handleDeletedObject(exception, self.myProcess, gotException);
				edition := self.myProcess.edition;		// cnwjre1 25/07/2014 from testing, more explicit invalid object protection
				if not gotException then
					system.forceOffUser(self.myProcess.node, self.myProcess);
				endif;
			endif;
			self.causeEvent(BGP_Object.BGP_DisplayUpdate, false, null);	//26 June 2012	cnwrs1 par 29858
		endif;
		
	elseif _eventTag = BGP_Object.TimerCheck_Event_Tag then	
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' _eventTag=TimerCheck_Event_Tag '&amp;_eventTag.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		if app.isSDSSecondaryDB then
			self.sdsCauseEvent(BGP_Object.BGP_SDSSecondaryProcess, true, process);	// 11 July 2011	cmwrs1		CCMS1150 - backup sds notification
			self.beginTimer(BGP_TerminateBuffer, Timer_OneShot, BGP_Object.TimerCheck_Event_Tag);
		else	//06 Nov 2012	cnwrs1		Par 28355 - 
			if app.myRoot.myBackup &lt;&gt; null then
				if app.myRoot.myBackup.sdsSecondaryBackup then
					lastSDSUpdate := app.actualTimeServer() - self.dateTimeLastSDSUpdate;
					if lastSDSUpdate.getMilliseconds() &gt;  (BGP_Object.BGP_HandShakeInterval*4) then
						app.writeLog(class.name&amp;'::'&amp;method.name&amp;' set SDS Secondary process oid  to null', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
						if self.mySDSSecondaryProcess &lt;&gt; null then
							self.causeEvent(BGP_Object.BGP_SDSSecondaryProcess, true, null);
						endif;
					endif;
					if app.myRoot.myBackup.status &lt;&gt; BackupStatus_Idle then 	//lost contact with secondary backup is dead
					endif;
				else
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' last heard from SDS Secondary '&amp;lastSDSUpdate.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
				endif;
				self.beginTimer(BGP_HandShakeInterval, Timer_OneShot, BGP_Object.TimerCheck_Event_Tag);
			endif;
		endif;
		
	elseif _eventTag = BGP_Object.DeleteBGPRequest_Event_Tag then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' isRunning='&amp;self.isRunning.String&amp;' myCurrentRequest='&amp;self.myCurrentRequest.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		if self.isRunning and 
		   self.myCurrentRequest &lt;&gt; null then
			request := self.myCurrentRequest;
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' will delete='&amp;request.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			app.myTrxUA.trxUpdateBGPControllerSDSTerm(self, false);
			app.myTrxDA.trxDeleteBGPRequest(null, request, true, app.myPassport);
		endif;
	endif;
end;</source>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerExceptionHandler" id="f81d398a-8498-4114-a68d-2898c53eb1e2">
        <source>timerExceptionHandler(_exc : Exception) : Integer;
//
//18 Ocr 2012	cnwrs1	JMT Backup testing Par 28953
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
//
constants
	TimerAlreadyRegistered = 1400;
	NofityicationNotSet = 1066;
vars
	exceptionType : Integer;
	returnVal : Integer;
begin
	returnVal := Ex_Pass_Back;
	exceptionType := _exc.errorCode;
	if exceptionType = TimerAlreadyRegistered or
	   exceptionType = NofityicationNotSet then
		if _exc.resumable then
			app.writeLog(exceptionType.String&amp;' exception has been ignored.', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			returnVal := Ex_Resume_Next;
		endif;
	endif;
epilog
	return returnVal;
end;
</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="1d649494-07d3-4ce8-84f6-4008320011c7">
        <updating/>
        <source>userNotification(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating;
//
//18 Apr 2012	cnwrs1	Par 29441 - shifted check for deleted object exception as the request is not locked till later and could go invalid between now and the tryLock
//18 Ocr 2012	cnwrs1	Par28593 
//06 Nov 2012	cnwrs1		Par 28355 - Fixup exceptions
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
// 03 Oct 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
//27 Sep 2018	jlgmd1	TFS 41133 Fix typo preventing correct username logging when terminating
//
vars
	request		: BGP_Request;
	userStr		: String;
	description	: String;
	controller	: BGP_Controller;
	errCode			: Integer;
	errTxt			: String;
//	isInvalid : Boolean;
//	str : String;
	msg : String;
	userCode : String;
begin
	on Exception do self.timerExceptionHandler(exception);
	on Exception do app.alertExceptionHandler(exception, null, method.name, errCode, errTxt, true, false);
	on LockException do app.alertLockExceptionHandler(exception);
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' parameters='&amp;_eventType.String&amp;' '&amp;_theObject.String&amp;' '&amp;_eventTag.String&amp;' '&amp;_userInfo.String, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	if _eventType = BGP_Object.BGP_ActionRequest then
		if _theObject &lt;&gt; null then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' BGP_ActionRequest', LogINFO);	//25 Nov 2019	NDL	TFS 47053
//			on Exception do app.handleDeletedObject(exception, _theObject, isInvalid);			// 07/03/2011 cnwmh5 #27142
//			str := _theObject.BGP_Request.processingStartTime.String;	// to test the handle deleted object
//			if not isInvalid then
			request := _theObject.BGP_Request;
//			endif;
			if request.isKindOf(BGP_CamsRequest) and
			   self.BGP_GenericController.myTerminal &lt;&gt; null then
				if _userInfo.String &lt;&gt; self.BGP_GenericController.myTerminal.code then
					app.writeLog(class.name&amp;'::'&amp;method.name&amp;' wrong terminal dont process '&amp;' _userInfo='&amp;_userInfo.String&amp;' cont='&amp;self.BGP_GenericController.myTerminal.code, LogINFO);	//25 Nov 2019	NDL	TFS 47053
					return;
				endif;
			endif;
			if self.processRequest(request) and 
			   app.isDoWindowEventInterrupted then
				msg := 'Doing windows instance processing';
				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				self.doInstanceProcessing(false);
			endif;
		endif;
	elseif _eventType = BGP_Object.BGP_TerminateAppRequest then
		// TFS 41133 jlgmd1 Make it easier to see who terminated the BGP by sending the usercode through with the notification
		if _userInfo &lt;&gt; null then
			userCode := _userInfo.String;
		else
			userCode := self.getUserCode;
		endif;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' BGP_TerminateAppRequest ', LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		msg := userCode&amp;" has stopped the BGP "&amp;self.name&amp;'.';
		app.createActivityHistory(ActivityHistoryGeneral, null, self, msg, false, false);
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053

		if app.isSDSSecondaryDB then
			self.causeEvent(BGP_Object.BGP_DisplayUpdate, false, null);
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' BGP_Object.BGP_DisplayUpdate', LogFATAL);	//25 Nov 2019	NDL	TFS 47053
			terminate;
		else
			self.terminateProcessing(userCode);
		endif;

	elseif _eventType = BGP_Object.BGP_Initilize then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' BGP_Initilize ', LogINFO);	//25 Nov 2019	NDL	TFS 47053
		self.doInstanceProcessing(true);
	elseif _eventType = BGP_Object.BGP_DebugLevelChangeEvent then
		app.changeLogLevel(_userInfo.Integer);
	elseif _eventType = BGP_Object.BGP_OutputInfo then
		self.doShowLogName(_userInfo.Process);
	elseif _eventType = BGP_Object.BGP_ApplicationStartRequest then
		controller := _userInfo.BGP_Controller;		
		if controller &lt;&gt; null then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' BGP_ApplicationStartRequest '&amp;controller.schemaName&amp;' '&amp;controller.appName, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			app.startApplicationWithParameter(controller.schemaName, controller.appName, controller);
			if app.myPassport &lt;&gt; null and 
			   app.myPassport.myUser &lt;&gt; null then //cnwrs1 17712 Aug 2008
				msg := self.getUserCode&amp;" has started the BGP "&amp;self.name&amp;' Controller.';
				app.createActivityHistory(ActivityHistoryGeneral, null, self, msg, false, false);
				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
			endif;
		endif;
	elseif _eventType = BGP_Object.BGP_SDSSecondaryProcess then	// 11 July 2011	cmwrs1		CCMS1150 - backup sds notification
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' BGP_SDSSecondaryProcess ', LogINFO);	//25 Nov 2019	NDL	TFS 47053
		if self.myProcess &lt;&gt; null and
		   self.mySDSSecondaryProcess &lt;&gt; null and
		   _userInfo.Process &lt;&gt; null and	// 06 Nov 2012	cnwrs1	Par28355 - 
		   self.mySDSSecondaryProcess &lt;&gt; _userInfo.Process then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' the secondary is running a new process so must be restarting. mySDSSecondaryProcess='&amp;self.mySDSSecondaryProcess.String&amp;' _userInfo='&amp;_userInfo.String, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			if self.isDBBackup and	// we are a backup controller
				// see if a backup was running
			   (app.myRoot.myBackup.status &lt;&gt; BackupStatus_Idle or	
				self.myCurrentRequest &lt;&gt; null) then
				system.causeEvent(NotifyBackupRestarted, true, null);
			endif;
		endif;
		app.myTrxUA.trxUpdateBGPControllerSDSProcs(self, _userInfo.Process);
		self.causeEvent(BGP_Object.BGP_DisplayUpdate, false, null);
	elseif _eventType = BGP_Object.BGP_DeleteBGPBackupDB then
		request := _userInfo.BGP_Request;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' delete BGP_BackupDB '&amp;_userInfo.String, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		app.myTrxDA.trxDeleteBGPRequest(null, request, true, app.myPassport);
		if app.myRoot.myBackup.status &lt;&gt; BackupStatus_Idle then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' backup status has not been reset.', LogINFO);	//25 Nov 2019	NDL	TFS 47053
			app.myTrxUA.trxUpdateBGPBackupStatus(app.myRoot.myBackup, BackupStatus_Idle);
		endif;
	endif;
	
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPControllerPost(self, app.myPassport);
	endif;
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="8d5c3245-d1f9-42bd-b419-53728809ac3e">
        <source>validateForUpdate();

// cnwdvb1 29 April 2003 
// cnwdb2	PAR 35364

vars

begin
	
	if self.isRunning() then
		app.raiseCMException1(BGPAppIsRunning, self.name, null, null);
	endif;
	
	if self.myUser = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Default User', null, null);
		app.raiseCMException(Input_required_field_DefltFld, null, null);
		

	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="xHandlerDisplay" id="4f60ac6c-b920-421d-91b0-b7a9ea39fb22">
        <source>xHandlerDisplay(exObj : Exception) : Integer;

// cnwdvb1 11 June 2003 

vars

begin

	if exObj.errorCode = 4 then
		if exObj.resumable then
			return  Ex_Resume_Next;
		endif;
	endif;
	return Ex_Pass_Back;

end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
