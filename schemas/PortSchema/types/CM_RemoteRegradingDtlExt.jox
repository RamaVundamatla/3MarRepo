    <JadeMethod name="doRegrading" id="bf9d839c-ebdb-4618-babc-f92f54aa035a">
        <source>doRegrading(_errorSet : CM_ErrorSet input);

// cnwdvb1 31 March 2003 

vars

	remoteDtl : CM_RemoteDataDtl;

begin

	app.myTrxUA.trxRegradeLogRemote(self, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		_errorSet.copyErrors(app.myPassport.allErrorWarnings);
	else
		_errorSet.copyErrors(app.myPassport.allWarnings);
		remoteDtl := self;
		app.myTrxUA.trxUpdateRemoteDataIsProcessed(remoteDtl,true, app.myPassport);
	endif;

end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="c4083edd-a162-4996-b10f-8ac50a5b4c77">
        <source>getDescription(): String;

// cnwdvb1 31 March 2003 

vars

begin
	return 'Regrading detail';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="productCode" id="e4a379c6-8437-4232-865f-8b06967274c3">
        <methodInvocation>mapping</methodInvocation>
        <source>productCode(set: Boolean; _value: String io) mapping;

// cnwdvb1 28 March 2003 

vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := app.buildLogProductCode(self.species, self.grade,
									  self.type, self.treatment, self.length);

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="saveFromTable" id="79726fe9-2783-4f54-a941-12ac6549c6ec">
        <updating/>
        <source>saveFromTable(_table: Table input; _entryTableColumns: Integer) updating;

// cnwdvb1 31 March 2003 

vars

begin

	self.area		:= _table.accessCell(2,_entryTableColumns).text.trimBlanks;
	self.location	:= _table.accessCell(3,_entryTableColumns).text.trimBlanks;
	self.supplier	:= _table.accessCell(4,_entryTableColumns).text.trimBlanks;
	self.species	:= _table.accessCell(5,_entryTableColumns).text.trimBlanks;
	self.grade		:= _table.accessCell(6,_entryTableColumns).text.trimBlanks;
	self.type		:= _table.accessCell(7,_entryTableColumns).text.trimBlanks;
	self.treatment	:= _table.accessCell(8,_entryTableColumns).text.trimBlanks;
	self.length		:= _table.accessCell(9,_entryTableColumns).text.trimBlanks;

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_entryTableColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="cb9c577c-c737-41b4-b613-213a742b0056">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteRegradingDtlExt; _realRemoteHdr: CM_RemoteDataHdr) updating;

// cnwdvb1 28 March 2003 

vars

	pxyRemoteDataExtra,
	realRemoteRejectExtra : CM_RemoteDataExtra;

begin
	inheritMethod(_proxy, _realRemoteHdr);
	self.area			:= _proxy.area;
	self.location		:= _proxy.location;
	self.supplier		:= _proxy.supplier;
	self.species		:= _proxy.species;
	self.grade			:= _proxy.grade;
	self.length			:= _proxy.length;
	self.type			:= _proxy.type;
	self.treatment		:= _proxy.treatment;
	self.tagClass		:= _proxy.tagClass;
	self.tagType		:= _proxy.tagType;
	
	foreach pxyRemoteDataExtra in _proxy.allRemoteDataExtra do
		create realRemoteRejectExtra as CM_RemoteRegradingExtra persistent;
		realRemoteRejectExtra.setForCreate(pxyRemoteDataExtra.CM_RemoteRegradingExtra, self);
	endforeach;

end;</source>
        <Parameter name="_proxy" type="CM_RemoteRegradingDtlExt"/>
        <Parameter name="_realRemoteHdr" type="CM_RemoteDataHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxyForRegradingExt" id="4bd84420-4f9c-44dc-8598-ce222844a0e9">
        <updating/>
        <source>setProxyForRegradingExt(_remoteHdr : CM_RemoteDataHdr; _tClass, _tType, _area, _location, _supplier, _species, _grade, _type, _treatment, _length : String) updating;

// cnwdvb1 27 March 2003 

vars

	tClass, tType : String;

begin
	
	self.area			:= _area;
	self.location		:= _location;
	self.supplier		:= _supplier;
	self.species		:= _species;
	self.grade			:= _grade;
	self.length			:= _length;
	self.type			:= _type;
	self.treatment		:= _treatment;
	self.tagClass		:= _tClass;
	self.tagType		:= _tType;
	
	self.setProxy(_remoteHdr);
end;</source>
        <Parameter name="_remoteHdr" type="CM_RemoteDataHdr"/>
        <Parameter name="_tClass" type="String"/>
        <Parameter name="_tType" type="String"/>
        <Parameter name="_area" type="String"/>
        <Parameter name="_location" type="String"/>
        <Parameter name="_supplier" type="String"/>
        <Parameter name="_species" type="String"/>
        <Parameter name="_grade" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_treatment" type="String"/>
        <Parameter name="_length" type="String"/>
    </JadeMethod>
</Class>
