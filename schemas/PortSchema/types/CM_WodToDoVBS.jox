    <JadeMethod name="updateStatusWoWLE" id="eb848a3e-58ea-4112-916d-a51f661282c9">
        <source>updateStatusWoWLE(_status : Integer;
				  _vbSlot     : CM_VehicleBookingTimeSlot);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/11/2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars
	woJob	:	CM_Job;
	wle		:	CM_WorkListEntry;
begin
	foreach woJob in self.allJobs do
		if woJob &lt;&gt; null then
			foreach wle in woJob.workListEntries do
					if wle.CM_WOVBSToDoSlotWLE.myVBSlot &lt;&gt; _vbSlot then
						continue;
					endif;
					if wle.status = JOB_COMPLETE then
						continue;
					endif;
					wle.setStatus(_status);
				endforeach;
			endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_vbSlot" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="validate" id="7fbd03fe-866b-478b-946a-f72c3da1bf1c">
        <source>validate()protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
04 October 2022	navcs2  ChangeRequest 54344: EUP - VAS Work Orders - Jobs
28 Dec 2022		navhl20	Task 56057(54344): WodToDoDetail validation
*/

vars

begin
	//Start 28.12.2022 navhl20 TFS 56057(54344)
	inheritMethod();
	if self.allVBSSlots.isEmpty() then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Vehicle_bookings), null, null); 
	endif;
	//End 28.12.2022 navhl20 TFS 56057(54344)
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
