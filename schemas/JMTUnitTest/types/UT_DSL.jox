    <JadeMethod name="addStop" id="5f567ea1-fa22-469f-9a2f-a6b4b3bd8808">
        <source>addStop(_ti: CM_TrackedItem; _stopTable: CM_StopsTable);
//17 November 2008	cnwdw1	
// Add a stop to a tracked item
vars
	tiSet: CM_TISet;
	stopArr: IntegerArray;
begin
	create tiSet transient;
	tiSet.add(_ti);
	create stopArr transient;
	stopArr.add(_stopTable.id);
	app.myTrxCA.trxCreateStopsForTIs(tiSet, stopArr, app.myPassport);
	checkTrxResult();
epilog
	delete tiSet;
	delete stopArr;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="addStopById" id="984c6658-7581-4e40-a7af-2d7e98d1bcc9">
        <source>addStopById(_tiObj:CM_TrackedItem; _stopId:Integer);
// --------------------------------------------------------------------------------
// Created:		20 April 2010 by cnwdad1
//
// Purpose:		Adds the specified Stop to the reference Tracked Item.
//
// Parameters:	_tiObj - A reference to the Tracked Item object.
//				_stopId - The Stop number.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allTIs		: CM_TISet;
	stopArray	: IntegerArray;
	
begin
	create allTIs transient;
	allTIs.add(_tiObj);
	create stopArray transient;
	stopArray.add(_stopId);
	app.myTrxCA.trxCreateStopsForTIs(allTIs, stopArray, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete allTIs;
	delete stopArray;
end;</source>
        <Parameter name="_tiObj" type="CM_TrackedItem"/>
        <Parameter name="_stopId" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addStopsFromCollection" id="3403a126-e8ff-4451-bcd0-02d448a795c5">
        <source>addStopsFromCollection(
	_realTI		: CM_TrackedItem input;
	_stops		: CM_StopsByIdDict;
	_passport	: CM_Passport input );

/*
Purpose:	This method will manipulate the appropriate stops on the real TrackedItem.
			Even though the method is called "addStopsFromCollection" the actual stops will be created, updated or
			deleted depending on the differences between the real TrackedItem and the collection of stops supplied.

Date				Who		Reason
21 January 2010		cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
// 04/11/2011   cnwrs1      PAR 28390 - Add _preAuthorised flag as Event Stop Request updates are preauthorised other are not
*/
	
vars
	
begin
	beginTransaction;
	_realTI.updateProxyStops(_stops, null, false, _passport);		// pars 28390 and 28930
	if _passport.hasErrors then
		abortTransaction;
	else
		commitTransaction;
	endif;
	
	self.assertTrueMsg( _passport.trxCompletedOK, _passport.getAllErrorsWarningsAsString );
	
	
epilog
	// currently required so if still in transaction state the next unit test will be run OK.
	if process.isInTransactionState then
		// If you use this instruction when not in transaction state,
		// all transaction duration locks on persistent objects will be released.
		abortTransaction;
	endif;
	
end;
</source>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_stops" type="CM_StopsByIdDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addStopsTable" id="ed3961d8-095d-4d14-8c27-f47950a36106">
        <source>addStopsTable(
	_id				: Integer;
	_code			: String;
	_heading		: String;
	_selectedTypes	: CM_CargoBOLTypeSet;
	_opts			: CM_AssociationDict ) : CM_StopsTable;
//12 November 2008	cnwdw1	
//
vars
	proxyStopsTable				: CM_StopsTable;
	stopTable					: CM_StopsTable;
	proxyStopsTableTemplate		: CM_StopTableTemplate;
	shortHeading				: String;
	isFull						: Boolean;
	isMT						: Boolean;
	setupStopTemplate			: Boolean;
	isTranshipLoadPortThisCountry: Boolean;
	pxyStopCriteria 			: CM_StopCriteria;
begin
	create proxyStopsTable transient;
	shortHeading := _opts.str( ETRow_ShortHeading );
	if shortHeading = null then
//		shortHeading := _heading[1:CM_StopsTable::shortHeading.length-1];
		shortHeading := _heading[1:CM_StopsTable::shortHeading.getLengthForString];
	endif;
	
	if not _selectedTypes.isEmpty then
		create pxyStopCriteria transient;
		pxyStopCriteria.setMyStopTable(proxyStopsTable);
		pxyStopCriteria.createStopCriteria(_selectedTypes, YACriteriaType_CargoType, pxyStopCriteria);
	endif;
	
	proxyStopsTable.setProxy(	_opts.bool( ETRow_RequiresInfo ),
								_code,
								_heading,
								shortHeading,
								_opts.int( ETRow_CustomsInfoEntry ),
								_id,
								_selectedTypes,
								_opts.bool( ETRow_IsNotAvailableForEntry ),
								_opts.bool( ETRow_AllowClearanceExpiryDate ),
								app.myRoot,
								_opts.str( JadeCode ),
								_opts.str( UserCode ),
								null					// ### TFS 61382 (61534) 01Dec2023 NAVPW1
								);
	
	setupStopTemplate := true;
	if self.opts.includesKey("SetupStopTemplate") then
		setupStopTemplate := self.opts.bool("SetupStopTemplate");
	endif;
	
	if setupStopTemplate then
		create proxyStopsTableTemplate transient;
		proxyStopsTableTemplate.setKeys( app.getMyTerminalDO_NOT_USE, proxyStopsTable );
		
		// make sure at least the isFull setting is on
		isFull := true;
		
		//cnwmc5 - 23 April 2014 - add in for new BOL only Stop types
		if _selectedTypes.includes(app.myRoot.allBOLTypes[BOLType_GeneralBillOfLading])
		and _selectedTypes.size = 1 then
			isFull := false;
		endif;
		
		if _opts.bool(ETRow_IsFull) then
			isFull := _opts.bool( ETRow_IsFull );
		endif;
		if _opts.bool( ETRow_IsMT ) then
			//isFull := true;
			isMT := _opts.bool(ETRow_IsMT);
		endif;
		
		proxyStopsTableTemplate.setProxy(	_opts.intArray( ETRow_CheckStopAreas ),
											_opts.intArray( ETRow_SetStopAreas ),
											_opts.intArray( ETRow_ProcessStopAreas ),
											null,									// Hold Voyages
											_opts.bool( ETRow_IsChildOnly ),
											_opts.bool( ETRow_IsChildIgnore ),
											_opts.bool( ETRow_IsCoastalOnly ),
											_opts.bool( ETRow_IsCoastalIgnore ),
											_opts.bool( ETRow_IsTranshipOnly ),
											_opts.bool( ETRow_IsTranshipIgnore ),
											//_opts.bool( ETRow_IsMT ),
											isMT,
											isFull);
	endif;
	
	app.myTrxCA.trxCreateStopsTable(proxyStopsTable, stopTable, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return stopTable;
	
epilog
	delete proxyStopsTable;
	
end;</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_selectedTypes" type="CM_CargoBOLTypeSet"/>
        <Parameter name="_opts" type="CM_AssociationDict"/>
        <ReturnType type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="addStopsTableTemplate" id="f91c930f-7abf-4abe-9b8e-327de4f60b58">
        <source>addStopsTableTemplate(
	_stopsTable	: CM_StopsTable io;
	_terminal	: CM_Terminal) : CM_StopTableTemplate;
// 29/07/2011	cnwmh5	Chang eto use UT_UnitTest.opts	
vars
	stopsTableTemplate		: CM_StopTableTemplate;
	proxyStopsTableTemplate	: CM_StopTableTemplate;
	passport				: CM_Passport;
	
begin
	passport	:= app.myPassport;
	
	create proxyStopsTableTemplate transient;
	
	// careful of order of booleans
	proxyStopsTableTemplate.setProxy(	self.opts.intArray( ETRow_CheckStopAreas ),
										self.opts.intArray( ETRow_SetStopAreas ),
										self.opts.intArray( ETRow_ProcessStopAreas ),
										null,									// Hold Voyages
										self.opts.bool( ETRow_IsChildOnly ),
										self.opts.bool( ETRow_IsChildIgnore ),
										self.opts.bool( ETRow_IsCoastalOnly ),
										self.opts.bool( ETRow_IsCoastalIgnore ),
										self.opts.bool( ETRow_IsTranshipOnly ),
										self.opts.bool( ETRow_IsTranshipIgnore ),
										self.opts.bool( ETRow_IsMT ),
										self.opts.bool( ETRow_IsFull ));
	
	proxyStopsTableTemplate.setKeys( _terminal, _stopsTable );
	
	app.myTrxCA.trxCreateStopTableTemplate( proxyStopsTableTemplate, stopsTableTemplate, passport );
	self.assertTrueMsg( passport.trxCompletedOK(), passport.getAllErrorsWarningsAsString() );
	
	return stopsTableTemplate;
	
epilog
	delete proxyStopsTableTemplate;
	
end;
</source>
        <Parameter name="_stopsTable" type="CM_StopsTable" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_StopTableTemplate"/>
    </JadeMethod>
    <JadeMethod name="addStorageDetail" id="2fdb58a2-9d22-4c7e-bab7-d23e20863e84">
        <source>addStorageDetail(_storageConfig : CM_StorageConfig; _code : String; _criteria : IntegerArray; _values : ObjectArray; _freeDays : Integer; _chargedDays : Integer;
				 _chargedDaysWorking : Boolean;
				 _freeDaysWorking : Boolean;
				 _stopCompletionFreeDays : Integer;
				 _receivalDateRule : Integer;
				 _noStorageIfNotFullyReceived : Boolean;
				 _stopTable : CM_StopsTable) : CM_StorageDetail;
// CCMS 1295 free storage days, individual storage criterion
// extended from 37343 to include charged days
//21 Jul 2017	cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold
vars
	indx	: Integer;
	chargedDaysType,
	freeDaysType	: Integer;
	criteria	: Integer;
	obj			: Object;
	value		: Any;
	storageDetailProxy	: CM_StorageDetail;
	storageDetail		: CM_StorageDetail;
	allTransientCriteriaObj	: CMIF_Array;
	proxyCriteria: CM_YACriteria;
	criteriaType : CM_YACriteriaType;
	itemCode : String;
	cooFee, cooFeeType : Integer;
	cal : CM_CalendarByCodeDict;
begin
	// ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1
	if self.opts.includesKey("cooFreeDays") then
		cooFee := self.opts.int("cooFreeDays");
	endif;
	if self.opts.includesKey("cooFreeDaysType") then
		cooFeeType := self.opts.int("cooFreeDaysType");
	endif;
	
	// ### TFS BUG 65740 21AUG2024 NAVAB1
	if self.opts.includesKey("AdditionaCalendars") then
		cal := self.opts.obj("AdditionaCalendars").CM_CalendarByCodeDict;
	endif;
	
	create storageDetailProxy transient;
	// Note: the null terminal parameter is deliberate, to keep these out of CM_Terminal.allYardAllocationsByCode as the 'code' value
	//	may not be unique here
	storageDetailProxy.setProxy(_code,
							_code,
							"",
							0,
							0,
							0,
							null,
							0,
							false,
							0,
							0,
							null,
							0,
							false,
							false,
							null,
							null,
							false,
							null);
					
	foreach indx in 1 to _criteria.size do
		criteria := _criteria[indx];
		value := null;
		if indx &lt;= _values.size then
			obj := _values[indx];
			if obj.isKindOf(CM_SlobField) then
				value := obj.CM_SlobField.getValueAsString();
			else
				value := obj.getYAIdentifier();
			endif;
		endif;				
		create proxyCriteria transient;
		criteriaType := app.myRoot.allYACriteriaTypes[criteria]; 
		itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.getLengthForString);
		proxyCriteria.setProxy(criteriaType, value, itemCode);
		proxyCriteria.setYardAllocation(storageDetailProxy);
	endforeach;
	
	if _chargedDaysWorking then
		chargedDaysType := CM_StorageDetail.Working_Days;
	else
		chargedDaysType := CM_StorageDetail.Calendar_Days;
	endif;
	if _freeDaysWorking then
		freeDaysType := CM_StorageDetail.Working_Days;
	else
		freeDaysType := CM_StorageDetail.Calendar_Days;
	endif;
	//storageDetailProxy.setValues(chargedDaysType, freeDaysType, _freeDays, _storageConfig, _chargedDays, 1, 0);						// TFS 2570
	storageDetailProxy.setValues(chargedDaysType, freeDaysType, _freeDays, _storageConfig, _chargedDays, 1, 
							_stopCompletionFreeDays,_receivalDateRule ,_noStorageIfNotFullyReceived,_stopTable, "",
							_storageConfig.roadReceivalType, _storageConfig.shipReceivalType, _storageConfig.railReceivalType, _storageConfig.unpackReceivalType, //09/06/2023	navkc1	CR 58007 Task 58006
							cal,
							//-1, -1);	// TFS 2570
							cooFee, cooFeeType, // ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1
							_storageConfig.includeFirstDay, _storageConfig.includeLastDay//29/02/2023	navkc1 CR 61899 Task 61904
							);

	app.myTrxCA.trxCreateStorageDetail(storageDetailProxy, allTransientCriteriaObj, storageDetail, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return storageDetail;

epilog
	if allTransientCriteriaObj &lt;&gt; null then
		allTransientCriteriaObj.purge();
		delete allTransientCriteriaObj;
	endif;
	delete storageDetailProxy;
end;</source>
        <Parameter name="_storageConfig" type="CM_StorageConfig"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_criteria" type="IntegerArray"/>
        <Parameter name="_values" type="ObjectArray"/>
        <Parameter name="_freeDays" type="Integer"/>
        <Parameter name="_chargedDays" type="Integer"/>
        <Parameter name="_chargedDaysWorking" type="Boolean"/>
        <Parameter name="_freeDaysWorking" type="Boolean"/>
        <Parameter name="_stopCompletionFreeDays" type="Integer"/>
        <Parameter name="_receivalDateRule" type="Integer"/>
        <Parameter name="_noStorageIfNotFullyReceived" type="Boolean"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <ReturnType type="CM_StorageDetail"/>
    </JadeMethod>
    <JadeMethod name="addStraddle" id="e197e7e5-d5fa-4899-9e40-afdfe92e1f08">
