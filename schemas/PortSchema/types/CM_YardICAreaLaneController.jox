    <JadeMethod name="validate" id="c85250a1-f99c-4ec5-8371-fdbafc58c91f">
        <source>validate(_passport: CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     29 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myTerminalArea &lt;&gt; null and
		(not self.myTerminalArea.isYardInterchangeArea and not self.myTerminalArea.isKindOf(CM_WorkPointInterchangeArea)) then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Expecting CM_YardInterchangeArea');
	endif;
	
	inheritMethod(_passport);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
