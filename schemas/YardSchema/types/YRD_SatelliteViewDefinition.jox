    <JadeMethod name="if_OnRectChanged" id="52625015-b81a-4b13-b6c8-3ca3f0dee2bf">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_RectangleHandler::onRectChanged"/>
        </interfaceImplements>
        <source>if_OnRectChanged(_rect : CMUI_ResizableRectFrame input);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Date		Who		Reason
27 March 2014	cnwer1	Initial creation PAR

*/

vars
		topOffset,
	leftOffset 			: Integer;
	areaViewPosition	: CM_TerminalAreaViewPosition;
	area 				: CM_TerminalArea;
	tmpWidth			: Integer;
	tmpHeight			: Integer;
begin
	areaViewPosition := _rect.userObject.CM_TerminalAreaViewPosition;
	if not _rect.isInResizeMode then
		return;
	endif;
	area := areaViewPosition.myTerminalArea;
	_rect.clearGraphics;
	topOffset := YRD_ContainerDrawingController.TitleHeight;
	_rect.drawFontSize:=8;
	_rect.drawTextAlign := Frame.DrawTextAlign_Left;
	
		_rect.autoRedraw:=true;
	_rect.ignoreSkin:=true;
	_rect.borderStyle:=self.BorderStyle_None;

	_rect.drawStyle:=Frame.DrawStyle_Solid;
	_rect.drawFillColor:=self.myTerminal.getConfig(SatelliteViewCellColour).Integer;//LightBlue;
	_rect.drawFilledRectangle(leftOffset,topOffset,leftOffset+_rect.width,topOffset+_rect.height, self.myTerminal.getConfig(SatelliteViewGridColour).Integer);//DarkBlue

	if _rect.drawTextWidth(area.id) &gt; _rect.width then
		_rect.width := _rect.drawTextWidth(area.id);
	endif;
	_rect.drawTextAlign := Frame.DrawTextAlign_Center;
	_rect.drawTextAt(area.id,_rect.width/2,0,self.myTerminal.getConfig(SatelliteViewFontColour).Integer);//Blue
	
	if areaViewPosition.rotation = 90 or areaViewPosition.rotation = 270 then	//08 Apr 2016	NDL	TFS 1796
		areaViewPosition.setWidthAndHeight(((_rect.height - (YRD_ContainerDrawingController.TitleHeight*2)) * 1/self.zoom).Integer,(_rect.width * 1/self.zoom).Integer);
	else
		areaViewPosition.setWidthAndHeight((_rect.width * 1/self.zoom).Integer,((_rect.height - (YRD_ContainerDrawingController.TitleHeight*2)) * 1/self.zoom).Integer);
	endif;
	//write areaViewPosition.height;
epilog

end;</source>
        <Parameter name="_rect" type="CMUI_ResizableRectFrame" usage="input"/>
    </JadeMethod>
