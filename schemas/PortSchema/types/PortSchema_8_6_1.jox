    <JadeMethod name="tfs5685STWRFinancialInstance" id="8c8a86f1-bcd4-4390-a0b4-23047c385aca">
        <source>tfs5685STWRFinancialInstance();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2017	jlgndl1	Initial creation	TFS 6938

*/

vars

	aFIO : CM_STWRInterface;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	aFIO := CM_STWRInterface.firstInstance().CM_STWRInterface;
	if aFIO = null then
	app.writeLog( method.qualifiedName &amp; " Create single instance of ADP Interface class for 8.4.2", LogINFO);
		aFIO := app.myTrxCA.trxCreateExternalFinanceClass(CM_STWRInterface).CM_STWRInterface;
	endif;

	self.addScriptRun(method.name);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tfs6962Conversion" id="dca9391a-39f0-44a5-88a5-d35a4c8d0027">
        <source>tfs6962Conversion();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2017	jlger1	Initial creation
21 November 2019	jlgzm1	TFS 46986 Refactor Event Transaction Reporting

*/

vars
	
	root 	: CM_Root;
	et 		: CM_EventType;
begin
	app.writeLog( method.qualifiedName &amp; " Converting event type classes for 8.6.1", LogINFO);
	root:=CM_Root.firstInstance;	
	//self.tfs6962ConvertClass(CMEVT_TruckArrival);
	//self.tfs6962ConvertClass(CMEVT_TruckEntry);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tfs6962ConvertClass" id="fa3cdff3-9af3-4629-955f-33137b61c3ac">
        <source>tfs6962ConvertClass(_class : Class) protected;
/*

Date		Who		Reason
09 December 2014	cnwer1	Initial creation PAR

*/

vars
	toDelete,
	os : ObjectSet;
	o : Object;
	t			: CM_EventTransaction;
begin
	if _class = null then
		return;
	endif;
	
	app.writeLog( method.qualifiedName &amp; " Converting event type class " &amp; _class.name &amp; " for 8.6.1", LogINFO);
	create toDelete transient;
	create os transient;
	_class.instances.copy(os);
	if os.first &lt;&gt; null then
			beginTransaction;
			foreach o in os discreteLock do
				
				t:=o.sendMsg("convertForCCMS1405").CM_EventTransaction;	
				if t &lt;&gt; null then
					toDelete.add(o);
				endif;
			endforeach;
			if not toDelete.isEmpty then
				toDelete.purge;	
			endif;	
		commitTransaction;
	endif;
epilog
	delete os;
	delete toDelete;

end;</source>
        <access>protected</access>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="updateCargoGroupComplete" id="05fcd435-c3b8-4856-bb26-dfefa537b44c">
        <source>updateCargoGroupComplete(_controller: CnEcReleaseController);
/*

Purpose:			Evaluate and set the new complete flag on all CM_CargoGroup instances,
					based on the transactions attached to them

Parameters:			Release controller

Return Value:		None

Date		Who		Reason
27 Jun 2018	jlgkpd1	TFS #39132 - Ship Manifest EDI load performance changes
	
*/

vars
	cargoGroup		: CM_CargoGroup;

begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Setting complete values on Cargo Groups", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting complete values on Cargo Groups") ;	
	endif;
	
	beginTransaction;
	foreach cargoGroup in CM_CargoGroup.instances do
		cargoGroup.setCompleteFromTransactions();
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Setting complete values on Cargo Groups complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting complete values on Cargo Groups complete") ;	
	endif;
	self.addScriptRun(method.name);
	
epilog
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateCashDrErrConfig" id="e46e72be-1578-4ba6-85fc-15a954cceef3">
        <source>updateCashDrErrConfig(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2018	jlgndl1	Initial creation	TFS 38952

*/

vars

	isError : Boolean;
	term : CM_Terminal;

begin
	
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Setting up Term Config 'CashOnlyInDebtOption'", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting up Term Config 'CashOnlyInDebtOption'") ;	
	endif;
	
	beginTransaction;
	foreach term in app.myRoot.allTerminals do
		isError := term.getConfig(CashProcUnderpayIsError).Boolean;
		if isError then
			term.setConfig(CashOnlyInDebtOption, 1.Integer );	// Error
		else
			term.setConfig(CashOnlyInDebtOption, 2.Integer ); // Warning;
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Setting up Term Config 'CashOnlyInDebtOption' complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting up Term Config 'CashOnlyInDebtOption' complete") ;	
	endif;
	self.addScriptRun(method.name);

epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateContainerVGMDetails" id="c7208a3a-cc8f-4730-8664-a0b5366eeb82">
        <source>updateContainerVGMDetails(_controller: CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 29/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	terminal : CM_Terminal;
	weightAuth, pxyWeighAuth : CM_WeighAuthority;
	authTerms : ObjectArray;
	authTerminal : CM_WeighAuthTerminal;
	container : CM_Container;
	certifiedName, certifiedRef : String;

begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Setting up Weigh Authorities and container VGM details", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting up Weigh Authorities and container VGM deails") ;	
	endif;
	
	beginTransaction;
	// create defaults first
	create authTerms transient;
	foreach  terminal in app.myRoot.allTerminals do
		certifiedRef := terminal.getConfig(DefaultWeightCertifiedBy).String.toUpper[1:100];
		certifiedName := terminal.getConfig(DefaultAuthPersonWeight).String.toUpper[1:100];
		
		if certifiedRef &lt;&gt; null and certifiedName &lt;&gt; null then
			weightAuth := app.myRoot.allWeighAuthorities[certifiedRef, certifiedName];
			if weightAuth = null then
				create pxyWeighAuth transient;
				pxyWeighAuth.setProxy(certifiedName, certifiedRef, null, null, null, null, null, null, null, null, false);
				create weightAuth persistent;
				weightAuth.setForCreate(pxyWeighAuth, authTerms);
			endif;
			if weightAuth.allWeighAuthTerminals[terminal] = null then
				create authTerminal;
				authTerminal.setForCreate(true, weightAuth, terminal);
			endif;
		endif;
	endforeach;			
	
	// now containers with authorised names and certified names
	foreach container in CM_Container.instances discreteLock do
		if container.weightCertifiedReference &lt;&gt; null or container.weightCertifiedName &lt;&gt; null then
			certifiedRef := container.weightCertifiedReference.toUpper[1:100];
			certifiedName := container.weightCertifiedName.toUpper[1:100];
			container.setMyVGMDetails(certifiedRef, certifiedName, null, null, null, null, null, null, null, null, null, null, null, null);
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Setting up Weigh Authorities and container VGM details complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting up Weigh Authorities and container VGM details complete") ;	
	endif;
	self.addScriptRun(method.name);
	
epilog
	delete authTerms;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateDrawingAttributes" id="16fa9c3c-90f0-4ebb-9d9e-7eddc49bd7ae">
        <source>updateDrawingAttributes(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2017	jlgma1	Initial creation
//17 Oct 2017	cnwma1  TFS #7431 JMT - Refactoring - Drawing Attributes Labels
*/

vars
	drwAttr : CM_DrawingAttribute;
	root: CM_Root;
	cargoType: CM_CargoType;
	hazardclass: CM_HazardClass;
	specialStow: CM_SpecialStow;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " updating drawing attributes", null);

	root := CM_Root.firstInstance;
	//TFS 7431 cnwma1  17.10.2017 
	foreach drwAttr in CM_DrawingAttribute.instances do

		if drwAttr.code[1:15] = "picTICargoType_" then
			beginTransaction;
			foreach cargoType in CM_CargoType.instances do
				if cargoType.myDrawingAttribute = drwAttr then
					cargoType.setMyDrawingAttribute(null);
//					write "CargoType " &amp; cargoType.abbreviation &amp; " null myDrawingAttribute";
				endif;
			endforeach;
			foreach hazardclass in CM_HazardClass.instances do
				if hazardclass.myDrawingAttribute = drwAttr then
					hazardclass.setMyDrawingAttribute(null);
//					write "HazardClass " &amp; hazardclass.code &amp; " null myDrawingAttribute";
				endif;
			endforeach;
			foreach specialStow in CM_SpecialStow.instances do
				if specialStow.myDrawingAttribute = drwAttr then
					specialStow.setMyDrawingAttribute(null);
//					write "SpecialStow " &amp; specialStow.code &amp; " null myDrawingAttribute";
				endif;
			endforeach;
			app.writeLog(method.qualifiedName &amp; " Deleted " &amp; drwAttr.code, LogINFO);
			delete drwAttr;
			commitTransaction;
			continue;
		endif;
		
		if drwAttr.myRoot &lt;&gt; root then
			beginTransaction;
			if root.allDrawingAttributes.includesKey(drwAttr.code) then
				foreach cargoType in CM_CargoType.instances do
					if cargoType.myDrawingAttribute = drwAttr then
						cargoType.setMyDrawingAttribute(null);
					endif;
				endforeach;
				foreach hazardclass in CM_HazardClass.instances do
					if hazardclass.myDrawingAttribute = drwAttr then
						hazardclass.setMyDrawingAttribute(null);
					endif;
				endforeach;
				foreach specialStow in CM_SpecialStow.instances do
					if specialStow.myDrawingAttribute = drwAttr then
						specialStow.setMyDrawingAttribute(null);
					endif;
				endforeach;
				app.writeLog(method.qualifiedName &amp; " Duplicate code, deleted " &amp; drwAttr.code, LogINFO);
				delete drwAttr;
				commitTransaction;
				continue;
			else
				drwAttr.myRoot := root;
				commitTransaction;
			endif;
		endif;
		
	if drwAttr.code[1:5].toUpper ="picTA".toUpper then
		
		beginTransaction;
		drwAttr.drawingAttrType := DrawingAttrType_TerminalArea;
		drwAttr.productType     :=ProductType_Extra;
		commitTransaction;
		
		
//		write drwAttr.code &amp; Tab &amp; drwAttr.drawingAttrType.String &amp; Tab &amp; drwAttr.productType.String;
		
		endif;
		
	
		if drwAttr.code[1:10] ="CargoType_" then
		
		beginTransaction;
		drwAttr.drawingAttrType := DrawingAttrType_CargoType;
		drwAttr.productType     :=ProductType_Extra;
		commitTransaction;
		
		
//		write drwAttr.code &amp; Tab &amp; drwAttr.drawingAttrType.String &amp; Tab &amp; drwAttr.productType.String;
		
		endif;
		
		if  drwAttr.code[1:12] = "HazardClass_" then
			beginTransaction;			
			drwAttr.drawingAttrType := DrawingAttrType_Hazard;
			drwAttr.productType     :=ProductType_Extra;
			commitTransaction;
//			write drwAttr.code &amp; Tab &amp; drwAttr.drawingAttrType.String &amp; Tab &amp; drwAttr.productType.String;
		endif;
		
		
		
		
//		if  drwAttr.code[1:12] = "HazardClass_" then
//			beginTransaction;			
//			drwAttr.drawingAttrType := DrawingAttrType_Hazard;
//			drwAttr.productType     :=ProductType_Extra;
//			commitTransaction;
//			write drwAttr.code &amp; Tab &amp; drwAttr.drawingAttrType.String &amp; Tab &amp; drwAttr.productType.String;
//		endif;
		
	
		
		if  drwAttr.code[1:12] = "SpecialStow_" then
			beginTransaction;			
			drwAttr.drawingAttrType := DrawingAttrType_Special;
			drwAttr.productType     :=ProductType_Extra;
			commitTransaction;
			
		endif;	
//		write drwAttr.code &amp;Tab &amp;Tab &amp; drwAttr.drawingAttrType.String &amp;Tab &amp; Tab &amp; drwAttr.productType.String;
		
		if  drwAttr.code[1:5] = "picTI" then
			
			beginTransaction;			
			drwAttr.drawingAttrType := DrawingAttrType_TrackedItem;
			//drwAttr.productType     :=ProductType_Extra;
			commitTransaction;
			
//				write drwAttr.code &amp;Tab &amp;Tab &amp; drwAttr.drawingAttrType.String &amp;Tab &amp; Tab &amp; drwAttr.productType.String &amp;Tab &amp; drwAttr.label; 
		endif;
		
		beginTransaction;
		if  drwAttr.code[1:5] = "picTI" then
		
			if drwAttr.code = PicTITimber then
//				write  drwAttr.code &amp; Tab  &amp;" Timber";
				drwAttr.productType := ProductType_Timb;
				
			elseif drwAttr.code = PicTIBreakBulk then
//				write  drwAttr.code &amp; Tab  &amp;" BreakBulk";
				drwAttr.productType := ProductType_BreakBulk;
			
			elseif drwAttr.code.isOneOf(PicTIInTransit,PicTIReadyToShip,PicTICustomHold,PicTIHazard,PicSpecialStow,PicTITBA,PicTIQueued,PicTIPlanned,PicTIActual,PicTIRT) then
//				write  drwAttr.code &amp; Tab  &amp;" TrackedItem";
				drwAttr.productType := ProductType_TI;
			
			elseif drwAttr.code = PicTICOU then		
//				write  drwAttr.code &amp; Tab  &amp;" Generator";
				drwAttr.productType := ProductType_Gen;
			
			elseif drwAttr.code.isOneOf(PicTI40Footer,PicTI45Footer,PicTI30Footer,PicTI30FooterBE,PicTI53Footer,PicTIWaterCooled,PicTIControlledAtmos,
										PicTIConnected,PicTIReefer,PicTIEmpty,	PicTIFlat,PicTICrib,PicTIFrame,PicTIOpentop,PicTIFantainer,PicTITank,PicTIHiCube,
										PicTI_OD_HLW,PicTI_OD_HL,PicTI_OD_HW,PicTI_OD_H,PicTI_OD_WL,PicTI_OD_L,PicTI_OD_W,PicTI40FooterBackEnd,
										PicTI53FooterBE,PicTI45FooterBackEnd,PicTIDoorsAft,PicTIDoorsFwd,PicTIDoorsAft40,PicTIDoorsFwd40)then
//				write  drwAttr.code &amp; Tab  &amp;" Container";
				drwAttr.productType := ProductType_Container;
			
			elseif drwAttr.code.isOneOf (PicTI10,PicTI1,PicTI0,PicTI2,PicTI3,PicTI4,PicTI5,PicTI6,PicTI7,PicTI8,PicTI9,PicTIBuilding,PicTIGap,PicTIHalfHeight,
										PicTIInteg,PicTILabour,PicTILight,PicTILoad,PicTIMTOnly,PicTIMotorAft,PicTIMotorAft40,PicTIMotorFwd,PicTIMotorFwd40,
										PicTIPower,PicTIUnavail,PicTIReeferGantry,PicTIHeavy,PicTIVoltageSingle,PicTIVoltageDual,PicTIDischarge,PicTIOversized) then
			drwAttr.productType := ProductType_Definition;
//				write drwAttr.code &amp; Tab  &amp;" Definition";
			
			else
//				write  drwAttr.code &amp; Tab  &amp;" N/A";
			endif;
			
		endif;
		commitTransaction;
		
		app.writeLog(method.qualifiedName &amp; " Updated drawing attribute " &amp; drwAttr.code &amp; ","&amp; drwAttr.label &amp; "," &amp; drwAttr.priority.String&amp; ","&amp; drwAttr.drawingAttrType.String &amp; ","&amp; drwAttr.productType.String, LogINFO);
	endforeach;
	//TFS 7431 cnwma1  17.10.2017

	app.writeLog(method.qualifiedName &amp; " Updating drawing attributes", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Updating drawing attributes") ;	
	endif;
	self.addScriptRun(method.name);

epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateDrawingAttributes2" id="df700655-5253-4ac5-b826-d207d861d388">
        <source>updateDrawingAttributes2(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 February 2018	jlgndl1	Initial creation	TFS 36752

*/

vars
	drwAttr : CM_DrawingAttribute;
	root: CM_Root;
begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Updating 'Frame' drawing attribute", null);

	root := CM_Root.firstInstance;
	foreach drwAttr in CM_DrawingAttribute.instances do
		if drwAttr.code = PicTIFrame then
			beginTransaction;
			drwAttr.drawingAttrType := DrawingAttrType_TrackedItem;
			drwAttr.productType := ProductType_Container;
			if drwAttr.priority &lt; 1 then	//09 Feb 2018	NDL	TFS 37019
				drwAttr.priority := root.allDrawingAttributesByTypePri.size + 1;	
			endif;
			commitTransaction;
		endif;

	endforeach;

	app.writeLog(method.qualifiedName &amp; " Updated 'Frame' drawing attribute", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Updated 'Frame' drawing attribute") ;	
	endif;
	self.addScriptRun(method.name);

epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateDrawingAttributes3" id="4509e82a-e0f3-4bae-9a50-756aa020d8d3">
        <source>updateDrawingAttributes3(_controller : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/11/2019	jlgdap1		Initial creation TFS 46405 AT Flat Rack adn OOG in LOLO Planning Screen
//
vars
	draw : CM_DrawingAttribute;

begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Update Product type on new Flat Rack drawing attributes", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Update Product type on new Flat Rack drawing attributes") ;	
	endif;
	
	beginTransaction;
	foreach draw in CM_Root.firstInstance.allDrawingAttributesByTypePri do
		if draw.code = PicTIFlatRackEndsDown or draw.code = PicTIFlatRackEndsUp then
			draw.setPropertyValue(CM_DrawingAttribute::productType.name, ProductType_Container);
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Update Product type on new Flat Rack drawing attributes COMPLETE",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry(" Update Product type on new Flat Rack drawing attributes COMPLETE") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateEDIActionActionTypes" id="aa5d8ede-d913-49e6-b71e-e462da5b4e64">
        <source>updateEDIActionActionTypes(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2019		jlgns1	Initial creation
// 31/10/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing

*/
vars	
	action : CM_EDIAction;					
begin

	
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " update EDIAction ActionTypes", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" update EDIAction ActionTypes") ;	
	endif;

	beginTransaction;
	foreach action in app.myRoot.allEDIActions discreteLock do	
		if action.actionType = "Place Hold" then		
			action.setPropertyValue(CM_EDIAction::actionType.name,EDIAction_PlaceHold);		
		elseif action.actionType  = "Remove Hold" then		
			action.setPropertyValue(CM_EDIAction::actionType.name,EDIAction_RemoveHolds);				
		endif;	
	endforeach;
	commitTransaction;	
	
	
	app.writeLog(method.qualifiedName &amp; " update EDIAction ActionTypes  complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry(" update EDIAction ActionTypes complete") ;	
	endif;
	
	self.addScriptRun(method.name);

epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateLicenseDecommissions" id="1a19f192-817e-4fbe-80c6-ddc979b8c56a">
        <source>updateLicenseDecommissions( _controller : CnEcReleaseController ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2019	jlgndl1	Initial creation	TFS 46169

*/

vars

	category : ConstantCategory;
	const : Constant;
	constDict : ConstantNDict;

	constantsToUpadteArray : IntegerArray;
	
	constantToUpdate : Constant;
	constValueInt : Integer;
	
	oldText : String;
	newText : String;
	updateText : String;

begin

	app.writeLog( method.qualifiedName &amp; "De-commissioning Licenses 'No Longer Used'... ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("De-commissioning Licenses 'No Longer Used'...") ;	
	endif;
	
	
	//Update the type of these so that they are skipped in the license and permission forms.
	create constantsToUpadteArray transient;
	constantsToUpadteArray.add(PmAutoShipPlanning);
	constantsToUpadteArray.add(PmBackup);
	constantsToUpadteArray.add(PmCargoNotificationReq);
	constantsToUpadteArray.add(PmCargoNotificationWeb);
	constantsToUpadteArray.add(PmCargoStopsReq);
	constantsToUpadteArray.add(PmCargoStopsWeb);
	constantsToUpadteArray.add(PmDeveloper);
	constantsToUpadteArray.add(PmExtTCPIntFace);
	constantsToUpadteArray.add(PmFleetFileMod);
	constantsToUpadteArray.add(PmHandHeldGateClient);
	constantsToUpadteArray.add(PmHandHeldRTGClient);
	constantsToUpadteArray.add(PmHandHeldRailConf);
	constantsToUpadteArray.add(PmHandHeldShip1Client);
	constantsToUpadteArray.add(PmKEA);
	constantsToUpadteArray.add(PmKPIModule);
	constantsToUpadteArray.add(PmODBCModule);
	constantsToUpadteArray.add(PmPDFBackground);
	constantsToUpadteArray.add(PmRMGFunctions);
	constantsToUpadteArray.add(PmRTGFunctions);
	constantsToUpadteArray.add(PmReeferMonitorMod);
	constantsToUpadteArray.add(PmRefCon);
	constantsToUpadteArray.add(PmRoadGateKiosk);
	constantsToUpadteArray.add(PmShipJobControllerModule);
	constantsToUpadteArray.add(PmShipPlanning);
	constantsToUpadteArray.add(PmStwOmanBespoke);
	constantsToUpadteArray.add(PmSubTerminalMod);
	constantsToUpadteArray.add(PmTradeSingleWindow);
	constantsToUpadteArray.add(PmTrailer);
	constantsToUpadteArray.add(PmTruckBooking);
	constantsToUpadteArray.add(PmUserCodeHookMod);
	constantsToUpadteArray.add(PmVehicleHandling);
	constantsToUpadteArray.add(PmVehicleMountedIMV);
	constantsToUpadteArray.add(PmVoyComodityPlan);
	constantsToUpadteArray.add(PmWebModule);
	constantsToUpadteArray.add(PmWeighbridgeIntFace);
	
	oldText := "&lt;PermType&gt;2&lt;/PermType&gt;";
	newText := "&lt;PermType&gt;3&lt;/PermType&gt;";	//PermType_NoLongerUsed 
	
	
	category := currentSchema.getCategory(XLAT_Permissions);		
	constDict := category.getConstants();
	
	foreach const in constDict do
		constValueInt := const.getSource.Integer;
		if not constantsToUpadteArray.includes( constValueInt ) then
			continue;
		endif;
		if const.text.pos(oldText,1) &gt; 0 then
			updateText := const.text.replaceString(oldText, newText);
		endif;
		if updateText &lt;&gt; null then
			beginTransaction;
			const.setText( updateText );
			commitTransaction;
		endif;
	endforeach;	

	
	
	app.writeLog( method.qualifiedName &amp; "Completed De-commissioning Licenses 'No Longer Used' ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Completed De-commissioning Licenses 'No Longer Used'") ;	
	endif;

epilog

	delete constantsToUpadteArray;

end;</source>
        <access>protected</access>
