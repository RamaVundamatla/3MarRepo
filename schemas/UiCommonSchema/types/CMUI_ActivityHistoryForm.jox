    <JadeMethod name="addToolbarControls" id="ce276b64-e367-41c2-bd4f-03d845ae4b36">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
------------------------------------------------------------------------
Created:			10 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
    queryToolbar,
	toolbar	: CMUI_Toolbar;

begin

	inheritMethod();
	
	if self.isPreSelected then	//22 Nov 2018	NDL	TFS 42116
		toolbar := self.frmToolbar;
		toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
		queryToolbar := self.frmQueryToolbar;
		queryToolbar.visible := false;
		return;
	endif;
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);	

	// cnwjk3 PAR 18356 - Date - 03/11/2008
    toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
    toolbar.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
    toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnTerminal, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSystem, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnAll, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnGeneral, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEmail, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCams, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEDI, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnGarbage, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExtInterface, CMUI_Toolbar.Control_Alignment_Left);	//17 Apr 2018	NDL	TFS 38135
	/*  LoadRite button no longer being used 
	if app.getMyUser.canDo(self.myTerminal, PmInMachineWeighing) then
		toolbar.addButton(self.btnLoadrite, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	*/
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	// cnwjk3 PAR 18356 - Date - 03/11/2008
    queryToolbar := self.frmQueryToolbar;
    queryToolbar.showCaptions := false;
    queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
    queryToolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
    queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
    queryToolbar.positionToolbarControls();
    queryToolbar.visible := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="allowsTableFilters" id="190721a1-9bf6-4d08-acad-1931755ef64f">
        <source>allowsTableFilters(_table: Table): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2016	cnwndl1	Initial creation	Make Activity History form use column organiser

*/

vars

begin
	return _table = self.tblActivity;

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="applyColumnFilter" id="9bf46588-e4ca-4d26-87a3-a5d6e01c5535">
        <updating/>
        <source>applyColumnFilter(_table: CM_DataTable io): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2016	cnwndl1	Initial creation	Make Activity History form use column organiser

*/

vars
	visibleCount : Integer;
begin
	if _table &lt;&gt; null then
		if _table.allowsColumnFilters then
			visibleCount := _table.applyColumnFilter( self.allColumnFilters );
		endif;
	endif;
	
	return visibleCount;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="btnAll_click" id="28a92efe-58f0-416c-bd07-c09e7d14c9b2">
