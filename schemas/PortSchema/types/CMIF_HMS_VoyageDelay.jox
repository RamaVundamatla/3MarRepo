    <JadeMethod name="copyDelay" id="75e6664e-5bfe-444a-9ce7-26a6db38339c">
        <updating/>
        <source>copyDelay(permanentDelay : HMS_VoyageDelay; workingVoyage: CMIF_HMS_WorkingVoyage) updating;

vars

begin
	isChargeable 	:= permanentDelay.isChargeable;
	startTime		:= permanentDelay.startTime;
	stopTime		:= permanentDelay.stopTime;
	myDelay			:= permanentDelay.myDelay;
	self.myPersistentVoyageDelay := permanentDelay;
	myWorkingVoyage	:= workingVoyage;
	self.myHMSVoyageData := permanentDelay.myVoyageData;
end;</source>
        <Parameter name="permanentDelay" type="HMS_VoyageDelay"/>
        <Parameter name="workingVoyage" type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="6fdea5d0-9e0f-4027-9242-44013d763aa8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	11 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	if _attrName = ETRow_DelayStartTime then
		return self.startTime.time.display();
	elseif _attrName = ETRow_DelayStartDate then
		return self.startTime.date.display();		
	elseif _attrName = ETRow_DelayEndTime then
		return self.stopTime.time.display();	
	elseif _attrName = ETRow_DelayEndDate then
		return self.stopTime.date.display();				
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="f009bafd-ac9e-4f8e-852f-4799918d9dab">
        <source>validateMe(_passport : CM_Passport input) : Boolean;
//--------------------------------------------------
// Created:	21 June 2005 By: cnwgd1
//--------------------------------------------------
vars
begin

	if self.myWorkingVoyage = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Voyage', null, null);
		app.raiseCMException(Input_required_field_voyage, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.myDelay = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Delay', null, null);
		app.raiseCMException(Input_required_field_delay, null, null); // cnwdb2	PAR 35364


	endif;
	
 	if (not self.startTime.isValid) then
 	//	app.raiseCMException1(REQUIRED_FIELD, 'Delay Start', null, null);
		app.raiseCMException(Input_required_field_delayStrt, null, null); // cnwdb2	PAR 35364
 	endif;
 	if (not self.stopTime.isValid) then
 	//	app.raiseCMException1(REQUIRED_FIELD, 'Delay Finish', null, null);
		app.raiseCMException(Input_required_field_delayFin, null, null); // cnwdb2	PAR 35364
 	endif; 	
 	
 	if _passport.hasErrors then
 		return false;
 	endif;

	if self.startTime &gt;= self.stopTime then
		app.raiseCMException1(AutoScheduleDateError, 'Start date/time must be before finish date/time', null, null);
	endif; 	 	

	if _passport.hasErrors() then
		return false;
	endif;
	return true;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
