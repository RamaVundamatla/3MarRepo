    <JadeMethod name="chkSDSSecondary_click" id="c2342de8-1286-4794-bf81-96106c9746e2">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkSDSSecondary_click(_checkbox: CheckBox input) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.myCurrentCntrl	:=	_checkbox;
	
	if app.msgBox("The binary and database directories are relative to the computer doing "&amp;
		           "the backup. The log directories are only ever done on the Primary database. "&amp;CrLf&amp;
		           "This means the directory used for the binary and database must be visible to the "&amp;
		           "Primary or Secondary SDS database computer, as applicable.", "Note:", 1) = 1 then
		beginTransaction;
		app.myServerAppObject.setUseSDSSecondary(_checkbox.value);
		commitTransaction;
		//force the change to be transferred to the secondary.
		app.myDBA.closeCurrentJournal();
	endif;
	
	self.setValidObjects();
end;</source>
        <Parameter name="_checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
