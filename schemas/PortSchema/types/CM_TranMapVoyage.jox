    <JadeMethod name="healthCheckIsValid" id="ec2815f5-91f1-4171-b83c-2bea3a3d7d21">
        <source>healthCheckIsValid(_agent : CMIF_InvoiceHealthAgent) : Boolean;
/*
Purpose:			
Date				Who			Reason
September 2017		CNWAB1		Initial creation
*/

vars
	message : String;
	resultType : Integer;
	detail : CMIF_InvoiceHealthAgentDetail;
	term : CM_Terminal;
// TFS 40620 	invLineDescs : CM_InvoiceLineDescMapDict;
	invLineDescs : CM_InvoiceLineDescSet;// TFS 40620 
	invLineDesc : CM_InvoiceLineDesc;
	paths : HugeStringArray;
	items : ObjectArray;
	bu : CM_Bank;
	invalid : Boolean;
	aResSB : CM_ResourceServiceBroker;
		aCT : CM_CalculationType;
	ild : CM_InvoiceLineDesc;
	aResType : HMS_ResourceType;
	qrm : CM_QuantityRangeMap;
	mapping : CM_TranMapInvoiceLineMapping;
begin
	on Exception do app.handleDeletedObject(exception, invLineDesc, invalid);
	
	bu := self.getBank();
	if bu = null then
		return true;
	endif;
	if not _agent.allBusinessUnits.includes(bu) then
		return true;
	endif;
	
//	term := self.getMyTerminal();
//	if term = null then
//		return true;
//	endif;
//	if not _agent.allTerminals.includes(term) then
//		return true;
//	endif;
	
	// ### CARGO  Calculation Type
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_CalcType) then
		resultType := CMIF_InvoiceHealthAgent.ResultType_CalcTypeVoyage;
		invLineDescs := self.getAllMappedInvoiceLineTypes();
		
		foreach invLineDesc in invLineDescs do
			if  invLineDesc.myCalculationType &lt;&gt; null then
				if not invLineDesc.myCalculationType.isVoyageCalcType then
					create detail transient;
					detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_CalcType,"Line Type: '" &amp; invLineDesc.narration &amp;  "'", CMIF_InvoiceHealthAgent.ItemType_TranMapHMS, self.getMyTerminal(), resultType, self);
				endif;
			endif;
		endforeach;
		if invalid then
			create detail transient;
			detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_InvoiceLineType,"Line Type is Invalid Object", CMIF_InvoiceHealthAgent.ItemType_TranMapAlloc, self.getMyTerminal(), CMIF_InvoiceHealthAgent.ResultType_Invalid, self);
			return false;
		endif;
		
		// ### CHECK that HMS resource type configuration matches calculation type configuration
		foreach aResSB in self.allResourceSBs do
			if aResSB.myResource &lt;&gt; null then
				aResType := aResSB.myResource.myResourceType;
				if aResType = null then
					return true;
				endif;
		
				foreach qrm in aResSB.myChildQuantityMap.allQuantityRanges discreteLock do
			
					// TFS 40620foreach	ild in qrm.allInvoiceLineMaps discreteLock do
					foreach mapping in qrm.allTMInvoiceLineMappings do // TFS 40620
						ild := mapping.myTMInvoiceLineDesc; // TFS 40620
						
						if ild.isVoid then
							continue;
						endif;
			
						aCT := ild.getCalcType();
						
						if aCT &lt;&gt; null then
							if aCT.requiresQuantity then
								if aCT.requiresQuantity &lt;&gt; aResType.isQuantityRequired then
									message := app.getErrorString3 (ServiceResourceDoNotMatch,"'" &amp; ild.narration &amp; "'","'" &amp; aResSB.myResource.description &amp; "'","quantity" );

									create detail transient;
									detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_CalcType,message, CMIF_InvoiceHealthAgent.ItemType_TranMapHMS, self.getMyTerminal(), CMIF_InvoiceHealthAgent.ResultType_Invalid, self);
								endif;
							endif;
							if aCT.requiresADate then
								if aCT.requiresADate &lt;&gt; aResType.isActionDateTimeRequired then
									message := app.getErrorString3 (ServiceResourceDoNotMatch,"'" &amp; ild.narration &amp; "'","'" &amp; aResSB.myResource.description &amp; "'","date" );

									create detail transient;
									detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_CalcType,message, CMIF_InvoiceHealthAgent.ItemType_TranMapHMS, self.getMyTerminal(), CMIF_InvoiceHealthAgent.ResultType_Invalid, self);
								
								endif;
							endif;		
							if aCT.requiresDateRange then
								if aCT.requiresDateRange &lt;&gt; aResType.isFromToDateTimeRequired then
									message := app.getErrorString3 (ServiceResourceDoNotMatch,"'" &amp; ild.narration &amp; "'","'" &amp; aResSB.myResource.description &amp; "'","date range" );
									create detail transient;
									detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_CalcType,message, CMIF_InvoiceHealthAgent.ItemType_TranMapHMS, self.getMyTerminal(), CMIF_InvoiceHealthAgent.ResultType_Invalid, self);
								endif;
							endif;
						endif;
					endforeach;
				endforeach;
			endif;
		endforeach;
		
		
		return false;
	endif;
	
	
	return true;
epilog
	delete invLineDescs;
end;</source>
        <Parameter name="_agent" type="CMIF_InvoiceHealthAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="7188e8f1-1473-49e6-a5d8-af6a57314715">
        <updating/>
        <source>initialise(_bank : CM_Bank) updating;

vars
	resSB : CM_ResourceServiceBroker;
begin

	self.myBank := _bank;

	resSB := self.allResourceSBs[CM_ResourceServiceBroker.DEFAULT_SB_MAP];
	if resSB = null then
		create resSB;
		resSB.initialiseRes(self);
	endif;

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
