    <JadeMethod name="validateForCreate" id="6ba82ebe-c162-48d8-b48a-153f547aadd3">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin

	self.validateMe();
	
	if app.myRoot.allWeighBridgeTypes.getAtKey(self.code) &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="1bcde62c-56c2-4017-b523-35d0de0235ef">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2014	cnwndl1	Initial creation

*/

vars

begin

	if not self.allWeighBridges.isEmpty then
		app.raiseCMException2( Object_IsBeingUsedInCriteria, app.getErrorString( WeighBridge ), self.allWeighBridges.first.name, null, null );
	endif;

epilog

end;</source>
    </JadeMethod>
