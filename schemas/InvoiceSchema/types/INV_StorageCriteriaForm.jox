	lblMessage.translateCaption(Xlat_0022112, locale);
	lblReceivalOpts.translateCaption(Xlat_0022113, locale);
	lblShipReceival.translateCaption(Xlat_0026082, locale);
	lblStopFreeDays.translateCaption(Xlat_0021310, locale);
	lblTruckReceival.translateCaption(Xlat_0026083, locale);
	lblWagonReceival.translateCaption(Xlat_0026084, locale);
//	optAllDays.translateCaption(Xlat_0022115, locale);		           // 30/05/2023 navkc1 CR 58013 Task 58014
//	optAllMonth.translateCaption(Xlat_0022116, locale);		           // 30/05/2023 navkc1 CR 58013 Task 58014
//	optFSAllDaysChg.translateCaption(Xlat_0022117, locale);		           // 30/05/2023 navkc1 CR 58013 Task 58014
//	optFSAllMonthsChg.translateCaption(Xlat_0022118, locale);		           // 30/05/2023 navkc1 CR 58013 Task 58014
//	optFSWorkCompChg.translateCaption(Xlat_0022119, locale);		           // 30/05/2023 navkc1 CR 58013 Task 58014
//	optFSWorkDaysChg.translateCaption(Xlat_0022120, locale);		           // 30/05/2023 navkc1 CR 58013 Task 58014
	optFirstLocation.translateCaption(Xlat_0022121, locale);
