        <source>getYAAutoPlanMessages(): String;
//30 September 2008	cnwdw1	
//
vars
	line: String;
	str: String;
	lines: StringArray512;
begin
	lines := app.myYAAgent.getLoggingArray(true);
	if lines &lt;&gt; null then
		foreach line in lines do
