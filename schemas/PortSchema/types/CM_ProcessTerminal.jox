    <JadeMethod name="pxyCreateUpdateProxy" id="a05b74c6-181a-487c-b76e-67b8a46ffec0">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgndl1	Initial creation	TFS 39140

*/

vars

	proxy : CM_ProcessTerminal;
	completedOK : Boolean;

begin

	proxy := inheritMethod();

	self.allVessels.copy( proxy.allVessels );
	
	completedOK := true;			
	return proxy;
	
epilog
	if not completedOK then			
		delete proxy;
	endif;	
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2b5e9cc1-7e55-4125-9b7b-9aef42cc78c0">
        <updating/>
        <source>setForCreate( _proxy :  CM_ProcessTerminal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgndl1	Initial creation	TFS 39140
12 Feb  2019	cnwma1	ChangeRequest 43244: PEL1 - Container Services - Segregation in WP for Depot and Terminal
*/

vars

begin

	self.setForUpdate( _proxy );
	
	self.myTerminal 	 := _proxy.myTerminal;
	self.myVoyageProcess := _proxy.myVoyageProcess;
	self.myDepotVoyage   := _proxy.myDepotVoyage;		//12.02.2019 cnwma1 TFS #43244 
epilog

end;</source>
        <Parameter name="_proxy" type="CM_ProcessTerminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2419e8c6-e271-4f6a-a58c-a9e200bddceb">
        <updating/>
        <source>setForUpdate( _proxy :  CM_ProcessTerminal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgndl1	Initial creation	TFS 39140
12 Feb  2019	cnwma1	ChangeRequest 43244: PEL1 - Container Services - Segregation in WP for Depot and Terminal
*/

vars

begin

	self.allVessels.clear();
	if not _proxy.allVessels.isEmpty then
		_proxy.allVessels.copy( self.allVessels );
	endif;

	self.allowUpdateOfIMSRBerth := _proxy.allowUpdateOfIMSRBerth;	//15 Oct 2018	NDL	TFS 41404
	self.myDepotVoyage          := _proxy.myDepotVoyage;            //12.02.2019 cnwma1 TFS #43244
epilog

end;</source>
        <Parameter name="_proxy" type="CM_ProcessTerminal"/>
    </JadeMethod>
    <JadeMethod name="setProxyData" id="e32e66cc-4118-43b5-a159-943ce1a876d8">
        <updating/>
        <source>setProxyData( 	_allVessels : CM_VesselSet input; 
				_allowUpdateOfIMSRBerth : Boolean;
				_myDepotVoyage :CM_Voyage;
				_myVoyageProcess : CM_VoyageProcess;
				_terminal        : CM_Terminal
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgndl1	Initial creation	TFS 39140
12 Feb  2019	cnwma1	ChangeRequest 43244: PEL1 - Container Services - Segregation in WP for Depot and Terminal
*/

vars

begin

	self.allVessels.clear();
	if not _allVessels.isEmpty then
		_allVessels.copy( self.allVessels );
	endif;
	
	self.allowUpdateOfIMSRBerth := _allowUpdateOfIMSRBerth;	//15 Oct 2018	NDL	TFS 41404
	self.myDepotVoyage          := _myDepotVoyage ; 		//12.02.2019 cnwma1 TFS #43244
	self.myVoyageProcess        := _myVoyageProcess;
	self.myTerminal             := _terminal;
epilog

end;</source>
        <Parameter name="_allVessels" type="CM_VesselSet" usage="input"/>
        <Parameter name="_allowUpdateOfIMSRBerth" type="Boolean"/>
        <Parameter name="_myDepotVoyage" type="CM_Voyage"/>
        <Parameter name="_myVoyageProcess" type="CM_VoyageProcess"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setProxyKeys" id="48630b25-98a6-49e8-8dbd-5cb2e3232084">
        <updating/>
        <source>setProxyKeys(	_myTerminal : CM_Terminal;
				_myVoyageProcess : CM_VoyageProcess;
				_myDepotVoyage   : CM_Voyage
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgndl1	Initial creation	TFS 39140
12 Feb  2019	cnwma1	ChangeRequest 43244: PEL1 - Container Services - Segregation in WP for Depot and Terminal
*/

vars

begin

	self.myTerminal 	 := _myTerminal;
	self.myVoyageProcess := _myVoyageProcess;
	self.myDepotVoyage   := _myDepotVoyage;
epilog

end;</source>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
        <Parameter name="_myVoyageProcess" type="CM_VoyageProcess"/>
        <Parameter name="_myDepotVoyage" type="CM_Voyage"/>
    </JadeMethod>
