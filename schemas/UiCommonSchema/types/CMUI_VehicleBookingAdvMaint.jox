    </JadeMethod>
    <JadeMethod name="populateCarrierCombo" id="ed2e3984-cc6b-45a1-bcd8-be43b0bcb1db">
        <source>populateCarrierCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 July 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
23 Dec 2022	navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
*/

vars
	carrier : CM_Carrier;
	vbTimeSlot : CM_VehicleBookingTimeSlot;		// 23.12.2022 navak20 TFS 55979
begin
	self.cmbCarrier.clear();

	self.cmbCarrier.addItemObject("", null);
	
	foreach carrier in app.myRoot.allCarriersRoad do
		self.cmbCarrier.addItemObject(carrier.code &amp; " - " &amp; carrier.description, carrier);
	endforeach;
	
	vbTimeSlot := self.myProxyVehicleBookingTimeSlot;	// 23.12.2022 navak20 TFS 55979
	//if self.myProxyVehicleBookingTimeSlot &lt;&gt; null and self.myProxyVehicleBookingTimeSlot.myCarrier &lt;&gt; null then	// 23.12.2022 navak20 TFS 55979
	if vbTimeSlot &lt;&gt; null and vbTimeSlot.myCarrier &lt;&gt; null then
		//self.cmbCarrier.listObject := self.myProxyVehicleBookingTimeSlot.myCarrier;	// 23.12.2022 navak20 TFS 55979
		self.cmbCarrier.listObject := vbTimeSlot.myCarrier;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCheckBoxes" id="347b55fc-aac5-47cf-8e2c-feef309a6ca4">
        <source>populateCheckBoxes(_slotType : CM_VehicleBookingTimeSlotType);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jul 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
23 Dec 2022	navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
06 Jul 2023	navma1	ChangeRequest 58753: EUP | Slot Creation - Date and Time defaults and updates
*/

vars
	vbTimeSlot : CM_VehicleBookingTimeSlot;				// 23.12.2022 navak20 TFS 55979
begin
	vbTimeSlot := self.myProxyVehicleBookingTimeSlot;	// 23.12.2022 navak20 TFS 55979
	if self.vehicleBookingMode = self.MODE_UPDATE or self.vehicleBookingMode = self.MODE_UPDATE_BULK then
		if _slotType &lt;&gt; vbTimeSlot.myVBTimeSlotType then
			self.chkKiosk.value      := _slotType.kioskCheck;
			self.chkPreGateIn.value  := _slotType.preGateInCheck;
			self.chkPreGateOut.value := _slotType.preGateOutCheck;
		else
			self.chkKiosk.value 	 := vbTimeSlot.kioskCheck;
			self.chkPreGateIn.value  := vbTimeSlot.preGateInCheck;
			self.chkPreGateOut.value := vbTimeSlot.preGateOutCheck;
		endif;
		

	elseif self.vehicleBookingMode = self.MODE_ADD then
		self.chkKiosk.value      := _slotType.kioskCheck;
		self.chkPreGateIn.value  := _slotType.preGateInCheck;
		self.chkPreGateOut.value := _slotType.preGateOutCheck;
	endif;
epilog

end;</source>
        <Parameter name="_slotType" type="CM_VehicleBookingTimeSlotType"/>
    </JadeMethod>
    <JadeMethod name="populateCombos" id="ee67bb55-af23-4d3b-ad60-be3b3d39781e">
        <source>populateCombos();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 July 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
13/08/2024		navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
10 Oct 2024		navah1	Bug 33064: Trailer Types selection is not filtered in the VBS

*/

vars
	
begin
	self.populateVbsTypeCombo();	
	self.setupCarrierCombo();
	self.populateSubCarrier();
	self.myAssistant.comboBoxTrailerType(self.cmbTILCType,null,null,self.getMyTerminal);  //10.10.2024 navah1 #33064 
	
	//13/08/2024 navcs2	ChangeRequest 63928 Start
	if self.myProxyVehicleBookingTimeSlot &lt;&gt; null and self.myProxyVehicleBookingTimeSlot.myTILCType &lt;&gt; null then
		//self.cmbTILCType.setObject(myProxyVehicleBookingTimeSlot.myTILCType);			  //10.10.2024 navah1 #33064
		self.cmbTILCType.setIndexFromObject(myProxyVehicleBookingTimeSlot.myTILCType);    //10.10.2024 navah1 #33064
	endif;
	//13/08/2024 navcs2	ChangeRequest 63928 End
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateDriverCombo" id="9e180e38-5cb1-419d-8ca9-637760f22b5a">
        <source>populateDriverCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
23 Dec 2022	navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
*/

vars
	iter : Iterator;
	driver : CM_DriverDetails;
	carrier : CM_Carrier;	// 23.12.2022 navak20 TFS 55979
	idx		: Integer;	// 23.12.2022 navak20 TFS 55979
	vbTimeSlot : CM_VehicleBookingTimeSlot;		// 23.12.2022 navak20 TFS 55979
begin

	self.cmbDriver.clear();
	self.cmbDriver.enabled := true;
	carrier := self.cmbCarrier.getCurrentItemObject.CM_Carrier;		// 23.12.2022 navak20 TFS 55979
	
	//if self.cmbCarrier.getCurrentItemObject.CM_Carrier &lt;&gt; null then	// 23.12.2022 navak20 TFS 55979
	if carrier &lt;&gt; null then
		//iter := self.cmbCarrier.getCurrentItemObject.CM_Carrier.allDrivers.createIterator;	// 23.12.2022 navak20 TFS 55979
		iter := carrier.allDrivers.createIterator;		// 23.12.2022 navak20 TFS 55979
		while iter.next( driver ) do
			if driver.myTerminal = self.myTerminal then
				idx := self.cmbDriver.addItem( driver.name );	// 23.12.2022 navak20 TFS 55979
				//self.cmbDriver.itemObject[self.cmbDriver.addItem( driver.name )] := driver;	// 23.12.2022 navak20 TFS 55979
				self.cmbDriver.itemObject[idx] := driver;		// 23.12.2022 navak20 TFS 55979
			endif;
		endwhile;
	endif;
	
	vbTimeSlot := self.myProxyVehicleBookingTimeSlot;	// 23.12.2022 navak20 TFS 55979
	//if self.myProxyVehicleBookingTimeSlot &lt;&gt; null and self.myProxyVehicleBookingTimeSlot.myDriver &lt;&gt; null then	// 23.12.2022 navak20 TFS 55979
	if vbTimeSlot &lt;&gt; null and vbTimeSlot.myDriver &lt;&gt; null then	// 23.12.2022 navak20 TFS 55979
		//self.cmbDriver.listObject := self.myProxyVehicleBookingTimeSlot.myDriver;	// 23.12.2022 navak20 TFS 55979
		self.cmbDriver.listObject := vbTimeSlot.myDriver;	// 23.12.2022 navak20 TFS 55979
	endif;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateSubCarrier" id="ee47a078-281d-42ca-8ecc-fd099e35e50a">
        <source>populateSubCarrier();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot

*/

vars
	carrier : CM_Carrier;
	vbTimeSlot : CM_VehicleBookingTimeSlot;	// 26.12.2022 navak20 TFS 55979
begin
	self.cmbSubCarrier.clear();
	self.cmbSubCarrier.addItemObject("", null);

	foreach carrier in app.myRoot.allSubCarriersRoad do
		self.cmbSubCarrier.addItemObject(carrier.description, carrier);
	endforeach;
	
	vbTimeSlot := self.myProxyVehicleBookingTimeSlot;
	if vbTimeSlot &lt;&gt; null and vbTimeSlot.mySubCarrier &lt;&gt; null then
		self.cmbSubCarrier.setIndexFromObject( vbTimeSlot.mySubCarrier);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTableBookingItems" id="aab7b1b9-90b2-4af8-b364-7be3a3fb877b">
        <source>populateTableBookingItems();
/*

Purpose:			Populates the Vehicle Booking Items Table

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
22 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
26 Dec 2022		navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
15 Nov 2023 	navlc30 ChangeRequest 61205: EUP | FR | 54329 | VBS - Pending issues - Issue 11
26 Feb 2025		navpw1	JIRA: MTN-34070 - Fixed VBS Item Table column organiser this is read automatically no need to do it manually.
05 Mar 2025		navpw1	JIRA: MTN-34070 - Refactored the way the form is loaded to support the column organiser

*/
vars
	tbl					: CM_DataTable;
	vehicleBookingItem	: CM_VehicleBookingTimeSlotItem;
	vbTimeSlot			: CM_VehicleBookingTimeSlot;
	iter				: Iterator;
	str					: String;
	
begin
	tbl := self.tblSlotItems;
	tbl.rows := tbl.fixedRows;
	vbTimeSlot := self.myProxyVehicleBookingTimeSlot;
	
	if vbTimeSlot &lt;&gt; null then
		iter := vbTimeSlot.allVehicleBookingItems.createIterator;
		
		while iter.next(vehicleBookingItem) do
			str := vehicleBookingItem.getAttributeStringForDefArray(tbl.allTblDataEntRows);
			tbl.addItemObject(vehicleBookingItem,str);
		endwhile;
	endif;
	
epilog
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateVbsTypeCombo" id="512e9351-56f7-4733-a0d3-13cf3493a487">
        <source>populateVbsTypeCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jul 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
26 Dec 2022	navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
24 Apr 2023	navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
*/

vars
	slotType	: CM_VehicleBookingTimeSlotType;
	iter 		: Iterator;
	vbTimeSlot	: CM_VehicleBookingTimeSlot;	// 26.12.2022 navak20 TFS 55979
begin
	self.cmbVbsSlotType.clear;
	
	iter := self.myTerminal.allTerminalVBSSlotTypes.createIterator;
	while iter.next(slotType) do
		if slotType.notAvailableForEntry then
			continue;
		endif;
		self.cmbVbsSlotType.addItemObject(slotType.description, slotType);
	endwhile;
	
	vbTimeSlot := self.myProxyVehicleBookingTimeSlot;	

	if vbTimeSlot &lt;&gt; null and vbTimeSlot.myVBTimeSlotType &lt;&gt; null then		
		self.cmbVbsSlotType.listIndex := self.cmbVbsSlotType.findObject(vbTimeSlot.myVBTimeSlotType);							//24.4.2023 navhl20 #57716[57718]
	endif;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateVehicleCombo" id="8000a50e-1f89-481c-a332-e4e4fe89627e">
        <source>populateVehicleCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
26 Dec 2022	navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
*/

vars
	vehicle		: CM_Vehicle;
	iter		: Iterator;
	driver		: CM_DriverDetails;
	vbTimeSlot	: CM_VehicleBookingTimeSlot;		// 26.12.2022 navak20 TFS 55979
	idx			: Integer;
begin
	self.cmbVehicle.clear();
	
	driver := self.cmbDriver.getCurrentItemObject.CM_DriverDetails;
	
	if driver &lt;&gt; null then
		iter := driver.allVehicleMachines.createIterator;
		while iter.next( vehicle ) do
			idx := self.cmbVehicle.addItem(vehicle.regNumber);
			self.cmbVehicle.itemObject[idx] := vehicle;
		endwhile;
	endif;
	
	vbTimeSlot := self.myProxyVehicleBookingTimeSlot;	// 26.12.2022 navak20 TFS 55979
	//if self.myProxyVehicleBookingTimeSlot &lt;&gt; null and self.myProxyVehicleBookingTimeSlot.myVehicle &lt;&gt; null then	// 26.12.2022 navak20 TFS 55979
	if vbTimeSlot &lt;&gt; null and vbTimeSlot.myVehicle &lt;&gt; null then		// 26.12.2022 navak20 TFS 55979
		//self.cmbVehicle.listObject := self.myProxyVehicleBookingTimeSlot.myVehicle;		// 26.12.2022 navak20 TFS 55979
		self.cmbVehicle.listObject := vbTimeSlot.myVehicle;		// 26.12.2022 navak20 TFS 55979
	endif;
	
epilog
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setAllVbsItems" id="29d7cd27-549c-44d4-b3ae-1b6424498ac6">
        <updating/>
        <source>setAllVbsItems(_vbsItems : CM_VehicleBookingByTs) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 December 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
*/

vars

begin
	_vbsItems.copy(self.allVehicleBookingTimeSlots);
epilog

end;</source>
        <Parameter name="_vbsItems" type="CM_VehicleBookingByTs"/>
    </JadeMethod>
    <JadeMethod name="setControls" id="ee6d9a70-a52f-45d2-a6a4-81b7a73e1096">
        <updating/>
        <source>setControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Aut 2022	navcs2	Initial creation
24 Apr 2023	navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
02 May 2023	navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
13 Jul 2023 navma1	FR | EUP 53429 - BR - VBS changes MTN - Multi Edit VBS items
*/

vars
	vbsSlot		: CM_VehicleBookingTimeSlot;
	vbsStatus   : Integer;
	str			: String;
begin
	vbsSlot 			 := self.myProxyVehicleBookingTimeSlot;							//13.07.2023 navma1 #53429
	self.txtId.text      := self.myVBSTimeSlot.id;
	self.txtId.enabled   := false;
	self.idLabel.enabled := false;														//02.5.2023 navhl20 #57402[57471]
	
	// populate check boxes and combos
	self.populateCheckBoxes(vbsSlot.myVBTimeSlotType);
	self.populateCombos();
	
	// set timestamps
	
	if vbsSlot.bookingTSstart &lt;&gt; null then
		self.startDT.setDate(vbsSlot.bookingTSstart.date());
		self.startTM.setTime(vbsSlot.bookingTSstart.time());
	endif;
	if  vbsSlot.bookingTSend &lt;&gt; null then
		self.endDT.setDate(vbsSlot.bookingTSend.date());
		self.endTM.setTime(vbsSlot.bookingTSend.time());
	endif;
	
	// ### TFS 53898 (53961) 01Feb2023 NAVPW1
	if vbsSlot.externalReference &lt;&gt; null then
		self.txtExternalReference.text := vbsSlot.externalReference;
	endif;
	// ### TFS 53898 (53961) 01Feb2023 NAVPW1
	
	if vbsSlot.remarks &lt;&gt; null then
		txtRemarks.text := vbsSlot.remarks;
	endif;
	
	self.initTblSlotItems();			// ### JIRA: MTN-34070 05Mar2025 NAVPW1
	self.populateTableBookingItems();

	self.txtExternalReference.enabled := true;
	self.lblExternalReference.enabled := true;
	
	self.cmbVbsSlotType.click(self.cmbVbsSlotType);
	
	if self.vehicleBookingMode = self.MODE_UPDATE then
		str := self.caption &amp; ' - Editing...' &amp; vbsSlot.id;
	elseif  self.vehicleBookingMode = self.MODE_UPDATE_BULK then
		str := self.caption &amp; ' - Editing...';
		str := str &amp; self.allVehicleBookingTimeSlots.listString(Comma,CM_VehicleBookingTimeSlot::id.name);
	else 
		str := self.caption &amp; ' - Adding...';
	endif;
	
	self.setCaption(str);												//13.07.2023 navma1 #53429
	
	vbsStatus := vbsSlot.getStatusInteger;
	
	if vbsStatus  = CM_VehicleBookingTimeSlot.BookedArrivedEarlyInt or
		vbsStatus = CM_VehicleBookingTimeSlot.BookedArrivedLateInt or
		vbsStatus = CM_VehicleBookingTimeSlot.BookedArrivedOntimeInt
	then
		self.vbsSlotItems.enabled 	:= false;
		self.lblVbsSlotType.enabled := false;
		self.cmbVbsSlotType.enabled := false;
		self.lblStartDT.enabled 	:= false;
		self.startDT.enabled		:= false;
		self.startTM.enabled 		:= false;
		self.lblEndDT.enabled 		:= false;
		self.endDT.enabled 			:= false;
		self.endTM.enabled 			:= false;
		self.lblCarrier.enabled 	:= false;
		self.cmbCarrier.enabled 	:= false;
		self.lblDriver.enabled 		:= false;
		self.cmbDriver.enabled 		:= false;
		self.chkKiosk.enabled 		:= false;
		self.chkPreGateIn.enabled 	:= false;
		self.chkPreGateOut.enabled 	:= false;
		self.lblSubCarrier.enabled  := false;
		self.cmbSubCarrier.enabled  := false;
		self.lblVehicle.enabled 	:= false;
		self.cmbVehicle.enabled 	:= false;
		self.txtRemarks.enabled 	:= true;
		self.txtCopySlots.enabled 	:= false;				//24.4.2023 navhl20 #57716[57718]
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setPxyVehicleBookTimeSlot" id="5f6d669f-b1c3-40a8-8b85-dff3fc712c82">
        <updating/>
        <source>setPxyVehicleBookTimeSlot(_proxyVehicleBookingTimeSlot : CM_VehicleBookingTimeSlot io; _vbsItems : Boolean) : Boolean protected, updating;
/*

Purpose:			Sets the Proxy Vehicle Booking Timeslot on the form with new values

Parameters:			_proxyVehicleBookingTimeSlot	CM_VehicleBookingTimeSlot	The proxy vehicle booking time slot to use
					_vbsItems						Boolean						Whether or not the slot has VBS items

Return Value:		Boolean	Represnting whether it was successful or not

Date			Who		Reason
13 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
25 Apr 2023 	navhl20 ChangeRequest 57733:[57734] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 02]
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
*/

vars
	vehicleBookingTimeSlot	: CM_VehicleBookingTimeSlotItem;
	scheduleTSstart 		: TimeStamp;
	scheduleTSend 			: TimeStamp;
	vBTerminal 				: CM_VehicleBookingTerminal;
	carrier, subCarrier 	: CM_Carrier;
	driver 					: CM_DriverDetails;
	vehicle 				: CM_Vehicle;
	remarks 
	,externalReference		: String;
	bookedTiIds 			: StringArray;
	ti						: CM_TrackedItem;
	vbTimeslotType 			: CM_VehicleBookingTimeSlotType;
	allBookingRefs 			: CM_BookingRefSet;
	allBulkReleases 		: CM_BulkReleaseSet;
	preGateInCheck,
	preGateOutCheck,
	kioskCheck				: Boolean;
	realVBSSLot				:CM_VehicleBookingTimeSlot;
	edition					: Integer;
	term				    : CM_Terminal;
	tILCType				: CM_TILCType;
begin

	term		   := self.myTerminal;
	vbTimeslotType := self.cmbVbsSlotType.listObject.CM_VehicleBookingTimeSlotType;
	carrier 	   := self.cmbCarrier.listObject.CM_Carrier;
	subCarrier 	   := self.cmbSubCarrier.listObject.CM_Carrier;
	driver 		   := self.cmbDriver.listObject.CM_DriverDetails;
	vehicle        := self.cmbVehicle.listObject.CM_Vehicle;
	tILCType	   := self.cmbTILCType.listObject.CM_TILCType;

	self.hasDeliveryOrPickup(_proxyVehicleBookingTimeSlot);
	
	scheduleTSstart.setDate(self.startDT.text.asDateJMT());
	scheduleTSstart.setTime(self.startTM.text.asTimeJMT());
	scheduleTSend.setDate(self.endDT.text.asDateJMT());
	scheduleTSend.setTime(self.endTM.text.asTimeJMT());


	remarks			  := self.txtRemarks.text;
	preGateInCheck    := self.chkPreGateIn.value;
	preGateOutCheck   := self.chkPreGateOut.value;
	kioskCheck        := self.chkKiosk.value;
	
	if self.txtExternalReference.visible then															//9.5.2023 navhl20 #57733[57734]
		externalReference := self.txtExternalReference.text;
	else
		externalReference := _proxyVehicleBookingTimeSlot.externalReference;
	endif;
	
	create allBulkReleases transient;
	create allBookingRefs transient;
	create bookedTiIds transient;
	
	foreach vehicleBookingTimeSlot in _proxyVehicleBookingTimeSlot.allVehicleBookingItems do 
		if vehicleBookingTimeSlot.myBulkRelease &lt;&gt; null and not allBulkReleases.includes(vehicleBookingTimeSlot.myBulkRelease) then
			allBulkReleases.add(vehicleBookingTimeSlot.myBulkRelease);
		endif;
		
		if vehicleBookingTimeSlot.myBooking &lt;&gt; null and not allBookingRefs.includes(vehicleBookingTimeSlot.myBooking) then
			allBookingRefs.add(vehicleBookingTimeSlot.myBooking);
		endif;
		
		if vehicleBookingTimeSlot.myTrackedItem &lt;&gt; null and not bookedTiIds.includes(vehicleBookingTimeSlot.myTrackedItem.id) then
			bookedTiIds.add(vehicleBookingTimeSlot.myTrackedItem.id);
		endif;
	endforeach;

	// Set the proxy with the parameters gathered from the controls
	if _vbsItems = false then
		_proxyVehicleBookingTimeSlot.pxyGetRealObjectAndEdition(realVBSSLot, edition);
		self.hasDeliveryOrPickup(realVBSSLot);
		_proxyVehicleBookingTimeSlot.setProxy(scheduleTSstart,
											scheduleTSend, 
											term.myVehicleBookingTerminal, 
											carrier,
											subCarrier,
											driver,
											vehicle, 
											remarks,
											self.hasDelivery, 
											self.hasPickup,
											bookedTiIds,
											null,
											vbTimeslotType,
											realVBSSLot.id,
											allBookingRefs,
											allBulkReleases,
											realVBSSLot.allVehicleBookingItems,
											preGateInCheck,
											preGateOutCheck,
											kioskCheck,
											externalReference,												//26.4.2023 navhl20 #57733[57734]
											tILCType);														// 08 Aug 2024 navcs2	ChangeRequest 63928
		return true;			
	endif;
	
	_proxyVehicleBookingTimeSlot.setProxy(scheduleTSstart,
											scheduleTSend, 
											term.myVehicleBookingTerminal, 
											carrier,
											subCarrier,
											driver,
											vehicle, 
											remarks,
											self.hasDelivery, 
											self.hasPickup,
											bookedTiIds,
											null,
											vbTimeslotType,
											_proxyVehicleBookingTimeSlot.id,								//24.4.2023 navhl20 #57733[57734]
											allBookingRefs,
											allBulkReleases,
											_proxyVehicleBookingTimeSlot.allVehicleBookingItems,			//24.4.2023 navhl20 #57733[57734]
											preGateInCheck,
											preGateOutCheck,
											kioskCheck,
											externalReference,												//24.4.2023 navhl20 #57733[57734]
											tILCType);														// 08 Aug 2024 navcs2	ChangeRequest 63928

	
	self.populateTableBookingItems();
	
	return true;
epilog
	delete allBulkReleases;
	delete allBookingRefs;
	delete bookedTiIds;
end;</source>
        <access>protected</access>
        <Parameter name="_proxyVehicleBookingTimeSlot" type="CM_VehicleBookingTimeSlot" usage="io"/>
        <Parameter name="_vbsItems" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
