    <JadeMethod name="doSave" id="b908863e-9480-46bc-bdcb-fb2585fae03a">
        <updating/>
        <source>doSave() : Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwndl1	Initial creation CCMS 1031 / Par 20474

*/

vars

begin

	if doUpdateCrane() then
		self.unloadForm();
	endif;
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
