<Class name="CM_VBSProcessSlotValidation" id="ebe9feed-ac4c-4fba-af80-c2393f05e0b3">
    <superclass name="CM_VBSProcess"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vehicleSchedule"/>
    <JadeMethod name="checkTimeSlotOutsideGrcePeriod" id="b72a413a-91b5-45fd-b0f7-cc17816420fb">
        <source>checkTimeSlotOutsideGrcePeriod(_allVehicleBookingSlots : CM_VehicleBookingTimeSlotById; _terminal : CM_Terminal; _outsideTimeSlotAction : Integer output; _slotIdsOutsideTime : StringArray input; _vvr : CM_VehicleVisitRecord; _retroDateTime : TimeStamp) : Boolean;
/*

Purpose:			Validates whether the vbs slot is valid and can be added to the vehicle visit record
					if start time is 07:00 AM and And slot Duration is 600 Min  the EndTime will be 05:00 PM
					if Grace Period is 30 Min Then
					Truck Allowed to Enter from 06:30 AM to 07:00 AM
Parameters:			_allVehicleBookingSlots	CM_VehicleBookingTimeSlotById	The vbs time slots to validate
					_terminal				CM_Terminal						The terminal to use for validation
					_outsideTimeSlotAction	Integer							The outside time slot action for the vbs slot type

Return Value:		NONE

Date		Who		Reason
26 May 2023	navpw1	Initial creation TFS: 57756 (57896)
16 Aug 2023 navma1	Bug 59805: EUP - VBS EDI Validation
20 Dec 2023 navbs1	ChangeRequest 61841: FR | EUP 53984 - Kiosk process and Interface - VBS Validation for Buffer time
09 Feb 2024 navhl20 ChangeRequest 62084:[62379] EUP | Retrospective Operations - [54177.010] - Road Entry
22 Mar 2024 navlc30 Bug 62711: EUP | FR - 53429 - SLot Time validation on Road gate and Kiosk
12 Nov 2024 navma1	EUP - VBS Slot start time validation is not checked against the VBS Booking Slot times
05 Feb 2025	navhl20 Bug MTN-19856: MTN - VBS Slot validation is not using the retrospective date/time entered in the gate.
*/

vars
	vbsTimeSlotType						: CM_VehicleBookingTimeSlotType;
	vbsTimeSlot							: CM_VehicleBookingTimeSlot;
	outsideTimeSlotAction,
	terminalGracePeriodForEndTime,
	slotTypeGracePeriodForStartTime		: Integer;
	currentTs 							: TimeStamp;
	result								: Boolean;
	
begin
	terminalGracePeriodForEndTime	:= _terminal.getConfig(VsOntimeGracePeriod).Integer;
	currentTs := app.actualTimeServer();													//22.03.2023 navlc30 #62711
	
	if _vvr &lt;&gt; null and _vvr.timeIn.isValid and _vvr.timeIn &lt; currentTs then				//09.02.2023 navhl20 #62084[62379]
		currentTs := _vvr.timeIn;
	endif;
	
	if _retroDateTime.isValid and _retroDateTime &lt; currentTs then							//05.02.2025 navhl20 #19856
		currentTs := _retroDateTime;
	endif;
	
	foreach vbsTimeSlot in _allVehicleBookingSlots do
		vbsTimeSlotType					:= vbsTimeSlot.myVBTimeSlotType;
		outsideTimeSlotAction			:= vbsTimeSlotType.outsideSlotTimeAction;
		slotTypeGracePeriodForStartTime	:= vbsTimeSlotType.gracePeriod;
		
		if currentTs &gt; vbsTimeSlot.bookingTSend.addMinutes(terminalGracePeriodForEndTime) then
			result := true;
			_slotIdsOutsideTime.add(vbsTimeSlot.externalReference);		//20.12.2023 navbs1 #61841
			_outsideTimeSlotAction := outsideTimeSlotAction;
			continue;
		endif;
		
		/*
		//13.02.2025 navhl20 #19856
		if currentTs.Date &gt; vbsTimeSlot.bookingTSstart.Date then
			result := true;
			_slotIdsOutsideTime.add(vbsTimeSlot.externalReference);		//20.12.2023 navbs1 #61841
			_outsideTimeSlotAction := outsideTimeSlotAction;
			continue;
		endif;
		
		//16.08.2023 navma1 #59805
		if currentTs.Time &lt; vbsTimeSlot.bookingTSstart.time.addMinutes(- slotTypeGracePeriodForStartTime) then  //12.11.2024 navma1 #MTN-33406
			result := true;
			_slotIdsOutsideTime.add(vbsTimeSlot.externalReference);		//20.12.2023 navbs1 #61841
			_outsideTimeSlotAction := outsideTimeSlotAction;
			continue;
		endif;*/
		
		if currentTs &lt; vbsTimeSlot.bookingTSstart.addMinutes(- slotTypeGracePeriodForStartTime) then	//13.02.2025 navhl20 #19856
			result := true;
			_slotIdsOutsideTime.add(vbsTimeSlot.externalReference);
			_outsideTimeSlotAction := outsideTimeSlotAction;
			continue;
		endif;
	endforeach;
	
	return result;
	
end;</source>
        <Parameter name="_allVehicleBookingSlots" type="CM_VehicleBookingTimeSlotById"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_outsideTimeSlotAction" type="Integer" usage="output"/>
        <Parameter name="_slotIdsOutsideTime" type="StringArray" usage="input"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_retroDateTime" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
