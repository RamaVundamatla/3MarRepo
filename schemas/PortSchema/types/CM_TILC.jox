    </JadeMethod>
    <JadeMethod name="setMyTypeWithLCs" id="6155563f-a326-425d-bacb-5c5da3c37a58">
        <updating/>
        <source>setMyTypeWithLCs(_type : CM_TILCType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2014	cnwmc5	Initial creation	PAR 33659
29 Oct 2020	NDL	TFS 50113
24 June 2024	navcs2	ChangeRequest 63596: CUX | Enable change of Trailer Type when MAFI has onboard cargo - GoLCrit 02
25 June 2024	navcs2	ChangeRequest 64765: CUX | Enable change of Trailer Type when MAFI has onboard cargo - Cargo Enquiry
*/

vars
	tilcc 	: CM_TILCController;
	lc 		: CM_TILCRow;	
	count 	: Integer;
	old : Integer;
	new : Integer;
	allowTrailerChange : Boolean;			// 24 June 2024	navcs2	ChangeRequest 63596
	child	: CM_TrackedItem;				// 25 June 2024	navcs	ChangeRequest 64765
	childItems	: CM_TISet;					// 25 June 2024	navcs	ChangeRequest 64765
	moveCntrl	: CMIF_MoveController;		// 25 June 2024	navcs	ChangeRequest 64765
begin
	if _type &lt;&gt; self.myTILCType then
	
		allowTrailerChange := app.myPassport.myTerminal.getConfig(AllowTrailerChange).Boolean;	// 24 June 2024	navcs2	ChangeRequest 63596
	
		if not self.myTerminal.roadProcessIsASPA then
			if self.hasAssociatedTIs() and not allowTrailerChange then							// 24 June 2024	navcs2	ChangeRequest 63596
				app.raiseCMException(Cannot_change_trailer_type, null, null);
				return;
			endif;
			
			self.myTILCType := _type;
			
			//15/10/2025	navkc1 JIRA 36057
			if _type &lt;&gt; null and _type.allowUpdateTotalWeight then
				self.updateTILCTotalWeightConfig(true);
			endif;
			
			
			// 25 June 2024	navcs	ChangeRequest 64765 Start
			create childItems transient;
			
			foreach tilcc in self.allLCs do
				foreach child in tilcc.allTrackedItems do
					childItems.add(child);
				endforeach;
			endforeach;
			// 25 June 2024	navcs	ChangeRequest 64765 End
			
			self.allLCs.purge();
			foreach count in 1 to self.myTILCType.numControllers do
				create lc persistent;
				lc.setMYTILC(self);
				if count = 1  and lc &lt;&gt; null then							// 24 June 2024	navcs2	ChangeRequest 63596
					foreach child in childItems do							// 25 June 2024	navcs	ChangeRequest 64765
						create moveCntrl transient;							// 25 June 2024	navcs	ChangeRequest 64765
						moveCntrl.setMyTrackedItem(child);					// 25 June 2024	navcs	ChangeRequest 64765
						moveCntrl.setMyToPrimaryLocation(lc);				// 25 June 2024	navcs	ChangeRequest 64765
						moveCntrl.executeMove(app.myPassport);				// 25 June 2024	navcs	ChangeRequest 64765
						delete moveCntrl;									// 25 June 2024	navcs	ChangeRequest 64765
					endforeach;												// 25 June 2024	navcs	ChangeRequest 64765
				endif;														// 25 June 2024	navcs	ChangeRequest 64765
			endforeach; 													// 25 June 2024	navcs	ChangeRequest 64765
			
		elseif self.myTerminal.roadProcessIsASPA then	
			old := self.myTILCType.numControllers;
			new := _type.numControllers;
			
			if old = new then
				//nothing to do with LCs
				self.myTILCType := _type;
				
			elseif old &lt; new then
				//add some extra lcs
				self.myTILCType := _type;
				while self.allLCs.size &lt; new do
					create lc persistent;
					lc.setMYTILC(self);
				endwhile;
				
			elseif old &gt; new then
				if self.hasAssociatedTIs() then
					app.raiseCMException(Cannot_change_trailer_type, null, null);
					return;
				endif;
				
				self.myTILCType := _type;
				self.allLCs.purge();
				foreach count in 1 to new do
					create lc persistent;
					lc.setMYTILC(self);
				endforeach; 
				
			endif;
			
			// 15/10/2025	navkc1 JIRA 36057
			if _type &lt;&gt; null and _type.allowUpdateTotalWeight then
				self.updateTILCTotalWeightConfig(true);
			endif;
			
			
		endif;
		
	endif;
	
epilog
	delete childItems;		// 25 June 2024	navcs	ChangeRequest 64765
	delete moveCntrl;		// 25 June 2024	navcs	ChangeRequest 64765
end;</source>
        <Parameter name="_type" type="CM_TILCType"/>
    </JadeMethod>
    <JadeMethod name="setParamsOnJRWGateTicket1" id="cc3a77c7-5d9c-4d95-848e-f0eb9e86466c">
        <updating/>
        <source>setParamsOnJRWGateTicket1(_jrwReport	: JadeReportWriterReport) updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	chasID,  chasLen, chasISO : String;

begin
	chasID := self.id;
	chasLen := self.CM_TILC.getLength().String;
	chasISO := self.CM_TILC.getISO();
	
	_jrwReport.setParameter('chassisID', chasID);
	_jrwReport.setParameter('chassisLen', chasLen);
	_jrwReport.setParameter('chassisISO', chasISO);
		

epilog

end;</source>
