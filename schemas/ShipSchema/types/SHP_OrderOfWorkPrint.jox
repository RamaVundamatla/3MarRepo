    <JadeMethod name="populateCmbSendToRep" id="3393a466-fe86-4801-acf9-3757f21ea6ae">
        <source>populateCmbSendToRep() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2017	cnwndl1	Initial creation	TFS 3216/3047

*/

vars

	show : Boolean;

begin

	self.optSendToRep.enabled := false;
	self.cmbSendToRep.enabled := false;
	
	self.myAssistant.comboVoyageObjectReports( cmbSendToRep, null );
	
	if self.cmbSendToRep.listCount = 1 then
		self.cmbSendToRep.listIndex := 1;
	endif;
	
	show := self.cmbSendToRep.listCount &gt; 0;
	self.optSendToRep.enabled := show;
	self.cmbSendToRep.enabled := show;
	self.cmbSendToRep.visible := show;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDynaKey" id="139070cd-ed4d-4c2e-a2f9-6047dc0c65e9">
        <updating/>
        <source>setDynaKey()  updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 18/07/2011	cnwmh5		#27479 - Change to handle Planned correctly.  Add old seq to Custom
// 30/10/012	PJS			PAR #30631 - moved from seq sheet form
vars
	firstVisibleColumn,
	sequenceOption			: Integer;
	sidePort				: Boolean;
	tbl						: CM_DataTable;
begin
	self.dynaKey := null;

	sequenceOption := self.cmbSequence.itemData[self.cmbSequence.listIndex];
	sidePort := self.cmbSide.itemData[self.cmbSide.listIndex].Integer.Boolean;
	
	if sequenceOption = self.Seq_Planned then
	
		if sidePort then
			self.dynaKey := ETRow_SeqNumPort;
		else
			self.dynaKey := ETRow_SeqNumStarboard;
		endif;
	
	elseif sequenceOption = self.Seq_Standard then		
		if sidePort then
			self.dynaKey := ETRow_SeqNumPort;
		else
			self.dynaKey := ETRow_SeqNumStarboard;
		endif;
	
	elseif sequenceOption = self.Seq_Custom then		
		if sidePort then
			self.dynaKey := ETRow_SeqNumCustomPort;
		else
			self.dynaKey := ETRow_SeqNumCustomStarboard;
		endif;
	endif;
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
