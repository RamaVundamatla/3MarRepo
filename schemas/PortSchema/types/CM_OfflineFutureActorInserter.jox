<Class name="CM_OfflineFutureActorInserter" id="f6f2a16c-513e-4cc1-9ecf-c34670fc6294">
    <superclass name="CM_OfflineActor"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>CCMS DPH 2278 etc</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myOfflineFutureActor" id="1587f22a-2e75-4ff9-9a88-4a51890375e7">
        <embedded/>
        <type name="CM_OfflineFutureActor"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="doAction" id="d545858a-7221-4b62-937a-c9325fb2e537">
        <updating/>
        <source>doAction(): Boolean updating;

/*

Purpose:			Set the CM_OfflineFutureActor myRoot reference ( -&gt; global collections on CM_Root) in a separate background activity.


Return Value:		


Date		Who		Reason

*/

vars

begin
	if self.getAndLockValidObject(myOfflineFutureActor, Share_Lock) then
		self.myOfflineFutureActor.setRoot(app.myRoot);
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyOfflineFutureActor" id="c70fa7ec-2113-4722-b23c-c3ee36313d72">
        <updating/>
        <source>setMyOfflineFutureActor(_value: CM_OfflineFutureActor) updating;

/*

Purpose:			Set the associated actor reference for which the doAction method will be done.


Return Value:		


Date		Who		Reason

*/

vars

begin
	if self.myOfflineFutureActor &lt;&gt; _value then 
		self.myOfflineFutureActor := _value;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="CM_OfflineFutureActor"/>
    </JadeMethod>
</Class>
