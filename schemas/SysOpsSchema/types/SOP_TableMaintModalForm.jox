<GUIClass name="SOP_TableMaintModalForm" id="bef0e870-57e3-4789-80b7-8c15205d5ed3">
    <superclass name="SOP_TableMaintForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="addToolbarControls" id="4e9ed3f4-44da-4fdc-b204-3b8edf972a06">
        <source>addToolbarControls() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2016	cnwmp6	Initial creation

*/

vars

begin
	inheritMethod();
	self.btnImport.visible := false;
	self.btnSubTerms.visible := false;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showWithObject" id="fb66b269-a6c2-4bf8-9a5c-d0dfcdc8df0c">
        <updating/>
        <source>showWithObject(pObj: CM_Object; _thumbnailOnly: Boolean; _doEdit: Boolean) updating;
//--------------------------------------------------
// Created:	09 December 2004 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	---------	-----------------------------------------------------
// 25/11/2019	jlgdap1		TFS 47706 PTR HMS _ Contact Details issue
vars

begin
	self.amInitialisingInEditMode	:= _doEdit;
	self.amInitialisingWithObject 	:= true;
	self.myCurrentObject 			:= pObj;
	self.useTblData					:= (not _thumbnailOnly);
	self.useThumbArea				:= true;
	self.isThumbnailVisible			:= true;

	if pObj &lt;&gt; null and (not pObj.isTransient) then	
		self.armNotesForObject(pObj);
	endif;
	
	// TFS 47706 PTR upgraded from 8.4.something to 8.6.1 - sometime in between those 2 releases,
	// showModal had security checking added in to it. This meant that in PTR's case, where their
	// licence is very limited to what they can do, the security in SOP_TableMaintForm rejected
	// their access to Email Contact maintenance, even though the user had the correct security
	// for that access. SOP_TableMaintForm has PmAdmTabledefineView as its permissionView but this
	// permission isn't included in HMS Module, which is the only licence module PTR have.
	// Calling initForm here before showModal creates the individual SOPTM class first, which
	// has its own permission - this supercedes the security check in showModal.
	self.initForm();
	self.showModal;

end;</source>
        <Parameter name="pObj" type="CM_Object"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ba03e6c2-7efd-47b8-b6d8-208650329c0a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007118, locale);
end;</source>
    </JadeMethod>
</GUIClass>
