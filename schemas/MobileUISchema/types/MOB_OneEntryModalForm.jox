    <JadeMethod name="handleCancel" id="3649de25-4e64-4f7b-8fb5-801ad37e9840">
        <updating/>
        <source>handleCancel() updating;
// ---------------------------------------------------------------------------
// Created:     23 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	app.mousePointer	:=	Busy;
	modalResult := ModalResultCancel;
	self.doCloseForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1802296f-8742-4150-a8f8-708cd01c4c54">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017614, locale);
	btn_ButtonLeft.translateCaption(Xlat_0013199, locale);
	btn_ButtonRight.translateCaption(Xlat_0013200, locale);
	lbl_Label1.translateCaption(Xlat_0013201, locale);
	lbl_Title.translateCaption(Xlat_0013202, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
