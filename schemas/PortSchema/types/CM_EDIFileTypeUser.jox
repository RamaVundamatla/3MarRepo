    <JadeMethod name="processFieldHooks" id="e03ad480-d3d1-4846-9ddb-c635b80d6dbe">
        <updating/>
        <source>processFieldHooks(_fieldArray : StringArray; _ediTI : CM_EDITrackedItem) updating;
/*
Date		Who		Reason
15 September 2008	cnwrd1	Initial creation

*/

vars
	fieldMappingType : CM_EDIFieldMappingType;
begin
	//ccms1008 messina  cnwrs1 Sept 2009
	foreach fieldMappingType in self.allEDIFieldMappingTypes do
		fieldMappingType.processFieldHooks(_fieldArray , _ediTI);
	endforeach;
epilog

end;

</source>
        <Parameter name="_fieldArray" type="StringArray"/>
        <Parameter name="_ediTI" type="CM_EDITrackedItem"/>
    </JadeMethod>
    <JadeMethod name="processFieldTest" id="c30c4408-2e8d-4dfd-92f8-e942349711f8">
        <updating/>
        <source>processFieldTest( _fieldArray : StringArray ) : String updating;
vars
	operator : CM_Operator;
	voyage : CM_Voyage;
	ti : CM_TrackedItem;
	voyCode : String;
	cargoId : String;
	cargoTypeDescr : String;
	cargoTypeId : Integer;
	isWeightCertified : Boolean;
	foundMatch : Boolean;
begin
	operator := app.myRoot.allOperators["MSL"];
	if _fieldArray[1] = "CARGO" then
//		app.writeLog(self.String&amp;" "&amp;_fieldArray[7]&amp;" "&amp;_fieldArray[21]&amp;" "&amp;_fieldArray[48]&amp;" "&amp;_fieldArray[49], 0);
		cargoTypeDescr := _fieldArray[7];
		cargoId := _fieldArray[21];
		voyCode := _fieldArray[48];
		isWeightCertified := _fieldArray[55].Boolean;
//		app.writeLog(self.String&amp;" "&amp;cargoTypeDescr&amp;" "&amp;cargoId&amp;" "&amp;voyCode&amp;" "&amp;weight.String, 0);
		voyCode := operator.getXlationSystemCode_Voyage(voyCode, null, null, null, foundMatch);
//		app.writeLog("voyCode="&amp;voyCode, 0);
//		app.writeLog("Terminal="&amp;app.myPassport.myTerminal.String, 0);
		voyage := app.myPassport.myTerminal.lookupVoyage(voyCode, null, false);
//		app.writeLog("voyage="&amp;voyage.String, 0);
		cargoTypeId := operator.getXlationSystemCode(cargoTypeDescr, XLATION_TYPE_CARGOTYPE_BYOP, foundMatch).Integer;
		if cargoTypeId = 0 then
			cargoTypeId := 1;
		endif;
//		app.writeLog("cargoTypeId="&amp;cargoTypeId.String, 0);
		ti := voyage.allOnshipTIsByCargoTypeId[cargoTypeId, cargoId];
		if ti &lt;&gt; null then 
//			app.writeLog("got the ti "&amp;cargoId&amp;" ti isWeightCertified ="&amp;ti.isWeightCertified.String&amp;" edi ti isWeightCertified ="&amp; isWeightCertified.String, 0);
			return ti.isWeightCertified.String;
		else
//			app.writeLog("Couldnt find it "&amp;cargoId, 0);
			return _fieldArray[55];
		endif;
	endif;
end;
</source>
        <Parameter name="_fieldArray" type="StringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="4f796a01-22bb-4961-9443-24270ba013ec">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	01 August 2006 By cnwth2

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
11/04/2013	cnwcs5		CCMS POL 2097 / par 31259 - removed call to processAttributeDependencies
*/
// 12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
// 08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 18 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
// 20 May 2024	navdap1	TFS 64200 MTN - User Defined Transport Manifest Load time/search locking
// 19 Nov 2025 navhl20 Bug MTN-36492: TPA - Overall System Slowness
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	passport		: CM_Passport;	
	ediTI			: CM_EDITrackedItem;
	count			: Integer;
	numLines		: Integer;
	line			: String;
	fieldArray		: StringArray512; //cnwdz2 par 18131
	ediUserDefinedAssist  : CMIF_EDIUserDefinedAssist;
	lineArray 		: StringArray512;	//cnwrs1 ccms 2044 21 Apr 2011
	theLines 		: HugeStringArray;
	progressInt		: TimeStampInterval;
	progressTS 		: TimeStamp;
begin
	progressTS := app.actualTimeAppServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support	//19.11.2025 navhl20 #36492
	passport := app.myPassport;
	create ediUserDefinedAssist transient;

	_ediFile.ediData.setXlationOperator(self.myXlationOperator);
	if self.myXlationOperator &lt;&gt; null then // cnwrd1 - preset myOperator to the xlationOperator if present.
		_ediFile.ediData.setOperator(self.myXlationOperator);
	endif;

	create fieldArray transient;
	create lineArray transient;	//cnwrs1 ccms 2044 28 Apr 2011
		
	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numLines	:= theLines.size;
	foreach line in theLines do
		count	:=	count + 1;
		
		progressInt := app.actualTimeAppServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support	//19.11.2025 navhl20 #36492
		if passport.myCMIFMonitor &lt;&gt; null  and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numLines, count, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeAppServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support	//19.11.2025 navhl20 #36492
			commitTransaction;			// TFS 64200
			process.sleep(100);			// TFS 64200
			beginTransaction;			// TFS 64200
		endif;
		if self.fileType = self.FORMAT_XML then	//cnwrs1 ccms 2044 21 Apr 2011
			lineArray.add(line);
			continue;
		endif;
		
		// split file for string array - changes for hook code
		fieldArray.clear;
		self.splitLine(line, fieldArray );
		
		if (not self.processFileLineHookCode(fieldArray)) then  // run the per line hook code (or true) 
			continue;
		endif;
		
		ediTI := self.loadFieldArray(fieldArray, _ediFile, null, ediUserDefinedAssist);	//ccms 2044 cnwrs1 2 May 2011
	endforeach;
	_ediFile.ediData.processAttributeDependencies(ediUserDefinedAssist, null, false, null); 
	
	if self.fileType = self.FORMAT_XML then	//cnwrs1 ccms 2044 21 Apr 2011
		self.processXMLFile(lineArray, _ediFile);
	endif;
epilog
	delete theLines;
	delete ediUserDefinedAssist;
	delete fieldArray;
	delete lineArray;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processFileFieldHookCode" id="db9eb9db-a0fb-4f50-91b5-65167af2dbb2">
        <source>processFileFieldHookCode(_fieldHook : CM_EDIFieldHookCode ; _lineFields : StringArray; _ediTi : CM_EDITrackedItem) ;
/*
Date		Who		Reason
04 September 2008	cnwrd1	Initial creation

*/

vars
	result 		: String;
	lineFields 	: StringArray;
	ediTi		: CM_EDITrackedItem;
begin	
	ediTi 		:= _ediTi;
	lineFields 	:= _lineFields;
	
	if _fieldHook.myHookCode &lt;&gt; null then
		result := app.myHookAgent.runHookLinkPublic(HookType_EDIFileFieldHook, _fieldHook, self, lineFields).String;

		_fieldHook.assignValue(ediTi , result);
	endif;


epilog

end;</source>
        <Parameter name="_fieldHook" type="CM_EDIFieldHookCode"/>
        <Parameter name="_lineFields" type="StringArray"/>
        <Parameter name="_ediTi" type="CM_EDITrackedItem"/>
    </JadeMethod>
    <JadeMethod name="processFileLineHookCode" id="ebd2d209-d29f-4db4-ac9a-73cb7b0be3ac">
        <source>processFileLineHookCode( _fieldArray : StringArray ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2008	cnwrd1	Initial creation

*/

vars
	result 	: Boolean;
	lineFields : StringArray;
begin
	lineFields := _fieldArray;
	
	if self.myIncludeLineHookLink &lt;&gt; null then
		result := app.myHookAgent.runHookLinkPublic(HookType_EDIFileIncludeLine, self, self, lineFields).Boolean;
	else
		result := true;
	endif;

	return result;
	
epilog

end;</source>
        <Parameter name="_fieldArray" type="StringArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processXMLFile" id="e1e4e60d-4e22-4f11-bc0b-6e9909d260d6">
        <updating/>
        <source>processXMLFile(_lineArray : StringArray512; _ediFile : CM_EDIFile input) updating, protected;
//
// cnwrs1 ccms 2044 21 Apr 2011
//
// 11/04/2012	cnwcs5	CCMS POL 2097 / par 31259 - removed call to processAttributeDependancies
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	fieldMapping : CM_EDIFieldMapping;
	fieldMappingType : CM_EDIFieldMappingType;
	xmlDoc : JadeXMLDocument;
	ediTI			: CM_EDITrackedItem;
	fieldArray		: StringArray512; //cnwdz2 par 18131
	ediUserDefinedAssist  : CMIF_EDIUserDefinedAssist;
	xmlElement : JadeXMLElement;
	xmlElements : JadeXMLElementArray;
	xmlElement2 : JadeXMLElement;
	lineStr : String;
	str : String;
	recuringTag : String;
	userStr : String;
begin

	on JadeXMLException do self.xmlExceptionHandler(exception);

	foreach str in _lineArray do
		lineStr := lineStr &amp; str&amp; CrLf;
	endforeach;
	create xmlDoc transient;
	create ediUserDefinedAssist transient;
	create fieldArray transient;

	xmlDoc.parseString(lineStr);
	create xmlElements transient;
	foreach fieldMappingType in self.allEDIFieldMappingTypes do
		recuringTag := fieldMappingType.controlValue;
		if recuringTag = null then
			foreach fieldMapping in fieldMappingType.allEDIFieldMappings do
				userStr := fieldMapping.userDesc;
				str := xmlDoc.getTagValueOfName(fieldMapping.userDesc);
				fieldArray.add(str);
			endforeach;
		else
			xmlDoc.findElementsByTagName(recuringTag, xmlElements);
			foreach xmlElement in xmlElements do
				fieldArray.clear();
				foreach fieldMapping in fieldMappingType.allEDIFieldMappings do
					userStr := fieldMapping.userDesc;
					xmlElement2 := xmlElement.getElementByTagName(fieldMapping.userDesc);
					if xmlElement2 &lt;&gt; null then
						str := xmlElement2.textData;
						fieldArray.add(str);
					else
						fieldArray.add(null);
					endif;
				endforeach;
				
				ediTI := self.loadFieldArray(fieldArray, _ediFile, recuringTag, ediUserDefinedAssist); //cnwrs1 ccms2044 28 Apr 2011
			endforeach;
		endif;
	endforeach;
	
	if recuringTag = null then
		ediTI := self.loadFieldArray(fieldArray, _ediFile, recuringTag, ediUserDefinedAssist); //cnwrs1 ccms2044 28 Apr 2011
	endif;
epilog
	delete xmlDoc;
	delete xmlElements;
	delete ediUserDefinedAssist;
	delete fieldArray;
end;
</source>
        <access>protected</access>
        <Parameter name="_lineArray" type="StringArray512"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="rawDataToHSA" id="977808f7-7593-4544-9816-7394b86af901">
        <source>rawDataToHSA(_ediFile : CM_EDIFile; _theLines: HugeStringArray input);
//
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 28 Jul 2015	cnwrs1	Par 36683 since new data is in rawData suport old data (8.3.2) from compressedFilelines
//6/07/2018 	JLGNS1	Bug 39173: MSL - Roro baplie not entirely loaded - HIGH PRIORITY
vars
	ediFile : CM_EDIFile;
	findMatchingQuote : Boolean;
	numQuotes : Integer;
	fileLine : String;
	fileLine2 : String;
	theLines: HugeStringArray;
	numberToIgnore : Integer;
	idx	: Integer;
	totalQuotes 	: Integer;	//Bug 39173
	lineNo 			: Integer;	//Bug 39173
	quoteOpenedLineNo : Integer;//Bug 39173
begin
	_theLines.clear;
	create theLines transient;
	fileLine := self.rawDataToString(_ediFile);
	if fileLine = null then
		self.compressedDataToHSD(_ediFile, _theLines);
	else
		fileLine.getHugeTokensForDelimiter(Cr, theLines);
		numberToIgnore := self.numberOfLinesToBeIgnored();
		foreach fileLine in theLines do
			lineNo := lineNo + 1;	//Bug 39173
			if fileLine.isBlank or fileLine.isBlankRecordCSV then
				continue;
			endif;
			// now any line(s) which contains an odd number of double quotes need to be combined together.
			numQuotes := fileLine.cnEcSubstringCount(DoubleQuote);
			totalQuotes := totalQuotes + numQuotes;	//Bug 39173
			if findMatchingQuote then
				// add this line to the previously save fileline(s)
				fileLine2	:= fileLine2 &amp; Space &amp; fileLine;
				// if this line has an even number of quotes then continue looking for the odd one.
				if numQuotes.isEven then
					// NOTE: This leave all double quotes in ?!?
					continue;
				endif;
				// otherwise we now have a matching (ie even number of double quotes) so add the concattenated line(s)
				// Do NOT remove the Double Quotes (PAR 17040)
				idx := idx + 1;
				if idx &gt; numberToIgnore then
					_theLines.addTruncated(fileLine2);
				endif;
				findMatchingQuote := false;
				continue;
			else
				if numQuotes.isEven then
					// line has even number of quotes so treat as normal
					idx := idx + 1;
					if idx &gt; numberToIgnore then
						_theLines.addTruncated(fileLine);
					endif;
					continue;
				endif;
				findMatchingQuote := true;	// odd number so only add once find the matching quote
				fileLine2 := fileLine;
				quoteOpenedLineNo := lineNo;	//Bug 39173
			endif;
		endforeach;
		ediFile := _ediFile;
		if process.isInTransactionState then
			ediFile.setNumContainers(0);
		endif;
	endif;
	
	if totalQuotes.isOdd then																							//Bug 39173		
		app.raiseCMException2(File_not_loaded_missing ,'"', quoteOpenedLineNo.String ,quoteOpenedLineNo.String,null);	//Bug 39173		
	endif;																												//Bug 39173		
	
	
epilog
	delete theLines;
end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_theLines" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="rawDataToString" id="5bfed3b9-7b05-4244-bfaf-91286ac10200">
        <source>rawDataToString(_ediFile : CM_EDIFile) : String;
//
//19 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//
// 25 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 6
vars
	fileLine : String;
	xmlData : String;
	xmlDoc : JadeXMLDocument;
begin
	on JadeXMLException do self.xmlExceptionHandler(exception);
	fileLine := _ediFile.getRawDataString();
	if self.fileType = CM_EDIFileType.FORMAT_XML then	// CCMS 2044 cnwrs1 02 May 2011
		create xmlDoc transient;
		xmlDoc.outputDeclaration := false;
		xmlDoc.parseString(fileLine);
		xmlData := xmlDoc.writeToString();
		if xmlData &lt;&gt; null then
			fileLine := xmlData;
		endif;
		return fileLine;
	endif;
	fileLine := fileLine.replaceString(CrLf, Cr);
	fileLine := fileLine.replaceString(Lf, Cr);
	return fileLine;
epilog
	delete xmlDoc;
end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setConfig" id="fd674192-1c6c-464d-9c37-4c782bcf2d88">
        <updating/>
        <source>setConfig(_key : String; _value : Any) updating;
/* ---------------------------------------------------------------------------
Created:     16 June 2008 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	/* // cnwrd1 ccms 1660 8.8.2008 - refactored
	if self.myEDIFileConfig = null then
		if self.isTransient then
			// setting the proxy
			create self.myEDIFileConfig transient;
		else
			// updating the persistent object so must be transaction state already
			create self.myEDIFileConfig persistent;
		endif;
	endif;
	*/
	self.createConfig(); // cnwrd1 ccms 1660 8.8.2008
	self.myEDIFileConfig.setConfig(_key, _value);
	
	
	
end;</source>
        <Parameter name="_key" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setConfigWarningsToIgnore" id="2b6a6fbf-a5f3-40c2-bced-e56f3ebe3cae">
        <updating/>
        <source>setConfigWarningsToIgnore(_errorList : ObjectArray) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2008	cnwrd1	Initial creation
// cnwrd1 ccms 1660 8.8.2008

*/

vars
	error			: Object;
	pxyInterestedWarning : CM_InterestedWarning;
begin
		
	if self.myEDIFileConfig = null then
		self.createConfig();
	endif;
	
	self.myEDIFileConfig.allWarningsToIgnore.clear();
		
	foreach error in _errorList do
		create pxyInterestedWarning transient;
		pxyInterestedWarning.setProxy(error.XLAT_Translation.myTranslatableText.number);
		self.myEDIFileConfig.allWarningsToIgnore.add(pxyInterestedWarning);
	endforeach;
epilog

end;</source>
        <Parameter name="_errorList" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setConfigsFromProxy" id="75b766ea-6f68-4a38-9e0a-86bc41630c63">
        <updating/>
        <source>setConfigsFromProxy(_pxyEDIFileTypeUser : CM_EDIFileTypeUser) updating;

vars
	stateDate : CM_StateData;
begin
	self.raiseExceptionIfTransient(method);
	if myEDIFileConfig = null then
		create myEDIFileConfig persistent;
	else
		myEDIFileConfig.allStateData.purge;
	endif;
	myEDIFileConfig.setForUpdate(_pxyEDIFileTypeUser.myEDIFileConfig);
end;
</source>
        <Parameter name="_pxyEDIFileTypeUser" type="CM_EDIFileTypeUser"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f5effc45-e991-4d1f-81e9-5e56d9c8e6d6">
        <updating/>
        <source>setForCreate(_pxyEDIFileTypeUser : CM_EDIFileTypeUser) updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.setForUpdate(_pxyEDIFileTypeUser);

end;</source>
        <Parameter name="_pxyEDIFileTypeUser" type="CM_EDIFileTypeUser"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="eb9566c2-f862-473c-863f-6b43391566b7">
        <updating/>
        <source>setForUpdate(_pxyEDIFileTypeUser : CM_EDIFileTypeUser) updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pxyFieldMappingType	: CM_EDIFieldMappingType; //ccms1008 messina  cnwrs1 Sept 2009
	newFieldMappingType	: CM_EDIFieldMappingType;
//	pxyCodeMapping,
//	newCodeMapping			: CM_EDIFieldHookCode;
	pxyHookLink,
	newHookLink				: CM_HookLink;
	newLineHookCode : CM_HookCode;
	pxyLineHookLink : CM_HookLink;
begin
	self.raiseExceptionIfTransient(method);
	
	self.name 				:= _pxyEDIFileTypeUser.name;
	self.type				:= _pxyEDIFileTypeUser.type;
	self.fileType			:= _pxyEDIFileTypeUser.fileType;
	
	self.setMyRoot();
	
	self.delimiter			:= _pxyEDIFileTypeUser.delimiter;
	self.dataType			:= _pxyEDIFileTypeUser.dataType;
	self.numLinesToIgnore 	:= _pxyEDIFileTypeUser.numLinesToIgnore;
	self.dateFormat			:= _pxyEDIFileTypeUser.dateFormat;
	self.dateDelimeter		:= _pxyEDIFileTypeUser.dateDelimeter;
	self.applyTranslations 	:= _pxyEDIFileTypeUser.applyTranslations;
	self.myXlationOperator	:= _pxyEDIFileTypeUser.myXlationOperator;
	self.emailActive		:= _pxyEDIFileTypeUser.emailActive;
	self.emailNumLinesToSearch := _pxyEDIFileTypeUser.emailNumLinesToSearch;
	
	self.emailSearchWords.purge();
	_pxyEDIFileTypeUser.emailSearchWords.copy(self.emailSearchWords);
	
	// linehook code
	delete self.myIncludeLineHookCode;
	self.myIncludeLineHookCode := null;
	
	if _pxyEDIFileTypeUser.myIncludeLineHookCode &lt;&gt; null then 
		pxyLineHookLink := _pxyEDIFileTypeUser.myIncludeLineHookLink;
		if pxyLineHookLink &lt;&gt; null then
			// need to set to the new persistent object
			pxyLineHookLink.setLinkObject(self);
		endif;
		if self.myIncludeLineHookCode = null then
			create self.myIncludeLineHookCode persistent;
			self.myIncludeLineHookCode.setForCreate(_pxyEDIFileTypeUser.myIncludeLineHookCode);
		else
			self.myIncludeLineHookCode.setForUpdate(_pxyEDIFileTypeUser.myIncludeLineHookCode);
		endif;
	else
		delete self.myIncludeLineHookCode;
	endif;
//ccms1008 messina  cnwrs1 Sept 2009	
	self.allEDIFieldMappingTypes.purge();
	foreach pxyFieldMappingType in _pxyEDIFileTypeUser.allEDIFieldMappingTypes do
		create newFieldMappingType persistent;
		newFieldMappingType.setForUpdate(pxyFieldMappingType, self);
	endforeach;
// //ccms1008 messina  cnwrs1 Sept 2009	
//	self.allEDIFieldHookCodes.purge();
//	foreach pxyCodeMapping in _pxyEDIFileTypeUser.allEDIFieldHookCodes do
//		create newCodeMapping persistent;		
//		newCodeMapping.setForUpdate(pxyCodeMapping, self);
//		self.allEDIFieldHookCodes.add(newCodeMapping );
//	endforeach;
	
	if _pxyEDIFileTypeUser.myEDIFileConfig &lt;&gt; null then
		self.setConfigsFromProxy(_pxyEDIFileTypeUser);
	endif;
	self.controlColumn := _pxyEDIFileTypeUser.controlColumn; //ccms1008 messina  cnwrs1 Sept 2009	
	
end;</source>
        <Parameter name="_pxyEDIFileTypeUser" type="CM_EDIFileTypeUser"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="9f01b206-8b51-4332-a709-cd012cf51963">
        <updating/>
        <source>setProxy(_name 				: String;
		_fileType			: Integer;
		_delimeter 			: Character;
		_dateFormat			: String;
		_dateDelimiter		: Character;
		_dataType			: Integer;
		_numLinesToIgnore 	: Integer;
		_applyXlations		: Boolean;
		_xlationOp			: CM_Operator;
		_emailActive		: Boolean;
		_emailSearchLines	: Integer;
		_emailSearchWords	: StringArray;
		_mylineHookCode		: CM_HookCode;
		_controlColumn : Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	self.raiseExceptionIfNotTransient(method);
	
	self.name 				:= _name;
	
	self.fileType			:= _fileType;//i.e. delimitied or fixed length
	self.delimiter			:= _delimeter;
	self.dateFormat			:= _dateFormat;
	self.dateDelimeter		:= _dateDelimiter;
	self.dataType			:= _dataType;
	self.numLinesToIgnore 	:= _numLinesToIgnore;
	self.applyTranslations 	:= _applyXlations;
	self.myXlationOperator 	:= _xlationOp;
	self.emailActive		:= _emailActive;
	self.emailNumLinesToSearch := _emailSearchLines;
	self.emailSearchWords.purge();
	_emailSearchWords.copy(self.emailSearchWords);
	self.myIncludeLineHookCode := _mylineHookCode;
	self.controlColumn := _controlColumn; //ccms1008 messina  cnwrs1 Sept 2009
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_fileType" type="Integer"/>
        <Parameter name="_delimeter" type="Character"/>
        <Parameter name="_dateFormat" type="String"/>
        <Parameter name="_dateDelimiter" type="Character"/>
        <Parameter name="_dataType" type="Integer"/>
        <Parameter name="_numLinesToIgnore" type="Integer"/>
        <Parameter name="_applyXlations" type="Boolean"/>
        <Parameter name="_xlationOp" type="CM_Operator"/>
        <Parameter name="_emailActive" type="Boolean"/>
        <Parameter name="_emailSearchLines" type="Integer"/>
        <Parameter name="_emailSearchWords" type="StringArray"/>
        <Parameter name="_mylineHookCode" type="CM_HookCode"/>
        <Parameter name="_controlColumn" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="splitLine" id="8bd0d095-caca-47be-87d5-288f6232ac41">
        <updating/>
        <source>splitLine( _line : String ; _fieldArray : StringArray input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 September 2008	cnwrd1	Initial creation

*/

vars

begin
	if self.fileType = self.FORMAT_DELIMITED then
//		self.splitLineDelimited(_line, _fieldArray);	// cnwrl1 16/09/2009 PAR 20320 - MES 1011 New Messina Messages - what it was
		self.splitLineDelimited(_line.removeCrLfs(), _fieldArray);		// to handle a double quote as last character better
	elseif self.fileType = self.FORMAT_FIXEDLENGTH then
		self.splitLineFixedLength(_line, _fieldArray);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled file format (' &amp; self.fileType.String &amp; ')');
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="_line" type="String"/>
        <Parameter name="_fieldArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="splitLineDelimited" id="fb245d4a-6485-48b4-9591-27f174b09e84">
        <updating/>
        <source>splitLineDelimited(_lineStr : String; _fieldArray : StringArray input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15/09/2008	cnwrd1	Initial creation
25/11/2009	cnwdad1	PAR #21720 Changed to recognise user-defined field delimiter.
*/
vars
	fieldMapping		: CM_EDIFieldMapping;
	pos					: Integer;
	fieldStr			: String;
	previousPos			: Integer;
	isCSVFileFormat		: Boolean;
	//fieldArray		: StringArray; //cnwdz2 par 18131
	fieldMappingType	: CM_EDIFieldMappingType; //ccms1008 messina  cnwrs1 Sept 2009
	
begin
// cnwdad1 25/11/2009 - PAR #21720 Changed to recognise delimited fields, not dependant on comma.
	//isCSVFileFormat	:=	self.delimiter = ",";			// PAR #17040
	isCSVFileFormat	:=	(self.fileType = CM_EDIFileType.FORMAT_DELIMITED);
	
	pos	:=	1;
	previousPos	:=	1;
	
	//fieldArray := _fieldArray; //cnwdz2 par 18131
	foreach fieldMappingType in self.allEDIFieldMappingTypes do //ccms1008 messina  cnwrs1 Sept 2009
		foreach fieldMapping in fieldMappingType.allEDIFieldMappings do
			if isCSVFileFormat then				// PAR #17040
				fieldStr	:=	_lineStr.getNextCSVToken(pos, self.delimiter).removeCrLfs().trimBlanks();		// cnwdad1 25/11/2009 - PAR #21720 Added delimiter parameter.
			else
				fieldStr	:=	_lineStr.cnEcNextDelimitedField(self.delimiter, pos).removeCrLfs().trimBlanks();
			endif;
			
		//	_fieldArray.add(fieldStr);
			_fieldArray.add(fieldStr[1:511]);	//04 Dec 2020	NDL	TFS 49781 - crap format file with no delimiters read the whole file as one line, truncate to max length handled.
			//th2 PAR12552 - bail, otherwise the 'getNextField' call loops back round to the start of the string
			if pos &lt; previousPos then //we've gone back to the end of line
				break;
			endif;
			
			previousPos	:=	pos;
		endforeach;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_lineStr" type="String"/>
        <Parameter name="_fieldArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="splitLineFixedLength" id="a27d59f8-8178-48ae-a3ce-e28c9491b277">
        <updating/>
        <source>splitLineFixedLength(_lineStr : String; _fieldArray : StringArray) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 September 2008	cnwrd1	Initial creation

*/

vars
	fieldMapping			: CM_EDIFieldMapping;
	pos						: Integer;
	delim,
	fieldStr				: String;
	len,
	idx						: Integer;
	fieldArray				:StringArray;
	fieldMappingType : CM_EDIFieldMappingType; //ccms1008 messina  cnwrs1 Sept 2009
begin
	

	len := _lineStr.length;
	pos := 1;
	fieldArray := _fieldArray;
	foreach fieldMappingType in self.allEDIFieldMappingTypes do //ccms1008 messina  cnwrs1 Sept 2009
		foreach fieldMapping in fieldMappingType.allEDIFieldMappings do
			fieldStr := _lineStr[pos: fieldMapping.length.max(1)].removeCrLfs().trimBlanks();
			pos := pos + fieldMapping.length;
			
			fieldArray.add(fieldStr);
			
			//if pos &gt;= len then // --
			if pos &gt; len then  // ++ cnwrd1 JMT ccms 1034, 4.8.2008 - if last position was single char length it would be missed out.
				break;
				//return;
			endif;
		endforeach;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lineStr" type="String"/>
        <Parameter name="_fieldArray" type="StringArray"/>
    </JadeMethod>
