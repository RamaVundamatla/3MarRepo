    <JadeMethod name="initTblOther" id="bccd9a49-12e1-45f5-b065-bbeafab7df06">
        <source>initTblOther(pTable : CM_EntryTable; pDef : String) protected;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableControl	: EntTableDef;
	theTable		: CM_EntryTable;
	
begin

	theTable := pTable;
	theTable.rows := 0;
		
	theTable.optimiseRowHeight := true;
	
	entTableControl := app.myController.getEntTableDef(pDef);
	theTable.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');

	/*theTable.top 	:= 5;
	theTable.left	:= 5;
	theTable.parentTopMargin	:= theTable.top;
	theTable.parentLeftMargin	:= theTable.left;
	theTable.parentRightMargin	:= 15;
	theTable.parentBottomMargin := 10;

	theTable.lockBottom := false;
	theTable.lockRight	:= false;
	theTable.stretchHeight := true;
	theTable.stretchWidth := true;*/
	theTable.visible := true;
	theTable.pictureViewMethod := 'picViewMethod';
	theTable.pictureLoadMethod := 'picLoadMethod';
	theTable.pictureExtractMethod := 'picExtractMethod';
	theTable.resetSize();
	//theTable.optimiseHeadingColumn();
		
				
end;</source>
        <access>protected</access>
        <Parameter name="pTable" type="CM_EntryTable"/>
        <Parameter name="pDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="isLimitedType" id="7d91b9b1-6926-4991-924b-c4bfb2477c55">
        <source>isLimitedType(_taType : Integer) : Boolean;
// TFS 3422 irregular block stack and bulk area added just for hazards
vars

begin
	if _taType = TA_TYPE_IRREGULAR_BLOCK_AREA or
	   _taType = TA_TYPE_BULK then
		return true;
	else
		return false;
	endif;
end;
</source>
        <Parameter name="_taType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidType" id="157d1052-30c9-43e7-be7e-c6dc5aa690b2">
        <source>isValidType(_ta: CM_TerminalArea) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// ---------------------------------------------------------------------------
begin


	if _ta.type = TA_TYPE_STRADDLE_STACK 
	or _ta.type = TA_TYPE_RTG
	or _ta.type = TA_TYPE_RMG 		//epr added RMG
	or _ta.type = TA_TYPE_FORK_LIFT_STACK
//	or _ta.type = TA_TYPE_IRREGULAR_BLOCK_AREA		//PAR #16753 - PAR 17151 removed
	or _ta.type = TA_TYPE_RORO_LANE_AREA   //cnwjo3 CCMS/PAR
	or _ta.type = TA_TYPE_GEN_CARGO_ALLOC_ROW					// TFS 49453
	or self.isLimitedType(_ta.type)			// TFS 3422 add more area types
	or _ta.isRestrictionBlockStack then
		return true;
	else
		return false;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="4d9abcc1-8da0-4994-8287-d59ee2393c73">
        <updating/>
        <source>loadCombos() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	hazTemp : CM_HazTempRange; 

begin
	self.cmbHazClass.listCollection(app.myRoot.allHazardClasses, true, ComboBox.DisplayCollection_Forward);
	self.tblFlashpoints.clear;
	self.tblFlashpoints.clearSelected();
	self.tblFlashpoints.rows := self.tblFlashpoints.fixedRows;
	foreach hazTemp in app.myRoot.allHazTempRanges do
		self.tblFlashpoints.addItemObject(hazTemp.getDisplayDetails(false), hazTemp);
	endforeach;
	
	self.cmbAcidBase.clear;
	self.cmbAcidBase.addItem(null);
	self.cmbAcidBase.addItem(CM_TIHazard.ACID);
	self.cmbAcidBase.addItem(CM_TIHazard.BASE);
	
	self.tblPackGroups.clear;
	self.tblFlashpoints.clearSelected();
	self.tblPackGroups.rows := self.tblPackGroups.fixedRows;
	self.tblPackGroups.addItemObject("I", null);
	self.tblPackGroups.addItemObject("II", null);
	self.tblPackGroups.addItemObject("III", null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="6b0e9cce-dc54-42b3-91ad-b3543ea989d4">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 06/11/2012	cnwcs5	par 39475 - removing location restrictions/ tiday translations
vars

begin
	inheritMethod();

	self.initSDF();
	self.initListBox();
	
	self.tblOther.changeMode := self.tblOther.ChangeMode_FirstOnly;
	
	// ### we are not using the tblData, so swap it for a list Tree
	self.tblData.visible 			:= false;
	self.tblData.parent 			:= self;
	self.mnuColumnOrganiser.visible := false;				
	self.staMain.visible 			:= false;
	self.bottomMargin				:= 0;
	self.staMain.top 				:= self.clientHeight;
	self.sptRestrictions.parent 	:= self.sptDataFilter;
	
	self.sptDataFilter.setupChildControls;
	
	self.frmGridArea.bubbleHelp 	:= app.getErrorString (Click_select_location) &amp; Cr &amp; 
										app.getErrorString (Hold_ctrl_butto_click_selec_ma) &amp; Cr &amp; 
										app.getErrorString (Hold_shift_butto_click_selec_m) &amp; Cr &amp;
										app.getErrorString(Left_butto_only_selec_singl_lo);
	
	self.frmGridArea.borderStyle 	:= BorderStyle_None;
	
	self.sptMain.setLeftToRightRatio(18);
	self.sptThumbEdit.showRightControl(50, true);
	
	self.sptRestrictions.setLeftToRightRatioAndResize(100);	// par 30475
	self.getXMLSettingsForSetup();
	self.doResize;
	self.doDrawLegend();

	if self.amInitialisingWithObject then
		self.doInitializeWithObject();
	endif;
		
	self.setNotifications();
end;</source>
        <access>protected</access>
    </JadeMethod>
