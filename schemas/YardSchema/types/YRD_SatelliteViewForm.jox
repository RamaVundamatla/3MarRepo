    <JadeMethod name="initializeDrawing" id="ca2cd8b1-4a28-4446-a44e-c8904e167183">
        <updating/>
        <source>initializeDrawing() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2010	cnwer1	Initial creation

*/

vars
	aTA : Object;
begin
		
	self.btnViewYardAlloc.value := false; 

	
	foreach aTA in self.allDrawingControllers do
		self.endNotificationForSubscriber(aTA);
	endforeach;
	
	
	self.allDrawingControllers.purge;
	self.setMyCurrentDrawingController(null, false);
	self.myCurrentTerminalArea := null;
	self.myDrawingFrame := null;

	
epilog

end;</source>
