    <JadeMethod name="doNotableClear" id="e1bbf310-0af2-46bb-9658-13f9ae62964a">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		/*if anObject.isKindOf(____OBJECT TYPE____) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(____EVENT_NAME_____));
			removedNotification := removedNotification + 1;
		endif;*/
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="16258cef-8ce4-4ba2-b22d-86c7ce74ddac">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	mess, head : String;
	bank : CM_Bank;
begin
	bank := self.myCurrentBank;
	if self.tblData.columns = 1 then
		app.msgBox("Please do a query first.","Print Problem", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if self.cmbParentObject.listObject &lt;&gt; null then
		mess := "Printing Mapping Table for " &amp; self.cmbChargeType.text  &amp; " " &amp;  self.cmbParentObject.text;
		head := bank.mailingName &amp; " Charge Mappings for " &amp; self.cmbChargeType.text &amp; " "  &amp; self.cmbParentObject.text;
	endif;

	self.doTblDataPrint(mess,head,"Charge Mappings");

end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="6bdc0942-e370-4d11-8165-81f9e6004097">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 31/05/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
// 07 June 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI

vars


	combo : CMUI_ComboBox;
	lstIdx : Integer;
begin
	self.myCurrentParentObject := self.cmbParentObject.listObject.CM_Object;

	if self.cmbChargeType.listIndex = -1 then
		app.msgBox("Please select a Charge Type to query on.", "Query Error", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	// PAR 17557
	if self.cmbChargeTypeCom.listIndex = -1 then
		app.msgBox("Please select a Combination Charge Type to query on.", "Query Error", MsgBox_Exclamation_Mark_Icon);
		self.cmbChargeTypeCom.setFocus();
		return;
	endif;

	if self.myCurrentParentObject = null then
		app.msgBox("Please select a " &amp; self.cmbChargeType.text &amp; " to query on.", "Mapping Error", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	// 35872
	self.myCurrentBank := self.cmbBank.listObject.CM_Bank;
	if self.myCurrentBank = null then
		return;
	endif;
	
	combo := self.cmbChargeTypeCom;
	self.loadLines();
	
	self.setToolbarButtons(true);
	
	lstIdx := combo.listIndex;
	 // PAR 17557
	if not combo.listObject.CM_DebtorType.isSystemGenerated() then // USER DEFINED DEBTOR TYPES
		self.doQueryDebtorType();
	elseif combo.listObject.CM_DebtorType.code  =  CM_DebtorType.DT_CARGO_OPERATOR then
		self.doQueryOperator();
	elseif combo.listObject.CM_DebtorType.code   =  CM_DebtorType.DT_FREIGHT_FORWARDER then
		self.doQueryFF(true,false,false);
	elseif combo.listObject.CM_DebtorType.code   =  CM_DebtorType.DT_CONSIGNEE then
		self.doQueryFF(false,false,true);
	elseif combo.listObject.CM_DebtorType.code   =  CM_DebtorType.DT_CONSIGNOR then
		self.doQueryFF(false,true,false);
	elseif combo.listObject.CM_DebtorType.code   =  CM_DebtorType.DT_CUSTOMS_AGENT then
		self.doQueryCA();
	elseif combo.listObject.CM_DebtorType.code   =  CM_DebtorType.DT_CARRIER then	// 24094 add Carrier
		self.doQueryCarrier();
	elseif combo.listObject.CM_DebtorType.code   = CM_DebtorType.DT_STEVEDORE_VOYAGE then		// TFS 44554
		self.doQueryStevedore();														// TFS 44554
	elseif combo.listObject.CM_DebtorType.code	=	CM_DebtorType.DT_SHIPPING_LINE then		// 07.06.2022 navak20 TFS 53204
		self.doQueryShippingLine();															// 07.06.2022 navak20 TFS 53204
	endif;
	self.setCaption("Charge Mapping Table - " &amp; self.cmbParentObject.text &amp; " " &amp; self.myCurrentBank.code); // 	TFS 2682

	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryCA" id="e608f15a-0ad1-472d-8d7c-5b737dc7cbf8">
        <updating/>
        <source>doQueryCA() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
// ---------------------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	op : CM_CustomsAgent;
	invoiceLineDesc : CM_InvoiceLineDesc;
	aMap : CM_InvoiceLineChargeMapping;
	row :Integer;
	column :Integer;
	count :Integer;
	pd :CMS_Progress;
	ls : Boolean;
	mapTable : Table;
	bank : CM_Bank;
	dict : CM_CustomsAgentByCodeDict;
begin
	bank := self.myCurrentBank;
	mapTable := self.tblData;

//	TFS 2682	self.setCaption("Charge Mapping Table - " &amp; self.cmbParentObject.text &amp; " " &amp; self.myCurrentBank.code);

	self.setNavigatorHeading(self.caption);
	
	on CM_ProgressException do haltProgress(exception, ls);

	mapTable.accessCell(1,1).text := "Invoice Line Types/ Customs Agent";

	create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.setAction("Loading Customs Agent...");

	app.cmsBeginLoad(ls);

	mapTable.columns := 1;
	mapTable.column := 1;
	mapTable.row := 1;
	mapTable.fixedRows := 1;
	
	dict := app.myRoot.allCustomsAgents;
	column := 1;
	pd.progress.partsInJob := dict.size;
	
	foreach op  in dict discreteLock do
		if op.isNotAvailableForEntry then
			continue;
		endif;
		if not global.isValidObject(op) then
			continue;
		endif;
		
		if self.myCurrentDebtorType.code  =  CM_DebtorType.DT_CUSTOMS_AGENT then
			if op &lt;&gt; self.myCurrentParentObject.CM_CustomsAgent then
				continue;
			endif;
		endif;

		mapTable.columns := mapTable.columns + 1;
		column := mapTable.columns;
		row := 1;
		mapTable.accessCell(row,column).text := op.name;
		mapTable.accessColumn(column).itemObject := op;
		foreach invoiceLineDesc in bank.invoiceLineDescriptors discreteLock where not invoiceLineDesc.isNotAvailableForEntry do
			if invoiceLineDesc.myDebtorType &lt;&gt; self.myCurrentDebtorType then //CP CCMS 1047 PAR 16666 cnwgb1 18 April 2008
				continue;
			endif;
			row := row + 1;
			aMap := bank.allInvLineChargeMappings[invoiceLineDesc, self.myCurrentParentObject, op];
			
			if aMap = null then
				mapTable.accessCell(row,column).text := invoiceLineDesc.myDebtorType.description; //CP CCMS 1047 PAR 16666 cnwgb1 18 April 2008
				mapTable.accessedCell.fontBold := false;
				mapTable.accessedCell.foreColor := DarkGray;
				mapTable.accessedCell.itemObject := null;
			else
				mapTable.accessCell(row,column).text := aMap.myDebtorType.description; //CP CCMS 1047 PAR 16666 cnwgb1 18 April 2008
				mapTable.accessedCell.fontBold := true;
				mapTable.accessedCell.foreColor := Black;
				mapTable.accessedCell.itemObject := aMap;
			
			endif;
		endforeach;

		count := count + 1;
		pd.progress.partsDone := count;
		app.doWindowEvents(0);
	endforeach;
	
	
	mapTable.row := 1;
	mapTable.column := 1;

//	self.setTableAlignment();

	self.setEnableObjects();
	if mapTable.columns &gt; 1 then // adm 050808 Par 47665
		mapTable.accessColumn(2).width := 100;
	endif;
epilog
	app.cmsEndLoad(ls);
	delete pd;

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryCarrier" id="49b3710a-a441-4cd0-b365-28eaf4ca1e7b">
        <updating/>
        <source>doQueryCarrier() updating;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	ca : CM_Carrier;
	invoiceLineDesc : CM_InvoiceLineDesc;
	aMap : CM_InvoiceLineChargeMapping;
	row :Integer;
	column :Integer;
	count :Integer;
	pd :CMS_Progress;
	ls : Boolean;
	mapTable : Table;
	bank : CM_Bank;
	dict : CM_CarrierByCodeDict;
begin
	bank := self.myCurrentBank;
	mapTable := self.tblData;

//	TFS 2682	self.setCaption(self.myCurrentBank.code &amp; " Charge Mapping Table - " &amp; self.cmbParentObject.text );

	self.setNavigatorHeading(self.caption);
	
	on CM_ProgressException do haltProgress(exception, ls);

	mapTable.accessCell(1,1).text := "Invoice Line Types/ Carrier";

	create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.setAction("Loading Carrier...");

	app.cmsBeginLoad(ls);

	mapTable.columns := 1;
	mapTable.column := 1;
	mapTable.row := 1;
	mapTable.fixedRows := 1;
	
	dict := app.myRoot.allCarriers;
	column := 1;
	pd.progress.partsInJob := dict.size;
	
	foreach ca  in dict discreteLock do
		if ca.isNotAvailableForEntry then
			continue;
		endif;
		if not global.isValidObject(ca) then
			continue;
		endif;
		
		if self.myCurrentDebtorType.code  =  CM_DebtorType.DT_CARRIER then
			if ca &lt;&gt; self.myCurrentParentObject.CM_Carrier then
				continue;
			endif;
		endif;

		mapTable.columns := mapTable.columns + 1;
		column := mapTable.columns;
		row := 1;
		mapTable.accessCell(row,column).text := ca.description;
		mapTable.accessColumn(column).itemObject := ca;
		foreach invoiceLineDesc in bank.invoiceLineDescriptors discreteLock  where not invoiceLineDesc.isNotAvailableForEntry do
			if invoiceLineDesc.myDebtorType &lt;&gt; self.myCurrentDebtorType then
				continue;
			endif;
			row := row + 1;
			aMap := bank.allInvLineChargeMappings[invoiceLineDesc, self.myCurrentParentObject, ca];
			
			if aMap = null then
				mapTable.accessCell(row,column).text := invoiceLineDesc.myDebtorType.description;
				mapTable.accessedCell.fontBold := false;
				mapTable.accessedCell.foreColor := DarkGray;
				mapTable.accessedCell.itemObject := null;
			else
				mapTable.accessCell(row,column).text := aMap.myDebtorType.description; 
				mapTable.accessedCell.fontBold := true;
				mapTable.accessedCell.foreColor := Black;
				mapTable.accessedCell.itemObject := aMap;
			
			endif;
		endforeach;

		count := count + 1;
		pd.progress.partsDone := count;
		app.doWindowEvents(0);
	endforeach;
	
	
	mapTable.row := 1;
	mapTable.column := 1;

	self.setEnableObjects();
	if mapTable.columns &gt; 1 then
		mapTable.accessColumn(2).width := 100;
	endif;
epilog
	app.cmsEndLoad(ls);
	delete pd;

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryDebtorType" id="61cc12b8-3819-49fc-83cc-110944b3cf46">
        <updating/>
        <source>doQueryDebtorType() updating;
// ---------------------------------------------------------------------------
// Created:     July 2008 ANDREW BISHOP
//
// Purpose:      // PAR 17557
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	invoiceLineDesc : CM_InvoiceLineDesc;
	aMap : CM_InvoiceLineChargeMapping;
	theDT : CM_DebtorType;
	theDebtor : CM_Debtor;
	row :Integer;
	column :Integer;
	count :Integer;
	pd :CMS_Progress;
	ls : Boolean;
	mapTable : Table;
	bank : CM_Bank;
begin
	bank := self.myCurrentBank;
	mapTable := self.tblData;
	
	theDT := self.cmbChargeTypeCom.listObject.CM_DebtorType;
	
//	TFS 2682	self.setCaption(self.myCurrentBank.code &amp; " Charge Mapping Table - " &amp; self.cmbParentObject.text );

	self.setNavigatorHeading(self.caption);
	
	on CM_ProgressException do haltProgress(exception, ls);

	mapTable.accessCell(1,1).text := "Invoice Line Types/ " &amp; theDT.description;

	create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.setAction("Loading " &amp; theDT.description &amp; "...");

	app.cmsBeginLoad(ls);

	mapTable.columns := 1;
	mapTable.column := 1;
	mapTable.row := 1;
	mapTable.fixedRows := 1;
	
	column := 1;
	pd.progress.partsInJob := theDT.allDebtors.size;
	
	foreach theDebtor in theDT.allDebtors discreteLock do
		count := count + 1;
		pd.progress.partsDone := count;
		app.doWindowEvents(0);

		if theDebtor.isSuspended then
			continue;
		endif;
		
		mapTable.columns := mapTable.columns + 1;
		column := mapTable.columns;
		row := 1;
		mapTable.accessCell(row,column).text := theDebtor.name;
		mapTable.accessColumn(column).itemObject := theDebtor;
		foreach invoiceLineDesc in bank.invoiceLineDescriptors discreteLock where not invoiceLineDesc.isNotAvailableForEntry do
			if invoiceLineDesc.myDebtorType &lt;&gt; self.myCurrentDebtorType then //CP CCMS 1047 PAR 16666 cnwgb1 18 April 2008
				continue;
			endif;
			row := row + 1;
			aMap := bank.allInvLineChargeMappings[invoiceLineDesc, self.myCurrentParentObject, theDebtor];
			
			if aMap = null then
				mapTable.accessCell(row,column).text := invoiceLineDesc.myDebtorType.description; //CP CCMS 1047 PAR 16666 cnwgb1 18 April 2008
				mapTable.accessedCell.fontBold := false;
				mapTable.accessedCell.foreColor := DarkGray;
				mapTable.accessedCell.itemObject := null;
			else
				mapTable.accessCell(row,column).text := aMap.myDebtorType.description; //CP CCMS 1047 PAR 16666 cnwgb1 18 April 2008
				mapTable.accessedCell.fontBold := true;
				mapTable.accessedCell.foreColor := Black;
				mapTable.accessedCell.itemObject := aMap;
			
			endif;
		endforeach;

	endforeach;
	
	
	mapTable.row := 1;
	mapTable.column := 1;

	self.setEnableObjects();
	mapTable.accessColumn(2).width := 100;
epilog
	app.cmsEndLoad(ls);
	delete pd;

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryFF" id="bdf2c60c-d749-4c44-9a4f-8395514b8015">
        <updating/>
        <source>doQueryFF(_ff, _cr, _ce : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     July 2008 ANDREW BISHOP
//
// Purpose:      // PAR 17557
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	aCon : CM_ConsigneeConsignor;
	invoiceLineDesc : CM_InvoiceLineDesc;
	aMap : CM_InvoiceLineChargeMapping;
	row :Integer;
	column :Integer;
	count :Integer;
	pd :CMS_Progress;
	ls : Boolean;
	mapTable : Table;
	bank : CM_Bank;
	theDT : CM_DebtorType;
begin
	bank := self.myCurrentBank;
	mapTable := self.tblData;
	theDT := self.cmbChargeTypeCom.listObject.CM_DebtorType;

//	TFS 2682	self.setCaption(self.myCurrentBank.code &amp; " Charge Mapping Table - " &amp; self.cmbParentObject.text );

	self.setNavigatorHeading(self.caption);
	
	on CM_ProgressException do haltProgress(exception, ls);

	mapTable.accessCell(1,1).text := "Invoice Line Types/ " &amp; theDT.description;

	create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.setAction("Loading " &amp; theDT.description &amp; "...");

	app.cmsBeginLoad(ls);

	mapTable.columns := 1;
	mapTable.column := 1;
	mapTable.row := 1;
	mapTable.fixedRows := 1;
	
	column := 1;
	pd.progress.partsInJob := app.myRoot.allConsigneeConsignors.size;
	
	foreach aCon in app.myRoot.allConsigneeConsignors discreteLock do
		count := count + 1;
		pd.progress.partsDone := count;
		app.doWindowEvents(0);

		if aCon.isNotAvailableForEntry then
			continue;
		endif;
		if _ff and not aCon.isFreightFwdr then
			continue;
		elseif _cr and not aCon.isConsignor then
			continue;
		elseif _ce and not aCon.isConsignee then
			continue;
		endif;
		

		mapTable.columns := mapTable.columns + 1;
		column := mapTable.columns;
		row := 1;
		mapTable.accessCell(row,column).text := aCon.description;
		mapTable.accessColumn(column).itemObject := aCon;
		foreach invoiceLineDesc in bank.invoiceLineDescriptors discreteLock  where not invoiceLineDesc.isNotAvailableForEntry do
			if invoiceLineDesc.myDebtorType &lt;&gt; self.myCurrentDebtorType then //CP CCMS 1047 PAR 16666 cnwgb1 18 April 2008
				continue;
			endif;
			row := row + 1;
			aMap := bank.allInvLineChargeMappings[invoiceLineDesc, self.myCurrentParentObject, aCon];
			
			if aMap = null then
				mapTable.accessCell(row,column).text := invoiceLineDesc.myDebtorType.description; //CP CCMS 1047 PAR 16666 cnwgb1 18 April 2008
				mapTable.accessedCell.fontBold := false;
				mapTable.accessedCell.foreColor := DarkGray;
				mapTable.accessedCell.itemObject := null;
			else
				mapTable.accessCell(row,column).text := aMap.myDebtorType.description; //CP CCMS 1047 PAR 16666 cnwgb1 18 April 2008
				mapTable.accessedCell.fontBold := true;
				mapTable.accessedCell.foreColor := Black;
				mapTable.accessedCell.itemObject := aMap;
			
			endif;
		endforeach;

	endforeach;
	
	
	mapTable.row := 1;
	mapTable.column := 1;

	self.setEnableObjects();
	mapTable.accessColumn(2).width := 100;
epilog
	app.cmsEndLoad(ls);
	delete pd;

end;</source>
        <Parameter name="_ff" type="Boolean"/>
        <Parameter name="_cr" type="Boolean"/>
        <Parameter name="_ce" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQueryOperator" id="c31afe20-0fbd-4cca-a784-4613cdbdbcd8">
        <updating/>
        <source>doQueryOperator() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
// ---------------------------------------------------------------------------
