    <JadeMethod name="pxyCreateUpdateProxy" id="a2af0d71-8a4e-4ad9-b8cf-da21f45e41bb">
        <source>pxyCreateUpdateProxy(): SelfType;

// cnwdvb1 23 October 2002 
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	pxyAllocation : CM_StockOrderAllocation;
	completedOK		: Boolean;
	
begin
	
	pxyAllocation := inheritMethod();
	pxyAllocation.myLocationsController := self.myLocationsController;
	pxyAllocation.mySOHLocation			:= self.mySOHLocation;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyAllocation;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyAllocation;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="87340bea-eadf-4fcb-802f-7e6049530d6f">
        <updating/>
        <source>setForCreate(_pxyAllocation : CM_StockOrderAllocation) updating;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.setForUpdate(_pxyAllocation);
end;</source>
        <Parameter name="_pxyAllocation" type="CM_StockOrderAllocation"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="14e25362-7b8b-4ecc-9ad0-7cfcb2bcf652">
        <updating/>
        <source>setForUpdate(_pxyAllocation : CM_StockOrderAllocation) updating;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	_pxyAllocation.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.allocQuantity 			:= _pxyAllocation.allocQuantity;
	self.allocTypeString 		:= _pxyAllocation.allocTypeString;
	self.myLocationsController 	:= _pxyAllocation.myLocationsController;
	self.mySOHLocation			:= _pxyAllocation.mySOHLocation;
		
end;</source>
        <Parameter name="_pxyAllocation" type="CM_StockOrderAllocation"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_StockOrderAlloc" id="8ec38afc-4c2f-4ac2-8ca6-0705bb7d55dc">
        <updating/>
        <source>setFromCMIF_StockOrderAlloc(_cmif : CMIF_StockOrderAllocation) updating;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.allocTypeString 		:= _cmif.allocTypeStr;
	self.myLocationsController 	:= _cmif.mySOHLocation.myLocationsController;
	self.mySOHLocation 			:= _cmif.mySOHLocation;
	
	if self.allocType = self.AllocType_Quantity then
		self.allocQuantity := _cmif.allocAmount;
	else
		self.allocQuantity := 0;	
	endif;

end;</source>
        <Parameter name="_cmif" type="CMIF_StockOrderAllocation"/>
    </JadeMethod>
