    <JadeMethod name="isDifferentForBayPlanMerge" id="933e1e4d-ae6e-41a9-9a84-b730e8ebe614">
        <source>isDifferentForBayPlanMerge(_toTI : CM_Container): Boolean;
//----------------------------------------------------------------
//	Created:	14 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 24/09/2012	cnwmh5	#30408 - Add the overdimension checking.
vars

begin

	if self.isoType &lt;&gt; _toTI.isoType then
		return true;
	elseif self.getTemperature &lt;&gt; _toTI.getTemperature then
		return true;
		//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNum'
	elseif self.getSealNum &lt;&gt; _toTI.getSealNum then
		return true;
	elseif self.overHeight &lt;&gt; _toTI.overHeight then
		return true;
	elseif self.overLengthFront &lt;&gt; _toTI.overLengthFront then
		return true;
	elseif self.overLengthRear &lt;&gt; _toTI.overLengthRear then
		return true;
	elseif self.overWidthLeft &lt;&gt; _toTI.overWidthLeft then
		return true;
	elseif self.overWidthRight &lt;&gt; _toTI.overWidthRight then
		return true;
	else
		return inheritMethod(_toTI);
	endif;
	
	
end;</source>
        <Parameter name="_toTI" type="CM_Container"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
