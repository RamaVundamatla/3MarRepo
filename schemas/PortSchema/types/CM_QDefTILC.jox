    <JadeMethod name="createProperties" id="687eee06-9b2b-44a5-b5f9-7b135b8a1143">
        <source>createProperties();
//19 November 2009	cnwml2
//+cnwml2 MSL CCMS 1027
//Date		    Who		    Reason
//27.May.2025   navsp1      JIRA-34864 CUX | Data Access Groups for MAFIs and Trailers - Development
vars
	tmpProp		: CM_QueryProperty;

begin
	inheritMethod();
	
	create tmpProp as CM_QDateProperty persistent;
	tmpProp.set('Off-Hire Date', CM_TILC::offHireDate.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QDateProperty persistent;
	tmpProp.set('On-Hire Date', CM_TILC::onHireDate.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	// 03/04/2014 cnwar2 #33799
	create tmpProp as CM_QAvailabilityGradeProperty persistent;
	tmpProp.set('Availability Grade', CM_TILC::availabilityGrade.name, self.className);
	tmpProp.allocationAttribute := YACriteriaType_AvGrade;
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//jlier1 TFS 54700 31/8/22
	create tmpProp as CM_QContentsStatusLookup persistent;
	tmpProp.set('Contents Status', 'contentsStatus', self.className);
	tmpProp.allocationAttribute := YACriteriaType_ContentsStatus;
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QTrailerCategoryMethod persistent;
	tmpProp.set('Chassis Category', CM_TILC::getTrailerCategory.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	///////////////////////////////////////// START ////////////////////////////////////////////////
	// 20/01/2024 navcs2 MTN-33832 CUX | Selector queries based on Onboard fields - changes required
	////////////////////////////////////////////////////////////////////////////////////////////////
	
	create tmpProp as CM_QStrCargoTypesOnboard persistent;
	tmpProp.set('Onboard Cargo Types', CM_TILC::getOnboardCargoTypes.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrCargoSubTypesOnboard persistent;
	tmpProp.set('Onboard Cargo Subtypes', CM_TILC::getOnboardSubTypes.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrConsignMethod persistent;
	tmpProp.CM_QStrConsignMethod.setType(CONSIGNEE);
	tmpProp.set('Onboard Consignee', CM_TILC::getOnboardConsignee.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrConsignMethod persistent;
	tmpProp.CM_QStrConsignMethod.setType(CONSIGNOR);
	tmpProp.set('Onboard Consignor', CM_TILC::getOnboardConsignor.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Onboard Damage', CM_TILC::getOnboardDamagedBool.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Onboard Is Hazardous', CM_TILC::getOnboardHazardousBool.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Onboard Hazard Detail', CM_TILC::getOnboardHazDetails.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Onboard Is Reefer', CM_TILC::getOnboardReeferBool.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrConsignMethod persistent;
	tmpProp.CM_QStrConsignMethod.setType(FREIGHT_FORWARDER);
	tmpProp.set('Onboard Freight Forwarder', CM_TILC::getOnboardFreightForwarder.name, self.className);
	tmpProp.allocationAttribute := YACriteriaType_FreightForward;
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Onboard Stops', CM_TILC::getOnboardHasStopsBool.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrCommodityMethod persistent;
	tmpProp.set('Onboard Commodity', CM_TILC::getOnboardCommodities.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QStrISOTypeOnboardMethod persistent;
	tmpProp.set('Onboard Iso Types', CM_TILC::getOnboardISOTypes.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrContentStatusMethod persistent;
	tmpProp.set('Onboard Contents Status', CM_TILC::getOnboardContentStatusDesc.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	/////////////////////////////////////////// END ////////////////////////////////////////////////
	//20/01/2024 navcs2 MTN-33832 CUX | Selector queries based on Onboard fields - changes required/
	////////////////////////////////////////////////////////////////////////////////////////////////
	
	create tmpProp as CM_QIntegerProperty persistent;                                                               //JIRA-34864
	tmpProp.set('Onboard Quantity', CM_TILC::getOnboardQuantity.name, self.className);                              //JIRA-34864
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'   //JIRA-34864
	self.allQueryProperties.add(tmpProp);                                                                           //JIRA-34864

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getSelectorVisibleColumns" id="e98db1b6-08c6-44c9-b006-a587fd50ceec">
        <source>getSelectorVisibleColumns(_sa: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2024	jlier1	Initial creation TFS 64054

*/

vars
	qProp	: CM_QueryProperty;
begin
	_sa.clear();

	inheritMethod(_sa);
	
	qProp := self.allQueryProperties[CM_TrackedItem::cargoType.name]; //cargo type
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;

	//trailer type
	qProp := self.allQueryProperties[CM_TrackedItem::getMyTILCType.name]; 
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	//operator 
	qProp := self.allQueryProperties[CM_TrackedItem::operatorCode.name]; 
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	//location
	qProp := self.allQueryProperties[CM_TrackedItem::locationId.name]; 
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;

epilog

end;</source>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
</Class>
