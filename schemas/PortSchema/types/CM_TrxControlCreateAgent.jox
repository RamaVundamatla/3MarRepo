    <JadeMethod name="trxCopyInvoiceLine" id="13e787ac-0936-4ae9-be26-cf134ad8b50b">
        <updating/>
        <source>trxCopyInvoiceLine(	_cmifInvoiceLine		: CMIF_InvoiceLineCopy io;
					_passport 			: CM_Passport input
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2023  navmv20 TFS 55304 Task 55542: Jade - Invoice Line Copy Jade Code

*/

vars
	pxyInvoiceLine,
	newInvoiceLine	: CM_InvoiceLine;
	allInvLines     : CM_InvoiceLineSet;
	allTrackedItems : CM_TIArray;
	trackedItem     : CM_TrackedItem;
	newInvoice      : CM_Invoice;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	if _cmifInvoiceLine.newInvoice then
		app.myUtilityCA.utlCreateInvoiceManual(_cmifInvoiceLine.pxyInvoice, newInvoice, app.myPassport);
		_cmifInvoiceLine.myInvoice := newInvoice;
		
		if (not self.checkValidationWithPassport(_passport)) then
			return;
		endif;
	endif;
	foreach pxyInvoiceLine in _cmifInvoiceLine.allSelectedInvoiceLines as CM_InvoiceLine do
		app.myUtilityCA.utlCreateInvLineManualCopy(_cmifInvoiceLine,pxyInvoiceLine, app.myPassport);
		
		if (not self.checkValidationWithPassport(_passport)) then
			return;
		endif;
	endforeach;
	
epilog
	self.finaliseActivityWithPassport(_passport);
	delete allInvLines;
end;</source>
        <Parameter name="_cmifInvoiceLine" type="CMIF_InvoiceLineCopy" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
