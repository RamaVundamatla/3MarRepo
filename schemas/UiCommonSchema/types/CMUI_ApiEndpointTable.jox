<GUIClass name="CMUI_ApiEndpointTable" id="0351a1c9-7323-415b-b6db-8739dadadc02">
    <superclass name="Table"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <Constant name="ColumnMethod" id="8c1643aa-b531-4565-aa2d-cbe4dc241d78">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="ColumnSpacer" id="974e088a-18d2-424c-8c39-8739dd28412b">
