    <JadeMethod name="setProxyForStaging" id="0c722033-95db-4cf7-aa4c-f8e10a2967de">
        <updating/>
        <source>setProxyForStaging(_reserveDetail : CM_ReserveDetail; _isForPicking : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Jul 2021	jlier1	Initial creation TFS 51626
22 Dec 2023	navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
13 Mar 2024	navma1  Bug 62928: EUP - Demo - Pack Load By Request Froze During Cargo Display for User Selection
05 Mar 2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
*/

vars
	allStagedLCs : CM_LCSet;
	tiSet 		 : CM_TISet;
	firstLC 	 : CM_LocationsController;
	productCode  : String;
	bulkRelease	 : CM_BulkRelease;
	context		 : String;
begin

	bulkRelease := _reserveDetail.myReserveHeader;
	context		:= bulkRelease.context;											//13.03.2023 navma1	#62928
	
	if not _reserveDetail.myReserveHeader.type = BR_TYPE_SHIP then				//22.12.2023 navhl20 #61092[61621]
		self.amountLoaded :=	_reserveDetail.getTotalLoadedDisplay();
	else
		self.amountLoaded :=_reserveDetail.getTotalReleasedDisplay();
	endif;
	
	self.amountPacked		:=_reserveDetail.getTotalPackedDisplay();
	self.amountStaged		:=_reserveDetail.getTotalStagedDisplay();
	self.packingType		:=_reserveDetail.packType;
	self.isFullyLoaded		:=_reserveDetail.isFullyLoaded();
	self.isFullyPacked	  	:=_reserveDetail.isFullyPacked();
	self.isStagingComplete	:=_reserveDetail.isStagingComplete();
	self.detailDescription  :=_reserveDetail.getCargoTypeAbbrev;
	productCode				:=_reserveDetail.getProductCode;
	
	if productCode &lt;&gt; null then
		self.detailDescription:=self.detailDescription &amp; " / " &amp; productCode;
	endif;
	
	if  context &lt;&gt; RelReqContext_CargoGroupReview then									//13.03.2023 navma1	#62928
		if _reserveDetail.isFullyStaged then
			create allStagedLCs transient;												//05 May 2017	NDL	TFS 4016
			_reserveDetail.getTotalStaged( null, firstLC, allStagedLCs );
		
			self.locationSummary := allStagedLCs.getFullId(", ");
		else
			if _isForPicking then		// MTN-34024
				create tiSet transient;
				self.locationSummary := _reserveDetail.getStagingLocationSummary(tiSet, firstLC);
			endif;
		endif;  
	endif;
	
	self.cargoGroupID	:=	_reserveDetail.getMyCargoGroupId();
	
	if self.cargoGroupID = null then
		self.cargoGroupID := _reserveDetail.getCargoID();
	endif;
		
epilog
	delete allStagedLCs;
	delete tiSet;
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <Parameter name="_isForPicking" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="1260bd34-95a4-468b-a7a6-d56fd94c81d2">
        <updating/>
        <source>setProxyFromObject(reserveDetail : CM_ReserveDetail) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 12 July 2019
TFS#		: 45289
Function	:

*** Changes ***
Date		Name	TFS#	Description
16/08/2019	jlgka1	45989	Fixed bug where the WS_ReserveDetail::UpdateDetails 
							is returning the remaining "packed" rather than the remaining to be released.
26/7/21		jlier1	52626	renamed and re-inmplemnted inheritMethod - wanted to be able just to created this object not have to create subclass instances
24/11/2024  navbk1  33415   TPT - Display Cargo group on some mobile apps 
****************************************************/

vars
	
begin
	inheritMethod(reserveDetail);
	self.quantityDescription := reserveDetail.getTotalRequestedDisplay();	
	self.detailDescription	 := reserveDetail.getProductISOTypeDescr();
	self.fullDescription	 := reserveDetail.getDescription();
	self.amountReleased 	 := reserveDetail.getTotalReleasedDisplay();
	//self.remainingRequired	 := reserveDetail.getTotalOutstandingDisplay();  what this should be once remaining required is changed to string max
	//epr TFS 45287 16/8/19
	self.remainingRequired	:= reserveDetail.getTotalOutstandingDisplay(); 	
	self.cargoGroupID := reserveDetail.getMyCargoGroupId();										//24/11/2024 navbk1 #33415
	
end;</source>
        <Parameter name="reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="setProxyRoadReserveSummary" id="7755ab2b-797e-4992-92cc-7968360bb7be">
        <updating/>
        <source>setProxyRoadReserveSummary(_reserveDetail : CM_ReserveDetail) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Apr 2025	navma1	MTN-34595 	DPH - Release Staging – Improve Performance of getRoadReleaseSummary() API
*/

vars

begin
	self.setOidDetails(_reserveDetail);
	
	self.quantityDescription := _reserveDetail.getTotalRequestedDisplay();	
	self.detailDescription	 := _reserveDetail.getProductISOTypeDescr();
	self.fullDescription	 := _reserveDetail.getDescription();
	self.amountReleased 	 := _reserveDetail.getTotalReleasedDisplay();
	self.remainingRequired	 := _reserveDetail.getTotalOutstandingDisplay(); 	
	self.cargoGroupID 		 := _reserveDetail.getMyCargoGroupId();		
epilog

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
</Class>
