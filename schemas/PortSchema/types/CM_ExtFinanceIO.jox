    <JadeMethod name="writeCashPaymentsToFile" id="2efb3e42-ab51-4f53-91cd-7126d175ce80">
        <source>writeCashPaymentsToFile(_file: File input; _receipt : CM_CashReceipt);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jun 2019	jlgsl4	TFS 44265 - JMT - Cash Export JMT Default
20 Sep 2019 cnwma1	Bug 46586: New Cash collection form showing Tax codes rather than Description
*/
constants
	FIELD_DELIMITER = ",";
vars
	cashPayment : CM_CashPayment;
	exportLine, carrier, driver, extInvoiceNumber,
	sequenceNumber, proformaRemarks, voyageCode,
	proformaDescription : String;
begin
	foreach cashPayment in _receipt.allCashPayments discreteLock do
		carrier := null; // output required payment fields; pre-process fields where references might be null
		if cashPayment.myCarrier &lt;&gt; null then
			carrier := cashPayment.myCarrier.code;
		endif;
		driver := null;
		if cashPayment.myDriver &lt;&gt; null then
			driver := cashPayment.myDriver.code;
		endif;
		extInvoiceNumber := null;
		if cashPayment.myInvoice &lt;&gt; null then
			extInvoiceNumber := cashPayment.myInvoice.getExternalInvoiceNumber();
		endif;
		sequenceNumber := null;
		if cashPayment.myInvoiceLine &lt;&gt; null then
			sequenceNumber := cashPayment.myInvoiceLine.sequenceNum.asStringJMT();
		endif;
		proformaRemarks := null;
		proformaDescription := cashPayment.proformaDesc.removeTabCrLfs();
		if cashPayment.myProformaDetail &lt;&gt; null then
			proformaRemarks := cashPayment.myProformaDetail.remarks.removeTabCrLfs();
		endif;
		voyageCode := null;
		if cashPayment.myVoyage &lt;&gt; null then
			voyageCode := cashPayment.myVoyage.code;
		endif;
		exportLine := cashPayment.getDateTimeLocalTZ().asStringJMT &amp; FIELD_DELIMITER &amp;
			cashPayment.cashValue.asStringJMT &amp; FIELD_DELIMITER &amp;
			cashPayment.isMinimumCharge.asStringJMT() &amp; FIELD_DELIMITER &amp;
			cashPayment.manual.asStringJMT() &amp; FIELD_DELIMITER &amp;
			carrier &amp; FIELD_DELIMITER &amp;
			cashPayment.myCashReceipt.getExternalInvoiceNumber() &amp; FIELD_DELIMITER &amp;
			cashPayment.myCashReceipt.externalReceiptNumber.asStringJMT() &amp; FIELD_DELIMITER &amp;
			cashPayment.myDebtorTerminal.myDebtor.name &amp; FIELD_DELIMITER &amp;
			driver &amp; FIELD_DELIMITER &amp;
			extInvoiceNumber &amp; FIELD_DELIMITER &amp;
			sequenceNumber &amp; FIELD_DELIMITER &amp;
			'"' &amp; proformaRemarks &amp; '"' &amp; FIELD_DELIMITER &amp;
			cashPayment.getMyTerminal().code &amp; FIELD_DELIMITER &amp;
			cashPayment.myTrackedItem.id &amp; FIELD_DELIMITER &amp;
			cashPayment.myUser.code &amp; FIELD_DELIMITER &amp;
			voyageCode &amp; FIELD_DELIMITER &amp;
			'"' &amp; proformaDescription &amp; '"' &amp; FIELD_DELIMITER &amp;
			'"' &amp; cashPayment.getStatusDescription(cashPayment.status) &amp; '"' &amp; FIELD_DELIMITER &amp;
			cashPayment.getTaxAmountForPayment().asStringJMT() &amp; FIELD_DELIMITER &amp;
			'"' &amp; cashPayment.getStatusDescription(cashPayment.status) &amp; '"' &amp; FIELD_DELIMITER &amp;
			cashPayment.getTaxCodeForPayment(false).asStringJMT() &amp; FIELD_DELIMITER &amp;              // 20.09.2019.cnwma1 #46586
			'"' &amp; cashPayment.getStatusDescription(cashPayment.status) &amp; '"' &amp; FIELD_DELIMITER &amp;
			cashPayment.getTaxRateForPayment().asStringJMT();
		_file.writeLine(exportLine);
	endforeach;
epilog

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_receipt" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="writeCreditLinesToFile" id="37f9f03e-7653-46ad-ad54-4764019820ca">
        <source>writeCreditLinesToFile(_file: File input; _credit: CM_CashCredit; _totalAmount: Decimal) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Jun 2019	jlgsl4	TFS 44265 - JMT - Cash Export JMT Default
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/
vars
	cashCreditDetail : CM_CashCreditDetail;
	exportLine,
	receiptNo        : String;
begin
	foreach cashCreditDetail in _credit.allDerivedFromCreditDetails discreteLock do
		receiptNo := "";
		if  cashCreditDetail.myCashPayment.myCashReceipt &lt;&gt; null then
			receiptNo := cashCreditDetail.myCashPayment.myCashReceipt.externalInvoiceNumber;
		endif;
		
		exportLine := cashCreditDetail.getDateTimeLocalTZ().asStringJMT() 				&amp; Comma &amp;
					  cashCreditDetail.cashValue.asStringJMT()			  				&amp; Comma &amp;
					  Space			 								 	 				&amp; Comma &amp;   //17.10.2019 cnwma1 TFS #46984
					  Space											 	  				&amp; Comma &amp;   //17.10.2019 cnwma1 TFS #46984
					  receiptNo;	
		
		_file.writeLine(exportLine);
	endforeach;
	
	foreach cashCreditDetail in _credit.allAppliedToCreditDetails discreteLock do
		
		receiptNo := "";
		if  cashCreditDetail.myCashPayment.myCashReceipt &lt;&gt; null then
			receiptNo := cashCreditDetail.myCashPayment.myCashReceipt.externalInvoiceNumber;
		endif;
		
		exportLine := cashCreditDetail.getDateTimeLocalTZ().asStringJMT() 				&amp; Comma &amp;
					(-cashCreditDetail.cashValue).asStringJMT() 		  				&amp; Comma &amp; // sum of derived and applied cash values should be 0
					Space									 			  				&amp; Comma &amp; //17.10.2019 cnwma1 TFS #46984
					Space										 		  				&amp; Comma &amp; //17.10.2019 cnwma1 TFS #46984
					receiptNo;	
					
		_file.writeLine(exportLine);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_credit" type="CM_CashCredit"/>
        <Parameter name="_totalAmount" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="writeHeaderCreditToFile" id="3c2c45e7-6328-4754-90d9-d3be590b14e3">
        <source>writeHeaderCreditToFile(_file : File input; _credit : CM_CashCredit);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jun 2019	jlgsl4	TFS 44265 - JMT - Cash Export JMT Default
*/

vars
	bank, 
	debtor,
	exportHeader : String;
begin
	if _credit.myBank &lt;&gt; null then
		bank := _credit.myBank.code;
	endif;
	if _credit.myDebtorTerminal &lt;&gt; null then
		debtor := _credit.myDebtorTerminal.myDebtor.name;
	endif;
	exportHeader := _credit.getDateTimeLocalTZ().asStringJMT() 					&amp; Comma &amp;
	         	    _credit.cashValue.asStringJMT              					&amp; Comma &amp;
		            _credit.comments.removeTabCrLfs()          					&amp; Comma &amp;
		            _credit.exportedCount.asStringJMT()        				 	&amp; Comma &amp;
		            _credit.externalId                                          &amp; Comma &amp;
		            bank                                                        &amp; Comma &amp;
		            debtor                                                      &amp; Comma &amp;
		            _credit.myDerivedFromCashReceipt.getExternalInvoiceNumber() &amp; Comma &amp;
		            _credit.myUser.code 										&amp; Comma &amp;
		            _credit.sequenceNum.asStringJMT;
					
	_file.writeLine(exportHeader);
epilog

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_credit" type="CM_CashCredit"/>
    </JadeMethod>
    <JadeMethod name="writeHeaderRecToFile" id="c5aed1e2-3ed5-42c2-8be7-8e7d1c1c67ae">
        <source>writeHeaderRecToFile(_file: File input; _receipt : CM_CashReceipt);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jun 2019	jlgsl4	TFS 44265 - JMT - Cash Export JMT Default
*/

constants
	FIELD_DELIMITER = ",";
vars
	agent, externalInvoiceNumber,
	paymentMethod, voyageCode,
	workOrder, exportHeader : String;
begin
	// output required _receipt fields; pre-process fields where references might be null
	if _receipt.myAgent &lt;&gt; null then
		if _receipt.myAgent.isA(CM_ConsigneeConsignor) then
			agent := _receipt.myAgent.CM_ConsigneeConsignor.code;
		else // it's a CM_CustomsAgent
			agent := _receipt.myAgent.CM_CustomsAgent.code;
		endif;
	endif;
	if _receipt.getCashInvoice() &lt;&gt; null then
		//externalInvoiceNumber := _receipt.getCashInvoice().externalFinancialId;
		externalInvoiceNumber := _receipt.getCashInvoice().getExternalFinancialId(); //08/12/2025	navkc1 JIRA 36262
	endif;
	if _receipt.getMyPaymentMethod() &lt;&gt; null then
		paymentMethod := _receipt.getMyPaymentMethod().code;
	endif;
	if _receipt.myVoyage &lt;&gt; null then
		voyageCode := _receipt.myVoyage.code;
	endif;
	if _receipt.myWorkOrder &lt;&gt; null then
		workOrder := _receipt.myWorkOrder.id;
	endif;
	exportHeader := _receipt.getDateTimeLocalTZ().asStringJMT() &amp; FIELD_DELIMITER &amp;
		_receipt.cashValue.asStringJMT &amp; FIELD_DELIMITER &amp;
		_receipt.cashAllocationRequired.asStringJMT() &amp; FIELD_DELIMITER &amp;
		_receipt.cashAlreadyAllocated.asStringJMT() &amp; FIELD_DELIMITER &amp;
		_receipt.cashId1 &amp; FIELD_DELIMITER &amp;
		_receipt.cashId2 &amp; FIELD_DELIMITER &amp;
		_receipt.cashId3 &amp; FIELD_DELIMITER &amp;
		_receipt.cashId3 &amp; FIELD_DELIMITER &amp;
		_receipt.cashPayment1.asStringJMT() &amp; FIELD_DELIMITER &amp;
		_receipt.cashPayment2.asStringJMT() &amp; FIELD_DELIMITER &amp;
		_receipt.chequeBank &amp; FIELD_DELIMITER &amp;
		_receipt.chequeBranch &amp; FIELD_DELIMITER &amp;
		_receipt.chequeDate.asStringJMT() &amp; FIELD_DELIMITER &amp;
		_receipt.chequeNumber &amp; FIELD_DELIMITER &amp;
		_receipt.effectiveDate.asStringJMT() &amp; FIELD_DELIMITER &amp;
		_receipt.exportedCount.asStringJMT() &amp; FIELD_DELIMITER &amp;
		_receipt.getExternalInvoiceNumber() &amp; FIELD_DELIMITER &amp;
		_receipt.externalReceiptNumber &amp; FIELD_DELIMITER &amp;
		agent &amp; FIELD_DELIMITER &amp;
		_receipt.getBankCode() &amp; FIELD_DELIMITER &amp;
		externalInvoiceNumber &amp; FIELD_DELIMITER &amp;
		_receipt.myDebtorTerminal.myDebtor.name &amp; FIELD_DELIMITER &amp;
		paymentMethod &amp; FIELD_DELIMITER &amp;
		_receipt.getMyTerminal().code &amp; FIELD_DELIMITER &amp;
		_receipt.myUser.code &amp; FIELD_DELIMITER &amp;		
		voyageCode &amp; FIELD_DELIMITER &amp;
		workOrder &amp; FIELD_DELIMITER &amp;
		_receipt.getPaymentStatusStr(_receipt.paymentStatus) &amp; FIELD_DELIMITER &amp;
		_receipt.getPaymentType().asStringJMT() &amp; FIELD_DELIMITER &amp;
		_receipt.sequenceNum.asStringJMT() &amp; FIELD_DELIMITER &amp;
		_receipt.getShipReleaseDate().asStringJMT() &amp; FIELD_DELIMITER &amp;
		_receipt.taxCode1 &amp; FIELD_DELIMITER &amp;
		_receipt.taxCode2 &amp; FIELD_DELIMITER &amp;
		_receipt.taxCode3 &amp; FIELD_DELIMITER &amp;
		_receipt.taxValue1.asStringJMT() &amp; FIELD_DELIMITER &amp;
		_receipt.taxValue2.asStringJMT() &amp; FIELD_DELIMITER &amp;
		_receipt.taxValue3.asStringJMT();
	_file.writeLine(exportHeader);
epilog

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_receipt" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="writeLineAsUTF8" id="f60dffcc-f8c8-4781-bba8-ee45a4b0bbac">
        <source>writeLineAsUTF8(_file : File; _line : String);
// 25113
vars

begin
	_file.writeBinary((_line &amp; CrLf).encodeUTF8());
end;
</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_line" type="String"/>
    </JadeMethod>
</Class>
