    <JadeMethod name="getXMLSettingsForSave" id="db137b36-83ca-4504-b14e-03d53a6adfa9">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theXML, localXML : String;
	value : String;
	idx, type : Integer;
begin
	theXML := inheritMethod();

	foreach idx in 1 to 4 do
		type := self.tblData.accessCell(idx, self.TblCol_Type).text.Integer;
		value := self.tblData.accessCell(idx, self.TblCol_Tick).text.Integer.String;
		localXML := localXML &amp; 
			global.formatAsXML("OPT" &amp; idx.String, type.String) &amp;
			global.formatAsXML("VAL" &amp; idx.String, value);
	
	endforeach;

	theXML := theXML &amp; localXML;
	
	theXML := theXML &amp; global.formatAsXML("ROWS" ,self.txtRows.text);
	theXML := theXML &amp; global.formatAsXML("POS" ,self.txtHeight.text);
	theXML := theXML &amp; global.formatAsXML("ENDS" ,self.chkRowEnd.value.Integer.String);
	theXML := theXML &amp; global.formatAsXML("WGHTS" ,self.chkUseWieights.value.Integer.String);
	theXML := theXML &amp; global.formatAsXML("COLS" ,self.chkColReversed.value.Integer.String);
	theXML := theXML &amp; global.formatAsXML("NOPLN" ,self.chkNoPlanIfStops.value.Integer.String);
	theXML := theXML &amp; global.formatAsXML("CRSONE" ,self.optCrossTermOne.value.Integer.String);
	theXML := theXML &amp; global.formatAsXML("CRSCOL" ,self.optCrossTermCol.value.Integer.String);
	theXML := theXML &amp; global.formatAsXML("WPC" ,self.txtPC.text);
	theXML := theXML &amp; global.formatAsXML("IGWRN" ,self.chkIgnoreWarning.value.Integer.String); // PAR 16606
	theXML := theXML &amp; global.formatAsXML("TWIN" ,self.chkTwinPlan.value.Integer.String);

	return theXML;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="c9ee34db-6aee-4914-afb5-64521de5971c">
        <source>getXMLSettingsForSetup();
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	idx : Integer;
begin
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, true);
	endif;

	theXML := userWindow.xmlInfo;

	foreach idx in 1 to 4 do

		theXMLValue := theXML.cnEcGetTagValueOfName("OPT" &amp; idx.String);
		if theXMLValue.Integer &gt; 0 then
			self.allOptions[idx] := theXMLValue.Integer;
			theXMLValue := theXML.cnEcGetTagValueOfName("VAL" &amp; idx.String);
			self.allValues[idx] := theXMLValue.Integer.Boolean;
		endif;
	endforeach;
	
	theXMLValue := theXML.cnEcGetTagValueOfName("ROWS" );
	self.txtRows.text := theXMLValue;
	
	theXMLValue := theXML.cnEcGetTagValueOfName("POS" );
	self.txtHeight.text := theXMLValue;

	theXMLValue := theXML.cnEcGetTagValueOfName("ENDS" );
	self.chkRowEnd.value := theXMLValue.Integer.Boolean;
	
	theXMLValue := theXML.cnEcGetTagValueOfName("WGHTS" );
	self.chkUseWieights.value := theXMLValue.Integer.Boolean;
	
	theXMLValue := theXML.cnEcGetTagValueOfName("IGWRN" ); // PAR 16606
	self.chkIgnoreWarning.value := theXMLValue.Integer.Boolean; // PAR 16606
		
	theXMLValue := theXML.cnEcGetTagValueOfName("COLS" );
	self.chkColReversed.value := theXMLValue.Integer.Boolean;

	theXMLValue := theXML.cnEcGetTagValueOfName("NOPLN" );
	self.chkNoPlanIfStops.value := theXMLValue.Integer.Boolean;

	theXMLValue := theXML.cnEcGetTagValueOfName("CRSCOL" );
	self.optCrossTermCol.value := theXMLValue.Integer.Boolean;

	theXMLValue := theXML.cnEcGetTagValueOfName("CRSONE" );
	self.optCrossTermOne.value := theXMLValue.Integer.Boolean;

	theXMLValue := theXML.cnEcGetTagValueOfName("WPC" );
	self.txtPC.text := theXMLValue;
	
	theXMLValue:=theXML.cnEcGetTagValueOfName("TWIN");
	self.chkTwinPlan.value:= theXMLValue.Integer.Boolean; 
end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="bd3fd2ab-24b7-436d-aa9e-bfc4115844f5">
        <updating/>
        <source>init(_weight : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		06 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.myController.init(self.myTerminal, self.mode, self.allJobs, self.myCurrentJS, self.myCurrentVoyage, false, null, null, null, null, self,false,null,null, false,false, false,false );
	self.myController.initQuery();
	self.setYardAreaFlipped();
	self.chkSplitTopHight.value := self.myTerminal.getConfig(AutoLoadPlanAt3Height).Boolean;
	if _weight then
		self.getAverageWeight();
	endif;
	self.doDisplayStatus(null);
end;</source>
