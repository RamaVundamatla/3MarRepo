    <JadeMethod name="tblTasks_contextMenu" id="9726b554-7f8f-416f-8beb-3b2104b68ef9">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTasks_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwndl1	Initial creation

*/

vars

begin

	if not self.wasCalledViaContext(false) then
		return false;
	endif;

	// we only want to show these contexts if we started at the enquiry form.

	return buildContextMenu(table, conwin, mouse, x, y);

epilog

end;</source>
