//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx	: Integer;
begin
	
	cmbLocation.clear;
	
	idx := cmbLocation.addItem(self.myTerminal.name);
