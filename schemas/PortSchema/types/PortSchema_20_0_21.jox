    <JadeMethod name="updateWorkPointandType" id="51f4f5ca-8165-4272-8a91-7d7e4f441cf7">
        <source>updateWorkPointandType(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2023	navhl20	ChangeRequest 57712:[54558] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars
	terminal 			: CM_Terminal;
	workPointType,
 	pxyWorkPointType	: CM_WorkPointType;
	workPoint			: CM_WorkPoint;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Update Work Point ", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Update Work Point ") ;	
	endif;
	
	beginTransaction;
	
	foreach terminal in app.myRoot.allTerminals do
		workPointType := terminal.allWorkPointTypes[WORK_POINT_TYPE_SHIP,'SHIP'];
		if workPointType = null then
			workPointType := terminal.createWorkPointTypeShip();
		endif;
		
		if workPointType &lt;&gt; null then
			foreach workPoint in terminal.allWorkPointsByCode do
				workPoint.setMyWorkPointType(workPointType);
			endforeach;
		endif;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Update Work Point completed ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Update Work Point completed") ;	
	endif;	
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateWorkorderDesc" id="2e1736cb-f397-4c88-9123-600774720529">
        <source>updateWorkorderDesc(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Oct 2022 navds20 ChangeRequest 56637:EUP - Add VAS WorkOrder Detail Types
21 Dec 2022 navhl20 Defect 55983(56637): MTN - The Description of the work order is incorrect if the cargo is requested from the web portal
*/

vars
	workOrderDetailType : CM_WorkOrderDetailType ;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
		app.writeLog(method.qualifiedName &amp; " Update Cargo Workorder description ", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Update Cargo Workorder description ") ;	
	endif;
	
	beginTransaction;
	
		workOrderDetailType := app.myRoot.allWorkOrderTaskTypes[WorkOrderMode_Voyage,WO_TASK_CARGOINITIAL];		
		if workOrderDetailType &lt;&gt; null then
			workOrderDetailType.setDescription(app.workorderDetailTypeEnumToStr(WorkOrderMode_Voyage,WO_TASK_CARGOINITIAL));
		endif;
		
		workOrderDetailType := app.myRoot.allWorkOrderTaskTypes[WorkOrderMode_Cargo,WO_TASK_TODO];		
		if workOrderDetailType &lt;&gt; null then
			workOrderDetailType.setDescription(app.workorderDetailTypeEnumToStr(WorkOrderMode_Cargo,WO_TASK_TODO));		
		endif;

	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Update Cargo Workorder description completed ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Update Cargo Workorder description completed") ;	
	endif;	
	
	self.addScriptRun(method.name);
epilog

end;</source>
