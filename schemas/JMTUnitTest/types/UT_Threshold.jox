/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	ti : CM_TrackedItem;
	stopsTable : CM_StopsTable;
	isoType : String;
	grade : CM_MTGrade;

begin

	stopsTable := self.addStopsForThresholdTest();

