    <JadeMethod name="setForUpdateWagonClass" id="b5bf7372-a8a7-4c1f-bd28-f0beca99e047">
        <updating/>
        <source>setForUpdateWagonClass(pProxyWagon: CM_Wagon input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 April 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	pos : Integer;
	lc : CM_LocationsController;
	lPreviousController : CM_WagonController;
	lNewController : CM_WagonController;
	lLoc : Integer;

begin

	if self.myWagonClass.lenInUnits &gt; pProxyWagon.myWagonClass.lenInUnits then
		// to a wagon type that is shorter
		// remove the extra location controllers if there is no cargo otherwise throw an error.
		foreach pos in  pProxyWagon.myWagonClass.lenInUnits + 1 to self.myWagonClass.lenInUnits reversed do
			lc := self.allLocationsControllersArray[pos];
			if not lc.allTrackedItems.isEmpty or not lc.allPlannedFutureMoves.isEmpty or not lc.allQueuedFutureMoves.isEmpty then
				// we have cargo in a position ( or queued or planned to a position ) that we want to delete. 
				app.raiseCMException2(Unable_to_change_wagon_class, pProxyWagon.myWagonClass.code, pos.String, null, null);
				//break;
			else
				lc.erase(0);
			endif;
		endforeach;
		self.causeEvent(self.myTerminal.getTerminalEvent(Wagon_Delete_Event),false,self);	// Yes we do need to treat this as a delete so that	
																							// the forms with drawings throw away the whole train and re-draw from scratch.
		
	elseif self.myWagonClass.lenInUnits &lt; pProxyWagon.myWagonClass.lenInUnits then
		// to a wagon type that is longer
		// create the extra location controllers.
		lPreviousController := self.allLocationsControllersArray.last;
		foreach lLoc in self.allLocationsControllersArray.size + 1 to pProxyWagon.myWagonClass.lenInUnits do
			create lNewController as pProxyWagon.getLocationContClassToCreate persistent;
			lNewController.setForCreate(pProxyWagon.id &amp; pProxyWagon.myWagonClass.locationIds[lLoc].trimBlanks,true, self, lPreviousController);
			lPreviousController := lNewController;
		endforeach;
		self.causeEvent(self.myTerminal.getTerminalEvent(Wagon_Delete_Event),false,self);
		
	endif;

epilog

end;</source>
        <Parameter name="pProxyWagon" type="CM_Wagon" usage="input"/>
    </JadeMethod>
</Class>
