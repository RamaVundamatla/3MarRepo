        <updating/>
        <source>btnSave_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2019	jlgab1	Initial creation
03 Dec 2021		navlw1  TFS# 51998
22 Aug 2022		navkc1	ChangeRequest 54569: Use the same new form for Edit mode
*/

vars

begin
	//navlw1 03 Dec 2021 TFS# 51998
	//if self.doValidateInvoiceLine then
	if (self.mode = self.UpdateMode_New and self.doValidateInvoiceLine) or self.mode = self.UpdateMode_Update then // 19/08/2022	navkc1	#54569 - Update mode don't need to validate Invoice Line
		self.doSaveService();
	endif;
	
	self.unloadForm();
epilog

end;</source>
