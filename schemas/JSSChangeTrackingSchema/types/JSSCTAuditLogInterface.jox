    <JadeMethod name="reportAuditResult" id="15d9c1ca-0eb4-43e5-aa4b-5f0fb5cfd0ab">
        <source>reportAuditResult(pResult: Integer; pMethod: String) protected;
/*
*/
vars
	errorMsg: String;
begin
	if pResult = 3002 then
		errorMsg := "Cannot use file - Not Open";
	elseif pResult = 3028 then
		errorMsg := "Database file is in use by another process";
	elseif pResult = 3021 then
		errorMsg := "Open of a database file failed";
	elseif pResult = 3054 then
		errorMsg := "Cannot access - invalid file number";
	elseif pResult = 3060 then
		errorMsg := "Database read past the current end of file";
	endif;
//	self.myNibblerManager.monitor(pMethod &amp; " returned " &amp; pResult.String &amp; ", " &amp; errorMsg, false);
end;</source>
        <access>protected</access>
        <Parameter name="pResult" type="Integer"/>
        <Parameter name="pMethod" type="String"/>
    </JadeMethod>
    <JadeMethod name="setReadOptions" id="d5a58154-6e34-455f-9e5c-0ba747a74e1f">
        <source>setReadOptions(pServerExecution: Boolean; pOptions: Integer);

begin
	self.myNibblerManager.monitor(self.class.name&amp;'::'&amp;method.name &amp; " options " &amp; pOptions.String, JSSCTNibblerManager.MONITOR_DEBUG);
	if pServerExecution then
		self.doSetReadOptionsSE(pOptions);
	else
		self.doSetReadOptions(pOptions);
	endif;
end;</source>
        <Parameter name="pServerExecution" type="Boolean"/>
        <Parameter name="pOptions" type="Integer"/>
    </JadeMethod>
</Class>
