    <JadeMethod name="valResourceTypeUsage" id="5b0e68a5-7430-4375-9676-0ed54fd56ffb">
        <source>valResourceTypeUsage(pProxyResourceTypeUsage , pProxyAutoApplyResourceTypeUsage : CM_ResourceTypeUsage);
/*
Date		Who		Reason
18 December 2009	conkc1	Initial creation
01 Dec 2023 navlc30 ChangeRequest 60748: EUP | VAS Mobile App - [53813.070] [BackEnd] Automatic VAS Resources
*/
vars

begin
	self.raiseExceptionIfNull(pProxyResourceTypeUsage, 'ResourceTypeUsage Proxy');
	pProxyResourceTypeUsage.raiseExceptionIfNotTransient(method);

	pProxyResourceTypeUsage.validateForCreate();
	
	if pProxyAutoApplyResourceTypeUsage &lt;&gt; null then								//15.12.2023 navlc30 #60748
		pProxyAutoApplyResourceTypeUsage.validateForCreate();
	endif;	
	
epilog

end;</source>
