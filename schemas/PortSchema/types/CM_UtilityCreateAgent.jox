    <JadeMethod name="utlCreateTrackedItem" id="dbcdf4b8-2e70-4e9b-b4c2-6e061cbab499">
        <updating/>
        <source>utlCreateTrackedItem(_pxyTI : CM_TrackedItem input; _newTI : CM_TrackedItem output; 
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     12 February 2001 by cnwdwq1
//
// Purpose:			 Creates a specific tracked item.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/05/2012	cnwcs5		par 29533 - attempt to trap as many exceptions as possible
// ---------------------------------------------------------------------------
vars
	control		: CMIF_TIUpdateController;
	tmpTerminal	: CM_Terminal;
	i : Real;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);	// par 29533
	
	if _pxyTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'trackedItem', null, null);
		return;
	endif;
	
	
	control := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	control.allTransientTIs.add(_pxyTI);
	tmpTerminal := _pxyTI.myTerminal;
			
	app.myValCA.valTrackedItems(control, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
		
	_newTI := tmpTerminal.createTrackedItem(_pxyTI, _passport);
	
epilog
	delete control;	


end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_newTI" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateTrackedItems" id="296b97d4-01ba-4522-aa6d-5b9da1b2d4f2">
        <updating/>
        <source>utlCreateTrackedItems(control : CMIF_TIUpdateController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwdwq1
//
// Purpose:		Creates persistent trackeditems for each transient in 
//				the control struct
// ---------------------------------------------------------------------------
vars
	passport			: CM_Passport;
	updateProgress		: Boolean;
begin
	// Always initialize the activity first
	self.initialiseActivity;
	app.setContinueCMExceptions(true);
	passport := _passport;
	updateProgress := (passport.myCMIFMonitor &lt;&gt; null);
	//-------------------------------------------------------------
	//   V A L I D A T I O N    S E C T I O N
	// Methods to validate data here
	//-------------------------------------------------------------
	app.myValCA.valTrackedItems(control, passport);

	if not self.checkValidationWithPassport(passport) then
		return;
	endif;

	self.createTrackedItems(control, _passport);

end;</source>
        <Parameter name="control" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateTrackedItemsNoChild" id="c433b813-6834-41b6-8465-6fa9b9f4f09f">
        <source>utlCreateTrackedItemsNoChild(_control : CMIF_TIUpdateController input; _passport : CM_Passport input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 March 2010	cnwas3	par 22954
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	ti 					: CM_TrackedItem;
	newTI 				: CM_TrackedItem;
	tmpTerminal			: CM_Terminal;
	totalTIs, tiCount	: Integer;
	tmpMonitor			: CMIF_Monitor;
	monProg				: Boolean;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin

	app.setContinueCMExceptions(false);

	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	totalTIs := _control.allTransientTIs.size;
	tmpMonitor := _passport.myCMIFMonitor;
	monProg := (tmpMonitor &lt;&gt; null);
	tmpTerminal := _passport.myTerminal;
	
	foreach ti in _control.allTransientTIs do
		tiCount := tiCount + 1;
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if monProg and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			tmpMonitor.updateProgress("Creating cargo " &amp; ti.id, totalTIs, tiCount);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		if ti.hasChildren then 
			ti.removeAllChildren();
		endif;
		
		newTI := tmpTerminal.createTrackedItem(ti, _passport);
		
		if newTI = null or _passport.hasErrors() then //rs1 apr 2006 cuscar
			break;
		endif;

		_control.addMyPersistentTI(newTI);
		
		//TH2 CCMS 1032 - CusCar for centreport - ugly hack to auto create a BOL for each car entered
		if tmpTerminal.getConfig(AutoCreateCusCarBOL).Boolean and CM_Car.hasInstance(newTI) then
			app.myUtilityUA.utlUpdateBOLInCusCar(newTI.CM_Car, _passport);
		endif;
		
	endforeach;

	// DVB found monitor was crashing for log upload. 01/03/2005
	if monProg and ti &lt;&gt; null then
		tmpMonitor.updateProgress("Creating cargo " &amp; ti.id, totalTIs, tiCount);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateTrackedItemsTranShip" id="d05c9a2c-98eb-470b-8b08-e2c3dc4077b3">
        <updating/>
        <source>utlCreateTrackedItemsTranShip(_tsController : CMIF_TranshipTIController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On 	By			Reason
// ----------	--------	--------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 22/07/2010	cnwdap1		PAR #25021 reverse order of TI validation and controller validation
// 22/07/2013	cnwdap1		PAR #31196 new parameter for setTranship method
// 17/10/2019	jlgzm1		TFS 47085 Transient Leak
// 20/11/2019	jlgzm1		TFS 47222 Remove All Import stops is redundant
// 02/05/2022	jlizm1		TFS 53084 GPHA revceival/release of tranship cargo
vars
	control	: CMIF_TIUpdateController;
	realTI, pxyTI : CM_TrackedItem;
	objs : CM_TISet;
	endTs,
	ts	: TimeStamp;
	diff : Integer;
	pxyCleanedUp : Boolean; // TFS 47085
begin
	
	if _tsController.allTrackedItems.isEmpty then
		app.raiseCMException2(MethodWithNullParam, method.name, 'Tranship TrackedItems', null, null);
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, pxyTI, pxyCleanedUp); // TFS 47085
	
	_passport.useTITransactionDeferUpdate := true; // PAR 13204
	_passport.useTIDictDeferUpdate := true; // PAR 13204

	//control := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	control := app.createTIUpdateControl(TI_UPDMODE_TRANSHIP, _passport.userCode, null);	// 19/02/2010 cnwar2 #21962
	create objs transient;
	
	foreach realTI in _tsController.allTrackedItems do
		//if realTI.myTranshipExport &lt;&gt; null then	// PAR #23645 CCMS 1116
			//objs.add(realTI.myTranshipExport);	// PAR #23645 CCMS 1116
		//endif;									// PAR #23645 CCMS 1116
		pxyTI := app.createUpdateProxy(realTI).CM_TrackedItem;
		pxyTI.setPxyFromCMIF_TranShip(_tsController, realTI);
		control.allTransientTIs.add(pxyTI);
	endforeach;
	_tsController.validate();						// PAR #25021
	app.myValCA.valTrackedItems(control, _passport);
	//_tsController.validate();						// PAR #25021
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	// PAR #23645 CCMS 1116 change message - we no longer erase any items
	//app.writeLog('Erasing ' &amp; objs.size.String &amp; ' Creating ' &amp; _tsController.allTrackedItems.size.String &amp; ' tranships', LogAlways);
	app.writeLog('Creating ' &amp; _tsController.allTrackedItems.size.String &amp; ' tranships', LogINFO);
	ts := app.actualTimeServer();
	
	app.writeLog('Starting ' &amp; method.name &amp; ' at ' &amp; ts.String, LogINFO);
	beginTransaction;
	self.initialiseActivity();

	//foreach realTI in objs do			// PAR #23645 CCMS 1116
		//realTI.erase(NORMAL_ERASE);	// PAR #23645 CCMS 1116
	//endforeach;						// PAR #23645 CCMS 1116
	
	// create EXPORT T/Ss
	//self.createTrackedItems(control, _passport);
	//self.utlCreateTrackedItemsNoChild(control, _passport);//par 22954	// PAR #23645 CCMS 1116

	// go through the Import TS
	foreach realTI in _tsController.allTrackedItems do : outerLoop
		// find the matching Proxy
		//foreach pxyTI in control.allPersistentTIs do
		foreach pxyTI in control.allTransientTIs do
			if realTI.id = pxyTI.id then
				// pxyTI is the transient tranship version of realTI - update tranship details
				//realTI.setTranship(pxyTI, _passport, _tsController.removeStops);			// PAR #31196
				realTI.setTranship(pxyTI, _passport, false);		// PAR #31196
				if _tsController.interModal then											// TFS 53084
					realTI.setTransitStatus(TI_TransitStatusInterModal, true, _passport);	// TFS 53084
				endif;
				continue outerLoop;
			endif;
		endforeach;

	endforeach;	
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;
	
	endTs := app.actualTimeServer();
	
	diff := endTs.getDifferenceInSeconds(ts).Integer;
	
	app.writeLog('Transaction took ' &amp; diff.String &amp; ' seconds to process.', LogINFO);
	
	
	
epilog
	delete objs;
	delete control;	
	delete pxyTI; // TFS 47085 If we got an error, may not have been deleted when deleting objs
end;</source>
        <Parameter name="_tsController" type="CMIF_TranshipTIController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateTrade" id="0c48afb0-5db0-41fe-afd6-16ffb37f78d2">
        <source>utlCreateTrade(pProxyTrade:CM_Trade; pNewTrade:CM_Trade output;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:      12 May 2003 by cnwsgp1
// 21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------
vars
	cancelSave : Boolean;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valTrade(pProxyTrade);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);

	create pNewTrade persistent;
	pNewTrade.setForCreate(pProxyTrade);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(pNewTrade);
	endif;
	
	//21.09.2020 cnwma1 TFS #49906
	if _passport.isOpsViewEnabled(null) then
		pNewTrade.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,
								 BGP_OpsViewWSRequest.OPS_TYPE_TRADE,
								 pNewTrade);
	endif;
	//21.09.2020 cnwma1 TFS #49906
end;</source>
        <Parameter name="pProxyTrade" type="CM_Trade"/>
        <Parameter name="pNewTrade" type="CM_Trade" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateTrain" id="9acbe1b7-a2e1-4882-966c-81927e23733c">
        <updating/>
        <source>utlCreateTrain(	_pxyTrain : CM_Train input;
				_realTrain : CM_Train output;
				_isValidate : Boolean;
				_isInitialise : Boolean;
				_passport : CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	06 November 2006 By cnwth2

Purpose:	

Changed On  Changed By	Reason
----------  ----------	--------------------------------------------------
28/07/2010	cnwdad1		PAR #25120, added parameter for calling "initialiseActivity".
//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
---------------------------------------------------------------------------
*/
vars
	trainArrivalEvent, trainDepartEvent : CMEVT_TrainTransaction;
begin
	if _isInitialise then
		self.initialiseActivity();
	endif;
	
	app.setContinueCMExceptions(true);
	app.myValCA.valTrain(_pxyTrain);
	
	if not self.checkValidationWithPassport(_passport) or _isValidate then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	create _realTrain persistent;
	_realTrain.setForCreate(_pxyTrain, trainArrivalEvent, trainDepartEvent);
	
	if _passport.noErrors() then //+ cnwmd1, CCMS 1067, Par 19710
		self.myCreateAuditAgent.audCreateGeneric(_realTrain);
		if trainArrivalEvent &lt;&gt; null then	//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
			trainArrivalEvent.setCAMSTimeStamp(app.actualTimeServer);	
		endif;
		if trainDepartEvent &lt;&gt; null then	//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
			trainDepartEvent.setCAMSTimeStamp(app.actualTimeServer);	
		endif;
	endif;
end;</source>
        <Parameter name="_pxyTrain" type="CM_Train" usage="input"/>
        <Parameter name="_realTrain" type="CM_Train" usage="output"/>
        <Parameter name="_isValidate" type="Boolean"/>
        <Parameter name="_isInitialise" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateTrainEvent" id="139b6f8d-b752-4dad-a76f-29910cdcb06c">
        <updating/>
        <source>utlCreateTrainEvent(_pxyEvent : CM_EventTransaction input; _event : CM_EventTransaction output; _train : CM_Train io; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 October 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	cmifEventCtrl : CMIF_TrainEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valTrainEvent(_pxyEvent, _train);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);

	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	_event := app.createEvent(_pxyEvent.type, _pxyEvent.dateTime, _train.getTerminal(), app.myPassport.userCode, false, _pxyEvent.noCharge,0).CM_EventTransaction;
	if _event  &lt;&gt; null and _passport.noErrors then
		_event.CMEVT_TrainTransaction.setMyTrain(_train);
		//_event.createCharge(app.myPassport);
		app.myPassport.addEventTransactionForDeferUpd(_event,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
 	endif;
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	create cmifEventCtrl transient;
	cmifEventCtrl.type := _pxyEvent.type;
	cmifEventCtrl.dateTime := _pxyEvent.dateTime;
	cmifEventCtrl.myTerminal := _train.getTerminal();
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.noCharge := _pxyEvent.noCharge;
	cmifEventCtrl.myTrain := _train;
	
	_event := app.createEventUsingCMIF(cmifEventCtrl);
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_pxyEvent" type="CM_EventTransaction" usage="input"/>
        <Parameter name="_event" type="CM_EventTransaction" usage="output"/>
        <Parameter name="_train" type="CM_Train" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateTug" id="ac38c9f3-0fe5-4564-8f3f-cf83d866f0ee">
