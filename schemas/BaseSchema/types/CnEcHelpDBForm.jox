    <JadeMethod name="loadForm" id="4cd000c8-f412-457d-b17b-3356625e1daa">
        <updating/>
        <source>loadForm() updating;

begin
	aFontName := app.fontName;
	aFontSize := app.fontSize;
	app.fontName := "MS Sans Serif";
	app.fontSize := 8;

	fraPassword.visible := true;
	lblPassword.caption := "Access to this tool requires the entry of an authorised password." &amp; CrLf &amp; CrLf &amp; "Contact Cardinal for further details.";
	statusLine.caption := "Password required";
	txtPassword.setFocus();
	fraOptions.visible := false;

	btnSaveChanges.enabled := false;
	btnGetForms.enabled := false;
	btnExtractForm.enabled := false;
	btnUpdateForm.enabled := false;

	sheetDetails.visible := false;
	sheetProjects.visible := false;
	sheetMaintenance.visible := false;
	fraOutput.visible := false;

	table.columnWidth[ 1 ]  := 160;
	table.columnWidth[ 2 ]  := 160;
	table.columnWidth[ 3 ]  :=  55;
	table.columnWidth[ 4 ]  :=  75;
	table.columnWidth[ 5 ]  :=  90;
	table.columnWidth[ 6 ]  :=  50;
	table.columnWidth[ 7 ]  :=  40;
	table.columnWidth[ 8 ]  :=  40;
end;</source>
    </JadeMethod>
    <JadeMethod name="lstForms_change_click" id="7508794f-81d7-44b0-b381-a01beedea42e">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstForms_change_click(listbox: ListBox input) updating;

vars
	form	: Form;
	cnEcHelpFormDetail	: CnEcHelpFormDetail;

begin
	if listbox.listObject &lt;&gt; null then	// if something selected then enable buttons
		self.resetLists(listbox);
		form := listbox.listObject.Form;
		cnEcHelpFormDetail := aMyHelp.getHelpForm(form);

		if cnEcHelpFormDetail.modified = null then
			statusLine.caption := "Form changed - " &amp; aMyHelp.getFormTimeStamp(form).String &amp; ".  This is a new form.";
		else
			statusLine.caption := "Form changed - " &amp; aMyHelp.getFormTimeStamp(form).String &amp; ".  Last database date - " &amp; cnEcHelpFormDetail.modified.String &amp; ".";
		endif;

/*
		write(cnEcHelpFormDetail.getFormDetail(0));
		write("-----" );
		write(cnEcHelpFormDetail.getFormDetail(1));
		write("-----" );
		write(cnEcHelpFormDetail.getFormDetail(2));
*/
	else
		self.resetLists(null);
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
