    <JadeMethod name="utlDeleteMenuUserReport" id="e2aef078-8724-48e8-ba84-fbd0769c78d6">
        <source>utlDeleteMenuUserReport(_userReportSet : CM_MenuUserItemSet input; _totalDelete : Boolean; _passport : CM_Passport input);

// cnwdvb1 30 October 2002 

vars

	menuUserItem	: CM_MenuUserItem;
	user			: CM_User;
	menuUserReport	: CM_MenuUserReport;
	template		: CM_ReportTemplate;
	set				: CM_MenuUserItemSet;
	
begin

	self.initialiseActivity();

	if (not _passport.noErrors) then
		return;
	endif;

	// Want to make this really specific; Get rid of template.
	if _totalDelete and _userReportSet.size = 1 then
		create set transient;
		menuUserReport := _userReportSet.first.CM_MenuUserReport;
		template := menuUserReport.myReportTemplate;
		template.allMenuUserReports.copy(set);
		foreach menuUserItem in set do
			if global.isValidObject(menuUserItem) then
				menuUserItem.erase(NORMAL_ERASE);
			endif;
		endforeach;
		return;
	endif;
	
	// Just a normal delete
	foreach menuUserItem in _userReportSet do
		if global.isValidObject(menuUserItem) then
			// Lock taken care of inside menuUserItem
			menuUserItem.erase(NORMAL_ERASE);
		endif;
	endforeach;

epilog
	delete set;
end;</source>
        <Parameter name="_userReportSet" type="CM_MenuUserItemSet" usage="input"/>
        <Parameter name="_totalDelete" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
