    <JadeMethod name="setValue" id="1177114f-903d-4425-bcda-d0a85b4247b3">
        <updating/>
        <source>setValue( _value : DateArray ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2020	jlgndl1	Initial creation	TFS 49569

*/

vars
	array : DateArray;
begin
	array := self.myValueArray;
	if array = null then
		create array persistent;
	endif;
	
	array.clear;
	
	_value.copy (array);
end;
