    <JadeMethod name="comboBoxCargoBOLTypeGate" id="ece56964-82fc-480c-aa76-d91093f0cb1e">
        <source>comboBoxCargoBOLTypeGate(pCmb : ComboBox input; _dfltCargoBOLType : Integer; 
			_includeCargoTypes, 
			_includeBOLTypes,
			_fromTerminal : Boolean);
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
// ---------------------------------------------------------------------------
vars
	defCargoBol		: CM_CargoBOLType;
	cargo			: CM_CargoType;
	bol				: CM_BOLType;
	tmpId,
	idx				: Integer;
	canDoLogs,
	canDoGeneralCargo	: Boolean;
//	canDoDeveloper	: Boolean;

begin
	canDoLogs			:= app.getMyUser.canDo(self.myTerminal, Mod_Logs);
	canDoGeneralCargo	:= app.getMyUser.canDo(self.myTerminal, Mod_GeneralCargo);
//	canDoDeveloper		:= app.getMyUser.canDo(self.myTerminal, PmDeveloper);
	pCmb.sorted := true;
	pCmb.clear();	

/*	if _includeCargoTypes then
		foreach cargo in app.myRoot.allCargoTypesById do
			tmpId := cargo.id;
			if (tmpId = TI_CargoType_Log and (not canDoLogs)) or 
			   (tmpId &gt; TI_CargoBOLType_JMTMax and (not canDoDeveloper)) or
			   (tmpId &gt; TI_CargoBOLType_Max and tmpId &lt; TI_CargoBOLType_JMTMax and 
			   		((not canDoGeneralCargo) or (not _includeGeneralCargoTypes))) then
				continue;
			endif;
	
			idx := pCmb.addItem(self.displayEntryCargoBolType(cargo));
			pCmb.itemObject[idx] := cargo;
			if tmpId = _dfltCargoBOLType then
				defCargoBol := cargo;
			endif;
		endforeach;
	endif;*/
	
	if _includeCargoTypes then
		foreach cargo in app.myRoot.allCargoTypesById where cargo.isShownInGateInOut do
			tmpId := cargo.id;
			if (tmpId = TI_CargoType_Log and (not canDoLogs)) or 
			   //(tmpId &gt; TI_CargoBOLType_JMTMax /*and (not canDoDeveloper)*/) or			// TFS 49252
			   (tmpId &gt; TI_CargoBOLType_JMTMax and (not app.myRoot.isClientCentrePort)) or	// TFS 49252
			   (tmpId &gt; TI_CargoBOLType_Max and tmpId &lt; TI_CargoBOLType_JMTMax and 
			   		((not canDoGeneralCargo and cargo.getTiBehaviourType() = TIBehaviourType_BreakBulkGen))) then
			   	continue;
			endif;
	
			idx := pCmb.addItem(self.displayEntryCargoBolType(cargo));
			pCmb.itemObject[idx] := cargo;
			if tmpId = _dfltCargoBOLType then
				defCargoBol := cargo;
			endif;
		endforeach;
	endif;
	
	if _includeBOLTypes then
		foreach bol in app.myRoot.allBOLTypes do
			tmpId := bol.id;
			if (tmpId = BOLType_Log and (not canDoLogs)) or
			   (tmpId = BOLType_GeneralDocket and (not canDoGeneralCargo)) or
			   (tmpId = BOLType_GeneralBillOfLading and (not canDoGeneralCargo)) then
				continue;
			endif;
	
			idx := pCmb.addItem(self.displayEntryCargoBolType(bol));
			pCmb.itemObject[idx] := bol;
	
			if tmpId = _dfltCargoBOLType then
				defCargoBol := bol;
			endif;
		endforeach;
	endif;
		
	if _fromTerminal then
		//CNWTH2 changed for PAR 7964 - it's up to calling method to specify a default 
		//cargoBOLType - it is valid for some screens to NOT default to the terminal's \
		//default cargoBOLType and have a null text/listobject set
		if defCargoBol &lt;&gt; null and
		   (not self.myTerminal.allCargoBOLTypes.includes(defCargoBol)) then
			// if the cargo/Bol type passed in is not null and not valid for this
			// terminal then go and get the default for this terminal
			defCargoBol := app.myPassport.getDefaultCargoBOLType();
		endif;
	endif;
	
	//Set the combobox data
	if defCargoBol &lt;&gt; null then
		pCmb.text := self.displayEntryCargoBolType(defCargoBol);
		pCmb.listObject := defCargoBol;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_dfltCargoBOLType" type="Integer"/>
        <Parameter name="_includeCargoTypes" type="Boolean"/>
        <Parameter name="_includeBOLTypes" type="Boolean"/>
        <Parameter name="_fromTerminal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCargoBolType" id="fdaaa653-ab06-40a1-b832-baa53604921e">
        <source>comboBoxCargoBolType(pCmb : ComboBox input; _dfltCargoBOLType : Integer; 
			_includeCargoTypes, 
			_includeBOLTypes,
			_includeGeneralCargoTypes,
			_fromTerminal : Boolean);
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
/*
Date		Who		Reason
28/10/2009	cnwdap1	PAR #90264 Filter out cargo types that require subcargo types but have none set up yet
05/05/2020	jlgdap1	TFS 49252 CPL Cargo Types not showing in System Admin
*/
// ---------------------------------------------------------------------------
vars
	defCargoBol		: CM_CargoBOLType;
	cargo			: CM_CargoType;
	bol				: CM_BOLType;
	tmpId,
	idx				: Integer;
	canDoLogs,
	canDoGeneralCargo	: Boolean;
//	canDoDeveloper	: Boolean;
	tmpUser			: CM_User;

begin
	tmpUser := app.getMyUser;
	
	canDoLogs			:= tmpUser.canDo(self.myTerminal, Mod_Logs);
	canDoGeneralCargo	:= tmpUser.canDo(self.myTerminal, Mod_GeneralCargo);
//	canDoDeveloper		:= tmpUser.canDo(self.myTerminal, PmDeveloper);
	pCmb.sorted := true;
	pCmb.clear();	
	
	if _includeCargoTypes then
		foreach cargo in app.myRoot.allCargoTypesById do
			// 31981 skip not-available-for-entry cargo types
			if cargo.isNotAvailableForEntry then
				continue;
			endif;
		
			// par no 16187--to  populate only those cargo types that are in selected column of terminal config
			if _fromTerminal and (not self.myTerminal.allCargoBOLTypes.includes(cargo)) then
				continue;
			endif;
			tmpId := cargo.id;
			if not cargo.isDynamicallyCreated then   // PAR 36449
				if (tmpId = TI_CargoType_Log and (not canDoLogs)) or 
				   //(tmpId &gt; TI_CargoBOLType_JMTMax /*and (not canDoDeveloper)*/) or			// TFS 49252
				   (tmpId &gt; TI_CargoBOLType_JMTMax and (not app.myRoot.isClientCentrePort)) or	// TFS 49252
				   (tmpId &gt; TI_CargoBOLType_Max and tmpId &lt; TI_CargoBOLType_JMTMax and 
						((not canDoGeneralCargo) or (not _includeGeneralCargoTypes))) then
						continue;
				endif;
			endif;
	
			// PAR #20964 if the cargo type requires cargo subtypes but none have been set up, don't display it
			if cargo.isSubCargoTypeRequired and not cargo.hasProductTypes then
				continue;
			endif;
			// PAR #90264 end
	
			idx := pCmb.addItem(self.displayEntryCargoBolType(cargo));
			pCmb.itemObject[idx] := cargo;
			if tmpId = _dfltCargoBOLType then
				defCargoBol := cargo;
			endif;
		endforeach;
	endif;
	
	if _includeBOLTypes then
		foreach bol in app.myRoot.allBOLTypes do
		// par no 16187--to  populate only those cargo types that are in selected column of terminal config
			if _fromTerminal and (not self.myTerminal.allCargoBOLTypes.includes(bol)) then
				continue;
			endif;
			tmpId := bol.id;
			if (tmpId = BOLType_Log and (not canDoLogs)) or
			   (tmpId = BOLType_GeneralDocket and (not canDoGeneralCargo)) or
			   (tmpId = BOLType_GeneralBillOfLading and (not canDoGeneralCargo)) then
				continue;
			endif;
	
			idx := pCmb.addItem(self.displayEntryCargoBolType(bol));
			pCmb.itemObject[idx] := bol;
	
			if tmpId = _dfltCargoBOLType then
				defCargoBol := bol;
			endif;
		endforeach;
	endif;
		
	if _fromTerminal then
		//CNWTH2 changed for PAR 7964 - it's up to calling method to specify a default 
		//cargoBOLType - it is valid for some screens to NOT default to the terminal's \
		//default cargoBOLType and have a null text/listobject set
		if defCargoBol &lt;&gt; null and
		   (not self.myTerminal.allCargoBOLTypes.includes(defCargoBol)) then
			// if the cargo/Bol type passed in is not null and not valid for this
			// terminal then go and get the default for this terminal
			defCargoBol := app.myPassport.getDefaultCargoBOLType();
		endif;
	endif;
	
	//Set the combobox data
	if defCargoBol &lt;&gt; null then
		pCmb.text := self.displayEntryCargoBolType(defCargoBol);
		//th2 PAR 13215
		pCmb.listIndex := pCmb.findObject(defCargoBol);
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_dfltCargoBOLType" type="Integer"/>
        <Parameter name="_includeCargoTypes" type="Boolean"/>
        <Parameter name="_includeBOLTypes" type="Boolean"/>
        <Parameter name="_includeGeneralCargoTypes" type="Boolean"/>
        <Parameter name="_fromTerminal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCargoBolTypeTerminal" id="8307aa34-8198-468e-8be0-b3b24180972a">
        <source>comboBoxCargoBolTypeTerminal(pCmb : ComboBox input; _dfltCargoBOLType : Integer; 
			_includeCargoTypes, 
			_includeBOLTypes,
			_includeGeneralCargoTypes,
			fromTerminal : Boolean);
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
// ---------------------------------------------------------------------------
vars
	defCargoBol		: CM_CargoBOLType;
	cargo			: CM_CargoType;
	bol				: CM_BOLType;
	tmpId,
	idx				: Integer;
	canDoLogs,
	canDoGeneralCargo	: Boolean;
//	canDoDeveloper	: Boolean;

begin
	canDoLogs			:= app.getMyUser.canDo(self.myTerminal, Mod_Logs);
	canDoGeneralCargo	:= app.getMyUser.canDo(self.myTerminal, Mod_GeneralCargo);
//	canDoDeveloper		:= app.getMyUser.canDo(self.myTerminal, PmDeveloper);
	pCmb.sorted := true;
	pCmb.clear();	
	if self.myTerminal = null then
		//barf here
//	endif;
//	foreach cargo in self.myTerminal.allCargoBOLTypes do
		if _includeCargoTypes then
		//foreach cargo in app.myRoot.allCargoTypesById do
			tmpId := cargo.id;
			if (tmpId = TI_CargoType_Log and (not canDoLogs)) or 
			   //(tmpId &gt; TI_CargoBOLType_JMTMax /*and (not canDoDeveloper)*/) or			// TFS 49252
			   (tmpId &gt; TI_CargoBOLType_JMTMax and (not app.myRoot.isClientCentrePort)) or	// TFS 49252
			   (tmpId &gt; TI_CargoBOLType_Max and tmpId &lt; TI_CargoBOLType_JMTMax and 
			   		((not canDoGeneralCargo) or (not _includeGeneralCargoTypes))) then
				//continue;
			endif;
	
			idx := pCmb.addItem(self.displayEntryCargoBolType(cargo));
			pCmb.itemObject[idx] := cargo;
			if tmpId = _dfltCargoBOLType then
				defCargoBol := cargo;
			endif;
			endif;
//		endforeach;
	endif;
	
	if _includeBOLTypes then
		foreach bol in app.myRoot.allBOLTypes do
			tmpId := bol.id;
			if (tmpId = BOLType_Log and (not canDoLogs)) or
			   (tmpId = BOLType_GeneralDocket and (not canDoGeneralCargo)) or
			   (tmpId = BOLType_GeneralBillOfLading and (not canDoGeneralCargo)) then
				continue;
			endif;
	
			idx := pCmb.addItem(self.displayEntryCargoBolType(bol));
			pCmb.itemObject[idx] := bol;
	
			if tmpId = _dfltCargoBOLType then
				defCargoBol := bol;
			endif;
		endforeach;
	endif;
		
	if fromTerminal then
		//CNWTH2 changed for PAR 7964 - it's up to calling method to specify a default 
		//cargoBOLType - it is valid for some screens to NOT default to the terminal's \
		//default cargoBOLType and have a null text/listobject set
		if defCargoBol &lt;&gt; null and
		   (not self.myTerminal.allCargoBOLTypes.includes(defCargoBol)) then
			// if the cargo/Bol type passed in is not null and not valid for this
			// terminal then go and get the default for this terminal
			defCargoBol := app.myPassport.getDefaultCargoBOLType();
		endif;
	endif;
	
	//Set the combobox data
	if defCargoBol &lt;&gt; null then
		pCmb.text := self.displayEntryCargoBolType(defCargoBol);
		pCmb.listObject := defCargoBol;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_dfltCargoBOLType" type="Integer"/>
        <Parameter name="_includeCargoTypes" type="Boolean"/>
        <Parameter name="_includeBOLTypes" type="Boolean"/>
        <Parameter name="_includeGeneralCargoTypes" type="Boolean"/>
        <Parameter name="fromTerminal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCargoGroup" id="74c9374c-0e99-4f20-9139-7a7461becf40">
        <source>comboBoxCargoGroup(_cmb : CMUI_ComboBox input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/06/2023	navkc1	CR 57496 Task 58405: UI - Release Request Cargo Group

*/

vars
	cargoGroup		: CM_TrackedItem;
	terminal		: CM_Terminal;
	
begin
	terminal := self.myTerminal;
	_cmb.clear();
	foreach cargoGroup in terminal.allCargoGroupsByIdCargoType discreteLock do
		_cmb.addItemObject(cargoGroup.id, cargoGroup);
	endforeach;
epilog

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCargoGroupType" id="b5ca6c38-c3c7-4883-905e-08f1ca6170c6">
        <source>comboBoxCargoGroupType(pCmb : ComboBox input; _dfltCargoBOLType : Integer);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 08 Aug 2023
TFS#		: 59741
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	cargoType	: CM_CargoType;
	idx, tmpId	: Integer;
	tmpUser		: CM_User;
	defCargoBol	: CM_CargoBOLType;
	failedDAC   : CM_DataAccessController;
	terminal	: CM_Terminal;
begin
	tmpUser := app.getMyUser;
	terminal := self.myTerminal;
	pCmb.sorted := true;
	pCmb.clear();	
	
	foreach cargoType in app.myRoot.allCargoTypesById do
		if cargoType.isNotAvailableForEntry then
			continue;
		endif;
		
		if cargoType.productType &lt;&gt; ProductType_CargoGroup then
			continue;
		endif;
		
		if not cargoType.allTerminals.includes(terminal) then
			continue;
		endif;
		
		tmpId := cargoType.id;
		
		idx := pCmb.addItem(self.displayEntryCargoBolType(cargoType));
		pCmb.itemObject[idx] := cargoType;
		if tmpId = _dfltCargoBOLType then
			defCargoBol := cargoType;
		endif;
	endforeach;
	
	
	if defCargoBol &lt;&gt; null then
		pCmb.text := self.displayEntryCargoBolType(defCargoBol);		
		pCmb.listIndex := pCmb.findObject(defCargoBol);
	endif;
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_dfltCargoBOLType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCargoTypeBreakBulk" id="7cdbda81-2f8c-46fb-89f6-28af953a1bd3">
        <source>comboBoxCargoTypeBreakBulk(_cmb : ComboBox input; _defaultCargoType : CM_CargoType);
//10 November 2009	cnwml2


vars

	cargoBOLTypeArray 	: CM_CargoBOLTypeArray;
	cargoBOLType,
	store				: CM_CargoBOLType;
	cargoType			: CM_CargoType;
//	found				: Boolean;
//ccms1108 used to populate combo box
begin
	_cmb.clear();
	
	cargoBOLTypeArray := self.myTerminal.allCargoBOLTypes;	
	foreach cargoBOLType in cargoBOLTypeArray do
		if (not CM_CargoType.hasInstance(cargoBOLType)) then
			continue;
		endif;
		
		if not cargoBOLType.CM_CargoType.isBreakBulk() and not cargoBOLType.CM_CargoType.isSubCargoTypeRequired then
			continue;
		endif;
		
		_cmb.itemObject[_cmb.addItem(cargoBOLType.description)] := cargoBOLType;
		if cargoBOLType = _defaultCargoType then
			store := cargoBOLType;
			//found := true;
		endif;
	endforeach;
	
	if store &lt;&gt; null then
		_cmb.listObject := store;
	endif;

epilog

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_defaultCargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCargoTypes" id="5c851795-fc99-46d9-b8ff-f7cdb14a1de0">
        <source>comboBoxCargoTypes(_cmb : ComboBox input; _defaultCargoType : CM_CargoType);
// ---------------------------------------------------------------------------
// Created:     01 April 2004	cnwth2
//
// Purpose:     N.B. CNWTH2 deciding not to check licencing for cargo types at this point - relying on 
//				terminal's cargo type collection to be legit for current licencing
//			 
// ----------   ----------  --------------------------------------------------
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
vars
	cargoBOLTypeArray 	: CM_CargoBOLTypeArray;
	cargoBOLType,
	store				: CM_CargoBOLType;
	cargoType			: CM_CargoType;
//	found				: Boolean;
begin
	_cmb.clear();
	
	create cargoBOLTypeArray transient;
	if self.myTerminal = null then
		app.myRoot.allCargoTypesById.copy(cargoBOLTypeArray);
	else
		self.myTerminal.allCargoBOLTypes.copy(cargoBOLTypeArray);
	endif;
//	cargoBOLTypeArray := self.myTerminal.allCargoBOLTypes;	
	foreach cargoBOLType in cargoBOLTypeArray do
		if (not CM_CargoType.hasInstance(cargoBOLType)) then
			continue;
		endif;
		
		_cmb.itemObject[_cmb.addItem(cargoBOLType.description)] := cargoBOLType;
		if cargoBOLType = _defaultCargoType then
			store := cargoBOLType;
			//found := true;
		endif;
	endforeach;
	
	if store &lt;&gt; null then
		_cmb.listObject := store;
	endif;
epilog
	delete cargoBOLTypeArray;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_defaultCargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCargoTypesAll" id="14f9232f-eb68-4824-8c2d-1aab4a4c5a99">
        <source>comboBoxCargoTypesAll(_cmb : ComboBox input; _defaultCargoType : CM_CargoType);
// ---------------------------------------------------------------------------
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
//
vars
	cargoBOLTypeArray 	: CM_CargoBOLTypeArray;
	cargoBOLType,
	store				: CM_CargoBOLType;
	cargoType			: CM_CargoType;
//	found				: Boolean;
begin
	_cmb.clear();
	
	create cargoBOLTypeArray transient;
	app.myRoot.allCargoTypesById.copy(cargoBOLTypeArray);
	foreach cargoBOLType in cargoBOLTypeArray do
		if (not CM_CargoType.hasInstance(cargoBOLType)) then
			continue;
		endif;
		
		_cmb.itemObject[_cmb.addItem(cargoBOLType.description)] := cargoBOLType;
		if cargoBOLType = _defaultCargoType then
			store := cargoBOLType;
			//found := true;
		endif;
	endforeach;
	
	if store &lt;&gt; null then
		_cmb.listObject := store;
	endif;
epilog
	delete cargoBOLTypeArray;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_defaultCargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCargoTypesForPacking" id="47417547-e3c6-444c-a2c9-21125d6cb7a7">
        <source>comboBoxCargoTypesForPacking(_cmb : ComboBox input; _defaultCargoType : CM_CargoType);
// ---------------------------------------------------------------------------
// Created:     08 November 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cargoBOLTypeArray 	: CM_CargoBOLTypeArray;
	cargoBOLType,
	store				: CM_CargoBOLType;
	cargoType			: CM_CargoType;
begin
	_cmb.clear();
	
	cargoBOLTypeArray := self.myTerminal.allCargoBOLTypes;	
	foreach cargoBOLType in cargoBOLTypeArray do
		if (not CM_CargoType.hasInstance(cargoBOLType)) then
			continue;
		endif;
		
		if (not cargoBOLType.CM_CargoType.canBePacked) then
			continue;
		endif;
		
		_cmb.itemObject[_cmb.addItem(cargoBOLType.description)] := cargoBOLType;
		if cargoBOLType = _defaultCargoType then
			store := cargoBOLType;
			//found := true;
		endif;
	endforeach;

	if store &lt;&gt; null then
		_cmb.listObject := store;
	endif;
	
	
	

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_defaultCargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCargoUpdateRequestType" id="be08bc82-666e-4bef-b26b-b66a390f60c2">
        <source>comboBoxCargoUpdateRequestType(_cmb : CMUI_ComboBox input);
/*

Date		Who		Reason
06 May 2014	cnwer1	Initial creation 

*/

vars

begin	
	_cmb.clear;
	_cmb.addItemWithData(EventRequestTypeStopsStr, EventRequestTypeStops);
	_cmb.addItemWithData(app.getErrorString(To_Do_Tasks), EventRequestTypeToDo);
	_cmb.addItemWithData(app.getErrorString(Remarks), EventRequestTypeRemarks);
	_cmb.addItemWithData(app.getErrorString(Grade), EventRequestTypeGrade);
	_cmb.addItemWithData(app.getErrorString(CM_Total_Weight),EventRequestTypeWeight); //37551 17/2/16 

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCargoWorkOrderTasks" id="c6da302a-5e7d-40be-aeea-f3e2b594437f">
        <source>comboBoxCargoWorkOrderTasks(_combo : CMUI_ComboBox input; _terminal : CM_Terminal);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/07/2009	cnwmd1	Initial creation
07/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
29/09/2021  navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
26/01/2023	navma1 	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/
vars
	taskDict		: CM_ToDoTaskDescByCode;
	tmpToDo			: CM_ToDoTaskDesc;
	sortString 		: String;
	workOrderDetail : CM_WorkOrderDetailType;
	root			: CM_Root;
begin
	
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForWOTerm(_terminal, null, taskDict);
	
	_combo.clear();
	_combo.sorted := true;									
	
	root			:= app.myRoot;
	workOrderDetail := root.allWorkOrderTaskTypes[WorkOrderMode_Cargo,WO_TASK_TODO];
	
	if workOrderDetail &lt;&gt; null then
		sortString := workOrderDetail.description &amp; " - ";		
		foreach tmpToDo in taskDict do
			_combo.addItemObject( sortString &amp; tmpToDo.description, tmpToDo );
		endforeach;
	endif;
	
	_combo.sorted := false;	
	
	foreach workOrderDetail in root.allWorkOrderTaskTypes discreteLock do
		if workOrderDetail.type &lt;&gt; WorkOrderMode_Cargo then
			continue;
		endif;
		
		if workOrderDetail.id = WO_TASK_TODO then
			continue;
		endif;
		
		_combo.addItemWithData(workOrderDetail.description,workOrderDetail.id);
	endforeach;
	
epilog
	delete taskDict;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCarrier" id="611a9d04-88d9-4771-b89a-26037cbe14e5">
        <source>comboBoxCarrier(_combo : ComboBox input; _carrier : CM_Carrier);
// ---------------------------------------------------------------------------
// Created:     08 January 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/03/2010	cnwmh5		PAR22747 - Remove carrier.isRail test
//	Mar 2011	cnwjre1		25096 add isNotAvailableForEntry test
// ---------------------------------------------------------------------------
vars
	text			: String;
	carrier			: CM_Carrier;
	carrierDict		: CM_CarrierByCodeDict;
begin
	_combo.clear();
	
//	_combo.sorted 	:= false;	//commented out 20 Aug 2015	NDL	Par 36789
	carrierDict 	:= app.myRoot.allCarriers;
	
	//PAR7793 - add blank to allow null selection
	_combo.addItem(null);
	
	// 05/03/2010 cnwmh5 #22747 remove the isRail test
	// Mar 2011 cnwjre1 25096 add the isNotAvailableForEntry test
	foreach carrier in carrierDict discreteLock where not carrier.isNotAvailableForEntry do	
		_combo.itemObject[_combo.addItem(self.displayEntryCarrier(carrier))] := carrier;
	endforeach;
	
	if _carrier &lt;&gt; null then
		text := self.displayEntryCarrier(_carrier);
		// 25096 if existing carrier is marked not available, show it anyway
		if _carrier.isNotAvailableForEntry then
			_combo.itemObject[_combo.addItem(text)] := _carrier;
		endif;
		
		_combo.text 		:= text;
		_combo.listObject 	:= _carrier;
	endif;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCarrierRail" id="a5c4219f-6575-4946-949c-a2391b5de644">
        <source>comboBoxCarrierRail(_cmb : ComboBox input; _carrier : CM_Carrier);
// ---------------------------------------------------------------------------
// Created:     08 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	Mar 2011	cnwjre1		25096 rail screens should only show rail carriers
//									also add the isNotAvailableForEntry test

// ---------------------------------------------------------------------------
vars
	text			: String;
	carrier			: CM_Carrier;
	carrierSet		: CM_CarrierSet;
begin
	_cmb.clear();	
	carrierSet := app.myRoot.allCarriersRail;
		
	foreach carrier in carrierSet where not carrier.isNotAvailableForEntry do
		_cmb.itemObject[_cmb.addItem(self.displayEntryCarrier(carrier))] := carrier;
	endforeach;
	
	if _carrier &lt;&gt; null then
		text := self.displayEntryCarrier(_carrier);
		// 25096 if existing carrier is marked not available, or is non-rail, show it anyway
		if _carrier.isNotAvailableForEntry or
		   not _carrier.isRail then
			_cmb.itemObject[_cmb.addItem(text)] := _carrier;
		endif;
		_cmb.text := text;
	   	_cmb.listObject := _carrier;
	endif;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCarrierRoad" id="370206c4-ecb1-437a-b4ba-f434bcf9a344">
        <source>comboBoxCarrierRoad(_cmb : ComboBox input; _carrier : CM_Carrier);
// ---------------------------------------------------------------------------
// Created:     Mar 2011 by cnwjre1 for 25096 road screens should only show road carriers
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ---------------------------------------------------------------------------

// 13 Feb 2014	NDL	Cahnged to not include empty lines caused by tring to add carriers we don't have permission to see.
vars
	text			: String;
	carrier			: CM_Carrier;
	carrierSet		: CM_CarrierSet;
begin
	_cmb.clear();	
	carrierSet := app.myRoot.allCarriersRoad;
		
	foreach carrier in carrierSet where not carrier.isNotAvailableForEntry do
		text := self.displayEntryCarrier(carrier);
		if text = null then
			continue;
		endif;
		_cmb.itemObject[_cmb.addItem(text)] := carrier;
	endforeach;
	
	if _carrier &lt;&gt; null then
		text := self.displayEntryCarrier(_carrier);
		if text = null then
			return;
		endif;
		// 25096 if existing carrier is marked not available, or is non-road, show it anyway
		if _carrier.isNotAvailableForEntry or
		   not _carrier.isRoad then
			_cmb.itemObject[_cmb.addItem(text)] := _carrier;
		endif;
		_cmb.text := text;
	   	_cmb.listObject := _carrier;
	endif;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCarrierTransportMode" id="06d1d1dd-e2e9-4dbb-8db0-ddc96fad5ac7">
        <source>comboBoxCarrierTransportMode(_cmb : ComboBox input; _carrier : CM_Carrier; _transportMode : String);
/*

Date		    Who			Reason
17 June 2010	cnwas3	  par 24344
Mar 2011		cnwjre1	  25096 add isNotAvailableForEntry test
11 August 2011	cnwdap1	  PAR #27972 Bulk release type no longer translatable, replaced by string constants
*/

vars
	text			: String;
	carrier			: CM_Carrier;
	carrierDict		: CM_CarrierByCodeDict;
	isRail,isRoad	: Boolean;
begin
	_cmb.clear();	
	carrierDict := app.myRoot.allCarriers;
		
	_cmb.addItem(null);
	
	//if _transportMode = app.getErrorString(BR_TYPE_DESCR_RAIL) then		// PAR #27972
	if _transportMode = BR_TYPE_RAIL_STR then								// PAR #27972
		isRail := true;
	//elseif _transportMode  = app.getErrorString(BR_TYPE_DESCR_ROAD) then	// PAR #27972
	elseif _transportMode  = BR_TYPE_ROAD_STR then							// PAR #27972
		isRoad := true;
	endif;
	
	// 25096 filter out not available for entry
	foreach carrier in carrierDict where not carrier.isNotAvailableForEntry do		
		if isRail and not carrier.isRail then 
			continue;			
		elseif isRoad and not carrier.isRoad then
			continue;			
		endif;		
		_cmb.itemObject[_cmb.addItem(self.displayEntryCarrier(carrier))] := carrier;
	endforeach;
	
	if _carrier &lt;&gt; null then 
		text := self.displayEntryCarrier(_carrier);
		// 25096 if existing carrier is not in the combo, add it and show it anyway
		if _cmb.findObject(_carrier) = -1 then
			_cmb.itemObject[_cmb.addItem(text)] := _carrier;
		endif;
		_cmb.text := text;
	   	_cmb.listObject := _carrier;
	endif;	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_transportMode" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCashDebtors" id="34481613-7e6c-48cc-8e7a-625caeb5dd72">
        <source>comboBoxCashDebtors(_cmb : ComboBox input; _term : CM_Terminal; _selectedDr : CM_Debtor; includeAny : Boolean );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2012	cnwndl1	Initial creation

*/

vars

	dr : CM_DebtorNode;
	index : Integer;
	drTerm : CM_DebtorTerminal;

begin

	_cmb.clear();
	
	if not app.isCashOnlyEnabled then
		return;
	endif;
	if _term &lt;&gt; null and not _term.isCashOnlyEnabled then
		return;
	endif;
	
	if includeAny then
		_cmb.addItem( Any_String );
	endif;
	
	if _term = null then
		// 33249 read debtors directly, not via debtor types
		foreach dr in app.myRoot.myRootCompany.debtors where not dr.isSuspended do
			if not dr.isKindOf( CM_Debtor ) then
				continue;
			endif;
			if dr.CM_Debtor.allDebtorTerminals.includesCashOnlyTerminals then
				index := _cmb.addItem( dr.name );
				_cmb.itemObject[ index ] := dr;
			endif;
		endforeach; 
	else
		foreach drTerm in _term.allDebtorTerminals do
			if drTerm.isCashOnly then				// 33249 only cash debtors
				dr := drTerm.myDebtor;
				index := _cmb.addItem( dr.name );
				_cmb.itemObject[ index ] := dr;
			endif;
		endforeach;
	endif;
	
	if _selectedDr &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject( _selectedDr );
	endif;
	
	if _cmb.listIndex &lt; 1 and includeAny then
		_cmb.listIndex := 1;
	endif;

epilog

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_selectedDr" type="CM_Debtor"/>
        <Parameter name="includeAny" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCellularVessels" id="2cb4226e-aec4-4572-ba13-fb7a9e407ee8">
        <source>comboBoxCellularVessels(_cmb : CMUI_ComboBox input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	iter : Iterator; 
	tmpTerm : CM_Terminal;
	tmpUser	: CM_User;
	tmpUserT	: CM_UserTerminal;
	showVesselByName : Boolean;
	vessel 			: CM_Vessel;
	vesselStructure : CM_VesselStructure;
begin
	
	// hacky way of getting the terminal because the config is set per terminal 
	tmpTerm := app.getMyTerminalDO_NOT_USE();
	if tmpTerm = null then
		tmpUser := app.getMyUser();
		if tmpUser &lt;&gt; null then
			tmpUserT := tmpUser.allUserTerminals.first;
			if tmpUserT &lt;&gt; null then
				tmpTerm := tmpUserT.getRealTerminal;
			endif;
		endif;
	endif;
	
	if tmpTerm &lt;&gt; null then
		showVesselByName:= tmpTerm.getConfig(VesselComboByName).Boolean;
	endif;


	iter:=app.myRoot.allVesselCellularStructures.createIterator;
	while iter.next(vesselStructure) do
		vessel:=vesselStructure.myVessel;
		if showVesselByName then	
			_cmb.addItemObject( vessel.name &amp;  " - (" &amp; vessel.code &amp; ")" ,vesselStructure); 
		else
			_cmb.addItemObject( vessel.code &amp; " -  ("  &amp; vessel.name &amp; ")",vesselStructure); 
		endif;
	endwhile;
	
	
epilog
	delete iter;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCellularVoyages" id="696dd536-f612-4534-b083-42e886f663a0">
        <source>comboBoxCellularVoyages(_cmb : CMUI_ComboBox input;_terminal : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	showVesselByName: Boolean;
	iter : Iterator;
	voyage	: CM_Voyage;
	failedDAC  :CM_DataAccessController;
begin
	if _terminal &lt;&gt; null then
		showVesselByName:= _terminal.getConfig(VesselComboByName).Boolean;
	endif;


	iter:=_terminal.allVoyagesByCode.createIterator;
	while iter.next(voyage) do
		if voyage.myStructuralElements = null then
			continue;
		endif;
		
		if voyage.isNullVoyage then 
			continue;
		endif;
		
		if not voyage.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;

		
		if showVesselByName then	
			if voyage.vesselName &lt;&gt; null then
				_cmb.addItemObject( voyage.vesselName.trimBlanks &amp;  " - (" &amp; voyage.code.trimBlanks &amp; ")",voyage.myStructuralElements); 
			else
				_cmb.addItemObject(voyage.code.trimBlanks,voyage.myStructuralElements); 
			endif;
		else
			_cmb.addItemObject(voyage.getId(),voyage.myStructuralElements); 
		endif;
	endwhile;
	
	
epilog
	delete iter;

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCodeGroupLogSpecs" id="81671cf8-a505-408b-94d3-8461b2ac94c6">
        <source>comboBoxCodeGroupLogSpecs(pCmb : ComboBox input; pCodeGroup : CM_CodeGroup);
// ---------------------------------------------------------------------------
// Created:     08 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

//	self.setAllCarrierCodes();
	pCmb.sorted := false;
	pCmb.listCollection(app.myRoot.allCodeGroups, true, 0);
	
	if pCodeGroup &lt;&gt; null then
		pCmb.text := self.displayEntryCodeGroupLogSpecs(pCodeGroup);
		pCmb.listObject := pCodeGroup;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pCodeGroup" type="CM_CodeGroup"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCodes" id="6e616188-b23d-42f2-9378-abadebb07131">
        <source>comboBoxCodes(pCmb : ComboBox input; pCode : CM_Code; pCodeGroup : CM_CodesByCodeDict; _includeUnavailableForEntry : Boolean);
//--------------------------------------------------------------
//Created: 28 January 2002 By: cnwgd1
//Changed CNWTH2 to consider CM_Code::notAvailableForEntry
//--------------------------------------------------------------
vars
	code				: CM_Code;
	
begin

	pCmb.clear();
	
	if pCodeGroup = null or
	   pCodeGroup.isEmpty then
		return;
	endif;
	
	foreach code in pCodeGroup do
		if not _includeUnavailableForEntry and
		   code.notAvailableForEntry then
			continue;
		endif;
		
		pCmb.itemObject[pCmb.addItem(code.code &amp; Tab &amp; code.description)] := code;
	endforeach;
	
	if pCode &lt;&gt; null then
		pCmb.text := pCode.code &amp; Tab &amp; pCode.description;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pCode" type="CM_Code"/>
        <Parameter name="pCodeGroup" type="CM_CodesByCodeDict"/>
        <Parameter name="_includeUnavailableForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCommodity" id="a420a809-2b1d-499d-b15b-eb49889fbf8b">
        <source>comboBoxCommodity(_combo : ComboBox input; _commodity : CM_Commodity);
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	_combo.clear();

	_combo.listCollection(app.myRoot.allCommodities, false, 0);
	
	if _commodity &lt;&gt; null then
		_combo.text := self.displayEntryCommodity(_commodity);
	
		if _combo.text &lt;&gt; null then
			_combo.listObject := _commodity;
		endif;
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_commodity" type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCommodityCargoType" id="24894fb0-c74e-4571-8fd2-80e38dcdc721">
        <source>comboBoxCommodityCargoType(_commodity : CM_Commodity; _cmb : ComboBox input; _cargoType : CM_CargoType);
//25 August 2009	cnwml2
// 04/03/2010		cnwcs5	par 22762 - invalid cargo types
//					cnwcs5 	par 22562 - Should only ever load commodities for the selected cargo type
//									  - if there are non then it should not load root commodities

vars
	com		: CM_Commodity;
	tmpColl : CM_CommodityByCodeDict;
	index	: Integer;
	str		: String;
begin
	
	_cmb.clear();
	
	if _cargoType = null then
		return;
	endif;
	
	foreach com in _cargoType.allCommodities do
		str	:= self.displayEntryCommodity (com);

		if str &lt;&gt; null then
			index := _cmb.addItem (str);
		
			_cmb.itemObject[index] := com;
		
			if _commodity = com then
				_cmb.listIndex := index;
			endif;
		endif;
	endforeach;

	return;

	create tmpColl transient;

	foreach com in app.myRoot.allCommodities do
		if _cargoType &lt;&gt; null and	// 04/03/2010 par 22762
			_cargoType.allCommodities.includes(com) then
			tmpColl.add(com);
		endif;
	endforeach;
	
	if tmpColl.size &gt; 0 then
		_cmb.listCollection(tmpColl, false, 0);
	else
		_cmb.listCollection(app.myRoot.allCommodities, false, 0);
	endif;
	
	if _commodity &lt;&gt; null then
		_cmb.text := self.displayEntryCommodity(_commodity);
		if _cmb.text &lt;&gt; null then
			_cmb.listObject := _commodity;
		endif;
	endif;

epilog
	delete tmpColl;
end;</source>
        <Parameter name="_commodity" type="CM_Commodity"/>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCommodityGroup" id="5fbed03a-3ca1-46be-9604-4ec3901dd839">
        <source>comboBoxCommodityGroup(pCmb : ComboBox input; pCommodityGroup : CM_CommodityGroup);
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

//	self.setAllCommodityCodes();
	pCmb.clear();
	pCmb.sorted := false;
	pCmb.listCollection(app.myRoot.allCommodityGroups, true, 0);
	
	if pCommodityGroup &lt;&gt; null then
		pCmb.listObject := pCommodityGroup;
		pCmb.text := self.displayEntryCommodityGroup(pCommodityGroup);
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pCommodityGroup" type="CM_CommodityGroup"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCommodityMultiSelected" id="a9226b18-4112-42c3-bdde-08c55c3c49e8">
        <source>comboBoxCommodityMultiSelected( _cmb : ComboBox input; _selectedCommodities : CM_CommodityByCodeDict; _commodity : CM_Commodity);
/* ---------------------------------------------------------------------------
Created:	10 July 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpCommodity	: CM_Commodity;
	tmpColl			: CM_CommodityByCodeDict;
	
begin

	if _selectedCommodities.isEmpty then	// get all commodities by default, when there are no selected commodities.
		self.comboBoxCommodity( _cmb, _commodity);	
		return;
	endif;
	
	create tmpColl transient;
	_cmb.clear();
	//pCmb.sorted := false;
	//_cmb.listCollection(app.myRoot.allCommodities, false, 0);

	foreach tmpCommodity in app.myRoot.allCommodities discreteLock do
		if _selectedCommodities.includes(tmpCommodity) then
			tmpColl.add(tmpCommodity);
		endif;
	endforeach;
	_cmb.listCollection(tmpColl, false, 0);
	
	if _commodity &lt;&gt; null and tmpColl.includes(_commodity) then
		_cmb.text := self.displayEntryCommodity(_commodity);
		if _cmb.text &lt;&gt; null then
			_cmb.listObject := _commodity;
		endif;
	endif;
	
epilog
	delete tmpColl;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_selectedCommodities" type="CM_CommodityByCodeDict"/>
        <Parameter name="_commodity" type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCommodityReefer" id="734f9957-78d9-4aa7-816b-feb31ebccb5a">
        <source>comboBoxCommodityReefer(pCmb : ComboBox input; pCommodity : CM_Commodity);
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpCmdty	: CM_Commodity;
	idx			: Integer;
	code		: String;
begin

	pCmb.clear();
	pCmb.sorted := false;
//	pCmb.listCollection(app.myRoot.allCommodities, true, 0);


	foreach tmpCmdty in app.myRoot.allCommodities do
		if tmpCmdty.hasTemp
		or tmpCmdty.requiresPower 
		or pCommodity = tmpCmdty then
		
			pCmb.itemObject[pCmb.addItem(tmpCmdty.code &amp; Tab &amp; tmpCmdty.description)] := tmpCmdty;
		endif;
		
	endforeach;
	
	if pCommodity &lt;&gt; null then
		pCmb.text := self.displayEntryCommodity(pCommodity);
		pCmb.listObject := pCommodity;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pCommodity" type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCompany" id="bce0da31-a270-4542-9e93-8642e0d4fa3e">
        <source>comboBoxCompany(pTbl : CM_EntryTable input; pAttrName : String);
// ---------------------------------------------------------------------------
// Created:     02 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	bank	: CM_Bank;
	str		: String;
		
begin

	foreach bank in self.myTerminal.companies
	 			where (not bank.isSuspended) and (bank.isBusinessUnit=true) do
		if str = null then
			str := bank.code;
		else
			str := str &amp; Tab &amp; bank.code;
		endif;
	endforeach;

	pTbl.setComboValues(pTbl.getRow(pAttrName), str);

end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxConsignGroup" id="5e64fa6f-7bb2-4080-ac75-49ab7f4adb31">
        <source>comboBoxConsignGroup(pCmb : ComboBox input; pConsignGroup : CM_ConsigneeConsignorGroup);
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

//	self.setAllCommodityCodes();
	pCmb.sorted := false;
	pCmb.listCollection(app.myRoot.allConsignGroups, true, 0);
	
	if pConsignGroup &lt;&gt; null then
		pCmb.text := self.displayEntryConsignGroup(pConsignGroup);
		pCmb.listObject := pConsignGroup;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pConsignGroup" type="CM_ConsigneeConsignorGroup"/>
    </JadeMethod>
    <JadeMethod name="comboBoxConsignor" id="424b0ab1-e4aa-4339-9e70-a1366a95520e">
        <source>comboBoxConsignor(_combo : ComboBox input; _consignor : CM_ConsigneeConsignor; _type : Integer);
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Changed On   24 June by CNWTH2 to consider data access and CM_ConsigneeConsignor.isNotAvailableForEntry
// ----------   ----------  --------------------------------------------------
// 08/04/2010	cnwdap1		PAR #23565 set combo intialised to true at end of method to stop double-loading of combos
// ---------------------------------------------------------------------------
vars
	consignor		: CM_ConsigneeConsignor;
	passport		: CM_Passport;
	failedDAC  		: CM_DataAccessController;
begin
	if _combo.isKindOf(CMUI_ComboConsignors) then
		_combo.CMUI_ComboConsignors.setType(_type);
		
		_combo.CMUI_ComboConsignors.setInitialised(false);
		//return;//th2 added 09/08/2007 - it will init itself on the dropdown event, otherwise we are just doing this twice.
	endif;

	_combo.clear();
	
	passport	:= app.myPassport;

	foreach consignor in app.myRoot.allConsigneeConsignors do
		//if we don't have access to the consign passed in, list it - it SHOULD be included regardless
		if (not consignor.canUserAccessSelf(null, failedDAC, passport) or consignor.isNotAvailableForEntry) and (consignor &lt;&gt; _consignor) then
			continue;
		endif;
			
		if _type = FREIGHT_FORWARDER and not consignor.isFreightFwdr then
			continue;
		elseif _type = CONSIGNEE and not consignor.isConsignee then
			continue;
		elseif _type = CONSIGNOR and not consignor.isConsignor then
			continue;
		endif;
		
		_combo.itemObject[_combo.addItem(self.displayEntryConsignor(consignor))] := consignor;
	endforeach;
	
	if _consignor &lt;&gt; null and _combo.findObject(_consignor) &gt; 0 then			//+cnwml2 PAR25402
		_combo.listObject := _consignor;
	endif;

	// PAR #23565 start
	if _combo.isKindOf(CMUI_ComboConsignors) then
		_combo.CMUI_ComboConsignors.setInitialised(true);
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_consignor" type="CM_ConsigneeConsignor"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxConsignorCashOnlyDr" id="94cea4fb-8fd6-43bc-bc10-5852dba05ccd">
        <source>comboBoxConsignorCashOnlyDr(_combo : ComboBox input; _consignor : CM_ConsigneeConsignor; _type : Integer; _term : CM_Terminal );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2013	cnwndl1	Initial creation - Only get the ones associated with a CASH ONLY debtor

*/

vars
	consignor : CM_ConsigneeConsignor;
	passport : CM_Passport;
	failedDAC : CM_DataAccessController;
	terminal : CM_Terminal;
begin

	_combo.clear();
	
	passport	:= app.myPassport;
	terminal := _term;
	if terminal = null and passport &lt;&gt; null then
		terminal := passport.myTerminal;
	endif;

	foreach consignor in app.myRoot.allConsigneeConsignors do
		//if we don't have access to the consign passed in, list it - it SHOULD be included regardless
		if (not consignor.canUserAccessSelf(null, failedDAC, passport) or consignor.isNotAvailableForEntry) and (consignor &lt;&gt; _consignor) then
			continue;
		endif;
			
		if _type = FREIGHT_FORWARDER and not consignor.isFreightFwdr then
			continue;
		elseif _type = CONSIGNEE and not consignor.isConsignee then
			continue;
		elseif _type = CONSIGNOR and not consignor.isConsignor then
			continue;
		endif;
		
		if consignor.debtor = null or not consignor.debtor.isCashOnlyDebtor( terminal ) then
			continue;
		endif;
		
		_combo.itemObject[_combo.addItem(self.displayEntryConsignor(consignor))] := consignor;
	endforeach;
	
	if _consignor &lt;&gt; null and _combo.findObject(_consignor) &gt; 0 then
		_combo.listObject := _consignor;
	endif;

	if _combo.isKindOf(CMUI_ComboConsignors) then
		_combo.CMUI_ComboConsignors.setInitialised(true);
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_consignor" type="CM_ConsigneeConsignor"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="comboBoxContactForCompany" id="9cee7050-64ec-48c1-8c2f-7c541e1f3457">
        <source>comboBoxContactForCompany(pCmb : ComboBox input; _contact : CM_EmailEntity; _company : CM_Object);
//-----------------------------------------
//Created: 06 April 2004 By: cnwgd1
//-----------------------------------------
vars

begin
	
	pCmb.clear();
	
	if _company = null then
		pCmb.listCollection(app.myRoot.allEmailEntities, true, 0);
	elseif CM_Stevedore.hasInstance(_company) then
		pCmb.listCollection(_company.CM_Stevedore.allContacts, true, 0);		
	elseif CM_ShippingLine.hasInstance(_company) then
		pCmb.listCollection(_company.CM_ShippingLine.allContacts, true, 0);		
	elseif CM_ShippingAgent.hasInstance(_company) then
		pCmb.listCollection(_company.CM_ShippingAgent.allContacts, true, 0);						
	endif;

	if _contact &lt;&gt; null then
		pCmb.text := self.displayEntryEmailAddress(_contact);
		if pCmb.text &lt;&gt; null then
		   	pCmb.listObject := _contact;
		endif;
	endif;
	
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_contact" type="CM_EmailEntity"/>
        <Parameter name="_company" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="comboBoxContentsStatus" id="e6c93a81-3ddd-49c7-8117-7a99a395cacc">
        <source>comboBoxContentsStatus(_cmb : CMUI_ComboBox input; _contentsStatus : CM_ContentsStatus);
// ---------------------------------------------------------------------------
// Created:     29 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	stat			: CM_ContentsStatus;
	statusDict		: CM_ContentsStatusByCodeDict;
	str				: String;
begin
	_cmb.clear();
	statusDict := app.myRoot.allContentsStatuses;
	foreach stat in statusDict do
		_cmb.itemObject[_cmb.addItem(stat.description)] := stat;
	endforeach;
	
	if _contentsStatus &lt;&gt; null then
		_cmb.listObject := _contentsStatus;
	endif;
	
	
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_contentsStatus" type="CM_ContentsStatus"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCoolingType" id="ea1e45b7-f17b-4f78-93f4-92a9e1f35e90">
        <source>comboBoxCoolingType(_table : CM_EntryTable input; _attributeName, _type : String);
//-----------------------------------------
//Created: 2 June 2005 By: cnwgd1
//-----------------------------------------
vars
	str	: String;
	row	: Integer;
begin
	
	str := ContainerCooledNullStr &amp; Tab &amp;
		   ContainerAirCooledStr &amp; Tab &amp;	
		   ContainerWaterCooledStr;

