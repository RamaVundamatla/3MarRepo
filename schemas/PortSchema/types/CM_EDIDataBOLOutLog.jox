        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getStatusForVoyage" id="22bc1141-6d46-4e86-a0b2-76f01fb9dd5c">
        <source>getStatusForVoyage(_logVoyage : CM_Voyage) : String;
//--------------------------------------------------------------
//Created: 11 December 2002 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	found 	: Boolean;
	bol		: CM_BOL;

begin
	if self.allBOLs.isEmpty then
		return self.File_Status_Imported;
	endif;

	foreach bol in self.allBOLs do		// where global.isValidObject(bol) do - inversed, can't be invalid
		if bol.CM_BOLOut.myVoyage = _logVoyage then
//			if bol.myExtension.CM_BOLExtLogOut.myLogVoyageNotLoaded &lt;&gt; null then
			if bol.myExtension.CM_BOLExtLogOut.myLogVoyageStructNotLoaded &lt;&gt; null then

				found := true;
				break;
			endif;
		endif;
	endforeach;

	if found then
		return self.File_Status_BOLCreated;	   
	endif;
	
	return self.File_Status_BOLLoaded;

end;</source>
        <Parameter name="_logVoyage" type="CM_Voyage"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includeAsHeaderInXML" id="60986362-8cec-45d9-a082-74f415529d19">
        <source>includeAsHeaderInXML(): Boolean;
//
//10 Nov 2014	cnwrs1	Par 34702 - Add support for JMT XML with implied header
//
vars

begin
	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="readFile" id="4c3ce015-d849-4e94-b569-35bc1c1d4e78">
        <updating/>
        <source>readFile(_copyFileToServer : Boolean; _voyageGlobal : CM_VoyageGlobal; _passport : CM_Passport input) : Boolean updating;
//--------------------------------------------------------------
//Created: 26 August 2002 By: cnwgd1
//--------------------------------------------------------------
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
//20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
vars
	logOutFile	: File;
	array 		: HugeStringArray;
	line 		: String;
	rtnValue 	: Boolean;
	lineNo		: Integer;
	pxyEDILog	: CM_EDIBOLOutLogTI;
	err			: CM_Error;
	str			: String;
//	voy			: CM_Voyage;
	voy			: CM_LogVoyageStructure;
	voySet		: CM_LogVoyageStructureSet;
	firstTime,
	deleteFile	: Boolean;
	progressTS : TimeStamp;
begin

	progressTS := app.actualTimeServer();		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	firstTime := true;
	
	create array transient;
	create voySet transient;
	
	create logOutFile transient;
	logOutFile.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	if _copyFileToServer then
		if (not self.copyFileToServer(logOutFile, _passport)) then
			return false;
		endif;
		deleteFile := true;
	else
		logOutFile.mode 		:= File.Mode_Input;
		logOutFile.shareMode 	:= File.Share_Read;
		logOutFile.fileName 	:= self.logOutFileName;
		if (not logOutFile.isAvailable) then 
			app.raiseCMException1(FileUnavailable, 'logOutFile', null, null);
			return false;
		endif;
	endif;

	
	self.updateProgress(progressTS, 'Reading items from file', 0, 0, true, _passport);
		
	beginLoad;

	while (not logOutFile.endOfFile) do
		line := logOutFile.readLine();
		lineNo := lineNo + 1;
		line.parseCSV(array);
		//if array.size &lt; 16 then
		if not (array.size = 16 or array.size = 18) then	// 09/09/2009 cnwar2 CCMS-1107/#20627
			app.raiseCMException1(IncorrectNumberOfFields, lineNo.String, null, null);
			return false;
		endif;
		
		if self.updateProgress(progressTS, 'Read ' &amp; lineNo.String &amp; ' items from file', CMIF_Monitor.MonitorReusePartsInJob_Done, lineNo, false, _passport) then
			app.raiseCMException(VB_USER_CANCELED_TRANS, null, null);
			return false;
		endif;
		
		if lineNo mod 200 = 0 then
			endLoad;			
			app.writeLog('  Read ' &amp; lineNo.String &amp; ' items from file', LogINFO);
			beginLoad;
		endif;
		create pxyEDILog transient;
		pxyEDILog.setProxy(self, array);
		pxyEDILog.validateForCreate(_voyageGlobal, _passport);
		if _passport.hasErrors then
			foreach err in _passport.allErrorWarnings do
				if str = null then
					str := err.text; 
				else
					str := str &amp; '; ' &amp; err.text;
				endif;
			endforeach;
			app.writeLog('  *** ERROR on line ' &amp; lineNo.String &amp; ' &gt;&gt;&gt; ' &amp; line, LogINFO);
			app.raiseCMException2(EDILogInvalid, pxyEDILog.id, lineNo.String &amp; ' (' &amp; str &amp; ')', null, null);		
			return false;
		endif;
//		if (not voySet.includes(pxyEDILog.myLogVoyage)) then
//			voySet.add(pxyEDILog.myLogVoyage);
//		endif;
		if (not voySet.includes(pxyEDILog.myLogVoyageStructure)) then
			voySet.add(pxyEDILog.myLogVoyageStructure);
		endif;

		if firstTime and pxyEDILog.loadDate.isValid() then
			self.loadStartDT.setDate(pxyEDILog.loadDate);
			self.loadStartDT.setTime(pxyEDILog.loadTime);
			firstTime := false;
		endif;					
	endwhile;

	endLoad;	

	foreach voy in voySet do
//		if (not self.allLogVoyages.includes(voy.CM_LogVoyage)) then
		if (not self.allLogVoyageStructures.includes(voy)) then
			self.allLogVoyageStructures.add(voy);
//			self.allLogVoyages.add(voy.CM_LogVoyage);
		endif;
	endforeach;
	
	
	self.updateProgress(progressTS, 'Finished reading from file - ' &amp; lineNo.String &amp; ' items', CMIF_Monitor.MonitorReusePartsInJob_Done, lineNo, true, _passport);
	app.writeLog('  Finished reading from file - ' &amp; lineNo.String &amp; ' items', LogINFO);

	return true;
	
epilog
	endLoad;
	if deleteFile then
		if logOutFile.isAvailable then
			logOutFile.close;
			logOutFile.purge;
		endif;
	endif;
	delete voySet;
	delete array;
	delete logOutFile;
end;</source>
        <Parameter name="_copyFileToServer" type="Boolean"/>
        <Parameter name="_voyageGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="5dd98ef9-8d38-4018-86d2-54e2be3382ab">
        <updating/>
        <source>setForCreate(_pxyEDIDataBOLOutLog : CM_EDIDataBOLOutLog; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 26 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyEDILog,
	realEDILog 	: CM_EDIBOLOutLogTI;
	err			: CM_Error;
	str			: String;
	
begin
	self.logOutFileName := _pxyEDIDataBOLOutLog.logOutFileName;
	self.fileShortName	:= _pxyEDIDataBOLOutLog.fileShortName;	
	self.myRoot			:= _pxyEDIDataBOLOutLog.myRoot;
	self.myTerminal 	:= _pxyEDIDataBOLOutLog.myTerminal;
	self.userCode		:= _pxyEDIDataBOLOutLog.userCode;
	self.loadStartDT	:= _pxyEDIDataBOLOutLog.loadStartDT;

	foreach pxyEDILog in _pxyEDIDataBOLOutLog.allEDILogsByLotHatchPlace do
		pxyEDILog.setParent(self);
		//app.myUtilityCA.utlCreateEDIBOLOutLog(pxyEDILog, realEDILog, _passport);
		
		create realEDILog persistent;
		realEDILog.setForCreate(pxyEDILog);

		if _passport.hasErrors then
			foreach err in _passport.allErrorWarnings do
				if str = null then
					str := err.text; 
				else
					str := str &amp; '; ' &amp; err.text;
				endif;
			endforeach;
			app.raiseCMException2(EDILogInvalid, pxyEDILog.id, ' unknown (' &amp; str &amp; ')', null, null);		
			return;
		endif;
	endforeach;
	

end;</source>
        <Parameter name="_pxyEDIDataBOLOutLog" type="CM_EDIDataBOLOutLog"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="ca7793e8-6700-4764-8fd2-88b6eb927bed">
        <updating/>
        <source>setProxy(_logOutFileName, _userCode : String; _terminal : CM_Terminal; _root : CM_Root) updating;
//--------------------------------------------------------------
//Created: 26 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	str : String;
	length : Integer;
begin
	self.myRoot			:= _root;
	self.myTerminal 	:= _terminal;
	self.logOutFileName := _logOutFileName;
	self.userCode		:= _userCode;
	//Par 16852 //par 17735 cnwdz2 15/08/08 shorten file base name to the last 30 characters if it is longer than 30 characters.
	self.fileShortName := app.shortenStringLength(self.logOutFileName.fileBaseName(),self.fileShortName.maxLength());
end;</source>
        <Parameter name="_logOutFileName" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="52123a59-48c8-40da-8f2b-b559398113f0">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
//
// 11 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	propName : String;
begin
	if _property = null then
		return false;
	endif;
	propName := _property.name;
	if propName = CM_EDIDataBOLOutLog::allBOLs.name or
	   propName = CM_EDIDataBOLOutLog::allEDILogsByLotHatchPlace.name or
	   propName = CM_EDIDataBOLOutLog::allLogVoyageStructures.name or
	   propName = CM_EDIDataBOLOutLog::setMyRoot.name or
	   propName = CM_EDIDataBOLOutLog::myTerminal.name or
	   propName = CM_EDIDataBOLOutLog::allEDILogsByLotHatchPlace.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="6c4d3884-9274-4206-ab99-c327ea89ea57">
        <source>validateForCreate();
//--------------------------------------------------------------
//Created: 26 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	if self.myRoot = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Root', null, null);
		app.raiseCMException(Input_required_field_root, null, null); // cnwdb2	PAR 35364
		return;						
	endif;
		
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', null, null);
		app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364
		return;								
	endif;
	
	if self.logOutFileName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Log Out File Name', null, null);
		app.raiseCMException(Input_required_field_logOutFle, null, null); // cnwdb2	PAR 35364
		return;								
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="5b0a6f5d-0a0c-4e91-81bb-f42cf77647e6">
        <source>validateForDelete();
//--------------------------------------------------------------
//Created: 19 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod();
	
	if (not self.allBOLs.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, 'Loaded File ' &amp; self.fileShortName, 'Load Out Docket', null, null);		
		return;
	endif;

end;</source>
    </JadeMethod>
</Class>
