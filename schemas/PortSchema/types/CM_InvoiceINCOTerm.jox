    <JadeMethod name="pxyCreateUpdateProxy" id="40425b1f-8d3b-4ca1-b59e-5517cabd1e53">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Purpose:			

Date		Who		Reason
16 May 2023 navtnr20	TFS CR 57983 Task 57984: EUP - INCO Terms TRX Layer
*/

vars
	pxyME : SelfType;
begin
	pxyME :=  inheritMethod();
	
	pxyME.myBusinessUnit := self.myBusinessUnit;
	pxyME.code := self.code;
	pxyME.description := self.description;
	
	return pxyME;

epilog

end;</source>
