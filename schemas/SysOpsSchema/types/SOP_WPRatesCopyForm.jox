    <JadeMethod name="doPropagate" id="0ea4fddd-27c6-4492-b87c-49371aba3776">
        <source>doPropagate():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

	selectedDict : CM_WorkPointByCodeDict;
	wpcr : CM_WorkPointCargoRates;
	wp : CM_WorkPoint;
	
	templateWpcr : CM_WorkPointCargoRates;
	allTemplates : CM_WPRatesByCargoTypeProduct;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	create selectedDict transient;
	self.mulWorkPoints.getSelected( selectedDict );

	if selectedDict.isEmpty then
		app.msgBox( app.getErrorString(Nothing_Selected), app.getErrorString(Warning), MsgBox_OK_Only );
		return false;
	endif;
	
	if self.myWpToCopy = null or self.myWpToCopy.allWorkPointRates.isEmpty then
		app.msgBox( app.getErrorString(Cargo_work_point_rates_propag), app.getErrorString(Warning), MsgBox_OK_Only );
		return false;
	endif;
	
	create allTemplates transient;
	foreach wpcr in self.myWpToCopy.allWorkPointRates do
		create templateWpcr transient;
		templateWpcr.setProxy(	wpcr.dailyHoursWorkable,	//_dailyHoursWorkable : Decimal;
								wpcr.jobType,	//_jobType : Integer;
								wpcr.myCargoType,	//_myCargoType : CM_CargoType;
								wpcr.myProduct,	//_myProduct : CM_Product;
								null,	//_myWorkPoint : CM_WorkPoint;
								wpcr.targetRatePHQuantity,	//_targetRatePHQuantity : Integer;
								wpcr.targetRatePHVolume,	//_targetRatePHVolume : Decimal;
								wpcr.targetRatePHWeight,	//_targetRatePHWeight : Decimal;
								wpcr.transferType	//_transferType : Integer
								);
		allTemplates.add( templateWpcr );
	endforeach;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxPropagateWorkPointRates( selectedDict, allTemplates, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theResult := app.showErrorWarningDialog( app.getErrorString(Propogate_changes), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings );
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
epilog

	delete selectedDict;
	if allTemplates &lt;&gt; null and not allTemplates.isEmpty then
		allTemplates.purge();
	endif;
	delete allTemplates;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getWPDescription" id="47cde782-cd09-4633-a88c-0e0c3cbe2b4e">
        <source>getWPDescription( _obj : CM_WorkPoint ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

begin

	if _obj.description &lt;&gt; null then
		return _obj.code &amp; " / " &amp; _obj.description;
	endif;
	
	return _obj.code;

epilog

end;</source>
        <Parameter name="_obj" type="CM_WorkPoint"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyWpToCopy" id="12b15e44-d7c2-4df1-88aa-ff181fc59999">
        <updating/>
        <source>setMyWpToCopy( _workPoint : CM_WorkPoint )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

begin

	self.myWpToCopy := _workPoint;

epilog

end;</source>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="00b388ec-cc33-4aec-a2a3-8b46c9d66cff">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2018	jlgndl1	Initial creation	TFS 41980

*/

vars

	availableDict : CM_WorkPointByCodeDict;

begin

	inheritMethod();
	
	self.width := 517;
	self.height := 559;
	
	self.cmbWorkPoint.clear();
	self.cmbWorkPoint.listCollection( self.myTerminal.allWorkPointsByCode, false, 0 );
	
	self.cmbWorkPoint.listIndex := self.cmbWorkPoint.findObject( self.myWpToCopy );
	
	create availableDict transient;
	self.myTerminal.allWorkPointsByCode.copy( availableDict );
	availableDict.remove( self.myWpToCopy );
	
	self.mulWorkPoints.caption := null;	//22 Nov 2018 NDL TFS 41980
	self.mulWorkPoints.myAvailableListBox.sorted := true;
	self.mulWorkPoints.mySelectedListBox.sorted := true;
	self.mulWorkPoints.setupControl( null, availableDict, SOP_WPRatesCopyForm::getWPDescription.name );
	self.mulWorkPoints.availableHeading := app.getErrorString(Available);
	self.mulWorkPoints.selectedHeading := app.getErrorString(Selected);
	self.mulWorkPoints.setSelected( null );
	
epilog

	delete availableDict;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="fe561c5d-0ca8-40cb-ba51-c4967ab31e83">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 November 2018 08:09:37.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023069, locale);
	lblInstruct.translateCaption(Xlat_0023070, locale);
	lblWPCopy.translateCaption(Xlat_0023071, locale);
	mulWorkPoints.translateCaption(Xlat_0023072, locale);
end;</source>
    </JadeMethod>
</GUIClass>
