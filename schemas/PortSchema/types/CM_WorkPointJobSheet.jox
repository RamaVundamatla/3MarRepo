epilog

end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForShipJob" id="a2649fb0-a120-45b6-ae89-1f9e1bcc8ab6">
        <source>setForShipJob(_job : CM_Job; _pxyVoyageJob : CM_VoyageWorkPointJob input; _voyageJob : CM_VoyageJob io; _hold : CM_GeneralCargoController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Oct 2023 navhl20 ChangeRequest 60090: EUP | Ship Operations in DD - [54176.020] -[Receive] Allocate Jobs to Gangs and Gangs to Holds
29 Nov 2023 navhl20 ChangeRequest 61510: EUP | Ship Operations in DD - [54176.020] - [Release] Allocate Jobs to Gangs and Gangs to Holds
05 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
*/

vars
	wod 			: CM_WorkOrderDtl;
	oldJobSheet		: CM_WorkPointJobSheet;
	voyWPJob		: CM_VoyageWorkPointJob;
	id				: String;
	jobController 	: CMIF_VoyageJobParams;
	req				: CM_HoldRequest;
	voyage			: CM_Voyage;
	type			: Integer;
begin
	if _job.isWorkOrderJob then
		wod := _job.getMyWorkOrderDtl();
		id := wod.CM_WorkOrderTIDtl.getVoyageJobId(_job,self);
		if wod.isKindOf(CM_WodReceive) then									//29.11.2023 navhl20 #61510
			voyage := wod.CM_WodReceive.myVoyage;
			type   := JOB_TYPE_DISCHARGE;									//05.12.2023 navhl20 #58400[61617]
		else
			voyage := wod.CM_WodRelease.myVoyage;
			type   := JOB_TYPE_LOAD;										//05.12.2023 navhl20 #58400[61617]
		endif;
		
		create jobController transient;
		
		_pxyVoyageJob.setProxyVoyage(voyage);
		_pxyVoyageJob.setProxyVoyageJob(null,id, _pxyVoyageJob.remarks, null,  null, type,null, null, _pxyVoyageJob.actualStartTs, _pxyVoyageJob.actualEndTs,null);
		_pxyVoyageJob.setMyWorkOrderJobSheet(_job.myJobSheetForWorkOrder);
		_pxyVoyageJob.setRequiredByDT(_job.requiredByDT);
		_pxyVoyageJob.setMyWODtl(wod.CM_WorkOrderTIDtl);
		_pxyVoyageJob.setProxy(id,type);
		_pxyVoyageJob.setMyWorkorderJob(_job);									//29.11.2023 navhl20 #61510
		if _job.retrospectiveDT.isValid then									//11.03.2024 navhl20 #60097
			_pxyVoyageJob.setRetrospectiveDT(_job.retrospectiveDT);
		endif;
		
		jobController.myVoyage 				 := _pxyVoyageJob.myVoyage;
		jobController.myProxyJob 			 := _pxyVoyageJob;
		jobController.autoSortIntoOOW 		 := false;
		jobController.craneID 				 := self.myWorkPoint.code;
		jobController.myJobType 			 := null;
		jobController.remarks 				 := null;
		jobController.myWorkPoint			 := self.myWorkPoint;
		jobController.allowOutOfOrderLoading := false;
		
		
		app.myUtilityCA.utlCreateVoyageJob(jobController, _voyageJob, app.myPassport);
		
		if app.myPassport.noErrors then
			create req;
			req.setForCreateInternal(_voyageJob, _voyageJob.requiredByDT);
			req.setCode(id);
			req.setSequenced(true);
			if wod.isKindOf(CM_WodReceive) then
				req.setMoveType(DISCHARGE_MOVETYPE);
				req.setMyHoldDischarge(_hold);
			else
				req.setMoveType(LOAD_MOVETYPE);
				req.setMyHoldLoad(_hold);
			endif;
			
			_voyageJob.setMyWorkPointJobSheet(self);
		endif;
	endif;
epilog
	delete jobController;
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_pxyVoyageJob" type="CM_VoyageWorkPointJob" usage="input"/>
        <Parameter name="_voyageJob" type="CM_VoyageJob" usage="io"/>
        <Parameter name="_hold" type="CM_GeneralCargoController"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0c7c18f4-fc62-4e1c-9222-8e768cd8a180">
        <updating/>
        <source>setForUpdate(_proxyObj:SelfType)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet
12 June 2023 navhl20 ChangeRequest 56777: EUP | LMS Gang API - Additional Attribute
*/

vars

begin
	self.myWorkPoint    	:= _proxyObj.myWorkPoint;
	self.myTerminal			:= _proxyObj.myTerminal;
	self.externalName   	:= _proxyObj.externalName;
	self.startDateTime		:= _proxyObj.startDateTime;
	self.externalReference1	:= _proxyObj.externalReference1;
	self.externalReference2	:= _proxyObj.externalReference2;
	self.externalReference3	:= _proxyObj.externalReference3;				//12.6.2023 navhl20 #56777
epilog

end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateJob" id="98d6e52a-7f43-4554-82a1-51e86b0787ba">
        <updating/>
        <source>setForUpdateJob(_allJobs : CM_JobSet)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
19 Jul 2023 navhl20 ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs
*/

vars
	job 		: CM_Job;
	wod 		: CM_WorkOrderDtl;
	oldJobSheet	: CM_WorkPointJobSheet;
begin
	foreach job in _allJobs do
		oldJobSheet := job.myJobSheetForWorkPoint;
		job.setMyWorkPointJobSheet(self);
		if job.isWorkOrderJob then
			wod := job.getMyWorkOrderDtl();								//19.7.2023 navhl20 #58333
			if wod &lt;&gt; null then
				if oldJobSheet &lt;&gt; null and oldJobSheet.allWorkOrderDetails.includes(wod) then
					oldJobSheet.allWorkOrderDetails.remove(wod);
				endif;
				self.allWorkOrderDetails.addNoDuplicates(wod,false);
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_allJobs" type="CM_JobSet"/>
    </JadeMethod>
    <JadeMethod name="setMyShift" id="775bdba3-0820-4709-824e-a153c1cb0f13">
        <updating/>
        <source>setMyShift(_pxyJobSheet   : CM_WorkPointJobSheet;
		   _passport	  : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet

*/

vars
	pxyShift  : CM_Shift;
	realShift : CM_ShiftEntity;
begin
	
	pxyShift := _pxyJobSheet.myShift;
	if pxyShift &lt;&gt; null then
		realShift := app.myProxyManager.getRealObject(pxyShift).CM_Shift;
		if realShift = null then
			realShift := _pxyJobSheet.myTerminal.allShiftsDay[pxyShift.startDateTime, pxyShift.code];
			
			if realShift = null then
				app.myUtilityCA.utlCreateShiftStd(pxyShift, _passport, realShift);
			else
				if realShift.pxyGetProxyObject = pxyShift then
					app.myUtilityUA.utlUpdateShift(pxyShift, _passport);
				endif;
			endif;
			if realShift &lt;&gt; null then
				self.myShift := realShift.CM_Shift;
			endif;
		endif;
	endif;
	
	

epilog

end;</source>
        <Parameter name="_pxyJobSheet" type="CM_WorkPointJobSheet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="fe3416e1-a1a5-4a46-bdb2-282e6224f2b0">
        <updating/>
        <source>setProxy( _shift         : CM_Shift;
		  _term          : CM_Terminal;
		  _workPoint     : CM_WorkPoint;
		  _startDateTime : TimeStamp; 
		  _externalName,
		  _externalRef1,
		  _externalRef2,
		  _externalRef3: String)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet
12 June2023 navhl20 ChangeRequest 56777: EUP | LMS Gang API - Additional Attribute
25 Jun 2023 navma1  ChangeRequest 58589[58595]: EUP | LMS Gang API - Endpoint
*/

vars

begin
	self.myShift        	:= _shift;
	self.myTerminal			:= _term;
	self.myWorkPoint		:= _workPoint;
	self.externalName   	:= _externalName.toUpper();
	self.startDateTime  	:= _startDateTime;
	self.externalReference1 := _externalRef1.toUpper();
	self.externalReference2 := _externalRef2.toUpper();
	self.externalReference3	:= _externalRef3.toUpper();			//12.6.2023 navhl20 #56777
epilog

end;</source>
        <Parameter name="_shift" type="CM_Shift"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <Parameter name="_startDateTime" type="TimeStamp"/>
        <Parameter name="_externalName" type="String"/>
        <Parameter name="_externalRef1" type="String"/>
        <Parameter name="_externalRef2" type="String"/>
        <Parameter name="_externalRef3" type="String"/>
    </JadeMethod>
