    <JadeMethod name="doPicCptP2SB2TClick" id="cf75476e-3ae6-4614-9bea-fb5c308842fb">
        <updating/>
        <source>doPicCptP2SB2TClick() updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		Port Side Standard Sequencing - Bottom To Top
//				Set the sequence numbers of the requests for the selected job in Port Side Standard Sequencing
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	// we need to set the sequence from both directions, just incase when the voyage arrives it is berthed the other way around
	self.doSetCustomSequencing(SHP_SlotReqSeqCarpetS2PB2T, self.myCurrentVoyage.starboardBerthed);
	self.doSetCustomSequencing(SHP_SlotReqSeqCarpetP2SB2T, not self.myCurrentVoyage.starboardBerthed);
end;</source>
