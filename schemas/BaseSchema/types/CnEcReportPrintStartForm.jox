    <JadeMethod name="btnCancel_click" id="a0ceb317-8a5f-4e93-90fa-f30448c0b9a7">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

begin
	self.modalResult	:=	1;
	self.unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOK_click" id="9258b09c-ee2f-46f5-bc84-f7a37f449f19">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOK_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;

	if self.doFormUpdate(false) then
		self.modalResult	:=	0;
		self.unloadForm();
	else
		// The notifications will have been ended if a queue entry was being updated, or
		// if an error message resulted after creating then trying to run the report.
		self.registerNotifications();
	endif;
epilog
	self.doWindowEvents(0);
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnPrintFile_click" id="ea9e03e5-8dec-40f2-8f47-b90b17fc4fea">
