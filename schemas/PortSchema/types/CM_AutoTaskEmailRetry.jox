    <JadeMethod name="getValueForRow" id="fd32f3e6-2af4-4a73-ba00-4be7f24f2b58">
        <source>getValueForRow(_rowName: String; _obj : Object output): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 January 2023	navmd1	Initial creation TFS 55020 OAuth Email Enhancements

*/

vars

begin
	if _rowName = ETRow_NumberOfRetries then
		return self.numMaxRetries.String;
	endif;
	
	return inheritMethod(_rowName, _obj);
epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0dc45606-cc24-4680-a397-2ee9e908bb55">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskEmailRetry) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 January 2023	navmd1	Initial creation TFS 55020 OAuth Email Enhancements

*/

vars

begin
	inheritMethod(_pxyAutoTask);
	
	self.requestClassName	:= BGP_EmailRetryRequest.name;
	self.numMaxRetries		:= _pxyAutoTask.numMaxRetries;

epilog

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskEmailRetry"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2ba8919f-c900-4b9e-be85-80c33394ba6e">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskEmailRetry) updating;
/*

Purpose:			

