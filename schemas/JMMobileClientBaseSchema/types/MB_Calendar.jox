        <source>click(cntrl: MB_Calendar input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl);
end;</source>
        <Parameter name="cntrl" type="MB_Calendar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="2f1fb356-cfdc-4bac-8fcc-f1ec3993bcdb">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isBuilt		:=	false;
	self.changeType		:=	self.ChangeType_None;
	self.dayNameLength	:=	3;
	self.borderStyle	:=	Control.BorderStyle_Single;
	self.show3D			:=	Control.Show3D_Use3D;
	self.transparent	:=	true;
end;</source>
    </JadeMethod>
    <JadeMethod name="createButton" id="a5211f3a-e3cf-4338-bda6-339d1ec07f56">
        <updating/>
        <source>createButton(_buttonObj:MB_CalendarButton io; _leftPos:Real ; _caption:String) updating, protected;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _buttonObj = null then
		create _buttonObj transient;
		_buttonObj.setCalendar(self);
		_buttonObj.parent	:=	self;
		self.form.addControl(_buttonObj);
		
		if self.isInPainter() then
			_buttonObj.actualEnabled	:=	false;
		endif;
	endif;
	
	_buttonObj.left				:=	_leftPos;
	_buttonObj.height			:=	self.clientHeight / (self.NumOfRows + 1);
	_buttonObj.width			:=	self.clientWidth / self.ButtonWidthRatio;
	_buttonObj.caption			:=	_caption;
	_buttonObj.foreColor		:=	self.foreColor;
	_buttonObj.fontName			:=	self.fontName;
	_buttonObj.fontSize			:=	self.fontSize;
	_buttonObj.fontBold			:=	self.fontBold;
	_buttonObj.fontItalic		:=	self.fontItalic;
	_buttonObj.fontUnderline	:=	self.fontUnderline;
	_buttonObj.fontStrikethru	:=	self.fontStrikethru;
end;</source>
        <access>protected</access>
        <Parameter name="_buttonObj" type="MB_CalendarButton" usage="io"/>
        <Parameter name="_leftPos" type="Real"/>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="createLabel" id="23c24ca8-c6ec-4c71-b13e-d393311d51c7">
        <updating/>
        <source>createLabel(_labelObj:MB_CalendarLabel io; _leftPos:Real; _width:Real; _caption:String) updating, protected;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _labelObj = null then
		create _labelObj transient;
		_labelObj.parent	:=	self;
		self.form.addControl(_labelObj);
		
		if self.isInPainter() then
			_labelObj.actualEnabled	:=	false;
		endif;
		
		_labelObj.borderStyle	:=	Control.BorderStyle_Single;
		_labelObj.alignment		:=	self.Alignment_Center_Middle;
		_labelObj.caption		:=	_caption;
	/*	Doesn't work in JADE 5.1
		if _labelObj = monthLabel then
			_labelObj.caption := today.monthName;
		else
			_labelObj.caption := today.year.String;
		endif;
	*/
	endif;
	
	_labelObj.left				:=	_leftPos;
	_labelObj.height			:=	self.clientHeight / (self.NumOfRows + 1);
	_labelObj.width				:=	_width;
	_labelObj.backColor			:=	self.backColor;
	_labelObj.foreColor			:=	self.foreColor;
	_labelObj.fontName			:=	self.fontName;
	_labelObj.fontSize			:=	self.fontSize;
	_labelObj.fontBold			:=	self.fontBold;
	_labelObj.fontItalic		:=	self.fontItalic;
	_labelObj.fontUnderline		:=	self.fontUnderline;
	_labelObj.fontStrikethru	:=	self.fontStrikethru;
end;</source>
        <access>protected</access>
        <Parameter name="_labelObj" type="MB_CalendarLabel" usage="io"/>
        <Parameter name="_leftPos" type="Real"/>
        <Parameter name="_width" type="Real"/>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="createTable" id="da7b7e34-64a9-495d-9b9c-d6b2fd536298">
        <updating/>
        <source>createTable(_tableObj:MB_CalendarTable io; _posTop:Real) updating, protected;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	today		:	Date;
	rowColCount	:	Integer;

begin
	if _tableObj = null then
		create _tableObj transient;
		_tableObj.setCalendar(self);
		_tableObj.parent	:=	self;
		self.form.addControl(_tableObj);
		
		if self.isInPainter() then
			_tableObj.actualEnabled	:=	false;
		endif;
		
		_tableObj.rows			:=	self.NumOfRows;
		_tableObj.columns		:=	self.DaysOfWeek;
		_tableObj.fixedRows		:=	_tableObj.rows;
		_tableObj.fixedColumns	:=	_tableObj.columns;
		_tableObj.alignment		:=	Table.Alignment_Center;
		_tableObj.borderStyle	:=	Window.BorderStyle_None;
		_tableObj.readOnly		:=	true;
		_tableObj.tabStop		:=	false;
		_tableObj.allowResize	:=	3; // None
		_tableObj.showDays(today);
		_tableObj.selectDay(today);
		_tableObj.fixed3D		:=	false;
	endif;
	
	_tableObj.top		:=	_posTop;
	_tableObj.width		:=	self.clientWidth;
	_tableObj.height	:=	self.clientHeight - _posTop;
	rowColCount			:=	_tableObj.rows - 1;
	
	while rowColCount &gt; 0 do
		_tableObj.rowHeight[rowColCount]	:=	(_tableObj.height / _tableObj.rows).rounded();
		rowColCount	:=	rowColCount - 1;
	endwhile;
	
	_tableObj.rowHeight[_tableObj.rows]	:=	_tableObj.height.Integer - (_tableObj.rows - 1) * (_tableObj.height / _tableObj.rows).rounded();
	rowColCount	:=	_tableObj.columns - 1;
	
	while rowColCount &gt; 0 do
		_tableObj.columnWidth[rowColCount]	:=	(_tableObj.width / _tableObj.columns).rounded; 
		rowColCount	:=	rowColCount - 1;
	endwhile;
	
	_tableObj.columnWidth[_tableObj.columns] := _tableObj.width.Integer - (_tableObj.columns - 1) * (_tableObj.width / _tableObj.columns).rounded();
	//self.myMonthTable.accessMode	:=	0;
	_tableObj.accessMode	:=	0;
	_tableObj.foreColor		:=	self.foreColor;
	
	if _tableObj.fontName &lt;&gt; self.fontName then	// Workaround for the bug in Painter that causes paint events in a loop
		_tableObj.fontName	:=	self.fontName;
	endif;
	
	_tableObj.fontSize			:=	self.fontSize;
	_tableObj.fontBold			:=	self.fontBold;
	_tableObj.fontItalic		:=	self.fontItalic;
	_tableObj.fontUnderline		:=	self.fontUnderline;
	_tableObj.fontStrikethru	:=	self.fontStrikethru;
end;</source>
        <access>protected</access>
        <Parameter name="_tableObj" type="MB_CalendarTable" usage="io"/>
        <Parameter name="_posTop" type="Real"/>
    </JadeMethod>
    <JadeMethod name="date" id="09997164-ecbd-44bf-b703-cb3db6e77947">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>date(set: Boolean; _value: Date io) mapping, updating;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	today	: Date;

begin
	// Check if 'value' is a valid date
	if not _value.isValid() then
		// Default current date
		_value	:=	today;
	endif;

	if set and self.isTransient() and _value &lt;&gt; null and self.date &lt;&gt; _value then
		if self.date &lt;&gt; null then
		 	if self.date.month &lt;&gt; _value.month or self.date.year &lt;&gt; _value.year then
				self.myMonthTable.showDays(_value);
			endif;
		endif;
		
		self.myMonthTable.selectDay(_value);
		self.myMonthLabel.caption	:=	_value.monthName;
		self.myYearLabel.caption	:=	_value.year.String;
		self.date	:=	_value;
		
		if self.changeType = self.ChangeType_None then
			self.changeType	:=	self.ChangeType_Script;
		else
			click(self);		
		endif;
		
		self.changeType	:=	self.ChangeType_None;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Date" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getIsBuilt" id="cbdc791c-0d2c-41fd-93a4-5ad0b9d037b1">
        <source>getIsBuilt():Boolean;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.isBuilt;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="paint" id="a7bb0ecd-f89b-4f67-a879-b3c579c26ab2">
        <controlMethod name="BaseControl::paint"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>paint(cntrl: MB_Calendar input) updating;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	today : Date;
	
begin
	inheritMethod(cntrl);
	
	if self.isInPainter() then
		self.buildSelf();
	elseif not self.isBuilt then
		self.buildSelf();
		self.isBuilt	:=	true;
		self.date		:=	today;
	endif;
end;</source>
        <Parameter name="cntrl" type="MB_Calendar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="refresh" id="2e7ddfcd-b955-4d29-bd48-44b8f8807380">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>refresh() updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod;
	
	if not self.isInPainter() then
		self.buildSelf();
		self.myMonthTable.selectDay(self.date);
	endif;
end;</source>
    </JadeMethod>
