    <JadeMethod name="pxyCreateUpdateProxy" id="5ad3d348-4781-4e22-a4a5-bd4a8038cf85">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
12 August 2009	cnwmd1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	pxy : SelfType;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();
	
	pxy.mySourceLocation := self.mySourceLocation;
	pxy.myTargetLocation := self.myTargetLocation;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e14b149f-5bb6-4188-a48c-b55293202a9c">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WorkOrderDtl) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwrd1	Initial creation

*/

vars
	proxy : CM_WodMove;
begin
	
	inheritMethod(_pxyWoDDtl);
	
	proxy 					:= _pxyWoDDtl.CM_WodMove;
	self.mySourceLocation 	:= proxy.mySourceLocation;
	self.myTargetLocation 	:= proxy.myTargetLocation;
	self.targetLocation 	:= proxy.targetLocation;
	self.autoRTQ 			:= proxy.autoRTQ;
	
epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyMove" id="0615ac7e-fc07-44bb-805a-15e8dc715325">
        <updating/>
        <source>setProxyMove(_srcLocation, _tgtLocation : CM_TerminalArea; _autoRTQ : Boolean; _lc: CM_LocationsController)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Aug 2009	cnwmd1	Initial creation
26 May 2022	navma1	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
*/

vars
	srcLocation, tgtLocation, tc: CM_LocationsController;
	dummyHeight : Integer;
	
begin

	if _srcLocation &lt;&gt; null then
		srcLocation := _srcLocation.getLocationsController(); 
	endif;
	
	if _tgtLocation &lt;&gt; null then
		tgtLocation := _tgtLocation.getLocationsController(); 
	endif;

	if tgtLocation = null and _lc &lt;&gt; null then 	//26.05.2022 navma1 #53038
		tgtLocation := _lc;
	endif;
	
	self.mySourceLocation := srcLocation;
	self.myTargetLocation := tgtLocation;
	
	if _tgtLocation &lt;&gt; null then
		self.targetLocation := _tgtLocation.id;
	endif;
	
	self.autoRTQ := _autoRTQ;
epilog

end;</source>
        <Parameter name="_srcLocation" type="CM_TerminalArea"/>
        <Parameter name="_tgtLocation" type="CM_TerminalArea"/>
        <Parameter name="_autoRTQ" type="Boolean"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="7efd95c9-ba76-4b1d-8f63-1eb535857f7d">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_WodMove::mySourceLocation.name    			or 
		propName = CM_WodMove::myTargetLocation.name 			
		then
		return false;
		
	endif;
	return inheritMethod(_rootClass, _property);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="4bf0b249-6fab-4c82-b8c0-f2892d40fae6">
        <source>validate()protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Aug 2009	cnwmd1	Initial creation
26 May 2022	navma1	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
06 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
*/

vars
	ti : CM_TrackedItem;
begin
	inheritMethod();
	
	
	if  self.myTargetLocation = null then								//06.03.2023 navma1 #56457:[56458]
		app.raiseCMException2(Work_order_task_require, self.getDisplayString(true), app.getErrorString(To_Location), null, null);
	endif;
	
	if not self.myParent.hasBeenApproved then							//06.03.2023 navma1 #56457:[56458]
		foreach ti in self.allSelectedTIs do
			if ti.myPrimaryActualLocation = null then
				continue;
			endif;
			if ti.myPrimaryActualLocation = self.myTargetLocation then
				app.raiseCMException2(ERR_ALREADY_HERE, ti.id, self.myTargetLocation.ident,null, null); 
				break;
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateForApproval" id="e03f1534-1456-497a-95b4-2322edbbe3e3">
        <source>validateForApproval();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Jan 2010	cnwrd1	Initial creation
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars

begin
	inheritMethod();
	
	if self.targetLocation = null and myTargetLocation = null then
		app.raiseCMException2(Work_order_task_require, self.getDisplayString(true), app.getErrorString(To_Location), null, null);
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
