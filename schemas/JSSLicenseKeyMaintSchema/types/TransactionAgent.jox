    <DbClassMap file="jsslicensemaint_transient"/>
    <JadeMethod name="trxAddUsedComponents" id="f0adb2c5-e26b-4ed5-af62-542bbf58ed46">
        <source>trxAddUsedComponents(	pTheCustomer:JSSLKCustomer input;
						pRequiredEdition:Integer;
						pAllComponents:JSSLKComponentArray;
						pExpiryDate:Date);
// --------------------------------------------------------------------------------
// Created:		23 January 2003 by cnwdad2
//
// Purpose:		Add multiple used product components to a Customer.
//
// Parameters:	pTheCustomer - The customer object to update.
//				pRequiredEdition - The object edition of the customer object.
//				pAllComponents - A collection of components to add.
//				pExpiryDate - The date on which the product license will expire.
//
// Returns:		Nothing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	beginTransaction;
	
	exclusiveLock(pTheCustomer);
	
	if pRequiredEdition &lt;&gt; 0 then
		if pRequiredEdition &lt;&gt; pTheCustomer.edition then
			JSSLKException.raise_(99999, $EDITION_OUTOFDATE("Customer", pTheCustomer.customerName));
		endif;
	endif;
	
	pTheCustomer.addUsedComponents(pExpiryDate, pAllComponents);
	
	commitTransaction;
end;</source>
        <Parameter name="pTheCustomer" type="JSSLKCustomer" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pAllComponents" type="JSSLKComponentArray"/>
        <Parameter name="pExpiryDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="trxCreateComponent" id="250500e7-05de-4e6c-b197-4f06b75ff7a2">
        <source>trxCreateComponent(	pComponentId:Integer;
					pComponentDescription:String;
					pTheProduct:JSSLKProduct;
					pTheNewComponent:JSSLKComponent output);
// --------------------------------------------------------------------------------
// Created:		23 January 2003 by cnwdad2
//
// Purpose:		Creates a new Product Component object.
//
// Parameters:	pComponentId - The component identifier.
//				pComponentDescription - A description of the product component.
//				pTheProduct - The owner of the component object.
//				pTheNewComponent - An output parameter for the new component object.
//
// Returns:		The newly created object as an output parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theComponent	: JSSLKComponent;
	
begin
	theComponent	:=	pTheProduct.allComponents[pComponentId];
	
	if theComponent = null then
		beginTransaction;
		theComponent	:=	pTheProduct.createComponent(pComponentId, pComponentDescription);
		commitTransaction;
		
		pTheNewComponent	:=	theComponent;
	else
		JSSLKException.raise_(99999, $PRODUCT_COMPONENT_EXISTS(pComponentId.String));
	endif;
end;</source>
        <Parameter name="pComponentId" type="Integer"/>
        <Parameter name="pComponentDescription" type="String"/>
        <Parameter name="pTheProduct" type="JSSLKProduct"/>
        <Parameter name="pTheNewComponent" type="JSSLKComponent" usage="output"/>
    </JadeMethod>
    <JadeMethod name="trxCreateCustomer" id="23536053-958a-4aaa-9fba-64ffecc459e0">
        <source>trxCreateCustomer(	pCustomerName:String;
					pTheRoot:JSSLKProductRoot;
					pTheNewCustomer:JSSLKCustomer output);
// --------------------------------------------------------------------------------
// Created:		23 January 2003 by cnwdad2
//
// Purpose:		Creates a new Customer object.
//
// Parameters:	pCustomerName - The name of the customer.
//				pTheRoot - The owner of the customer object.
//				pTheNewCustomer - An output parameter for the new customer object.
//
// Returns:		The newly created object as an output parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCustomer	: JSSLKCustomer;
	
begin
	theCustomer	:=	pTheRoot.allCustomers[pCustomerName];
	
	if theCustomer = null then
		beginTransaction;
		theCustomer	:=	pTheRoot.createCustomer(pCustomerName);
		commitTransaction;
		
		pTheNewCustomer	:=	theCustomer;
	else
		JSSLKException.raise_(99999, $CUSTOMER_EXISTS(pCustomerName));
	endif;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pTheRoot" type="JSSLKProductRoot"/>
        <Parameter name="pTheNewCustomer" type="JSSLKCustomer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="trxCreateProduct" id="2084e27f-14c2-4950-8441-d4f4927a3dbe">
        <source>trxCreateProduct(	pProductName:String;
					pProductCode:String;
					pProductVersion:String;
					pProductLogo:Binary;
					pTheRoot:JSSLKProductRoot;
					pTheNewProduct:JSSLKProduct output);
// --------------------------------------------------------------------------------
// Created:		23 January 2003 by cnwdad2
//
// Purpose:		Creates a new Product object.
//
// Parameters:	pProductName - The name of the product.
//				pProductCode - The unique product code.
//				pProductVersion - The release version of the product.
//				pProductLogo - An image of the product logo.
//				pTheRoot - The owner of the product object.
//				pTheNewProduct - An output parameter for the new product object.
//
// Returns:		The newly created object as an output parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theProduct	: JSSLKProduct;
	
begin
	theProduct	:=	pTheRoot.allProducts[pProductName];
	
	if theProduct = null then
		beginTransaction;
		theProduct	:=	pTheRoot.createProduct(pProductName, pProductCode, pProductVersion, pProductLogo);
		commitTransaction;
		
		pTheNewProduct	:=	theProduct;
	else
		JSSLKException.raise_(99999, $PRODUCT_EXISTS(pProductName));
	endif;
end;</source>
        <Parameter name="pProductName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pProductVersion" type="String"/>
        <Parameter name="pProductLogo" type="Binary"/>
        <Parameter name="pTheRoot" type="JSSLKProductRoot"/>
        <Parameter name="pTheNewProduct" type="JSSLKProduct" usage="output"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteComponent" id="5cca4e0d-a1b2-4801-9bc6-2bb0e94bde40">
        <source>trxDeleteComponent(pTheComponent:JSSLKComponent io);
// --------------------------------------------------------------------------------
// Created:		23 January 2003 by cnwdad2
//
// Purpose:		Deletes the specified Product Component object.
//
// Parameters:	pTheComponent - The Product Component to delete.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	beginTransaction;
	
	exclusiveLock(pTheComponent);
	delete pTheComponent;
	
	commitTransaction;
end;</source>
        <Parameter name="pTheComponent" type="JSSLKComponent" usage="io"/>
    </JadeMethod>
