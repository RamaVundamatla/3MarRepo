    <JadeMethod name="getMoveAcceptTimeLocalTZ" id="0993677e-abd4-4d29-bde1-f9309e666f62">
        <source>getMoveAcceptTimeLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2016	cnwns1	Initial creation
// 02 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.acceptTS);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="jrwGetIMEXDescription" id="713cd8e1-b469-4433-9f17-024dd11b8762">
        <source>jrwGetIMEXDescription():String;
// ---------------------------------------------------------------------------
// Created:     08 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	imx : CM_IMEXStatus;
	
begin
	imx := app.myRoot.allImexStatuses[self.imexStatus];
	
	if imx &lt;&gt; null then
		return imx.description;
	else
		return CM_IMEXStatus.Unknown_IMEXStatus;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="myISOType" id="f34467f8-d34c-43e7-afa1-eb5ee1a7a56b">
        <methodInvocation>mapping</methodInvocation>
        <source>myISOType(set : Boolean; _value : CM_ISOType io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2012	cnwndl1	Initial creation	Par 30471

*/

vars

	invalidObject : Boolean;
	code : String;

begin

	if not set then
		if _value &lt;&gt; null then
			on Exception do app.handleDeletedObject( exception, _value, invalidObject );
			code := _value.code;
			if invalidObject then
				_value := null;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_ISOType" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForMove" id="ebdd9197-3a69-45a8-bd9c-dc801a86ac5e">
        <updating/>
        <source>setForMove(_history :CM_MachineMoveHistory; _kpiMachine :CM_KPIMachineEntity)updating;
// ---------------------------------------------------------------------------
// Created:     04 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  _history	- move history for an instant move
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.acceptTS		:= _history.getAcceptMoveTS;
	self.duration		:= _history.getMoveDuration;
	self.finishTS		:= _history.getEndOfMoveTS;
	self.grossDuration	:= _history.getGrossMoveDuration;
	//self.netDuration	:= ???
	self.numTEU			:= _history.getTEU;
	self.slackTime		:= _history.getMoveSlackTime;
	self.startTS		:= _history.getStartOfMoveTS;
	self.weight			:= _history.weight;
	self.imexStatus 	:= _history.getIMEXStatus;
	self.isMT			:= _history.isMT;
	self.myCargoType	:= _history.getCargoType;
	self.myISOType		:= _history.getISOType;
	self.sourceLocation	:= _history.sourceLocation;
	self.targetLocation	:= _history.targetLocation;
	self.tiId			:= _history.tiId;
	
	self.allMachineHistory.addNoDuplicates (_history, false);
	
	self.myKPIMachineEntity		:= _kpiMachine;
epilog

end;</source>
        <Parameter name="_history" type="CM_MachineMoveHistory"/>
        <Parameter name="_kpiMachine" type="CM_KPIMachineEntity"/>
    </JadeMethod>
    <JadeMethod name="setForSetDown" id="f962f8a8-3c9d-441b-bd97-24a15d789081">
        <updating/>
        <source>setForSetDown(_history :CM_MachineMoveHistory; _kpi :CM_KPIMachineEntity)updating;
// ---------------------------------------------------------------------------
// Created:     04 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.acceptTS		:= _history.getAcceptMoveTS;
	self.duration		:= _history.getMoveDuration;
	self.finishTS		:= _history.getEndOfMoveTS;
	self.grossDuration	:= _history.getGrossMoveDuration;
	//self.netDuration	:= ???
	self.numTEU			:= _history.getTEU;
	self.slackTime		:= _history.getMoveSlackTime;
	self.startTS		:= _history.getStartOfMoveTS;
	self.weight			:= _history.weight;
	self.imexStatus 	:= _history.getIMEXStatus;
	self.isMT			:= _history.isMT;
	self.myCargoType	:= _history.getCargoType;
	self.myISOType		:= _history.getISOType;
	self.tiId			:= _history.tiId;
	
	// get all history items for this move
	_history.getAllMoveEntries (self.allMachineHistory);

	self.sourceLocation		:= _history.getStartOfMoveSourceLocation;
	self.targetLocation		:= _history.targetLocation;

	self.myKPIMachineEntity	:= _kpi;
epilog

end;</source>
        <Parameter name="_history" type="CM_MachineMoveHistory"/>
        <Parameter name="_kpi" type="CM_KPIMachineEntity"/>
    </JadeMethod>
</Class>
