    <JadeMethod name="selectCargoItem" id="29a06f91-81b2-4314-9607-661ae073863e">
        <updating/>
        <source>selectCargoItem( _manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2015	cnwndl1	Initial creation	Par 37011

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	errMsg : String;
	
	revDict : CM_TIByIdCargoTypeDictRev;	
	cargoIdLength : Integer;	
	cargoIdReversed : String;	
	
begin

	self.setMyTrackedItem( null );

	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;
	
	term := self.myMobileDataAgent.myTerminal;
	
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	
		cargoIdReversed := cargoId.reverse;
		
		firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		firstTi := term.allOnsiteTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := term.allOnsiteTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		
	endif;
		
	if tiArray.size = 1 then
		self.setMyTrackedItem( tiArray.first );
		return;
		
	else
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setDoSearchImmediate( cargoId.trimBlanks &lt;&gt; null );
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSITE);	
		
		self.gotoForm( MOB_HHCargoFind, false );
		return;
		
	endif;
	

epilog

	delete tiArray;
	delete iter;
	delete revDict;	

end;</source>
        <Parameter name="_manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="7b0f74be-315c-41b7-ae03-4de7f65aa54e">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2015	cnwndl1	Initial creation	Par 37011

*/

vars

	useFullDesc : Boolean;
	todoTask : CM_ToDoTask;
	taskDesc : CM_ToDoTaskDesc;
	lineStr : String;
	index : Integer;
	desc1 : String;
	desc2 : String;

begin

	self.getSessionAgent().setMySelectedTI( _ti );
	app.myMobileCargoFindAgent.setMyTrackedItemToProcess( null );
	self.myTrackedItem := _ti;
	
	self.cmbTasks.clear();
	self.btnOne.enabled := false;
	
	if _ti = null then
		self.lblCargoType.caption := null;
		self.lblCargoDesc.caption := null;
	
	else
		self.txtCargoId.text := _ti.id;
		_ti.getShortDescriptions( desc1, desc2 );
		self.lblCargoType.caption := desc1;
		self.lblCargoDesc.caption := desc2;
		
		useFullDesc := app.myPassport.myTerminal.getConfig( HhTaskUseFullDesc ).Boolean;
		foreach todoTask in _ti.allToDoTasksToDo do	
			taskDesc := todoTask.toDoTaskDesc;	
			if useFullDesc or taskDesc.shortDescription = null then
				lineStr := taskDesc.description;
			else
				lineStr := taskDesc.shortDescription;
			endif;	
			index := self.cmbTasks.addItem( lineStr );
			self.cmbTasks.itemObject[index] := todoTask;	
			self.btnOne.enabled := true;	
		endforeach;
		
		if self.cmbTasks.listCount &gt; 1 then
			lineStr := "&lt;" &amp; app.getErrorString(Please_select_todo_task) &amp; "&gt;";
			self.cmbTasks.addItemAt( lineStr, 1 );
		endif;
	
	endif;
	
	if self.cmbTasks.listCount &lt; 1 then
		lineStr := "&lt;" &amp; app.getErrorString(No_Current_tasks) &amp; "&gt;";
		self.cmbTasks.addItemAt( lineStr, 1 );
	endif;
	
	self.cmbTasks.listIndex := 1;
	self.changeTask();
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
