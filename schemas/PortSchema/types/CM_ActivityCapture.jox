    <JadeMethod name="stopCapture" id="7b7a1051-cea8-4e84-981e-7383215cd072">
        <updating/>
        <source>stopCapture() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	08 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	prof			: JadeProfiler;
	now				: TimeStamp;
	fileFolder		: FileFolder;
	duration		: Real;
begin
	if (not self.currentlyCapturing) then
		return;
	endif;
	
	duration := (now - self.startTime.Time).Time.getTotalMilliseconds();
	
	if self.doProfile and duration &gt; self.durationThreshold then
		prof := process.profiler;
		prof.stop;
		create fileFolder transient;
		fileFolder.fileName := global.getJadeInstallDirServer;
		prof.fileName := fileFolder.fileName &amp; '\' &amp; self.myPassport.getUserCode &amp; '_' &amp; now.getNumeralString &amp; '.log';
		prof.report();
		self.logProfile(prof.fileName);
	endif;
	self.logDiagnostic('Capture ended @ ' &amp; now.time.String &amp; '- mode '&amp; self.getModeDescr() &amp; ':');
	
epilog

	self.currentlyCapturing := false;
	delete fileFolder;
end;</source>
        <access>protected</access>
    </JadeMethod>
