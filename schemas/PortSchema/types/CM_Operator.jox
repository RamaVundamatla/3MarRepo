    <JadeMethod name="getXlationSystemCode_Voyage" id="f2a179f3-d25d-469a-beb3-db7e9daf189a">
        <source>getXlationSystemCode_Voyage( _foreignCode : String; _vesselName, _lloydsNumber, _callSign : String;  _foundMatch :Boolean output) : String;

/*
Date		Who		Reason
20 Aug 2018 jlggb1	TFS 40081 New Method getXlationSystemCode_VoyageEx gets the internals that was in this method.
20 Aug 2018 jlggb1  TFS 40081 Refine Voyage translation to take into account voyage direction.
*/

vars

begin
	return self.getXlationSystemCode_VoyageEx( _foreignCode, _vesselName, _lloydsNumber, _callSign, 0, _foundMatch);
end;
</source>
        <Parameter name="_foreignCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_lloydsNumber" type="String"/>
        <Parameter name="_callSign" type="String"/>
        <Parameter name="_foundMatch" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXlationSystemCode_VoyageEx" id="f9056634-591b-4aaf-a8a3-5e190dab5960">
        <source>getXlationSystemCode_VoyageEx( _foreignCode : String; _vesselName, _lloydsNumber, _callSign : String; _direction : Integer; _foundMatch :Boolean output; _params: ParamListType) : String;

/*

This should only be called when you have a direction value (other that 0) or an import criteria setting, otherwise call getXlationSystemCode_Voyage, which calls this method.


Date		Who		Reason
18 Nov 2005	cnwjc2	Initial creation
nn Nov 2006 	cnwrs1	CCMS 1054 add support for callsign and lloyds number
19 Nov 2010	cnwkpd1	PAR #25810 - EDI Performance information
11/11/2010	cnwrl1	PAR 26099 - Performance enhancement of vessel access.
15/12/2010  cnwrs1  CCMS 1976 - change voyage xlation to use inland terminals if they exist
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks
07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures.  Use systemCode instead og myVoyage
											  - renamed method.  Make this method only place voyage inward xlations done -used to us getXlationSystemCode as well
13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
18 Aug 2018 jlggb1	TFS 40089 Voyage Translations ignoring vessel when IMO and Call sign not on vessel record
20 Aug 2018 jlggb1	TFS 40081 New Method getXlationSystemCode_VoyageEx
20 Aug 2018 jlggb1  TFS 40081 Refine Voyage translation to take into account voyage direction.
21 Feb 2019 jlgsl4  TFS 42728 - SNO - file callsign doesn't match Voyage Code translation's vessel's callsign
05 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
*/
constants 
	INWARDS = -1;
	EITHER = 0;
	OUTWARDS = 1;
vars
	xlation				: CM_Xlation_In;
	operatorTerminal	: CM_OperatorTerminal;
    systemCode			: String; 
	foreignCodeAsIs		: String; 
    foreignCodeUC		: String;
    vessel				: CM_Vessel;
    xlationTable		: CM_XlationTable;
	coll				: CM_MemberKeyDictionary;
	iter				: Iterator;
	terminalArray 		: CM_TerminalArray;	//ccms 1976 cnwrs1 16 dec 2010
	terminal 			: CM_Terminal;
	voyage				: CM_Voyage;
	terminalCopy 		: CM_Terminal; // TFS 42728
	score : Integer;		//19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
	bestMatch : Integer;	//19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
	haveCriteria : Boolean;
	count : Integer;
	param : Any;
	paramIsImport : Boolean;
begin
	foreignCodeAsIs	:= _foreignCode.trimBlanks;
	
	//type is XLATION_TYPE_VOYAGETERMINAL
	
	if foreignCodeAsIs = null then
		return systemCode;
	endif;
	
	// Find the vessel in JMT.
	// ======================
	// First we do a name search.
	// If found, we do an additional lloyds number/call sign check if lloyds number or call sign is given in the file. If the vessel in JMT has a different (non blank) 
	// lloyds number or call sign  then the vessel found is discarded. Note that a vessel in JMT that doesn't have lloyds number or call sign will never be discarded.
	//
	// If we have not determined a vessel after these checks, we do a lloyds number search, failing that a call sign search. Note that the vessel name is not checked in that case
	// jlggb1 18 Aug 2018
	
	count := app.getParamListTypeLength(_params);		//19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
	if count = 1 then
		param := app.getParamListTypeEntry(1, _params);
		if param.isKindOf(Boolean) then
			paramIsImport := param.Boolean;		//a false param means xlation with isImport or not isImport are correct
		endif;
	endif;

	if _vesselName &lt;&gt; null then //ccms 1054
		vessel := app.myRoot.getVesselByName(_vesselName);
		
		//par 17672 cnwrs1 Aug 2008 now we have a vessel by name check that its lloyds number or callsign match (if we have them)
		if vessel &lt;&gt; null then
			if not vessel.canCreateVoyages then
				vessel := null;
			elseif (_lloydsNumber &lt;&gt; null and vessel.lloydsNumber &lt;&gt; null) and _lloydsNumber &lt;&gt; vessel.lloydsNumber then // jlggb1 TFS 40089 18 August 2018
				vessel := null;
			elseif (_callSign &lt;&gt; null and vessel.callSign &lt;&gt; null) and _callSign &lt;&gt; vessel.callSign then // jlggb1 TFS 40089 18 August 2018
				vessel := null;
			endif;
		endif;
	endif;
	
	// if the correct vessel has not been found via the vessel name attempt through the lloydsNumber or callSign
	if vessel = null and (_callSign &lt;&gt; null or _lloydsNumber &lt;&gt; null) then
		vessel	:= app.myRoot.getVesselByLloydsNumber( _lloydsNumber, true );
		
		if vessel = null then
			vessel	:= app.myRoot.getVesselByCallSign( _callSign, true );
		endif;
	endif;

	foreignCodeUC 	:= foreignCodeAsIs.toUpper;
	terminal 		:= app.myPassport.myTerminal;	//cnwrs1 ccms 1976 15 Dec 2010
	terminalCopy := terminal; // TFS 42768
	create terminalArray transient;
	
	terminalArray.add(terminal);
	
	foreach terminal in terminal.allTerminalsForVoyageInland do
		terminalArray.add(terminal);
	endforeach;
	
	foreach terminal in terminalArray do
		operatorTerminal 	:= self.allOperatorTerminals[terminal];
		
		if operatorTerminal &lt;&gt; null then
			xlationTable := operatorTerminal.allXlationTables[XLATION_TYPE_VOYAGETERMINAL, null];
		endif;

		if xlationTable &lt;&gt; null then 	
			// PAR #25810 - recoded assuming sorted foreign codes are all uppercase
			delete iter;		// PAR #26678
			
			coll	:= xlationTable.allInwardTranslations;
			iter 	:= coll.createIterator();
			
			haveCriteria := false;		//19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
			if paramIsImport then
				coll.startKeyGeq(foreignCodeUC, iter);
				while iter.next(xlation) do 		//19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
					if xlation.foreignCode &lt;&gt; foreignCodeUC then
						break;
					endif;
					if xlation.myXlationCriteria &lt;&gt; null then
						haveCriteria := true;
						break;
					endif;
				endwhile;
			endif;
			
			coll.startKeyGeq(foreignCodeUC, iter);		//start again
			bestMatch := -1;		//19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
			
			while iter.next(xlation) do 
				if xlation.foreignCode &lt;&gt; foreignCodeUC then
					break;
				endif;
								
				voyage := xlation.getMySystemObject.CM_Voyage;
				
				if voyage &lt;&gt; null and (vessel = null or voyage.getMyVessel() = vessel) then
					if voyage.inwardCode &lt;&gt; null then // There is an explicit difference between inward and outwards voyage code
						if _direction = INWARDS and xlation.systemCode.toUpper() &lt;&gt; voyage.inwardCode.toUpper() then
							continue;
						elseif _direction = OUTWARDS and xlation.systemCode.toUpper() &lt;&gt; voyage.code.toUpper() then
							continue;
						endif;
					endif;
					// got a match
					if haveCriteria then
						if not xlation.isCriteriaMatch(score, _params) then
							continue;
						endif;
				
						if score &gt; bestMatch then
							// found a better match
							systemCode 	:= xlation.systemCode;
							bestMatch	:= score;
							if systemCode &lt;&gt; null then
								_foundMatch := true;
							endif;
						endif;
					else
						systemCode := xlation.systemCode;
						if systemCode &lt;&gt; null then
							_foundMatch := true;
							break; // TFS 42728 - do vessel check before returning translated voyage code
							//return systemCode; // TFS 42728		
						endif;		
					endif;
				endif;
			endwhile;	
		endif;
		
		if systemCode &lt;&gt; null then
			break;
		endif;
	endforeach;
	
	if systemCode = null or (vessel = null and _vesselName &lt;&gt; null and terminalCopy.isEnforceCallsignForXlation()) then // TFS 42728
		systemCode := foreignCodeAsIs;// TFS 42728 - when Enforce is enabled, if couldn't match vessel on basis of name, callsign
	endif; // TFS 42728 -  or Lloyd's number, return raw voyage code, else return translated code
	
	return systemCode;
	
epilog
	delete iter;
	delete terminalArray;
end;
</source>
        <Parameter name="_foreignCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_lloydsNumber" type="String"/>
        <Parameter name="_callSign" type="String"/>
        <Parameter name="_direction" type="Integer"/>
        <Parameter name="_foundMatch" type="Boolean" usage="output"/>
        <Parameter name="_params" type="ParamListType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYADisplay" id="62598edf-e5b6-4c7d-a6f3-0d2ea57bf23c">
        <source>getYADisplay(): String;
// --------------------------------------------------------------------------------
// Created:		08 March 2005 by cnwdad1:2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
