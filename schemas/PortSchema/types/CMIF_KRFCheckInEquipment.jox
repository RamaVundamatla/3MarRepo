    <JadeMethod name="copyToRealWSObject" id="ebe9f125-ef65-4adc-9341-18067cbde71d">
        <source>copyToRealWSObject(_realRequest: KRF_CheckInEquipment input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Feb 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message

*/

vars
	consignment : CMIF_KRFCheckInConsignment;
	realConsignment : KRF_CheckInConsignment;
	hazard : CMIF_KRFCheckInHazardous;
	realHazard : KRF_CheckInHazardous;
	seal : CMIF_KRFCheckInSeal;
	realSeal : KRF_CheckInSeal;
begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.empty := self.empty;
	_realRequest.equipmentID := self.equipmentID;
	_realRequest.equipmentType := self.equipmentType;
	_realRequest.netWeightKG := self.netWeightKG;
	_realRequest.orderNumber := self.orderNumber;
	_realRequest.overGauge := self.overGauge;
	_realRequest.overheight := self.overheight;
	_realRequest.sizeTypeCode := self.sizeTypeCode;
	_realRequest.tareWeightKG := self.tareWeightKG;
	_realRequest.underBond := self.underBond;

// manual population of checkInParticulars required
	if self.checkInParticulars &lt;&gt; null then
		create _realRequest.checkInParticulars transient;
		_createdObjects.add(_realRequest.checkInParticulars);
		self.checkInParticulars.copyToRealWSObject(_realRequest.checkInParticulars, _createdObjects);
	endif;

// manual population of consignments required
	if self.allConsignments &lt;&gt; null then
		foreach consignment in self.allConsignments do
			create realConsignment transient;
			_createdObjects.add(realConsignment);
			consignment.copyToRealWSObject(realConsignment, _createdObjects);
			_realRequest.consignments.add(realConsignment);
		endforeach;
	endif;

// manual population of hazardous required
	if self.allHazardous &lt;&gt; null then
		foreach hazard in self.allHazardous do
			create realHazard transient;
			_createdObjects.add(realHazard);
			hazard.copyToRealWSObject(realHazard, _createdObjects);
			_realRequest.hazardous.add(realHazard);
		endforeach;
	endif;

// manual population of imex required
	if self.imex &lt;&gt; null then
		create _realRequest.imex transient;
		_createdObjects.add(_realRequest.imex);
		self.imex.copyToRealWSObject(_realRequest.imex, _createdObjects);
	endif;

// manual population of refrigeration required
	if self.refrigeration &lt;&gt; null then
		create _realRequest.refrigeration transient;
		_createdObjects.add(_realRequest.refrigeration);
		self.refrigeration.copyToRealWSObject(_realRequest.refrigeration, _createdObjects);
	endif;

// manual population of seals required
	if self.allSeals &lt;&gt; null then
		foreach seal in self.allSeals do
			create realSeal transient;
			_createdObjects.add(realSeal);
			seal.copyToRealWSObject(realSeal, _createdObjects);
			_realRequest.seals.add(realSeal);
		endforeach;	
	endif;		
epilog

end;</source>
        <Parameter name="_realRequest" type="KRF_CheckInEquipment" usage="input"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="8a2e1649-2777-47c6-ab52-00485ef59d14">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message

*/

vars

begin
	if self.allSeals &lt;&gt; null then
		self.allSeals.purge();
	endif;
	if self.allHazardous &lt;&gt; null then	
		self.allHazardous.purge();
	endif;
	if self.allConsignments &lt;&gt; null then	
		self.allConsignments.purge();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFromContainer" id="abc2b178-9f40-475d-8cac-5e8dab815268">
        <updating/>
        <source>setFromContainer(_container : CM_Container) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
*/

vars
	isoType : CM_ISOType;
begin
	self.equipmentType := "CONTAINER";
	self.equipmentID := _container.id;
	self.tareWeightKG := _container.weightTare.Integer;
	self.netWeightKG := _container.weightCargo.Integer;
	self.sizeTypeCode := _container.isoType;
	self.empty := _container.isEmpty();
	self.overheight := _container.isOverHeight();
	isoType :=  app.myRoot.allISOTypes[_container.isoType];
	return isoType.isReefer();
epilog

end;</source>
        <Parameter name="_container" type="CM_Container"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
