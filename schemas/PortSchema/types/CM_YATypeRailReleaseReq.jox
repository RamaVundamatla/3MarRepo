<Class name="CM_YATypeRailReleaseReq" id="a45bd7ea-c181-4e64-85a5-62e20eadc270">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="df385cac-ac92-4486-a4a8-1f73c4b62afc">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// 14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  
// --------------------------------------------------------------------------------
vars
	terminalObj			: CM_Terminal;
	dict				: CM_BulkReleaseByTypeStCodeDict;
	release				: CM_BulkRelease;
	iter				: Iterator;
	typeKey,
	statusKey			: Integer;
	codeKey				: String;
	dateReqKey			: TimeStamp;
	
begin
	terminalObj	:=	_terminalObj;
	
	if terminalObj = null and app.isDevelopmentSystem() then
		terminalObj	:=	CM_Terminal.firstInstance();
	endif;
	
	dict := terminalObj.allBulkReleaseByTypeByStByCd;
	iter := dict.createIterator();
	dict.startKeyGeq(BR_TYPE_RAIL, BR_PENDING, null, null, iter);
	
	while iter.next(release) do
		iter.getCurrentKeys(typeKey,statusKey,codeKey,dateReqKey); //MTN-35226
		
		if typeKey &lt;&gt; BR_TYPE_RAIL then
			break;
		endif;
		
		if statusKey &lt;&gt; BR_PENDING and statusKey &lt;&gt; BR_ACTIVE then
			continue;
		endif;
		
		_allCriteriaValues.add(release);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="8c06d878-b2dd-4c03-8920-1e622f8fd7c2">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
//01 August 2008	cnwdw1
begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="ea51729c-85c7-4766-a7d0-6bc3262979bd">
        <source>getDisplay(dataObj : Object) : String;
//01 August 2008	cnwdw1
begin
	return dataObj.CM_BulkRelease.code;
end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="0245284d-e8d2-443e-8c9e-a384df65f48c">
        <source>getObjects(objects: ObjectLongNameDict input);
//05 August 2008	cnwdw1	
// 14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  
// Return a dict of objects for this criteria type
vars
	dict				: CM_BulkReleaseByTypeStCodeDict;
	release				: CM_BulkRelease;
	iter				: Iterator;
	typeKey,
	statusKey			: Integer;
	codeKey				: String;
	dateReqKey			: TimeStamp;
begin
	dict := app.getMyTerminalDO_NOT_USE().allBulkReleaseByTypeByStByCd;
	iter := dict.createIterator;
	dict.startKeyGeq(BR_TYPE_RAIL, BR_PENDING, null, null, iter);
	while iter.next(release) do
		iter.getCurrentKeys(typeKey, statusKey, codeKey, dateReqKey); //MTN-35226
		
		if typeKey &lt;&gt; BR_TYPE_RAIL then
			break;
		endif;
		
		if statusKey &lt;&gt; BR_PENDING and statusKey &lt;&gt; BR_ACTIVE then
			continue;
		endif;
		objects[release.getYAIdentifier] := release;
	endwhile;

epilog
	delete iter;
end;
</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="f8c451c9-2295-4d2e-ad85-2c7df083c81d">
