//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/08/2013	cnwdap1		Initial creation PAR #32331
//
vars

begin
	// make list box bigger, and place it over the textbox
	self.lstColourList.move(self.txtColourList.getFormLeft, self.txtColourList.getFormTop, self.txtColourList.width, 125);
