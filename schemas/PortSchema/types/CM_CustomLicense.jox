    <JadeMethod name="getAuditText" id="1d2539a1-377c-4b83-b48c-6f344a6809db">
        <source>getAuditText(): String;
// ##### CR59571 TASK 59573 NAVAB1 04AUG2023
vars
	txt,
	tmpStr	: String;
	ta		: CM_TerminalArea;
	docType	: CM_CustomDocumentType;
	
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	if self.allTerminalAreas.size() &gt; 0 then
		txt := txt &amp; self.allTerminalAreas.getName() &amp; AuditStringSeparator;
		
		foreach ta in self.allTerminalAreas do
			if ta &lt;&gt; null then
				tmpStr := ta.getDisplayName(true) &amp; Cr &amp; tmpStr;
			endif;
		endforeach;
		
		txt := txt &amp; CM_CustomLicense::allTerminalAreas.name &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		
	endif;
	
	if self.allCustomDocumentTypes.size() &gt; 0 then
		txt := txt &amp; self.allCustomDocumentTypes.getName() &amp; AuditStringSeparator;
		
		foreach docType in self.allCustomDocumentTypes do
			if docType &lt;&gt; null then
				tmpStr := docType.code &amp; " - " &amp; docType.description &amp; Cr &amp; tmpStr;
			endif;
		endforeach;
		
		txt := txt &amp; CM_CustomLicense::allCustomDocumentTypes.name &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		
	endif;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="968e14fc-5182-49b8-9888-90f00f1a6ad7">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//07/08/2023	navkc1	CR 59571   Task 59705: UI - Cust Lic Maint

*/

vars

begin
	if _attrName = ETRow_NafeList then
		return self.notAvailForEntry.getYesNo();
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="32cef52f-3130-471e-8b34-146505dd4ab6">
        <source>pxyCreateUpdateProxy(): SelfType;
// ##### CR59571 TASK 59573 NAVAB1 04AUG2023
vars
	pxySelf 	: SelfType;
	completeOK	: Boolean;
	
begin
	pxySelf :=  inheritMethod();
	
	self.allCustomDocumentTypes.copy(pxySelf.allCustomDocumentTypes);
	self.allTerminalAreas.copy(pxySelf.allTerminalAreas);
	pxySelf.myTerminal := self.myTerminal;
	
	completeOK := true;
	return pxySelf;

epilog
	if not completeOK then
		delete pxySelf;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="42f45415-2b19-4e9e-8c97-48f28f721a08">
        <updating/>
        <source>setForCreate(_pxy: SelfType) updating;
// ##### CR59571 TASK 59573 NAVAB1 04AUG2023
vars

begin
	_pxy.raiseExceptionIfNotTransient(method);
	
	self.raiseExceptionIfTransient(method);
	
	self.setForUpdate(_pxy);
	
epilog

end;</source>
        <Parameter name="_pxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8ecfaa10-efa1-45b2-a667-bf8e1f60b4b4">
        <updating/>
        <source>setForUpdate(_pxy : SelfType) updating;
// ##### CR59571 TASK 59573 NAVAB1 04AUG2023
vars

begin
	_pxy.raiseExceptionIfNotTransient(method);
	
	self.raiseExceptionIfTransient(method);
	
	self.code := _pxy.code;
	self.description := _pxy.description;
	self.myTerminal := _pxy.myTerminal;
	self.notAvailForEntry := _pxy.notAvailForEntry;
	
	self.allCustomDocumentTypes.clear();
	_pxy.allCustomDocumentTypes.copy(self.allCustomDocumentTypes);
	
	self.allTerminalAreas.clear();
	_pxy.allTerminalAreas.copy(self.allTerminalAreas);
epilog

end;</source>
        <Parameter name="_pxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="5c85b492-5670-4913-bf29-68578cd398da">
        <updating/>
        <source>setProxy(_code, _desc : String; _terminal : CM_Terminal; _nafe : Boolean; _allCustomDocTypes : CM_CustomDocumentTypeByCode; _allTermAreas : CM_TerminalAreaSet)  updating;
// ##### CR59571 TASK 59573 NAVAB1 04AUG2023
vars

begin

	self.code := _code;
	self.description := _desc;
	self.myTerminal := _terminal;
	self.notAvailForEntry := _nafe;
	
	self.allCustomDocumentTypes.clear();
	if _allCustomDocTypes &lt;&gt; null then
		_allCustomDocTypes.copy(self.allCustomDocumentTypes);
	endif;
	
	self.allTerminalAreas.clear();
	if _allTermAreas &lt;&gt; null then
		_allTermAreas.copy(self.allTerminalAreas);
	endif;
	
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_nafe" type="Boolean"/>
        <Parameter name="_allCustomDocTypes" type="CM_CustomDocumentTypeByCode"/>
        <Parameter name="_allTermAreas" type="CM_TerminalAreaSet"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="85277014-7a68-48c8-b97d-bf05925d46e4">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
// ##### CR59571 TASK 59573 NAVAB1 04AUG2023
begin
