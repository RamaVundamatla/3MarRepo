    <JadeMethod name="translateForm" id="2136f4ee-1ac1-48ef-9eee-3c6e962de3b1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018847, locale);
	btnClear.translateCaption(Xlat_0018848, locale);
	btnClose.translateCaption(Xlat_0018849, locale);
	btnTestAP.translateCaption(Xlat_0018850, locale);
	lblTestAutoPlan.translateCaption(Xlat_0018851, locale);
	mnuAddYA.translateCaption(Xlat_0018852, locale);
	mnuColOrg.translateCaption(Xlat_0018853, locale);
	mnuContexts.translateCaption(Xlat_0018854, locale);
	mnuEditYA.translateCaption(Xlat_0018855, locale);
	mnuInspect.translateCaption(Xlat_0018856, locale);
	mnuPlanItems.translateCaption(Xlat_0018857, locale);
	mnuRemoveItems.translateCaption(Xlat_0018858, locale);
	mnuRemovePlanned.translateCaption(Xlat_0018859, locale);
	mnuSendToEnquiry.translateCaption(Xlat_0018860, locale);
	mnuSendToMove.translateCaption(Xlat_0018861, locale);
	mnuSendToReport.translateCaption(Xlat_0018862, locale);
	mnuShowAPLog.translateCaption(Xlat_0018863, locale);
	mnuSummarise.translateCaption(Xlat_0018864, locale);
	shtFail.translateCaption(Xlat_0018865, locale);
	shtResults.translateCaption(Xlat_0018866, locale);
	shtSelected.translateCaption(Xlat_0018867, locale);
end;</source>
    </JadeMethod>
