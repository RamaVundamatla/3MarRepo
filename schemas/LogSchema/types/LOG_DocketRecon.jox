        <updating/>
        <source>tblHeaderData_rowColumnChg(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	app.mousePointer := MousePointer_HourGlass;
	self.selectHeader(table.row);
epilog
