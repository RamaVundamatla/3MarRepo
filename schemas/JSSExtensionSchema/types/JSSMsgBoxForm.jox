<GUIClass name="JSSMsgBoxForm" id="ebc40840-ea6b-4494-a326-2b8ac082b0bc">
    <superclass name="JSSBaseDialogForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>___________________________________________________________________________

