    <JadeMethod name="setSideTo" id="169caada-bd17-4ea9-9f64-56c0c565b2c5">
        <updating/>
        <source>setSideTo(_value : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 September 2009	cnwer1	Initial creation
28/06/2010	cnwmh5	PAR23494 - If changing the orientation also need to change the bow / stern marks

*/

vars
	oldBowMark		: Decimal[12,2];				// 28/06/2010 cnwmh5 #23494
begin
	if self.sideTo &lt;&gt; _value then
		self.sideTo:=_value;
		
		// 28/06/2010 cnwmh5 #23494 - Start
		oldBowMark := self.bowMarkTo;
		self.bowMarkTo := self.sternMarkTo;
		self.sternMarkTo := oldBowMark;
		// 28/06/2010 cnwmh5 #23494 - End
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSternMarkToValue" id="aec3eca7-7231-46c5-b1a9-c966507a6e00">
        <updating/>
