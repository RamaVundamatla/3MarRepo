    <JadeMethod name="checkLabourRestrictionHook" id="37522c58-17c1-4ea3-91c5-dd6e963f74ed">
        <source>checkLabourRestrictionHook(_terminalArea : CM_TerminalArea io; _locations : CM_LCArray io);
// ---------------------------------------------------------------------------
// Created:	28 April 2010 By Graeme Black cnwgb1
// Purpose:	POE Warning Lights PAR 21639.
// 			Runs User Hook Code for changing a Labour Restriction. Puts up Warning Dialog
//			if the hook returns anything (assumed to be a string)
// ---------------------------------------------------------------------------
vars
	hookStr : Any;
	allWarnings : HugeStringArray;
begin
	hookStr := app.myHookAgent.runHookLinkPublic(HookType_LabourRestriction,_terminalArea.myTerminal,_terminalArea.myTerminal, _terminalArea, _locations);
	if hookStr &lt;&gt; null then	// Par 17827 CCMS 1507 Hook for Port Otago
		create allWarnings transient;
		allWarnings.add(hookStr.String);
		app.showErrorWarningDialogArray("Labour Restriction", null, allWarnings, ErrWarnMode_CanAckWarnings);
	endif;

epilog
	delete allWarnings;
end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea" usage="io"/>
        <Parameter name="_locations" type="CM_LCArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="checkUnitTestRunnerRunning" id="2d9657a7-feea-41b5-869a-2e0bffdae868">
        <source>checkUnitTestRunnerRunning() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 April 2025	navpw1	Initial creation - Moved from unit test app to use when starting MTN App

*/

vars
	jadeNodes		: NodeDict;
	jadeNode		: Node;
	allProcesses	: ProcessDict;
	jadeProcess 	: Process;
	invalidJadeNode	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, jadeNode, invalidJadeNode);
	create jadeNodes transient;
	create allProcesses transient;
	
	system.nodes.copy(jadeNodes);
	
	if jadeNodes.isEmpty then
		return null;
	endif;
	
	foreach jadeNode in jadeNodes do :nodeLoop
		allProcesses.clear();
		if invalidJadeNode then
			invalidJadeNode := false;
			continue;
		endif;
		
		jadeNode.processes.copy(allProcesses);
		
		if allProcesses.isEmpty then
			continue nodeLoop;
		endif;
		
		foreach jadeProcess in allProcesses do
			if not jadeProcess.persistentApp.name = "JMTUnitTestRunner" then
				continue;
			endif;
			
			return true;	
		endforeach;
	endforeach;
	
	return false;
	
epilog
	delete jadeNodes;
	delete allProcesses;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearErrorWarningForm" id="38750d11-2882-4b82-b03d-add5d3e2540e">
        <source>clearErrorWarningForm();
// ---------------------------------------------------------------------------
