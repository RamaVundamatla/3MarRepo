	//cargo Type
	create tmpProp as CM_QCargoTypeLookupMethod persistent;
	tmpProp.set('Cargo Type', CM_CashPayment::getTrackedItemCargoType.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
