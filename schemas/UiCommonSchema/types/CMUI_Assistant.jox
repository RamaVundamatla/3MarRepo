    <JadeMethod name="comboBoxStowageNumber" id="018a4b60-65f0-4874-81ce-cb6900d40aff">
        <source>comboBoxStowageNumber(_combo : CMUI_ComboBox input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 May 2009	cnwer1	Initial creation

*/

vars


	idx : Integer;
begin
	_combo.sorted := false;
	_combo.clear;
	
	// dont need this
	//idx := self.cmbStowageNumber.addItem(null);
	idx := _combo.addItem(Vessel_Stowage_Type_BCT_Text);
	_combo.itemData[idx] := Vessel_Stowage_Type_BCT;	

	idx := _combo.addItem(Vessel_Stowage_Type_BTC_Text);
	_combo.itemData[idx] := Vessel_Stowage_Type_BTC;

	_combo.listIndex := 1;
epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxStructureVoyages" id="edd90e11-2934-48a1-8c31-deed5fb68ca2">
        <source>comboBoxStructureVoyages(_cmb : CMUI_ComboBox input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 July 2013	cnwrd1	Initial creation

*/

vars
	iter : Iterator; 
	tmpTerm : CM_Terminal;
	tmpUser	: CM_User;
	tmpUserT	: CM_UserTerminal;
	showVesselByName : Boolean;
	vessel 			: CM_Vessel;
	vesselStructure : CM_VesselStructuralElements;
	vesselDict : CM_VesselSet;
begin
	
	// hacky way of getting the terminal because the config is set per terminal 
	tmpTerm := app.getMyTerminalDO_NOT_USE();
	if tmpTerm = null then
		tmpUser := app.getMyUser();
		if tmpUser &lt;&gt; null then
			tmpUserT := tmpUser.allUserTerminals.first;
			if tmpUserT &lt;&gt; null then
				tmpTerm := tmpUserT.getRealTerminal;
			endif;
		endif;
	endif;
	
	if tmpTerm &lt;&gt; null then
		showVesselByName:= tmpTerm.getConfig(VesselComboByName).Boolean;
	endif;

	
	iter:=CM_VesselStructuralElements.instances.createIterator;
	while iter.next(vesselStructure) do
		vessel:=vesselStructure.myVessel;
		//vesselDict.add(vessel);
		if showVesselByName then	
			_cmb.addItemObject( vessel.name &amp;  " - (" &amp; vessel.code &amp; ")" ,vesselStructure); 
		else
			_cmb.addItemObject( vessel.code &amp; " -  ("  &amp; vessel.name &amp; ")",vesselStructure); 
		endif;
	endwhile;

	/*create vesselDict transient;

	iter:=app.myRoot.allVesselCellularStructures.createIterator;
	while iter.next(vesselStructure) do
		vessel:=vesselStructure.myVessel;
		vesselDict.add(vessel);
		if showVesselByName then	
			_cmb.addItemObject( vessel.name &amp;  " - (" &amp; vessel.code &amp; ")" ,vesselStructure); 
		else
			_cmb.addItemObject( vessel.code &amp; " -  ("  &amp; vessel.name &amp; ")",vesselStructure); 
		endif;
	endwhile;
	
	
	iter:=app.myRoot.allVesselROROStructures.createIterator;
	while iter.next(vesselStructure) do
		vessel:=vesselStructure.myVessel;
		
		if vesselDict.includes(vessel) then
			continue;
		endif;
		
		if showVesselByName then	
			_cmb.addItemObject( vessel.name &amp;  " - (" &amp; vessel.code &amp; ")" ,vesselStructure); 
		else
			_cmb.addItemObject( vessel.code &amp; " -  ("  &amp; vessel.name &amp; ")",vesselStructure); 
		endif;
	endwhile;*/
	
epilog
	delete iter;
	delete vesselDict;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxSubHandlingTypes" id="afa43be2-f476-4627-9de7-c2546759f09e">
        <source>comboBoxSubHandlingTypes( _combo : ComboBox input; _handlingType : CM_HandlingType );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

	allHandlingSubTypes : CM_HandlingSubByTypeCode;
	index : Integer;
	obj : Object;
	
begin

	_combo.clear();
	_combo.addItem( null );
	
	if _handlingType = null then
		return;
	endif;
	
	create allHandlingSubTypes transient;
	_handlingType.getValidSubTypes( allHandlingSubTypes, false );
	
	
	foreach obj in allHandlingSubTypes do
		index := _combo.addItem( obj.CM_HandlingSubType.description );
		_combo.itemObject[index] := obj;
	endforeach;

epilog

	delete allHandlingSubTypes;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_handlingType" type="CM_HandlingType"/>
    </JadeMethod>
    <JadeMethod name="comboBoxSubTerminal" id="b9370bbb-30d1-4842-ac62-8477fed225c7">
        <source>comboBoxSubTerminal(_comboboxObj : ComboBox input; _subTerminalObj : CM_SubTerminal; _terminalObj:CM_Terminal);
// --------------------------------------------------------------------------------
// Created:		07 April 2009 by cnwdad1
//
// Purpose:		Populates the specified ComboBox control with Sub-Terminals of the
//				specified Terminal.
//
// Parameters:	_comboboxObj - A reference to the combobox control to populate.
//				_subTerminalObj - A reference to the default Sub-Terminal.
//				_terminalObj - A reference to the current Terminal.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	subTerminalObj	: CM_SubTerminal;
	rowPointer		: Integer;

begin
	_comboboxObj.clear();
	
	if _terminalObj = null then
		return;
	endif;
	
	if _terminalObj.getConfig( IsSubTerminalAreaDefined ).Boolean then
		_comboboxObj.addItem(null);
	endif;
	
	foreach subTerminalObj in _terminalObj.allSubTerminals do
		rowPointer	:=	_comboboxObj.addItem(subTerminalObj.code);
		_comboboxObj.itemObject[rowPointer]	:=	subTerminalObj;
	endforeach;
	
	if _subTerminalObj &lt;&gt; null then
		_comboboxObj.cnEcSetObjectIndex(_subTerminalObj);
	endif;
end;</source>
        <Parameter name="_comboboxObj" type="ComboBox" usage="input"/>
        <Parameter name="_subTerminalObj" type="CM_SubTerminal"/>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="comboBoxSubTerminalType" id="69801c69-b71c-4046-82a1-9533a29e9e5a">
        <source>comboBoxSubTerminalType(_cmb: CMUI_ComboBox input);
/*
----------   ----------  --------------------------------------------------
Created:	07 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	idx		: Integer;
begin
	
	if _cmb = null then
		return;
	endif;
	_cmb.clear();
	
	idx := _cmb.addItem(SubTermType_Marine);
	idx := _cmb.addItem(SubTermType_Depot);
	idx := _cmb.addItem(SubTermType_Warehouse);
end;
</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxSupplier" id="4abf324e-06c4-45c2-acd0-22c817aae78a">
        <source>comboBoxSupplier(pCmb : ComboBox input; pSupplier : CM_Operator);
//--------------------------------------------------------------
//Created: March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	operator : CM_Operator;		//cnwmc5 - 26 Nov 2013 - PAR 33068
	failedDAC  :CM_DataAccessController;
begin
	//cnwmc5 - 9 Jan 2013 - PAR 33274 - no longer need work around as JADE Plant fixed listCollection issue.. 
	pCmb.listCollection(app.myRoot.allOperators, true, 0);
	
	//cnwmc5 - 26 Nov 2013 - PAR 33068 - work around for JADE listCollection issue..
	/*foreach operator in app.myRoot.allOperators do
		//cnwmc5 - 27 Nov 2013 - PAR 33087 - additional changes for work around of listCollection issue..
		if operator = null then
			continue;
		endif;
	
		if (not operator.canUserAccessSelf(null, failedDAC,  app.myPassport)) then
			continue;
		endif;
	
		if operator.isNotAvailableForEntry then
			continue;
		endif;
		
		pCmb.itemObject[pCmb.addItem(operator.code &amp; Tab &amp; operator.description)] := operator;
	endforeach;*/
	
	
	if (pSupplier &lt;&gt; null) and (pSupplier.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		pCmb.text := self.displayEntryOperator(pSupplier);
		pCmb.listObject := pSupplier;
	endif;
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pSupplier" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTAGroup" id="fdfdf41a-e734-4852-b602-262b7fa24828">
        <source>comboBoxTAGroup(_cmb : ComboBox input);
/*
----------   ----------  --------------------------------------------------
Created:	16 January 2007 By cnwth2

Purpose:	hack for gdanks  -rtg lanes not my design - forced to add to existing structure.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ta			: CM_TerminalArea;
	iter		: Iterator;
	taGroupDict	: CM_TAGroupByIdDict;
	taGroup		: CM_TerminalAreaGroup;
	obj			: Object;
	uniqueLaneGrouping : CM_TerminalAreaGroup;
	taSet, objSet		: ObjectSet;
	idx			: Integer;
	dynaDict : DynaDictionary;
	
	add : Boolean;
begin
	create dynaDict transient;	
	dynaDict.setMembership(CM_TerminalAreaGroup);
	dynaDict.addMemberKey("label", false, true);
	dynaDict.endKeys(true);

	_cmb.clear();
	_cmb.sorted := false;
	idx := _cmb.addItem('New Group');
	_cmb.itemData[idx] := 3;
	
	create objSet transient;
	create taSet transient;
	taGroupDict := app.getMyTerminalDO_NOT_USE.allTerminalAreaGroups;
	taGroupDict.copy(dynaDict);
//	iter := taGroupDict.createIterator;
	iter := dynaDict.createIterator;
	
	
	while iter.next(taGroup) do
		//test if the areas that contribute to this area are the same or differnt from
		//the areas that make up the unique groups we've already found
		ta := taGroup.allTAsByTypeId.first;
		if not taSet.includes(ta) then
			taSet.add(ta);
			objSet.add(taGroup);
			continue;		
		endif;
		
		
	endwhile;
	
	foreach obj in objSet do

		idx := _cmb.addItem('Add before '  &amp; obj.CM_TerminalAreaGroup.getAreasDescr());
		_cmb.itemObject[idx] := obj;
		_cmb.itemData[idx] := 1;
		
		idx := _cmb.addItem('Add after ' &amp; obj.CM_TerminalAreaGroup.getAreasDescr());
		_cmb.itemObject[idx] := obj;
		_cmb.itemData[idx] := 2;
	endforeach;
	
epilog
	delete dynaDict;
	delete objSet;
	delete iter;
	delete taSet;
end;


</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTAType" id="2b385255-d0bc-4520-acfc-19290c3d316d">
        <source>comboBoxTAType(_cmb : ComboBox input ;_taType : CM_TerminalAreaType; _sorted : Boolean);
// ---------------------------------------------------------------------------
// Created:     17 June 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/02/2018	jlgdap1		TFS 37255 C3 Terminal Config Error
// ---------------------------------------------------------------------------
vars
	areaType	: CM_TerminalAreaType;
	idx			: Integer;
	firstArea 	: CM_TerminalArea;
begin
	//Some terminal areas do not shown here
	_cmb.clear;
	
	_cmb.sorted := _sorted;
	
	idx := _cmb.addItem("");
	_cmb.itemObject[idx] := null;
	
	foreach areaType in app.myRoot.allTerminalAreaTypes do
	
		if areaType.getIsNotAvailableForEntry then
			continue;
		endif;
		
		if areaType.isGantryLaneAreaType then
			continue;
		endif;
		
		if  areaType.type = TA_TYPE_BUILDING then
			continue;
		endif;
		
		firstArea :=areaType.allTerminalAreasByTerminal.getAtKeyGeq(myTerminal,null).CM_TerminalArea;
		if firstArea = null then
			continue;
		endif;
		if firstArea.myTerminal &lt;&gt; self.myTerminal then
			continue;
		endif;
		
			
		idx := _cmb.addItem(areaType.description);
		_cmb.itemObject[idx] := areaType;
		
	endforeach;
	
	if _taType &lt;&gt; null and _taType.type &lt;&gt; TA_TYPE_BUILDING then
		//_cmb.listObject := _taType;								// TFS 37255
		// We may not have found any terminal areas for the type	// TFS 37255
		// Setting the listObject in this case gives a 14008 error	// TFS 37255
		_cmb.listIndex := _cmb.findObject(_taType);					// TFS 37255
	endif;
	
end;
</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_taType" type="CM_TerminalAreaType"/>
        <Parameter name="_sorted" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTILCType" id="517af524-ccf6-402d-beb9-48d3e5922e13">
        <source>comboBoxTILCType(_combo : ComboBox input; _type	:CM_TILCType );
/*
Parameters:		_type - will be selected and also added if it is not aready there

Date		Who		Reason
05 April 2007	cnwer1	Initial creation - PAR#xxxx
06 Dec 2012		cnwcs5	par 30852 - take trailer type isNotAvailableForEntry into account
*/
vars
	type	: CM_TILCType;
	index 	: Integer;
	found	: Boolean;
begin
	foreach type in app.myRoot.allTILCTypes discreteLock do	
		// do not include trailer types that are not available for entry
		// unless it is the default type we want to select
		if type.isNotAvailableForEntry then
			if type &lt;&gt; _type then
				continue;
			endif;
		endif;
		
		if type = _type then
			found := true;
		endif;
		
		index						:=_combo.addItem(type.description);	// par 30852 Dec 2012
		_combo.itemObject [index] 	:= type;
	endforeach;
		
	if _type &lt;&gt; null then 
		// make sure it is selected
		index 				:= _combo.findObject(_type);
		_combo.listIndex	:= index;
	endif;	
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_type" type="CM_TILCType"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTIReceiveType" id="15e0fee9-1651-4775-85b5-276aed9199df">
        <updating/>
        <source>comboBoxTIReceiveType(_cmb : CMUI_ComboBox input; 
				_canViewRoad, _canViewRail, _includeUnknown: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2013	cnwmc5	Initial creation

*/
vars

begin
	if _canViewRoad then
		_cmb.itemData[_cmb.addItem(TI_TRANSMODE_ROAD_STR)] := TI_TRANSMODE_ROAD;
	endif;
	
	if _canViewRail then
		_cmb.itemData[_cmb.addItem(TI_TRANSMODE_RAIL_STR)] := TI_TRANSMODE_RAIL;
	endif;
	
	if _includeUnknown then
		_cmb.itemData [_cmb.addItem (TI_TRANSMODE_NULL_STR)] := TI_TRANSMODE_NULL;
	endif;	
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_canViewRoad" type="Boolean"/>
        <Parameter name="_canViewRail" type="Boolean"/>
        <Parameter name="_includeUnknown" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTIsByProduct" id="7b3f5cec-2601-434a-99e6-4c537cbf9430">
        <source>comboBoxTIsByProduct(_cmb : CMUI_ComboBox input;
					_product : CM_Product; 
					_itemId : String);
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     CNWTH2 reminder - in future may need to pass in allLocControllers to not include/include
//				to filter SOHLocations
//			 
// ----------   ----------  --------------------------------------------------
vars
	ti				: CM_TrackedItem;
	sohLoc			: CM_SOHLocation;
	tiId			: String;
	found			: Boolean;
begin
	_cmb.clear();
	if _product = null then
		return;
	endif;
	
	foreach sohLoc in _product.allSOHLocations discreteLock do
		/*
		if (not _availableLocations.includesKey(sohLoc.myLocationsController.CM_WarehouseRowController.id)) then
			continue;
		endif;
		*/
		foreach ti in sohLoc.allTrackedItems discreteLock 
			where ti.state &lt;&gt; TI_STATE_DELETED do // AKB2004NOV
			if ti.myParent &lt;&gt; null or
			   ti.myStockOrderTILine &lt;&gt; null then
				continue;
			endif;
			
			tiId := ti.id;
			if tiId = _itemId then
				found := true;
			endif;
			
			_cmb.itemObject[_cmb.addItem(ti.id)] := ti;
		endforeach;
	endforeach;
	
	if found then
		_cmb.text := _itemId;
	endif;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_itemId" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTempC" id="3bad3575-b695-43b6-a913-987f2ad15665">
        <source>comboBoxTempC(pCmb : ComboBox input; pTemp : Real);
//comboBoxTempC(pTable : CM_EntryTable io; pAttrName : String);
// ---------------------------------------------------------------------------
// Created:     02 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
