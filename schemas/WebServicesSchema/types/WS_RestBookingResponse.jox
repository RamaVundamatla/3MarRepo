    <JadeMethod name="setProxyFromObject" id="76e7907a-2f21-474a-8caa-dcbab287bd54">
        <updating/>
        <source>setProxyFromObject(_bookingRef : CM_BookingRef; _objectsToBeDeleted : ObjectArray input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2023	navpw1	Initial creation TFS: 56850 (56871)

*/

vars
	carrier				: CM_Carrier;
	consignee,
	consignor,
	freightForwarder	: CM_ConsigneeConsignor;
	operator			: CM_Operator;
	stevedore			: CM_Stevedore;
	transhipVoyage,
	voyage				: CM_Voyage;
	bookingRefItem		: CM_BRefItemContainer;
	wsCargo				: WS_RestBookingCargoObject;
	
begin
	carrier := _bookingRef.myCarrier;
	if carrier &lt;&gt; null then
		self.carrierId := carrier.code;
	endif;
	
	consignee := _bookingRef.myConsignee;
	if consignee &lt;&gt; null then
		self.consigneeId := consignee.code;
	endif;
	
	consignor := _bookingRef.myConsignor;
	if consignor &lt;&gt; null then
		self.consignorId := consignor.code;
	endif;
	
	self.customsAgentId := _bookingRef.customsAgent;
	self.destinationPortId := _bookingRef.destinationPort;
	self.directDelivery := _bookingRef.directDelivery;
	self.dischargePortId := _bookingRef.dischargePort;
	
	freightForwarder := _bookingRef.myFreightForwarder;
	if freightForwarder &lt;&gt; null then
		self.freightForwarderId := freightForwarder.code;
	endif;
	
	self.id := _bookingRef.bookingReference;
	
	operator := _bookingRef.myOperator;
	if operator &lt;&gt; null then
		self.operatorId := operator.code;
	endif;
	
	self.packAsType := app.bookingPackAsEnumToString(_bookingRef.packAs);
	self.receiveAsTranship := _bookingRef.receiveAsTranship;
	//self.releaseRequestId := ;
	self.remarks := _bookingRef.bookingRefRemarks;
	self.shippingReference := _bookingRef.shippingReference;
	self.status := _bookingRef.status;
	
	stevedore := _bookingRef.myStevedore;
	if stevedore &lt;&gt; null then
		self.stevedoreId := stevedore.code;
	endif;
	
	self.stockBooking := _bookingRef.isStockBookingRef;
	
	transhipVoyage := _bookingRef.myTranshipVoyage;
	if transhipVoyage &lt;&gt; null then
		self.transhipOriginalVoyageId := transhipVoyage.code;
	endif;
	
	voyage := _bookingRef.myVoyage;
	if voyage &lt;&gt; null then
		self.voyageId := voyage.code;
		self.voyageArrivalDT := voyage.arrivedDT.asJSONFormat;
	endif;
	
	//Create proxy cargo items from booking items
	foreach bookingRefItem in _bookingRef.allBookingRefItems as CM_BRefItemContainer do
		create wsCargo transient;
		wsCargo.setProxyFromBookingItem(bookingRefItem, _objectsToBeDeleted);
		self.cargo.add(wsCargo);
        _objectsToBeDeleted.add(wsCargo);       //MTN-32915
	endforeach;
	
end;</source>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
        <Parameter name="_objectsToBeDeleted" type="ObjectArray" usage="input"/>
    </JadeMethod>
</Class>
