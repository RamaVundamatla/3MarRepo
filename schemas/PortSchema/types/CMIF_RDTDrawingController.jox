    <JadeMethod name="reCalcColsForFlip" id="8e1791c4-2c45-447c-ac63-799eca0a93dd">
        <updating/>
        <source>reCalcColsForFlip() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	cnwjk3	Initial creation

*/

vars
	newLeftCol,
	newLeftColDraw,
	newRightCol,
	newRightColDraw	: Integer;
begin
	newLeftCol := self.rightGridCol;
	newRightCol := self.leftGridCol;
	newLeftColDraw := self.rightGridCol;
	newRightColDraw := self.leftGridCol - (self.rightGridColDraw - self.rightGridCol);

	if newRightColDraw &lt; 1 then
		newRightColDraw := 1;
	endif;
	
	self.leftGridCol := newLeftCol;
	self.rightGridCol := newRightCol;
	self.leftGridColDraw := newLeftColDraw;
	self.rightGridColDraw := newRightColDraw;
	
	// Recalculate number of columns to draw
	self.calcGridDrawColsFlipped();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reCalcRowsCols" id="b8e2fa9b-d08e-4b6f-ae2f-f8dc7cd4b0ab">
        <updating/>
        <source>reCalcRowsCols() updating, protected;

/*

Purpose:  re-calulate top/bottom rows and left/right cols based on the current scale factor, numRowsFit/numColsFit
          and viewport size. 			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars
begin
	if self.flipV then

		self.topGridRow := self.bottomGridRow + numGridRowsFit - 1;
		if self.bottomGridRow &lt; 1 then
			self.bottomGridRow := 1;
		endif;	
			
	else
		self.bottomGridRow := self.topGridRow + numGridRowsFit - 1;
		if self.bottomGridRow &gt; self.maxGridRow then
			self.bottomGridRow := self.maxGridRow;
		endif;

		// Adjust when numRowsFit == 0
		if self.topGridRow &gt; self.bottomGridRow then
			self.bottomGridRow := self.topGridRow;
		endif;

	endif;

	if self.flipH then

		self.leftGridCol := self.rightGridCol + numGridColsFit - 1;
		if self.rightGridCol &lt; 1 then
			self.rightGridCol := 1;
		endif;	
			
	else
		self.rightGridCol := self.leftGridCol + numGridColsFit - 1;
		if self.rightGridCol &gt; self.maxGridCol then
			self.rightGridCol := self.maxGridCol;
		endif;

		// Adjust when numColsFit == 0
		if self.leftGridCol &gt; self.rightGridCol then
			self.rightGridCol := self.leftGridCol;
		endif;

	endif;
		
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reCalcRowsForFlip" id="690db8af-0d55-4491-b45a-fe6eb90436f6">
        <updating/>
        <source>reCalcRowsForFlip() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	cnwjk3	Initial creation

*/

vars
	newTopRow,
	newTopRowDraw,
	newBottomRow,
	newBottomRowDraw	: Integer;
begin
	newTopRow := self.bottomGridRow;
	newBottomRow := self.topGridRow;
	newTopRowDraw := self.bottomGridRow;
	newBottomRowDraw := self.topGridRow - (self.bottomGridRowDraw - self.bottomGridRow);

	if newBottomRowDraw &lt; 1 then
		newBottomRowDraw := 1;
	endif;
	
	self.topGridRow := newTopRow;
	self.bottomGridRow := newBottomRow;
	self.topGridRowDraw := newTopRowDraw;
	self.bottomGridRowDraw := newBottomRowDraw;
	
	
	// Recalculate number of rows to draw
	self.calcGridDrawRowsFlipped();
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reDrawAreaFromLocation" id="7a9433c8-3229-4ecb-9341-ff0d0e243900">
        <updating/>
        <source>reDrawAreaFromLocation(_lc : CM_LocationsController; _mode : Integer) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars
	
	ta		 	: CM_TerminalArea;
	isDrawForkLiftStack : Boolean;
begin
	if self.myDisplayBuilder &lt;&gt; null then
		delete self.myDisplayBuilder;
	endif;

	if self.isLocationInRailArea(_lc) then
		create self.myDisplayBuilder as CMIF_RDTRailDisplayBuilder transient;
	else
		create self.myDisplayBuilder as CMIF_RDTGriddedDisplayBuilder transient;
	endif;
	
	self.myDisplayBuilder.myRTVehicleConfig := self.myRTVehicleConfig; // 10 Feb 2012	NDL	Par 29108
	
	// restrict the mode to one that is supported
	self.drawMode := self.myDisplayBuilder.getSupportedMode(_mode);
	
	// restrict lanscape view if not supported
	if self.isLandscape and not self.myDisplayBuilder.canDisplayLandscape(self.drawMode) then
		self.isLandscape := false;
	endif;
	
	// restrict portrait view if not supported
	if not self.isLandscape and not self.myDisplayBuilder.canDisplayPortrait(self.drawMode) then
		self.isLandscape := true;
	endif;
	
	// restrict horizontal flip if not supported
	if self.flipH and not self.myDisplayBuilder.canFlipH(self.drawMode) then
		self.flipH := false;
	endif;
	
	// restrict vertical flip if not supported
	if self.flipV and not self.myDisplayBuilder.canFlipV(self.drawMode) then
		self.flipV := false;
	endif;
	
	ta := _lc.myTerminalArea;
	
	// Retrieve measurements of the grid and the elements to draw in it from the form
	self.myDrawingFrame.form.IF_RDTYardForm.getGridSizes(self.drawMode, ta, self.gridWidthFt, self.gridHeightFt);
	self.myDrawingFrame.form.IF_RDTYardForm.getLCSizes(self.drawMode, ta, self.lcXGridOffsetFt, self.lcYGridOffsetFt, self.lcWidthFt, self.lcHeightFt);
	self.myDrawingFrame.form.IF_RDTYardForm.getTISizes(self.drawMode, ta, self.tiXGridOffsetFt, self.tiYGridOffsetFt); 
	self.myDrawingFrame.form.IF_RDTYardForm.getWagonSizes(self.drawMode, ta, self.wagonXGridOffsetFt, self.wagonYGridOffsetFt, self.wagonWidthFt, self.wagonHeightFt);
	self.myDrawingFrame.form.IF_RDTYardForm.getTrackSizes(self.drawMode, ta, self.trackXGridOffsetFt, self.trackYGridOffsetFt, self.trackWidthFt, self.trackHeightFt);
	
	if self.isLocationInRailArea(_lc) then
		
		//create self.myDisplayBuilder as CMIF_RDTRailDisplayBuilder transient;
		// For non-gridded areas we build the display first, as we need to work out which grid location the location
		// controller is in.
		self.myDisplayBuilder.initTrackSizes(self.trackXGridOffsetFt, self.trackYGridOffsetFt, self.trackWidthFt, self.trackHeightFt);
		self.myDisplayBuilder.initWagonSizes(self.wagonXGridOffsetFt, self.wagonYGridOffsetFt, self.wagonWidthFt, self.wagonHeightFt);
		self.myDisplayBuilder.initLCSizes(self.lcXGridOffsetFt, self.lcYGridOffsetFt, self.lcWidthFt, self.lcHeightFt);
		self.myDisplayBuilder.initTISizes(self.tiXGridOffsetFt, self.tiYGridOffsetFt);
		//self.myDisplayBuilder.build(CMIF_RDTRailDisplayBuilder.MODE_TOPDOWN, _lc, _lc.myTerminalArea, self.leftGridColDraw, self.rightGridColDraw, self.topGridRowDraw, self.bottomGridRowDraw, self.scaleFactor, self.isLandscape, self.flipH, self.flipV); 
		self.myDisplayBuilder.build(self.drawMode, _lc, _lc.myTerminalArea, self.leftGridColDraw, self.rightGridColDraw, self.topGridRowDraw, self.bottomGridRowDraw, self.scaleFactor, self.isLandscape, self.flipH, self.flipV); 
	endif;
	
	
	self.updateLocation(_lc);
	
	// Center the columns around the location
	if self.flipH then
		self.calcCenteredColumnsFlipped();
	else
		self.calcCenteredColumnsUnflipped();
	endif;
	
	// Center the rows around the location
	if self.flipV then
		self.calcCenteredRowsFlipped();
	else
		self.calcCenteredRowsUnflipped();
	endif;	
		
	// Calculate number of cols/rows that fit
	self.calcViewSizes();
	
	// Calculate the draw cols
	if self.flipH then
		self.calcGridDrawColsFlipped();
	else
		self.calcGridDrawColsUnflipped();
	endif;

	// Calculate the draw rows
	if self.flipV then
		self.calcGridDrawRowsFlipped();
	else
		self.calcGridDrawRowsUnflipped();
	endif;
	
	
	if self.isLocationInGriddedArea(_lc) then	
		// For gridded areas we only build the display for the visible portion of the area. So, we build the
		// display after we have calculated how many cols/rows are visible and which grid location the 
		// location controller of interest is containe within.  This is easy for gridded areas, as there is a 
		// one-to-one mapping between location controller and display grid location 
		
		//create self.myDisplayBuilder as CMIF_RDTGriddedDisplayBuilder transient;
		
		self.myDisplayBuilder.initLCSizes(self.lcXGridOffsetFt, self.lcYGridOffsetFt, self.lcWidthFt, self.lcHeightFt);
		self.myDisplayBuilder.initTISizes(self.tiXGridOffsetFt, self.tiYGridOffsetFt);
		
		//19/04/2011 cnwdz2 par27313 start
		isDrawForkLiftStack := self.isDrawForkLiftStack(_lc);
		if isDrawForkLiftStack then
			self.myDisplayBuilder.setDrawForkLiftStack(true);
			self.myDisplayBuilder.setLookForkLiftStackFromBottom(self.lookForkLiftStackFromBottom);
		endif;
		//19/04/2011 cnwdz2 par27313 end		
		
		self.myDisplayBuilder.build(self.drawMode, _lc, _lc.myTerminalArea, self.leftGridColDraw, self.rightGridColDraw, self.topGridRowDraw, self.bottomGridRowDraw, self.scaleFactor, self.isLandscape, self.flipH, self.flipV); 		
	endif;
	
	self.drawEverything();	
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="rePositionHVLabelFrames" id="0c737765-b890-4d24-bf7d-950e11d38dbd">
        <source>rePositionHVLabelFrames(_parentFrame:Frame) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 November 2010	#cnwdz2	 26196

*/

vars
	
begin
	//23/09/2010 cnwdz2 25642
	if self.myTopHLabelsFrame &lt;&gt; null then
		self.myTopHLabelsFrame.left := self.myDrawingFrame.left;
		self.myTopHLabelsFrame.width := self.myDrawingFrame.width;
	endif;
	
	if self.myBottomHLabelsFrame &lt;&gt; null then
		self.myBottomHLabelsFrame.left := self.myDrawingFrame.left;
		self.myBottomHLabelsFrame.width := self.myDrawingFrame.width;
		self.myBottomHLabelsFrame.top := self.myViewportFrame.clientHeight() - self.myBottomHLabelsFrame.height;
	endif;
	
	if self.myLeftVLabelsFrame &lt;&gt; null then
		self.myLeftVLabelsFrame.top := self.myDrawingFrame.top;
		self.myLeftVLabelsFrame.height := self.myDrawingFrame.height;
	endif;
	
	if self.myRightVLabelsFrame &lt;&gt; null then
		self.myRightVLabelsFrame.top := self.myDrawingFrame.top;
		self.myRightVLabelsFrame.height := self.myDrawingFrame.height;
		self.myRightVLabelsFrame.left := self.myViewportFrame.clientWidth() - self.myRightVLabelsFrame.width - _parentFrame.left + 1;
	endif;
	
	if self.myTopLeftLabelFrame &lt;&gt; null then
		self.myTopLeftLabelFrame.left := 0;
		self.myTopLeftLabelFrame.top := 0;
	endif;
	
	if self.myTopRightLabelFrame &lt;&gt; null then
		self.myTopRightLabelFrame.left := self.myViewportFrame.clientWidth() - self.myTopRightLabelFrame.width - _parentFrame.left + 1;
		self.myTopRightLabelFrame.top := 0;
	endif;
	
	if self.myBottomLeftLabelFrame &lt;&gt; null then
		self.myBottomLeftLabelFrame.left := 0; 
		self.myBottomLeftLabelFrame.top := self.myViewportFrame.clientHeight() - self.myBottomLeftLabelFrame.height;
	endif;
	
	if self.myBottomRightLabelFrame &lt;&gt; null then
		self.myBottomRightLabelFrame.left := self.myViewportFrame.clientWidth() - self.myBottomRightLabelFrame.width - _parentFrame.left + 1;
		self.myBottomRightLabelFrame.top := self.myViewportFrame.clientHeight() - self.myBottomRightLabelFrame.height;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_parentFrame" type="Frame"/>
    </JadeMethod>
    <JadeMethod name="refresh" id="8c231dc6-5a6e-486e-8ebb-b7c9592ad25e">
        <updating/>
        <source>refresh() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwjk3	Initial creation

*/

vars

begin
	self.drawEverything();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetScrollOffsets" id="b442bd04-18d0-48f3-9ebe-448f57a7adde">
        <updating/>
        <source>resetScrollOffsets() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2010	cnwjk3	Initial creation

*/

vars

begin
	self.hScrollOffset := 0;
	self.vScrollOffset := 0;
epilog

