    <JadeMethod name="create" id="ef46356c-2205-44b3-bbc6-70ce03463e71">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 July 2022 		navam1 	ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN
05 October 2022		navmd1	TFS 55088 Only allow running in GUI app
24 January 2024		navmd1	TFS 60905 Refactor SSO for Superuser
03 Sept    2025 	navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client
*/

vars
	hadException	: Boolean;
begin
	if app.applicationType &lt;&gt; Application.ApplicationType_GUI then
		app.raiseUnexpectedProgramError(class.name, method.name, "SSO can only run on a GUI application");
		return;
	endif;

	on Exception do self.handleExceptions(exception, hadException);	
	create self.mySSOHelper transient;
	if self.mySSOHelper &lt;&gt; null then
		//self.mySSOHelper.usePresentationClient := self.usePresentationClient;
		self.mySSOHelper.usePresentationClient := true; //because the single sign on (MSAL) library dll exists on the thin client and not on the server
	endif;

	// MTN-35151 - navec1 - Okta SSO
	self.oktaSsoInFlight := false;
	create self.myOktaSsoHelper transient;
	if self.myOktaSsoHelper &lt;&gt; null then
		self.myOktaSsoHelper.usePresentationClient := true; //because library dll exists on the client side not on the server
	endif;
	
	self.provider := app.myRoot.getConfig(SsoProvider).Integer;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="fed46fa1-8478-44f9-b007-7675656a53d8">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2022 navam1 ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN
03 Sept 2025 navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client
*/

vars

begin
	delete self.mySSOHelper;
	
	// MTN-35151 - navec1 - Okta SSO
	on Exception do self.skipOktaExpcept(exception);
		myOktaSsoHelper.cancel();	// ensure listener is stopped
		myOktaSsoHelper.dispose();	// ensure all objects are disposed	
		delete self.myOktaSsoHelper;
	on Exception do null; // reset
epilog

end;</source>
    </JadeMethod>
