    <JadeMethod name="doDelete" id="4acb7c64-3112-4259-9fd4-cd39f2fff48a">
        <source>doDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

	obj : CM_Object;
	msg : String;

begin

	obj := self.myTerminal.getHandHeldConfig( null ).CM_HandHeldConfig;
	
	if obj &lt;&gt; null then
		msg := app.getErrorString(Sure_want_delet_hand_held_conf);
		if app.msgBox(msg, app.getErrorString(Warning),MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
		app.myTrxDA.trxDeleteCMObject( obj, app.myPassport );
		self.loadHandHeldConfig(null);
		self.resetButtons();
	endif;
	
epilog

end;</source>
    </JadeMethod>
