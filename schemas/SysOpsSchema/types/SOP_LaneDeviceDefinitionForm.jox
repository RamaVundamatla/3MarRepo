    <JadeMethod name="setupForm" id="2954d7c8-bdcc-481a-a0f8-141fea94ea7c">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     10 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	
	// set modal result to cancel - we only set it to OK if they click theOK button
	self.modalResult	:= IDCANCEL;

	btnOk.zOrder(1);
	btnCancel.zOrder (1);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8f055168-682a-4647-ba3b-ca5ad99b8c47">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018596, locale);
end;</source>
    </JadeMethod>
