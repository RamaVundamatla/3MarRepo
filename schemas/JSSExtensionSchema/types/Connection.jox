<Class name="Connection">
    <JadeMethod name="jssGetStateDescription" id="7ee8b065-77dc-4e71-ad4c-7cc0a306b920">
        <source>jssGetStateDescription():String;
// --------------------------------------------------------------------------------
// Created:		21 November 2000 by cnwdad1
//
// Purpose:		Returns a description of the current state of the connection.
//
// Parameters:	None
//
// Returns:		A translatable string corresponding to the connection state.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	connectionState	: Integer;
	
begin
	connectionState	:=	self.state;
	
	if connectionState = Connection.Disconnected then
		return $JSS_CONNSTATE_DISCONNECTED;
	elseif connectionState = Connection.Connecting then
		return $JSS_CONNSTATE_CONNECTING;
	elseif connectionState = Connection.Connected then
		return $JSS_CONNSTATE_CONNECTED;
	elseif connectionState = Connection.Disconnecting then
		return $JSS_CONNSTATE_DISCONNECTING;
	else
		return $JSS_CONNSTATE_UNKNOWN(connectionState.String);
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
