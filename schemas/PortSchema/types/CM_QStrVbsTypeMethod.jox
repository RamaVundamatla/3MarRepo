<Class name="CM_QStrVbsTypeMethod" id="53debc3f-484a-460c-ab8a-367651ffc82e">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="e2bd0744-bc96-4d7b-8f73-d1fd47f1d010">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Aug 2023 navhl20 Bug 60056: FR | 53429 - VBS Selector issues

*/

vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="a63f9a94-3ed7-48c7-af34-2044b999cdcb">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2023	navlw1	Initial creation ChangeRequest 58146: EUP - VBS MTN - [6] - Selector Query and JRW Part 2
25 Aug 2023 navhl20 Bug 60056: FR | 53429 - VBS Selector issues
*/

vars
	vbsSlotType		: CM_VehicleBookingTimeSlotType;
	selectStr		: String;
	storeIdx		: Integer;
	idx				: Integer;
	selectedSlot	: CM_VehicleBookingTimeSlotType;
	term 			: CM_Terminal;
begin
	_combo.clear();
	_combo.sorted := true;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		selectStr := _queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		selectStr := _queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;
	
	term := _passport.myTerminal;
	if term &lt;&gt; null then
		foreach vbsSlotType in term.allTerminalVBSSlotTypes discreteLock do
			idx := _combo.addItem( vbsSlotType.code.toUpper() &amp; Space &amp; Hyphen &amp; Space &amp; vbsSlotType.description );		//25.8.2023 navhl20 #60058
			_combo.itemObject[idx] := vbsSlotType;
			if vbsSlotType.notAvailableForEntry then
				_combo.itemEnabled[idx] := false;
			endif;
			if vbsSlotType.description = selectStr then
				selectedSlot := vbsSlotType;
			endif;	
		endforeach;
			
		storeIdx  := _combo.findObject(selectedSlot);
		if storeIdx &gt; 0 and storeIdx &lt; _combo.listCount then
			_combo.listIndex := storeIdx;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="1418e6fa-f6ab-4d30-9380-7f1b27170112">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2023	navlw1	Initial creation ChangeRequest 58146: EUP - VBS MTN - [6] - Selector Query and JRW Part 2
25 Aug 2023 navhl20 Bug 60056: FR | 53429 - VBS Selector issues
*/

vars
	selectionValue, idx : Integer;
	array 				: ObjectArray;
	vbsType 			: CM_VehicleBookingTimeSlotType;
	dict 				: CM_ToDoTaskDescByShortDesc;
	str					: String;
	os					: ObjectSet;
	ut					: CM_UserTerminal;
	obj					: Object;
	multiTerminal		: Boolean;
	propname			: String;
	crit				: CM_SelectorCriteriaLine;
begin
	
	_tbl.rows := 0;
	
	if _params = null then
		return;
	endif;
	
	array := _tbl.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear();
	
	propname := "myTerminal";
	crit := _params.allCriteriaByPropertyName.getAtKeyGeq(propname, null);
	if crit &lt;&gt; null and crit.propName &lt;&gt; propname then
		crit := null;
	endif;
	
	if crit = null then
		propname := "getTerminal";
		crit := _params.allCriteriaByPropertyName.getAtKeyGeq(propname, null);
		if crit &lt;&gt; null and crit.propName &lt;&gt; propname then
			crit := null;
		endif;
	endif;

	create os transient;
	
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(os);
	else
		foreach ut in _passport.myUser.allUserTerminals do
			os.add(ut.getMyTerminal);
		endforeach;
	endif;
	
	multiTerminal := (os.size &gt; 1);
	
	foreach obj in os do
		foreach vbsType in obj.CM_Terminal.allTerminalVBSSlotTypes do	
		
			selectionValue := 0;
			if _operator &lt;&gt; null and  _operator.CM_QStringIsOneOf.allSelectionValues.includes(vbsType.description) then
				selectionValue := 1;
				array.add(vbsType);
			endif;
		
			idx := _tbl.addItem(selectionValue.String &amp; Tab  &amp; vbsType.code.toUpper() &amp; Space &amp; Hyphen &amp; Space &amp; vbsType.description.toUpper());
			_tbl.accessRow(idx).itemObject := vbsType;
		endforeach;
	endforeach;
epilog
	delete os;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="f5a9b9ca-a952-43cc-9e39-8b868f8a4449">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2023	navlw1	Initial creation ChangeRequest 58146: EUP - VBS MTN - [6] - Selector Query and JRW Part 2

*/

vars
	numRows,
	idx					: Integer;
	str 				: String;
	slotType 			: CM_VehicleBookingTimeSlotType;
	vvrStrArray			: StringArray; 
begin
	create vvrStrArray transient;
	
	numRows := _tbl.rows;
	foreach idx in _tbl.fixedRows + 1 to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			slotType := _tbl.accessRow(idx).itemObject.CM_VehicleBookingTimeSlotType;
			vvrStrArray.add(slotType.description);
		endif;
	endforeach;
	
	_op.setSearchValue(vvrStrArray);

epilog
	delete vvrStrArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="23750648-7146-4f4d-afe0-1ea156c40812">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2023	navlw1	Initial creation ChangeRequest 58146: EUP - VBS MTN - [6] - Selector Query and JRW Part 2

*/

vars
	slotType : CM_VehicleBookingTimeSlotType;
begin
	if _value.isKindOf (CM_VehicleBookingTimeSlotType) then	
		if _value &lt;&gt; null then
			slotType := _value.CM_VehicleBookingTimeSlotType;
			return slotType.description;
		else
			return null;
		endif;
	endif;
	
	return _value.String;
	
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="153b106a-951c-43f0-b274-e62bd476a126">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2023	navlw1	Initial creation ChangeRequest 58146: EUP - VBS MTN - [6] - Selector Query and JRW Part 2

*/

vars
	invalidObj 		: Boolean;
	object			: CM_VehicleBookingTimeSlotType;
	returnVal		: String;
begin

	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		elseif _value.isKindOf(CM_VehicleBookingTimeSlotType) then
			object := _value.CM_VehicleBookingTimeSlotType;
		elseif _value.isKindOf(String) then
			returnVal := _value.String;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		returnVal := object.description;
	endif;
	
	return returnVal;
	
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
