    <Constant name="SEPARATOR" id="06572bcb-2320-4e8d-8b80-352896b64861">
        <source>"\"</source>
        <type name="String"/>
    </Constant>
    <ImplicitInverseRef name="applicationSchema" id="ef785ea7-8747-4011-a3d1-bf3c2d65541c">
        <embedded/>
        <type name="Schema"/>
        <access>readonly</access>
        <text>This property will only be used when the instance is a shared transient.

It is used to tell the application that is started in the JSSChangeTrackingSchema
what the user's application schema is when it converts the object id into a
class.</text>
    </ImplicitInverseRef>
    <PrimAttribute name="eventType" id="b85d09e4-e6f9-40f2-ad36-7697b70a3c43">
