    <JadeMethod name="validateForCreate" id="a04306aa-f2cb-44c4-8868-b860d3589f7c">
        <source>validateForCreate();
/*
Date		Who		Reason
15 Dec 2008	conks1	Initial creation
13/03/2013	cnwcs5	CCMS POL 2097 / par 31259 - transaltion criteria
*/
vars
	code	:String;
	xlation	:CM_Xlation;
begin
	code := self.foreignCode;
	
	if app.myRoot.allXLAT_Categories[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, code, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
