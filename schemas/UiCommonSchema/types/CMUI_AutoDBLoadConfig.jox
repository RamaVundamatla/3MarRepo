<GUIClass name="CMUI_AutoDBLoadConfig" id="f11f4b60-1a88-45c9-8665-94a816dd56c3">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <Constant name="COL_HEADER_AUTO_DBLOAD" id="e91f86c5-ce3f-4b85-84b8-5c72ed4baf0e">
        <source>"Auto DB Load"</source>
        <type name="String"/>
    </Constant>
    <Constant name="COL_HEADER_MESSAGE" id="87e147f7-25ff-4cbe-9b4c-c9a5eb49b190">
        <source>"Message"</source>
        <type name="String"/>
    </Constant>
    <Constant name="COL_HEADER_TRANS_MODE" id="7ab115d1-c9ba-47f9-b04f-de9ba21c5097">
        <source>"Transport Mode"</source>
        <type name="String"/>
    </Constant>
    <Constant name="COL_HEADER_TYPE" id="fdcc7e22-5fdb-4ab0-8eee-9336dd5b7d37">
        <source>"Type"</source>
        <type name="String"/>
    </Constant>
    <Constant name="STR_EDIAUTODBLOADCONFIG" id="dfa54921-9a23-4e84-b0f4-387aee29727d">
        <source>"EDIAutoDBLoadConfig"</source>
        <type name="String"/>
    </Constant>
    <ImplicitInverseRef name="tblEDIProcessConfig" id="c52f55d4-4008-409a-afbf-316fb0537b4f">
        <embedded/>
        <type name="CM_Table"/>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="ef397d4e-0a43-4367-b82b-ecdf3d39abec">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023	navra1	Initial creation for 58278

*/

vars

begin
	self.permissionView  := PmAdmAutoDBLoadView;
	self.permissionMaint := PmAdmAutoDBLoadMaint;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="410e0edc-5f52-4f46-b76b-489d1e5b2651">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023	navra1	Initial creation for 58278
11 Aug  2023    navsp1  ChangeRequest 59751: EUP | Manifest and Calloff - AutoDB Load config
*/

vars
	configPair : CM_NameValuePair;
	configPairDict : CM_NameValuePairDict;
	rowIdx :Integer;
	key : String;
	value : String;
begin	
	create configPairDict transient;

	foreach rowIdx in self.tblEDIProcessConfig.fixedRows + 1 to self.tblEDIProcessConfig.rows do
		create configPair transient;
		
		key := null;		
		
		key :=	self.tblEDIProcessConfig.accessCell(rowIdx, 1).text &amp; "|" &amp; 
				self.tblEDIProcessConfig.accessCell(rowIdx, 2).text &amp; "|" &amp;
				self.tblEDIProcessConfig.accessCell(rowIdx, 3).text;
				
		value := self.tblEDIProcessConfig.accessCell(rowIdx, 4).text.Integer.String &amp; self.tblEDIProcessConfig.accessCell(rowIdx, 5).text.Integer.String &amp; self.tblEDIProcessConfig.accessCell(rowIdx, 6).text.Integer.String; //11.Aug.2023 navsp1 TFS 59751
		
		if key = null then 
			continue; 
		endif;
			
		configPair.createNewPair(key, value);
		configPairDict.add(configPair);	
		
	endforeach;
	
	if configPairDict.size() &gt; 0 then
		if self.getMyTerminal() &lt;&gt; null then
			app.myTrxUA.trxUpdateTerminalDBLoadConfig(self.getMyTerminal(), configPairDict, app.myPassport);
		endif;
	endif;
	
	inheritMethod();		

epilog
	configPairDict.purge();
	delete configPairDict;

end;</source>
    </JadeMethod>
    <JadeMethod name="initTable" id="d2a39caa-42b8-4ef7-bf6e-6096ae723c02">
        <updating/>
        <source>initTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023	navra1	Initial creation for 58278
11 Aug  2023    navsp1  ChangeRequest 59751: EUP | Manifest and Calloff - AutoDB Load config
*/

vars
	idx : Integer;

begin	

	self.tblEDIProcessConfig.defaultRowHeight := 17;
	self.tblEDIProcessConfig.rows := 1;	
	self.tblEDIProcessConfig.fixedRows := 2;
	self.tblEDIProcessConfig.columns := 6;
	self.tblEDIProcessConfig.fixed3D := false;	
	self.tblEDIProcessConfig.accessColumn(1).width := 60;
	self.tblEDIProcessConfig.accessColumn(2).width := 140;
	self.tblEDIProcessConfig.accessColumn(3).width := 107;
	self.tblEDIProcessConfig.accessColumn(4).width := 93;
    self.tblEDIProcessConfig.accessColumn(5).width := 93;
    self.tblEDIProcessConfig.accessColumn(6).width := 93;
	self.tblEDIProcessConfig.alignment := Table.Alignment_Center;
	self.tblEDIProcessConfig.accessRow(1).enabled := false;	
	self.tblEDIProcessConfig.accessRow(1).fontBold := true;
	self.tblEDIProcessConfig.accessRow(1).foreColor := Black;
	
	self.tblEDIProcessConfig.accessColumn(1).inputType := Table.InputType_None;
	self.tblEDIProcessConfig.accessColumn(2).inputType := Table.InputType_None;
	self.tblEDIProcessConfig.accessColumn(3).inputType := Table.InputType_None;
	self.tblEDIProcessConfig.accessColumn(4).inputType := Table.InputType_CheckBox;	
	self.tblEDIProcessConfig.accessColumn(5).inputType := Table.InputType_CheckBox;	
    self.tblEDIProcessConfig.accessColumn(6).inputType := Table.InputType_CheckBox;	
	
	self.tblEDIProcessConfig.width := 580.0;
	self.width := 620.0;
	self.height:= 325.0;
	
	foreach idx in 1 to self.menuItemCount do
		self.menuItems(idx).visible := false;		
	endforeach;
	
	self.tblEDIProcessConfig.accessCell(1, 1).text:= self.COL_HEADER_MESSAGE &amp; Tab &amp; self.COL_HEADER_TYPE &amp; Tab &amp; self.COL_HEADER_TRANS_MODE &amp; Tab &amp; self.COL_HEADER_AUTO_DBLOAD &amp; Tab;
    self.tblEDIProcessConfig.accessCell(2, 1).text:= Tab &amp; Tab &amp; Tab &amp; "Create" &amp; Tab &amp; "Replace" &amp; Tab &amp; "Cancel";
    self.tblEDIProcessConfig.accessCell(1, 4).mergeCells := Table.MergeCells_Merge;

	return;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8ca48736-569f-49c4-8451-5778b461a2a0">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023	navra1	Initial creation for 58278
11 Aug  2023    navsp1  ChangeRequest 59751: EUP | Manifest and Calloff - AutoDB Load config
*/

vars
	baseScm : Schema;
	category : ConstantCategory;
	const : Constant;
	constDict : ConstantNDict;
	tableRowCols : StringArray;
	text : String;
	tableString : String;
	nameValue : CM_NameValuePair;
    configValue : String;
begin
	inheritMethod();	
	
	self.initTable();	

	create tableRowCols transient;
	
	baseScm := rootSchema.getSchema(PortSchemaName);
	category := baseScm.getCategory(STR_EDIAUTODBLOADCONFIG);	
	
	constDict := category.getConstants();	
	
	foreach const in constDict do
		tableString := '';
		tableRowCols.clear();
		text := const.valueAsString;
		text.getTokensForDelimiter('|', tableRowCols);
		tableString := tableRowCols[1] &amp; Tab &amp; tableRowCols[2] &amp; Tab &amp; tableRowCols[3];
		nameValue := self.myTerminal.allDBLoadOptions[text];
		if nameValue &lt;&gt; null then
            configValue := nameValue.value; //11.Aug.2023 navsp1 TFS 59751 &gt;&gt;&gt;&gt;
            if configValue.length = 3 then          
                 tableString := tableString &amp; Tab &amp; configValue[1:1] &amp; Tab &amp; configValue[2:1] &amp; Tab &amp; configValue[3:1]; 
            elseif configValue.length = 1 then
                tableString := tableString &amp; Tab &amp; configValue &amp; Tab &amp; configValue &amp; Tab &amp; configValue;
            endif;                          //11.Aug.2023 navsp1 TFS 59751 &lt;&lt;&lt;&lt;
		else
			tableString := tableString &amp; Tab &amp; '0';			
		endif;
		
		self.tblEDIProcessConfig.addItem(tableString);
		
	endforeach;
epilog	
	delete tableRowCols;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="563e5369-374b-4f0a-a1c3-c98ac7e34571">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 08 June 2023 08:16:23.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026098, locale);
end;</source>
    </JadeMethod>
</GUIClass>
