    </JadeMethod>
    <JadeMethod name="utlUpdateRoadJobDevices" id="e25ec7f2-7a42-4448-bda7-f37f1d64ff12">
        <updating/>
        <source>utlUpdateRoadJobDevices(_roadJob : CM_RoadJob input;
						_dev : String; _action : Integer) updating;
/*
	Created on 07 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
begin
	self.initialiseActivity();
	self.raiseExceptionIfNull(_roadJob, "Road Job");
	
	exclusiveLock(_roadJob);
	
	if _action = _roadJob.Add_Device then
		if _roadJob.allWorkingDeviceIDs.includes(_dev) then
			return;
		endif;
		_roadJob.allWorkingDeviceIDs.add(_dev);
	else 
		if not _roadJob.allWorkingDeviceIDs.includes(_dev) then
			return;
		endif;
		_roadJob.allWorkingDeviceIDs.remove(_dev);
	endif;
	_roadJob.updateStatus;
	_roadJob.causeEvent(_roadJob.myTerminal.getTerminalEvent(RoadJob_Create_Event), false, _roadJob);			

end;</source>
        <Parameter name="_roadJob" type="CM_RoadJob" usage="input"/>
        <Parameter name="_dev" type="String"/>
        <Parameter name="_action" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRoadJobRFIDTag" id="dfb6f28f-4ce4-43ea-a4aa-026228b210cd">
        <updating/>
        <source>utlUpdateRoadJobRFIDTag(_roadJob : CM_RoadJob input;
						_rfidTag : CM_RFIDTag input	) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.initialiseActivity();

	self.raiseExceptionIfNull(_roadJob,"Road Job");
	
	exclusiveLock(_roadJob);
	
	//epr par 20789 17/3/10
	if  _rfidTag = null then
	//raise exception if the system has rfid tags they must select an rfid tag
	//	app.raiseCMException1(REQUIRED_FIELD,"RFID Tag", "RFID_Tag",null);
		app.raiseCMException(Input_required_field_RFIDTag, "RFID_Tag",null); // cnwdb2	PAR 35364
		return;
	endif;
	//th2 added 22/01/07 - shouldn't ever try to assign an rfid tag to a job when it is
	//already assigned to a different job (GUI list of available tags should also prevent this).
	if _rfidTag.myRoadJob &lt;&gt; null and _rfidTag.myRoadJob &lt;&gt; _roadJob then
		app.raiseCMException2(Rfid_alrea_assig_diffe_road_th,_rfidTag.code, _rfidTag.myRoadJob.regNumber,"RFID_Tag",null);
		return;
	endif;

	_roadJob.setMyRFIDTag(_rfidTag);
	
	
	
epilog

end;</source>
        <Parameter name="_roadJob" type="CM_RoadJob" usage="input"/>
        <Parameter name="_rfidTag" type="CM_RFIDTag" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRoadJobWithReleaseTI" id="7511be03-d2cf-4755-9f00-aa39470b6932">
        <updating/>
        <source>utlUpdateRoadJobWithReleaseTI(_job : CM_RoadJob io; _ti : CM_TrackedItem io; _passport : CM_Passport input; _remove : Boolean)updating;

// 28/05/2010	cnwcs5	par 24292 - use CM_InterchangeArea instead of CM_YardInterchangeArea
// 18/06/2010 	cnwcs4	par 24418 - change of parameters
vars
	chkHazDocs 		: Boolean;
	wle				: CM_WorkListEntry;
	tiRequest 	: CM_TIRequest;
	request 		: CM_Request;
	moveController 	: CMIF_MoveController;
	loc 			: CM_BlockController;
	icArea 			: CM_TerminalArea;	// par 24292
begin
	app.setContinueCMExceptions(false);
	
	chkHazDocs 	:= _passport.myTerminal.getConfig(GateInOutHazardousWarning).Boolean;
	icArea 		:= _job.getYardInterchangeArea();	// par 24418
	
	if chkHazDocs and _ti.isHazardous then
		app.raiseCMWarning1(WarningConfirmHazadousDocos, _ti.id, null, null, _job);
		return;
	endif;
	
	if _ti.jobRoadRelease &lt;&gt; null then
		app.raiseCMException(ItemAlreadyLoaded, _ti.id, _job);
		return;
	endif;
	if icArea.isKindOf(CM_CraneTransferArea) then	//31 Jan 2013	NDL	Par 31102
		loc := null;
	else
		loc := icArea.CM_InterchangeArea.myInTransitToLocation;
	endif;
	
	create tiRequest transient;
	//Nb Proxy request points to ACTUAL TI, otherwise actual request ends up pointing to transient TI !
	tiRequest.setProxy(false, _ti.voyageCode, _ti.eirNumber, // lClean, lconsignorVoyageCode, leirNumber	//cnwas3 par 27766
								null, null, null, _ti.freightForwarderCode, null,false, //lconsignee, ldoorsForward,pDeliveryNumber,lFreightForwarder,lFreightPayee, lisReceipt
								null,null, 0,null, false, null, false, 		// lISOType, lOperator, lNumRequested, lreasonCode, lHeavy, lMask, lneedCOU,
								false, null, null, false, null, _ti.getPinNumber(), null,	// lneedGenerator, lDate, lvoyageCode, lCheckISO, pJob, pAVG
								false, null, 
								null, _ti,
								app.getMyUserCode, _job.myTerminal);

	tiRequest.validate(null);
	//Add the request. This creates a real request from our proxy &amp; adds to job
	// I also creates the wles for each request, so needs to be done before the move
	if _passport.hasErrors then
		return;
	endif;	
	request := _job.addRequest(tiRequest, _passport);
	if request = null 
	or _passport.hasErrors then
		return;
	endif;	
	// Par 8543 Need wle for move validation to work correctly.
	if request = null then
		return;
	endif;
	wle := _job.getWLEForTI(_ti);

	create moveController transient;
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyTrackedItem(_ti);
	moveController.setMyToPrimaryLocation(_job.myVehicle.locationsController);
	moveController.setJobForMove(_job);
	if wle &lt;&gt; null then
		moveController.setMyWorkListEntry(wle);
	endif;
	
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	
	if _passport.hasErrors then
		return;
	endif;		
	
	app.myUtilityUA.utlMoveVehicle(	_job.myVehicle, loc, _passport);
	
	_job.updateStatus;
	
	app.myUtilityUA.utlUpdateVehicleVisitRecordTIs(_job);
epilog
	delete moveController;
end;
</source>
        <Parameter name="_job" type="CM_RoadJob" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_remove" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRoadOpsDispCrit" id="bd5c4242-d68a-44fe-813a-69330890765d">
        <updating/>
        <source>utlUpdateRoadOpsDispCrit(	_roadOpsCrit : IntegerArray input;
							_pxyTerminal  : CM_Terminal input;
							_passport : CM_Passport input
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2016	cnwndl1	Initial creation	TFS 2995/2638

*/

vars

	terminal : CM_Terminal;
	expectedEdition : Integer;

begin

	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_roadOpsCrit, 'Types Integer Array');
	
	_pxyTerminal.pxyGetRealObjectAndEdition(terminal, expectedEdition);
	self.raiseExceptionIfNull(terminal, 'Terminal');
	
	if _passport.noErrors then
		terminal.setRoadOpsDisplayCriteria( _roadOpsCrit );
	endif;

epilog

end;</source>
        <Parameter name="_roadOpsCrit" type="IntegerArray" usage="input"/>
        <Parameter name="_pxyTerminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRoadProcess" id="286706d9-df9e-44d5-a8a4-b1ecc556eaed">
        <source>utlUpdateRoadProcess(pProxyRoadProcess : CM_RoadProcess; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	realRoadProcess : CM_RoadProcess;
	expectedEdition : Integer;

begin

	self.initialiseActivity();

	pProxyRoadProcess.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyRoadProcess.pxyGetRealObjectAndEdition(realRoadProcess, expectedEdition);
	
	if realRoadProcess = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_RoadProcess.name, null, null);
		return;
	endif;

	app.myValUA.valRoadProcess(realRoadProcess, pProxyRoadProcess);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realRoadProcess);

	if _passport.noErrors and realRoadProcess.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, ' Road Process ', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRoadProcess, true);
	endif;
	
	if _passport.noErrors then
		realRoadProcess.setForUpdate(pProxyRoadProcess);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRoadProcess, false);
	endif;
end;</source>
        <Parameter name="pProxyRoadProcess" type="CM_RoadProcess"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRoot" id="7e35d497-c1c0-4125-bc96-2845e6183364">
        <source>utlUpdateRoot(_root : CM_Root input);
// -----------------------------------------------------------------------------
// Created:		19 February 2002 by cnwka1
//
// Purpose:		Used by initialization of a clean system, hence no use of proxies
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	_root.initialiseRoot();
epilog
