    <JadeMethod name="setActOrPlanAsReqd" id="9cc7f49b-1c71-4a66-b903-f6b603fcb698">
        <source>setActOrPlanAsReqd(newTime:	TimeStamp) : Integer;
//-----------------------------------------------------------------------
//	Created:	21 August 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	now:	TimeStamp;
begin
	now := app.actualTimeServer();	// 26/5/16 cnwmp6 TFS 488 - Multi timezone support
	//now:="22 February 1999, 00:00:00".TimeStamp; // For testing only
 	// When the time that is being set is less than the current time,
 	// ask the user if they wish to set the 'Actual' or the 'Planned' Time.
 	if newTime &lt; now
 	and self.myProxyMovement.moveStatusNEW &lt;&gt; MovementStatus_Actual then
 		// Ask user if 'Act' or 'Plan'
 		if app.msgBox(app.getErrorString(HMS_ActualTimeForMove), app.getErrorString(Confirm_ACTUAL_Time), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
 			// Time is actual
 			return MovementStatus_Actual;		
 		endif;
 	endif;	
 	return self.myProxyMovement.moveStatusNEW;
end;</source>
        <Parameter name="newTime" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
