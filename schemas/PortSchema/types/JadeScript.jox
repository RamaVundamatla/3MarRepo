    <JadeMethod name="rel861_tfs39618" id="b82c8782-d488-43fc-a82c-f817c8593dc2">
        <source>rel861_tfs39618();
/*

Purpose:			POST RELEASE FINISHING DEV

Parameters:			TFS 39618 PATCH 1

Return Value:		

Date		Who		Reason
28 January 2019	jlgab1	Initial creation

*/

vars
	sch : Schema;
	cls : Class;
	constDict : ConstantNDict;
	const : Constant;

	defEmail : CM_InvStatusDefaultEmail;
	invProcess : CM_InvoiceProcess;
	invStatus : CM_InvoiceStatus;
	stat : Integer;
	inv : CM_Invoice;
	root : CM_Root;
begin
	root := CM_Root.firstInstance;


	/*
	sch := rootSchema.getSchema("PortSchema");
	cls := sch.getClass("CM_Invoice");
	create constDict transient;
	cls.getConstants(constDict);
	
	const := constDict["INVOICE_APPROVED"];
	beginTransaction;
	const.cnEcSetSource("11");
	commitTransaction;
	*/
	
	// DUPLICATE INVOICE STATUSES, Change LINX 10 to 11
	invProcess := CM_Root.firstInstance.allInvoiceProcesses["LINX"];
	
	invStatus := invProcess.allStatuses[10];
	
	if invStatus &lt;&gt; null then
		beginTransaction;
		invStatus.setPropertyValue("id", CM_Invoice.INVOICE_APPROVED);
		commitTransaction;
	endif;
	foreach inv in invProcess.allInvoices	discreteLock do
		if inv.status = 10 then
			beginTransaction;
			inv.setPropertyValue("status", CM_Invoice.INVOICE_APPROVED);
			commitTransaction;
	
		
		endif;
	endforeach;
	
	// DEFAULT EMAIL FOR APPROVED
	defEmail := root.allInvStatusDefaultEmails[330];
	if defEmail &lt;&gt; null then
		beginTransaction;
		defEmail.setPropertyValue(CM_InvStatusDefaultEmail::type.name, PINEmail_InvProcLinxOffset + CM_Invoice.INVOICE_APPROVED);
		defEmail.setPropertyValue(CM_InvStatusDefaultEmail::name.name, "Approved");
		defEmail.setPropertyValue(CM_InvStatusDefaultEmail::subjectLine.name, "Approved");
		commitTransaction;
	
	endif;

	// ALL DEFAULT EMAILS HAD WRONG NAME
	foreach invProcess in root.allInvoiceProcesses	discreteLock do
		foreach invStatus in invProcess.allStatuses	discreteLock do
			defEmail := root.allInvStatusDefaultEmails[invProcess.pinEmailOffset + invStatus.id];
			if defEmail &lt;&gt; null then
				
				if invStatus.description &lt;&gt; defEmail.name then
					beginTransaction;
					defEmail.setPropertyValue(CM_InvStatusDefaultEmail::name.name, invStatus.description);
					defEmail.setPropertyValue(CM_InvStatusDefaultEmail::subjectLine.name,invStatus.description);
					commitTransaction;
				endif;
			endif;
	
		endforeach;
	
	endforeach;

epilog

end;</source>
    </JadeMethod>
