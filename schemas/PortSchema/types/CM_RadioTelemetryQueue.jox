    <JadeMethod name="validateUpdate" id="aff720cf-0da5-45db-a8df-dd88970c838b">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

	term : CM_Terminal;
	queuesToCheck : CM_RTQueueArray;
	realQueue : CM_RadioTelemetryQueue;
	queue : CM_RadioTelemetryQueue;

begin
	
	if self.myParentQueue = null then
	//	app.raiseCMException1(REQUIRED_FIELD,"parent queue",null,null);
		app.raiseCMException(Input_required_field_parentQue,null,null); // cnwdb2	PAR 35364
	endif;

	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Id' , 'id', null);
		app.raiseCMException(Input_required_field_id , 'id', null); // cnwdb2	PAR 35364
	endif;
	
	//23 Jan 2013	NDL	Par 30914 Existing validation in sub classes was not only doing the id checking 
	//								against its own queue types. Vehicle Mounted App requires unique queue names across all queues.  
	if self.myParentQueue &lt;&gt; null then
		term := self.getMyTerminal;
	endif;
	if term &lt;&gt; null and not self.isKindOf(CM_MasterQueue) then
		realQueue := self.pxyGetRealObject();
		create queuesToCheck transient;
		term.getAllQueues( queuesToCheck );
		
		foreach queue in queuesToCheck do
			if queue.id &lt;&gt; self.id then
				continue;
			endif;
			if queue = self or queue = realQueue then
				continue;
			endif;
			app.raiseCMException1( ERR_QUEUE_EXISTS, self.id , null, null );
			break;
		endforeach;
		
	endif; 

epilog

	delete queuesToCheck;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
