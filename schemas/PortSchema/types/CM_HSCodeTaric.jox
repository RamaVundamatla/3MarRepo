    <JadeMethod name="getMyParent" id="a62e448e-b212-4d6f-96f1-d0cf7b05bc12">
        <source>getMyParent(): CM_HarmonizedSystem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/02/2023	navkc1 CR 59577 Task 62410: Jade - New TRX for HS Taric

*/

vars

begin
	
	if self.myHSSubCode &lt;&gt; null and self.myHSSubCode.isTransient() and not self.myHSSubCode.pxyIsProxy() then
		return app.myRoot.allHSSubCodes[self.myHSSubCode.id];
	endif;
	
	return self.myHSSubCode;

epilog

end;</source>
        <ReturnType type="CM_HarmonizedSystem"/>
    </JadeMethod>
