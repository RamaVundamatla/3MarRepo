    <JadeMethod name="copyFrom" id="4710301c-cd57-47e6-9945-9423d9f58c4d">
        <updating/>
        <source>copyFrom(_map : CM_CommodityMap; _commodityCode : String; _parent : CM_ContentsMap) updating;
// 32311 set up self from the parameter plus the new contents status, copy all of the parameter map children under self.
vars
	sb 			: CM_TransServiceBroker;
	mm			: CM_MoveServiceBroker;
	newChild	: CM_TransServiceBroker;
	newMM		: CM_MoveServiceBroker;
begin
	self.commodityCode := _commodityCode;
	if _parent = null then
		self.contentsMap := _map.contentsMap;
	else
		self.contentsMap := _parent;
	endif;
	foreach sb in _map.allTransServiceBrokersByType do
		create newChild as sb.class persistent;
		newChild.copyFrom(sb, sb.myTransactionType, self);
	endforeach;
	foreach mm in _map.moveMap do
		create newMM persistent;
		newMM.copyFrom(mm, self);
	endforeach;
end;
</source>
        <Parameter name="_map" type="CM_CommodityMap"/>
        <Parameter name="_commodityCode" type="String"/>
        <Parameter name="_parent" type="CM_ContentsMap"/>
    </JadeMethod>
