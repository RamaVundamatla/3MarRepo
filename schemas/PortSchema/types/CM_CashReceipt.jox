    <JadeMethod name="getUncreditedAmount" id="885c62ee-7c9c-45e9-8dfb-d49aac616124">
        <source>getUncreditedAmount() : Decimal;
/*

Purpose:			
	Go through the existing credits to allow for manual credits which don't include the values here
	rather than through the payments and proformas
Parameters:			

Return Value:		

Date		Who		Reason

18 Sep 2019	cnwma1	Bug 46582: Cash Credit are not being accounted for correctly
*/
vars
	credit		: CM_CashCredit;
	total		: Decimal[23, 6];
begin

	total := self.cashValue;  //08.01.2020 cnwma1 #48211
	foreach credit in self.allDerivedFromCashCredits do
		total := total - credit.cashValue;
	endforeach;
	
	return total;
end;
</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getUserName" id="cd386211-6122-4742-ac4a-78138587e62b">
        <source>getUserName():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

begin

	if self.myUser = null then
		return null;
	endif;
	
	if self.myUser.userName.trimBlanks = null then
		return self.myUser.code;
	endif;
	
	return self.myUser.userName;

epilog

