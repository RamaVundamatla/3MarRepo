    <JadeMethod name="jreProformaDetails" id="f07dbb9d-5a08-45e4-9ef7-174273f73606">
        <source>jreProformaDetails();
// check the match between cash receipt proforma allCashPayments and allProformaDetails before doing any conversion for 34917
vars
	cr	: CM_CashReceipt;
	cp	: CM_CashPayment;
	pd	: CM_ProformaDetails;
	payTotal,
	profTotal,
	detTotal	: Decimal[16, 4];
begin
	foreach cr in CM_CashReceipt.instances do
		payTotal := 0; detTotal := 0; profTotal := 0;
		foreach cp in cr.allCashPayments do
			payTotal := payTotal + cp.cashValue;
			if cp.isProformaPayment then
				profTotal := profTotal + cp.cashValue;
			endif;
		endforeach;
		foreach pd in cr.allProformaDetails do
			detTotal := detTotal + pd.lineTotal;
		endforeach;
		if profTotal &lt;&gt; 0 or detTotal &lt;&gt; 0 then
			write cr.externalInvoiceNumber &amp; " payTotal=" &amp; payTotal.String &amp; " detTotal=" &amp; detTotal.String &amp; " profTotal=" &amp; profTotal.String;
			if profTotal &lt;&gt; detTotal then
				//cr.inspectModal;
			endif;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreRunBGTask" id="85d1d6a4-f6b4-4857-b8f8-71c08958894e">
        <source>jreRunBGTask();
// run storage processor, for 24016 testing
vars
	task			: CM_AutoTask;
	tmpClass		: Class;
	request			: BGP_Request;
	term			: CM_Terminal;
begin

	app.initialize();

	if app.myPassport.myTerminal = null then 
		term := CM_Root.firstInstance.allTerminals['T01'];
		app.myPassport.setMyTerminal(term);
	endif;

	//task := CM_AutoTaskStorageProcessor.firstInstance;	// or any other suitable instance
	foreach task in CM_AutoTaskSummarySnapShot.instances do
		//if task.description = "TEST CCMS 1043" then
		if task.description = "CCMS 1043 DT" then
			write " found " &amp; task.String;
			break;
		endif;
	endforeach;

	write 'Processing task (' &amp; task.description &amp; ')';
	tmpClass := self.getClass(task.requestClassName);
	if tmpClass = null then
		// Class has not been correctly setup.
		write task.requestClassName &amp; ' Request class not found';
		return;
	endif;

	create request as tmpClass transient;
	request.initRequestFromTask(task);
	if process.isInTransactionState then
		commitTransaction;
	endif;

	request.action();

	self.unlock(task);
	write method.name&amp;" completed";	
	
epilog	
	write method.name&amp;" epilog";	
	if task &lt;&gt; null then
		self.unlock(task);
	endif;
	delete request;
end;</source>
    </JadeMethod>
    <JadeMethod name="jreRunReportBGRequest" id="0793f4ac-25f3-403e-9180-a16c64d4a565">
        <source>jreRunReportBGRequest();
// run report background for TFS 978 testing
vars
	found		: Boolean;
	request		: BGP_ReportRequest;
	term		: CM_Terminal;
begin

	app.initialize();

	if app.myPassport.myTerminal = null then 
		term := CM_Root.firstInstance.allTerminals['CST'];
		app.myPassport.setMyTerminal(term);
	endif;

	foreach request in BGP_ReportRequest.instances do
		if request.myReportDef &lt;&gt; null then
			//bogus one created in CM_ReportTemplate
		//	if request.myReportDef.isSystemMenuItem and request.myReportDef.myMenuReportRoot = null then
				found := true;
				break;
		//	endif;
		endif;
	endforeach;

	if found then
		request.action();
		write method.name &amp; " 'action' completed";	
		beginTransaction;
		delete request;
		commitTransaction;
	else
		write "No suitable BGP_ReportRequests found";
	endif;
	
epilog	
	write method.name&amp;" epilog";	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="jreSetReeferConnect" id="e4c3092a-116e-4230-a6d4-f897e68b1eb7">
        <source>jreSetReeferConnect();

vars
	ts		: TimeStamp;
	term	: CM_Terminal;
	ti		: CM_TrackedItem;
	count	: Integer;
begin
	term := CM_Root.firstInstance.allTerminals["JT1"];
	beginTransaction;
	foreach ti in term.allOnsiteTIsByCargoTypeId do
		if ti.isReefer then
			ts := ti.receivedDT;
			ti.setFirstConnectDT(ts);
			count := count + 1;
		endif;
	endforeach;
	commitTransaction;
	write count;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreSuspenseInvoices" id="c3b7876f-73d1-4bb4-a750-c6c8a430f290">
        <source>jreSuspenseInvoices();
// RDT suspense invoices - put each invoice line back through old and new getInvoice code to see if any differencec
vars
	iter	: Iterator;
	trans	: CM_TITransaction;
	bank	: CM_Bank;
	invType	: CM_InvoiceDesc;
	invLine		: CM_InvoiceLine;
	invLineType	: CM_InvoiceLineDesc;
	invoice,
	invoice1,
	invoice2	: CM_Invoice;
	debtor	: CM_Debtor;
	status	: Integer;
	msg		: String;
	msg1, msg2, msg3, msg4, msg5	: String;
	new1, new2	: Boolean;
	matchCount	: Integer;
	nullCount, noMatchCount	: Integer;
	
begin
	debtor := CM_VoidDebtor.firstInstance;
	status := CM_Invoice.INVOICE_SUSPENSE;
	iter := debtor.invoicesByStatus.createIterator();
	debtor.invoicesByStatus.startKeyGeq(status, iter);
	while iter.next(invoice) do
		if invoice.status &lt;&gt; status then
			break;
		endif;
		
		invType := invoice.invoiceType;
		foreach invLine in invoice.invoiceLines do
			invLineType := invLine.invoiceLineDesc;
			trans := invLine.myTransactionTI;
			if trans = null then
				continue;
			endif;
			
			msg1 := "Invoice " &amp; invoice.sequenceNum.String &amp; " transaction " &amp; trans.class.name &amp; " " &amp; trans.dateTime.String;
			msg2 := "Line " &amp; invLine.sequenceNum.String;
			//msg3 := "Invoice line type " &amp; invLineType.narration &amp; " inv type " &amp; invLineType.invoiceType.description &amp; " accrual " &amp; invLineType.invoiceType.accrualType.String;
			invoice1 := invLineType.bank.getAutoInvoiceX(invType, trans, debtor, false, new1);
			invoice2 := invLineType.bank.getAutoInvoiceY(invType, trans, debtor, false, new2);
			if invoice1 &lt;&gt; invoice2 then
				msg := "** Invoice difference";
				if invoice1 = null then
					msg := msg &amp; " null invoice1";
				else
					msg := msg &amp; " invoice1=" &amp; invoice1.sequenceNum.String;
				endif;
				if invoice2 = null then
					msg := msg &amp; " null invoice2";
				else
					msg := msg &amp; " invoice2=" &amp; invoice2.sequenceNum.String;
				endif;
				write msg1;write msg2;write msg3;write msg;
				noMatchCount := noMatchCount + 1;
			else
				matchCount := matchCount + 1;
				msg := "  Invoice match";
				if invoice1 = null then
					msg := msg &amp; " null invoice";
					nullCount := nullCount + 1;
				else
					msg := msg &amp; " invoice=" &amp; invoice1.sequenceNum.String;
				endif;
			endif;
			///write msg;
					
		endforeach;
	endwhile;

	write "End - found " &amp; matchCount.String &amp; " matching invoices, " &amp; nullCount.String &amp; " are null, " &amp; noMatchCount.String &amp; " found no match";

	
epilog
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="jreTest1" id="305e9a09-020c-41f2-8470-c3d9bc8dca13">
        <source>jreTest1();
// GLCode is expected to be in the format 1.69.R20.1161001.000000
vars
	code,
	rest	: String;
	code1,
	code2,
	code3,
	code4,
	code5	: String;
begin
	code := '1.69.R20.1161001.000000';
write code;	
	code1 := jreTest2(code, rest);
	code := rest;
	code2 := jreTest2(code, rest);
	code := rest;
	code3 := jreTest2(code, rest);
	code := rest;
	code4 := jreTest2(code, rest);
	code := rest;
	code5 := jreTest2(code, rest);
	code := rest;
write code1;	write code2;write code3;write code4;write code5;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreTest1264A" id="9b0dae0e-bb2d-45d1-87d6-0ce99cdd5ede">
        <source>jreTest1264A();

vars
	charge	: CM_Charge;
	invLine	: CM_InvoiceLine;
	count,
	total	: Integer;
begin
	foreach charge in CM_Charge.instances do
		total := total + 1;
		if charge.invoiceLine = null then
			count := count + 1;
		endif;
	endforeach;
	
	write count;
	write total;
	
	count := 0;
	total := 0;
	foreach invLine in CM_InvoiceLine.instances do
		total := total + 1;
		if invLine.charges.isEmpty() then
			count := count + 1;
		endif;
	endforeach;
	
	write count;
	write total;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreTest2" id="9f160560-db2c-4174-877c-6fcf1f80b52b">
        <source>jreTest2(_code : String; _rest : String output) : String;
// GLCode is expected to be in the format 1.69.R20.1161001.000000
vars
	work	: String;
	result	: String;
	pos1,
	pos2	: Integer;
begin
	if _code = null then
		return null;
	endif;
	
	pos1 := 1;
	pos2 := 1;
	work := _code;
	pos2 :=  work.pos('.', pos1);
	if pos2 &gt; 1 then
		result := work[pos1:pos2 - 1];
		if pos2 &lt; work.length then
			work := work[pos2 + 1:end];
			pos2 := pos2 + 1;
			pos1 := pos2;
		endif;
	else
		result := work;
	endif;
	
	_rest := work;
	return result;

end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_rest" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jreTest25822" id="a59f4c17-d2b6-4b29-9a83-9ac840ead992">
        <source>jreTest25822();
// par 25822, object volatility conversion logging
//  check all relevant objects created since the patch to see if still stable
vars
	start	: Date;
	vessel	: CM_Vessel;
	voy		: CM_Voyage;
	oa		: ObjectArray;
	obj		: Object;
	ta		: CM_TerminalArea;
	itg		: CM_ISOTypeGroup;
begin
	start := "25/01/2011".Date;
	create oa transient;

	foreach vessel in CM_Vessel.instances do
		if vessel.createdTime.date &gt;= start and
		   vessel.myCellularVesselStructure &lt;&gt; null then
			write "New vessel " &amp; vessel.code;
			write " allBays40ByLabel " &amp; self.getObjectVolatility(vessel.myCellularVesselStructure.allBays40ByLabel).String;
			write " allBaysByLabel " &amp; self.getObjectVolatility(vessel.myCellularVesselStructure.allBaysByLabel).String;
			write " allBaysByOrdinal " &amp; self.getObjectVolatility(vessel.myCellularVesselStructure.allBaysByOrdinal).String;
			write " allHatchlids " &amp; self.getObjectVolatility(vessel.myCellularVesselStructure.allHatchlids).String;
			write " allHolds " &amp; self.getObjectVolatility(vessel.myCellularVesselStructure.allHolds).String;
		endif;
	endforeach;

	foreach voy in CM_Voyage.instances do
		if voy.createdTime.date &gt;= start and
		   voy.myCellularVoyageStructure &lt;&gt; null then
			write "New voyage " &amp; voy.code;
			write " allBayVoyagesById " &amp; self.getObjectVolatility(voy.myCellularVoyageStructure.allBayVoyagesById).String;
			write " allBayVoyagesById40 " &amp; self.getObjectVolatility(voy.myCellularVoyageStructure.allBayVoyagesById40).String;
			write " allBayVoyagesByOrdinal " &amp; self.getObjectVolatility(voy.myCellularVoyageStructure.allBayVoyagesByOrdinal).String;
			write " allHatchLids " &amp; self.getObjectVolatility(voy.myCellularVoyageStructure.allHatchLids).String;
			write " allHolds " &amp; self.getObjectVolatility(voy.myCellularVoyageStructure.allHolds).String;
		endif;
	endforeach;
	
	CM_TerminalArea.allInstances(oa, 0, true);
	foreach obj in oa do
		ta := obj.CM_TerminalArea;
		if ta.createdTime.date &gt;= start then
			write "New terminal area " &amp; ta.id &amp; " " &amp; ta.class.name;
			write " allLocationsControllers " &amp; self.getObjectVolatility(ta.allLocationsControllers).String;
		endif;
	endforeach;
	
	foreach itg in CM_ISOTypeGroup.instances do
		if itg.createdTime.date &gt;= start then
			write "New ISO type group " &amp; itg.code;
			write " allISOTypes " &amp; self.getObjectVolatility(itg.allISOTypes).String;
		endif;
	endforeach;

end;

</source>
    </JadeMethod>
    <JadeMethod name="jreTest26799" id="21928f64-e093-4247-9955-03dfd77b7455">
        <source>jreTest26799();
// see if there are any invoices which show a difference in GST or total between the invoice print and extract calculations
vars
	different,
	count	: Integer;
	amt, taxAmt1,
	taxAmt2,
	total	: Decimal[12, 2];
	invStatTotal,
	taxTotal	: Real;
	work,
	taxRate		: Real;
	idx		: Integer;
	codes	: StringArray;
	rates	: RealArray;
	amounts	: RealArray;
	taxMulti : Boolean;
	
	term	: CM_Terminal;
	bank	: CM_Bank;
	invoice	: CM_Invoice;
	invLineStatDict	: CM_InvoiceLineStatByNarManDict;
begin
	app.initialize;

	create codes transient;
	create rates transient;
	create amounts transient;

	term := "2351.35".asOid.CM_Terminal;
	taxMulti := term.getConfig(InvoiceMultiTaxRates).Boolean;
	bank := term.getBusinessUnit;
	create invLineStatDict transient;
	foreach invoice in bank.allInvoices do
		if invoice.isPosted then
			continue;
		endif;
		count := count + 1;
		if invoice.isZeroRatedTax then
			continue;
		endif;
		invLineStatDict.clear;
		invStatTotal := invoice.getInvoiceStats(invLineStatDict, null, false, false);
		amt := invStatTotal;
		invoice.getTaxForInvoice(taxMulti, amt, codes, rates, amounts);
		taxTotal := 0;
		foreach idx in 1 to 4 do
			if idx &lt;= codes.size then
				taxTotal := taxTotal + (amounts[idx] * (rates[idx] / 100));
			endif;
		endforeach;
		taxAmt1 := taxTotal.jMTRoundedTo($CM_ChargeQuantity.decimalPlaces);
		
		taxRate := invoice.getTaxRateForInvoice();
		total := invoice.getTotalAmount();
		work := total * taxRate * 0.01;
		taxAmt2 := work.jMTRoundedTo($CM_ChargeQuantity.decimalPlaces);
		if taxAmt1 &lt;&gt; taxAmt2 then
			write "invoice " &amp; invoice.sequenceNum.String
					&amp; " debtor " &amp; invoice.debtor.name &amp; " printed tax=" &amp; taxAmt1.String &amp; " exported tax=" &amp; taxAmt2.String
					&amp; " taxRate=" &amp; taxRate.String &amp; " codes.size=" &amp; codes.size.String;
			different := different + 1;
			if different &gt; 15 then
				break;
			endif;
		endif;
	endforeach;
	write count;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreTest26799A" id="dcd83983-f58c-41b6-9de1-1575afda9ceb">
        <source>jreTest26799A();
// compare the various CM_Invoice getTax and getTotal calculations
vars
	different,
	count	: Integer;
	amt, taxAmt1,
	taxAmt2,
	taxAmt3,
	total,
	totalAmount : Decimal[12, 2];
	invStatTotal,
	taxTotal	: Real;
	work,
	taxRate		: Real;
	idx		: Integer;
	codes	: StringArray;
	rates	: RealArray;
	amounts	: RealArray;
	taxMulti : Boolean;
	
	term	: CM_Terminal;
	bank	: CM_Bank;
	invoice	: CM_Invoice;
	invLineStatDict	: CM_InvoiceLineStatByNarManDict;
begin
	app.initialize;

	create codes transient;
	create rates transient;
	create amounts transient;

	term := "2351.35".asOid.CM_Terminal;
	taxMulti := term.getConfig(InvoiceMultiTaxRates).Boolean;
	bank := term.getBusinessUnit;
	create invLineStatDict transient;
	foreach invoice in bank.allInvoices do
		if not invoice.isPosted then
			continue;
		endif;
		if invoice.isVoided then
			continue;
		endif;
		count := count + 1;
		if invoice.isZeroRatedTax then
			continue;
		endif;
		invLineStatDict.clear;
		invStatTotal := invoice.getInvoiceStats(invLineStatDict, null, false, false);
		amt := invStatTotal;
		totalAmount := invoice.getTotalAmount;
		invoice.getTaxForInvoice(taxMulti, amt, codes, rates, amounts);
		taxTotal := 0;
		foreach idx in 1 to 4 do
			if idx &lt;= codes.size then
				taxTotal := taxTotal + (amounts[idx] * (rates[idx] / 100));
			endif;
		endforeach;
		taxAmt1 := taxTotal.jMTRoundedTo($CM_ChargeQuantity.decimalPlaces);
		
		taxRate := invoice.getTaxRateForInvoice();
		total := invoice.getTotalAmount();
		work := total * taxRate * 0.01;
		taxAmt2 := work.jMTRoundedTo($CM_ChargeQuantity.decimalPlaces);
		work := invoice.getTaxAmountForInvoice();
		taxAmt3 := work.jMTRoundedTo($CM_ChargeQuantity.decimalPlaces);
		if taxAmt1 &lt;&gt; taxAmt2 then
			write "invoice " &amp; invoice.sequenceNum.String
					&amp; " debtor " &amp; invoice.debtor.name &amp; " printed tax=" &amp; taxAmt1.String &amp; " exported tax=" &amp; taxAmt2.String
					&amp; " taxRate=" &amp; taxRate.String &amp; " codes.size=" &amp; codes.size.String;
			different := different + 1;
			if different &gt; 15 then
				break;
			endif;
		endif;
		if taxAmt1 &lt;&gt; taxAmt3 then
			write "invoice " &amp; invoice.sequenceNum.String
					&amp; " debtor " &amp; invoice.debtor.name &amp; " printed tax=" &amp; taxAmt1.String &amp; " getTaxAmountForInvoice=" &amp; taxAmt3.String;
			different := different + 1;
			if different &gt; 15 then
				break;
			endif;
		endif;
		if totalAmount &lt;&gt; amt then
			write "invoice " &amp; invoice.sequenceNum.String
					&amp; " debtor " &amp; invoice.debtor.name &amp; " getTotalAmount=" &amp; totalAmount.String &amp; " getInvoiceStats=" &amp; amt.String;
			different := different + 1;
			if different &gt; 15 then
				break;
			endif;
		endif;
	endforeach;
	write count;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreTest26799B" id="a3d4c69d-498b-4d92-817d-0f5ae20f44ef">
        <source>jreTest26799B();

vars
	rate	: Real;
	total	: Decimal[12,2];
	tax		: Decimal[4,2];
	tax1,
	tax2	: Decimal[12,2];
begin
	tax := 0.15;
	foreach total in 1 to 1000000 step 0.01 do
		tax1 := total * rate;
		tax := (tax1 / total) * 100;
		tax2 := total * tax;
		if tax1 &lt;&gt; tax2 then
			write total.String&amp;" tax1="&amp;tax1.String&amp;" tax2="&amp;tax2.String;
		endif;
	endforeach;
	write "end";
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreTest3" id="80ed9195-f9f6-416f-a9ea-e3e190554229">
        <source>jreTest3();
// service -&gt; charge, count open/pending/suspense invoice charge count
vars
	service	: CM_Service;
	charge	: CM_Charge;
	inv		: CM_Invoice;
	count	: Integer;
begin
	foreach service in CM_Service.instances do
		count := 0;
		foreach charge in service.charges do
			if charge.invoiceLine &lt;&gt; null then
				inv := charge.invoiceLine.invoice;
				if inv &lt;&gt; null then
					if inv.status = 0 or inv.status = 1 or inv.status = 4 then
						count := count + 1;
					endif;
				endif;
			endif;
		endforeach;
		write service.name &amp; " " &amp; count.String;
	endforeach;
end;
</source>
    </JadeMethod>
