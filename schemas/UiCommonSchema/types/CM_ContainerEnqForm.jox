    <JadeMethod name="cmbOperator_click" id="b3266d48-4e70-4f59-869c-e7ed09c3d745">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOperator_click(combobox: ComboBox input) updating;
// -------------------------------------------
// Created 13 January 2005 by cnwdvb1
// -------------------------------------------
// Changed On 	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/12/2016	cnwdap1		TFS 3030 SNO Empty Container Pool Management
// 30/01/2018	jlgdap1		TFS 36815 Operator Empty Pool Party on different tab
// 13/04/2018	jlgmd1		TFS 38086 POL Change Operator causing 1090
vars

	ti : CM_TrackedItem;
	operator : CM_Operator;								// TFS 3039
	poolParty : CM_MTPoolingParty;						// TFS 3039
	operTerm : CM_OperatorTerminal;						// TFS 3039
	table : CM_EntryTable;				// TFS 36815

begin

	ti := self.myCurrentObject.CM_TrackedItem;
	if ti = null then
		return;
	endif;
		
	if self.cmbOperator.getCurrentItemObject &lt;&gt; null then							// TFS 3039
		operator := self.cmbOperator.getCurrentItemObject.CM_Operator;				// TFS 3039
		operTerm := operator.allOperatorTerminals[self.myTerminal];					// TFS 3039
		if operTerm &lt;&gt; null then													// TFS 3039
			table := self.getTableForRow(ETRow_PoolParty);										// TFS 36815
			if table &lt;&gt; null then														// TFS 38086 (If the tab with PoolPary hasn't been opened yet, then this will be null)
				poolParty := operTerm.myPoolingParty;									// TFS 3039
				if poolParty &lt;&gt; null then												// TFS 3039
					//self.tblEdit1.setValueByName(ETRow_PoolParty, poolParty.code);	// TFS 3039	// TFS 36815
					table.setValueByName(ETRow_PoolParty, poolParty.code);				// TFS 3039	// TFS 36815
				else																	// TFS 3039
					//self.tblEdit1.setValueByName(ETRow_PoolParty, null);				// TFS 3039	// TFS 36815
					table.setValueByName(ETRow_PoolParty, null);						// TFS 3039	// TFS 36815
				endif;																	// TFS 3039
			endif;																		// TFS 38086
		endif;																		// TFS 3039
	endif;																			// TFS 3039

   
end;</source>
