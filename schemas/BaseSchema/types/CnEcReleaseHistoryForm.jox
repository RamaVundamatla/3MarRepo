        <source>btnClose_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		10 August 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
