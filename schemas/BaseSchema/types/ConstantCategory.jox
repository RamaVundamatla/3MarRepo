<Class name="ConstantCategory">
    <JadeMethod name="cnEcGetConstants" id="5796714a-73df-44a1-aa69-5cb2279ee86e">
        <source>cnEcGetConstants():ConstantNDict;
// --------------------------------------------------------------------------------
// Created:		22 April 2009 by cnwdad1
//
// Purpose:		Returns a reference to the receiver's collection of Constants.
//
// Parameters:	None
//
// Returns:		The a reference to receiver's collection of Constants.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.consts;
end;</source>
        <ReturnType type="ConstantNDict"/>
    </JadeMethod>
