        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="d038cd01-0df6-401e-b54a-54eb381e7106">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YAData): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/05/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars
	ptiDate, startDate, endDate : Date;
	ti : CM_TrackedItem;
	reserveCriteria : CM_ReleaseByTypeCriteria;
	criteria : CM_YACriteria;
	
begin
	ptiDate := null;
	startDate := null;
	endDate := null;
	
	ti := _cmifAutoPlan.getMyTrackedItem;
	if ti &lt;&gt; null then
		self.getCriteriaValueForTi(_cmifAutoPlan.getMyTrackedItem, ptiDate);
		
	else
		// We're probably for a release request
		reserveCriteria := _cmifAutoPlan.getReserveSelectionCriteria();
		if reserveCriteria &lt;&gt; null then
			foreach criteria in reserveCriteria.allCriteria where criteria.myYACriteriaType.isPTIDateRange do
				startDate := criteria.myYAData.CM_YADataDateRange.startDate;
				endDate := criteria.myYAData.CM_YADataDateRange.endDate;
			endforeach;
		endif;
	endif;
	
	if ptiDate &lt;&gt; null then
		return ptiDate &gt;= _yaData.CM_YADataDateRange.startDate and ptiDate &lt;= _yaData.CM_YADataDateRange.endDate;
		
	else
		// Comparing date ranges - so let's only match if the date range in the release request is entirely within the range on the yard allocation
		if startDate &gt;= _yaData.CM_YADataDateRange.startDate and startDate &lt;= _yaData.CM_YADataDateRange.endDate
		and endDate &gt;= _yaData.CM_YADataDateRange.startDate and endDate &lt;= _yaData.CM_YADataDateRange.endDate then
			return true;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YAData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPTIDateRange" id="5b3a16e9-89c9-4994-8911-7cdd8b236644">
        <source>isPTIDateRange(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/06/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range 
//
vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
