        <type name="CMIF_SAPAutoPreInvEstArray"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allPreInvoice" id="f4ce5ad1-fe40-4174-a3fb-7808ec5c4499">
        <memberTypeInverse/>
        <type name="CMIF_SAPAutoPreInvItemArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="currency" id="154cc35d-05b7-4675-8796-41f7dfed4d30">
        <type name="String"/>
        <text>if cashReceipt.getBank.isPelDomestic then
	value := "IDR";
else
	value := "USD";
endif;</text>
    </PrimAttribute>
