    <JadeMethod name="isValidForRT" id="1638c31a-8d82-4ea1-a498-258918a00887">
        <source>isValidForRT() : Boolean;
/*

Date		Who		Reason
19 May 2017	cnwer1	Initial creation TFS 995 

*/

vars

begin
	if not self.available then
		return false;
	endif;
	
	if self.isNotAvailableForEntry then
		return false;
	endif;
	
	if self.myRTDevice = null then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidOnQueueVoyageTIID" id="6710f9c2-9220-4d26-8a0f-fc15da428c97">
        <source>isValidOnQueueVoyageTIID(	_cargoID : String;				
							_allValidTIs : CM_TISet input): CM_TrackedItem;
/*
Date		Who		Reason
04 June 2010	cnwer1	Initial creation
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
05/07/2017 cnwer1		VMT changes tfs 5345 refactored to remove redundant params
*/

vars
	masterQ	:	CM_MasterQueue;
	ti	:	CM_TrackedItem;
	voyage	:	CM_Voyage;
	aQ	:	CM_RadioTelemetryQueue;
	allTIs	: CM_TISet;
	job 	: CM_Job;
begin
	if self.myTerminal.radioTelemetry = null then
		return null;
	endif;
	masterQ := self.myTerminal.radioTelemetry.masterQueue;
	if masterQ = null then
		return null;
	endif;
	//------------------
	//This machine is in a Queue, if its a voyage queue, use that first!
	//------------------	
	aQ := self.getQueue;
	if aQ.isKindOf(CM_VoyageQueue) then
		voyage := aQ.CM_VoyageQueue.myVoyage;
	elseif aQ.isKindOf(CM_VoyageCraneQueue) then
		voyage := aQ.CM_VoyageCraneQueue.myVoyage;
	endif;
	
	if voyage = null then
		return null;
	endif;

	//---------------------
	//Search for the TI. (on each voyage)
	//---------------------
	
	create allTIs transient;
	if voyage.searchForOnShipOrQTI(_cargoID.toUpper, allTIs, true) then	// 22 Dec 2010	NDL	Par 26471
				
		foreach ti in allTIs do
			job := ti.getFirstAvailableDischargeJob();
			if job &lt;&gt; null then
				if not _allValidTIs.includes(ti) then
					_allValidTIs.add(ti);	
				endif;
//	PAR 35091			elseif ti.myPrimaryActualLocation.isKindOf(CM_ShipBlockController) then // PAR 34534
			elseif ti.myPrimaryActualLocation.isShipBlockStack() //	PAR 35091
			or ti.myPrimaryActualLocation.isGeneralCargoController() //	PAR 35703
			 or ti.myPrimaryActualLocation.isWorkPointLaneController() //	PAR 35091
			or ti.myPrimaryActualLocation.isCraneLaneController() then //	PAR 35091
				if not _allValidTIs.includes(ti) then
					_allValidTIs.add(ti);	
				endif;
			endif;
		endforeach;
		ti:=null;
		
		if _allValidTIs.size  = 1 then		//PAR 3730 AJA 25/9/00: Warn if more than one item matches search key		
			ti := _allValidTIs.first;		
		endif;
	endif;
	
	return ti;

epilog
	//Transient array is created in mq::getVoyageQueueVoyages
	delete allTIs;
end;</source>
        <Parameter name="_cargoID" type="String"/>
        <Parameter name="_allValidTIs" type="CM_TISet" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="isWeighBridgeWeighable" id="40a2c4df-4df5-4375-bfb5-9d66ef36e7c4">
        <source>isWeighBridgeWeighable(_objs: ObjectArray input; _errMsg : String output): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33268
08 Jan 2018	NDL	TFS 36437
*/

vars

begin
	
	if self.myTerminal= null or self.myTerminal.allWeighBridges.isEmpty then
		return false;
	endif;
	
	if not self.myMachineController.allTrackedItems.size &lt; 2 then
		return false;
	endif;
	
	if _objs &lt;&gt; null then
		_objs.addExclusive( self );
		if self.myMachineController.allTrackedItems.size = 1 then
			_objs.addExclusive( self.myMachineController.allTrackedItems.first );
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_objs" type="ObjectArray" usage="input"/>
        <Parameter name="_errMsg" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jrwGetGrossRunningHours" id="57caf3c2-bf82-495d-97a6-b19ea5d021bb">
        <source>jrwGetGrossRunningHours(_date :Date; _shift :String; _userId :String):Integer;
// ---------------------------------------------------------------------------
// Created:     03 November 2010 by cnwcs5
// Purpose:     Report Writer Method
// Parameters:  None
// Returns:     Gross Running hours in seconds for a date or shift on a date
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result			:Integer;
	startTS, endTS	:TimeStamp;
	time			:Time;
	shift			:CM_Shift;
	coll			:CM_ShiftStartDateCodeDict;
	match			:Boolean;
begin
	startTS := null;
	endTS 	:= null;
	startTS.setDate (_date);
	startTS.setTime ('00:00'.Time);
	
	endTS.setDate (_date);
	time.setTime (23, 59, 59, 999);
	endTS.setTime (time);
	// looking for logon/logoff history items that span the date
	if _shift &lt;&gt; null then
		// limit to shift start/end time
		create coll transient;
		
		self.myTerminal.getShiftsFromRange (coll, startTS, endTS);
		
		foreach shift in coll do
			if shift.code = _shift then
				// can only be one for same code for day
				startTS := shift.startDateTime;
				endTS 	:= shift.endDateTime;
				match	:= true;
				break;
			endif;
		endforeach;
		if not match then
			return 0;
		endif;
	endif;

	result := self.getGrossRunningHours (startTS, endTS, _userId);
	
	return result;
epilog
	if coll &lt;&gt; null then
		coll.purge;
		delete coll;
	endif;
end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_shift" type="String"/>
        <Parameter name="_userId" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="machineStatus" id="53d63ceb-2339-4efd-9905-0a422b34c11c">
        <methodInvocation>mapping</methodInvocation>
        <source>machineStatus(set: Boolean; value: Integer io) mapping;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

begin
	value := 0;
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if status = null then
		return;
	endif;
	
	if self.loggedOn then
		value := status.status;
	else
		if self.isIMV and self.myTerminal.getConfig(AllowIMVWorkRTLoggedOff).Boolean then //cnwrd1 for par 31382
			value := status.status;
		else
			value := STATUS_OFFLINE;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="machineStatusString" id="0ac1f6d0-a5b2-4386-8496-eb4f7b1e856d">
        <methodInvocation>mapping</methodInvocation>
        <source>machineStatusString(set: Boolean; value: String io) mapping;
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.machineStatus = STATUS_IDLE then
		value := "Idle";
	elseif self.machineStatus = STATUS_ASSIGNED then
		value := "Assigned";
	elseif self.machineStatus = STATUS_OFFLINE then
		value := "Offline";
	elseif self.machineStatus = STATUS_WORKING then
		value := "Working";
	elseif self.machineStatus = STATUS_RESTORE then
		value := "Restore?";
	else
		value := "Unknown!";
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
