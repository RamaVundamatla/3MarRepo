<CollClass name="CM_KPICargoByTermCargoDTDict" id="f0781c43-7440-4121-9a93-905914f746d3">
    <loadFactor>66</loadFactor>
    <memberType name="CM_KPICargoEntity"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="statistic"/>
    <MemberKey>
        <property name="CM_KPI::myTerminal"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_KPICargoEntity::myCargoType"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_KPI::dateTime"/>
    </MemberKey>
    <JadeMethod name="getAllTIsForCargoMonth" id="7d92cb49-9add-4e94-898b-ca9eb79557ce">
        <source>getAllTIsForCargoMonth(_terminal : CM_Terminal;_cargoType : CM_CargoType;_month : TimeStamp; _contLength : Integer; _tiSet : ObjectArray input);
/*

Date		Who		Reason
10 Oct 2010	cnwas3	par 25163
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars	
	iter  					: Iterator;
	cargoEntity 			: CM_KPICargoEntity;	
	idx 					: Integer;
	numItems,numQty 		: Integer;
	numVolume, numWeight 	: Decimal[23,5];
	now,month 				: TimeStamp;
begin	
	if _tiSet = null then
		return;
	endif;
	
	now := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	month := _month.cnEcGetBeginningOfMonth();
	
	iter := _cargoType.allKPICargo.createIterator();
	cargoEntity := _cargoType.allKPICargo.getAtKeyGeq(_terminal,month);
	if cargoEntity = null or _terminal &lt;&gt; cargoEntity.myTerminal or _cargoType &lt;&gt; cargoEntity.myCargoType then
		return;
	endif;
	iter.startAtObject(cargoEntity);
	while iter.next(cargoEntity) and 
		(cargoEntity.dateTime &lt;= now and cargoEntity.dateTime.date.month() = month.date.month()) do
				cargoEntity.getAllTrackedItems(_contLength,_tiSet);	
	endwhile;

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_month" type="TimeStamp"/>
        <Parameter name="_contLength" type="Integer"/>
        <Parameter name="_tiSet" type="ObjectArray" usage="input"/>
    </JadeMethod>
</CollClass>
