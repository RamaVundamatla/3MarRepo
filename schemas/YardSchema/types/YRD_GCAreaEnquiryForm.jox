	if _hide then
		self.frmToolbar.visible := false;
	else

		// need to do this to get toolbars correct
		self.frmToolbar.alignContainer := Frame.AlignContainer_Top; 

		self.frmToolbar.visible := true;
	endif;

	self.doResize();


end;</source>
