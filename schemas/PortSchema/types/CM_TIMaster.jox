        <source>getStopsAuditText() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2008	cnwrd1	Initial creation

*/

vars

	stop	: CM_StopsTable;
	txt				: String;
begin
	foreach stop in self.allStopsNew do
		txt := txt &amp; stop.getAuditText() &amp; ', ';
	endforeach;

