    <JadeMethod name="deleteTask" id="6a8efae8-19c2-4ad8-b8c3-8102ff740539">
        <source>deleteTask(_entry : CM_RTQueueEntry);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2011	cnwdw1	Initial creation
*/
vars
	lMoveControl	: CMIF_MoveController;
	wleArray,
	wlesWithWarnings	: CM_WLEArray;
begin

	if _entry.myWorkListEntry.myTrackedItem &lt;&gt; null then
		create lMoveControl transient;
		if _entry.isPlanOnPickupNoTarget then 
			lMoveControl.setMoveMode(QUEUE_PLAN_ON_PICKUP);
		else
			lMoveControl.setMoveMode(QUEUE_MODE);
		endif;
		lMoveControl.setMyTrackedItem(_entry.myWorkListEntry.myTrackedItem);
		lMoveControl.setMyWorkListEntry(_entry.myWorkListEntry);
		lMoveControl.isForcedMove := true;
		app.myTrxUA.trxUpdateMoveTIUndo(lMoveControl, app.myPassport);
	else
		create wleArray transient;
		create wlesWithWarnings transient;
		wleArray.add(_entry.myWorkListEntry);
		app.myTrxUA.trxUpdateWLEsUnqueue(wleArray, wlesWithWarnings, app.myPassport);
	endif;
	
	self.assertNoTrxErrorsOrWarnings();
			
epilog
	delete lMoveControl;
	delete wleArray;
	delete wlesWithWarnings;
end;</source>
        <Parameter name="_entry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="deleteTempRange" id="4853c77a-a54e-48e8-bdc8-754c9f986c7e">
        <source>deleteTempRange(_tempRange : Any);

/*

Purpose:		

Date			Who		Reason
19/06/2015	cnwmh5	Initial creation

*/

vars

	tempRange					: CM_TempRange;

begin

	if _tempRange.isKindOf(Real) then
		tempRange := app.myRoot.allTempRanges[_tempRange.Real];
	elseif _tempRange.isKindOf(CM_TempRange) then
		tempRange := _tempRange.CM_TempRange;
	endif;
	
	if tempRange = null then
		return;
	endif;
	
	app.myTrxDA.trxDeleteTempRange(tempRange, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

end;</source>
        <Parameter name="_tempRange" type="Any"/>
    </JadeMethod>
    <JadeMethod name="deleteTerminalArea" id="4bd6c58c-3316-4d5a-ac1b-e3bea17aebf3">
        <source>deleteTerminalArea(name: String);
//17 July 2008	cnwdw1	
//
vars
	ta : CM_TerminalArea;
	location: CM_LocationsController;
	ti: CM_TrackedItem;
	index: Integer;
	tis, tisToDelete: CM_TISet;
	queue: CM_RadioTelemetryQueue;
	vehicle   : CM_VehicleMachine;
	interchangeArea		: CM_InterchangeArea;
	gridController		: CM_Object;
	labourRestriction	: CM_LabourRestriction;				// 16/08/2011 cnwmh5
	locationRestriction	: CM_LocationRestriction;			// 16/08/2011 cnwmh5
	subBlockStack		: CM_SubBlockStack;					// 07/02/2014 cnwmh5
	wagon: CM_Wagon;
	rail: CM_Rail;
	track: CM_RailLine;
	obj					: Object;
	gate				: CM_Gate;
	wagonSet : CM_WagonSet;
	futureMoveArray : CM_FutureMoveArray;
	futureMoveQueuedArray : CM_FutureMoveArray;
	allLCs : CM_LCSet;
	allObjs : ObjectArray;
	pxyTermArea : CM_TerminalArea ; //11/07/2014 cnwdb2
	
	
	yardMoveRequest : CM_YardMoveRequest ; 
	count : Integer ; 
	
	invalid : Boolean;
	edition : Integer;
	
	
begin

	
	ta := getTerminal.allTerminalAreas[name.toUpper];
	if ta &lt;&gt; null then
		create tisToDelete transient;
		create allLCs transient;
		create allObjs transient;
		create tis transient;
		ta.getAllLocationsControllers(allObjs);
		allObjs.copy(allLCs);
		
		//cnwdb2 21/04/2015 error with invalid objects on CM_YardMoveRequest.
		beginTransaction;
			foreach yardMoveRequest in CM_YardMoveRequest.instances do	
				if yardMoveRequest.myTargetTA &lt;&gt; null and global.isValidObject(yardMoveRequest.myTargetTA) then
					if yardMoveRequest.myTargetTA.id = name.toUpper then
						yardMoveRequest.setPropertyValue("myTargetTA", null);
						yardMoveRequest.setPropertyValue("mySourceLocation", null);
						yardMoveRequest.setPropertyValue("myTargetLocation", null);
					endif ;
				endif ; 			
			endforeach ;
		commitTransaction;
		
// AKB		foreach location in ta.allLocationsControllers do
		on Exception do app.handleDeletedObject( exception, ti, invalid );
		foreach location in allLCs do
			tis.clear();
			foreach ti in location.allTrackedItems do
				if not tisToDelete.includes(ti) then
					tisToDelete.add(ti);
				endif;
			endforeach;
			foreach index in 1 to location.allQueuedFutureMoves.size do
				ti := location.allQueuedFutureMoves[index].CM_FutureMoveQueued.myTrackedItem ;
				if ti = null then
					if futureMoveQueuedArray = null then
						create futureMoveQueuedArray transient;
					endif;
					futureMoveQueuedArray.add( location.allQueuedFutureMoves[index].CM_FutureMoveQueued);
				elseif not tis.includes(ti) then
					edition := ti.edition;
					if invalid then
						invalid := false;
						if futureMoveQueuedArray = null then
							create futureMoveQueuedArray transient;
						endif;
						futureMoveQueuedArray.add( location.allQueuedFutureMoves[index].CM_FutureMoveQueued);
						continue;
					endif;
					tis.add(location.allQueuedFutureMoves[index].CM_FutureMoveQueued.myTrackedItem);
				endif;
			endforeach;
			if futureMoveQueuedArray &lt;&gt; null then
				beginTransaction;
				futureMoveQueuedArray.purge;
				commitTransaction;
				delete futureMoveQueuedArray;
				futureMoveQueuedArray := null;
			endif;
			foreach ti in tis do
				unqueueTI(ti);
			endforeach;
			tis.clear;
			foreach index in 1 to location.allPlannedFutureMoves.size do
				ti := location.allPlannedFutureMoves[index].CM_FutureMovePlanned.myTrackedItem;
				if ti &lt;&gt; null then
					tis.add(ti);
				else
					if futureMoveArray = null then
						create futureMoveArray transient;
					endif;
					futureMoveArray.add( location.allPlannedFutureMoves[index].CM_FutureMovePlanned );
				endif;
			endforeach;
			if futureMoveArray &lt;&gt; null then
				beginTransaction;
				futureMoveArray.purge;
				commitTransaction;
				delete futureMoveArray;
				futureMoveArray := null;
			endif;
			foreach ti in tis do
				unplanTI(ti);
			endforeach;
			if location.isKindOf(CM_YardController) then			// 19/07/2011 cnwmh5 
				foreach vehicle in location.CM_YardController.allVehicleMachines do
					self.deleteVehicle(vehicle);
				endforeach;
			endif;
			if location.isKindOf(CM_RTGController) then				// 03/08/2011 cnwmh5
				foreach interchangeArea in location.CM_RTGController.myTerminalArea.allAssociatedInterchangeAreas do
					foreach gridController in interchangeArea.allGridControllersByName do
						if gridController.isKindOf(CM_LaneController) then
							foreach vehicle in gridController.CM_LaneController.allVehicleMachines do
								self.deleteVehicle(vehicle);
							endforeach;
						endif;
					endforeach;					
				endforeach;
			endif;
		endforeach;
		if ta.swapStack &lt;&gt; null then
			foreach location in ta.swapStack.allLocationsControllers do
				foreach ti in location.allTrackedItems do
					if not tisToDelete.includes(ti) then
						tisToDelete.add(ti);
					endif;
				endforeach;
			endforeach;
		endif;
		
		if ta.isKindOf(CM_Rail) then
			rail := ta.CM_Rail;
			foreach track in rail.allRailLines do
			    app.repairCollection(track.allWagonsById); 
				foreach wagon in track.allWagonsById do
					self.deleteWagonAndAssociatedObjs(wagon);
				endforeach;
				app.repairCollection(track.allWagons);
			endforeach;
		endif;
		
		// epr allowedMachines is inversed collection no need to clear before deleting - was causing unit test failures further down
		/*if ta.allowedMachines.size &gt; 0 then
			pxyTermArea := app.createUpdateProxy(ta).CM_TerminalArea; 
			pxyTermArea.allowedMachines.clear()  ; 
			app.myTrxUA.trxUpdateTerminalArea(pxyTermArea, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endif; 
		*/
		foreach ti in tisToDelete do
			deleteTrackedItem(ti, false); // AKB added false
		endforeach;
		foreach queue in ta.allSubRTQueues do
			self.deleteQueue(queue);
		endforeach;
		foreach labourRestriction in ta.allRestrictionsLabour do			// 16/08/2011 cnwmh5
			self.deleteLabourRestriction(labourRestriction);
		endforeach;
		foreach locationRestriction in ta.allRestrictionsLocation do		// 16/08/2011 cnwmh5
			self.deleteLocationRestriction(locationRestriction);
		endforeach;
		if ta.isKindOf(CM_InterchangeArea) then								// 14/09/2012 cnwmh5
			beginTransaction;
			if ta.CM_InterchangeArea.myDefaultOutGate &lt;&gt; null then
				ta.CM_InterchangeArea.setPropertyValue("myDefaultOutGate", null);
			endif;
			foreach gate in ta.CM_InterchangeArea.allGateDefaults do
				gate.setPropertyValue("myDefaultInterchangeArea", null);
			endforeach;
			commitTransaction;
		endif;
		
		if ta.isKindOf(CM_GridArea) then									// 07/02/2014 cnwmh5
			foreach subBlockStack in ta.CM_GridArea.allSubBlockStacks do
				self.deleteSubBlockStack(subBlockStack);
			endforeach;
		endif;	
		
		//06 May 2021	NDL	TFS 50906
		if not ta.allLocationActivity.isEmpty then
			beginTransaction;
			ta.allLocationActivity.purge();
			commitTransaction;
		endif;
		
		self.deleteTATasks(ta);
		self.deleteAllMachineRulesForTA(ta);
		self.deleteTAFromSatView(ta);
		self.ignoreTrxWarnings(true);
		app.myTrxDA.trxDeleteTerminalArea(ta, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
epilog
	delete tisToDelete;
	delete tis;
	delete wagonSet;
	delete allLCs;
	delete allObjs;
	delete pxyTermArea;
	delete futureMoveArray;
	delete futureMoveQueuedArray;
end;</source>
        <Parameter name="name" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteTerminalAreaPhoto" id="dda7d137-2de8-4e59-a602-fafef1d451a8">
        <source>deleteTerminalAreaPhoto(_ta:CM_TerminalArea; _loadTime : TimeStamp);
/*
Purpose - 	
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61456
*/

vars
	photo : CM_Photo;
	iter : Iterator;
	ts : TimeStamp;
begin
	iter := _ta.allAttachments.createIterator();
	_ta.allAttachments.startKeyGeq(CM_Attachment.Type_Photo, iter);
	while iter.next(photo) do
		if photo.type &lt;&gt; CM_Attachment.Type_Photo then
			break;
		endif;
		
		ts := photo.getLoadTimeStamp();	
		if ts = _loadTime then
			app.myTrxDA.trxDeleteCargoPhoto(photo, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_loadTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="deleteTerminalAreaStorageGroup" id="83241eda-6314-4255-91d4-72a82669eb3f">
        <source>deleteTerminalAreaStorageGroup(_code: String);
//
vars
	termAreaStorageGroup	: CM_TerminalAreaStorageGroup;

begin

	termAreaStorageGroup := self.getTerminal().allTerminalAreaStorageGroups[_code];
	if termAreaStorageGroup = null then
		return;
	endif;
	
 	app.myTrxDA.trxDeleteTerminalAreaStorageGp(termAreaStorageGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteTiStopsExcept" id="5a17100c-4ed8-48e7-b514-75c2b0c05150">
        <source>deleteTiStopsExcept( _ti : CM_TrackedItem input; _keepThese : CM_StopsTableByIdDict; _clearOldValues : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2015	cnwndl1	Initial creation	Par 36543

*/

vars
	
	garbageStartValue : Boolean;
	tiStops : CM_StopsByIdDict;
	deleteStops : CM_StopsTableSet;
	stop : CM_Stops;
	stopsTable: CM_StopsTable;
	tiSet: CM_TISet;
	info : String;

begin

	garbageStartValue := app.isGarbageCollectionProcess;

	create tiSet transient;
	create deleteStops transient;
	tiSet.add(_ti);

	
	tiStops := _ti.getAllStops();
	foreach stop in tiStops do
		stopsTable := stop.myStopsTable;
		if not _keepThese.includes(stopsTable) then
			deleteStops.add( stopsTable );
		endif;
	endforeach;
	
	if not deleteStops.isEmpty then
		app.isGarbageCollectionProcess := true;
		foreach stopsTable in deleteStops do
			info := null;	//allowed if app.isGarbageCollectionProcess = true;
			app.myTrxDA.trxDeleteStopForTIsBulk(tiSet, stopsTable, info, app.myPassport);
			self.assertTrueMsg( app.myPassport.noErrors, "Failed cleaning up stop '" &amp; stopsTable.heading &amp; "' - " &amp; app.myPassport.getErrorsAndWarningsAsString);
		endforeach;
	endif;
	

epilog

	app.isGarbageCollectionProcess := garbageStartValue;
	delete tiSet;
	delete deleteStops;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_keepThese" type="CM_StopsTableByIdDict"/>
        <Parameter name="_clearOldValues" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteTidalClass" id="9ef49535-2b74-4cf4-a8c9-fcb2bfc14342">
        <source>deleteTidalClass(_tidalClassId : String);

/*

Purpose:		Delete a Tidal Class	

Date			Who		Reason
21/12/2011		cnwmh5	Initial creation

*/

vars

	tidalClass			: HMS_TidalClass;
	
begin

	tidalClass := app.myRoot.allTidalClasses[_tidalClassId];
	if tidalClass &lt;&gt; null then
		//app.myTrxDA.trxDeleteTidalClass(tidalClass, app.myPassport);
		//self.assertNoTrxErrorsOrWarnings();
		// Note Trx doesn't actually do anything
		beginTransaction;
		delete tidalClass;
		commitTransaction;
	endif;

epilog

end;</source>
        <Parameter name="_tidalClassId" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteTidalModel" id="33a15be9-1840-4554-a1dc-7339416c9021">
        <source>deleteTidalModel(_tidalModelId : String);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
22 December 2011	cnwmh5	Initial creation

