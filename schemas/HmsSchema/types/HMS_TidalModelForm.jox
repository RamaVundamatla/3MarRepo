    <JadeMethod name="buildComboRegion" id="0a8124a7-b67e-4da9-85d5-2dedc4d2f820">
        <updating/>
        <source>buildComboRegion()updating, protected;

vars
	tmpHarbour 	: HMS_Harbour;
	region,
	regionSaved	: HMS_HarbourRegion;
	index		: Integer;
	cmb			: ComboBox;
begin

	cmb := self.cmbRegion;
	
	//Par17906 Feb 2009. When saving Harbour (in Admin), an event comes here. So we are loosing current region.
	regionSaved := cmb.listObject.HMS_HarbourRegion;	//Moreover, when self.myWorkingMovement &lt;&gt; null, it becomes invalid.

	cmb.clear();
	cmb.sorted := true;
	// populate region combobox
	tmpHarbour := self.myTerminal.myHarbour;
//	if tmpHarbour &lt;&gt; null then
//		foreach region in tmpHarbour.allRegions do
//			cmb.itemObject[cmb.addItem(region.description)] := region;
//		endforeach;
//	endif;
	foreach region in app.myRoot.allHMSHarbourRegions do
		if region.getHarbourReal() = null or region.getHarbourReal() = tmpHarbour then
			if region.myHeightCheckpoint &lt;&gt; null or region.myCurrentCheckpoint &lt;&gt; null  then
				cmb.itemObject[cmb.addItem(region.description)] := region;
			endif;
		endif;
	endforeach; 

	if regionSaved &lt;&gt; null and self.myWorkingMovement = null then	//Par17906 Feb 2009. Saving region for the screen from JMT Navigator - when there is no movement.
		cmb.listObject := regionSaved;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
