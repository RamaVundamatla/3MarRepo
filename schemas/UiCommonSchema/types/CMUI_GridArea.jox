    <JadeMethod name="getFirstLastColumnsForPoints" id="9623764a-9404-409a-8137-091032f63f61">
        <source>getFirstLastColumnsForPoints(_rowLabel : String input; _xPoint, _yPoint : Real input; _cellStartColumn, _cellEndColumn : Object output);

/*

Purpose:		Get the 1st and last column that falls full within the points		

Date			Who		Reason
07/11/2012		cnwmh5	Initial creation

*/

vars

	gridRow				: CMUI_GridRow;
	gridPoint			: CMUI_GridPoint;

	iter				: Iterator;

begin

	// get the row based on the label
	foreach gridRow in self.allGridRows do
		if gridRow.label = _rowLabel then
			break;
		endif;	
	endforeach;
	
	if gridRow = null then
		return;
	endif;
	
	iter := gridRow.allGridPointsByColumn.createIterator;
	while iter.next(gridPoint) do
		if _cellStartColumn = null and gridPoint.x1 &gt;= _xPoint then
			_cellStartColumn := gridPoint.myGridColumn;
		endif;
		if gridPoint.x2 &lt;= _yPoint then
			_cellEndColumn := gridPoint.myGridColumn;
		endif; 
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_rowLabel" type="String" usage="input"/>
        <Parameter name="_xPoint" type="Real" usage="input"/>
        <Parameter name="_yPoint" type="Real" usage="input"/>
        <Parameter name="_cellStartColumn" type="Object" usage="output"/>
        <Parameter name="_cellEndColumn" type="Object" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getGridColumnByLabel" id="0678a745-18e4-4a8b-8860-3c562ebcc48d">
        <source>getGridColumnByLabel(_label : String) : CMUI_GridColumn;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aColumn : CMUI_GridColumn;
begin
	foreach aColumn in  self.allGridColumns do
		if aColumn.label = _label then
			return aColumn;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="_label" type="String"/>
        <ReturnType type="CMUI_GridColumn"/>
    </JadeMethod>
