        <source>copyFile(pSourcePath:String; pTargetPath:String; pNodeOptions:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 July 2002 by cnwdad1
//
// Purpose:		Copies the requested file into the specified path.
//
//				*********************************************************************
//				* You must call the setUnixFlags method before calling this method. *
//				*********************************************************************
//
// Parameters:	pSourcePath - The pathname of the source file to be copied.
//				pTargetPath - The pathname of the file's destination.
//				pNodeOptions - A combination of the source and target nodes, i.e.
//					Client, AppServer or DB Server.  Refer to the class constants
//					on this interface class.  Note that the source and target
//					can be the same node.  For example:
//
//					a) NODE_SOURCE_CLIENT + NODE_TARGET_DBSERVER = the file source
//						node is the workstation client, and the file target node
//						is the Database Server machine.
//
//					b) NODE_SOURCE_CLIENT + NODE_TARGET_CLIENT = the file source
//						node is the workstation client, and the file target node
//						is the workstation client (i.e. the source and target are
//						the same node).
//
// Returns:		True if the operation succeeded, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsgWithParams(method.name, pSourcePath, pTargetPath, pNodeOptions).Boolean;
end;</source>
        <Parameter name="pSourcePath" type="String"/>
