    <JadeMethod name="getVoyageTaxExempt" id="be18e4e4-cd84-4add-af07-d29c6780a25a">
        <source>getVoyageTaxExempt(_term : CM_Terminal; _voyage : CM_Voyage) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2018	jlgndl1	Initial creation	TFS 37562 - Default behaviour when no hook code found,
							called by sendMsg from CM_HookAgent::compileAndRunHookLinkPrivate, when no hook code defined for terminal.

*/

vars

	reference : Integer;
	
begin
	
