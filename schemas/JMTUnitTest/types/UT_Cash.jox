    <JadeMethod name="cashTestMultipleReceipts2b" id="4c65bbad-68cc-427d-9c56-0366b328a21f">
        <updating/>
        <source>cashTestMultipleReceipts2b(_id1 : String; _drTerm1 : CM_DebtorTerminal input; _type : Integer) updating, protected;
/*

Purpose:		

Parameters:			

Return Value:		


Date		Who		Reason
22 Feb 2020 cnwma1 Bug 50843: GUQ - Error 1090 in Cash Collection while trying to save

*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	expected	: Integer;
	count		: Integer;
	invoiceEveryReceipt	: Boolean;
	
	cashReceipt1 : CM_CashReceipt;
	cashReceipt2 : CM_CashReceipt;
	cashReceipt3	: CM_CashReceipt;
	cashPayment	: CM_CashPayment;
	profDetail	: CM_ProformaDetails;
	paymentMeth : CM_PaymentMethod;

	status	: Integer;
	isZeroRated : Boolean;
	termsOfTrade : CM_InvoiceTermsOfTrade;
	purchaseOrderNumber : String;
	narration : String;
	invAssistant	: Object;

	onsiteTi1	: CM_TrackedItem;
	vvrOut	: CM_VehicleVisitRecord;
	carrier	: CM_Carrier;
	truckOut	: CM_Vehicle;

	nowDate,
	baseDate,
	endDate : Date;
	profTotal,
	lineTotal,
	cashToPay,
	cashTotal	: Decimal [23,6];
	postedInvoice,
	cashInvoice	: CM_Invoice;
	invLine : CM_InvoiceLine;
	
	debtorType	: CM_DebtorType;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	obj				: Object;
	allAgents		: ObjectArray;
	agent,
	agent1,
	agent2	: CM_CashInvoiceProformaAgent;
	type : CM_TerminalAreaType;
	blockStack1,
	blockStack2	: CM_BlockStack;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;
	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
begin
	msg := method.name;
	self.setTerminalConfig(CashInvoiceEveryReceipt, false);
	invoiceEveryReceipt := false;

	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");
	blockStack2 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS2").CM_BlockStack;
	self.assertTrueMsg(blockStack2 &lt;&gt; null, "Block Stack UT_BS2 not found...");
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	
	cargoId := _id1;
	onsiteTi1 := self.createContainerFromVoyage(self.myVoyage, cargoId, blockStack1, "22G1", operator, "GENL", "NZPOE", "NZPOE", 2200, 4500).CM_Container;
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, msg &amp; " On Site Cargo 1 '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(onsiteTi1);
	// back-date the transactions to get storage
	baseDate := nowDate - 20;
	self.setTransactionDate(onsiteTi1, baseDate);
	
	// move the container to get some current charges
	self.move(onsiteTi1, blockStack2);
	self.move(onsiteTi1, blockStack1);
	self.move(onsiteTi1, blockStack2);
	
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	// first payment effective 4 days ago
	now.setDate(nowDate - 4);
	agent1 := self.createProformaAgent(now, onsiteTi1);
	allAgents.add(agent1);
	// agent 1 invoice lines 3 times $20 for move all to debtor UT_Cash1,
	//	3 pro forma lines  Rel road $20, Storage x5 $100 and Storage x11 $440
	//  total to pay 620
	
	cashToPay := agent1.getTotal();		// 620
	
	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;
	
	// first receipt is for all charges

	cashReceipt1 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, msg &amp; " Cash Receipt 1 for on site cargo not created...");

	
	// second receipt is for an extra 4 days storage
	//  Create new agent
	delete agent1;
	allAgents.clear();
	now.setDate(nowDate);
	agent1 := self.createProformaAgent(now, onsiteTi1);
	allAgents.add(agent1);

	cashToPay := agent1.getTotal();		// 160 for the extra storage

	cashReceipt2 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	self.assertTrueMsg(cashReceipt2 &lt;&gt; null, msg &amp; " Cash Receipt 2 for on site cargo not created...");
	
	// check the receipts before releasing
	count := 0;
	cashTotal := 0;
	foreach cashPayment in cashReceipt1.allCashPayments do
		count := count + 1;
		cashTotal := cashTotal + cashPayment.cashValue;
	endforeach;
	self.assertEqualMsg(count, 6, "receipt 1 cash payments");
	self.assertEqualMsg(cashTotal, 620.Decimal, "Receipt 1 cash payment total");
	count := 0;
	lineTotal := 0;
	foreach invLine in cashReceipt1.allInvoiceLines do
		count := count + 1;
		lineTotal := lineTotal + invLine.lineTotal;
	endforeach;
	self.assertEqualMsg(count, 3, "receipt 1 invoice lines");
	self.assertEqualMsg(lineTotal, 60.Decimal, "Receipt 1 invoice line total");
	count := 0;
	profTotal := 0;
	foreach profDetail in cashReceipt1.allProformaDetails do
		count := count + 1;
		profTotal := profTotal + profDetail.lineTotal;
	endforeach;
	self.assertEqualMsg(count, 3, "receipt 1 pro forma details");
	self.assertEqualMsg(profTotal, 560.Decimal, "Receipt 1 proforma detail total");

	count := 0;
	cashTotal := 0;
	foreach cashPayment in cashReceipt2.allCashPayments do
		count := count + 1;
		cashTotal := cashTotal + cashPayment.cashValue;
	endforeach;
	self.assertEqualMsg(count, 1, "receipt 2 cash payments");
	self.assertEqualMsg(cashTotal, 160.Decimal, "Receipt 2 cash payment total");
	count := 0;
	lineTotal := 0;
	foreach invLine in cashReceipt2.allInvoiceLines do
		count := count + 1;
		lineTotal := lineTotal + invLine.lineTotal;
	endforeach;
// TFS 45953	self.assertEqualMsg(count, 3, "receipt 2 invoice lines");
// TFS 45953	self.assertEqualMsg(lineTotal, 60.Decimal, "Receipt 2 invoice line total");
	self.assertEqualMsg(count, 0, "receipt 2 invoice lines");// TFS 45953 there should be no invoice lines. the invoice lines are on the first cash receipt
	self.assertEqualMsg(lineTotal, 0.Decimal, "Receipt 2 invoice line total");// TFS 45953
	count := 0;
	profTotal := 0;
	foreach profDetail in cashReceipt2.allProformaDetails do
		count := count + 1;
		profTotal := profTotal + profDetail.lineTotal;
	endforeach;
// TFS 45953		self.assertEqualMsg(count, 3, "receipt 2 pro forma details");
// TFS 45953		self.assertEqualMsg(profTotal, 160.Decimal, "Receipt 2 proforma detail total");
	self.assertEqualMsg(count, 1, "receipt 2 pro forma details");// TFS 45953 there should only 1 proforma, it matches the single cash payment
	self.assertEqualMsg(profTotal, 160.Decimal, "Receipt 2 proforma detail total"); // TFS 45953	

	// make this debtor no longer cash-only
	beginTransaction;
	_drTerm1.setCashOnly(false);
	commitTransaction;

	
	// gate container out
	// create carrier and truck
	self.deleteVehicle(VehicleNumOut);
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, self.myDebtor1);
	self.assertNotNull(carrier);
	truckOut := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truckOut &lt;&gt; null, "Truck not created...");
	// Clear all the stops
	self.deleteStops(onsiteTi1);

	vvrOut := self.createVVR( truckOut, onsiteTi1 );
	self.assertTrueMsg(vvrOut &lt;&gt; null, msg &amp; " Vehicle Visit Record not created...");
	
	self.gateInTruck( vvrOut, false );
	
	self.workTruck( vvrOut, 2 );

	self.gateOutTruck( vvrOut, false ); 
	
	// receipt 1 invoice should have the original charges and all of the payments on it
	cashInvoice := cashReceipt1.getCashInvoice();
	count := 0;
	foreach cashPayment in cashInvoice.allCashPayments do
		count := count + 1;
	endforeach;
	//self.assertEqualMsg(count, 7, "receipt 1 invoice cash payments at end");
	count := 0;
	foreach invLine in cashInvoice.invoiceLines do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 3, "receipt 1 invoice lines at end " &amp; _type.String);
	
	// nothing on receipt 2 invoice
	count := 0;
	cashInvoice := cashReceipt2.getCashInvoice();
	foreach cashPayment in cashInvoice.allCashPayments do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 7, "receipt 2 invoice cash payments at end");
	count := 0;
	foreach invLine in cashInvoice.invoiceLines do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 3, "receipt 2 invoice lines at end");
	
	count := 0;
	foreach invLine in onsiteTi1.invoiceLines do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 6, "cargo invoice lines at end");

epilog
	beginTransaction;
	_drTerm1.setCashOnly(true);
	commitTransaction;

	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	delete invAssistant;
end;</source>
        <access>protected</access>
        <Parameter name="_id1" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal" usage="input"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cashTestMultipleReceipts3" id="1b3ebc83-03f4-48a1-b806-4e1714d6809e">
        <updating/>
        <source>cashTestMultipleReceipts3(_id1 : String; _drTerm1 : CM_DebtorTerminal; _type : Integer) updating, protected;
/*

Purpose:		Cash module testing, TFS 2186 handling of pro forma payments from several receipts.  The first receipt pays everything up to a given date, 
				the second receipt pays for 2 more days storage and the third receipt pays for another 2 days storage.
				The cargo is then released at the last date.  This checks that the invoice lines and cash payments go to the correct invoices,
				and is called twice, once with the CashInvoiceEveryReceipt option set false and then with it set true.
				This determines the number of cash invoices created from the cash receipts and the allocation of the lines and payments between them.

Parameters:			

Return Value:		


Date		Who		Reason
22/06/2016	cnwjre1	TFS 2073 and 2186

*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	expected	: Integer;
	count		: Integer;
	invoiceEveryReceipt	: Boolean;
	
	cashReceipt1 : CM_CashReceipt;
	cashReceipt2 : CM_CashReceipt;
	cashReceipt3	: CM_CashReceipt;
	cashPayment	: CM_CashPayment;
	profDetail	: CM_ProformaDetails;
	paymentMeth : CM_PaymentMethod;

	status	: Integer;
	isZeroRated : Boolean;
	termsOfTrade : CM_InvoiceTermsOfTrade;
	purchaseOrderNumber : String;
	narration : String;
	invAssistant	: Object;

	onsiteTi1	: CM_TrackedItem;
	vvrOut	: CM_VehicleVisitRecord;
	carrier	: CM_Carrier;
	truckOut	: CM_Vehicle;

	nowDate,
	baseDate,
	endDate : Date;
	profTotal,
	lineTotal,
	cashToPay,
	cashTotal	: Decimal [23,6];
	postedInvoice,
	cashInvoice	: CM_Invoice;
	invLine : CM_InvoiceLine;
	
	debtorType	: CM_DebtorType;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	obj				: Object;
	allAgents		: ObjectArray;
	agent,
	agent1,
	agent2	: CM_CashInvoiceProformaAgent;
	type : CM_TerminalAreaType;
	blockStack1,
	blockStack2	: CM_BlockStack;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;
	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
begin
	msg := method.name;
	if _type = 0 then
		self.setTerminalConfig(CashInvoiceEveryReceipt, false);
		invoiceEveryReceipt := false;
	else
		self.setTerminalConfig(CashInvoiceEveryReceipt, true);
		invoiceEveryReceipt := true;
	endif;

	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");
	blockStack2 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS2").CM_BlockStack;
	self.assertTrueMsg(blockStack2 &lt;&gt; null, "Block Stack UT_BS2 not found...");
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	
	cargoId := _id1;
	onsiteTi1 := self.createContainerFromVoyage(self.myVoyage, cargoId, blockStack1, "22G1", operator, "GENL", "NZPOE", "NZPOE", 2200, 4500).CM_Container;
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, msg &amp; " On Site Cargo 1 '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(onsiteTi1);
	// back-date the transactions to get storage
	baseDate := nowDate - 20;
	self.setTransactionDate(onsiteTi1, baseDate);
	
	// move the container to get some current charges
	self.move(onsiteTi1, blockStack2);
	self.move(onsiteTi1, blockStack1);
	self.move(onsiteTi1, blockStack2);
	
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	// first payment effective 4 days ago
	now.setDate(nowDate - 4);
	agent1 := self.createProformaAgent(now, onsiteTi1);
	allAgents.add(agent1);
	// agent 1 invoice lines 3 times $20 for move all to debtor UT_Cash1,
	//	3 pro forma lines  Rel road $20, Storage x5 $100 and Storage x11 $440
	//  total to pay 620
	
	cashToPay := agent1.getTotal();		// 620
	
	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;
	
	// first receipt is for all charges

	cashReceipt1 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, msg &amp; " Cash Receipt 1 for on site cargo not created...");

	
	// second receipt is for an extra 2 days storage
	//  Create new agent
	delete agent1;
	allAgents.clear();
	now.setDate(nowDate - 2);
	agent1 := self.createProformaAgent(now, onsiteTi1);
	allAgents.add(agent1);

	cashToPay := agent1.getTotal();		// 80 for the extra storage

	cashReceipt2 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	self.assertTrueMsg(cashReceipt2 &lt;&gt; null, msg &amp; " Cash Receipt 2 for on site cargo not created...");
	
	// third receipt is for another extra 2 days storage bring it up to date
	//  Create new agent
	delete agent1;
	allAgents.clear();
	now.setDate(nowDate);
	agent1 := self.createProformaAgent(now, onsiteTi1);
	allAgents.add(agent1);

	cashToPay := agent1.getTotal();			// 80 for more extra storage

	cashReceipt3 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	self.assertTrueMsg(cashReceipt3 &lt;&gt; null, msg &amp; " Cash Receipt 3 for on site cargo not created...");

	// check the receipts before releasing
	count := 0;
	cashTotal := 0;
	foreach cashPayment in cashReceipt1.allCashPayments do
		count := count + 1;
		cashTotal := cashTotal + cashPayment.cashValue;
	endforeach;
	self.assertEqualMsg(count, 6, "receipt 1 cash payments");
	self.assertEqualMsg(cashTotal, 620.Decimal, "Receipt 1 cash payment total");
	count := 0;
	lineTotal := 0;
	foreach invLine in cashReceipt1.allInvoiceLines do
		count := count + 1;
		lineTotal := lineTotal + invLine.lineTotal;
	endforeach;
	self.assertEqualMsg(count, 3, "receipt 1 invoice lines");
	self.assertEqualMsg(lineTotal, 60.Decimal, "Receipt 1 invoice line total");
	count := 0;
	profTotal := 0;
	foreach profDetail in cashReceipt1.allProformaDetails do
		count := count + 1;
		profTotal := profTotal + profDetail.lineTotal;
	endforeach;
	self.assertEqualMsg(count, 3, "receipt 1 pro forma details");
	self.assertEqualMsg(profTotal, 560.Decimal, "Receipt 1 proforma detail total");

	count := 0;
	cashTotal := 0;
	foreach cashPayment in cashReceipt2.allCashPayments do
		count := count + 1;
		cashTotal := cashTotal + cashPayment.cashValue;
	endforeach;
	self.assertEqualMsg(count, 1, "receipt 2 cash payments");
	self.assertEqualMsg(cashTotal, 80.Decimal, "Receipt 2 cash payment total");
	count := 0;
	lineTotal := 0;
	foreach invLine in cashReceipt2.allInvoiceLines do
		count := count + 1;
		lineTotal := lineTotal + invLine.lineTotal;
	endforeach;
// TFS 45953	self.assertEqualMsg(count, 3, "receipt 2 invoice lines");
// TFS 45953	self.assertEqualMsg(lineTotal, 60.Decimal, "Receipt 2 invoice line total");
	self.assertEqualMsg(count, 0, "receipt 2 invoice lines"); // TFS 45953 there should be no invoice lines. the invoice lines are on the first cash receipt
	self.assertEqualMsg(lineTotal, 0.Decimal, "Receipt 2 invoice line total");// TFS 45953
	
	count := 0;
	profTotal := 0;
	foreach profDetail in cashReceipt2.allProformaDetails do
		count := count + 1;
		profTotal := profTotal + profDetail.lineTotal;
	endforeach;
	
// TFS 45953	self.assertEqualMsg(count, 3, "receipt 2 pro forma details");
// TFS 45953	self.assertEqualMsg(profTotal, 80.Decimal, "Receipt 2 proforma detail total");
	self.assertEqualMsg(count, 1, "receipt 2 pro forma details"); // TFS 45953 there should only 1 proforma, it matches the single cash payment
	self.assertEqualMsg(profTotal, 80.Decimal, "Receipt 2 proforma detail total");

	count := 0;
	cashTotal := 0;
	foreach cashPayment in cashReceipt3.allCashPayments do
		count := count + 1;
		cashTotal := cashTotal + cashPayment.cashValue;
	endforeach;
	self.assertEqualMsg(count, 1, "receipt 3 cash payments");
	self.assertEqualMsg(cashTotal, 80.Decimal, "Receipt 3 cash payment total");
	count := 0;
	lineTotal := 0;
	foreach invLine in cashReceipt3.allInvoiceLines do
		count := count + 1;
		lineTotal := lineTotal + invLine.lineTotal;
	endforeach;
// TFS 45953	self.assertEqualMsg(count, 3, "receipt 3 invoice lines");
// TFS 45953	self.assertEqualMsg(lineTotal, 60.Decimal, "Receipt 3 invoice line total");
	self.assertEqualMsg(count, 0, "receipt 3 invoice lines"); // TFS 45953 there should be no invoice lines. the invoice lines are on the first cash receipt
	self.assertEqualMsg(lineTotal, 0.Decimal, "Receipt 3 invoice line total"); // TFS 45953
	count := 0;
	profTotal := 0;
	foreach profDetail in cashReceipt3.allProformaDetails do
		count := count + 1;
		profTotal := profTotal + profDetail.lineTotal;
	endforeach;
// TFS 45953	self.assertEqualMsg(count, 3, "receipt 3 pro forma details");
// TFS 45953	self.assertEqualMsg(profTotal, 80.Decimal, "Receipt 3 proforma detail total");
	self.assertEqualMsg(count, 1, "receipt 3 pro forma details"); // TFS 45953 there should only 1 proforma, it matches the single cash payment
	self.assertEqualMsg(profTotal, 80.Decimal, "Receipt 3 proforma detail total");

	// gate container out
	// create carrier and truck
	self.deleteVehicle(VehicleNumOut);
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, self.myDebtor1);
	self.assertNotNull(carrier);
	truckOut := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truckOut &lt;&gt; null, "Truck not created...");
	// Clear all the stops
	self.deleteStops(onsiteTi1);

	vvrOut := self.createVVR( truckOut, onsiteTi1 );
	self.assertTrueMsg(vvrOut &lt;&gt; null, msg &amp; " Vehicle Visit Record not created...");
	
	self.gateInTruck( vvrOut, false );
	
	self.workTruck( vvrOut, 2 );

	self.gateOutTruck( vvrOut, false ); 
	
	// receipt 1 invoice should have all of the charges and all of the payments on it
	cashInvoice := cashReceipt1.myCashInvoice;
	expected := 8;
	count := 0;
	foreach cashPayment in cashInvoice.allCashPayments do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, expected, "receipt 1 invoice cash payments at end");
	count := 0;
	foreach invLine in cashInvoice.invoiceLines do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 6, "receipt 1 invoice lines at end " &amp; _type.String);
	
	if invoiceEveryReceipt then
		cashInvoice := cashReceipt2.myCashInvoice;
		count := 0;
		foreach cashPayment in cashInvoice.allCashPayments do
			count := count + 1;
		endforeach;
		self.assertEqualMsg(count, 0, "receipt 2 invoice cash payments at end");
		count := 0;
		foreach invLine in cashInvoice.invoiceLines do
			count := count + 1;
		endforeach;
		self.assertEqualMsg(count, 0, "receipt 2 invoice lines at end");
		cashInvoice := cashReceipt3.myCashInvoice;
		count := 0;
		foreach cashPayment in cashInvoice.allCashPayments do
			count := count + 1;
		endforeach;
		self.assertEqualMsg(count, 0, "receipt 3 invoice cash payments at end");
		count := 0;
		foreach invLine in cashInvoice.invoiceLines do
			count := count + 1;
		endforeach;
		self.assertEqualMsg(count, 0, "receipt 3 invoice lines at end");
	else
		// receipt 2  and receipt 3 invoices should be null
		cashInvoice := cashReceipt2.myCashInvoice;
		self.assertNullMsg(cashInvoice, "receipt 2 invoice at end");
	
		cashInvoice := cashReceipt3.myCashInvoice;
		self.assertNullMsg(cashInvoice, "receipt 3 invoice at end");
	endif;

epilog
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	delete invAssistant;
end;</source>
        <access>protected</access>
