    <JadeMethod name="utlUpdateInvoiceProcess" id="2ef949c1-32a8-44c3-a988-e711ad0181f1">
        <updating/>
        <source>utlUpdateInvoiceProcess(_pxyInvoiceProcess : CM_InvoiceProcess; _passport : CM_Passport input) updating;
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars
	expectedEdition		: Integer;
	realInvoiceProcess 	: CM_InvoiceProcess;

begin
	self.initialiseActivity();

	_pxyInvoiceProcess.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyInvoiceProcess.pxyGetRealObjectAndEdition(realInvoiceProcess, expectedEdition);
	
	if realInvoiceProcess = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceProcess.name, null, null);
		return;
	endif;

	app.myValUA.valInvoiceProcess(_pxyInvoiceProcess, realInvoiceProcess, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realInvoiceProcess);
	
	if _passport.noErrors and realInvoiceProcess.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Invoice Process', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceProcess, true);
	endif;

	if _passport.noErrors then
		realInvoiceProcess.setForUpdate(_pxyInvoiceProcess);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceProcess, false);
	endif;
epilog

end;</source>
        <Parameter name="_pxyInvoiceProcess" type="CM_InvoiceProcess"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceSSAllocMap" id="ee419b7b-eb92-4743-b89c-3fa296de10b1">
        <source>utlUpdateInvoiceSSAllocMap(	_update : Boolean;					
							 _pxyQM : CM_QuantityMap input; 
							 _pxyQRM : CM_QuantityRangeMap input;
							 _realServiceBroker : CM_SnapShotServiceBroker input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2019	jlgndl1	Initial creation	TFS 43153

*/

vars
	expectedEdition, eventUpdateVoyageArea		: Integer;
	realQRM : CM_QuantityRangeMap;
	realQM : CM_QuantityMap;
	alloc : CM_InvoiceAllocation;
//	tranMap : CM_TranMapSSSummary;
	
	// need to support update auditing on  2 sepearte objects, need 2 agents.
	audAgentQM : CM_UpdateTransactionAuditAgent;
	audAgentQRM : CM_UpdateTransactionAuditAgent;
	updateQM : Boolean;
begin

	create audAgentQM transient;
	create audAgentQRM transient;

	self.initialiseActivity();
	app.setContinueCMExceptions(true);	

	self.raiseExceptionIfNull(_pxyQM, 'Quantity Map');
	
	app.setContinueCMExceptions(false);
	app.myValUA.valInvoiceCargoAllocMap(_pxyQM);
	app.myValUA.valInvoiceTMQuantityRangeMap(_pxyQRM);
	
	if not self.checkValidationWithPassport(app.myPassport) then
		return;
	endif;
	
	realQM := _pxyQM.pxyGetRealObject();
	
	if _update then
		realQRM := _pxyQRM.pxyGetRealObject();
		audAgentQRM.audUpdateGeneric(realQRM, true);	// pre change audit
	else
		create realQRM;
		realQRM.setForCreate(_pxyQRM);
	endif;

	if _realServiceBroker &lt;&gt; null then 
		audAgentQM.audUpdateGeneric( realQM, true );	// pre change audit
		realQM.setForUpdate( _pxyQM );
		updateQM := true;
	endif;
	
	realQRM.setForUpdate(_pxyQRM);
	
	if not app.myPassport.hasErrorsOrWarnings() then
		if _realServiceBroker &lt;&gt; null then
			alloc := realQM.myInvoiceAllocation;
			app.myEventManager.createSingleObjInfoNoteEvt( _realServiceBroker, app.myPassport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE), alloc );
		endif;
	endif;
	
	if app.myPassport.noErrors then
		if not _update then
			app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(realQRM);	// create new audit
		else
			audAgentQRM.audUpdateGeneric(realQRM, false);	//post change audit
		endif;
		if updateQM then
			audAgentQM.audUpdateGeneric(realQM, false);	// post change audit
		else
			if realQM &lt;&gt; null then
				app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(realQM);	// create new audit
			endif;
		endif;
	endif;

epilog

	delete audAgentQM; 
	delete audAgentQRM; 
	
end;</source>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_pxyQM" type="CM_QuantityMap" usage="input"/>
        <Parameter name="_pxyQRM" type="CM_QuantityRangeMap" usage="input"/>
        <Parameter name="_realServiceBroker" type="CM_SnapShotServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceShipMapping" id="bbbb92c5-a500-436b-b7a6-60d06600eda0">
        <source>utlUpdateInvoiceShipMapping(_pxyInvoiceShipTermMapping : CM_InvoiceShipTermMapping io;
							  _passport 		       : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Dec 2022 navtnr20	TFS CR 55622 Task 55690: Jade - Shipping Terms TRX

*/

vars
	realShippingLine:CM_InvoiceShipTermMapping;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	_pxyInvoiceShipTermMapping.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyInvoiceShipTermMapping.pxyGetRealObjectAndEdition(realShippingLine, expectedEdition);
	
	if realShippingLine = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceContractShipTerm.name, null, null);
		return;
	endif;
	


	app.myValUA.valInvShipMapping(_pxyInvoiceShipTermMapping);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realShippingLine);

	if _passport.noErrors and realShippingLine.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Ship Term Mapping', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realShippingLine, true);
	endif;
	
	if _passport.noErrors then
		realShippingLine.setForUpdate(_pxyInvoiceShipTermMapping);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realShippingLine, false);
		app.myEventManager.createSingleObjInfoNoteEvt(realShippingLine.myShippingTerm.myBusinessUnit,app.myPassport.myTerminal.getTerminalEvent(Event_InvShipMappingUpdate),realShippingLine);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_pxyInvoiceShipTermMapping" type="CM_InvoiceShipTermMapping" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceSplitDetails" id="ec12a7ac-8cb3-4e34-adb1-50bd10e38279">
        <updating/>
        <source>utlUpdateInvoiceSplitDetails(	pCopyInvoice : CM_Invoice input;
								pNewInvoice : CM_Invoice input;
								_passport : CM_Passport input
								) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 Decemeber 2012	cnwndl1	Initial creation	Par 30685

*/

vars

begin

	self.initialiseActivity();
	
	if pCopyInvoice = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Invoice.name, null, null);
		return;
	endif;
	
	if pNewInvoice = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Invoice.name, null, null);
		return;
	endif;

	if (not self.checkValidationWithPassport(_passport)) then
		return;	
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(pNewInvoice);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(pNewInvoice, true);
	endif;
	
	if _passport.noErrors then
		pNewInvoice.setInvoiceSplitDetailsFrom(pCopyInvoice);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(pNewInvoice, false);
		pNewInvoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, pNewInvoice);
	endif;

end;
</source>
        <Parameter name="pCopyInvoice" type="CM_Invoice" usage="input"/>
        <Parameter name="pNewInvoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceStatus" id="345dce9d-2162-4333-b1c7-ccdba7796298">
        <source>utlUpdateInvoiceStatus(_status : CMIF_InvoiceStatus; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
15 Dec 2008	cnwkpd1	PAR #18652 - Change causeEvent inside trx to immediate false
10/04/2018	jlgdap1	TFS 37858 PEL1 Invoice Status Advancement
22/11/2018  cnwma1  Bug 42175: PEL1 - Auto Posting Invoices after WSDL 1.2 Sucesss
*/

vars
	realInvoice:CM_Invoice;
	expectedEdition:Integer;
	pProxyInvoice : CM_Invoice;
	newInvoiceStatus : CM_InvoiceStatus; // TFS 39618	
begin

	if _status.myInvoice = null then
		app.cmsAbortTransaction();
		return;
	endif;
	
	self.initialiseActivity();
	pProxyInvoice := _status.myInvoice;
	
	pProxyInvoice.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyInvoice.pxyGetRealObjectAndEdition(realInvoice, expectedEdition);
	
	if realInvoice = null then	
	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Invoice.name, null, null);
		return;
	endif;

	pProxyInvoice.toDT := _status.toDT; // PAR 10090
	
	app.myValUA.valInvoiceStatus(realInvoice, _status); // PAR 18434
	
	if (not self.checkValidationWithPassport(_passport)) then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Errors " &amp; app.myPassport.getErrorsAndWarningsAsString &amp; "Current Status = " &amp; realInvoice.status.String, LogDEBUG);
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realInvoice);

	if _passport.noErrors and realInvoice.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Invoice', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, true);
	endif;
	
	if _passport.noErrors then
		//realInvoice.setForUpdateStatus(_status);				// TFS 37858
		 // ### JIRA 35468 31JUL2025 NAVAB1 set the packages thing so it can be used when setting the status
		realInvoice.setRunPackages(_status.runPackages);		//navra1 - CR 61910/Task 62303 - 16th Feb 2024
		realInvoice.setForUpdateStatus(_status, false);			// TFS 37858 // TFS 39618
	// JIRA 35468	realInvoice.setRunPackages(_status.runPackages);		//navra1 - CR 61910/Task 62303 - 16th Feb 2024
		//realInvoice.runPackages := _status.runPackages;		//navra1 - CR 61910/Task 62303 - 16th Feb 2024
		//realInvoice.runPackages := true;						//navra1 - CR 61910/Task 62303 - 16th Feb 2024
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoice, false);
		//realInvoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, realInvoice);		// PAR #18652 22/11/2018  cnwma1  Bug 42175
		realInvoice.causeEvent(realInvoice.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, realInvoice);		           // 22/11/2018  cnwma1  Bug 42175
	endif;

epilog
	
	
end;</source>
        <Parameter name="_status" type="CMIF_InvoiceStatus"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvoiceStatusNew" id="cb96a5b9-0704-48b6-a768-4fb6ba8fe61a">
        <updating/>
        <source>utlUpdateInvoiceStatusNew(_pxyInvoiceStatus : CM_InvoiceStatus; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2018	jlgsl4	Initial creation

*/

vars
	expectedEdition		: Integer;
	realInvoiceStatus 	: CM_InvoiceStatus;

begin
	self.initialiseActivity();

	_pxyInvoiceStatus.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyInvoiceStatus.pxyGetRealObjectAndEdition(realInvoiceStatus, expectedEdition);
	
	if realInvoiceStatus = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceStatus.name, null, null);
		return;
	endif;

	app.myValUA.valInvoiceStatusNew(_pxyInvoiceStatus, realInvoiceStatus, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realInvoiceStatus);
	
	if _passport.noErrors and realInvoiceStatus.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Invoice Status', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceStatus, true);
	endif;

	if _passport.noErrors then
		realInvoiceStatus.setForUpdate(_pxyInvoiceStatus);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceStatus, false);
	endif;
epilog

end;</source>
        <Parameter name="_pxyInvoiceStatus" type="CM_InvoiceStatus"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
