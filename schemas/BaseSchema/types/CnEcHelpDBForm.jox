        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNewFormInclude_click(btn: Button input) updating;

vars
	object	: Object;
	myIndex	: Integer;
	changes	: Boolean;

begin
	foreach myIndex in 1 to lstForms_new.listCount do
		if lstForms_new.itemSelected[myIndex] then
			object := lstForms_new.itemObject[myIndex];
			
			if object &lt;&gt; null then
				changes := true;
				aAllNewForms.remove(object);
				aAllIncludedForms.add(object);
				aAllChangedForms.add(object);		// 'cos it is!
