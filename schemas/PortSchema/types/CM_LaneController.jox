//
// ---------------------------------------------------------------------------
vars

begin
	if _inBoom then
		return self.getLaneDevice(CM_LaneDevice.Type_BoomIn).CM_LDBoom;
	else
		return self.getLaneDevice(CM_LaneDevice.Type_BoomOut).CM_LDBoom;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_inBoom" type="Boolean"/>
        <ReturnType type="CM_LDBoom"/>
    </JadeMethod>
