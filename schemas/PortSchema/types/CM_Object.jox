    <JadeMethod name="setExtensionObjectValue" id="056d5822-d582-4093-b346-4fea44b7de81">
        <updating/>
        <source>setExtensionObjectValue(_key : String; _value : Any) updating;
/*

Purpose:			set the value for the passed in key

Parameters:			Unique key and the value required
Date		Who		Reason
27 Sep 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms
23/02/2012	cnwcs5	Par 29158 - CCMS CPL 2086 - Allow transients to have object extensions 
23/04/2012	cnwcs5	CCMS POL 2172 / par 29480 - update the edition so system notifications work
29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/

vars
	objExtension	: CM_ObjectExtension;
	
begin
	objExtension := self.getMyObjectExtension();
	
	// Do nothing if there is no extension and the incoming value is null
	if objExtension = null and _value = null then
		return;
	endif;
	
	// Create an extension if required
	if objExtension = null then
		if self.isTransient then 
			create objExtension transient;
		else
			create objExtension persistent;
		endif;
		
		objExtension.setForCreate(self);
	endif;
	
	objExtension.setValue(_key, _value);
	
	// If after we return the extension has no remaining state data (i.e. all the
	// possible values are null), then delete it as a tidy up
	if objExtension.allStateData.isEmpty() then
		delete objExtension;
	endif;
		
	if not self.isTransient then
		self.updateObjectEdition (self);	// par 30292
	endif;
	
epilog

end;</source>
        <Parameter name="_key" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
