    <JadeMethod name="testAgainstDeliveryRequest" id="5e680d36-ca77-42a3-9d14-2604abc82e39">
        <source>testAgainstDeliveryRequest(reqToTest: CM_DeliveryRequest) protected;
// ---------------------------------------------------------------------------
// Created:      23 Aug 2006 by cnwyl1
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(reqToTest);

	// PAR 12298 &amp; 12358
 	if reqToTest.isoType.trimRight &lt;&gt; null then
 		//---------------------
 		//If there's an ISO type, test it.
 		//---------------------
 		if not self.isSimilarToISOType(reqToTest.isoType) then
		
			if reqToTest.isoGroup &lt;&gt; null then //cnwrd1 22.12.09 ++
				//cnwrd1 par 30414 25.9.2012
				if not reqToTest.testISOGroup(self.isoTypeGroup.trimRight, null) then
					app.raiseCMException3(TI_TestReqISOGroup, self.id, self.isoTypeGroupDesc, reqToTest.isoGroup, null, null);
				endif;
			else
				app.raiseCMException3(TI_TestReqISO, self.id, self.isoType, reqToTest.isoType, null,self);
			endif;
			
			/*
			if reqToTest.doISOGroupCheck then
				if not self.isSimilarToISOTypeGroup(reqToTest.isoType) then
					app.raiseCMException3(TI_TestReqISOGroup, self.id, self.isoTypeGroupDesc, reqToTest.isoType, null, null);
				endif;
			else
				app.raiseCMException3(TI_TestReqISO, self.id, self.isoType, reqToTest.isoType, null, null);
			endif;
			*/
		endif;
	else	//no isoType to test, check ISO group
		if reqToTest.isoGroup &lt;&gt; null then
			//cnwrd1 par 30414 25.9.2012
			if not reqToTest.testISOGroup(self.isoTypeGroup.trimRight, null) then
				app.raiseCMException3(TI_TestReqISOGroup, self.id, self.isoTypeGroupDesc, reqToTest.isoGroup, null, null);
			endif;
		endif;
	endif;

end;
</source>
        <access>protected</access>
        <Parameter name="reqToTest" type="CM_DeliveryRequest"/>
    </JadeMethod>
