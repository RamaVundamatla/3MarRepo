		availGrade 	:= app.myRoot.allAvailabilityGrades[mtGrade];
	endif;

	combo := self.cmbAvailGrade;
	
	combo.setObject(availGrade);
	
	self.tblSearch.setValueByName(ETRow_FiltAvailGrade, combo.text);
	
end;</source>
