<Class name="CMUI_GridPoint">
    <JadeMethod name="disabledAppearance" id="de0da0f3-723c-480f-977c-2b290d2f8e2d">
        <source>disabledAppearance(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2014	cnwndl1	Initial creation	Par 35346	- migrated up from YRD_WagonWheels class

*/

vars

begin
	return self.myGridArea.YRD_WagonArea.disabledAppearance;

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getColWheel" id="9e331a0b-df1b-4a93-b1ac-329a705ebf8a">
        <source>getColWheel(_wagon: CM_Wagon): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2014	cnwndl1	Initial creation		Par 35346	- migrated up from YRD_WagonWheels class

*/

vars

begin

	if self.disabledAppearance then
		return YRD_WagonArea.DisabledGrey_Dark;
		
	elseif self.myGridArea.YRD_WagonArea.isOutward then

		if app.getMyTerminalConfigDO_NOT_USE(UseOutwardRailConfirm).Boolean and _wagon &lt;&gt; null then
			if _wagon.confirmedOutwards then
				return Green;
			else
				return Red;
			endif;	
		else
			return Black;
		endif;
	else
		if _wagon &lt;&gt; null then
			if _wagon.confirmed then
				return Green;
			else
				return Red;
			endif;	
		else
			return Black;
		endif;
	endif;

end;


</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isBoxcar" id="518acf20-ed6f-4487-b5b8-cabe1d830560">
        <source>isBoxcar():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2013	cnwndl1	Initial creation

*/

vars

begin

	if self.myGridArea.isBoxcar then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
