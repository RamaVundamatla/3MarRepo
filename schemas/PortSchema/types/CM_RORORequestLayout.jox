    <JadeMethod name="getProposedVisiblity" id="afec5592-6b3a-4715-a130-4bb2bfc6a60c">
        <source>getProposedVisiblity(_colour: Integer output): Boolean;
/*
Purpose:			
Date		Who		Reason
21 September 2011	cnwab1	Initial creation
*/

vars

begin

	if self.myRequest &lt;&gt; null then
		if self.myRequest.isBackEndRequest then
			return self.myRequest.CM_ROROSlotRequest.mySlotRequestForward.getProposedVisiblity(_colour);
		else
			return self.myRequest.getProposedVisiblity(_colour);
		endif;
	else
		return false;
	endif;
epilog

end;</source>
