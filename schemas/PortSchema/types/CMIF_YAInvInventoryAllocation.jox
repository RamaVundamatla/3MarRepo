    <JadeMethod name="isImexStatus_Match" id="20629922-93ad-4e91-94aa-39aca3add66e">
        <source>isImexStatus_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose:			

Date		Who		Reason
24MAY2021	NAVAB1	TFS 51219
*/


vars
	ti : CM_TrackedItem;
	status : Integer;
begin

	if _yaData.isEmpty() then
		return true;
	endif;
	
	ti := self.myLocationEvent.myTrackedItem;
	if ti = null then
		return false;
	endif;
	
	
	status := ti.getReceivalIMEXStatus();

	if (status &lt;&gt; null and _yaData.isEmpty()) then
		return true;
	endif;
	
	if self.includeDLRsSOBsImexCheckCase(_yaData) then
		return true;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanNormal::isImexStatus_Compare, status);
end;</source>
