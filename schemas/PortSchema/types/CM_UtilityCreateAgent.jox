    <JadeMethod name="utlCreateInvContractDtl" id="590df46a-ec43-4b21-b986-3cd9e5af9b7e">
        <source>utlCreateInvContractDtl(_pxyObject : CM_InvoiceContractDetails; _realObject : CM_InvoiceContractDetails output; _passport : CM_Passport input);
/*
Purpose:			

Date		Who		Reason
01DEC2022	NAVAB1	TFS CR 55623 TASK 55673
*/
vars

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCreateInvContractDtl(_pxyObject);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	create _realObject as _pxyObject.class  persistent; // ### TFS CR 55624 TASK 55698 23JAN2023 NAVAB1
	_realObject.setForCreate(_pxyObject);
	
	if _passport.noErrors then
