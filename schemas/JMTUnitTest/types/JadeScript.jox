    <JadeMethod name="mdhTestXMLDocument" id="1324e7d0-f2e3-490c-8a56-8ef13a237ee9">
        <source>mdhTestXMLDocument();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
23 September 2011	cnwmh5	Initial creation

*/
constants
	ClassName						: String = "UT_JMT";
	MethodName						: String = "tCheck_addHoursUsageOK";
	XMLAdditional					: String = "UT_Additional";
	XMLCategories					: String = "Categories";
vars
	
	xmlDocument						: JadeXMLDocument;
	xmlElementAdditional,
	xmlElementCategories, 
	xmlElementCategory				: JadeXMLElement;
	klass							: Class;
	meth							: Method;
	
	deleteCategory					: StringArray;
	
	methodText						: String;
	i								: Integer;
	categ							: String;
	
begin

	klass := currentSchema.getClass(ClassName);
	if klass = null then
		write "Can't find the selected class (" &amp; ClassName &amp; ")";
		return;
	endif;
	
	meth := klass.getMethod(MethodName);
	if meth = null then
		write "Can't find the selected method (" &amp; ClassName &amp; "::" &amp; MethodName &amp; ")";
		return;
	endif;

	methodText := meth.text;
	
	create xmlDocument transient;
	xmlDocument.outputDeclaration := null;
	if methodText &lt;&gt; null then
		xmlDocument.parseString(meth.text);
	endif;
	
	xmlElementAdditional := xmlDocument.getElementByTagName(XMLAdditional);
	if xmlElementAdditional = null then
		xmlElementAdditional := xmlDocument.addElement(XMLAdditional);
	endif;
	
	xmlElementCategories := xmlDocument.getElementByTagName(XMLCategories);
	if xmlElementCategories = null then
		xmlElementCategories := xmlElementAdditional.addElement(XMLCategories);
	endif;
	
	create deleteCategory transient;
	deleteCategory.add("Category3");
	deleteCategory.add("Category6");
	deleteCategory.add("Category9");
	deleteCategory.add("Category12");
	
	foreach i in 1 to 19 do
		categ := "Category" &amp; i.String;
		xmlElementCategory := xmlElementCategories.getElementByTagName(categ);
		if xmlElementCategory = null then
			xmlElementCategories.addElement(categ);	
		else
			if deleteCategory.includes(categ) then
				delete xmlElementCategory;
			endif;
		endif;
	endforeach;
	
	beginTransaction;
	meth.setPropertyValue('text', xmlDocument.writeToString().trimBlanks());
	commitTransaction;

epilog

	delete xmlDocument;
	delete deleteCategory;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhTestasdf" id="65ac1518-736c-4a33-90ee-384c858ec478">
        <source>mdhTestasdf();

/*

Purpose:		

Date			Who		Reason
19 March 2015	cnwmh5	Initial creation

*/

vars

	file					: File;

	systemName				: String;
	tempStr					: String;
	pos						: Integer;
	directory				: String;
	
begin

	app.initialize();
	
	directory := app.getJadeInstallDir();
	pos := 1;
	pos := directory.reversePos("\");
	directory := directory[1:pos];
	directory := directory &amp; "logs";
		
	create file transient;
	file.fileName := directory &amp; "\AutmationRunDetails.txt";
	file.usePresentationFileSystem := true;
	if file.isAvailable then
		file.purge();
	endif;
	
	// get the system name
	tempStr := app.getJadeInstallDirAppServer();
	pos := 1;
	systemName := tempStr.scanUntil("\", pos);
	pos := pos + 1;
	systemName := tempStr.scanUntil("\", pos);
	
	file.writeLine(app.cnGetJadeVersion() &amp; ";" &amp; app.myRoot.getVersionAndPatchLevel());
	
epilog

	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhTestingAgain6" id="bed55472-1680-4266-a2ef-5f399c3ff501">
        <source>mdhTestingAgain6();

/*

Purpose:			

Date			Who		Reason
08 September 2016	cnwmh5	Initial creation

*/

vars

	changesInSource				: UM_ChangesInSource;
	
begin

	app.initialize();
	
	
	create changesInSource transient;
	
	// get the changes from the current system
	changesInSource.extractChangesCurrent();
	
	// get the changes from the other system
	changesInSource.extractChangesOtherSystem();
	
	// what's in current system and not in other
	changesInSource.findMissingDetails();
	
	// go get the mssing details from the other system
	changesInSource.updateOtherOutputFile();
	
	
	// do compare again and see where the difference are
	changesInSource.updateDoFullCompare(true);
	changesInSource.reloadXMLDocuments();
	changesInSource.compareChangesGlobalConstants();
	changesInSource.compareChangesSchemas();

epilog

	delete changesInSource;
	
	terminate;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhTranslationCheck" id="18ea1a3b-0840-49ef-8863-3ce34b48101c">
        <source>mdhTranslationCheck();

/*

Purpose:		Check the XLAT translatable string for duplicate id.

Date			Who		Reason
16 July 2012	cnwmh5	Initial creation

*/

vars
	constantCategory		: ConstantCategory;
	constant				: Constant;
	locale					: CM_Locale;
	existingTranslations	: XLAT_TranslatableTextByCatNmbr;
	translatableText		: XLAT_TranslatableText;
	category				: XLAT_Category;
	tmpCategoryDict,
	tmpConstantDict			: ConstantNDict;
	portScm					: Schema;
	checked,
	bad						: Integer;
	indexOf					: Integer;
	
	constantValueArray		: IntegerArray;
	constantNameArray		: StringArray;
	
	allMethodRefs			: MethodSet;
	
	methodRefsEmpty			: Boolean;
	
begin
	
	app.initialize();
	
	portScm := rootSchema.getSchema("PortSchema");
	
	create constantValueArray transient;
	create constantNameArray transient;
	create allMethodRefs transient;
	
	foreach category in app.myRoot.allXLAT_Categories do
	
		if category.constantCategoryName = XLAT_Menus or
		   category.constantCategoryName = XLAT_ReportNames or
		   category.constantCategoryName = EntTableRows then
			continue;
		endif;

		constantCategory := portScm.getCategory(category.constantCategoryName);
	
		tmpConstantDict := constantCategory.getConstants();
		
		constantValueArray.clear();
		constantNameArray.clear();
	
		foreach constant in tmpConstantDict do
			checked := checked + 1;
		
			allMethodRefs.clear();
			constant.getMethodRefs(allMethodRefs);
			methodRefsEmpty := false;
			if allMethodRefs.isEmpty() then
				methodRefsEmpty := true;
			endif;
						
			indexOf := constantValueArray.indexOf(constant.valueAsInteger);
			if indexOf &gt; 0 then
				bad := bad + 1;
				write category.constantCategoryName &amp; Tab &amp; constant.name &amp; Tab &amp; constant.getSource() &amp; Tab &amp; methodRefsEmpty.String &amp; Tab &amp;
					constantNameArray[indexOf];
			else
				constantValueArray.add(constant.valueAsInteger);
				constantNameArray.add(constant.name &amp; Tab &amp; methodRefsEmpty.String);
			endif;			
	
		endforeach;
	
	endforeach;
		
	if bad &gt; 0 then 
		write "Number of bad records: " &amp; bad.String;
	endif;
	
epilog

	delete constantValueArray;
	delete constantNameArray;
	delete allMethodRefs;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="mdhTranslationCheck2" id="4a23bb1c-b16e-4664-8263-af3613d77608">
        <source>mdhTranslationCheck2();

/*

Purpose:		Check the XLAT translatable string for no text.

Date			Who		Reason
16 July 2012	cnwmh5	Initial creation

*/

vars
	constantCategory		: ConstantCategory;
	constant				: Constant;
	meth					: Method;
	category				: XLAT_Category;
	tmpConstantDict			: ConstantNDict;
	portScm					: Schema;
	
	alreadyReadArray		: IntegerArray;
	constantDupArray		: IntegerArray;
	
	allMethodRefs			: MethodSet;
	
	hasReferences			: Boolean;
	constantId				: Integer;
	textNull				: Boolean;
	
begin
	
	app.initialize();
	
	portScm := rootSchema.getSchema("PortSchema");
	
	create alreadyReadArray transient;
	create allMethodRefs transient;
	create constantDupArray transient;
	
	foreach category in app.myRoot.allXLAT_Categories do
	
		if category.constantCategoryName = XLAT_Menus or
		   category.constantCategoryName = XLAT_ReportNames or
		   category.constantCategoryName = EntTableRows then
			continue;
		endif;

		constantCategory := portScm.getCategory(category.constantCategoryName);
	
		tmpConstantDict := constantCategory.getConstants();
		
		alreadyReadArray.clear();
		constantDupArray.clear();
	
		// work out the duplicate ids and add to duplicate array
		foreach constant in tmpConstantDict do
			constantId := constant.valueAsInteger;
			//indexOf := alreadyReadArray.indexOf(constantId);
			textNull := constant.text = null;
			if textNull then
				if not constantDupArray.includes(constantId) then
					constantDupArray.add(constantId);
				endif;
			else
				alreadyReadArray.add(constantId);
			endif;
		
		endforeach;
			
		// now have the duplicates get the details for the duplicate
		foreach constant in tmpConstantDict do
			constantId := constant.valueAsInteger;
			
			if not constantDupArray.includes(constantId) then
				continue;
			endif;
			
			constantCategory := constant.GlobalConstant.getCategory();
			
			// if has methods then write details
			allMethodRefs.clear();
			constant.getMethodRefs(allMethodRefs);
			hasReferences := false;
			foreach meth in allMethodRefs do
				hasReferences := true;
				write constantCategory.name &amp; Tab &amp; constant.name &amp; Tab &amp; constantId.String &amp; Tab &amp; meth.getSchemaType().name &amp; Tab &amp; meth.name;
			endforeach;
			
			// if doesn't have any methods then write details
			if not hasReferences then
				write constantCategory.name &amp; Tab &amp; constant.name &amp; Tab &amp; constantId.String &amp; Tab &amp; Tab;
			endif;
						
		endforeach;
		
	endforeach;
	
epilog

	delete alreadyReadArray;
	delete allMethodRefs;
	delete constantDupArray;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="mdhTrxNoReferences" id="22f84645-220d-4c41-aa22-4772a05599cd">
        <source>mdhTrxNoReferences();

/*

Purpose:		

Date			Who		Reason
20 May 2015	cnwmh5	Initial creation

*/

vars
	
	schema							: Schema;
	schema1 						: Schema;
	klass							: Class;
	meth							: Method;
	usage							: UM_MethodPropertyUsage;
	obj								: Object;
	file							: File;
	file2							: File;
	file3							: File;
	meth2							: Method;
	
	classNameArray					: StringArray;
	methodNameArray					: StringArray;
	methodsDict						: MethodNDict;
	
	methodRefSet					: MethodSet;
	
	iter							: Iterator;

	className						: String;
	methodName						: String;
	methodClassName					: String;
	methodMethodName				: String;
	originalClassName				: String;
	originalMethodName				: String;
	level							: Integer;
	index							: Integer;
	index2							: Integer;
	numIndentsStr					: String;
	unitTestsUsedBy					: String;
	methodsUsedBy					: String;
	formsUsedBy						: String;
	usedByFormUnitTest				: Character;
	unitTestsUsedByCount			: Integer;
	formsUsedByCount				: Integer;
	methodsUsedByCount				: Integer;
	count							: Integer;
	
begin

	schema := rootSchema.getSchema("PortSchema");
	if schema = null then
		write "Unable to find schema (PortSchema).  Exiting JadeScript";
		return;
	endif;
	
	create file transient;
	file.fileName := "c:\temp\" &amp; method.name &amp; ".txt";
	if file.isAvailable then
		file.purge;
	endif;
	
	create file2 transient;
	file2.fileName := "c:\temp\" &amp; method.name &amp; ".csv";
	if file2.isAvailable then
		file2.purge;
	endif;
	file2.writeLine("trxClass/Method,trxClass,trxMethod,Form/UnitTest,class/method,class,method");
	
	create file3 transient;
	file3.fileName := "c:\temp\" &amp; method.name &amp; "UsageCount.csv";
	if file3.isAvailable then
		file3.purge;
	endif;
	file3.writeLine("trxClass/Method,Cls / Mth,trxClass,trxMethod,Form Count,UnitTest Count,Method Count");
	
	
	create usage transient;
		
	create classNameArray transient;
	classNameArray.add("CM_TrxControlCreateAgent");
	classNameArray.add("CM_TrxControlDeleteAgent");
	classNameArray.add("CM_TrxControlUpdateAgent");
	classNameArray.add("CM_TrxControlRTAgent");
	
	///create methodNameArray transient;
	//methodNameArray.add("trxCreateActivityHistory");
	///methodNameArray.add("trxCreateVVRSecurityGate");
	///methodNameArray.add("trxCreateCurrencyCode");
	///methodNameArray.add("trxCreateEDIFile");
	
	create methodRefSet transient;
	
	foreach className in classNameArray do
	
		// get the class
		klass := schema.getClass(className);
		if klass = null then
			schema1 := rootSchema.getSchema("MobileServerSchema");
			klass := schema1.getClass(className);
			if klass = null then
				continue;
			endif;
		endif;
		
		originalClassName := klass.name;
		
		// get the methods
		methodsDict := klass.cnGetMethods();
			
		// process the methods
		foreach meth in methodsDict do
			
			
			originalMethodName := meth.name;
	
			methodRefSet.clear();
			meth.getMethodRefs(methodRefSet);
	
			if methodRefSet.isEmpty() then
				//file.writeLine(originalClassName &amp; "::" &amp; originalMethodName);
				write originalClassName &amp; "," &amp; originalMethodName;
				count := count + 1;
			endif;
	
		endforeach;
	
	endforeach;
	write 'count: ' &amp; count.String;
	
epilog

	delete usage;
	delete classNameArray;
	delete methodNameArray;
	
	delete iter;
	
	delete file;
	delete file2;
	delete file3;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhTrxSpecialBish" id="bae46a76-f938-47ca-9b86-50f92db5b32c">
        <source>mdhTrxSpecialBish();

/*

Purpose:		Create a csv file with the details of TrxResponseTimeAnalysis from selected systems

Date			Who		Reason
03/02/2014		cnwmh5	Initial creation

*/

vars
	
	schema							: Schema;
	klass							: Class;
	meth							: Method;
	usage							: UM_MethodPropertyUsage;
	obj								: Object;
	file							: File;
	file2							: File;
	meth2							: Method;
		
	classNameArray					: StringArray;
	methodNameArray					: StringArray;
	schemaNameArray					: StringArray;
	classMethodNameArray			: StringArray;
	tokens							: StringArray;
	formsUsedByArray				: StringArray;
	unitTestsUsedByArray			: StringArray;
	tempArray						: StringArray;
	tempArray2						: StringArray;
	
	iter							: Iterator;

	className						: String;
	methodName						: String;
	methodClassName					: String;
	methodMethodName				: String;
	level							: Integer;
	index							: Integer;
	index2							: Integer;
	numIndentsStr					: String;
	usedByFormUnitTest				: Character;
	line 							: String;
	unitTestsUsedBy					: String;
	methodsUsedBy					: String;
	formsUsedBy						: String;
	indexZ							: Integer;
	unitTestCount					: Integer;
	tmpStr							: String;
	formsIsBigger					: Boolean;
	
begin


	// read in the file
	create classNameArray transient;
	create methodNameArray transient;
	create schemaNameArray transient;

	create tokens transient;
	create usage transient;
	create tempArray transient;
	create tempArray2 transient;
	
	create formsUsedByArray transient;
	create unitTestsUsedByArray transient;
	
	create file transient;
	file.fileName := "c:\temp\bishFile.txt";
	file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version	
	create file2 transient;
	file2.fileName := "c:\temp\FormUnitTestUsage.csv";
	if file2.isAvailable() then
		file2.purge();
	endif;
	file2.writeLine("Class / Method,Forms,Unit Tests");
	
	while not file.endOfFile do
	
		line := file.readLine();
		
		tokens.clear();
		line.getTokensForDelimiter(" ", tokens);
		schemaNameArray.add(tokens[1]);
		classNameArray.add(tokens[2]);
		methodNameArray.add(tokens[3]);
	
	endwhile;


	foreach indexZ in 1 to schemaNameArray.size step 1 do
		
		schema := rootSchema.getSchema(schemaNameArray[indexZ]);
		if schema = null then
			continue;
		endif;
		
		klass := schema.getClass(classNameArray[indexZ]);
		if klass = null then
			continue;
		endif;
		
		meth := klass.getMethodInHTree(methodNameArray[indexZ]);
		if meth = null then
			continue;
		endif;
		
		level := 1;
		usage.clearCollections(true);
		usage.setCurrentMethod(meth);
		usage.addMethodToList(meth, level, true);
		
		//write CrLf &amp; CrLf;
		foreach index in 1 to usage.allRefs.size do
			meth := usage.allRefs[index].Method;
			numIndentsStr := null;
			foreach index2 in 1 to usage.refsByLevel[index] do
				numIndentsStr := numIndentsStr.trimBlanks() &amp; Tab;
			endforeach;
		endforeach;
		
		formsUsedBy := null;
		unitTestsUsedBy := null;
		methodsUsedBy := null;
		unitTestCount := 0;
		formsUsedByArray.clear();
		unitTestsUsedByArray.clear();
		tempArray := null;
		tempArray2 := null;
		write CrLf &amp; CrLf &amp; usage.currentMethod.getSchemaType().name &amp; "::" &amp; usage.currentMethod.name &amp; CrLf;
		iter := usage.tempDictionary.createIterator;
		while iter.next(obj) do
			meth2 := obj.Method;
			usage.tempDictionary.getIteratorKeys(className, methodName, methodClassName, methodMethodName, usedByFormUnitTest, iter);
			if usedByFormUnitTest = "F" then
				if not formsUsedByArray.includes(meth2.getSchemaType().name) then
					formsUsedByArray.add(meth2.getSchemaType().name);
				endif;
			elseif usedByFormUnitTest = "U" then
				if not unitTestsUsedByArray.includes(meth2.getSchemaType().name &amp; "::" &amp; meth2.name) then
					unitTestsUsedByArray.add(meth2.getSchemaType().name &amp; "::" &amp; meth2.name);
				endif;
			else	
			endif;
		endwhile;
		
		if not formsUsedByArray.isEmpty() then
			write Tab &amp; "Used by Form(s):" &amp; CrLf &amp; Tab &amp; Tab &amp; formsUsedByArray.concatenate(CrLf &amp; Tab &amp; Tab);
		endif;
		if not unitTestsUsedByArray.isEmpty() then
			//write Tab &amp; "Used by Unit Test(s):" &amp; unitTestsUsedBy;
			write Tab &amp; "Used by Unit Test(s):" &amp; CrLf &amp; Tab &amp; Tab &amp; unitTestsUsedByArray.concatenate(CrLf &amp; Tab &amp; Tab);
			//file.writeLine(Tab &amp; "Used by Unit Test(s):" &amp; unitTestsUsedBy);
		endif;	
		
		file2.writeLine(usage.currentMethod.getSchemaType().name &amp; "::" &amp; usage.currentMethod.name);
		delete tempArray;
		create tempArray transient;
		delete tempArray2;
		create tempArray2 transient;
		formsIsBigger := false;
		if formsUsedByArray.size &gt; unitTestsUsedByArray.size then
			tempArray := formsUsedByArray;
			tempArray2 := unitTestsUsedByArray;
			formsIsBigger := true;
		else	
			tempArray := unitTestsUsedByArray;
			tempArray2 := formsUsedByArray;
		endif;
		
		tmpStr := null;
		foreach index in 1 to tempArray.size step 1 do
			
			tmpStr := ",";
			if formsIsBigger then
				tmpStr := tmpStr &amp; tempArray[index];
				if index &gt; tempArray2.size then
					tmpStr := tmpStr &amp; ",";
				else	
					tmpStr := tmpStr &amp; "," &amp; tempArray2[index];
				endif;
			else
				if index &gt; tempArray2.size then
					//tmpStr := tmpStr &amp; ",";
				else
					tmpStr := tmpStr &amp; tempArray2[index];
				endif;
				tmpStr := tmpStr &amp; "," &amp;tempArray[index];
			endif;
			file2.writeLine(tmpStr);
			
		endforeach;
		
		
		write CrLf;
	
	endforeach;
	
	
epilog

	delete usage;
	delete classNameArray;
	delete methodNameArray;
	
	delete iter;
	
	delete classMethodNameArray;
	
	delete schemaNameArray;
	delete tempArray;
	delete tempArray2;

	delete tokens;
	
	//delete formsUsedByArray;
	//delete unitTestsUsedByArray;
	
	create file transient;
	
	
	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhTrxSpecialBish2" id="e03d5960-d38d-473f-8e52-b35b48ca5b55">
        <source>mdhTrxSpecialBish2();

/*

Purpose:		Create a csv file with the details of TrxResponseTimeAnalysis from selected systems

Date			Who		Reason
03/02/2014		cnwmh5	Initial creation

*/

vars
	
	schema							: Schema;
	schema1 						: Schema;
	klass							: Class;
	meth							: Method;
	usage							: UM_MethodPropertyUsage;
	obj								: Object;
	file							: File;
	meth2							: Method;
	fileFolder						: FileFolder;
	fileNode						: FileNode;
	file3							: File;
	file2							: File;
		
	classNameArray					: StringArray;
	methodNameArray					: StringArray;
	methodsDict						: MethodNDict;
	classMethodNameArray			: StringArray;
	detailsArray					: HugeStringArray;
	totalArray						: IntegerArray;
	tokens							: StringArray;
	formsUsedByArray				: StringArray;
	unitTestsUsedByArray			: StringArray;
	checkClassMethodArray			: StringArray;
	methodsUsedByArray				: StringArray;
	tempArray						: StringArray;
	tempArray2						: StringArray;
	notFoundArray					: StringArray;
	
	iter							: Iterator;
	
	className						: String;
	methodName						: String;
	methodClassName					: String;
	methodMethodName				: String;
	originalClassName				: String;
	originalMethodName				: String;
	level							: Integer;
	index							: Integer;
	index2							: Integer;
	numIndentsStr					: String;
	usedByFormUnitTest				: Character;
	unitTestsUsedByCount			: Integer;
	formsUsedByCount				: Integer;
	methodsUsedByCount				: Integer;
	pos								: Integer;
	clientName						: String;
	line 							: String;
	trxId							: String;
	trxCount						: Integer;
	commaCount						: Integer;
	fileCount						: Integer;
	baseCommaCount					: Integer;
	methodFound						: Boolean;
	unitTestsUsedBy					: String;
	methodsUsedBy					: String;
	formsUsedBy						: String;
	indexZ							: Integer;
	unitTestCount					: Integer;
	tmpStr							: String;
	formsIsBigger					: Boolean;
	
begin

	create file2 transient;
	file2.fileName := "c:\temp\FormUnitTestUsage1.csv";
	if file2.isAvailable() then
		file2.purge();
	endif;
	file2.writeLine("Class / Method,Forms,Unit Tests,Method");

	// load in the file to check against
	create checkClassMethodArray transient;
	
	create file3 transient;
	file3.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	file3.fileName := "c:\temp\bishFile.txt";
	
	create tokens transient;
	while not file3.endOfFile() do
		line := file3.readLine();
		tokens.clear();
		line.getTokensForDelimiter(" ", tokens);
		checkClassMethodArray.add(tokens[2] &amp; "::" &amp; tokens[3]);
	endwhile;

	schema := rootSchema.getSchema("PortSchema");
	if schema = null then
		write "Unable to find schema (PortSchema).  Exiting JadeScript";
		return;
	endif;
	
	create classMethodNameArray transient;
	classMethodNameArray.add(null);
	
	create detailsArray transient;
	detailsArray.add("trxClass/Method,Cls / Mth,trxClass,trxMethod,Form Used By,UnitTest Used By, Method Used By");
	
	tokens.clear();
	tokens := detailsArray[1].cnGetTokens(",");	
	baseCommaCount := tokens.size - 1;  // + 1;
	
	create totalArray transient;
	totalArray.add(0);
	
	create usage transient;
		
	create classNameArray transient;
	classNameArray.add("CM_TrxControlCreateAgent");
	classNameArray.add("CM_TrxControlDeleteAgent");
	classNameArray.add("CM_TrxControlUpdateAgent");
	classNameArray.add("CM_TrxControlRTAgent");
	
	create methodNameArray transient;
	create formsUsedByArray transient;
	create unitTestsUsedByArray transient;
	create methodsUsedByArray transient;
	create notFoundArray transient;
	
	foreach className in classNameArray do
	
		// get the class
		klass := schema.getClass(className);
		if klass = null then
			schema1 := rootSchema.getSchema("MobileServerSchema");
			klass := schema1.getClass(className);
			if klass = null then
				continue;
			endif;
		endif;
		
		originalClassName := klass.name;
		
		// get the methods
		methodsDict := klass.cnGetMethods();
			
		// process the methods
		foreach meth in methodsDict do
			
			if not methodNameArray.isEmpty() and not methodNameArray.includes(meth.name) then
				continue;
			endif;
	
			originalMethodName := meth.name;
	
			level := 1;
			usage.clearCollections(true);
			usage.setCurrentMethod(meth);
			usage.addMethodToList(meth, level, true);
			
			write CrLf &amp; CrLf;
			foreach index in 1 to usage.allRefs.size do
				meth := usage.allRefs[index].Method;
				numIndentsStr := null;
				foreach index2 in 1 to usage.refsByLevel[index] do
					numIndentsStr := numIndentsStr.trimBlanks() &amp; Tab;
				endforeach;
				write usage.refsByLevel[index].String &amp; numIndentsStr &amp; meth.getSchema().name &amp; Tab &amp; meth.getSchemaType().name &amp; Tab &amp; meth.name;
			endforeach;
			
			formsUsedByCount := 0;
			unitTestsUsedByCount := 0;
			methodsUsedByCount := 0;
			formsUsedByArray.clear();
			unitTestsUsedByArray.clear();
			methodsUsedByArray.clear();
			tempArray := null;
			tempArray2 := null;
			methodFound := false;
			write CrLf &amp; CrLf &amp; usage.currentMethod.getSchemaType().name &amp; "::" &amp; usage.currentMethod.name &amp; CrLf;
			iter := usage.tempDictionary.createIterator;
			while iter.next(obj) do
				meth2 := obj.Method;
				usage.tempDictionary.getIteratorKeys(className, methodName, methodClassName, methodMethodName, usedByFormUnitTest, iter);
				//if usedByFormUnitTest = "F" then
				//	formsUsedByCount := formsUsedByCount + 1;
				//elseif usedByFormUnitTest = "U" then
				//	unitTestsUsedByCount := unitTestsUsedByCount + 1;
				//elseif usedByFormUnitTest = "M" then
				//	methodsUsedByCount := methodsUsedByCount + 1;
				//endif;
				
				
				
				if usedByFormUnitTest = "F" then
					if not formsUsedByArray.includes(meth2.getSchemaType().name) then
						formsUsedByArray.add(meth2.getSchemaType().name);
					endif;
				elseif usedByFormUnitTest = "U" then
					if not unitTestsUsedByArray.includes(meth2.getSchemaType().name &amp; "::" &amp; meth2.name) then
						unitTestsUsedByArray.add(meth2.getSchemaType().name &amp; "::" &amp; meth2.name);
					endif;
				else
					if checkClassMethodArray.includes(meth2.getSchemaType().name &amp; "::" &amp; meth2.name) then
						methodFound := true;
						checkClassMethodArray.remove(meth2.getSchemaType().name &amp; "::" &amp; meth2.name);
						if not methodsUsedByArray.includes(meth2.getSchemaType().name &amp; "::" &amp; meth2.name) then
							methodsUsedByArray.add(meth2.getSchemaType().name &amp; "::" &amp; meth2.name);
						endif;
					endif;				
				endif;
			endwhile;
			
			if not methodFound then
				continue;
			endif;
			
			if not formsUsedByArray.isEmpty() then
				write Tab &amp; "Used by Form(s):" &amp; CrLf &amp; Tab &amp; Tab &amp; formsUsedByArray.concatenate(CrLf &amp; Tab &amp; Tab);
			endif;
			if not unitTestsUsedByArray.isEmpty() then
				//write Tab &amp; "Used by Unit Test(s):" &amp; unitTestsUsedBy;
				write Tab &amp; "Used by Unit Test(s):" &amp; CrLf &amp; Tab &amp; Tab &amp; unitTestsUsedByArray.concatenate(CrLf &amp; Tab &amp; Tab);
				//file.writeLine(Tab &amp; "Used by Unit Test(s):" &amp; unitTestsUsedBy);
			endif;	
			if not methodsUsedByArray.isEmpty() then
				//write Tab &amp; "Used by Unit Test(s):" &amp; unitTestsUsedBy;
				write Tab &amp; "Used by Method(s):" &amp; CrLf &amp; Tab &amp; Tab &amp; methodsUsedByArray.concatenate(CrLf &amp; Tab &amp; Tab);
				//file.writeLine(Tab &amp; "Used by Unit Test(s):" &amp; unitTestsUsedBy);
			endif;
			
			file2.writeLine(usage.currentMethod.getSchemaType().name &amp; "::" &amp; usage.currentMethod.name);
			delete tempArray;
			create tempArray transient;
			delete tempArray2;
			create tempArray2 transient;
			formsIsBigger := false;
			if formsUsedByArray.size &gt; unitTestsUsedByArray.size then
				tempArray := formsUsedByArray;
				tempArray2 := unitTestsUsedByArray;
				formsIsBigger := true;
			else	
				tempArray := unitTestsUsedByArray;
				tempArray2 := formsUsedByArray;
			endif;
			
			tmpStr := null;
			foreach index in 1 to tempArray.size step 1 do
				
				tmpStr := ",";
				if formsIsBigger then
					tmpStr := tmpStr &amp; tempArray[index];
					if index &gt; tempArray2.size then
						tmpStr := tmpStr &amp; ",";
					else	
						tmpStr := tmpStr &amp; "," &amp; tempArray2[index];
					endif;
					if index &gt; methodsUsedByArray.size then
						tmpStr := tmpStr &amp; ",";
					else	
						tmpStr := tmpStr &amp; "," &amp; methodsUsedByArray[index];
					endif;
				else
					if index &gt; tempArray2.size then
						//tmpStr := tmpStr &amp; ",";
					else
						tmpStr := tmpStr &amp; tempArray2[index];
					endif;
					tmpStr := tmpStr &amp; "," &amp; tempArray[index];
					if index &gt; methodsUsedByArray.size then
						tmpStr := tmpStr &amp; ",";
					else	
						tmpStr := tmpStr &amp; "," &amp; methodsUsedByArray[index];
					endif;
				endif;
				file2.writeLine(tmpStr);
				
			endforeach;
			
		endforeach;
	
		write CrLf;
	
	endforeach;
	
	file2.writeLine("Not called by a Trx");
	foreach line in checkClassMethodArray do
		file2.writeLine(",,," &amp; line);
	endforeach;
	
epilog

	delete usage;
	delete classNameArray;
	delete methodNameArray;
	
	delete iter;
	
	delete classMethodNameArray;
	delete detailsArray;
	
	delete fileFolder;
	delete methodsUsedByArray;
	delete notFoundArray;
	
	delete tokens;
	
	delete checkClassMethodArray;
	
	delete file3;
	delete file2;
	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhTrxSpecialBish3" id="1052b5a6-61e6-4ae9-878a-af82c5581e6c">
        <source>mdhTrxSpecialBish3();

/*

Purpose:		Create a csv file with the details of TrxResponseTimeAnalysis from selected systems

Date			Who		Reason
03/02/2014		cnwmh5	Initial creation

*/

vars
	
	schema							: Schema;
	klass							: Class;
	meth							: Method;
	usage							: UM_MethodPropertyUsage;
	obj								: Object;
	file							: File;
	file2							: File;
	meth2							: Method;
		
	classNameArray					: StringArray;
	methodNameArray					: StringArray;
	schemaNameArray					: StringArray;
	classMethodNameArray			: StringArray;
	tokens							: StringArray;
	formsUsedByArray				: StringArray;
	unitTestsUsedByArray			: StringArray;
	tempArray						: StringArray;
	tempArray2						: StringArray;
	
	iter							: Iterator;

	className						: String;
	methodName						: String;
	methodClassName					: String;
	methodMethodName				: String;
	level							: Integer;
	index							: Integer;
	index2							: Integer;
	numIndentsStr					: String;
	usedByFormUnitTest				: Character;
	line 							: String;
	unitTestsUsedBy					: String;
	methodsUsedBy					: String;
	formsUsedBy						: String;
	indexZ							: Integer;
	unitTestCount					: Integer;
	tmpStr							: String;
	formsIsBigger					: Boolean;
	
begin


	// read in the file
	create classNameArray transient;
	create methodNameArray transient;
	create schemaNameArray transient;

	create tokens transient;
	create usage transient;
	create tempArray transient;
	create tempArray2 transient;
	
	create formsUsedByArray transient;
	create unitTestsUsedByArray transient;
	
	create file transient;
	file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	file.fileName := "c:\temp\bishFile2.txt";
	
	create file2 transient;
	file2.fileName := "c:\temp\UnitTestUsageCount.csv";
	if file2.isAvailable() then
		file2.purge();
	endif;
	file2.writeLine("Class / Method,Unit Test Count");
	
	while not file.endOfFile do
	
		line := file.readLine();
		
		tokens.clear();
		line.getTokensForDelimiter(" ", tokens);
		schemaNameArray.add(tokens[1]);
		classNameArray.add(tokens[2]);
		methodNameArray.add(tokens[3]);
	
	endwhile;


	foreach indexZ in 1 to schemaNameArray.size step 1 do
		
		schema := rootSchema.getSchema(schemaNameArray[indexZ]);
		if schema = null then
			continue;
		endif;
		
		klass := schema.getClass(classNameArray[indexZ]);
		if klass = null then
			continue;
		endif;
		
		meth := klass.getMethodInHTree(methodNameArray[indexZ]);
		if meth = null then
			continue;
		endif;
		
		level := 1;
		usage.clearCollections(true);
		usage.setCurrentMethod(meth);
		usage.addMethodToList(meth, level, true);
		
		//write CrLf &amp; CrLf;
		foreach index in 1 to usage.allRefs.size do
			meth := usage.allRefs[index].Method;
			numIndentsStr := null;
			foreach index2 in 1 to usage.refsByLevel[index] do
				numIndentsStr := numIndentsStr.trimBlanks() &amp; Tab;
			endforeach;
		endforeach;
		
		formsUsedBy := null;
		unitTestsUsedBy := null;
		methodsUsedBy := null;
		unitTestCount := 0;
		//formsUsedByArray.clear();
		unitTestsUsedByArray.clear();
		tempArray := null;
		tempArray2 := null;
		write CrLf &amp; CrLf &amp; usage.currentMethod.getSchemaType().name &amp; "::" &amp; usage.currentMethod.name &amp; CrLf;
		iter := usage.tempDictionary.createIterator;
		while iter.next(obj) do
			meth2 := obj.Method;
			usage.tempDictionary.getIteratorKeys(className, methodName, methodClassName, methodMethodName, usedByFormUnitTest, iter);
			//if usedByFormUnitTest = "F" then
				//if not formsUsedByArray.includes(meth2.getSchemaType().name) then
				//	formsUsedByArray.add(meth2.getSchemaType().name);
				//endif;
			//elseif usedByFormUnitTest = "U" then
			if usedByFormUnitTest = "U" then
				if not unitTestsUsedByArray.includes(meth2.getSchemaType().name &amp; "::" &amp; meth2.name) then
					unitTestsUsedByArray.add(meth2.getSchemaType().name &amp; "::" &amp; meth2.name);
				endif;
			else	
			endif;
		endwhile;
		
		//if not formsUsedByArray.isEmpty() then
		//	write Tab &amp; "Used by Form(s):" &amp; CrLf &amp; Tab &amp; Tab &amp; formsUsedByArray.concatenate(CrLf &amp; Tab &amp; Tab);
		//endif;
		if not unitTestsUsedByArray.isEmpty() then
			//write Tab &amp; "Used by Unit Test(s):" &amp; unitTestsUsedBy;
			write Tab &amp; "Used by Unit Test(s):" &amp; CrLf &amp; Tab &amp; Tab &amp; unitTestsUsedByArray.concatenate(CrLf &amp; Tab &amp; Tab);
			//file.writeLine(Tab &amp; "Used by Unit Test(s):" &amp; unitTestsUsedBy);
		endif;	
		
		file2.writeLine(usage.currentMethod.getSchemaType().name &amp; "::" &amp; usage.currentMethod.name &amp; "," &amp;
			unitTestsUsedByArray.size.String);
		
		/*
		file2.writeLine(usage.currentMethod.getSchemaType().name &amp; "::" &amp; usage.currentMethod.name);
		delete tempArray;
		create tempArray transient;
		delete tempArray2;
		create tempArray2 transient;
		formsIsBigger := false;
		if formsUsedByArray.size &gt; unitTestsUsedByArray.size then
			tempArray := formsUsedByArray;
			tempArray2 := unitTestsUsedByArray;
			formsIsBigger := true;
		else	
			tempArray := unitTestsUsedByArray;
			tempArray2 := formsUsedByArray;
		endif;
		
		tmpStr := null;
		foreach index in 1 to tempArray.size step 1 do
			
			tmpStr := ",";
			if formsIsBigger then
				tmpStr := tmpStr &amp; tempArray[index];
				if index &gt; tempArray2.size then
					tmpStr := tmpStr &amp; ",";
				else	
					tmpStr := tmpStr &amp; "," &amp; tempArray2[index];
				endif;
			else
				if index &gt; tempArray2.size then
					//tmpStr := tmpStr &amp; ",";
				else
					tmpStr := tmpStr &amp; tempArray2[index];
				endif;
				tmpStr := tmpStr &amp; "," &amp;tempArray[index];
			endif;
			file2.writeLine(tmpStr);
			
		endforeach;
		*/
		
		write CrLf;
	
	endforeach;
	
	
epilog

	delete usage;
	delete classNameArray;
	delete methodNameArray;
	
	delete iter;
	
	delete classMethodNameArray;
	
	delete schemaNameArray;
	delete tempArray;
	delete tempArray2;

	delete tokens;
	
	//delete formsUsedByArray;
	delete unitTestsUsedByArray;
	
	create file transient;
	
	
	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhTrxUsageDetails" id="0e50635a-a482-48a4-90d0-06b3465880ad">
        <source>mdhTrxUsageDetails();

/*

Purpose:		

Date			Who		Reason
31 January 2014	cnwmh5	Initial creation

*/

vars

	fileFolder					: FileFolder;
	fileNode					: FileNode;
	file						: File;
	
	systemArray					: StringArray;
	classMethArray				: StringArray;
	trxCountArray				: IntegerArray;
	
	line						: String;
	trxId						: String;
	trxCount					: Integer;
	pos							: Integer;
	clientName					: String;
	fileCount					: Integer;
	
begin

	create fileFolder transient;
	fileFolder.fileName := "c:\temp\";
	fileFolder.usePresentationFileSystem := true;
	fileFolder.mask := "*TransactionResponseTimeAnalysis*.csv";
	
	create systemArray transient;
	create classMethArray transient;
	create trxCountArray transient;
	foreach fileCount in 1 to (fileFolder.files.size + 1) do
		systemArray.add(null);
		classMethArray.add(null);
		trxCountArray.add(0);
	endforeach;
	
	
	fileCount := 2;
	foreach fileNode in fileFolder.files where fileNode.isKindOf(File) do
	
		pos := 1;
		clientName := fileNode.name.scanUntil("_", pos);
		systemArray[fileCount] := clientName;
		
		delete file;
		create file transient;
		file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
		file.fileName := fileNode.fileName;
		
		while not file.endOfFile do
		
			line := file.readLine();
			if not line.cnContains("TrxControl") then
				continue;
			endif;
			
			pos := 1;
			trxId := line.scanUntil(",", pos);
			pos := pos + 1;
			trxCount := line.scanUntil(",", pos).Integer;
			pos := 2;
			trxId := trxId.scanUntil('"', pos);
			
			classMethArray[fileCount] := trxId;
			trxCountArray[1] := trxCountArray[1] + trxCount;
			trxCountArray[fileCount] := trxCount;
						
			write clientName &amp; Tab &amp; trxId &amp; Tab &amp; trxCount.String;
			
		endwhile;
		
		fileCount := fileCount + 1;
	
	endforeach;
	
	///foreach fileCount in 2 to systemArray.size do
	///	write systemArray[fileCount] &amp; Tab &amp; classMethArray[fileCount] &amp; Tab &amp; trxCountArray[fileCount].String;
	///endforeach;
	
	

epilog

	delete fileFolder;
	delete file;
	
	delete systemArray;
	delete classMethArray;
	delete trxCountArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mdhTrxUsageDetailsNoTests" id="ba4c39a8-3e94-4def-a55d-f69d8a0466f9">
        <source>mdhTrxUsageDetailsNoTests();

/*

Purpose:		Create a csv file with the details of TrxResponseTimeAnalysis from selected systems

Date			Who		Reason
03/02/2014		cnwmh5	Initial creation

*/

vars
	
	schema							: Schema;
	schema1 						: Schema;
	klass							: Class;
	meth							: Method;
	usage							: UM_MethodPropertyUsage;
	obj								: Object;
	file							: File;
	meth2							: Method;
	fileFolder						: FileFolder;
	fileNode						: FileNode;
		
	classNameArray					: StringArray;
	methodNameArray					: StringArray;
	methodsDict						: MethodNDict;
	classMethodNameArray			: StringArray;
	detailsArray					: HugeStringArray;
	totalArray						: IntegerArray;
	tokens							: StringArray;
	
	iter							: Iterator;

	className						: String;
	methodName						: String;
	methodClassName					: String;
	methodMethodName				: String;
	originalClassName				: String;
	originalMethodName				: String;
	level							: Integer;
	index							: Integer;
	index2							: Integer;
	numIndentsStr					: String;
	usedByFormUnitTest				: Character;
	unitTestsUsedByCount			: Integer;
	formsUsedByCount				: Integer;
	methodsUsedByCount				: Integer;
	pos								: Integer;
	clientName						: String;
	line 							: String;
	trxId							: String;
	trxCount						: Integer;
	commaCount						: Integer;
	fileCount						: Integer;
	baseCommaCount					: Integer;
	
begin

	schema := rootSchema.getSchema("PortSchema");
	if schema = null then
		write "Unable to find schema (PortSchema).  Exiting JadeScript";
		return;
	endif;
	
	create classMethodNameArray transient;
	classMethodNameArray.add(null);
	
	create detailsArray transient;
	detailsArray.add("trxClass/Method,Cls / Mth,trxClass,trxMethod,Form Count,UnitTest Count,Method Count");
	
	tokens := detailsArray[1].cnGetTokens(",");	
	baseCommaCount := tokens.size - 1;  // + 1;
	
	create totalArray transient;
	totalArray.add(0);
	
	create usage transient;
		
	create classNameArray transient;
	classNameArray.add("CM_TrxControlCreateAgent");
	classNameArray.add("CM_TrxControlDeleteAgent");
	classNameArray.add("CM_TrxControlUpdateAgent");
	classNameArray.add("CM_TrxControlRTAgent");
	
	create methodNameArray transient;
	//methodNameArray.add("trxUpdateEDITIPackComplete");
	
	foreach className in classNameArray do
	
		// get the class
		klass := schema.getClass(className);
		if klass = null then
			schema1 := rootSchema.getSchema("MobileServerSchema");
			klass := schema1.getClass(className);
			if klass = null then
				continue;
			endif;
		endif;
		
		originalClassName := klass.name;
		
		// get the methods
		methodsDict := klass.cnGetMethods();
			
		// process the methods
		foreach meth in methodsDict do
			
			if not methodNameArray.isEmpty() and not methodNameArray.includes(meth.name) then
				continue;
			endif;
	
			originalMethodName := meth.name;
	
			level := 1;
			usage.clearCollections(true);
			usage.setCurrentMethod(meth);
			usage.addMethodToList(meth, level, true);
			
			write CrLf &amp; CrLf;
			foreach index in 1 to usage.allRefs.size do
				meth := usage.allRefs[index].Method;
				numIndentsStr := null;
				foreach index2 in 1 to usage.refsByLevel[index] do
					numIndentsStr := numIndentsStr.trimBlanks() &amp; Tab;
				endforeach;
				write usage.refsByLevel[index].String &amp; numIndentsStr &amp; meth.getSchema().name &amp; Tab &amp; meth.getSchemaType().name &amp; Tab &amp; meth.name;
			endforeach;
			
			formsUsedByCount := 0;
			unitTestsUsedByCount := 0;
			methodsUsedByCount := 0;
			iter := usage.tempDictionary.createIterator;
			while iter.next(obj) do
				meth2 := obj.Method;
				usage.tempDictionary.getIteratorKeys(className, methodName, methodClassName, methodMethodName, usedByFormUnitTest, iter);
				if usedByFormUnitTest = "F" then
					formsUsedByCount := formsUsedByCount + 1;
				elseif usedByFormUnitTest = "U" then
					unitTestsUsedByCount := unitTestsUsedByCount + 1;
				elseif usedByFormUnitTest = "M" then
					methodsUsedByCount := methodsUsedByCount + 1;
				endif;
			endwhile;
			
			classMethodNameArray.add((originalClassName &amp; "::" &amp; originalMethodName)[1:50]);
			detailsArray.add(originalClassName &amp; "::" &amp; originalMethodName &amp; "," &amp; (originalClassName &amp; "::" &amp; originalMethodName)[1:50] &amp; "," &amp;
				originalClassName &amp; "," &amp; originalMethodName &amp; "," &amp; formsUsedByCount.String &amp;  "," &amp; 
				unitTestsUsedByCount.String &amp; "," &amp; methodsUsedByCount.String);
			totalArray.add(0);
						
		endforeach;
	
	endforeach;
	
	// now read through the files extracted and create the combined file.
	create fileFolder transient;
	fileFolder.fileName := "c:\TransactionResponseTimeAnalysis\";
	fileFolder.usePresentationFileSystem := true;
	fileFolder.mask := "*TransactionResponseTimeAnalysis*.csv";
	
	fileCount := 0;
	foreach fileNode in fileFolder.files where fileNode.isKindOf(File) do
	
		fileCount := fileCount + 1;
		
		delete file;
		create file transient;
		file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
		file.fileName := fileNode.fileName;
		
		while not file.endOfFile do
		
			line := file.readLine();
			if not line.cnContains("TrxControl") then
				continue;
			endif;
			
			pos := 1;
			trxId := line.scanUntil(",", pos);
			pos := pos + 1;
			trxCount := line.scanUntil(",", pos).Integer;
			pos := 2;
			trxId := trxId.scanUntil('"', pos);
			
			index := classMethodNameArray.indexOf(trxId);
			if index &gt; 0 then
				totalArray[index] := totalArray[index] + trxCount;
			endif;
			
		endwhile;
	
	endforeach;
	file.close();
		
	delete file;
	create file transient;
	file.fileName := "c:\temp\" &amp; method.name &amp; "TRTAUsageCount.csv";
	if file.isAvailable then
		file.purge;
	endif;
	
	file.writeLine(detailsArray[1] &amp; ",Total");
	foreach index in 2 to detailsArray.size step 1 do
		file.writeLine(detailsArray[index] &amp; "," &amp; totalArray[index].String);
	endforeach;
	
epilog

	delete usage;
	delete classNameArray;
	delete methodNameArray;
	
	delete iter;
	
	delete classMethodNameArray;
	delete detailsArray;
	
	delete fileFolder;
	
	
	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhUNLExtract30062" id="433113c8-e10e-46b8-abb6-9e710a804599">
        <source>mdhUNLExtract30062();

/*

Purpose:		Check the XLAT translatable string for no text.

Date			Who		Reason
16 July 2012	cnwmh5	Initial creation

*/

vars
	constantCategory		: ConstantCategory;
	constant				: Constant;
	meth					: Method;
	category				: XLAT_Category;
	tmpConstantDict			: ConstantNDict;
	portScm					: Schema;
	
	alreadyReadArray		: IntegerArray;
	constantDupArray		: IntegerArray;
	
	allMethodRefs			: MethodSet;
	
	hasReferences			: Boolean;
	constantId				: Integer;
	textNull				: Boolean;
	indexOf					: Integer;
	
begin
	
	app.initialize();
	
	portScm := rootSchema.getSchema("PortSchema");
	
	create alreadyReadArray transient;
	create allMethodRefs transient;
	create constantDupArray transient;
	
	foreach category in app.myRoot.allXLAT_Categories do
	
		if category.constantCategoryName = XLAT_Menus or
		   category.constantCategoryName = XLAT_ReportNames or
		   category.constantCategoryName = EntTableRows then
			continue;
		endif;

		constantCategory := portScm.getCategory(category.constantCategoryName);
	
		tmpConstantDict := constantCategory.getConstants();
		
		alreadyReadArray.clear();
		constantDupArray.clear();
	
		// work out the duplicate ids and add to duplicate array
		foreach constant in tmpConstantDict do
			constantId := constant.valueAsInteger;
			indexOf := alreadyReadArray.indexOf(constantId);
			//textNull := constant.text = null;
			if indexOf &gt; 0 then
				if not constantDupArray.includes(constantId) then
					constantDupArray.add(constantId);
				endif;
			else
				alreadyReadArray.add(constantId);
			endif;
		
		endforeach;
			
		// now have the duplicates get the details for the duplicate
		foreach constant in tmpConstantDict do
			constantId := constant.valueAsInteger;
			
			if not constantDupArray.includes(constantId) then
				continue;
			endif;
			
			constantCategory := constant.GlobalConstant.getCategory();
			
			// if has methods then write details
			allMethodRefs.clear();
			constant.getMethodRefs(allMethodRefs);
			//hasReferences := false;
			foreach meth in allMethodRefs do
				//hasReferences := true;
				write  meth.getSchemaType().schema.name &amp; CrLf &amp; "Method " &amp; meth.getSchemaType().name &amp; " " &amp; meth.name;
			endforeach;
			
			// if doesn't have any methods then write details
			//if not hasReferences then
			//	write constantCategory.name &amp; Tab &amp; constant.name &amp; Tab &amp; constantId.String &amp; Tab &amp; Tab;
			//endif;
						
		endforeach;
		
	endforeach;
	
epilog

	delete alreadyReadArray;
	delete allMethodRefs;
	delete constantDupArray;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="mdhUTCashFailJulyAugust2019" id="8a0705ba-9534-4209-9b75-5bd33b1e80eb">
        <source>mdhUTCashFailJulyAugust2019();
/*

Purpose:		Find all the tests that were failing July / August 2019	

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2019	jlgmh5	Initial creation

*/

vars

	root 					: UM_Root;
	classMethod				: UM_UnitTestClassMethod;
	testResult				: UM_UnitTestResult;
	
	iter					: Iterator;
	iter2					: Iterator;

	startTS					: TimeStamp;
	endTS					: TimeStamp;
	
	currentMethod			: String;
	failingDates			: String;

begin

	app.initialize();

	startTS := startTS.setDateTime(2019, 07, 01, 00, 00, 00, 00);
	endTS := endTS.setDateTime(2019, 08, 31, 23, 59, 59, 00);
	
	root := UM_Root.firstInstance;
	if root = null then
		app.msgBox("Unable to find instance of UM_Root.  Exiting Jadescript...", "UM_Root Error", 
			MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	iter := root.allRunnableUTClassesMethods.createIterator;
	root.allRunnableUTClassesMethods.startKeyGeq("UT_Cash", "", iter);
	
	while iter.next(classMethod) do
	
		if classMethod.className &lt;&gt; "UT_Cash" then
			break;
		endif;
		
		if classMethod.methodName = "tUpdateCashOptions" then
		//	write 'debugging';
		endif;
		
		if currentMethod &lt;&gt; classMethod.methodName then
			if currentMethod &lt;&gt; null  and failingDates &lt;&gt; null then
				write "UT_Cash::" &amp; currentMethod ; //  &amp; Tab &amp; "Failed on the following date(s): " &amp; failingDates;
				failingDates := null;
			endif;
			currentMethod := classMethod.methodName;		
		endif;
	
		delete iter2;
		iter2 := classMethod.allUnitTestResults.createIterator;
		classMethod.allUnitTestResults.startKeyGeq(endTS, iter2);
		while iter2.next(testResult) do
		
			if testResult.getMyTestRunRunDate() &lt; startTS.Date then
				break;
			endif;
			
	
		///	if classMethod.methodName = "tUpdateCashOptions" then
		///		write testResult.String &amp; Tab &amp; testResult.hasFailed.String &amp; Tab &amp; testResult.result.String &amp; Tab &amp; 
		///			testResult.getMyTestRunRunDate().String;
		//	endif;
		
			if testResult.hasFailed then
				if failingDates.length &gt; 0 then
					failingDates := failingDates &amp; " ; ";
				endif;
				failingDates := failingDates.trimBlanks() &amp; testResult.getMyTestRunRunDate().format("dd/MM/yyyy");
			endif;
		
		endwhile;
	
	endwhile;
	
	if currentMethod &lt;&gt; null  then
		write "UT_Cash::" &amp; currentMethod &amp; Tab &amp; "Failed on the following date(s): " &amp; failingDates;
		failingDates := null;
	endif;
	

epilog

	delete iter;
	delete iter2;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhXLATFormMethodMonthlyCut" id="d41f25f7-1893-4a43-b2aa-b345585df507">
        <source>mdhXLATFormMethodMonthlyCut();

/*

Purpose:		Generate translateForm Method - For CUT ONLY	

Date			Who		Reason
23/05/2015		cnwmh5	Initial creation

*/

vars

	verAdmin					: UT_Verification_Admin;
	runTestDailyOnSave 			: UM_UnitTestRun;
	
	userSummaryDict 			: CM_AssociationDict;

begin

	app.initialize();

	create verAdmin transient;
	//create runTestDailyOnSave transient;
	create userSummaryDict transient;

	verAdmin.sendMsgWithIOParams('vGenXLATFormMethod_MDH', userSummaryDict);

epilog

	delete verAdmin;
	//delete runTestDailyOnSave;
	delete userSummaryDict;

end;</source>
    </JadeMethod>
    <JadeMethod name="methodCountPerClass" id="d17ff72e-1b5b-4940-8928-28cc2bd08b91">
        <source>methodCountPerClass();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2012	cnwmc5	Initial creation

*/
constants
	Capitals	: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
	
vars
	testCount		: Integer;
	ignoredCount	: Integer;
	
	klass				: Class;
	meth				: Method;
	
	classes				: ClassColl;
	methodsDict			: MethodNDict;
	
	iter				: Iterator;
	
	itemsFoundArray		: StringArray512;
	
	str					: String;
	msgStr				: String;
	methSource			: String;
	sourceLine			: String;
	lineDetails			: String;
	
	totalCount			: Integer;
	lineCount			: Integer;
	length				: Integer;
	posCrLf				: Integer;
	trxPos				: Integer;
	
	flag				: Boolean;
	
begin
	// get the class
	klass := currentSchema.getClass("UT_DSL");
	if klass = null then
		return;
	endif;
	
	// get all the subclasses
	create classes transient;
	klass.allLocalSubclasses(classes);
	classes.add(klass);
	
	testCount := 0;
	ignoredCount := 0;
	
	// read through all the classes
	foreach klass in classes do
		
		methodsDict := klass.cnGetMethods();
		delete iter;
		iter := methodsDict.createIterator;
		
		// read through all the methods for that class
		while iter.next(meth) do
		
			if meth.name[1:1] = "t" and Capitals.pos(meth.name[2:1], 1) &gt; 0 then
				testCount := testCount + 1;
			endif;
			if meth.name[1:1] = "i" and Capitals.pos(meth.name[2:1], 1) &gt; 0 then
				ignoredCount := ignoredCount + 1;
			endif;
		endwhile;
		
		write klass.name &amp; Tab &amp; "Test Count:" &amp; Tab &amp; testCount.String &amp; Tab &amp; "Ignored Count:" &amp; Tab &amp; ignoredCount.String;
		testCount := 0;
		ignoredCount := 0;
		
	endforeach;
	
epilog
	delete classes;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="methodSource" id="e7326894-c5dd-498a-93b9-d043540b62e8">
        <source>methodSource();
//02 July 2009	cnwdw1	
//
vars
	schema: Schema;
	testClass: Class;
	testMethod: Method;
	profile: UT_Profile;
	linePos: Integer;
	line, token: String;
	tokens : StringArray;
begin
	schema := rootSchema.getSchema("JMTUnitTest");
	testClass := schema.getClass("UT_AutoPlan");
	testMethod := testClass.getMethod("tAutoplanOf40ToRightEdgeOfTA");
	linePos := 1;
	testMethod.getSource.cnEcGetNextLine(linePos);
	line :=  testMethod.getSource.cnEcGetNextLine(linePos);
	create tokens transient;
	line.replaceChar(Tab, ' ');
	line.getTokensForDelimiter(" ", tokens);
	foreach token in tokens do
		if token[1:3] = "cnw" then
			write token;
		endif;
	endforeach;
	delete tokens;
end;</source>
    </JadeMethod>
