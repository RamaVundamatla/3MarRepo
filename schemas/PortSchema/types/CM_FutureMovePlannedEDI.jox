<Class name="CM_FutureMovePlannedEDI" id="e5c123d0-3834-47bd-9e4c-2e647707c20e">
    <superclass name="CM_FutureMovePlanned"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <JadeMethod name="setEDIBayPlanController" id="5239981f-cac6-42de-b795-d1eebb82e53d">
        <updating/>
        <source>setEDIBayPlanController(_controller : CM_VoyageEDIBayPlanController) updating;
/*
------------------------------------------------------------------------
Created:			21 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars

begin
	self.myVoyageEDIBayPlanController := _controller;
end;</source>
        <Parameter name="_controller" type="CM_VoyageEDIBayPlanController"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2a2bce4c-03a1-454b-a8f1-e1dce6a8e4cc">
        <updating/>
        <source>setForCreate(_control : CMIF_MoveController; _moveType : Integer; arrayIndex : Integer ) updating;
/*
------------------------------------------------------------------------
Created:			21 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
											

------------------------------------------------------------------------
*/
begin
	if _moveType &lt;&gt; TI_FutureMoveEDI then
		app.raiseCMException1(Err_InvalidFutureMove, 'Not an EDI move for edi class', null, null);
		return;
	endif;
	self.myTerminal := _control.myToTerminal;
	self.moveType := _moveType;
	self.setLocations(_control.allToLocations);
	if _control.myTrackedItem = null then
		//-------------------------------
		//EDI moves have a special "null" future move as an array element placeholder
		//on all of the CM_SlotControllers that DONT have a TI future move for THIS SLOT.
		//This way, we can ask for the "x"th futuremove for an EDI bayplan display, and in 
		//this instance, display null (i.e. no trackeditem in this edi bayplan).
		//DQ 10/Feb/2003
		//-------------------------------
		return;
	endif;
	_control.myTrackedItem.setPlannedFutureMove(arrayIndex, self);
end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="arrayIndex" type="Integer"/>
    </JadeMethod>
</Class>
