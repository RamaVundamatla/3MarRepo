    <JadeMethod name="getInvoiceType" id="79b55eaf-13a5-4602-b80e-8a8f8758b702">
        <source>getInvoiceType(_description : String) : CM_InvoiceDesc;
// return the invoice type for the given description (is unique by description)
vars
	inv : CM_InvoiceDesc;
	bank	: CM_Bank;
begin
	bank := self.getTerminal().getDefaultCompanyBank();
	foreach inv in bank.invoiceTypes  discreteLock do
		if inv.description = _description then
			return inv;
		endif;
	endforeach;
	
	return null;
end;
</source>
