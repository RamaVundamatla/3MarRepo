<Class name="CM_YardAllocationTemplate" id="cf881c5f-3652-4173-8988-0e9f1dfae522">
    <superclass name="CM_YardAllocation"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This is really a "snap shot".  The templates as per the GUI are in class CM_YATemplate</text>
    <DbClassMap file="yardAllocations"/>
    <ExplicitInverseRef name="myYATemplateGroup" id="aec2ba1a-5ad9-416c-843c-95db77600110">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_YATemplateGroup"/>
        <access>readonly</access>
        <Inverse name="CM_YATemplateGroup::allYardAllocations"/>
    </ExplicitInverseRef>
    <JadeMethod name="buildCurrentAllocation" id="15374f33-dba8-457b-a04f-994dc3e24d37">
        <source>buildCurrentAllocation(_terminal : CM_Terminal);

// Created by cnwdvb1 on 08 August 2006

vars

	ya	: CM_YardAllocation;

begin

	// Create new allocation.
	create ya persistent;
	// Set up all from template.
	ya.setForCreateFromTemplate(self, _terminal);
	
	// Recalculate the priorities based on current system settings.
	ya.recalculateCriteriaPriorities();

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="includeInYardDisplays" id="16287f4c-2885-4852-b6d5-3c02696798ce">
        <source>includeInYardDisplays(): Boolean;

// Created by cnwdvb1 on 07 August 2006

vars

begin
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
