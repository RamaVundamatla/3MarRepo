	product		: CM_Product;
begin
	foreach object in self.allDetails do
		if object.isKindOf(CMIF_ReserveTIDetail) then
			cmifDetail := object.CMIF_ReserveTIDetail;
			if currentObject.isKindOf(CM_CargoType) then
				cargoType := currentObject.CM_CargoType;
				if cmifDetail.myCargoType = cargoType then
					totalOnsite := totalOnsite + cmifDetail.totalOnsite;
