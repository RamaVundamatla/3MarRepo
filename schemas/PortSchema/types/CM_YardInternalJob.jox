    <JadeMethod name="shouldAuditProperty" id="5d08fc5a-ad81-4092-9076-c3f007bd5ddf">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

vars
	propName	: String;
	
begin
	propName := _property.name;
	if propName = CM_YardInternalJob::allTrackedItems.name or
	  propName = CM_YardInternalJob::allTrackedItemsSwap.name then
	   	return false;
	endif;
	
	return inheritMethod(_rootClass, _property);
