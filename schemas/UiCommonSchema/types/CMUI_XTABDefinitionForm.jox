    <JadeMethod name="refreshColumns" id="dfe465fe-ed36-4260-838e-f544199e00d3">
        <source>refreshColumns() protected;

// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/12/2009	cnwcs5		Simplified setting width/heights - always done on create
// ---------------------------------------------------------------------------

vars
	obj			: Object;
	count		: Integer;
	btn			: Button;
	btnWidth	: Real;		// cnwcs5 16/12/2009
begin
	btnWidth := self.btnField.width;	// cnwcs5 16/12/2009
	
	foreach obj in self.allButtons_columns do
		btn			:= obj.Button;
		btn.left	:= count * btnWidth;
		btn.top		:= 1;			// cnwcs5 16/12/2009
		count 		:= count + 1;
	endforeach;
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="refreshFields" id="3c0686ab-7dd4-4646-a46b-dc2ed1b0ae33">
        <source>refreshFields() protected;

// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/12/2009	cnwcs5		Simplified setting width/heights - always done on create
// ---------------------------------------------------------------------------

vars
	obj				: Object;
	count			: Integer;
	start			: Integer;
	btn				: Button;
	fieldTop		: Real;
	frmWidth		: Real;
	btnHeight, btnWidth	: Real;
begin
	btnHeight	:= self.btnField.height;	// cnwcs5 16/12/2009
	btnWidth	:= self.btnField.width;		// cnwcs5 16/12/2009
	
//	// we want to centre the buttons across their parent so first figure out where the first one has to go
//	start	:= ( self.frmCells.width - ( self.allButtons_cells.size * self.frmRows.width ) ) div 2;
//	if start &lt; 0 then
//		start := 0;
//	endif;
//	// Above does not seem to work correctly - when come in from the display form - so default to 10.
	start		:= 10;
	fieldTop	:= 20;						// arbitrary position
	frmWidth	:= frmCells.width - start;
	
	foreach obj in self.allButtons_cells do
		btn			:= obj.Button;
		btn.left	:= start + ( count * btnWidth );	// cnwcs5 16/12/2009
		btn.top		:= fieldTop;
		count 		:= count + 1;
		if start + ( ( count + 1 ) * btnWidth ) &gt;= frmWidth then	// cnwcs5 16/12/2009
			// the next button will be too many for 1 row so drop it down.
			count 		:= null;
			fieldTop	:= fieldTop + btnHeight;		// cnwcs5 16/12/2009
		endif;
		//btn.height	:= btnDisplayHeight;
	endforeach;
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="refreshRows" id="cc2bf334-4554-4db0-b485-533b19644079">
        <source>refreshRows() protected;

// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	16/12/2009	cnwcs5		Simplified setting width/heights - always done on create
// ---------------------------------------------------------------------------

vars
	obj			: Object;
	count		: Integer;
	btn			: Button;
	btnHeight	: Real;		// cnwcs5 16/12/2009
begin
	btnHeight := self.btnField.height;
	
	foreach obj in self.allButtons_rows do
		btn			:= obj.Button;
		btn.left	:= 1;						// cnwcs5 16/12/2009
		btn.top		:= count * btnHeight;		// cnwcs5 16/12/2009
		count 		:= count + 1;
	endforeach;
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
