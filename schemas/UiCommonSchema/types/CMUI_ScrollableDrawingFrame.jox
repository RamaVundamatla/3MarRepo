    <JadeMethod name="getLegendString" id="2d5d52f1-65b1-40a5-aba3-ae909ea556fe">
        <source>getLegendString(_theCode : String) : String;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theCode : String;
	theViewMode : Integer;
	theString : String;
	anOp : CM_Operator;
	aVoy : CM_Voyage;
	aTemp : CM_TempRange;
	aCom : CM_Commodity;
	aCon : CM_ConsigneeConsignor;
	aPort : CM_Port;
	anISO : CM_ISOTypeGroup;
	carrier: CM_Carrier;
	
begin
	theViewMode := self.viewMode;
	theCode := _theCode.trimBlanks;
	
	if theViewMode = VIEW_OPERATOR then
		anOp := app.myRoot.allOperators[theCode];
		if anOp &lt;&gt; null then
			theString := anOp.description.trimBlanks;
		else
			theString := theCode;
		endif;
		
	elseif theViewMode = VIEW_VOYAGE then
		aVoy := self.myTerminal.lookupVoyage (theCode, null, false);
		if aVoy &lt;&gt; null then
			theString := aVoy.description.trimBlanks;
		else
			theString := theCode;
		endif;
		
	elseif theViewMode = VIEW_TEMPERATURE then
		theString := theCode;
	elseif theViewMode = VIEW_COMMODITY then
		aCom := app.myRoot.allCommodities[theCode];
		if aCom &lt;&gt; null then
			theString := aCom.description.trimBlanks;
		else
			theString := theCode;
		endif;
	elseif theViewMode = VIEW_WEIGHT then
		theString := theCode;
	elseif theViewMode = VIEW_CONSIGNEE then
		aCon := app.myRoot.allConsigneeConsignors[theCode];
		if aCon &lt;&gt; null then
			theString := aCon.description.trimBlanks;
		else
			theString := theCode;
		endif;
	elseif theViewMode = VIEW_DISPORT or theViewMode = VIEW_LOADPORT then
		//aPort := app.myRoot.allPorts[theCode];
		aPort := app.myRoot.allPorts[theCode];
		if aPort &lt;&gt; null then
			theString := aPort.description.trimBlanks;
		else
			theString := theCode;
		endif;
	elseif theViewMode = VIEW_STATUS then
		theString := theCode;
	elseif theViewMode = VIEW_ISOGROUP then
		anISO := app.myRoot.allISOTypeGroups[theCode];
		if anISO &lt;&gt; null then
			theString := anISO.description.trimBlanks;
		else
			theString := theCode;
		endif;
	elseif theViewMode = VIEW_CARRIERIN or theViewMode = VIEW_CARRIEROUT then	// 12/6/17 MAP TFS4209
		carrier := app.myRoot.allCarriers[theCode];
		if carrier &lt;&gt; null then
			theString := carrier.description.trimBlanks();
		else
			theString := theCode;
		endif;

	endif;

	return theString;
end;</source>
        <Parameter name="_theCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPointFromLC" id="073dbf3e-4a26-4c9f-9c6b-9f785f938045">
        <updating/>
        <source>getPointFromLC(_controller : CM_LocationsController) : CMUI_GridPoint updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 18/05/2021	navdap1		TFS 49899 MTN Labour on Block for New GC Areas
// ---------------------------------------------------------------------------
vars
	lRow, lCol : Integer;
	lGridArea : CMUI_GridArea;
	aGridPoint, lGridPoint : CMUI_GridPoint;
	maxRow, maxCol : Integer;
	aGC		: CM_GridController;
	aGA		: CM_GridArea;
	
begin
	aGridPoint := null;
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. ");	
	if _controller.isKindOf(CM_GridController) then
		aGC := _controller.CM_GridController;
		aGA := aGC.myTerminalArea.CM_GridArea;
		foreach lGridArea in self.allGridAreasByRowColumn do
			if lGridArea.flipHorizontal then
				maxCol := lGridArea.allGridColumns.size;
				lCol := (maxCol - aGA.allGridColumns.indexOf(aGC.myGridColumn)) + 1;
			else
//				lCol := aGA.allGridColumns.indexOf(aGC.myGridColumn);
				lCol := aGC.myGridColumn.column;
			endif;
			if lGridArea.flipVertical then
				maxRow := lGridArea.allGridRows.size;
				lRow := (maxRow - aGA.allGridRows.indexOf(aGC.myGridRow)) + 1;
			else
//				lRow := aGA.allGridRows.indexOf(aGC.myGridRow);
				lRow := aGC.myGridRow.row;
			endif;
		
			lGridPoint := lGridArea.allGridPoints[lRow,lCol];


			if lGridPoint &lt;&gt; null then
				if lGridPoint.myLocationsController = _controller then
					aGridPoint := lGridPoint;
					break;
				endif;
			endif;
		endforeach;				
	endif;
	// TFS 3422 handle general cargo areas as well, added CM_IrregularBlockController test
	if _controller.isKindOf(CM_LogController) or _controller.isKindOf(CM_SlotController) or
	   //_controller.isKindOf(CM_IrregularBlockController) then														// TFS 49899
	   _controller.isKindOf(CM_IrregularBlockController) or _controller.isKindOf(CM_GeneralCargoAllocGroup) then	// TFS 49899
		foreach lGridArea in self.allGridAreasByRowColumn do
			foreach lGridPoint in lGridArea.allGridPoints do
				if lGridPoint.myLocationsController = _controller then
					aGridPoint := lGridPoint;
					break;
				endif;
			endforeach;
		endforeach;				
	endif;

	return aGridPoint;
end;</source>
        <Parameter name="_controller" type="CM_LocationsController"/>
        <ReturnType type="CMUI_GridPoint"/>
    </JadeMethod>
    <JadeMethod name="getPointFromTI" id="73b5c5d0-540f-47b7-8fa3-194a8223932e">
        <updating/>
        <source>getPointFromTI(_aTI : CM_TrackedItem; _theX : Real output; _theY : Real output; _theGridPoint : CMUI_GridPoint output )  updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	theTI, lTarget : CM_TrackedItem;
	theIndex, lCol : Integer;
	
	theX, theY : Real;
	lGridArea : CMUI_GridArea;
	theGridPoint, lGridPoint : CMUI_GridPoint;
	lMoveController : CMIF_MoveController;
	theLC : CM_LocationsController;
	
begin
	theGridPoint := null;
	theTI := _aTI;
	
	if self.displayMode = DISPLAY_MODE_ACTUAL then
		theLC := theTI.getPrimaryLocation(REAL_MODE);
	elseif self.displayMode  = DISPLAY_MODE_QUEUE then
		theLC := theTI.getPrimaryLocation(PLANNING_MODE);
	elseif self.displayMode  = DISPLAY_MODE_PLAN then
		theLC := theTI.getPrimaryLocation(QUEUE_MODE);
	endif;
	
	if theLC &lt;&gt; null then
		theGridPoint := self.getPointFromLC(theLC);

		if theGridPoint &lt;&gt; null then
			theX := (theGridPoint.x1 + 5);
			if self.displayMode = DISPLAY_MODE_ACTUAL then
				theIndex := theGridPoint.allTrackedItems.indexOf(theTI);
			elseif self.displayMode  = DISPLAY_MODE_QUEUE then
				theIndex := theGridPoint.allQueuedTrackedItems.indexOf(theTI);
			elseif self.displayMode  = DISPLAY_MODE_PLAN then
				theIndex := theGridPoint.allPlannedTrackedItems.indexOf(theTI);
			endif;
			theY := theGridPoint.getYPosFromIdx(theIndex);
		endif;
	endif;
	
	_theX := theX;
	_theY := theY;
	_theGridPoint :=	theGridPoint;
end;</source>
        <Parameter name="_aTI" type="CM_TrackedItem"/>
        <Parameter name="_theX" type="Real" usage="output"/>
        <Parameter name="_theY" type="Real" usage="output"/>
        <Parameter name="_theGridPoint" type="CMUI_GridPoint" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getRowEndPositionFromY" id="9ee5bdf4-2343-4b19-a620-6f1be953623c">
        <source>getRowEndPositionFromY(_y : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		Pass in a y pixel position and this will work out which row in the scrollable area you have clicked on
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow, idx : Integer;

	tmpPoint	: CMUI_GridPoint;
	tmpRow		: CMUI_GridRow;
		
begin
	foreach theRow in 1 to self.allRowEndPositions.size do : outerLoop
		if self.allRowEndPositions[theRow] &gt;= _y then
			break;
		endif;
	endforeach;
	
	return theRow;
end;</source>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowHeight" id="c354adbd-41a8-4977-88b6-1a300cb1ecbe">
        <source>getRowHeight(_row : Integer) : Real;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	totalHeight, theHeight, aHeight : Real;
	idx : Integer;
	
begin
	if _row &lt; 1 then
		return 0;
	endif;
	
	if _row &lt;= self.allRowEndPositions.size then
		if _row = 1 then
			return self.allRowEndPositions[_row];
		else
			theHeight := self.allRowEndPositions[_row];
			totalHeight := self.allRowEndPositions[_row - 1];
			return	(theHeight - totalHeight);
		endif;
	endif;
	
	return 0;
end;</source>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalColumns" id="3ae0f70b-07e2-4ff0-b717-9a83436afb66">
        <source>getTotalColumns() : Integer;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
