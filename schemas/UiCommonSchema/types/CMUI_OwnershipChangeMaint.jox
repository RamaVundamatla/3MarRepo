    <JadeMethod name="doPermissions" id="45d70193-14bb-412a-9728-b8b60358f418">
        <source>doPermissions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
30/11/2023	navkc1 ChangeRequest 58254 Task 58255: UI - New Permission
06 Sep 2024 navrv30	Bug 65913: EUP | Not able to Save INCO and Invoice Contract (COO) - 54837
*/

vars
	isCOOApproved	: Boolean;
begin
	isCOOApproved := (self.myOwnershipChange &lt;&gt; null and self.myOwnershipChange.isApproved()); // ### TFS CR 64164 TASK 64733 20JUNE024 NAVAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) or  isCOOApproved then
		self.btnRemove.enabled := false;
		self.btnAddItems.enabled := false;
		// ### TFS CR 64164 TASK 64733 20JUNE024 NAVAB1 self.btnUpdate.enabled := false; - should be able to see the detail
		//self.btnApprove.enabled := false; 30/11/2023	navkc1 ChangeRequest 58254 Task 58255
		self.tblData.userInputEnabled := false;	
		self.btnClose.enabled := true;
		self.btnAttachment.enabled := true;
		//self.btnSave.enabled := false;	//06 Sep 2024 navrv30	Bug 65913
		self.txtRefNumber.enabled := false;
		self.txtAddFreeDaysNew.enabled := false;
		self.txtCondition.enabled := false;
		self.txtRemarks.enabled := false;
		self.cmbStorageOperator.enabled := false;
		self.cmbNewOperator.enabled := false;
		//self.cmbIncoTerm.enabled := false;	//06 Sep 2024 navrv30	Bug 65913
		self.cmbFrightForwarder.enabled := false; 
		self.mskCOOFromStart.enabled 	:= false;
		self.mskCOOFromStartTime.enabled := false;
		self.chkSelectAll.enabled := false; // ### TFS CR 64164 TASK 64733 20JUNE024 NAVAB1
		self.tblData.readOnly := true; // ### TFS CR 64164 TASK 64733 20JUNE024 NAVAB1
	endif;
	
	//30/11/2023	navkc1 ChangeRequest 58254 Task 58255
	if not app.myCurrentUserCan(self.myTerminal, PmInvOwnershipChangeApprove) or isCOOApproved then
		self.btnApprove.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="9c24f598-1ba6-43ef-bfd8-0555090c28f3">
        <updating/>
        <source>doSave()updating;
/*

