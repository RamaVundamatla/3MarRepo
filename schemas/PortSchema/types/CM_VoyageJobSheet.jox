    <JadeMethod name="getCraneType" id="ee541d27-6710-4a50-8da7-4e55b7aa62e2">
        <source>getCraneType() : Integer;
// ---------------------------------------------------------------------------
// Created:		31 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aC : CM_Crane;
begin
	aC := self.getMyCrane();
	
	if aC &lt;&gt; null then
		//if aC.canTwinLift then
		if aC.machineLiftType = TWIN_LIFT then//ccms1595 27/11/07
			return JobTypePriority_Crane2;
		else
			return JobTypePriority_Crane1;
		endif;
	endif;
	
	return JobTypePriority_Crane1;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCurrentBay" id="595c8ba1-5b21-4607-acd8-1918ecf073eb">
        <source>getCurrentBay() : CM_Bay;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	aBay,aftBay : CM_Bay;
	theDateTime	: TimeStamp;
	invalid 		: Boolean;
	currentJob		: CM_Job;
	
begin
	// a null bay means set crane at rest

	if self.myVoyage.arrivedDT = null then // the ship not here
		aBay := null;
	elseif self.myCurrentJob = null then // not working yet
		aBay := null;
	else
//		if global.isValidObject(self.myCurrentJob) then
		currentJob := self.myCurrentJob;
		if currentJob &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, currentJob, invalid);
			currentJob.CM_VoyageJob.getBays(aBay,aftBay);
		endif;
	endif;
	return aBay;
end;</source>
        <ReturnType type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="getCurrentBayOrdinal" id="7be9a9b6-c5c4-4b65-9de7-04bc20d59b05">
        <source>getCurrentBayOrdinal(_flipH : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aBay,aftBay : CM_Bay;
begin
	aBay := self.getCurrentBay();
	
	if aBay = null then
//		return 1;
		return -1;	// cnwvu1	31/10/2006	PAR12644  (for the special case when crane is resting)
	else

		if _flipH then
			return (self.myVoyage.myCellularVoyageStructure.allBayVoyagesByOrdinal.size - aBay.ordinalBay + 1);
		else
			return aBay.ordinalBay;
		endif;

	endif;
end;</source>
        <Parameter name="_flipH" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDelaysOverlapping" id="4aab4687-5ee4-4104-bfe7-cfbc142fb6eb">
        <source>getDelaysOverlapping( _delays : CM_ObjectSet input; _startTS : TimeStamp; _endTS : TimeStamp);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2012	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	delay : CM_Delay;
	crane : CM_Crane;
	wp : CM_WorkPoint;

begin

	iter := self.myVoyage.allDelays.createIterator;
	while iter.next( delay ) do
		if delay.overlapsRange( _startTS, _endTS ) then
			//_delays.addExclusive( delay );
			_delays.addNoDuplicates( delay, false );
		endif;
	endwhile;
	
	
	crane := self.getMyCrane();
	if crane &lt;&gt; null then
	//	delete iter;
	//	iter := crane.allDelays.createIterator;
	//	while iter.next( delay ) do
	//		if delay.overlapsRange( _startTS, _endTS ) then
	//			_delays.addExclusive( delay );
	//		endif;
	//	endwhile;
		// 29 Sep 2012	NDL	Par 30357
		crane.allDelays.getDelaysForPeriod( _delays, _startTS, _endTS );
	endif;
	
	
	wp := self.getMyWorkPoint;
	if wp &lt;&gt; null then
	//	delete iter;
	//	iter := wp.allDelays.createIterator;
	//	while iter.next( delay ) do
	//		if delay.overlapsRange( _startTS, _endTS ) then
	//			_delays.addExclusive( delay );
	//		endif;
	//	endwhile;
		// 29 Sep 2012	NDL	Par 30357
		wp.allDelays.getDelaysForPeriod( _delays, _startTS, _endTS );
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_delays" type="CM_ObjectSet" usage="input"/>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDownHoursForTsRange" id="2bf1bceb-f4a0-4283-9121-79de5bcb60ff">
        <source>getDownHoursForTsRange( _startTS : TimeStamp; _endTS : TimeStamp ):Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

begin

	if not _startTS.Date.isValid
	or not _endTS.Date.isValid
	or not self.includesWPOpHrs()	//we are not using Work Point Operating Hours for this voyage/crane
	then
		return 0;
	endif;
	
	return self.myVoyage.getDownHoursForTsRange( self.crane, _startTS, _endTS );
	

epilog

end;</source>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getEndDateFromReceiveRelease" id="5e146a5b-d92a-488a-b2a0-55be22987e86">
        <source>getEndDateFromReceiveRelease() : TimeStamp;

/*
Purpose:			
Date				Who			Reason
APRIL 2017		CNWAB1		Initial creation
*/


vars
	tmpWorkEnded : TimeStamp;
	aTran : CM_TITransaction;
	ls : Boolean;
begin
	tmpWorkEnded := self.myVoyage.arrivedDT;
	
	aTran := self.allShipReceivals.last;
	
	if aTran &lt;&gt; null then
		if aTran.dateTime.isValid then
			tmpWorkEnded :=  aTran.dateTime;
		endif;
	endif;
	
	aTran := self.allShipReleases.last;
	if aTran &lt;&gt; null then
		if aTran.dateTime.isValid and aTran.dateTime &gt; tmpWorkEnded then
			tmpWorkEnded :=  aTran.dateTime;
		endif;	
	endif;

	return tmpWorkEnded;
epilog

end;
</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getHatchLashStats" id="4b89d631-f3ea-4083-ab40-a4a1fe7b8fb7">
