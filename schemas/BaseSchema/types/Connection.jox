<Class name="Connection">
    <JadeMethod name="cnEcGetStateDescription" id="ed2d8e95-dd70-4a06-bed4-250681952e46">
        <source>cnEcGetStateDescription():String;
// --------------------------------------------------------------------------------
// Created:		21 November 2000 by cnwdad1
//
// Purpose:		Returns a description of the current state of the connection.
//
// Parameters:	None
//
// Returns:		A translatable string corresponding to the connection state.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	connectionState	: Integer;
	
begin
	connectionState	:=	self.state;
	
	if connectionState = Connection.Disconnected then
		return $CNEC_CONNSTATE_DISCONNECTED;
	elseif connectionState = Connection.Connecting then
		return $CNEC_CONNSTATE_CONNECTING;
	elseif connectionState = Connection.Connected then
		return $CNEC_CONNSTATE_CONNECTED;
	elseif connectionState = Connection.Disconnecting then
		return $CNEC_CONNSTATE_DISCONNECTING;
	else
		return $CNEC_CONNSTATE_UNKNOWN(connectionState.String);
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="fileExceptionHandler" id="8d8a5014-02bb-4584-b320-199e6b900b08">
