    <JadeMethod name="incrementDepartureTime" id="59005a2d-6bf8-4022-916d-834f9497ffc0">
        <source>incrementDepartureTime(arrivedDT : TimeStamp; departedDT : TimeStamp);
/*
AJA 3/8/00: The method simply changes the departure date time of the form to match the dwell time
derived from the two timestamp arguments. Can be used to prefill the voyage details from a voyage
template or to amend departure date by a consistent time period based on arrival time
*/

vars
    dwellHrs : Integer;
    estimatedDeptTime : TimeStamp;
	estimatedDeptLocal: TimeStamp;
begin
	if myCurrentWorkingVoyage = null then
		return;
	endif;
	dwellHrs := arrivedDT.differenceInHours(departedDT);

	estimatedDeptTime := myCurrentWorkingVoyage.arrivedDT.changeByXXHours(dwellHrs);
    myCurrentWorkingVoyage.departedDT := estimatedDeptTime;

	estimatedDeptLocal := self.systemToLocalTime(estimatedDeptTime);	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
	txtDateDepart.setDate(estimatedDeptLocal.Date);
	txtTimeDepart.setTime(estimatedDeptLocal.Time);
end;</source>
        <Parameter name="arrivedDT" type="TimeStamp"/>
        <Parameter name="departedDT" type="TimeStamp"/>
    </JadeMethod>
