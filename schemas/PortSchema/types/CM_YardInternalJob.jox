24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars

begin
	
	if not self.allRequests.isEmpty then
		return self.allRequests.first.isPlanOnPickup;
	endif;
epilog

end;</source>
