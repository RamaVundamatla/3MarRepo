    <JadeMethod name="getDetailForRemoteQuery" id="625092e3-9abe-4c07-bf73-153e06a7a8e4">
        <source>getDetailForRemoteQuery() : String;

// cnwdvb1 10 June 2003 

vars

	type,
	treatment,
	length 				: CM_Code;
	strArrayType,
	strArrayTreatment	: StringArray;
	iter				: Iterator;
	theCode,
	theType,
	theTreatment,
	theSpecies,
	theGrade,
	detail				: String;
	typeRef				: CM_LogType;
	treatmentRef		: CM_LogTreatment;
	lengthRef			: CM_LogLength;

begin

	if self.notAvailableForEntry then
		return null;
	endif;
	
	theSpecies	:= self.myLogSpecies.code;
	theGrade	:= self.code;
	
	create strArrayTreatment transient;
	create strArrayType transient;
	
	iter := self.allLogTypes.createIterator();
	strArrayType.add(null);
	while iter.next(type) do
		if type.notAvailableForEntry then
			continue;
		endif;
		strArrayType.add(type.code);
	endwhile;
	delete iter;
	
	iter := self.allLogTreatments.createIterator();
	strArrayTreatment.add(null);
	while iter.next(treatment) do
		if treatment.notAvailableForEntry then
			continue;
		endif;
		strArrayTreatment.add(treatment.code);
	endwhile;
	delete iter;	
	
	iter := self.allLogLengths.createIterator();
	foreach theType in strArrayType do
		foreach theTreatment in strArrayTreatment do
			iter.reset();
			while iter.next(length) do
				if length.notAvailableForEntry then
					continue;
				endif;
				theCode := length.code;
				detail := detail &amp; self.formatAsXML(XML_CODE, theSpecies &amp; ',' &amp; theGrade &amp; 
				',' &amp; theType &amp; ',' &amp; theTreatment &amp; ',' &amp; theCode);
			endwhile;
		endforeach;
	endforeach;
	return detail;
	
epilog
	delete strArrayTreatment;
	delete strArrayType;
	delete iter;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDetailForRemoteQueryV3" id="28114ada-4fed-42bd-b52e-f3a04741b51a">
        <source>getDetailForRemoteQueryV3() : String;

// cnwdvb1 10 June 2003 

vars

	type,
	treatment,
	length 				: CM_Code;
	strArrayType,
	strArrayTreatment	: StringArray;
	iter				: Iterator;
	theCode,
	theType,
	theTreatment,
	theSpecies,
	theGrade,
	detail,
	theMinSED,
	theMaxSED,
	theMinMeanSED,
	theMaxMeanSED		: String;
	typeRef				: CM_LogType;
	treatmentRef		: CM_LogTreatment;
	lengthRef			: CM_LogLength;

begin

	if self.notAvailableForEntry then
		return null;
	endif;
	
	theSpecies	:= self.myLogSpecies.code;
	theGrade	:= self.code;
	theMinSED		:= self.minSED.String;
	theMaxSED		:= self.maxSED.String;
	theMinMeanSED	:= self.minMeanSED.String;
	theMaxMeanSED	:= self.maxMeanSED.String;
	
	create strArrayTreatment transient;
	create strArrayType transient;
	
	iter := self.allLogTypes.createIterator;
	strArrayType.add(null);
	while iter.next(type) do
		if type.notAvailableForEntry then
			continue;
		endif;
		strArrayType.add(type.code);
	endwhile;
	delete iter;
	
	iter := self.allLogTreatments.createIterator;
	strArrayTreatment.add(null);
	while iter.next(treatment) do
		if treatment.notAvailableForEntry then
			continue;
		endif;
		strArrayTreatment.add(treatment.code);
	endwhile;
	delete iter;	
	
	iter := self.allLogLengths.createIterator;
	foreach theType in strArrayType do
		foreach theTreatment in strArrayTreatment do
			iter.reset();
			while iter.next(length) do
				if length.notAvailableForEntry then
					continue;
				endif;
				theCode := length.code;
				detail := detail &amp; self.formatAsXML(XML_CODE, theSpecies &amp; ',' &amp; theGrade &amp; 
				',' &amp; theType &amp; ',' &amp; theTreatment &amp; ',' &amp; theCode &amp; ',' &amp; theMinSED &amp; ',' &amp; theMaxSED &amp;
				',' &amp;  theMinMeanSED &amp; ',' &amp; theMaxMeanSED);
			endwhile;
		endforeach;
	endforeach;
	return detail;
	
epilog
	delete strArrayTreatment;
	delete strArrayType;
	delete iter;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProductsForTypeTreatLength" id="aed5bf9e-a697-4585-9a1b-e0973e58004c">
        <source>getProductsForTypeTreatLength(_operator : CM_Operator; _typeCode, _treatCode, _lengthCode : String; _productSet : CM_ProductSet input);
// ---------------------------------------------------------------------------
// Created:     30 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	logType		: CM_LogType;
	logTreat	: CM_LogTreatment;
	logLength	: CM_LogLength;
	product		: CM_Product;
	
begin

	if _operator = null and
	   _typeCode = null and
	   _treatCode = null and
	   _lengthCode = null then
	   	self.allProducts.copy(_productSet);
	   	return;
	endif;
	
	logType		:= self.allLogTypes[_typeCode];
	logTreat	:= self.allLogTreatments[_treatCode];
	logLength	:= self.allLogLengths[_lengthCode];
	foreach product in self.allProducts do
		if _operator &lt;&gt; null and logType &lt;&gt; null and
		   (not logType.myCodeGroupLogSpecs.allOperators.includes(_operator)) then
		   	continue;
		endif;
		if logType &lt;&gt; null and 
		   (not logType.allProducts.includes(product)) then
			continue;
		endif;
		if logTreat &lt;&gt; null and 
		   (not logTreat.allProducts.includes(product)) then
			continue;
		endif;
		if logLength &lt;&gt; null and 
		   (not logLength.allProducts.includes(product)) then
			continue;
		endif;
		_productSet.add(product);
	endforeach;

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_typeCode" type="String"/>
        <Parameter name="_treatCode" type="String"/>
        <Parameter name="_lengthCode" type="String"/>
        <Parameter name="_productSet" type="CM_ProductSet" usage="input"/>
    </JadeMethod>
