<PrimType name="Boolean">
    <JadeMethod name="jssFormat" id="88a9ae6f-4e6f-484e-8786-27eaa159c1e3">
        <source>jssFormat(pTrueValue:String; pFalseValue:String):String;
//	Returns the string appropriate for the cuurent true/false value of self.
vars
	trueString	: String;
	falseString	: String;

begin
	// If no values supplied use default.

	if pTrueValue.trimBlanks = null then
		trueString	:=	$JSS_TRUE;
	else
		trueString	:=	pTrueValue;
	endif;

	if pFalseValue.trimBlanks = null then
		falseString	:=	$JSS_FALSE;
	else
		falseString	:=	pFalseValue;
	endif;

	if self	then
		return trueString;
	else
		return falseString;
	endif;
end;</source>
        <text>___________________________________________________________________________

