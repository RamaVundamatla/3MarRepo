    <JadeMethod name="btnCancel_click" id="b66be1df-f138-45d6-9342-f1b8d7393818">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 September 2009	cnwjk3	Initial creation

*/

vars

begin
	self.reason := null;
	self.modalResult := IDCANCEL;
	self.unloadForm();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOK_click" id="9de636b2-4819-46e9-bd34-2dc170fc12ef">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOK_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 September 2009	cnwjk3	Initial creation

*/

vars

begin
	self.reason := self.txtReason.text.trimBlanks();
	self.modalResult := IDOK;
	self.unloadForm();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTitle" id="c71c8116-0fe7-4dfc-b24e-82b8c64f6c28">
        <updating/>
        <source>setTitle(_title : String) updating;
/*
Purpose:		 // PAR 34269	
Date		Who		Reason
06 June 2014	cnwab1	Initial creation
*/

vars

begin
	self.txtTitle	 := _title;
epilog

end;</source>
        <Parameter name="_title" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="27875784-0181-433a-993d-de08f19e2bb0">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 September 2009	cnwjk3	Initial creation

*/

vars

begin
	inheritMethod();
	
	if self.txtTitle &lt;&gt; null then
		self.caption := self.caption	 &amp; " " &amp; self.txtTitle;
	endif;
	
	self.height := self.height-20;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c5daff4a-aa5e-44ff-a01a-a89692e99b6a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0011457, locale);
	btnCancel.translateCaption(Xlat_0011458, locale);
	btnOK.translateCaption(Xlat_0011459, locale);
	lblReason.translateCaption(Xlat_0011460, locale);
	txtReason.translateBubbleHelp(Xlat_0018157, locale);
end;</source>
    </JadeMethod>
</GUIClass>
