<Class name="CnEcCurrencyRange" id="6a8a445e-91a1-42ef-879b-494ae7e45375">
    <superclass name="CnEcValueRange"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
