    <JadeMethod name="getRelatedMoves" id="ffd54d2f-b3b2-4edc-ab58-92e65a9773a3">
        <source>getRelatedMoves( _txns: CM_TITransactionByDateTypeDict io);
/*
Purpose: Return a collection of all the moves related to this move. 
         Will include all the Move/Pickup/Setdowns legs

Date		Who		Reason
09 May 2012	cnwdw1	Initial creation
*/
vars
	txns: CM_TITransactionByDateTypeDict;
	txn: CM_TITransaction;
	craneTxn, moveTxn, lastMove: CM_Move;
	setdown: CM_SetDown;
	lc: CM_LocationsController;
	tmpFoundHeight: Integer;
	iter: Iterator;

begin

	lastMove := self;
	if not self.isMachineMove then
		_txns.add(lastMove);
		return;
	endif;
	
	iter := lastMove.myTrackedItem.allTransactions.createIterator();
	iter.startAtObject(lastMove);
	iter.back(txn);
	
	// Voyage Load
	craneTxn := getCraneTxnFor(lastMove);
	if craneTxn &lt;&gt; null then
		_txns.add(craneTxn);
		create setdown transient;
		setdown.setFromCraneMoveTxn(lastMove.CM_SetDown, craneTxn);
		lastMove := setdown;
	endif;
	
	_txns.add(lastMove);
	
	while iter.back(txn) do
		if txn.class = CM_Pickup and lastMove.class = CM_SetDown then
			_txns.add(txn);
			self.myTerminal.findLocationFromString(txn.CM_Move.targetLocn, true, lc, tmpFoundHeight);
			lastMove := txn.CM_Move;
			if lc = null or lc.myTerminalArea = null or not lc.myTerminalArea.isInterchangeArea then
				// Found a pickup from terminal area so this is start of the move
				break;
			endif;
		elseif txn.class = CM_SetDown and lastMove.class = CM_Pickup then
			_txns.add(txn);
			lastMove := txn.CM_Move;
		endif;
	endwhile;

	// Voyage Discharge
	craneTxn := getCraneTxnFor(lastMove);
	if craneTxn &lt;&gt; null then
		_txns.add(craneTxn);
	endif;
	
epilog
	delete txns;
	delete iter;
end;</source>
        <Parameter name="_txns" type="CM_TITransactionByDateTypeDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getSourceLocationsController" id="523e3068-e164-4c1d-a598-12c028976b5c">
        <source>getSourceLocationsController() : CM_LocationsController;
/*
07 Dec 2022 navma1 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
*/
vars
	lc				: CM_LocationsController;
	tmpFoundHeight  : Integer;
begin
	
	if self.sourceLocn &lt;&gt; app.getErrorString(Nowhere) then													//13.12.2022 navma1 #52499
		self.myTerminal.findLocationFromString(self.sourceLocn, true, lc, tmpFoundHeight);
	endif;
	
	return lc;
epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
