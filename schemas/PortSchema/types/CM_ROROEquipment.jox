<Class name="CM_ROROEquipment" id="68c09377-ca84-428b-a351-b9b03a601737">
    <superclass name="CM_DeckItem"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This is refered to as "Equipment" on the user side</text>
    <DbClassMap file="vesselStructures"/>
    <PrimAttribute name="weight" id="88d6f1f7-98bc-4185-b6de-cc235e734c1d">
        <precision>12</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="cloneMySelf" id="014ed6dd-4f9e-4a7e-a7b7-a1349d5359da">
        <source>cloneMySelf(_newDeck : CM_Deck; _copy : Boolean) : CM_ROROEquipment;
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars
	deckItem : CM_DeckItem;
	newMe : SelfType;
begin
	newMe := self.cloneSelf(_copy);


	newMe.myDeck := _newDeck;
	
	if self.myLayout &lt;&gt; null then
		newMe.myLayout := self.myLayout.cloneMySelf(newMe, newMe.getLayer(), _copy);
	endif;
	
	return newMe;
epilog

end;</source>
        <Parameter name="_newDeck" type="CM_Deck"/>
        <Parameter name="_copy" type="Boolean"/>
        <ReturnType type="CM_ROROEquipment"/>
    </JadeMethod>
    <JadeMethod name="delete" id="5f8d98eb-358a-4f84-a6ce-322efc42c306">
        <updating/>
        <source>delete() updating;
/*
Date		    Who			Reason
17 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	if self.isTransient then
		return;
	endif;
	
	if self.myDeck &lt;&gt; null then
		self.myDeck.causeEvent(EVENT_DECK_ITEM_DELETE,false,self);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="92cf5819-e936-4846-9754-8489407407d6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Date		    Who			Reason
16 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	if _attrName = ETRow_IsMovable then
		return null;
	elseif _attrName = ETRow_Length then
		return null;
	elseif _attrName = ETRow_Width then
		return null;
	elseif _attrName = ETRow_MaxClearHeight  then
		return null;
	elseif _attrName = ETRow_MaxLoadAxel then
		return null;
	elseif _attrName= ETRow_MaxLoadM2 then
		return null;
	elseif _attrName = ETRow_MaxTotalWeight then
		return null;
	elseif _attrName = ETRow_TotalWeight then
		return self.weight.asStringJMT();
	else
		return inheritMethod(_attrName, _short);
	endif;
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
