    <JadeMethod name="setValueForRow" id="c94e5dfa-4111-4690-857c-90d42a82cf0f">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2009	cnwas3	Initial creation

*/

vars
	filePath : String;
begin
	if _rowName = ETRow_BgpCreateInvoiceCharges then
		self.chkCreateInvoiceCharges:=_value.Boolean;
	elseif _rowName = ETRow_BgpAutoSelectorQuery then		
		self.mySelectorQuery:=_value.CM_MenuUserQuery;
	elseif _rowName = ETRow_ServerFilePath then
		filePath := _value.String;
		if filePath &lt;&gt; null and
		   filePath[filePath.length()] &lt;&gt; "\" then
			filePath := filePath &amp; "\";
		endif;
		self.networkPath := filePath;
	elseif _rowName = ETRow_BgpSnapShotDefinition then
		self.mySSDefinition := _value.CM_OutputFormat_SS;
	else
		inheritMethod(_rowName, _value);
	endif;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="975ff573-379d-40fb-b912-e637ef95961a">
        <source>validate();
// ---------------------------------------------------------------------------
// Created:     21 December 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();

	if self.myTerminal = null then		// #24990 15/07/2010											
	//	app.raiseCMException1(REQUIRED_FIELD,app.getErrorString(Terminal), ETRow_BgpAutoSelectorQuery, null);
		app.raiseCMException1(Input_required_field_Required,app.getErrorString(Terminal), ETRow_BgpAutoSelectorQuery, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	/* par 21800 moved to snapshot summary definition now
	if self.mySelectorQuery = null then																		//cnwas3 par 24528 begin
		app.raiseCMException1(REQUIRED_FIELD,app.getErrorString(Selector_query_txt), ETRow_BgpAutoSelectorQuery, null);
		return;
	endif;
	*/
	
	if self.mySSDefinition = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Snapshot_definition), ETRow_BgpSnapShotDefinition, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Snapshot_definition), ETRow_BgpSnapShotDefinition, null); // cnwdb2	PAR 35364
		return;
	endif;																											//cnwas3 par 24528 end
	
	if self.mySelectorQuery &lt;&gt; null then	//07 Feb 2011	NDL	Par 26631
	
		if self.mySSDefinition.mode &lt;&gt; self.mySelectorQuery.queryMode then
		//	app.raiseCMException1(REQUIRED_FIELD,app.getErrorString(Modes_different), ETRow_BgpAutoUser, null);	//cnwas3 par 24528 - changed to use xlat_exceptions
			app.raiseCMException1(Input_required_field_Required,app.getErrorString(Modes_different), ETRow_BgpAutoUser, null);	// cnwdb2	PAR 35364
		endif;
		
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
</Class>
