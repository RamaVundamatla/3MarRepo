    <JadeMethod name="getTerminal" id="19192ae7-cf07-4d1e-b870-48d55e92246e">
        <source>getTerminal() : CM_Terminal;
/*
Date		Who		Reason
14 Aug 2006	cnwer1	Initial creation - PAR#xxxx
23 Oct 2012	cnwcs5	par 29653 - change of return type for getForm
*/
vars
	ta		:CM_TerminalArea;
	form	:CM_BaseForm;
begin
    ta := self.myCurrentTerminalArea;
	
	if ta &lt;&gt; null then
        return ta.myTerminal;
    endif;

	form := self.getForm;
	
	if form &lt;&gt; null then
		return form.myTerminal;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getTilePlan" id="8a01d2ca-0808-48d6-acb1-23c9e7c2e291">
        <source>getTilePlan()protected;

/*

Purpose:	Creates a tile plan which is simple an integer array each integer is a row and the integer value is the number of columns

			if tiled it will try to create a nice tile plan ...
				e.g. 3 x 3  4 x 4 etc if remaining dock bars to add will add from the bottom up so would be 3,3,4 
				
			if not just 1 column per row		


Return Value:		


Date		Who		Reason
28 July 2006	cnwer1	Initial creation - PAR#xxxx

*/

vars
	num,
	i, j, k, h,v : Integer;
	x,y , rem 	: Real;
begin
	num:=self.allDockBars.size;
	if num = 0 then
		return;
	endif;
	
	if tiled then
		x:= num.Real.sqrt;
		if x.Integer = x then
			y:=x.Integer;
		else
			y:=num div x;
			rem:= num - (x.Integer * y);
		endif;
	
		h:=x.Integer.max(y.Integer).Integer;
		v:=x.Integer.min(y.Integer).Integer;
	
		dockTilePlan[v]:=null;
		
		k:=1;
		
		i:= v;
		while i &gt; 0 do
			if rem &gt; 0 then
				rem:= rem - 1;
			else
				k:= 0;
			endif;
			dockTilePlan[i]:=h  +  k;
			i:=i -1;
		endwhile;
	else
		i:=1;
		while i &lt; num do			
			dockTilePlan[i]:=1;
			i:=i+1;
		endwhile;
		
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleUserNotification" id="63dac042-06fc-4c6e-a4d8-352a3dc43363">
        <source>handleUserNotification(	_event : Integer; _obj : CM_Object input);
/*
Date		Who		Reason
16 Aug 2006	cnwer1	Initial creation - PAR#xxxx
24/09/2009	cnwcs5	par 21698 - vehcile not showing in table under interchange area
23/10/2012	cnwcs5	par 29653 - hide completed jobs
22/11/2017  cnwma1  TFS #7692 QNS - System buffering
*/
vars
	vehicle 	: CM_Vehicle;
	wle 		: CM_WorkListEntry;
	roadJob 	: CM_RoadJob;
	obj			: CMIF_RoadOpObject;
	rowIdx 		: Integer;
	idx			: Integer;
	expanded 	: Boolean;
	form		: YRD_RoadOperationsForm;
	topRow		: Integer;
	table		: CM_GroupingTable;
	invalidWLE  : Boolean;
	expandedObjects : ObjectSet;
	edition : Integer;
begin 
	//epr par 35702 CCMS 2457 17/2/15
	form := self.getForm;
	if _obj.isKindOf(CM_WorkListEntry) then
		wle := _obj.CM_WorkListEntry;	
		obj	:= self.findCMIF_RoadOpObjWithWLE(wle);	
		on Exception do app.handleDeletedObject(exception,wle,invalidWLE);
		if obj = null then
			// worklist entry not shown anywhere		
			//14 mar 2012	NDL	Par 28969 - But maybe it should be!!
			if wle.job &lt;&gt; null and wle.job.isKindOf(CM_RoadJob) then
				roadJob := wle.job.CM_RoadJob;
				
				if roadJob &lt;&gt; null then
					//epr TFS 7828 24/11/17
					if self.checkLogDocket then
						// cnwmc5 - 30 Jan 2015 - PAR 35528
						if roadJob.containsLogDocket() then
							return;
						endif;	
					endif;
					vehicle := roadJob.myVehicle;					
					if vehicle &lt;&gt; null then
						obj := self.findCMIF_RoadOpObjWithVehicle(vehicle);		
						//epr par 35702 5/3/15
						if form &lt;&gt; null then
							
							if form.dkcVehicles.visible then   				//22/11/2017 cnwma1 TFS #7828
								idx := form.lstJobs.findObject(vehicle);								
								if idx &gt; 0 then
									expanded :=	form.lstJobs.itemExpanded[idx];
									//21 Dec 2016	NDL	TFS 3123
									create expandedObjects transient;
									if expanded then
										form.getExpandedForByCriteriaList( expandedObjects, vehicle, false );
									endif;
									form.lstJobsUpdateVehicle(vehicle, expanded, false, expandedObjects);
								endif;
							endif;
						endif;
					endif;
				endif;
			endif;
		endif;
		
		//epr par 35702 3/3/15
		if obj = null then
			return;
		endif;
		
		if _event = WLE_Update_Event then
			//06 Dec 2017	NDL	TFS 8030
			edition := wle.edition;
			if invalidWLE then
				return;
			endif;
			obj.updateDataTableObject(wle);
			
		elseif _event = WLE_Create_Event then
			//06 Dec 2017	NDL	TFS 8030
			edition := wle.edition;
			if invalidWLE then
				return;
			endif;
			if obj.addDataTableObject(wle) then	// cms10/09/2009
				obj.allWLEs.add(wle);
			endif;								// cms10/09/2009
			
		elseif _event = WLE_Delete_Event then
			obj.removeDataTableObject(wle);
			obj.allWLEs.remove(wle);	
			//epr par 35702 CCMS 2457 17/2/15
			if form &lt;&gt; null then
				if form.dkcVehicles.visible then   				//22/11/2017 cnwma1 TFS #7828
					idx := form.lstJobs.findObject(wle);				
					if idx &gt; 0 then
						form.lstJobs.removeItem(idx);
					endif;
				endif;
			endif;
		elseif _event = EVENT_WLE_COMPLETE then
			//wle has been completed need to change row colour
			obj.myDataTable.findObjectInRow(_obj,rowIdx);
			obj.setTableRowColour(_obj,rowIdx);
		endif;
		
	elseif _obj.isKindOf(CM_Vehicle) then
		vehicle := _obj.CM_Vehicle;
		obj 	:= self.findCMIF_RoadOpObjWithVehicle(_obj.CM_Vehicle);
		
		if obj &lt;&gt; null then
			if _event = Vehicle_VTA_Area_Update then
				// remove from existing tables;
				obj.removeVehicleFromDataTable(vehicle,false);			
				obj.refreshCaptions;
				
				// add to new area
				obj := self.getCMIFRoadOpObjFromVehicle(vehicle);	
				
				if obj &lt;&gt; null then
					obj.addVehicleToDataTable(vehicle);

					obj.resortDataTable;	// par 21698
				endif;
				
			elseif _event = RoadJob_Delete_Event then
				//remove from existing tables;
				obj.removeVehicleFromDataTable(vehicle,true);
				obj.reloadDataTable(); // PAR 18175 cnwgb1 13.8.08
				
			elseif _event = Vehicle_Update_Event then
				if obj &lt;&gt; null then
					obj.updateDataTableObject(_obj);
				endif;			
			endif;
		endif;
		
	elseif _obj.isKindOf(CM_RoadJob) then
		roadJob := _obj.CM_RoadJob;
		vehicle := roadJob.myVehicle;
		obj 	:= self.findCMIF_RoadOpObjWithVehicle(vehicle);
		
		//epr TFS 7828 24/11/17
		if self.checkLogDocket then
			// cnwmc5 - 30 Jan 2015 - PAR 35528
			if roadJob.containsLogDocket() then
				return;
			endif;	
		endif;
		
		if _event = RoadJob_Delete_Event then
			//remove from existing tables;
			if obj &lt;&gt; null then
				obj.removeVehicleFromDataTable(vehicle,true);
				obj.reloadDataTable(); // PAR 18175 cnwgb1 13.8.08
			endif;
			
		elseif  _event = RoadJob_Create_Event then
			//add to new area
			obj := self.getCMIFRoadOpObjFromVehicle(vehicle);	
			
			if obj &lt;&gt; null then
				obj.addVehicleToDataTable(vehicle);
				
				obj.resortDataTable;	// par 21698
			endif;
			
		elseif _event = RoadJob_Update_Event then
			if obj = null then 										// PAR 17703
				obj := self.getCMIFRoadOpObjFromVehicle(vehicle); 	// PAR 17703
			endif; 													// PAR 17703
			
			if obj &lt;&gt; null then
				obj.addVehicleToDataTable(vehicle); 				// PAR 17703
				
				//06 Sep 2012	NDL	Par 29668
				table 	:= obj.myDataTable;
				topRow 	:= table.topRow;
				
				obj.reloadDataTable();
				
				//06 Sep 2012	NDL	Par 29668
				if topRow &gt; table.fixedRows and topRow &lt;= table.rows then
					table.topRow := topRow;
				endif;
				
			endif;
		endif;
	endif;
	
	//change which proceed options are enabled disabled
	self.changeProceedOptionsEnabled;
epilog
	if obj&lt;&gt; null then
		obj.refreshCaptions(); 
	endif;
	delete expandedObjects;
end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="hideAllDynamicMenuItems" id="c245e13e-f51a-4360-b607-6715a2f88eae">
        <source>hideAllDynamicMenuItems();
/*
Date		Who		Reason
15 August 2006	cnwer1	Initial creation - PAR#xxxx
*/
vars
	roadOpObject : CMIF_RoadOpObject;
	menu 		: Object;
begin
	foreach roadOpObject in self.allCMIFRoadOpObjects do
		foreach menu in roadOpObject.allMenuItems do
			menu.MenuItem.visible:=false;
		endforeach;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initController" id="4433154d-57a9-4499-90a0-8f80112f4537">
        <updating/>
        <source>initController(	_jobSheet :CM_RoadJobSheet;
					_baseDockBar	: JadeDockBar input;
					_baseDockContainer : JadeDockContainer input;
					_dockAreaHeightPCent : Real;
					_tiled : Boolean) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	roadOpObj 	: CMIF_RoadOpObject;
	preGate : CMIF_RoadOpPreGate;
	yard 	: CMIF_RoadOpYard;
	lanesIn : CMIF_RoadOpInLanes;
	lanesOut : CMIF_RoadOpOutLanes;
	areas : IntegerArray;
	areasVisible : BooleanArray;
begin
	self.myJobSheet := _jobSheet;
	
	create areas transient;
	create areasVisible transient;

	create roadOpObj as CMIF_RoadOpOutLanes transient;
	self.allCMIFRoadOpObjects[RoadOpsForm_GateOut]:=roadOpObj;	
	areas.add(1);
	areasVisible.add(true);

	create roadOpObj as CMIF_RoadOpInLanes transient;
	self.allCMIFRoadOpObjects[RoadOpsForm_GateIn]:=roadOpObj;	
	areas.add(2);
	areasVisible.add(true);
		
	create roadOpObj as CMIF_RoadOpYard  transient;
	self.allCMIFRoadOpObjects[RoadOpsForm_Yard]:=roadOpObj;	
	areas.add(3);
	areasVisible.add(true);
	
	create roadOpObj as CMIF_RoadOpPreGate transient;
	self.allCMIFRoadOpObjects[RoadOpsForm_PreGate]:=roadOpObj;
	areas.add(4);
	areasVisible.add(true);
	
	self.tiled := _tiled;
	self.myBaseDockBar:=_baseDockBar;	
	self.myBaseDockContainer:=_baseDockContainer;
	self.dockAreaHeightPCent:=_dockAreaHeightPCent;
	self.allDockContainers.add(_baseDockContainer);
	
	self.buildDockBars();
	self.setTiled(self.tiled);							//+cnwml2 PAR21536
	self.doShowHideAreas(areas,areasVisible);
	
	//epr TFS 7828 24/11/17
	self.maxElapsedMins := self.getTerminal.getConfig(GateElapsedTimeExceeded).Integer;
	self.checkLogDocket:= self.getForm.checkLogDocket;
epilog
	delete areas;
	delete areasVisible;
end;</source>
        <Parameter name="_jobSheet" type="CM_RoadJobSheet"/>
        <Parameter name="_baseDockBar" type="JadeDockBar" usage="input"/>
        <Parameter name="_baseDockContainer" type="JadeDockContainer" usage="input"/>
        <Parameter name="_dockAreaHeightPCent" type="Real"/>
        <Parameter name="_tiled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadAreaTables" id="fec1bd58-167b-4287-b0ff-f725c3f31e7c">
        <updating/>
        <source>loadAreaTables()updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/10/2012	cnwcs5		par 29653 - minor rework
// ---------------------------------------------------------------------------
vars
	obj 			: CMIF_RoadOpObject;
	areas 			: IntegerArray;
	area 			: Integer;
	areasVisible 	: BooleanArray;
	form			: YRD_RoadOperationsForm;
	proceedMenu,
	powerMenu		: MenuItem;
begin
	create areas transient;
	create areasVisible transient;
	
	form 			:= self.getForm;
	proceedMenu 	:= form.mnuProceed;
	powerMenu		:= form.mnuBoldRequiresPower;
	
	foreach obj in self.allCMIFRoadOpObjects do 
		area := area + 1;
		
		obj.init;
		obj.setupProceedOptions (proceedMenu);
		obj.setupBoldPowerOption (powerMenu);
		obj.loadDataTable;
		
		areas.add( area);
		areasVisible.add (obj.isAreaShowing());
	endforeach;
	
	self.setTiled(self.tiled);				//+cnwml2 PAR21536
		
	self.doShowHideAreas(areas, areasVisible);
	
epilog
	delete areas;
	delete areasVisible;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="refreshCaptions" id="171d3396-6025-4f5b-af44-c35e2749cc30">
        <source>refreshCaptions(_table :CM_GroupingTable);
// ---------------------------------------------------------------------------
// Created:     09 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj	:CMIF_RoadOpObject;
begin
	obj := self.findCMIF_RoadOpObjWithTable (_table);
	
	obj.refreshCaptions;
epilog

end;</source>
        <Parameter name="_table" type="CM_GroupingTable"/>
    </JadeMethod>
    <JadeMethod name="reloadTables" id="6783fb46-8e4a-4e31-a952-87a69719aa80">
        <source>reloadTables()protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
29 September 2006	cnwer1	Initial creation - PAR#xxxx
11/08/2009			cnwcs5	ccms1061 - optimise row delete
19/03/2010			cnwcs5	par 23193 - tracked item notifications
*/
vars
	cmif_RoadOpObj : CMIF_RoadOpObject;
begin
	foreach cmif_RoadOpObj in self.allCMIFRoadOpObjects do
		if cmif_RoadOpObj.myDataTable = null then 
			continue;
		endif;
		cmif_RoadOpObj.reloadDataTable;	// par 23193
	endforeach;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resizeWidths" id="a37d8fb6-aa51-45be-8bc9-dcaff540661d">
        <source>resizeWidths();
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	row,i,j,col,
	numColumns,numVisible,
	numColVisible: Integer;
	parentContainer : JadeDockContainer;
	dockBar: JadeDockBar;
	allObjects : CMIF_RoadOpObjects;
	roadOpObj : CMIF_RoadOpObject;
	areaHeight: Integer;
begin
	create allObjects transient;
	self.getAllRoadOpObjectsByDockOrder(allObjects);
		
	i:=1;
	j:=1;
	row:=1;
	
	foreach row in 1 to self.dockTilePlan.size do
		numColumns:=numColumns + self.dockTilePlan[row];
		numVisible:=0;
		foreach col in i to numColumns do
			roadOpObj:=	allObjects[i];
			numVisible:=numVisible + roadOpObj.isAreaShowing().Integer;
			parentContainer:=roadOpObj.myDockBar.parent.JadeDockContainer;
			i:=i+1;
		endforeach;	
		parentContainer.visible:=numVisible &lt;&gt; 0;
		numColVisible:=numColVisible + parentContainer.visible.Integer;
		if parentContainer.visible  then
			foreach col in j to numColumns do
				dockBar:= allObjects[j].myDockBar;
				dockBar.width:=(parentContainer.clientWidth/numVisible).truncated;
				j:=j+1;
			endforeach;	
		endif;
		j:=i;
	endforeach;
	
	
	parentContainer:=self.allDockContainers[1].JadeDockContainer;
	areaHeight:= ((parentContainer.parent.height * self.dockAreaHeightPCent)/100).Integer;
	if numColVisible &lt;&gt; 0 then
		areaHeight:=(areaHeight/numColVisible).Integer;
	endif;
	foreach row in 1  to self.dockTilePlan.size reversed do
		parentContainer:=self.allDockContainers[row].JadeDockContainer;
		if parentContainer.visible then
			parentContainer.height:=areaHeight;	
		endif;
	endforeach;

epilog
	if allObjects &lt;&gt; null then
		delete allObjects;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterFromHandhelds" id="2ebda2b1-e040-4a32-adfd-c7325726bf45">
