    <JadeMethod name="createInterModalTransitStatus" id="43831c11-1427-44e6-92e3-b4cfbbe37c80">
        <source>createInterModalTransitStatus(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 May 2022			jlizm1	Initial creation TFS 53083 GPHA revceival/release of tranship cargo
*/

vars

	status : CM_TransitStatus;
	proxyStatus : CM_TransitStatus;
	
begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Creating Inter-Modal transit status object", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Creating Inter-Modal transit status object") ;	
	endif;
	
	if app.myRoot.allTransitStatuses[TI_TransitStatusInterModal] = null then
		create proxyStatus transient;
		proxyStatus.setProxyForNewStructure(TI_TransitStatusInterModal, White, "Inter-Modal", "INT");
		
		beginTransaction;
		create status persistent;
		status.setForCreate(proxyStatus);
		commitTransaction;
		
	else
		app.writeLog(method.qualifiedName &amp; " Inter-Modal transit status with code 'INT' already exists", LogINFO);
		if _controller &lt;&gt; null then
			_controller.logEntry(" Inter-Modal transit status with code 'INT' already exists") ;	
		endif;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Creating Inter-Modal transit status object complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Creating Inter-Modal transit status object complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

end;</source>
