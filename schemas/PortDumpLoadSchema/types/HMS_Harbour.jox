<Class name="HMS_Harbour">
    <JadeMethod name="importPLXMLReference" id="ce1ef423-0a1d-45a6-a2cc-c24434605b38">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = "myRoot" then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
