<GUIClass name="INV_CashTrxConsolidateForm" id="538298a1-dbd1-4074-b96a-e5f223e37666">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Consolidate cash receipts into one total balance, only meaningful with the original simple cash receipts, not used.</text>
    <ImplicitInverseRef name="cmbDebtor" id="0ab587f9-3c1e-44bb-bea2-ae2b95d6b803">
