    <JadeMethod name="doSave" id="60433a50-dd9c-4dff-b268-edef23431568">
        <updating/>
        <source>doSave() : Boolean updating;
//--------------------------------------------------------------
//Created: 04 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	termArea : CM_TerminalArea;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	app.mousePointer := MousePointer_HourGlass;
	
	termArea := self.cmbYardArea.listObject.CM_TerminalArea;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWLEQueueRequest(self.myCurrentWLE, termArea, chkBestPick.value, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Queue Request', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;																				
	
	return true;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="b5fb749a-a0ef-4798-968e-66b350bdbc30">
        <source>getDescription();
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	10/03/2010	cnwjre1		CCMS 1101 extend the display for all release-by-type properties
//							and for general cargo as well as containers.
// ---------------------------------------------------------------------------

vars
	msgStr 		: String;
	isISOType	: Boolean;
	isEmpty		: Boolean;
	imex	: CM_IMEXStatus;
	rqst	: CM_DeliveryRequest;
begin

	rqst := self.myDeliveryRequest;
	if rqst.myCargoType &lt;&gt; null then
		isISOType := rqst.myCargoType.isISOType();
	endif;
	if isISOType then
	// container
		isEmpty := (rqst.commodity = self.myTerminal.getDefaultEmptyCommodity());
		if rqst.isoType &lt;&gt; null then
			msgStr := addString(msgStr, "ISO : " &amp; rqst.isoType.trimBlanks);
		endif;
		if rqst.isoGroup &lt;&gt; null then
			msgStr := addString(msgStr, "ISO Group : " &amp; rqst.isoGroup.trimBlanks);
		endif;
		if rqst.operatorCode &lt;&gt; null then
			msgStr := addString(msgStr, "Oper : " &amp; rqst.operatorCode);
		endif;
		if rqst.imexStatus &lt;&gt; TI_IMEX_STATUS_NULL then
			imex:= app.myRoot.allImexStatuses[rqst.imexStatus];
			if imex &lt;&gt; null then
				msgStr := addString(msgStr, "IMEX : " &amp; imex.description);
			endif;
		endif;
		if isEmpty then
			msgStr := addString(msgStr, rqst.commodity);
			if rqst.clean then
				msgStr := addString(msgStr, "Clean");
			endif;
			if rqst.heavyRated then
				msgStr := addString(msgStr, " Heavy Duty");
			endif;
		else
			if rqst.commodity &lt;&gt; null then
				msgStr := addString(msgStr, "Commodity : " &amp; rqst.commodity);
			endif;
			if rqst.voyageCode &lt;&gt; null then
				msgStr := addString(msgStr, "Voyage : " &amp; rqst.voyageCode);
			endif;
			if rqst.consignee &lt;&gt; null then
				msgStr := addString(msgStr, " Deliver To : " &amp; rqst.consignee.trimBlanks);
			endif;
			if rqst.billOfLading &lt;&gt; null then
				msgStr := addString(msgStr, "BOL : " &amp; rqst.billOfLading);
			endif;
		endif;
	
		if rqst.isKindOf(CM_YardDeliveryRequest) then
		// Also get mt grade &amp; target location
			msgStr := addString(msgStr, "Total Requested: " &amp; rqst.totalRequested.String);
			if rqst.CM_YardDeliveryRequest.targetLocation &lt;&gt; "" then
				msgStr := addString(msgStr, "Dest : " &amp; rqst.CM_YardDeliveryRequest.targetLocation);
			endif;
			//cnwrd1 par 26633 17.12.2010			
			//msgStr := addString(msgStr, "Avail. Grade : " &amp; app.myRoot.allAvailabilityGrades[ rqst.CM_YardDeliveryRequest.mtGrade].description);
			msgStr := addString(msgStr, "Avail. Grade : " &amp;  rqst.getAvailabilityGrades());
			
		else
			msgStr := addString(msgStr, "1 of " &amp; rqst.totalRequested.String);
		endif;
	else
		// general cargo
		if rqst.myCargoType &lt;&gt; null then
			msgStr := addString(msgStr, "Cargo : "&amp; rqst.myCargoType.description);
			if rqst.mySubCargoType &lt;&gt; null then
				msgStr := addString(msgStr, rqst.mySubCargoType.description);
			endif;
		endif;
		if rqst.operatorCode &lt;&gt; null then
			msgStr := addString(msgStr, "Oper : " &amp; rqst.operatorCode);
		endif;
		if rqst.mark &lt;&gt; null then
			msgStr := addString(msgStr, "Mark : " &amp; rqst.mark);
		endif;
		if rqst.voyageCode &lt;&gt; null then
			msgStr := addString(msgStr, "Voyage : " &amp; rqst.voyageCode);
		endif;
		if rqst.billOfLading &lt;&gt; null then
			msgStr := addString(msgStr, "BOL : " &amp; rqst.billOfLading);
		endif;
	
		if rqst.isKindOf(CM_YardDeliveryRequest) then
			msgStr := addString(msgStr, "Total Requested: " &amp; rqst.totalRequested.String);
			if rqst.CM_YardDeliveryRequest.targetLocation &lt;&gt; "" then
				msgStr := addString(msgStr, "Dest : " &amp; rqst.CM_YardDeliveryRequest.targetLocation);
			endif;
			//cnwrd1 par 26633 17.12.2010			
			//msgStr := addString(msgStr, "Avail. Grade : " &amp; app.myRoot.allAvailabilityGrades[ rqst.CM_YardDeliveryRequest.mtGrade].description);
			msgStr := addString(msgStr, "Avail. Grade : " &amp;  rqst.getAvailabilityGrades());
		else
			msgStr := addString(msgStr, "1 of " &amp; rqst.totalRequested.String);
		endif;
	endif;

	self.lblDesc.caption := msgStr;
	self.lblDesc.fontBold := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="getDescriptionOriginal" id="44e7fa26-f3e9-4e4f-a937-f6d943832ca4">
        <source>getDescriptionOriginal();
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	msgStr : String;

begin

	msgStr := "Request Details:" &amp; Cr &amp; Cr;
	msgStr := msgStr &amp; "ISO : " &amp; self.myDeliveryRequest.isoType.trimBlanks;
	msgStr := msgStr &amp; ", Oper : " &amp; self.myDeliveryRequest.operatorCode;
	msgStr := msgStr &amp; ", Clean : " &amp; app.getYesNo(self.myDeliveryRequest.clean);
	
	if self.myDeliveryRequest.isKindOf(CM_YardDeliveryRequest) then
		//'Also get mt grade &amp; target location
		msgStr := msgStr &amp; " Total Requested: " &amp; self.myDeliveryRequest.totalRequested.String;
		//msgStr := msgStr &amp; " Avail. Grade : " &amp; self.myDeliveryRequest.CM_YardDeliveryRequest.targetLocation.String;
		//msgStr := msgStr &amp; " Deliver To : " &amp; app.myRoot.allAvailabilityGrades[ self.myDeliveryRequest.CM_YardDeliveryRequest.mtGrade].description;
		//cnwrd1 par 26633 17.12.2010
		msgStr := msgStr &amp; " Avail. Grade : " &amp; self.myDeliveryRequest.getAvailabilityGrades();		
		msgStr := msgStr &amp; " Deliver To : " &amp; self.myDeliveryRequest.CM_YardDeliveryRequest.targetLocation.String;		

	else
		msgStr := msgStr &amp; ", Dest : " &amp; self.myDeliveryRequest.consignee.trimBlanks;
		msgStr := msgStr &amp; ", 1 of " &amp; self.myDeliveryRequest.totalRequested.String;
	endif;
	self.lblDesc.caption := msgStr;
	self.lblDesc.fontBold := true;

end;</source>
    </JadeMethod>
