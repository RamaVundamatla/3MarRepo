<Class name="CM_DeckVesselSub" id="b1ee5d3c-f8bd-4c72-ac68-17184644323f">
    <superclass name="CM_DeckVessel"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vesselStructures"/>
    <ExplicitInverseRef name="myParentDeck" id="d5fd4631-cc86-4a43-847d-9eb1713ee56d">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_DeckVessel"/>
        <access>readonly</access>
        <Inverse name="CM_DeckVessel::allSubDecks"/>
    </ExplicitInverseRef>
    <JadeMethod name="cloneMySelfSub" id="83b0b433-7cf8-4d10-a00e-0d5eedbae65f">
        <source>cloneMySelfSub(  _parentDeck : CM_DeckVessel;_clearCode : Boolean; _copy : Boolean): CM_DeckVesselSub;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 Mar 2011	cnwer1	Initial creation
16 May 2011 cnwer1	27486 - no need to set the roro vessel structure as it is derived from its parent
*/

vars
	newDeck : CM_DeckVesselSub;
begin
	newDeck := self.cloneSelf(_copy);
	newDeck.setMyParentDeck(_parentDeck);
	
	if _clearCode then
		newDeck.code:=null;
	endif;
	

	self.cloneMySelfSuper(newDeck, _copy);

	

	return newDeck;
epilog

end;</source>
        <Parameter name="_parentDeck" type="CM_DeckVessel"/>
        <Parameter name="_clearCode" type="Boolean"/>
        <Parameter name="_copy" type="Boolean"/>
        <ReturnType type="CM_DeckVesselSub"/>
    </JadeMethod>
    <JadeMethod name="cloneMySelfSubForVoyage" id="d78e30e9-e3a9-4b9f-8058-c20e791059c9">
        <source>cloneMySelfSubForVoyage(_parentDeck : CM_DeckVoyage; _transient: Boolean): CM_DeckVoyageSub;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	newDeck : CM_DeckVoyageSub;
begin
	newDeck := self.cloneSelfAs(CM_DeckVoyageSub,_transient).CM_DeckVoyageSub;
	newDeck.setMyParentDeck(_parentDeck);
	
	self.cloneMySelfSuper(newDeck, _transient);

	

	return newDeck;
	
epilog

end;</source>
        <Parameter name="_parentDeck" type="CM_DeckVoyage"/>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="CM_DeckVoyageSub"/>
    </JadeMethod>
    <JadeMethod name="delete" id="273542bd-61b4-4822-8298-97b77f66b52e">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2011	cnwer1	Initial creation

*/

vars
	roroStructure : CM_ROROVesselStructure;
begin
	if self.isTransient then
		return;
	endif;
	
	if self.myParentDeck &lt;&gt; null then
		roroStructure:=self.myParentDeck.myROROStructure;
		if roroStructure &lt;&gt; null then
			roroStructure.causeEvent(EVENT_VESSEL_DECK_DELETE,false,self);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getROROStructure" id="155d89e8-8c10-467e-ad59-fa21ed328a49">
        <source>getROROStructure() : CM_ROROVesselStructure;
/*
Purpose:			
Date		Who		Reason
03 May 2011	cnwab1	Initial creation
*/

vars

begin
	if self.myParentDeck &lt;&gt; null then
		return self.myParentDeck.myROROStructure;
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="CM_ROROVesselStructure"/>
    </JadeMethod>
    <JadeMethod name="getVessel" id="08e7f284-5bcd-4ddf-8221-66719d62b6de">
        <source>getVessel() : CM_Vessel;
/*
Purpose:			
Date		Who		Reason
21 April 2011	cnwab1	Initial creation
*/

vars

begin
	return self.myParentDeck.myROROStructure.myVessel;
epilog

end;</source>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
