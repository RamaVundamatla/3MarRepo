    <JadeMethod name="createGCController" id="39c4e514-6d91-4d9d-aca2-3035f35327b8">
        <updating/>
        <source>createGCController() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	if self.myGCController &lt;&gt; null then
		return;
	endif;
	
	if self.isTransient then 
		create self.myGCController transient;
	else
		create self.myGCController persistent;
	endif;
	self.myGCController.setFromROROGCDefn();
epilog

end;</source>
    </JadeMethod>
