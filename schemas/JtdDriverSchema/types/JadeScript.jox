    <JadeMethod name="th2RunTestGateInOut" id="b9b33de3-1907-440f-b71b-2b9f14fc7bdd">
        <source>th2RunTestGateInOut();

vars
	tran	: GateInOut2;
	now					: TimeStamp;
	rtgArea				: CM_RTGArea;
	releaseTI			: CM_TrackedItem;
	lc					: CM_LocationsController;
	loopCount,
	idx					: Integer;
begin
	app.initialize;
	app.sequenceId:= 2;
	
	create tran transient;
	tran.pauseTime := 500;
//	process.traceMethodsOfExecution(true);
	tran.startup;
	
	tran.thZLogonRTGCrane();
	/*
	//th2 hack to populate the allTrackedItems working set
	rtgArea := app.myPassport.myTerminal.allTerminalAreasByTypeId[TA_TYPE_RTG, 'D'].CM_RTGArea;
	foreach lc in rtgArea.allGridControllersByRowColumn reversed do
		//releaseTI := lc.allTrackedItems.last;//highest in stack
		foreach releaseTI in lc.allTrackedItems where 
		   releaseTI.myPrimaryActualLocation = lc and 
		   releaseTI.myPrimaryQueuedLocation = null and
		   releaseTI.allBulkReleasesAssigned.isEmpty do
			app.jtdMyTransactionGenerator.JmtTransactionGenerator.allTrackedItems.add(releaseTI);
			idx := idx + 1;
			if idx &gt; 100 then
				break;
			endif;
		endforeach;
	endforeach;
	*/
	foreach loopCount in 0 to 1 do
		app.doWindowEvents(tran.pauseTime);
		app.jtdMyTransactionGenerator.JmtTransactionGenerator.loopCount := loopCount;
	
		app.doWindowEvents(tran.pauseTime);
		tran.gio01_showInOutSheets;
	
		app.doWindowEvents(tran.pauseTime);
		tran.gio03_enterGateInDetails;

		app.doWindowEvents(tran.pauseTime);
		tran.gio04_rfidTagSwipeGateIn();
		
		app.doWindowEvents(tran.pauseTime);
		tran.gio05_rfidTagFormProceed();
		
		app.doWindowEvents(tran.pauseTime);
		tran.gio06_rfidTagSwipeGateLaneIn();
		
		app.doWindowEvents(tran.pauseTime);
		tran.gio07_handHeldGateLaneIn();
		
		app.doWindowEvents(tran.pauseTime);
		tran.gio08_rtgContainerInTake();
		
		app.doWindowEvents(tran.pauseTime);
		tran.gio09_rtgContainerInDrop();
	
		app.doWindowEvents(tran.pauseTime);
		tran.gio10_rtgContainerOutTake();
	
		app.doWindowEvents(tran.pauseTime);
		tran.gio11_rtgContainerOutDrop();
	
		app.doWindowEvents(tran.pauseTime);
		tran.gio12_rfidTagSwipeGateLaneOut();
		
		app.doWindowEvents(tran.pauseTime);
		tran.gio13_handHeldGateLaneOut();

	endforeach;
	
epilog
	delete tran;
end;</source>
    </JadeMethod>
