    <JadeMethod name="isTaskReadyForPickup" id="db221ee6-34e5-47f0-bfe4-4e651e09bc2c">
        <source>isTaskReadyForPickup() : Boolean;

vars
	ti: CM_TrackedItem;
	ready: Boolean;
begin
	if self.myTask = null or not self.myTask.isPickup() then
		return false;
	endif;
	
	ready := self.myTask.isPrevSetdownComplete;
	if not ready then
		self.logMessage(LOG_FULL, "Machine " &amp; self.getMachineId &amp; " waiting for setdown task " &amp; self.getPrevTaskDisplay);
	endif;
	
	return ready;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTaskReadyForSetdown" id="f33b1933-32b3-4b60-bed5-7f82a718b86b">
        <source>isTaskReadyForSetdown() : Boolean;

vars
	ready: Boolean;
begin
	if self.myTask = null or not self.myTask.isSetdown() then
		return false;
	endif;

	ready := self.myTask.isNextTaskReadyForPickup;
	if not ready then
		self.logMessage(LOG_FULL, "Machine " &amp; self.getMachineId &amp; " waiting for pickup task " &amp; self.getNextTaskDisplay);
	endif;
	
	return ready;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
