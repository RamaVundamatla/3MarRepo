    <JadeMethod name="getXMLSettingsForSave" id="e83eea05-e31a-439e-8203-b78662ea5ac4">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 22/12/2011	cnwdap1		PAR #28064 Retain colour legend table width
vars
	theXML		: String;
	// cnwjk3 SFW1030
	hideYAM	,
	hideRTG,
	hideFTP		: Boolean;
	//cnwmc5 - PAR #30890 - 09/01/2013
	deWidth,
	leWidth,
	dcWidth : Real;
begin
	theXML := inheritMethod();

	//cnwmc5 - PAR #30890 - 09/01/2013
	if self.dkcExtraInfo.width &gt; 0 then
		dcWidth:=dkbCargoPic.width/self.dkcExtraInfo.width;
	endif;
	
	if self.dkcSubMain.height &gt; 0 then
		deWidth:=self.dkcExtraInfo.height/self.dkcSubMain.height;
	endif;
	
	if self.dkcMain.width &gt; 0 then
		leWidth:=self.dkcSubMainCol.width/self.dkcMain.width;
	endif;
	
	theXML := theXML &amp; 
			
	// cnwjk3 SFW1030
	global.formatAsXML(XML_HY,self.xmlYAM.Integer.String) &amp;
	global.formatAsXML(XML_HF,self.xmlFTP.Integer.String) &amp;
	global.formatAsXML(self.XML_HideRTG,self.xmlHideRTG.Integer.String) &amp;
	global.formatAsXML(XML_ZS,self.xmlZoomFactor.String) &amp;
	global.formatAsXML(XML_VM,self.xmlViewMode.String) &amp;
	global.formatAsXML(XML_SE,(self.xmlSelector).Integer.String) &amp;	 //28 Jul 2011	NDL	Par 27890 
	global.formatAsXML(XML_HL,self.xmlLegend.Integer.String) &amp;
	global.formatAsXML(XML_DC, dcWidth.String) &amp;		//cnwmc5 - PAR #30890 - 09/01/2013
	global.formatAsXML(XML_DE, deWidth.String) &amp; //epr par 19289 2/409		//cnwmc5 - PAR #30890 - 09/01/2013
	global.formatAsXML(XML_LE, leWidth.String) &amp;		// PAR #28064			//cnwmc5 - PAR #30890 - 09/01/2013
	global.formatAsXML(XML_HeightRestriction,self.xmlHeightRestrict.String) &amp;	//epr par 33594 24/1/15
	global.formatAsXML(XML_Directions, self.xmlDirections.Integer.String);	// 9/10/17 MAP TFS7084

	return theXML;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="558efc8d-15f7-4e39-a1d6-1dd66c3ded5a">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		Get the user preferences from the user details for this form
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 22/12/2011	cnwdap1		PAR #28064 Retain colour legend table width
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	hideL : Boolean;
	// cnwjk3 SFW1030
	hideYAM, 
	hideFTP,
	hideRTG		: Boolean;
	viewMode : Integer;
	zoomScale,
	cargoWidth,
	extraInfoHeight,
	colourLegendWidth	: Real;		// PAR #28064
	hideS : Boolean; //29 Jul 2011	NDL	Par 27890
begin
	// par 11163 rs jan 2006
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
	endif;
	if userWindow = null then
		return;
	endif;

	theXML := userWindow.xmlInfo;

	// cnwjk3 SFW1030
	// #### HIDE YAM
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HY);
 	hideYAM := false;
 	if theXMLValue &lt;&gt; null then
 		hideYAM := theXMLValue.Integer.Boolean;
 	endif;
	// #### HIDE FTP
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HF);
 	hideFTP := false;
 	if theXMLValue &lt;&gt; null then
 		hideFTP := theXMLValue.Integer.Boolean;
 	endif;
	
	//#### Hide RTG machine details
	theXMLValue := theXML.cnEcGetTagValueOfName(self.XML_HideRTG);
	hideRTG:=false;
	if theXMLValue &lt;&gt; null then
		hideRTG:=theXMLValue.Integer.Boolean;
	endif;
	// #### HIDE LEGEND
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HL);
 	hideL := false;
 	if theXMLValue &lt;&gt; null then
 		hideL := theXMLValue.Integer.Boolean;
 	endif;
	
	//29 Jul 2011	NDL	Par 27890
	// #### HIDE SELECTOR
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_SE);
 	hideS := false;
 	if theXMLValue &lt;&gt; null then
 		hideS := theXMLValue.Integer.Boolean;
 	endif;
	
	//epr par 33954 24/3/15
	self.xmlHeightRestrict:=theXML.cnEcGetTagValueOfName(XML_HeightRestriction).Integer;

	self.xmlDirections := theXML.cnEcGetTagValueOfName(XML_Directions).Integer.Boolean;		// 9/10/17 MAP TFS7084
	
 	// #### ZOOM SCALE
 	zoomScale := theXML.cnEcGetTagValueOfName(XML_ZS).Real;
	
 	if zoomScale = 0 then
	 	zoomScale := CMUI_GridDrawingController.ScaleFactor_2;
	endif;
	self.xmlZoomFactor := zoomScale;
	
	// #### VIEWMODE
 	viewMode := theXML.cnEcGetTagValueOfName(XML_VM).Integer;
 
 	if viewMode = 0 then
	 	viewMode := VIEW_VOYAGE;
	endif;

	self.xmlViewMode := viewMode;

	
	xmlTAViewObject:=theXML.cnEcGetTagValueOfName(self.myTerminal.code &amp; self.XML_TAView).String;
	
	// ### SET CONTROLS
 
 	// cnwjk3 SFW1030
	self.xmlYAM := hideYAM;
	self.xmlFTP := hideFTP;
	self.xmlHideRTG := hideRTG;
	self.xmlLegend := hideL;


	cargoWidth := theXML.cnEcGetTagValueOfName(XML_DC).Real;	
	extraInfoHeight := theXML.cnEcGetTagValueOfName(XML_DE).Real;	
	colourLegendWidth := theXML.cnEcGetTagValueOfName(XML_LE).Real;		// PAR #28064
	
	if cargoWidth = 0 then
		cargoWidth := 390;
	endif; 
	if extraInfoHeight = 0 then
		extraInfoHeight := 103;
	endif; 
	if colourLegendWidth = 0 then				// PAR #28064
		colourLegendWidth := 100;				// PAR #28064
	endif;										// PAR #28064
	self.xmlCargoWidth := cargoWidth;
	self.xmlExtInfoHeight := extraInfoHeight;
	self.xmlLegendWidth := colourLegendWidth;	// PAR #28064
	self.xmlSelector := hideS;	//29 Jul 2011	NDL	Par 27890
	
epilog
	
	if self.xmlZoomFactor = 0 then
	 	self.xmlZoomFactor := CMUI_GridDrawingController.ScaleFactor_2;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="getYardAllocString" id="cdaa49c9-3ba1-4f69-a17f-6d718161ebfa">
        <source>getYardAllocString(_objs : ObjectArray) : String;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
	anLC : CM_LocationsController;
	locTxt, lcID : String;
	ta : CM_TerminalArea;
begin
	
	if _objs = null then
		return null;
	endif;
	
	if _objs.isEmpty then
		return null;
	endif;
	
	foreach anObject in _objs do
		anLC := anObject.CM_LocationsController;
		if not anLC.useInYA() then
			continue;
		endif;
		
		if ta &lt;&gt; anLC.myTerminalArea then
			if ta &lt;&gt; null then // not the first time
				locTxt := locTxt &amp;  "; ";
			endif;
			ta := anLC.myTerminalArea;
			locTxt := locTxt &amp; ta.id &amp; " " &amp; anLC.ident;
		else
			locTxt := locTxt &amp;  "," &amp; anLC.ident;
		endif;
	endforeach;
	
	return locTxt;
end;</source>
        <Parameter name="_objs" type="ObjectArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
