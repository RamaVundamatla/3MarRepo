<Class name="WS_Stop" id="11b3b548-42e7-4a36-87dd-c5bc4e10a655">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Represents Stops defined in the system.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="description" id="372d03a4-4815-4b1d-b7b7-35c638d84e9f">
        <type name="String"/>
        <text>Stop Description  ex.Financial Stop</text>
    </PrimAttribute>
    <PrimAttribute name="id" id="21e02b79-8de5-459b-863d-d0ba704d9051">
        <embedded/>
        <type name="Integer"/>
        <text>Stop Id ex.1</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="5e917dfe-7eb0-4a08-95e6-d23f640f749a">
        <updating/>
        <source>setProxyFromObject(_object: CM_StopsTable) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2008	cnwkao1	Initial creation

*/

vars

begin
	inheritMethod(_object);
	self.id				:= _object.CM_StopsTable.id;
	self.description	:= _object.CM_StopsTable.heading;
epilog

end;</source>
        <Parameter name="_object" type="CM_StopsTable"/>
    </JadeMethod>
</Class>
