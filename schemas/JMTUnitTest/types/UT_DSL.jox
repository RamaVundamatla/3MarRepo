    <JadeMethod name="xCheckBGPProcessDetails" id="bbc83976-5317-473d-849e-52b219419730">
        <source>xCheckBGPProcessDetails();

/*

Purpose:		Check details on the selected BGP Processes

Date			Who		Reason
21/07/2014		cnwmh5	Initial creation

*/

vars

	manager						: BGP_Manager;
	controller					: BGP_Controller;

	bgpManagerToCheck			: StringArray;
	
	iter						: Iterator;
	
	processSignOnTime			: TimeStamp;
	invalidProcess				: Boolean;
	
begin

	on Exception do app.handleDeletedObject(exception, controller.myProcess, invalidProcess);	

	create bgpManagerToCheck transient;
	bgpManagerToCheck.add("AUTO");
	bgpManagerToCheck.add("CHANGE CONTROL");
	
	iter := app.myRoot.allBGPManagers.createIterator;
	while iter.next(manager) do
		if not bgpManagerToCheck.includes(manager.name) then
			continue;
		endif;
		
		foreach controller in manager.allBGPControllers discreteLock do
			processSignOnTime := null;
			controller.myProcess.edition;
			if not invalidProcess then
				processSignOnTime := controller.myProcess.signOnTime;
			endif;			
	//		app.writeLog(manager.String &amp; Tab &amp; manager.name &amp; Tab &amp; controller.String &amp; Tab &amp; 
	//			controller.name &amp; Tab &amp; controller.myProcess.String &amp; Tab &amp; "processSignOnTiem: " &amp; processSignOnTime.String &amp; Tab &amp; 
	//			"dateTimeLastStarted: " &amp; controller.dateTimeLastStarted.String &amp; Tab &amp; 'isRunning(): ' &amp; controller.isRunning().String, LogINFO); 
				
		endforeach;
		
		
	endwhile;
	
epilog

	delete bgpManagerToCheck;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="xCheckIfGT20FtRtnAftLC" id="60c9f6c6-450b-428e-acd1-ba7c4a2b7b1b">
        <source>xCheckIfGT20FtRtnAftLC(_theLC : CM_LocationsController io);

/*

Purpose:		Checks to see if &gt; 20Ft container and returns correct slot

Date			Who		Reason
09/12/2014		cnwmh5	Initial creation

*/

vars

	lc						: CM_LocationsController;
	isoType					: CM_ISOType;

begin

	// isotype not specified so don't care
	if not self.opts.includesKey("ISOType") then
		return;
	endif;

	// not a container so don't care
	if self.opts.includesKey("CargoType") and self.opts.int("CargoType") &lt;&gt; TI_CargoType_Container then
		return;
	endif;

	// get iso type
	isoType := app.myRoot.allISOTypes[self.opts.str("ISOType")];
	if isoType = null then
		return;
	endif;
	
	// is 20Ft then don't care
	if isoType.is20ftLong then
		return;
	endif;
	
	// aft slot null so return the fwd slot
	lc := _theLC.getAftLC();
	if lc = null then
		_theLC := _theLC.getFwdLC();
	endif;
	
	// fwd slot so do nothing
	
epilog

end;</source>
        <Parameter name="_theLC" type="CM_LocationsController" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xCheckIsDeleted" id="38ea0196-ebe9-495d-83e6-ad76a20595f4">
        <source>xCheckIsDeleted(_obj : Object)  : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2015	cnwdb2	Initial creation

*/

vars
	isInvalidObject : Boolean ; 
begin

	if _obj &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,_obj,isInvalidObject) ; 
		_obj.edition ; 
	endif;
	  
	return isInvalidObject;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xCreatePxyForAddCargoMethods" id="5815a241-c9fc-4e41-8bc0-0da7d77ed5c5">
        <source>xCreatePxyForAddCargoMethods(_areaOrVoyage : Any; _cargoType : CM_CargoType; _tmpID : String; _pxyTI : CM_TrackedItem io);

/*

Purpose:		Create the pxy ti for the addVoyageCargo methods

Date			Who		Reason
10/03/2014		cnwmh5	Initial creation

*/

vars
	
	subT							: CM_SubTerminal;
	terminal						: CM_Terminal;
	voyage							: CM_Voyage;
	commodity						: CM_Commodity;
	cargoType						: CM_CargoType;
	isoType							: CM_ISOType;
		
	temperature						: Real;
	isVoyage						: Boolean;
	remarks							: String;
	overHeight						: Decimal[14,4];
	overFront						: Decimal[14,4];
	overRear						: Decimal[14,4];
	overLeft						: Decimal[14,4];
	overRight						: Decimal[14,4];
	
begin

	if _areaOrVoyage.isKindOf(CM_TerminalArea) then
		terminal := _areaOrVoyage.CM_TerminalArea.myTerminal;
	elseif _areaOrVoyage.isKindOf(CM_Voyage) then
		terminal := _areaOrVoyage.CM_Voyage.myTerminal;
		isVoyage := true;
	endif;
	self.assertNotNull(terminal);
	
	cargoType := _cargoType;
	
	if self.opts.includesKey("Commodity") then
		commodity := app.myRoot.allCommodities[self.opts.str("Commodity")];
		self.assertNotNull(commodity);
		if commodity.allCargoTypes.isEmpty() then
			if cargoType.id &lt;&gt; TI_CargoType_Container then
				cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container].CM_CargoType;
			endif;
		else
			 if commodity.allCargoTypes[cargoType.id] = null then
				cargoType := commodity.allCargoTypes.first;
			endif;
		endif;
	endif;
	
	_pxyTI := terminal.createTI(cargoType, true);
	_pxyTI.zSetPxyTerminal(terminal);
	
	if isVoyage then
		_pxyTI.changeState(TI_STATE_ONSHIP, app.myPassport);
	endif;

	_pxyTI.setCargoType(cargoType.id);
	
	if cargoType.id = TI_CargoType_Generator then
		if self.opts.includesKey("GeneratorType") then
			_pxyTI.CM_Generator.setMyGeneratorType(self.opts.obj("GeneratorType").CM_GeneratorType);
		else
			_pxyTI.CM_Generator.setMyGeneratorType(app.myRoot.allGeneratorTypes.first);
		endif;
	elseif cargoType.productType = ProductType_Trailer then
		if self.opts.includesKey("TrailerType") then
			_pxyTI.CM_TILC.setMyType(self.opts.obj("TrailerType").CM_TILCType);
		else
			_pxyTI.CM_TILC.setMyType(app.myRoot.allTILCTypes.first);
		endif;
	else
		if cargoType.isSubCargoTypeRequired then
			if self.opts.includesKey("SubType") then
				_pxyTI.setMyProduct(self.opts.obj("SubType").CM_Product);
			else
				_pxyTI.setMyProduct(cargoType.allProducts.first);
			endif;
		endif;
	endif;

	if self.opts.includesKey("Quantity") then
		_pxyTI.zSetPxyQuantity(self.opts.int("Quantity"));
	endif;
	
	if not isVoyage and self.opts.includesKey("Voyage") then
		voyage := self.opts.obj("Voyage").CM_Voyage;
	else
		if isVoyage then
			voyage := _areaOrVoyage.CM_Voyage;
		else
			voyage := terminal.getNullVoyage();
		endif;
	endif;
	_pxyTI.zSetPxyVoyage(voyage, voyage.code);
	
	// set the operator
	if self.opts.includesKey("Operator") then
		_pxyTI.setMyOperator(self.opts.obj("Operator").CM_Operator);
	endif;
	if _pxyTI.myOperator = null then
		_pxyTI.setMyOperator(app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString]);
		if _pxyTI.myOperator = null then
			_pxyTI.setMyOperator(app.myRoot.allOperators["MSK"]);
			if _pxyTI.myOperator = null then
				_pxyTI.setMyOperator(app.myRoot.allOperators["MSL"]);
				if _pxyTI.myOperator = null then
					_pxyTI.setMyOperator(app.myRoot.allOperators.first);
				endif;
			endif;
		endif;
	endif;
	
	// set the commodity
	if commodity &lt;&gt; null then
		_pxyTI.setCommodity(commodity.code);
	else
		if _pxyTI.commodity = null then
			if app.myRoot.allCommodities["GENL"].allCargoTypes[cargoType.id] = null then
				if cargoType.isCommodityRequired then
					if not cargoType.allCommodities.isEmpty() then
						_pxyTI.setCommodity(cargoType.allCommodities.first.code);
					else
						_pxyTI.setCommodity("GENL");
					endif;
				endif;
			else
				_pxyTI.setCommodity("GENL");
			endif;
		endif;
	endif;
	commodity := _pxyTI.getCommodityObject();
	
	if self.opts.includesKey("IMEXStatus") then
		_pxyTI.setImExStatus(self.opts.int("IMEXStatus"));
	elseif isVoyage then
		_pxyTI.setImExStatus(TI_IMEX_STATUS_REMAINONBOARD);
	else
		_pxyTI.setImExStatus(TI_IMEX_STATUS_IMPORT);
	endif;
	
	if self.opts.includesKey("Weight") then
		_pxyTI.setWeight(self.opts.dec("Weight"), null, app.myPassport);
	else	
		_pxyTI.setWeight(4000, null, app.myPassport);
	endif;
	
	if self.opts.includesKey("TotalWeight") then
		_pxyTI.setTotalWeight(self.opts.dec("TotalWeight"), null, app.myPassport);
	else
		_pxyTI.setTotalWeight(4000, null, app.myPassport);
	endif;
	
	_pxyTI.zSetPxyCompany(terminal.getDefaultCompanyBank);
	
	if self.opts.includesKey("DischargePort") then
		_pxyTI.zSetPxyDischargePort(self.opts.str("DischargePort"));
	else
		_pxyTI.zSetPxyDischargePort(terminal.getConfig(PortDestCode).String);
	endif;
	
	if self.opts.includesKey("DestinationPort") then							// 07/08/2015 cnwmh5
		_pxyTI.zSetPxyDestinationPort(self.opts.str("DestinationPort"));
	endif;
	
	if self.opts.includesKey("ISOType") then
		_pxyTI.changeISOType(self.opts.str("ISOType"), null, app.myPassport);
	else	
		_pxyTI.changeISOType("2200", null, app.myPassport);
	endif;	
	
	// check to see if commodity is reefer and work out a temperature if not passed across
	if commodity &lt;&gt; null and commodity.hasTemp then
		_pxyTI.changeISOType("2231", null, app.myPassport);
		_pxyTI.createReeferPropertiesIfReqd("new");
		
		if self.opts.includesKey("Temperature") then
			
		else
			if commodity.maxTemp = commodity.minTemp then
				temperature := commodity.maxTemp;
			else
				temperature := commodity.minTemp;
			endif;
			_pxyTI.myReeferProperties.setTemperature(temperature);
		endif;
	endif;
	
	if _pxyTI.myCargoType.id = TI_CargoType_Container then
		if self.opts.includesKey("AvailabilityGrade") then
			_pxyTI.CM_Container.setPropertyValue("availabilityGrade", (self.opts.int("AvailabilityGrade").Integer));
		endif;
		// 22/07/2015 cnwmh5
		overHeight := self.opts.dec("OverHeight");
		overFront := self.opts.dec("OverFront");
		overRear := self.opts.dec("OverRear");
		overLeft := self.opts.dec("OverLeft");
		overRight := self.opts.dec("OverRight");
		_pxyTI.CM_Container.setOverDimensionsOnly(overHeight, overFront, overRear, overLeft, overRight);
	endif;
	
	global.setExtraData(_pxyTI.allExtraData, _pxyTI, "createdByUnitTest" , self.getClassMethodCreatedBy());
	// 13/07/015 cnwmh5
	remarks := _pxyTI.remarks;
	if remarks &lt;&gt; null then
		remarks := remarks &amp; CrLf;
	endif;
	_pxyTI.zSetPxyRemarks(remarks &amp; self.createdByUnitTest(remarks));
	
	if app.isSubTerminalsOn(terminal) then
		subT := terminal.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
			0,	
			TI_IMEX_STATUS_IMPORT,
			"MT",
			true); 
		_pxyTI.setSubTerminal(subT,null);
	endif;
	
	_pxyTI.zSetPxyId(_tmpID);

epilog

end;</source>
        <Parameter name="_areaOrVoyage" type="Any"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_tmpID" type="String"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xCreatePxyForAddVoyCargoMeths" id="42ce101d-859c-44f6-a637-c5e6b7a64f2f">
        <source>xCreatePxyForAddVoyCargoMeths(_voyage : CM_Voyage; _cargoType : CM_CargoType; _tmpID : String; _pxyTI : CM_TrackedItem io);

/*

Purpose:		Create the pxy ti for the addVoyageCargo methods

Date			Who		Reason
10/03/2014		cnwmh5	Initial creation

*/

vars
	
	subT							: CM_SubTerminal;
	
	remarks							: String;
	
begin

	
	_pxyTI := _voyage.myTerminal.createTI(_cargoType, true);
	_pxyTI.zSetPxyTerminal(_voyage.myTerminal);

	_pxyTI.setCargoType(_cargoType.id);
	
	// set the operator
	if self.opts.includesKey("Operator") then
		_pxyTI.setMyOperator(self.opts.obj("Operator").CM_Operator);
	endif;
	if _pxyTI.myOperator = null then
		_pxyTI.setMyOperator(app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString]);
	endif;
	if _pxyTI.myOperator = null then
		_pxyTI.setMyOperator(app.myRoot.allOperators["MSK"]);
	endif;
	if _pxyTI.myOperator = null then
		_pxyTI.setMyOperator(app.myRoot.allOperators["MSL"]);
	endif;
	if _pxyTI.myOperator = null then
		_pxyTI.setMyOperator(app.myRoot.allOperators.first);
	endif;
		
	if self.opts.includesKey("Commodity") then
		_pxyTI.setCommodity(self.opts.str("Commodity"));
		if self.opts.str("Commodity") = "REEF" then
			_pxyTI.setTemperature(4);
		endif;
	endif;
	if _pxyTI.commodity = null then
		_pxyTI.setCommodity("GENL");
	endif;
	
	if self.opts.includesKey("IMEXStatus") then
		_pxyTI.setImExStatus(self.opts.int("IMEXStatus"));
	else
		_pxyTI.setImExStatus(TI_IMEX_STATUS_REMAINONBOARD);
	endif;
	
	_pxyTI.setMyVoyage(_voyage, app.myPassport);
	_pxyTI.changeState(TI_STATE_ONSHIP, app.myPassport);
	
	if self.opts.includesKey("Weight") then
		_pxyTI.setWeight(self.opts.dec("Weight"), null, app.myPassport);
	else	
		_pxyTI.setWeight(4000, null, app.myPassport);
	endif;
	
	if self.opts.includesKey("TotalWeight") then
		_pxyTI.setTotalWeight(self.opts.dec("TotalWeight"), null, app.myPassport);
	else
		_pxyTI.setTotalWeight(4000, null, app.myPassport);
	endif;
	
	_pxyTI.zSetPxyCompany(_voyage.myTerminal.getDefaultCompanyBank);
	
	
	if self.opts.includesKey("DischargePort") then
		_pxyTI.zSetPxyDischargePort(self.opts.str("DischargePort"));
	else
		_pxyTI.zSetPxyDischargePort(_voyage.myTerminal.getConfig(PortDestCode).String);
	endif;
	
	if self.opts.includesKey("Is40") then
		_pxyTI.changeISOType("4200", null, app.myPassport);
	elseif self.opts.includesKey("ISOType") then
		_pxyTI.changeISOType(self.opts.str("ISOType"), null, app.myPassport);
	else	
		_pxyTI.changeISOType("2200", null, app.myPassport);
	endif;
	
	if self.opts.includesKey("AvailabilityGrade") and _pxyTI.isKindOf(CM_Container) then
		_pxyTI.CM_Container.setPropertyValue("availabilityGrade", (self.opts.int("AvailabilityGrade").Integer));
	endif;
	
	global.setExtraData(_pxyTI.allExtraData, _pxyTI, "createdByUnitTest" , self.getClassMethodCreatedBy());
	// 13/07/015 cnwmh5
	remarks := _pxyTI.remarks;
	if remarks &lt;&gt; null then
		remarks := remarks &amp; CrLf;
	endif;
	_pxyTI.zSetPxyRemarks(remarks &amp; self.createdByUnitTest(remarks));
	
	if app.isSubTerminalsOn(_voyage.myTerminal) then
		subT := _voyage.myTerminal.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
			0,	
			TI_IMEX_STATUS_IMPORT,
			"MT",
			true); 
		_pxyTI.setSubTerminal(subT,null);
	endif;
	
	_pxyTI.zSetPxyId(_tmpID);

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_tmpID" type="String"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xCreateROROVesselStructure" id="0e8e00cc-d19d-4e45-9c5b-8d6008b2354d">
        <source>xCreateROROVesselStructure(vesselName :  String) : CM_Vessel;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 March 2011	cnwer1	Initial creation

*/

vars
	vessel  	: CM_Vessel;
	operator 	: CM_Operator;
	
begin
	operator := app.myRoot.allOperators["ANL"];
	vessel := self.addVesselLOLOholdsRORO(vesselName,operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	return vessel;

								
epilog
	
end;</source>
        <Parameter name="vesselName" type="String"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="xCreateTIForLocation" id="de855f45-4bce-41cb-ad6a-212cc3013380">
        <source>xCreateTIForLocation(_areaOrVoyage : Any; _location : CM_LocationsController input; _getNextLocation : Boolean io; _gcOOTLDefn : CM_DeckItem io);

/*

Purpose:		Make the Cargo

Date			Who		Reason
28/10/2014		cnwmh5	Initial creation

*/

vars

	cargoType						: CM_CargoType;
	moveController					: CMIF_MoveController;
	pxyTI							: CM_TrackedItem;
	realTI							: CM_TrackedItem;
	lc								: CM_LocationsController;
	
	lcs								: CM_LCArray;
	
	tmpID							: String;
	warningsIgnored					: Boolean;
	warningsAck						: Boolean;
	isVoyage						: Boolean;
	isRORO							: Boolean;
	useDuplicateID					: Boolean;
	nextNum							: Integer;
	isGC							: Boolean;
	isOOTL							: Boolean;
	
begin

	
	delete moveController;
	create moveController transient;
	moveController.setMyToPrimaryLocation(_location);
	moveController.setMoveMode(REAL_MODE);

	if _areaOrVoyage.isKindOf(CM_TerminalArea) then
		app.myPassport.setMyTerminal(_areaOrVoyage.CM_TerminalArea.myTerminal);
			//moveController.setMyToPrimaryLocation(_location);
	elseif _areaOrVoyage.isKindOf(CM_Voyage) then
		app.myPassport.setMyTerminal(_areaOrVoyage.CM_Voyage.myTerminal);
		isVoyage := true;
		isRORO := _areaOrVoyage.CM_Voyage.myROROStructure &lt;&gt; null;
		isOOTL := self.opts.includesKey("OOTL") or self.opts.includesKey("OOTL40");
		isGC := self.opts.includesKey("xMetres") and self.opts.includesKey("yMetres") and not isOOTL;
	endif;
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);

	// get the cargo type
	if self.opts.includesKey("CargoType") then
		cargoType := app.myRoot.allCargoTypesById[self.opts.int("CargoType")];
	endif;
	if cargoType = null then
		cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	endif;
	self.assertNotNull(cargoType);
	
	create lcs transient;
	
	warningsIgnored := app.myPassport.warningsIgnored;
	app.myPassport.setWarningsIgnored(true);
	warningsAck := app.myPassport.warningsAcknowledged;
	app.myPassport.setWarningsAcknowledged(true);
	
	// check to see if useDuplicateID
	if cargoType.allowDuplicates then
		useDuplicateID := self.opts.includesKey("UseDuplicateID");	
	endif;
	
	nextNum := self.nextNum;
	if isVoyage then
		if isRORO then
			tmpID := _areaOrVoyage.CM_Voyage.myROROStructure.getNextQuickCargoID(cargoType.id);
		else
			tmpID := _areaOrVoyage.CM_Voyage.getNextQuickCargoID2(cargoType, useDuplicateID, self.doGetNextID, nextNum, _location);
		endif;
	else	
		tmpID := _areaOrVoyage.CM_TerminalArea.getNextQuickCargoID2(cargoType, useDuplicateID, self.doGetNextID, nextNum);
		if useDuplicateID then
			self.sendMsgWithParams("updateDoGetNextID", not self.doGetNextID);
		endif;
	endif;
	
	
	self.xCreatePxyForAddCargoMethods(_areaOrVoyage, cargoType, tmpID, pxyTI);
	moveController.setMyTrackedItem(pxyTI);
	
	// make sure if voyage that can be added to the required slot
	
	if _areaOrVoyage.isKindOf(CM_Voyage) and pxyTI.myCargoType.id = TI_CargoType_Container and not pxyTI.is20 and not isGC then
		if not self.xMakeSureSlotCanAccept(moveController) then
			_getNextLocation := true;
			delete pxyTI;
			return;
		endif;
	endif;
	
	
	
	if not isGC then
		app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, app.myPassport);
	///elseif isOOTL then
	//	_gcOOTLDefn := app.myTrxCA.trxCreateROROOOTLCargo(_gcOOTLDefn.CM_ROROLocnDefnVoyage, null, pxyTI, not self.opts.includesKey("OOTLRotated"), 
	//		self.opts.real("xMetres").Decimal, self.opts.real("yMetres").Decimal, self.opts.obj("Deck").CM_DeckVoyage, app.myPassport);
	elseif isGC then
		_gcOOTLDefn := app.myTrxCA.trxCreateROROGCCargo(false, _gcOOTLDefn.CM_ROROGCDefnVoyage, null, pxyTI, self.opts.real("xMetres"), self.opts.real("yMetres"), 
			self.opts.obj("Deck").CM_DeckVoyage, app.myPassport);
	endif;
		
	// check to see if cannot move error/warning has occurred.  In this case pass the ti back and 
	// get another location to try.
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Conta_diffe_lengt_there_canno_);
	self.expectedTrxErrors.add(Err_Cannot_Move);
	self.expectedTrxErrors.add(Move_StackHeight40);
	self.expectedTrxErrors.add(SlotIsUnavailable);
	self.expectedTrxErrors.add(ERR_NO_MOVE_ODD);
	self.expectedTrxErrors.add(Move_WillBeOverCap) ;
	self.expectedTrxErrors.add(Err_MoveSize);
	_getNextLocation := false;
	if self.checkErrorWarningHasOccurred() then
		self.sendMsgWithParams('updateNextNum', nextNum);
		_getNextLocation := true;
		return;
	endif;		
	
	self.expectedTrxErrors.add(ItemAlreadyExists);
	if self.checkErrorWarningHasOccurred() then
		self.sendMsgWithParams('updateNextNum', nextNum + 1);
		_getNextLocation := true;
		return;
	endif;	
	
	///app.writeLog(realTI.String &amp; Tab &amp; realTI.id &amp; Tab &amp; realTI.locationId, LogAlways);
	
	self.assertNoTrxErrorsOrWarnings();
	if not isGC and not isOOTL then
		self.assertNotNull(realTI);
		self.assertEqualMsg(global.isValidObject(realTI), true, "Tracked Item (" &amp; tmpID &amp; ") not created for following reason: " &amp; CrLf &amp;
			app.myPassport.getAllErrorsAndWarnsFullAsStr());
	//else
	
	endif;
	
	// update the next number
	self.sendMsgWithParams('updateNextNum', nextNum);
	
	if not self.opts.includesKey("DontDeleteStops") then
		if not isGC and not isOOTL then
			self.deleteStops(realTI);
		elseif isOOTL then
		///	self.deleteStops(_gcOOTLDefn.getLC().allTrackedItems.last());
		else
			self.deleteStops(_gcOOTLDefn.CM_ROROGCDefnVoyage.myGCController.allTrackedItems.last());
		endif;
	endif;
	
epilog

	app.myPassport.setWarningsIgnored(warningsIgnored);
	app.myPassport.setWarningsAcknowledged(warningsAck);

	delete lcs;
	delete moveController;
	
end;</source>
        <Parameter name="_areaOrVoyage" type="Any"/>
        <Parameter name="_location" type="CM_LocationsController" usage="input"/>
        <Parameter name="_getNextLocation" type="Boolean" usage="io"/>
        <Parameter name="_gcOOTLDefn" type="CM_DeckItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xCreateTIsForVoyCargoMeths" id="117e3734-434c-4f57-ab9c-5805864a978b">
        <source>xCreateTIsForVoyCargoMeths(_voyage : CM_Voyage; _slots : CM_LCArray input);

/*

Purpose:		Make the Cargo

Date			Who		Reason
10/03/014	cnwmh5	Initial creation

*/

vars

	cargoType						: CM_CargoType;
	slot 							: CM_LocationsController;
	aftSlot							: CM_LocationsController;
	moveController					: CMIF_MoveController;
	pxyTI							: CM_TrackedItem;
	realTI							: CM_TrackedItem;
	
	lcs								: CM_LCArray;
	
	tmpID							: String;
	warningsIgnored					: Boolean;
	warningsAck						: Boolean;
	
begin


	app.myPassport.setMyTerminal(_voyage.myTerminal);
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);

	//if self.opts.includesKey("CargoType") then
	//	cargoType := app.myRoot.allCargoTypesById[self.opts.int("CargoType")];
	//endif;
	if cargoType = null then
		cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	endif;
	self.assertNotNull(cargoType);
	
	
	create lcs transient;
	
	warningsIgnored := app.myPassport.warningsIgnored;
	app.myPassport.setWarningsIgnored(true);
	warningsAck := app.myPassport.warningsAcknowledged;
	app.myPassport.setWarningsAcknowledged(true);
	
	foreach slot in _slots do
	
		delete moveController;
		create moveController transient;
		moveController.setMyToPrimaryLocation(slot);
		if slot.isKindOf(CM_SlotController) then
			tmpID := _voyage.getNextQuickCargoID(cargoType.id);
		else
			tmpID := _voyage.myROROStructure.getNextQuickCargoID(cargoType.id);
		endif;
		
		self.xCreatePxyForAddVoyCargoMeths(_voyage, cargoType, tmpID, pxyTI);
		
		app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		self.assertNotNull(realTI);
		self.assertEqualMsg(global.isValidObject(realTI), true, "Tracked Item (" &amp; tmpID &amp; ") not created for following reason: " &amp; CrLf &amp;
			app.myPassport.getAllErrorsAndWarnsFullAsStr());
		//app.writeLog(realTI.String &amp; Tab &amp; Tab &amp; "realTI (" &amp; realTI.id &amp; ") has been created" &amp; Tab &amp; 
		//	'slot: ' &amp; slot.ident, LogAlways);
		
		if not self.opts.includesKey("DontDeleteStops") then
			self.deleteStops(realTI);
		endif;
	
	endforeach;
	
epilog

	app.myPassport.setWarningsIgnored(warningsIgnored);
	app.myPassport.setWarningsAcknowledged(warningsAck);

	delete lcs;
	delete moveController;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_slots" type="CM_LCArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="xFixUpTrackedItem" id="7ee6638f-5c40-42fe-a732-ee11ed60f4ce">
        <source>xFixUpTrackedItem(_ti: CM_TrackedItem input);
//18 November 2008	cnwdw1	
//
vars
	trackedItemId: String;
	invalid: Boolean;
	queuedFutureMove : CM_FutureMove;
	allFMs			: CM_FutureMoveArray;
		port			: CM_Port;
	voy : CM_Voyage;
	child : CM_TrackedItem;
	queueTask : CM_RTQueueTask;
	qLoc : CM_LocationsController;
	parent : CM_TrackedItem;
	invalidTerm : Boolean;
begin

	if _ti &lt;&gt; null then
		beginTransaction;
		if not global.isValidObject(_ti.myProduct) then
			_ti.setPropertyValue("myProduct", null);
		endif;
		create allFMs transient;
		foreach queuedFutureMove in _ti.allQueuedFutureMoves do
			if queuedFutureMove.myWorkListEntry = null then
				allFMs.add(queuedFutureMove);
			else
				qLoc := queuedFutureMove.getPrimaryLocation;
				if qLoc = null or qLoc.myTerminal &lt;&gt; _ti.myTerminal then
					allFMs.add(queuedFutureMove);
				endif;
			endif;
		endforeach;	
		allFMs.purge;
		
		allFMs.clear;
		foreach queuedFutureMove in _ti.allPlannedFutureMoves do
			if queuedFutureMove.myWorkListEntry = null then
				allFMs.add(queuedFutureMove);
			else
				delete queuedFutureMove.myWorkListEntry;
				allFMs.add(queuedFutureMove);
			endif;
		endforeach;	
		allFMs.purge;
		
		if not global.isValidObject(_ti.myVoyage) then
			_ti.setPropertyValue("myVoyage", null);
		endif;
		if _ti.myVoyage &lt;&gt; null and _ti.myVoyage.myTerminal &lt;&gt; _ti.myTerminal then
			_ti.setPropertyValue("myVoyage", null);
			queueTask := _ti.queueTask;
			if queueTask &lt;&gt; null then
				delete queueTask;
			endif;
		endif;
		
		voy := _ti.myVoyage;
		if voy &lt;&gt; null then
			port := _ti.getRoot.allPorts[_ti.dischargePort.trimBlanks];
			if port &lt;&gt; null and not voy.includesPort(port) then
				voy.addPortToAllPorts(port);
			endif;
		endif;
		
		// No FMs but has a Qd LC
		if _ti.myPrimaryQueuedLocation &lt;&gt; null and _ti.allQueuedFutureMoves.isEmpty then
			_ti.setPropertyValue("myPrimaryQueuedLocation", null);
		endif;
		if _ti.myPrimaryPlannedLocation &lt;&gt; null and _ti.allPlannedFutureMoves.isEmpty then
			_ti.setPropertyValue("myPrimaryPlannedLocation", null);
		endif;
		commitTransaction;
	endif;
	
	if not _ti.allChildren.isEmpty then
		foreach child in _ti.allChildren do
			if child.myTerminal &lt;&gt; _ti.myTerminal then
				beginTransaction;
				 child.setPropertyValue("myTerminal",_ti.myTerminal);
				commitTransaction;
			endif;
		endforeach;
	endif;
	
	if _ti.isChild then
		parent := _ti.getParent();
		if not parent.allChildren.includes(_ti) then
			if _ti.isKindOf(CM_ClipOnUnit) and parent.isKindOf(CM_Container) then
				beginTransaction;
				parent.setPropertyValue("cou",null);
				commitTransaction;
			endif;	
		endif;
	endif;
	
	if _ti.myTerminal &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, _ti.myTerminal, invalidTerm );
		if _ti.myTerminal.code = null then
			// just de-referncing to fire exception handler if required
		endif;
		if invalidTerm then
			beginTransaction;
			_ti.setPropertyValue("myTerminal",null);
			commitTransaction;
		endif;
	endif;
	
	if  _ti.myPrimaryActualLocation &lt;&gt; null and _ti.myTerminal &lt;&gt; _ti.myPrimaryActualLocation.myTerminal then
		beginTransaction;
		_ti.setPropertyValue("myTerminal",_ti.myPrimaryActualLocation.myTerminal);
		commitTransaction;
	endif;
	
epilog
	abortTransaction;
	delete allFMs;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="xGetBaseLocationsPassedIn" id="47252659-0c75-4f95-b6c2-d3f0f271362a">
        <source>xGetBaseLocationsPassedIn(_locationType : Any; _locationsToFill : Any; _noLocationsToFill : Integer; _locationToFillArray : CM_LCArray io; 
		_singleLocation : Boolean output; _iter : Iterator io) : Integer;

/*

Purpose:		From the locations passed in setup the base locations to use

Date			Who		Reason
03/12/2014		cnwmh5	Initial creation

*/

vars

	theLC						: CM_LocationsController;
	theLC2						: CM_LocationsController;
	terminalArea				: CM_TerminalArea;
	voyage						: CM_Voyage;
	bay							: CM_BayVoyage;
	deck						: CM_DeckVoyage;
	defn						: CM_ROROLocnDefnVoyage;
	defn1						: CM_ROROSlotDefn;

	strs						: StringArray;
	tmpStrs						: StringArray;
	errorArray					: StringArray512;
	
	iter						: Iterator;
	
	index						: Integer;	
	strLoc						: String;
	noLocationsToFill			: Integer;
	isRORO						: Boolean;
	isLOLO						: Boolean;
	isOOTL						: Boolean;
	isRotate					: Boolean;
	isGC						: Boolean;

begin

	create strs transient;
	create tmpStrs transient;
	create errorArray transient;
	
	if _locationType.isKindOf(CM_TerminalArea) then
		terminalArea := _locationType.CM_TerminalArea;
	elseif _locationType.isKindOf(CM_Voyage) then
		voyage := _locationType.CM_Voyage;
		isOOTL := self.opts.includesKey("OOTL") or self.opts.includesKey("OOTL40");
		isRotate := self.opts.includesKey("1x3") or self.opts.includesKey("1x5") or self.opts.includesKey("2x3") or
			self.opts.includesKey("2x5");
		isRORO := self.opts.includesKey("RORO") or isOOTL or isRotate;	
		isGC := self.opts.includesKey("xMetres") and self.opts.includesKey("yMetres") and not isOOTL;
	endif;
		
	// set up the locations collection
	if isRotate then
		theLC := _locationToFillArray.first;
		////noLocationsToFill := _locationToFillArray.size;
		noLocationsToFill := _noLocationsToFill;
	elseif _locationsToFill = null then
	///if _locationsToFill = null then
		if terminalArea &lt;&gt; null then
			if terminalArea.isGridArea then
				theLC := _locationType.CM_GridArea.allGridControllersByRowColumn.first;
				theLC := _locationType.CM_GridArea.getNextAvailableLocation(theLC.CM_GridController);
			else
				theLC := terminalArea.allLocationsControllers.first;
			endif;	
		elseif voyage &lt;&gt; null then
			if isRORO then
				if not isOOTL and not isRotate then
					deck := self.opts.obj("Deck").CM_DeckVoyage;
					if deck &lt;&gt; null then
						theLC := deck.allROROLocnDefnByCode.first.getLC();
					else
						theLC := voyage.myROROStructure.allDecksByCode.first.allROROLocnDefnByCode.first.getLC();
					endif;
				endif;
			else
				theLC := voyage.myCellularVoyageStructure.allBayVoyagesById.first.allSlotControllersByOrdinal.first;
			endif;
		endif;
		if theLC &lt;&gt; null then
			_locationToFillArray.add(theLC);
		endif;
		if isOOTL or isRotate then 
			theLC := _locationToFillArray.first;
		endif;
		
		// get the number of locations we want to fill
		if _noLocationsToFill = 0 then
			noLocationsToFill := 1;
		else	
			noLocationsToFill := _noLocationsToFill;
		endif;
		if not isOOTL and not isRotate then
			_singleLocation := true;
		endif;			
	elseif _locationsToFill.isKindOf(String) or _locationsToFill.isKindOf(StringArray) then
		if _locationsToFill.isKindOf(String) then
			strs.add(_locationsToFill.String);
			if _noLocationsToFill = 0 then
				noLocationsToFill := 1;
			else	
				noLocationsToFill := _noLocationsToFill;
			endif;
			if not isOOTL and not isRotate then
				_singleLocation := true;
			endif;
		else	
			_locationsToFill.StringArray.copy(strs);
			noLocationsToFill := strs.size;
		endif;
		
		// loop through the strings and get the location controllers
		foreach strLoc in strs do
			tmpStrs.clear();
			tmpStrs.add(strLoc);
			if terminalArea &lt;&gt; null then
				terminalArea.findLocation(tmpStrs, false, theLC, index);
			elseif voyage &lt;&gt; null then
				voyage.findLocation(tmpStrs, false, theLC, index);
			endif;
			if theLC &lt;&gt; null then
				_locationToFillArray.add(theLC);
			else
				if terminalArea &lt;&gt; null then
					errorArray.add("Location " &amp; strs[1] &amp; " in area " &amp; terminalArea.id &amp; " does not exist");
				elseif voyage &lt;&gt; null then
					errorArray.add("Location " &amp; strs[1] &amp; " on voyage" &amp; voyage.code &amp; " does not exist");
				endif;
			endif;
		endforeach;
	else
		_locationsToFill.Collection.copy(_locationToFillArray);
		noLocationsToFill := _locationToFillArray.size;
	endif;
	
	// check to see if any invalid locations 
	strLoc := null;
	if not errorArray.isEmpty() then
		strLoc := "The following locations are invalid:" &amp; CrLf &amp; errorArray.concatenate(CrLf);	
//		app.writeLog(strLoc, LogINFO);
	endif;
	self.assertNull(strLoc);
	
	// set the iter to the first in _locationsToFillArray
	if terminalArea &lt;&gt; null then
		if _locationType.isKindOf(CM_StraddleStack) then
			_iter := _locationType.CM_StraddleStack.allGridControllersByRowColumn.createIterator;
			while _iter.next(theLC) and theLC &lt;&gt; _locationToFillArray.first do
			endwhile;
		else
			_iter := terminalArea.allLocationsControllers.createIterator;
			while _iter.back(theLC) and theLC &lt;&gt; _locationToFillArray.first do
			endwhile;
		endif;
	elseif voyage &lt;&gt; null then
		if isRORO then
			if theLC &lt;&gt; null then	
				
				if theLC.isKindOf(CM_ROROGCController) then
					deck := voyage.myROROStructure.allDecksByCode[theLC.CM_ROROGCController.myDeck.code];
				else
					deck := voyage.myROROStructure.allDecksByCode[theLC.CM_ROROSlotController.myDeck.code];
				endif;
			endif;
			if deck = null then
				deck := voyage.myROROStructure.allDecksByCode.first;
			else
				
				if theLC.isKindOf(CM_ROROGCController) then
					_iter := deck.allROROGCDefnByCode.createIterator;
					deck.allROROGCDefnByCode.startKeyGtr(theLC.getID(), _iter);
				else
					_iter := deck.allROROLocnDefnByOrdinal.createIterator;
					deck.allROROLocnDefnByOrdinal.startKeyGtr(theLC.getDefn().CM_ROROLocnDefnVoyage.ordinal, _iter);
				endif;
				
				while _iter.back(defn) do
					
					if defn = theLC.getDefn() then
						break;
					endif;
				endwhile;
			endif;
		else
			if theLC &lt;&gt; null then
				bay := voyage.myCellularVoyageStructure.allBayVoyagesById[theLC.CM_SlotController.myBayVoyage.id];
			endif;
			if bay = null then
				bay := voyage.myCellularVoyageStructure.allBayVoyagesById.first;
			else
				_iter := bay.allSlotControllersByOrdinal.createIterator;
				while _iter.next(theLC2) and theLC2 &lt;&gt; theLC do
				endwhile;
			endif;
		endif;
	endif;
	
	if isOOTL or isRotate then
		if _locationToFillArray.size &lt; noLocationsToFill then
			noLocationsToFill := _locationToFillArray.size;
		else
			
		endif;	
	endif;
	
	return noLocationsToFill;
	
epilog

	delete strs;
	delete tmpStrs;
	delete errorArray;
	delete iter;

end;
</source>
        <Parameter name="_locationType" type="Any"/>
        <Parameter name="_locationsToFill" type="Any"/>
        <Parameter name="_noLocationsToFill" type="Integer"/>
        <Parameter name="_locationToFillArray" type="CM_LCArray" usage="io"/>
        <Parameter name="_singleLocation" type="Boolean" usage="output"/>
        <Parameter name="_iter" type="Iterator" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xGetIsLastHold" id="c213152f-f210-4c02-879a-0768e1a88234">
        <source>xGetIsLastHold(_theLC : CM_LocationsController) : Boolean;

/*

Purpose:		Work out whether we are looking at LOLO or RORO
				If nothing is passed in _locationsToFill then
				will default to LOLO

Date			Who		Reason
05/12/2014		cnwmh5	Initial creation

*/

vars

	isoType						: CM_ISOType;

	isLastHold					: Boolean;
	
begin

	if _theLC &lt;&gt; null then
		if self.opts.includesKey("CargoType") then
						
		else
			if self.opts.includesKey("ISOType") then
				isoType := app.myRoot.allISOTypes[self.opts.str("ISOType")];
			else
				isoType := app.myRoot.allISOTypes["2200"];
			endif;	
			if not isoType.is20ftLong then
				isLastHold := _theLC.CM_SlotController.myBayVoyage.isLastInHold();
			endif;
		endif;
	endif;
	
	return isLastHold;

epilog

	

end;</source>
        <Parameter name="_theLC" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xGetNextLocationToAddTITo" id="cdf3ccb3-4ba6-45e6-9665-9e0d17e16cb0">
        <source>xGetNextLocationToAddTITo(_locationType : Any; _theLC : CM_LocationsController io; _getNextLocation : Boolean; _singleLocation : Boolean; _iter : Iterator io);

/*

Purpose:		Get the next available empty locations to use
				This may still not be usage for the tracked item
				being created

Date			Who		Reason
03/12/2014		cnwmh5	Initial creation

*/

vars

	theLC							: CM_LocationsController;
	terminalArea					: CM_TerminalArea;
	voyage							: CM_Voyage;
	bay								: CM_BayVoyage;
	tempBay							: CM_BayVoyage;
	isoType							: CM_ISOType;
	tempDeck						: CM_DeckVoyage;
	defn							: CM_ROROLocnDefnVoyage;
	
	iter							: Iterator;
	
	indexOf							: Integer;
	count							: Integer;
	maxStackSize					: Integer;
	tempLCRow, tempLCCol, 
	theLC2Row, theLC2Col			: Integer;
	tempLCFH, tempLCFV,
	theLC2FH, theLC2FV				: Boolean;
	isRORO							: Boolean;
	getNextLocationDone				: Boolean;
	isLastHold						: Boolean;
	isOOTL							: Boolean;
	isRotate						: Boolean;
	isGC							: Boolean;
	
begin

	if _locationType.isKindOf(CM_TerminalArea) then
		terminalArea := _locationType.CM_TerminalArea;
	elseif _locationType.isKindOf(CM_Voyage) then
		voyage := _locationType.CM_Voyage;
		isOOTL := self.opts.includesKey("OOTL") or self.opts.includesKey("OOTL40");
		isRotate := self.opts.includesKey("1x3") or self.opts.includesKey("1x5") or self.opts.includesKey("2x3") or
			self.opts.includesKey("2x5");
		isRORO := self.opts.includesKey("RORO") or isOOTL or isRotate;	
		isGC := self.opts.includesKey("xMetres") and self.opts.includesKey("yMetres") and not isOOTL;
	endif;


	if terminalArea &lt;&gt; null then
		// not grid area then just return the first location
		if terminalArea.allLocationsControllers.size = 1 then
			_theLC := terminalArea.allLocationsControllers.first;
			return;
		elseif terminalArea.isGridArea then
			maxStackSize := _locationType.CM_GridArea.heightOfStack;
			
			while true do : exitGetLocationsController
			
				// not getNextLocation so do the following
				if not _getNextLocation then
				
					theLC := _theLC;
					theLC.getRowColumn(tempLCRow, tempLCCol, tempLCFH, tempLCFV);
					_theLC := _locationType.CM_GridArea.getNextAvailableLocation(_theLC.CM_GridController);
					if _theLC = null then
						break exitGetLocationsController;
					endif;
					_theLC.getRowColumn(theLC2Row, theLC2Col, theLC2FH, theLC2FV);
					
					if theLC2Row &lt; tempLCRow or (theLC2Row = tempLCRow and theLC2Col &lt; tempLCCol) then
						_theLC := theLC;
					endif;
					
					
					if _theLC.CM_GridController.isAvailable(-1, null) then
						if _theLC.allTrackedItems.size &lt; maxStackSize then
							break exitGetLocationsController;
						endif;
					endif;
				
				endif;
								
				if terminalArea.isRTGArea then
					_iter.back(_theLC);
				else
					_iter.next(_theLC);
				endif;
				break exitGetLocationsController;
			endwhile;
			return;
		endif;
	elseif voyage &lt;&gt; null then
	
		if isRORO then
		
			while true do : exitLoopRORO
			
				if _theLC &lt;&gt; null then
					defn := _theLC.getDefn().CM_ROROLocnDefnVoyage;
				endif;
				
				
				if _getNextLocation and not getNextLocationDone then
					_iter.back(defn);
					getNextLocationDone := true;
				endif;
				
				if defn &lt;&gt; null then
					_theLC := defn.CM_ROROLocnDefnVoyage.getNextFreeSlotController();
					if _theLC &lt;&gt; null then
						self.xCheckIfGT20FtRtnAftLC(_theLC);
						if _theLC &lt;&gt; null then
							return;
						endif;
					endif;
					tempDeck := defn.myDeck.CM_DeckVoyage;
				endif;
				
				_iter.back(defn);
				
				if defn = null then
					delete iter;
					iter := voyage.myROROStructure.allDecksByCode.createIterator;
					voyage.myROROStructure.allDecksByCode.startKeyGtr(tempDeck.code, iter);
					iter.next(tempDeck);
					if tempDeck = null then
						break exitLoopRORO;
					endif;
					_theLC := tempDeck.allROROLocnDefnByOrdinal.last.getLC();
					delete _iter;
					_iter := tempDeck.allROROLocnDefnByOrdinal.createIterator;
					tempDeck.allROROLocnDefnByOrdinal.startKeyGtr(_theLC.getDefn().CM_ROROLocnDefnVoyage.ordinal, _iter);
					while _iter.back(defn) and defn &lt;&gt; _theLC.getDefn() do
					endwhile;
					endif;
				
			endwhile;	
		
		else
			
			while true do : exitLoop
					
				if _theLC &lt;&gt; null then
					tempBay := _theLC.CM_SlotController.myBayVoyage;
				endif;
				
				if _getNextLocation and not getNextLocationDone then
					_iter.next(_theLC);
					getNextLocationDone := true;
				endif;
				
				if _theLC &lt;&gt; null then
					
					///write method.qualifiedName &amp; Tab &amp; _theLC.getID().String &amp; Tab &amp; _theLC.CM_SlotController.mySlotDefnVoyage.unavailable.String &amp; Tab &amp; 
					///	_theLC.CM_SlotController.hasTIsOfMode(REAL_MODE).String &amp; Tab &amp; 'isLastHold: ' &amp; self.xGetIsLastHold(_theLC).String;
					if not _theLC.CM_SlotController.mySlotDefnVoyage.unavailable and not _theLC.CM_SlotController.hasTIsOfMode(REAL_MODE) and 
							not self.xGetIsLastHold(_theLC) then
						return;
					endif;
			
				endif;
				
				_iter.next(_theLC);
				
				if _theLC = null then
					while true do
						delete iter;
						iter := voyage.myCellularVoyageStructure.allBayVoyagesById.createIterator;
						voyage.myCellularVoyageStructure.allBayVoyagesById.startKeyGtr(tempBay.id, iter);
						iter.next(bay);
						if bay = null then
							break exitLoop;
						endif;
						delete _iter;
						_iter := bay.allSlotControllersByOrdinal.createIterator;
						_iter.next(_theLC);
						if _theLC &lt;&gt; null then
							break;
						endif;
					endwhile;
				endif;
				
			endwhile;
			
		endif;
	endif;
	
	_theLC := null;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_locationType" type="Any"/>
        <Parameter name="_theLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_getNextLocation" type="Boolean"/>
        <Parameter name="_singleLocation" type="Boolean"/>
        <Parameter name="_iter" type="Iterator" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xHandleFileException" id="bd7037da-8a8b-41ec-b784-0b3060dbd638">
        <source>xHandleFileException(_exObj : Exception; _fileName: String) : Integer protected;
//
//27 July 2017	jlgrs1	Initial creation
//
vars

begin
	if _exObj.errorCode = 5003 then
		app.writeLog(_fileName&amp;" not found, so unable to purge.", LogINFO);
		return Ex_Resume_Next;
	elseif _exObj.errorCode = 5030 then
		app.writeLog(_fileName&amp;" being used in other process, so unable to purge.", LogINFO);
		return Ex_Resume_Next;
	endif;
epilog
    return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_fileName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xMakeSureSlotCanAccept" id="0e34e296-caeb-405d-b7f3-2cc20a99dcdd">
        <source>xMakeSureSlotCanAccept(_moveController : CMIF_MoveController io) : Boolean;

/*

Purpose:		Make sure the slot can accept container of the size getting created

Date			Who		Reason
11/03/2014		cnwmh5	Initial creation

*/

vars

	isoType							: CM_ISOType;
	location						: CM_LocationsController;
	loloSlot						: CM_SlotController;
	
	canUseLocation					: Boolean;
	units 							: Real;
	tArray 							: CM_LCArray;
	lc 								: CM_SlotController;
	count 							: Integer;
	
begin
	
	canUseLocation := true;
	
	location := _moveController.myToPrimaryLocation;
	
	if location.isKindOf(CM_SlotController) then
		
		loloSlot := location.CM_SlotController;
		
		canUseLocation := loloSlot.getSpannedToLCsUnitTest(_moveController);
		
		if canUseLocation then
			isoType := _moveController.myTrackedItem.getISOTypeObject();
			if not isoType.is20ftLong then
				beginTransaction;
				if isoType.is40ftLong then
					loloSlot.setIs40ft(true);
					loloSlot.mySlotDefnVoyage.setFortyFrontBack(true, true);
				elseif isoType.is30ftLong then
					loloSlot.setIs30ft(true);
					loloSlot.mySlotDefnVoyage.setPropertyValue("is30", loloSlot.is30ft);
				elseif isoType.is45ftLong then
					loloSlot.setIs45ft(true);
					loloSlot.mySlotDefnVoyage.setPropertyValue("is45", loloSlot.is45ft);
				elseif isoType.is53ftLong then
					loloSlot.setIs53ft(true);
					loloSlot.mySlotDefnVoyage.setPropertyValue("is53", loloSlot.is53ft);
				endif;
				commitTransaction;
			endif;
		endif;
	endif;
	
	return canUseLocation;
	
epilog

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xSetupOOTLRotateIfRequired" id="0b71bf4e-787a-483b-abce-ded8ceeb4606">
        <source>xSetupOOTLRotateIfRequired(_rotate : Boolean; _locationsToFill : CM_LCArray io) : Boolean;

/*

Purpose:		Setup the OOTL and Rotate if required
				At this point it has no cargo in it

Date			Who		Reason
13//11/2014		cnwmh5	Initial creation

*/

vars

	deck					: CM_DeckVoyage;
	ootlLayer 				: CM_DeckLayerLayout;
	vessel					: CM_Vessel;
	allStateData 			: CM_StateDataDict;
	pxyDefn					: CM_ROROLocnDefnVoyage;
	ootlDefn				: CM_ROROLocnDefnVoyage;
	lastDefn 				: CM_ROROLocnDefnVoyage;
	pxyItemLayout			: CM_DeckItemLayout;
	realItemLayout 			: CM_DeckItemLayout;
	realDefn 				: CM_DeckItem;
	isoType					: CM_ISOType;
	slotDefn				: CM_ROROSlotDefnVoyage;
	obj						: Object;
	slotLC					: CM_ROROSlotController;
	slotDefn2				: CM_ROROSlotDefn;
	
	theSlots				: CM_LCArray;
	theSlotsAlt				: CM_LCArray;
	
	numT 					: Integer;
	maxH					: Decimal[12,2];
	xMetres					: Decimal[12,2];
	yMetres 				: Decimal[12,2]; 
	idxSt					: Integer;
	idxEnd 					: Integer;
	locnHeight				: Decimal[12,2];
	locnWidth				: Decimal[12,2];
	locnGap 				: Decimal[12,2];
	idx 					: Integer;
	newCode 				: String;
	ord						: Integer;
	passedString			: String;
	isLoad					: Boolean;
	rotated					: Boolean;
	
begin

	// get the deck
	deck := self.opts.obj("Deck").CM_DeckVoyage;
	if deck = null then
		return false;
	endif;
	
	isLoad := self.opts.bool("Load");

	numT := deck.numTier;
	if numT = 0 then
		numT := 1;
	endif;
	maxH := numT * HEIGHT_FULL_OD;
	maxH := (maxH * 0.3048); // convert to metres
	
	// ### Get the GC Layer for this deck
	///if not isLoad then
		ootlLayer := deck.myDeckLayout.getOOTLLayer(); // Gets or creates
	///else
	///	ootlLayer := deck.myDeckLayout.getCCLoadLayer();
	///endif;
		
	idxEnd := 1;
	idxSt := 1;
		
	if self.opts.bool("OOTL40") then
		idxEnd := 2;
	endif;
	
	// get the iso type so can work out which locations to return
	if self.opts.includesKey("ISOType") then
		isoType := self.getISOType(self.opts.str("ISOType")).CM_ISOType;
	endif;	
		
	xMetres := self.opts.real("xMetres").Decimal;
	yMetres := self.opts.real("yMetres").Decimal;
		
	// ### Get the standard width and gap measurements
	vessel := ootlLayer.getVessel();
	if vessel &lt;&gt; null then
		allStateData := vessel.allStateData;
	endif;
		
	if allStateData = null or allStateData.size= 0 then // PAR 28971
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;
	if not _rotate then
		global.getExtraData(allStateData,RoRoLocationWidth,locnHeight);
		global.getExtraData(allStateData,RoRoLocationLength,locnWidth);
		global.getExtraData(allStateData,RoRoLocationGap,locnGap);
	else
		global.getExtraData(allStateData,RoRoLocationWidth,locnWidth);
		global.getExtraData(allStateData,RoRoLocationLength,locnHeight);
		global.getExtraData(allStateData,RoRoLocationGap,locnGap);
	endif;
	
	app.myPassport.clearErrorsWarnings();
	
	// ### go through each positions required - 1 for 20, 2 for a 40
	// ### the first location is the forward primary location, the backend, if required,
	// ### is aft of the primary, which is basically to the left of the primary
	
	foreach idx in idxSt to idxEnd do
		// Get Unique Ordinal and Code
		ootlDefn := null;
		slotLC := null;
		
		newCode := deck.getLabelForNewLocation(false, true, null, ord);	//11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name
		///write method.qualifiedName() &amp; Tab &amp; 'idx: ' &amp; idx.String &amp; Tab &amp; 'newCode: ' &amp; newCode;
		
		///if newCode = "D1135O" then
		///	write 'time to debug';
		///endif;

		if ootlDefn = null then
			// ### BASIC GRAPHIC for new OOTL Item - OOTL Defn and Layout - locnCargo.isForty
			pxyItemLayout := ootlLayer.setProxyNewItemOOTL(true, xMetres, yMetres, false, true, newCode, White, locnHeight, locnWidth, locnGap);
			pxyItemLayout.setMyDeckLayer(ootlLayer);
			beginTransaction;
			app.myUtilityCA.utlCreateDeckItemLayout(pxyItemLayout, realItemLayout, app.myPassport); 
			
			create pxyDefn transient;
			pxyDefn.setProxy(deck.myVoyageStructure, newCode, null, null, realItemLayout, deck, false, true, false, 0, 0, 0, maxH, numT, 
				ord, ROROLocn_OOTL_AF, 0, lastDefn, ootlLayer, true, true); // PAR 28318
			
			app.myUtilityCA.utlCreateRORODeckItem(pxyDefn, realDefn, app.myPassport);
			commitTransaction;
			ootlDefn := realDefn.CM_ROROLocnDefnVoyage;
			lastDefn := realDefn.CM_ROROLocnDefnVoyage;
			// ## Prepare for back end locn
			lastDefn := ootlDefn;
			if not _rotate then
				xMetres := xMetres + locnGap + locnWidth + (1 / ROROStructurePixelsPerMetre); // PAR 29990
			else
				yMetres := yMetres - locnGap - locnHeight - (1 / ROROStructurePixelsPerMetre); // PAR 29990
			endif;
		endif;
		delete pxyDefn;
		delete pxyItemLayout;
		
		///write method.qualifiedName() &amp; Tab &amp; 'location added: ' &amp; ootlDefn.getNextFreeSlotController().String;
		
		foreach slotDefn2 in ootlDefn.allROROSlotDefnByOrdinal reversed, discreteLock do
			if slotDefn2.isAvailable and slotDefn2.CM_ROROSlotDefnVoyage.mySlotController.allTrackedItems.isEmpty() then
				_locationsToFill.add(slotDefn2.CM_ROROSlotDefnVoyage.mySlotController);
				///write method.qualifiedName() &amp; Tab &amp; 'lc: ' &amp; _locationsToFill[_locationsToFill.size].String &amp; Tab &amp; 
				///	_locationsToFill[_locationsToFill.size].CM_ROROSlotController.ident.String;
			endif;
		endforeach;
		
		
		
	endforeach;
	////commitTransaction;
	
	if isLoad then
	
		ootlDefn := realDefn.CM_ROROLocnDefnVoyage;
	
		create theSlots transient;
		create theSlotsAlt transient;
		foreach slotDefn2 in ootlDefn.allROROSlotDefnByOrdinal reversed, discreteLock do
			theSlots.add(slotDefn2.CM_ROROSlotDefnVoyage.mySlotController);
		endforeach;
		// if this is for 2 locns then myAdjacentSlotAft will not be null and will be the aft slot
		if ootlDefn.myAdjacentSlotAft &lt;&gt; null then
			foreach slotDefn2 in ootlDefn.myAdjacentSlotAft.allROROSlotDefnByOrdinal reversed, discreteLock do
				theSlots.add(slotDefn2.CM_ROROSlotDefnVoyage.mySlotController);
			endforeach;
		endif;
		// if this is for 2 locns then the link between the fwd and aft slot CC are linked when the voyage allocation reference is made
		beginTransaction;
		app.myTrxUA.doUpdateRORORequestVA(theSlots, theSlotsAlt, true, null, 1, LOAD_MOVETYPE, app.myPassport);
		commitTransaction;
		self.assertNoTrxErrorsOrWarnings();
	
	endif;
	
	if _rotate then
		app.myTrxUA.trxUpdateROROLocnDefnRotate(ootlDefn, 1, 1, false, app.myPassport, isLoad);
	endif;
	
	return true;

epilog

	abortTransaction;
	delete theSlots;
	delete theSlotsAlt;

end;</source>
        <Parameter name="_rotate" type="Boolean"/>
        <Parameter name="_locationsToFill" type="CM_LCArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xSetupRotatedCells" id="a41096d6-6dd1-4d53-b213-37c7ab52f977">
        <source>xSetupRotatedCells(_voyage : CM_Voyage; _startingLocations : Any; _locationsToFill : CM_LCArray io) : Boolean;

/*

Purpose:		Rotate the cells an pass the locations back

Date			Who		Reason
13/11/2014		cnwmh5	Initial creation

*/

vars

	theLC							: CM_LocationsController;
	isoType							: CM_ISOType;
	defnLocn						: CM_ROROLocnDefn;
	defnLocn2						: CM_ROROSlotDefn;
	obj								: Object;

	strs							: StringArray;
	tmpLCArray						: CM_LCArray;
	objArray						: CM_ObjectArray;
	locationsToFill 				: CM_LCArray;
	
	iter							: Iterator;

	items							: Integer;
	split							: Integer;
	cellsRotated					: Boolean;
	idx								: Integer;
	maxDiff							: Integer;
	count							: Integer;
	code							: String;
	str								: String;

begin

	///if not _startingLocations.isKindOf(String) then
	///	return false;
	//endif;
	
	cellsRotated := true;

	///create strs	transient;

	// get the items and split details
	if self.opts.includesKey("1x3") then
		items := 3;
		split := 1;
		maxDiff := 2;
	elseif self.opts.includesKey("1x5") then
		items := 5;
		split := 1;
		maxDiff := 4;
	elseif self.opts.includesKey("2x3") then
		items := 6;
		split := 2;
		maxDiff := 5;
	elseif self.opts.includesKey("2x5") then
		items := 10;
		split := 2;
		maxDiff := 10;
	endif;
	
	create locationsToFill transient;
	create strs transient;
	
	if _startingLocations.isKindOf(String) then
		strs.add(_startingLocations.String.trimBlanks());
		_voyage.findLocation(strs, false, theLC, idx);
		if theLC &lt;&gt; null then
			locationsToFill.add(theLC);
		endif;
	elseif _startingLocations.isKindOf(StringArray) then
		foreach str in _startingLocations.StringArray do
			strs.clear();
			strs.add(str);
			_voyage.findLocation(strs, false, theLC, idx);
			if theLC &lt;&gt; null and not locationsToFill.includes(theLC) then
				locationsToFill.add(theLC);
			endif;
		endforeach;
	elseif _startingLocations.isKindOf(Collection) then
		_startingLocations.Collection.copy(locationsToFill);
	endif;
	
	
	// find the location on the voyage
	////strs.add(_startingLocations.String.trimBlanks());
	////_voyage.findLocation(strs, false, theLC, idx);
	////if theLC = null then
	////	return false;
	///endif;
	
	foreach theLC in locationsToFill do
	
		
		// rotate the cells
		app.myTrxUA.trxUpdateROROLocnDefnRotate(theLC.getDefn().CM_ROROLocnDefn, items, split, false, app.myPassport, self.opts.includesKey("isLoad"));
		self.assertNoTrxErrorsOrWarnings();
		
		// get the iso type so can work out which locations to return
		if self.opts.includesKey("ISOType") then
			isoType := self.getISOType(self.opts.str("ISOType")).CM_ISOType;
		endif;	
		
		create objArray transient;
		objArray := theLC.getDefn().CM_ROROLocnDefn.getLocationsForRotationGroup(items, split);
		
		foreach obj in objArray do
			defnLocn := obj.CM_ROROLocnDefn;
			foreach defnLocn2 in defnLocn.allROROSlotDefnByOrdinal discreteLock, reversed do
				_locationsToFill.add(defnLocn2.myROROLocnDen.getLC());
				/////write method.qualifiedName() &amp; Tab &amp; defnLocn2.myROROLocnDen.code;
			endforeach;
		endforeach;
	endforeach;
	
	create tmpLCArray transient;
	_locationsToFill.sortLCsInToSeqOrder();
	
	foreach theLC in _locationsToFill do
		if code &lt;&gt; theLC.getDefn().code then
			code := theLC.getDefn().code;
			count := count + 1;
		endif;
		if count &gt; maxDiff then
			break;
		endif;
		tmpLCArray.add(theLC);
	endforeach;
	
	tmpLCArray.copy(_locationsToFill);
	return cellsRotated;
	
epilog

	delete strs;
	delete tmpLCArray;
	delete objArray;
	delete locationsToFill;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_startingLocations" type="Any"/>
        <Parameter name="_locationsToFill" type="CM_LCArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xmlData_CustomStops" id="c8dadb2d-5c46-499a-b1a5-30013bae161c">
        <source>xmlData_CustomStops(_vesselCode : String; _voyageCode : String; _cargoType : String; _bol : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2025	naviv1	Initial creation

*/

vars
	customStopsXml : String;
begin
	customStopsXml := '&lt;?xml version="1.0" encoding="utf-16"?&gt; &lt;JMTInternalCustomStop xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"&gt;
  &lt;AllCustomStops&gt;
   &lt;CustomStops&gt;
      &lt;isUSCustomMessage&gt;false&lt;/isUSCustomMessage&gt;
      &lt;packCount&gt;2&lt;/packCount&gt;
      &lt;quantity&gt;0&lt;/quantity&gt;
