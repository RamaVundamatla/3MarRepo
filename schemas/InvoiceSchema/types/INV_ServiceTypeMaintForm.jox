    <JadeMethod name="displayService" id="a8490178-ecd4-4b16-abaf-91b8eb021573">
        <source>displayService(_theObject : CM_Service) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2022	navkc1	Initial creation

*/

vars

begin
	if _theObject = null then
		return null;
	else
		return _theObject.CM_Service.name;
	endif;
epilog

