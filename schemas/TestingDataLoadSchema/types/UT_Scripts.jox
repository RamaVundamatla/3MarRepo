    <JadeMethod name="resetData_53179" id="98a35c0c-2e2c-4d5b-888c-18b61a77f7f8">
        <source>resetData_53179();
/*

Purpose:	Reset 53179	

Date		Who		Reason
28/09/2022	navmh5	Initial creation

*/

vars

	terminal				: CM_Terminal;
	terminal1				: CM_Terminal;
	userMenuQuery			: CM_MenuUserQuery;
	user					: CM_User;

begin

	
	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
    terminal := app.myRoot.allTerminals["PNL"];
    if terminal = null then
	   return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// Set passport user
	user := app.myRoot.allUsers["SUPERUSER"];
	app.myPassport.setMyUser(user);
	
	foreach userMenuQuery in CM_MenuUserQuery.instances discreteLock do
		
		terminal1 := userMenuQuery.getMyTerminal();
		if terminal1 = null or terminal1.code &lt;&gt; terminal.code then
			continue;
		endif;
		
		if userMenuQuery.getHeading() &lt;&gt; "Query 53179" then
			continue;
		endif;
		
		beginTransaction;
		delete userMenuQuery;
		commitTransaction;
		
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_53564" id="cd00f1b3-6d9a-4fd1-9684-4c21b253869a">
        <source>resetData_53564();
/*

Purpose:	Reset 53564		

Date		Who		Reason
03/05/2022	navmh5	Initial creation

*/
constants

	VehicleID				: String = "53564";
	TrackedItem1			: String = "PNL53564001";
	
vars
	
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	vehicle					: CM_Vehicle;
	passportTerm 			: CM_Terminal;
	ti						: CM_TrackedItem;
	operator				: CM_Operator;
	gate 					: CM_Gate;
	machine					: CM_Machine;
	queue					: CM_RadioTelemetryQueue;
	task					: CM_RTQueueTask;
	bs						: CM_BlockStack;
	gbs						: CM_ForkLiftStack;
	gbsLocation				: CM_LocationsController;
	
	tasks					: CM_RTQueueTaskArray;
	strs					: StringArray;
	
	taskFound				: Boolean;
	foundHeight				: Integer;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["PNL"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	self.deleteContainer(TrackedItem1);
	self.deleteVehicle(VehicleID);
	
	gate := self.getGate("GATE_VTA");
	self.assertNotNull(gate);
	
	self.opts.clear();
	self.opts.addAssoc("Carrier", "GCS");
	self.opts.addAssoc("Terminal", terminal.code);
	vvr := self.gateInContainer(VehicleID, TrackedItem1, "2200", "MSK", "MT", gate);
		 
	self.moveVehicleToYard(vvr.vehicle);
	
	ti := self.getTrackedItem(TrackedItem1);
	self.assertNotNull(ti);
	
	self.moveRTTask(ti.getQueueEntry(), self.getQueue("TEST53564"));
	
	machine := self.getMachine("F535");
	self.assertNotNull(machine);
	
	queue := self.getQueue("Master");
	self.assertNotNull(queue);
	
	beginTransaction;
	machine.addToQueue(queue, true, 0);
	commitTransaction;
	
	queue := self.getQueue("TEST53564");
	self.assertNotNull(queue);
		
	create tasks transient;
	queue.getAllTasks(tasks);
	
	taskFound := false;
	foreach task in tasks discreteLock do
		
		if task.taskType &lt;&gt; 4 then
			continue;
		endif;
		
		if task.tiId &lt;&gt; "MSC 2200" then
			continue;
		endif;
		
		taskFound := true;
		break;
	
	endforeach;
	
	self.assertTrueMsg(taskFound, "Director Task in queue 'TEST53564' with the details 'MSC 2200' NOT found.....");
	
	bs := self.getTerminalArea("A53564").CM_BlockStack;
	self.assertNotNullMsg(bs, "Block Stack 'A53564' NOT found.....");
	
	beginTransaction;
	task.setSourceLocation(bs.allLocationsControllers.first);
	commitTransaction;
	
	bs := self.getTerminalArea("SHED1").CM_BlockStack;
	self.assertNotNullMsg(bs, "Block Stack 'SHED1' NOT found.....");
	
	beginTransaction;
	task.setTargetLocation(bs.allLocationsControllers.first);
	commitTransaction;
	
	queue := self.getQueue("TEST53564");
	self.assertNotNull(queue);
		
	create tasks transient;
	queue.getAllTasks(tasks);
	
	taskFound := false;
	foreach task in tasks discreteLock do
		
		if task.taskType &lt;&gt; 0 then
			continue;
		endif;
		
		if task.tiId &lt;&gt; "PNL53564002" then
			continue;
		endif;
		
		taskFound := true;
		break;
	
	endforeach;
	
	self.assertTrueMsg(taskFound, "Pickup Task in queue 'TEST53564' with the details 'PNL53564002' NOT found.....");
	
	bs := self.getTerminalArea("A53564").CM_BlockStack;
	self.assertNotNullMsg(bs, "Block Stack 'A53564' NOT found.....");
	
	beginTransaction;
	task.setTargetLocation(bs.allLocationsControllers.first);
	commitTransaction;
		
	ti := self.getTrackedItem("PNL53564002");
	self.assertNotNullMsg(ti, "Unable to find Tracked Item (PNL53564002).....");
	
	self.unqueueTI(ti);
	self.moveQueued(ti, bs);
	self.moveRTTask(ti.getQueueEntry(), self.getQueue("TEST53564"));
	
	queue := self.getQueue("TEST53564");
	self.assertNotNull(queue);
		
	create tasks transient;
	queue.getAllTasks(tasks);
	
	taskFound := false;
	foreach task in tasks discreteLock do
		
		if task.taskType &lt;&gt; 4 then
			continue;
		endif;
		
		if task.tiId &lt;&gt; "MSK 2210" then
			continue;
		endif;
		
		taskFound := true;
		break;
	
	endforeach;
	
	self.assertTrueMsg(taskFound, "Director Task in queue 'TEST53564' with the details 'MSC 2210' NOT found.....");
	
	gbs := self.getTerminalArea("G1").CM_ForkLiftStack;
	self.assertNotNullMsg(bs, "Gridded Block Stack 'G1' NOT found.....");
	
	create strs transient;
	strs.add("D01");
	
	gbs.findLocation(strs, false, gbsLocation, foundHeight);
	
	beginTransaction;
	task.setSourceLocation(gbsLocation);
	commitTransaction;
	
	
	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	
	delete tasks;
	delete strs;

end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_53573" id="6ef4805e-e952-43d3-a613-53de30c1dbaf">
        <source>resetData_53573();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2020	jlgmh5	Initial creation

*/

constants

	VoyageID					: String = "CSCP0000";
	VesselID					: String = "CSCP";

vars

	voyage						: CM_Voyage;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	
	arrivalTS					: TimeStamp;
	departureTS					: TimeStamp;

begin

	app.initialize();
		
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["PNL"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	self.deleteVoyage(VoyageID);
	
	// set arrival and departure dates
	arrivalTS.setDate("05/11/2018".Date);
	arrivalTS.setTime("15:32:00".Time);
	departureTS := arrivalTS;
	departureTS.setDate("05/11/2050".Date);
	
	self.opts.purge();
	self.opts.addAssoc("Trade", "Other");
	self.opts.addAssoc("tsArrival", arrivalTS);
	self.opts.addAssoc("tsDeparture", departureTS);
	self.opts.addAssoc("Terminal", terminal.code);
	
	voyage := self.addVoyageWithContainerStructur(VoyageID, VesselID[1:9], "QUPA", "QUPA");
	if voyage = null then
		app.writeLog("Inward voyage (" &amp; VoyageID &amp; ") was not created.", LogINFO);
	endif;
	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	
end;






</source>
    </JadeMethod>
    <JadeMethod name="resetData_53578" id="636c3a9c-de7e-499f-9204-a2729a8a6139">
        <source>resetData_53578();

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/05/2022	navmk3	Initial creation

*/
constants

	ContId3						: String = "JLG53578A03";
	ContId4						: String = "JLG53578A04";
	ContId5						: String = "JLG53578A05";
	ContId6						: String = "JLG53578A06";
	ContId7						: String = "JLG53578A07";
	ContId8						: String = "JLG53578A08";
	ContId9						: String = "JLG53578A09";
	ContId10					: String = "JLG53578A10";
	ContId11					: String = "JLG53578A11";
	ContId12					: String = "JLG53578A12";
	ContId13					: String = "JLG53578A13";
	ContId14					: String = "JLG53578A14";
	ContId15					: String = "JLG53578A15";
vars
	terminal, passportTerm		: CM_Terminal;
	ti							: CM_TrackedItem;
	voyage 						: CM_Voyage;
	terminalArea				: CM_TerminalArea;
	user						: CM_User;
	forklift					: CM_Machine;
	releaseRequest				: CM_BulkRelease;
	truck						: CM_Vehicle;
	operator					: CM_Operator;
	source, target				: CM_TerminalArea;
	queue						: CM_SubQueue;
	yardJob						: CM_YardInternalJob;
	yardJobSet				: CM_JobSet;
begin
	app.initialize();
	
	/*****************************************************
	 * Terminal - PNL
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("PNLDEFAULT");
	
	terminal := app.myRoot.allTerminals["PNL"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	// delete internal jobs if already exist
	create yardJobSet transient;
	foreach yardJob in CM_YardInternalJob.instances discreteLock where yardJob.jobId = "RRR53578A" do
		yardJobSet.add(yardJob);
	endforeach;
	
	app.myTrxDA.trxDeleteJobs(yardJobSet, app.myPassport);
	
	// queue JLG53578A03 from H3PTI to M4
	ti := self.getTrackedItem(ContId3);
	terminalArea := self.getTerminalArea("M4");
	if ti &lt;&gt; null and terminalArea &lt;&gt; null then
		self.moveQueued(ti, terminalArea.CM_ForkLiftStack.allGridControllersByRowColumn[1,16]);
	endif;

	// queue JLG53578A04 and JLG53578A05 from WASH4 to M4 J04
	ti := self.getTrackedItem(ContId4);
	terminalArea := self.getTerminalArea("M4");
	if ti &lt;&gt; null and terminalArea &lt;&gt; null then
		self.moveQueued(ti, terminalArea.CM_ForkLiftStack.allGridControllersByRowColumn[1,10]);
	endif;
	ti := self.getTrackedItem(ContId5);
	terminalArea := self.getTerminalArea("M4");
	if ti &lt;&gt; null and terminalArea &lt;&gt; null then
		self.moveQueued(ti, terminalArea.CM_ForkLiftStack.allGridControllersByRowColumn[2,10]);
	endif;
	
	// queue JLG53578A06 and JLG53578A07 from WASH3 to H8DROP and M4 J04
	ti := self.getTrackedItem(ContId6);
	terminalArea := self.getTerminalArea("H8DROP");
	if ti &lt;&gt; null and terminalArea &lt;&gt; null then
		self.moveQueued(ti, terminalArea);
	endif;
	ti := self.getTrackedItem(ContId7);
	terminalArea := self.getTerminalArea("H3PTI");
	if ti &lt;&gt; null and terminalArea &lt;&gt; null then
		self.moveQueued(ti, terminalArea);
	endif;
	
	// queue JLG53578A08 and JLG53578A09 from WASH3 to M4 J04 and M4 I05
	ti := self.getTrackedItem(ContId8);
	terminalArea := self.getTerminalArea("M4");
	if ti &lt;&gt; null and terminalArea &lt;&gt; null then
		self.moveQueued(ti, terminalArea.CM_ForkLiftStack.allGridControllersByRowColumn[1,9]);
	endif;
	ti := self.getTrackedItem(ContId9);
	terminalArea := self.getTerminalArea("M4");
	if ti &lt;&gt; null and terminalArea &lt;&gt; null then
		self.moveQueued(ti, terminalArea.CM_ForkLiftStack.allGridControllersByRowColumn[1,10]);
	endif;
	
	// queue JLG53578A10 and JLG53578A11 from H2PTI to H3PTI
	ti := self.getTrackedItem(ContId10);
	terminalArea := self.getTerminalArea("H3PTI");
	if ti &lt;&gt; null and terminalArea &lt;&gt; null then
		self.moveQueued(ti, terminalArea);
	endif;
	ti := self.getTrackedItem(ContId11);
	terminalArea := self.getTerminalArea("H3PTI");
	if ti &lt;&gt; null and terminalArea &lt;&gt; null then
		self.moveQueued(ti, terminalArea);
	endif;
	
	// queue JLG53578A12 and JLG53578A13 from M4 to Q10DROP
	/*ti := self.getTrackedItem(ContId12);
	terminalArea := self.getTerminalArea("Q10DROP");
	if ti &lt;&gt; null and terminalArea &lt;&gt; null then
		self.moveQueued(ti, terminalArea);
	endif;
	ti := self.getTrackedItem(ContId13);
	terminalArea := self.getTerminalArea("Q10DROP");
	if ti &lt;&gt; null and terminalArea &lt;&gt; null then
		self.moveQueued(ti, terminalArea);
	endif;
	*/
	
	deleteReleaseRequest("RRR53578A");
	
	operator := self.getOperator("MSC");
	terminalArea := self.getTerminalArea("M4");
	// Create MT Release
	self.opts.addAssoc("ISOType", "2210");
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc("Terminal Area", terminalArea);
	self.opts.addAssoc("Carrier", self.getCarrier("AAUTO"));
	self.opts.addAssoc("Number", 2);
	releaseRequest := addReleaseByTypeRequestOpts("RRR53578A", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	ti := self.getTrackedItem(ContId12);
	self.deleteStops(ti);
	beginTransaction;
	ti.setSubTerminal(releaseRequest.mySubTerminal, null);
	commitTransaction;
	
	ti := self.getTrackedItem(ContId13);
	self.deleteStops(ti);
	beginTransaction;
	ti.setSubTerminal(releaseRequest.mySubTerminal, null);
	commitTransaction;
	
	source := self.getTerminalArea("M4");
	target := self.getTerminalArea("Q10DROP");
	queue := self.getQueue("ECH - WAREHOUSE MOVES").CM_SubQueue;
	yardJob := self.createInternalDeliveryMove(releaseRequest, source, target, queue, "2210", "GEN2");
	self.assertTrueMsg(yardJob &lt;&gt; null and app.isValidObject(yardJob), "Yard Job is invalid");
	self.assertTrueMsg(not yardJob.allEntries.isEmpty, "Yard Job has no RTQ entries");
	
	yardJob := self.createInternalDeliveryMove(releaseRequest, source, target, queue, "2210", "GEN2");
	self.assertTrueMsg(yardJob &lt;&gt; null and app.isValidObject(yardJob), "Yard Job is invalid");
	self.assertTrueMsg(not yardJob.allEntries.isEmpty, "Yard Job has no RTQ entries");
	
	// queue director task for JLG53578A14 and JLG53578A15 from L5 to trucks
	deleteReleaseRequest("RRR53578B");
	deleteVehicle("TRK53578A");
	deleteVehicle("TRK53578B");
	
	terminalArea := self.getTerminalArea("L5");
	// Create MT Release
	self.opts.addAssoc("ISOType", "451B");
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc("Terminal Area", terminalArea);
	self.opts.addAssoc("Carrier", self.getCarrier("AAUTO"));
	self.opts.addAssoc("Number", 2);
	releaseRequest := addReleaseByTypeRequestOpts("RRR53578B", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);

	ti := self.getTrackedItem(ContId14);
	self.deleteStops(ti);
	beginTransaction;
	ti.setSubTerminal(releaseRequest.mySubTerminal, null);
	commitTransaction;
	
	ti := self.getTrackedItem(ContId15);
	self.deleteStops(ti);
	beginTransaction;
	ti.setSubTerminal(releaseRequest.mySubTerminal, null);
	commitTransaction;
	
	self.opts.addAssoc("release", releaseRequest);
	self.opts.addAssoc("Carrier", self.getCarrier("AAUTO").code);
	self.gateOutContainer("TRK53578A", "", "", null, true, "GATE", null);
	self.gateOutContainer("TRK53578B", "", "", null, true, "GATE", null);
	
	/*
	forklift := self.getMachine("TRF");
	self.machineLogon(forklift);
	self.machineAcceptSpecifiedTask(forklift, ti.allWorklistEntries.first.allRTQueueEntries.first);		
	
	self.machinePickup(forklift);
	self.machineSetdown(forklift, ti , "MWDROP");
	self.machineLogOff(forklift);
	
	ti := self.getTrackedItem(ContId2);
	if ti &lt;&gt; null and terminalArea &lt;&gt; null then
		self.moveQueued(ti, terminalArea.CM_ForkLiftStack.allGridControllersByRowColumn[1,4]);
	endif;
	
	forklift := self.getMachine("TRF");
	self.machineLogon(forklift);
	self.machineAcceptSpecifiedTask(forklift, ti.allWorklistEntries.first.allRTQueueEntries.first);		
	
	self.machinePickup(forklift);
	self.machineSetdown(forklift, ti , "MWDROP");
	self.machineLogOff(forklift);
	*/
	user := app.myRoot.allUsers["PNLDEFAULT"];
	self.assertNotNull(user);
	beginTransaction;
	user.setStateData(ConfigGrp_Web, "isGraphicalView", "True");
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_53588" id="553abfed-fd52-4f28-83da-c91b5d2fd8a7">
        <source>resetData_53588();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2020	jlgmh5	Initial creation

*/

constants

	VoyageID					: String = "YOCH0006";
	VesselID					: String = "YOCH";

vars

	voyage						: CM_Voyage;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	
	arrivalTS					: TimeStamp;
	departureTS					: TimeStamp;

begin

	app.initialize();
		
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["PNL"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	self.deleteVoyage(VoyageID);
	
	// set arrival and departure dates
	arrivalTS.setDate("05/11/2018".Date);
	arrivalTS.setTime("15:32:00".Time);
	departureTS := arrivalTS;
	departureTS.setDate("05/11/2050".Date);
	
	self.opts.purge();
	self.opts.addAssoc("Trade", "Other");
	self.opts.addAssoc("tsArrival", arrivalTS);
	self.opts.addAssoc("tsDeparture", departureTS);
	self.opts.addAssoc("Terminal", terminal.code);
	
	voyage := self.addVoyageWithContainerStructur(VoyageID, VesselID[1:9], "PAC", "PAC");
	if voyage = null then
		app.writeLog("Inward voyage (" &amp; VoyageID &amp; ") was not created.", LogINFO);
	endif;
	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	
end;







</source>
    </JadeMethod>
    <JadeMethod name="resetData_53713" id="b91b318c-1c97-4a7e-9174-b40c66b448cc">
        <updating/>
        <source>resetData_53713() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2022	NAVMP4	Initial creation

*/

constants

	VoyageID1					: String = "MOCH4387";
	VoyageID2					: String = "MOCH4388";
	VoyageID3					: String = "MOCH4389";
	VoyageID4					: String = "MOCH4390";
	VoyageID5					: String = "MOCH4391";
	VesselID					: String = "MOCH1";
	
vars

	voyage1						: CM_Voyage;
	voyage2						: CM_Voyage;
	voyage3						: CM_Voyage;
	voyage4					    : CM_Voyage;
	voyage5						: CM_Voyage;
	operator1					: CM_Operator;
	operator2					: CM_Operator;
	operator3					: CM_Operator;
	aPort 						: CM_Port;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	ti							: CM_Container;
	ti1							: CM_TrackedItem;
	tisToDelete					: StringArray;
	bs						    : CM_BlockStack;
	yardlocation				: CM_LocationsController;
	controller					: CMIF_TranshipTIController;
	
	arrivalTS1					: TimeStamp;
	departureTS1				: TimeStamp;
	arrivalTS2					: TimeStamp;
	departureTS2				: TimeStamp;
	arrivalTS3					: TimeStamp;
	departureTS3				: TimeStamp;
	arrivalTS4					: TimeStamp;
	departureTS4				: TimeStamp;
	arrivalTS5					: TimeStamp;
	departureTS5				: TimeStamp;


begin

	app.initialize();
		
	/*****************************************************
	 * Terminal - PNL
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["PNL"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	// delete the cargoes on terminal and voyage
	create tisToDelete transient;
	tisToDelete.add("PNL53713A01");
	tisToDelete.add("PNL53713A02");
	tisToDelete.add("PNL53713A03");
	tisToDelete.add("PNL53713A04");
	tisToDelete.add("PNL53713A05");
	tisToDelete.add("PNL53713A06");
	tisToDelete.add("PNL53713A07");
	tisToDelete.add("PNL53713A08");
	tisToDelete.add("PNL53713A09");
	tisToDelete.add("PNL53713A10");
	
	tisToDelete.add("PNL53713B01");
	tisToDelete.add("PNL53713B02");
	tisToDelete.add("PNL53713B03");
	tisToDelete.add("PNL53713B04");
	tisToDelete.add("PNL53713B05");
	tisToDelete.add("PNL53713B06");
	tisToDelete.add("PNL53713B07");
	tisToDelete.add("PNL53713B08");
	
	tisToDelete.add("PNL53713C01");
	tisToDelete.add("PNL53713C02");
	tisToDelete.add("PNL53713C03");
	tisToDelete.add("PNL53713C04");
	tisToDelete.add("PNL53713C05");
	tisToDelete.add("PNL53713C06");
	tisToDelete.add("PNL53713C07");
	tisToDelete.add("PNL53713C08");
	tisToDelete.add("PNL53713C09");
	tisToDelete.add("PNL53713C10");
	tisToDelete.add("PNL53713C11");
	tisToDelete.add("PNL53713C12");
	
	tisToDelete.add("PNL53713D01");
	tisToDelete.add("PNL53713D02");
	tisToDelete.add("PNL53713D03");
	tisToDelete.add("PNL53713D04");
	tisToDelete.add("PNL53713D05");
	tisToDelete.add("PNL53713D06");
	tisToDelete.add("PNL53713D07");
	tisToDelete.add("PNL53713D08");
	tisToDelete.add("PNL53713D09");
	tisToDelete.add("PNL53713D10");
	tisToDelete.add("PNL53713D11");
	tisToDelete.add("PNL53713D12");
	
	tisToDelete.add("PNL53713E01");
	tisToDelete.add("PNL53713E02");
	tisToDelete.add("PNL53713E03");
	tisToDelete.add("PNL53713E04");
	tisToDelete.add("PNL53713E05");
	tisToDelete.add("PNL53713E06");
	tisToDelete.add("PNL53713E07");
	tisToDelete.add("PNL53713E08");
	tisToDelete.add("PNL53713E09");
	tisToDelete.add("PNL53713E10");
	tisToDelete.add("PNL53713E11");
	tisToDelete.add("PNL53713E12");
	
	self.deleteTIResetScript(tisToDelete, terminal);
	
	// delete the Voyagees
	self.deleteVoyage(VoyageID1);
	self.deleteVoyage(VoyageID2);
	self.deleteVoyage(VoyageID3);
	self.deleteVoyage(VoyageID4);
	self.deleteVoyage(VoyageID5);
	
	// set arrival and departure dates
	arrivalTS1.setDate("05/01/2040".Date);
	arrivalTS1.setTime("15:32:00".Time);
	departureTS1 := arrivalTS1;
	departureTS1.setDate("05/02/2040".Date);
	
	// create the Voyage MOCH4387
	self.opts.purge();
	self.opts.addAssoc("Trade", "Pacificia : East Coast Service");
	self.opts.addAssoc("tsArrival", arrivalTS1);
	self.opts.addAssoc("tsDeparture", departureTS1);
	self.opts.addAssoc("Terminal", terminal.code);
	
	voyage1 := self.addVoyageWithContainerStructur(VoyageID1, VesselID[1:9], "MSK", "PAC");
	if voyage1 = null then
		app.writeLog("Inward voyage (" &amp; VoyageID1 &amp; ") was not created.", LogINFO);
	endif;
	
	// set arrival and departure dates
	arrivalTS2.setDate("05/01/2041".Date);
	arrivalTS2.setTime("15:32:00".Time);
	departureTS2 := arrivalTS2;
	departureTS2.setDate("05/02/2041".Date);
	
	// create the Voyage MOCH4388
	self.opts.purge();
	self.opts.addAssoc("Trade", "Pacificia : East Coast Service");
	self.opts.addAssoc("tsArrival", arrivalTS2);
	self.opts.addAssoc("tsDeparture", departureTS2);
	self.opts.addAssoc("Terminal", terminal.code);
	
		voyage2 := self.addVoyageWithContainerStructur(VoyageID2, VesselID[1:9], "MES", "PAC");
	if voyage2 = null then
		app.writeLog("Inward voyage (" &amp; VoyageID2 &amp; ") was not created.", LogINFO);
	endif;
	
	// set arrival and departure dates
	arrivalTS3.setDate("05/01/2042".Date);
	arrivalTS3.setTime("15:32:00".Time);
	departureTS3 := arrivalTS3;
	departureTS3.setDate("05/02/2042".Date);
	
    // create the Voyage MOCH4389
	self.opts.purge();
	self.opts.addAssoc("Trade", "Pacificia : East Coast Service");
	self.opts.addAssoc("tsArrival", arrivalTS3);
	self.opts.addAssoc("tsDeparture", departureTS3);
	self.opts.addAssoc("Terminal", terminal.code);

	
		voyage3 := self.addVoyageWithContainerStructur(VoyageID3, VesselID[1:9], "PAC", "PAC");
	if voyage3 = null then
		app.writeLog("Inward voyage (" &amp; VoyageID3 &amp; ") was not created.", LogINFO);
	endif;
	
	// set arrival and departure dates
	arrivalTS4.setDate("05/01/2043".Date);
	arrivalTS4.setTime("15:32:00".Time);
	departureTS4 := arrivalTS4;
	departureTS4.setDate("05/02/2043".Date);
	
	// create the Voyage MOCH4388
	self.opts.purge();
	self.opts.addAssoc("Trade", "Pacificia : East Coast Service");
	self.opts.addAssoc("tsArrival", arrivalTS4);
	self.opts.addAssoc("tsDeparture", departureTS4);
	self.opts.addAssoc("Terminal", terminal.code);
	
		voyage4 := self.addVoyageWithContainerStructur(VoyageID4, VesselID[1:9], "MSK", "PAC");
	if voyage4 = null then
		app.writeLog("Inward voyage (" &amp; VoyageID4 &amp; ") was not created.", LogINFO);
	endif;
	
	// set arrival and departure dates
	arrivalTS5.setDate("05/01/2044".Date);
	arrivalTS5.setTime("15:32:00".Time);
	departureTS5 := arrivalTS5;
	departureTS5.setDate("05/02/2044".Date);
	
	// create the Voyage MOCH4388
	self.opts.purge();
	self.opts.addAssoc("Trade", "Pacificia : East Coast Service");
	self.opts.addAssoc("tsArrival", arrivalTS5);
	self.opts.addAssoc("tsDeparture", departureTS5);
	self.opts.addAssoc("Terminal", terminal.code);
	
		voyage5 := self.addVoyageWithContainerStructur(VoyageID5, VesselID[1:9], "MES", "PAC");
	if voyage5 = null then
		app.writeLog("Inward voyage (" &amp; VoyageID5 &amp; ") was not created.", LogINFO);
	endif;
	operator1 := self.getOperator("MSK");
	self.assertNotNull(operator1);
	
	operator2 := self.getOperator("MES");
	self.assertNotNull(operator2);
	
	operator3 := self.getOperator("PAC");
	self.assertNotNull(operator3);
	
	bs := self.getTerminalArea("SHED1").CM_BlockStack;
	self.assertNotNull(bs);	
	
	// add containers on voyage1
	ti := self.addContainerOnShip("PNL53713A01", operator1, "2210", "MT", null, voyage1, "NZNSN", voyage1.code).CM_Container;	
	ti := self.addContainerOnShip("PNL53713A02", operator1, "4510", "MT", null, voyage1, "NZNSN", voyage1.code).CM_Container;
	ti := self.addContainerOnShip("PNL53713A03", operator2, "2210", "MT", null, voyage1, "NZNSN", voyage1.code).CM_Container;
	ti := self.addContainerOnShip("PNL53713A04", operator2, "2210", "GEN", null, voyage1, "NZNSN", voyage1.code).CM_Container;	
	ti := self.addContainerOnShip("PNL53713A05", operator2, "4510", "MT", null, voyage1, "NZNSN", voyage1.code).CM_Container;
	ti := self.addContainerOnShip("PNL53713A06", operator2, "4510", "GEN", null, voyage1, "NZNSN", voyage1.code).CM_Container;	
	ti := self.addContainerOnShip("PNL53713A07", operator3, "2210", "GEN", null, voyage1, "NZNSN", voyage1.code).CM_Container;
	beginTransaction;
	ti.setLoadPort("AUNTL");
	commitTransaction;
	ti := self.addContainerOnShip("PNL53713A08", operator3, "4510", "GEN", null, voyage1, "NZNSN", voyage1.code).CM_Container;
	beginTransaction;
	ti.setLoadPort("AUNTL");
	commitTransaction;
	ti := self.addContainerOnShip("PNL53713A09", operator3, "2210", "MT", null, voyage1, "NZNSN", voyage1.code).CM_Container;
	ti := self.addContainerOnShip("PNL53713A10", operator3, "4510", "MT", null, voyage1, "NZNSN", voyage1.code).CM_Container;

		
	// create containers on terminal for the voyage MOCH4387
	opts.addAssoc(UTTI_VoyageCode, "MOCH4387");
	opts.addAssoc(UTTI_DischargePort, "NZAKL");
	
	ti := self.addContainerAtLocation("PNL53713B01", operator1, "2210", "MT", TI_IMEX_STATUS_EXPORT, bs);
	ti := self.addContainerAtLocation("PNL53713B02", operator1, "2210", "GEN", TI_IMEX_STATUS_EXPORT, bs);
	ti := self.addContainerAtLocation("PNL53713B03", operator1, "4510", "MT", TI_IMEX_STATUS_EXPORT, bs);
	ti := self.addContainerAtLocation("PNL53713B04", operator1, "4510", "GEN", TI_IMEX_STATUS_EXPORT, bs);	
	ti := self.addContainerAtLocation("PNL53713B05", operator2, "2210", "MT", TI_IMEX_STATUS_EXPORT, bs);
	ti := self.addContainerAtLocation("PNL53713B06", operator2, "4510", "MT", TI_IMEX_STATUS_EXPORT, bs);
	ti := self.addContainerAtLocation("PNL53713B07", operator3, "2210", "MT", TI_IMEX_STATUS_EXPORT, bs);
	ti := self.addContainerAtLocation("PNL53713B08", operator3, "4510", "MT", TI_IMEX_STATUS_EXPORT, bs);	

	
	// create containers on voyageS MOCH4387,MOCH4388,MOCH4389, IMEX - Remain On Board, Transit Status - DLR
	
	ti := self.addContainerOnShip("PNL53713D01", operator1, "2210", "MT", null, voyage1, "NZAKL", voyage1.code).CM_Container;
	self.editIMEXStatus(ti, TI_IMEX_STATUS_REMAINONBOARD, true);
	self.editTRANSITStatus(ti, TI_TransitStatusDLR);
	ti := self.addContainerOnShip("PNL53713D02", operator1, "2210", "GEN", null, voyage1, "NZAKL", voyage1.code).CM_Container;
	self.editIMEXStatus(ti, TI_IMEX_STATUS_REMAINONBOARD, true);
	self.editTRANSITStatus(ti, TI_TransitStatusDLR);
	ti := self.addContainerOnShip("PNL53713D03", operator2, "4510", "MT", null, voyage1, "NZAKL", voyage1.code).CM_Container;
	self.editIMEXStatus(ti, TI_IMEX_STATUS_REMAINONBOARD, true);
	self.editTRANSITStatus(ti, TI_TransitStatusDLR);
	ti := self.addContainerOnShip("PNL53713D04", operator3, "4510", "GEN", null, voyage1, "NZAKL", voyage1.code).CM_Container;
	self.editIMEXStatus(ti, TI_IMEX_STATUS_REMAINONBOARD, true);
	self.editTRANSITStatus(ti, TI_TransitStatusDLR);
	ti := self.addContainerOnShip("PNL53713D05", operator2, "2210", "MT", null, voyage2, "NZAKL", voyage2.code).CM_Container;
	self.editIMEXStatus(ti, TI_IMEX_STATUS_REMAINONBOARD, true);
	self.editTRANSITStatus(ti, TI_TransitStatusDLR);
	ti := self.addContainerOnShip("PNL53713D06", operator2, "2210", "GEN", null, voyage2, "NZAKL", voyage2.code).CM_Container;
	self.editIMEXStatus(ti, TI_IMEX_STATUS_REMAINONBOARD, true);
	self.editTRANSITStatus(ti, TI_TransitStatusDLR);
	ti := self.addContainerOnShip("PNL53713D07", operator1, "4510", "MT", null, voyage2, "NZAKL", voyage2.code).CM_Container;
	self.editIMEXStatus(ti, TI_IMEX_STATUS_REMAINONBOARD, true);
	self.editTRANSITStatus(ti, TI_TransitStatusDLR);
	ti := self.addContainerOnShip("PNL53713D08", operator3, "4510", "GEN", null, voyage2, "NZAKL", voyage2.code).CM_Container;	
	self.editIMEXStatus(ti, TI_IMEX_STATUS_REMAINONBOARD, true);
	self.editTRANSITStatus(ti, TI_TransitStatusDLR);
	ti := self.addContainerOnShip("PNL53713D09", operator3, "2210", "MT", null, voyage3, "NZAKL", voyage3.code).CM_Container;
	self.editIMEXStatus(ti, TI_IMEX_STATUS_REMAINONBOARD, true);
	self.editTRANSITStatus(ti, TI_TransitStatusDLR);
	ti := self.addContainerOnShip("PNL53713D10", operator3, "2210", "GEN", null, voyage3, "NZAKL", voyage3.code).CM_Container;
	self.editIMEXStatus(ti, TI_IMEX_STATUS_REMAINONBOARD, true);
	self.editTRANSITStatus(ti, TI_TransitStatusDLR);
	ti := self.addContainerOnShip("PNL53713D11", operator1, "4510", "MT", null, voyage3, "NZAKL", voyage3.code).CM_Container;
	self.editIMEXStatus(ti, TI_IMEX_STATUS_REMAINONBOARD, true);
	self.editTRANSITStatus(ti, TI_TransitStatusDLR);
	ti := self.addContainerOnShip("PNL53713D12", operator2, "4510", "GEN", null, voyage3, "NZAKL", voyage3.code).CM_Container;
	self.editIMEXStatus(ti, TI_IMEX_STATUS_REMAINONBOARD, true);
	self.editTRANSITStatus(ti, TI_TransitStatusDLR);
	
	
	// create containers on voyageS MOCH4387,MOCH4388,MOCH4389, IMEX - Remain On Board, Transit Status - SOB
	self.opts.addAssoc("Operator", app.myRoot.allOperators["MSK"]);
    ti := self.addContainerAtLocnDisch("PNL53713E01","2210", "MT", TI_IMEX_STATUS_REMAINONBOARD, bs.myLocationsController, aPort, voyage1);
	self.editTRANSITStatus(ti, TI_TransitStatusSOB);
	ti := self.addContainerAtLocnDisch("PNL53713E02","2210", "GEN", TI_IMEX_STATUS_REMAINONBOARD, bs.myLocationsController, aPort, voyage1);
	self.editTRANSITStatus(ti, TI_TransitStatusSOB);
	ti := self.addContainerAtLocnDisch("PNL53713E03","4510", "MT", TI_IMEX_STATUS_REMAINONBOARD, bs.myLocationsController, aPort, voyage1);
	self.editTRANSITStatus(ti, TI_TransitStatusSOB);
	ti := self.addContainerAtLocnDisch("PNL53713E04","4510", "GEN", TI_IMEX_STATUS_REMAINONBOARD, bs.myLocationsController, aPort, voyage1);
	self.editTRANSITStatus(ti, TI_TransitStatusSOB);	
	ti := self.addContainerAtLocnDisch("PNL53713E05","2210", "MT", TI_IMEX_STATUS_REMAINONBOARD, bs.myLocationsController, aPort, voyage2);
	self.editTRANSITStatus(ti, TI_TransitStatusSOB);
	ti := self.addContainerAtLocnDisch("PNL53713E06","2210", "GEN", TI_IMEX_STATUS_REMAINONBOARD, bs.myLocationsController, aPort, voyage2);
	self.editTRANSITStatus(ti, TI_TransitStatusSOB);
	ti := self.addContainerAtLocnDisch("PNL53713E07","4510", "MT", TI_IMEX_STATUS_REMAINONBOARD, bs.myLocationsController, aPort, voyage2);
	self.editTRANSITStatus(ti, TI_TransitStatusSOB);
	ti := self.addContainerAtLocnDisch("PNL53713E08","4510", "GEN", TI_IMEX_STATUS_REMAINONBOARD, bs.myLocationsController, aPort, voyage2);
	self.editTRANSITStatus(ti, TI_TransitStatusSOB);
	ti := self.addContainerAtLocnDisch("PNL53713E09","2210", "MT", TI_IMEX_STATUS_REMAINONBOARD, bs.myLocationsController, aPort, voyage3);
	self.editTRANSITStatus(ti, TI_TransitStatusSOB);
	ti := self.addContainerAtLocnDisch("PNL53713E10","2210", "GEN", TI_IMEX_STATUS_REMAINONBOARD, bs.myLocationsController, aPort, voyage3);
	self.editTRANSITStatus(ti, TI_TransitStatusSOB);
	ti := self.addContainerAtLocnDisch("PNL53713E11","4510", "MT", TI_IMEX_STATUS_REMAINONBOARD, bs.myLocationsController, aPort, voyage3);
	self.editTRANSITStatus(ti, TI_TransitStatusSOB);
	ti := self.addContainerAtLocnDisch("PNL53713E12","4510", "GEN", TI_IMEX_STATUS_REMAINONBOARD, bs.myLocationsController, aPort, voyage3);
	self.editTRANSITStatus(ti, TI_TransitStatusSOB);
	
    // Generate Receive/Release transactions with different imex status
	self.moveAllCargoOnVoyage2(voyage1, bs.myLocationsController);
	self.moveAllCargoOnVoyage2(voyage2, bs.myLocationsController);
	self.moveAllCargoOnVoyage2(voyage3, bs.myLocationsController);
	
	// create containers on voyage MOCH4389
	opts.addAssoc(UTTI_VoyageCode, "MOCH4390");
	opts.addAssoc(UTTI_DischargePort, "NZAKL");
	
	ti := self.addContainerOnShip("PNL53713C01", operator1, "2210", "MT", null, voyage4, "NZAKL", voyage4.code).CM_Container;
	ti := self.addContainerOnShip("PNL53713C02", operator1, "2210", "GEN", null, voyage4, "NZAKL", voyage4.code).CM_Container;
	ti := self.addContainerOnShip("PNL53713C03", operator1, "4510", "MT", null, voyage4, "NZAKL", voyage4.code).CM_Container;
	ti := self.addContainerOnShip("PNL53713C04", operator1, "4510", "GEN", null, voyage4, "NZAKL", voyage4.code).CM_Container;	
	ti := self.addContainerOnShip("PNL53713C05", operator2, "2210", "MT", null, voyage4, "NZAKL", voyage4.code).CM_Container;
	ti := self.addContainerOnShip("PNL53713C06", operator2, "2210", "GEN", null, voyage4, "NZAKL", voyage4.code).CM_Container;	
	ti := self.addContainerOnShip("PNL53713C07", operator2, "4510", "MT", null, voyage4, "NZAKL", voyage4.code).CM_Container;
	ti := self.addContainerOnShip("PNL53713C08", operator2, "4510", "GEN", null, voyage4, "NZAKL", voyage4.code).CM_Container;	
	ti := self.addContainerOnShip("PNL53713C09", operator3, "2210", "MT", null, voyage4, "NZAKL", voyage4.code).CM_Container;
	ti := self.addContainerOnShip("PNL53713C10", operator3, "2210", "GEN", null, voyage4, "NZAKL", voyage4.code).CM_Container;
	ti := self.addContainerOnShip("PNL53713C11", operator3, "4510", "MT", null, voyage4, "NZAKL", voyage4.code).CM_Container;
	ti := self.addContainerOnShip("PNL53713C12", operator3, "4510", "GEN", null, voyage4, "NZAKL", voyage4.code).CM_Container;
	
	foreach ti1 in voyage4.allOnshipTIsByCargoTypeId discreteLock do
			self.deleteStops(ti1);
	
	create controller transient;
	controller.allTrackedItems.add(ti1);
	controller.myExportDestPort    := app.myRoot.allPorts['NZBLU'];
	controller.myExportDisPort     := app.myRoot.allPorts['NZTIU'];
	controller.myExportVoyage      := voyage5;
	controller.remarks             := "53171 Tranship";
	self.makeTrackedItemTranship(controller);
	endforeach;

    self.moveAllCargoOnVoyage2(voyage4, bs.myLocationsController);
	self.moveAllCargoOnVoyage2(voyage5, bs.myLocationsController);
	

	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	
		delete tisToDelete;
		delete controller;

	
end;

</source>
    </JadeMethod>
    <JadeMethod name="resetData_53726" id="03157c48-54e5-41e2-abb8-fe3ed7a75d07">
        <source>resetData_53726();

/*

Purpose:			

Parameters:			

Return Value:		

   Date		     Who		Reason
04 April 2022	navmp4	Initial creation

*/

constants

	VoyageID					: String = "VOY_53726";
	VesselID				    : String = "MSCK";
	CraneId					    : String = "CRN1";

vars
	voyage						: CM_Voyage;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	voyageLoadJob				: CM_VoyageJob;
	tmpLoadCC					: CMIF_LoadColorCode;
	ti							: CM_Container;
	operator					: CM_Operator;
	bs						    : CM_BlockStack;
	vvr						: CM_VehicleVisitRecord;
	vehicle					: CM_Vehicle;
	
	slotsFrom					: CM_SlotControllerArray;
	tisToDelete					: StringArray;
	arrivalTS					: TimeStamp;
	departureTS				    : TimeStamp;
	
begin

	app.initialize();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["TT1"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	self.deleteVehicle("53726");
	
	create tisToDelete transient;
	tisToDelete.add("JLG53726A01");
	
	self.deleteTIResetScript(tisToDelete, terminal);
	
	self.deleteVoyage(VoyageID);
	
	// set arrival and departure dates
	arrivalTS.setDate("05/01/2022".Date);
	arrivalTS.setTime("15:32:00".Time);
	departureTS := arrivalTS;
	departureTS.setDate("05/02/2050".Date);
	
	// create the Voyage MOCH4387
	self.opts.purge();
	self.opts.addAssoc("Trade", "New Zealand East Coast");
	self.opts.addAssoc("tsArrival", arrivalTS);
	self.opts.addAssoc("tsDeparture", departureTS);
	
	voyage := self.addVoyageWithContainerStructur(VoyageID, VesselID[1:9], "MSC", "ANZ");
	if voyage = null then
		app.writeLog("Inward voyage (" &amp; VoyageID &amp; ") was not created.", LogINFO);
	endif;
	
    voyage := self.getVoyage(VoyageID);
	self.assertNotNull(voyage);
	
	// colour code the load slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageID, "45", DeckOnDeck, 1, 1, 1, slotsFrom);
	self.markSlotsAsLoadJob(slotsFrom,tmpLoadCC);
	self.markSlotsAsLoadCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	
	slotsFrom.clear();
	
	self.getJobSlotControllers(VoyageID, "45", DeckOnDeck, 1, 1, 1, slotsFrom);
	
	voyageLoadJob := self.addVoyageJob(voyage, CraneId, slotsFrom, false);
	self.assertNotNull(voyageLoadJob);
	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	delete slotsFrom;		
	delete tisToDelete;
	delete tmpLoadCC;
end;


</source>
    </JadeMethod>
    <JadeMethod name="resetData_53763" id="0eea8e6c-7302-4eeb-8061-6785c6477ddf">
        <source>resetData_53763();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/06/2022	navmh5	Initial creation

*/


vars

	terminal				: CM_Terminal;
	passportTerm			: CM_Terminal;
	ti						: Object;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
				
	
begin

	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["PNL"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("PNL53763A01");
	tisToDelete.add("PNL53763A02");
	tisToDelete.add("PNL53763A03");
	tisToDelete.add("PNL53763A07");
	tisToDelete.add("PNL53763B01");
	tisToDelete.add("PNL53763B02");
	tisToDelete.add("PNL53763B03");
	tisToDelete.add("PNL53763B04");
	tisToDelete.add("PNL53763B05");
	tisToDelete.add("PNL53763B06");
	tisToDelete.add("PNL53763B07");
	tisToDelete.add("PNL53763D01");
	
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, true);
		endif;	
		
	endforeach;

epilog

	app.myPassport.setMyTerminal(passportTerm);

	delete tisToDelete;
	delete tiSet;
	
		
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_53847" id="3913ced7-fedb-4c63-9d57-f1d2d74d03ba">
        <source>resetData_53847();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/06/2022	navmh5	Initial creation

*/


vars

	terminal				: CM_Terminal;
	passportTerm			: CM_Terminal;
	ti						: Object;
	cont					: CM_Container;
	cont2					: CM_Container;
	cont3					: CM_Container;
	operator				: CM_Operator;
	terminalArea			: CM_TerminalArea;
	toDoTask				: CM_ToDoTaskDesc;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
				
	
begin

	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["PNL"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("PNLA6233207");
	tisToDelete.add("PNLA3153666");
	tisToDelete.add("PNLA8566323");
		
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, true);
		endif;	
		
	endforeach;
	
	operator := app.myRoot.allOperators["MSK"].CM_Operator;
	self.assertNotNull(operator);
	
	terminalArea := self.getTerminalArea("H2PTI");
	self.assertNotNull(terminalArea);
	
	self.opts.clear();
	self.opts.addAssoc(UTTI_VoyageCode, "SAGI00001");
	self.opts.addAssoc(UTTI_TotalWeight, 6000.Decimal);
	self.opts.addAssoc("Terminal", terminal.code);
		
	cont := self.addContainerAtLocation(tisToDelete[1], operator, "4532", "MT", TI_IMEX_STATUS_STORAGE, terminalArea).CM_Container;
	self.assertNotNull(cont);
	
	self.opts.clear();
	self.opts.addAssoc(UTTI_VoyageCode, "SAGI00001");
	self.opts.addAssoc(UTTI_TotalWeight, 6000.Decimal);
	self.opts.addAssoc("Remarks", "(PTI quoted stack)");
	self.opts.addAssoc("Terminal", terminal.code);
	
	cont2 := self.addContainerAtLocation(tisToDelete[2], operator, "4532", "MT", TI_IMEX_STATUS_STORAGE, terminalArea).CM_Container;
	self.assertNotNull(cont2);
	
	self.opts.clear();
	self.opts.addAssoc(UTTI_VoyageCode, "CALI00001");
	self.opts.addAssoc(UTTI_TotalWeight, 6000.Decimal);
	self.opts.addAssoc("Terminal", terminal.code);
		
	cont3 := self.addContainerAtLocation(tisToDelete[3], operator, "4532", "MT", TI_IMEX_STATUS_STORAGE, terminalArea).CM_Container;
	self.assertNotNull(cont3);
	
	self.opts.clear();
	self.opts.addAssoc("Terminal", terminal.code);
	self.opts.addAssoc("AvailabilityGrade", 108);
	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(cont3);
		
	// set to do tasks
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey("PTI");
	self.assertNotNull(toDoTask);
	
	tiSet.clear();
	tiSet.add(cont);
	tiSet.add(cont3);
	self.addToDoTask(toDoTask, tiSet);
		
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey("RepSt");
	self.assertNotNull(toDoTask);
	
	tiSet.clear();
	tiSet.add(cont);
	self.addToDoTask(toDoTask, tiSet);
	
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey("QSent");
	self.assertNotNull(toDoTask);
	
	tiSet.clear();
	tiSet.add(cont);
	self.addToDoTask(toDoTask, tiSet);
	
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey("e-pti");
	self.assertNotNull(toDoTask);
	
	tiSet.clear();
	tiSet.add(cont2);
	self.addToDoTask(toDoTask, tiSet);
	
	

epilog

	app.myPassport.setMyTerminal(passportTerm);
	app.myPassport.setWarningsIgnored(false);

	delete tisToDelete;
	delete tiSet;
	
		
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_53849" id="1158b3d7-1911-4d58-ba47-73fb60e4fb9a">
        <source>resetData_53849();
/*

Purpose:	Reset 53848

Date		Who		Reason
29/07/2022	navmh5	Initial creation

*/

constants

	USER_DEF_NAME : String = "JMTInternalCargoOnSite";

vars
	
	terminal				: CM_Terminal;
	passportTerm 			: CM_Terminal;
	ti						: CM_TrackedItem;
	ediFileObj 				: CM_EDIFile;
	ediDataObj 				: CM_EDIData;
	passportObj				: CM_Passport;
	lc						: CM_GapController;
	obj						: Object;
	reeferJob 				: CM_YardActivity;	
	
	tiSet					: CM_TISet;
	tiConnectArray			: ObjectArray;
	tiMonitorArray			: ObjectArray;
	tiDisconnectArray		: ObjectArray;
	lcConnectArray			: ObjectArray;
	connectedArray			: ObjectArray;
	
	count					: Integer;
	errorMsg 				: String;
	ediText					: String;
	now						: TimeStamp;
	str						: String;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["PNL"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	// delete the tracked items
	write "Deleting Tracked Items......";
	app.writeLog("Deleting Tracked Items......", LogINFO);
	create tiSet transient;
	foreach count in 1 to 16 do
		if count &lt; 15 then
			ti := self.getTrackedItem("PNLS00000" &amp; count.String.padLeadingZeros(2));
		else
			ti := self.getTrackedItem("PNLO00000" &amp; count.String.padLeadingZeros(2));
		endif;
		if ti = null then
			continue;
		endif;
		
		tiSet.add(ti);
	endforeach;
	
	foreach ti in tiSet do
		self.deleteTrackedItem(ti, false);
	endforeach;
	
	// load the data
	write "Creating Tracked Items......";
	app.writeLog("Creating Tracked Items......", LogINFO);
	passportObj	:=	app.myPassport;
	ediText := dataSetup_53848();
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME &amp; method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	// Connect reefers
	write "Connecting Reefers......";
	app.writeLog("Connecting Reefers......", LogINFO);
	create tiConnectArray transient;
	create tiMonitorArray transient;
	create tiDisconnectArray transient;
	foreach count in 1 to 16 do
		
		str := "S";
		if count &gt;= 15 then
			str := "O";
		endif;
				
		ti := self.getTrackedItem("PNL" &amp; str &amp; "00000" &amp; count.String.padLeadingZeros(2));
		if ti = null then
			continue;
		endif;
		
		tiMonitorArray.add(ti);
	
		if count = 15 then
			lc := ti.getMyGapPower();
			self.updateTIConnection(ti, true, true, app.actualTimeAppServer, lc);
			tiDisconnectArray.add(ti);
	    elseif count &lt; 5 or count &gt; 8 then
			lc := ti.getMyGapPower();
			self.updateTIConnection(ti, true, true, app.actualTimeAppServer, lc);
		else	
			tiConnectArray.add(ti);
		endif;
	endforeach;
	
	// Create connect walk path jobs
	write "Creating Connect Jobs......";
	app.writeLog("Creating Connect Jobs......", LogINFO);
	now := now.addHours(-3);
	foreach obj in tiConnectArray do
		reeferJob := self.addReeferJob( obj.CM_TrackedItem, CM_YardActivity.ReeferConnect, now );
	endforeach;
	
	// Create monitor walk path jobs
	write "Creating Monitor Jobs......";
	app.writeLog("Creating Monitor Jobs......", LogINFO);
	foreach obj in tiMonitorArray do
		reeferJob := self.addReeferJob( obj.CM_TrackedItem, CM_YardActivity.ReeferMonitor, now );
	endforeach;
	
	// Create disconnect walk path jobs
	write "Creating Disconnect Jobs......";
	app.writeLog("Creating Disconnect Jobs......", LogINFO);
	foreach obj in tiDisconnectArray do
		reeferJob := self.addReeferJob( obj.CM_TrackedItem, CM_YardActivity.ReeferDisconnect, now );
	endforeach;
	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	
	delete tiSet;
	delete tiConnectArray;
	delete tiMonitorArray;
	delete tiDisconnectArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resetData_53850" id="b13e76d4-9cb2-4d81-8e0f-623c73355fe6">
        <source>resetData_53850();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/06/2022	navmh5	Initial creation

*/


vars

	terminal				: CM_Terminal;
	passportTerm			: CM_Terminal;
	ti						: Object;
	cont					: CM_Container;
	cont2					: CM_Container;
	cont3					: CM_Container;
	operator				: CM_Operator;
	terminalArea			: CM_TerminalArea;
	toDoTask				: CM_ToDoTaskDesc;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
				
	
begin

	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["PNL"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("PNLA6233207");
	tisToDelete.add("PNLA3153666");
	tisToDelete.add("PNLA8566323");
		
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, true);
		endif;	
		
	endforeach;
	
	operator := app.myRoot.allOperators["MSK"].CM_Operator;
	self.assertNotNull(operator);
	
	terminalArea := self.getTerminalArea("H2PTI");
	self.assertNotNull(terminalArea);
	
	self.opts.clear();
	self.opts.addAssoc(UTTI_VoyageCode, "SAGI00001");
	self.opts.addAssoc(UTTI_TotalWeight, 6000.Decimal);
	self.opts.addAssoc("Terminal", terminal.code);
		
	cont := self.addContainerAtLocation(tisToDelete[1], operator, "4532", "MT", TI_IMEX_STATUS_STORAGE, terminalArea).CM_Container;
	self.assertNotNull(cont);
	
	self.opts.clear();
	self.opts.addAssoc(UTTI_VoyageCode, "SAGI00001");
	self.opts.addAssoc(UTTI_TotalWeight, 6000.Decimal);
	self.opts.addAssoc("Remarks", "(PTI quoted stack)");
	self.opts.addAssoc("Terminal", terminal.code);
	
	cont2 := self.addContainerAtLocation(tisToDelete[2], operator, "4532", "MT", TI_IMEX_STATUS_STORAGE, terminalArea).CM_Container;
	self.assertNotNull(cont2);
	
	self.opts.clear();
	self.opts.addAssoc(UTTI_VoyageCode, "CALI00001");
	self.opts.addAssoc(UTTI_TotalWeight, 6000.Decimal);
	self.opts.addAssoc("Terminal", terminal.code);
		
	cont3 := self.addContainerAtLocation(tisToDelete[3], operator, "4532", "MT", TI_IMEX_STATUS_STORAGE, terminalArea).CM_Container;
	self.assertNotNull(cont3);
	
	self.opts.clear();
	self.opts.addAssoc("Terminal", terminal.code);
	self.opts.addAssoc("AvailabilityGrade", 108);
	
	app.myPassport.setWarningsIgnored(true);
	self.updateTrackedItem(cont3);
		
	// set to do tasks
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey("PTI");
	self.assertNotNull(toDoTask);
	
	tiSet.clear();
	tiSet.add(cont);
	tiSet.add(cont3);
	self.addToDoTask(toDoTask, tiSet);
		
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey("RepSt");
	self.assertNotNull(toDoTask);
	
	tiSet.clear();
	tiSet.add(cont);
	self.addToDoTask(toDoTask, tiSet);
	
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey("QSent");
	self.assertNotNull(toDoTask);
	
	tiSet.clear();
	tiSet.add(cont);
	self.addToDoTask(toDoTask, tiSet);
	
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey("e-pti");
	self.assertNotNull(toDoTask);
	
	tiSet.clear();
	tiSet.add(cont2);
	self.addToDoTask(toDoTask, tiSet);
	
	

epilog

	app.myPassport.setMyTerminal(passportTerm);
	app.myPassport.setWarningsIgnored(false);

	delete tisToDelete;
	delete tiSet;
	
		
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_53897" id="b9b1563d-81c7-408e-840e-ef6e12a0a5c8">
        <source>resetData_53897();

/*

Purpose:			

Parameters:			

Return Value:		

   Date		     Who		Reason
16 June 2022	navmp4	Initial creation

*/

constants

	VoyageID1					: String = "MSHO0001";
	VoyageID2					: String = "TRF70000";
	VoyageID3					: String = "ACDI0000";
	VesselID1				    : String = "MSHO";
	VesselID2				    : String = "TRF7";
	VesselID3				    : String = "ACDI";


vars
	voyage1						: CM_Voyage;
	voyage2						: CM_Voyage;
	voyage3						: CM_Voyage;
	terminal					: CM_Terminal;
	passportTerm				: CM_Terminal;
	tisToDelete					: StringArray;

	arrivalTS					: TimeStamp;
	departureTS			        : TimeStamp;
	now 						: TimeStamp;

begin

	app.initialize();
	
	/*****************************************************
	 * Terminal - PNL
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	terminal := app.myRoot.allTerminals["PNL"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	self.deleteVoyage(VoyageID1);
	self.deleteVoyage(VoyageID2);
	self.deleteVoyage(VoyageID3);
	
	// set arrival and departure dates
	//arrivalTS.setDate(now.date());
	arrivalTS.setTime(now.time());
	arrivalTS:= now.addDays(-2);
	departureTS := arrivalTS.addDays(1);
	departureTS.setTime("12:00:00".Time);
	
	// create the Voyage MSHO0001
	self.opts.purge();
	self.opts.addAssoc("Trade", "MSC Kiwi Service");
	self.opts.addAssoc("tsArrival", arrivalTS);
	self.opts.addAssoc("tsDeparture", departureTS);
	self.opts.addAssoc("Terminal", terminal.code);

	
	voyage1 := self.addVoyageWithContainerStructur(VoyageID1, VesselID1[1:9], "MSC", "MSC");
	if voyage1 = null then
		app.writeLog("Inward voyage (" &amp; VoyageID1 &amp; ") was not created.", LogINFO);
	endif;
	
	// create the Voyage TRF70000
	self.opts.purge();
	self.opts.addAssoc("Trade", "Toyofuji");
	self.opts.addAssoc("tsArrival", arrivalTS);
	self.opts.addAssoc("tsDeparture", departureTS);
	self.opts.addAssoc("Terminal", terminal.code);

	
	voyage2 := self.addVoyageWithContainerStructur(VoyageID2, VesselID2[1:9], "TYF", "TYF");
	if voyage2 = null then
		app.writeLog("Inward voyage (" &amp; VoyageID2 &amp; ") was not created.", LogINFO);
	endif;

	
	// create the Voyage ACDI0000
	self.opts.purge();
	self.opts.addAssoc("Trade", "Other");
	self.opts.addAssoc("tsArrival", arrivalTS);
	self.opts.addAssoc("tsDeparture", departureTS);
	self.opts.addAssoc("Terminal", terminal.code);
	
	voyage3 := self.addVoyageWithContainerStructur(VoyageID3, VesselID3[1:9], "NYK", "NYK");
	if voyage3 = null then
		app.writeLog("Inward voyage (" &amp; VoyageID3 &amp; ") was not created.", LogINFO);
	endif;	
	

	
epilog

	app.myPassport.setMyTerminal(passportTerm);

end;


</source>
    </JadeMethod>
    <JadeMethod name="resetData_53950" id="e3c9f531-4d54-4d69-b1b5-77b67a9c9b09">
        <source>resetData_53950();

vars
	yaLocations					: ObjectArray;
	locations1					: CM_LCArray;
	terminalArea				: CM_GridArea;
	ya							: CM_YardAllocation;
	terminal, passportTerm		: CM_Terminal;
	ti 							: CM_TrackedItem;
begin

	app.initialize();
	
	/*****************************************************
	 * Terminal - PNL
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("PNLDEFAULT");
	
	terminal := app.myRoot.allTerminals["PNL"];
	if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);

	terminalArea := self.getTerminalArea("A2").CM_GridArea;
	ya := self.getYA("E SAGI00001 2210 53950");

	create yaLocations transient;
	create locations1 transient;
	locations1.add(terminalArea.allGridControllersByRowColumn[4, 3]);
	locations1.clear;
	self.allLocationsBetween(locations1, terminalArea.allGridControllersByRowColumn[4, 3], terminalArea.allGridControllersByRowColumn[4, 3]);
	
	yaLocations.add(locations1);
	
	self.updateYABlocks(ya, yaLocations);

	ya := self.getYA("E CALI00001 NZTRG 4532 TEST 53950");
	
	if (ya &lt;&gt; null) then
	self.deleteYA("E CALI00001 NZTRG 4532 TEST 53950");
	endif;
	
	ya := self.getYA("E CALI00001 NZTRG 4510 TEST 53950");
	
	if (ya &lt;&gt; null) then
	self.deleteYA("E CALI00001 NZTRG 4510 TEST 53950");
	endif;

	ti := self.getTrackedItem("PNL53950A01");
	self.assertNotNull(ti);
	self.unplanTI(ti);
end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_53976" id="9e8257f5-4e33-46cd-b33d-ba7487b3a246">
        <source>resetData_53976();

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/08/2022	navmh5	Initial creation

*/


vars

	tmCargoAllocation		: CM_TranMapCargoAllocation;
	invCargoAllocation		: CM_InvoiceCargoAllocation;
	obj						: Object;
	
	tmFound					: Boolean;

begin

	app.initialize();

	foreach tmCargoAllocation in CM_TranMapCargoAllocation.instances discreteLock do
	
		if tmCargoAllocation.name &lt;&gt; "TEST53976" then
			continue;
		endif;
		
		beginTransaction;
		foreach obj in tmCargoAllocation.allInvoiceCargoAllocations discreteLock do
			invCargoAllocation := obj.CM_InvoiceCargoAllocation;
			
			if invCargoAllocation.code = "CONT IMP MSK RECEIVED - SHIP" then
				delete invCargoAllocation;
				//write invCargoAllocation.String &amp; Tab &amp; invCargoAllocation.code &amp; Tab &amp; invCargoAllocation.description;
			endif;
		
		endforeach;
		commitTransaction;
		
		break;
	
	endforeach;
	
	
	


end;
</source>
    </JadeMethod>
    <JadeMethod name="resetData_54868" id="55481d72-60e4-414e-bb92-2e25466552ea">
        <source>resetData_54868();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/09/2022	navmk3	Initial creation

*/
constants
	ReleaseNumber			= "RELRAIL54868A01";
	RailAreaId				= "RA68";
	WagonClassCode			= "UK";
	WagonMasterCode			= "WGN868";
	TrainCode				= "TRAIN54868";
vars
	terminal, passportTerm			: CM_Terminal;
	release, pxyBulkRelease			: CM_BulkRelease;
	wagonClass						: CM_WagonClass;
	wagonMaster						: CM_WagonMaster;
	train							: CM_Train;
	railArea						: CM_Rail;
	pxyMaster						: CM_WagonMaster;
	wagon							: CM_Wagon;
	allTrackedItems					: CM_TIByIdDups;
	wagMoveControl					: CMIF_WagonMoveController;
	agent							: CM_RailProcessingAgent;
	allWagons						: CM_WagonArray;
	
	cmifObjects : ObjectArray;
	intFaceBP : CMIF_BuildPriority;
	cmifRequest : CMIF_Request;
	obj			: Object;
	railIORake : CM_RailJSInOutRake;
	wle : CM_WorkListEntry;
	railJob : CM_RailJob;
	allWles : CM_WLEArray;
	
begin
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	self.deleteReleaseRequest(ReleaseNumber);
	// add release requests
	self.opts.addAssoc("Number", 2);
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("Voyage", self.getVoyage("MSCK000010").CM_Voyage);
	self.opts.addAssoc("Operator", app.myRoot.allOperators["MSL"].CM_Operator);
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("Carrier", self.getCarrier("AAUTO"));
	
	release := self.addReleaseByTypeRequestOpts(ReleaseNumber, 2, 1);

	// add Bag of Sand request line
	pxyBulkRelease	:=	app.createUpdateProxy(release).CM_BulkRelease;
	self.opts.addAssoc("NoDelete", true);
	self.opts.addAssoc("ProductStr", "BIGSAND");
	self.addReleaseRequestByTypeLine(ReleaseNumber, app.myRoot.allCargoTypesById[10016].id, null, null, 10, pxyBulkRelease);
	
	// add CAR request line
	self.opts.purge();
	delete pxyBulkRelease;
	release := self.getReleaseRequest(ReleaseNumber);
	pxyBulkRelease	:=	app.createUpdateProxy(release).CM_BulkRelease;
	self.opts.addAssoc("NoDelete", true);
	self.addReleaseRequestByTypeLine(ReleaseNumber, app.myRoot.allCargoTypesById[7].id, null, null, 10, pxyBulkRelease);
	
	// add wagon
	self.deleteRailArea(RailAreaId);
	
	wagonClass	:=	app.myRoot.allWagonClasses[WagonClassCode];

	wagonMaster := self.getRoot.allWagonMasters[WagonMasterCode];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	
	self.deleteTrain(TrainCode,null);

		
	// ****** ADD NEW TRAIN
	train := self.addTrain(TrainCode, null);
	self.assertNotNull(train);
	
	// ****** ADD NEW RAIL AREA
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNull(railArea);
	
	// ****** CREATE MASTER FOR SOME REASON
	create pxyMaster transient;
	pxyMaster.setProxy(	WagonMasterCode,	//_id : String;
						wagonClass,	//_myWagonClass : CM_WagonClass;
						CM_Carrier.firstInstance,	//_myCarrier : CM_Carrier;
						300,	//_maxCargoHeight	: Decimal; 
						0,	//_maxCargoWeight	: Decimal;
						0	//_tareWeight	: Decimal
						);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	
	create allTrackedItems transient;
	self.opts.addAssoc("RailLine", railArea.allRailLinesByIndex[1]);
	wagon := self.addWagonToTrainOption2(train, wagonMaster, allTrackedItems, false);
	delete pxyMaster;
	
	// confirm Inwards
	create wagMoveControl transient;
	create allWagons transient;
	allWagons.add(wagon);
	wagMoveControl.myTargetRailLine	:=	railArea.allRailLinesByIndex[2];
	wagMoveControl.targetPosition	:=	1;
	allWagons.copy(wagMoveControl.allWagons);
	wagMoveControl.doAutoPlanOfCargo	:=	true;
	self.ignoreTrxWarnings(true);
		
	app.myTrxUA.trxUpdateWagonConfirmToRail(wagMoveControl, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), "Train/Wagon confirm to Rail failed.");
	
	
	//assign the first 5 break bulk items to outwards rail
	release := self.getReleaseRequest(ReleaseNumber);
	railIORake := railArea.getRailJSInOutRake( Rail_JSIO_Type_Out );
	self.assertTrueMsg( railIORake &lt;&gt; null, "No Rail Area IO Rake not found in pre-test");
	create cmifObjects transient;
	create intFaceBP transient;
	cmifObjects.add(intFaceBP);
	intFaceBP.mode := 1;
	release.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	release.setInterfaceBP(intFaceBP, railIORake);
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNull(cmifRequest);
	//cmifRequest.quantityTxt := 5;
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach obj in cmifObjects do
		intFaceBP := obj.CMIF_BuildPriority;
		delete intFaceBP.myProxyRailJob;
		intFaceBP.allCMIFRequests.purge;
		delete intFaceBP;
	endforeach;
	cmifObjects.purge;
	delete cmifObjects;
	
	create allWles transient;
	foreach railJob in railIORake.railJobs do
		foreach wle in railJob.workListEntries do
			allWles.add( wle );
		endforeach;
	endforeach;
	
	// assign release to wagon
	//Assign the wles to the wagons 
	create agent transient;
	agent.initialise( self.getTerminal );
	agent.doAssignReleasesToWagons( allWles, allWagons, false, false );
epilog
	
end;
	</source>
    </JadeMethod>
    <JadeMethod name="resetData_54873" id="94ce981a-35d2-47c5-a76f-462b47a3f859">
