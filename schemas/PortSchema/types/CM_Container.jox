    <JadeMethod name="is20NextToAGap" id="6a17e714-ec76-4f3d-896a-dd25534243a9">
        <source>is20NextToAGap(pDroppedPosition : String; _terminal : CM_Terminal) : Boolean;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
// PAR 4075 AKB2002NOV
// Note:			Called if changing ISO Typ ethat chnages the length
// Purpose:		if we are a 20 footer and the user is changing our lengththen check whether we will be over a gap
//				i.e. 20' stack location, gap, 20' stack location. If this is the case this is not allowed
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
// ---------------------------------------------------------------------------

vars
	ta	: CM_TerminalArea;
	lc	: CM_LocationsController;
	gc	: CM_GapController;
	tmpLocnString,taString, locnString	: String;
	i, lAccess, colLabelWidth,rowLabelWidth	: Integer;
	theBits : StringArray;
begin
	theBits := pDroppedPosition.getTokens;
	
	if theBits.size &lt; 2 then
		//we can't  find out about gaps
		return false;
	endif;
	
	taString := theBits[1];
	locnString := theBits[2];

	ta := _terminal.allTerminalAreas[taString];
	if ta = null then
//	or not global.isValidObject(ta) then
		return false;
	endif;
	// Gaps are only on Fork Lifts, at the moment, so anything else can not be over a gap
	if not ta.isKindOf(CM_ForkLiftStack) then
		return false;
	endif;
	lc := ta.CM_ForkLiftStack.getLC(locnString);
	if lc = null then
		return false;
	endif;
	
	if lc.CM_StackController.getNextGap = null then
		return false;	
	endif;

	gc := lc.CM_StackController.getNextGap;

	if gc.width = 0 then
		return false;	
	endif;

	return true;
epilog
	delete theBits;
end;</source>
        <Parameter name="pDroppedPosition" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
