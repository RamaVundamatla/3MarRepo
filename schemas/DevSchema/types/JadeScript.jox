    <JadeMethod name="pwCreateAuditConfigs" id="556368f8-906d-4dd1-ab94-7c9ae7cf1974">
        <source>pwCreateAuditConfigs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2022	navpw1	Initial creation TFS: 52752

*/

vars
	root : CM_Root;
	schema : Schema;
	auditConfig : CM_AuditConfig;
	cmObjectClass : Class;
	
	classColl : ClassColl;
	class : Class;
	iterClass : Iterator;
	
	dummyObj : CM_Object;
	transObj : CM_Object;
	canHaveAudits: Boolean;
	auditClass: Class;
	
	iterAuditConfig : Iterator;

begin
	app.initialize();
	
	root := CM_Root.firstInstance;
	
	schema := currentSchema;
	while schema.name &lt;&gt; "PortSchema" do
		schema := schema.superschema;
	endwhile;
	cmObjectClass := CM_Object;
	
	classColl := schema.getAllClasses(false);
	iterClass := classColl.createIterator;
	
	beginTransaction;
	
		// We Audit the fact that we're enabling/disabling CM_AuditConfigs
		// But We might not have one yet, so lets do that first up
		auditConfig := root.allAuditConfigs[ CM_AuditConfig.name ];
		if auditConfig = null then
			//its not there add it.	
			root.createAuditConfig( CM_AuditConfig );	
		endif;
	
	while iterClass.next( class ) do

		if not class.inheritsFrom( CM_Object ) then
			//only interested in classes under CM_Object
			continue;
		endif;
		
		if class.abstract or class.transient then
			continue;
		endif;
		
		if class = CM_AvailableForRelease then
			continue;
		endif;
		
		//check to see whether its supposed to be available
		dummyObj := class.firstInstance.CM_Object;
		
		if dummyObj = null or dummyObj.class = CM_Object then
			create transObj as class transient;
			dummyObj := transObj;
		endif;
						
		canHaveAudits := dummyObj@canHaveAudits;
		auditClass := dummyObj@auditClass;
		
		delete transObj;
		
		if not canHaveAudits or auditClass = null then
			//this class is not audited.
			continue;
		endif;
		
		//If we get to here the class should be able to be audited.
		//check that the audit config has been created
		auditConfig := root.allAuditConfigs[ auditClass.name ];
		if auditConfig = null then
			//its not there add it.	
			auditConfig := root.createAuditConfig( auditClass );
			if not auditConfig.canBeUserDisabled then
				app.myUtilityUA.updAuditConfigSetIsEnable( true, auditConfig, app.myPassport);
			endif;
		endif;
		
	endwhile;
	
	//And one special case - "CM_Edit" / 'Tracked Item Edit' Creates audits against CM_Tracked Item that
	//replicate the values in the 'Edits' created via the Container Enquiry Form.
	auditConfig := root.allAuditConfigs[ CM_Edit.name ];
	if auditConfig = null then
		//its not there add it.	
		root.createAuditConfig( CM_Edit );	
	endif;
	
	//clean up any CM_AuditConfig objects for classes that have been deleted and have no associated audits.
	//i.e. at th etime of writing there was a "CM_TIMasterGroup"
	iterAuditConfig := root.allAuditConfigs.createIterator;
	while iterAuditConfig.next( auditConfig ) do
		class := schema.getClass( auditConfig.className );
		if class = null and auditConfig.allAuditObjects.isEmpty then
			delete auditConfig;
		endif;
	endwhile;
	
	commitTransaction;

epilog

	delete classColl;
	delete iterClass;
	delete iterAuditConfig;

end;</source>
    </JadeMethod>
