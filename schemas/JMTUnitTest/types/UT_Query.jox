    <JadeMethod name="tTransactionQuery" id="89acf02a-4b23-4dd5-a61b-52898b24bfc8">
        <updating/>
        <source>tTransactionQuery()updating;
// cnwns1
// cnwjre1 Mar 2012
// basic cargo transaction query, by id
//** Make sure that each of these methods has distinct cargo ids so they don't see transactions of other methods
vars
	agent : CM_QueryBuilderAgent;
	ti, ti1, ti2, ti3: CM_TrackedItem;
	results: CM_TITransactionSet;
	obj: Object;
	ids	: StringArray;
	iter: Iterator;
	trans	: CM_TITransaction;
	now	: Date;
begin
	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString);
	bs := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	
	self.deleteContainer("UUTU0000001");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 0);
	ti := self.addContainer("UUTU0000001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti, bs);
	assertTrue(ti.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	
	self.deleteContainer("UUTU0000002");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	ti1 := self.addContainer("UUTU0000002", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti1, bs);
	assertTrue(ti1.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti1.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 2);
	
	self.deleteContainer("TEST0000003");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 2);
	ti2 := self.addContainer("TEST0000003", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti2, bs);
	assertTrue(ti2.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti2.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 3);
	
	self.deleteContainer("TEST0000004");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 3);
	ti3 := self.addContainer("TEST0000004", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti3, bs);
	assertTrue(ti3.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti3.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 4);
	
	create agent transient;
	create results transient;
	agent.setResultArray(results);
	agent.setQueryTypeAndMode(CM_QueryDefinition.Transaction_Query_Type, CM_QueryDefinition.CargoTransaction_Query_Mode);
	agent.addCriteria('myTerminal', 'equal to', self.getTerminal());
	agent.addCriteria('dateTime', 'equal to', now.shortFormatJMT);
	agent.addCriteria('id', 'range', "UUT");
	agent.doQuery();
	
	assertTrue(results.size &gt; 0);
	create ids transient;
	iter := results.createIterator;
	
	// should be CM_Create, CM_Move, CM_Receive at least for UUTU000001 and UUTU000002
	while iter.next(obj) do
		trans := obj.CM_TITransaction;
		if trans.isKindOf(CM_Create) then
			ids.add(trans.id);
		endif;
	endwhile;
		
	assertTrueMsg(ids.includes(ti.id), 'Includes ' &amp; ti.id);
	assertTrueMsg(ids.includes(ti1.id), 'Includes ' &amp; ti1.id);
	assertFalseMsg(ids.includes(ti2.id), 'Not include ' &amp; ti2.id);
	assertFalseMsg(ids.includes(ti3.id), 'Not include' &amp; ti3.id);

epilog
	delete agent;
	delete results;
	delete iter;
	delete ids;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTransactionQueryOperator" id="3a120db2-33a2-482e-b9b8-9ce56768af08">
        <updating/>
        <source>tTransactionQueryOperator()updating;
// cnwns1
// cnwjre1 Mar 2012
// basic cargo transaction query, by operator
//** Make sure that each of these methods has distinct cargo ids so they don't see transactions of other methods
vars
	agent : CM_QueryBuilderAgent;
	ti, ti1, ti2, ti3: CM_TrackedItem;
	results: CM_TITransactionSet;
	obj: Object;
	ids	: StringArray;
	iter: Iterator;
	trans	: CM_TITransaction;
	now	: Date;
begin
	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString);
	bs := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	
	self.deleteContainer("UUTU0000011");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 0);
	ti := self.addContainer("UUTU0000011", self.getOperator('UTOP'),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti, bs);
	assertTrue(ti.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	
	self.deleteContainer("UUTU0000012");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	ti1 := self.addContainer("UUTU0000012", self.getOperator('UTO2'),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti1, bs);
	assertTrue(ti1.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti1.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 2);
	
	self.deleteContainer("TEST0000013");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 2);
	ti2 := self.addContainer("TEST0000013", self.getOperator('UTOP'),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti2, bs);
	assertTrue(ti2.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti2.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 3);
	
	self.deleteContainer("TEST0000014");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 3);
	ti3 := self.addContainer("TEST0000014", self.getOperator('UTO2'),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti3, bs);
	assertTrue(ti3.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti3.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 4);
	
	create agent transient;
	create results transient;
	agent.setResultArray(results);
	agent.setQueryTypeAndMode(CM_QueryDefinition.Transaction_Query_Type, CM_QueryDefinition.CargoTransaction_Query_Mode);
	agent.addCriteria('myTerminal', 'equal to', self.getTerminal());
	agent.addCriteria('dateTime', 'equal to', now.shortFormatJMT);
	agent.addCriteria('getCargoOperator', 'equal to', "UTOP");
	agent.doQuery();
	
	assertTrue(results.size &gt; 0);
	create ids transient;
	iter := results.createIterator;
	
	// should be CM_Create, CM_Move, CM_Receive at least for UUTU000011 and TEST0000013
	while iter.next(obj) do
		trans := obj.CM_TITransaction;
		if trans.isKindOf(CM_Create) then
			ids.add(trans.id);
		endif;
	endwhile;
		
	assertTrueMsg(ids.includes(ti.id), 'Includes ' &amp; ti.id);
	assertFalseMsg(ids.includes(ti1.id), 'Not includes ' &amp; ti1.id);
	assertTrueMsg(ids.includes(ti2.id), 'Include ' &amp; ti2.id);
	assertFalseMsg(ids.includes(ti3.id), 'Not include' &amp; ti3.id);

epilog
	delete agent;
	delete results;
	delete iter;
	delete ids;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTransactionQueryOperatorDiff" id="42b40d75-fa95-404f-9505-7d9e05d42be6">
        <updating/>
        <source>tTransactionQueryOperatorDiff()updating;
// cnwns1
// cnwjre1 Mar 2012
// basic cargo transaction query, by cargo/transaction operator difference
//** Make sure that each of these methods has distinct cargo ids so they don't see transactions of other methods
vars
	agent : CM_QueryBuilderAgent;
	ti, ti1, ti2, ti3: CM_TrackedItem;
	results: CM_TITransactionSet;
	obj: Object;
	ids	: StringArray;
	iter: Iterator;
	trans	: CM_TITransaction;
	now	: Date;
begin
	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString);
	bs := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	
	self.deleteContainer("UUTU0000021");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 0);
	ti := self.addContainer("UUTU0000021", self.getOperator('UTOP'),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti, bs);
	assertTrue(ti.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	
	self.deleteContainer("UUTU0000022");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	ti1 := self.addContainer("UUTU0000022", self.getOperator('UTOP'),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti1, bs);
	assertTrue(ti1.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti1.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 2);
	
	self.deleteContainer("TEST0000023");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 2);
	ti2 := self.addContainer("TEST0000023", self.getOperator('UTOP'),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti2, bs);
	assertTrue(ti2.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti2.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 3);
	
	self.deleteContainer("TEST0000024");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 3);
	ti3 := self.addContainer("TEST0000024", self.getOperator('UTOP'),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti3, bs);
	assertTrue(ti3.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti3.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 4);
	// change operator on the last TI
	self.opts.addAssoc("Operator", self.getOperator('UTO2'));
	self.updateTrackedItem(ti3);
	
	create agent transient;
	create results transient;
	agent.setResultArray(results);
	agent.setQueryTypeAndMode(CM_QueryDefinition.Transaction_Query_Type, CM_QueryDefinition.CargoTransaction_Query_Mode);
	agent.addCriteria('myTerminal', 'equal to', self.getTerminal());
	agent.addCriteria('dateTime', 'equal to', now.shortFormatJMT);
	agent.addCriteria('doesOperatorMatch', 'equal to', "No");
	agent.doQuery();
	
	assertTrue(results.size &gt; 0);
	create ids transient;
	iter := results.createIterator;
	
	// should be CM_Create, CM_Move, CM_Receive at least for TEST0000024
	while iter.next(obj) do
		trans := obj.CM_TITransaction;
		if trans.isKindOf(CM_Create) then
			ids.add(trans.id);
		endif;
	endwhile;
		
	assertFalseMsg(ids.includes(ti.id), 'Not include ' &amp; ti.id);
	assertFalseMsg(ids.includes(ti1.id), 'Not include ' &amp; ti1.id);
	assertFalseMsg(ids.includes(ti2.id), 'Not include ' &amp; ti2.id);
	assertTrueMsg(ids.includes(ti3.id), 'Includes ' &amp; ti3.id);

epilog
	delete agent;
	delete results;
	delete iter;
	delete ids;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTransactionQueryType" id="c56a2db9-e1b3-4e91-85a2-dca2ee5f8b76">
        <updating/>
        <source>tTransactionQueryType()updating;
// cnwns1
// cnwjre1 Mar 2012
// basic cargo transaction query, by transaction type
//** Make sure that each of these methods has distinct cargo ids so they don't see transactions of other methods
vars
	agent : CM_QueryBuilderAgent;
	ti, ti1, ti2, ti3: CM_TrackedItem;
	results: CM_TITransactionSet;
	obj: Object;
	ids	: StringArray;
	iter: Iterator;
	trans	: CM_TITransaction;
	now	: Date;
begin
	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString);
	bs := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	
	self.deleteContainer("UUTU0000031");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 0);
	ti := self.addContainer("UUTU0000031", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti, bs);
	assertTrue(ti.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	
	self.deleteContainer("UUTU0000032");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	ti1 := self.addContainer("UUTU0000032", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti1, bs);
	assertTrue(ti1.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti1.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 2);
	
	self.deleteContainer("TEST0000033");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 2);
	ti2 := self.addContainer("TEST0000033", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti2, bs);
	assertTrue(ti2.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti2.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 3);
	
	self.deleteContainer("TEST0000034");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 3);
	ti3 := self.addContainer("TEST0000034", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti3, bs);
	assertTrue(ti3.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti3.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 4);
	self.createTransaction(ti3, global.getTiTxnTypeForClass(CM_Damage), null);
	
	create agent transient;
	create results transient;
	agent.setResultArray(results);
	agent.setQueryTypeAndMode(CM_QueryDefinition.Transaction_Query_Type, CM_QueryDefinition.CargoTransaction_Query_Mode);
	agent.addCriteria('myTerminal', 'equal to', self.getTerminal());
	agent.addCriteria('dateTime', 'equal to', now.shortFormatJMT);
	agent.addCriteria('getTransactionType', 'equal to', app.myRoot.allTransactionTypes[TRANS_TYPE_DAMAGED]);
	agent.doQuery();
	
	assertTrueMsg(results.size &gt; 0, 'Should be some results');
	create ids transient;
	iter := results.createIterator;
	
	// should be CM_Damage for TEST000034 only
	while iter.next(obj) do
		trans := obj.CM_TITransaction;
		if trans.isKindOf(CM_Damage) then
			ids.add(trans.id);
		endif;
	endwhile;
		
	assertFalseMsg(ids.includes(ti.id), 'Not include ' &amp; ti.id);
	assertFalseMsg(ids.includes(ti1.id), 'Not include ' &amp; ti1.id);
	assertFalseMsg(ids.includes(ti2.id), 'Not include ' &amp; ti2.id);
	assertTrueMsg(ids.includes(ti3.id), 'Includes' &amp; ti3.id);

epilog
	delete agent;
	delete results;
	delete iter;
	delete ids;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVoyageDepartureQuery" id="eb1ffbb5-b139-4f41-9d8b-7a2fa08b3350">
        <updating/>
        <source>tVoyageDepartureQuery() updating;
// cnwmp6
/*	

Date		Who		Reason
09 July 2012	cnwmc5	Initial creation - par 29540
// 10 Sep 2019	cnwrs1	TFS 46030
*/

vars
	agent 		: CM_QueryBuilderAgent;
	ti			: CM_TrackedItem;
	results		: CM_TISet;
	vessel 		: CM_Vessel;
	voyage 		: CM_Voyage;
	operator 	: CM_Operator;
	now			: TimeStamp;
	voyageName 	: String;
	boatName	: String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	bs := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	
	operator := getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	voyageName := "UTVOY1" &amp; self.getProfileStr(UT_Profile.P_INITIAL);
	boatName := "UTBOAT" &amp; self.getProfileStr(UT_Profile.P_INITIAL);
	deleteVoyage(voyageName);
	deleteVessel(boatName);
	vessel := addVesselCellular(boatName, operator);
	voyage := addVoyageWithContainerStructur(voyageName, boatName, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	ti := addContainerOnShip("VUT12345678", operator, "2200", "GENL", null, voyage, 'NZPOE', '010682');
	
	create agent transient;
	create results transient;
	agent.setResultArray(results);
	agent.setQueryMode(null);
	agent.addCriteria('myTerminal', 'equal to', getTerminal);
	agent.addCriteria('voyageCode', 'equal to', voyage);
	agent.addCriteria('getVoyageDepartureDate', 'less than', now.addDays(4).date);
	agent.addCriteria('id', 'contains', 'VUT');
	agent.doQuery();
	
	assertTrue(results.size = 1);
	assertTrue(results.includes(ti));
	results.clear();
	delete agent;
	
	create agent transient;
	agent.setResultArray(results);
	agent.setQueryMode(null);
	agent.addCriteria('myTerminal', 'equal to', getTerminal);
	agent.addCriteria('voyageCode', 'equal to', voyage);
	agent.addCriteria('getVoyageDepartureDate', 'greater than', now.date);
	agent.addCriteria('id', 'contains', 'VUT');
	agent.doQuery();
	
	assertTrue(results.size = 1);
	assertTrue(results.includes(ti));
	results.clear();
	delete agent;
	
	create agent transient;
	agent.setResultArray(results);
	agent.setQueryMode(null);
	agent.addCriteria('myTerminal', 'equal to', getTerminal);
	agent.addCriteria('voyageCode', 'equal to', voyage);
	agent.addCriteria('getVoyageDepartureDate', 'equal to', now.addDays(2).date);
	agent.addCriteria('id', 'contains', 'VUT');
	agent.doQuery();
	
	assertTrue(results.size = 1);
	assertTrue(results.includes(ti));
	results.clear();
	delete agent;
	
	create agent transient;
	agent.setResultArray(results);
	agent.setQueryMode(null);
	agent.addCriteria('myTerminal', 'equal to', getTerminal);
	agent.addCriteria('voyageCode', 'equal to', voyage);
	agent.addCriteria('getVoyageDepartureDate', 'greater than', now.date);
	agent.addCriteria('id', 'contains', 'VUT');
	agent.doQuery();
	
	assertTrue(results.size = 1);
	assertTrue(results.includes(ti));
	results.clear();
	delete agent;
	
	create agent transient;
	agent.setResultArray(results);
	agent.setQueryMode(null);
	agent.addCriteria('myTerminal', 'equal to', getTerminal);
	agent.addCriteria('voyageCode', 'equal to', voyage);
	agent.addCriteria('getVoyageDepartureDate', 'less than', now.date);
	agent.addCriteria('id', 'contains', 'VUT');
	agent.doQuery();
	
	assertTrue(results.size = 0);
	assertTrue(not results.includes(ti));
	results.clear();
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete agent;
	delete results;
end;
</source>
    </JadeMethod>
