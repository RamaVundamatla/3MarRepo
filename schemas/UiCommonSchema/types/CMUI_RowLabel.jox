<GUIClass name="CMUI_RowLabel" id="8a267e04-6cd4-41cc-9433-cbeffddf89ad">
    <superclass name="CMUI_Label"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="click" id="b0c33da5-3e0a-4a1a-8735-51a7f4f30bfb">
        <controlMethod name="Label::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(label: Label input) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     13 April 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(label);
	self.parent.CMUI_RowInputDisplayFrame.myRowFrame.handleInputDisplayFrmClick(label.parent.CMUI_RowInputDisplayFrame.myRowFrame.frmInput);

end;</source>
        <Parameter name="label" type="Label" usage="input"/>
    </JadeMethod>
