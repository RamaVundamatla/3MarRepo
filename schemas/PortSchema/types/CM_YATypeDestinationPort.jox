    <JadeMethod name="isSnapShotDataMatch" id="1c08f4ad-bd9a-4515-ab6a-dee95089a583">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;

vars
	obj		: Object;
begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	foreach obj in _criteria.myYAData.CM_YADataObjects.allObjects do
		if obj.CM_Port.code = _propertyValue then
			return true;
		endif;
	endforeach;
	
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="5405a4d9-87e0-4d13-8542-d971bd7d207f">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2023	navmk20	Task 57998: JADE - Storage Config - YA Criteria Storage Matching

*/

vars
	destinationPort		: CM_Port;
	yaData				: CM_YAData;
	myDestinationPort 	: String;
begin

	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then 
		myDestinationPort := _tiTrx.myTrackedItem.destinationPort;
	elseif _ti&lt;&gt; null then
		myDestinationPort := _ti.destinationPort; 
	endif;
	
	if myDestinationPort &lt;&gt; null then
		destinationPort := app.myRoot.allActiveDestinations[ myDestinationPort];
	endif;
	
	yaData := _criteria.myYAData;
	
	if yaData.CM_YADataObjects.matchesStorage(destinationPort) then
		return true;
	endif;
	
	if yaData.isKindOf(CM_YADataPattern) and
	   yaData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
