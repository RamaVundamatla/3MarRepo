    <JadeMethod name="getEDIFilesFromSFTP" id="14098ee8-7bbc-4be5-8f34-33407d8e8dce">
        <updating/>
        <source>getEDIFilesFromSFTP(_object : HugeStringArray) updating;
//
// 19 Sep 2019	cnwrs1	TFS 46528 SFTP
//
vars
	strArray : HugeStringArray;
	count : Integer;
	sftpEntity : CM_SFTPEntity;
	hadError : Boolean;
	sftpRequest : CMIF_SFTPRequest;
	result : String;
	fileName : String;
	destDirectory : String;
	str : String;
	waitingTime : Integer;
	timeOut : Integer;
	oa : ObjectArray;
	obj : Object;
//	files : StringArray;
//	str : StringArray;
begin
	app.initialize;
//	self.logLevel := LogWARN;	//22 Nov 2019	NDL	TFS 47053 - now part of 'initialize'
	process.profiler.methodCount := 50;
	process.profiler.start();
	if _object = null then
		create sftpRequest transient;
		create strArray transient;
		sftpEntity := CM_SFTPEntity.firstInstance;
		sftpRequest.mySFTPEntity := sftpEntity;
		sftpRequest.myTerminal := app.myRoot.allTerminals['UT'];
//		create files transient;
		destDirectory := "c:\Testdb2\c_misc\edi\UT";
		sftpRequest.loadSelf(sftpEntity.getServerNameForConnect(), sftpEntity.userId, sftpEntity.getPwForUse(null), sftpEntity.port, sftpEntity.sourceDirectory, null, destDirectory, null, null, null, null, sftpEntity.timeOut, null);
	else
		strArray := _object.HugeStringArray;
		
		foreach str in strArray do
			if str[1:13] = "destDirectory" then
				destDirectory := str[14:end];
				write class.name&amp;'::'&amp;method.name&amp;' -'&amp;str[14:end]&amp;'-';
			elseif str[1:13] = "CM_SFTPEntity" then
				write class.name&amp;'::'&amp;method.name&amp;' -'&amp;str[15:end]&amp;'-';
			
				sftpEntity := str[15:end].asOid.CM_SFTPEntity;
			elseif str[1:9] = "CMIF_SFTP" then
				write class.name&amp;'::'&amp;method.name&amp;' -'&amp;str[10:end]&amp;'-';
				sftpRequest := str[10:end].asOid.CMIF_SFTPRequest;
			endif;
		endforeach;
		create oa transient;
		CMIF_SFTPRequest.allSharedTransientInstances(oa, 999999, false);
		foreach obj in oa do
			if obj.CMIF_SFTPRequest.mySFTPEntity = sftpEntity then
				sftpRequest := obj.CMIF_SFTPRequest;
				break;
			endif;
		endforeach;
	endif;
	write class.name&amp;'::'&amp;method.name&amp;' 60 '&amp;sftpEntity.String&amp;'-'&amp;sftpRequest.String;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' 33 '&amp;sftpEntity.String&amp;'-'&amp;sftpRequest.String, LogWARN);
	sftpRequest.init();
	sftpRequest.processEdiSFTPGet();
	process.sleep(20000);
	write class.name&amp;'::'&amp;method.name&amp;' 64 '&amp;sftpEntity.String&amp;'-'&amp;sftpRequest.String;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' 33 '&amp;sftpEntity.String&amp;'-'&amp;sftpRequest.String, LogWARN);
epilog
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' epilog', LogINFO);	//26 Nov 2019	NDL	TFS 47053
	delete sftpRequest;
	delete strArray;
//	delete files;

	process.profiler.stop();
	process.profiler.report();
write class.name&amp;'::'&amp;method.name&amp;' END.';
	terminate;
end;</source>
        <Parameter name="_object" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="getEDIKeyFileSegmentType" id="e2c07279-70c5-4e1e-bfcd-23cd984a8e03">
        <source>getEDIKeyFileSegmentType(_keySegment : String) : Integer;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		21 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 21/08/2009 	cnwsh3 		CCMS SFW1868 PAR20300 - CSI Inspection Stop revmoval via CUSRES
//----------------------------------------------------------------------
// 30 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window - NZCS &amp; MPI stops
// 11 Feb 2019  jlggb1	42598 Underbond Movement for One Stop

vars

begin
	if _keySegment = EDIKeySegment_FTXDIN then
		return EDIKeySegment_FTXDIN_Value;
	elseif _keySegment = EDIKeySegment_FTXQIN then
		return EDIKeySegment_FTXQIN_Value;
	elseif _keySegment = EDIKeySegment_GIS then
		return EDIKeySegment_GIS_Value;
	elseif _keySegment = EDIKeySegment_CARST then	//08 Sep 2016	NDL	TFS 2278 / 2670
		return EDIKeySegment_CARST_Value;
	elseif _keySegment = EDIKeySegment_CTORECR then	//08 Sep 2016	NDL	TFS 2278 / 2670
		return EDIKeySegment_CTORECR_Value;	
	elseif _keySegment = EDIKeySegment_SEAOUTR then	//08 Sep 2016	NDL	TFS 2278 / 2670
		return EDIKeySegment_SEAOUTR_Value;	
	elseif _keySegment = EDIKeySegment_AQISHOLD then	//08 Sep 2016	NDL	TFS 2278 / 2670
		return EDIKeySegment_AQISHOLD_Value;	
	elseif _keySegment = EDIKeySegment_XRAYADV then	//08 Sep 2016	NDL	TFS 2278 / 2670
		return EDIKeySegment_XRAYADV_Value;	
	elseif _keySegment = EDIKeySegment_CTOREMR then	//08 Sep 2016	NDL	TFS 2278 / 2670
		return EDIKeySegment_CTOREMR_Value;	
	elseif _keySegment = EDIKeySegment_UBMREQR then	//11 Feb 2019	jlggb1	42598
		return EDIKeySegment_UBMREQR_Value;	
	elseif _keySegment = EDIKeyField_Clearance then	// TFS 39133
		return EDIKeyField_Clearance_Value;	// TFS 39133
	// ### TFS 58834 20July2023 NAVPW1
	elseif _keySegment = EDIKeySegment_MOT then
		return EDIKeySegment_MOT_Value;
	// ### TFS 58834 20July2023 NAVPW1
	endif;

	return null;
epilog
end;</source>
        <Parameter name="_keySegment" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getEDIKeyFileSegmentTypeStr" id="daeef8a7-81c3-45f9-9f1e-e7066fa57e3e">
        <source>getEDIKeyFileSegmentTypeStr(_keySegmentInt : Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2016	cnwndl1	Initial creation	TFS 2278 / 2670
30 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window - NZCS &amp; MPI stops
11 Feb 2019  jlggb1	42598 Underbond Movement for One Stop
*/

vars

begin
	if _keySegmentInt = EDIKeySegment_FTXDIN_Value then
		return EDIKeySegment_FTXDIN;
	elseif _keySegmentInt = EDIKeySegment_FTXQIN_Value then
		return EDIKeySegment_FTXQIN;
	elseif _keySegmentInt = EDIKeySegment_GIS_Value then
		return EDIKeySegment_GIS;
	elseif _keySegmentInt = EDIKeySegment_CARST_Value then	
		return EDIKeySegment_CARST;
	elseif _keySegmentInt = EDIKeySegment_CTORECR_Value then	
		return EDIKeySegment_CTORECR;	
	elseif _keySegmentInt = EDIKeySegment_SEAOUTR_Value then
		return EDIKeySegment_SEAOUTR;	
	elseif _keySegmentInt = EDIKeySegment_AQISHOLD_Value then	
		return EDIKeySegment_AQISHOLD;	
	elseif _keySegmentInt = EDIKeySegment_XRAYADV_Value then	
		return EDIKeySegment_XRAYADV;	
	elseif _keySegmentInt = EDIKeySegment_CTOREMR_Value then	
		return EDIKeySegment_CTOREMR;	
	elseif _keySegmentInt = EDIKeySegment_UBMREQR_Value then	
		return EDIKeySegment_UBMREQR;	
	elseif _keySegmentInt = EDIKeyField_Clearance_Value then // TFS 39133
		return EDIKeyField_Clearance; // TFS 39133
	endif;

	return null;
epilog
end;</source>
        <Parameter name="_keySegmentInt" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEntTableForCompRoadGate" id="fcfb66ce-e54a-4f72-b72c-e842c756e717">
        <source>getEntTableForCompRoadGate( _obj : Object) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2014	cnwrd1	Initial creation

*/

vars
	commodity : CM_Commodity;	
	bulkRelease		: CM_BulkRelease;
	reserve			: CM_ReserveDetail;
	cargoType 	: CM_CargoType;
	ti : CM_TrackedItem;
begin
	
	if _obj = null then
		return null;
	endif;
	
	// Booking Ref check
	if  _obj.isKindOf(CM_BookingRefItem) then

		if _obj.CM_BookingRefItem.cargoType = TI_CargoType_Container then
			commodity := app.myRoot.allCommodities[_obj.CM_BookingRefItem.commodity];
			if commodity &lt;&gt; null and commodity.isEmpty then
				return ETDef_ContainerEmpty;
			else
				return ETDef_ContainerFull;
			endif;
		else
			return ETDef_GeneralCargo;
		endif;
	endif;

	// Bulk Release check
	if _obj.isKindOf(CM_ReserveDetail) then
		reserve			:= _obj.CM_ReserveDetail;
		bulkRelease		:= reserve.myReserveHeader;


		cargoType := reserve.getCargoType();
		if cargoType = null then
			return null;
		endif;
		
		if cargoType.id = TI_CargoType_Container then
			if bulkRelease.fullRelease then
				return ETDef_ContainerFull;
			else
				return ETDef_ContainerEmpty;
			endif;
		else
			return ETDef_GeneralCargo;
		endif;	
	endif;

		
	// Tracked Item check
	if _obj.isKindOf(CM_TrackedItem) then
		ti := _obj.CM_TrackedItem;

		if ti.cargoType = TI_CargoType_Container then
			commodity := ti.getCommodityObject();
			if commodity &lt;&gt; null then 
				if commodity.isEmpty then
					return ETDef_ContainerEmpty;
				else
					return ETDef_ContainerFull;
				endif;
			else
				return ETDef_ContainerEmpty;
			endif;
		else
			return ETDef_GeneralCargo;
		endif;

	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEntTableRowTranslation" id="13acbc80-e006-482c-8851-9b42117d6042">
        <source>getEntTableRowTranslation(_entRow : String; _entGrp : String) : String;
/*

Purpose:			Return translation of ent table row
					Pass in the entRow Global Constant &amp; the Category this should get a unique EntTableRow object and
					and then return the translation
Parameters:			

Return Value:		


Date		Who		Reason
14 August 2012	cnwer1	Initial creation CCMS SFW 1280

*/

vars
	entTableHeader : EntTableRowHeader;
	entTableRow, foundEntTableRow : EntTableRow;
	translation : XLAT_Translation;
begin
	entTableHeader:=self.myRoot.myEntTableDataRoot.allEntTableRowHeadersByName[_entRow];
	
	if entTableHeader = null then
		return null;
	endif;
	
	foreach entTableRow in entTableHeader.allEntTableRows do
		if entTableRow.myGroup = null then
			continue;
		endif;
		if entTableRow.myGroup.name = _entGrp then
			foundEntTableRow:=entTableRow;
			break;
		endif;
	endforeach;
	
	if foundEntTableRow &lt;&gt; null then
		translation:= foundEntTableRow.getTranslation(self.myCurrentLocale);
	endif;
	
	if translation = null and foundEntTableRow &lt;&gt; null then
		// try with default locale
		translation:= foundEntTableRow.getTranslation(self.myRoot.getLocale(StandardTextLocaleStr, false));
	endif;
	
	if translation &lt;&gt; null then
		return translation.text;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_entRow" type="String"/>
        <Parameter name="_entGrp" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorString" id="ce2239a9-1b1f-4aca-9257-ee6aaa12d793">
        <source>getErrorString(errorCode : Integer) : String;

vars
	errMsg : XLAT_Translation;
begin

	if errorCode &lt; self.baseErrorNum then
		return self.getJadeErrorString(errorCode);
	endif;

	errMsg := self.zGetTranslatedText(XLAT_Exceptions, errorCode);
	if errMsg &lt;&gt; null then
		if app.useShortErrorMsg and errMsg.shortText &lt;&gt; null then
			return errMsg.shortText;
		endif;
		return errMsg.text;	
	endif;
//	return "Error " &amp; errorCode.String &amp; ": Unknown message";		// cnwrl1 22/05/2009 PAR 19668 - CCMS 1814
	return "Error " &amp; errorCode.String &amp; UnknownMessage;
end;</source>
        <Parameter name="errorCode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorString1" id="c5f17aa8-bd18-4ef8-a12d-39705734a83c">
        <source>getErrorString1(errorCode : Integer; param : String) : String;

/*

Date		Who		Reason
21 May 2008	cnwkpd1	PAR #16687 - Correct String too long errors in error messages

*/

vars
	errMsg : XLAT_Translation;
	sa : HugeStringArray;
		
begin
	if errorCode &lt; self.baseErrorNum then
		return getJadeErrorString(errorCode);
	endif;
	errMsg := self.zGetTranslatedText(XLAT_Exceptions, errorCode);
	if errMsg = null then
//		return "Error " &amp; errorCode.String &amp; ": Unknown message";	// cnwrl1 22/05/2009 PAR 19668 - CCMS 1814
		return "Error " &amp; errorCode.String &amp; UnknownMessage;
	endif;
	
	create sa transient;
	sa.addTruncated(param);		//	sa[1] := param;		PAR #16687
	
	return errMsg.getTextWithSubstitutedParams(sa);	
	
epilog
	delete sa;
	
end;</source>
        <Parameter name="errorCode" type="Integer"/>
        <Parameter name="param" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
