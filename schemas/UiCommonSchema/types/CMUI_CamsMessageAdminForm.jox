    <JadeMethod name="doSelectUnselectAll" id="fd542500-2b44-4125-8407-d0a3b9bc9ffa">
        <source>doSelectUnselectAll(_select : Boolean; _table : CMUI_ListTable input);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/
vars
	idx : Integer;

begin
	foreach idx in 1 to _table.rows do
		_table.accessCell(idx, 1).text := _select.cnEcGetTableCheckBoxValue();
	endforeach;
epilog

end;</source>
        <Parameter name="_select" type="Boolean"/>
        <Parameter name="_table" type="CMUI_ListTable" usage="input"/>
    </JadeMethod>
