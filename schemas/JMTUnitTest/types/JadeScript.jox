    <JadeMethod name="checkExternalFinSysTermConfig" id="9ccfcb23-f1f8-477d-af8d-c134c9ec1818">
        <source>checkExternalFinSysTermConfig();

/*

Purpose:		Check that the Terminal Config - External Financial System has been set	

Date			Who		Reason
27/05/013		cnwmh5	Initial creation

*/

vars

	term					: CM_Terminal;
	finIOClass 				: CM_ExtFinanceIO;
	
begin


	foreach term in CM_Terminal.instances discreteLock do
		write term.code;
		finIOClass := term.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		if finIOClass = null then
			write 'External Financial System (Terminal Config | Financial is not set for Terminal (' &amp; term.code &amp; ')';
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="checkForAppMyRoot" id="6f9a1844-c918-4f6a-bf72-c3d25547d3e6">
        <source>checkForAppMyRoot();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2012	cnwmc5	Initial creation

*/

vars
	klass				: Class;
	meth				: Method;
	
	classes				: ClassColl;
	methodsDict			: MethodNDict;
	
	iter				: Iterator;
	
	itemsFoundArray		: StringArray512;
	
	str					: String;
	msgStr				: String;
	methSource			: String;
	sourceLine			: String;
	
	totalCount			: Integer;
	lineCount			: Integer;
	length				: Integer;
	posCrLf				: Integer;
	
begin
	// get the class
	klass := currentSchema.getClass("UT_DSL");
	if klass = null then
		return;
	endif;
	
	// get all the subclasses
	create classes transient;
	klass.allLocalSubclasses(classes);
	classes.add(klass);
	
	create itemsFoundArray transient;
	
	// read through all the class methods source code to see if any of the no nos are found
	foreach klass in classes do
		
		methodsDict := klass.cnGetMethods();
		delete iter;
		iter := methodsDict.createIterator;
		while iter.next(meth) do
			methSource := meth.getSource();
			methSource.cnReplaceString(Tab, " ");
			length := methSource.length;
			
			if not methSource.cnContains("app.myRoot") then
				continue;
			endif;
			
			posCrLf := -1;
			lineCount := 0;
				
			// Read the source and see what is currently already defined
			// read through the file getting current constants
			while true do
				if methSource &lt;&gt; null then
					if posCrLf = -1 then
						posCrLf := 1;
					else
						posCrLf := posCrLf + 2;
					endif;
					if (posCrLf + 2) &gt; methSource.length then
						break;
					endif;
					methSource := methSource[posCrLf:end];
				endif;
				
				posCrLf := 1;
				posCrLf := methSource.pos(CrLf, posCrLf);
				if posCrLf = 0 or (posCrLf + 1) &gt; length then
					break;
				endif;
				sourceLine := methSource[1:posCrLf-1];
				lineCount := lineCount + 1;
				
				// Filter out this stuff
				if not sourceLine.cnContains("app.myRoot.") or sourceLine.cnContains("foreach") or sourceLine.cnContains("ETRow_") or sourceLine.cnContains("ETDef_") or 
					sourceLine.cnContains("allPorts") or sourceLine.cnContains("isClient") or sourceLine.cnContains("allTidalClasses") or sourceLine.cnContains("allImexStatuses") or 
					sourceLine.cnContains("baseErrorNum") or sourceLine.cnContains("createIterator") or sourceLine.cnContains("myRootCompany;") or
					sourceLine.cnContains("TI_CONTENTS_STATUS_") or sourceLine.cnContains("EVENT_POWER_OFF_EXCEEDED") or sourceLine.cnContains("app.getErrorString") or
					sourceLine.cnContains("YACriteriaType_") or sourceLine.cnContains("myRoot.getConfig") or sourceLine.cnContains("RTMoveMethod_") or 
					sourceLine.cnContains("TI_CargoType_") then
					continue;
				endif;
				
				itemsFoundArray.add(klass.name &amp; "::" &amp; meth.name &amp; Tab &amp; "Line: " &amp; lineCount.String &amp; "." &amp; Tab &amp; sourceLine);
			endwhile;
			
		endwhile;
		
	endforeach;
	
	foreach str in itemsFoundArray do
		msgStr := msgStr &amp; str &amp; CrLf;
		totalCount := totalCount + 1;
	endforeach;
	
	write "Starting...";
	write msgStr;
	write totalCount;
	
epilog
	delete classes;
	delete iter;
	delete itemsFoundArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="checkForTrxWithNoAssert" id="3ca4be1e-139c-4156-85fb-c6b72f4bab8e">
        <source>checkForTrxWithNoAssert();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2012	cnwmc5	Initial creation

*/

vars
	klass				: Class;
	meth				: Method;
	
	classes				: ClassColl;
	methodsDict			: MethodNDict;
	
	iter				: Iterator;
	
	itemsFoundArray		: StringArray512;
	
	str					: String;
	msgStr				: String;
	methSource			: String;
	sourceLine			: String;
	lineDetails			: String;
	
	totalCount			: Integer;
	lineCount			: Integer;
	length				: Integer;
	posCrLf				: Integer;
	trxPos				: Integer;
	
	flag				: Boolean;
	
begin
	// get the class
	klass := currentSchema.getClass("UT_DSL");
	if klass = null then
		return;
	endif;
	
	// get all the subclasses
	create classes transient;
	klass.allLocalSubclasses(classes);
	classes.add(klass);
	
	create itemsFoundArray transient;
	
	// read through all the class methods source code to see if any of the no nos are found
	foreach klass in classes do
		
		methodsDict := klass.cnGetMethods();
		delete iter;
		iter := methodsDict.createIterator;
		while iter.next(meth) do
			methSource := meth.getSource();
			methSource.cnReplaceString(Tab, " ");
			length := methSource.length;
			
			if not methSource.cnContains(".trx") then
				continue;
			endif;
			
			posCrLf := -1;
			lineCount := 0;
			
			flag := false;
				
			// Read the source and see what is currently already defined
			// read through the file getting current constants
			while true do
				if methSource &lt;&gt; null then
					if posCrLf = -1 then
						posCrLf := 1;
					else
						posCrLf := posCrLf + 2;
					endif;
					if (posCrLf + 2) &gt; methSource.length then
						break;
					endif;
					methSource := methSource[posCrLf:end];
				endif;
				
				posCrLf := 1;
				posCrLf := methSource.pos(CrLf, posCrLf);
				if posCrLf = 0 or (posCrLf + 1) &gt; length then
					break;
				endif;
				sourceLine := methSource[1:posCrLf-1];
				lineCount := lineCount + 1;
				
				if not flag then
					if not sourceLine.cnContains(".trx") then //or methSource.cnContains("trxCompletedOK") then
						continue;
					endif;
					flag := true;
					trxPos := lineCount;
					lineDetails := sourceLine;
					continue;
				endif;
				
				if lineCount &lt;= (trxPos + 3) then
					if sourceLine.cnContains("assertNoTrxErrorsOrWarnings") or methSource.cnContains("trxCompletedOK") then
						flag := false;
						continue;
					endif;
					continue;
				else
					itemsFoundArray.add(klass.name &amp; "::" &amp; meth.name &amp; Tab &amp; "Line: " &amp; trxPos.String &amp; Tab &amp; lineDetails);
					flag := false;
				endif;
			endwhile;
			
		endwhile;
		
	endforeach;
	
	foreach str in itemsFoundArray do
		msgStr := msgStr &amp; str &amp; CrLf;
		totalCount := totalCount + 1;
	endforeach;
	
	write "Starting...";
	write msgStr;
	write totalCount;
	
epilog
	delete classes;
	delete iter;
	delete itemsFoundArray;
	
end;</source>
    </JadeMethod>
