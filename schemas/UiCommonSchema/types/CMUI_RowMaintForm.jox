    <JadeMethod name="tblDataDisplayRow" id="c978f4a1-4b76-4112-9164-a989b609ae1b">
        <updating/>
        <source>tblDataDisplayRow(table: Table input; obj: Object): String updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	display			: String;
	controller		: CM_RowController;
begin

	if (not obj.isKindOf(CM_RowController)) then
		return null;
	endif;
	
	controller := obj.CM_RowController;
	//show data by definition
	display := controller.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	return display;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
