    <JadeMethod name="shouldAuditProperty" id="df36b3da-b062-4b9f-9fab-26f85cb22414">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2023 navhl20	ChangeRequest 57301: EUP - [Framework] - Improve Audits on Work orders

*/

vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName  = CM_WodReceive::transport.name
	then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="a0123b8f-b58d-475e-b83b-3b803a28067d">
        <source>validate() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 018	jlgdap1	Initial creation TFS 38501 PEl1 Work Order Changes
26 May 2022	navma1	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
11 Jul 2023 navma1	Defect 59095: EUP - Able to save the Receive Cargo Work Order without the Booking selected when the VAS Subscription is on/off
19 Jan 2024 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
*/
vars

begin

	inheritMethod();
	
	if not app.myPassport.isVASEnabled then
		if self.myBookingRef = null then
			if self.transport = TI_TRANSMODE_ROAD or self.transport = TI_TRANSMODE_RAIL  then
				app.raiseCMException2(Work_order_task_require, self.getDisplayString(true), app.getErrorString(Booking), null, null);
			endif;
		endif;
	endif;

	if self.transport = TI_TRANSMODE_SHIP then			//19.01.2024 navhl20 #62066
		if self.myVoyage = null then
			app.raiseCMException2(Work_order_task_require, self.getDisplayString(true), app.getErrorString(Voyage), null, null);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateAddTI" id="17e93e8e-41ca-4a23-bb8f-1f1984c349fc">
        <source>validateAddTI( _ti : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2019	jlgndl1	Initial creation	TFS 43282

*/

vars

	wod : CM_WorkOrderDtl;

begin

	if not self.isTransient then	
		wod := _ti.getWorkOrderDetailOfType( self.detailType );
		if wod &lt;&gt; null and wod &lt;&gt; self then
			app.raiseCMException2(Alrea_assig_not_work_order_thi, _ti.id, self.getDisplayString(true) &amp; " " &amp; self.getMyParent.id, null, null);
		endif;	
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateForApproval" id="e7dd3135-5ba8-4822-8ad2-fa6d7d12f1ae">
        <source>validateForApproval();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2018	jlgdap1		Initial creation TFS 38501 PEl1 Work Order Changes
// 30/10/2024   navma1		MTN-33243 EUP - NTO-1049 - Make Booking not required for WO Approval
//
vars

begin
	inheritMethod();
	
	if not app.myPassport.isVASEnabled then				//30.10.2024 navma1 #MTN-33243
		if self.myParent.hasBeenApproved() then			
			if self.myBookingRef = null then
				if self.transport = TI_TRANSMODE_ROAD or self.transport = TI_TRANSMODE_RAIL  then
					app.raiseCMException2(Work_order_task_require, self.getDisplayString(true), app.getErrorString(Booking), null, null);
				endif;
			endif;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
