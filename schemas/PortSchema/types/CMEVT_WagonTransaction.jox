    <JadeMethod name="setWagonSealCheckDetails" id="061a9c45-1aa8-41c0-8b57-f74c0acb1532">
        <updating/>
        <source>setWagonSealCheckDetails( _pxyWagonCheckDetailArray : ObjectArray ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2015	cnwndl1	Initial creation	Par 36658

*/

vars

	allSealCheckDetails : CM_SealCheckDetailSet;
	obj : Object;
	pxySealCheckDetail : CM_WagonSealCheckDetail;
	realSealCheckDetail : CM_WagonSealCheckDetail;
	any	: Any;

begin

	if self.type &lt;&gt; EVT_WagonSealCheck then
		return;
	endif;
	
	any := self.getExtraData( self.AllSealCheckDetails );
	if any &lt;&gt; null then
		if any.isKindOf( CM_SealCheckDetailSet ) then
			allSealCheckDetails := any.CM_SealCheckDetailSet;
			if not allSealCheckDetails.isEmpty then
				allSealCheckDetails.purge();
			endif;
			delete allSealCheckDetails;
		endif;	
	endif;
	
	if _pxyWagonCheckDetailArray = null or _pxyWagonCheckDetailArray.isEmpty then
		return;
	endif;
	
	create allSealCheckDetails persistent;
	
	foreach obj in _pxyWagonCheckDetailArray do
		pxySealCheckDetail := obj.CM_WagonSealCheckDetail;
		create realSealCheckDetail;
		realSealCheckDetail.setFromProxy(pxySealCheckDetail);
		realSealCheckDetail.setMyWagonSealCheck( self );
		allSealCheckDetails.add( realSealCheckDetail );
	endforeach;
	
	if allSealCheckDetails.isEmpty then
		delete allSealCheckDetails;
		return;
	endif;
	
	self.setExtraData( self.AllSealCheckDetails, allSealCheckDetails );
	
epilog

end;</source>
        <Parameter name="_pxyWagonCheckDetailArray" type="ObjectArray"/>
    </JadeMethod>
</Class>
