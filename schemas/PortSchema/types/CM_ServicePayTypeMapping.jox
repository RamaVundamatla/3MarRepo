    <JadeMethod name="delete" id="51320861-992d-4756-9867-c638ff653cf1">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	term : CM_Terminal;
	str : String;

begin

	if self.isTransient then
		return;
	endif;

	term := app.myPassport.myTerminal;

	term.causeEvent( term.getTerminalEvent(EVENT_MAPPING_DELETE), false, self );
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="fa527879-af02-4ded-8646-a60d82bc4b47">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation

*/

vars

	tmpProxy : SelfType;
	completedOK		: Boolean;
	
begin

	tmpProxy := inheritMethod();
	
	tmpProxy.myBank := self.myBank;
	tmpProxy.myService := self.myService;
	tmpProxy.myDebtor := self.myDebtor;
	
	completedOK := true;		
	return tmpProxy;
	
epilog

	if not completedOK then			
		delete tmpProxy;
	endif;	
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
