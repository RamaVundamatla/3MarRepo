    <JadeMethod name="setMyOrganisation" id="5398c286-8210-44ce-be60-e981f82c18ff">
        <updating/>
        <source>setMyOrganisation(_value : CM_Organisation) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 November 2007	cnwer1	Initial creation - PAR#15269

*/
vars

begin

	if self.myOrganisation &lt;&gt; _value then
		self.myOrganisation:=_value;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="CM_Organisation"/>
    </JadeMethod>
