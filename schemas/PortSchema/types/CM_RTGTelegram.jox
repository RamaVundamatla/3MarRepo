    <JadeMethod name="validateForCreate" id="76073e32-2728-46be-b870-cc0709076c4d">
        <source>validateForCreate(_machine : CM_Machine);
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if _machine =  null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Machine', null, null);
		app.raiseCMException(Input_required_field_machine, null, null); // cnwdb2	PAR 35364
	endif;

	if self.number = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Number', null, null);
		app.raiseCMException(Input_required_field_number, null, null); // cnwdb2	PAR 35364
	else
		//validate it is unique for this machines collection
		
	endif;

	if self.height = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Height', null, null);
		app.raiseCMException(Input_required_field_height, null, null); // cnwdb2	PAR 35364


	endif;
	
	if self.weight = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Weight', null, null);
		app.raiseCMException(Input_required_field_weight, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.location = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Location', null, null);
		app.raiseCMException(Input_required_field_location, null, null); // cnwdb2	PAR 35364
	else
		//validate it is a real location
		if self.getLocationController(_machine) = null then
			//raise new exception
			//maybe overkill here
			app.raiseCMException2(ERR_FIELD_LOCATION,self.location, 'Location', null, null);
		endif;
	endif;
	
	if self.twistlock = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'TwistLock', null, null);
		app.raiseCMException(Input_required_field_twistLock, null, null); // cnwdb2	PAR 35364
	else
		//has to be C or O
		if not isTwistLockOpen and  not isTwistLockClosed then
			//raise new exception
			app.raiseCMException2(ERR_FIELD_TWISTLOCK,self.twistlock, 'TwistLock', null, null);
		endif;
	endif;
	
	if self.xPos = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'xPos', null, null);
		app.raiseCMException(Input_required_field_xPos, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.yPos = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'yPos', null, null);
		app.raiseCMException(Input_required_field_yPos, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.ver = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'ver', null, null);
		app.raiseCMException(Input_required_field_ver, null, null); // cnwdb2	PAR 35364


	endif;
	
	//length check its 20 | 40 | 45
	if self.length = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'length', null, null);
		app.raiseCMException(Input_required_field_length, null, null); // cnwdb2	PAR 35364
	else
		if self.length &lt;&gt; LENGTH_20FOOT and
			self.length &lt;&gt; LENGTH_40FOOT and
			self.length &lt;&gt; LENGTH_45FOOT then
			app.raiseCMException1(ERR_FIELD_LENGTH, self.length.String, 'length', null);
		endif;
			
	endif;
	
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
</Class>
