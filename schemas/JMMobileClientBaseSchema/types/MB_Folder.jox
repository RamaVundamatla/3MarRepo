<GUIClass name="MB_Folder" id="7dc5b841-bfde-410a-960b-ca67bf95217d">
    <superclass name="Folder"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="isColorFixed" id="e89f3fb1-0a48-4bad-9fb3-53aceae958ef">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setBackForeColor" id="386984fa-bc23-47a4-add7-e5ac5d0c61d1">
        <updating/>
        <source>setBackForeColor(_backColor: Integer; _foreColor: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		09 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isColorFixed then
		return;
	else
		inheritMethod(_backColor, _foreColor);
	endif;
end;</source>
        <Parameter name="_backColor" type="Integer"/>
        <Parameter name="_foreColor" type="Integer"/>
    </JadeMethod>
