<Class name="CM_ScriptHistoryRecord" id="10e9bce1-212e-42d7-bd30-beb2e027076c">
    <instanceVolatility>stable</instanceVolatility>
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="fixup"/>
    <Constant name="StateDictName" id="2a8c9a10-f13c-4d07-9b42-604abf4ada5a">
        <source>"AllScriptsRun"</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="computerName" id="c8687275-3fdf-44f3-a150-16b81a5d6f76">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="duration" id="d5b2231c-76c4-419f-80b2-ef2c966ba94e">
        <embedded/>
        <type name="Time"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="methodText" id="c6ed13bc-d499-481b-90c0-a9f39224bd4e">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="runDate" id="670823bd-aae3-4930-87e1-5f0af40de395">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="userName" id="8a0431b7-cab4-4a5f-a351-63574e1d41bc">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The Computer/Domain Users usercode</text>
    </PrimAttribute>
    <JadeMethod name="createRecordData" id="ddf5781c-9805-46b2-b785-35b190b6c090">
        <options>4</options>
        <source>createRecordData(_code : String; _duration : Time) typeMethod;
/*

Purpose:			Keep track of whodunit!

Parameters:			

Return Value:		

Date			Who		Reason
07 May 2021		navmd1	Initial creation TFS 51191 Record Script Runner history

*/

vars
	stateData			: Any;
	allScriptsRunDict	: CM_ScriptHistoryByDT;
	myObj				: SelfType;
	isOK				: Boolean;
begin
	
	// Store these in the CM_Root stateData collection (because, why not)
	stateData := app.myRoot.getConfig(CM_ScriptHistoryRecord.StateDictName);
	
	beginTransaction;
	
	create myObj persistent;
	
	myObj.methodText	:= _code;
	myObj.userName		:= app.userName;
	myObj.computerName	:= app.computerName;
	myObj.duration		:= _duration;
	
	myObj.runDate		:= app.actualTimeServer();
	
	if stateData = null then
		create allScriptsRunDict persistent;
		app.myRoot.setConfig(CM_ScriptHistoryRecord.StateDictName, allScriptsRunDict, false);
	else
		allScriptsRunDict := stateData.CM_ScriptHistoryByDT;
	endif;
	
	allScriptsRunDict.add(myObj);
	
	commitTransaction;
	
	isOK := true;
epilog
	if not isOK then
		abortTransaction;
	endif;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_duration" type="Time"/>
    </JadeMethod>
    <JadeMethod name="display" id="38a4b0b6-3420-4bce-af5a-13440faaf1d5">
        <source>display(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 May 2021		navmd1	Initial creation

*/

vars
	str,
	newStr,
	delim	: String;
	pos		: Integer;
begin
	str := inheritMethod();

	// All of this just to show the duration to a sensible value ;)
	
	delim := CM_ScriptHistoryRecord::duration.name &amp; " =";
	pos := str.pos(delim, 1);
	pos := pos + delim.length;
	
	newStr := str[1:pos];
	newStr := newStr &amp; self.duration.formatAsHHMMSSmmm;
	
	str.scanUntil(CrLf, pos);
	pos := pos + 1;
	
	newStr := newStr &amp; str[pos:end];
	
	// And again....
	str := newStr;
	delim := CM_ScriptHistoryRecord::runDate.name &amp; " =";
	pos := str.pos(delim, 1);
	pos := pos + delim.length;
	
	newStr := str[1:pos];
	newStr := newStr &amp; self.runDate.formatAsYYYYMMDDHHMMSSMMM;
	
	str.scanUntil(CrLf, pos);
	pos := pos + 1;
	
	newStr := newStr &amp; str[pos:end];
	
	return newStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
