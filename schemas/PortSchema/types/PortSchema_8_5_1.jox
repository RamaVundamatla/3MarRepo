    <JadeMethod name="setupIMEXTransition" id="4c0eeac6-9c3f-48c8-a862-a5837769e7e1">
        <updating/>
        <source>setupIMEXTransition(_controller: CnEcReleaseController) updating;
/*

Purpose: create IMEXTransitionCriteria for terminals needing one
		 on basis of MTImportIfIntendedOffsite config value

Parameters:			

Return Value:		

Date			Who		Reason
09 April 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status 

*/

vars
	theTerminal : CM_Terminal;
	transitionProxy, transition: CM_IMEXTransitionCriteria;
	realTransition : CM_ObjectMatchCriteria;
	criteriaCargoType,
	criteriaIMEX,
	criteriaStatus : CM_YACriteria;
	
begin

	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	foreach theTerminal in app.myRoot.allTerminals do
		if not theTerminal.getConfig(MTImportIfIntendedOffsite).Boolean then
			create transitionProxy transient;
			create transition transient;
			create criteriaCargoType transient;
			transitionProxy.allCriteria.add(criteriaCargoType);
			criteriaCargoType.setProxy(CM_YATypeCargoType.firstInstance, "CONT", "Cargo Type");
			
			create criteriaStatus transient;
			transitionProxy.allCriteria.add(criteriaStatus);
			criteriaStatus.setProxy(CM_YATypeContentsStatus.firstInstance, "MT", "Contents S");
			
			create criteriaIMEX transient;
			transitionProxy.allCriteria.add(criteriaIMEX);
			criteriaIMEX.setProxy(CM_YATypeImexStatus.firstInstance, "IMP", "IMEX Statu");
			
			transitionProxy.setBaseData(transitionProxy.getTableDisplayString, "MT IMPORT CONT", theTerminal, TI_IMEX_STATUS_STORAGE);
			
			realTransition := transition;
			app.myTrxCA.trxCreateObjMatchCrit(transitionProxy, realTransition, app.myPassport );
			
			delete transitionProxy;
			delete transition;
		endif;
	endforeach;
	
	app.writeLog(method.qualifiedName &amp; " Creating 'MT IMPORT CONT' IMEXTransitionCriteria for terminals needing it", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Creating 'MT IMPORT CONT' IMEXTransitionCriteria for terminals needing it") ;	
	endif;

	
	app.writeLog(method.qualifiedName &amp; " Creating 'MT IMPORT CONT' IMEXTransitionCriteria for terminals needing it complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Creating 'MT IMPORT CONT' IMEXTransitionCriteria for terminals needing it complete") ;	
	endif;
	self.addScriptRun(method.name);

epilog
	delete transitionProxy;
	delete transition;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="specificPostStandard" id="08393749-f225-4642-bafc-96f037f2fe44">
        <updating/>
        <source>specificPostStandard(pControllerObj: CnEcReleaseController) updating;
/*

Date		Who		Reason
10 September 2015	cnwer1	Initial creation PAR

*/
// 14 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 26 Feb 2018	jlgsl4	TFS 37088 - use plannedDT instead of hireDT
// 12/03/2018	jlgdap1	TFS 37427 PEL1 Voyage Status Enhancements
// 22/03/2018	jlgdap1	TFS 37445 PEL1 Voyage Status Security
// 11/04/2018	jlgdap1	TFS 37966 PEL1 Archived Status
// 17/09/2018	jlgmd1	Sync'd from WMAST
// 18/01/2019	jlgdap1	Initial creation TFS 41738 JMT System Items icon missing from the Navigator pane
vars

