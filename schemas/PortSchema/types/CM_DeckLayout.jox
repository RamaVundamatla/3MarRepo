vars

begin
	self.myDeck:=_deck;
epilog

end;</source>
        <Parameter name="_deck" type="CM_Deck"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="e036a135-f10e-4c55-98f5-98d07e4e348b">
