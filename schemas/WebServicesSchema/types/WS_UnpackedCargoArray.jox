<CollClass name="WS_UnpackedCargoArray" id="a6c6f701-d6e0-47c5-b623-c8cf38308c94">
    <memberType name="WS_UnpackedCargo"/>
    <superclass name="ObjectArray"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <JadeMethod name="findUnpackedProxyIdTypeLoc" id="61dba84b-c914-48be-b0ea-549ce6e827b8">
        <source>findUnpackedProxyIdTypeLoc(_id : String; _cargoType : CM_CargoType; _locId : String ) : WS_UnpackedCargo;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2020	jlgndl1	Initial creation	TFS 47356

*/

vars

	proxyUnpack : WS_UnpackedCargo;
	
begin

	if _id = null or _cargoType = null or _locId = null then
		return null;
	endif;
	
	foreach proxyUnpack in self do
		if proxyUnpack.id &lt;&gt; _id then
			continue;
		endif;
		if proxyUnpack.location &lt;&gt; _locId then
			continue;
		endif;
		if proxyUnpack.cargoType = null or ( proxyUnpack.cargoType.id &lt;&gt; _cargoType.id ) then
			continue;
		endif;
		return proxyUnpack;
	endforeach;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_locId" type="String"/>
        <ReturnType type="WS_UnpackedCargo"/>
    </JadeMethod>
    <JadeMethod name="findUnpackedProxyWithId" id="2070c37c-d845-4cd7-a3eb-67a85d3a70d4">
        <source>findUnpackedProxyWithId(_id : String) : WS_UnpackedCargo;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2018	jlger1	Initial creation

*/

vars
	proxyUnpack : WS_UnpackedCargo;
begin
	if _id = null then
		return null;
	endif;
	
	foreach proxyUnpack in self do
		if proxyUnpack.id = _id then
			return proxyUnpack;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="WS_UnpackedCargo"/>
    </JadeMethod>
</CollClass>
