    <JadeMethod name="getTableViewThumbnailData" id="27ce12dc-2738-41b3-8274-2bb9180ba9f6">
        <source>getTableViewThumbnailData(_dateStr: String; _entdef : String): String;
/*
Purpose:			
Date		Who		Reason
10 April 2017	cnwab1	Initial creation
*/

vars
	ti : CM_TrackedItem;
	dataStr : String;
begin
	on Exception do self.handleInvalidClass(exception); // JLGAB1	TFS 8098

	dataStr := _dateStr;
	
	if _entdef = ETDef_BookRefThumb then // TFS 4052
		ti := dataStr.asOid.CM_TrackedItem; // TFS 4052
			if ti &lt;&gt; null then // TFS 4052
				if ti.isChild() then
					dataStr := "       " &amp; ti.getIDwithAmount(); // TFS 4052
				else
					dataStr := ti.getIDwithAmount(); // TFS 4052
				endif;
			endif; // TFS 4052
	endif; // TFS 4052
		
	return dataStr;
epilog
	on Exception do null;
end;</source>
        <Parameter name="_dateStr" type="String"/>
        <Parameter name="_entdef" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableViewThumbnailOid" id="21eb3279-20da-4c73-8f9b-7f90b1283405">
        <source>getTableViewThumbnailOid(_oidStr: String; _entdef: String): CM_Object;
/*
Purpose:			
Date		Who		Reason
10 April 2017	cnwab1	Initial creation
*/

vars
	obj : CM_Object;
begin
	on Exception do self.handleInvalidClass(exception); // JLGAB1	TFS 8098

	if _entdef = ETDef_BookRefThumb then // TFS 4052
		obj := _oidStr.asOid.CM_Object; // TFS 4052
		if obj &lt;&gt; null then
			return obj;
		endif;
	endif;

	return inheritMethod(_oidStr, _entdef);
epilog
	on Exception do null;
end;</source>
        <Parameter name="_oidStr" type="String"/>
        <Parameter name="_entdef" type="String"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
