    <JadeMethod name="getDisplayStringForAttribute" id="96cdb8c1-4edc-48db-9acf-a2ccd1c0a0a6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/06/2009	cnwndl1	Initial creation
01/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	str, type	: String;							// PAR #31155
	value		: Decimal [22,10];					// PAR #31155

begin

	if _attrName = ETRow_AllowHiCubeYesNo then
		return allowHiCube.getYes();
	elseif _attrName = ETRow_NoEmptyWagons then // PAR 23176
		return noEmptyWagons.getYes();
	elseif _attrName = ETRow_IsNotAvailableForEntryYN then
		return isNotAvailableForEntry.getYes();
	elseif _attrName = ETRow_MaxHeight then
		return maxHeight.asStringMeasurementJMT();
	elseif _attrName = ETRow_MaxWidth then
		return maxWidth.asStringMeasurementJMT();
	elseif _attrName = ETRow_MaxWeightWagon then
		return maxWeightWagon.asStringWeightJMT();
	elseif _attrName = ETRow_MaxWeight then // PAR 23176
		return maxWeight.asStringWeightJMT();
		
	elseif _attrName.isMeasurementType then											// PAR #31155
		// _attrName will be formatted as WTRow_&lt;real ent row name&gt;_&lt;weight unit&gt;	// PAR #31155
		_attrName.getRowNameMeasureType(str, type);									// PAR #31155
		return self.getMeasurementStringForAttrib(str, type, _short);				// PAR #31155
			
	endif;

	return inheritMethod(_attrName, _short);
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
