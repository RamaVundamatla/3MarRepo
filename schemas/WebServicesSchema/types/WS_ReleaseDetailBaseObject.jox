    <JadeMethod name="delete" id="db75450c-f53c-4c8f-a069-51da7c9ce816">
        <updating/>
        <source>delete() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/06/2024	navdap1		Initial creation TFS 63107 CUX | GET /releaseRequest API to return release request line items
//
vars

begin
	delete self.amounts;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="ffb49164-6801-4f00-b603-14d24fa7c684">
        <updating/>
        <source>setProxyFromObject(_reserveDetail : CM_ReserveDetail) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/06/2024	navdap1		Initial creation TFS 63107 CUX | GET /releaseRequest API to return release request line items
//
vars

begin
	self.cargoTypeId := _reserveDetail.getCargoTypeAbbrev();
	self.cargoSubTypeId := _reserveDetail.getProductCode();
	self.description := _reserveDetail.getDescription();
	self.fullyLoaded := _reserveDetail.isFullyLoaded;
	self.fullyPacked := _reserveDetail.isFullyPacked;
	self.locations := _reserveDetail.getLocation;
	self.packingType := _reserveDetail.packType;
	self.quantityRequested := _reserveDetail.getTotalRequested();
	self.stagingComplete := _reserveDetail.isStagingComplete;
	self.volumeRequested := _reserveDetail.getVolumeForSummary();
	self.weightRequested := _reserveDetail.getTotalWeightRequested();
	
	create self.amounts transient;
	self.amounts.setProxyFromObject(_reserveDetail);
epilog

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
</Class>
