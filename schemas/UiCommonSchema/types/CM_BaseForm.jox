    <JadeMethod name="mnuToolbarMoreClone_click" id="f06ae99a-0d10-48e7-b6c8-b2fac4203427">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuToolbarMoreClone_click(_menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     29 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 27/08/2012	cnwcs5	par 30274 - handle 2-state button as menuitem
vars
	btn					: CMUI_ButtonForToolbar;
	tmpMenuUserToolbar	: CM_MenuUserToolbar;
	value				: Boolean;
begin
	if _menuItem.userObject &lt;&gt; null then
		if _menuItem.userObject.isKindOf(CMUI_ButtonForToolbar) then 
			btn := _menuItem.userObject.CMUI_ButtonForToolbar;
			
			//epr par 30590 28/1/15
			if btn.style = Button.Style_2State or  btn.style =  Button.Style_Auto2State then	// par 30274 - 2-state button
				value 		:= btn.value;
				btn.value	:= not value;
			endif;
			
			btn.click(btn);
			
		elseif _menuItem.userObject.isKindOf(CM_MenuUserToolbar) then
			tmpMenuUserToolbar := _menuItem.userObject.CM_MenuUserToolbar;
			
			app.mainForm.sendMsgWithParams(CM_BaseForm.DoMenuUserToolbarClick, app.isControlKeyDown(), tmpMenuUserToolbar);
		endif;
		
	endif;
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
