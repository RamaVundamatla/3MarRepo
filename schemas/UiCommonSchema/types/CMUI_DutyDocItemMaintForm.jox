    <JadeMethod name="translateForm" id="d9c397af-ba4c-4ff0-9d81-15c8b59f4e70">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 September 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018635, locale);
	btnAsCar.translateCaption(Xlat_0019187, locale);
	btnCancel.translateCaption(Xlat_0018636, locale);
	btnFind.translateBubbleHelp(Xlat_0018637, locale);
	btnHSCode.translateBubbleHelp(Xlat_0018638, locale);
	btnSave.translateCaption(Xlat_0018639, locale);
	btnSaveNext.translateCaption(Xlat_0018640, locale);
	chkDutyExempt.translateCaption(Xlat_0018641, locale);
	lbAgent.translateCaption(Xlat_0018642, locale);
	lbBOL.translateCaption(Xlat_0018643, locale);
	lbOperator.translateCaption(Xlat_0018644, locale);
	lbPOL.translateCaption(Xlat_0018645, locale);
	lblChassis.translateCaption(Xlat_0018646, locale);
	lblColour.translateCaption(Xlat_0018647, locale);
	lblConsignee.translateCaption(Xlat_0018648, locale);
	lblCurrency.translateCaption(Xlat_0018649, locale);
	lblDO.translateCaption(Xlat_0018650, locale);
	lblDOExp.translateCaption(Xlat_0018651, locale);
	lblDuty.translateCaption(Xlat_0018652, locale);
	lblDutyCode.translateCaption(Xlat_0018653, locale);
	lblDutyExempt.translateCaption(Xlat_0018654, locale);
	lblEngine.translateCaption(Xlat_0018655, locale);
	lblExemptBene.translateCaption(Xlat_0018656, locale);
	lblExemptCode.translateCaption(Xlat_0018657, locale);
	lblExemptSource.translateCaption(Xlat_0018658, locale);
	lblForeignValue.translateCaption(Xlat_0018659, locale);
	lblGrossWeight.translateCaption(Xlat_0018660, locale);
	lblHSCode.translateCaption(Xlat_0018661, locale);
	lblID.translateCaption(Xlat_0018662, locale);
	lblLocalFreight.translateCaption(Xlat_0018663, locale);
	lblLocalIns.translateCaption(Xlat_0018664, locale);
	lblLocalValue.translateCaption(Xlat_0018665, locale);
	lblNetValue.translateCaption(Xlat_0018666, locale);
	lblNetWeight.translateCaption(Xlat_0018667, locale);
	lblNumPlate.translateCaption(Xlat_0018668, locale);
	lblOrigin.translateCaption(Xlat_0018669, locale);
	lblPOD.translateCaption(Xlat_0018670, locale);
	lblPacking.translateCaption(Xlat_0018671, locale);
	lblQuantity.translateCaption(Xlat_0018672, locale);
	lblRatePercent.translateCaption(Xlat_0018673, locale);
	lblVCCDate.translateCaption(Xlat_0018674, locale);
	lblVCCNo.translateCaption(Xlat_0018675, locale);
	lblVehMake.translateCaption(Xlat_0018676, locale);
	lblVehModel.translateCaption(Xlat_0018677, locale);
