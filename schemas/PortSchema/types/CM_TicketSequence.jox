    <JadeMethod name="getPseudoIds" id="1e2b23e2-419e-40ef-b3f8-5bfa262359bb">
        <updating/>
        <source>getPseudoIds(_logIDArray : StringArray input)updating;
//--------------------------------------------------------------
//Created: 30 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : CM_TicketSequence;
	str,
	lastNum,
	pseudoLogId,
	trailingNum,
	fromIdLeadingStr  : String;
	num, cnt	: Integer;
	
begin

	_logIDArray.add(self.fromId);

	if self.toId &lt;&gt; self.fromId then
		_logIDArray.add(self.toId);
			
		if (not self.fromId.isInteger) then
			trailingNum := self.fromId.getTrailingIntegerString();
			lastNum := self.fromId.getTrailingInteger().String; 					
			if lastNum.isInteger then
				fromIdLeadingStr := self.fromId;
				if trailingNum.length &gt; lastNum.length then
					pseudoLogId := (fromIdLeadingStr.cnEcStripAtEnd(trailingNum) &amp; 
									(lastNum.Integer + 1).String.padZeros(trailingNum.length).String);
				else
					pseudoLogId := (fromIdLeadingStr.cnEcStripAtEnd(trailingNum) &amp; 
									(lastNum.Integer + 1).String);			
				endif;
				cnt := 1;		// As we have added first one to array earlier			
				while pseudoLogId &lt;&gt; self.toId do
					if cnt &gt; self.quantity then
						break;
					endif;
					_logIDArray.add(pseudoLogId);
					lastNum := pseudoLogId.getTrailingInteger().String;
					trailingNum := pseudoLogId.getTrailingIntegerString();
					if trailingNum.length &gt; lastNum.length then
						lastNum := (lastNum.Integer + 1).String;
						pseudoLogId := (pseudoLogId.cnEcStripAtEnd(trailingNum) &amp; lastNum.padZeros(trailingNum.length).String);
					else
						pseudoLogId := (pseudoLogId.cnEcStripAtEnd(trailingNum) &amp; (lastNum.Integer + 1).String);			
					endif;
					cnt := (cnt + 1);
				endwhile;
			endif;
		else
			pseudoLogId := (self.fromId.Integer + 1).String;
			while pseudoLogId &lt;&gt; self.toId do
				if cnt &gt; self.quantity then
					break;
				endif;			
				_logIDArray.add(pseudoLogId);
				pseudoLogId := (pseudoLogId.Integer + 1).String;
				cnt := (cnt + 1);				
			endwhile;		
		endif;
	endif;	

end;</source>
        <Parameter name="_logIDArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isTicketIdNotInSequence" id="e833c325-7ff2-40bb-b7ad-59660670e3cc">
        <source>isTicketIdNotInSequence(_ticketId : String) : Boolean;
// -----------------------------------------------------------------------------
// Created:		10 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin

	if self.allTicketIds.includes(_ticketId) then
		return false;
	endif;
	
	return true;
//	return (_ticketId &lt;= self.toId) and (_ticketId &gt;= self.fromId);
end;</source>
        <Parameter name="_ticketId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAllTicketIds" id="6a450d9f-fdd0-40b3-a2cf-529270c47405">
        <updating/>
        <source>setAllTicketIds()updating, protected;
//--------------------------------------------------------------
//Created: 06 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.getPseudoIds(self.allTicketIds);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d50bcfb8-8269-4a96-92b9-a73041a6ba65">
        <updating/>
        <source>setForCreate(_proxyTicketSeq : CM_TicketSequence  ) updating;
//--------------------------------------------------------------
//Created: 19 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	_proxyTicketSeq.raiseExceptionIfNotTransient(method);
	self.setForUpdate(_proxyTicketSeq);

end;</source>
        <Parameter name="_proxyTicketSeq" type="CM_TicketSequence"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7fecade3-866e-4225-bca2-e9e18b517534">
        <updating/>
        <source>setForUpdate(_proxyTicketSeq : CM_TicketSequence) updating;
// -----------------------------------------------------------------------------
// Created:		02 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.fromId 	:= _proxyTicketSeq.fromId;
	self.toId		:= _proxyTicketSeq.toId;
	self.quantity 	:= _proxyTicketSeq.quantity;
	self.scale 		:= _proxyTicketSeq.scale;

	if _proxyTicketSeq.allTicketIds &lt;&gt; null and not _proxyTicketSeq.allTicketIds.isEmpty then
		_proxyTicketSeq.allTicketIds.copy(self.allTicketIds);	
	endif;
	
end;</source>
        <Parameter name="_proxyTicketSeq" type="CM_TicketSequence"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="3683f32e-f46d-428a-aba3-5e53668ebe23">
        <updating/>
        <source>setProxy(_fromId : String;
		_toId : String;
		_quantity : Integer;
		_scale : Boolean) updating;
//--------------------------------------------------------------
//Created: 19 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	fromId 		:= _fromId;
	toId		:= _toId;
	quantity 	:= _quantity;
	scale 		:= _scale;
	
	self.allTicketIds.clear(); //&lt;-- Added, clear first.
	self.setAllTicketIds();
	
end;</source>
        <Parameter name="_fromId" type="String"/>
        <Parameter name="_toId" type="String"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_scale" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTicketSequenceId" id="b5ab3fba-9e63-432a-b0c6-420f5636177e">
        <source>validateTicketSequenceId(_pseudoIdArray : StringArray) : Boolean;
//--------------------------------------------------------------
//Created: 30 April 2002 By: cnwgd1
//--------------------------------------------------------------
constants 
	MsgStr = "in the Database. These entries must be unique.";
vars
	id	: String;
	rtValue : Boolean;
begin

	foreach id in _pseudoIdArray do
		rtValue := self.isTicketIdNotInSequence(id);
		if not rtValue then
			app.raiseCMException3(ERR_DUPLICATED_LABEL, 'Log ID', id, MsgStr, ETRow_FromId, self);
			return false;	//One duplicate is all we need to quit
		endif;
	endforeach;

	return true;
end;</source>
        <Parameter name="_pseudoIdArray" type="StringArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
