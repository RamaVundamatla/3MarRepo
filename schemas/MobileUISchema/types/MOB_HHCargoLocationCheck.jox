    <JadeMethod name="translateForm" id="388f382d-983d-4cdc-8adc-45fe48ddc515">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020779, locale);
	lblCargoGroupId.translateCaption(Xlat_0020780, locale);
	lblCountValue.translateCaption(Xlat_0020781, locale);
	lblLocation.translateCaption(Xlat_0020782, locale);
	lblWeightValue.translateCaption(Xlat_0020783, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoGroupId_gotFocus" id="e73f4cad-5ceb-4f13-b3aa-5b3fb26fbad6">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoGroupId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

begin

	if self.txtCargoGroupId.text = self.lblCargoGroupId.caption.toUpper then
		self.txtCargoGroupId.selStart := 0;
		self.txtCargoGroupId.selLength := self.lblCargoGroupId.caption.length;
		self.setMyCargoGroup( null );
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoGroupId_lostFocus" id="e66b7e56-b7b8-4fdf-8466-2fb358e24530">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoGroupId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation Par 36608

*/

vars

begin

	if self.txtCargoGroupId.text.trimBlanks = null then
		self.txtCargoGroupId.text := self.lblCargoGroupId.caption.toUpper;
		self.setMyCargoGroup( null );
	else
		if ( self.myCargoGroup &lt;&gt; null and self.myCargoGroup.id &lt;&gt; self.txtCargoGroupId.text )
		or ( self.myCargoGroup = null and self.txtCargoGroupId.text &lt;&gt; self.lblCargoGroupId.caption.toUpper )	//01 Aug 2013	NDL	Par 32140
		then
			self.selectCargoGroup( false );
		endif;
	endif;
	
	self.txtCargoGroupId.selStart := 0;
	self.txtCargoGroupId.selLength := 0;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtLocation_gotFocus" id="31f724d3-dd96-408a-b4fd-9621fad5803d">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLocation_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

begin

	if self.txtLocation.text = self.lblLocation.caption.toUpper then
		self.txtLocation.selStart := 0;
		self.txtLocation.selLength := self.lblLocation.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtLocation_lostFocus" id="c689fdb0-1e4a-4833-aecd-fcb384c7e4e4">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLocation_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	location : CM_LocationsController;

begin

	if self.txtLocation.text.trimBlanks = null then
		self.txtLocation.text := self.lblLocation.caption.toUpper;
		self.txtLocation.userObject := null;
	else
		if self.findLocationToCheck( location ) then
			self.txtLocation.text := location.getFullId;
			self.txtLocation.userObject := location;
		else
			self.txtLocation.userObject := null;
		endif;
	endif;
	
	self.txtLocation.selStart := 0;
	self.txtLocation.selLength := 0;

epilog


end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
