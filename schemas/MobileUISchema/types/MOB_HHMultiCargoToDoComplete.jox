    <JadeMethod name="cmbTasksPopulate" id="e312a5df-cc0a-4124-90e5-c08b9c0e28da">
        <source>cmbTasksPopulate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2015	cnwndl1	Initial creation	Par 36993

*/

vars

	iter : Iterator;
	taskDesc : CM_ToDoTaskDesc;
	lineStr : String;
	index : Integer;
	useFullDesc : Boolean;

begin

	self.cmbTasks.clear();
	
	useFullDesc := self.myTerminal.getConfig( HhTaskUseFullDesc ).Boolean;

	iter := app.myPassport.myTerminal.myRoot.allToDoTaskDescsBySortOrder.createIterator;
	self.cmbTasks.addItem( "&lt;" &amp; app.getErrorString(Please_select_task) &amp; "&gt;" );
	while iter.next( taskDesc ) do
		if useFullDesc or taskDesc.shortDescription = null then
			lineStr := taskDesc.description;
		else
			lineStr := taskDesc.shortDescription;
		endif;
		index := self.cmbTasks.addItem( lineStr );
		self.cmbTasks.itemObject[index] := taskDesc;
		if taskDesc.requiredExtraInfo &lt;&gt; null then	//11 Jul 2016	NDL	TFS 2116
			self.cmbTasks.itemEnabled[index] := false;
		endif;
	endwhile;
	
	self.cmbTasks.listIndex := 1;

epilog

end;</source>
    </JadeMethod>
