    <JadeMethod name="getDisplayStringForAttribute" id="54dd403a-1700-46cf-895c-c48b5d5390d7">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 October 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if _attrName = ETRow_EmailToCC then
		return  self.emailRecipientCC;
	elseif _attrName = ETRow_EmailToBCC then
		return self.emailRecipientBCC;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="e8fde4fb-2bbd-48cd-889b-9fedf0142de7">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			


Return Value:		


Date			Who		Reason
21 August 2007	cnwer1	Initial creation - PAR#xxxx
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/
vars
	tmpFaultType : CM_FaultType;
	completedOK		: Boolean;
begin
	tmpFaultType:= inheritMethod();

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpFaultType;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpFaultType;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a05bd166-38bc-44e0-a20d-540fac461be8">
        <updating/>
        <source>setForCreate(_pxyFaultType : CM_FaultType ) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.setForUpdate(_pxyFaultType);

	self.myRoot:=app.myRoot;

epilog

end;</source>
        <Parameter name="_pxyFaultType" type="CM_FaultType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ec9c5d09-e7c3-4d15-8c2e-e8b49d8cc3e3">
        <updating/>
        <source>setForUpdate(_pxyFaultType : CM_FaultType ) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.code:=_pxyFaultType.code;
	self.description:=_pxyFaultType.description;
	self.emailBody:=_pxyFaultType.emailBody;
	self.emailRecipient:=_pxyFaultType.emailRecipient;
	self.emailRecipientCC:=_pxyFaultType.emailRecipientCC;
	self.emailRecipientBCC:=_pxyFaultType.emailRecipientBCC;
	self.emailSubject:=_pxyFaultType.emailSubject;
	

epilog

end;</source>
        <Parameter name="_pxyFaultType" type="CM_FaultType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="272ef343-07c1-4cd3-a8f1-f47d371db023">
        <updating/>
        <source>setProxy(	_code,
			_description,
			_emailRecipient,
			_emailToCC,
			_emailToBCC,
			_emailSubject,
			_emailBody : String) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.code :=_code;
	self.description:=_description;
	self.emailBody:=_emailBody;
	self.emailRecipient:=_emailRecipient;
	self.emailRecipientCC:=_emailToCC;
	self.emailRecipientBCC:=_emailToBCC;
	self.emailSubject:=_emailSubject;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_emailRecipient" type="String"/>
        <Parameter name="_emailToCC" type="String"/>
        <Parameter name="_emailToBCC" type="String"/>
        <Parameter name="_emailSubject" type="String"/>
        <Parameter name="_emailBody" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="2575483a-9ae0-434e-8a98-80c9510aa069">
        <source>validateForCreate();
/*

Purpose:			


Return Value:		


Date			Who		Reason
30 August 2007	cnwer1	Initial creation - PAR#xxxx
22 October 2008	consw1	Par 18262 - correct duplicates validation
*/
vars

begin
	self.validateForUpdate();

	if app.myRoot.allFaultTypes[self.code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
		return;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="e715f647-5c84-4124-ac80-974c18bf1b56">
        <source>validateForUpdate();
/*

Purpose:			


Return Value:		


Date			Who		Reason
30 August 2007	cnwer1	Initial creation - PAR#xxxx
22 October 2008	consw1	Par 18262 - correct duplicates validation
23/12/2014  cnwdb2	PAR 35364
*/
vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', null, null);
		app.raiseCMException(Input_required_field_code, null, null); // cnwdb2	PAR 35364
		return;
	endif;

	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', null, null);
		app.raiseCMException(Input_required_field_Desc, null, null); // cnwdb2	PAR 35364


		return;
	endif;
	
//	if app.myRoot.allFaultTypes[self.code] &lt;&gt; null then
//		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
//		return;
//	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
