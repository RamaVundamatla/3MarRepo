    <JadeMethod name="buildNibbler_InitializeClass" id="5b261e66-203c-4e6b-884f-8f5e4a90781a">
        <source>buildNibbler_InitializeClass(pInitializeClassRequest: JSSCTInitializeClassRequest input): String;
/*
*/
begin
	return JSSCT_Nibbler_InitializeClass.String &amp; SEPARATOR &amp; pInitializeClassRequest.getOidString() &amp; SEPARATOR;
end;</source>
        <Parameter name="pInitializeClassRequest" type="JSSCTInitializeClassRequest" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildNibbler_RaiseAlert" id="44fb2184-d05c-4228-b3a0-913bbe9ab0b6">
        <source>buildNibbler_RaiseAlert(pShortMessage: String; pLongMessage: String): String;
/*
*/
begin
	return JSSCT_Nibbler_RaiseAlert.String &amp; SEPARATOR &amp; pShortMessage.String &amp; SEPARATOR &amp; pLongMessage.String &amp; SEPARATOR;
end;</source>
        <Parameter name="pShortMessage" type="String"/>
        <Parameter name="pLongMessage" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildNibbler_Respond" id="51c77b39-e41b-480c-b6ce-6db536d93a19">
        <source>buildNibbler_Respond(pNibbler: JSSCTNibblerManager): String;
/*
*/
vars
	xmlDocument: JSSXmlDocument;
	xmlElement: JSSXmlElement;
begin
	create xmlDocument transient;
	xmlElement := xmlDocument.addElement("CT_Response", "");
	xmlElement.addElement("title", pNibbler.myTitle);
	xmlElement.addElement("journal", pNibbler.lastAuditFileNumber.String);
	xmlElement.addElement("timestamp", pNibbler.lastAuditFileTimeStamp.String);
	xmlElement.addElement("complete", pNibbler.lastAuditFileComplete.String);
	xmlElement.addElement("state", pNibbler.state);
	xmlElement.addElement("process", process.getOidString());
	xmlElement.addElement("startedApp", pNibbler.isStartedApplication.String);

	return JSSCT_Nibbler_Respond.String &amp; SEPARATOR &amp; xmlDocument.buildXmlString() &amp; SEPARATOR;
epilog
	delete xmlDocument;
end;</source>
        <Parameter name="pNibbler" type="JSSCTNibblerManager"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildNibbler_Started" id="b0340a56-ff4d-4952-a9ba-1669dbb4d0b8">
        <source>buildNibbler_Started(pNibbler: JSSCTNibblerManager): String;
/*
*/
vars
	xmlDocument: JSSXmlDocument;
	xmlElement: JSSXmlElement;
begin
	create xmlDocument transient;
	xmlElement := xmlDocument.addElement("CT_Response", "");
	xmlElement.addElement("title", pNibbler.myTitle);
	xmlElement.addElement("journal", pNibbler.lastAuditFileNumber.String);
	xmlElement.addElement("timestamp", pNibbler.lastAuditFileTimeStamp.String);
	xmlElement.addElement("complete", pNibbler.lastAuditFileComplete.String);
	xmlElement.addElement("state", "Started");
	xmlElement.addElement("process", process.getOidString());
	xmlElement.addElement("startedApp", pNibbler.isStartedApplication.String);

	return JSSCT_Nibbler_Started.String &amp; SEPARATOR &amp; xmlDocument.buildXmlString() &amp; SEPARATOR;
epilog
	delete xmlDocument;
end;</source>
        <Parameter name="pNibbler" type="JSSCTNibblerManager"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildNibbler_Terminate" id="9704a611-2b76-4334-a7f9-f1ba933b6069">
