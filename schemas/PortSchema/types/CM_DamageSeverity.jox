    <JadeMethod name="validateForDelete" id="5960323e-4ab4-41cb-8575-4ed307d057cb">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	if self.allDamageInstances.isNotEmpty then
		app.raiseCMException1(Cannot_Delete_DamageSeverity, self.code, null, null);
	endif;
epilog

end;</source>
