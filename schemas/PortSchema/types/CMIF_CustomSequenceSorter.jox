    <JadeMethod name="getNextCraneLaneForTwin" id="9d9e1ce6-77d8-4121-a95b-3fb2c8f90c9f">
        <source>getNextCraneLaneForTwin(_isAllocateCraneLane : Boolean; _voyageJob : CM_VoyageJob; _nextCraneId : Integer io) : Integer protected;
// -------------------------------------------
// Created 29 September 2005 by cnwdvb1
// -------------------------------------------
vars

	crane	: CM_Crane;

begin

	if not _isAllocateCraneLane then
		return 0;
	endif;
	
	// Only load jobs.
	if not _voyageJob.jobType = JOB_TYPE_LOAD then
		return 0;
	endif;
	
	// Need job sheet.
	if _voyageJob.myVoyageJobSheet = null then
		return 0;
	endif;
	
	crane := _voyageJob.myVoyageJobSheet.getMyCrane();
	
	// Need a crane.
	if crane = null then
		return 0;
	endif;
	
	return crane.getNextCraneLaneForTwin(_nextCraneId);
end;</source>
        <access>protected</access>
        <Parameter name="_isAllocateCraneLane" type="Boolean"/>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <Parameter name="_nextCraneId" type="Integer" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSortClasses" id="9673f2d3-9c1c-4882-8bf0-ce42afc61476">
        <source>getSortClasses(_sortType : String; _sortClass, _sortClassOther : Class output) protected;
// ---------------------------------------------------------------------------
// Created:     24 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _sortType = SeqSort_BotTopPortStar then
		_sortClass := CMIF_CustSeqB2TP2S;
		_sortClassOther := CMIF_CustSeqB2TS2P;
	elseif _sortType = SeqSort_BotTopStarPort then
		_sortClass := CMIF_CustSeqB2TS2P;
		_sortClassOther := CMIF_CustSeqB2TP2S;
	elseif _sortType = SeqSort_PortStarBotTop then
		_sortClass := CMIF_CustSeqP2SB2T;
		_sortClassOther := CMIF_CustSeqS2PB2T;
	elseif _sortType = SeqSort_PortStarTopBot then
		_sortClass := CMIF_CustSeqP2ST2B;
		_sortClassOther := CMIF_CustSeqS2PT2B;
	elseif _sortType = SeqSort_StarPortBotTop then
		_sortClass := CMIF_CustSeqS2PB2T;
		_sortClassOther := CMIF_CustSeqP2SB2T;
	elseif _sortType = SeqSort_StarPortTopBot then
		_sortClass := CMIF_CustSeqS2PT2B;
		_sortClassOther := CMIF_CustSeqP2ST2B;
	elseif _sortType = SeqSort_TopBotPortStar then
		_sortClass := CMIF_CustSeqT2BP2S;
		_sortClassOther := CMIF_CustSeqT2BS2P;
	elseif _sortType = SeqSort_TopBotStarPort then
		_sortClass := CMIF_CustSeqT2BS2P;
		_sortClassOther := CMIF_CustSeqT2BP2S;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled sortType (' &amp; _sortType &amp; ')');
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_sortType" type="String"/>
        <Parameter name="_sortClass" type="Class" usage="output"/>
        <Parameter name="_sortClassOther" type="Class" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTwinSortTypeReversed" id="6a401dc4-2b03-4a2f-9a04-7ae7dc530e96">
        <source>getTwinSortTypeReversed(_sortType : String) : String protected;
// -------------------------------------------
// Created 30 August 2005 by cnwdvb1
// -------------------------------------------
vars

begin


	if _sortType = SeqSort_BotTopPortStar then
		return SeqSort_BotTopStarPort;
		
	elseif _sortType = SeqSort_BotTopStarPort then
		return SeqSort_BotTopPortStar;
		
	elseif _sortType = SeqSort_PortStarBotTop then
		return SeqSort_StarPortBotTop;
		
	elseif _sortType = SeqSort_StarPortBotTop then
		return SeqSort_PortStarBotTop;
		
	elseif _sortType = SeqSort_PortStarTopBot then	
		return SeqSort_StarPortTopBot;	
		
	elseif _sortType = SeqSort_StarPortTopBot then
		return SeqSort_PortStarTopBot;
		
	elseif _sortType = SeqSort_TopBotPortStar then
		return SeqSort_TopBotStarPort;
		
	elseif _sortType = SeqSort_TopBotStarPort then
		return SeqSort_TopBotPortStar;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_sortType" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="resequenceForTwinLift" id="d188d0df-dff9-4548-bb3f-3f312c7ce8cb">
        <source>resequenceForTwinLift(	_voyageJob:CM_VoyageJob;
						_seqNumStart:Integer;
						_allLiftsInObj:ObjectArray;
						_allLiftsReversedObj:ObjectArray):Integer protected;
// --------------------------------------------------------------------------------
// Created:		17 January 2006 by cnwdad1
//
// Purpose:		Resequences a sorted twin-lift job.
//
// Parameters:	_voyageJob - A reference to the job to be resequenced.
//				_seqNumStart - The starting sequence number.
//				_allLiftsInObj - A reference to the "In" lifts.
//				_allLiftsReversedObj - A reference to the "reversed" lifts.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementObj		: Object;
	sorterObj		: CMIF_CustomSequenceObject;
	lastObj			: CMIF_CustomSequenceObject;
	isTwinLift		: Boolean;
	seqNumber		: Integer;
	nextCraneId		: Integer;
	shipSLiftIfDiffHeights, shipSLiftIfTLWgtExced, isBoldLine		: Boolean;
	aCrane : CM_Crane;
	maxLiftWeightTL : Integer;
	maxTwinLiftDiff : Integer;
	maxTwinLiftDiffSource : String;
begin
	isBoldLine	:=	true;
	shipSLiftIfTLWgtExced := _voyageJob.myTerminal.getConfig(ShipSLiftIfTLWgtExced).Boolean; // 'Make S/Lift if crane twin lift weight exceeded'
	shipSLiftIfDiffHeights := _voyageJob.myTerminal.getConfig(ShipSLiftIfDiffHeights).Boolean;
/*	maxTwinLiftDiff := _voyageJob.myTerminal.getConfig(MaxCraneWeightDiffForTL).Integer;	//14 June 2010 NDL	Par 24108
	
	aCrane := _voyageJob.getJobCrane();
	if aCrane &lt;&gt; null then
		maxLiftWeightTL := aCrane.maxLiftWeightTL;
		//14 June 2010 NDL	Par 24108
		if aCrane.weightDifference &gt; 0 then
			maxTwinLiftDiff := aCrane.weightDifference.Integer;
		endif;
	endif; */
	_voyageJob.getWeightValidationValues( maxTwinLiftDiffSource, aCrane, maxLiftWeightTL, maxTwinLiftDiff);
	
	foreach elementObj in _allLiftsInObj do
		sorterObj	:=	elementObj.CMIF_CustomSequenceObject;
		isTwinLift	:=	sorterObj.isTwinLift(lastObj, shipSLiftIfTLWgtExced, maxLiftWeightTL, shipSLiftIfDiffHeights, maxTwinLiftDiff);
		
		if isTwinLift then
			lastObj.isTwinLiftProperty	:=	true;
			
			if not self.sameSequenceReq then
				seqNumber	:=	seqNumber + 1;
			endif;
		else
			nextCraneId	:=	self.getNextCraneLaneForTwin(self.allocateCraneLane, _voyageJob, nextCraneId);
			seqNumber	:=	seqNumber + 1;
			isBoldLine	:=	not isBoldLine;
		endif;
		
		sorterObj.seqNumTwin			:=	seqNumber;
		sorterObj.isTwinLiftProperty	:=	isTwinLift;
		sorterObj.nextCraneLane			:=	nextCraneId;
		sorterObj.useBold				:=	isBoldLine;
		lastObj							:=	sorterObj;
	endforeach;
	
	seqNumber	:=	(_seqNumStart - 1).max(0);
	lastObj		:=	null;
	nextCraneId	:=	0;
	
	// Run through reversed sorted objects and apply sequence numbers.
	foreach elementObj in _allLiftsReversedObj do
		sorterObj	:=	elementObj.CMIF_CustomSequenceObject;
		isTwinLift	:=	sorterObj.isTwinLift(lastObj, shipSLiftIfTLWgtExced, maxLiftWeightTL, shipSLiftIfDiffHeights, maxTwinLiftDiff);
		
		if isTwinLift then
			if not self.sameSequenceReq then
				seqNumber	:=	seqNumber + 1;
			endif;
		else
			nextCraneId	:=	self.getNextCraneLaneForTwin(self.allocateCraneLane, _voyageJob, nextCraneId);
			seqNumber	:=	seqNumber + 1;
		endif;
		
		sorterObj.seqNumOtherTwin		:=	seqNumber;
		sorterObj.nextCraneLaneOther	:=	nextCraneId;
		lastObj							:=	sorterObj;
	endforeach;
	
	return seqNumber;
end;</source>
        <access>protected</access>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <Parameter name="_seqNumStart" type="Integer"/>
        <Parameter name="_allLiftsInObj" type="ObjectArray"/>
        <Parameter name="_allLiftsReversedObj" type="ObjectArray"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSingleSortDict" id="7a2eac6f-367a-4ce0-9f3d-8ce9d6458319">
        <source>setSingleSortDict(_sortType	: String; _dynaIn : DynaDictionary input) protected;
// -------------------------------------------
// Created 29 August 2005 by cnwdvb1
// -------------------------------------------
vars

	ordinalDeck,
	ordinalCell,
	ordinalBay,
	ordinalTier,
	fortyFooter			: String;

begin

	ordinalDeck		:= CMIF_CustomSequenceObject::mySlotController.name &amp; '.' &amp; CM_SlotController::ordinalDeck.name; 
	ordinalCell		:= CMIF_CustomSequenceObject::mySlotController.name &amp; '.' &amp; CM_SlotController::ordinalCell.name;
	ordinalBay		:= CMIF_CustomSequenceObject::mySlotController.name &amp; '.' &amp; CM_SlotController::myBayVoyage.name &amp; '.' &amp; CM_BayVoyage::ordinalBay.name;
	ordinalTier		:= CMIF_CustomSequenceObject::mySlotController.name &amp; '.' &amp; CM_SlotController::ordinalTier.name;
	fortyFooter		:= CMIF_CustomSequenceObject::myRequest.name &amp; '.' &amp; CM_SlotRequest::fortyFront.name;

	// These are all the load sorts.
	if _sortType = SeqSort_BotTopPortStar then
		_dynaIn.addMemberKey(ordinalBay, false, false);
		_dynaIn.addMemberKey(ordinalDeck, false, false);
		if self.useSeperateLength then
			_dynaIn.addMemberKey(fortyFooter, false, false);
		endif;
		_dynaIn.addMemberKey(ordinalCell, false, false);
		_dynaIn.addMemberKey(ordinalTier, false, false);
		
	elseif _sortType = SeqSort_BotTopStarPort then
		_dynaIn.addMemberKey(ordinalBay, false, false);
		_dynaIn.addMemberKey(ordinalDeck, false, false);
		if self.useSeperateLength then
			_dynaIn.addMemberKey(fortyFooter, false, false);
		endif;
		_dynaIn.addMemberKey(ordinalCell, true, false);
		_dynaIn.addMemberKey(ordinalTier, false, false);
		
	elseif _sortType = SeqSort_PortStarBotTop then
		_dynaIn.addMemberKey(ordinalBay, false, false);
		_dynaIn.addMemberKey(ordinalDeck, false, false);
		if self.useSeperateLength then
			_dynaIn.addMemberKey(fortyFooter, false, false);
		endif;
		_dynaIn.addMemberKey(ordinalTier, false, false);
		_dynaIn.addMemberKey(ordinalCell, false, false);
		
	elseif _sortType = SeqSort_StarPortBotTop then
		_dynaIn.addMemberKey(ordinalBay, false, false);
		_dynaIn.addMemberKey(ordinalDeck, false, false);
		if self.useSeperateLength then
			_dynaIn.addMemberKey(fortyFooter, false, false);
		endif;
		_dynaIn.addMemberKey(ordinalTier, false, false);
		_dynaIn.addMemberKey(ordinalCell, true, false);
	
	// These are all the discharge sorts.
	elseif _sortType = SeqSort_PortStarTopBot then		
		_dynaIn.addMemberKey(ordinalBay, false, false);
		_dynaIn.addMemberKey(ordinalDeck, false, false);
		if self.useSeperateLength then
			_dynaIn.addMemberKey(fortyFooter, true, false);
		endif;
		_dynaIn.addMemberKey(ordinalTier, true, false);
		_dynaIn.addMemberKey(ordinalCell, false, false);
	
	elseif _sortType = SeqSort_StarPortTopBot then
		_dynaIn.addMemberKey(ordinalBay, false, false);
		_dynaIn.addMemberKey(ordinalDeck, false, false);
		if self.useSeperateLength then
			_dynaIn.addMemberKey(fortyFooter, true, false);
		endif;
		_dynaIn.addMemberKey(ordinalTier, true, false);
		_dynaIn.addMemberKey(ordinalCell, true, false);
		
	elseif _sortType = SeqSort_TopBotPortStar then
		_dynaIn.addMemberKey(ordinalBay, false, false);
		_dynaIn.addMemberKey(ordinalDeck, false, false);
		if self.useSeperateLength then
			_dynaIn.addMemberKey(fortyFooter, true, false);
		endif;
		_dynaIn.addMemberKey(ordinalCell, false, false);
		_dynaIn.addMemberKey(ordinalTier, true, false);
		
	elseif _sortType = SeqSort_TopBotStarPort then
		_dynaIn.addMemberKey(ordinalBay, false, false);
		_dynaIn.addMemberKey(ordinalDeck, false, false);
		if self.useSeperateLength then
			_dynaIn.addMemberKey(fortyFooter, true, false);
		endif;
		_dynaIn.addMemberKey(ordinalCell, true, false);
		_dynaIn.addMemberKey(ordinalTier, true, false);
	
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_sortType" type="String"/>
        <Parameter name="_dynaIn" type="DynaDictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTwinSortDict" id="8e350709-7a44-45a2-8f42-a2647ef81d0b">
        <source>setTwinSortDict(_sortType	: String; _dynaIn : DynaDictionary input) protected;
// -------------------------------------------
// Created 29 August 2005 by cnwdvb1
// -------------------------------------------
vars

	ordinalDeck,
	ordinalCell,
	ordinalBay,
	ordinalTier,
	fortyFooter		: String;

begin

	
	ordinalDeck		:= CMIF_CustomSequenceObject::mySlotController.name &amp; '.' &amp; CM_SlotController::ordinalDeck.name; 
	ordinalCell		:= CMIF_CustomSequenceObject::mySlotController.name &amp; '.' &amp; CM_SlotController::ordinalCell.name;
	ordinalBay		:= CMIF_CustomSequenceObject::mySlotController.name &amp; '.' &amp; CM_SlotController::myBayVoyage.name &amp; '.' &amp; CM_BayVoyage::ordinalBay.name;
	ordinalTier		:= CMIF_CustomSequenceObject::mySlotController.name &amp; '.' &amp; CM_SlotController::ordinalTier.name;
	fortyFooter		:= CMIF_CustomSequenceObject::myRequest.name &amp; '.' &amp; CM_SlotRequest::fortyFront.name;

	// These are all the load sorts.
	if _sortType = SeqSort_BotTopPortStar then
		_dynaIn.addMemberKey(ordinalDeck, true, false);
		if self.useSeperateLength then
			_dynaIn.addMemberKey(fortyFooter, false, false);
		endif;
		_dynaIn.addMemberKey(ordinalCell, false, false);
		_dynaIn.addMemberKey(ordinalTier, false, false);
		_dynaIn.addMemberKey(ordinalBay, false, false);
		
	elseif _sortType = SeqSort_BotTopStarPort then
		_dynaIn.addMemberKey(ordinalDeck, true, false);
		if self.useSeperateLength then
			_dynaIn.addMemberKey(fortyFooter, false, false);
		endif;
		_dynaIn.addMemberKey(ordinalCell, true, false);
		_dynaIn.addMemberKey(ordinalTier, false, false);
		_dynaIn.addMemberKey(ordinalBay, false, false);
		
	elseif _sortType = SeqSort_PortStarBotTop then
		_dynaIn.addMemberKey(ordinalDeck, true, false);
		if self.useSeperateLength then
			_dynaIn.addMemberKey(fortyFooter, false, false);
		endif;
		_dynaIn.addMemberKey(ordinalTier, false, false);
		_dynaIn.addMemberKey(ordinalCell, false, false);
		_dynaIn.addMemberKey(ordinalBay, false, false);
		
	elseif _sortType = SeqSort_StarPortBotTop then
		_dynaIn.addMemberKey(ordinalDeck, true, false);
		if self.useSeperateLength then
			_dynaIn.addMemberKey(fortyFooter, false, false);
		endif;
		_dynaIn.addMemberKey(ordinalTier, false, false);
		_dynaIn.addMemberKey(ordinalCell, true, false);
		_dynaIn.addMemberKey(ordinalBay, false, false);
	
	// These are all the discharge sorts.
	elseif _sortType = SeqSort_PortStarTopBot then		
		_dynaIn.addMemberKey(ordinalDeck, false, false);
		if self.useSeperateLength then
			_dynaIn.addMemberKey(fortyFooter, true, false);
		endif;
		_dynaIn.addMemberKey(ordinalTier, true, false);
		_dynaIn.addMemberKey(ordinalCell, false, false);
		_dynaIn.addMemberKey(ordinalBay, false, false);
	
	elseif _sortType = SeqSort_StarPortTopBot then
		_dynaIn.addMemberKey(ordinalDeck, false, false);
		if self.useSeperateLength then
			_dynaIn.addMemberKey(fortyFooter, true, false);
		endif;
		_dynaIn.addMemberKey(ordinalTier, true, false);
		_dynaIn.addMemberKey(ordinalCell, true, false);
		_dynaIn.addMemberKey(ordinalBay, false, false);
		
	elseif _sortType = SeqSort_TopBotPortStar then
		_dynaIn.addMemberKey(ordinalDeck, false, false);
		if self.useSeperateLength then
			_dynaIn.addMemberKey(fortyFooter, true, false);
		endif;
		_dynaIn.addMemberKey(ordinalCell, false, false);
		_dynaIn.addMemberKey(ordinalTier, true, false);
		_dynaIn.addMemberKey(ordinalBay, false, false);
		
	elseif _sortType = SeqSort_TopBotStarPort then
		_dynaIn.addMemberKey(ordinalDeck, false, false);
		if self.useSeperateLength then
			_dynaIn.addMemberKey(fortyFooter, true, false);
		endif;
		_dynaIn.addMemberKey(ordinalCell, true, false);
		_dynaIn.addMemberKey(ordinalTier, true, false);
		_dynaIn.addMemberKey(ordinalBay, false, false);
	
	endif;
	
end;</source>
