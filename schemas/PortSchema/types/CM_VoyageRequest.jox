    <JadeMethod name="splitCompletedWLEs" id="783cf225-638d-483c-901a-8edee243be8e">
        <updating/>
        <source>splitCompletedWLEs(_toJob: CM_VoyageJob) updating;
// --------------------------------------------------------------------------------
// Created:		16 September 2010 by cnwjo3
//
// Purpose:		par 23366
//
vars
	wle : CM_WorkListEntry;
begin
	foreach wle in self.allWorkListEntries do
		//just checking again that its complete
		if wle.status &lt;&gt; WLE_COMPLETED then
			return;
		endif;
	endforeach;

	inheritMethod(_toJob);	

	self.splitWLEs(_toJob);
	
end;</source>
        <Parameter name="_toJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="splitUnactionedWLEs" id="cebce329-ec5f-4a61-8ebd-065c1c2963e3">
        <updating/>
        <source>splitUnactionedWLEs(_newJob: CM_VoyageJob) updating;
//--------------------------------------------------------------
//Created: 24 April 2003 By: cnwgd1
//--------------------------------------------------------------
// 01/04/2010	cnwcs5	par 23383 - pass context info (_request) to updateTICollections 
//									via new parameter (_extra)
vars
	
begin

	// check to see if all are unactioned first as can only split unactioned requests
	if not self.doISplit() then
		return;
	endif;
		
	inheritMethod(_newJob);	
	
	self.splitWLEs(_newJob);
	
epilog
end;</source>
        <Parameter name="_newJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="splitUnqueuedWLEs" id="4635f456-f389-4000-a86f-fe8adfaae5b9">
        <updating/>
        <source>splitUnqueuedWLEs(_newJob: CM_VoyageJob) updating;
// --------------------------------------------------------------------------------
// Created:		20 April 2010 by cnwjo3
//
// Purpose:		par 23520.  This method basically ignores (doesn't add) certain
//				requests/WLE if they have been queued or completed
//				so when the new voyage job is created it only has unplanned
//				requests.
//
vars
	
	wle 		: CM_WorkListEntry;
begin

	//CNWRD1 assuming requedst : WLE 1:1 ratio here for voyage jobs.
	//check to see if all WLE are incomplete and unplanned as can only want to
	//split unplanned requests
	foreach wle in self.allWorkListEntries do
		//if the WLE has been planned or queued we don't want to split it.
		if wle.myFutureMove &lt;&gt; null then
			if  wle.myFutureMove.isKindOf(CM_FutureMoveQueued) then  //cnwrd1 we are only shifting unqued work. 
				return;
			endif;
		endif;
	endforeach;

	inheritMethod(_newJob);	
	
	self.splitWLEs(_newJob);
	

epilog

end;</source>
        <Parameter name="_newJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="testCommodityGroup" id="3e4dff8f-6a0f-4ba3-bd38-25b1b9a721cc">
        <source>testCommodityGroup(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2008	cnwer1	Initial creation

*/

vars
	commodityGroup : CM_CommodityGroup; //cnwas3 PAR 24273
begin
	commodityGroup := self.getAttrCommodityGroup();		//cnwas3 PAR 24273
	if commodityGroup = null then				//cnwas3 PAR 24273
		return false;
	endif;
	
	if not commodityGroup.isSpecialStow then			//cnwas3 PAR 24273
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdateAllocation" id="4feecef7-6681-45d9-bb43-be9d965dacba">
        <source>validateForUpdateAllocation(_voyageAlloc : CM_VoyageAllocation);
/*
Purpose:			
Date		Who		Reason
19 January 2012	cnwab1	Initial creation
*/

vars
	theAllocation : CM_VoyageAllocation;
	voyLC : CM_VoyageController;
	posStr : String;
begin
	theAllocation := self.allAllocations.first.CM_VoyageAllocation;
	
	if theAllocation &lt;&gt; null then
		if theAllocation &lt;&gt; _voyageAlloc then
			// changing from 40 to 20? If want to allow changing 20 to 40 then would have to add in the link  reference between the 20 20 foot requests
			if theAllocation.getIs40() &lt;&gt;  _voyageAlloc.getIs40() then
				voyLC := self.getMyLC();
				
				if voyLC &lt;&gt; null then
					posStr := voyLC.getFullId();
				endif;
				app.raiseCMException1(Posit_alrea_colou_coded_chang_, posStr, null, null);
			endif;

		endif;
	endif;
epilog

end;</source>
        <Parameter name="_voyageAlloc" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="f0cad650-705c-43c4-9f67-d049856ab878">
        <source>validateMoveTo(_control : CMIF_MoveController input);
/*
------------------------------------------------------------------------
Created:			18 February 2003 by cnwdwq1
Purpose:			Checks the slot request against the intended move
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
begin
	if _control.moveMode = REAL_MODE then
		//We only do this if we are PLANNING.
		return;
	endif;
	
	if _control.moveMode = PLANNING_MODE 
	and not _control.doingAutoLoadPlanning then // supress warnings for auto load planning
// cnwdad1 30/07/2010 - PAR #24045.
		//_control.myTrackedItem.testAgainstRequest(self);
		_control.myTrackedItem.testAgainstSlotRequest(self, _control);
	endif;
end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateQuantityUpdate" id="ca38cf8e-b172-42e8-b53f-40d1f487e02e">
        <source>validateQuantityUpdate(_qty : Decimal);
/*
Purpose:			
Date		Who		Reason
19 January 2012	cnwab1	Initial creation
*/

vars
	wle 		: CM_WorkListEntry;
	wleTICount 	: Integer;
begin
	if _qty &gt; self.allWorkListEntries.size then
		return; // should be OK
	endif;
	
	//cnwmc5 - 28/01/2013 - PAR #31058
	wleTICount := 0;
	foreach wle in self.allWorkListEntries discreteLock do
		if wle.myTrackedItem &lt;&gt; null then
			wleTICount := wleTICount + 1;
		endif;
	endforeach;
	
	if wleTICount &gt; _qty then
		app.raiseCMException2(Canno_remov_item_from_being_wo, self.code, wle.job.jobId, null, null);
	endif;
	
	return;
	
	/*foreach wle in self.allWorkListEntries discreteLock do
		if wle.job &lt;&gt; null then // this is good for planning and queueing as must be in a job to do those
			app.raiseCMException2(Canno_remov_item_from_being_wo, self.code, wle.job.jobId, null, null);
			return;
		endif;
	endforeach;*/
	
epilog

end;</source>
        <Parameter name="_qty" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="validateRequestLink" id="5c4d448a-65f6-40bb-bbf4-d18bb01ac136">
        <updating/>
        <source>validateRequestLink(_theRequest : CM_Request) updating ;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	theLocn,theLLocn : String;
begin
	if self.pxyIsProxy then
		theLocn := _theRequest.pxyGetRealObject.CM_Request.getLC.getStowageId(null);
		theLLocn := self.pxyGetRealObject.CM_RORORequest.getLC.getStowageId(null);
	else
		theLocn := _theRequest.getLC.getStowageId(null);
		theLLocn := self.getLC.getStowageId(null);
	endif;
	if self.moveType &lt;&gt; DLR_MOVETYPE and self.moveType &lt;&gt; SOB_MOVETYPE then
		app.raiseCMException2(ERR_INVALID_VALUE,app.getErrorString(Move_type).toUpper, app.getErrorString(Request_at) &amp; " " &amp; theLLocn &amp; " " &amp; app.getErrorString(Cannot_linked_since_not_coded), null, null);
	endif;
	if _theRequest.getMoveType() &lt;&gt; DLR_MOVETYPE and _theRequest.getMoveType &lt;&gt; SOB_MOVETYPE then
		app.raiseCMException2(ERR_INVALID_VALUE,app.getErrorString(Move_type).toUpper, app.getErrorString(Request_at) &amp; " " &amp; theLocn &amp; " " &amp; app.getErrorString(Cannot_linked_since_not_coded), null, null);
	endif;
	if self.moveType &lt;&gt; _theRequest.getMoveType then
		app.raiseCMException2(ERR_INVALID_VALUE,app.getErrorString(Move_type).toUpper, app.getErrorString(Requests_being_linked) &amp; ", " &amp; theLLocn &amp; "/" &amp; theLocn &amp; ", " &amp; app.getErrorString(Have_different_move_types), null, null);
	endif;
	if self.getAttrCargoType() &lt;&gt; _theRequest.getAttrCargoType() then
		app.raiseCMException2(ERR_INVALID_VALUE,app.getErrorString(CM_Cargo_Type).toUpper, app.getErrorString(Requests_being_linked) &amp; ", " &amp; theLLocn &amp; "/" &amp; theLocn &amp; ", " &amp; app.getErrorString(Have_different_cargo_types), null, null);
	endif;
	if self.getAttrEmpty() &lt;&gt; _theRequest.getAttrEmpty() then
		app.raiseCMException2(ERR_INVALID_VALUE,app.getErrorString(Empty).toUpper &amp; " " &amp; app.getErrorString(Attrib), app.getErrorString2(Request_linked_no_matching, theLocn, app.getErrorString(Empty)), null, null);
	endif;
// PAR 32120 see validateRequestLinkSameToSame
//	if self.getAttrIs40() &lt;&gt; _theRequest.getAttrIs40() then
//		app.raiseCMException2(ERR_INVALID_VALUE,app.getErrorString(Forty).toUpper &amp; " " &amp; app.getErrorString(Attrib), app.getErrorString2(Request_linked_no_matching, theLocn, app.getErrorString(Forty)), null, null);
//	endif;
	if self.getAttrPowerRequired() &lt;&gt; _theRequest.getAttrPowerRequired() then
		app.raiseCMException2(ERR_INVALID_VALUE,app.getErrorString(Power).toUpper &amp; " " &amp; app.getErrorString(Attrib), app.getErrorString2(Request_linked_no_matching, theLocn, app.getErrorString(Power)), null, null);
	endif;
	if self.getAttrWaterCooled() &lt;&gt; _theRequest.getAttrWaterCooled() then
		app.raiseCMException2(ERR_INVALID_VALUE,app.getErrorString(WaterCooled).toUpper &amp; " " &amp; app.getErrorString(Attrib), app.getErrorString2(Request_linked_no_matching, theLocn, app.getErrorString(WaterCooled)), null, null);
	endif;
	
	if self.getAttrDischargePort() &lt;&gt; _theRequest.getAttrDischargePort() then
		app.raiseCMException2(ERR_INVALID_VALUE,app.getErrorString(DischargePort), app.getErrorString(Requests_being_linked) &amp; ", " &amp; theLLocn &amp; "/" &amp; theLocn &amp; ", " &amp; app.getErrorString(Have_differe_discharge_ports), null, null);
	endif;
	
	// 15/07/2013 cnwmh5 #31938
	self.validateRequestLinkSameToSame(_theRequest, theLLocn, theLocn);
	
end;</source>
        <Parameter name="_theRequest" type="CM_Request"/>
    </JadeMethod>
</Class>
