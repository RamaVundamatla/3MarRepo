    <JadeMethod name="setMeasurementTypeValue" id="a97faa23-ed21-4ba8-a195-16de7c84eea5">
        <updating/>
        <source>setMeasurementTypeValue(_columnName : String; _value : String)  : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2014	cnwmc5	Initial creation	PAR 34533

*/

vars
	measureType, 
	rowName 		: String;
	measure 		: CM_MeasurementType;
	
begin

	_columnName.getRowNameMeasureType(rowName, measureType);
	measure := app.myRoot.allMeasurementTypesByShortName[measureType];
	if measure &lt;&gt; null and 
	   not measure.isDefault then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyEDIConfig" id="7220d03b-2e5f-48c2-8c26-b37b892f9c32">
        <updating/>
        <source>setMyEDIConfig( _value : CM_EDIConfig ) updating;

/*
Date			Who		Reason
03 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
	
vars
	voyageCodeStr	: String;
	
begin
	self.exclusiveLock(_value.allEDIFilesByEdiClientRef);
	self.exclusiveLock(_value.allEDITrackedItemsByIdStatus);
	if self.myEDIConfig &lt;&gt; _value then
		self.myEDIConfig	:= _value;
	endif;
	
	if self.myEDIConfig = null then
		return;
	endif;
	
	// maintain the manual collection on allEDITrackedItemsByVoyageCode
	voyageCodeStr	:= self.getVoyageCode();
	if voyageCodeStr = null then
		return;
	endif;
	
	self.setVoyageCode( voyageCodeStr );
	
epilog
	
end;
</source>
        <Parameter name="_value" type="CM_EDIConfig"/>
    </JadeMethod>
    <JadeMethod name="setMyEDIData" id="8f5ac5fb-4915-4dc5-bbde-419f80ee845f">
        <updating/>
        <source>setMyEDIData(_ediData : CM_EDIData) updating;

// cnwdvb1 24 January 2003 
// 20 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediFileType : CM_EDIFileType;
begin
// 14 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
	ediFileType := _ediData.getEDIFileType();
	if ediFileType &lt;&gt; null then
		self.exclusiveLock(ediFileType.allEDIFiles);
	endif;
//	self.exclusiveLock(_ediData.ediConfig.allEDIFilesByEdiClientRef);
//	self.exclusiveLock(_ediData.ediConfig.allEDITrackedItemsByIdStatus);
	self.myEDIData := _ediData;
//	self.myEDIConfig := _ediData.ediConfig; //cnwrs1 par 24210 13 may 2010	// cnwrl1 03/06/2010 PAR 24299 - what it was
//	if _ediData &lt;&gt; null then	//cnwrs1 ccms 1976 15 dec 2010 
//		self.setMyEDIConfig( _ediData.ediConfig ); 
//	endif;
end;
</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
