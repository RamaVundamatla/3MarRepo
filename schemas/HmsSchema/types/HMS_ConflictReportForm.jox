    <JadeMethod name="doBaseFormSave" id="cfe3b83f-fb4f-4b18-adf3-1cf2eb81f9c1">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars
	hmsSavedConflictReport : HMS_SavedConflictReport;
	
begin
	app.myTrxCA.trxCreateSavedConflictReport(self.myConflictManager, hmsSavedConflictReport, app.myPassport);

	if not app.myPassport.hasErrors then
		app.msgBox("Conflicts Report successfully saved", "Save Successful", MsgBox_Information_Icon + MsgBox_OK_Only);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
