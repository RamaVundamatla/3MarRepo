<Class name="CM_O2Reading" id="33d4aa88-deeb-4368-b2ae-a6baab9a55d1">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="tempreading"/>
    <PrimAttribute name="dateTime" id="fef85f1a-4279-4cf2-8a9b-dc2bba4eafa0">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myO2ReadingTransaction" id="23e0df7b-22f3-4087-bf6c-736e3055aa50">
        <embedded/>
        <type name="CM_O2ReadingTransaction"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myReeferProperties" id="812124c2-ac0c-4301-9889-642e681da322">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_TIReeferProperties"/>
        <access>readonly</access>
        <Inverse name="CM_TIReeferProperties::allO2Readings"/>
    </ExplicitInverseRef>
    <PrimAttribute name="o2" id="492c691d-46b2-4f1e-9477-1058e6bee6fd">
        <precision>12</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="userId" id="0f0d4100-e32a-49b8-b8b7-cf6c101d2f8b">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="cloneForTrackedItemRefs" id="74c5389a-bb16-4322-91a1-c327a003b4fd">
        <updating/>
        <source>cloneForTrackedItemRefs(_ti : CM_TrackedItem) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars

begin
	self.myReeferProperties := _ti.myReeferProperties;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b1399701-928d-4672-8595-3933e27a7a91">
        <updating/>
        <source>setForCreate(_o2Params : CMIF_O2Reading) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/12/2025	navdap1		Initial creation MTN-36569 CPL Reefer Runner Integration
//
vars
	ti : CM_TrackedItem;

begin
	self.dateTime := _o2Params.dateTime;
	self.o2 := _o2Params.o2;
	
	ti := _o2Params.myTrackedItem;
	ti.createReeferPropertiesIfReqd(self.dateTime);
	self.myReeferProperties := ti.myReeferProperties;
	
	self.userId := _o2Params.userId;
epilog

end;</source>
        <Parameter name="_o2Params" type="CMIF_O2Reading"/>
    </JadeMethod>
</Class>
