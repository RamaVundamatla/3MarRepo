        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="printReleaseWorksheet" id="8c28f459-ba81-4846-a925-873c3c5cafb0">
        <source>printReleaseWorksheet(_jobsToPrint: CM_RailJobArray; _reportName: String);
//----------------------------------------------------------------
//	Created:	18 February 2005	by Jason Chapman  (cnwjc2)
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------
// 18 Mar 2010	consw1		PAR #22886 - Leaking report transients
//----------------------------------------------------------------
vars
	qryReport 			: CM_QryReport;
	jrwManager			: JadeReportWriterManager;
	jrwReport			: JadeReportWriterReport;
	jrwFileName			: String;
	jrwTransient		: CM_JRWWLE;
	reefer				: Object;
	jadeReport			: JadeReport;
	termDict			: CM_TerminalByCodeDict;
	job					: CM_RailJob;
	wle					: CM_WorkListEntry;
begin

	
	qryReport := app.myRoot.getQryReport(_reportName);//"Yard Worksheet - MT Rail Release");
	
	if qryReport = null then
		//app.msgBox('Report ' &amp; _reportName &amp; ' not found.','Report',0);//- cnwmd1, CCMS 1067, Par 19710
		app.msgBox(app.getErrorString1(Report_not_found, _reportName), app.getErrorString(Report),0);//+ cnwmd1, CCMS 1067, Par 19710
		return;
	endif;
	
	jrwTransient := app.myQAFilter.createJRWTransient(CM_JRWWLE).CM_JRWWLE;
	
	if jrwTransient = null then
		//app.raiseUnexpectedProgramError(class.name, method.name, 'Failed to create JRW transient singleton');//- cnwmd1, CCMS 1067, Par 19710
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Failed_create_JRW_singleton));//+ cnwmd1, CCMS 1067, Par 19710
		return;
	endif;
	
	jrwTransient.allWorkListEntries.clear();
	//populate the JRW transient singleton
	foreach job in _jobsToPrint do
		foreach wle in job.workListEntries do
			jrwTransient.allWorkListEntries.add(wle);
		endforeach;
	endforeach;
	
	create termDict transient;
	termDict.add(self.myTerminal);
//	jrwTransient.allTerminals.add(self.myTerminal);
	jrwTransient.setAllTerminals(termDict);
			
	jrwManager := app.createReportWriterManager();
	
	create jadeReport transient;

	app.printer.printPreview := false;

	jrwFileName := qryReport.jrwReportName.first;
	jrwReport := jrwManager.getReport(jrwFileName);
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	jadeReport.description := jrwReport.name;
	app.printer.setReport(jadeReport);
	jrwReport.run();

	if self.chkPrintPreview.value then
		app.printPreview(jadeReport, true);
	else
		app.printer.printReport(jadeReport);
	endif;

	abortTransaction;		// to clear any locks held by the report writer
	
epilog
	delete jrwManager;
	delete jrwReport;
	delete termDict;
end;</source>
        <Parameter name="_jobsToPrint" type="CM_RailJobArray"/>
        <Parameter name="_reportName" type="String"/>
    </JadeMethod>
    <JadeMethod name="removeDynamicGridAreaFrames" id="42bfd4cd-5676-41e1-901d-ef1e8d5cf200">
        <source>removeDynamicGridAreaFrames() protected;
// ---------------------------------------------------------------------------
// Created:     11 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// Purpose:		Remove all of the dynamically created grid area frames.
//				This should be done before mySDF.clearAll is done which
//				removes the transient objects representing the grid area frames.
//				Note this is done here instead of on mySDF so that we can
//				delete only the dynamic controls and not self.frmGridArea
//				which is the painted frame used to clone the controls.
// ---------------------------------------------------------------------------
vars
	gridArea : CMUI_GridArea;

begin
	// PAR 19396 - each wagon has a seperate frame. If an item is selected the current wagon frame is held on the forms reference
	// 						This local reference is left visible and with the same drawing when rail areas are changed, so here we are clearing and making invisible.
	self.frmGridArea.visible := false;
	self.frmGridArea.clearGraphics();

	foreach gridArea in self.mySDF.allGridAreasByColumnRow do
		if gridArea.myGridAreaFrame &lt;&gt; self.frmGridArea then
			delete gridArea.myGridAreaFrame;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="removeWagonRailAllocation" id="c41990e1-5009-412f-8632-c2a126be2aa7">
        <updating/>
        <source>removeWagonRailAllocation()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2009	cnwmd1	Initial creation

*/

vars
	wagonColl : ObjectSet;
begin
/*
	wagon := self.myCurrentWagon;
	
	if wagon = null then
		app.msgBox(app.getErrorString(Please_select_wagon),app.getErrorString(No_Wagon_selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if app.msgBox(app.getErrorString(Sure_that_wish_remov_colou_cod), app.getErrorString(Colour_coding), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	wagon.removeRailAllocation(app.myPassport);
	
	if (not app.myPassport.trxCompletedOK) then
		app.showErrorWarningDialog(app.getErrorString(Colour_coding_delete), app.myPassport, ErrWarnMode_Update);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
	else
		self.clearErrorWarnings();
	endif;
*/
	create wagonColl transient;
	self.getSelectedWagons(wagonColl, null); 
	if wagonColl.size = 0 then
		app.msgBox(app.getErrorString(Please_select_wagon),app.getErrorString(No_Wagon_selected), MsgBox_Exclamation_Mark_Icon);
		return;
	elseif app.msgBox(app.getErrorString(Sure_that_wish_remov_colou_cod), app.getErrorString(Colour_coding), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	app.myTrxDA.trxDeleteRailAllocsForWagons(wagonColl, app.myPassport);
epilog
	delete wagonColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="removedUnrelatedJobWLE" id="88972182-6e9d-4f06-95ff-d040bc884247">
        <source>removedUnrelatedJobWLE( railJob : CM_RailJob ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
29 July 2009	cnwndl1	Initial creation
17 Nov 2016 	cnwrs1	Par 37738 TFS 2949 incorrect UPSP rail location being displayed
23 May 2019		jlgzm1	TFS 42840 - Getting 1090 error doing deleted object check
*/

vars

	iter : Iterator;
	wleArray: CM_WLEArray;
	wle : CM_WorkListEntry;
	job 	: CM_Job;
	allJobs : CM_JobSet;
	rowIdx : Integer;
	invalid : Boolean;

begin
	on Exception do app.handleDeletedObject(exception, self.myCurrentListObject, invalid);		 // PAR 37738
	
	create wleArray transient;
	create allJobs transient;
	
	if myCurrentListObject &lt;&gt; null then
		myCurrentListObject.getAllWLEs(wleArray);
		if invalid then
			return true;
		endif;
		foreach wle in wleArray do
			job := wle.job;
			if not allJobs.includes(job) then
				allJobs.add(job);
			endif;
		endforeach;
	endif;
	
	if allJobs.includes(railJob) then
		return false;
		
	else
		iter := railJob.workListEntries.createIterator;
		while iter.next(wle) do
			if self.tblWorkEntries.findObjectInRow(wle, rowIdx) then
				self.tblWorkEntries.removeItem(rowIdx);
			endif;
		endwhile;
		
		return true;
		
	endif;
	
epilog

	delete wleArray;
	delete allJobs;
	delete iter;
	
end;</source>
        <Parameter name="railJob" type="CM_RailJob"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectISOSource" id="ecfd237f-9087-4bab-8006-723a2f32de07">
        <source>selectISOSource();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 June 2010	cnwrd1	Initial creation

*/


vars
	sourceForm	: CMUI_SelectISOSourceMulti;
	wleArray : CM_WLEArray;
begin
	create wleArray transient;
	
	self.getAllWLEsInTableSelected(wleArray );

	if wleArray.isEmpty then
		return;
	endif;
	
	sourceForm := app.loadForm(CMUI_SelectISOSourceMulti, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_SelectISOSourceMulti;

	sourceForm.centreWindow;
	sourceForm.setMyTerminal(self.myTerminal);
	//sourceForm.myCurrentWLE := self.myCurrentWLE;
	wleArray.copy ( sourceForm.allWLEs);
	
	sourceForm.myDeliveryRequest := self.myCurrentWLE.myRequest.CM_DeliveryRequest;

	sourceForm.showModal;

epilog 
	delete wleArray;
end;</source>
