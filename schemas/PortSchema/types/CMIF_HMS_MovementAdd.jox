<Class name="CMIF_HMS_MovementAdd" id="78affa75-e334-4178-a854-523abf31e873">
    <superclass name="CMIF_HMS_StackChange"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <ImplicitInverseRef name="appliesToMovement" id="4bb6bb54-e724-4a8e-ad18-fb070e68c3f8">
        <embedded/>
        <type name="CMIF_HMS_WorkingMovement"/>
    </ImplicitInverseRef>
    <JadeMethod name="applyChange" id="3d36869f-8bb4-4fe2-b1b2-1e963b463a61">
        <updating/>
        <source>applyChange() updating;

vars

begin
 	// Add movement to its parent voyage collection of allWorkingMovements
 	appliesToMovement.myWorkingVoyage.allWorkingMovements.add(appliesToMovement);

 	// Add movement to the controller's allMovementsInViewByDT collection
    appliesToMovement.myViewControllerCurrent := ofViewController;

   	// Update views
 	ofViewController.view_NewSelectedMovement(appliesToMovement, false);
end;</source>
    </JadeMethod>
    <JadeMethod name="getMyWorkingMovement" id="03fe2de3-b279-4d4d-b442-1c34aea9af10">
        <source>getMyWorkingMovement(): CMIF_HMS_WorkingMovement;
//--------------------------------------------------
// Created:	20 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.appliesToMovement;

end;</source>
        <ReturnType type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="undoChange" id="e4517eb1-c6bb-4772-879b-f875120ab8c0">
        <updating/>
        <source>undoChange() updating;

vars

begin
   	// Remove movement from its parent voyage collection of allWorkingMovements
 	//appliesToMovement.ofVoyageForDisplay:=null;
 	appliesToMovement.myVoyageForDisplay := null; 	

 	// Remove movement to the controller's allMovementsInViewByDT collection
    //appliesToMovement.ofCurrentView:=null;
    appliesToMovement.myViewControllerCurrent := null;    

    // Update views
	if ofViewController.myCurrentWorkingVoyage &lt;&gt; null then    
	 	ofViewController.view_NewSelectedMovement(ofViewController.myCurrentWorkingVoyage.allWorkingMovements.first.CMIF_HMS_WorkingMovement, false);
	endif;
end;</source>
    </JadeMethod>
</Class>
