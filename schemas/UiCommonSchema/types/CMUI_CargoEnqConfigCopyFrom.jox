	unloadForm;
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnNext_click" id="25809e9d-58c4-434f-9c36-5ed2750ad41b">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNext_click(btn: Button input) updating;

vars

begin
	self.doNext();
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doNext" id="6a977701-5c23-4063-b10f-500ff7aaf1f4">
        <updating/>
        <source>doNext() updating, protected;

vars
	indx		: Integer;
	user		: CM_User;
	listBox		: ListBox;
	typesForm 	: CMUI_CargoEnqConfigCopyTypes;
begin

	create typesForm transient;
	listBox := self.lstUserFrom;
	foreach indx in 1 to listBox.listCount do
		if listBox.itemSelected[indx] then
			user := listBox.itemObject[indx].CM_User;
			typesForm.allUsers.add(user);
		endif;
	endforeach;
	typesForm.copyFrom := true;
	typesForm.centreWindow;
	typesForm.setMyTerminal(self.myTerminal);
	//typesForm.show;
	typesForm.showModal;	// 10/02/2015 cnwar2 #34359

	self.unloadForm();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstUserFrom_click" id="14f43652-c430-44c5-b049-9d41d697e5f6">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstUserFrom_click(listbox: ListBox input) updating;

vars

begin
	self.btnNext.enabled := true;
end;
</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateUsers" id="2d0c1f2c-dc48-4ded-8b00-0c970917706d">
        <updating/>
        <source>populateUsers() updating, protected;
// all users into the copy-from list
vars
	idx		: Integer;
	userName	: String;
	user	: CM_User;
begin
	self.lstUserFrom.clear();
	foreach user in app.myRoot.allUsers discreteLock do
		// exclude not-for-entry and self
		if user.isNotAvailableForEntry or
		   user = app.myPassport.myUser then
			continue;
		endif;
		if user.userName = null then
			userName := user.code;
		else
			userName := user.userName; 
		endif;
		idx := self.lstUserFrom.addItem(userName);
		lstUserFrom.itemObject[idx] := user;
	endforeach;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c16c4cab-08ca-4ca3-b75d-8d862bcd6a35">
        <updating/>
        <source>setupForm() updating;

vars

begin
	inheritMethod();
	
	self.populateUsers();
	self.btnNext.enabled := false;
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ea378398-c24d-4a76-ac1b-a3f0717fdbf6">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:40:12.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023236, locale);
	btnCancel.translateCaption(Xlat_0016849, locale);
	btnNext.translateCaption(Xlat_0016850, locale);
end;</source>
    </JadeMethod>
</GUIClass>
