    <JadeMethod name="doListboxDblClick" id="c9c6114a-aff4-4417-9d67-bca0678373f5">
        <updating/>
        <source>doListboxDblClick(listbox : ListBox input) updating;

vars
	numRows,
	idx,
	i,
	lvl		: Integer;

begin
	app.mousePointer := MousePointer_HourGlass;

	idx := listbox.listIndex;
	if idx &lt;&gt; -1 then
		if listbox.itemExpanded[idx] then
			listbox.itemExpanded[idx] := false;
		else
			numRows := listbox.listCount;
			lvl := listbox.itemLevel[idx];
			listbox.itemExpanded[idx] := true;
			foreach i in idx+1 to numRows do
				if listbox.itemLevel[i] = lvl then
					break;
				endif;
				listbox.itemExpanded[i] := true;
			endforeach;
		endif;
	endif;

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuContextMenuInspect" id="24c00317-d034-480c-b57f-6f6386d13382">
        <source>doMnuContextMenuInspect();
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 13 February 2004
//
