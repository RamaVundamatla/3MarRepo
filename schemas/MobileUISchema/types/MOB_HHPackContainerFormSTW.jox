    <JadeMethod name="handleBtnOne" id="f709c8c4-b4de-4937-a42c-38bc35ddfa73">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	vehicle : CM_Vehicle;
	roadJob : CM_RoadJob;
	wle : CM_WorkListEntry;
	incompleteWleSet : CM_WLESet;
	bulkRel : CM_BulkRelease;
	parentResDet: CM_ReserveDetail;
	childResDet: CM_ReserveDetail;
	doWarn : Boolean;

begin

	//12 Nov 2018	NDL	TFS 38083
	bulkRel := self.myMobileGenericAgent.myBulkRelease;
	if bulkRel &lt;&gt; null and bulkRel.isPackingType and bulkRel.allReserveDetails.size = 1 then
		// Packing request with one parent
		parentResDet := bulkRel.allReserveDetails.first;
		if parentResDet.totalRequested = 1 then
			// add warning if bulk rel has single container on single parent and not all items packed.
			foreach childResDet in bulkRel.allReservePackingChildren do
				if not childResDet.isFullyPacked() then
					doWarn := true;
					break;
				endif;
			endforeach;
			if doWarn then
				if self.msgBox(app.getErrorString(Have_reque_compl_this_pack_req) &amp; CrLf &amp;  app.getErrorString(Continue), app.getErrorString(Continue), MsgBox_Yes_No, false) = MsgBox_Return_No then
					return;
				endif;
			endif;
		endif;
	endif;

	if self.myMobileGenericAgent.myTruck &lt;&gt; null then
		vehicle := self.myMobileGenericAgent.myTruck;
		
		if vehicle &lt;&gt; null then
			roadJob := vehicle.allRoadJobs.first.CM_RoadJob;
		endif;
		
		if roadJob &lt;&gt; null then
			create incompleteWleSet transient;
			foreach wle in roadJob.workListEntries do
				if wle.status = WLE_COMPLETED then
					continue;
				endif;
				if wle.isReceipt then
					continue;
				endif;
				if wle.myTrackedItem &lt;&gt; null then
					continue;
				endif;
				incompleteWleSet.add( wle );
			endforeach;
			if not incompleteWleSet.isEmpty then
				if self.msgBox( app.getErrorString(Truck_still_incom_jobs_want_co),  app.getErrorString(Continue), MsgBox_Yes_No, false ) &lt;&gt; MsgBox_Return_Yes then
					return;
				endif;
			endif;
			foreach wle in incompleteWleSet do
				app.myTrxUA.trxUpdateWLEStatusDirectWLE(wle.CM_YardWLE, WLE_COMPLETED, app.myPassport);	
				if app.myPassport.hasErrors then
					self.msgBox(app.myPassport.getErrorsAsString,app.getErrorString(Error), MsgBox_OK_Only, true);
					return;
				endif;
			endforeach;
		endif;
		
	endif;
	
	self.gotoForm( MOB_HHPackComplete, false );
	return;

epilog

	delete incompleteWleSet;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnThree" id="72f5eab5-a83a-4c10-8f31-3195a94fae2b">
