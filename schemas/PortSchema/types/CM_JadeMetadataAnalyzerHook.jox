<Class name="CM_JadeMetadataAnalyzerHook" id="0109d68a-3e28-43f5-a042-40e554e9a008">
    <superclass name="JadeMetadataAnalyzer"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <CompAttribute name="allMetaConstantsToCheck" id="3402f390-ca7d-440c-a83e-4390df6a5bce">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <ImplicitInverseRef name="allSchemaEntities" id="a3ab8629-5377-4ba6-ab3e-38c8567bd87b">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="addMetaConstant" id="5d31b01e-4ab7-43a1-9aa2-b7deea38e52f">
        <updating/>
        <source>addMetaConstant(_metaConstant : String) updating;
// -------------------------------------------
// Created 09 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.allMetaConstantsToCheck.add(_metaConstant);
	
end;</source>
        <Parameter name="_metaConstant" type="String"/>
    </JadeMethod>
    <JadeMethod name="addSchemaEntity" id="d47a2089-783b-430e-b9a5-d54e98cbccc1">
        <updating/>
        <source>addSchemaEntity(_entity : SchemaEntity) updating;
// -------------------------------------------
// Created 09 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.allSchemaEntities.add(_entity);


end;</source>
        <Parameter name="_entity" type="SchemaEntity"/>
    </JadeMethod>
    <JadeMethod name="canAccessSchemaEntity" id="22fbe532-2bb8-4aae-bd93-652feebf055e">
        <source>canAccessSchemaEntity(_schemaEntity: SchemaEntity; _errorMessage: String output): Boolean;
// -------------------------------------------
// Created 09 February 2005 by cnwdvb1
// -------------------------------------------
constants

	Class_Name = 'Class';
vars

	entity	: Object;
	subs	: ClassColl;
	okClass,
	class,
	class2	: Class;
	
	
begin

	// Only checking classes at this stage.
	if _schemaEntity.isKindOf(Class) then
		class := 	_schemaEntity.Class;
		if class.name = Class_Name then
			return true;
		endif;
		create subs transient;
		foreach entity in self.allSchemaEntities where entity.isKindOf(Class) do
			okClass := entity.Class;

			if class.name = okClass.name then
				return true;
			else
				subs.clear();
				okClass.allSubclasses(subs);
				foreach class2 in subs do
					if class.name = class2.name then
						return true;
					endif;
				endforeach;
			endif;
		endforeach;
		_errorMessage := 'You do not have permisson to access schema entity (' &amp; _schemaEntity.name &amp; ')';
		return false;
	endif;
	
	return true;

epilog
	delete subs;
end;</source>
        <Parameter name="_schemaEntity" type="SchemaEntity"/>
        <Parameter name="_errorMessage" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canAccessStatement" id="1b32fd46-ad13-468f-911f-c29927e183cc">
        <source>canAccessStatement(_statement: String; _errorMessage: String output): Boolean;
// -------------------------------------------
// Created 09 February 2005 by cnwdvb1
// -------------------------------------------
vars
	statement	: String;

begin
	
	if self.allMetaConstantsToCheck.includes(_statement) then
		_errorMessage := 'You do not have permission to use the code statement (' &amp; _statement &amp; ')';
		return false;
	endif;
	
	return true;


end;</source>
        <Parameter name="_statement" type="String"/>
        <Parameter name="_errorMessage" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="0a31713b-3ae4-4f50-9e64-1131cf5f5cab">
        <updating/>
        <source>create() updating;
// -------------------------------------------
// Created 09 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.addSchemaEntity(Class);


end;</source>
    </JadeMethod>
</Class>
