    <JadeMethod name="setIndex" id="27d7d3e1-f9df-4785-aa34-33185fb4fd74">
        <updating/>
        <source>setIndex(_idx : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     20 December 2002		cnwth2	
//
// Purpose:     This is to maintain the ORDER in which child objects are displayed
//				Sets the attribute, then bumps everything else 'down'
//			 
// ----------   ----------  --------------------------------------------------
vars
	parentObj			: CM_MenuEntity;
	childObj			: CM_MenuEntity;
	
begin
	if _idx &lt; 1 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempted to set menu index less than 1!');		
		return;
	endif;
	
	self.index := _idx;
	
	if self.myParent = null then
		return;
	endif;
	
	parentObj := self.myParent;	
	
	foreach childObj in parentObj.allChildren do
		if childObj = self then
			continue;
		endif;
		
		if childObj.index = self.index or
			childObj.index &gt; self.index then
			childObj.index := childObj.index + 1;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
