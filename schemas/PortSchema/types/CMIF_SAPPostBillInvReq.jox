        <source>getActivityHistoryExtraDetails(_activityHistory: CM_ActivityHistoryExtInterface input): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2019	jlgndl1	Initial creation	TFS 46758

*/

vars
	
begin
	
	return self.getInvoiceIdString( _activityHistory );

epilog

end;</source>
        <Parameter name="_activityHistory" type="CM_ActivityHistoryExtInterface" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
