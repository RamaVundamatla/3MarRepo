    <JadeMethod name="doSave" id="98488a14-7b9d-454b-aa83-b475e020105a">
        <updating/>
        <source>doSave() : Boolean updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 10 July 2023
TFS#		: 58636
Function	:

*** Changes ***
Date			Name		TFS#		Description
27 Jul 2023		jlika1		59068		EUP - Goods Receipt - Move Transaction area triggers
26/03/2024		navcs2		ChangeRequest 60397: EUP | FR 54085 - Load Confirmation / Goods Receipt - Multiple Move transaction criteria, Event Only Trigger
****************************************************/

vars
	camsMoveProxy 		: CM_CamsMoveTATypeCritieria;
	realCamsMoveProxy 	: CM_CamsMoveTATypeCritieria;
	fromAreaType 		: Integer;
	toAreaType 			: Integer;
	exclAreaType 		: Integer;
	isForUpdate			: Boolean;
	result 				: Integer;
begin
	if self.validateCriteria() then	
		if self.myCamprotocol &lt;&gt; null and self.myCurrentMoveCrit = null then			// 26/03/2024		navcs2		ChangeRequest 60397
			create camsMoveProxy transient;		
			isForUpdate := false;
		elseif self.myCamprotocol &lt;&gt; null and self.myCurrentMoveCrit &lt;&gt; null then		// 26/03/2024		navcs2		ChangeRequest 60397
			camsMoveProxy := self.myCurrentMoveCrit;
			isForUpdate := true;
		endif;
		
		if self.myCamprotocol.isGoodsReceipt() and self.cmbFromAreaType.text = app.getErrorString(MoveTATypeVoyage) then
			fromAreaType := CM_CamsMoveTATypeCritieria.VoyageArea;
		elseif self.myCamprotocol.isGoodsReceipt() and self.cmbFromAreaType.text = app.getErrorString(MoveTATypeAnyArea) then
			fromAreaType := CM_CamsMoveTATypeCritieria.AnyArea;
		elseif self.myCamprotocol.isLoadConfirmation() and self.cmbFromAreaType.text = app.getErrorString(MoveTATypeAnyArea) then
			fromAreaType := CM_CamsMoveTATypeCritieria.AnyArea;
		else
			fromAreaType := self.cmbFromAreaType.listObject.CM_TerminalAreaType.type;
		endif;
		
		if self.myCamprotocol.isGoodsReceipt() and self.cmbToAreaType.text = app.getErrorString(MoveTATypeVoyage) then
			toAreaType := CM_CamsMoveTATypeCritieria.VoyageArea;
		elseif self.myCamprotocol.isGoodsReceipt() and self.cmbToAreaType.text = app.getErrorString(MoveTATypeAnyArea) then
			toAreaType := CM_CamsMoveTATypeCritieria.AnyArea;
		elseif self.myCamprotocol.isGoodsReceipt() and self.cmbToAreaType.text = app.getErrorString(MoveTATypeTruck) then
			toAreaType := CM_CamsMoveTATypeCritieria.TruckArea;
		elseif self.myCamprotocol.isGoodsReceipt() and self.cmbToAreaType.text = app.getErrorString(MoveTATypeWagon) then
			toAreaType := CM_CamsMoveTATypeCritieria.WagonLocation;
		elseif self.myCamprotocol.isLoadConfirmation() and self.cmbToAreaType.text = app.getErrorString(MoveTATypeVoyage) then
			toAreaType := CM_CamsMoveTATypeCritieria.VoyageArea;
		elseif self.myCamprotocol.isLoadConfirmation() and self.cmbToAreaType.text = app.getErrorString(MoveTATypeTruck) then
			toAreaType := CM_CamsMoveTATypeCritieria.TruckArea;
		elseif self.myCamprotocol.isLoadConfirmation() and self.cmbToAreaType.text = app.getErrorString(MoveTATypeWagon) then
			toAreaType := CM_CamsMoveTATypeCritieria.WagonLocation;
		else
			toAreaType := self.cmbToAreaType.listObject.CM_TerminalAreaType.type;
		endif;
		
		if self.cmbExclAreaType.listObject &lt;&gt; null then
			exclAreaType := self.cmbExclAreaType.listObject.CM_TerminalAreaType.type;
		else
			exclAreaType := -1;
		endif;
		
		while true do	
		
			if isForUpdate then
				camsMoveProxy := app.createUpdateProxy(self.myCurrentMoveCrit).CM_CamsMoveTATypeCritieria;			//26/03/2024 navcs2	ChangeRequest 60397
				camsMoveProxy.setProxy(fromAreaType, toAreaType, exclAreaType);
				app.myTrxUA.trxUpdateCamsMoveTAType(camsMoveProxy, app.myPassport);
			else
				camsMoveProxy.setProxy(fromAreaType, toAreaType, exclAreaType);
				app.myTrxCA.trxCreateCamsMoveTAType(camsMoveProxy, realCamsMoveProxy, self.myCamprotocol, app.myPassport);
			endif;
			
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				return true;
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknowledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
				
			return false;	
		endwhile;
	endif;
	return false;
epilog
	delete camsMoveProxy;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableDisableExcludeTA" id="9638dce5-6639-4a75-963f-31fa639996ec">
        <source>enableDisableExcludeTA();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2024	navcs2	ChangeRequest 60397: EUP | FR 54085 - Load Confirmation / Goods Receipt - Multiple Move transaction criteria, Event Only Trigger

*/

vars

begin
	if self.cmbToAreaType.text = app.getErrorString(MoveTATypeVoyage) or self.cmbFromAreaType.text = app.getErrorString(MoveTATypeVoyage)  then
		self.cmbExclAreaType.enabled := true;
	else
		self.cmbExclAreaType.enabled := false;
		self.cmbExclAreaType.text := null;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetForm" id="9aba6ea8-4be4-47ca-ae4b-1acc0c5e9ffc">
        <updating/>
        <source>resetForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2024	navcs2	ChangeRequest 60397: EUP | FR 54085 - Load Confirmation / Goods Receipt - Multiple Move transaction criteria, Event Only Trigger

*/

vars

begin
	self.myCurrentMoveCrit := null;
	self.setupCombos();
	self.btnAdd.caption := self.ADD;
	self.setupTable(ETDef_MoveTaTypeCriteria);
	self.btnDelete.enabled := false;
	self.enableDisableExcludeTA();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setComboBoxTAType" id="a3ea8815-96a8-4c20-81db-c6fde7ae15e3">
        <source>setComboBoxTAType(pCmb : CMUI_ComboBox io; pTAType : CM_TerminalAreaType) protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 10 July 2023
TFS#		: 58636
Function	:

*** Changes ***
Date			Name		TFS#		Description
04 Aug 2023		jlika1		59582		EUP Goods Receipt - Move Area Type Config - Filter options
****************************************************/

vars
	ta 		: CM_TerminalAreaType;
	iter 	: Iterator;
	str 	: String;	
	root	: CM_Root;
	
begin
	root := app.myRoot;
	pCmb.sorted := true;
	iter := root.allTerminalAreaTypes.createIterator();
		
	while iter.next(ta) do
				
		if ta.getIsNotAvailableForEntry() then 
			continue;
		endif;
		
		pCmb.itemObject[pCmb.addItem(ta.description.trimRight)] := ta;
	endwhile;
	//do they want to default or not? for now do not  default but add a validation to make it mandatory
	/*if not root.allTerminalAreaTypes.isEmpty then
		pCmb.listIndex := 1;
	endif;
	*/
	if pTAType &lt;&gt; null then
		if pCmb.text &lt;&gt; null then
			pCmb.listObject := pTAType;
		endif;
	endif;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="pCmb" type="CMUI_ComboBox" usage="io"/>
        <Parameter name="pTAType" type="CM_TerminalAreaType"/>
    </JadeMethod>
    <JadeMethod name="setMyMoveTrxCriteria" id="ced404a3-4990-4c79-a631-73389ee7d7b9">
        <updating/>
        <source>setMyMoveTrxCriteria(_moveTrxCriteria : CM_CamsMoveTATypeCritieria) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 10 July 2023
TFS#		: 58636
Function	:

*** Changes ***
Date			Name		TFS#		Description
26/03/2024		navcs2		ChangeRequest 60397
****************************************************/

begin
	/*
	beginTransaction;
	self.myCamprotocol.addMyMoveTrxCriteria(_moveTrxCriteria);
	commitTransaction;
	
	self.setupTable(ETDef_MoveTaTypeCriteria);
	*/
end;</source>
        <Parameter name="_moveTrxCriteria" type="CM_CamsMoveTATypeCritieria"/>
    </JadeMethod>
    <JadeMethod name="setupCombos" id="712954bd-4e23-41d1-a064-13e9795de982">
        <source>setupCombos();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2024	navcs2	ChangeRequest 60397: EUP | FR 54085 - Load Confirmation / Goods Receipt - Multiple Move transaction criteria, Event Only Trigger

*/

vars
	terminalAreaType	: CM_TerminalAreaType;
	moveTrxCriteria		: CM_CamsMoveTATypeCritieria;
begin
	if self.myCamprotocol &lt;&gt; null and self.myCurrentMoveCrit &lt;&gt; null then
		
		moveTrxCriteria := self.myCurrentMoveCrit;
		
		if self.myCamprotocol.isGoodsReceipt() and moveTrxCriteria.fromTaType = CM_CamsMoveTATypeCritieria.VoyageArea then
			self.cmbFromAreaType.text := app.getErrorString(MoveTATypeVoyage);
		elseif self.myCamprotocol.isGoodsReceipt() and moveTrxCriteria.fromTaType = CM_CamsMoveTATypeCritieria.AnyArea then
			self.cmbFromAreaType.text := app.getErrorString(MoveTATypeAnyArea);
		elseif self.myCamprotocol.isLoadConfirmation() and moveTrxCriteria.fromTaType = CM_CamsMoveTATypeCritieria.AnyArea then
			self.cmbFromAreaType.text := app.getErrorString(MoveTATypeAnyArea);
		else
			terminalAreaType := app.myRoot.allTerminalAreaTypes[moveTrxCriteria.fromTaType];
			self.cmbFromAreaType.text := terminalAreaType.description.trimRight;
		endif;
		
		if self.myCamprotocol.isGoodsReceipt() and moveTrxCriteria.toTAType = CM_CamsMoveTATypeCritieria.AnyArea then		
			self.cmbToAreaType.text := app.getErrorString(MoveTATypeAnyArea);
		elseif self.myCamprotocol.isGoodsReceipt() and moveTrxCriteria.toTAType = CM_CamsMoveTATypeCritieria.VoyageArea then
			self.cmbToAreaType.text := app.getErrorString(MoveTATypeVoyage);
		elseif self.myCamprotocol.isGoodsReceipt() and moveTrxCriteria.toTAType = CM_CamsMoveTATypeCritieria.TruckArea then
			self.cmbToAreaType.text := app.getErrorString(MoveTATypeTruck);
		elseif self.myCamprotocol.isGoodsReceipt() and moveTrxCriteria.toTAType = CM_CamsMoveTATypeCritieria.WagonLocation then		
			self.cmbToAreaType.text := app.getErrorString(MoveTATypeWagon);
		elseif self.myCamprotocol.isLoadConfirmation() and moveTrxCriteria.toTAType = CM_CamsMoveTATypeCritieria.VoyageArea then
			self.cmbToAreaType.text := app.getErrorString(MoveTATypeVoyage);
		elseif self.myCamprotocol.isLoadConfirmation() and moveTrxCriteria.toTAType = CM_CamsMoveTATypeCritieria.TruckArea then
			self.cmbToAreaType.text := app.getErrorString(MoveTATypeTruck);
		elseif self.myCamprotocol.isLoadConfirmation() and moveTrxCriteria.toTAType = CM_CamsMoveTATypeCritieria.WagonLocation then		
			self.cmbToAreaType.text := app.getErrorString(MoveTATypeWagon);
		else
			terminalAreaType := app.myRoot.allTerminalAreaTypes[moveTrxCriteria.toTAType];
			self.cmbToAreaType.text := terminalAreaType.description.trimRight;
		endif;
		
		terminalAreaType := app.myRoot.allTerminalAreaTypes[moveTrxCriteria.notToTAType];
		if terminalAreaType &lt;&gt; null then
			self.cmbExclAreaType.text := terminalAreaType.description.trimRight;
		else
			self.cmbExclAreaType.text := null;
		endif;
		
	elseif self.myCurrentMoveCrit = null then
		self.cmbExclAreaType.text := null;
		self.cmbToAreaType.text := null;
		self.cmbFromAreaType.text := null;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3f31986f-a844-48a4-8fd3-deb5ea6dadbb">
        <updating/>
        <source>setupForm() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 10 July 2023
TFS#		: 58636
Function	:

*** Changes ***
Date			Name		TFS#		Description
27 Jul 2023		jlika1		59068		EUP - Goods Receipt - Move Transaction area triggers
04 Aug 2023		jlika1		59582		EUP Goods Receipt - Move Area Type Config - Filter options
20/03/2024		navcs2		ChangeRequest 60397: EUP | FR 54085 - Load Confirmation / Goods Receipt - Multiple Move transaction criteria, Event Only Trigger
****************************************************/
vars
	terminalAreaType	: CM_TerminalAreaType;
	moveTrxCriteria		: CM_CamsMoveTATypeCritieria;
begin
	inheritMethod();
	
	self.setComboBoxTAType(self.cmbFromAreaType, null);
	self.setComboBoxTAType(self.cmbToAreaType, null);

	if self.myCamprotocol.isGoodsReceipt() then
		self.cmbFromAreaType.addItem(app.getErrorString(MoveTATypeVoyage));
		self.cmbFromAreaType.addItem(app.getErrorString(MoveTATypeAnyArea));
		
		self.cmbToAreaType.addItem(app.getErrorString(MoveTATypeAnyArea));
		self.cmbToAreaType.addItem(app.getErrorString(MoveTATypeVoyage));
		self.cmbToAreaType.addItem(app.getErrorString(MoveTATypeTruck));
		self.cmbToAreaType.addItem(app.getErrorString(MoveTATypeWagon));
	elseif self.myCamprotocol.isLoadConfirmation() then
		self.cmbFromAreaType.addItem(app.getErrorString(MoveTATypeAnyArea));
		
		self.cmbToAreaType.addItem(app.getErrorString(MoveTATypeVoyage));
		self.cmbToAreaType.addItem(app.getErrorString(MoveTATypeTruck));
		self.cmbToAreaType.addItem(app.getErrorString(MoveTATypeWagon));

	endif;
	self.setComboBoxTAType(self.cmbExclAreaType, null);	
	
	self.setupCombos();
	
	self.btnOk.visible := false;
	self.btnCancel.caption := "Close";
	
	self.setupTable(ETDef_MoveTaTypeCriteria);		// 20/03/2024 navcs2 ChangeRequest 60397
	
	 if self.myCamprotocol.isGoodsReceipt() then
		self.lblExclAreaType.visible := true;
		self.lblExclAreaTypeLC.visible := false;
	 elseif self.myCamprotocol.isLoadConfirmation() then
		self.lblExclAreaType.visible := false;
		self.lblExclAreaTypeLC.visible := true;
	 endif;	
	
	self.enableDisableExcludeTA();			// 17/05/2024 navcs2 ChangeRequest 60397
end;</source>
    </JadeMethod>
    <JadeMethod name="setupTable" id="b3ee9be5-f17d-46e8-bc8e-5a3ec8cccc2e">
        <source>setupTable(_theEntDef : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2024	navcs2	ChangeRequest 60397: EUP | FR 54085 - Load Confirmation / Goods Receipt - Multiple Move transaction criteria, Event Only Trigger

*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
	moveCrit		: CM_CamsMoveTATypeCritieria;
	idx				: Integer;
	theDataLine		: String;
	xmlStr			: String;
begin
	theTable := self.tblMoveTas;
	theTable.allSelectedObjects.clear;
	
	if _theEntDef &lt;&gt; null then
		theTable.userInputEnabled := false;
		theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
		theTable.selectionType := CM_EntryTable.SelectionType_Row;
		theTable.rows := theTable.fixedRows;
		entTableDef := app.myController.getEntTableDef(_theEntDef);
		theTable.setTblDataEntRowsFromDef(entTableDef);
		theTable.readOnly := false;	
		theTable.fixedColumns := 0;
		theTable.fixedRows := 1;
		theTable.rows := 1;
	else
		theTable.rows := 1;	
	endif;
	
	if not self.myCamprotocol.allMoveTrxCriteria.isEmpty then
		foreach moveCrit in  self.myCamprotocol.allMoveTrxCriteria do
			if idx &gt;= JadeTableRowLimit then
				app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; 
							  JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
				break;
			endif;
			theDataLine := moveCrit.getAttributeStringForDefArray(theTable.allTblDataEntRows);
			theTable.accessRow(theTable.addItem(theDataLine)).itemObject := moveCrit;		
			idx := idx + 1;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="tblMoveTas_click" id="dd1713be-9802-42bc-a99e-88ae85a248d0">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMoveTas_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2024	navcs2	ChangeRequest 60397: EUP | FR 54085 - Load Confirmation / Goods Receipt - Multiple Move transaction criteria, Event Only Trigger

*/
constants

vars
	selectedCrit : CM_CamsMoveTATypeCritieria;
begin
	selectedCrit := self.tblMoveTas.allSelectedObjects.first.CM_CamsMoveTATypeCritieria;
	
	if selectedCrit &lt;&gt; null then
		self.myCurrentMoveCrit := selectedCrit;
		self.btnDelete.enabled := true;
		self.btnAdd.caption := self.UPDATE;
		self.setupCombos();
	else
		self.btnDelete.enabled := false;
		self.btnAdd.caption := self.ADD;
	endif;
	
	self.enableDisableExcludeTA(); // 17/05/2024 navcs2 ChangeRequest 60397
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9f5f0286-eec2-49ca-ae89-d240117f7bbc">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 22 May 2024 10:59:27.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026183, locale);
	btnAdd.translateCaption(Xlat_0026836, locale);
	btnDelete.translateCaption(Xlat_0026275, locale);
	lblExclAreaType.translateCaption(Xlat_0026184, locale);
	lblExclAreaTypeLC.translateCaption(Xlat_0026268, locale);
	lblFromAreaType.translateCaption(Xlat_0026185, locale);
	lblToAreaType.translateCaption(Xlat_0026186, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateCriteria" id="a64a803b-5779-4bc7-8ea0-cc6c0b6b768b">
        <source>validateCriteria() : Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 09 August 2023
TFS#		: 59582
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	errorMessage : String;
begin
	errorMessage  := "";
	if self.cmbFromAreaType.listIndex &lt; 1 then
		errorMessage := lblFromAreaType.caption;		
	elseif self.cmbToAreaType.listIndex &lt; 1 then
		errorMessage := lblToAreaType.caption;		
	endif;
	/*
	elseif self.cmbExclAreaType.listIndex &lt; 1 and self.myCamprotocol.isGoodsReceipt() then
		errorMessage := lblExclAreaType.caption;		
	elseif self.cmbExclAreaType.listIndex &lt; 1 and self.myCamprotocol.isLoadConfirmation() then
		errorMessage := lblExclAreaTypeLC.caption;		
	endif;	
	*/
	if errorMessage &lt;&gt; "" then
		app.msgBox(errorMessage &amp; ' is Mandatory. Please choose one from the option', 'User Error', MsgBox_OK_Only);
		return false;
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
