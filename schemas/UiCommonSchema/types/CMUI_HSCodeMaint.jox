    <JadeMethod name="tblCodesActive_rowColumnChg" id="917c6900-080d-429f-a423-efce97d6bd75">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCodesActive_rowColumnChg(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	rowIndex : Integer;
	hs : CM_HarmonizedSystem;
	
begin
	rowIndex := self.tblCodesActive.row;
	if rowIndex &gt; self.tblCodesActive.fixedRows and rowIndex &lt;= self.tblCodesActive.rows then
		hs := self.tblCodesActive.accessRow( rowIndex ).itemObject.CM_HarmonizedSystem;
		self.txtDescription.text := hs.getFullDescription();
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
