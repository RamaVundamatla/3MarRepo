<Class name="CM_YAIrregularBlock" id="db9c3576-7228-4d6e-8509-b84208e05ae6">
    <superclass name="CM_YABlock"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="uicommon"/>
    <JadeMethod name="buildLocationStatistics" id="7beb11c5-e77b-4c49-bf62-b16ef19862c9">
        <updating/>
        <source>buildLocationStatistics() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2008	conkc1	Initial creation
27 Aug 2013	NDL	Par 32308

*/

vars

	statisticsObj		: CM_LocationStatistics;
	proxyStatsObj		: CM_LocationStatistics;
	taStatsObj			: CM_LocationStatistics;
	fm					: CM_FutureMove;
	fmq					: CM_FutureMoveQueued;
	fmp					: CM_FutureMovePlanned;
	ti					: CM_TrackedItem;
	
	tmpTI				: CM_TrackedItem;
	gcQueuedOut			: Integer;
	gcPlannedOut		: Integer;
	gcQueuedIn			: Integer;
	gcPlannedIn			: Integer;
	container			: CM_Container;
	irrBlock			: CM_IrregularBlockController;
	yc					: CM_YardController;
	tmpStats			: CM_LocationStatistics;
	
begin

	if self.myLocationStatistics = null then
		create proxyStatsObj transient;
		proxyStatsObj.setParent(self);
		create statisticsObj  persistent;
		statisticsObj.setupForCreate(proxyStatsObj);
	else
		statisticsObj	:=	self.myLocationStatistics;
	endif;
	
	taStatsObj := self.myLocationStatistics;

	exclusiveLock(self.myLocationStatistics);
	self.myLocationStatistics.clearSystemCounts();  //clear values so we can start a fresh
	
	foreach yc in self.allYardControllers do
		if yc.isKindOf(CM_IrregularBlockController) then
			irrBlock := yc.CM_IrregularBlockController;
			irrBlock.buildLocationStatsTranisent(tmpStats);
			
			statisticsObj.total := statisticsObj.total + tmpStats.total;
			statisticsObj.used := statisticsObj.used + tmpStats.used;
			statisticsObj.queuedIn := statisticsObj.queuedIn + tmpStats.queuedIn;
			statisticsObj.queuedOut := statisticsObj.queuedOut + tmpStats.queuedOut;
			statisticsObj.free := statisticsObj.free + tmpStats.free;
			statisticsObj.plannedIn := statisticsObj.plannedIn + tmpStats.plannedIn;
			statisticsObj.plannedOut := statisticsObj.plannedOut + tmpStats.plannedOut;
			
			delete tmpStats;
		endif;
	endforeach;
	
	self.myLocationStatistics.setUpdateTimestamp();
	
epilog

	delete tmpStats;
	delete proxyStatsObj;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="fb441113-1485-4516-a322-ea89e660e7e5">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2020	jlgndl1	Initial creation	TFS 49775

*/

vars

	location : CM_YardController;

begin

	if not self.isTransient then
		foreach location in self.allYardControllers discreteLock do
			if location.isKindOf( CM_IrregularBlockController ) then
				location.CM_IrregularBlockController.setYAMaxCapacity(0);
			endif;
		endforeach;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getIrregularBlockController" id="23b5b97a-ff75-4f30-ba30-74b80f8b25dd">
        <source>getIrregularBlockController() : CM_IrregularBlockController;
/* ---------------------------------------------------------------------------
Created:     25 June 2008 by cnwrs2

Purpose:     PAR 17217
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpController	: CM_YardController;
begin
	tmpController := self.allYardControllers.first;
	if (not CM_IrregularBlockController.hasInstance(tmpController)) then
		// should never happen
		return null;
	endif;
	return tmpController.CM_IrregularBlockController;
	
epilog

end;</source>
        <ReturnType type="CM_IrregularBlockController"/>
    </JadeMethod>
    <JadeMethod name="getLocationsString" id="f885a1bc-911b-46d1-bfec-fe2152e62611">
        <source>getLocationsString(): String;
//----------------------------------------------------------------
//	Created:	29 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx, x1, y1, z1 : Integer;
	rack : CM_IrregularBlockController;
	obj : Object;
	objs : ObjectSet;
	allRacks : CM_IrregularBlockLCsByRegion;
begin
	create allRacks transient;
	foreach obj in self.allYardControllers discreteLock do
		rack := obj.CM_IrregularBlockController;
		
		rack.getSortKeys(x1, y1, z1);
		
		//epr par 35915 15/4/15
		allRacks.putAtKey( x1,y1,z1,rack);
	endforeach;
	
	return allRacks.getYAShelfLocationString(false); // TFS 43424 FALSE
epilog
	delete allRacks;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="b92034ff-b74f-4c40-8fe6-047fb9209505">
        <source>getName(): String;
/*
Purpose:			
Date		Who		Reason
17 September 2013	cnwab1	Initial creation
*/

vars

begin
	return self.getLocationsString();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUsageStats" id="3063d6be-7c7f-4275-94fd-7fa14df2075c">
        <source>getUsageStats(_usedMatching, _userNotMatching, _empty, _positionCount : Integer output; _cmifAutoPlan : CMIF_YAAutoPlanNormal input);
// ---------------------------------------------------------------------------
// Created:     11 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpYC				: CM_YardController;
	tmpTI				: CM_TrackedItem;

begin

	// Run through all locations for this block.
	foreach tmpYC in self.allYardControllers discreteLock do
		
		foreach tmpTI in tmpYC.allTrackedItems discreteLock  do
			_cmifAutoPlan.attachTI(tmpTI);
			if self.myYardAllocationIn.compareCriteriaToCMIF(null, _cmifAutoPlan) then
				_usedMatching := _usedMatching + 1;
			else
				_userNotMatching := _userNotMatching + 1;
			endif;
		endforeach;
		
	endforeach;
	
	_positionCount := _usedMatching + _userNotMatching;
	
	// Concept of empty does not apply to a Irregular Block - they can have unlimited items
//	_empty	:= (_positionCount - (_usedMatching + _userNotMatching).max(0));
	
end;</source>
        <Parameter name="_usedMatching" type="Integer" usage="output"/>
        <Parameter name="_userNotMatching" type="Integer" usage="output"/>
        <Parameter name="_empty" type="Integer" usage="output"/>
        <Parameter name="_positionCount" type="Integer" usage="output"/>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlanNormal" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getYAMDisplay" id="7f751940-e027-4427-ac9d-255fcf7008f7">
        <source>getYAMDisplay(pIsSortIn:Boolean): String;
// Get display suitable for YAM
vars
	tmp : String;
	pos : Integer;
begin
	tmp := self.getLocationsString();
	
	pos := tmp.pos(";",1);
	
	if pos &gt; 0 then
		tmp := tmp[1:pos-1];
	endif;

//	return inheritMethod(pIsSortIn) &amp; " " &amp; tmp;

	return tmp;
end;</source>
        <Parameter name="pIsSortIn" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialiseForDecking" id="efc76afc-7ca8-4f1f-910e-05f4d4511d2e">
        <source>initialiseForDecking(_pxyDeckingOptions: CM_YADeckingOptionsBlock input);
/* ---------------------------------------------------------------------------
Created:     25 June 2008 by cnwrs2

Purpose:     PAR-17217 - need to setup for Irregulat Block Areas
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpController		: CM_YardController;
begin

	if self.allYardControllers.isEmpty then
		return;
	endif;

	foreach tmpController in self.allYardControllers do
		tmpController.setupForDeckingInBlock(1, 1, _pxyDeckingOptions);
	endforeach;

	//do default out - reverse of in
	_pxyDeckingOptions.setOutDeckingReverseOfIn();

epilog

end;</source>
        <Parameter name="_pxyDeckingOptions" type="CM_YADeckingOptionsBlock" usage="input"/>
    </JadeMethod>
</Class>
