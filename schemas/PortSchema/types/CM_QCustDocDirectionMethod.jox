    <JadeMethod name="setComboValues" id="2b009384-c231-4644-b9e1-9ca8bd2bb377">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars

begin
	_combo.clear;
	_combo.addItem(CM_CustomDocumentType@getDirectStrFromInt(CM_CustomDocumentType.CustDocTypeDir_Inward));
	_combo.addItem(CM_CustomDocumentType@getDirectStrFromInt(CM_CustomDocumentType.CustDocTypeDir_Outward));

	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.text := CM_CustomDocumentType@getDirectStrFromInt(_queryOperator.CM_QIntegerLookupEqual.searchValue);
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := CM_CustomDocumentType@getDirectStrFromInt(_queryOperator.CM_QIntegerLookupNotEqual.searchValue);
	endif;

epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="4615f4bf-a5f8-449d-b004-e92b742932de">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QIntegerIsOneOf; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	int		: Integer;
	strObj	: CM_String;
	idx		: Integer;
	intArray: IntegerArray;
begin
	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	create intArray transient;
	
	intArray.add(CM_CustomDocumentType.CustDocTypeDir_Inward);
	intArray.add(CM_CustomDocumentType.CustDocTypeDir_Outward);
	
	foreach int in intArray do
		create strObj transient;
		strObj.string := CM_CustomDocumentType@getDirectStrFromInt(int);
		
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(int) then
			idx := _tbl.addItem(1.String &amp; Tab &amp; strObj.string);
		else
			idx := _tbl.addItem(0.String &amp; Tab &amp; strObj.string);	
		endif;
		_tbl.accessRow(idx).itemObject := strObj;
		_tbl.row := idx;
		_tbl.change(_tbl);	
		
	endforeach;
epilog
	delete intArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="81a172d2-44d0-4b2b-8d24-652405b19868">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	str		: String;
	numRows,
	idx		: Integer;
	ia		: IntegerArray;
begin
	
	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			str := _tbl.accessCell(idx, 2).text;
			ia.add(self.translateToSearchValue(str).Integer);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="6c5b0cc3-099b-4e55-888f-1fcaa8ee97ae">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars

begin
	return CM_CustomDocumentType@getDirectStrFromInt(_value.Integer);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="4d71978c-651e-48dd-884d-3d8a7a1b223a">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars

begin
	if _value.isKindOf(IntegerArray) then	
		return _value;
	elseif _value.isKindOf(Integer) then
		return _value.String;
	endif;
	
	return CM_CustomDocumentType@getDirectIntFromStr(_value.String);
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
