    <JadeMethod name="addObjectsToTable" id="2a552e11-be0d-4f6d-82d4-b60dae27dfce">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2013	cnwer1	Initial creation HAT 2189

*/

vars
	iter : Iterator;
	dutyDocItem	: CM_DutyDocItem;
	dutyDocTerminal : CM_DutyDocTerminalRoot;
	breakOut : Boolean;
begin
	
	dutyDocTerminal:=app.myDutyDocRoot.allDutyDocTerminalRoots[self.myTerminal];
	
	
	iter:=dutyDocTerminal.allDutyDocItems.createIterator;

	self.endNotificationForSubscriber(self);
	
	while iter.next(dutyDocItem) do
		
		if self.includeObject(dutyDocItem, app.myPassport) then
			self.addObjectToTable(dutyDocItem, _numItems, breakOut);
			
			if breakOut then
				break;
			endif;
		endif;
	endwhile;
	
epilog
	delete iter;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
