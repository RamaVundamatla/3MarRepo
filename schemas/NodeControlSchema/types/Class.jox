<Class name="Class">
    <JadeMethod name="isSubclassOf" id="c7faf181-a500-46e6-88ac-f1dec9722cbb">
        <source>isSubclassOf(clas:Class):Boolean;

vars
	cc:Class;
begin
	cc:=self;
	while cc.superclass &lt;&gt; null do
		if cc.superclass.name = clas.name then
			return true;
		endif;
		cc:=cc.superclass;
	endwhile;
	return false;
end;
</source>
        <Parameter name="clas" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
