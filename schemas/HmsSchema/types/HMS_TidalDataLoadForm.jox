    <JadeMethod name="translateForm" id="353b2949-f9d0-4d29-acd2-42bdb1732466">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2018 16:40:07.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022928, locale);
	btnDeleteData.translateBubbleHelp(Xlat_0005961, locale);
	btnDeleteData.translateCaption(Xlat_0005962, locale);
	btnLoadBrowse.translateCaption(Xlat_0000833, locale);
	btnLoadData.translateBubbleHelp(Xlat_0000829, locale);
	btnLoadData.translateCaption(Xlat_0000830, locale);
	lblFileName.translateCaption(Xlat_0000831, locale);
	lblFileType.translateCaption(Xlat_0000832, locale);
	lblFileType_1.translateCaption(Xlat_0005963, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="b677bea7-a8cb-4d02-8f20-e90a542e3947">
        <updating/>
        <source>updateProgress(_cmifMonitor: CMIF_Monitor input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	11 October 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pb				: ProgressBar;
begin
	//inheritMethod(_cmifMonitor);

	
	self.pbProgressBar.partsInJob := _cmifMonitor.partsInJob;	
	self.pbProgressBar.partsDone := _cmifMonitor.partsDone;
	self.lblModalInfo.caption := 'Items Loaded '&amp; '=' &amp; _cmifMonitor.partsDone.String;

	_cmifMonitor.monitorReturnValue := self.modalDialogReturnValue;	
	self.frmModalDialog.doWindowEvents(0);
	self.btnModalOpt1.doWindowEvents(0);
	self.btnModalOpt2.doWindowEvents(0);

	if self.modalDialogReturnValue = ModalDialogReturn_Option2 then
		_cmifMonitor.monitorReturnValue := CMIF_Monitor.MonitorReturnValue_Cancel;
	elseif self.modalDialogReturnValue = ModalDialogReturn_Option1 then
		_cmifMonitor.monitorReturnValue := CMIF_Monitor.MonitorReturnValue_Return;
	endif;
	
	

end;
</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
</GUIClass>
