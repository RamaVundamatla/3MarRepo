    <JadeMethod name="doClearDeckDetails" id="70ee31ca-ef26-4207-9deb-e54dfc68b2f4">
        <source>doClearDeckDetails() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars
	cntrl : Control;	
	indx : Integer;
begin
	
	
	foreach indx in 1 to self.controlCount do
		cntrl := self.controls(indx);
		if cntrl.isKindOf(CMUI_TextBox) and cntrl.parent = self.picDeckDetails then
			cntrl.CMUI_TextBox.readOnly:=false;
			cntrl.CMUI_TextBox.text:=null;	
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClearDeckGraphics" id="1cffc161-a1ef-436e-a243-b703587455f8">
        <updating/>
        <source>doClearDeckGraphics() updating;
/*
Purpose:			
Date		Who		Reason
23 May 2011	cnwab1	Initial creation
12/03/2012	cnwmh5	#29100 - Correctly clean up proxy deck stuff
*/

vars
	proxyItemLayout		: CM_DeckItemLayout;
	proxyDeck			: CM_Deck;
	invalid, isResizable : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myLayerFrame, invalid); // PAR 31671


	// PAR 27595 clear out graphic
	self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.doBtnClearClick(true);
	proxyDeck := self.myCurrentProxyDeck;								// 12/03/2012 cnwmh5 #29100 
	proxyItemLayout := self.myCurrentProxyItemLayout;					// 12/03/2012 cnwmh5 #29100 
	self.myCurrentProxyDeck := null;
	self.myCurrentProxyItemLayout := null;
	self.myCurrentProxyLayerLayout := null;
	self.drawDeckLayouts(CMUI_PointDrawingFrame.Mode_DisplayOnly, true); // PAR 27821 pass in mode PAR 28058
	if self.myLayerFrame &lt;&gt; null then
		self.myLayerFrame.unloadForm();
		self.myLayerFrame := null;
		self.myUIStylesFrame := null; // unloaded by layer frame
	endif;
	delete proxyItemLayout;												// 12/03/2012 cnwmh5 #29100
	delete proxyDeck;													// 12/03/2012 cnwmh5 #29100
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCloneBackFrame" id="acc205bd-723d-417b-a8b8-cb77d873669d">
        <updating/>
        <source>doCloneBackFrame(_layer : CM_DeckLayerLayout) updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aLayer : CM_DeckLayerLayout;
	obj : Object;
	backFrame : CMUI_PointDrawingFrame;
begin
	// if _layer.type &lt;&gt; ROROLayerType_Cargo and _layer.type &lt;&gt; ROROLayerType_Lanes and _layer.type &lt;&gt; ROROLayerType_Structure then
	if not _layer.isDefinable() then
		return;
	endif;
	
		aLayer := _layer;
		backFrame := self.frmBackground.cloneSelf(true);
		self.addControl(backFrame);		

		backFrame.name := app.getErrorString(Bckdrwfrm) &amp; aLayer.code;
		backFrame.parent := self.shtGraphics;
		backFrame.backColor := Red;
		backFrame.transparent := true;
		backFrame.visible := false;
		backFrame.autoRedraw := true;
		backFrame.parentAspect := self.frmScrollable.parentAspect;
		backFrame.scaleFactor := self.scaleFactor;
		// FOR POSITION SEE REPOSITION METHOD ON THIS FORM repositionAllBackFrames
		backFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_DisplayOnly;
		backFrame.userObject := aLayer;
		backFrame.zOrder(0);
		self.allBackgroundFrames.add(backFrame);
		
	
	
epilog

end;</source>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
    </JadeMethod>
    <JadeMethod name="doCloneBackFrames" id="6db06540-b32e-4507-98a7-2c6b38205926">
        <updating/>
        <source>doCloneBackFrames() updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aLayer : CM_DeckLayerLayout;
	obj : Object;
	backFrame : CMUI_PointDrawingFrame;
begin
	self.allBackgroundFrames.purge();

	// EDITING so have a proxy
	if self.myCurrentProxyDeck &lt;&gt; null and  self.myCurrentProxyDeck.myDeckLayout &lt;&gt; null  then
		foreach aLayer in self.myCurrentProxyDeck.myDeckLayout.allDeckLayerLayouts discreteLock do
			self.doCloneBackFrame(aLayer);
		endforeach;
	// VIEWING so no proxy
	else
		if self.myCurrentDeck &lt;&gt; null and  self.myCurrentDeck.myDeckLayout &lt;&gt; null then
			foreach aLayer in self.myCurrentDeck.myDeckLayout.allDeckLayerLayouts discreteLock do
				self.doCloneBackFrame(aLayer);
			endforeach;
		endif;
	endif;
	self.frmBackground.visible := false;
	self.repositionAllBackFrames();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCopyDeck" id="8a00d774-e7df-43fe-8bb4-aa11b7a22977">
        <updating/>
        <source>doCopyDeck() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 March 2011	cnwer1	Initial creation

*/

vars
	 copyDeck : CM_Deck;
	 parentDeck : CM_Deck;
begin

	if self.myCurrentDeck = null then
		return;
	endif;
	
	//epr par 27486 16/5/11
	if self.myCurrentDeck.isKindOf(CM_DeckVesselSub) then
		copyDeck:=self.myCurrentDeck.CM_DeckVesselSub.cloneMySelfSub(self.myCurrentDeck.CM_DeckVesselSub.myParentDeck, true, true);
	elseif self.myCurrentDeck.isKindOf(CM_DeckVoyageSub) then
		copyDeck:=self.myCurrentDeck.CM_DeckVoyageSub.cloneMySelfSub(self.myCurrentDeck.CM_DeckVoyageSub.myParentDeck, true, true);

	else
		copyDeck:=self.myCurrentDeck.cloneMySelf(self.myCurrentDeck.getROROStructure, true, true);
	endif;
	
	self.myCurrentDeck:=null;
	self.myCurrentProxyDeck:=copyDeck;
	
	
	self.doChangeMode(self.Mode_Copy);
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteDeck" id="35d87f6b-91d4-4d1d-8b19-cc84df459bba">
        <updating/>
        <source>doDeleteDeck() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 March 2011	cnwer1	Initial creation

*/

vars
	
	result : Integer;
begin

	if app.msgBox(app.getErrorString2(ConfirmDelete,app.getErrorString(Deck),self.myCurrentDeck.code.String),app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt;  MsgBox_Return_Yes then
		return;
	endif;

	while true do
	
		app.myTrxDA.trxDeleteRORODeck (self.myCurrentDeck,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Vessel) &amp; " " &amp; app.getErrorString(Deck), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
	endwhile;
epilog


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteDeckItem" id="6015ec15-975e-429b-9619-bb2487714ba2">
        <updating/>
        <source>doDeleteDeckItem() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	result : Integer;
	deckItem : CM_DeckItem;
begin

	if self.tblDeckItems.accessRow(self.tblDeckItems.row) = null then
		return;
	endif;
	deckItem:=self.tblDeckItems.accessRow(self.tblDeckItems.row).itemObject.CM_DeckItem;

	if deckItem = null then
		return;
	endif;
	
	if app.msgBox(app.getErrorString2(ConfirmDelete,app.getErrorString(Deck) &amp; " " &amp; app.getErrorString(Item),deckItem.code.String),app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt;  MsgBox_Return_Yes then
		return;
	endif;

	while true do
	
		app.myTrxDA.trxDeleteRORODeckItem(deckItem,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Vessel) &amp; " " &amp; app.getErrorString(Deck), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		
		break;
	endwhile;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDrawCentreRedLine" id="3fc2619e-588b-404a-9f0b-089ce18f5117">
        <source>doDrawCentreRedLine();
// ---------------------------------------------------------------------------
// Created:     28 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	frame : Frame;

begin


	frame := self.frmScrollable.myDrawingFrame;
	// CENTRE LINE
	frame.drawWidth := 1;
	frame.drawStyle := Frame.DrawStyle_Solid;
	frame.drawLine(0,(ROROStructureCentreLine * self.scaleFactor),self.rulerHPixels,(ROROStructureCentreLine * self.scaleFactor),Red);
	// REAR LINE
	frame.drawWidth := 1;
	frame.drawStyle := Frame.DrawStyle_Solid;
	frame.drawLine((ROROStructureRearLine * self.scaleFactor),0,(ROROStructureRearLine * self.scaleFactor), self.rulerVPixels,Red);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawChangeCrossMode" id="f0d4def3-83d8-44b1-b39b-8de7e55efbd8">
        <source>doDrawChangeCrossMode();
/*
Purpose:			
Date		Who		Reason
05 May 2011	cnwab1	Initial creation
*/

vars

	frame : Frame;
	vertical, horizontal : Decimal[6,2];
	showCross : Boolean;
	scale, pixelPerMetre, tmpX, tmpY : Real;
begin
	scale := self.scaleFactor;
	if scale = 0 then
		scale := 1;
	endif;
	
	frame := self.frmScrollable.myDrawingFrame;

		frame.clearGraphics();
		// CENTRE LINE
		self.doDrawCentreRedLine();
		frame.CMUI_PointDrawingFrame.drawAllPolygons(null);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawCurrentLayer" id="c2bde1cf-c2f4-40ed-84ad-d9ac0e678ed1">
        <updating/>
        <source>doDrawCurrentLayer() updating;
/*
Purpose:			
Date		Who		Reason
18 April 2011	cnwab1	Initial creation
*/

vars
	layerFrame : CMUI_PointDrawingFrame;
begin
	if self.myCurrentProxyLayerLayout = null then
		layerFrame := self.getFrameForLayer(self.myCurrentDeck.myDeckLayout.allDeckLayerLayouts.first);
	else
		layerFrame := self.getFrameForLayer(self.myCurrentProxyLayerLayout);
	endif;
	
		self.doDrawLayer(layerFrame);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawCurrentPoly4CurrentLayer" id="b541cff7-6c7b-4dc3-9831-fe086bf0fadb">
        <updating/>
        <source>doDrawCurrentPoly4CurrentLayer() updating; 
// ---------------------------------------------------------------------------
// Created:     April 2011 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame, layerFrame : CMUI_PointDrawingFrame;
	theGraphic : CM_DeckItemLayout;
	theSDF : CMUI_ScrollableDrawingFrame;
	area : Decimal[12,4];
		theFrameGraphic : CM_DeckItemLayout;
begin
	theSDF := self.frmScrollable;
	theFrame := theSDF.myDrawingFrame.CMUI_PointDrawingFrame;

	theGraphic := self.myCurrentProxyItemLayout;
	if theGraphic = null then
		// PAR 27595
		//if self.mode = self.Mode_View then
			theFrame.doBtnClearClick(true);
			self.doDrawCentreRedLine();
		//endif;
		return;
	endif;
	// ### REGISTER FOR NOTES
	self.beginNotification(theGraphic, EVENT_RORO_ITEM_SELECT, Response_Continuous, null);
	
//	area:=theGraphic.myPolygonPixels.calculateArea/100;
//	self.lblArea.caption:=app.getErrorString(Math_Area) &amp;  " : " &amp; area.asStringJMT();

	self.lblArea.caption:=app.getErrorString(Math_Area) &amp;  " (m2) : " &amp; theGraphic.getAreaInSquareMetres().asStringJMTWithPrecision(1, false); // PAR 30630 set to 2 decimal places
	// we make these transparent so that the other polygons for this terminal can be seen underneath
	if theFrame.mode &lt;&gt; theFrame.Mode_MultiSelect then
		theFrame.mode := CMUI_PointDrawingFrame.Mode_LineAlter;
	endif;
	theFrame.transparent := true;
	if theFrame.mode &lt;&gt; theFrame.Mode_MultiSelect then
		theFrameGraphic := theFrame.theGraphic.CM_DeckItemLayout; // PAR 28155
		theFrame.doBtnClearClick(true);
		 theFrame.theGraphic := theFrameGraphic; // PAR 28155
		 if theFrameGraphic = null then	// 28764 so that deletes from SHP_ROROVoyageDeckDefnForm work
			theFrame.theGraphic := theGraphic;
		 endif;
	endif;
	theFrame.enabled := true;
	theSDF.transparent := true;
	theFrame.doAddToArraysForProxy(theGraphic);
	
	theFrame.drawAllPolygons(White);

	// this draws all the polygons on the background frame, makes it easier to line up what you are drawing
	self.doDrawCurrentLayer();
	self.doDrawCentreRedLine();
//	layerFrame := self.getFrameForLayer(self.myCurrentProxyLayerLayout);
//	self.doDrawLayer(layerFrame);


end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawLabelH" id="04a7b81b-43e8-432c-ad2d-c91c5a223039">
        <source>doDrawLabelH();
// ---------------------------------------------------------------------------
// Created:     10 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
/*

RULER

SCALE
####

1 foot = 3 pixels
8 feet = 24 pixels
20 feet = 60 pixels
40 feet = 120 pixels

1 metre = 10 pixels
6 metre = 60 pixels (20 feet)
2.4 metre = 24 pixels (8 feet)

*/
vars
	frame : Frame;
	m, idx : Integer;
	length : Integer;
	scale : Decimal[12,4];
	x1,y1,x2,y2 : Real;

begin
	scale := self.scaleFactor;
	
	frame := self.frmScrollable.myHLabels;
	frame.clearGraphics();
	length := self.rulerHPixels;
	
	frame.backColor := White;
	frame.drawLine(0,10,length,10, Black);
	frame.drawLine(0,55,length,55, Black);
	frame.height := 70;
	frame.width := length;
	frame.drawFontSize := 8;
	
	self.frmScrollable.myDrawingFrame.top := 70;
	self.frmScrollable.myVLabels.top := 70;
	frame.drawLine(0,10,0,20 ,Black); // ZERO METRES
	frame.drawLine(0,55,0,65 ,Black); // ZERO SECTION
	
	//m := -15;
	m := ((ROROStructureRearLine/10) * -1).Integer; // -15
	
	
	foreach idx in 1 to length do
		frame.drawTextAlign := Frame.DrawTextAlign_Center;
		// 1 METRE MARK
		if idx mod 10 = 0 then
			m := m + 1;
			frame.drawWidth := 1;
			
			x1 := (idx * scale);
			y1 := 10; 
			x2 := (idx * scale);
			y2 := 20;

			frame.drawLine(x1,y1,x2,y2 ,Black);
		endif;
		// 5 METRE MARK
		if idx mod 50 = 0 then
			frame.drawWidth := 2;
			
			x1 := (idx * scale);
			y1 := 10; 
			x2 := (idx * scale);
			y2 := 25;

			frame.drawLine(x1,y1,x2,y2, Black);
			
			x1 := (idx * scale);
			y1 := 27; 
			frame.drawTextAt(m.String,x1,y1,Black);
		endif;
		// 10 METRE MARK
		if idx mod 100 = 0 then
			frame.drawWidth := 2;
			
			x1 := (idx * scale);
			y1 := 10; 
			x2 := (idx * scale);
			y2 := 25;
			frame.drawLine(x1,y1,x2,y2, Black);
		endif;
	
	endforeach;
	
	self.doDrawSections();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawLabelV" id="d096b3e5-7cf8-4c46-9c3a-bdb763e5026d">
        <source>doDrawLabelV();
// ---------------------------------------------------------------------------
// Created:     10 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
/*

RULER

SCALE
####

1 foot = 3 pixels
8 feet = 24 pixels
20 feet = 60 pixels
40 feet = 120 pixels

1 metre = 10 pixels
6 metre = 60 pixels (20 feet)
2.4 metre = 24 pixels (8 feet)

*/

vars
	frame : Frame;
	m, idx : Integer;
	scale : Decimal[12,4];
	x1,y1,x2,y2 : Real;
begin
	scale := self.scaleFactor;
	
	frame := self.frmScrollable.myVLabels;
	frame.clearGraphics();
	
	frame.backColor := White;
	frame.drawLine(10,0,10,1000, Black);
	frame.width := 50;
	frame.drawFontSize := 8;
	
	self.frmScrollable.myDrawingFrame.left := 50;
	self.frmScrollable.myHLabels.left := 50;
	frame.drawLine(10,0,20,0 ,Black);
	
	m := ((ROROStructureCentreLine/10) * -1).Integer; // -30
	
	foreach idx in 1 to self.rulerVPixels do
		if idx mod 10 = 0 then
			m := m + 1;
			frame.drawWidth := 1;
			
			x1 := 10;
			y1 := (idx * scale);
			x2 := 20;
			y2 := (idx * scale);
			
			frame.drawLine(x1,y1,x2,y2, Black);
		endif;
		if idx mod 50 = 0 then
			frame.drawWidth := 2;

			x1 := 10;
			y1 := (idx * scale);
			x2 := 25;
			y2 := (idx * scale);
			
			frame.drawLine(x1,y1,x2,y2, Black);

			x1 := 27;
			y1 := ((idx-6) * scale);
			frame.drawTextAt(m.String,x1,y1,Black);
		endif;
		if idx mod 100 = 0 then
			frame.drawWidth := 2;

			x1 := 10;
			y1 := (idx * scale);
			x2 := 25;
			y2 := (idx * scale);
			frame.drawLine(x1,y1,x2,y2, Black);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawLayer" id="ff20886a-3969-481b-a215-bdc8dfd68004">
        <updating/>
        <source>doDrawLayer(_frame : CMUI_PointDrawingFrame) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		This draws all the polygons fro this terminal on a background frame, that the user cannot alter
// ---------------------------------------------------------------------------
vars

//	theRORODefn : CM_ROROStructure;
	deckItemLayout, theGraphicBeingDrawn : CM_DeckItemLayout;
	aGraphic : CM_Graphic;
	theFrame : CMUI_PointDrawingFrame;
	theColour : Integer;
	graphArray : CM_GraphicArray;
	theDeck : CM_DeckLayout;
	theLayer : CM_DeckLayerLayout;
	drawRemarks : Boolean;
begin
	if _frame = null then
		return;
	endif;
	
	theFrame := _frame; 
	drawRemarks := self.btnDrawRemarks.value.Boolean;
	
//	theGraphicBeingDrawn := self.myCurrentProxyItemLayout; 	
	theFrame.doBtnClearClick(true);
	
	theLayer := _frame.userObject.CM_DeckLayerLayout;
	if theLayer = null then
		app.msgBox(app.getErrorString(Choose_layer),app.getErrorString(Layer_problem), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	// ### REGISTER FOR NOTES
	self.beginNotification(theLayer, EVENT_RORO_LAYER_SELECT, Response_Continuous, null);
	self.beginNotification(theLayer, EVENT_RORO_LAYER_VISIBLE, Response_Continuous, null);
	self.beginNotification(theLayer, EVENT_RORO_LAYER_UPDATE, Response_Continuous, null);
	
	foreach deckItemLayout in theLayer.allDeckItemLayouts do
		// ### REGISTER FOR NOTES
		self.beginNotification(deckItemLayout, EVENT_RORO_ITEM_SELECT, Response_Continuous, null);
		self.beginNotification(deckItemLayout, EVENT_RORO_ITEM_VISIBLE, Response_Continuous, null);
		self.beginNotification(deckItemLayout, EVENT_RORO_ITEM_UPDATE, Response_Continuous, null);
		
	endforeach;
	
	theFrame.doDrawLayerLayout(theLayer, null, self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame);
	self.allPictures.purge();
	
	if drawRemarks then
		foreach deckItemLayout in theLayer.allDeckItemLayouts do
			self.doDrawRemarks(theFrame, deckItemLayout);
		endforeach;
	endif;

	theFrame.enabled := false;
	theFrame.visible := theLayer.isVisible;

end;</source>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="doDrawLayers" id="f6b57475-e91f-4152-9ff0-008e3d51827b">
        <updating/>
        <source>doDrawLayers() updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	obj : Object;
	layerFrame : CMUI_PointDrawingFrame;
begin
	
	foreach obj in self.allBackgroundFrames reversed, discreteLock do
		layerFrame := obj.CMUI_PointDrawingFrame;
		
		self.doDrawLayer(layerFrame);
		layerFrame.zOrder(1);

	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawRemarks" id="b8c23bf3-4b30-452b-91da-5de1d736f85c">
        <updating/>
        <source>doDrawRemarks(_frame : CMUI_PointDrawingFrame; _graphic : CM_DeckItemLayout) updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aPoint : Point;
	tmpPict : Picture;
	rem : String;
begin
//	rem := _graphic.getRemark();// PAR 27595
	//17 Apr 2012	NDL	Par 29444
	if _graphic.myDeckItem &lt;&gt; null
	and  _graphic.myDeckItem.remarks &lt;&gt; null then
		rem := _graphic.myDeckItem.remarks;
	endif; 
	if rem = null then
		return;
	endif;
	
//	aPoint := _graphic.getExtremePoint(CM_Graphic.Position_Right);
	aPoint := _graphic.getExtremePoint(CM_Graphic.Position_Left);	//17 Apr 2012	NDL	Par 29444
	if aPoint = null then
		return;
	endif;
	
	tmpPict := self.picRemarks.cloneSelf(true);
	self.addControl(tmpPict);
	self.allPictures.add(tmpPict);
	tmpPict.parent := self.frmScrollable.myDrawingFrame;
	tmpPict.bubbleHelp := _graphic.code &amp; " - " &amp; rem;// PAR 27595
	//tmpPict.userObject := _graphic;
	tmpPict.userObject := _graphic.myDeckItem;	//17 Apr 2012	NDL	Par 29444
	tmpPict.left := (aPoint.x * self.scaleFactor) + 5;
	tmpPict.top := (aPoint.y * self.scaleFactor);
	tmpPict.visible := true;
	tmpPict.zOrder(1);
	
epilog

end;</source>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame"/>
        <Parameter name="_graphic" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="doDrawSection" id="46f21dae-b03f-4c62-b57f-57bcf9092aac">
        <source>doDrawSection(_frame : Frame input; _section : CM_VesselSection) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	xSect : Decimal[12,4];
	x1,y1,x2,y2 : Real;
begin
	_frame.drawTextAlign := Frame.DrawTextAlign_Left;
	_frame.drawWidth := 2;
	
	xSect := (_section.position * ROROStructurePixelsPerMetre) + ROROStructureRearLine;
	
	x1 := (xSect * self.scaleFactor);
	y1 := 55; 
	x2 := (xSect * self.scaleFactor);
	y2 := 65; 
	_frame.drawLine(x1,y1,x2,y2 ,Black);
	
	x1 := ((xSect+5) * self.scaleFactor);
	y1 := 55; 
	_frame.drawTextAt(_section.code,x1,y1,Black);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_section" type="CM_VesselSection"/>
    </JadeMethod>
