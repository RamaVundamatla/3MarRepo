    <JadeMethod name="getDisplayStringForAttribute" id="c37c93e0-d608-487d-96ee-c8fdc1264fc1">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64732 - 25th June 2024

*/

vars

begin
	if _attrName = ETRow_RequestType or _attrName = ETRow_BgpRequestType then
		return self.getRequestType();
	elseif _attrName = ETRow_BgpActionFutureDate then
		return self.getActionFutureDate().asStringJMT();
	elseif _attrName = ETRow_BgpTerminal or _attrName = ETRow_TerminalCode then
		return self.getTerminalCode();
	elseif _attrName = ETRow_BgpCargoID then
		return self.getCargoId();
	elseif _attrName = ETRow_BgpAutoCargoType then
		return self.getCargoTypeId().String;
	elseif _attrName = ETRow_BgpAutoProduct then
		return self.getCargoSubTypeId();
	elseif _attrName = ETRow_BgpAutoLocation then
		return self.getLocationString();
	elseif _attrName = ETRow_BgpCargoQty then
		return self.getCargoQty();
	elseif _attrName = ETRow_BgpAnniversaryDate then
		return self.getAnniversaryDate().asStringJMT();
	elseif _attrName = ETRow_BgpRequestDetail then
		return self.getRequestDetail();
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
