    <JadeMethod name="myTerminal" id="7a546418-b4d5-441f-927b-2c9787138f15">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
//--------------------------------------------------
// Created:	27 March 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(set, _value);
	
	if set then
		return;
	endif;
	
	if _value = null then
		if self.vehicle &lt;&gt; null then
			_value := self.vehicle.myTerminal;
