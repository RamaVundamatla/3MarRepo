    <JadeMethod name="cmbVoyageInvProp_click" id="c8912316-7890-44e8-9416-07b1e45b444d">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyageInvProp_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	thevoyage : CM_Voyage;
	theTable : CM_EntryTable;
begin
	theTable := self.tblInvProperties;

	theTable.setValueByControlName(combobox.name, combobox.text);

	thevoyage := combobox.listObject.CM_Voyage;
	if thevoyage &lt;&gt; null then
		if thevoyage.arrivedDT &lt;&gt; null then
			theTable.setValueByName(ETRow_ArrivalTS,self.systemToLocalTime(thevoyage.arrivedDT).String);// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			theTable.setValueByName(ETRow_ArrivalTS,"Not Set Yet");
		endif;
		if thevoyage.departedDT &lt;&gt; null then
			theTable.setValueByName(ETRow_DepartureTS,self.systemToLocalTime(thevoyage.departedDT).String);// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			theTable.setValueByName(ETRow_DepartureTS,"Not Set Yet");
		endif;
		theTable.setValueByName(ETRow_VoyageDesc,thevoyage.getDisplayDetails(false));
	endif;

end;</source>
