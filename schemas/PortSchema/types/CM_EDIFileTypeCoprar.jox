<Class name="CM_EDIFileTypeCoprar" id="f8df7c3c-a8ea-410d-be6b-8bc9f481dafb">
    <superclass name="CM_EDIFileTypeUNEDIFACT"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="cb7cbb17-39f6-48d9-9a88-b8303ea573f6">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.name	:= "COPRAR - Container discharge/loading order";
	self.type	:= EDIFileType_Coprar;
end;</source>
    </JadeMethod>
    <JadeMethod name="createEDIData" id="00951132-48e5-4c0b-bcba-9543304af55c">
        <source>createEDIData(_transient: Boolean): CM_EDIDataLoadList;
//----------------------------------------------------------------
//	Created:	cnwrs1 June 2009
//----------------------------------------------------------------
vars
	loadList : CM_EDIDataLoadList;
begin
	if _transient then
		create loadList transient;
	else
		create loadList persistent;
	endif;
	return loadList;
end;
</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="CM_EDIDataLoadList"/>
    </JadeMethod>
    <JadeMethod name="extractFile" id="8b44d064-fa80-493f-acfe-1a7b7b3a28de">
        <updating/>
        <source>extractFile(_ediFile: CM_EDIFile input; _number: Integer; _recipient: CM_Operator) updating;
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
vars
	ediDataLoadList	: CM_EDIDataLoadList;
	ediTI			: CM_EDITrackedItem;
	file			: File;
	operatorOid		: CM_Operator;
	voyageOid		: CM_Voyage;
	now				: TimeStamp;
	ediFile			: CM_EDIFile;
	ediData			: CM_EDIData;
	terminal		: CM_Terminal;
	typeCode 		: String;
	foundMatch		: Boolean;
	str : String;
begin
	ediFile 	:= _ediFile;
	ediData		:= ediFile.ediData;
	terminal	:= app.myPassport.myTerminal;
	
	if (not CM_EDIDataLoadList.hasInstance(ediData)) then
		app.raiseCMException2(ERR_INVALID_EDI_FORMAT, self.name, ediData.class.name, null, null);
		return;
	endif;

	ediDataLoadList := ediData.CM_EDIDataLoadList;

	typeCode := "45";
	if ediDataLoadList.listType = 'D' then
		typeCode := "43";
	endif;

	if _recipient = null then
		operatorOid := app.myRoot.allOperators[ediDataLoadList.operatorCode];
	else
		operatorOid := _recipient;
	endif;
	
	voyageOid := terminal.lookupVoyage(ediDataLoadList.voyageCode, null, false);
//	longString.string := "UNB+UNOA:2+" &amp; operatorOid.getSystemXlationCode(ediDataLoadList.fromPort,XLATION_TYPE_PORT_BYOP).trimBlanks.toUpper &amp; "+" &amp; ediDataLoadList.operatorCode.trimBlanks &amp; "+" &amp; now.date.shortYearCams() &amp; ":" &amp; now.time.format("HHmm") &amp; "+" &amp; number.String &amp; "+++++" &amp; ediDataLoadList.operatorCode.trimBlanks.toUpper &amp; "'";
//  to comply with v6 behaviour - no xlation on our port
	str := str &amp; "UNB+UNOA:2+" &amp; "+" &amp; "+" &amp; now.date.shortYearEDI() &amp; ":" &amp; now.time.format("HHmm") &amp; "+" &amp; _number.String &amp; "+++++" &amp;  "'" &amp; CrLf;
	str := str &amp; "UNH+" &amp; voyageOid.getEDIMessageCode() &amp; "+COPRAR:D:95B:UN:SMDG20'" &amp; CrLf;
	str := str &amp; "BGM+"&amp;typeCode&amp;"+" &amp; _number.String &amp; "+9'" &amp; CrLf;
	str := str &amp; "DTM+137:" &amp; now.date.shortYearEDI() &amp; now.time.shortFormatEDI() &amp; ":201'" &amp; CrLf;
	str := str &amp; "TDT+20+" &amp; operatorOid.getXlationForeignCode(ediDataLoadList.voyageCode, XLATION_TYPE_VOYAGETERMINAL, foundMatch).trimBlanks.toUpper &amp; "+++"  &amp; ":172:20+++" &amp; voyageOid.callSign.trimRight &amp; ":103:11:" &amp; ediDataLoadList.vesselName.trimBlanks.toUpper &amp; "'" &amp; CrLf;
	str := str &amp; "LOC+9+" &amp; operatorOid.getXlationForeignCode(ediDataLoadList.ediConfig.myTerminal.getConfig(PortDestCode).String, XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
//	str := str &amp; "LOC+61+" &amp; operatorOid.getXlationForeignCode(ediDataLoadList.toPort,XLATION_TYPE_PORT_BYOP).trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
//	str := str &amp; "DTM+132:" &amp; ediDataLoadList.arriveTime.date.shortYearEDI() &amp; ediDataLoadList.arriveTime.time.shortFormatEDI() &amp; ":201'" &amp; CrLf;
	if voyageOid.arrivedDT &lt;&gt; null then
		str := str &amp; "DTM+132:" &amp; voyageOid.arrivedDT.date.shortYearEDI() &amp; voyageOid.arrivedDT.time.shortFormatEDI() &amp; ":201'" &amp; CrLf;
	endif;
	if voyageOid.departTargetDT &lt;&gt; null then
		str := str &amp; "DTM+133:" &amp; voyageOid.departTargetDT.date.shortYearEDI() &amp; voyageOid.departTargetDT.time.shortFormatEDI() &amp; ":201'" &amp; CrLf;
	endif;
	str := str &amp; "NAD+CF+" &amp; self.myRoot.getXlationForeignOperatorCode(operatorOid, operatorOid.code, foundMatch).trimBlanks.toUpper &amp; ":172:20'" &amp; CrLf;   // cnwrd1 par 19675 14.5.09

	foreach ediTI in ediDataLoadList.allEDITrackedItems do
		str := str &amp; self.extractTI(ediTI.CM_EDILoadListTI, 0, operatorOid);
	endforeach;

	str := str &amp; "UNT+" &amp; (str.countOccurrences("'")).String &amp; "+" &amp; voyageOid.getEDIMessageCode &amp;"'" &amp; CrLf;
	str := str &amp; "UNZ+1+" &amp; _number.String &amp; "'" &amp; CrLf;
	ediFile.setRawDataString(str);
	ediFile.writeFile();
epilog
//	delete tisByLocation;
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_recipient" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="extractTI" id="ef7ee478-0141-49cb-8154-176d7de157c5">
        <updating/>
        <source>extractTI(_ediTI : CM_EDITrackedItem input; _number : Integer; _operator : CM_Operator) : String updating, protected;
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//09 Jul 2018   cnwma1	Bug 39347: SNO - Error in BAPLIE when reporting reefer temepratures
vars
	rem,fullCode,imCode,port,imEx: String;
	int			: Integer;
	foundMatch	: Boolean;
	ediTI : CM_EDILoadListTI;
	str : String;
begin
	ediTI := _ediTI.CM_EDILoadListTI;
	if ediTI.cargoType = TI_CargoType_Container then
		str := str &amp; "EQD+CN+" &amp; ediTI.id.trimBlanks.toUpper &amp; "+" &amp; ediTI.isoType &amp; "++" &amp; imEx &amp; "+" &amp; fullCode &amp; "'" &amp; CrLf;
	else //handle as  BBLK
		str := str &amp; "EQD+BB+" &amp; ediTI.id.trimBlanks.toUpper &amp; "+" &amp; ediTI.isoType &amp; "+++'" &amp; CrLf;//par 5159 
	endif;
	if ediTI.bookingRef &lt;&gt; null then	
		str := str &amp; "RFF+BN:" &amp; ediTI.bookingRef.trimBlanks.toUpper &amp; "'" &amp; CrLf;
//		str := str &amp; "RFF+AAY:" &amp; ediTI.bookingRef.trimBlanks &amp; "'");
	endif;
	if ediTI.dischargePort &lt;&gt; null then
		if _operator = null then
			str := str &amp; "LOC+11+" &amp; ediTI.dischargePort.trimBlanks.toUpper &amp; "'" &amp; CrLf;//":139:6'"
		else
			str := str &amp; "LOC+11+" &amp; _operator.getXlationForeignCode(ediTI.dischargePort,XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;//":139:6'"
		endif;
	endif;
	if ediTI.destinationPort&lt;&gt; null then
		if _operator = null then
			str := str &amp; "LOC+7+" &amp; ediTI.destinationPort.trimBlanks.toUpper &amp; "'" &amp; CrLf;//":139:6'"
		else
			str := str &amp; "LOC+7+" &amp; _operator.getXlationForeignCode(ediTI.destinationPort,XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;//":139:6'"
		endif;
	endif;
	str := str &amp; "MEA+WT++KGM:" &amp; ediTI.weight.asStringWeightJMT() &amp; "'" &amp; CrLf;

	// par 12051 MEA is compulary
	if ediTI.cargoType &lt;&gt; TI_CargoType_Container then	//process as gross dimensions
		str := str &amp; "DIM+1+CMT:" &amp; ediTI.length.asStringMeasurementJMT() &amp; ":" &amp; ediTI.width.asStringMeasurementJMT() &amp; ":" &amp; ediTI.height.asStringMeasurementJMT() &amp; "'" &amp; CrLf; 
	else			//process as overdimensions
		if ediTI.length &lt;&gt; 0 then
			str := str &amp; "DIM+9+CMT:" &amp; ediTI.length.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
		endif;
		if ediTI.width &lt;&gt; 0 then
			str := str &amp; "DIM+9+CMT::" &amp; ediTI.width.asStringMeasurementJMT() &amp; "'" &amp; CrLf; //cnwrd1 ccms 1060 fix
		endif;
		if ediTI.height &lt;&gt; 0 then
			str := str &amp; "DIM+9+CMT:::" &amp; ediTI.height.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
		endif;
	endif;

	if ediTI.temperature &lt;&gt; NULL_TEMPERATURE then
		if _operator &lt;&gt; null and //par16227 cnwrs1 mar 2008
		   _operator.getConfig(EDITempFormat).Boolean then
			if ediTI.temperature &lt; 0 then
				str := str &amp; "TMP+2+-" &amp; ediTI.temperature.Integer.positive.stringWithLeadingZeros(3) &amp; ":CEL'" &amp; CrLf;
			else
				str := str &amp; "TMP+2+" &amp; ediTI.temperature.Integer.positive.stringWithLeadingZeros(3) &amp; ":CEL'" &amp; CrLf;
			endif;
		else
			//str := str &amp; "TMP+2+" &amp; ediTI.temperature.asStringJMTWithPrecision($CM_CamEDIFACTTemp.decimalPlaces, false) &amp; ":CEL'" &amp; CrLf; //09.07.2018 cnwma1 TFS#39347
			str := str &amp; "TMP+2+" &amp; ediTI.temperature.asStringEDIWithPrecision($CM_CamEDIFACTTemp.decimalPlaces) &amp; ":CEL'" &amp; CrLf;   //09.07.2018 cnwma1 TFS#39347
		endif;
	endif;
	if ediTI.commodity.trimBlanks &lt;&gt; null then
		if _operator = null then
			str := str &amp; "FTX+AAA+++" &amp; ediTI.commodity.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		else
			str := str &amp; "FTX+AAA+++" &amp; _operator.getXlationForeignCode(ediTI.commodity,XLATION_TYPE_COMMODITY_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;
		endif;
	endif;
	if ediTI.consignee &lt;&gt; null then		//ccms 1915 - PAR 22271
		if _operator = null then
			str := str &amp; "NAD+CN+++" &amp; ediTI.consignee.trimBlanks.toUpper &amp; "'" &amp; CrLf;//":139:6'"
		else
			str := str &amp; "NAD+CN+++" &amp; _operator.getXlationForeignCode(ediTI.consignee,XLATION_TYPE_CONSIGNEE_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;//":139:6'"
		endif;
	endif;
	if ediTI.imCodes.size &gt; 0 then
		foreach imCode in ediTI.imCodes do
			str := str &amp; "DGS+IMD+" &amp; imCode.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		endforeach;
	endif;
	if ediTI.getTranshipVoyageCode &lt;&gt; null then
		if _operator = null then
			str := str &amp; "TDT+30+" &amp; ediTI.getTranshipVoyageCode.trimBlanks.toUpper &amp; "+++"  &amp; ":172:20+++" &amp;  ":103:11:" &amp;  "'" &amp; CrLf;
		else
			str := str &amp; "TDT+30+" &amp; _operator.getXlationForeignCode(ediTI.getTranshipVoyageCode, XLATION_TYPE_VOYAGETERMINAL, foundMatch).trimBlanks.toUpper &amp; "+++"  &amp; ":172:20+++" &amp;  ":103:11:" &amp;  "'" &amp; CrLf;
		endif;
		if ediTI.getTranshipDischargePort &lt;&gt; null then
			if _operator = null then
				str := str &amp; "LOC+11+" &amp; ediTI.getTranshipDischargePort.code.toUpper &amp; "'" &amp; CrLf;//":139:6'"
			else
				str := str &amp; "LOC+11+" &amp; _operator.getXlationForeignCode(ediTI.getTranshipDischargePort.code, XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;//":139:6'"
			endif;
		endif;
		if ediTI.transhipPortCodes.size &gt; 0 then
			foreach port in ediTI.transhipPortCodes do
				if _operator = null then
					str := str &amp; "LOC+64+" &amp; port.toUpper &amp; "'" &amp; CrLf;//":139:6'"
				else
					str := str &amp; "LOC+64+" &amp; _operator.getXlationForeignCode(port, XLATION_TYPE_PORT_BYOP, foundMatch).trimBlanks.toUpper &amp; "'" &amp; CrLf;//":139:6'"
				endif;
			endforeach;
		endif;
		if ediTI.transhipBookingRef &lt;&gt; null then	
			str := str &amp; "RFF+BN:" &amp; ediTI.transhipBookingRef.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		endif;
		if ediTI.transhipBOLId &lt;&gt; null then	
			str := str &amp; "RFF+BM:" &amp; ediTI.transhipBOLId.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		endif;
	endif;
	return str;
end;</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="9c8b4d21-d9aa-4806-bb24-067e44ed12a3">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//	Created:	11 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	_ediDataClass := CM_EDIDataLoadList;
	_dataType := EDIDataType_LoadList;
	_fileTypeCode := self.type;
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getEDIPartyRules" id="a4b3553a-ef5c-486a-a04f-9b061465cd6c">
        <source>getEDIPartyRules(_ediParty: CM_EDIParty): CM_EDIPartyRules protected;
//
// 30 Aug 2017	jlgrs1	TFS 6797 SNO SpecialStow
//
vars

begin
	if _ediParty = null then
		return null;
	endif;

	return _ediParty.getRulesForFileType(EDIFileType_Coprar);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediParty" type="CM_EDIParty"/>
        <ReturnType type="CM_EDIPartyRules"/>
    </JadeMethod>
    <JadeMethod name="getFTXData" id="be8d60f9-965d-496b-8bb8-babc6bdbb403">
        <source>getFTXData(_msgHelper: CMIF_EDIFACTHelper io; _ediPartyRules :CM_EDIPartyRules; _params : CMIF_EDIFACTParams io);
//
// 30 Aug 2017	jlgrs1	TFS 6797 SNO SpecialStow
//
vars
	dtCode : String;
	rule : CM_EDIEDIFactRule;
	ruleFunction : Integer;
	segmentValue : String;
	ftxArray : StringArray512;
	specialStow : String;
	params : CMIF_EDIFACTParams;
	foundMatch : Boolean;
	temperature : Real;
begin
	if _ediPartyRules &lt;&gt; null and 
	   not _ediPartyRules.allEDIPartyRules.isEmpty then																																	//+TFS3602 For Any Free Text Translation
		rule := _ediPartyRules.allEDIPartyRules.getEDIEDIFactRule(CM_EDIEDIFactRule.Item_FTX_3_1);
		if rule &lt;&gt; null then
			dtCode := _msgHelper.currentMessage;
			if  dtCode[1:4].cnContains("FTX+") then                                                                		
				dtCode := dtCode[5 : end];
				create ftxArray transient;
				dtCode.getTokensForDelimiter ("+'", ftxArray);
				if ftxArray[1] = rule.value then
					ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_FTX_3_1, rule.value, segmentValue);
					if ruleFunction = CM_EDIEDIFactRule.Function_FTX_3_1_Stowage then
						specialStow := rule.getFTXSpecialStowage(ftxArray);
						if specialStow &lt;&gt; null then
							_params.specialStowage := specialStow;
						endif;
					endif;
				endif;
				delete ftxArray;
			endif;
		endif;
	endif;
epilog
	delete ftxArray;
end;</source>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyRules"/>
        <Parameter name="_params" type="CMIF_EDIFACTParams" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="5d1aca56-0904-442f-9fb3-efed3c4289e5">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) protected, updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
02 Feb 2012	cnwrs1	Par 29076 	Fix up Hazard Processing in EDI
15 aug 2012 cnwrs1 	par 30203 	failing to load with muliple UNH/UNTs
20 Oct 2012 cnwcs5	par 30361 	condition was around wrong way
07 Mar 2013	cnwcs5	CCMS POL 2097 
					/ par 31259 commodity xlations
16 Sep 2013 cnwah9 				removed error messages and unnecessary code
03 Dec 2013 cnwah9 				fixing failed unit tests.
12 Jan 2015	cnwrs1	Par 35504 	Refactor EDI file load for .NET
10 Sep 2015	cnwrs1	Par 32883 	EDI File Type sequence number
08 Oct 2015	cnwrs1	Par 36863 	make EDI consistant times when refreshing progress bar
29/04/2016	cnwdap1	TFS #1699 	VGM changes
13 May 2016	cnwns1	TFS 488 	Multi Timezone Support
04 Aug 2016	cnwrs1	Par 38117 	make deleted EDI for finable
04 Aug 2016 cnwma1 	TFS #2492 
					PAR #38116 	PNL - Haz field not matching when the same
18 Aug 2016	cnwrs1	TFS 2552 	Group 6 RFF+BM should update BOL not TranshipBOL
27 Jun 2017	cnwdap1	TFS 4492 	SNO VERMAS Changes
27 Jun 2017	cnwrs1	TFS 4462 	SNO add Terminal Operator, Unknown Seal and support multiple seals
18 Aug 2017 jlggb1  TFS 6565 	SNO COPRAR to handle EGW as gross weight
24 Aug 2017	jlgdap1	TFS 6691	1090 when COM segment encountered before EQD segment
30 Aug 2017	jlgrs1	TFS 6797 	SNO SpecialStow
08 May 2018	jlgrs1	TFS 36425 	SingleLine Booking partial processing not working
08 Jun 2018	jlgrs1	TFS 39018 	SNO Cargo Operator in COPRAR
20 Jul 2018	jlgrs1	TFS 39859 	WEL Coprar file not loading
25 Jul 2018	jlgrs1	TFS 37973	SNO Cargo Operator not working correctly from TFS 39018
30 Jul 2018	jlgrs1	TFS 39918 	SNO Voyage not always translating
05 Dec 2018	jlgrh7 	TFS 41900 	SNO - COPRAR fail due to wrong voyage ID
18 Jan 2019	jlgrs1	TFS 41659 
						42276 	STWR Make EDI MultiThreaded Stage 8
07 Apr 2019	jlgrs1	TFS 41913 	STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
10 Apr 2025	navdap1	MTN-14781 CPL | Increase BOL Field Length
01 Aug 2025 navsp1  JIRA-35530 Solution Implementation - COPRAR Trailer Support
============================================================================*/
constants
	ProgressBarRefresh : Integer = 2000;	
vars
	ediTI : CM_EDILoadListTI;
	ediData : CM_EDIDataLoadList;
	lineStr : String;
	message : String;
	int : Integer;
	aLength : Integer;
	aWidth : Integer;
	aHeight : Integer;
	generatedediTINo : Integer;
	voyageCode : String;
	loadPort : String;
	dischargePort : String;
	group : Integer;
	code : String;
	ediTIId : String;
	isotype : String;
	haz : String;
	undg : String;
	msgCount : Integer;
	numMsgs : Integer;
	passport : CM_Passport;
	msgHelper : CMIF_EDIFACTHelper;
	strTmp : String;
	operatorVoyageCode : String;
	xlationOperator : CM_Operator;
	operatorVoyage : CM_Operator;			// cnwrl1 21/07/2010 PAR 25093
	transhipOperatorVoyage : CM_Operator;			// cnwrl1 21/07/2010 PAR 25093
	debug : Boolean;
	dischargeList : Boolean;
	loadList : Boolean;
	vesselName : String;
	lloydsNumber : String;
	callSign : String;
	transhipVoyageCode : String;
	transhipVesselName : String;
	transhipLloydsNumber : String;
	transhipCallSign : String;
	transhipOperatorVoyageCode	: String;
	tdtType : String;
    tempConsignee : String;
    subTag : String;
	untCount : Integer;	//15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
	foundMatch	: Boolean;
	theLines : HugeStringArray;
	rawSenderCode : String;
	creationTS : TimeStamp;
	sequence : String;
	fileType : String;
	version : String;
	recipientCode : String;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
	dateTimeStr : String;						// TFS 4492
	vgmDT : TimeStamp;							// TFS 4492
	commsType : String;							// TFS 4492
	sealNumber : String;
	sealType : String;
	commsDetail : String;									// TFS 6691
	mobile, ediTrans, email, fax, mail, phone : String;		// TFS 6691
	docsIssued, determined : TimeStamp;						// TFS 6691
	ediPartyRules : CM_EDIPartyRules;
	params : CMIF_EDIFACTParams;
	senderParty	: CM_EDIParty;
	ruleFunction : Integer; 	
	nad1_1Code : String;
	nad1_1Function : String;
	nad2_1Function : String;
	nad3_1Function : String;
	nad1_LL : Boolean;
	cargoOperatorCode : String;
	segmentValue : String;
    terminal        : CM_Terminal;  //JIRA-35530
    isTrailerType   : Boolean;      //JIRA-35530
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport := app.myPassport;
    terminal    := passport.myTerminal;         //JIRA-35530
	ediData := _ediFile.ediData.CM_EDIDataLoadList;
	debug := false;
	
	create msgHelper transient;
	msgHelper.setEDIFile(_ediFile);
    params := msgHelper.myCurrentParams;

	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach lineStr in theLines do
		msgCount	:= msgCount + 1;
		untCount 	:= untCount + 1;	//15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs

		
		commsType := null;							// TFS 6691
		commsDetail := null;						// TFS 6691
		mobile := null;								// TFS 6691
		ediTrans := null;							// TFS 6691
		email := null;								// TFS 6691
		fax := null;								// TFS 6691	
		mail := null;								// TFS 6691
		phone := null;								// TFS 6691
		docsIssued := null;							// TFS 6691
		determined := null;							// TFS 6691
		
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		msgHelper.setNextMessage(lineStr);	//set the current message
		
		//get current
		message := msgHelper.currentMessage;
		
//BGM
		if msgHelper.currentTag = "BGM" then//
			if group = 0 then
				msgHelper.setNextField();
				if msgHelper.currentSubItem = "43" then
					dischargeList := true;
					ediData.setListType("D");
				elseif msgHelper.currentSubItem = "45" then
					loadList := true;
					ediData.setListType("L");
				endif;
			endif;
//CNT
		elseif msgHelper.currentTag = "CNT" then
			group := 0;
//COM
		elseif msgHelper.currentTag = "COM" then							// TFS 4492
			msgHelper.setNextField();										// TFS 4492
			commsType := msgHelper.currentSubItem;							// TFS 4492
			msgHelper.setNextSubItem();										// TFS 4492
			if ediTI = null then									// TFS 6691
				commsType := msgHelper.currentSubItem;				// TFS 6691
				if commsType.isOneOf("AL", "AM") then				// TFS 6691
					mobile := commsDetail;							// TFS 6691
				elseif msgHelper.currentSubItem = "EI" then			// TFS 6691
					ediTrans := commsDetail;						// TFS 6691
				elseif msgHelper.currentSubItem = "EM" then			// TFS 6691
					email := commsDetail;							// TFS 6691
				elseif msgHelper.currentSubItem = "FX" then			// TFS 6691
					fax := commsDetail;								// TFS 6691
				elseif msgHelper.currentSubItem = "MA" then			// TFS 6691
					mail := commsDetail;							// TFS 6691
				elseif msgHelper.currentSubItem = "TE" then			// TFS 6691
					phone := commsDetail;							// TFS 6691
				endif;												// TFS 6691
			else															// TFS 4492
				ediTI.vgmCommsType := msgHelper.currentSubItem;				// TFS 4492
				if msgHelper.currentSubItem.isOneOf("AL", "AM") then		// TFS 4492
					ediTI.vgmPhone := commsType;							// TFS 4492
				elseif msgHelper.currentSubItem = "EI" then					// TFS 4492
					ediTI.vgmEDITransmission := commsType;					// TFS 4492
				elseif msgHelper.currentSubItem = "EM" then					// TFS 4492
					ediTI.vgmElectronicMail := commsType;					// TFS 4492
				elseif msgHelper.currentSubItem = "FX" then					// TFS 4492
					ediTI.vgmTelefax := commsType;							// TFS 4492
				elseif msgHelper.currentSubItem = "MA" then					// TFS 4492
					ediTI.vgmMail := commsType;								// TFS 4492
				elseif msgHelper.currentSubItem = "TE" then					// TFS 4492
					ediTI.vgmTelephone := commsType;						// TFS 4492
				endif;														// TFS 4492
			endif;													// TFS 6691
//CTA
		elseif msgHelper.currentTag = "CTA" then//
			if group = 3 or
			   group = 4 then
				group := 5;
			elseif group = 6 or
			   group = 7 then
				group := 8;
			endif;
			msgHelper.setNextField();															// TFS 4492
			if msgHelper.currentField = "RP" then												// TFS 4492
				// signature of VGM authorised person											// TFS 4492
				ediTI.vgmAuthSignature := msgHelper.currentSubItem;								// TFS 4492
			elseif msgHelper.currentField = "BN" then											// TFS 4492
				// details on subsequent COM segment											// TFS 4492
			endif;																				// TFS 4492
//DGS 
		elseif msgHelper.currentTag = "DGS" then//
		//03 Dec 2013 cnwah9
			if group = 6 or	//par16796 cnwrs1 june 2008
			   group = 7 then  //par 26798 cnwrs1 24 Jan 2011
				group := 7; 
				msgHelper.setNextField();
				if msgHelper.currentField = "IMD" then
					msgHelper.setNextField();
					haz := msgHelper.currentSubItem;
					msgHelper.setNextField();
					undg := msgHelper.currentSubItem;	//par26798 cnwrs1 25 Jan 2011
					ediTI.imCodes.add(haz &amp; ":+" &amp; undg);
					ediTI.setHazardous(haz &amp; ":+" &amp; undg);  // 04/08/2016 cnwma1  TFS #2492 PAR #38116
				endif;
			endif;
//DIM
		elseif msgHelper.currentTag = "DIM" then//
			if group = 6 then 
				msgHelper.setNextField();
				code := msgHelper.currentField;
				msgHelper.setNextField();
				if msgHelper.currentSubItem = "CMT" or
				   msgHelper.currentSubItem = "CM"	then // valid baplie 1 still used by some systems
					msgHelper.setNextSubItem();
					aLength := msgHelper.currentSubItem.Integer;
					msgHelper.setNextSubItem();
					aWidth := msgHelper.currentSubItem.Integer;
					msgHelper.setNextSubItem();
					aHeight := msgHelper.currentSubItem.Integer;
					ediTI.setDim(aLength, aWidth, aHeight);
					ediTI.setOutOfGauge('Y'); //par16796 cnwrs1 June 2008
				endif;
			endif;
//DTM
		elseif msgHelper.currentTag = "DTM" then												// TFS 4492
			msgHelper.setNextField();															// TFS 4492
			if msgHelper.currentField = "798" then												// TFS 4492
				// VGM determination date/time													// TFS 4492
				dateTimeStr := msgHelper.currentSubItem.trimBlanks();							// TFS 4492
				vgmDT := dateTimeStr.getUNEDIFACTTimeStamp(msgHelper.currentSubItem.Integer);	// TFS 4492
				if ediTI &lt;&gt; null then											// TFS 6691
					ediTI.vgmDeterminationDT := vgmDT;											// TFS 4492
				else															// TFS 6691
					determined := vgmDT;										// TFS 6691
				endif;															// TFS 6691
			elseif msgHelper.currentField = "137" then											// TFS 4492
				// VGM documentation issue date/time											// TFS 4492
				dateTimeStr := msgHelper.currentSubItem.trimBlanks();							// TFS 4492
				vgmDT := dateTimeStr.getUNEDIFACTTimeStamp(msgHelper.currentSubItem.Integer);	// TFS 4492
				if ediTI &lt;&gt; null then											// TFS 6691
					ediTI.vgmDocsIssuedDT := vgmDT;												// TFS 4492
				else															// TFS 6691
					docsIssued := vgmDT;										// TFS 6691
				endif;															// TFS 6691
			endif;																				// TFS 4492

//EQA

//EQD
		elseif msgHelper.currentTag = "EQD" then//
			group := 6; 
            msgHelper.setNextField();
            isTrailerType := msgHelper.currentField = "TE";                 //JIRA-35530
            if msgHelper.currentField = "CN" or isTrailerType then          //JIRA-35530
                msgHelper.setNextField();
				params.myCargoOperator := null; 
				//cnwmc5 - 8 June 2016 - TFS 2121 - changed to use 'msgHelper.currentSubItem'
				if msgHelper.currentSubItem.length &gt; 11 then
                    ediTIId := msgHelper.currentSubItem[1:4] &amp; msgHelper.currentSubItem[6:7];
                else
                    ediTIId := msgHelper.currentSubItem;
                endif;
				
                if ediTI &lt;&gt; null and //first time through
                   ediTI.id = null then // if the last ediTI has no id
                    generatedediTINo := generatedediTINo + 1;
                    ediTI.setIdDefault(generatedediTINo.String);
                endif;
                create ediTI persistent;
                ediTI.setForCreateNew(ediData);
                
                //  par 30361 - changed = to &lt;&gt; on next line
				if params.cargoOperator &lt;&gt; null then
                    ediTI.setOpCode(params.mySenderOperator, params.cargoOperator.code);
                elseif params.mySenderOperator &lt;&gt; null and
				   ediData.myOperator &lt;&gt; null then		
                    ediTI.setOpCode(params.mySenderOperator, ediData.myOperator.code);
                else
                    // no tranlation for operator in file.
                    ediTI.setOpCode(params.mySenderOperator, params.senderOperatorCode);
                endif;
                
                // The Load and Discharge ports must be set AFTER the Operator has been set.
                ediTI.setLoadPort(loadPort);
                ediTI.setDischargePort(dischargePort);
                
                ediTI.setID(ediTIId);
                ediTI.setTemp(NULL_TEMPERATURE.String);
                
                msgHelper.setNextField();
                
                if isTrailerType then                                       //JIRA-35530
                    ediTI.setCargoType(terminal.defaultTrailerCargoType);   //JIRA-35530
                    ediTI.setTrailerType(msgHelper.currentSubItem);         //JIRA-35530              
                    
                else
                    isotype := msgHelper.currentSubItem;
                    if params.mySenderOperator &lt;&gt; null then
                        ediTI.setISOType(xlationOperator.getXlationSystemCode(isotype, XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:4]);
                    else
                        ediTI.setISOType(isotype[1:4]);
                    endif;
                endif;
                msgHelper.setNextField();
                msgHelper.setNextField();
                msgHelper.setNextField();
                if msgHelper.currentField = "4" then
                    ediTI.fullOrMT := "E";
                elseif msgHelper.currentField = "5" then
                    ediTI.fullOrMT := "F";
                endif;

				if commsDetail &lt;&gt; null then							// TFS 6691
					ediTI.vgmCommsType := commsType;				// TFS 6691
					ediTI.vgmEDITransmission := ediTrans;			// TFS 6691
					ediTI.vgmElectronicMail := email;				// TFS 6691
					ediTI.vgmMail := mail;							// TFS 6691
					ediTI.vgmPhone := mobile;						// TFS 6691
					ediTI.vgmTelefax := fax;						// TFS 6691
					ediTI.vgmTelephone := phone;					// TFS 6691
					ediTI.vgmDocsIssuedDT := docsIssued;			// TFS 6691
					ediTI.vgmDeterminationDT := determined;			// TFS 6691
				endif;												// TFS 6691

                int := int + 1;
            endif;
//EQN

//FTX
		elseif msgHelper.currentTag = "FTX" then//

			if group = 6 then 
				msgHelper.setNextField();
				if msgHelper.currentField = "AAA" then
					msgHelper.setNextField();
					msgHelper.setNextField();
					msgHelper.setNextField();
					self.setRawCommodityValue (group, ediTI, msgHelper.currentField);	// par 31259
				endif;
				// CCMS 1462 Add Vents
				if msgHelper.currentField = "OSI" then
					msgHelper.setNextField();
					msgHelper.setNextField();
					if msgHelper.currentField &lt;&gt; null then//par18451 nov 2008 cnwrs1
						ediTI.setVents(msgHelper.currentField);
					endif;
				endif;
				if msgHelper.currentField = "HAN" then //ccms1635 Jan 2008 cnwrs1
					msgHelper.setNextField();
					msgHelper.setNextField();
					params.specialStowage := null;
					self.getFTXData(msgHelper, ediPartyRules, params);
					ediTI.specialStowage := params.specialStowage;
					if msgHelper.currentField = "WCR" then
						ediTI.setCooledType("W");
					elseif msgHelper.currentField = "CHM" then
						self.setRawCommodityValue (group, ediTI, msgHelper.currentField);	// par 31259
					endif;
				endif;
			endif;
//LOC
		elseif msgHelper.currentTag = "LOC" then//
			if group = 2 then
			   group := 3;
			endif;
			if group = 9 then
				group := 10;
			endif;
			if group = 3 then
				msgHelper.setNextField();
				if msgHelper.currentField = "9" then
					msgHelper.setNextField();
					loadPort := msgHelper.currentSubItem[1:5];
				elseif msgHelper.currentField = "11" then
					msgHelper.setNextField();
					dischargePort := msgHelper.currentSubItem[1:5];
				endif;
			elseif group = 6 then
				msgHelper.setNextField();
				if msgHelper.currentField = "7" then
					msgHelper.setNextField();
					ediTI.setDestinationPort(msgHelper.currentSubItem[1:5]);
				elseif msgHelper.currentField = "9" then
					msgHelper.setNextField();
					ediTI.setLoadPort(msgHelper.currentSubItem[1:5]);
				elseif msgHelper.currentField = "11" then
					msgHelper.setNextField();
					ediTI.setDischargePort(msgHelper.currentSubItem[1:5]);
				endif;
			elseif group = 10 then
				msgHelper.setNextField();
				if msgHelper.currentField = "5" or 
				   msgHelper.currentField = "11" or 
				   msgHelper.currentField = "164" or
				   msgHelper.currentField = "PDS" then
					if dischargeList then
						msgHelper.setNextField();
						ediTI.setTranshipDischargePort(msgHelper.currentSubItem[1:5]);
					endif;
				endif;
				if msgHelper.currentField = "64" or 
				   msgHelper.currentField = "68" or 
				   msgHelper.currentField = "70" then
					if dischargeList then
						msgHelper.setNextField();
						ediTI.transhipPortCodes.add(msgHelper.currentSubItem[1:5]);
					endif;
				endif;
			endif;
//MEA
		elseif msgHelper.currentTag = "MEA" then//
			if group = 6 then
				msgHelper.setNextField();
				if msgHelper.currentField = "WT" then
					msgHelper.setNextField();
					// If VGM, check for licence and update weight certified				// TFS #1699
					if msgHelper.currentField = "VGM" and app.myRoot.canDo(Mod_EDIVGM) then	// TFS #1699
						msgHelper.setNextField();											// TFS #1699
						msgHelper.setNextSubItem();											// TFS #1699
						ediTI.setWeight(msgHelper.currentSubItem.Integer);					// TFS #1699
						ediTI.isWeightCertified := true;									// TFS #1699
					else																	// TFS #1699
						msgHelper.setNextField();
						msgHelper.setNextSubItem();
						ediTI.setWeight(msgHelper.currentSubItem.Integer);
					endif;																	// TFS #1699
					
				elseif msgHelper.currentField = "AAE" then
					msgHelper.setNextField();
					
					if msgHelper.currentField = "AAS" then		// Ventilation.
						msgHelper.setNextField();
						msgHelper.setNextSubItem();
						ediTI.setVents(msgHelper.currentSubItem);
					elseif msgHelper.currentField = "G" 
						or msgHelper.currentField = "EGW" then	// Weight. //jlggb1 18.8.17 TFS 6565
						msgHelper.setNextField();
						msgHelper.setNextSubItem();
						ediTI.setWeight(msgHelper.currentSubItem.Integer);
					elseif msgHelper.currentField = "ZC" then	// Carbon Dioxide.
						msgHelper.setNextField();
						msgHelper.setNextSubItem();
						ediTI.setEDITIProperty(CM_EDILoadListTI::carbonDioxide.name, msgHelper.currentSubItem.Integer, _ediFile, null, null,null);	//cnwrs1 15 dec 2010 ccms1976	//21.11.2022 navma1 #55424
					elseif msgHelper.currentField = "ZO" then	// Oxygen.
						msgHelper.setNextField();
						msgHelper.setNextSubItem();
						ediTI.setEDITIProperty(CM_EDILoadListTI::oxygen.name, msgHelper.currentSubItem.Integer, _ediFile, null, null,null);	//cnwrs1 15 dec 2010 ccms1976 //21.11.2022 navma1 #55424
						
					elseif msgHelper.currentField = "VGM" and app.myRoot.canDo(Mod_EDIVGM) then	// TFS #1699
						msgHelper.setNextField();												// TFS #1699
						msgHelper.setNextSubItem();												// TFS #1699
						ediTI.setWeight(msgHelper.currentSubItem.Integer);						// TFS #1699
						ediTI.isWeightCertified := true;										// TFS #1699
                    elseif msgHelper.currentField = "AET" then                      //JIRA-35530
                        msgHelper.setNextField();                                   //JIRA-35530
                        if msgHelper.currentSubItem = "KGM" then                    //JIRA-35530
                            msgHelper.setNextSubItem();                             //JIRA-35530
                            ediTI.setWeight(msgHelper.currentSubItem.Integer);      //JIRA-35530
						endif;                                                      //JIRA-35530
					endif;
// End of PAR #23117 changes.
				endif;
			endif;
//NAD
		elseif msgHelper.currentTag = "NAD" then//
			nad1_LL := false;
			msgHelper.setNextField();
            subTag := msgHelper.currentField;
			nad1_1Code := subTag;
			if group &lt; 4 then
				group := 4;
			endif;
			if passport.myTerminal &lt;&gt; null then
				senderParty := passport.myTerminal.allEDIPartiesBySenderCode[params.senderOperatorCode];
			endif;
			if ediPartyRules &lt;&gt; null then
				ruleFunction := ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_NAD_1_1, nad1_1Code, segmentValue);
				if ruleFunction &lt;&gt; CM_EDIRule.Function_Undefined then
					if ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper then
						nad1_1Function := CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc;
						msgHelper.setNextField();
						if xlationOperator &lt;&gt; null then
							cargoOperatorCode := xlationOperator.getXlationSystemCode(msgHelper.currentSubItem, XLATION_TYPE_OPERATOR_BYOP, foundMatch)[1:30];
							params.myCargoOperator := app.myRoot.allOperators[cargoOperatorCode];
						else
							params.myCargoOperator := app.myRoot.allOperators[msgHelper.currentSubItem];
						endif;
						if ediTI &lt;&gt; null then
							ediTI.setOpCode(params.mySenderOperator, params.cargoOperatorCode);
						endif;
						if params.cargoOperator &lt;&gt; null and
						   ediData.myOperator = null then
							ediData.setOperator(params.cargoOperator);
						endif;
					elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee then
						nad1_1Function := CM_EDILoadListTI::consignee.name;
						nad1_LL := true;
					elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor then
						nad1_1Function := CM_EDILoadListTI::consignor.name;
						nad1_LL := true;
					elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd then
						nad1_1Function := CM_EDILoadListTI::freightForwarder.name;
						nad1_LL := true;
					elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertNam then
						nad1_1Function := CM_EDILoadListTI::weightCertifiedName.name;
						nad1_LL := true;
					elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertRef then
						nad1_1Function := CM_EDILoadListTI::weightCertifiedReference.name;
						nad1_LL := true;
					endif;
					if nad1_1Function &lt;&gt; null then
						msgHelper.setNextField();
						if nad1_LL then
							if xlationOperator &lt;&gt; null then
								ediTI.setPropertyValue(nad1_1Function, xlationOperator.getXlationSystemCode(msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30]);
							else
								ediTI.setPropertyValue(nad1_1Function, msgHelper.currentSubItem.trimBlanks()[1:30]);
							endif;
						endif;
					endif;
				endif;
				ruleFunction := ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_NAD_2_1, nad1_1Code, segmentValue);
				if ruleFunction &lt;&gt; CM_EDIRule.Function_Undefined then
					if ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper then
						nad2_1Function := CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc;
						if xlationOperator &lt;&gt; null then
							cargoOperatorCode := xlationOperator.getXlationSystemCode(msgHelper.currentSubItem, XLATION_TYPE_OPERATOR_BYOP, foundMatch)[1:30];
							params.myCargoOperator := app.myRoot.allOperators[cargoOperatorCode];
						else
							params.myCargoOperator := app.myRoot.allOperators[msgHelper.currentSubItem];
						endif;
						if ediTI &lt;&gt; null then
							ediTI.setOpCode(params.mySenderOperator, params.cargoOperatorCode);
						endif;
						if params.cargoOperator &lt;&gt; null and
						   ediData.myOperator = null then
							ediData.setOperator(params.cargoOperator);
						endif;
					elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee then
						nad2_1Function := CM_EDILoadListTI::consignee.name;
						nad1_LL := true;
					elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor then
						nad1_1Function := CM_EDILoadListTI::consignor.name;
						nad1_LL := true;
					elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd then
						nad1_1Function := CM_EDILoadListTI::freightForwarder.name;
						nad1_LL := true;
					elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertNam then
						nad2_1Function := CM_EDILoadListTI::weightCertifiedName.name;
						nad1_LL := true;
					elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertRef then
						nad2_1Function := CM_EDILoadListTI::weightCertifiedReference.name;
						nad1_LL := true;
					endif;
					if nad2_1Function &lt;&gt; null then
						msgHelper.setNextField();
						msgHelper.setNextField();
						if nad1_LL then
							if xlationOperator &lt;&gt; null then
								ediTI.setPropertyValue(nad2_1Function, xlationOperator.getXlationSystemCode(msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30]);
							else
								ediTI.setPropertyValue(nad2_1Function, msgHelper.currentSubItem.trimBlanks()[1:30]);
							endif;
						endif;
					endif;
				endif;
				ruleFunction := ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_NAD_3_1, nad1_1Code, segmentValue);
				if ruleFunction &lt;&gt; CM_EDIRule.Function_Undefined then
					if ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper then
						nad3_1Function := CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc;
						if xlationOperator &lt;&gt; null then
							cargoOperatorCode := xlationOperator.getXlationSystemCode(msgHelper.currentSubItem, XLATION_TYPE_OPERATOR_BYOP, foundMatch)[1:30];
							params.myCargoOperator := app.myRoot.allOperators[cargoOperatorCode];
						else
							params.myCargoOperator := app.myRoot.allOperators[msgHelper.currentSubItem];
						endif;
						if ediTI &lt;&gt; null then
							ediTI.setOpCode(params.mySenderOperator, params.cargoOperatorCode);
						endif;
						if params.cargoOperator &lt;&gt; null and
						   ediData.myOperator = null then
							ediData.setOperator(params.cargoOperator);
						endif;
					elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee then
						nad3_1Function := CM_EDILoadListTI::consignee.name;
						nad1_LL := true;
					elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor then
						nad1_1Function := CM_EDILoadListTI::consignor.name;
						nad1_LL := true;
					elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd then
						nad1_1Function := CM_EDILoadListTI::freightForwarder.name;
						nad1_LL := true;
					elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertNam then
						nad3_1Function := CM_EDILoadListTI::weightCertifiedName.name;
						nad1_LL := true;
					elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_WghtCertRef then
						nad3_1Function := CM_EDILoadListTI::weightCertifiedReference.name;
						nad1_LL := true;
					endif;
					if nad3_1Function &lt;&gt; null then
						msgHelper.setNextField();
						msgHelper.setNextField();
						msgHelper.setNextField();
						if nad1_LL then
							if xlationOperator &lt;&gt; null then
								ediTI.setPropertyValue(nad3_1Function, xlationOperator.getXlationSystemCode(msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30]);
							else
								ediTI.setPropertyValue(nad3_1Function, msgHelper.currentSubItem.trimBlanks()[1:30]);
							endif;
						endif;
					endif;
				endif;
			endif;
			if nad1_1Function = null and
			   nad2_1Function = null and
			   nad3_1Function = null then
				if group = 4 then
					if subTag = "CA"  then		// Sender operator
						msgHelper.setNextField();
						// cnwrl1 26/07/2010 PAR 25093 - start of replacement coding
						params.senderOperatorCode	:= msgHelper.currentSubItem;
						params.senderOperatorCode	:= app.myRoot.getXlationSystemOperatorCode(params.mySenderOperator, params.senderOperatorCode, foundMatch)[1:4];
						params.mySenderOperator		:= app.myRoot.allOperators[params.senderOperatorCode];
						if xlationOperator = null then
							xlationOperator := params.mySenderOperator;
						endif;
						ediData.setOperator(params.mySenderOperator);
						// cnwrl1 26/07/2010 PAR 25093 - end of coding
						if voyageCode &lt;&gt; null then	//par 25136 cnwrs1 22 jul 2010 
							// cnwrl1 22/07/2010 PAR 25093 - start of replacement coding
							// Use the operator voyage code translation if it exists.
							voyageCode	:= self.getXlationOperatorVoyageCode(xlationOperator,
																				operatorVoyage,
																				voyageCode,
																				vesselName,
																				lloydsNumber,
																				callSign );
							ediData.setVoyageCode( voyageCode );
							// cnwrl1 22/07/2010 PAR 25093 - end of coding
						endif;
					elseif subTag = "CF" then		// Container operator!
						msgHelper.setNextField();
						// NOTE: Even though this should be the operatorVoyage set up the operatorSender for compatablity with 7.8.2 etc.
						// cnwrl1 26/07/2010 PAR 25093 - start of coding
						params.senderOperatorCode	:= msgHelper.currentSubItem;
						params.senderOperatorCode	:= app.myRoot.getXlationSystemOperatorCode(params.mySenderOperator, params.senderOperatorCode, foundMatch)[1:4];
						params.mySenderOperator		:= app.myRoot.allOperators[params.senderOperatorCode];
						ediData.setOperator( params.mySenderOperator );
						if xlationOperator = null then
							xlationOperator := params.mySenderOperator;
							_ediFile.ediData.setXlationOperator(params.mySenderOperator);
						endif;
						// cnwrl1 26/07/2010 PAR 25093 - end of coding
						
						/*																																				//-TSF41900
						if ediData.voyageCode = null then	//par 25136 cnwrs1 22 jul 2010 
							// cnwrl1 20/07/2010 PAR 25046
							voyageCode := self.getXlationOperatorVoyageCode(xlationOperator,
																				operatorVoyage,
																				voyageCode,
																				vesselName,
																				lloydsNumber,
																				callSign );
							ediData.setVoyageCode( voyageCode ); // cnwrl1 20/07/2010 PAR 25046
						endif;
						*/
						if ediData.voyageCode &lt;&gt; null then	 //par 25136 cnwrs1 22 jul 2010 						//+TFS41900 Do trnslation for ediData.voyageCode first 
							// cnwrl1 20/07/2010 PAR 25046
							voyageCode := self.getXlationOperatorVoyageCode(xlationOperator,			
																				operatorVoyage,
																				ediData.voyageCode,
																				vesselName,
																				lloydsNumber,
																				callSign );
						else
							voyageCode := self.getXlationOperatorVoyageCode(xlationOperator,
																				operatorVoyage,
																				voyageCode,
																				vesselName,
																				lloydsNumber,
																				callSign );
							endif;
							ediData.setVoyageCode( voyageCode ); // cnwrl1 20/07/2010 PAR 25046
						//endif;
					elseif subTag = "CN" then  //Consignee
						msgHelper.setNextField();
						tempConsignee := msgHelper.currentField; 
						msgHelper.setNextField();
						msgHelper.setNextField();
						ediTI.setConsignee(msgHelper.currentField);
						if ediTI.consignee = null and tempConsignee &lt;&gt; null then // cnwgb1 24.5.2011 PAR 27580
							ediTI.setConsignee(tempConsignee);
						endif;
					endif;
				// cnwrl1 26/08/2010 PAR 25559 (group 6)
				elseif group = 6 or group = 9 then // cnwgb1 24.5.2011 PAR 27580 (add group 9)
					if subTag = "CN" then		// consignee details
						msgHelper.setNextField();
					   tempConsignee := msgHelper.currentField; 
						msgHelper.setNextField();
						msgHelper.setNextField();
						ediTI.setConsignee(msgHelper.currentField);
						if ediTI.consignee = null and tempConsignee &lt;&gt; null then // cnwgb1 24.5.2011 PAR 27580
							ediTI.setConsignee(tempConsignee);
						endif;
					endif;
					
				elseif group = 10 then													// TFS #1699
					if subTag = "AM" then												// TFS #1699
						// Authorised Official for VGM									// TFS #1699
						msgHelper.setNextField();										// TFS #1699
						msgHelper.setNextField();										// TFS #1699
						msgHelper.setNextField();										// TFS #1699
						ediTI.weightCertifiedName := msgHelper.currentField.toUpper;	// TFS #1699
					elseif subTag = "SPC" then													// TFS 4492
						// Responsible Party for VGM											// TFS 4492
						msgHelper.setNextField();												// TFS 4492
						msgHelper.setNextField();												// TFS 4492
						msgHelper.setNextField();												// TFS 4492
						ediTI.weightCertifiedReference := msgHelper.currentField.toUpper;		// TFS 4492
					endif;																// TFS #1699
				endif;		
			endif;

//PCD

//RFF
		elseif msgHelper.currentTag = "RFF" then//
			if group = 0 then
				group := 1;
			endif;
			if group = 1 or
			   group = 2  or
			   group = 6  then
				msgHelper.setNextField();
				if msgHelper.currentSubItem = "STF" then
					msgHelper.setNextSubItem();
					self.setRawCommodityValue (group, ediTI, msgHelper.currentField);	// par 31259
				endif;
				if msgHelper.currentSubItem = "BN" then
					msgHelper.setNextSubItem();
					ediTI.setBookingRef(msgHelper.currentSubItem[1:20]);
				endif;
				// 16/10/2014 cnwar2 #35053
				if msgHelper.currentSubItem = "BM" then
					msgHelper.setNextSubItem();
					ediTI.bol := msgHelper.currentSubItem[1:35];			// MTN-14781
				endif;
				
				if msgHelper.currentSubItem = "VGR" then								// TFS #1699
					msgHelper.setNextSubItem();											// TFS #1699
					ediTI.weightCertifiedReference := msgHelper.currentSubItem.toUpper;	// TFS #1699
				endif;																	// TFS #1699
				
			elseif group = 9 then
				msgHelper.setNextField();
				if msgHelper.currentSubItem = "BN" then
					msgHelper.setNextSubItem();
					ediTI.transhipBookingRef := msgHelper.currentSubItem[1:20];
				endif;
				if msgHelper.currentSubItem = "BM" then
					msgHelper.setNextSubItem();
					ediTI.transhipBOLId := msgHelper.currentSubItem[1:35];	// MTN-14781
				endif;
			endif;
//RNG

//SEL
		elseif msgHelper.currentTag = "SEL" then//
			if group = 6 then
				msgHelper.setNextField();
				sealNumber := msgHelper.currentField;
				msgHelper.setNextField();
				sealType := msgHelper.currentSubItem;
				if sealType = "CA" or sealType = null then
					ediTI.sealNum := sealNumber;
				elseif sealType = "SH" then
					ediTI.sealShipper := sealNumber;
				elseif sealType = "CU" then
					ediTI.sealCustoms := sealNumber;
				elseif sealType = "TO" then
					ediTI.sealTerminalOperator := sealNumber;
				else
					ediTI.sealUnknown := sealNumber;
				endif;
			endif;
//TDT
		elseif msgHelper.currentTag = self.TDT then
			if group &lt; 2 then
				group := 2;
			endif;
			if group &gt; 5 then
				group := 9;
			endif;
			if group = 2 then
				msgHelper.setNextField();
				if msgHelper.currentField = "20" then
					self.getVoyageDetailsFromTDT(	msgHelper,
													voyageCode,
													operatorVoyageCode,
													operatorVoyage,			// cnwrl1 26/07/2010 PAR 25093
													vesselName,
													lloydsNumber,
													callSign ); //cnwrs1 ccms 1137 16 july 2010
					
					// cnwrl1 26/07/2010 PAR 25093 - start of coding
					// Because some of Nelson's clients (ANL and COS) in particular do not send
					// through the mandatory UNB record the operator is not getting set up.
					// To cater for this we will use the first valid TDT+20 operator
					// if and only if the operator is not already set up.
					if params.mySenderOperator = null then
						params.mySenderOperator		:= operatorVoyage;
						params.senderOperatorCode	:= operatorVoyageCode;
						ediData.setOperator( params.mySenderOperator );
					endif;
					// cnwrl1 26/07/2010 PAR 25093 - end of coding
					ediData.setVoyageCode(voyageCode);
				endif;
			elseif group = 9 then
				msgHelper.setNextField();
				if msgHelper.currentField = "10" or 
				   msgHelper.currentField = "30" then //cnwrs1 CCMS 1137 01 July 2010
				   tdtType := msgHelper.currentField;
					if dischargeList then
						self.getVoyageDetailsFromTDT(	msgHelper,
														transhipVoyageCode,
														transhipOperatorVoyageCode,
														transhipOperatorVoyage,		// cnwrl1 26/07/2010 PAR 25093
														transhipVesselName,
														transhipLloydsNumber,
														transhipCallSign ); //cnwrs1 ccms 1137 16 july 2010

						if transhipVoyageCode = null then
							if tdtType = "30" then
								transhipVoyageCode := NULL_VOYAGE_CODE;
							else
								transhipVoyageCode := null;
								transhipOperatorVoyageCode	:= null;
								transhipVesselName := null;
								transhipLloydsNumber := null;
								transhipCallSign := null;
								continue;
							endif;
						endif;
						// cnwrl1 20/07/2010 PAR 25046 - start of replacement coding
						// Use the operator voyage code translation if it exists.
						transhipVoyageCode	:= self.getXlationOperatorVoyageCode(xlationOperator,
																					operatorVoyage,
																					transhipVoyageCode,
																					transhipVesselName,
																					transhipLloydsNumber,
																					transhipCallSign );
						ediTI.setTranshipVoyageCode( transhipVoyageCode );
						ediTI.transhipVesselName := transhipVesselName; //cnwrs1 par 25195 13 aug 2010
						// cnwrl1 20/07/2010 PAR 25046 - end of coding
					endif;
				endif;
			endif;
//TMD

//TMP
		elseif msgHelper.currentTag = "TMP" then//
			if group = 6 then
				msgHelper.setNextField();
				if msgHelper.currentField = "2" then
					msgHelper.setNextField();
					strTmp := msgHelper.currentSubItem;
					strTmp.cnReplaceChar(' ', null); //ccms1635 Jan 2008 cnwrs1
					ediTI.setTemp(strTmp);
				endif;
			endif;
// cnwdad1 08/11/2010 - PAR #26017.
// cnwdad1 16/11/2010 - Temporarily put original code back, until we have a design to implement UNA handling.
//UNA
//		elseif msgHelper.currentTag = "UNA" then
//			msgHelper.setFirstField();
//UNB
		elseif msgHelper.currentTag = self.UNB then
			if group = 0 then
				// cnwrl1 21/07/2010 PAR 25093 - start of replacement coding
				// get The translated Sender Operator and Code.
/*				self.getUNB_ElementData(	msgHelper,
											operatorSenderCode,
										operatorSender, rawSenderCode, recipientCode, creationTS, sequence);
				ediData.setOperator( operatorSender );*/
				// cnwrl1 21/07/2010 PAR 25093 - end of coding
				self.getUNBData(ediData, msgHelper, params.senderOperatorCode, rawSenderCode, recipientCode, ediPartyRules, params.mySenderOperator, creationTS, sequence);
				xlationOperator := params.mySenderOperator;
				_ediFile.ediData.setXlationOperator(xlationOperator);
			endif;
//UNH
		elseif msgHelper.currentTag = "UNH" then
			untCount := 1;	//15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
			self.getUNHData(_ediFile.ediData, msgHelper, fileType, version);
			if _ediFile.ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE and
			   not self.processSenderRecipientSeq(rawSenderCode, recipientCode, fileType, version, _ediFile.ediData.fileName, creationTS, sequence, _ediFile.ediData, passport.myTerminal) then
				ediData.status := CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE;
			endif;
//UNT
		elseif msgHelper.currentTag = "UNT" then
			group := 0;
		endif;

	endforeach;
	
//	self.doTranslations (_ediFile, null);
epilog
	delete theLines;
	delete msgHelper;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
