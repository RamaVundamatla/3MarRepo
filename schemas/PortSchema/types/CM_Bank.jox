    <JadeMethod name="getSeqNum" id="37d0839e-00d0-4a9d-aca5-de16c27c2f9b">
        <source>getSeqNum(seriesCode : String) : Integer;
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	ks : CM_KeySeries;
	pfix, sfix : String;
	root : Integer;
	sk :CM_SeriesKey;

begin
	ks := self.keySeries[seriesCode];
//	if not global.isValidObject(ks) then
	if ks = null then
		create ks persistent;
		ks.code := seriesCode;
		ks.description := seriesCode;
		create sk persistent;
		ks.nextKey := sk;
		sk.setForUpdate(null, "CTL", 1, null, null);
		self.keySeries.add(ks);
	endif;

//	lock(ks, Reserve_Lock, Transaction_Duration, 5000);
	reserveLock(ks); // This will make it use the INI configuration for duration

	ks.reserve(app.computerName, process.signOnUserCode, pfix, root, sfix);
	ks.issue(app.computerName, process.signOnUserCode);
	
	return root;

epilog
	unlock(ks);
end;</source>
        <Parameter name="seriesCode" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSeqNumCharge" id="2066f4b8-f7bf-4810-bd3e-ed5190f6d909">
        <source>getSeqNumCharge() : Integer;
// PAR 18104
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	ks : CM_KeySeries;
	pfix, sfix : String;
	root : Integer;
	sk :CM_SeriesKey;
	bank : CM_Bank;
begin

	bank := app.myRoot.myRootCompany;
	
	ks := bank.keySeries[SN_CHARGE];
//	if not global.isValidObject(ks) then
	if ks = null then
		create ks persistent;
		ks.code := SN_CHARGE;
		ks.description := SN_CHARGE;
		create sk persistent;
		ks.nextKey := sk;
		sk.setForUpdate(null, "CTL", 1, null, null);
		bank.keySeries.add(ks);
	endif;

//	lock(ks, Reserve_Lock, Transaction_Duration, 5000);
	reserveLock(ks); // This will make it use the INI configuration for duration

	ks.reserve(app.computerName, process.signOnUserCode, pfix, root, sfix);
	ks.issue(app.computerName, process.signOnUserCode);

	return root;

epilog
	unlock(ks);
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSeqNumInvoiceLine" id="b8d2d1e4-6a36-4043-922d-73cc21c9a211">
        <source>getSeqNumInvoiceLine() : Integer;
// PAR 18104
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	ks : CM_KeySeries;
	pfix, sfix : String;
	root : Integer;
	sk :CM_SeriesKey;
	bank : CM_Bank;
begin
	bank := app.myRoot.myRootCompany;
	
	ks := bank.keySeries[SN_INVOICELINE];
//	if not global.isValidObject(ks) then
	if ks = null then
		create ks persistent;
		ks.code := SN_INVOICELINE;
		ks.description := SN_INVOICELINE;
		create sk persistent;
		ks.nextKey := sk;
		sk.setForUpdate(null, "CTL", 1, null, null);
		bank.keySeries.add(ks);
	endif;

//	lock(ks, Reserve_Lock, Transaction_Duration, 5000);
	reserveLock(ks); // This will make it use the INI configuration for duration

	ks.reserve(app.computerName, process.signOnUserCode, pfix, root, sfix);
	ks.issue(app.computerName, process.signOnUserCode);

	return root;

epilog
	unlock(ks);
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getServiceByExtRef" id="f308d7f8-82ea-45a1-ba3a-56602b4dd2bb">
        <source>getServiceByExtRef(_externalRef: String): CM_Service;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 August 2023		navmd1	Initial creation TFS 59959

*/

vars
	service		: CM_Service;
begin
	if _externalRef = null then
		return null;
	endif;
	
	foreach service in self.services where service.externalReference1 = _externalRef do
		return service;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_externalRef" type="String"/>
        <ReturnType type="CM_Service"/>
    </JadeMethod>
