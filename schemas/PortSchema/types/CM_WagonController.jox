    <JadeMethod name="calculateMoveLCs" id="6fb997c8-e1dc-4f29-bd50-1168a25f872f">
        <source>calculateMoveLCs(_ti : CM_TrackedItem): Real;
/*
 ------------------------------------------------------------------------
Created:			13 September 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

	len	: Real;
begin

	// DVB changed 1 Sep 2003 to return units divide by 2;
	len := _ti.getLengthInUnits();
	if len &gt; 1 then
		return len div 2;
	else
		return 1;
	endif;
//	return ti.getLengthInUnits();
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Real"/>
    </JadeMethod>
