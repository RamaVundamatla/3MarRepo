    <JadeMethod name="cmbISOType_lostFocus" id="2f3d5996-ca47-4227-a2d7-64bad9b58992">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbISOType_lostFocus(combobox: GTE_ComboISOType input) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sheet		: GTE_Sheet;
	isoType		: CM_ISOType;
	entryTable	: CM_EntryTable;
	row			: Integer;
	
begin
	sheet	:=	combobox.mySheet;
	self.setCellTextFromControl(sheet, combobox, combobox.text);

	if sheet.myMenuAction.code &lt;&gt; NavObj_GTE_OutByType then
		self.setISOTypeFields(sheet);
		// now done in setCargoTypeFields(..)
		//self.myAssistant.GTE_Assistant.showHideCEDOField(combobox.mySheet.myTblExtra,1);// ### CCMS 1294 AKB2005JAN
	else
		isoType	:=	sheet.getISOType();
		
		if isoType &lt;&gt; null then	
			sheet.setHeading(isoType.code);	
		endif;
	endif;
	
	sheet.setContainerSizeFromISOType();
end;</source>
        <Parameter name="combobox" type="GTE_ComboISOType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbImexStatus_click" id="2c9c0ea8-dcbe-4b2c-9e07-3f40d6597f3b">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbImexStatus_click(combobox: ComboBox input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/11/2009	cnwas3	Initial creation
*/
begin
	if combobox.text &lt;&gt; app.getIMEXStringFromIMEXStatus(TI_IMEX_STATUS_EXPORT)
	and not app.myPassport.myTerminal.getConfig(ShowPortOfCallTranship).Boolean
	then
		self.tblExtra.hideRowByName(ETRow_MyTranshipToPort, false);
	else
		self.tblExtra.showRowByName(ETRow_MyTranshipToPort, false);
	endif;
	
	// cnwdad1 17/05/2010 - PAR #24240.
	self.setSubTerminalDefault(self.topSheet.isReceival(), true, self.topSheet.myTblExtra);
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
