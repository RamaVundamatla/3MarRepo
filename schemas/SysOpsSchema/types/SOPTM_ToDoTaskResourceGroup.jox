end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="6eba61c9-2122-40b2-95d5-6d4a9e69c31e">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	theForm : SOP_TableMaintForm;
	
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_ToDoTskResourceGrpTbl);
	
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_ToDoTskResGrpEntryTbl);
	
	theForm.shtTblInput1.visible := true;
	
	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="a02b2fb8-f14f-4453-9106-d08ee40d0166">
        <updating/>
        <source>showThumbnail(_resourceTypeGroup: CM_ResourceTypeGroup) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2023	navpw1	Initial creation

*/

vars
	theForm				: SOP_TableMaintForm;
	iter 				: Iterator;
	obj 				: Object;
	allResourceTypes	: CM_ResourceTypeDict;
	additionalInfo  	: String;
	theRow 		    	: Integer;
	
begin
	theForm	:=	self.myForm;
	theForm.tblInput1.clearValues();
	theForm.tblInput1.setValueByName(ETRow_Code, _resourceTypeGroup.code);
	theForm.tblInput1.setValueByName(ETRow_Description, _resourceTypeGroup.description);
	theForm.tblInput1.setValueByName(ETRow_IsNotAvailableForEntry, _resourceTypeGroup.isNotAvailableForEntry);		
	
	create allResourceTypes transient;
	iter := _resourceTypeGroup.allResourceTypes.createIterator;

	while iter.next( obj ) do
		if obj.isKindOf(CM_ResourceType) then
			allResourceTypes.add( obj.CM_ResourceType );
		endif;
	endwhile;
	
	theForm.mulSelect1.setSorted(true);
	theForm.mulSelect1.setSelected(allResourceTypes);
	self.disableMulSelect1Contents();
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_resourceTypeGroup" type="CM_ResourceTypeGroup"/>
    </JadeMethod>
</Class>
