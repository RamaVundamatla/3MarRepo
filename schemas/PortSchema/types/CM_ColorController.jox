    <JadeMethod name="create" id="c8491586-9233-4310-9526-b7b4531f0835">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     25 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.setDefaultColors();

end;</source>
    </JadeMethod>
    <JadeMethod name="getColorValue" id="257eb9aa-1364-42c0-b124-a05625d65726">
        <source>getColorValue(_win : Window; _color : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     25 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _color &lt; 0 then
		return _win.getSystemColor( -(_color));
	else
		return _color;
	endif;

end;</source>
        <Parameter name="_win" type="Window"/>
        <Parameter name="_color" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDefaultColors" id="8e529e5d-fc75-4b63-8748-33f8734f31b6">
        <updating/>
        <source>setDefaultColors() updating;
// ---------------------------------------------------------------------------
// Created:     25 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

//Color_InfoBk	
/*
	self.controlBackColor	:= White;	// typically used for non-input controls
	self.formBackColor		:= -(Window.Color_3DFace);
	self.headingColumnColor	:= Gray;
	self.rowColor1			:= 16055996;
	self.rowColor2			:= 16703915;
	self.valueColumnColor	:= White;	// DO NOT CHANGE - would need to change back color for all controls on forms

// test colours

		self.formBackColor		:= app.convertRGBToColor(149, 188, 253);	//16763831;
		self.controlBackColor	:= -(Window.Color_InfoBk);
		self.headingColumnColor	:= app.convertRGBToColor(248, 220, 247);

*/

	self.controlBackColor	:= app.convertRGBToColor(255, 255, 232);	//White;	// typically used for non-input controls
	self.formBackColor		:= app.convertRGBToColor(230, 230, 230);	// (204, 204, 204);

//	self.headingColumnColor	:= app.convertRGBToColor(254, 250, 196);	// 244, 241, 205);
// 	self.headingColumnColor	:= app.convertRGBToColor(249, 242, 226);	// no 2
	self.headingColumnColor	:= app.convertRGBToColor(238, 236, 203);		// no 1
	

	self.rowColor1			:= app.convertRGBToColor(255, 255, 232);	//White;
	self.rowColor2			:= app.convertRGBToColor(242, 242, 225);	//White;
	self.valueColumnColor	:= White;	//app.convertRGBToColor(255, 255, 232);	//White;	// DO NOT CHANGE - would need to change back color for all controls on forms

	//cnwmc5 - 1/2/2013 - PAR #31051
	if app.isUsingSkin() then
		//self.headingColumnColor	:= app.convertRGBToColor(230, 230, 230);
		//self.headingColumnColor	:= White;
		self.headingColumnColor	:= app.convertRGBToColor(247, 247, 250);
		self.rowColor1			:= White;
		self.rowColor2			:= app.convertRGBToColor(251, 251, 251);
		
		// navmd1 TFS 51086 - JADE 2020 temporary fixes to set the colours back to what they were in 2016 and previous
		self.controlBackColor	:= White;
	endif;
end;</source>
    </JadeMethod>
</Class>
