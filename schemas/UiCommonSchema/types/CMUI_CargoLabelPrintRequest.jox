    <JadeMethod name="clickBreakBulk" id="b5e3a205-ce0c-46e8-8290-cc0bdedc0242">
        <source>clickBreakBulk();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2013	cnwndl1	Initial creation

*/

vars

	firstIndex : Integer;
	lastIndex : Integer;

begin

	if self.chkAddSuffix.value then
		self.lblFirst.visible := true;
		self.lblLastSuffix.visible := true;
		self.lblMainIdValue.visible := true;
		self.lblSeparator.visible := true;
		self.txtFirstSuffix.visible := true;
		self.txtLastSuffix.visible := true;
		self.txtMainIdValue.visible := true;
		
		if self.myBreakBulkObject &lt;&gt; null then
			firstIndex := 1;
			if CM_BreakBulkGeneric.hasInstance(self.myBreakBulkObject) then
				self.txtMainIdValue.text := self.myBreakBulkObject.CM_BreakBulkGeneric.id;
				lastIndex := self.myBreakBulkObject.CM_BreakBulkGeneric.totalQuantity;
			elseif CMGTE_Receival.hasInstance(self.myBreakBulkObject) then
				self.txtMainIdValue.text := self.myBreakBulkObject.CMGTE_Receival.id;
				lastIndex := self.myBreakBulkObject.CMGTE_Receival.totalQuantity;
			elseif CMGTE_ReceivalByType.hasInstance(self.myBreakBulkObject) then
				lastIndex := self.myBreakBulkObject.CMGTE_ReceivalByType.getTotalQuantity();
			endif;
			if lastIndex &gt; 1 then
				self.txtFirstSuffix.text := firstIndex.padLeadingWith("0",lastIndex.String.length);
				self.txtLastSuffix.text := lastIndex.String;
			endif;	
		endif;
		
		self.txtSeparator.visible := true;
		
		self.lblNumIds.visible := false;
		self.txtNumIds.visible := false;
		self.chkAuto.visible := false;
		
	else
		self.lblFirst.visible := false;
		self.lblLastSuffix.visible := false;
		self.lblMainIdValue.visible := false;
		self.lblSeparator.visible := false;
		self.txtFirstSuffix.visible := false;
		self.txtLastSuffix.visible := false;
		self.txtMainIdValue.visible := false;
		self.txtSeparator.visible := false;
		
		self.lblNumIds.visible := true;
		self.txtNumIds.visible := true;
		self.chkAuto.visible := true;
		
	endif;

epilog

end;</source>
    </JadeMethod>
