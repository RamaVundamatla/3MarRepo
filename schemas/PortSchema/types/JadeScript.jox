    <JadeMethod name="damageInstance" id="61b11836-2df1-4e1e-aab5-2b6e1e226da2">
        <source>damageInstance();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	terminal : CM_Terminal;
	dInstance	:CM_DamageInstance;
	objArr 		: ObjectArray;
begin
	create objArr transient;
	CM_DamageInstance.allInstances(objArr, 0, true);
	
	beginTransaction;
	
	foreach dInstance in objArr as CM_DamageInstance do
		if dInstance.repaired then
			dInstance.setStatus(DamageStatusRepaired);
		endif;
	endforeach;
	
	commitTransaction;
epilog
	delete objArr;
end;</source>
    </JadeMethod>
