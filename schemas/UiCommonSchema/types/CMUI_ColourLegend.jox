    <JadeMethod name="addLegendItem" id="016c57fb-8aee-4fef-968e-9d5750d457f7">
        <source>addLegendItem(_caption: String; _foreColor, _backColor: Integer; _pictureName: String; _fontBold: Boolean);
//----------------------------------------------------------------
//	Created:	29 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx		: Integer;
	fColor	: Integer;
	bColor	: Integer;
	pic		: Control;
begin
	fColor := _foreColor;
	bColor := _backColor;
	
	if fColor = null then
		fColor := Black;
	endif;
	
	if bColor = null and fColor = null then
		bColor := White;
	endif;
	
	idx := self.lstColours.addItem(_caption);
	self.lstColours.itemForeColor[idx] := fColor;
	self.lstColours.itemBackColor[idx] := bColor;
	self.lstColours.fontBold := _fontBold;	//bugger
	pic := self.getControl(_pictureName);
	
	if pic &lt;&gt; null and pic.isKindOf(Picture) then
		self.lstColours.itemPicture[idx] := pic.Picture.picture;
	endif;
	

end;</source>
        <Parameter name="_caption" type="String"/>
        <Parameter name="_foreColor" type="Integer"/>
        <Parameter name="_backColor" type="Integer"/>
        <Parameter name="_pictureName" type="String"/>
        <Parameter name="_fontBold" type="Boolean"/>
    </JadeMethod>
