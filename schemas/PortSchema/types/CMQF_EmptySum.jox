    <JadeMethod name="delete" id="f0ffcd6e-b30f-44bf-b8e8-cf6948be4c13">
        <updating/>
        <source>delete() updating;
//----------------------------------------------------------------
//	Created:	28 September 2004	by Jason Chapman  (cnwjc2)
