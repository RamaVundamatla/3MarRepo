    <JadeMethod name="erase" id="1c9e47eb-030a-4abd-bf74-407adfee0601">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2021	navndl1	Initial creation	TFS 49912

*/

vars


begin

	if not self.allProductMinMax.isEmpty then
		self.allProductMinMax.purge();
	endif;
	

	inheritMethod(_eraseLevel);

epilog

end;</source>
