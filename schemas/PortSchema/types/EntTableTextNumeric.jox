<Class name="EntTableTextNumeric" id="b12d6234-d388-431b-b0bf-a778960df07a">
    <superclass name="EntTableCellControl"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
