    <JadeMethod name="getTrainObject" id="4effb7a9-f682-4fbe-af32-3278ef4b58a6">
        <source>getTrainObject() : CM_Train;
// ---------------------------------------------------------------------------
// Created:     23 July 2009 by cnwab1 PAR 20341
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTrain : CM_Train;
begin
		theTrain := self.job.getMyTrain();

		if theTrain = null then
			if self.myTrackedItem &lt;&gt; null then
				theTrain := self.myTrackedItem.getMyTrainObject(not self.job.isRelease());
			endif;
		endif;
		
		return theTrain;

epilog

end;</source>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="getTrainString" id="6a2d4ec6-cfa3-4b93-a4e9-09ae9417403a">
        <source>getTrainString() : String;
// ---------------------------------------------------------------------------
// Created:     23 July 2009 by cnwab1 PAR 20341
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	trainStr : String;
	train : CM_Train;
	wagon : CM_Wagon;
begin
	train := self.getTrainObject();
	
	//21 Aug 2009	NDL	CCMS 1094
	if train = null then
		if self.isYardReleaseAssigned then
			wagon := self.CM_YardWLE.allLocationControllers.first.myWagon;
			if wagon &lt;&gt; null then
				train := wagon.myTrainOutwards;
			endif;
		endif;
	endif;
	
	if train &lt;&gt; null then
		trainStr := train.code;
	endif;
	
	return trainStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTreeDescription" id="cfa0cedd-ee9f-4d62-9f7a-ca6307ed1d33">
        <source>getTreeDescription() : String;
// ---------------------------------------------------------------------------
// Created:     09 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	delReq		: CM_DeliveryRequest;
	tmpType,
	cln,
	str,
	opCode,
	releaseDate	: String;
	release		: CM_BulkRelease;
	invalid 	: Boolean;
	bolNumber	: String;
	bol			: CM_BOL;
	amountString : String;
begin
	bol := self.myBOL;
	if bol &lt;&gt; null then
//		and global.isValidObject(self.myBOL) then
		on Exception do app.handleDeletedObject(exception, bol, invalid);
		bolNumber := bol.number;
		if not invalid then
			return app.getErrorString(BillOfLading) &amp; ' ' &amp; bolNumber;
		endif;
		on Exception do null;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		str := self.myTrackedItem.id;
		if CM_TIRequest.hasInstance(self.myRequest) then
			if self.myRequest.isReleaseType then
				str := str &amp; ' ' &amp; self.myRequest.CM_TIRequest.deliveryNumber;
			endif;
		endif;
		return str;
	endif;
		
	if CM_DeliveryRequest.hasInstance(self.myRequest) then
		delReq := self.myRequest.CM_DeliveryRequest;
		if delReq.clean then
			cln := app.getErrorString(Clean);
		endif;
		if delReq.operatorCode = null 
		and delReq.myOperatorGroup &lt;&gt; null then
			opCode := delReq.myOperatorGroup.code &amp; "'";
		else
			opCode := delReq.operatorCode;
		endif;
		tmpType := delReq.isoType;
		
		//10 May 2010	NDL Par 24064
		if tmpType = null then
			tmpType := delReq.isoGroup;
		endif;
		
		if tmpType = null then
			if delReq.myCargoType &lt;&gt; null then
				tmpType := delReq.myCargoType.description;
			endif;
		endif;
		release := delReq.bulkRelease;
		if release &lt;&gt; null then
			releaseDate := '(' &amp; release.getDisplayStringForAttribute(ETRow_RequestDate, true) &amp; ')';
		endif;
		
		//epr TFS 36605 15/1/17 making it clearing that they are any id and any amount
		if self.isAnyAmount then
			amountString:="?";
		else
			amountString:=self.getMoveAmountDisplay(true);
		endif;
		
		str := amountString &amp; ' ' &amp;
				opCode &amp; ' ' &amp;
				tmpType &amp; ' ' &amp;
				delReq.consigneeCode &amp; ' ' &amp;
				delReq.deliveryNumber &amp; ' ' &amp;
				cln &amp; ' ' &amp;
				releaseDate;	// 30/01/2008 cnwar2 #15525
	endif;

	return str;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTreeDescription_Full" id="9de532c8-0b3d-4b4c-9c37-d6bd59290583">
        <source>getTreeDescription_Full():String;
// ---------------------------------------------------------------------------
// Created:     03 September 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str : String;
begin
	str := self.getTreeDescription;
	
	if self.isReceipt then
		return app.getErrorString1 (XLAT_WLE_TREE_RECEIPT, str);
	endif;
	
	return app.getErrorString1 (XLAT_WLE_TREE_RELEASE, str);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVbsti" id="5586c792-f56f-434c-9b34-b37589169e0e">
        <source>getVbsti() : CM_VehicleBookingTimeSlotItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2024	navpw1	Initial creation JIRA: MTN-14770

*/

vars
	gateEntity	: CMGTE_Entity;
	wleRequest	: CM_Request;
	delReq		: CM_DeliveryRequest;
	
begin
	wleRequest := self.myRequest;
	
	if wleRequest = null then
		return null;
	endif;
	
	if not wleRequest.isDeliveryRequest then
		return null;
	endif;
	
	delReq := wleRequest.CM_DeliveryRequest;
	
	gateEntity := delReq.myGateEntity;
	if gateEntity = null then
		return null;
	endif;
	
	return gateEntity.myVbsti;
	
end;</source>
        <ReturnType type="CM_VehicleBookingTimeSlotItem"/>
    </JadeMethod>
    <JadeMethod name="getVehicleWLELocationID" id="aefaeb4f-f4d3-4f5a-a248-a808e6b5ee9c">
        <source>getVehicleWLELocationID() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 Nov 2010	cnwmh5	Initial creation #26320
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	vehicle		: CM_Vehicle;
	wle			: CM_WorkListEntry;
	locationStr : String;
	pos			: Integer;
begin
	
	vehicle := self.getJobVehicle();
	if vehicle &lt;&gt; null then
		foreach wle in self.job.workListEntries discreteLock do	//06.03.2025 navma1 #MTN-34179
			if wle.isReceipt then
				continue;
			endif;
			pos := pos + 1;
			if self = wle then 
				break;
			endif;
		endforeach;
		if pos &gt; 0 then
			locationStr := vehicle.regNumber &amp; "(" &amp; pos.String &amp; ") "  &amp; TI_TRANSMODE_ROAD_STR;
		endif;
	endif;

	return locationStr;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWagonController" id="85e40455-eb4a-4328-8e3d-133cf38a975b">
        <source>getWagonController():CM_WagonController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2013	cnwndl1	Initial creation	Par 32479

*/

vars

	lc : CM_LocationsController;

begin

	lc := self.getTargetLocation;
	if lc &lt;&gt; null and lc.isWagon then
		return lc.CM_WagonController;
	endif;

	return null;

epilog

end;</source>
        <ReturnType type="CM_WagonController"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrder" id="7c20494f-a10a-45b5-bd11-58b1320d1504">
        <source>getWorkOrder():CM_WorkOrder;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023	navhl20	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
11 Sep 2024 navma1  Bug 65777: EUP | 53729 - Delivery Dispatch Screen - wrong WO info when multiple in one Job
*/

vars
	job 	: CM_Job;
	woJob   : CM_Job;
	wod		: CM_WorkOrderDtl;
	woWle	: CM_WOWLE;
begin
	
	job := self.job;
	
	if job &lt;&gt; null then
		wod := job.myWODtl;
		
		if wod &lt;&gt; null then
			return wod.getMyParent();
		endif;
		
		wod := job.myWorkOrderDtlToDo;
		
		if wod &lt;&gt; null then
			return wod.getMyParent();
		endif;
	endif;
	
	woWle := self.myWorkOrderWLE;
	
	if woWle &lt;&gt; null then
		woJob := woWle.job;
	endif;
	
	if woJob &lt;&gt; null then
		wod := woJob.myWODtl;
	endif;
	
	if wod &lt;&gt; null then
		return wod.getMyParent();
	endif;

	return null;
epilog

end;</source>
        <ReturnType type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrderTIDtl" id="34bf53be-9f1b-4d6b-a863-6b6b8fa7c040">
        <source>getWorkOrderTIDtl() : CM_WorkOrderTIDtl;
// -----------------------------------------------------------------------------
// Created:		27 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 17 Apr 2023 navma1  ChangeRequest 55440:[54990] EUP - Release Cargo Work Order - Enhancement
// -----------------------------------------------------------------------------

vars
	request 	: CM_Request;
	wod	    	: CM_WorkOrderDtl;
	bulkRelease	: CM_BulkRelease;
	
begin
	
	if self.job = null then
		return null;
	endif;

	if  self.job.myWODtl &lt;&gt; null then
		return self.job.myWODtl;
	endif;
	
	request := self.myRequest;
	
	if request &lt;&gt; null then
		bulkRelease := request.myOriginatingBulkRelease;
		if  bulkRelease &lt;&gt; null then
			foreach wod in bulkRelease.allWOReleases do
				
				if wod.CM_WorkOrderTIDtl.allSelectedTIs.includes(self.myTrackedItem) then
					return wod.CM_WorkOrderTIDtl;
				endif;
			endforeach;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_WorkOrderTIDtl"/>
    </JadeMethod>
    <JadeMethod name="getWorkingMachineID" id="372ce9fc-2fe2-4006-8e5f-5aa0f9ef808f">
        <source>getWorkingMachineID() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 Nov 2010	cnwrd1	Initial creation
04 Mar 2025 navma1	MTN - [Performance Issue] - 1081 with multiple gate in/gate out processes running
10 Mar 2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
16 Apr 2025	jlizm1	MTN 34590 Error 1308 building road operations table
*/

vars
	machineID   : String;
	rtqTask     : CM_RTQueueTask;
	rtqEntry    : CM_RTQueueEntry;
	allEntries	: CM_RTQueueEntryArray;
	entryTasks	: CM_RTQueueTaskArray;
	invalid		: Boolean;				// MTN-34024
	isFirst		: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, rtqEntry, invalid);		// MTN-34024
	on Exception do app.handleDeletedObject(exception, rtqTask, invalid);
	
	create allEntries transient;
	self.allRTQueueEntries.copy(allEntries);

	foreach rtqEntry in allEntries discreteLock do	//04.03.2024 navma1	MTN-33569
		
		entryTasks := rtqEntry.allTasks.cloneSelf(true);
		// MTN-34024 handle error 4
		if invalid then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Exception on rtqEntry - handled", LogDEBUG);
			invalid := false;
			continue;
		endif;
		
		foreach rtqTask in entryTasks discreteLock	do
			isFirst := rtqTask.isFirstTask;
			if invalid then
				app.writeLog(method.qualifiedName &amp; Tab &amp; "Exception on rtqEntry - handled", LogDEBUG);
				invalid := false;
				continue;
			endif;
		
			if not isFirst then
				continue;
			endif;
			
			/*  
			// ### TFS 51855 24MAY2022 NAVAB1
			// overwrite the machine if we have one, should end up with the last machine currently working the wle in multimove.
			if rtqTask.getMachineID() &lt;&gt; null then
				machineID := rtqTask.getMachineID();
			endif;				
			NOW */
			
			if rtqTask.myMachine &lt;&gt; null then 	// ### TFS 51855 24MAY2022 NAVAB1
				return rtqTask.myMachine.code; 	// ### TFS 51855 24MAY2022 NAVAB1
			endif;				
			
			machineID := rtqTask.getMachineID(); // ### TFS 51855 24MAY2022 NAVAB1
			if machineID &lt;&gt; null then 			 // ### TFS 51855 24MAY2022 NAVAB1
				return machineID; 				 // ### TFS 51855 24MAY2022 NAVAB1
			endif;
			
		endforeach;
		
		delete entryTasks;
	endforeach;
	
	return machineID;
epilog
	delete entryTasks;
	delete allEntries;
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasNonReviewedAlerts" id="2419ba9b-3eb9-4521-8800-e9ea1c8e470b">
        <source>hasNonReviewedAlerts(_onlyFromHandHelds : Boolean): Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
29 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	result : Boolean;
begin
	result:= inheritMethod(_onlyFromHandHelds);
	if result then
		return result;
	endif;
	
	if self.job &lt;&gt; null then
		result := job.hasNonReviewedAlerts(_onlyFromHandHelds);
	endif;
	
	return result;


epilog

end;</source>
        <Parameter name="_onlyFromHandHelds" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="id" id="040d1f21-3692-4a2e-bff6-a180bc0f19f0">
