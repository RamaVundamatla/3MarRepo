begin
	wagon:="12083.50549".asOid.CM_Wagon;
	ti:="4949.2202215".asOid.CM_TrackedItem;
	release:="2161.1550158".asOid.CM_BulkRelease;
	resDetail:="7753.1667978".asOid.CM_ReserveDetail;
	create validWleSet transient;
	wle:=wagon.getWLEforCargo(ti,resDetail);
	
	write wle;
	//if wle = null then
		wle:= release.getRailWleToAssignTiTo(null,ti);
	//endif;
	if wle &lt;&gt; null then
	write wle;
		write wle.id;
		ti.testAgainstRequest(release.allRequestsBeingActioned.first);
	endif;
	
	create wagons transient;
	release.getAssociatedWagons(wagons,true);
/*	foreach resDetail in release.allReserveDetails discreteLock do
		foreach req in resDetail.allDeliveryRequests discreteLock do
			foreach wle in req.allWorkListEntries discreteLock do
				if wle.status = WLE_COMPLETED then
					continue;
				endif;
				if wle.myTrackedItem = null
				or wle.myTrackedItem.isRRP
				or wle.myTrackedItem = ti
				then
					req := wle.myRequest;
					if req = null then
						continue;
					endif;
			
					if wle.myTrackedItem = ti then
						// if its actually this one, use it
						
						break;
					else
						//otherwise add to the valid set of wles to consider
						validWleSet.addNoDuplicates( wle, false );
					endif;
				endif;
			endforeach;
		endforeach;
	endforeach;
	validWleSet.inspectModal;*/
	

		wagons.inspectModal;
epilog
	delete wagons;
	delete validWleSet;
end;</source>
