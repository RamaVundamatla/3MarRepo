    <JadeMethod name="utlUpdateTaskRemove" id="d9ebaa49-5485-4087-98bd-19bae7ebd575">
        <source>utlUpdateTaskRemove(_rtQueueTask :CM_RTQueueTask input; _passport : CM_Passport input);

// cnwdvb1 14 April 2003 
//31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
vars
	realRTQueueTask		: CM_RTQueueTask;
	expectedEdition		: Integer;
begin

	self.initialiseActivity();

	_rtQueueTask.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	_rtQueueTask.pxyGetRealObjectAndEdition(realRTQueueTask, expectedEdition);
	
	if realRTQueueTask = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_RTQueueTask.name, null, null);
		return;
	endif;

	exclusiveLock(realRTQueueTask);

	if _passport.noErrors and realRTQueueTask.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Task Allocate Machine', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		realRTQueueTask.removeMachine();
	endif;

epilog

end;</source>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTaskSwitchIMV" id="fbecb596-fe4d-44ad-bafa-c5e3b5aa03bd">
        <source>utlUpdateTaskSwitchIMV(pProxyRTQueueTask:CM_RTQueueTask input; _passport : CM_Passport input);
/*
Purpose:			
Parameters:			
Return Value:		

Date			Who		Reason
22 April 2010	cnwrd1	Initial creation  ccms 1124 par 23362
24/11/2010		cnwcs5	par 23714/ccms 1132 - link transaction to switch history
31 Mar 2025 	navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/
vars
	realRTQueueTask	:CM_RTQueueTask;
	expectedEdition	:Integer;
	theTI 			: CM_TrackedItem;
	newMachine,
	oldMachine 		: CM_Machine;
	trx				: CM_Move;		// 24/11/2010 cnwcs5 par 23714/ccms 1132
begin
	self.initialiseActivity();

	pProxyRTQueueTask.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	pProxyRTQueueTask.pxyGetRealObjectAndEdition(realRTQueueTask, expectedEdition);
	
	if realRTQueueTask = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_RTQueueTask.name, null, null);
		return;
	endif;

	exclusiveLock(realRTQueueTask);

	if _passport.noErrors and realRTQueueTask.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Task Allocate Machine', null, null);
		return;
	endif;
	
	theTI 		:= realRTQueueTask.ti;
	oldMachine 	:= realRTQueueTask.machine;
	newMachine 	:= pProxyRTQueueTask.intendedMachine;
	
	if oldMachine = newMachine then
		return;
	endif;
		
	if _passport.noErrors then
		// 	I need to move the TI to the new mashine
		trx := theTI.moveToLocation(newMachine.myMachineController, null, 
				null, null, REAL_MODE, false, true, false, true, false, false, null, null, null, null, null, _passport);	// TFS 2651
	endif;
	
	//and call setMachine on the task
	if _passport.noErrors then
		realRTQueueTask.setMachine(newMachine);
	endif;
	
	if _passport.noErrors then //cnwrd1 par 23997 28.4.2010
		// need to find last move on oldMachine history, and 'move' this to newMachine
		newMachine.amendMoveHistoryForIMVSwitch( oldMachine, theTI, trx);	// 24/11/2010 cnwcs5 par 23714/ccms 1132
	endif;
	

	if _passport.noErrors then
		realRTQueueTask.myEntry.sendNotesForRelatedEntry();
	endif;

epilog

end;</source>
        <Parameter name="pProxyRTQueueTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTaskSwitchJobs" id="83fa73c1-506e-4d3e-9227-bc387f6e6027">
        <updating/>
        <source>utlUpdateTaskSwitchJobs(_theTask : CM_RTQueueTask input; _theWLE : CM_WorkListEntry; _oldJob,_newJob : CM_Job ; _passport : CM_Passport input ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 November 2012	cnwrd1	Initial creation

*/

vars

	oldWLE,
	newWLE			: CM_WorkListEntry;
	oldRequest,
	newRequest		: CM_Request;
	anEntry			: CM_RTQueueEntry;
	lane,
	oldTargetlocn		: CM_LocationsController;
	aTask				: CM_RTQueueTask;
	theTerminal 		: CM_Terminal;
	aCrane 				: CM_Crane;
	aWP					: CM_WorkPoint;
	ta					: CM_TerminalArea;
	theTask				: CM_RTQueueTask;
	anRTQEntry			: CM_RTQueueEntry;
begin
	self.initialiseActivity();
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;
	
	
	theTask := _theTask;
	
	if _theWLE &lt;&gt; null then //cnwrd1 par 34038 rejig for wle
		oldWLE := _theWLE;
		// get the task if we dont have already
		if theTask = null then		
			anRTQEntry := oldWLE.getFirstUncompleteRTEntry;
			
			if anRTQEntry &lt;&gt; null then
				theTask := anRTQEntry.getFirstUncompletedTask;
			endif;			
		endif;
	elseif _theTask &lt;&gt; null then
		oldWLE := theTask.myEntry.myWorkListEntry;
	endif;

	
	if oldWLE = null then
		return;
	endif;
	

	newWLE := _newJob.getNextFreeVoyageWLE();
	
	
	//need to change the job on all the RTQ entries for the wle's
	// change the job on the wle itself
	//change the job on the request
	
	theTerminal  := oldWLE.getTerminalForAlert();

	oldRequest := oldWLE.myRequest;
	newRequest := newWLE.myRequest;
	
	oldWLE.moveToNewRequest(newRequest);

	newWLE.moveToNewRequest(oldRequest);
	
	
	//changes to move planned containers
	//if either ti is queued then we need to requeue and replan
	// if container is planned we need to update that with the new target location.
	
	// now need to fix the target locations  - not changing queues here for now
	
	if _oldJob.myJobSheet.CM_VoyageJobSheet.crane = _newJob.myJobSheet.CM_VoyageJobSheet.crane then
		//same crane/queue nothing else to do
	elseif theTask &lt;&gt; null then
		//need to change crane lane target/queue?		
		oldTargetlocn := theTask.targetLocation;
		lane := null;
		
		aCrane := theTask.myEntry.getJobCrane();
		
		if aCrane &lt;&gt; null then	//have a crane switch lanes
			if aCrane.transferArea &lt;&gt; null then
				lane := aCrane.transferArea.getFirstAvailableLoadLane;
			endif;
		else //assume were using workpoints then
			aWP := _newJob.CM_VoyageJob.getWorkPointObject().CM_WorkPoint;
			
			if aWP &lt;&gt; null then
				ta := aWP.myWorkPointInterchangeArea; //this may not be setup....
			endif;
			
			if ta &lt;&gt; null and ta.isKindOf(CM_InterchangeArea) then
				lane:=ta.CM_InterchangeArea.getDefaultLane;
			endif;
	
		endif;
		
		// basically an amend target location
		if lane &lt;&gt; null and _theTask.status &lt;&gt; TASK_COMPLETE then //if its complete then we dont care here .
			app.myUtilityUA.utlUpdateRTTaskTargetLocation(lane, theTask, null,_passport);
		endif;	
		
	endif;
	
	//send some notes
	app.myEventManager.createSingleObjInfoNoteEvt(oldWLE, theTerminal.getTerminalEvent(WLE_Update_Event), oldWLE);
	app.myEventManager.createSingleObjInfoNoteEvt(newWLE, theTerminal.getTerminalEvent(WLE_Update_Event), newWLE);
	
epilog
end;</source>
        <Parameter name="_theTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_theWLE" type="CM_WorkListEntry"/>
        <Parameter name="_oldJob" type="CM_Job"/>
        <Parameter name="_newJob" type="CM_Job"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTaxCode" id="86ba1f40-f966-4b6b-ad4a-5ef89ad353ef">
        <source>utlUpdateTaxCode(_pxyTaxCode : CM_TaxCode; _passport : CM_Passport input);
//---------------------------------------
// Created: 18 May 2006 By: cnwgd1
//---------------------------------------
vars

	expectedEdition	: Integer;
