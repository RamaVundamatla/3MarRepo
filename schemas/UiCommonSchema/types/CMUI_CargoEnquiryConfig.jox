    <JadeMethod name="checkForDuplicates" id="ee96daf2-a2e1-46da-b3ea-b4b38ffbd3d4">
        <source>checkForDuplicates(_newName : String; _tab :CM_UserConfigTab) : Boolean;
// called from CMUI_CargoEnqConfigEditTab for add and rename to check if the new name is already used by a tab
vars
	isOK	: Boolean;
	uctab	: CM_UserConfigTab;
begin
	isOK := true;
	// hard-code clash with any non-user tabs
	if _newName = "Tranship" then
		return false;
	endif;
	foreach uctab in self.myProxyUserCargoType.allUserConfigTabs do
		if uctab.description = _newName and
		   uctab &lt;&gt; _tab then
			isOK := false;
			break;
		endif;
	endforeach;

	return isOK;
end;
</source>
        <Parameter name="_newName" type="String"/>
        <Parameter name="_tab" type="CM_UserConfigTab"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
