    <JadeMethod name="selectTargetArea" id="43a5b2f9-a664-4aee-8dcf-d409b89771c6">
        <updating/>
        <source>selectTargetArea( _locationsController : CM_LocationsController ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2016	cnwndl1	Initial creation	TFS 1484

*/

vars

	
	reserveDetail : CM_ReserveDetail;
	showDocActions : Boolean;

begin

	reserveDetail := self.getReserveDetail();
	if reserveDetail &lt;&gt; null and reserveDetail.myReserveDetailActions &lt;&gt; null then
		showDocActions := reserveDetail.myReserveDetailActions.hasActions();
	endif;

	self.myTargetLocation := _locationsController;

	if self.myTargetLocation = null then
		self.lblTotals.caption := null;
		self.btnStageAll.visible := false;
		self.btnDocActions.visible := false; //20 Sep 2016	NDL	TFS 2647 / 2001
	else
		self.lblTotals.caption := self.myTargetLocation.getFullId;
		self.btnStageAll.visible := true;
		self.btnDocActions.visible := showDocActions; //21 Sep 2016	NDL	TFS 2647 / 2001
		self.cmbTargetArea.parent := self.shtAvailable;
	endif;
	
	if _locationsController &lt;&gt; self.myMobileGenericAgent.myYardLocation then
		 self.myMobileGenericAgent.setMyYardLocation( _locationsController );
		 self.warnedMultiRel := false;	//05 May 2016	NDL	TFS 1936
		 self.warnedNoPrimArea := false;	//05 May 2016	NDL	TFS 1936
	endif;

epilog

end;</source>
        <Parameter name="_locationsController" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setSelectableOrder" id="757fed64-026d-427d-8806-34d1e8f7fbac">
        <source>setSelectableOrder( _tiSet : CM_TISet input; _tiArray : CM_TIArray input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation

*/

vars

	dynaDict : DynaDictionary;

begin

	if _tiSet.isEmpty then
		return;
	endif;

	create dynaDict transient;
	dynaDict.setMembership( CM_TrackedItem );
	dynaDict.addMemberKey( "id", false, true );
	dynaDict.endKeys(true);
	
	_tiSet.copy( dynaDict );
	
	dynaDict.copy( _tiArray );

epilog

	delete dynaDict;

end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupAvailable" id="718ee6de-f94b-457a-8845-4a6da9a1bae4">
        <updating/>
        <source>setupAvailable( _reserveDetail : CM_ReserveDetail ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation

*/

constants

	TAB_INDEX_START = 1000;
	
vars

	reserveDetail : CM_ReserveDetail;
	index : Integer;

	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	tiSet : CM_TISet;
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	size : Integer;
	buttonCaption : String;
	visibleButtons : Boolean;
	buttonHeight : Integer;
	resDetString : String;
	isQueued : Boolean;
	tiTotalCount : Integer;
	firstStagingLC : CM_LocationsController;
	workingTiSet : CM_TISet;
	lc : CM_LocationsController;
	chgColour : Boolean;
	locSumm : String;
	stwComplete : Boolean;
	
begin

	if self.availableCount &gt; 0 then
		foreach buttonNumber in 1 to self.availableCount do
			menuButton := self.btnAvailTemp.getControl( buttonNumber ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.visible := false;
				delete menuButton;
			endif;
		endforeach;
		self.availableCount := 0;
		buttonNumber := 0;
	endif;

	if self.myBulkRelease = null then
		//nothing to do but clear the fileds etc.
	else
		self.cmbRelItems.clear();
		foreach reserveDetail in self.myBulkRelease.allReserveDetails do
			index := self.cmbRelItems.addItem( reserveDetail.getStwHandHeldCmbDetails( chgColour ) );
			self.cmbRelItems.itemObject[index] := reserveDetail;
			if chgColour then
				self.cmbRelItems.itemBackColor[index] := LightGray;
			endif;
		endforeach;
		if self.myBulkRelease.isPackingType then	//08 Dec 2015	NDL	Par 37288
			foreach reserveDetail in self.myBulkRelease.allReservePackingChildren do
				index := self.cmbRelItems.addItem( reserveDetail.getStwHandHeldCmbDetails( chgColour ) );
				self.cmbRelItems.itemObject[index] := reserveDetail;
				if chgColour then
					self.cmbRelItems.itemBackColor[index] := LightGray;
				endif;
			endforeach;
		endif;
		if _reserveDetail &lt;&gt; null then
			self.cmbRelItems.listIndex := self.cmbRelItems.findObject( _reserveDetail );
			resDetString := _reserveDetail.getStwHandHeldDetails( stwComplete );
			
			//13 Dec 2016	NDL	TFS 3037/2369
			create tiSet transient;
			self.getSelectableCargoReleaseSTW( tiSet, self.myBulkRelease, _reserveDetail, firstStagingLC );
			locSumm := self.getLocationSummary( tiSet );
			delete tiSet;
			resDetString := resDetString &amp; " " &amp; locSumm;
			
		else
			if self.cmbRelItems.listCount &gt; 1 then
				self.cmbRelItems.addItemAt( "&lt;" &amp; app.getErrorString(Please_select_release_item) &amp; "&gt;", 1 );
				self.cmbRelItems.listIndex := 1;
			endif;
		endif;
	endif;
	
	self.txtReserveDesc.text := resDetString;
	
	create tiSet transient;
	create workingTiSet transient;
	
	self.getSelectableCargoReleaseSTW( workingTiSet, self.myBulkRelease, _reserveDetail, firstStagingLC );
	
	//filter out those that are on a machine.	//06 Apr 2016	NDL	TFS 1667
	foreach ti in workingTiSet do
		lc := ti.myPrimaryActualLocation;
		if lc = null or lc.isMachineController then
			continue;
		endif;
		tiSet.add(ti);
	endforeach;
	
	
	size := tiSet.size;	
	create tiArray transient;
	self.setSelectableOrder( tiSet, tiArray );
	
	buttonHeight := self.getScrollingButtonHeight();
	self.btnAvailTemp.height := buttonHeight;
	buttonWidth := self.getButtonWidthSetScrollBar( size, self.frmAvailable, self.btnAvailTemp.height, self.scrAvailable );

	foreach ti in tiArray do
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnAvailTemp.getControl( buttonNumber ).MOB_Button;
		if menuButton = null then
			menuButton := self.btnAvailTemp.loadControl( buttonNumber ).MOB_Button;
		endif;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" 
										&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		//elseif ti.isBulkByWeight and ti.isBulkByVolume then
		elseif ( ti.isBulkByWeight or ti.isBulkByVolume ) then	//10 dec 2015	NDL	Par 37288
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")" 
										&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, " " ); //30 May 2017	NDL	TFS 4587
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
		visibleButtons := true;
		
		tiTotalCount := tiTotalCount + ti.totalQuantity.max(1);
		
	endforeach;
	
	
	self.availableCount := buttonNumber;
	self.shtAvailable.caption := self.availableHeading &amp; " (" &amp; tiTotalCount.String &amp; ")";
	
	self.btnAvailTemp.visible := false;
	self.frmAvailable.caption := null;
	
	self.lblNoAvailable.visible := not visibleButtons;

epilog

	delete tiArray;
	delete tiSet;
	delete workingTiSet;

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="6576f752-fe2f-44f8-83ee-2f15d5c2eb32">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation

*/

vars

	sheetName : String;
	resDetail : CM_ReserveDetail;

begin

//	if self.myBulkRelease.allReserveDetails.size = 1 and self.myBulkRelease.isRoadType then
	if self.myBulkRelease.allReserveDetails.size = 1 and ( self.myBulkRelease.isRoadType or self.myBulkRelease.isShipType or self.myBulkRelease.isRailType ) then
		self.setupAvailable( self.myBulkRelease.allReserveDetails.first );
		self.setupStaged( self.myBulkRelease.allReserveDetails.first );
		self.setupSelected( self.myBulkRelease.allReserveDetails.first );
	elseif self.myMobileGenericAgent.myReserveSelection &lt;&gt; null then
		self.cmbRelItems.listIndex := self.cmbRelItems.findObject(self.myMobileGenericAgent.myReserveSelection);
		self.setupAvailable( self.myMobileGenericAgent.myReserveSelection );
		self.setupStaged( self.myMobileGenericAgent.myReserveSelection );
		self.setupSelected( self.myMobileGenericAgent.myReserveSelection );
	elseif not self.myMobileGenericAgent.allReserveDetails.isEmpty then
		resDetail := self.myMobileGenericAgent.allReserveDetails.first;
		self.myMobileGenericAgent.setAllReserveDetails(null);
		self.cmbRelItems.listIndex := self.cmbRelItems.findObject(resDetail);
		self.setupAvailable( resDetail );
		self.setupStaged( resDetail );
		self.setupSelected( resDetail );
	else
		self.setupAvailable( null );
		self.setupStaged( null );
		self.setupSelected( null );
	endif;
	
	self.doResizeControls(true);
	
	self.txtCargoId.setFocus();	//19 Apr 2016	NDL	TFS 1868
	
	//21 Sep 2016	NDL	TFS 2647
	sheetName := self.myMobileGenericAgent.stringField1;
	if sheetName &lt;&gt; null then
		self.myMobileGenericAgent.setMyReserveDetail(null);
		self.myMobileGenericAgent.setPackContainerDetails(null, null, null, null, null);
		self.myMobileGenericAgent.setStringField1( null );
		if sheetName = self.shtSelected.name then
			self.fldCargo.querySheetChg(self.fldCargo,self.shtSelected);
			self.fldCargo.topSheet := self.shtSelected;
		elseif sheetName = self.shtStaged.name then
			self.fldCargo.querySheetChg(self.fldCargo,self.shtStaged);
			self.fldCargo.topSheet := self.shtStaged;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7852459a-df3f-45c6-8214-358788051d5e">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;	
	self.myBulkRelease := self.myMobileGenericAgent.myBulkRelease;
	self.myMachine := self.myMobileGenericAgent.myMachine;	//06 Apr 2016	NDL	TFS 1667
	self.selectTargetArea( self.myMobileGenericAgent.myYardLocation );
	
	inheritMethod();
	
	self.availableHeading := self.shtAvailable.caption;
	self.selectedHeading := self.shtSelected.caption;
	self.stagedHeading := self.shtStaged.caption;
	
	self.setupCmdButtons( 1, app.getErrorString(Back), null, null, null, null );
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupSelected" id="467a8b42-63cd-4ea9-94a7-03d56b7880a7">
        <updating/>
        <source>setupSelected( _reserveDetail : CM_ReserveDetail )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2016	cnwndl1	Initial creation	TFS 1667

*/

constants

	TAB_INDEX_START = 1000;
	
vars

	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	size : Integer;
	buttonCaption : String;
	futureMove : CM_FutureMove;
	location : String;
	buttonHeight : Integer;
	reason : String;
	cargoGroupId : String;
	tiTotalCount : Integer;
	docActions : CM_DocumentActions;
	docActionsSet : CM_DocumentActionsSet;
	taskAndStopStr : String;
	reserveDetail : CM_ReserveDetail;
	
begin

	create docActionsSet transient;

	if self.selectedCount &gt; 0 then
		foreach buttonNumber in 1 to self.selectedCount do
			menuButton := self.btnSelectedTemp.getControl( buttonNumber ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.visible := false;
				delete menuButton;
			endif;
		endforeach;
		self.selectedCount := 0;
		buttonNumber := 0;
	endif;
	
	if self.myBulkRelease &lt;&gt; null then
		foreach reserveDetail in self.myBulkRelease.allReserveDetails do
			docActions := reserveDetail.myReserveDetailActions;
			if docActions &lt;&gt; null then
				docActionsSet.add(docActions);
			endif;
		endforeach;
		//27 Jan 2017	NDL	TFS 3157
		foreach reserveDetail in self.myBulkRelease.allReservePackingChildren do
			docActions := reserveDetail.myReserveDetailActions;
			if docActions &lt;&gt; null then
				docActionsSet.add(docActions);
			endif;
		endforeach;
	endif;
	
	create tiArray transient;
	self.myMachine.myMachineController.allTrackedItems.copy(tiArray);
	size := tiArray.size;	

	buttonHeight := self.getScrollingButtonHeight();
	self.btnSelectedTemp.height := buttonHeight;
	buttonWidth := self.getButtonWidthSetScrollBar( size, self.frmSelected, self.btnSelectedTemp.height, self.scrSelected );

	foreach ti in tiArray do
		
		cargoGroupId := null;
		if ti.myCargoGroup &lt;&gt; null then
			cargoGroupId := ti.myCargoGroup.id;
		endif;
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnSelectedTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		if cargoGroupId &lt;&gt; null then
			location := CrLf &amp; ti.myPrimaryActualLocation.getFullId &amp; ", " &amp; cargoGroupId;
		else
			location := CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		endif;
		
		foreach docActions in docActionsSet do
			taskAndStopStr := docActions.getTaskAndStopStrForTi(ti,true);
			if taskAndStopStr &lt;&gt; null then
				location := location &amp; " " &amp; taskAndStopStr;
				break;
			endif;
		endforeach;
		
		if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" 
										&amp; location;
		elseif ( ti.isBulkByWeight or ti.isBulkByVolume ) then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")" 
										&amp; location;
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; location;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, null ); //30 May 2017	NDL	TFS 4587
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
		tiTotalCount := tiTotalCount + ti.totalQuantity.max(1);
		
	endforeach;
	
	self.selectedCount := buttonNumber;
	self.shtSelected.caption := self.selectedHeading &amp; " (" &amp; tiTotalCount.String &amp; ")";
	
	
	self.btnSelectedTemp.visible := false;
	self.frmSelected.caption := null;
	
	self.lblNoSelected.visible := self.selectedCount &lt; 1;
	
	
epilog

	delete tiArray;
	delete docActionsSet;
	
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="setupStaged" id="99ba6966-6edf-4b91-8e13-eaa1033b20e1">
        <updating/>
        <source>setupStaged( _reserveDetail : CM_ReserveDetail )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

constants

	TAB_INDEX_START = 1000;
	
vars

	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	size : Integer;
	buttonCaption : String;
	futureMove : CM_FutureMove;
	location : String;
	buttonHeight : Integer;
	reason : String;
	cargoGroupId : String;
	tiTotalCount : Integer;
	docActions : CM_DocumentActions;
	taskAndStopStr : String;
	docActionsSet : CM_DocumentActionsSet;
	reserveDetail : CM_ReserveDetail;
	
begin

	create docActionsSet transient;

	if self.stagedCount &gt; 0 then
		foreach buttonNumber in 1 to self.stagedCount do
			menuButton := self.btnStagedTemp.getControl( buttonNumber ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.visible := false;
				delete menuButton;
			endif;
		endforeach;
		self.stagedCount := 0;
		buttonNumber := 0;
	endif;

	create tiArray transient;
	foreach ti in self.myBulkRelease.allTrackedItemsAssigned do
		if _reserveDetail = null then
			continue;
		endif;
		//if not _reserveDetail.allTrackedItems.includes(ti) then
		if not _reserveDetail.includeTrackedItem(ti, false) then //23/06/2023	navkc1	CR 58406 Task 58408
			continue;
		endif;
		if ti.isStagedFor( self.myBulkRelease ) then
			if _reserveDetail.isKindOf( CM_ReserveSelection ) then
				tiArray.addExclusive( ti );
			elseif _reserveDetail.isKindOf( CM_ReserveTI ) then
				if _reserveDetail.CM_ReserveTI.getTI = ti then
					tiArray.addExclusive( ti );
				endif;
			endif;
		endif;
	endforeach;
	
	if self.myBulkRelease &lt;&gt; null then
		foreach reserveDetail in self.myBulkRelease.allReserveDetails do
			docActions := reserveDetail.myReserveDetailActions;
			if docActions &lt;&gt; null then
				docActionsSet.add(docActions);
			endif;
		endforeach;
		//27 Jan 2017	NDL	TFS 3157
		foreach reserveDetail in self.myBulkRelease.allReservePackingChildren do
			docActions := reserveDetail.myReserveDetailActions;
			if docActions &lt;&gt; null then
				docActionsSet.add(docActions);
			endif;
		endforeach;
	endif;
	
	size := tiArray.size;	

	buttonHeight := self.getScrollingButtonHeight();
	self.btnStagedTemp.height := buttonHeight;
	buttonWidth := self.getButtonWidthSetScrollBar( size, self.frmStaged, self.btnStagedTemp.height, self.scrStaged );

	foreach ti in tiArray do
		
		cargoGroupId := null;
		if ti.myCargoGroup &lt;&gt; null then
			cargoGroupId := ti.myCargoGroup.id;
		endif;
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnStagedTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		if cargoGroupId &lt;&gt; null then
			location := CrLf &amp; ti.myPrimaryActualLocation.getFullId &amp; ", " &amp; cargoGroupId;
		else
			location := CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		endif;
		
		foreach docActions in docActionsSet do
			taskAndStopStr := docActions.getTaskAndStopStrForTi(ti,true);
			if taskAndStopStr &lt;&gt; null then
				location := location &amp; " " &amp; taskAndStopStr;
				break;
			endif;
		endforeach;
		
		if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" 
										&amp; location;
	//	elseif ti.isBulkByWeight and ti.isBulkByVolume then
		elseif ( ti.isBulkByWeight or ti.isBulkByVolume ) then	//10 dec 2015	NDL	Par 37288
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")" 
										&amp; location;
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; location;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, null ); //30 May 2017	NDL	TFS 4587
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
		tiTotalCount := tiTotalCount + ti.totalQuantity.max(1);
		
	endforeach;
	
	self.stagedCount := buttonNumber;
	self.shtStaged.caption := self.stagedHeading &amp; " (" &amp; tiTotalCount.String &amp; ")";
	
	
	self.btnStagedTemp.visible := false;
	self.frmStaged.caption := null;
	
	self.lblNoStaged.visible := self.stagedCount &lt; 1;
	
	
epilog

	delete tiArray;
	delete docActionsSet;
	
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b5a93bbb-2a43-46d8-bab2-3caf1fae6f8c">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:49:43.
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021203, locale);
	btnAvailTemp.translateCaption(Xlat_0021204, locale);
	btnDocActions.translateCaption(Xlat_0021437, locale);
	btnSelectedTemp.translateCaption(Xlat_0021205, locale);
	btnStageAll.translateCaption(Xlat_0021206, locale);
	btnStagedTemp.translateCaption(Xlat_0021207, locale);
	frmAvailable.translateCaption(Xlat_0021208, locale);
	frmSelected.translateCaption(Xlat_0021209, locale);
	frmStaged.translateCaption(Xlat_0021210, locale);
	lblNoAvailable.translateCaption(Xlat_0021211, locale);
	lblNoSelected.translateCaption(Xlat_0021212, locale);
	lblNoStaged.translateCaption(Xlat_0021213, locale);
	lblTotals.translateCaption(Xlat_0021001, locale);
	shtAvailable.translateCaption(Xlat_0021215, locale);
	shtSelected.translateCaption(Xlat_0021216, locale);
	shtStaged.translateCaption(Xlat_0021217, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_change" id="f6537be7-5bdf-4bb7-b390-7c9b817a7451">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_change(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation

*/

vars

begin

	self.convertCargoIdForSearch(	self.txtCargoId.text.toUpper,	//_rawId: String;
									0,	//_cargoType : Integer;
									0,	//_imex : Integer;
									null,	//_voyage : CM_Voyage;
									self.convertedCargoId,	//_convertedCargoId: String output;
									self.convertedAltId	//_convertedAltId: String output
									);
//	self.txtCargoId.text := self.convertedCargoId;
	self.txtCargoId.text := self.convertedAltId;	//08 Aug 2016	NDL	TFS 2567 - Is used for both cargo id and alternate id, don't truncate to 20
	
	self.findCargoInList();

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
