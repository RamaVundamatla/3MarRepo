<Class name="WS_Photo" id="adfb7f9f-0f13-4ec1-afc0-1d94a5356855">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="cargoId" id="729d4227-f970-4985-a002-97126592400b">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>The cargo id of the cargo you are adding the photo to. Maximum length is 30 characters.</text>
    </PrimAttribute>
    <PrimAttribute name="cargoType" id="61815709-f85d-4707-8f37-e2afe65235d0">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>The cargo type abbreviation of the cargo you are adding the photo to. Maximum length is 30 characters.</text>
    </PrimAttribute>
    <PrimAttribute name="description" id="36f388cf-21dc-49ac-bcf4-a2da7a9ca28f">
        <length>121</length>
        <embedded/>
        <type name="String"/>
        <text>The description saved against the photo. Maximum length is 120 characters</text>
    </PrimAttribute>
    <PrimAttribute name="photoBytes" id="9e4238e1-c3ae-4ee4-b9ac-5c8c4846fc9c">
        <type name="Binary"/>
        <text>The binary representation of the photo.</text>
    </PrimAttribute>
    <PrimAttribute name="voyage" id="2b90891a-411b-4573-b84a-7be1d677470c">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>The voyage code for the cargo. Maximum length is 30 characters.</text>
    </PrimAttribute>
</Class>
