	elseif pErrorCode = 13872 then
		errorMessage	:=	"Invalid hash size.";
	elseif pErrorCode = 13873 then
		errorMessage	:=	"Invalid encryption algorithm.";
	elseif pErrorCode = 13874 then
		errorMessage	:=	"Invalid authentication algorithm.";
	elseif pErrorCode = 13875 then
		errorMessage	:=	"Invalid certificate signature.";
	elseif pErrorCode = 13876 then
		errorMessage	:=	"Load failed.";
	elseif pErrorCode = 13877 then
		errorMessage	:=	"Deleted via RPC call.";
	elseif pErrorCode = 13878 then
		errorMessage	:=	"Temporary state created to perform reinit. This is not a real failure.";
	elseif pErrorCode = 13879 then
		errorMessage	:=	"The lifetime value received in the Responder Lifetime Notify is below the Windows 2000 configured minimum value. Please fix the policy on the peer machine.";
	elseif pErrorCode = 13881 then
		errorMessage	:=	"Key length in certificate is too small for configured security requirements.";
	elseif pErrorCode = 13882 then
		errorMessage	:=	"Max number of established MM SAs to peer exceeded.";
	elseif pErrorCode = 13883 then
		errorMessage	:=	"IKE received a policy that disables negotiation.";
	elseif pErrorCode = 13884 then
		errorMessage	:=	"ERROR_IPSEC_IKE_NEG_STATUS_END";
	elseif pErrorCode = 14000 then
		errorMessage	:=	"The requested section was not present in the activation context.";
	elseif pErrorCode = 14001 then
		errorMessage	:=	"This application has failed to start because the application configuration is incorrect. Reinstalling the application may fix this problem.";
	elseif pErrorCode = 14002 then
		errorMessage	:=	"The application binding data format is invalid.";
	elseif pErrorCode = 14003 then
		errorMessage	:=	"The referenced assembly is not installed on your system.";
	elseif pErrorCode = 14004 then
		errorMessage	:=	"The manifest file does not begin with the required tag and format information.";
	elseif pErrorCode = 14005 then
		errorMessage	:=	"The manifest file contains one or more syntax errors.";
	elseif pErrorCode = 14006 then
		errorMessage	:=	"The application attempted to activate a disabled activation context.";
	elseif pErrorCode = 14007 then
		errorMessage	:=	"The requested lookup key was not found in any active activation context.";
	elseif pErrorCode = 14008 then
		errorMessage	:=	"A component version required by the application conflicts with another component version already active.";
	elseif pErrorCode = 14009 then
		errorMessage	:=	"The type requested activation context section does not match the query API used.";
	elseif pErrorCode = 14010 then
		errorMessage	:=	"Lack of system resources has required isolated activation to be disabled for the current thread of execution.";
	elseif pErrorCode = 14011 then
		errorMessage	:=	"An attempt to set the process default activation context failed because the process default activation context was already set.";
	elseif pErrorCode = 14012 then
		errorMessage	:=	"The encoding group identifier specified is not recognized.";
	elseif pErrorCode = 14013 then
		errorMessage	:=	"The encoding requested is not recognized.";
	elseif pErrorCode = 14014 then
		errorMessage	:=	"The manifest contains a reference to an invalid URI.";
	elseif pErrorCode = 14015 then
		errorMessage	:=	"The application manifest contains a reference to a dependent assembly which is not installed.";
	elseif pErrorCode = 14016 then
		errorMessage	:=	"The manifest for an assembly used by the application has a reference to a dependent assembly which is not installed.";
	elseif pErrorCode = 14017 then
		errorMessage	:=	"The manifest contains an attribute for the assembly identity which is not valid.";
	elseif pErrorCode = 14018 then
		errorMessage	:=	"The manifest is missing the required default namespace specification on the assembly element.";
	elseif pErrorCode = 14019 then
		errorMessage	:=	"The manifest has a default namespace specified on the assembly element but its value is not " &amp; CNEC_DOUBLE_QUOTE &amp; "urn:schemas-microsoft-com:asm.v1" &amp; CNEC_DOUBLE_QUOTE &amp; ".";
	elseif pErrorCode = 14020 then
		errorMessage	:=	"The private manifest probe has crossed the reparse-point-associated path.";
	elseif pErrorCode = 14021 then
		errorMessage	:=	"Two or more components referenced directly or indirectly by the application manifest have files by the same name.";
	elseif pErrorCode = 14022 then
		errorMessage	:=	"Two or more components referenced directly or indirectly by the application manifest have window classes with the same name.";
	elseif pErrorCode = 14023 then
		errorMessage	:=	"Two or more components referenced directly or indirectly by the application manifest have the same COM server CLSIDs.";
	elseif pErrorCode = 14024 then
		errorMessage	:=	"Two or more components referenced directly or indirectly by the application manifest have proxies for the same COM interface IIDs.";
	elseif pErrorCode = 14025 then
		errorMessage	:=	"Two or more components referenced directly or indirectly by the application manifest have the same COM type library TLBIDs.";
	elseif pErrorCode = 14026 then
		errorMessage	:=	"Two or more components referenced directly or indirectly by the application manifest have the same COM ProgIDs.";
	elseif pErrorCode = 14027 then
		errorMessage	:=	"Two or more components referenced directly or indirectly by the application manifest are different versions of the same component which is not permitted.";
	elseif pErrorCode = 14028 then
		errorMessage	:=	"A component's file does not match the verification information present in the component manifest.";
	elseif pErrorCode = 14029 then
		errorMessage	:=	"The policy manifest contains one or more syntax errors.";
	elseif pErrorCode = 14030 then
		errorMessage	:=	"Manifest Parse Error : A string literal was expected, but no opening quote character was found.";
	elseif pErrorCode = 14031 then
		errorMessage	:=	"Manifest Parse Error : Incorrect syntax was used in a comment.";
	elseif pErrorCode = 14032 then
		errorMessage	:=	"Manifest Parse Error : A name was started with an invalid character.";
	elseif pErrorCode = 14033 then
		errorMessage	:=	"Manifest Parse Error : A name contained an invalid character.";
	elseif pErrorCode = 14034 then
		errorMessage	:=	"Manifest Parse Error : A string literal contained an invalid character.";
	elseif pErrorCode = 14035 then
		errorMessage	:=	"Manifest Parse Error : Invalid syntax for an XML declaration.";
	elseif pErrorCode = 14036 then
		errorMessage	:=	"Manifest Parse Error : An invalid character was found in text content.";
	elseif pErrorCode = 14037 then
		errorMessage	:=	"Manifest Parse Error : Required white space was missing.";
	elseif pErrorCode = 14038 then
		errorMessage	:=	"Manifest Parse Error : The character '&gt;' was expected.";
	elseif pErrorCode = 14039 then
		errorMessage	:=	"Manifest Parse Error : A semi colon character was expected.";
	elseif pErrorCode = 14040 then
		errorMessage	:=	"Manifest Parse Error : Unbalanced parentheses.";
	elseif pErrorCode = 14041 then
		errorMessage	:=	"Manifest Parse Error : Internal error.";
	elseif pErrorCode = 14042 then
		errorMessage	:=	"Manifest Parse Error : White space is not allowed at this location.";
	elseif pErrorCode = 14043 then
		errorMessage	:=	"Manifest Parse Error : End of file reached in invalid state for current encoding.";
	elseif pErrorCode = 14044 then
		errorMessage	:=	"Manifest Parse Error : Missing parenthesis.";
	elseif pErrorCode = 14045 then
		errorMessage	:=	"Manifest Parse Error : A single or double closing quote character (\' or \" &amp; CNEC_DOUBLE_QUOTE &amp; ") is missing.";
	elseif pErrorCode = 14046 then
		errorMessage	:=	"Manifest Parse Error : Multiple colons are not allowed in a name.";
	elseif pErrorCode = 14047 then
		errorMessage	:=	"Manifest Parse Error : Invalid character for decimal digit.";
	elseif pErrorCode = 14048 then
		errorMessage	:=	"Manifest Parse Error : Invalid character for hexadecimal digit.";
	elseif pErrorCode = 14049 then
		errorMessage	:=	"Manifest Parse Error : Invalid Unicode character value for this platform.";
	elseif pErrorCode = 14050 then
		errorMessage	:=	"Manifest Parse Error : Expecting white space or '?'.";
	elseif pErrorCode = 14051 then
		errorMessage	:=	"Manifest Parse Error : End tag was not expected at this location.";
	elseif pErrorCode = 14052 then
		errorMessage	:=	"Manifest Parse Error : The following tags were not closed: %1.";
	elseif pErrorCode = 14053 then
		errorMessage	:=	"Manifest Parse Error : Duplicate attribute.";
	elseif pErrorCode = 14054 then
		errorMessage	:=	"Manifest Parse Error : Only one top level element is allowed in an XML document.";
	elseif pErrorCode = 14055 then
		errorMessage	:=	"Manifest Parse Error : Invalid at the top level of the document.";
	elseif pErrorCode = 14056 then
		errorMessage	:=	"Manifest Parse Error : Invalid XML declaration.";
	elseif pErrorCode = 14057 then
		errorMessage	:=	"Manifest Parse Error : XML document must have a top level element.";
	elseif pErrorCode = 14058 then
		errorMessage	:=	"Manifest Parse Error : Unexpected end of file.";
	elseif pErrorCode = 14059 then
		errorMessage	:=	"Manifest Parse Error : Parameter entities cannot be used inside markup declarations in an internal subset.";
	elseif pErrorCode = 14060 then
		errorMessage	:=	"Manifest Parse Error : Element was not closed.";
	elseif pErrorCode = 14061 then
		errorMessage	:=	"Manifest Parse Error : End element was missing the character '&gt;'.";
	elseif pErrorCode = 14062 then
		errorMessage	:=	"Manifest Parse Error : A string literal was not closed.";
	elseif pErrorCode = 14063 then
		errorMessage	:=	"Manifest Parse Error : A comment was not closed.";
	elseif pErrorCode = 14064 then
		errorMessage	:=	"Manifest Parse Error : A declaration was not closed.";
	elseif pErrorCode = 14065 then
		errorMessage	:=	"Manifest Parse Error : A CDATA section was not closed.";
	elseif pErrorCode = 14066 then
		errorMessage	:=	"Manifest Parse Error : The namespace prefix is not allowed to start with the reserved string " &amp; CNEC_DOUBLE_QUOTE &amp; "xml" &amp; CNEC_DOUBLE_QUOTE &amp; ".";
	elseif pErrorCode = 14067 then
		errorMessage	:=	"Manifest Parse Error : System does not support the specified encoding.";
	elseif pErrorCode = 14068 then
		errorMessage	:=	"Manifest Parse Error : Switch from current encoding to specified encoding not supported.";
	elseif pErrorCode = 14069 then
		errorMessage	:=	"Manifest Parse Error : The name 'xml' is reserved and must be lower case.";
	elseif pErrorCode = 14070 then
		errorMessage	:=	"Manifest Parse Error : The standalone attribute must have the value 'yes' or 'no'.";
	elseif pErrorCode = 14071 then
		errorMessage	:=	"Manifest Parse Error : The standalone attribute cannot be used in external entities.";
	elseif pErrorCode = 14072 then
		errorMessage	:=	"Manifest Parse Error : Invalid version number.";
	elseif pErrorCode = 14073 then
		errorMessage	:=	"Manifest Parse Error : Missing equals sign between attribute and attribute value.";
	elseif pErrorCode = 14074 then
		errorMessage	:=	"Assembly Protection Error: Unable to recover the specified assembly.";
	elseif pErrorCode = 14075 then
		errorMessage	:=	"Assembly Protection Error: The public key for an assembly was too short to be allowed.";
	elseif pErrorCode = 14076 then
		errorMessage	:=	"Assembly Protection Error: The catalog for an assembly is not valid, or does not match the assembly's manifest.";
	elseif pErrorCode = 14077 then
		errorMessage	:=	"An HRESULT could not be translated to a corresponding Win32 error code.";
	elseif pErrorCode = 14078 then
		errorMessage	:=	"Assembly Protection Error: The catalog for an assembly is missing.";
	elseif pErrorCode = 14079 then
		errorMessage	:=	"The supplied assembly identity is missing one or more attributes which must be present in this context.";
	elseif pErrorCode = 14080 then
		errorMessage	:=	"The supplied assembly identity has one or more attribute names that contain characters not permitted in XML names.";
	endif;
epilog
	return errorMessage;
end;</source>
        <Parameter name="pErrorCode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnwndl1_Test_MsgBox" id="fd1ccc6c-0fda-450d-b46c-2ba7f19209d4">
        <source>cnwndl1_Test_MsgBox();

vars

begin
	app.initialize();
	
	app.msgBox("Textual content of the message for test purpses only!!! Via the CnEcMsgBoxForm", "Message Box heading", -5);
	
	app.msgBox("Textual content of the message for test purpses only!!! Via the normal method", "Message Box heading", MsgBox_Retry_Cancel);
	
	app.finalize();
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwndl1_Test_Spell_Check" id="e46ec459-e0e2-4820-93ce-3ff45513c0ea">
        <source>cnwndl1_Test_Spell_Check();

vars
	spellCheck	: CnEcSpellCheck;
	prose		: String;
	
begin
	app.initialize();
	app.cnEcSetBaseRoot(true);
	
	prose := "The quick brown, fugly, fox jumps over the lazy dog. --    The quick ugly brown fox jumps over the laxy dog.";
	//prose := "big brown bastard bruce beast barrow bilge biscuit bull beef basket";
	
	create spellCheck transient;
	write spellCheck.checkProse(prose);
epilog
	delete spellCheck;
	app.finalize();
end;</source>
    </JadeMethod>
