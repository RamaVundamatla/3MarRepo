    <JadeMethod name="buildCmbOperator" id="d382be7b-fa68-410b-926d-677f5245f943">
        <source>buildCmbOperator();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Nov 2023 navlc30 ChangeRequest 61256: EUP | FR | 54329 | VBS - Pending issues - Issue 12

*/
constants
	AnyStringIndex : Integer = 1;
vars
	operator	:	CM_Operator;
begin
	self.cmbOperator.clear;
	self.cmbOperator.addItemWithData(Any_String, AnyStringIndex);
	foreach operator in app.myRoot.allOperators do
		if operator &lt;&gt; null then
			self.cmbOperator.addItemObject(operator.code &amp; Tab &amp; operator.description, operator);
		endif;
	endforeach;
	self.cmbOperator.setIndexForItemData(AnyStringIndex);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbRrid" id="cb2e0d46-83dc-4614-910b-3eb5bcf7b0af">
        <source>buildCmbRrid();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen

*/

vars
	iter			: Iterator;
	release			: CM_BulkRelease;
	booking			: CM_BookingRef;
	source			: Integer;
	allBulkReleases	: CM_BulkReleaseByTypeStCodeDict;
	allBookingRefs	: CM_BookingRefsByStatusRefDups;
	
begin
	self.cmbRRID.clear();
	self.cmbRRID.enabled := true;
	self.setCargoMode(false);
	
	source := self.cmbSource.getCurrentItemData;
	allBulkReleases := self.myTerminal.allBulkReleaseByTypeByStByCd;
	allBookingRefs := self.myTerminal.allBookingRefsByStatusRef;
	
	if source = self.SOURCE_RELEASE then
		iter := allBulkReleases.createIterator;
		allBulkReleases.startKeyGeq(BR_TYPE_ROAD, BR_ACTIVE, null, null, iter);
		
		while iter.next(release) do
			if release.status &gt; BR_ACTIVE then
				break;
			endif;
			self.cmbRRID.addItemObject(release.code, release);
		endwhile;
		
	elseif source = self.SOURCE_BOOKING then	
		iter := allBookingRefs.createIterator;
		allBookingRefs.startKeyGeq(BOOKING_REF_PENDING, null, iter);
		
		while iter.next(booking) do
			if booking.status &gt; BOOKING_REF_ACTIVE then
				break;
			endif;
			self.cmbRRID.addItemObject(booking.bookingReference, booking);
		endwhile;
		
	elseif source = self.SOURCE_CARGO then
		self.setCargoMode(true);
		
	endif;
	
epilog
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbSlotType" id="18e0ef70-6b39-43b2-b1b5-c63b260c2dcb">
        <source>buildCmbSlotType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Sep 2022 navma1	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
06 Sep 2023	navlw1	Bug 60367: FR | 53429 - VBS MTN - Enquiry Screen issues

*/

vars
	slotType	: CM_VehicleBookingTimeSlotType;
	iter 		: Iterator;
begin
	
	self.cmbSlotType.clear;
	self.cmbSlotType.addItemWithData(Any_String, self.VbsSlotType_Setting); //06.09.2023 navlw1 tfs #60367
	
	iter := self.myTerminal.allTerminalVBSSlotTypes.createIterator;
	
	while iter.next(slotType) do
		self.cmbSlotType.addItemObject(slotType.code &amp;" - " &amp; slotType.description, slotType);
	endwhile;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbSource" id="cc98566c-3c66-4cc3-8743-15194ec86e47">
        <source>buildCmbSource();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
25 Aug 2023	navlw1	Bug 60046: FR | 53429 - VBS MTN - Enquiry Screen issues

*/

vars
	direction : Integer;
begin
	self.cmbSource.clear();
	self.cmbSource.enabled := true;
	direction := self.cmbDirection.getCurrentItemData;
	if direction = DIRECTION_PICKUP then
		self.cmbSource.addItemWithData("Cargo", self.SOURCE_CARGO);
		self.cmbSource.addItemWithData("Release Request", self.SOURCE_RELEASE);
		self.cmbSource.addItemWithData("", self.SOURCE_EMPTY);
	elseif direction = DIRECTION_DELIVERY then
		self.cmbSource.addItemWithData("Cargo", self.SOURCE_CARGO);
		self.cmbSource.addItemWithData("Booking", self.SOURCE_BOOKING);
		self.cmbSource.addItemWithData("", self.SOURCE_EMPTY);
	elseif direction = self.DIRECTION_ANY then
		self.cmbSource.addItemWithData("Cargo", self.SOURCE_CARGO);
		self.cmbSource.addItemWithData("Booking", self.SOURCE_BOOKING);
		self.cmbSource.addItemWithData("Release Request", self.SOURCE_RELEASE);
		self.cmbSource.addItemWithData("", self.SOURCE_EMPTY);
	endif;
epilog

end;</source>
    </JadeMethod>
