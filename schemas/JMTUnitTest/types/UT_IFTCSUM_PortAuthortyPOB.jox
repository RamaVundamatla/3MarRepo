    <JadeMethod name="tIFCSUMWithConsignee" id="19e4acce-c8e6-43e3-8dd8-515f35081548">
        <source>tIFCSUMWithConsignee();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
// 06 Nov 2023	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/

constants
	VoyageName 	= 'XL0011';
	BoatName 	= 'XLBOAT';
	OperatorCode : String = "WLA";
	EDIPartyName : String = "IFCSUMAUBNE94B";
	ContainerId1 = 'XLUW1234501';
//	ContainerId2 = 'XL1234502';
//	ContainerId3 = 'XL1234503';
	Commodity1	= 'FROZEN FISH';
//	Commodity2	= 'FZFS';
vars
	tempStr	: String;
	ediText	: String;
	ediTI : CM_EDITrackedItem;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediFile	: CM_EDIFile;
    ediData : CM_EDIData;
	passport : CM_Passport;
	operator : CM_Operator;
	ediParty : CM_EDIParty;
	ti : CM_TrackedItem;
	carCargoType : CM_CargoType;
	hondaConsign : CM_ConsigneeConsignor;
	hondaMake : CM_VehicleMake;
	rules : CM_EDIPartyRules;
	cargoType : CM_CargoType;
	port : CM_Port;
	espusActivity : Boolean;
	nzwhoActivity : Boolean;
begin
//	self.setTerminalConfig(EdiShipManAllowPartial, true);
	self.setTerminalConfig(ProcIFCSUMPortAuthority, true);

	passport := app.myPassport;
	port := app.myRoot.allPorts["ESPUS"];
	self.assertNotNullMsg("ESPUS", 'Port ESPUS not found in set up');
	espusActivity := port.isActive;
	if espusActivity then
		beginTransaction;
		port.setIsActive(false);
		commitTransaction;
	endif;
	self.assertEqualMsg(port.isActive, false, "Port ESPUS is active");
	port := app.myRoot.allPorts["NZWHO"];
	self.assertNotNullMsg("NZWHO", 'Port NZWHO not found in set up');
	nzwhoActivity := port.isActive;
	if nzwhoActivity then
		beginTransaction;
		port.setIsActive(false);
		commitTransaction;
	endif;
	self.assertEqualMsg(port.isActive, false, "Port NZWHO is active");
	operator := app.myRoot.allOperators.getAtKey(OperatorCode);
	self.assertNotNullMsg(operator, 'WLA operator not found in set up');
	carCargoType := app.myRoot.allCargoTypesById.getAtKey(7);
	hondaConsign := app.myRoot.allConsigneeConsignors.getAtKey("00172");
	if hondaConsign = null then
		hondaConsign := self.addConsigneeConsignor("00172","HONDA AUSTRALIA PTY",true,true,false);
	endif;
	hondaMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("HONDA");
	self.assertTrueMsg(hondaMake &lt;&gt; null, "Vehicle Make of 'HONDA' not found during setup.");
	
	self.deleteEDIInwardXlation (Commodity1, XLATION_TYPE_COMMODITY_BYOP, operator, null);
	
	self.deleteVoyage(VoyageName);
	voyage	:= self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel	:= self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VoyageName, BoatName, OperatorCode, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	
	beginTransaction;
	if voyage &lt;&gt; null then
		port := app.myRoot.allPorts["AUADL"];
		if not voyage.includesPort(port) then
			voyage.addPortToAllPorts(port);
		endif;
		port := app.myRoot.allPorts["AUBNE"];
		if not voyage.includesPort(port) then
			voyage.addPortToAllPorts(port);
		endif;
		if not voyage.allOperators.includes(operator) then
			voyage.allOperators.add(operator);
		endif;
	endif;
	commitTransaction;

	self.deleteEDIParty(EDIPartyName&amp;"_"&amp;OperatorCode);
	if app.isRunningInDMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(10046);		//Cannon
	elseif app.isRunningInWMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(10056);		//Cannon
	endif;
	
	ediParty := self.createEDIParty(EDIPartyName&amp;"_"&amp;OperatorCode, method.qualifiedName &amp; " Unit Test", "WLA_EXPORT", operator); 
	self.createEDIPartyIFCSUMPOB49B(ediParty, hondaConsign, carCargoType, hondaMake, false, false, false, null, cargoType, false);
	
	self.deleteEDIInwardXlation('HONDA AUSTRALIA PTY', XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	self.createEDIXlation('HONDA AUSTRALIA PTY', hondaConsign.code, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null);
	// load the "edi file" data here.
	ediText :=
"UNB+UNOA:2+WLA_EXPORT+POAUTHBNE+110411:1458+44989'
UNH+1+IFCSUM:D:94B:UN:AU11'
BGM+785+000651143001+9+AB'
DTM+137:202304130220:203'
CNT+10:0054'
CNT+16:0009'
TDT+20+"&amp;VoyageName&amp;"+++WLA+++9377494:::ANIARA'
LOC+11+NZPOE'
EQD+TE+"&amp;ContainerId1&amp;"+4555++3+5'
CNI+0001'
LOC+28+NZWHO'
LOC+9+DEHAM'
LOC+7+NZPOE'
LOC+27+ESPUS'
RFF+BM:BE12777058'
NAD+CN++HONDA AUSTRALIA PTY'
NAD+CZ++HONDA MOTORS JAPAN'
GID+00001+00000001:PK'
PIA+5+8400:MS'
FTX+AAA+++"&amp;Commodity1&amp;"'
FTX+AAA+++"&amp;Commodity1&amp;"'
MEA+AAE+AAL+KGM:4780'
MEA+AAE+ABJ+MTQ:50.490'
PCI++WA6701194-01'
SGP+"&amp;ContainerId1&amp;"+00000001'
CNT+16:137'
UNT+43+1'
UNZ+1+44989'";
	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_IFCSUMAUBNE94B, "IFCSUM", "IFCSUM_"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	
    ediData := ediFile.ediData;
    self.assertNotNull(ediData);
	
	self.assertEqualMsg(ediData.allEDITrackedItems.size, 2, "Total number of ediTis");
     foreach ediTI in ediData.allEDITrackedItems do		
		if ediTI.isKindOf(CM_EDICargoOnShipTI) then
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.id, "XLUW1234501", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, "Motor Vehicle", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.getPortOfOrigin(), "ESPUS", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.bol, "BE12777058", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.dischargePort, "NZPOE", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.loadPort, "DEHAM", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.destinationPort, "NZPOE", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.quantity, 1, "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weight.String, "4780.0000", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.volume.String, "50.490", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.consignee, "00172", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "IMPORT", "For_User Item 1");
		elseif ediTI.isKindOf(CM_EDIBOLHdrTI) then
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.id, "BE12777058", "For BOL 1");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.loadPort, "DEHAM", "For BOL 1");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.dischargePort, "NZPOE", "For BOL 1"); 
		endif;
    endforeach;
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 1, "Total number of on ship Tis");
	foreach ti in voyage.allOnshipTIsByIdCargoType do
		self.assertEqualMsg(ti.cargoTypeDescr, "Motor Vehicle", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.getPortOfOrigin(), "ESPUS", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.billOfLading, "BE12777058", "For Cargo On Ship");
		self.assertEqualMsg(ti.dischargePort, "NZPOE", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.loadPort, "DEHAM", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.destinationPort, "NZPOE", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.quantity, 1, "For Cargo On Ship"); 
		self.assertEqualMsg(ti.weight.String, "4780.0000", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.totalVolume.String, "50.4900", "For Cargo On Ship"); 
		if app.isRunningInDMAST() then
			self.assertEqualMsg(ti.commodity, "VINW", "For Cargo On Ship");
		elseif app.isRunningInWMAST() then
			self.assertEqualMsg(ti.commodity, "TBA", "For Cargo On Ship");
		endif;
		self.assertEqualMsg(ti.consignee, "00172", "For Cargo On Ship");
		self.assertEqualMsg(ti.getImExStatusString, "Import", "For Cargo on ship");
	endforeach;
	port := app.myRoot.allPorts["ESPUS"];
	self.assertEqualMsg(port.isActive, true, "Port ESPUS not active");
//	port := app.myRoot.allPorts["NZWHO"];
//	self.assertEqualMsg(port.isActive, true, "Port NZWHO not active");

epilog
	port := app.myRoot.allPorts["ESPUS"];
	if port &lt;&gt; null then
		beginTransaction;
		port.setIsActive(espusActivity);
		commitTransaction;
	endif;
	port := app.myRoot.allPorts["NZWHO"];
/*	if port &lt;&gt; null then
		beginTransaction;
		port.setIsActive(espusActivity);
		commitTransaction;
	endif;*/
end;
</source>
    </JadeMethod>
    <JadeMethod name="tIFCSUMWithEQD_CN" id="2c71a196-5ea3-4543-b0b5-55f9a5f976a1">
        <source>tIFCSUMWithEQD_CN();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
22 Oct 2024	navsp1	JIRA MTN-19367: NSW | IFCSUM - Incorrect Port of Origin and Destination for Some Items in File
*/

constants
	VoyageName 	= 'XL0011';
	BoatName 	= 'XLBOAT';
	OperatorCode : String = "WLA";
	EDIPartyName : String = "IFCSUMAUBNE94B";
	ContainerId1 = 'XLUW1234501';
	ContainerId2 = 'XL1234502';
	ContainerId3 = 'XL1234503';
	Commodity1	= 'FROZEN FISH';
//	Commodity2	= 'FZFS';
vars
	tempStr	: String;
	ediText	: String;
	ediTI : CM_EDITrackedItem;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediFile	: CM_EDIFile;
    ediData : CM_EDIData;
	passport : CM_Passport;
	operator : CM_Operator;
	ediParty : CM_EDIParty;
	ti : CM_TrackedItem;
	carCargoType : CM_CargoType;
	hondaConsign : CM_ConsigneeConsignor;
	hondaMake : CM_VehicleMake;
	rules : CM_EDIPartyRules;
	cargoType : CM_CargoType;
	port : CM_Port;
begin
//	self.setTerminalConfig(EdiShipManAllowPartial, true);
	self.setTerminalConfig(ProcIFCSUMPortAuthority, true);
	passport := app.myPassport;
	operator := app.myRoot.allOperators.getAtKey(OperatorCode);
	self.assertNotNullMsg(operator, 'WLA operator not found in set up');
	carCargoType := app.myRoot.allCargoTypesById.getAtKey(7);
	hondaConsign := app.myRoot.allConsigneeConsignors.getAtKey("00172");
	if hondaConsign = null then
		hondaConsign := self.addConsigneeConsignor("00172","HONDA AUSTRALIA PTY",true,true,false);
	endif;
	hondaMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("HONDA");
	self.assertTrueMsg(hondaMake &lt;&gt; null, "Vehicle Make of 'HONDA' not found during setup.");
	
	self.deleteEDIInwardXlation (Commodity1, XLATION_TYPE_COMMODITY_BYOP, operator, null);
	
	self.deleteVoyage(VoyageName);
	voyage	:= self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel	:= self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VoyageName, BoatName, OperatorCode, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	
	beginTransaction;
	if voyage &lt;&gt; null then
		port := app.myRoot.allPorts["AUADL"];
		if not voyage.includesPort(port) then
			voyage.addPortToAllPorts(port);
		endif;
		port := app.myRoot.allPorts["AUBNE"];
		if not voyage.includesPort(port) then
			voyage.addPortToAllPorts(port);
		endif;
		if not voyage.allOperators.includes(operator) then
			voyage.allOperators.add(operator);
		endif;
	endif;
	commitTransaction;

	self.deleteEDIParty(EDIPartyName&amp;"_"&amp;OperatorCode);
	if app.isRunningInDMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(10046);		//Cannon
	elseif app.isRunningInWMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(10056);		//Cannon
	endif;
	
	ediParty := self.createEDIParty(EDIPartyName&amp;"_"&amp;OperatorCode, method.qualifiedName &amp; " Unit Test", "WLA_EXPORT", operator); 
	self.createEDIPartyIFCSUMPOB49B(ediParty, hondaConsign, carCargoType, hondaMake, false, false, false, null, cargoType, false);
	
	self.createEDIXlation (Commodity1, "FZFS", XLATION_TYPE_COMMODITY_BYOP, false, operator, null, -21, -19);

	// load the "edi file" data here.
	ediText :=
"UNB+UNOA:2+WLA_EXPORT+POAUTHBNE+110411:1458+44989'
UNH+1+IFCSUM:D:94B:UN:AU11'
BGM+785+000651143001+9+AB'
DTM+137:202304130220:203'
CNT+10:0054'
CNT+16:0009'
TDT+20+"&amp;VoyageName&amp;"+++WLA+++9377494:::ANIARA'
LOC+11+NZPOE'
EQD+CN+"&amp;ContainerId1&amp;"+4555++3+5'
CNI+0001'
LOC+9+ANCUR'
LOC+7+NZPOE'
LOC+20+NZLYT'
LOC+27+BEZEE'
RFF+BM:BE12777058'
NAD+CN++BMW AUSTRALIA'
NAD+CZ++BAYERISCHE MOTOREN WERKE AG'
GID+00001+00000001:PK'
PIA+5+8400:MS'
FTX+AAA+++"&amp;Commodity1&amp;"'
FTX+AAA+++"&amp;Commodity1&amp;"'
MEA+AAE+AAL+KGM:4780'
MEA+AAE+ABJ+MTQ:50.490'
PCI++WA6701194-01'
SGP+"&amp;ContainerId1&amp;"+00000001'
CNT+16:137'
UNT+43+1'
UNZ+1+44989'";
	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_IFCSUMAUBNE94B, "IFCSUM", "IFCSUM_"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	
    ediData := ediFile.ediData;
    self.assertNotNull(ediData);
	
	self.assertEqualMsg(ediData.allEDITrackedItems.size, 2, "Total number of ediTis");
     foreach ediTI in ediData.allEDITrackedItems do		
		if ediTI.isKindOf(CM_EDICargoOnShipTI) then
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.id, ContainerId1, "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, "ISO Container", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.getPortOfOrigin(), "BEZEE", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.bol, "BE12777058", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.dischargePort, "NZPOE", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.loadPort, "ANCUR", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.destinationPort, "NZLYT", "For Item 1"); 	//JIRA 19367
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.quantity, 1, "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weight.String, "4780.0000", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.volume.String, "50.490", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.consignee, "BMW AUSTRALIA", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "IMPORT", "For_User Item 1");
		elseif ediTI.isKindOf(CM_EDIBOLHdrTI) then
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.id, "BE12777058", "For BOL 1");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.loadPort, "ANCUR", "For BOL 1");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.dischargePort, "NZPOE", "For BOL 1"); 
		endif;
    endforeach;
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 1, "Total number of On Ship Tis");
	foreach ti in voyage.allOnshipTIsByIdCargoType do
		self.assertEqualMsg(ti.id, ContainerId1, "For Cargo On Ship");
		self.assertEqualMsg(ti.cargoTypeDescr, "ISO Container", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.getPortOfOrigin(), "BEZEE", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.billOfLading, "BE12777058", "For Cargo On Ship");
		self.assertEqualMsg(ti.dischargePort, "NZPOE", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.loadPort, "ANCUR", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.destinationPort, "NZLYT", "For Cargo On Ship");  					//JIRA 19367
		self.assertEqualMsg(ti.quantity, 1, "For Cargo On Ship"); 
		self.assertEqualMsg(ti.weight.String, "4780.0000", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.totalVolume.String, "50.4900", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.commodity, "TBA", "For Cargo On Ship");
		self.assertEqualMsg(ti.consignee, "BMW A", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.getImExStatusString, "Import", "For Cargo On Ship");
	endforeach;

	// load the "edi file" data here.
	ediText :=
"UNB+UNOA:2+WLA_EXPORT+POAUTHBNE+110411:1458+44989'
UNH+1+IFCSUM:D:94B:UN:AU11'
BGM+785+000651143001+9+AB'
DTM+137:202304130220:203'
CNT+10:0054'
CNT+16:0009'
TDT+20+"&amp;VoyageName&amp;"+++WLA+++9377494:::ANIARA'
LOC+11+NZPOE'
EQD+CN+"&amp;ContainerId2&amp;"+4555++9+5'
CNI+0001'
LOC+9+DEHAM'
LOC+7+NZPOE'
LOC+20+NZLYT'
LOC+27+BEZEE'
RFF+BM:BE12777058'
NAD+CN++BMW AUSTRALIA'
NAD+CZ++BAYERISCHE MOTOREN WERKE AG'
GID+00001+00000001:PK'
PIA+5+8400:MS'
FTX+AAA+++"&amp;Commodity1&amp;"'
FTX+AAA+++"&amp;Commodity1&amp;"'
MEA+AAE+AAL+KGM:4780'
MEA+AAE+ABJ+MTQ:50.490'
PCI++WA6701194-01'
SGP+"&amp;ContainerId2&amp;"+00000001'
CNT+16:137'
UNT+43+1'
UNZ+1+44989'";
	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_IFCSUMAUBNE94B, "IFCSUM", "IFCSUM_"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	
    ediData := ediFile.ediData;
    self.assertNotNull(ediData);
	
	self.assertEqualMsg(ediData.allEDITrackedItems.size, 2, "Total number of ediTis 2");
     foreach ediTI in ediData.allEDITrackedItems do		
		if ediTI.isKindOf(CM_EDICargoOnShipTI) then
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.id, ContainerId2, "For Item 2");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, "ISO Container", "For Item 2");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.getPortOfOrigin(), "BEZEE", "For Item 2"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.bol, "BE12777058", "For Item 2");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.dischargePort, "NZPOE", "For Item 2"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.loadPort, "DEHAM", "For Item 2"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.destinationPort, "NZLYT", "For Item 2"); 		//JIRA 19367
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.quantity, 1, "For Item 2"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weight.String, "4780.0000", "For Item 2"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.volume.String, "50.490", "For Item 2"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.consignee, "BMW AUSTRALIA", "For Item 2");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "Import", "For_User Item 2");
		elseif ediTI.isKindOf(CM_EDIBOLHdrTI) then
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.id, "BE12777058", "For BOL 2");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.loadPort, "DEHAM", "For BOL 2");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.dischargePort, "NZPOE", "For BOL 2"); 
		endif;
    endforeach;
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 2, "Total number of On Ship Tis 2");
	foreach ti in voyage.allOnshipTIsByIdCargoType do
		if ti.id = ContainerId2 then
			self.assertEqualMsg(ti.id, ContainerId2, "For Cargo On Ship 2");
			self.assertEqualMsg(ti.cargoTypeDescr, "ISO Container", "For Cargo On Ship 2"); 
			self.assertEqualMsg(ti.getPortOfOrigin(), "BEZEE", "For Cargo On Ship 2"); 
			self.assertEqualMsg(ti.billOfLading, "BE12777058", "For Cargo On Ship 2");
			self.assertEqualMsg(ti.dischargePort, "NZPOE", "For Cargo On Ship 2"); 
			self.assertEqualMsg(ti.loadPort, "DEHAM", "For Cargo On Ship 2"); 
			self.assertEqualMsg(ti.destinationPort, "NZLYT", "For Cargo On Ship 2"); 					//JIRA 19367
			self.assertEqualMsg(ti.quantity, 1, "For Cargo On Ship 2"); 
			self.assertEqualMsg(ti.weight.String, "4780.0000", "For Cargo On Ship 2"); 
			self.assertEqualMsg(ti.totalVolume.String, "50.4900", "For Cargo On Ship 2"); 
			self.assertEqualMsg(ti.commodity, "TBA", "For Cargo On Ship 2");
			self.assertEqualMsg(ti.consignee, "BMW A", "For Cargo On Ship 2"); 
			self.assertEqualMsg(ti.getImExStatusString, "Import", "For Cargo on Ship 2");
		endif;
	endforeach;
	
	// load the "edi file" data here.
	ediText :=
"UNB+UNOA:2+WLA_EXPORT+POAUTHBNE+110411:1458+44989'
UNH+1+IFCSUM:D:94B:UN:AU11'
BGM+785+000651143001+9+AB'
DTM+137:202304130220:203'
CNT+10:0054'
CNT+16:0009'
TDT+20+"&amp;VoyageName&amp;"+++WLA+++9377494:::ANIARA'
LOC+9+NZPOE'
EQD+CN+"&amp;ContainerId3&amp;"+4555++9+5'
CNI+0001'
LOC+11+DEHAM'
LOC+7+DEHAM'
LOC+20+NZLYT'
LOC+88+BEZEE'
RFF+BM:BE12777058'
NAD+CN++BMW AUSTRALIA'
NAD+CZ++BAYERISCHE MOTOREN WERKE AG'
GID+00001+00000001:PK'
PIA+5+8400:MS'
FTX+AAA+++"&amp;Commodity1&amp;"'
FTX+AAA+++"&amp;Commodity1&amp;"'
MEA+AAE+AAL+KGM:4780'
MEA+AAE+ABJ+MTQ:50.490'
PCI++WA6701194-01'
SGP+"&amp;ContainerId3&amp;"+00000001'
CNT+16:137'
UNT+43+1'
UNZ+1+44989'";
	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_IFCSUMAUBNE94B, "IFCSUM", "IFCSUM_"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	
    ediData := ediFile.ediData;
    self.assertNotNull(ediData);
	
	self.assertEqualMsg(ediData.allEDITrackedItems.size, 2, "Total number of ediTis 3");
     foreach ediTI in ediData.allEDITrackedItems do		
		if ediTI.isKindOf(CM_EDICargoOnShipTI) then
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.id, ContainerId3, "For Item 3");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, "ISO Container", "For Item 3");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.getPortOfOrigin(), "BEZEE", "For Item 3"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.bol, "BE12777058", "For Item 3");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.dischargePort, "DEHAM", "For Item 3"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.loadPort, "NZPOE", "For Item 3"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.destinationPort, "NZLYT", "For Item 3"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.quantity, 1, "For Item 3"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weight.String, "4780.0000", "For Item 3"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.volume.String, "50.490", "For Item 3"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.consignee, "BMW AUSTRALIA", "For Item 3");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "Export", "For_User Item 3");
		elseif ediTI.isKindOf(CM_EDIBOLHdrTI) then
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.id, "BE12777058", "For BOL 3");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.loadPort, "NZPOE", "For BOL 3");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.dischargePort, "DEHAM", "For BOL 3"); 
		endif;
    endforeach;
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 3, "Total number of On Ship Tis 3");
	foreach ti in voyage.allOnshipTIsByIdCargoType do
		if ti.id = ContainerId3 then
			self.assertEqualMsg(ti.id, ContainerId3, "For Cargo On Ship 3");
			self.assertEqualMsg(ti.cargoTypeDescr, "ISO Container", "For Cargo On Ship 3"); 
			self.assertEqualMsg(ti.getPortOfOrigin(), "BEZEE", "For Cargo On Ship 3"); 
			self.assertEqualMsg(ti.billOfLading, "BE12777058", "For Cargo On Ship 3");
			self.assertEqualMsg(ti.dischargePort, "DEHAM", "For Cargo On Ship 3"); 
			self.assertEqualMsg(ti.loadPort, "NZPOE", "For Cargo On Ship 3"); 
			self.assertEqualMsg(ti.destinationPort, "NZLYT", "For Cargo On Ship 3"); 
			self.assertEqualMsg(ti.quantity, 1, "For Cargo On Ship 3"); 
			self.assertEqualMsg(ti.weight.String, "4780.0000", "For Cargo On Ship 3"); 
			self.assertEqualMsg(ti.totalVolume.String, "50.4900", "For Cargo On Ship 3"); 
			self.assertEqualMsg(ti.commodity, "TBA", "For Cargo On Ship 3");
			self.assertEqualMsg(ti.consignee, "BMW A", "For Cargo On Ship 3"); 
			self.assertEqualMsg(ti.getImExStatusString, "Export", "For Cargo On Ship 3");
		endif;
	endforeach;
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="tIFCSUMWithHSRule" id="4a1ae002-1849-44df-8e18-a75b4b2849ce">
        <updating/>
        <source>tIFCSUMWithHSRule() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
15 August 2024	navlw1	TFS 65152: NSW | IFCSUM Enhancements
25 Oct	  2024  navsp1  JIRA 33157 NSW | FR - IFCSUM - Consignee to Cargo Type Mappings Not Applied to Matching Cargo	

*/
constants
	VoyageName1 	: String = 'VoyHSRule01';
	EDIPartyName 	: String = "IFCSUMHSRule94B";
	VesselName1 	: String = 'IFCSUMHSCode';
	HSCodeId		: String = '870323';
	HSCodeId1 		: String = '847989';
	HSCodeId2 		: String = '871680';
	HSCodeId3 		: String = '842911';
	HSCodeId4		: String = '870390';
	HSCodeId5		: String = '842710';
vars
	voyage 			: CM_Voyage;
	vessel 			: CM_Vessel;
	term 			: CM_Terminal;
	oper1			: CM_Operator;
	ediParty 		: CM_EDIParty;
	cargoType,
	defCargoType	: CM_CargoType;
	hsCode			: CM_HSCodeCode;
	ediData,
	tempStr			: String;
	filesToDelete 	: CM_EDIFileSet;
	ediFile			: CM_EDIFile;
	port			: CM_Port;
	rules			: CM_EDIPartyRules;
	ruleItem		: CM_EDIRule;
	hsItem			: CM_EDIIFCSUMHSRule;
	hsCodeStrArray	: StringArray;
	shipManAllowPar, 
	portAuth		: Boolean;
	ediTI			: CM_EDITrackedItem;
	consignee		: CM_ConsigneeConsignor;//JIRA 33157
	consigneeCT		: CM_CargoType;			//JIRA 33157
	consRule		: CM_EDIIFCSUMRule;		//JIRA 33157
begin
	shipManAllowPar := self.setTerminalConfig(EdiShipManAllowPartial, true).Boolean;
	portAuth := self.setTerminalConfig(ProcIFCSUMPortAuthority, true).Boolean;
	
	create filesToDelete transient;
	create hsCodeStrArray transient;
	// delete voyage
	self.deleteVoyage(VoyageName1);
	voyage	:= self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage);
	// delete vessel
	self.deleteVessel(VesselName1);
	vessel	:= self.getVessel(VesselName1);
	self.assertIsDeleted(vessel);
	
	// get terminal
	term := self.getTerminal();
	self.assertNotNullMsg(term, "Terminal is null");
	// get the operator
	oper1 := app.myRoot.allOperators.getAtKey("UTOP");
	self.assertTrueMsg(oper1 &lt;&gt; null, "Operator of 'UTOP' not found during setup.");
	// create the vessel
	vessel := self.addVesselCellular(VesselName1, oper1);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	// create the voyage
	voyage := self.addVoyageWithContainerStructur(	VoyageName1,
													vessel.name,
													oper1.code,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	
	beginTransaction;
	if voyage &lt;&gt; null then
		port := app.myRoot.allPorts["AUPKL"];
		if not voyage.includesPort(port) then
			voyage.addPortToAllPorts(port);
		endif;
		if not voyage.allOperators.includes(oper1) then
			voyage.allOperators.add(oper1);
		endif;
	endif;
	commitTransaction;
	
	self.deleteEDIParty(EDIPartyName &amp; "_HSCODE");
	ediParty := self.createEDIParty(EDIPartyName &amp; "_HSCODE", method.qualifiedName &amp; " Unit Test", oper1.code &amp; "HS", oper1); 
	self.assertNotNullMsg(ediParty, "EDI Party has not been created");
	
	// hs codes
	hsCode := app.myRoot.allHSCodes[HSCodeId];
	self.assertNotNullMsg(hsCode, "HS Code not found");
	hsCodeStrArray.add(hsCode.id);
	
	hsCode := app.myRoot.allHSCodes[HSCodeId1];
	self.assertNotNullMsg(hsCode, "HS Code not found");
	hsCodeStrArray.add(hsCode.id);
	
	hsCode := app.myRoot.allHSCodes[HSCodeId2];
	self.assertNotNullMsg(hsCode, "HS Code not found");
	hsCodeStrArray.add(hsCode.id);
	
	hsCode := app.myRoot.allHSCodes[HSCodeId3];
	self.assertNotNullMsg(hsCode, "HS Code not found");
	hsCodeStrArray.add(hsCode.id);
	
	hsCode := app.myRoot.allHSCodes[HSCodeId4];
	self.assertNotNullMsg(hsCode, "HS Code not found");
	hsCodeStrArray.add(hsCode.id);
	
	hsCode := app.myRoot.allHSCodes[HSCodeId5];
	self.assertNotNullMsg(hsCode, "HS Code not found");
	hsCodeStrArray.add(hsCode.id);
	
	// cargo type
	if app.isRunningInDMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(11195);
	elseif app.isRunningInWMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(11526);
	endif;
	//defCargoType := cargoType;														//JIRA 33157
	defCargoType := app.myRoot.allCargoTypesByDescription["Rebar"].CM_CargoType;		//JIRA 33157
	self.assertNotNull(defCargoType);													//JIRA 33157
	
	// Test One - HSCodes in file, cargo type/subtype should be set correctly, and carrier remarks should be set on the ediTI
	self.createEDIPartyIFCSUMHSCode(ediParty,cargoType,defCargoType,"20GR40",hsCodeStrArray, oper1);
	rules := ediParty.getRulesForFileType(EDIFileType_IFCSUM94B);
	self.assertNotNullMsg(rules, "No edi party rules");
	foreach ruleItem in rules.allEDIPartyRules do
		hsItem := ruleItem.CM_EDIIFCSUMHSRule;
		self.assertNotNullMsg(hsItem, "HsCode item is null");
	endforeach;
	self.assertEqualMsg(rules.allEDIPartyRules.size, 6, "Total edi rules should be 6");
	
	// get the file
	ediData := self.xIFCSUMHSCode94Bfile_1;
	ediFile	:=	self.ediLoadFileName(ediData, EDIFileType_Unknown, "POB_IFCSUMHSCODE", "POB_IFCSUMHSCODE" &amp; method.name);
	self.assertTrueMsg(ediFile &lt;&gt; null, "EDI file not created. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.clearExpectedTrxErrors();
	//self.expectTrxError(Inv_dis_por_not_in_disch_comp);								//JIRA 33157 - commenting as the logic changed in PortSchema::CM_EDICargoOnShipTI::verifySelf.
	// verify
	self.ediVerify(ediFile);
	//tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED);	//JIRA 33157		
	// db load
	self.clearExpectedTrxErrors();
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	filesToDelete.add(ediFile);
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 22, "Total number of ediTis");
	
	foreach ediTI in ediFile.ediData.allEDITrackedItems do		
		if ediTI.isKindOf(CM_EDICargoOnShipTI) then
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.carrierRemarks, "POSTCODE-2020:ECP-DOORS AFT; CMA MT POOL- 999 VBS: BOOKING REQUIRED 42 FRIENDSHIP ROA:D, MATRAVILLE SYDNEY 2036", "Carrier Remarks should match");
			self.assertNotNullMsg(ediTI.CM_EDICargoOnShipTI.hsCode, "hsCode should not be null");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, cargoType.description, "cargo type description should match");	//JIRA 33157
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.product, "20GR40", "cargo subtype should match");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "IMPORT", "Should have an ImexStatus Import");
		endif;
	endforeach;
	
	// Test Two - no HSCode supplied in the IFCSUM file, there is no matching consignee/cargo type mapping in the matching EDI Party rule,
	// and there is no default cargo type specified in the EDI Party rule, cargoType/subtype should be null and we should see errors
	self.deleteEDIParty(EDIPartyName &amp; "_HSCODE");
	ediParty := self.createEDIParty(EDIPartyName &amp; "_HSCODE", method.qualifiedName &amp; " Unit Test", oper1.code &amp; "HS", oper1); 
	self.assertNotNullMsg(ediParty, "EDI Party has not been created");
	
	// create file method and then use it to create some stuff
	self.createEDIPartyIFCSUMHSCode(ediParty,null,null,null,null, oper1);
	rules := ediParty.getRulesForFileType(EDIFileType_IFCSUM94B);
	self.assertNotNullMsg(rules, "Edi Party should have some rules");
	
	ediData := self.xIFCSUMHSCode94Bfile_2;
	ediFile	:=	self.ediLoadFileName(ediData, EDIFileType_Unknown, "POB_IFCSUMHSCODE", "POB_IFCSUMHSCODE" &amp; method.name);
	self.clearExpectedTrxErrors();
	//self.expectTrxError(Inv_dis_por_not_in_disch_comp);				//JIRA 33157
	self.expectTrxError(Cargot_not_valid_cargot_system);
	self.expectTrxError(ERR_TOT_QUAN_ONE);
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS);
	self.clearExpectedTrxErrors();
	foreach ediTI in ediFile.ediData.allEDITrackedItems do		
		if ediTI.isKindOf(CM_EDICargoOnShipTI) then
			self.assertNullMsg(ediTI.CM_EDICargoOnShipTI.carrierRemarks, "Carrier Remarks should be null");
			self.assertNullMsg(ediTI.CM_EDICargoOnShipTI.hsCode, "hsCode should not be null");
			self.assertNullMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, "cargo type should be null");
			self.assertNullMsg(ediTI.CM_EDICargoOnShipTI.product, "cargo subtype should be null");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "IMPORT", "Should have an ImexStatus Import");
		endif;
	endforeach;
	
	// Test Three - no HSCode supplied in the IFCSUM file,																	//JIRA 33157 &gt;&gt;&gt;&gt;&gt;START&gt;&gt;&gt;&gt;&gt;
	// and there is no default cargo type specified in the EDI Party rule
	// But there is a matching consignee/cargo type mapping in the matching EDI Party rule
	// cargoType should use the consignee cargo type.
	self.deleteEDIParty(EDIPartyName &amp; "_HSCODE");
	ediParty := self.createEDIParty(EDIPartyName &amp; "_HSCODE", method.qualifiedName &amp; " Unit Test", oper1.code &amp; "HS", oper1); 
	self.assertNotNullMsg(ediParty, "EDI Party has not been created");
	
	// create file method and then use it to create some stuff
	consignee := self.addConsigneeConsignor("CON15", "UT Consignee", true, false, false);
	self.assertNotNull(consignee);
	consigneeCT := app.myRoot.allCargoTypesByDescription["UTREBAR101"].CM_CargoType;
	self.assertNotNull(consigneeCT);
	self.opts.purge();
	self.opts.addAssoc("ConsigneeCode", consignee.code);
	self.opts.addAssoc("ConsigneeCT", consigneeCT.id);
	self.createEDIPartyIFCSUMHSCode(ediParty, null, defCargoType, null, null, oper1);
	self.opts.purge();
	
	rules := ediParty.getRulesForFileType(EDIFileType_IFCSUM94B);
	self.assertNotNullMsg(rules, "No edi party rules");
	foreach ruleItem in rules.allEDIPartyRules where ruleItem.isKindOf(CM_EDIIFCSUMRule) do
		consRule := ruleItem.CM_EDIIFCSUMRule;
		self.assertNotNullMsg(consRule, "Consignee Rule item is null");
	endforeach;
	self.assertEqualMsg(rules.allEDIPartyRules.size, 1, "Total edi rules should be 1");
	
	// get the file
	ediData := self.xIFCSUM94Bfile_3;
	ediFile	:=	self.ediLoadFileName(ediData, EDIFileType_Unknown, "POB_IFCSUMHSCODE", "POB_IFCSUMHSCODE" &amp; method.name);
	self.assertTrueMsg(ediFile &lt;&gt; null, "EDI file not created. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.clearExpectedTrxErrors();
	
	// verify
	self.ediVerify(ediFile);
	
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED);	
	// db load
	self.clearExpectedTrxErrors();
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	filesToDelete.add(ediFile);
	self.assertEqualMsg(ediFile.ediData.allEDITrackedItems.size, 1, "Total number of ediTis");
	
	foreach ediTI in ediFile.ediData.allEDITrackedItems do		
		if ediTI.isKindOf(CM_EDICargoOnShipTI) then
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.carrierRemarks, "POSTCODE-2020:ECP-DOORS AFT; CMA MT POOL- 999 VBS: BOOKING REQUIRED 42 FRIENDSHIP ROA:D, MATRAVILLE SYDNEY 2036", "Carrier Remarks should match");
			self.assertNotNullMsg(ediTI.CM_EDICargoOnShipTI.hsCode, "hsCode should not be null");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, consigneeCT.description, "cargo type description should match with consignee cargo type");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "IMPORT", "Should have an ImexStatus Import");
		endif;
	endforeach;																												//JIRA 33157 &lt;&lt;&lt;&lt;&lt;END&lt;&lt;&lt;&lt;&lt;
	
	
	//cleanup if successfull
	self.deleteVoyage(VoyageName1);
	voyage := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(VesselName1);
	vessel := self.getVessel(VesselName1);
	self.assertIsDeleted(vessel);
	
	self.deleteEDIParty(EDIPartyName &amp; "_HSCODE");
	self.assertIsDeleted(ediParty);
epilog
	self.setTerminalConfig(EdiShipManAllowPartial, shipManAllowPar);
	self.setTerminalConfig(ProcIFCSUMPortAuthority, portAuth);
	delete filesToDelete;
	delete hsCodeStrArray;
	self.opts.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="tIFCSUMWithNoSGP" id="e5a50898-765a-41ab-bd37-b9f5035e7e48">
        <source>tIFCSUMWithNoSGP();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP


*/

constants
	VoyageName 	= 'XL0011';
	BoatName 	= 'XLBOAT';
	OperatorCode : String = "WLA";
	EDIPartyName : String = "IFCSUMAUBNE94B";
//	ContainerId1 = 'XL1234501';
//	ContainerId2 = 'XL1234502';
//	ContainerId3 = 'XL1234503';
//	Commodity1	= 'FROZEN FISH';
//	Commodity2	= 'FZFS';
vars
	tempStr	: String;
	ediText	: String;
	ediTI : CM_EDITrackedItem;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediFile	: CM_EDIFile;
    ediData : CM_EDIData;
	passport : CM_Passport;
	operator : CM_Operator;
	ediParty : CM_EDIParty;
	ti : CM_TrackedItem;
	carCargoType : CM_CargoType;
	hondaConsign : CM_ConsigneeConsignor;
	hondaMake : CM_VehicleMake;
	rules : CM_EDIPartyRules;
	cargoType : CM_CargoType;
	port : CM_Port;
begin
//	self.setTerminalConfig(EdiShipManAllowPartial, true);
	self.setTerminalConfig(ProcIFCSUMPortAuthority, true);
	passport := app.myPassport;
	operator := app.myRoot.allOperators.getAtKey(OperatorCode);
	self.assertNotNullMsg(operator, 'WLA operator not found in set up');
	carCargoType := app.myRoot.allCargoTypesById.getAtKey(7);
	hondaConsign := app.myRoot.allConsigneeConsignors.getAtKey("00172");
	if hondaConsign = null then
		hondaConsign := self.addConsigneeConsignor("00172","HONDA AUSTRALIA PTY",true,true,false);
	endif;
	hondaMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("HONDA");
	self.assertTrueMsg(hondaMake &lt;&gt; null, "Vehicle Make of 'HONDA' not found during setup.");
	
//	self.deleteEDIInwardXlation (Commodity1, XLATION_TYPE_COMMODITY_BYOP, operator, null);
	
	self.deleteVoyage(VoyageName);
	voyage	:= self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel	:= self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VoyageName, BoatName, OperatorCode, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	
	beginTransaction;
	if voyage &lt;&gt; null then
		port := app.myRoot.allPorts["AUADL"];
		if not voyage.includesPort(port) then
			voyage.addPortToAllPorts(port);
		endif;
		port := app.myRoot.allPorts["AUBNE"];
		if not voyage.includesPort(port) then
			voyage.addPortToAllPorts(port);
		endif;
		if not voyage.allOperators.includes(operator) then
			voyage.allOperators.add(operator);
		endif;
	endif;
	commitTransaction;

	self.deleteEDIParty(EDIPartyName&amp;"_"&amp;OperatorCode);
	if app.isRunningInDMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(10046);		//Cannon
	elseif app.isRunningInWMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(10056);		//Cannon
	endif;
	
	ediParty := self.createEDIParty(EDIPartyName&amp;"_"&amp;OperatorCode, method.qualifiedName &amp; " Unit Test", "WLA_EXPORT", operator); 
	self.createEDIPartyIFCSUMPOB49B(ediParty, hondaConsign, carCargoType, hondaMake, false, false, false, null, cargoType, false);
	beginTransaction;
	ediParty.getRulesForFileType(EDIFileType_IFCSUM94B).CM_EDIPartyIFCSUMRules.setPropertyValue(CM_EDIPartyIFCSUMRules::cargoSegmentIsPCI.name, true);
	commitTransaction;
	
	// load the "edi file" data here.
	ediText :=
"UNB+UNOA:2+WLA_EXPORT+POAUTHBNE+110411:1458+44989'
UNH+1+IFCSUM:D:94B:UN:AU11'
BGM+785+000651143001+9+AB'
DTM+137:202304130220:203'
CNT+10:0054'
CNT+16:0009'
TDT+20+"&amp;VoyageName&amp;"+++WLA+++9377494:::ANIARA'
LOC+11+NZPOE'
CNI+0001'
LOC+9+DEHAM'
LOC+7+NZPOE'
LOC+20+NZLYT'
LOC+27+BEZEE'
RFF+BM:BE12777058'
NAD+CN++BMW AUSTRALIA'
NAD+CZ++BAYERISCHE MOTOREN WERKE AG'
GID+00001+0000001:PK'
PIA+5+8400:MS'
FTX+AAA+++BMW 1-SERIES 2022'
MEA+AAE+AAL+KGM:26507'
MEA+AAE+ABJ+MTQ:218.026'
PCI++WA6701194-01'
CNT+16:137'
UNT+43+1'
UNZ+1+44989'";
	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_IFCSUMAUBNE94B, "IFCSUM", "IFCSUM_"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	
    ediData := ediFile.ediData;
    self.assertNotNull(ediData);
	
	self.assertEqualMsg(ediData.allEDITrackedItems.size, 2, "Total number of ediTis");
    foreach ediTI in ediData.allEDITrackedItems do		
		if ediTI.isKindOf(CM_EDICargoOnShipTI) then
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, "Cannon", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.id, "WA6701194-01", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.getPortOfOrigin(), "BEZEE", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.bol, "BE12777058", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.dischargePort, "NZPOE", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.loadPort, "DEHAM", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.destinationPort, "NZLYT", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.quantity, 0, "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weight.String, "26507.0000", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.volume.String, "218.026", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.consignee, "BMW AUSTRALIA", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "IMPORT", "For_User Item 1");
		elseif ediTI.isKindOf(CM_EDIBOLHdrTI) then
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.id, "BE12777058", "For BOL 1");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.loadPort, "DEHAM", "For BOL 1");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.dischargePort, "NZPOE", "For BOL 1"); 
		endif;
    endforeach;
	
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 1, "Total number of on ship Tis");
	foreach ti in voyage.allOnshipTIsByIdCargoType do
		self.assertEqualMsg(ti.cargoTypeDescr, "Cannon", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.getPortOfOrigin(), "BEZEE", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.billOfLading, "BE12777058", "For Cargo On Ship");
		self.assertEqualMsg(ti.dischargePort, "NZPOE", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.loadPort, "DEHAM", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.destinationPort, "NZLYT", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.quantity, 0, "For Cargo On Ship"); 
		self.assertEqualMsg(ti.weight.String, "26507.0000", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.totalVolume.String, "218.0260", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.commodity, "", "For Cargo On Ship");
		self.assertEqualMsg(ti.consignee, "BMW A", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.getImExStatusString, "Import", "For Cargo on ship");
	endforeach;
epilog
 
end;
</source>
    </JadeMethod>
    <JadeMethod name="tIFCSUMWithNoSGPNoParty" id="7e42223d-99e7-4438-aca1-769ed77b75dc">
        <source>tIFCSUMWithNoSGPNoParty();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP


*/

constants
	VoyageName 	= 'XL0011';
	BoatName 	= 'XLBOAT';
	OperatorCode : String = "WLA";
	EDIPartyName : String = "IFCSUMAUBNE94B";
//	ContainerId1 = 'XL1234501';
//	ContainerId2 = 'XL1234502';
//	ContainerId3 = 'XL1234503';
//	Commodity1	= 'FROZEN FISH';
//	Commodity2	= 'FZFS';
vars
	tempStr	: String;
	ediText	: String;
	ediTI : CM_EDITrackedItem;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediFile	: CM_EDIFile;
    ediData : CM_EDIData;
	passport : CM_Passport;
	operator : CM_Operator;
	ediParty : CM_EDIParty;
	ti : CM_TrackedItem;
	carCargoType : CM_CargoType;
	hondaConsign : CM_ConsigneeConsignor;
	hondaMake : CM_VehicleMake;
	rules : CM_EDIPartyRules;
	cargoType : CM_CargoType;
	port : CM_Port;
begin
	self.setTerminalConfig(EdiShipManAllowPartial, true);
	self.setTerminalConfig(ProcIFCSUMPortAuthority, true);
	passport := app.myPassport;
	operator := app.myRoot.allOperators.getAtKey(OperatorCode);
	self.assertNotNullMsg(operator, 'WLA operator not found in set up');
	carCargoType := app.myRoot.allCargoTypesById.getAtKey(7);
	hondaConsign := app.myRoot.allConsigneeConsignors.getAtKey("00172");
	if hondaConsign = null then
		hondaConsign := self.addConsigneeConsignor("00172","HONDA AUSTRALIA PTY",true,true,false);
	endif;
	hondaMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("HONDA");
	self.assertTrueMsg(hondaMake &lt;&gt; null, "Vehicle Make of 'HONDA' not found during setup.");
	
//	self.deleteEDIInwardXlation (Commodity1, XLATION_TYPE_COMMODITY_BYOP, operator, null);
	
	self.deleteVoyage(VoyageName);
	voyage	:= self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel	:= self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VoyageName, BoatName, OperatorCode, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	
	beginTransaction;
	if voyage &lt;&gt; null then
		port := app.myRoot.allPorts["AUADL"];
		if not voyage.includesPort(port) then
			voyage.addPortToAllPorts(port);
		endif;
		port := app.myRoot.allPorts["AUBNE"];
		if not voyage.includesPort(port) then
			voyage.addPortToAllPorts(port);
		endif;
		if not voyage.allOperators.includes(operator) then
			voyage.allOperators.add(operator);
		endif;
	endif;
	commitTransaction;

	self.deleteEDIParty(EDIPartyName&amp;"_"&amp;OperatorCode);
//	if app.isRunningInDMAST() then
//		cargoType := app.myRoot.allCargoTypesById.getAtKey(10046);		//Cannon
//	elseif app.isRunningInWMAST() then
//		cargoType := app.myRoot.allCargoTypesById.getAtKey(10056);		//Cannon
//	endif;
//	
//	ediParty := self.createEDIParty(EDIPartyName&amp;"_"&amp;OperatorCode, method.qualifiedName &amp; " Unit Test", "WLA_EXPORT", operator); 
//	self.createEDIPartyIFCSUMPOB49B(ediParty, hondaConsign, carCargoType, hondaMake, false, false, false, null, cargoType, false);
	
	// load the "edi file" data here.
	ediText :=
"UNB+UNOA:2+WLA_EXPORT+POAUTHBNE+110411:1458+44989'
UNH+1+IFCSUM:D:94B:UN:AU11'
BGM+785+000651143001+9+AB'
DTM+137:202304130220:203'
CNT+10:0054'
CNT+16:0009'
TDT+20+"&amp;VoyageName&amp;"+++WLA+++9377494:::ANIARA'
LOC+11+NZPOE'
CNI+0001'
LOC+9+DEHAM'
LOC+7+NZPOE'
LOC+20+NZLYT'
LOC+27+BEZEE'
RFF+BM:BE12777058'
NAD+CN++BMW AUSTRALIA'
NAD+CZ++BAYERISCHE MOTOREN WERKE AG'
GID+00001+00000018:PK'
PIA+5+8400:MS'
FTX+AAA+++BMW 1-SERIES 2022'
MEA+AAE+AAL+KGM:26507'
MEA+AAE+ABJ+MTQ:218.026'
PCI++WA6701194-01'
CNT+16:137'
UNT+43+1'
UNZ+1+44989'";
	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_IFCSUMAUBNE94B, "IFCSUM", "IFCSUM_"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS);
	
    ediData := ediFile.ediData;
    self.assertNotNull(ediData);
	
	self.assertEqualMsg(ediData.allEDITrackedItems.size, 2, "Total number of ediTis");
    foreach ediTI in ediData.allEDITrackedItems do		
		if ediTI.isKindOf(CM_EDICargoOnShipTI) then
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.id, "WA6701194-01", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, "", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.getPortOfOrigin(), "BEZEE", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.bol, "BE12777058", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.dischargePort, "NZPOE", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.loadPort, "DEHAM", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.destinationPort, "NZLYT", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.quantity, 0, "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weight.String, "26507.0000", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.volume.String, "218.026", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.consignee, "BMW AUSTRALIA", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "IMPORT", "For_User Item 1");
		elseif ediTI.isKindOf(CM_EDIBOLHdrTI) then
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.id, "BE12777058", "For BOL 1");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.loadPort, "DEHAM", "For BOL 1");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.dischargePort, "NZPOE", "For BOL 1"); 
		endif;
    endforeach;
	
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 0, "Total number of on ship Tis");
/*	foreach ti in voyage.allOnshipTIsByIdCargoType do
		self.assertEqualMsg(ti.cargoTypeDescr, "Cannon", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.getPortOfOrigin(), "BEZEE", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.billOfLading, "BE12777058", "For Cargo On Ship");
		self.assertEqualMsg(ti.dischargePort, "NZPOE", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.loadPort, "DEHAM", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.destinationPort, "NZLYT", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.quantity, 18, "For Cargo On Ship"); 
		self.assertEqualMsg(ti.weight.String, "26507.0000", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.totalVolume.String, "218.0260", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.commodity, "", "For Cargo On Ship");
		self.assertEqualMsg(ti.consignee, "BMW A", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.getImExStatusString, "Import", "For Cargo on ship");
	endforeach;*/
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="tIFCSUMWithSGP" id="b822244c-8e7c-4ebd-8c60-ec0e0d88235e">
        <source>tIFCSUMWithSGP();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
// 06 Nov 2023	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/

constants
	VoyageName 	= 'XL0011';
	BoatName 	= 'XLBOAT';
	OperatorCode : String = "WLA";
	EDIPartyName : String = "IFCSUMAUBNE94B";
	ContainerId1 = 'XLUW1234501';
//	ContainerId2 = 'XL1234502';
//	ContainerId3 = 'XL1234503';
	Commodity1	= 'FROZEN FISH';
//	Commodity2	= 'FZFS';
vars
	tempStr	: String;
	ediText	: String;
	ediTI : CM_EDITrackedItem;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediFile	: CM_EDIFile;
    ediData : CM_EDIData;
	passport : CM_Passport;
	operator : CM_Operator;
	ediParty : CM_EDIParty;
	ti : CM_TrackedItem;
	carCargoType : CM_CargoType;
	hondaConsign : CM_ConsigneeConsignor;
	hondaMake : CM_VehicleMake;
	rules : CM_EDIPartyRules;
	cargoType : CM_CargoType;
	port : CM_Port;
begin
//	self.setTerminalConfig(EdiShipManAllowPartial, true);
	self.setTerminalConfig(ProcIFCSUMPortAuthority, true);
	passport := app.myPassport;
	operator := app.myRoot.allOperators.getAtKey(OperatorCode);
	self.assertNotNullMsg(operator, 'WLA operator not found in set up');
	carCargoType := app.myRoot.allCargoTypesById.getAtKey(7);
	hondaConsign := app.myRoot.allConsigneeConsignors.getAtKey("00172");
	if hondaConsign = null then
		hondaConsign := self.addConsigneeConsignor("00172","HONDA AUSTRALIA PTY",true,true,false);
	endif;
	hondaMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("HONDA");
	self.assertTrueMsg(hondaMake &lt;&gt; null, "Vehicle Make of 'HONDA' not found during setup.");
	
	self.deleteEDIInwardXlation (Commodity1, XLATION_TYPE_COMMODITY_BYOP, operator, null);
	
	self.deleteVoyage(VoyageName);
	voyage	:= self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel	:= self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VoyageName, BoatName, OperatorCode, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	
	beginTransaction;
	if voyage &lt;&gt; null then
		port := app.myRoot.allPorts["AUADL"];
		if not voyage.includesPort(port) then
			voyage.addPortToAllPorts(port);
		endif;
		port := app.myRoot.allPorts["AUBNE"];
		if not voyage.includesPort(port) then
			voyage.addPortToAllPorts(port);
		endif;
		if not voyage.allOperators.includes(operator) then
			voyage.allOperators.add(operator);
		endif;
	endif;
	commitTransaction;

	self.deleteEDIParty(EDIPartyName&amp;"_"&amp;OperatorCode);
	if app.isRunningInDMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(10046);		//Cannon
	elseif app.isRunningInWMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(10056);		//Cannon
	endif;
	
	ediParty := self.createEDIParty(EDIPartyName&amp;"_"&amp;OperatorCode, method.qualifiedName &amp; " Unit Test", "WLA_EXPORT", operator); 
	self.createEDIPartyIFCSUMPOB49B(ediParty, hondaConsign, carCargoType, hondaMake, false, false, false, null, cargoType, false);
	
	self.createEDIXlation (Commodity1, "FZFS", XLATION_TYPE_COMMODITY_BYOP, false, operator, null, -21, -19);
	// load the "edi file" data here.
	ediText :=
"UNB+UNOA:2+WLA_EXPORT+POAUTHBNE+110411:1458+44989'
UNH+1+IFCSUM:D:94B:UN:AU11'
BGM+785+000651143001+9+AB'
DTM+137:202304130220:203'
CNT+10:0054'
CNT+16:0009'
TDT+20+"&amp;VoyageName&amp;"+++WLA+++9377494:::ANIARA'
LOC+11+NZPOE'
EQD+TE+"&amp;ContainerId1&amp;"+4555++3+5'
CNI+0001'
LOC+9+DEHAM'
LOC+7+NZPOE'
LOC+20+NZLYT'
LOC+27+BEZEE'
RFF+BM:BE12777058'
NAD+CN++BMW AUSTRALIA'
NAD+CZ++BAYERISCHE MOTOREN WERKE AG'
GID+00001+00000001:PK'
PIA+5+8400:MS'
FTX+AAA+++"&amp;Commodity1&amp;"'
FTX+AAA+++"&amp;Commodity1&amp;"'
MEA+AAE+AAL+KGM:4780'
MEA+AAE+ABJ+MTQ:50.490'
PCI++WA6701194-01'
SGP+"&amp;ContainerId1&amp;"+00000001'
CNT+16:137'
UNT+43+1'
UNZ+1+44989'";
	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_IFCSUMAUBNE94B, "IFCSUM", "IFCSUM_"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	
    ediData := ediFile.ediData;
    self.assertNotNull(ediData);
	
	self.assertEqualMsg(ediData.allEDITrackedItems.size, 2, "Total number of ediTis");
     foreach ediTI in ediData.allEDITrackedItems do		
		if ediTI.isKindOf(CM_EDICargoOnShipTI) then
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, "Cannon", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.getPortOfOrigin(), "BEZEE", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.bol, "BE12777058", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.dischargePort, "NZPOE", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.loadPort, "DEHAM", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.destinationPort, "NZLYT", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.quantity, 1, "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weight.String, "4780.0000", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.volume.String, "50.490", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.consignee, "BMW AUSTRALIA", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "IMPORT", "For_User Item 1");
		elseif ediTI.isKindOf(CM_EDIBOLHdrTI) then
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.id, "BE12777058", "For BOL 1");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.loadPort, "DEHAM", "For BOL 1");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.dischargePort, "NZPOE", "For BOL 1"); 
		endif;
    endforeach;
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 1, "Total number of on ship Tis");
	foreach ti in voyage.allOnshipTIsByIdCargoType do
		self.assertEqualMsg(ti.cargoTypeDescr, "Cannon", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.getPortOfOrigin(), "BEZEE", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.billOfLading, "BE12777058", "For Cargo On Ship");
		self.assertEqualMsg(ti.dischargePort, "NZPOE", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.loadPort, "DEHAM", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.destinationPort, "NZLYT", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.quantity, 1, "For Cargo On Ship"); 
		self.assertEqualMsg(ti.weight.String, "4780.0000", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.totalVolume.String, "50.4900", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.commodity, "", "For Cargo On Ship");
		self.assertEqualMsg(ti.consignee, "BMW A", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.getImExStatusString, "Import", "For Cargo on ship");
	endforeach;
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="tIFCSUMWithSGP2" id="3f51dae9-f365-4dc1-8ddc-708692c4f018">
        <source>tIFCSUMWithSGP2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2023	jlirs1	Initial creation
*/

constants
	VoyageName 	= 'XL0011';
	BoatName 	= 'XLBOAT';
	OperatorCode : String = "WLA";
	EDIPartyName : String = "IFCSUMAUBNE94B";
	ContainerId1 = 'BEAU5781367';
//	ContainerId2 = 'XL1234502';
//	ContainerId3 = 'XL1234503';
	Commodity1	= 'FROZEN FISH';
//	Commodity2	= 'FZFS';
vars
	tempStr	: String;
	ediText	: String;
	ediTI : CM_EDITrackedItem;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediFile	: CM_EDIFile;
    ediData : CM_EDIData;
	passport : CM_Passport;
	operator : CM_Operator;
	ediParty : CM_EDIParty;
	ti : CM_TrackedItem;
	carCargoType : CM_CargoType;
	hondaConsign : CM_ConsigneeConsignor;
	hondaMake : CM_VehicleMake;
	rules : CM_EDIPartyRules;
	cargoType : CM_CargoType;
	port : CM_Port;
	ediCargoTiCt : Integer;
begin
//	self.setTerminalConfig(EdiShipManAllowPartial, true);
	self.setTerminalConfig(ProcIFCSUMPortAuthority, true);
	passport := app.myPassport;
	operator := app.myRoot.allOperators.getAtKey(OperatorCode);
	self.assertNotNullMsg(operator, 'WLA operator not found in set up');
	carCargoType := app.myRoot.allCargoTypesById.getAtKey(7);
	hondaConsign := app.myRoot.allConsigneeConsignors.getAtKey("00172");
	if hondaConsign = null then
		hondaConsign := self.addConsigneeConsignor("00172","HONDA AUSTRALIA PTY",true,true,false);
	endif;
	hondaMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("HONDA");
	self.assertTrueMsg(hondaMake &lt;&gt; null, "Vehicle Make of 'HONDA' not found during setup.");
	
	self.deleteEDIInwardXlation (Commodity1, XLATION_TYPE_COMMODITY_BYOP, operator, null);
	
	self.deleteVoyage(VoyageName);
	voyage	:= self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel	:= self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VoyageName, BoatName, OperatorCode, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	
	beginTransaction;
	if voyage &lt;&gt; null then
		port := app.myRoot.allPorts["THLCH"];
		if not voyage.includesPort(port) then
			voyage.addPortToAllPorts(port);
		endif;
		port := app.myRoot.allPorts["AUBNE"];
		if not voyage.includesPort(port) then
			voyage.addPortToAllPorts(port);
		endif;
		if not voyage.allOperators.includes(operator) then
			voyage.allOperators.add(operator);
		endif;
	endif;
	commitTransaction;

	self.deleteEDIParty(EDIPartyName&amp;"_"&amp;OperatorCode);
	if app.isRunningInDMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(10046);		//Cannon
	elseif app.isRunningInWMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(10056);		//Cannon
	endif;
	
	ediParty := self.createEDIParty(EDIPartyName&amp;"_"&amp;OperatorCode, method.qualifiedName &amp; " Unit Test", "WLA_EXPORT", operator); 
	self.createEDIPartyIFCSUMPOB49B(ediParty, hondaConsign, carCargoType, hondaMake, false, false, false, null, cargoType, false);
	rules := ediParty.getRulesForFileType(EDIFileType_IFCSUM94B);
	beginTransaction;
	rules.setPropertyValue(CM_EDIPartyIFCSUMRules::oneMEAPerGID.name, true);
	commitTransaction;
	self.setTerminalConfig(ProcIFCSUMPortAuthority, true);
	
	self.createEDIXlation (Commodity1, "FZFS", XLATION_TYPE_COMMODITY_BYOP, false, operator, null, -21, -19);

	// load the "edi file" data here.
	ediText := x400txt;

	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_IFCSUMAUBNE94B, "IFCSUM", "IFCSUM_"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	
    ediData := ediFile.ediData;
    self.assertNotNull(ediData);
	
	self.assertEqualMsg(ediData.allEDITrackedItems.size, 328, "Total number of ediTis");
     foreach ediTI in ediData.allEDITrackedItems do		
		if ediTI.isKindOf(CM_EDICargoOnShipTI) then
			if ediTI.CM_EDICargoOnShipTI.id = "BEAU5781367" then
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.cargoTypeDescr, "ISO Container", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.id, "BEAU5781367", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.getPortOfOrigin(), "AUBNE", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.bol, "2688079230", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.dischargePort, "THLCH", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.loadPort, "AUBNE", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.destinationPort, "IDJKT", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.quantity, 0, "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.weight.String, "20460.0000", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.volume.String, "50.000", "For Item 1"); 
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.consignee, "", "For Item 1");
			self.assertEqualMsg(ediTI.CM_EDICargoOnShipTI.imexStatus, "EXPORT", "For_User Item 1");
			endif;
			ediCargoTiCt := ediCargoTiCt + 1;
		elseif ediTI.isKindOf(CM_EDIBOLHdrTI) then
		if ediTI.CM_EDIBOLHdrTI.id = "2033513281" then
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.id, "2033513281", "For BOL 1");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.loadPort, "AUBNE", "For BOL 1");
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.dischargePort, "SGSIN", "For BOL 1"); 
			self.assertEqualMsg(ediTI.CM_EDIBOLHdrTI.destinationPort, "IDJKT", "For BOL 1"); 
			endif;
		endif;
    endforeach;
	self.assertEqualMsg(ediCargoTiCt, 257, "Total number of on ship EDI Tis");
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 257, "Total number of on ship Tis");
	foreach ti in voyage.allOnshipTIsByIdCargoType do
		if ti.id = "BEAU5781367" then
		self.assertEqualMsg(ti.cargoTypeDescr, "ISO Container", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.getPortOfOrigin(), "AUBNE", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.billOfLading, "2688079230", "For Cargo On Ship");
		self.assertEqualMsg(ti.dischargePort, "THLCH", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.loadPort, "NZPOE", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.destinationPort, "IDJKT", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.quantity, 1, "For Cargo On Ship"); 
		self.assertEqualMsg(ti.weight.String, "20460.0000", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.totalVolume.String, "50.0000", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.commodity, "TBA", "For Cargo On Ship");
		self.assertEqualMsg(ti.consignee, "", "For Cargo On Ship"); 
		self.assertEqualMsg(ti.getImExStatusString, "Export", "For Cargo on ship");
		endif;
	endforeach;
epilog

end;
</source>
