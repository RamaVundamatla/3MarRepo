    <ExternalMethod name="monthChange" id="bd42ce81-c08b-4ac8-9148-8abf5770fe99">
        <updating/>
        <entrypoint>CallControlEvent</entrypoint>
        <library name="jadpmap"/>
        <source>monthChange(pTheCalendar: JSSCalendar input) is CallControlEvent in jadpmap updating;</source>
        <Parameter name="pTheCalendar" type="JSSCalendar" usage="input"/>
    </ExternalMethod>
    <JadeMethod name="redrawSelf" id="37d51032-dd25-4ca3-9eac-c893b862aea8">
        <updating/>
        <source>redrawSelf() updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Redraw after some visual change to the appearance has occurred.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	firstDate		: Date;					// Date of the 1st of the current month
	firstDay		: Integer;				// dayOfWeek of 1st of the current month

	fillDays		: Integer;				// Number of filler days before first day
	daysInMonth		: Integer;				// Number of days in the current month

	theControl		: Control;
	theCalendarDay	: JSSCalendarDay;
	monthRow		: Integer;
	monthColumn		: Integer;
	workDate		: Date;

	dayIter			: Iterator;
	dayNumber		: Integer;

begin
	daysInMonth	:= currentMonth.jssDaysInMonth(currentYear.jssIsLeapYear());
    firstDate.setDate(1, currentMonth, currentYear);
    firstDay	:= firstDate.dayOfWeek;

	// Calculate number of filler days before start of month.
	
	fillDays := firstDay - self.weekStartsOn;
	
	if fillDays &lt; 0 then
		fillDays := fillDays + 7;
	endif;

	// Calculate number of week lines required to display this month.
	
	self.numberOfWeeks := (fillDays + daysInMonth + 6) div 7;

    // Set up month heading
    if self.isShowMonthHeading then
    	self.myMonthHeading.visible		:= true;
    	self.myMonthHeading.caption		:= firstDate.monthName &amp; ' ' &amp; firstDate.year.String;
    else
    	self.myMonthHeading.visible		:= false;
	endif;

	// Set up day headings.
	
	workDate := firstDate - fillDays;
	
	foreach theControl in self.allDayHeadings do
		theControl.fontBold	:=	self.isMonthHeadingBold;
		
		if self.isShortDayName then
			theControl.JSSCalendarHeading.caption	:= workDate.dayName[1:3];
		else
			theControl.JSSCalendarHeading.caption	:= workDate.dayName;
		endif;
		
		theControl.visible						:= self.isShowWeekends or workDate.dayOfWeek &lt; 6;
		workDate								:= workDate + 1;		
	endforeach;

	// Set up days.
	
	dayIter		:= self.allDays.createIterator();
	dayNumber	:= 0;
	workDate	:= firstDate - fillDays - 1;
	
	foreach monthRow in 1 to 6 do
		foreach monthColumn in 1 to 7 do
			dayIter.next(theControl);
			theCalendarDay	:= theControl.JSSCalendarDay;
			workDate		:= workDate + 1;

			if monthRow &gt; 1 or monthColumn &gt; fillDays then
				dayNumber := dayNumber + 1;
			endif;

			// Make weekend days invisible if necessary.
			
			theCalendarDay.visible := self.isShowWeekends or workDate.dayOfWeek &lt; 6;

			if dayNumber = 0 or dayNumber &gt; daysInMonth then
				theCalendarDay.setDay(0);
				theCalendarDay.backColor := self.unavailableColor;
				
				if monthRow &gt; self.numberOfWeeks then
					theCalendarDay.visible := false;
				endif;
				
				continue;
			endif;

			// Must be a vaild date in the month.
			
			theCalendarDay.setDay(dayNumber);
			theCalendarDay.backColor	:= self.availableColor;
			theCalendarDay.foreColor	:= self.availableTextColor;

			// Update caption with any events for this day.
			
            theCalendarDay.refreshCaption();
		endforeach;
	endforeach;

    // Now resize with new settings.
    
    self.resizeContents();
epilog	
	delete dayIter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="f8dae070-59e4-4937-a837-971ceba85a3f">
        <updating/>
        <source>repositionAfterResize() updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Repositions the child controls after the receiver is resized.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
   	newLeft		: Real;
   	newTop		: Real;
   	newWidth	: Real;
   	newHeight	: Real;

begin
	newLeft		:= self.left;
	newTop		:= self.top;
	newWidth	:= self.width;
	newHeight	:= self.height;

	if isLockRight then
		newLeft		:= (parent.width - newWidth - distanceFromRight).max(0);
	endif;
	
	if isLockBottom then
		newTop		:= (parent.height - newHeight - distanceFromBottom).max(0);
	endif;
	
	if isStretchWidth then
		newWidth	:= (parent.width - newLeft - distanceFromRight).max(0);
	endif;
	
	if isStretchHeight then
		newHeight	:= (parent.height - newTop - distanceFromBottom).max(0);
	endif;

	if newLeft &lt;&gt; self.left
	or newTop &lt;&gt; self.top
	or newWidth &lt;&gt; self.width
	or newHeight &lt;&gt; self.height
	then
		self.move(newLeft, newTop, newWidth, newHeight);
		self.resizeContents();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeContents" id="07a23a6c-f1b0-4de1-bb7e-a8bb7e573707">
        <updating/>
        <source>resizeContents() updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Resizes the receiver's child controls.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	MAX_MONTH_HEADING_HEIGHT	: Integer = 50;
	MAX_DAY_HEADING_HEIGHT		: Integer = 30;
	MONTH_HEADING_PROPORTION	: Decimal = 0.1;
// cnwdad1 20/05/2001.  Where the calendar control is quite small, the day heading names were too large for the row.
	DAY_HEADING_PROPORTION		: Decimal = 0.12;	// 0.08;

vars
	numberOfColumns		: Integer;
	widthPerColumn		: Real;
	heightPerRow		: Real;
	nextLeft			: Real;
	nextTop				: Real;
	firstDayRowTop		: Real;
	theControl			: Control;
	columnNumber		: Integer;
	monthColumn			: Integer;
	columnWidth			: Integer;
	monthRow			: Integer;
	rowHeight			: Integer;
	dayIter				: Iterator;
	monthHeadingHeight	: Integer;
	dayHeadingHeight	: Integer;
	maxDayFontSize		: Real;

begin
	// Handle resize call before control has been built.
	
	if self.myMonthHeading = null then
		return;
	endif;

	if self.isShowWeekends then
		numberOfColumns	:= 7;
	else
		numberOfColumns	:= 5;
	endif;

	monthHeadingHeight	:= MAX_MONTH_HEADING_HEIGHT.min((self.clientHeight() * MONTH_HEADING_PROPORTION).Integer);
	dayHeadingHeight	:= MAX_DAY_HEADING_HEIGHT.min((self.clientHeight() * DAY_HEADING_PROPORTION).Integer);	

	widthPerColumn		:= self.clientWidth() / numberOfColumns;
	heightPerRow		:= self.clientHeight() - dayHeadingHeight;
	
	if self.isShowMonthHeading then
		heightPerRow	:= heightPerRow - monthHeadingHeight;
	endif;
	
	heightPerRow	:= heightPerRow / self.numberOfWeeks;

	// First size month heading.
	
	nextTop := 0;
	
	if self.isShowMonthHeading then
		myMonthHeading.move(0, nextTop, self.clientWidth(), monthHeadingHeight);
		myMonthHeading.setMaximumFontSize();
		nextTop := monthHeadingHeight;
	endif;

	// Then size the day headings.
	
	nextLeft		:= 0;
	columnNumber	:= 0;
	maxDayFontSize	:= 100;
	
	foreach theControl in self.allDayHeadings do
		if theControl.visible then
			columnNumber	:= columnNumber + 1;
			columnWidth		:= (columnNumber * widthPerColumn - nextLeft).rounded;
			theControl.move(nextLeft, nextTop, columnWidth, dayHeadingHeight);
			theControl.JSSCalendarHeading.setMaximumFontSize();
			maxDayFontSize	:= theControl.fontSize.min(maxDayFontSize);
			nextLeft		:= nextLeft + columnWidth;
		endif;
	endforeach;

	// Now set all the font sizes for the days to the same value.
	
	foreach theControl in self.allDayHeadings do
		if theControl.visible then
			theControl.fontSize := maxDayFontSize;
		endif;
	endforeach;

	nextTop			:= nextTop + dayHeadingHeight;
	firstDayRowTop	:= nextTop;

	// Now size all the days.
	
	dayIter := self.allDays.createIterator();
	
	foreach monthRow in 1 to self.numberOfWeeks do
		rowHeight		:= (monthRow * heightPerRow + firstDayRowTop - nextTop).rounded;
		columnNumber	:= 0;
		nextLeft		:= 0;
		
		foreach monthColumn in 1 to 7 do
			dayIter.next(theControl);
			
			if theControl.visible then
				columnNumber	:= columnNumber + 1;
				columnWidth		:= (columnNumber * widthPerColumn - nextLeft).rounded;
				theControl.move(nextLeft, nextTop, columnWidth, rowHeight);
				nextLeft		:= nextLeft + columnWidth;
			endif;
		endforeach;
		
		nextTop := nextTop + rowHeight;
	endforeach;
epilog
	delete dayIter;
end;</source>
    </JadeMethod>
    <JadeMethod name="setAvailableColor" id="6937c894-ea81-4152-bc62-2879577cbf12">
        <updating/>
        <source>setAvailableColor(pValue: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Updates the color for an available day, and resets all other colors.
//
// Parameters:	pValue - The new color for available days.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
   	if self.availableColor &lt;&gt; pValue then 
   		self.changeColors(	self.availableColor,
   							pValue,
   							self.unavailableColor,
   							self.unavailableTextColor,
   							self.highlightColor,
   							self.highlightTextColor,
   							self.headingTextColor,
   							self.headingColor);
		self.availableTextColor := pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setAvailableTextColor" id="fb640597-2dde-45d7-b24d-c992121fb9af">
        <updating/>
        <source>setAvailableTextColor(pValue: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Updates the text color for an available day, and resets all other
//				colors.
//
// Parameters:	pValue - The new text color for available days.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDisplayMonth" id="55676910-deeb-4523-84a6-352c7e910fd9">
        <updating/>
        <source>setDisplayMonth(pMonth:Integer; pYear:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Updates the currently displayed month and year.
//
// Parameters:	pMonth - The new month to display.
//				pYear - The new year to display.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.currentMonth &lt;&gt; pMonth or self.currentYear &lt;&gt; pYear then
		self.setSelectedDate(null, false);

		self.currentMonth	:= pMonth;
		self.currentYear	:= pYear;

		self.redrawSelf();
		self.monthChange(self);
	endif;
end;</source>
        <Parameter name="pMonth" type="Integer"/>
        <Parameter name="pYear" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setHeadingColor" id="68dff807-df36-4bcc-8e04-f2d0857ef905">
        <updating/>
        <source>setHeadingColor(pValue: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Updates the color for headings, and resets all other colors.
//
// Parameters:	pValue - The new color for the headings.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.headingColor &lt;&gt; pValue then 
  		self.changeColors(	self.availableColor,
  							self.availableTextColor,
  							self.unavailableColor,
  							self.unavailableTextColor,
  							self.highlightColor,
  							self.highlightTextColor,
  							self.headingTextColor,
  							pValue);
		self.headingColor := pValue;
	endif;
end;</source>
