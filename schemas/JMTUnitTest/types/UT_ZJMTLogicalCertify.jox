    <JadeMethod name="iCheckForRoadOps79731Error" id="0b2dec97-6f9f-4816-9722-c7cd18171b6b">
        <source>iCheckForRoadOps79731Error();

/*

Purpose:		Check to see if 79731 on Road Ops might occur

Date			Who		Reason
06/05/2014		cnwmh5	Initial creation

*/

vars

	request							: CM_Request;

	requestSet						: CM_RequestSet;
	errorArray						: StringArray512;
	
	str								: String;
	written							: Boolean;
	details							: String;
	
begin

	create errorArray transient;
	
	create requestSet transient;
	CM_YardDeliveryRequest.instances.copyNoDups(requestSet);
	CM_DeliveryRequest.instances.copyNoDups(requestSet);
	CM_TIRequest.instances.copyNoDups(requestSet);
	
	foreach request in requestSet do
		
		details := null;
		
		if request.isKindOf(CM_TIRequest) then
			
			if request.CM_TIRequest.trackedItem = null or global.isValidObject(request.CM_TIRequest.trackedItem) then
				continue;
			endif;
			if request.myJob = null and request.bulkRelease = null then
				continue;
			endif;
			if request.myJob &lt;&gt; null and request.myJob.getMyTerminal().code &lt;&gt; "UT" then
				continue;
			endif;
			if request.bulkRelease &lt;&gt; null and request.bulkRelease.myTerminal.code &lt;&gt; "UT" then
				continue;
			endif;
			if request.CM_TIRequest.trackedItem = null then
				continue;
			endif;
			if global.isValidObject(request.CM_TIRequest.trackedItem) then
				continue;
			endif;	
			
			details := global.isValidObject(request.CM_TIRequest.trackedItem).String;
			
		elseif request.isKindOf(CM_DeliveryRequest) then
		
			if request.CM_DeliveryRequest.myCargoType = null then
				continue;
			endif;
			if global.isValidObject(request.CM_DeliveryRequest.myCargoType) then
				continue;
			endif;
			
			details := global.isValidObject(request.CM_DeliveryRequest.myCargoType).String;
		
		else
			
			details := null;
						
		endif;
		
		if details = null then
			continue;
		endif;
		
		if request.myJob &lt;&gt; null then
			details := request.identity.String &amp; Tab &amp; request.creationTime.String &amp; Tab &amp; request.myJob.String &amp; Tab &amp; 
				request.myJob.id &amp; Tab &amp; request.myJob.getMyTerminal().code &amp; Tab &amp; details;
		endif;
		
		if request.bulkRelease &lt;&gt; null then
			details := request.identity.String &amp; Tab &amp; request.creationTime.String &amp; Tab &amp; request.bulkRelease.String &amp; Tab &amp; 
				request.bulkRelease.code &amp; Tab &amp; request.bulkRelease.myTerminal.code &amp; Tab &amp; details;
		endif;
		
		errorArray.add(details);
		
	endforeach;	
	
	written := false;
	foreach str in errorArray do
		if not written then
			app.writeLog("The following request's have an invalid cargoType or trackedItem", LogINFO);
			written := true;
		endif;
		app.writeLog(str, LogINFO);
	endforeach;
	
	self.assertEqual(errorArray.size, 0);
		
epilog

	//delete deliveryRequestSet;
	delete requestSet;
	delete errorArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="iHandleAutoCollection" id="aee82c66-64a5-4c7b-96e9-ab1fb1cf25c3">
        <source>iHandleAutoCollection(_exc : Exception; _obj : Object; _invalidObject : Boolean io) : Integer;
//
// 18 Nov 2019	jlgrs1	TFS 47300 collections not in pxyCreateUpdateProxy method
//
constants
	CollAutomatic = 1088;
vars
	returnVal : Integer;
begin
	returnVal := Ex_Pass_Back;
	
	// PAR #27142 - if the handler has been armed for a local variable that has not yet been
	// initialised when the exception occurs, then it is not for us, so just pass back immediately
	if _obj = null then				
		return returnVal;
	endif;
	
	if _exc.errorCode = CollAutomatic then
		if _exc.errorObject = _obj or 
		   self.getOwnerForObject(_exc.errorObject) = _obj then
			// Set _invalidObject, and resume in the calling method, which will then
			// interrogate excOccurred, to identify an invalid/deleted object
			_invalidObject := true;
			if _exc.resumable then
				returnVal := Ex_Resume_Next;
			endif;
		endif;
	endif;
epilog
	return returnVal;
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_invalidObject" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tCheckBulkItemsTermIsInvalid" id="28077352-adee-45ef-8801-561c3895d38a">
        <source>tCheckBulkItemsTermIsInvalid();

/*

Purpose:		Check to see if the bulk item's terminal has been trashed	

Date			Who		Reason
02/10/2014		cnwmh5	Initial creation

*/

vars
	
	bulk			: CM_Bulk;
	
	errorStrArray	: StringArray512;

begin

	// 30/06/2014 cnwmh5 - Check to see if any bulk items are getting their terminal trashed
	create errorStrArray transient;
	foreach bulk in CM_Bulk.instances do
		if not global.isValidObject(bulk.myTerminal) then
			errorStrArray.add("TI (" &amp; bulk.String &amp; " - " &amp; bulk.id &amp; ") has an invalid terminal and was created on " &amp; bulk.creationTime.String);
		endif;
	endforeach;
	
	self.assertEqualMsg(errorStrArray.isEmpty(), true, errorStrArray.concatenate(CrLf) &amp; CrLf &amp; errorStrArray.size.String);
	

epilog

	delete errorStrArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckCMQFrefsAndColls1" id="9ddac4bc-8b43-41e1-ac1b-12ebfba37cf1">
        <source>tCheckCMQFrefsAndColls1();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2016	cnwndl1	Initial creation	TFS 2329

		This test is looking for non-inversed references ( and collections ) in sub-classes
		of the CMQF_FilterReports objects.
		These may be left with invalid references as the result of a delete of an object.
		While the CMQF's are declared as transients, some are actually presisted and stored
		with report templates etc.
		If you touch a Template (i.e. try to use it or click on it in the Report Runner form)
		and it has one of these invalid object refs you will get a crash.
		Approx 700 methods were updated to try to avoid this happening.
		The singleton refs are now all declared as 'protected' and should only be accessed by
		their respective 'set' and 'get' methods.
		The collections are generally protected via exception handlers, and the generic
		'removeInvalidObjects' method.
		The following code should alert us to new 'non inversed' refs being added so that they
		can be appropriately checked.

*/

vars

	schema : Schema;
	classColl : ClassColl;
	class : Class;
	iterClass : Iterator;
	
	propColl : PropertyNDict;
	iterProp : Iterator;
	prop : Property;
	ref : Reference;
	collClass : CollClass;
	
	collClassesEffected : ObjectArray;
	effectedClass : Type;
	
	obj : Object;
	
	errMessage : String;

begin

	schema := currentSchema;
	while schema.name &lt;&gt; "PortSchema" do
		schema := schema.superschema;
	endwhile;
	
	classColl := schema.getAllClasses(false);
	
	create collClassesEffected transient;

	iterClass := classColl.createIterator;
	while iterClass.next( class ) do
		if not class.inheritsFrom( CMQF_FilterReports ) then
			//not a class we care about
			continue;
		endif;
		propColl := class.getProperties();
		iterProp := propColl.createIterator;
		while iterProp.next ( prop ) do
			if not prop.isKindOf(Reference) then
				// this property is not object or collection related
				continue;
			endif;
			ref := prop.Reference;
			if ref.isKindOf(ExplicitInverseRef) then
				// this one is inversed, it will look after itself
				continue;
			endif;
			
			if prop.getType.inheritsFrom( Collection ) then
				collClass :=  prop.getType.CollClass;
				effectedClass := collClass.getMemberType;
				if effectedClass = CM_Debtor then
					if class = CMQF_CashCredit
					or class = CMQF_CashReceipt
					or class = CMQF_CashTransactions
					or class = CMQF_InvoiceContract
					then
						//now handled in CM_Debtor::erase
						continue;
					endif;
				elseif effectedClass = CM_TerminalArea then
					if class = CMQF_Container
					or class = CMQF_FilterReports
					then
						//now handled in CM_TerminalArea::erase
						continue;
					endif;
				elseif effectedClass = CM_Machine then
					if class = CMQF_CraneKPI
					then
						//now handled in CM_Machine::erase
						continue;
					endif;
				elseif effectedClass = CMIF_MTReportDetail then
					if class = CMQF_Empty
					or class = CMQF_EmptySum
					then
						//already handled in CMQF_Empty::delete &amp; CMQF_EmptySum::delete
						continue;
					endif;
				elseif effectedClass = CMIF_ExportStiffSum then
					if class = CMQF_ExportStiff
					then
						//now handled in CMQF_ExportStiff::delete
						continue;
					endif;
				elseif effectedClass = CM_Voyage then
					if class = CMQF_HMSVoyages
					or class = CMQF_TerminalTIs
					or class = CMQF_TrainLoadListTIs
					or class = CMQF_InvoiceProforma
					then
						//now handled in CM_Voyage::erase
						continue;
					endif;
				elseif effectedClass = CM_Bank then
					if class = CMQF_Invoice
					or class = CMQF_InvoiceLine
					then
						//now handled in CM_Bank::delete
						continue;
					endif;
				elseif effectedClass = CM_Port then
					if class = CMQF_TerminalTIs
					or class = CMQF_VoyageGeneralCargoSummary
					or class = CMQF_VoyageSummary
					then
						//now handled in CM_Port::erase
						continue;
					endif;
				elseif effectedClass = CM_CargoType then
					if class = CMQF_TerminalTIs
					or class = CMQF_VoyageSummary
					then
						//now handled in CM_CargoType::delete
						continue;
					endif;
				elseif effectedClass = CM_BOL then
					if class = CMQF_VoyageGeneralCargoSummary
					then
						//now handled in CM_BOL::delete
						continue;
					endif;
				elseif effectedClass = CM_ToDoTaskDesc then
					if class = CMQF_TerminalTIs
					or class = CMQF_ResourceUsage
					or class = CMQF_WOTransactions
					then
						//now handled in CM_ToDoTaskDesc::delete
						continue;
					endif;
				elseif effectedClass = CM_Train then
					if class = CMQF_TrainLoadListTIs
					then
						//now handled in CM_Train::erase
						continue;
					endif;
				elseif effectedClass = CM_TrackedItem then
					if class = CMQF_TerminalTIs
					or class = CMQF_TrackedItem
					or class = CMQF_TrainLoadListSummary
					or class = CMQF_TrainLoadListTIs
					or class = CMQF_VoyageGeneralCargoSummary
					or class = CMQF_InvoiceProforma
					then
						//now handled in CM_ToDoTaskDesc::delete
						continue;
					endif;
				elseif effectedClass = CM_InvoiceDesc then
					if class = CMQF_Invoice and prop.name = CMQF_Invoice::allInvoiceTypes.name
					then
						//now handled in CMQF_Invoice::cloneReferences
						continue;
					endif;
				elseif effectedClass = CM_InvoiceLineDesc then
					if class = CMQF_InvoiceLine and prop.name = CMQF_InvoiceLine::allInvoiceLineTypes.name
					then
						//never referenced
						continue;
					elseif class = CMQF_InvoiceContract and prop.name = CMQF_InvoiceContract::allInvoiceLineTypes.name then
						// handled in CM_InvoiceLineDesc erase
						continue;
					endif;
				elseif effectedClass = CM_DelayTypeGroup then
					if class = CMQF_MachineHistory
					then
						//now handled in the 6 current references
						continue;
					endif;
				elseif effectedClass = CM_DelayType then
					if class = CMQF_MachineHistory
					then
						//now handled in the 6 current references
						continue;
					endif;
				elseif effectedClass = CMIF_SpecialStowSummary then
					if class = CMQF_PlanWeightSummary
					then
						//now handled in the 1 current reference
						continue;
					endif;
				elseif effectedClass = CM_String then
					if class = CMQF_PlanWeightSummary
					then
						//not currently referenced
						continue;
					endif;
				elseif effectedClass = CMIF_SOHReporter then
					if class = CMQF_SOHLocation
					then
						//now handled in the 1 current reference
						continue;
					endif;
				elseif effectedClass = CM_StopsTable then
					if class = CMQF_TrackedItem
					then
						//now handled in the 5 current references
						continue;
					endif;
				elseif effectedClass = CM_VoyageJob then
					if class = CMQF_TrackedItem
					then
						//now handled in the 4 current references
						continue;
					endif;
				elseif effectedClass = CM_WorkListEntry then
					if class = CMQF_TrainLoadListSummary
					then
						//now handled in the 2 current references
						continue;
					endif;
				elseif effectedClass = CM_Hold then
					if class = CMQF_VoyageSummary
					then
						//now handled in the 8 current references
						continue;
					endif;
				elseif effectedClass = CM_QueryReportParam then
					if class = CMQF_FilterReports
					then
						//now handled in the 7 current references
						continue;
					endif;
				elseif effectedClass = CM_QueryCriteriaLineHolder then
					if class = CMQF_FilterReports
					then
						//deliberately ignoring this one.
						//will deal with any issues in this one, if and when they arise.
						continue;
					endif;
				elseif effectedClass = CM_EventType then
					if class = CMQF_ASPAReports
					then
						//now handled in the 4 current references
						continue;
					endif;
					
				elseif effectedClass = CM_Vessel then
					if class = CMQF_ASPAReports
					then
						//handled 1 current references
						continue;
					endif;
					
				elseif ( effectedClass = CMIF_LocActRepInventoryLine or
						effectedClass = CMIF_LocActRepThroughPutSum or
						effectedClass = CMIF_LocActRepThroughPut
						) then
					//transient class, purged in CMQF_LocationActivity collection
					continue;
					
				elseif effectedClass = CM_CalculationType then
					if class = CMQF_InvoiceContract then
						// handled in CM_CalculationType delete
						continue;
					endif;
					
				elseif effectedClass = CM_InvoiceContract then
					if class = CMQF_InvoiceContract then
						// handled in CM_InvoiceContract delete
						continue;
					endif;
				
				// 24/01/2024 NAVKC1
				elseif effectedClass = CM_InvoiceContractDetails then
					if class = CMQF_InvoiceContract then
					// handled in CM_InvoiceContractDetails delete
						continue;
					endif;
				
				// 24/01/2024 NAVKC1
				elseif effectedClass = CM_InvoiceContractRateEntry then
					if class = CMQF_InvoiceContract then
					// handled in CM_InvoiceContractRateEntry delete
						continue;
					endif;
					
				elseif effectedClass = CM_Service then
					if class = CMQF_InvoiceContract then
						// handled in CM_Service erase
						continue;
					endif;
					
				elseif effectedClass = CM_InvoiceUnitOfMeasure then
					if class = CMQF_InvoiceContract then
						// handled in CM_InvoiceUnitOfMeasure delete
						continue;
					endif;
				elseif effectedClass = CM_VehicleBookingTimeSlotType then
					if class = CMQF_VehicleBookingReport then
						continue;
					endif;
				endif;
			else
				if prop.Reference.access = 2.Character then
					//protected, so should have get and set methods to protect against bad refs...
					continue;
				endif;
				effectedClass := prop.getType;
			endif; 
			
			if effectedClass = null or effectedClass.isKindOf(PrimType) then
				//string arrays, integer arrays etc, can be created as references, but we are not interested in them.
				continue;
			endif;
			
			if effectedClass.isKindOf(Class) then
			
				if effectedClass = CM_Terminal
				or effectedClass = CM_User
				or effectedClass = CM_Operator
				or effectedClass = CM_Cash
				or effectedClass = CM_Invoice
				or effectedClass = CM_InvoiceLine
				or effectedClass = CM_IMEXStatus
				or effectedClass = CM_BOLType
				or effectedClass = CM_LogLot  // just not dicking with this one.
				or effectedClass = CMIF_LogSummaryReportData  // or this one.
				then
					//can't be deleted in real systems.
					continue;
				endif;
			
			
				if not collClassesEffected.includes(effectedClass) then
					collClassesEffected.add(effectedClass);
				endif;
			endif;
			
			if effectedClass.isKindOf(Class) then
				if errMessage &lt;&gt; null then
					errMessage := errMessage &amp; CrLf;
				endif;
				errMessage := errMessage &amp; class.name &amp; "." &amp; prop.name &amp; ", kind = " &amp; effectedClass.name;
			else
				if errMessage &lt;&gt; null then
					errMessage := errMessage &amp; CrLf;
				endif;
				errMessage := errMessage &amp; class.name &amp; "." &amp; prop.name &amp; ", kind (NON CLASS)  = " &amp; effectedClass.String;
			endif;
			
		endwhile;
		delete iterProp;
		
	endwhile;
	
	self.assertTrueMsg(errMessage = null, errMessage);
	
epilog

	delete classColl;
	delete iterClass;
	delete iterProp;
	delete collClassesEffected;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckCMQFrefsAndColls2" id="6bbbca25-29b7-4f02-a5e0-cec7f04bec5c">
        <source>tCheckCMQFrefsAndColls2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2016	cnwndl1	Initial creation	TFS 2329

		This test is looking for invalid object references ( and collections ) in sub-classes
		of the CMQF_FilterReports objects.
		See 'tCheckCMQFrefsAndColls1' to see why.

*/

vars

	schema : Schema;
	classColl : ClassColl;
	class : Class;
	iterClass : Iterator;
	
	propColl : PropertyColl;
	iterProp : Iterator;
	prop : Property;
	ref : Reference;
	collClass : CollClass;
	effectedClass : Type;
	
	iterClassInst : Iterator;
	classInstance : Object;
	propertyValueObject : Object;
	
	errorMess : String;
	invalid : Boolean;
	edition : Integer;
	
	collPropObjectsIter : Iterator;
	collection : Collection;
	
begin

	//get a collection of all of the classes in PortSchema so we can find all of the CMQF_FilterReports sub classes
	schema := currentSchema;
	while schema.name &lt;&gt; "PortSchema" do
		schema := schema.superschema;
	endwhile;	
	classColl := schema.getAllClasses(false);
	
	on Exception do app.handleDeletedObject( exception, propertyValueObject, invalid );

	iterClass := classColl.createIterator;
	// iterate thru each of the classes.
	while iterClass.next( class ) do
		if not class.inheritsFrom( CMQF_FilterReports ) then
			//not a class we care about
			continue;
		endif;
		
		//get a collection of the properties on this class, so we can find all of the non-inversed references and collections to check
	//	propColl := class.getProperties();
		propColl := class.allPropertiesUpTo(CMQF_FilterReports);
		iterProp := propColl.createIterator;
		while iterProp.next ( prop ) do
			if not prop.isKindOf(Reference) then
				// this property is not an object or a collection
				continue;
			endif;
			ref := prop.Reference;
			if ref.isKindOf(ExplicitInverseRef) then
				// this one is inversed, it will look after itself
				continue;
			endif;
			
			//Ok we have a non inversed collection or singleton that could cause us grief.
			if ref.getType.inheritsFrom( Collection ) then
				collClass :=  ref.getType.CollClass;
				//This one is a collection
				effectedClass := collClass.getMemberType;
				
				if effectedClass = null or effectedClass.isKindOf(PrimType) then
					//string arrays, integer arrays etc, can be created as references, but we are not interested in them.
					continue;
				endif;
				//should be a collection of objects
				iterClassInst := class.instances.createIterator;
				while iterClassInst.next( classInstance ) do
					invalid := false;
					collection := classInstance.getPropertyValue( ref.name ).Collection;
					if collection = null or collection.isEmpty then
						continue;
					else
						collPropObjectsIter := collection.createIterator;
						while collPropObjectsIter.next( propertyValueObject ) do
							edition := propertyValueObject.edition;
							if invalid then
								if errorMess &lt;&gt; null then
									errorMess := errorMess &amp; CrLf;
								endif;
								errorMess := errorMess &amp; classInstance.String &amp; " : '" &amp; ref.name &amp; "' contains an invalid object" ;
								break;
							endif;
						endwhile;
						delete collPropObjectsIter;
					endif;
				endwhile;
				delete iterClassInst;
				
			else
				//should be a singleton reference
				iterClassInst := class.instances.createIterator;
				while iterClassInst.next( classInstance ) do
					invalid := false;
					propertyValueObject := classInstance.getPropertyValue( ref.name ).Object;
					if propertyValueObject = null then
						continue;
					else
						edition := propertyValueObject.edition;
						if invalid then
							if errorMess &lt;&gt; null then
								errorMess := errorMess &amp; CrLf;
							endif;
							errorMess := errorMess &amp; classInstance.String &amp; " : '" &amp; ref.name &amp; "' is invalid" ;
						endif;
					endif;
				endwhile;
				delete iterClassInst;
			endif; 
			
		endwhile;
		delete iterProp;
		delete propColl;
		
	endwhile;
	
	self.assertTrueMsg(errorMess = null, errorMess);
	
epilog

	delete classColl;
	delete iterClass;
	delete iterProp;
	delete iterClassInst;
	delete collPropObjectsIter;
	delete propColl;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckCMStrings" id="d8ed7756-1208-4c4a-9be7-ad9a22be1f02">
        <source>tCheckCMStrings();
// jlgmd1
// cnwkpd1
/*
Purpose:			Check all the CM_Strings instances to ensure they are all linked to a
					parent object

Date		Who		Reason
06 Jul 2015	cnwkpd1	PAR #36578 - Tidy up leaked CM_Strings objects
	
*/

vars
	oa 				: ObjectArray;
	s				: CM_Strings;
	
begin
	create oa transient;
	
	foreach s in CM_Strings.instances do
		if s.myObject = null then
			oa.add(s);
		endif;
	endforeach;

	self.assertEqual(oa.size, 0);	

epilog
	delete oa;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckCargoTypesSetupCorrectly" id="2ee136cb-8e23-4060-8031-678f966a5269">
        <source>tCheckCargoTypesSetupCorrectly();

/*

Purpose:		Check that Cargo Types have been set up correctly

Date			Who		Reason
05/11/2014		cnwmh5	Initial creation

*/

vars

	cargoType					: CM_CargoType;
	terminal					: CM_Terminal;
	
	tiArray						: CM_TIArray;
	
	iter						: Iterator;
	iter2						: Iterator;
	
	msg							: String;
	issueSubType				: Boolean;
	issueCommodity				: Boolean;
	tiMessage					: String;
	issueFound					: Boolean;

begin

	msg := CrLf;
	
	create tiArray transient;

	iter := app.myRoot.allCargoTypesById.createIterator;
	while iter.next(cargoType) do
		issueSubType := false;
		issueCommodity := false;
		// check cargo types subtype required against number of subtypes
		if cargoType.isSubCargoTypeRequired and cargoType.allProducts.isEmpty() then
			issueSubType := true;
		endif;
		//  check cargo types commodity required against number of commodities
		if cargoType.isCommodityRequired and cargoType.allCommodities.isEmpty() then
			issueCommodity := true;
		endif;
		if issueCommodity or issueSubType then
			// check the terminal to see if any tracked items exist
			tiMessage := null;
			delete iter2;
			iter2 := app.myRoot.allTerminals.createIterator;
			while iter2.next(terminal) do
				self.opts.purge();
				self.opts.addAssoc("Terminal", terminal.code);
				self.getTIsByCargoTypeNoTIId(cargoType, true, tiArray);
				
				if not tiArray.isEmpty() then
					tiMessage := tiMessage &amp; CrLf &amp; Tab &amp; "Terminal (" &amp; terminal.code &amp; " - " &amp; terminal.name &amp; 
						") has " &amp; tiArray.size.String &amp; " Tracked Items" ;
				endif;
			endwhile;
			msg := "Cargo Type (" &amp; cargoType.abbreviation &amp; " - " &amp; cargoType.description &amp; ") created on " &amp; cargoType.creationTime.date.format("dd/MM/yyyy");
			if issueCommodity then
				msg := msg &amp; CrLf &amp; Tab &amp; "Commodity Required checked but no commodities";
			endif;
			if issueSubType then
				msg := msg &amp; CrLf &amp; Tab &amp; "SubType Required check but no subTypes";
			endif;
			if tiMessage &lt;&gt; null then
				msg := msg &amp; tiMessage;
			endif;
			app.writeLog(msg, LogINFO);
			issueFound := true;
		endif;
	endwhile;
	
	self.assertFalse(issueFound);

epilog

	delete iter;
	delete iter2;
	delete tiArray;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Fails&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tCheckClassMapFiles" id="4db8b1f9-5c1d-446a-ae26-6eca12d343c7">
        <source>tCheckClassMapFiles();
// cnwmh5
/*

Purpose:			Check that JMTUnitTest (schema) classes are mapped to the 'unitTest' dat file
					And that WebServicesSchema classes are mapped to the 'webservice' dat file
					Except for REST web services, which are mapped to the 'restwebservice' dat file

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2013	cnwmc5	Initial creation

*/

vars
	klass				: Class;
	classesToIgnore 	: ClassColl;
	invalidMapClasses	: ClassColl;
	
	scm					: Schema;
	restReq,
	restReq2,
	restRes,
	restNavisPxy,
	restGAPI,
	restPxy,
	restRequest,
	restObjArr,
	restInternalObj,
	restInternalResponse,
	restIntObjArr,
	restWebAgent,
	restResponse		: Class;
	
	dbClassMap			: DbClassMap;
	
begin
	scm := rootSchema.getSchema(WebServicesSchemaName);
	self.assertNotNullMsg(scm, "Unable to find WebServicesSchema");
	restReq				:= scm.getClass("WS_NavisRestRequest");
	restReq2			:= scm.getClass("WS_RestRequest");
	restRes				:= scm.getClass("WS_NavisRestResponse");
	restNavisPxy		:= scm.getClass("WS_NavisProxyObject");
	restGAPI			:= scm.getClass("WS_GenericAPIObject");
	restPxy				:= scm.getClass("WS_RestProxyObject");
	restRequest			:= scm.getClass("WS_RestRequest");
	restObjArr			:= scm.getClass("WS_RestObjArray");
	restInternalObj		:= scm.getClass("WS_RestInternalProxyObject");
	restInternalResponse:= scm.getClass("WS_RestInternalResponse");
	restIntObjArr		:= scm.getClass("WS_RestIntObjArray");
	restWebAgent		:= scm.getClass("WS_RestWebServiceAgent");
	restResponse		:= scm.getClass("WS_RestResponse");
	
	create classesToIgnore transient;
	classesToIgnore.add(self.getClass("JMTUnitTest"));
	classesToIgnore.add(self.getClass("GJMTUnitTest"));
	classesToIgnore.add(self.getClass("SJMTUnitTest"));
	
	classesToIgnore.add(self.getClass("CMUI_Graph"));
	classesToIgnore.add(self.getClass("CMUI_BarGraph"));
	classesToIgnore.add(self.getClass("CMUI_GraphLegend"));
	classesToIgnore.add(self.getClass("CMUI_LineGraph"));
	classesToIgnore.add(self.getClass("CMUI_PointLineGraph"));
	
	classesToIgnore.add(scm.getClass("WebServicesSchema"));
	classesToIgnore.add(scm.getClass("SWebServiceSchema"));
	classesToIgnore.add(scm.getClass("WS_UnitTestAgent"));
	
	classesToIgnore.add(self.getClass(UT_ListTable.name));
	classesToIgnore.add(self.getClass(UT_Table.name));
	
	create invalidMapClasses transient;
	foreach dbClassMap in DbClassMap.instances do
		klass := dbClassMap.diskClass;
		
		// Check JMTUnitTest Maps
		if (klass.schema.name = "JMTUnitTest" 
			and not classesToIgnore.includes(klass)
			and klass.getDbFile.name &lt;&gt; "unitTest")
		or	// Check WebServicesSchema Maps
			(klass.schema.name = WebServicesSchemaName
			and not classesToIgnore.includes(klass)
			and klass.getDbFile.name &lt;&gt; "webservice")
		then
			// REST webservices are 'special'
			if (klass.isSubclassOf(JadeRestService)
				or klass.isSubclassOf(restReq)
				or klass.isSubclassOf(restReq2)
				or klass.isSubclassOf(restRes)
				or klass.isSubclassOf(restPxy)
				or klass.isSubclassOf(restGAPI)
				or klass.isSubclassOf(restNavisPxy)
				or klass.isSubclassOf(restObjArr)
				or klass.isSubclassOf(restInternalObj)
				or klass.isSubclassOf(restInternalResponse)
				or klass.isSubclassOf(restIntObjArr)
				or klass.isSubclassOf(restResponse)
				or klass = restGAPI
				or klass = restRequest
				or klass = restObjArr
				or klass = restInternalObj
				or klass = restInternalResponse
				or klass = restIntObjArr
				or klass = restWebAgent
				or klass = restResponse
				)
				and klass.getDbFile.name = "restwebservice"
			then
				continue;
			endif;
			
//			if klass.countPersistentInstances &gt; 0 then
				invalidMapClasses.add(klass);
				app.writeLog("Map file: " &amp; klass.getDbFile.name &amp; " - Class: " &amp; klass.name, LogINFO);
//			endif;
		endif;
	endforeach;
	
	self.assertEqualMsg(invalidMapClasses.size, 0, "Check error log for invalid Class maps");
epilog
	delete classesToIgnore;
	delete invalidMapClasses;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckConstPermFormTypeIsSet" id="31db7a17-da30-4cab-9b4a-cc1ee5365ebf">
        <source>tCheckConstPermFormTypeIsSet();
/*

Purpose: Validates each of the Constants permission has the new 'View' or 'Maint' value set

Parameters:			

Return Value:		

Date		Who		TFS		Reason
11 September 2019	jlgdi1			Initial creation

*/

constants
	PERMTYPE_SPECIAL : Integer = 2;
	TYPE_NOT_SET : Integer = 0;
	
vars
	permAgent : CM_PermissionAgent;
	permObj : CM_PermissionObject;

begin
	create permAgent transient;
	permAgent.populatePermissionDict(true, true, 0);
	
	foreach permObj in permAgent.allPermissionsByName do
		if permObj.permType = PERMTYPE_SPECIAL then
			continue;
		endif;
		assertFalseMsg(permObj.formType = TYPE_NOT_SET, 
					   'The form type of ' &amp; permObj.constName &amp; ' must be set to either 1 - Form is View Type or 2 - Form is Maint Type');
	endforeach;

epilog
	delete permAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckCustomsActions" id="3da009ce-0c5c-4d79-b85c-041673e1284d">
        <source>tCheckCustomsActions();
/*

Purpose:			This was added to make sure no one adds Customs Acxtions that will break Unit Tests. Not listed on CR was done as checking/validation test.

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
30 August 2023	navpw1	Initial creation TFS: 60146 (60177)

*/

vars
	allEDIActions			: CM_EDIActionByNameDict;
	ediAction				: CM_EDIAction;
	customsActionsToRemove	: StringArray;
	
begin
	create customsActionsToRemove transient;
	allEDIActions := app.myRoot.allEDIActions;
	
	foreach ediAction in allEDIActions where ediAction.myEDIFileType.type = EDIFileType_JMTInternal do
		if ediAction.name.isOneOf("Add MPI INTERNAL", "MPI BACC REMOVE B07", "MPI Clearance B06", "MPI Clearance B06 MAF",
									"MPI Fumigate Add", "MPI Import Stop", "MPI Import Stop Off B07", "MPI Import Stop Off B04",
									"MPI Import Stop Off B08", "MPI MAF BACC Off", "MPI MAF Stop Off - UT", "MPI Wash Add", "NZCS Clearance 819",
									"NZCS CUST DOC REMOVE C06", "NZCS Clearance C06", "NZCS Export Stop Off 819", "NZCS Import Stop",
									"NZCS Import Stop Off 804", "NZCS Import Stop Off 830", "NZCS Import Stop Off 807", "NZCS Import Stop Off 819", 
									"TSW GC B07", "TSW GC B08", "TSW GC C06", "TSW LAND 1C", "TSW LAND 1O", "TSW TT B07", "TSW TT B08", "TSW TT C06",
									"NZCS Import Stop Off 819-1", "NZCS Import Stop Off 819-2")
		then
			continue;
		endif;
		
		customsActionsToRemove.add(ediAction.name);
		self.logMessage("Please remove: '" &amp; ediAction.name &amp; "'");
		
	endforeach;
	
	self.assertTrueMsg(customsActionsToRemove.isEmpty, "Expected: Empty | Please remove the following: " &amp; customsActionsToRemove.asCSV(false));
	
epilog
	delete customsActionsToRemove;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckDataDumpClasses" id="0ad80799-f265-4a41-b543-ae6c010b53a5">
        <source>tCheckDataDumpClasses();
// jlgmd1
/*	cnwkpd1

Purpose:			Perform a rebuild of the data dump classes using the current code, then perform 
					a validation of all the newly created Data Dump Classes and features to ensure they are valid

Parameters:			None

Return Value:		None

Date		Who		Reason
03 Feb 2017	cnwkpd1	TFS 3243 - JMT push Events
01 Nov 2023 navmd1	TFS 61063 - More checks to highlight 1310 errors because the push events agent does things slightly differently than data extract

*/

vars
	agent 			: CM_DataDumpMaintenanceAgent;
	ddc,
	featureDDC		: CM_DataDumpClass;
	ddf				: CM_DataDumpFeature;
	mappedClass,
	cls				: Class;
	msg				: String;
	feat			: Feature;
	foundOne		: Boolean;
	subs			: ClassColl;
	badFeatures		: ObjectSet;
	fullLogging 	: Boolean;
	pushEventsAgent	: CM_PushEventsAgent;
	now				: TimeStamp;
	source,
	environment,
	aType,
	subType			: String;
	terminal		: CM_Terminal;	
	obj				: CM_Object;
	createdObj		: Boolean;
begin
	
	fullLogging := false;  // Log everything or just the errors
	
	// Use the Data Dump Maintenance agent to rebuild from the current code version
	create agent transient;
	agent.maintainDataDumpClasses();
	agent.maintainDataDumpFeatureUpdate();
	agent.maintainDataDumpDefStoredProcs();
	
	self.assertTrue(app.myPassport.trxCompletedOK);
	
	create pushEventsAgent transient;

	// And validate the resulting structure	
	create badFeatures transient;
	
	foreach ddc in app.myRoot.allDataDumpClasses discreteLock do
		if fullLogging then
			self.logMessage("Checking class " &amp; ddc.className);
		endif;
		
		foreach ddf in ddc.allDataDumpFeatures discreteLock do
			
			if ddf.returnValueIsAnObject then
			
				if ddf.featureName = DataDumpOidStr or
				   ddf.featureName = DataDumpOidHex or
				   ddf.featureName = DataDumpOidBin then
					continue;
				endif;
				
				msg := "  Checking feature " &amp; ddf.featureName;
				
				feat := ddf.myFeature;
				if feat = null then
					mappedClass := ddf.mySubClassFeatureType.Class;
				else
					mappedClass := feat.getType().Class;
				endif;
				
				cls := mappedClass;
				foundOne := false;
				
				// Check that the mapped class or one of its superclasses is also exposed
				while true do
				
					featureDDC := app.myRoot.allDataDumpClasses[cls.name];
					
					if featureDDC &lt;&gt; null then
						if cls = mappedClass then
							msg := msg &amp; Tab &amp; mappedClass.name &amp; " OK";
						else
							msg := msg &amp; Tab &amp; mappedClass.name &amp; " superClass " &amp; cls.name &amp; " OK";
						endif;
						foundOne := true;
						break;
					endif;
					
					// Try the superclasses, up to CM_Object, in case one of them is exposed
					if cls.name = CM_Object.name then
						break;
					endif;
					
					cls := cls.getSuperclass;
				endwhile;

				// If we didn't find a superclass then check all the subclasses of the mapped class
				if not foundOne then
					delete subs;
					create subs transient;
					mappedClass.allSubclasses(subs);
					
					foreach cls in subs do
						featureDDC := app.myRoot.allDataDumpClasses[cls.name];
					
						if featureDDC &lt;&gt; null then
							msg := msg &amp; Tab &amp; "&lt;&lt; " &amp; mappedClass.name &amp; " subClass " &amp; cls.name &amp; " OK";
							foundOne := true;
							break;
						endif;
					endforeach;
				endif;
				
				if not foundOne then
					msg := "*****" &amp; Tab &amp; msg &amp; Tab &amp; "&lt;&lt;&lt;&lt; Class " &amp; mappedClass.name &amp; " is not exposed" &amp; Tab &amp; "*****";
					badFeatures.add(ddf);
					if not fullLogging then
						self.logMessage(msg);
					endif;
				endif;
				
				if fullLogging then
					self.logMessage(msg);
				endif;
			else
				// Check if the subClassName is the same as the DataDumpClass and log a warning so someone can check if the person adding the feature had a stroke and is doing ok... ;)
				// But we can't change the old ones as this clears any existing Data Extracts ... so need to this about this a little more
				/*if ddf.subClassName = ddc.className then
					msg := "*****" &amp; Tab &amp; Tab &amp; "&lt;&lt;&lt;&lt; Feature " &amp; ddf.subClassName &amp; "::" &amp; ddf.featureName &amp; " is being treated like a subclass, but being exposed on the superclass" &amp; Tab &amp; "*****";
					self.logMessage(msg);
				endif;*/
			endif;
		endforeach;
		
		// Make sure Event Stream can send all attributes - this helps pick up duplicates by throwing a 1310 error
		delete subs;
		create subs transient;
		ddc.getRealSubClasses(subs, true);
		
		foreach cls in subs do
			// Some classes are really abstract ones even though they aren't marked as such, so skip them
			if cls = CM_AvailableForRelease or
				cls = CM_MachineHistory
			then
				continue;
			endif;
			
			createdObj := false;
			obj := cls.lastInstance.CM_Object;
			if obj = null then
				// If we don't have a real object yet for some reason, then create a transient one
				// ... no idea if this actually works for the event stream though!
				createdObj := true;
				create obj as cls transient;
			endif;
			
			//self.logMessage("Checking Event Stream JSON for " &amp; obj.String &amp; " (" &amp; cls.name &amp; ")");
			pushEventsAgent.getPushEventsDetailForObject(obj, now, source, environment, terminal, aType, subType);
			if createdObj then
				delete obj;
				createdObj := false;
			endif;
		endforeach;
	
	endforeach;
	
	self.assertEqual(badFeatures.size, 0);
	
epilog
	delete subs;
	delete agent;
	delete badFeatures;
	delete pushEventsAgent;
	
	if createdObj and obj &lt;&gt; null then
		delete obj;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckForPersistents" id="5cadd805-eeba-4cf7-be14-ed86637e543e">
        <source>tCheckForPersistents();
// cnwmk3
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2013	cnwmc5	Initial creation

*/

vars
	klass			: Class;
	
	classes			: ClassColl;
	persistents		: ClassColl;
	
	dbClassMap		: DbClassMap;
	
begin	
	create persistents transient;
	
	classes := currentSchema.getAllClasses(false);
	
	foreach klass in classes do
		if not klass.transient and klass.name.cnContains("UT_") then
			persistents.add(klass);
		endif;
	endforeach;
	
	if persistents.size &gt; 0 then
		foreach klass in persistents do
			app.writeLog(klass.name, LogINFO);
		endforeach;
	endif;
	
	self.assertTrueMsg(persistents.isEmpty, "Unit test classes should not be persistent, '" &amp; persistents.first.String &amp; "' is");
	
epilog
	delete classes;
	delete persistents;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckForTIsToDelete" id="c66d02f8-b363-4d90-bcf6-4bd5050f1879">
        <source>tCheckForTIsToDelete();

/*

Purpose:		Find TI's to delete	

Date			Who		Reason
12/08/2015		cnwmh5	Initial creation

*/
constants
	NextTrackedItemToStartAt		: String = "NextTrackedItemToStartAt: ";
	CommitAt						: Integer = 1000;
	RunForMinutes					: Integer = 20;
vars

	root 							: UM_Root;
	classMethod						: UM_UnitTestClassMethod;
	unitTestResult					: UM_UnitTestResult;
	nextTrackedItemToStartAt		: CM_TrackedItem;
	startAtTI						: CM_TrackedItem;
	objToDelete						: UM_ObjectsToDelete;
	schema							: Schema;
	klass							: Class;
	startAtClass					: Class;
	prop							: Property;
	propObjValue					: Object;
	obj								: Object;
	newTerm							: CM_Terminal;
	newOperator						: CM_Operator;
	cou								: CM_ClipOnUnit;
	passport						: CM_Passport;

	classes							: ClassColl;
	tiSet							: CM_TISet;
	nullRefsDelObjArray				: StringArray;
	properties						: PropertyColl;
	objsToDeleteArray				: ObjectArray;
	
	iterClass						: Iterator;
	iterTI							: Iterator;
	iterProp						: Iterator;
	
	tempStr							: String;
	pos								: Integer;
	startSize 						: Integer;
	totNoToCheck					: Integer;
	noToCheck						: Integer;
	noToDelete						: Integer;
	isInvalidObject					: Boolean;
	runForStartTime					: TimeStamp;
	
begin

	return;

	root := UM_Root.firstInstance;
	self.assertNotNull(root);
	
	schema := rootSchema.getSchema("PortSchema");
	self.assertNotNull(schema);
	
	klass := schema.getClass("CM_TrackedItem");
	self.assertNotNull(klass);
	
	create objsToDeleteArray transient;
			
	newTerm := app.getTerminalByName("Unit Test") ; 
	newOperator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);      
	
	runForStartTime := app.cnGetServerTime();
	runForStartTime := runForStartTime.addMinutes(RunForMinutes);
	
	on Exception do app.handleDeletedObject(exception, propObjValue, isInvalidObject) ; 
	
	create nullRefsDelObjArray transient;
	nullRefsDelObjArray.add("myTerminal");
	nullRefsDelObjArray.add("myCargoType");
	nullRefsDelObjArray.add("myVoyage");
	
	// get all the tracked item classes
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	// get the number of tracked items 
	foreach klass in classes do
		startSize := startSize + klass.instances.size;
	endforeach;
	totNoToCheck := (startSize * (10 / 100)).Integer;
	noToCheck := totNoToCheck;
		
	// work out where we need to start our checking from
	classMethod := root.allRunnableUTClassesMethods[method.getSchemaType().name, method.name];
	if classMethod &lt;&gt; null then
		unitTestResult := classMethod.allUnitTestResults.first;
		tempStr := unitTestResult.details.uncompressToString();
		pos := 1;
		pos := tempStr.pos(NextTrackedItemToStartAt, pos);
		if pos &gt; 0 then
			pos := pos + NextTrackedItemToStartAt.length;
			tempStr := tempStr.scanUntil(Cr, pos);
			pos := 1;
			pos := tempStr.pos("/", pos);
			startAtTI := tempStr[pos+1:end].asObject().CM_TrackedItem;
			startAtClass := startAtTI.getClassForObject(startAtTI);
		endif;
	endif;
	
	// null class so just get the first one in the collection
	if startAtClass = null then
		startAtClass := classes.first;
	endif;
	
	iterClass := classes.createIterator;
	iterClass.startAtObject(startAtClass);
	while iterClass.next(klass) do : maxNumberToDeleteFound
	
		// no instances so go to next class
		if klass.instances.isEmpty() then
			continue;
		endif;
	
		if app.cnGetServerTime() &gt; runForStartTime then
			//iterTI.next(obj);
			nextTrackedItemToStartAt := obj.CM_TrackedItem;
			break maxNumberToDeleteFound;
		endif;
	
		delete tiSet;
		create tiSet transient;
		klass.instances.copy(tiSet);
		
		if startAtTI = null then
			startAtTI := tiSet.first;
		endif;
		
		delete iterTI;
		iterTI := tiSet.createIterator;
		iterTI.startAtObject(startAtTI);
		while iterTI.next(obj) do
		
			// read through the properties and find those that are in error
			delete properties;
			properties := obj.class.allProperties();
			
			delete iterProp;
			iterProp := properties.createIterator;
			while iterProp.next(prop) do
			
				isInvalidObject := false;
			
				// don't want if match any of the following
				if not prop.isKindOf(Reference) or prop.virtual or prop.name[1:1] = "_" or 
						prop.name = "schema" then
					continue;
				endif;
			
				propObjValue  := obj.getPropertyValue(prop.name).Object;
			//	write obj.String &amp; Tab &amp; obj.CM_TrackedItem.id &amp; Tab &amp; prop.name &amp; Tab &amp; propObjValue.String;
				if propObjValue &lt;&gt; null then
					propObjValue.edition();
				endif;
				if isInvalidObject or (propObjValue &lt;&gt; null and not global.isValidObject(propObjValue)) or 
						(propObjValue = null and nullRefsDelObjArray.includes(prop.name)) then
					
					// update the required fields if they need updating	
					beginTransaction;
					if prop.name = "myCargoType" then
						obj.setPropertyValue("cargoType", "11202");
					elseif prop.name = "myTerminal" then
						obj.setPropertyValue(prop.name, newTerm);
					elseif prop.name = "myOperator" then
						obj.setPropertyValue(prop.name, newOperator);
					elseif prop.name = "myVoyage" then
						if global.isValidObject(obj.getPropertyValue("myTerminal").CM_Terminal) then
							obj.setPropertyValue(prop.name, obj.getPropertyValue("myTerminal").CM_Terminal.getNullVoyage());
						else
							obj.setPropertyValue(prop.name, null);
						endif;
					elseif prop.name = "companyOid" then					// 13/08/2015 cnwmh5
						obj.setPropertyValue(prop.name, null);
					endif;
					commitTransaction;	
					
					if not objsToDeleteArray.includes(obj) then
						//write obj.String &amp; Tab &amp; obj.CM_TrackedItem.id &amp; Tab &amp; prop.name &amp; Tab &amp; propObjValue.String &amp; Tab &amp; 
						//	'isInvalidObject: ' &amp; isInvalidObject.String &amp; Tab &amp; 
						//	'isValidObj: ' &amp; (propObjValue &lt;&gt; null and not global.isValidObject(propObjValue)).String &amp; Tab &amp; 
						//	'nullRefs includes: ' &amp; (propObjValue = null and nullRefsDelObjArray.includes(prop.name)).String;
						objsToDeleteArray.add(obj);
					endif;
				endif;
				
			endwhile;
			
			// need to update other obj fields so can delete
			if not objsToDeleteArray.includes(obj) then
				continue;
			endif;
			
			beginTransaction;
			obj.CM_TrackedItem.setPropertyValue("readyToShip", false);
	
			// check that locations are not invalid
			if not global.isValidObject(obj.CM_TrackedItem.myPrimaryActualLocation) then
				obj.CM_TrackedItem.setPropertyValue("myPrimaryActualLocation", null);
			endif;
			if not global.isValidObject(obj.CM_TrackedItem.myPrimaryPlannedLocation) then
				obj.CM_TrackedItem.setPropertyValue("myPrimaryPlannedLocation", null);
			endif;
			if not global.isValidObject(obj.CM_TrackedItem.myPrimaryQueuedLocation) then
				obj.CM_TrackedItem.setPropertyValue("myPrimaryQueuedLocation", null);
			endif;		
			
			obj.CM_TrackedItem.allQueuedFutureMoves.purge();
			obj.CM_TrackedItem.allPlannedFutureMoves.purge();
			
			// if child then need to detach from parent
			if obj.CM_TrackedItem.isChild() then
				if obj.isKindOf(CM_ClipOnUnit) and obj.CM_TrackedItem.myParent = null then
						obj.CM_ClipOnUnit.setPropertyValue("myParent", obj.CM_ClipOnUnit.myReefer);
					endif;
				obj.CM_TrackedItem.myParent.detachChild(obj.CM_TrackedItem);
			endif;
			
			if obj.CM_TrackedItem.hasChildren then
				obj.CM_TrackedItem.detachChildren();
			endif;
			
			if obj.isKindOf(CM_Container) then
				cou := obj.CM_Container.getCou();
				if cou &lt;&gt; null and cou.myReefer &lt;&gt; null then
					if cou.myParent = null then
						cou.setPropertyValue("myParent", cou.myReefer);
					endif;
					cou.myReefer.detachCOU(passport);
				endif;
			endif;
			
			commitTransaction;
			
			/*******************************************************************************
			* Anything that needs updating but has begin/commitTransaction
			*******************************************************************************/
			
			if obj.CM_TrackedItem.isQueued() then
				self.unqueueTI(obj.CM_TrackedItem);	
			endif;
			
			if obj.CM_TrackedItem.isPlanned(PLANNING_MODE) then
				self.unplanTI(obj.CM_TrackedItem);
			endif;
			
			noToCheck := noToCheck - 1;
			//if noToCheck = 0 then
			if app.cnGetServerTime() &gt; runForStartTime then
				iterTI.next(obj);
				nextTrackedItemToStartAt := obj.CM_TrackedItem;
				break maxNumberToDeleteFound;
			endif;
			
		endwhile;
	
	endwhile;
	
	// read through objectsToDeleteArray and add to objsToDelete
	beginTransaction;
	foreach obj in objsToDeleteArray do
		objToDelete := root.allObjectsToDeleteByObject[obj.getOidAsString];
		if objToDelete = null then
			create objToDelete persistent;
			objToDelete.updateDetails(obj, UM_ObjectsToDelete.WhenToDeleteNext);
			noToDelete := noToDelete + 1;
			if (noToDelete / 1000).Decimal.fractionValue = 0 then	
				commitTransaction;
				beginTransaction;
			endif; 
		endif;
	endforeach;
	commitTransaction;
	
	///write "Starting at " &amp; startAtClass.String &amp; " (" &amp; startAtClass.name &amp; ") " &amp; 
	///	startAtTI.String &amp; " (" &amp; startAtTI.id &amp; ") " &amp; noToDelete.String &amp; 
	///	" record(s) added to UM_ObjectsToDelete from " &amp; startSize.String &amp; CrLf &amp;
	///	"NextTrackedItemToStartAt: " &amp; nextTrackedItemToStartAt.String;
	
	app.writeLog("Starting at " &amp; startAtClass.String &amp; " " &amp; startAtTI.String &amp; " " &amp; noToDelete.String &amp; 
		" record(s) added to UM_ObjectsToDelete from " &amp; startSize.String, LogINFO);
	app.writeLog("NextTrackedItemToStartAt: " &amp; nextTrackedItemToStartAt.String, LogINFO);
	self.assertNull(nextTrackedItemToStartAt);
	

epilog

	delete classes;
	delete iterClass;
	delete iterTI;
	delete tiSet;
	delete nullRefsDelObjArray;
	delete properties;
	delete iterProp;
	delete objsToDeleteArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckGateEntitiesInvalidVbsti" id="536624fd-c2d7-441a-b7d4-e54367189ce9">
        <source>tCheckGateEntitiesInvalidVbsti();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2024	navpw1	Initial creation

*/

vars
	gteEntity			: CMGTE_Entity;
	invalidGTEVbstis	: ObjectArray;
	msg					: String;
	
begin
	create invalidGTEVbstis transient;
	
	foreach gteEntity in CMGTE_Entity.instances do
		if not global.isValidObject(gteEntity) then
			continue;
			
		endif;
		
		if gteEntity.myVbsti = null then
			continue;
			
		endif;
		
		if global.isValidObject(gteEntity.myVbsti) then
			continue;
		endif;
		
		invalidGTEVbstis.add(gteEntity);
		
	endforeach;
	
	if invalidGTEVbstis.isNotEmpty then
		msg := "Gate Entities with Invalid vbsti's" &amp; CrLf;
		foreach gteEntity in invalidGTEVbstis as CMGTE_Release do
			msg &amp;= "Gate Entity: " &amp; gteEntity.getOidString() &amp; CrLf;
		endforeach;
	endif;
	
	self.assertTrueMsg(invalidGTEVbstis.isEmpty, msg.cnEcStripAtEnd(CrLf));
	
epilog
	delete invalidGTEVbstis;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckLocationsController" id="7283b343-e6e4-4686-93f7-1c2bb7497488">
        <source>tCheckLocationsController();
// jlgmd1
// cnwkpd1
/*
Purpose:			Check all the Location Controllers allTrackedItem collection for deleted objects
					This should never happen but it does. Not sure why??

Date		Who		Reason
27 Aug 2013	cnwkpd1	Added size check to allTrackedItemsById
02 Dec 2013	cnwkpd1	Added exception handler so the test can be run in multi user mode
	
*/

vars
	oa 				: ObjectArray;
	lc	 			: CM_LocationsController;
	o 				: Object;
	iter 			: Iterator;
	invalidCount 	: Integer;
	badOnes			: ObjectSet;
	invalid			: Boolean;
	methodName		: String;
	
begin
	
	methodName := method.qualifiedName;
	create oa transient;
	CM_LocationsController.allInstances(oa, 0, true);
	
	app.writeLog(methodName &amp; Tab &amp; "Checking "&amp;oa.size.asStringJMTWithOptionalCommas(true, false)&amp;" CM_LocationsController objects", 0);
	
	on Exception do app.handleDeletedObject(exception, lc, invalid);
	
	create badOnes transient;
	iter := oa.createIterator();
	while iter.next(lc) do
		// KPD - added size check here after new problem detected (JADE PAR #60207)
		if lc.allTrackedItems.size &lt;&gt; lc.allTrackedItemsById.size then
			invalidCount := invalidCount + 1;
			badOnes.tryAdd(lc);
			app.writeLog(methodName &amp; Tab &amp; lc.String &amp; " mismatch in size of allTrackedItems and allTrackedItemsById detected", 0);
		else
			foreach o in lc.allTrackedItems do
				if not app.isValidObject(o) then
					invalidCount := invalidCount + 1;
					badOnes.tryAdd(lc);
					app.writeLog(methodName &amp; Tab &amp; lc.String &amp; " allTrackedItems contains invalid object " &amp; o.String, 0);
				endif;
			endforeach;
		endif;
	endwhile;
//	if badOnes.size &gt; 0 then
//		badOnes.inspectModal();
//	endif;
	///self.assertEqual(invalidCount, 0);
	// 14/02/2011 cnwmh5 - As this is corrupted data that cannot be fixed only want to know 
	// if we have more that the 2 that are known about
	self.assertEqual(invalidCount, 0);	

epilog
	delete oa;
	delete badOnes;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckOnsiteAndPreNoteRefs" id="51640a92-75bf-4a54-b329-277ba596f12d">
        <source>tCheckOnsiteAndPreNoteRefs();
// cnwndl1

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 March 2011	cnwndl1	Initial creation

*/

vars
	bad,
	oa : ObjectArray;
	ti : CM_TrackedItem;
	obj : Object;
	iter : Iterator;
	str : String;
	raiseError : Boolean;
	
begin

	create oa transient;
	create bad transient;
	
	CM_TrackedItem.allInstances(oa, 0, true);
	iter := oa.createIterator;
	while iter.next(ti) do
		if ti.getPropertyValue('myOnsiteTerminal')&lt;&gt; null and ti.getPropertyValue('myNotifiedTerminal') &lt;&gt; null then
			bad.add(ti);
		endif;
	endwhile;
	
	if not bad.isEmpty then
		str := "Cargo with both 'myOnsiteTerminal' set and 'myNotifiedTerminal' set!!" &amp; CrLf;
		foreach obj in bad do
			ti := obj.CM_TrackedItem;
			str := str &amp; CrLf &amp; ti.myTerminal.code &amp; " / " &amp; ti.String &amp; " / " &amp; ti.id;
		endforeach;
	endif;
	
	raiseError := str.trimBlanks &lt;&gt; null;
	self.assertEqualMsg(raiseError, false, str);
	
epilog

	delete oa;
	delete bad;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckOrpanedRootdefObjects" id="b4cfeaa9-ac7d-4d30-9db8-fbbea0444362">
        <source>tCheckOrpanedRootdefObjects();
// jlgmd1
/* cnwkpd1

Purpose:			Check all RootSchema class instances stored in the _rootdef map file and ensure they are
					all still connected to JMT objects in some way
					
Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2014	cnwkpd1	PAR #33353 - tidy up creation of RootSchema classes
27 Nov 2014	cnwkpd1	PAR #35261 - Changes to prepare for JADE 7.1

*/

vars
	classesToCheck	: StringArray;
	clsName			: String;
	
	props			: ObjectArray;
	property		: Property;
	propIter		: Iterator;
	cls				: Class;
	
	oa				: ObjectArray;
	allObjects		: ObjectSet;
	iter			: Iterator;
	obj,
	refObj,
	firstObj,
	lastObj			: Object;
	count			: Integer;
	
	lg				: CM_LayoutGraphic;
	menuRootQuery 	: CM_MenuRootQuery;
	strArrayObj 	: Object;
	strArrayIter	: Iterator;

begin
	// Set up the list of RootSchema classes that need to be checked
	create classesToCheck transient;
	classesToCheck.add(StringArray.name);
	classesToCheck.add(IntegerArray.name);
	classesToCheck.add(PointArray.name);
	classesToCheck.add(HugeStringArray.name);
	classesToCheck.add(DynaDictionary.name);
	classesToCheck.add(JadeDynamicObject.name);
	
	// Get all the instances of all these classes
	create allObjects transient;
	create oa transient;
	iter := oa.createIterator();
	
	foreach clsName in classesToCheck do
		oa.clear();
		rootSchema.getClass(clsName).allInstances(oa, 0, false);
		if not oa.isEmpty then
			app.writeLog(oa.size.String &amp; ' instances of ' &amp; clsName &amp; ' found', LogINFO);
			oa.copy(allObjects);
		endif;
	endforeach;
	
	app.writeLog(allObjects.size.String &amp; ' instances of all selected classes found', LogINFO);
	
	// Search all properties for non-exclusive references of any of the selected classes
	create props transient;
	Property.allInstances(props, 0, true);
	
	app.writeLog('Processing ' &amp; props.size.String &amp; ' properties', LogINFO);
	
	propIter := props.createIterator();
	while propIter.next(property) do
	
		if property.subId.Integer = null  and classesToCheck.includes(property.type.name) then
			cls := property.schemaType.Class;
			
	/*		app.writeLog('Found non-attribute property ' &amp; 
				   property.schemaType.schema.name &amp; '::' &amp;
				   property.schemaType.name &amp; '::' &amp;
				   property.name &amp;
				   ' (' &amp; property.type.name &amp; ')', LogINFO); */
			
			oa.clear();
			
			cls.allInstances(oa, 0, true);
			
			if not oa.isEmpty then
				app.writeLog('Found non-attribute property ' &amp; 
					   property.schemaType.schema.name &amp; '::' &amp;
					   property.schemaType.name &amp; '::' &amp;
					   property.name &amp;
					   ' (' &amp; property.type.name &amp; ')', LogINFO);
		
				app.writeLog(oa.size.String &amp; ' instances of ' &amp; cls.name &amp; ' found', LogINFO);
		
				iter.reset();
		
				while iter.next(obj) do
					
					refObj := obj.getPropertyValue(property.name).Object;
					if refObj &lt;&gt; null then
						if allObjects.includes(refObj) then
							allObjects.remove(refObj);
						else
							app.writeLog('&gt;&gt;&gt;&gt; ' &amp; obj.String &amp; ' has invalid ' &amp; property.name &amp; ' (' &amp; refObj.String &amp; ')', LogINFO);
						endif;
					endif;
					
				endwhile;
			
			endif;
			
		endif;
		
	endwhile;
	
	//menu Root Query has a collection of StringArrays in an Object Array that are not discoverd in the code above,
	//so considered to be orphans which they are not. Deal with them here.
	menuRootQuery := CM_MenuRootQuery.firstInstance;
	strArrayIter := menuRootQuery.allNonCargoVisibleColumns.createIterator;
	while strArrayIter.next( strArrayObj ) do
		if allObjects.includes(strArrayObj) then
			allObjects.remove(strArrayObj);
		endif;
	endwhile;
	delete strArrayIter;
	
	strArrayIter := menuRootQuery.allDefNonCargoVisibleColumns.createIterator;
	while strArrayIter.next( strArrayObj ) do
		if allObjects.includes(strArrayObj) then
			allObjects.remove(strArrayObj);
		endif;
	endwhile;
	delete strArrayIter;
	
	// And if PointArray is being checked, then also check the CM_LayoutGraphic::allLocationPointPolygons collections
	if classesToCheck.includes(PointArray.name) then
		oa.clear();
		CM_LayoutGraphic.allInstances(oa, 0, true);
			
		if not oa.isEmpty then
			app.writeLog(oa.size.String &amp; ' instances of ' &amp; CM_LayoutGraphic.name &amp; ' found', LogINFO);
			
			iter.reset();
			while iter.next(lg) do
				foreach obj in lg.allLocationPointPolygons do
					if allObjects.includes(obj) then
						allObjects.remove(obj);
					else
						app.writeLog('&gt;&gt;&gt;&gt; ' &amp; lg.String &amp; ' has invalid object (' &amp; obj.String &amp; ') in allLocationPointPolygons', LogINFO);
					endif;		
				endforeach;
			endwhile;
		
		endif;
	endif;
		
	
	app.writeLog(allObjects.size.String &amp; ' instances of all selected classes not associated', LogINFO);
	
	// Find first and last unassociated instance of each class
	firstObj := allObjects.first();
	lastObj := null;
	count := 0;
	
	foreach obj in allObjects do
		if lastObj &lt;&gt; null and self.getClassForObject(obj).name &lt;&gt; lastObj.class.name then
			app.writeLog(count.String &amp; ' instances of ' &amp; lastObj.class.name &amp; ' not associated', LogINFO);
			app.writeLog('First ' &amp; firstObj.String &amp; ' created ' &amp; firstObj.creationTime.String, LogINFO);
			app.writeLog('Last ' &amp; lastObj.String &amp; ' created ' &amp; lastObj.creationTime.String, LogINFO);
			firstObj := obj;
			count := 0;
		endif;
		
		lastObj := obj;
		count := count + 1;
	endforeach;
	
	if firstObj &lt;&gt; null and lastObj &lt;&gt; null then
		app.writeLog(count.String &amp; ' instances of ' &amp; lastObj.class.name &amp; ' not associated', LogINFO);
		app.writeLog('First ' &amp; firstObj.String &amp; ' created ' &amp; firstObj.creationTime.String, LogINFO);
		app.writeLog('Last ' &amp; lastObj.String &amp; ' created ' &amp; lastObj.creationTime.String, LogINFO);
	endif;
	
	assertTrue(allObjects.isEmpty());
	
	
epilog
	delete allObjects;
	delete iter;
	delete oa;
	delete props;
	delete propIter;
	delete classesToCheck;
	delete strArrayIter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckOrphanedPointArrays" id="9574ede8-e774-46ce-b5b9-1b0dbc618127">
        <source>tCheckOrphanedPointArrays();
// jlgmd1
/*	cnwkpd1

Purpose:			Check for orphaned PointArray instances being created.

					
Date		Who		Reason
23 Jan 2014	cnwkpd1	PAR #33353 - tidy up creation of RootSchema classes
27 Nov 2014	cnwkpd1	PAR #35261 - Changes to prepare for JADE 7.1

*/

vars
	props			: ObjectArray;
	property		: Property;
	propIter		: Iterator;
	cls				: Class;
	
	oa				: ObjectArray;
	allArrays		: ObjectSet;
	iter			: Iterator;
	obj				: Object;
	arr				: PointArray;
	
	lg				: CM_LayoutGraphic;
	
begin
	// Get all the unconnected PointArray instances
	create oa transient;
	iter := oa.createIterator();
	PointArray.allInstances(oa, 0, false);
	
	app.writeLog(oa.size.String &amp; ' instances of PointArray found', LogINFO);
	
	create allArrays transient;
	oa.copy(allArrays);
	oa.clear();
	
	// Search all properties for non-exclusive StringArray references
	create props transient;
	Property.allInstances(props, 0, true);
	
	app.writeLog('Processing ' &amp; props.size.String &amp; ' properties',LogINFO);
	
	propIter := props.createIterator();
	while propIter.next(property) do
	
		if property.type.name = PointArray.name and property.subId.Integer = null then
			cls := property.schemaType.Class;
			
			app.writeLog('Found non-attribute PointArray ' &amp; 
				   property.schemaType.schema.name &amp; '::' &amp;
				   property.schemaType.name &amp; '::' &amp;
				   property.name, LogINFO);
			
			oa.clear();
			
			cls.allInstances(oa, 0, true);
	
			app.writeLog(oa.size.String &amp; ' instances of ' &amp; cls.name &amp; ' found', LogINFO);
	
			iter.reset();
	
			while iter.next(obj) do
				
				arr := obj.getPropertyValue(property.name).PointArray;
				if arr &lt;&gt; null then
					if allArrays.includes(arr) then
						allArrays.remove(arr);
					else
						app.writeLog('&gt;&gt;&gt;&gt; ' &amp; obj.String &amp; ' has invalid ' &amp; property.name &amp; arr.String, LogINFO);
					endif;
				endif;
				
			endwhile;
			
		endif;
		
	endwhile;
	
	// And also check the CM_LayoutGraphic::allLocationPointPolygons collections
	oa.clear();
	CM_LayoutGraphic.allInstances(oa, 0, true);
	
	app.writeLog(oa.size.String &amp; ' instances of ' &amp; CM_LayoutGraphic.name &amp; ' found', LogINFO);
	
	iter.reset();
	while iter.next(lg) do
		foreach obj in lg.allLocationPointPolygons do
			if allArrays.includes(obj) then
				allArrays.remove(obj);
			else
				app.writeLog('&gt;&gt;&gt;&gt; ' &amp; lg.String &amp; ' has invalid object (' &amp; obj.String &amp; ') in allLocationPointPolygons', LogINFO);
			endif;		
		endforeach;
	endwhile;
	
	app.writeLog(allArrays.size.String &amp; ' instances of PointArray not associated', LogINFO);
	
	if not allArrays.isEmpty then
		app.writeLog('First ' &amp; allArrays.first.String &amp; ' created ' &amp; allArrays.first.creationTime.String, LogINFO);
		app.writeLog('Last ' &amp; allArrays.last.String &amp; ' created ' &amp; allArrays.last.creationTime.String, LogINFO);
	endif;
	
	// Check there are no non associated arrays
	assertTrue(allArrays.isEmpty);

	
epilog
	delete allArrays;
	delete iter;
	delete oa;
	delete props;
	delete propIter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckProxyUpdateCollections" id="d40e80ba-e5f0-496e-839b-d8f9a496ee97">
        <source>tCheckProxyUpdateCollections();
//
// 18 Nov 2019	jlgrs1	TFS 47300 collections not in pxyCreateUpdateProxy method
//
vars
	object : CM_Object; 
	object2 : CM_Object;
	object3 : CM_Object;
	object4 : CM_Object;
	pxyObj : CM_Object;
	collObj : CM_Object;
	obj : Object;
	propObject : Object;
//	propArray : ObjectArray; 
	collArray : ObjectArray;
	allProps : PropertyColl;
	property : Property;
	propname : String;
	str : String;
	coll : Collection;
	pxyColl : Collection;
	aClass : Class;	// the class of the collection in cClass
	bClass : Class;	// trying to find non abstract aClass
	cClass : Class;	// the main class we are processing
	subs : ClassColl;
	isAutoColl : Boolean;
//	isDupKey : Boolean;
	masterSubclasses : ClassColl;
	superClassSet : ClassSet;
	initialTransients : ObjectArray;
	endingTransients : ObjectArray;
	count : Integer;
begin
//return;
	on Exception do self.iHandleAutoCollection(exception, coll, isAutoColl);
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["UT"]);
	create initialTransients transient;
	create endingTransients transient;
	create masterSubclasses transient;
	create superClassSet transient;
	process.allTransientInstances(initialTransients, 0);
	CM_Object.withAllSubclasses(masterSubclasses);
	foreach cClass in masterSubclasses do
		if not cClass.getSuperclass = CM_Object then
			superClassSet.clear;
			cClass.cnEcGetAllSuperclasses(superClassSet);
			if not superClassSet.includes(CM_Object) then
				continue;
			endif;
		endif;
		if cClass.abstract then
			continue;
		endif;
		if not global.isValidObject(app.myRoot) then
			app.setPropertyValue("myRoot", CM_Root.firstInstance);
		endif;
		if cClass = CM_Terminal or 
		   cClass = CM_Root or
		   cClass = CM_AvailableForRelease or
		   cClass = CM_Object then
			continue;
		endif;
		if cClass = CM_PackJob then
			cClass := cClass;
		endif;
		create collArray transient;
		allProps := cClass.allPropertiesUpTo(Object);
		foreach property in allProps do
			propname := property.name;
			if property.isKindOf(Reference) and
			   propname &lt;&gt; "schema" and
			   propname[1:1] &lt;&gt; "_" and
			   not property.virtual then
				if property.type.cnEcIsCollection and
				   not property.type.CollClass.memberType.isKindOf(PrimType) and
				   not cClass.transient then 
					
					if cClass = CM_KPISnapshotDtl or		//* Error 1215: Persistent objects cannot reference transient objects
						cClass = CM_KPIRoadSnapshotDtl or
						cClass = CM_KPITrainSnapshotDtl or
						cClass = CM_KPIVoyageSnapshotDtl or
						cClass = CM_KPIYardSnapshotDtl then
					   continue;
					endif;
					collArray.add(property);
				endif;
			endif;
		endforeach;
		foreach propObject in collArray do
			property := propObject.Property;
			propname := property.name;

			beginTransaction;
			create object as cClass persistent;
			if CM_SecurityRole.hasInstance(object) then
				create object2 as CM_SecurityRoleVisibility persistent;
				object.setPropertyValue(CM_SecurityRole::mySecurityRoleVisibility.name, object2);
			elseif CM_DeckLayerLayout.hasInstance(object) then
				create object2 as CM_DeckLayout persistent;
				object.setPropertyValue(CM_DeckLayerLayout::myDeckLayout.name, object2);
			elseif CM_DeckLayout.hasInstance(object) then
				create object2 as CM_DeckVoyage persistent;
				object.setPropertyValue(CM_DeckLayout::myDeck.name, object2);
			elseif CM_Deck.hasInstance(object) then
				create object2 as CM_DeckLayout persistent;
				object2.setPropertyValue(CM_DeckLayout::myDeck.name, object);
			elseif CM_Gate.hasInstance(object) then
				create object2 as CM_GateAreaUsage persistent;
				object.CM_Gate.allGateAreas_IN.add(object2.CM_GateAreaUsage);
				object.CM_Gate.allGateAreas_OUT.add(object2.CM_GateAreaUsage);
				create object3 as CM_GateArea persistent;
				object2.setPropertyValue(CM_GateAreaUsage::myGateArea.name, object3);
				abortTransaction;
				continue;
			elseif CM_RTMoveMethodRule.hasInstance(object) then
				create object2 as CM_RTQueueMultiRuleTAMaster persistent;
				object.setPropertyValue(CM_RTMoveMethodRule::myRTQueueMultiRule.name, object2);
			elseif CM_RTVehicleConfig.hasInstance(object) then
				create object2 as CM_RTScreenConfig persistent;
				object.setPropertyValue(CM_RTVehicleConfig::myDayScreenConfig.name, object2);
				object.setPropertyValue(CM_RTVehicleConfig::myNightScreenConfig.name, object2);
				abortTransaction;
				continue;
