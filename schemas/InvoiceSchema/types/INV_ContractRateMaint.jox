    <JadeMethod name="mnuInspectObject_click" id="03491a3b-04fa-42db-8424-4ce9147fd09e">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuInspectObject_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Feb 2023 navtnr20	TFS CR 55646 TTask 55665: UI - Contract Details
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes

*/

vars
	defaultEntry : CM_InvoiceContractRateEntry;
	defaultEntryDates : CMIF_ContractRateEntryDates; //25 October 2023 navmv20 CR 60503 Task 60505
begin
	defaultEntryDates:= self.tblData.accessRow(self.tblData.row).itemObject.CMIF_ContractRateEntryDates; //25 October 2023 navmv20 CR 60503 Task 60505
	//defaultEntry:= self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceContractRateEntry; //25 October 2023 navmv20 CR 60503 Task 60505
		
