    <JadeMethod name="isInUse" id="c41e3203-e44b-4f54-a238-c509d5b54c15">
        <source>isInUse() : Boolean;

vars

	controller	: CM_GridController;


begin

	foreach controller in self.allGridControllersByName do
		if controller.hasTIs then
			return true;
		endif;
		if controller.hasRestrictions(NULL_RESTRICTION) then
			return true;
		endif;
		if controller.mySubBlockStack &lt;&gt; null then // PAR7455 AKB2004FEB added
			return true;
		endif;
	endforeach;
	
	return false;
	
end;</source>
