    <JadeMethod name="addJobToSheet" id="b85d33be-af3f-43ef-ae82-eb0518065987">
        <updating/>
        <source>addJobToSheet(_job : CM_RailJob input) updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myJobSheet = null then
		create self.myJobSheet;
	endif;
	
	_job.removeFromJobSheet(); // is auto connected to the terminal's rail job sheet
	self.myJobSheet.addJob(_job, 0);  // PAR 25980 this must be done before the following setInOutRakeSheet
	_job.setInOutRakeSheet(null);

	/*  // ### TFS 51855 18MAY2022 NAVAB1 MOVED TO CM_TrackedItem::createRailReleaseJob
	if app.myPassport.isOpsViewEnabled(_job.myTerminal) then // ### TFS 51855 06JAN2022 NAVAB1
		_job.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB, _job); // ### TFS 51855 06JAN2022 NAVAB1
	endif;
*/
epilog

end;</source>
        <Parameter name="_job" type="CM_RailJob" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addProxyWagon" id="beee412a-d0a0-49bd-9aab-4c2318a7e9f8">
        <source>addProxyWagon(_inward: Boolean; _pxyWagon: CM_Wagon input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2016	cnwmp6	Initial creation

*/

vars

begin
	_pxyWagon.setMyTrain(_inward, self);
epilog

end;</source>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_pxyWagon" type="CM_Wagon" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addWagon" id="5a737fe4-1bb8-4c23-8dd4-6199efb60c68">
        <updating/>
        <source>addWagon( _moveController : CMIF_WagonMoveController; _inward : Boolean; _wagon : CM_Wagon input; _atPos : Integer) : Integer updating;

/*

Purpose:			Add a wagon to the train.  The wagon is inserted before the wagon
					at the given position (at the end if _atPos is 0).
					When a wagon is added to an inward train, the add is also applied
					to the outward train when the wagon is in the same position on
					both the inward and outward trains.
					

Parameters:			_inward : Inwards/Outwards train

Return Value:		New position of wagon


Date		Who		Reason
29 May 2009	consw1	PAR 19710 - SFW1067 Rail Simplifications
25 Jun 2009	consw1	PAR 20109 - Remove transaction should be recorded with the source train

*/

vars
	auditAddInwards, auditAddOutwards : Boolean;
	currentPos, newPos : Integer;
	moveOutwards : Boolean;
	effectiveDate : TimeStamp;	//23 Feb 2021	NDL	TFS 50837

begin

	//23 Feb 2021	NDL	TFS 50837
	effectiveDate := null;
	if _moveController &lt;&gt; null and _moveController.effectiveTimeStamp.date.isValid then
		effectiveDate := _moveController.effectiveTimeStamp;
	endif;
	
	if _wagon = null then
		app.setContinueCMExceptions(false);
		//app.raiseCMException2(MethodWithNullParam, method.name, "Wagon Reference", null, null); //- cnwmd1, CCMS 1067, Par 19710
		app.raiseCMException2(MethodWithNullParam, method.name, app.getErrorString(Wagon_reference), null, null); //+ cnwmd1, CCMS 1067, Par 19710
	endif;
	
	if _inward then
		//  Inward Train
		newPos := _atPos;
		if _atPos = 0 then
			newPos := self.allWagonsByOrderInward.size + 1;
		endif;
		currentPos := _wagon.getMyPositionTrainInwards;
		if _wagon.myTrainInwards = self then
			if currentPos &lt; newPos then
				newPos := newPos - 1;
			endif;
			if currentPos = newPos then
				return newPos;	// already in position
			endif;
		endif;
		//  Is the wagon in the same position on both the inward and outward trains?
		//  If so, set flag to indicate that the move should be applied to outward train also.
		moveOutwards := (_wagon.myTrainOutwards = _wagon.myTrainInwards and _wagon.getMyPositionTrainOutwards = currentPos);
		//  Audit inward change
		if _wagon.myTrainInwards = null then
			auditAddInwards := true;
		elseif _wagon.myTrainInwards = self then
			_wagon.createTransaction( effectiveDate, EVT_WagonMoved, self, newPos, null, _inward, null, null, null);
		else
			_wagon.createTransaction( effectiveDate, EVT_WagonRemove, _wagon.myTrainInwards, null, null, _inward, null, null, null);
			auditAddInwards := true;
		endif;
		//  Take wagon off current inward train
		if _wagon.myTrainInwards &lt;&gt; null then
			_wagon.myTrainInwards.removeWagon(_inward, _wagon);
		endif;
		//  Add wagon to new position on inward train
		if newPos &gt; self.allWagonsByOrderInward.size then
			self.allWagonsByOrderInward.add(_wagon);
		else
			self.allWagonsByOrderInward.insert(newPos, _wagon);
		endif;
		if not self.allWagonsByIdInward.includes(_wagon) then
			self.allWagonsByIdInward.add(_wagon);
		endif;
		//  Audit inward add
		if auditAddInwards then
			_wagon.createTransaction( effectiveDate, EVT_WagonAdd, self, null, null, _inward, null, null, null);
		endif;
	else
		//  Outward Train
		newPos := _atPos;
		if _atPos = 0 then
			newPos := self.allWagonsByOrderOutward.size + 1;
		endif;
		currentPos := _wagon.getMyPositionTrainOutwards;
		if _wagon.myTrainOutwards = self then
			if currentPos &lt; newPos then
				newPos := newPos - 1;
			endif;
			if currentPos = newPos then
				return newPos;	// already in position
			endif;
		endif;
	endif;
	
	if moveOutwards or not _inward then
		//  Audit outward change
		if _wagon.myTrainOutwards = null then
			auditAddOutwards := true;
		elseif _wagon.myTrainOutwards = self then
			_wagon.createTransaction( effectiveDate, EVT_WagonMoved, self, newPos, null, false, null, null, null);
		else
			_wagon.createTransaction( effectiveDate, EVT_WagonRemove, _wagon.myTrainOutwards, null, null, false, null, null, null);
			auditAddOutwards := true;
		endif;
		//  Take wagon off current outward train
		if _wagon.myTrainOutwards &lt;&gt; null then
			_wagon.myTrainOutwards.removeWagon(false, _wagon);
		endif;
		//  Add wagon to new position on outward train
		if newPos &gt; self.allWagonsByOrderOutward.size then
			self.allWagonsByOrderOutward.add(_wagon);
		else
			self.allWagonsByOrderOutward.insert(newPos, _wagon);
		endif;
		if not self.allWagonsByIdOutward.includes(_wagon) then
			self.allWagonsByIdOutward.add(_wagon);
		endif;
		//  Audit outward add
		if auditAddOutwards then
			_wagon.createTransaction( effectiveDate, EVT_WagonAdd, self, null, null, false, null, null, null);
		endif;
	endif;

	return newPos;
	
epilog

end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_wagon" type="CM_Wagon" usage="input"/>
        <Parameter name="_atPos" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="areAllWagonsDeparted" id="9e3bbc76-130b-4975-b6cc-92e3ef797ed7">
        <source>areAllWagonsDeparted() : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	wagon 	: CM_Wagon;
begin
	foreach wagon in self.allWagonsByIdOutward discreteLock do // PAR 21697
		if not wagon.isDeparted() then
			return false;
		endif;
	endforeach;

	return true;

end;



</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="arrivalProcess" id="c2e0755c-c6a4-455f-b9e3-740679565a4c">
        <updating/>
        <source>arrivalProcess(_wagon : CM_Wagon) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ti : CM_TrackedItem;
	wagon : CM_Wagon;
begin
	if self.isDeparted() then
		return;
	endif;
	
	if self.myTerminal = null then
		//app.raiseUnexpectedProgramError(class.name, method.name, 'self.myTerminal is null'); //- cnwmd1, CCMS 1067, Par 19710
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Myterminal_null)); //+ cnwmd1, CCMS 1067, Par 19710
		return;
	endif;
	
	
	foreach ti in _wagon.allTIsReceived discreteLock do
		if not self.allTIsReceived.includes(ti) then
			self.allTIsReceived.add(ti);
		endif;
	endforeach;
	
end;


</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
