    <JadeMethod name="fieldExtWebSrvs_change" id="f87b4921-38f5-4338-a4c1-6c7aa4aebdfc">
        <controlMethod name="CMUI_FieldFrame::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fieldExtWebSrvs_change(frame: Frame) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
25 Aug 2025	navnk30		JIRA 35718: 6 - YARA | Create a BGP to create a release request from the Order Create/Order Update XML received

*/

vars
	currExtWSObject	: CM_ExternalWebServiceDef;
begin
	currExtWSObject := self.fieldExtWebSrvs.getObject().CM_ExternalWebServiceDef;
	if CM_AgGatewayServiceDef.hasInstance(currExtWSObject) then
		self.fieldTerminal.enabled := false;
		self.myAssistant.fieldTerminal(self.fieldTerminal, currExtWSObject.CM_AgGatewayServiceDef.myTerminal);
	else
		self.fieldTerminal.enabled := true;
		self.myAssistant.fieldTerminal(self.fieldTerminal, self.aMyBGPObject.getMyTerminal());
	endif;
epilog

end;</source>
        <Parameter name="frame" type="Frame"/>
    </JadeMethod>
