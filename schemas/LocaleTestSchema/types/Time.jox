    <JadeMethod name="currentLocaleFormatJMT" id="91a171d9-6d84-43d9-9b61-1147f0160a40">
        <source>currentLocaleFormatJMT() : String;
// -------------------------------------------
// Created 10 February 2005 by cnwdvb1
// -------------------------------------------
// if format changes then you may have to change primitiveType String.convertToTimeStamp() and String.convertToTime() as well
vars

begin
// cnwdad1 18/06/2009 - PAR #19942.
	//return self.format('HH:mm');
	return self.format(app.getTimeShortFormat(false));
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="shortFormatJMT" id="f79a08bf-25ad-493d-97b9-1e04cd1a3b71">
        <source>shortFormatJMT() : String;
// cmwrs1 aug 2005
// Extra info: if format changes then you may have to change primitiveType String.convertToTime();
vars

begin
