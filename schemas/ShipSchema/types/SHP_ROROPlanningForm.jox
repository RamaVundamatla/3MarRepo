    <JadeMethod name="showRequestLinker" id="4f9767ac-8629-4570-8a76-bd2c18d06e3d">
        <updating/>
        <source>showRequestLinker(_linkMode : Integer) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/


vars
	theForm : Form;
	theLeftRequests: CM_RequestArray;
	tmpSlotController	: CM_VoyageROROController;
	aRequest : CM_RORORequest;
	tmpObj		: Object;
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	create theLeftRequests transient;

	//cnwmc5 - 1 August 2013 - PAR 31651
	if self.mySideViewForm &lt;&gt; null then
		self.mySideViewForm.myROROLocnDrawingController.getSelectedDLRItems(theLeftRequests);
	endif;
	if theLeftRequests.isEmpty() then
		self.myROROPlanDrawController.getSelectedDLRItems(theLeftRequests);
	endif;
	
	/*self.myROROPlanDrawController.getSelectedDLRItems(theLeftRequests); // PAR 28327
	if self.mySideViewForm &lt;&gt; null then
		self.mySideViewForm.myROROLocnDrawingController.getSelectedDLRItems(theLeftRequests);// PAR 28327
	endif;*/
	
	/* PAR 28327
	foreach tmpObj in self.myROROPlanDrawController.allSelectedObjects do
		// ### ONLY DO THIS FOR CONTAINER SLOTS
		if (not tmpObj.isKindOf(CM_ROROSlotRequest)) then
			continue;
		endif;
		tmpSlotController := tmpObj.CM_RORORequest.myROROController;		

		aRequest := null;
		if self.modeView = ShpDisplayMode_ColCodeDisch then
			aRequest := tmpSlotController.myRORORequestDischarge;
		else
			aRequest := tmpSlotController.myRORORequestLoad;
		endif;
		//13/07/2010 cnwdz2 24599
		if aRequest = null then
			continue;
		endif;
		
		if aRequest.moveType &lt;&gt; DLR_MOVETYPE and aRequest.moveType &lt;&gt; SOB_MOVETYPE then
			aRequest := null;
		endif;
		if aRequest &lt;&gt; null then
			theLeftRequests.add(aRequest);
		endif;
	endforeach;
*/
	// Now create the form
	theForm := app.getForm(SHP_LinkSlotRequestsForm.name);
	if theForm = null then
		create theForm as SHP_LinkSlotRequestsForm;
	endif;


	theForm.SHP_LinkSlotRequestsForm.myTerminal := self.myTerminal;
	theForm.SHP_LinkSlotRequestsForm.magRequests.formDisplayEntryMethodName := "displayStuff";
	theForm.SHP_LinkSlotRequestsForm.myVoyage := self.myCurrentVoyage;
	
	// pass through and validate the collection of requests
	if theForm.SHP_LinkSlotRequestsForm.setCollectionsRORO(theLeftRequests, _linkMode) then
		theForm.showModal();
	endif;
epilog
	delete theLeftRequests;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_linkMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showReturnCargoToYardForm" id="6c2e8849-790b-48d5-a115-08aff2527af1">
        <updating/>
        <source>showReturnCargoToYardForm(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2012	cnwmc5	Initial creation - PAR 29306

*/

vars
	theTI : CM_TrackedItem;
	tiArray : CM_TIArray;
	obj : Object;
begin
	if self.myROROPlanDrawController &lt;&gt; null then
		create tiArray transient;
		self.myROROPlanDrawController.getAllSelectedTIs(tiArray);
		
		tiArray.removeDuplicateObjects(); // PAR 29306

		if tiArray.isEmpty() then
			app.msgBox(app.getErrorString(Please_select_cargo_return), app.getErrorString(Select_cargo), MsgBox_OK_Only+MsgBox_Stop_Icon);
			return;
		endif;
		
		self.myAssistant.showReturnCargoToYardForm(self.myCurrentVoyage, tiArray, self.myMasterMenuAction, true);
	endif;
epilog
	delete tiArray;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
