    <JadeMethod name="changeFilterOptions" id="3ae19959-8c8c-42ad-b0d0-c6cbce5c8241">
        <source>changeFilterOptions() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	if self.optTableData.value then
		self.txtFilter.visible := false;
		self.tblFilterValues.visible := true;
		self.btnUnselectAll.visible := true;
		self.btnSelectAll.visible := true;
	elseif self.optUserData.value then
		self.tblFilterValues.visible := false;
		self.btnUnselectAll.visible := false;
		self.btnSelectAll.visible := false;
		self.txtFilter.visible := true;
	else
		self.tblFilterValues.visible := false;
		self.btnUnselectAll.visible := false;
		self.btnSelectAll.visible := false;
		self.txtFilter.visible := false;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cmbColumnFilter_click" id="c7fbd90b-ad95-488c-9ee2-5366033e2b19">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbColumnFilter_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	app.mousePointer :=	Busy;

	self.doSelectColumnToFilter();
	
	frmFilterValues.visible := cmbColumnFilter.listIndex &gt; 0;

epilog

	app.mousePointer :=	Idle;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
