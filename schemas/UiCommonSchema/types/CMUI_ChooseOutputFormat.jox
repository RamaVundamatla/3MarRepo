    <JadeMethod name="btnBrowse_click" id="b247483d-f625-4245-bd16-80545c4a4c98">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBrowse_click(btn: Button input) updating;
/*
Purpose:	

Date		Who		Reason
19 September 2024	navab1	CR 65813 TASK 65877
*/

vars

begin
	self.myFile := self.getFileForExtract(null,self.getFileExtension());
	self.txtFileName.text :=  "";
	if self.myFile &lt;&gt; null then
		self.txtFileName.text := self.myFile.fileName;
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
