    <JadeMethod name="cnEcInitializeBackupApp" id="9126d5a7-da9b-449f-ba29-13e54dd52655">
        <updating/>
        <source>cnEcInitializeBackupApp() updating;
// --------------------------------------------------------------------------------
// Created:		06 February 2001 by cnwdad1
//
// Purpose:		Used as the initialize method for a backup application which backs
//				up the development environment's database directory to a directory
//				specified in the JADE initialization file.
//
//				Note that the backup directory must be relative to the JADE server
//				node, and the backup is run in a quiescent mode.  As soon as the
//				backup is finished, the application will terminate itself.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dbAdminObj			: CnEcDatabaseAdmin;

begin
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);
	self.cnEcInitializeBaseSchema();

	dbAdminObj	:=	self.myBaseRoot.myDatabaseAdmin;
	dbAdminObj.backupAllDatabaseFiles();
	
	terminate;		// Close down the application.
end;</source>
    </JadeMethod>
