// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myFilterCargoType := self.cmbFiltCargoType.listObject.CM_CargoType;
