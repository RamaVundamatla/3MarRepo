    <JadeMethod name="loadPort" id="adace5a6-ce8c-4774-b31e-960aff8e5b1e">
        <methodInvocation>mapping</methodInvocation>
        <source>loadPort(set: Boolean; _value: String io) mapping;
// cnwrs1 June 2006 protected the old 3 digit codes
vars
	port : CM_Port;
begin
	if not set then
		if self.loadPort.length = 3 then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.loadPort, null);
			if port &lt;&gt; null and port.portCode = self.loadPort then
				_value := port.code;
			else
				_value := self.loadPort;
			endif;
		else
			_value := self.loadPort;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="normaliseAction" id="6111b18e-879f-429d-b226-ac8b9bac16a3">
        <source>normaliseAction(_existingBox : CM_TrackedItem) : String;
// ---------------------------------------------------------------------------
// Created:	02 July 2010 By Graeme Black cnwgb1
// For:		PAR 23418 MSL 1079
// Purpose:	Conditionally alter the Add/Update/Delete.
//			If there is a prexisting Tracked Item, then convert Adds to Updates
//			If there isn't then convert updates to Adds
//			Ignore invalid deletes - they are silly 
// ---------------------------------------------------------------------------
vars
	ediAction : String;
begin

	ediAction := self.messageMode;

	//01 Nov 2019	NDL	TFS 47101
	if self.myEDIData &lt;&gt; null and self.myEDIData.fileVersion = "One Stop Prenote" then
		if not self.getMyTerminal.getConfig(EdiAlwaysProcPrenote).Boolean then
			// If its a 'One Stop Prenote' AND they haven't told us to
			// always process, then don't play with the action field.
			return ediAction;
		endif;
	endif;
	
	if ediAction.isBlank() then
		ediAction := CM_EDITrackedItem.EDI_ACTION_ADD;	
	endif;
	
	if _existingBox = null then
		if ediAction = CM_EDITrackedItem.EDI_ACTION_UPDATE or
			ediAction = CM_EDITrackedItem.EDI_ACTION_MODIFY then
			ediAction := CM_EDITrackedItem.EDI_ACTION_ADD;
		elseif ediAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
			return null;
		endif;
	else
		if ediAction = CM_EDITrackedItem.EDI_ACTION_ADD then
			ediAction := CM_EDITrackedItem.EDI_ACTION_UPDATE;
		endif;
	endif;
	return ediAction;
epilog
end;</source>
        <Parameter name="_existingBox" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processAttributeDependencies" id="99420bf2-4d53-4e20-b661-41721acafff9">
        <updating/>
        <source>processAttributeDependencies(_ediUserDefinedAssist : CMIF_EDIUserDefinedAssist input; _strIdentifier : String; _reset : Boolean; _xlationOperator :CM_Operator) updating;
//
// cnwrs1 15 Feb 2010 par 21329
// Date			Who		Reason
// 28 Apr 2011	cnwrs1	ccms 2044 - added strIdentifier
// 11 apr 2013	cnwcs5	ccmc pol 2097 / par 31259 - comodity xlations
//20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
//01 Dec 2016	cnwrs1	TFS 2987 if no cooling type check with container Range
// 26 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 20 Sep 2017	jlgrs1	TFS 5457 Make JMTInternal XML work
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 21 May 2024	navhn30	Bug 63125: EUP* | Transport Manifest UDF - Transport Reference customer error when try to Verify Road manifest
// 12 Feb 2025  navsp1  JIRA SNO - Inconsistent behavior of ITEMIZED field 
vars
	tmpProduct				: CM_Product;
	contRange : CM_ContRange;
	ediTI : CM_EDITrackedItem;
	str : String;
	manifest : CM_EDIDataTransManifest;		// TFS 63125
begin
//write class.name&amp;'::'&amp;method.name&amp;' isoType='&amp;self.isoType&amp;' coolingtype='&amp;self.coolingType.String;
	inheritMethod(_ediUserDefinedAssist, _strIdentifier, _reset, _xlationOperator);
	if _reset then 
		foreach ediTI in _ediUserDefinedAssist.allChildrenEDITIs do
			str := str &amp; ediTI.String&amp;' ';
			if ediTI.id = null then
				ediTI.setId(self.id);
			endif;
		endforeach;
		_ediUserDefinedAssist.allChildrenEDITIs.clear;
//write class.name&amp;'::'&amp;method.name&amp;' self='&amp;self.String&amp;' assist.myMasterEDITI='&amp;_ediUserDefinedAssist.myMasterEDITI.String&amp;' reset='&amp;_reset.String&amp;' str='&amp;str;
	else
		if self.cargoType = null and self.product &lt;&gt; null then
			//epr TFS 6980 26/9/17 if we passsed in products there was a problem with 2 different cargo types with the same product id
			tmpProduct := self.getMyProduct(null, self.operatorCode);	
			
			if tmpProduct &lt;&gt; null and 
			   cargoType = 0 then 
				self.cargoType := tmpProduct.myCargoType.id;
			endif;
		endif;
		
		if self.myEDIData.isKindOf(CM_EDIDataTrainConsist) then
			if self.wagonNumber = null then
				self.wagonNumber := _ediUserDefinedAssist.currentWagonNumber;
			endif;
		endif;
		
		// make sure the manual collection on CM_EDIConfig gets maintained
		self.setConsignorVoyage( self.getConsignorVoyage() );	// cnwrl1 11/06/2010 PAR 24299
		
		if self.isoType = null then
			contRange := self.getContRange();
			if contRange &lt;&gt; null then
				self.isoType := contRange.isoType;
			endif;
		endif;
		if self.coolingType = ContainerCooledNull then
			if contRange = null then
				contRange := self.getContRange();
			endif;
			if contRange &lt;&gt; null then
				self.coolingType := contRange.coolingType;
			endif;
		endif;	
		
		// TFS 63125
		if self.myEDIData.isTransportManifestRelated then
			if self.myEDIData.isKindOf(CM_EDIDataGateDoc) then
				manifest := self.myEDIData.CM_EDIDataGateDoc.myTransportManifest;
			elseif self.myEDIData.isKindOf(CM_EDIDataTrainConsist) then
				manifest := self.myEDIData.CM_EDIDataTrainConsist.myTransportManifest;
			endif;
			
			if manifest &lt;&gt; null then
				self.manifestNumber := manifest.manifestNumber;
			endif;
		endif;
		// TFS 63125 end
	endif;
	
	self.setItemisedData();		//JIRA-27323
epilog
	
end;
</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <Parameter name="_strIdentifier" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="de6e8cdc-a6b8-4e0f-8d64-85a9c9b6df57">
        <source>pxyCreateUpdateProxy(): SelfType;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		08 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// 08/03/2010	cnwsh3		PAR22993
//----------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 19 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	pxy : SelfType;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();
	
	pxy.myEDIData := self.myEDIData;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="requiresHumidity" id="ef610709-66fb-4c51-8143-86d560fa5b02">
        <source>requiresHumidity() : Boolean;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
//
vars
	operator : CM_Operator;
	isoType : CM_ISOType;
	commodity : CM_Commodity;
begin
	operator := app.myRoot.allOperators[self.operatorCode];
	if operator = null then
		return false;
	endif;
	if (not operator.requiresHumidity) then
		return false;
	endif;
	isoType := app.myRoot.allISOTypes[self.isoType];
	if isoType = null then
		return false;
	endif;
	commodity := app.myRoot.allCommodities[self.commodity];
	if commodity = null then
		return false;
	endif;
	if (isoType.isReefer or isoType.isIntegral) and 
	   commodity.hasTemp then
		return true;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="requiresPower" id="18f95420-7a1b-4478-8b20-02e8bedf3607">
        <source>requiresPower() : Boolean;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
//
vars
	operator : CM_Operator;
	isoType : CM_ISOType;
	commodity : CM_Commodity;
begin
	operator := app.myRoot.allOperators[self.operatorCode];
	if operator = null then
		return false;
	endif;
	if (not operator.requiresVentilation) then
		return false;
	endif;
	isoType := app.myRoot.allISOTypes[self.isoType];
	if isoType = null then
		return false;
	endif;
	commodity := app.myRoot.allCommodities[self.commodity];
	if commodity = null then
		return false;
	endif;
	if (isoType.isReefer or isoType.isIntegral or isoType.isPowered) and 
	   (commodity.hasTemp or commodity.requiresPower) then
		return true;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="requiresTemperature" id="e913a7db-3338-46d2-8156-aa57c321249a">
        <source>requiresTemperature() : Boolean;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
//
vars
	operator : CM_Operator;
	isoType : CM_ISOType;
	commodity : CM_Commodity;
begin
	operator := app.myRoot.allOperators[self.operatorCode];
	if operator = null then
		return false;
	endif;
	if (not operator.requiresVentilation) then
		return false;
	endif;
	isoType := app.myRoot.allISOTypes[self.isoType];
	if isoType = null then
		return false;
	endif;
	commodity := app.myRoot.allCommodities[self.commodity];
	if commodity = null then
		return false;
	endif;
	if (isoType.isReefer or isoType.isIntegral) and 
	   commodity.hasTemp then
