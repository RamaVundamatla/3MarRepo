    <JadeMethod name="setSearchToolbar" id="e7d810aa-24c7-4acf-8224-592aa9045988">
        <source>setSearchToolbar() protected;
//----------------------------------------------------------------------
//
//  Created by RBarr
//
//	Date 20 April 2006
//
//----------------------------------------------------------------------
// 03/12/2009	cnwmh5	PAR21651 - Rewrite so that frame adjust correctly
//						for show captions
//----------------------------------------------------------------------
vars
	
	tmpControl	: Control;
	numControls,
	i			: Integer;
	tmpParent1	: Window;
	
	currentHeight	: Real;
	newHeight		: Real;
	heightDiff		: Real;
	
begin

	// get the current height
	currentHeight := self.frmSearchToolbar.height;
	
	// set whether show captions is set
	self.frmSearchToolbar.showCaptions := self.frmToolbar.showCaptions;

	// get the new height
	newHeight := self.frmSearchToolbar.height;
	
	// get the difference in heights
	heightDiff := newHeight - currentHeight;
	
	// get the diff if grpOptions top &lt; height of toolbar
	if heightDiff = 0 and grpOptions.top &lt; self.frmSearchToolbar.height then
		heightDiff := ToolbarCaptionsHeight;		
	endif;

	// read through the controls adjusting those required
	numControls := self.controlCount;
	foreach i in 1 to numControls do
		tmpControl := self.controls(i);
		tmpParent1 := tmpControl.parent;
		
		if tmpControl.isKindOf(CMUI_Toolbar) then
			continue;
		endif;
		
		if tmpParent1.name &lt;&gt; self.frmSearch.name then //and tmpParent1.name &lt;&gt; self.grpOptions.name then
			continue;
		endif;
		
		// add the diff to the height
		tmpControl.top := tmpControl.top + heightDiff;
		
	endforeach;
	
	// set the frames height
	self.frmSearch.height := self.frmSearch.height + heightDiff;
	
epilog
	
end;

/*
vars
	
begin
	//What is the main toolbar doing?
	self.frmSearchToolbar.showCaptions := self.frmToolbar.showCaptions;
	
	//Set the height of the frame according to caption status so we have room for controls.
	if not self.frmSearchToolbar.showCaptions then
		frmSearch.height := frmSearch.height + ToolbarCaptionsHeight;
	endif;
	
end;
*/</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setSheetCaptions" id="004b65da-a306-4a88-b52b-18a7760e2f22">
        <source>setSheetCaptions(_sheet : CMUI_DataTableSheet input;_locale : CM_Locale)protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2009	cnwmd1	Initial creation

*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	definition : Integer;
begin
	if _sheet = shtMessages then
		definition := Xlat_0004109;
	elseif _sheet = shtFormCaptions then
		definition := Xlat_0004076;
	elseif _sheet = shtMenuEntities then
		definition := Xlat_0007219;
	elseif _sheet = shtPermissions then
		definition := Xlat_0004081;
	elseif _sheet = shtReportNames then
		definition := Xlat_0004082;
	elseif _sheet = shtTableEntitys then
		definition := Xlat_0004077;
	endif;
	
	_sheet.setCaption(definition, _sheet, _locale);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sheet" type="CMUI_DataTableSheet" usage="input"/>
        <Parameter name="_locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="setSheetFocus" id="535349c4-eb76-4b28-a868-f754266fe904">
        <source>setSheetFocus()protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2009	cnwmd1	Initial creation

*/

vars

begin
	if shtMessages.myDataTable.rows &gt; shtMessages.myDataTable.fixedRows then
		shtMessages.showMySheet;
	elseif shtFormCaptions.myDataTable.rows &gt; shtFormCaptions.myDataTable.fixedRows then
		shtFormCaptions.showMySheet;
	elseif shtMenuEntities.myDataTable.rows &gt; shtMenuEntities.myDataTable.fixedRows then
		shtMenuEntities.showMySheet;
	elseif shtPermissions.myDataTable.rows &gt; shtPermissions.myDataTable.fixedRows then
		shtPermissions.showMySheet;
	elseif shtReportNames.myDataTable.rows &gt; shtReportNames.myDataTable.fixedRows then
		shtReportNames.showMySheet;
	elseif shtTableEntitys.myDataTable.rows &gt; shtTableEntitys.myDataTable.fixedRows then
		shtTableEntitys.showMySheet;
	endif;
epilog

end;</source>
        <access>protected</access>
