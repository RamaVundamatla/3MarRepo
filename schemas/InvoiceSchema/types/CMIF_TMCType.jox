    <JadeMethod name="initialiseXCargo" id="33f995fb-e9d3-45ce-bcfd-a7dea1520fca">
        <source>initialiseXCargo();
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tranMap : CM_TranMap;
	tmctig : CMIF_TMCTranGroup;

begin
	foreach tranMap in self.myTMCController.myBank.myCurrentTranMapCargo do
		if tranMap.isKindOf(CM_SystemTranMap) then
			create tmctig as CMIF_TMCTranDefaultGroup;
		else
			create tmctig;
		endif;
		tmctig.myTranMapCargo := tranMap;
		tmctig.itemName := tmctig.getName();
		tmctig.extractName := tmctig.getCode();	// 23659
		tmctig.myGroup := self;
		tmctig.myTMCController := self.myTMCController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
		tmctig.initialise(self.myGroup.CMIF_TMCRoot.groupCount);
	endforeach;


end;</source>
    </JadeMethod>
