    <JadeMethod name="createInvoiceLineMapWO" id="f558dcc6-2f31-4e5c-ae05-024910cdc49f">
        <updating/>
        <source>createInvoiceLineMapWO(_invoiceLine : String; _quantityRangeMapObj : CM_QuantityRangeMap; _mapType : Integer; _isInContract : Boolean; _groupingType : String; _vesselCategory: HMS_VesselCategory; _transferType: CM_VoyageJobTransferType) : Boolean updating, protected;
/*
Purpose:	TFS 40620		
Date				Who			Reason
OCTOBER 2018		CNWAB1		Initial creation
*/

vars
	found	: Boolean;
	ls		: Boolean;
	lookForVoid	: Boolean;
	searchKey,
	key		: Integer;
	iter	: Iterator;
	ild,
	invLineDescObj,
	invoiceLineDescObj : CM_InvoiceLineDesc;
	pxyQR : CM_QuantityRangeMap;
	groupTypeObj		: CM_TranMapInvoiceLineGroupType;
	pxyMapping			: CM_TranMapInvoiceLineMapping;
	lineMapDict		: CM_TMInvLineMapByCargoAttrDict;
	groupType		: CM_TranMapInvoiceLineGroupType;
	lineMapping		: CM_TranMapInvoiceLineMapping;
	updateController :CMIF_TranMapLinesController;
	transferType	: CM_VoyageJobTransferType;
	vesselCategory	: HMS_VesselCategory;
	mapping : CM_TranMapInvoiceLineMapping;
begin
	// If we are creating a mapping we are doing that by updating the quantity range
	// The update of the QR purges all the existing mappings and re creates them
	// If we are updating the QR we make a proxy of the QR with all its current mappings and then add the new one
	
	
	
	self.getInvoiceLineDetails(_invoiceLine, invoiceLineDescObj);
	
	
	if self.baseColumnCount.isOneOf(15,17,18) then
		self.getGroupTypeDetails(_groupingType, groupTypeObj);	// 3/10/18 MAP TFS41202
	else
		groupTypeObj := self.myBank.getInvLineGroupAll();
	endif;
	

	iter := _quantityRangeMapObj.allTMInvoiceLineMappings.createIterator();
	while iter.next(mapping) do
		_quantityRangeMapObj.allTMInvoiceLineMappings.getIteratorKeys(key, iter);
		if mapping.myTMInvoiceLineDesc = invoiceLineDescObj 
		and mapping.myTMInvoiceLineGroupType = groupTypeObj then
				found := true;
				break;
		endif;
	endwhile;
	
	
	
	
	if not found then
		create updateController transient;
		app.cmsBeginLoad(ls);
		pxyQR := app.createUpdateProxy(_quantityRangeMapObj).CM_QuantityRangeMap;
		pxyQR.clear();
		app.cmsEndLoad(ls);

		if pxyQR.allRegisteredMethods = null then	//14 Jan 2011	NDL	Leaking transient in unit test
			create pxyQR.allRegisteredMethods transient;
		endif;
		_quantityRangeMapObj.allRegisteredMethods.copy(pxyQR.allRegisteredMethods);
		updateController.pxyQRMap := pxyQR;
		// copy the existing invoice line descriptions to the proxy, but not a VOID entry if there is no VOID in the load for this quantity range map
		// 32674 do this based on the voidList value only
		if self.voidList[self.rowCount] = false then
			lookForVoid := true;
		endif;

		lineMapDict := _quantityRangeMapObj.allTMInvoiceLineMappings;
		foreach lineMapping in lineMapDict do
			ild := lineMapping.myTMInvoiceLineDesc;
			key := lineMapping.mapValue;
			transferType := lineMapping.myTransferType;
			vesselCategory := lineMapping.myVesselCategory;
			groupType := lineMapping.myTMInvoiceLineGroupType;
			if lookForVoid then
				if ild.narration = self.voidInvoiceLineDesc then
					if searchKey = 0 then
						continue;
					elseif searchKey = key then
						continue;
					endif;
				endif;
			endif;
			create pxyMapping transient;
			pxyMapping.update(key, ild, pxyQR, groupType, transferType, vesselCategory, null, null, null);
		endforeach;
		
		key := 0;

		create pxyMapping transient;
		pxyMapping.update(key, invoiceLineDescObj, pxyQR, groupTypeObj, _transferType, _vesselCategory, null, null, null);

		app.myTrxUA.trxUpdateInvoiceTMTransaction(updateController, self.passport);
	endif;
	
	return true;
epilog
	app.cmsEndLoad(ls);				// 08/04/2011 cnwmh5 #27347
	delete updateController;
	delete pxyQR;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_invoiceLine" type="String"/>
        <Parameter name="_quantityRangeMapObj" type="CM_QuantityRangeMap"/>
        <Parameter name="_mapType" type="Integer"/>
        <Parameter name="_isInContract" type="Boolean"/>
