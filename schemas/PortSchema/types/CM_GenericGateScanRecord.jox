    <JadeMethod name="pxyCreateUpdateProxy" id="49eed38b-24c5-480b-8ad8-e8837a0fed47">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			Creates an Update proxy and populates references

Parameters:			NONE

Return Value:		SelfType: The proxy to use for updating

Date				Who		Reason
22 February 2022	navpw1	Initial creation TFS: 52773
16 July 2022		navmd1	TFS 52777 Tidy up/review code

*/

vars
	pxy 				: SelfType;
	cargoItem,
 	pxyCargoItem		: CM_CargoScanRecordData;
	
begin
	pxy 			:= inheritMethod();
	pxy.myTerminal 	:= self.myTerminal;
	
	foreach cargoItem in self.allCargoItems as CM_CargoScanRecordData do
		create pxyCargoItem transient;
		pxyCargoItem.setProxyForCreate(cargoItem.id, cargoItem.alternateId, cargoItem.type, cargoItem.sealTypes, cargoItem.sealValues);
		pxy.allCargoItems.add(pxyCargoItem);
	endforeach;
	
	return pxy;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="387223fd-1464-4eec-a4ad-7e8b33744d53">
        <updating/>
        <source>setForCreate(_pxyGateScanRecord : CM_GenericGateScanRecord) updating;
/*

Purpose:			Sets the fields for our CM_GenericGateScanRecord

Parameters:			_pxyGateScanRecord	CM_GenericGateScanRecord	The proxy CM_GenericGateScanRecord to update our real object from

Return Value:		NONE

Date				Who		Reason
14 February 2022	navpw1	Initial creation TFS: 52773
28 July 2022		navmd1	TFS 52773 Tidy up/review code

*/

vars
	pxyCargoItem,
	realCargoItem				: CM_CargoScanRecordData;

begin
	inheritMethod(_pxyGateScanRecord);
	
	// Attributes
	self.batNumber		:= _pxyGateScanRecord.batNumber;
	self.carrierCode	:= _pxyGateScanRecord.carrierCode;
	self.chassisId		:= _pxyGateScanRecord.chassisId;
	self.driverCode		:= _pxyGateScanRecord.driverCode;
	self.driverName		:= _pxyGateScanRecord.driverName;
	self.licenseNumber 	:= _pxyGateScanRecord.licenseNumber;
	self.scaleWeight 	:= _pxyGateScanRecord.scaleWeight;

	foreach pxyCargoItem in _pxyGateScanRecord.allCargoItems as CM_CargoScanRecordData do
		create realCargoItem persistent;
		realCargoItem.setForCreate(pxyCargoItem);
		self.allCargoItems.add(realCargoItem);
	endforeach;
	
end;</source>
        <Parameter name="_pxyGateScanRecord" type="CM_GenericGateScanRecord"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="55807f35-8066-49d3-a12f-26429a66d1f2">
        <updating/>
        <source>setForUpdate(_pxyGateScanRecord : CM_GenericGateScanRecord) updating;
/*

Purpose:			Sets the fields for our CM_GenericGateScanRecord

Parameters:			_pxyGateScanRecord	CM_GenericGateScanRecord	The proxy CM_GenericGateScanRecordto update our real object from

Return Value:		NONE

Date				Who		Reason
17 February 2022	navpw1	Initial creation TFS: 52773
28 July 2022		navmd1	TFS 52773 Tidy up/review code

*/

vars
	pxyCargoItem,
	realCargoItem					: CM_CargoScanRecordData;
	index							: Integer;
	allNewCargo,
	allExistingCargo				: CM_GenericScanRecDataArray;
	
begin
	//Attributes
	self.batNumber		:= _pxyGateScanRecord.batNumber;
	self.carrierCode	:= _pxyGateScanRecord.carrierCode;
	self.chassisId		:= _pxyGateScanRecord.chassisId;
	self.driverCode		:= _pxyGateScanRecord.driverCode;
	self.driverName		:= _pxyGateScanRecord.driverName;
	self.licenseNumber 	:= _pxyGateScanRecord.licenseNumber;
	self.scaleWeight 	:= _pxyGateScanRecord.scaleWeight;
	
	//References
	self.myTerminal		:= _pxyGateScanRecord.myTerminal;
	self.myVVR			:= _pxyGateScanRecord.myVVR;
	
	
	// Go through all the cargo and do the following
		// If the cargoId and alternateId and type match - then update it
		// If neither the cargoId, nor alternateId nor type match - then create it
		// If the existing cargo record isn't in the new one - then delete it
	
	allNewCargo := _pxyGateScanRecord.allCargoItems;
	allExistingCargo := self.allCargoItems;
	
	foreach pxyCargoItem in allNewCargo as CM_CargoScanRecordData do :processCargoItems
		foreach realCargoItem in allExistingCargo as CM_CargoScanRecordData do
			if 	pxyCargoItem.id = realCargoItem.id and
				pxyCargoItem.type = realCargoItem.type and
				pxyCargoItem.alternateId = realCargoItem.alternateId
			then
				realCargoItem.setForUpdate(pxyCargoItem);
				continue processCargoItems;
			endif;
		endforeach;
		
		// Didn't find a matching record that exists, so lets create a new one
		create realCargoItem persistent;
		realCargoItem.setForCreate(pxyCargoItem);
		self.allCargoItems.add(realCargoItem);
	endforeach;
	
	
	
	//We have to loop through the array backwards as we are removing items that do not exist in our _pxyGateScanRecord.allCargoItems
	//Going backwards makes the indexing work and means no items are missed
	foreach index in 1 to self.allCargoItems.size reversed do :processCargoitems
		realCargoItem := self.allCargoItems[index].CM_CargoScanRecordData;
		
		foreach pxyCargoItem in _pxyGateScanRecord.allCargoItems as CM_CargoScanRecordData do
			if pxyCargoItem.id = realCargoItem.id and 
				pxyCargoItem.type = realCargoItem.type and
				pxyCargoItem.alternateId = realCargoItem.alternateId
			then
				continue processCargoitems;
			endif;
		endforeach;
		
		self.allCargoItems.remove(realCargoItem);
		delete realCargoItem;
	endforeach;
	
end;</source>
        <Parameter name="_pxyGateScanRecord" type="CM_GenericGateScanRecord"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCreate" id="12cecbb2-7e6d-47dc-92f7-cf1c0b91038f">
        <updating/>
        <source>setProxyForCreate(_deviceId, _batNumber, _carrierCode, _chassisId, _driverCode, _driverName, _licenseNumber : String; 
					_weight : Decimal; _timestamp : TimeStampOffset; _myTerminal : CM_Terminal) updating;
/*

Purpose:			Sets the fields applicable for create, on our proxy CM_GenericGateScanRecord

Parameters:			_deviceId		String		The device id for the gate record
					_batNumber		String		The bat number for the gate record
					_carrierCode	String		The carrier code for the gate record
					_chassisId		String		The chassis id for the gate record
					_driverCode		String		The driver code for the gate record
					_driverName		String		The truck company of the truck the gate record was received on
					_licenseNumber	String		The license number of the truck the gate record was received on
					_timestamp		TimeStamp	The timestamp of the gate record
					_myTerminal		CM_Terminal	The terminal the gate record belongs to

Return Value:		NONE

Date				Who		Reason
14 February 2022	navpw1	Initial creation TFS: 52773
12 July 2022		navmd1	TFS 52777 Tidy up/review code

*/

begin
	self.deviceId 		:= _deviceId;
	self.batNumber 		:= _batNumber;
	self.carrierCode 	:= _carrierCode;
	self.chassisId 		:= _chassisId;
	self.driverCode 	:= _driverCode;
	self.driverName 	:= _driverName;
	self.licenseNumber 	:= _licenseNumber;
	self.timestamp 		:= _timestamp;
	
	self.myTerminal 	:= _myTerminal;
	
	self.setWeight(_weight);
	
end;</source>
        <Parameter name="_deviceId" type="String"/>
        <Parameter name="_batNumber" type="String"/>
        <Parameter name="_carrierCode" type="String"/>
        <Parameter name="_chassisId" type="String"/>
        <Parameter name="_driverCode" type="String"/>
        <Parameter name="_driverName" type="String"/>
        <Parameter name="_licenseNumber" type="String"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_timestamp" type="TimeStampOffset"/>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setProxyForUpdate" id="91a4912a-cb62-4619-bad4-b851204f05ae">
        <updating/>
        <source>setProxyForUpdate(_batNumber, _carrierCode, _chassisId, _driverCode, _driverName, _licenseNumber : String; _weight : Decimal; _vvr : CM_VehicleVisitRecord) updating;
/*

Purpose:			Sets the fields applicable for update, on our proxy CM_GenericGateScanRecord

Parameters:			_batNumber		String					The bat number for the gate record
					_carrierCode	String					The carrier code for the gate record
					_chassisId		String					The chassis id for the gate record
					_driverCode		String					The driver code for the gate record
					_driverName		String					The truck company of the truck the gate record was received on
					_licenseNumber	String					The card id used for receiving the gate record
					_scaleWeight	Decimal					The scale weight of the gate record
					_vvr			CM_VehicleVisitRecord	The vehicle visit record to associate the gate scan record with

Return Value:		NONE

Date		Who		Reason
16 February 2022	navpw1	Initial creation TFS: 52773

*/

begin
	self.batNumber 		:= _batNumber;
	self.carrierCode 	:= _carrierCode;
	self.chassisId 		:= _chassisId;
	self.driverCode 	:= _driverCode;
	self.driverName 	:= _driverName;
	self.licenseNumber 	:= _licenseNumber;
	
	self.setWeight(_weight);
	
	self.myVVR			:= _vvr;
	
end;</source>
        <Parameter name="_batNumber" type="String"/>
        <Parameter name="_carrierCode" type="String"/>
        <Parameter name="_chassisId" type="String"/>
        <Parameter name="_driverCode" type="String"/>
        <Parameter name="_driverName" type="String"/>
        <Parameter name="_licenseNumber" type="String"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setWeight" id="7169b322-7cf4-4be7-9082-c70ad4d9ab9d">
        <updating/>
        <source>setWeight(_scaleWeight: Decimal) updating, protected;
/*

Purpose:			Make sure we store weight in KGs, so it can be transformed later

Parameters:			_scaleWeight	Decimal		The scale weight of the gate record

Return Value:		

Date			Who		Reason
12 July 2022	navmd1	TFS 52777 Tidy up/review code

*/

vars
	weighBridge	: CM_WeighBridgeObj;
	found		: Boolean;
begin
	
	if self.deviceId &lt;&gt; null then
		foreach weighBridge in self.myTerminal.allWeighBridges discreteLock do
			if weighBridge.deviceId = self.deviceId then
				found := true;
				break;
			endif;
		endforeach;
	endif;
	
	if not found or weighBridge.myWeightType = null then
		// Nothing we can do, so just send through the weight as-is
		self.scaleWeight := _scaleWeight;
	else
		app.writeLog(method.qualifiedName &amp; " Converting weight from " &amp; weighBridge.myWeightType.shortName, LogTRACE);
		self.scaleWeight := app.convertMeasurementForStorage(weighBridge.myWeightType.shortName, _scaleWeight);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_scaleWeight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="da0f2cc0-fdc4-45a6-8616-07f111d0fff0">
        <source>validateForCreate();
/*

Purpose:			Validates that our mandatory fields are set for Create

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
14 February 2022	navpw1	Initial creation TFS: 52773
28 July 2022		navmd1	TFS 52773 Tidy up/review code

*/

vars
	existingGateScanRecord	: CM_GenericGateScanRecord;
	genericIfaceAPIDevice	: CM_Object;
	
begin
	
	if self.myTerminal = null then
		app.raiseCMException1(REQUIRED_FIELD, self.myTerminal.name, null, null);
	endif;
	
	if self.deviceId = null then
		app.raiseCMException1(REQUIRED_FIELD, "device-id", null, null);
	endif;
	
	if self.timestamp = null then
		app.raiseCMException1(REQUIRED_FIELD, "timestamp", null, null);
	endif;
	
	existingGateScanRecord := self.myTerminal.allGenericScanRecs[self.deviceId, self.timestamp];
	if existingGateScanRecord &lt;&gt; null then
		app.raiseCMException3(Gate_scan_record_duplicate, self.deviceId, self.timestamp.String, self.myTerminal.name, null, null);
	endif;
	
	//Do we have a GenericIfaceAPIDevice (CM_WeighBridgeObj or CM_ScanReaderObj) to match the Generic Scan Record to
	genericIfaceAPIDevice := app.myAlternateDict.getGnrcIfaceDvcById(self.deviceId, self.myTerminal.code);
	if genericIfaceAPIDevice = null then
		app.raiseCMException2(WB_not_matched, self.deviceId, self.myTerminal.code, null, null);
	endif;
	
	self.validateMe();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="4100e2f2-a1dc-4b75-a062-fb1176b454e8">
