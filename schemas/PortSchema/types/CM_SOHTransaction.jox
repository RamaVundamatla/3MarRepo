    <JadeMethod name="erase" id="bbea7ce7-d7cd-49ea-98ec-3d20e7ec93f1">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//--------------------------------------------------------------
//Created: 30 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tiTrans : CM_TITransaction;
begin

	if (not self.allTITransactions.isEmpty) then
		foreach tiTrans in self.allTITransactions do
			tiTrans.setMySOHTransaction(null);
		endforeach;
	endif;
	
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDateTimeLocalTZ" id="50adb6ac-366d-4f00-84ea-10828dbf3a04">
        <source>getDateTimeLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2016	cnwns1	Initial creation
// 30 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.dateTime);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="e83b2cf3-14a7-449c-af81-06a98faf590b">
        <source>getDisplayString() : String;
//--------------------------------------------------------------
//Created: 16 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	return 	self.getProductCode() &amp; CrLf &amp;
			'Previous Qty: ' &amp; self.beforeQuantity.String &amp; '  ' &amp;
			' Adjustment: ' &amp; self.adjustQuantity.String &amp; CrLf &amp;
			'Previous Volume: ' &amp; self.beforeVolume.String &amp; '  ' &amp;
			' Adjustment: ' &amp; self.adjustVolume.String &amp; CrLf &amp;
			'Previous Weight: ' &amp; self.beforeWeight.asStringWeightJMT() &amp; '  ' &amp;
			' Adjustment: ' &amp; self.adjustWeight.asStringWeightJMT();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getID" id="020b1414-49a6-476d-a20f-83294514b3f2">
        <source>getID() : String;
//--------------------------------------------------------------
//Created: 16 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.myStockOnHand &lt;&gt; null then
		return self.myStockOnHand.getID();
	endif;
	return '&lt;deleted&gt;';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="c19f9ca4-4ec5-4930-a3a6-cabb9f8a5a1f">
        <source>getName(): String;

vars

begin
	return inheritMethod() &amp; ' ' &amp; self.getID;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProductCode" id="84e4ccbc-a5e4-40c4-8874-1a39b5f237a5">
        <source>getProductCode() : String;
//--------------------------------------------------------------
//Created: 17 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.myStockOnHand &lt;&gt; null then
		return self.myStockOnHand.getProductCode();
	endif;
	return '&lt;deleted&gt;';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPushEventsDateTime" id="3d75efd6-0016-4bd7-a5e2-0f4d3d5e5ddf">
        <source>getPushEventsDateTime() : TimeStamp;
/*

Purpose:			Get the relevant timestamp from the receiver to be used in the header
					of the Push Events message

Parameters:			None

Return Value:		TimeStamp of the receiver's "event"

Date		Who		Reason
15 Feb 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars

begin
	return self.dateTime;
	
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getType" id="3eb7ad34-e2e5-42a7-8be7-e9b7cf02ad49">
        <source>getType(): Integer;
// ---------------------------------------------------------------------------
// Created:     10 March 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.type;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isSohTrx" id="399a7303-3c32-47e3-860a-b55e5eeb442d">
        <source>isSohTrx(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setValuesPostUpdate" id="6bba0a21-222d-48ad-8020-ba2a24fdd13f">
        <updating/>
        <source>setValuesPostUpdate(_tiTxn : CM_TITransaction input)updating;
//--------------------------------------------------------------
//Created: 29 October 2002 By: cnwgd1
//--------------------------------------------------------------
//Note: _tiTxn can be null if no TI was involved in the update.
vars

begin
	if _tiTxn &lt;&gt; null then
		_tiTxn.setMySOHTransaction(self);
	endif;
	self.adjustQuantity := (self.myStockOnHand.currentQuantity - self.beforeQuantity);
	self.adjustVolume 	:= (self.myStockOnHand.currentVolume - self.beforeVolume);
	self.adjustWeight 	:= (self.myStockOnHand.currentWeightKgs - self.beforeWeight);		
end;</source>
        <Parameter name="_tiTxn" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setValuesPriorUpdate" id="17b092f8-3558-4fd9-ad08-29e53bbdd3b0">
        <updating/>
        <source>setValuesPriorUpdate(_soh : CM_StockOnHand; _type : Integer; _userCode, _comment : String; _parent : Object) updating;
//--------------------------------------------------------------
//Created: 29 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	if _soh = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null SOH reference.');
		return;
	endif;
	
	self.beforeQuantity := _soh.currentQuantity;
	self.beforeVolume	:= _soh.currentVolume;
	self.beforeWeight	:= _soh.currentWeightKgs;
	self.dateTime		:= app.serverTimestampAtTrxStart;
	
	self.myStockOnHand 	:= _soh;
	
	self.type			:= _type;
	self.userCode		:= _userCode;
	
end;</source>
        <Parameter name="_soh" type="CM_StockOnHand"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_parent" type="Object"/>
    </JadeMethod>
    <JadeMethod name="typeString" id="fbb135e0-8595-4ced-b295-834d45f4cdc9">
        <methodInvocation>mapping</methodInvocation>
        <source>typeString(_set: Boolean; _value: String io) mapping;
//--------------------------------------------------------------
//Created: 03 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	str : String;
begin
	if _set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	str := 'TransType_' &amp; self.type.String;
	_value := app.currentLocale.getStringValue(str);
	if _value = null then
		_value := 'Unknown Type';
	endif;
	
end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
