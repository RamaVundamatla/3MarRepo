    <JadeMethod name="setDetails" id="4db9669b-596d-4e17-bc99-a37284806bf5">
        <updating/>
        <source>setDetails(_entRow : EntTableRow) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/10/2020	jlgdap1		Initial creation TFS 49227 MTN Navis API - nReefer API
//
vars
	inputType : String;

begin
	if _entRow.inputType = Table.InputType_TextBox or _entRow.inputType = Table.InputType_TextNumeric or _entRow.inputType = Table.InputType_SignedNumeric then
		if _entRow.myEntTableCellControl &lt;&gt; null and _entRow.myEntTableCellControl.getDecimals &lt;&gt; null then
			inputType := self.DecimalWidget;
		else
			inputType := self.TextWidget;
		endif;
	elseif _entRow.inputType = Table.InputType_None then
		inputType := self.LabelWidget;
	elseif _entRow.inputType = Table.InputType_CheckBox then
		inputType := self.CheckboxWidget;
	else
		inputType := self.LabelWidget;
	endif;
	
	self.widgetType := inputType;
	self.lovKey := _entRow.controlName;
	if self.lovKey &lt;&gt; null then
		self.widgetType := self.LovWidget;
	endif;
	
	if self.widgetType = self.DecimalWidget then
		self.height := 1;
	elseif _entRow.name = ETRow_ReeferRemarks then
		self.height := 1;
	else
		self.height := 0;
	endif;
	self.weight := 0;
	
	if self.lovKey &lt;&gt; null then
		self.extraEntry := app.getErrorString(None);
	endif;
epilog

end;</source>
        <Parameter name="_entRow" type="EntTableRow"/>
    </JadeMethod>
</Class>
