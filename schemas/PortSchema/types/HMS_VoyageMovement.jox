    <JadeMethod name="setOccursOnDT" id="fd0e8ae6-e044-45b3-bc7c-f7eff4304e51">
        <updating/>
        <source>setOccursOnDT(_value: TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:     04 January 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
07 Apr 208	cnwkpd1	PAR #16465 - Any timing changes need to update owning HMS_VoyageData
					object so that Graphical View will stay in sync
30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/

vars
	tmpVoyage	: CM_Voyage;

begin
	inheritMethod(_value);
	
	if self.myHMSVoyageData &lt;&gt; null then
	
		self.updateObjectEdition (self.myHMSVoyageData);	// par 30292	// PAR #16465
	
		tmpVoyage := self.myHMSVoyageData.myVoyage;
		if tmpVoyage &lt;&gt; null then
			if self.isTransient or  not tmpVoyage.isTransient then
			
				if self.moveType = HMSMovementTypeArrival then
					tmpVoyage.setArrivalDT(_value);
				elseif self.moveType = HMSMovementTypeDeparture then
					tmpVoyage.setDepartureDT(_value);	
				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_value" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setPilotExemptOnFutureMove" id="28ca431a-a487-44fa-b99a-e9ce3b548151">
        <updating/>
        <source>setPilotExemptOnFutureMove( now : TimeStamp ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2012	cnwndl1	Initial creation	Par 29496

*/

vars

begin

	// only interested in future movements.
	if self.occursOnDTNEW &lt;= now then
		return;
	endif;
	
	if self.myHMSVoyageData.isPilotExempt &lt;&gt; self.pilotExempt then
		self.pilotExempt := self.myHMSVoyageData.isPilotExempt;
	endif;

epilog

end;</source>
        <Parameter name="now" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="8efb08d0-8266-42c2-8cdd-0bf2cbac07cd">
        <updating/>
        <source>setProxy(_aftClearanceFrom, _aftClearanceTo, _bowMarkTo, _sternMarkTo, _foreClearanceFrom, _foreClearanceTo : Decimal;
		_locationPilotLaunch, _locationTug, _numContractTugs, _moveStatus, _numLineCrewRequired, _relativeOrderTimeLines,
		_relativeOrderTimePlaunch, _relativeOrderTimeTugs, _sideTo : Integer; _draftFwd, _draftAft : Real;
		 _moveType, _remarks, _shipsMaster : String; _occursOnDT : TimeStamp; _chargeForMove, _isAgentDefault,
		 _overlapsWharfSection, _pilotExempt : Boolean; _myPilot : HMS_Pilot; _myMaster : HMS_Master;_myPilotLaunch : HMS_PilotLaunch;
		 _myLineCompany : HMS_LineCompany; _myShippingAgent : CM_ShippingAgent; _myShippingLine : CM_ShippingLine;
		 _myContact : CM_EmailAddress2; _myBerth : HMS_Berth; _myTidalClass : HMS_TidalClass; _myHarbour : HMS_Harbour;
		 /*_allPilots : HMS_PilotByCodeDict;*/  _allMovementPilotDetails : HMS_MovementPilotDetailsSet)updating;// TFS 44438 - after 040 cut/release
//--------------------------------------------------
// Created:	08 April 2004 By: cnwgd1
//--------------------------------------------------
// 30 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

vars
	tempMvmntPilotDetails, // TFS 44438
	pxyMvmntPilotDetails : HMS_MovementPilotDetails; // TFS 44438
begin
	self.raiseExceptionIfNotTransient(method);
	
	if _myHarbour = null then
		if self.myHMSVoyageData &lt;&gt; null  then
			self.myHarbour := self.myHMSVoyageData.myHarbour;
		endif;
	else 
		self.myHarbour := _myHarbour;
	endif;
 	
 	self.aftClearanceFrom			:= _aftClearanceFrom;
	self.aftClearanceTo 			:= _aftClearanceTo;
	self.bowMarkTo 					:= _bowMarkTo;
	self.chargeForMove				:= _chargeForMove;
    self.draftFwd 					:= _draftFwd;
    self.draftAft 					:= _draftAft;	
	self.foreClearanceFrom 			:= _foreClearanceFrom;
	self.foreClearanceTo			:= _foreClearanceTo;
	self.isAgentDefault 			:= _isAgentDefault;
	self.locationPilotLaunch 		:= _locationPilotLaunch;
	self.locationTug 				:= _locationTug;
	self.moveType 					:= _moveType;
	self.numContractTugs 			:= _numContractTugs; 
    self.moveStatusNEW				:= _moveStatus;
	self.numLineCrewRequired 		:= _numLineCrewRequired;
	self.occursOnDTNEW 				:= _occursOnDT; 	
	self.overlapsWharfSection 		:= _overlapsWharfSection;
	self.pilotExempt				:= _pilotExempt;
	self.relativeOrderTimeLines		:= _relativeOrderTimeLines;
	self.relativeOrderTimePlaunch	:= _relativeOrderTimePlaunch;
	self.relativeOrderTimeTugs		:= _relativeOrderTimeTugs;
	self.remarks					:= _remarks;
	self.shipsMaster				:= _shipsMaster;
	self.sideTo						:= _sideTo;
	self.sternMarkTo				:= _sternMarkTo;

 	//self.myPilot 					:= _myPilot;
	//31 Oct 2018	NDL	TFS 41662
	/*self.setUnusedMyPilotRefToNull(); // --&gt; TFS 44438
	self.allPilots.clear();
	if _allPilots &lt;&gt; null and not _allPilots.isEmpty then
		_allPilots.copy( self.allPilots );
	endif;*/ // &lt;-- TFS 44438
	
	self.allMovementPilotDetails.clear(); // --&gt; TFS 44438 - create proxies for all the movement details...
	if _allMovementPilotDetails &lt;&gt; null and not _allMovementPilotDetails.isEmpty then
		foreach tempMvmntPilotDetails in self.allMovementPilotDetails do
			pxyMvmntPilotDetails := tempMvmntPilotDetails.pxyCreateUpdateProxy();
			self.allMovementPilotDetails.add(pxyMvmntPilotDetails);
		endforeach;
	endif; // &lt;-- // TFS 44438

	self.myMaster 					:= _myMaster;
 	//self.myPilotLaunch 				:= _myPilotLaunch; // TFS 44438
 	self.myLineCompany 				:= _myLineCompany;
 	self.myShippingAgent 			:= _myShippingAgent;
 	self.myShippingLine				:= _myShippingLine; 	
 	self.myContact 					:= _myContact;
 	self.myBerth 					:= _myBerth;
 	self.myTidalClass 				:= _myTidalClass;

end;</source>
        <Parameter name="_aftClearanceFrom" type="Decimal"/>
        <Parameter name="_aftClearanceTo" type="Decimal"/>
        <Parameter name="_bowMarkTo" type="Decimal"/>
        <Parameter name="_sternMarkTo" type="Decimal"/>
        <Parameter name="_foreClearanceFrom" type="Decimal"/>
