    <JadeMethod name="createTALocationAudits" id="15fd0e4a-24ba-4690-8ecc-bad2d99dd3ec">
        <source>createTALocationAudits()protected;
// ---------------------------------------------------------------------------
// Created:     03 March 2011 by cnwcs5 CCMS CPL 2027 /PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc		:CM_LocationsController;
	set		:CM_LCSet;
	int		:Integer;
	str		:String;
begin
	create set transient;
	
	if self.updateMode = self.UpdateMode_HeightRestriction or
		self.updateMode = self.UpdateMode_LocationAvailable or
		self.updateMode = self.UpdateMode_LocationUnavailable then
		foreach lc in self.allLocationControllers do
			if not lc.isKindOf(CM_GridController) then
				continue;
			endif;			
			set.add (lc);
		endforeach;

		if set.isEmpty then
			// nothing will be updated
			return;
		endif;
		
		if self.updateMode = self.UpdateMode_HeightRestriction then
			// work out value for Nothing From &lt;nn&gt;
			int := self.availability - PAD_USER_UNAVAILABLE;
			str	:= CM_AuditTALocations.AuditDetail_HeightRestrict &amp; int.String;
			
			app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (self.myGridArea, set, CM_AuditTALocations.LocnTypeUpdate_HeightRestrict, AuditCreated, str);
		elseif self.updateMode = self.UpdateMode_LocationAvailable then
			app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (self.myGridArea, set, CM_AuditTALocations.LocnTypeUpdate_LocationAvail, AuditCreated, CM_AuditTALocations.AuditDetail_FullyAvailable);

		elseif self.updateMode = self.UpdateMode_LocationUnavailable then
			app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (self.myGridArea, set, CM_AuditTALocations.LocnTypeUpdate_LocationUnavail, AuditCreated, CM_AuditTALocations.AuditDetail_NotAvailable);
		endif;
		
	elseif self.updateMode = self.UpdateMode_PowerDamaged or
		self.updateMode = self.UpdateMode_PowerGood then
		
		foreach lc in self.allLocationControllers do
			if not lc.isKindOf(CM_GridController) then
				continue;
			endif;			
			if lc.CM_GridController.power then
				set.add (lc);
			endif;
		endforeach;
		
		if self.updateMode = self.UpdateMode_PowerDamaged then
			app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (self.myGridArea, set, CM_AuditTALocations.LocnTypeUpdate_PowerDamage, AuditCreated, null);
		elseif self.updateMode = self.UpdateMode_PowerGood then
			app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (self.myGridArea, set, CM_AuditTALocations.LocnTypeUpdate_PowerAvail, AuditCreated, null);
		endif;
	endif; 
epilog
	delete set;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateControllers" id="8cbbab2c-3c3b-4c2a-940c-0d2572dc1d94">
        <source>updateControllers(_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03/03/2011	cnwcs5		CCMS CPL 2027 / PAR 27126
// ---------------------------------------------------------------------------

vars
	aController : CM_LocationsController;
	aTowerController, aGridController : CM_GridController;
	aTower,aTI : CM_TrackedItem;
	theString : String;
	theResult : Boolean;
	//theDiscrepancy : CM_TIDiscrepancy;
	userInfo : String;
	fullValue, idx, beforeAvail, afterAvail, beforeMax, afterMax : Integer;
begin
	// 03/03/2011 cnwcs5 CCMS CPL 2027 / PAR 27126
	// create audits before we do any updating
	self.createTALocationAudits;
	
	foreach aController in self.allLocationControllers do
		if not aController.isKindOf(CM_GridController) then
			continue;
		endif;
		aGridController := aController.CM_GridController;
		aGridController.remarks := self.remarks.trimBlanks;
		
		if self.updateMode = self.UpdateMode_HeightRestriction 
		or self.updateMode = self.UpdateMode_LocationAvailable 
		or self.updateMode = self.UpdateMode_LocationUnavailable then
			beforeAvail := aGridController.getMaxStackingHeight();
			beforeMax := aGridController.allTrackedItems.size;
			aGridController.updateFromCMIF_GridRegion(self);
			self.updateKPIHeights(beforeAvail, beforeMax, aGridController);
		elseif self.updateMode = self.UpdateMode_PowerDamaged then
			if aGridController.power then
				aGridController.powerDamaged := true;
			endif;
		elseif self.updateMode = self.UpdateMode_PowerGood then
			if aGridController.power then
				aGridController.powerDamaged := false;
			endif;
		endif; 

		aGridController.myTerminalArea.causeEvent(aGridController.myTerminal.getTerminalEvent(EVENT_TI_MOVE), false, aGridController);

		//Do we have TOWERS/TIs, and are we SETTING POWER DAMAGED?
		if self.updateMode = self.UpdateMode_PowerDamaged then
	
			//############################
			// UPDATE TOWERS
			
			//We need to Advise Users of Towers, and Update their nonOperational bool flag
			aTowerController := aGridController.getNextControllerOfType(CM_TowerController);
			if aTowerController = null then
				aTowerController := aGridController.getPreviousControllerOfType(CM_TowerController);
			endif;
			if aTowerController &lt;&gt; null then
				foreach aTower in aTowerController.allTrackedItems do
					if aTower.isKindOf(CM_Tower) then
						aTower.CM_Tower.setNonOperational(true);
						
						theString := app.getErrorString1(VB_TOWER_DISCREP,aTower.id);
						//th2 discrepancies obsolete - see CMEVT_OverriddenWarning
						//app.myUtilityCA.utlCreateTIDiscrepancy(aTower, theString, theDiscrepancy);
						if _passport.hasErrors then
						//	app.writeStatement("AKB" &amp; " " &amp; class.name &amp; '::' &amp; method.name &amp; " 1. ERROR Creating a discrepancy on " &amp; aTower.id);
							return;
						endif;
					endif;
				endforeach;
			endif;
			
			//###########################
			// UPDATE TRACKED ITEMS
			foreach aTI in aController.allTrackedItems do
				if aTI.isAttributeTrue(TI_Attrib_RequiresPower) or aTI.isAttributeTrue(TI_Attrib_RequiresTemperature) then
				
					theString := app.getErrorString1(VB_TI_POWER_DISCREP,aTI.id);
					//th2 discrepancies obsolete - see CMEVT_OverriddenWarning
					//app.myUtilityCA.utlCreateTIDiscrepancy(aTI,theString,theDiscrepancy);
					if _passport.hasErrors then
//						app.writeStatement("AKB" &amp; " " &amp; class.name &amp; '::' &amp; method.name &amp; " 1. ERROR Creating a discrepancy on " &amp; aTI.id);
						return;
					endif;
				endif;
			endforeach;
		endif;

	endforeach;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateKPIHeights" id="77627b19-a494-4ca9-8397-69060572c249">
        <source>updateKPIHeights(_beforeAvail, _beforeMax : Integer; aGridController : CM_GridController);
// ---------------------------------------------------------------------------
// Created:		08 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	userInfo : String;
	maxTIs, fullValue, idx, beforeAvail, afterAvail, beforeMax, afterMax : Integer;
	theTerminal : CM_Terminal;
begin
	if aGridController = null then
		return;
	endif;
	
	theTerminal := aGridController.myTerminal;

	// no kpi license
//	if not app.myPassport.myUser.canDo(theTerminal, PmKPIModule) then
	if not app.myPassport.myUser.canDo(theTerminal, Mod_BaseSystem) then//07 Oct 2019	NDL	TFS 46169
		return;
	endif;


	beforeAvail := _beforeAvail;
	beforeMax := _beforeMax;
			
	afterAvail := aGridController.getMaxStackingHeight();
	afterMax := aGridController.allTrackedItems.size;
	if (beforeMax = beforeAvail) then
		fullValue :=  -1;
	elseif (afterMax = afterAvail) then
		fullValue :=  1;
	endif;
	maxTIs := (afterAvail - beforeAvail);
	userInfo := "0^0^0^0^" &amp; fullValue.String &amp; "^1^0^" &amp; maxTIs.String;
	aGridController.myTerminalArea.causeEvent(aGridController.myTerminal.getTerminalEvent(EVENT_KPIYARDMOVE), false, userInfo);
	
	if beforeAvail &gt; afterAvail then
		afterAvail := afterAvail  + 1;
		foreach idx in afterAvail to beforeAvail do
			userInfo := "0^0^0^0^0^" &amp; idx.String &amp; "^-1^0";
			aGridController.myTerminalArea.causeEvent(aGridController.myTerminal.getTerminalEvent(EVENT_KPIYARDMOVE), false, userInfo);
		endforeach;
	else
		beforeAvail := beforeAvail  + 1;
		foreach idx in beforeAvail to afterAvail do
			userInfo := "0^0^0^0^0^" &amp; idx.String &amp; "^1^0";
			aGridController.myTerminalArea.causeEvent(aGridController.myTerminal.getTerminalEvent(EVENT_KPIYARDMOVE), false, userInfo);
		endforeach;
	
	endif;

end;</source>
        <Parameter name="_beforeAvail" type="Integer"/>
        <Parameter name="_beforeMax" type="Integer"/>
        <Parameter name="aGridController" type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="validateControllers" id="4df31fb5-4464-40b9-95cf-cddc1737a950">
        <source>validateControllers();
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aController : CM_LocationsController;
	aTower : CM_GridController;
	maxHeight : Integer;
	realHeight : Integer;
begin

	maxHeight := -1;
	foreach aController in self.allLocationControllers do

		// #########################################
		// AVAILABILITY
			
		if self.updateMode = self.UpdateMode_LocationAvailable
		or self.updateMode = self.UpdateMode_LocationUnavailable then
			if self.availability = PAD_UNAVAILABLE or  self.availability = PAD_USER_UNAVAILABLE  then
				//---------------------
				//Trying to set unavailable.
				//---------------------
				if aController.numTIs &lt;&gt; 0 or 
					aController.numPlannedTIs &gt; 0 or 
					aController.numQueuedTIs &gt; 0 then
					 // AKB2009SEPapp.raiseCMException2(ERR_LC_HAS_TIS," ACTUAL ", aController.getFullId, null, null);
					app.raiseCMException1(ERR_LC_HAS_TIS_ACTUAL, aController.getFullId, null, null); // AKB2009SEP
				endif;
		 	endif;
		endif;
		if  self.updateMode = self.UpdateMode_HeightRestriction then
			if maxHeight = -1 then				
				maxHeight := self.myGridArea.heightOfStack;
			endif;													

			//----------------------
			//Calculate the height where they want to restrict from
			//----------------------
			realHeight := self.availability - PAD_USER_UNAVAILABLE ;
			//----------------------
			//And check its not going to upset us
			//----------------------
			if realHeight &gt; maxHeight and maxHeight &lt;&gt; -1 then
				app.raiseCMException3(ERR_REST_HEIGHT, realHeight.String, self.id, "this Area is limited to a maximum stack height of " &amp; maxHeight.String, null, null);
			endif;

			//---------------------
			//Test to see if there is anything planned/queued/actually there or above.
			//---------------------
			if aController.numTIs &gt;= realHeight then
				app.raiseCMException3(ERR_REST_HEIGHT, realHeight.String, aController.getName, "there is already a container at or above the height you are restricting", null, null);
			endif; 
			if aController.numPlannedTIs &gt;= realHeight then
				app.raiseCMException3(ERR_REST_HEIGHT, realHeight.String, aController.getName, "there is already a container planned at or above the height you are restricting", null, null);
			endif; 
			if aController.numQueuedTIs &gt;= realHeight then
				app.raiseCMException3(ERR_REST_HEIGHT, realHeight.String, aController.getName, "there is already a container queued at or above the height you are restricting", null, null);
			endif; 
		endif; // AVAILABILITY
	
	









		// #########################################
		// POWER DAMAGED
			
		//Do we have TOWERS/TIs, and are we SETTING POWER DAMAGED?
		if self.updateMode = self.UpdateMode_PowerDamaged then
			if aController.CM_GridController.power &lt;&gt; true then
				app.raiseCMException(ERR_LC_NO_POWER, null, null);
			endif;

			//We need to Advise Users of Towers, and Update their nonOperational bool flag
			aTower := aController.CM_GridController.getNextControllerOfType(CM_TowerController);
			if aTower = null then
				aTower := aController.CM_GridController.getPreviousControllerOfType(CM_TowerController);
			endif;
			if aTower &lt;&gt; null then
				app.raiseCMException1(VB_CHANGE_TOWER_STATUS, aTower.allTrackedItems.size.String, app.getMyUserCode, app.getMyUser());

			endif;
		endif;
	endforeach;



end;</source>
    </JadeMethod>
</Class>
