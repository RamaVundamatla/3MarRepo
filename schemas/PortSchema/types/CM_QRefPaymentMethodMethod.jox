    <JadeMethod name="setComboValues" id="5cf96c2a-fce5-479b-8592-111e2d1feba4">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars
	payMeth			: CM_PaymentMethod;
	payMethDict		: CM_PaymentMethodByCodeDict;
	qrl				: CM_QReferenceLookup;
begin
	_combo.clear();
	payMethDict := app.myRoot.allPaymentMethods;
	
	foreach payMeth in payMethDict do
		_combo.itemObject[_combo.addItem(payMeth.description)] := payMeth;
	endforeach;

	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="77ac0fbd-da59-4df8-a592-2eb8ebc7644b">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

begin
	if _value &lt;&gt; null then
		return _value.CM_PaymentMethod.description;
	endif;

	return null;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="d78cd83f-d539-438a-90b6-c0852eed8290">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

begin

	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;

		if _value.isKindOf(CM_PaymentMethod) then
			return _value.CM_PaymentMethod;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
