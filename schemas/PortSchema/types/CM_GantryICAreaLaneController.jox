    <JadeMethod name="getDrawingAttributes" id="78077747-5152-4bde-8cdb-c7fbacf4e0d6">
        <source>getDrawingAttributes(pDisplay: Integer; pView: Integer; pHeight: Integer; pColour: Integer output; pLetter: String output);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwer1	Initial creation

*/

vars

begin
	inheritMethod(pDisplay, pView, pHeight, pColour, pLetter);
	pLetter := "L";
	if pColour = NULL_COLOURCODE then
		pColour := Gray;
	endif;
epilog

end;</source>
        <Parameter name="pDisplay" type="Integer"/>
        <Parameter name="pView" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
