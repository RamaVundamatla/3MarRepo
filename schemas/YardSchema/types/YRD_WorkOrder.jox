    <JadeMethod name="buildCmbBillingAdj" id="5a7008f1-6043-45ad-8381-9dcfe8e0101c">
        <updating/>
        <source>buildCmbBillingAdj() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	billing,
	ta 			  : CM_WodBillingAdjustment;
	period 		  : Decimal[6,2];
	timespanmin,
	idx,
	newrow 		  : Integer;
	voyage	      : CM_Voyage;
	resused		  : HMS_ResourceUsed;
	timespanqdays : Decimal [12,2];
	tmpTS,
	newFromDateTime,
	newToDateTime,
	oldFromDateTime,
	oldToDateTime : TimeStamp;
begin
	if self.myPxyTask &lt;&gt; null  and self.myPxyTask.isKindOf(CM_WodBillingAdjustment) then
		ta := self.myPxyTask.CM_WodBillingAdjustment;
		if ta &lt;&gt; null then	
			voyage := ta.getMyVoyageObject();
			if voyage &lt;&gt; null then
				resused := voyage.getExtensionResourceUsed();
				
				if resused &lt;&gt; null then
					if resused.fromDateTime.isValid
					and resused.toDateTime.isValid
					and resused.toDateTime &gt; resused.fromDateTime then


						timespanmin := resused.fromDateTime.getDifferenceInMinutes(resused.toDateTime);
					//quarterdayminutes := 360;
						timespanqdays := timespanmin / 1440;
						
						// ### Build captions
						self.lblBillingAdjExplain.caption := app.getErrorString1(Current_extensi_period_days,timespanqdays.String);

						tmpTS := self.systemToLocalTime(resused.fromDateTime);
						oldFromDateTime := resused.fromDateTime;
						self.lblBillingAdjExplain.caption := self.lblBillingAdjExplain.caption &amp; CrLf &amp; app.getErrorString1(Current_extension_start, tmpTS.asStringJMT());
						
						tmpTS 			:= self.systemToLocalTime(voyage.departedDT);
						oldToDateTime	:= voyage.departedDT;
						newToDateTime 	:= voyage.departedDT;
						newFromDateTime := ta.newFromDateTime;
						
						self.lblBillingAdjExplain.caption := self.lblBillingAdjExplain.caption &amp; CrLf &amp; app.getErrorString1(Current_extension, tmpTS.asStringJMT());
						
						self.cmbBillingAdjPeriod.clear();
						self.cmbBillingAdjPeriod.sorted := false;
						
						idx := -1;
						while true do
							period := period + 0.25;
							if period &gt; timespanqdays then
								break;
							endif;
							
							if period &gt; 100 then
								break;
							endif;
							
							newrow := self.cmbBillingAdjPeriod.addItem(period.String &amp; " Days");
						 
							 if ta.newUnitsUsed = period then
								idx := newrow;
							endif;
						endwhile;
						self.cmbBillingAdjPeriod.listIndex := idx;
						
						if timespanqdays &lt; 0.25 then
							app.msgBox(app.getErrorString(Exten_perio_less_than_quart_sm), app.getErrorString(Problem),MsgBox_OK_Only);
						endif;
					endif;
				endif;
				if ta.isComplete or ta.getStatus() = WO_STATUS_APPROVED then
					self.grpBillingAdj.enabled := false;
				endif;
				self.txtBillingAdjReason.text := ta.remarks;
				self.lblBillingAdjStart.caption :="";
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbBol" id="ab7bf638-3a3a-4fa4-b976-7cf37bd6a608">
        <updating/>
        <source>buildCmbBol(_voyage : CM_Voyage)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Jul 2023	navma1	Initial creation
06 Jul 2023 navhl20 Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
*/

vars
	iter 	: Iterator;
	bol		: CM_BOL;
begin
	if _voyage &lt;&gt; null then
		iter := _voyage.allBOLInByTypeStatusNumDT.createIterator;
	else
		iter := self.myTerminal.allBOLsReceivedByDTType.createIterator;
	endif;
	self.cmbBol.clear();
	self.cmbBol.addItem("");
	
	while iter.next(bol) do
		self.cmbBol.addItemObject(bol.number, bol);
	endwhile;
	
	if self.myPxyTask &lt;&gt; null then
		bol := self.myPxyTask.CM_WodReceive.myBillOfLading;
		if bol &lt;&gt; null then	
			self.cmbBol.setIndexFromObject(bol);
			self.cmbBol_click(self.cmbBol);
		endif;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="buildCmbBolItems" id="75ad7642-a303-40df-8cf1-af393ef125f3">
        <updating/>
        <source>buildCmbBolItems(_bol : CM_BOL)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2023	navma1	Initial creation
25 Jul 2023 navma1	Bug 59315: MTN - For the Ship Receive work orders there is no button to add the created cargo on ship
*/

vars
	item : CM_BOLDtl;
begin
	self.cmbBolItems.clear();
	self.cmbBolItems.addItem("");
	
	if _bol &lt;&gt; null then
		foreach item in _bol.allBOLDtls do
			self.cmbBolItems.addItemObject(item.getShortDisplay(), item);
		endforeach;
		
		if _bol.allBOLDtls.size = 1 then
			self.cmbBolItems.setIndexFromObject(_bol.allBOLDtls.first);
			self.cmbBolItems_click(self.cmbBolItems);						//5.07.2023 navma1 #56738
		endif;
	endif;
	
	item := self.myPxyTask.CM_WodReceive.myBillOfLadingDtl;
	
	if item &lt;&gt; null then	
		self.cmbBolItems.setIndexFromObject(item);
	endif;

epilog

end;</source>
        <Parameter name="_bol" type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="buildCmbBooking" id="0a344951-c3f8-46ba-89a1-643204578002">
        <updating/>
        <source>buildCmbBooking(_voyage: CM_Voyage)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
11 Jul 2023 navma1	Defect 59095: EUP - Able to save the Receive Cargo Work Order without the Booking selected when the VAS Subscription is on/off
23 Dec 2024	navbs1	Bug MTN-33524: MTN - Notifications in the work order details screen update the release request assigned as a new work order is created
*/

vars
	booking,
	item	: CM_BookingRef;
	iter 	: Iterator;
	term    : CM_Terminal;
	voyage  : CM_Voyage;
	
begin
	term := self.myTerminal;
	
	//self.beginClassNotification(CM_BookingRef, false, term.getTerminalEvent(Event_BookingRefAdd), Response_Continuous, 0);			//23.12.2024 navbs1 #33524
	//self.beginClassNotification(CM_BookingRef, false, term.getTerminalEvent(Event_BookingRefUpdate), Response_Continuous, 0);			//23.12.2024 navbs1 #33524
	//self.beginClassNotification(CM_TrackedItem, false,term.getTerminalEvent(TIEvent_PreNote_Add), Response_Continuous, 0);			//23.12.2024 navbs1 #33524
	
	self.cmbBooking.clear();
	self.cmbBooking.addItemObject("", null);
	
	
	if _voyage &lt;&gt; null then
		iter := _voyage.allBookingRefs.createIterator;
		_voyage.allBookingRefs.startKeyGeq(null, null, iter);
	else
		iter := term.allBookingRefsByStatusRef.createIterator;
		term.allBookingRefsByStatusRef.startKeyGeq(BOOKING_REF_PENDING, null, iter);
	endif;
	
	
	while iter.next(booking) do
		if booking.status &gt; BOOKING_REF_ACTIVE then
			break;
		endif;
		self.cmbBooking.addItemObject(booking.bookingReference, booking);
	endwhile;
	
	if self.myPxyTask.isKindOf(CM_WodReceive) then													//28.06.2023 navma1 #58920
		item := self.myPxyTask.CM_WodReceive.myBookingRef;
	elseif self.myPxyTask.isKindOf(CM_WodRelease) then												//04.07.2023 navma1 #58952
		item := self.myPxyTask.CM_WodRelease.myBookingRef;
	endif;
	
	if item &lt;&gt; null then
		if  self.cmbBooking.findObject(item) = -1  then												//04.07.2023 navma1 #58976
			self.cmbBooking.itemObject[self.cmbBooking.addItem(item.bookingReference)] := item;
		endif;
		self.cmbBooking.listObject := item;	
		self.cmbBooking_click(self.cmbBooking);														//06.7.2023 navhl20 #58952
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="buildCmbBookingItem" id="1c7c844a-3299-4e2d-affb-d7e8ad3eae8a">
        <updating/>
        <source>buildCmbBookingItem(_booking: CM_BookingRef)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Apr 2023	navhl20	ChangeRequest 57322:[57323] EUP - VAS Task linked with Receive Cargo work Order
28 Jun 2023 navma1	Bug 58920: MTN - 1090 Exception when actioning the Release Cargo Work Order for Export Bookings
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
*/

vars
	item : CM_BookingRefItem;
begin
	self.cmbBookingItem.clear();
	
	if _booking &lt;&gt; null then
		foreach item in _booking.allBookingRefItems do
			self.cmbBookingItem.addItemObject(item.getDisplayString(), item);
		endforeach;
		
		if _booking.allBookingRefItems.size = 1 then
			self.cmbBookingItem.setIndexFromObject(_booking.allBookingRefItems.first);
		endif;
	endif;
	
	if self.myPxyTask.isKindOf(CM_WodReceive) then						//28.06.2023 navma1 #58920
		item := self.myPxyTask.CM_WodReceive.myBookingRefItem;
	elseif self.myPxyTask.isKindOf(CM_WodRelease) then					//04.07.2023 navma1 #58952
		item := self.myPxyTask.CM_WodRelease.myBookingRefItem;
	endif;
	
	if item &lt;&gt; null then	
		self.cmbBookingItem.setIndexFromObject(item);
		self.cmbBookingItem_click(self.cmbBookingItem);
	endif;
epilog

end;</source>
        <Parameter name="_booking" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="buildCmbCancelReq" id="2f0ff301-aa4a-4562-86d5-411b489c0a9c">
        <updating/>
        <source>buildCmbCancelReq() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	_hmsCancel,ta : CM_WodHMSRequestCancel;
begin
	if self.myPxyTask &lt;&gt; null  and self.myPxyTask.isKindOf(CM_WodHMSRequestCancel) then
			ta := self.myPxyTask.CM_WodHMSRequestCancel;
			if ta &lt;&gt; null then	
				self.cmbWorkOrderC.listIndex := self.cmbWorkOrderC.findObject(ta.myWorkOrderToCancel);
				
				if ta.isComplete then
					self.grpCancelRequest.enabled := false;
				endif;
			endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbCargoReq" id="249f0d6e-ec3e-4329-93e7-5a7fd7698db0">
        <updating/>
        <source>buildCmbCargoReq() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	weightMeasure, volumeMeasure : CM_MeasurementType;
	weight, volume : String;
	imexStatus : CM_IMEXStatus;
	dischargePort : CM_Port;
	transferType : CM_VoyageJobTransferType;
	loadPort : CM_Port;	
	estStartTS : TimeStamp;	
	estEndTS : TimeStamp;	
	localRequiredByDT : TimeStamp;
	voyageProcess : CM_VoyageProcess;
	harbour : HMS_Harbour;
	resources : HMS_ResourceByTypeDict;	
	_cargoRequest,ta : CM_WodCargoRequest;
	voy : CM_Voyage;

begin
	self.lblVoyage.left := self.lblCargoType.left;
    self.lblVoyage.width := self.lblCargoType.width;
	self.cmbVoyage.left := self.cmbCargoType.left;
	self.cmbVoyage.width := self.cmbCargoType.width;
	if self.myPxyTask &lt;&gt; null  and self.myPxyTask.isKindOf(CM_WodCargoRequest) then
			ta := self.myPxyTask.CM_WodCargoRequest;
			voy := self.myPxyTask.getMyVoyageObject();
			if ta &lt;&gt; null then	
				self.populateCmbDebtor();
				self.displayResources(ta);
				if voy &lt;&gt; null then
					voyageProcess := voy.myVoyageProcess;		
				endif;
				
				harbour := self.myTerminal.myHarbour;
		
				if ta.myVoyageCargoRequest &lt;&gt; null then
					//Part of total voyage cargo request
					if ta.myVoyageCargoRequest.myBerth &lt;&gt; null then
						self.cmbBerthCR.listIndex := self.cmbBerthCR.findObject( ta.myVoyageCargoRequest.myBerth );
					endif; 
					self.lblBerthCR.visible := true;
					self.cmbBerthCR.visible := true;
					
					localRequiredByDT := self.systemToLocalTime(ta.myVoyageCargoRequest.requiredByDT);
					//self.dtReqBy.setDate(localRequiredByDT.date);
					//self.tmReqBy.setTime(localRequiredByDT.time);
				else
					//An individual additional cargo request
					self.lblBerthCR.visible := false;
					self.cmbBerthCR.visible := false;
				endif;
				
				self.cmbCargoType.listIndex := self.cmbCargoType.findObject(ta.myCargoType);
				self.cmbCargoType_click(self.cmbCargoType);
				self.cmbCargoSubType.listIndex := self.cmbCargoSubType.findObject(ta.myCargoSubType);
				self.cmbCommodity.listIndex := self.cmbCommodity.findObject(ta.myCommodity);
				self.cmbOperator.listIndex := self.cmbOperator.findObject(ta.myOperator);
				self.cmbConsignee.listIndex := self.cmbConsignee.findObject(ta.myConsignee);
				self.cmbConsignor.listIndex := self.cmbConsignor.findObject(ta.myConsignor);
				self.cmbFreightFwdr.listIndex := self.cmbFreightFwdr.findObject(ta.myFreightForwarder);
				self.myAssistant.comboBoxSpecialStow(self.cmbSpecialStow,ta.getSpecialStowObject);
		
				weightMeasure := app.getDefaultMeasurementForType(Type_Weight);
				volumeMeasure := app.getDefaultMeasurementForType(Type_Volume);
				if ta.myCargoType &lt;&gt; null then
					weightMeasure := ta.myCargoType.getDefaultMeasurementForType(Type_Weight);
					volumeMeasure := ta.myCargoType.getDefaultMeasurementForType(Type_Volume);
				endif;
				if ta.myCargoSubType &lt;&gt; null then
					weightMeasure := ta.myCargoSubType.getDefaultMeasurementForType(Type_Weight);
					volumeMeasure := ta.myCargoSubType.getDefaultMeasurementForType(Type_Volume);
				endif;
				self.txtTotalQuantity.text := ta.totalQuantity.String;
				weight := app.convertMeasurementForDisplay(weightMeasure.shortName, ta.totalWeight);
				volume := app.convertMeasurementForDisplay(volumeMeasure.shortName, ta.totalVolume);
				self.txtTotalWeight.setValues(weight &amp; Space &amp; weightMeasure.shortName);
				self.txtTotalVolume.setValues(volume &amp; Space &amp; volumeMeasure.shortName);
				if ta.weightTare &lt;&gt; null then
					weight := app.convertMeasurementForDisplay(weightMeasure.shortName, ta.weightTare);
					self.txtTareWeight.setValues(weight &amp; Space &amp; weightMeasure.shortName);
				endif;
				if ta.weightCargo &lt;&gt; null then
					weight := app.convertMeasurementForDisplay(weightMeasure.shortName, ta.weightCargo);
					self.txtCargoWeight.setValues(weight &amp; Space &amp; weightMeasure.shortName);
				endif;
		
				imexStatus := app.myRoot.allImexStatuses[ta.imexStatus];
				if imexStatus &lt;&gt; null then
					self.cmbImexStatus.listIndex := self.cmbImexStatus.findObject(imexStatus);
					if imexStatus.code = TI_IMEX_STATUS_IMPORT then
						self.cmbDischargePort.enabled := false;
					else
						self.cmbDischargePort.enabled := true;
					endif;
				endif;
				dischargePort := app.myRoot.allPorts[ta.dischargePort];
				if dischargePort &lt;&gt; null then
					self.cmbDischargePort.listIndex := self.cmbDischargePort.findObject(dischargePort);
				endif;
				self.cmbWorkPoint.listIndex := self.cmbWorkPoint.findObject(ta.getMyWorkPoint);
				transferType := app.myRoot.allVoyageJobTransferTypes[ta.transferType];
				if transferType &lt;&gt; null then
					self.cmbTransferType.listIndex := self.cmbTransferType.findStringExact(1, transferType.description);
				endif;
				self.txtNumGangs.text := ta.numGangs.String;
				self.cmbLocation.listIndex := self.cmbLocation.findObject(ta.myLocationsController);
		
				loadPort := app.myRoot.allPorts[ta.loadPort];
				if loadPort &lt;&gt; null then
					self.cmbLoadPort.listIndex := self.cmbLoadPort.findObject(loadPort);
				endif;
				self.txtBOLNumber.text := ta.bolNumber;
				
				estStartTS := self.systemToLocalTime(ta.estimatedStartTS);
				estEndTS := self.systemToLocalTime(ta.estimatedEndTS);
				self.txtEstStartDate.setDate(estStartTS.date);
				self.txtEstStartTime.setTime(estStartTS.time);
				self.txtEstEndDate.setDate(estEndTS.date);
				self.txtEstEndTime.setTime(estEndTS.time);
				
				if ta.isComplete or ta.getStatus() = WO_STATUS_APPROVED then
					self.grpCargoRequest.enabled := false;
					self.tblResources.enabled := false;
				endif;
			endif;
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbExtension" id="356d1678-76f0-4c39-809d-4538f8f72c61">
        <updating/>
        <source>buildCmbExtension() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			ho		Reason
23 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	ta : CM_WodExtension;
	voyage : CM_Voyage;
	processHarbour : CM_ProcessHarbour;
	resources : HMS_ResourceByTypeDict;

begin
	if self.myPxyTask &lt;&gt; null  and self.myPxyTask.isKindOf(CM_WodExtension) then
			ta := self.myPxyTask.CM_WodExtension;
			voyage := self.myPxyTask.getMyVoyageObject();
			if ta &lt;&gt; null then 
				if ta.occursOnDT.isValid then
					self.txtMoveOnDateNew.setDate(ta.occursOnDT.date);
					self.txtMoveOnTimeNew.setTime(ta.occursOnDT.time);
				endif;
				self.displayResources(ta);
				self.chkHasRamp.value := ta.hasRamp;
				
				if ta.isComplete then
					self.grpExtension.enabled := false;
				endif;
			endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbMarineDept" id="d93e00b6-8e24-43ca-a890-7dd26f9d2237">
        <updating/>
        <source>buildCmbMarineDept() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
25 April 2022	navukv20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	_wodtl,ta : CM_WodMarineServicesDepart;
	voyageStatus : CM_VoyageStatus;
	voy : CM_Voyage;
begin
	if self.myPxyTask &lt;&gt; null  and self.myPxyTask.isKindOf(CM_WodMarineServicesDepart) then
		ta := self.myPxyTask.CM_WodMarineServicesDepart;
		voy := self.myPxyTask.getMyVoyageObject();
		if ta &lt;&gt; null then	
			self.displayResources(ta);
			
			if ta.draftFwd &lt;&gt; null then
				self.txtDraftFwdMD.text := ta.draftFwd.String;
			endif;
			if ta.draftAft &lt;&gt; null then
				self.txtDraftAftMD.text := ta.draftAft.String;
			endif;
			if ta.bowMarkTo &lt;&gt; null then
				self.txtBowMarkToMD.text := ta.bowMarkTo.String;
			endif; 
			if voy &lt;&gt; null and voy.myHMSVoyageData &lt;&gt; null then
				self.cmbTowVoyageMD.visible := voy.myHMSVoyageData.requiresTow;
				self.lblTowingVoyMD.visible := self.cmbTowVoyageMD.visible;
				self.cmbTowVoyageMD.setObject( ta.myTowingVoyage );
				
				if ta.isComplete then
					self.grpMarineD.enabled := false;
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbMarineInit" id="eb57ab2e-a763-4378-b3ae-5404dd845c28">
        <updating/>
        <source>buildCmbMarineInit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	_wodtl,ta : CM_WodMarineServicesInitial;
	voy : CM_Voyage;
begin
	if _wodtl &lt;&gt; null then
			self.cmbBerthMI.listIndex := self.cmbBerthMI.findObject( _wodtl.myBerth );
	endif;	
	
	if self.myPxyTask &lt;&gt; null  and self.myPxyTask.isKindOf(CM_WodMarineServicesInitial) then
			ta := self.myPxyTask.CM_WodMarineServicesInitial;
			voy := self.myPxyTask.getMyVoyageObject();
			if ta &lt;&gt; null then	
				self.cmbBerthMI.listIndex := self.cmbBerthMI.findObject( ta.myBerth );
				if ta.draftFwd &lt;&gt; null then
					self.txtDraftFwdMI.text := ta.draftFwd.String;
				endif;
				if ta.draftAft &lt;&gt; null then
					self.txtDraftAftMI.text := ta.draftAft.String;
				endif;
				if ta.bowMarkTo &lt;&gt; null then
					self.txtBowMarkToMI.text := ta.bowMarkTo.String;
				endif;
				self.chkHasRampMI.value := ta.hasRamp;
				self.optStarboardMI.value := ta.starboardBerthed;
				self.displayResources(ta);
				if voy.myHMSVoyageData &lt;&gt; null then
					self.cmbTowVoyageMI.visible := voy.myHMSVoyageData.requiresTow;
					self.lblTowingVoyMI.visible := self.cmbTowVoyageMI.visible;
					self.cmbTowVoyageMI.setObject( ta.myTowingVoyage );
					
					if ta.isComplete then
						self.grpMarineI.enabled := false;
					endif;
				endif;
			endif;
		endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbNewVoyageReq" id="db3e4cef-e302-43eb-8316-591de258cf8a">
        <updating/>
        <source>buildCmbNewVoyageReq() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
25 April 2022	navukv20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	ta : CM_WodVoyageRequest;
	tmpTS: TimeStamp;
	voy : CM_Voyage;
begin
	if self.myPxyTask &lt;&gt; null  and self.myPxyTask.isKindOf(CM_WodVoyageRequest) then
		ta := self.myPxyTask.CM_WodVoyageRequest;
		voy := self.myPxyTask.getMyVoyageObject();
		if ta &lt;&gt; null then
			// ARRIVAL
			tmpTS := ta.estimatedArrivalTS;
			if not tmpTS.isValid() then
				tmpTS := voy.estimatedArrivalDT;
			endif;
			if not tmpTS.isValid() then
				tmpTS := voy.arrivedDT;
			endif;
			self.txtEstArrVR.setDate(tmpTS.date);
			self.txtEstArrTimeVR.setTime(tmpTS.time);
			
			// DEPARTURE
			tmpTS := ta.estimatedDepartureTS;
			if not tmpTS.isValid() then
				tmpTS := voy.estimatedDepartureDT;
			endif;
			if not tmpTS.isValid() then
				tmpTS :=  voy.departedDT;
			endif;
			self.txtEstDepVR.setDate(tmpTS.date);
			self.txtEstDepTimeVR.setTime(tmpTS.time);
			
			self.txtCodeVoyageInVR.text := ta.voyageCodeIn;
			self.txtCodeVoyageOutVR.text := ta.voyageCodeOut;

			self.buildComboAllPorts(ta);
			self.buildComboAllOperators(ta);
			
			self.buildComboAllVisitTypes(self.cmbVisitTypeVR,ta.visitTypeCode);
			self.buildComboAllVesCat(self.cmbVesselCatVR,ta.vesselCategoryCode);
			
			self.chkHasCargoVR.value := ta.hasCargo;
			self.txtGeneralRemarksVR.text := ta.generalRemarks; 
			
			if ta.isComplete or ta.getStatus() = WO_STATUS_APPROVED then
				self.grpNewVoyageRequest.enabled := false;
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbNullVoyage" id="0710233e-6b6c-45ad-a65f-f75cc34982ce">
        <source>buildCmbNullVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	voyage : CM_Voyage;	
    iter 	: Iterator;
begin
	iter := self.myTerminal.allVoyagesNew.createIterator;
	voyage := self.myVoyage;
	self.cmbVoyage.clear;
	
	while iter.next(voyage) do
		self.cmbVoyage.listIndex := self.cmbVoyage.addItemObject(voyage.code &amp; Tab &amp; voyage.vesselName, voyage);
	endwhile; 
	
	if self.myPxyTask &lt;&gt; null  and self.myPxyTask.isKindOf(CM_WodNullVoyage) then
		voyage := self.myPxyTask.CM_WodNullVoyage.myNewVoyage;
		if voyage &lt;&gt; null then	
		
			self.cmbVoyage.setIndexFromObject(voyage);	
		endif;
	endif;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbOrganisation" id="a9ec6238-7f98-47bc-aa97-6387296df54c">
        <source>buildCmbOrganisation();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 March 2022		navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars

begin
	self.cmbOgrainisation.setObject(app.myPassport.myUser.myOrganisation);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbPermitRequest" id="7366e37e-e44c-497d-8d95-6a108adbb37a">
        <updating/>
        <source>buildCmbPermitRequest() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
25 April 2022	navukv20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
16 Aug 2022		navhl20		Bug 54481: MTN - Work Orders - Can not find all the permit types while creating a permit request

*/

vars
	ta : CM_WodPermitRequest;
	pos,
	initialMarineStatus : Integer;
	wodtl : CM_WodCargoRequest;
	voy : CM_Voyage;
begin
	if self.myPxyTask &lt;&gt; null  and self.myPxyTask.isKindOf(CM_WodPermitRequest) then
			ta := self.myPxyTask.CM_WodPermitRequest;
			//voy := self.myPxyTask.getMyVoyageObject();		//16.8.2022 navhl20 TFS 54481
			voy := self.myVoyage;								//16.8.2022 navhl20 TFS 54481
			if ta &lt;&gt; null then	
				self.cmbPermitType.clear;						//16.8.2022 navhl20 TFS 54481
				if ta &lt;&gt; null and ta.isAdditionalCargo then
					self.cmbPermitType.addItemWithData(app.workOrderPermitsString(INV_WO_PERMIT_CARGOPENALTY), INV_WO_PERMIT_CARGOPENALTY);	//2
					self.cmbPermitType.addItemWithData( app.workOrderPermitsString(INV_WO_PERMIT_CARGONOPENALTY), INV_WO_PERMIT_CARGONOPENALTY);	//3
				else
				
					self.cmbPermitType.addItemWithData( app.workOrderPermitsString(INV_WO_PERMIT_MANUALETMAL),INV_WO_PERMIT_MANUALETMAL);	//1
				
					if voy &lt;&gt; null and voy.myGeneralCargoVoyage &lt;&gt; null then
						self.cmbPermitType.addItemWithData(app.workOrderPermitsString(INV_WO_PERMIT_CARGOPENALTY), INV_WO_PERMIT_CARGOPENALTY);	//2
						self.cmbPermitType.addItemWithData( app.workOrderPermitsString(INV_WO_PERMIT_CARGONOPENALTY), INV_WO_PERMIT_CARGONOPENALTY);	//3
						self.cmbPermitType.addItemWithData( app.workOrderPermitsString(INV_WO_PERMIT_CONTINUNOPENALTY), INV_WO_PERMIT_CONTINUNOPENALTY);	//4
						self.cmbPermitType.addItemWithData( app.workOrderPermitsString(INV_WO_PERMIT_CONTINUEPENALTY), INV_WO_PERMIT_CONTINUEPENALTY);	//5
					endif;
				endif;
			endif;
			if ta.permitType &gt; 0 then
				self.cmbPermitType.listIndex := self.cmbPermitType.findItemData( ta.permitType );
			else
				self.cmbPermitType.listIndex :=self.cmbPermitType.findItemData( INV_WO_PERMIT_MANUALETMAL);
			endif;
			self.selectPermitType();
			self.cmbPermitType.enabled:=not ta.isComplete;
			if ta.permitDetailType &gt; 0 then
				self.cmbPermitFor.setIndexForItemData(ta.permitDetailType);
				self.cmbPermitFor.enabled:=not ta.isComplete;
			endif;
			
			self.cmbRelatedWO.enabled := not ta.isComplete;
			self.selectPermitFor();
			
			
			self.myAssistant.comboBoxOperator(self.cmbPermitOperator,ta.myOperator,self.myVoyage);
			
			self.txtPermitTotalDays.text:=ta.myParent.CM_WorkOrderVoyage.lengthOfTime.asStringJMT;
			
			if ta.isComplete then
				self.grpPermit.enabled := false;
			endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbRelExtRel" id="fb1264b7-a95d-421c-9497-f659e876f89b">
        <source>buildCmbRelExtRel();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	iter 	: Iterator;
	release : CM_BulkRelease;
	wodtl 	: CM_WorkOrderDtl;

begin
	
	wodtl := self.lstTasks.listObject.CM_WorkOrderDtl;
	iter := self.myTerminal.allBulkReleaseByTypeByStByCd.createIterator;
	self.myTerminal.allBulkReleaseByTypeByStByCd.startKeyGeq(BR_TYPE_ROAD, BR_PENDING, null, null, iter);

	while iter.next(release) do
		if release.status &gt; BR_ACTIVE then
			break;
		endif;
		if release.releaseByType then
			continue;
		endif;
		self.cmbRelExtRel.addItemObject(release.code, release);
	endwhile;
	
	self.populateAvailableWORels( wodtl.CM_WodReleaseExtension );
	self.cmbRelExtWORel.listIndex := -1; // Work order cargo release
	self.cmbRelExtRel.listIndex := -1; // Bulk Release

	if wodtl.CM_WodReleaseExtension.myReleaseWorkOrder &lt;&gt; null then
	self.cmbRelExtWORel.setIndexFromObject( wodtl.CM_WodReleaseExtension.myReleaseWorkOrder);
	self.cmbRelExtWORel.click( self.cmbRelExtWORel );
	endif;
		
	if self.myPxyTask &lt;&gt; null  and self.myPxyTask.isKindOf(CM_WodRelease) then
		release := self.myPxyTask.CM_WodRelease.getMyReleaseRequest();
		if release &lt;&gt; null then								
			self.cmbRelExtRel.setIndexFromObject(release);	
		endif;
	endif;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbRelease" id="1e395c96-c93f-45f3-b7fd-f9376f285c0e">
        <source>buildCmbRelease();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Mar 2022	navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
07 Feb 2023	navcs2	ChangeRequest 55440: EUP - Cargo Work Order Enhancements (54990)
18 Apr 2023	navhl20 ChangeRequest 55442:[57629] EUP - Pack Cargo Work Order - Enhancement
02 May 2023 navma1	Defect 57816: MTN - WO - The release requests are not filtering correctly based on the transport mode selected..
14 June 2023 navhl20 Bug 58634: MTN - Release by Type option should be disabled if there is no VAS subscription 
23 Dec 2024	navbs1	Bug MTN-33524: MTN - Notifications in the work order details screen update the release request assigned as a new work order is created
*/

vars
	iter 	: Iterator;
	release : CM_BulkRelease;
	mode    : Integer;
	term    : CM_Terminal;
begin	
	
	term := self.myTerminal;
	self.cmbReleaseRequest.clear();
	
	//self.beginClassNotification(CM_BulkRelease, false, term.getTerminalEvent(BulkRelease_Update_Event), Response_Continuous, 0); 		//23.12.2024 navbs1 #33524
	
	if self.myPxyTask &lt;&gt; null and self.myPxyTask.isKindOf(CM_WodRelease) then				//18.4.2023 navhl20 #55442[57629]
		mode := app.transportModeStringToENum(self.cmbTransMode.text);						//02.05.2023 navma1 #57816
	else
		mode := BR_TYPE_PACKING;
	endif;
	
	iter := term.allBulkReleaseByTypeByStByCd.createIterator;
	term.allBulkReleaseByTypeByStByCd.startKeyGeq(mode, BR_PENDING, null, null, iter);

	self.cmbReleaseRequest.addItemObject("", null);
	
	while iter.next(release) do
		if release.type &lt;&gt; mode then													    //02.05.2023 navma1 #57816
			continue;
		endif;
		if release.status &gt; BR_ACTIVE then
			break;
		endif;
		if not self.hasVasSubscription then													//14.6.2023 navhl20 #58634
			if release.releaseByType then
				continue;
			endif;
		endif;
		self.cmbReleaseRequest.addItemObject(release.code, release);
	endwhile;
	
	if self.myPxyTask &lt;&gt; null  then
		if self.myPxyTask.isKindOf(CM_WodRelease) then
			release := self.myPxyTask.CM_WodRelease.getMyReleaseRequest();
		elseif self.myPxyTask.isKindOf(CM_WodPack) then
			release := self.myPxyTask.CM_WodPack.myReleaseRequest;
		endif;
	endif;
	
	if release &lt;&gt; null then
		if release.status &gt; BR_ACTIVE then
			self.cmbReleaseRequest.addItemObject(release.code, release);
		endif;
		
		self.cmbReleaseRequest.setIndexFromObject(release);	
		self.btnSelectCargo.enabled := true;
	endif;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbReserveDetails" id="6a053694-3ee2-443b-990a-b266460952a9">
        <source>buildCmbReserveDetails(_bulkRelease: CM_BulkRelease);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Mar 2023	navcs2	ChangeRequest 55440:[54990]: EUP - Release Cargo Work Order - Enhancement
20 Apr 2023 navma1  ChangeRequest 57324:[57325] EUP - VAS Task linked with Release Cargo Work Order
05 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
*/

vars
	iter 			: Iterator;
	reserveDetail	: CM_ReserveDetail;
	cargoType		: CM_CargoType;
begin
	self.cmbReserveDetail.clear();
	
	if _bulkRelease = null or _bulkRelease.releaseByType = false then
		return;
	else
		if self.myPxyTask.isKindOf(CM_WodPack) then																//05.07.2024 navhl20 #61368
			iter := _bulkRelease.allReservePackingChildren.createIterator;
			while iter.next(reserveDetail) do
				self.cmbReserveDetail.addItemObject(reserveDetail.getDescriptionShort, reserveDetail);
			endwhile;
		else
			iter := _bulkRelease.allReserveDetails.createIterator;
			while iter.next(reserveDetail) do
				self.cmbReserveDetail.addItemObject(reserveDetail.getDescriptionShort, reserveDetail);
			endwhile;
		endif;
	endif;
	
	if self.cmbReserveDetail.listCount = 1 then																	//05.07.2024 navhl20 #61368
		self.cmbReserveDetail.listIndex := 1;
	endif;
	
	if self.cmbReserveDetail.listCount = 0 then																	//05.07.2024 navhl20 #61368
		self.cmbReserveDetail.visible := false;
		self.lblReserveDetail.visible := false;
	endif;
	
	if self.myPxyTask.isKindOf(CM_WodRelease) and self.myPxyTask.CM_WodRelease.myReserveDetail &lt;&gt; null then		//05.07.2024 navhl20 #61368
		reserveDetail := self.myPxyTask.CM_WodRelease.myReserveDetail;
		cargoType     := reserveDetail.CM_ReserveSelection.myCargoType;
		
		self.cmbReserveDetail.setIndexFromObject(reserveDetail);
		self.buildListToDoTasks(cargoType);												//17.04.2023 navma1 #57324:[57325]
	elseif self.myPxyTask.isKindOf(CM_WodPack) and self.myPxyTask.CM_WodPack.myReserveDetail &lt;&gt; null then		//05.07.2024 navhl20 #61368
		reserveDetail := self.myPxyTask.CM_WodPack.myReserveDetail;
		cargoType     := reserveDetail.CM_ReserveSelection.myCargoType;
		
		self.cmbReserveDetail.setIndexFromObject(reserveDetail);
		self.buildListToDoTasks(cargoType);	
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="buildCmbShiftMovemet" id="df525382-4086-4233-88c2-877d1ce26b90">
        <updating/>
        <source>buildCmbShiftMovemet() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
25 April 2022	navukv20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	_shiftDtl,ta : CM_WodShiftMovement;
	voy : CM_Voyage;
	movement : HMS_VoyageMovement;
	seaHarbourRegion : HMS_HarbourRegion;
	seaHRArrivalBerth : HMS_Berth;
	localOccursOnDT : TimeStamp;
	processHarbour : CM_ProcessHarbour;					
	resources : HMS_ResourceByTypeDict;					
	berthArrival : TimeStamp;	
begin
	if self.myPxyTask &lt;&gt; null  and self.myPxyTask.isKindOf(CM_WodShiftMovement) then
			ta := self.myPxyTask.CM_WodShiftMovement;
			voy := ta.getMyVoyageObject();
			if ta &lt;&gt; null then	
				self.displayResources(ta);
				if voy &lt;&gt; null then
					self.txtDraftFwd.text := voy.draftBow.String;
					self.txtDraftAft.text := voy.draftStern.String;
					
					
					if self.workOrderMode = self.MODE_ADD then
						// DEFAULTS
						self.chkHasRampSM.value := voy.myHMSVoyageData.hasRamp;
						self.optStarboardSM.value := voy.starboardBerthed;
					else
						self.chkHasRampSM.value := ta.hasRamp;
						self.optStarboardSM.value := ta.starboardBerthed;
					
					endif;
				endif;
		
				// get the movement corresponding to the work order occursOnDT
				
				if ta.occursOnDT.isValid then
					localOccursOnDT := self.systemToLocalTime( ta.occursOnDT );
					self.txtMoveOnDate.setDate( localOccursOnDT.date );
					self.txtMoveOnTime.setTime( localOccursOnDT.time );
					if voy &lt;&gt; null then
						movement := voy.myHMSVoyageData.allVoyageMovements[ta.occursOnDT];
					endif;
				endif;
				
				
				if ta.berthArrival.date.isValid then
					berthArrival := self.systemToLocalTime( ta.berthArrival );
					self.txtBerthArrDate.setDate( berthArrival.date );
					self.txtBerthArrTime.setTime( berthArrival.time );
				endif;
				
				
				if ta.draftFwd &lt;&gt; null then
					self.txtDraftFwd.text := ta.draftFwd.String;
				endif;
				if ta.draftAft &lt;&gt; null then
					self.txtDraftAft.text := ta.draftAft.String;
				endif;
				if ta.myFromBerth &lt;&gt; null then
					self.txtBerthFrom.text := ta.myFromBerth.code;
					if movement &lt;&gt; null and movement.myPreviousMovement &lt;&gt; null then
						if movement.myPreviousMovement.isLogicalBerth then
							self.txtBowMarkFrom.text := app.getErrorString(NotApplicable);
							self.txtSternMarkFrom.text := app.getErrorString(NotApplicable);
						else
							self.txtBowMarkFrom.text := movement.myPreviousMovement.HMS_VoyageMovement.bowMarkTo.String;
							self.txtSternMarkFrom.text := movement.myPreviousMovement.HMS_VoyageMovement.sternMarkTo.String;
						endif;
					else
						self.txtBowMarkFrom.text := app.getErrorString(NotApplicable);
						self.txtSternMarkFrom.text := app.getErrorString(NotApplicable);
					endif;
				else
					self.txtBerthFrom.text := null;
					seaHarbourRegion := app.myRoot.getSeaHarbourRegion;
					if seaHarbourRegion &lt;&gt; null then
						seaHRArrivalBerth := seaHarbourRegion.getArrivalBerth();
						if seaHRArrivalBerth &lt;&gt; null then
							self.txtBerthFrom.text := seaHRArrivalBerth.getDisplayString();
						endif;
					endif;
					
					self.txtBowMarkFrom.text := app.getErrorString(NotApplicable);
					self.txtSternMarkFrom.text := app.getErrorString(NotApplicable);
				endif;
				if ta.myToBerth &lt;&gt; null then
					self.cmbToBerth.listIndex := self.cmbToBerth.findObject(ta.myToBerth);
					self.txtBowMarkTo.text := ta.bowMarkTo.String;
					self.txtSternMarkTo.text := ta.sternMarkTo.String;
				endif;
				if ta.relativeOrderTimePlaunch &lt;&gt; null then
					self.txtLaunchRelative.text := ta.relativeOrderTimePlaunch.String;
				endif;
				if ta.relativeOrderTimeTugs &lt;&gt; null then
					self.txtTugRelative.text := ta.relativeOrderTimeTugs.String;
				endif;
				if ta.relativeOrderTimeLines &lt;&gt; null then
					self.txtLineRelative.text := ta.relativeOrderTimeLines.String;
				endif;
				
				self.shiftDateTime := ta.occursOnDT ;
				//if movement = null then
				if movement = null and voy &lt;&gt; null then 
					if voy.myHMSVoyageData &lt;&gt; null and ta.occursOnDT &lt;&gt; null and voy.myHMSVoyageData.allVoyageMovements &lt;&gt; null then
						movement := voy.myHMSVoyageData.allVoyageMovements.getAtKeyLeq(ta.occursOnDT);
					endif;
				endif;
				if movement &lt;&gt; null then
					self.myMovement := movement;
				endif;
				
				
				if voy &lt;&gt; null and voy.myHMSVoyageData &lt;&gt; null then
					self.cmbTowVoyage.visible := voy.myHMSVoyageData.requiresTow;
					self.lblTowingVoy.visible := self.cmbTowVoyage.visible;
					self.cmbTowVoyage.setObject( ta.myTowingVoyage );
					
					if ta.isComplete then
						self.grpShiftMovement.enabled := false;
					endif;
				endif;
				
			endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbStatus" id="32804ef8-83d9-4227-b9e0-e3a51710ada5">
        <source>buildCmbStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Mar 2022	navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars
	currentStatus : Integer;
	pxyWorkOrder  : CM_WorkOrder;
	term		  : CM_Terminal;
	voyageProcess : CM_VoyageProcess;
begin
	pxyWorkOrder := self.myPxyWorkOrder;
	
	if pxyWorkOrder  &lt;&gt; null then
		currentStatus := pxyWorkOrder.taskStatus;
	endif;
	self.myAssistant.comboBoxWorkOrderStatus(self.cmbWorkOrderStatus, 
											app.myPassport.myUser.myOrganisation.isExternal,
											currentStatus);
											
	self.cmbWorkOrderStatus.listIndex := self.cmbWorkOrderStatus.findString(1, app.workOrderStatusEnumToString(currentStatus) );	//15.02.2023 navma1 #56561
	
	//15.02.2023 navma1 #56561
	if pxyWorkOrder &lt;&gt; null and currentStatus = WO_STATUS_NOTAPPROVED then
		term 		  := pxyWorkOrder.getMyTerminal;
		voyageProcess := term.getDefaultVoyageProcess();
		if voyageProcess &lt;&gt; null and voyageProcess.isEUPDefaultProcess then
			self.cmbWorkOrderStatus.enabled := false;
			self.grpVisitDetails.enabled	:= false;
			self.grpOperatorsVR.enabled		:= false;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbTask" id="4283d86c-613d-461b-8f24-d6f4788e986d">
        <source>buildCmbTask();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1  ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
*/

vars

begin
	
	if self.workOrderType = WorkOrderMode_Cargo then										
		self.myAssistant.comboBoxCargoWorkOrderTasks(self.cmbWorkOrderStatus,self.myTerminal);
	elseif 	self.workOrderType = WorkOrderMode_Voyage then																				
		self.myAssistant.comboBoxVoyageWorkOrderTasks(self.cmbWorkOrderStatus,self.myTerminal);		
	else																							// 15/12/2022	navcs2	#56840:[54265]
		self.myAssistant.comboBoxToDoWorkOrderTasks(self.cmbWorkOrderStatus,self.myTerminal);		// 15/12/2022	navcs2	#56840:[54265]
	endif;																							// 15/12/2022	navcs2	#56840:[54265]
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbTimeChange" id="823703b9-877d-486a-a799-c10d5a695559">
        <updating/>
        <source>buildCmbTimeChange() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2022	navhl20 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	timeChange,ta : CM_WodTimeChange;
begin
	if self.myPxyTask &lt;&gt; null  and self.myPxyTask.isKindOf(CM_WodTimeChange) then
			ta := self.myPxyTask.CM_WodTimeChange;
			if ta &lt;&gt; null then	
				if ta.occursOnDT.isValid then
					self.txtMoveOnDateTC.setDate(ta.occursOnDT.date);
					self.txtMoveOnTimeTC.setTime(ta.occursOnDT.time);
				endif;
				self.cmbWorkOrder.listIndex := self.cmbWorkOrder.findObject(ta.myWorkOrderToUpdate);
				
				if ta.isComplete then
					self.grpTimeChange.enabled := false;
				endif;
			endif;
		endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbTransport" id="dfcabf4a-a62f-4041-b9f7-156194bd8771">
        <updating/>
        <source>buildCmbTransport(_str:String)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jan 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
04 Jul 2023 namva1	Bug 58976: MTN - Error 14008 when opening Release Rail Work orders
14 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes
12 Apr 2024 navhl20 ChangeRequest 63583: EUP | 54014 - Cargo Work Orders Enhancements - Remedial
*/

vars
	cmb    : CMUI_ComboBox;
	train  : CM_Train;
	voyage : CM_Voyage;
	pxyWod : CM_WorkOrderDtl;
	term   : CM_Terminal;
	pxyWO  : CM_WorkOrder;
begin
	term := self.myTerminal;
	cmb  := self.cmbTransport;
	
	cmb.clear;
	
	if _str = TI_TRANSMODE_RAIL_STR then
		foreach train in term.allTrainsOnTerminal do 
			cmb.addItemObject(train.code, train);
		endforeach;
	else
		foreach voyage in term.allVoyagesByCode do 
			cmb.addItemObject(voyage.code, voyage);
		endforeach;
	endif;
	
	pxyWod :=  self.myPxyTask;
	
	if pxyWod.CM_WorkOrderTIDtl.getTransport() = null then			//12.04.2024 navhl20 #63583
		pxyWO  := self.myPxyWorkOrder;
		if pxyWO &lt;&gt; null and pxyWO.allWoDtls.isNotEmpty() then
			pxyWod := pxyWO.allWoDtls.first;
		endif;
	endif;
	
	if pxyWod &lt;&gt; null then
		if pxyWod.isKindOf(CM_WodReceive) then
			if _str = TI_TRANSMODE_RAIL_STR then
				train := pxyWod.CM_WodReceive.myTrain;
			else
				voyage := pxyWod.CM_WodReceive.myVoyage;
			endif;
	    elseif pxyWod.isKindOf(CM_WodRelease) then
			if _str = TI_TRANSMODE_RAIL_STR then
				train := pxyWod.CM_WodRelease.myTrain;
			else
				voyage := pxyWod.CM_WodRelease.myVoyage;
			endif;
	    endif;
		
		if _str = TI_TRANSMODE_RAIL_STR then
			if train &lt;&gt; null then
				if  cmb.findObject(train) = -1  then						//04.07.2023 navma1 #58976
					cmb.itemObject[cmb.addItem(train.code)] := train;
				endif;
				cmb.listObject := train;	
			endif;
		else
			if voyage &lt;&gt; null then	
				if  cmb.findObject(voyage) = -1  then						//04.07.2023 navma1 #58976
					cmb.itemObject[cmb.addItem(voyage.code)] := voyage;
				endif;
				cmb.listObject := voyage;	
			endif;
		endif;
		
		self.cmbTransport_click(cmb);										//14.9.2023 navhl20 #60063
		self.btnSelectCargo.enabled := true;
    endif;
epilog

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="buildCmbTransportMode" id="56194d7f-f336-418f-9d4c-1d16e5685c9c">
        <updating/>
        <source>buildCmbTransportMode() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date	     Who	Reason
26 Dec 2022 navdp20	ChangeRequest 56661:[56012] - Add Transport Mode to Receive and Release work orders
25 Jan 2022 navhl20 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
02 May 2023 navma1	Defect 57816: MTN - WO - The release requests are not filtering correctly based on the transport mode selected
12 Apr 2024 navhl20 ChangeRequest 63583: EUP | 54014 - Cargo Work Orders Enhancements - Remedial
15 Apr 2024 navsp1  TFS Bug 62295: EUP | FR 54084 - CallOff Message - "Unknown" Type Release Request Not Created for Zimmer Case.
*/
vars
	port 	  : String;
	thePort   : CM_Port;
	transport : Integer;
	cmb		  : CMUI_ComboBox;
	transMode : Integer;
	pxyWod	  : CM_WorkOrderDtl;
	pxyWO	  : CM_WorkOrder;
begin
	
	cmb := self.cmbTransMode;
    cmb.clear();
	cmb.addItem(TI_TRANSMODE_ROAD_STR);	
	cmb.addItem(TI_TRANSMODE_RAIL_STR);
	cmb.addItem(TI_TRANSMODE_SHIP_STR);								//25.01.2022 navma1 56661[56012]
	cmb.addItem(TI_TRANSMODE_UNKNOWN_STR);							//15.04.2024 navsp1 TFS 62295
    cmb.listIndex := cmb.findString(1,TI_TRANSMODE_ROAD_STR);
	
	pxyWod := self.myPxyTask;										//12.04.2024 navhl20 #63583
	
	if pxyWod.CM_WorkOrderTIDtl.getTransport() = null then			//12.04.2024 navhl20 #63583
		pxyWO := self.myPxyWorkOrder;
		if pxyWO &lt;&gt; null and pxyWO.allWoDtls.isNotEmpty() then
			pxyWod := pxyWO.allWoDtls.first;
		endif;
	endif;
	
	if pxyWod &lt;&gt; null then
		if pxyWod.isKindOf(CM_WodRelease) then
			transMode := pxyWod.CM_WodRelease.transport;
		elseif pxyWod.isKindOf(CM_WodReceive) then
			transMode := pxyWod.CM_WodReceive.transport;
	    endif;
    endif;
	
	if transMode &lt;&gt; null then
		cmb.listIndex 			 	:= cmb.findString(1,app.transportModeENumToString(transMode));
		self.btnSelectCargo.enabled := true;
	endif;
	
	self.cmbTransMode_click(cmb);	//25.1.2023 navhl20 #55443[54991]
end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbUnPack" id="74892f1a-2bbb-498a-a0ca-d3c13affded1">
        <source>buildCmbUnPack();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
*/

vars
	ta : CM_TerminalArea;
	wodtl 	: CM_WorkOrderDtl;
begin
	
	wodtl := self.myPxyTask;
	if wodtl &lt;&gt; null and wodtl.CM_WodUnpack.myUnpackToLocation &lt;&gt; null then
		ta := wodtl.CM_WodUnpack.myUnpackToLocation.myTerminalArea;
		self.cmbUnpkToLocal.listObject := ta;
	endif;
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbWaterReq" id="60f1f2b3-4d34-441e-93fc-b4b65dd6317f">
        <updating/>
        <source>buildCmbWaterReq() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2022	navhl20 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	ta : CM_WodWaterRequest;
begin
	if self.myPxyTask &lt;&gt; null  and self.myPxyTask.isKindOf(CM_WodWaterRequest) then
			ta := self.myPxyTask.CM_WodWaterRequest;
			if ta &lt;&gt; null then	
				if ta.myHMSResourceType &lt;&gt; null then
					self.cmbResourceType.listIndex := self.cmbResourceType.findObject(ta.myHMSResourceType);
					self.cmbResourceType_click(self.cmbResourceType);
				endif;
				if ta.myHMSResource &lt;&gt; null then
					self.cmbResource.listIndex := self.cmbResource.findObject(ta.myHMSResource);
				endif;
				self.txtUnitsUsed.text := ta.unitsUsed.String;
				if ta.fromDateTime.isValid then
					self.txtFromDate.setDate(ta.fromDateTime.date);
					self.txtFromTime.setTime(ta.fromDateTime.time);
				endif;
				if ta.toDateTime.isValid then
					self.txtToDate.setDate(ta.toDateTime.date);
					self.txtToTime.setTime(ta.toDateTime.time);
				endif;
			
				self.cmbWTransferType.listIndex := self.cmbWTransferType.findObject(app.myRoot.allVoyageJobTransferTypes[ta.transferType]);
				if ta.isComplete then
					self.grpWaterRequest.enabled := false;
				endif;
			endif;
		endif;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildComboAllOperators" id="9162bbbc-026f-4e57-a262-6056b0706829">
        <source>buildComboAllOperators(_wod : CM_WodVoyageRequest);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	tmpPassport	: CM_Passport;
	operator : CM_Operator;
	opStr : String;
	failedDAC  :CM_DataAccessController;
begin
	self.cmbOpCargoDischVR.clear();
	self.cmbOpCargoLoadVR.clear();
	self.cmbOpVoyageVR.clear();
	
	self.cmbOpCargoDischVR.sorted := true;
	self.cmbOpCargoLoadVR.sorted := true;
	self.cmbOpVoyageVR.sorted := true;

	tmpPassport := app.myPassport;
	
	foreach operator in app.myRoot.allOperators	discreteLock do
		if operator.isNotAvailableForEntry  then
			continue;
		endif;
		if tmpPassport &lt;&gt; null 
		and  (not operator.canUserAccessSelf(null, failedDAC, tmpPassport)) then
			continue;
		endif;
	
		opStr := operator.code &amp; Tab &amp; operator.description;

		self.cmbOpCargoDischVR.addItemObject(opStr,operator);
		self.cmbOpCargoLoadVR.addItemObject(opStr,operator);
		self.cmbOpVoyageVR.addItemObject(opStr,operator);
		
	endforeach;
	
	self.cmbOpCargoDischVR.setIndexFromObject(app.myRoot.allOperators[_wod.cargoOperatorCodeDischarge]);
	self.cmbOpCargoLoadVR.setIndexFromObject(app.myRoot.allOperators[_wod.cargoOperatorCodeLoad]);
	self.cmbOpVoyageVR.setIndexFromObject(app.myRoot.allOperators[_wod.voyageOperatorCode]);
	
epilog

end;</source>
        <Parameter name="_wod" type="CM_WodVoyageRequest"/>
    </JadeMethod>
    <JadeMethod name="buildComboAllPorts" id="ba297c14-a00c-4619-a11e-2da9a07b8940">
        <source>buildComboAllPorts(_wod : CM_WodVoyageRequest);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	port    	: CM_Port;
	portStr 	: String;
	allPorts	: CM_PortByCodeDict;
begin
	if  _wod &lt;&gt; null then
		create allPorts transient;
		
		self.getActivePorts(_wod,allPorts);       
		
		self.cmbPortOriginVR.clear();
		self.cmbPortLastVR.clear();
		self.cmbPortNextPortVR.clear();
		self.cmbPortLastCallVR.clear();
		
		self.cmbPortOriginVR.sorted   := true;
		self.cmbPortLastVR.sorted 	  := true;
		self.cmbPortNextPortVR.sorted := true;
		self.cmbPortLastCallVR.sorted := true;
		
		
		foreach port in allPorts do
			
			if port.isNotAvailableForEntry  or (not port.isPort) then
				continue;
			endif;
			
			portStr := port.getDisplayFormatted(false);
			
			self.cmbPortOriginVR.addItemObject(portStr,port);
			self.cmbPortLastVR.addItemObject(portStr,port);
			self.cmbPortNextPortVR.addItemObject(portStr,port);
			self.cmbPortLastCallVR.addItemObject(portStr,port);
			
		endforeach;
		
		if  not allPorts.isEmpty then
			self.cmbPortOriginVR.setIndexFromObject(allPorts[_wod.portCode1]);
			self.cmbPortLastVR.setIndexFromObject(allPorts[_wod.portCode2]);
			self.cmbPortNextPortVR.setIndexFromObject(allPorts[_wod.portCode4]);
			self.cmbPortLastCallVR.setIndexFromObject(allPorts[_wod.portCode5]);
		endif;
	endif;
	
epilog
	delete allPorts;
end;</source>
        <Parameter name="_wod" type="CM_WodVoyageRequest"/>
    </JadeMethod>
