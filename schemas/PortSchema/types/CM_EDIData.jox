    <JadeMethod name="removeTempErrors" id="1ae61e04-2b32-471c-8390-851574cf2626">
        <updating/>
        <source>removeTempErrors() updating;
/*

Purpose:			Clear out errors that are run specific.

Parameters:			null

Return Value:		null

Date		Who		Reason
07 February 2019	jlgzm1	TFS 43292 - EDI previous errors still showing after successful dbload

*/
vars
	error : CM_EDIError;
begin
	foreach error in self.allErrorWarnings do
		if error.errorCode = 1027 or error.errorCode = 1081 then //lock or deadlock
			self.allErrorWarnings.remove(error);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetStatusForReprocess" id="acc54cc4-6b75-4e1f-81af-5abc20ebcfcc">
        <updating/>
        <source>resetStatusForReprocess()updating;
// ---------------------------------------------------------------------------
// Created:     03 May 2010 by cnwcs5
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti	:CM_EDITrackedItem;
begin
	// we don't want to call this for edi data that does not handle re-processing
	if not self.isKindOf (CM_EDIDataCustomStop) and
		not self.isKindOf (CM_EDIDataOperatorStop) then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Cannot reprocess EDI Data Type');
	endif;
	
	foreach ti in self.allEDITrackedItems do
		ti.setStatus (CM_EDIFile.EDI_STATUS_UNPROCESSED);
	endforeach;
	
	self.setStatus (CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCrossReference" id="25a3d361-98ad-4003-9cd9-0d583e67d4fe">
        <source>setCrossReference(_coll :DynaDictionary; _obj1 :Object; _obj2 :CM_Object) protected;
/*
Date			Who		Reason
14 July 2011	cnwcs5	Initial creation - par 26557
*/
vars

begin
	if _obj1 = null or _obj2 = null then
		return;
	endif;
	
	if _coll [_obj1] = null then
		_coll [_obj1] := _obj2;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="DynaDictionary"/>
        <Parameter name="_obj1" type="Object"/>
        <Parameter name="_obj2" type="CM_Object"/>
    </JadeMethod>
