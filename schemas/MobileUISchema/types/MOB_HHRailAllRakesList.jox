    <JadeMethod name="populateListRakes" id="96aa9772-91af-4011-9289-0146e14b3ca4">
        <source>populateListRakes();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 March 2017	cnwsc8	refactored to move method to Port Schema	TFS2314
20 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars
	train 		: CM_Train;
	railLine 	: CM_RailLine;
	rline		: CM_RailLine;
	details 	: StringArray;
	index 		: Integer;
	str 		: String;
	tokens		: StringArray;
	strArray	: StringArray;
	
	wagons		: String;
	items		: String;
	notified	: String;
	confirmed	: String;
begin
	lstRakes.clear();
	train := self.myMobileGenericAgent.myCurrentTrain;
	create strArray transient;
	
	details := train.getPopulateListRakes(self.myMobileGenericAgent.inward, self.myMobileGenericAgent.allConfirmedTis, strArray);
	if details = null then
		return;
	endif;

	create tokens transient;
	wagons := " " &amp; app.getErrorString(Wagons) &amp; ", ";
	items := " " &amp; app.getErrorString(Items);	
	
	foreach str in details do
		tokens.clear();
		str.getTokensForDelimiter(";",tokens);
		if tokens.size = 5 then
			rline := tokens[1].asOid.CM_RailLine;
			if rline &lt;&gt; null then
				railLine := rline;
				str := railLine.getFullId;
				
				// populate the potential, i.e. what we know is there.
				notified := " - " &amp; app.getErrorString(Notified) &amp; " " &amp; tokens[2] &amp; wagons &amp; tokens[3] &amp; items;
		
				// populate how much we know has been checked.
				confirmed := " - " &amp; app.getErrorString(Confirmed) &amp; " " &amp; tokens[4] &amp; wagons &amp; tokens[5] &amp; items;

				index := lstRakes.addItem(str);
				lstRakes.itemObject[index] := railLine;		
				
				index := lstRakes.addItem(notified);
				lstRakes.itemObject[index] := railLine;		

				index := lstRakes.addItem(confirmed);
				lstRakes.itemObject[index] := railLine;		
			endif;
		endif;
	endforeach;
epilog
	delete details;
	delete strArray;
	if tokens &lt;&gt; null then
		delete tokens;
	endif;
end;</source>
    </JadeMethod>
