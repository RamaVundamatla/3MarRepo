    <JadeMethod name="utlUpdateStagedTis" id="3f24854e-62d8-4ec1-995a-7cbc176aace5">
        <source>utlUpdateStagedTis(_reserveDetail : CM_ReserveSelection input; _tiSet : CM_TISet; _term : CM_Terminal; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Jan 2023 navhl20 ChangeRequest 58760:[61583] EUP | VAS Mobile App - [53813.050] VAS Tasks for Release Cargo Work Order
30 Jan 2023 navhl20 Defect 62239: EUP | VAS Mobile App - [53813.040] VAS Tasks in other Operational Mobile Apps - Flow Integration - Job automatically unassigned from Gang
22 May 2024	navpw1	TFS: 64096 (64098) - Added support for Work Order To Do Tasks.
25 Sep 2024 navhl20	ChangeRequest 62456:[66078] EUP* | VAS Mobile App - [53813.040] VAS Tasks in other Operational Mobile Apps - Flow Integration - 2
10 Feb 2025	navhl20 Bug MTN-34023: EUP | 54176 - Ship operations in Delivery Dispatch screen - remaining issues
*/

vars
	wod				: CM_WorkOrderTIDtl;
	wodTodo			: CM_WodToDo;
	ti				: CM_TrackedItem;
	br				: CM_BulkRelease;
	todoJob,
	woJob			: CM_WorkOrderJob;
	workOrder		: CM_WorkOrder;
	toDoTask		: CM_ToDoTaskDesc;
	transType		: CM_TransactionType;
	transTypeIsWO	: Boolean;
	request			: CM_Request;
	release			: CM_BulkRelease;
begin
	self.initialiseActivity();
	
	if _reserveDetail &lt;&gt; null then
		wod := _reserveDetail.allWodReleases.first.CM_WorkOrderTIDtl;				//25.09.2024 navhl20 #62456:[66078]
		
		if wod = null and _reserveDetail.myReserveHeader &lt;&gt; null then				//25.09.2024 navhl20 #62456:[66078]
			release := _reserveDetail.myReserveHeader;
		endif;
		
		if release &lt;&gt; null and release.type = BR_TYPE_PACKING then					//25.09.2024 navhl20 #62456:[66078]
			foreach request in _reserveDetail.allRequests where request.isKindOf(CM_WOPackRequest) do
				woJob := request.myJob.CM_WorkOrderJob;
				if woJob &lt;&gt; null then
					wod := woJob.myWODtl;
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	if wod &lt;&gt; null then
		wodTodo := wod.allToDoRequests.first;
		woJob	:= wod.allJobs.first.CM_WorkOrderJob;
	endif;
	
	if wodTodo &lt;&gt; null then
		todoJob	:= wodTodo.allJobs.first.CM_WOToDoTaskJob;
	endif;
	
	if todoJob &lt;&gt; null then
		toDoTask := todoJob.getToDoTask();
	endif;
	
	if toDoTask &lt;&gt; null then
		transType := toDoTask.myTransactionType;
	endif;
	
	if transType &lt;&gt; null then
		transTypeIsWO := transType.isForWorkOrder();
	endif;
	
	foreach ti in _tiSet do
		//Assign ti to Reserve detail
		_reserveDetail.addTI( ti ); 
		
		br := _reserveDetail.myReserveHeader;
		
		if br &lt;&gt; null then	
			br.createAssignedTransaction( ti, false );	
		endif;
		
		self.updateObjectEdition(_reserveDetail);
		if _reserveDetail.myReserveHeader &lt;&gt; null then
			self.updateObjectEdition(_reserveDetail.myReserveHeader);
		endif;
		
		//Assign ti to Work order detail and to do task
		if wod &lt;&gt; null then
			wod.allSelectedTIs.addNoDuplicates(ti,false);
			wod.allActionedTIs.addNoDuplicates(ti,false);
			self.updateObjectEdition(wod);
			self.updateObjectEdition(wod.myParent);
			
			if not transTypeIsWO and woJob &lt;&gt; null then
				woJob.splitWleForTodo(ti);									//30.01.2023 navhl20 #62239
				woJob.allTrackedItems.add(ti);								//10.02.2025 navhl20 #34023
				
			elseif woJob &lt;&gt; null then
				woJob.allTrackedItems.add(ti);
				workOrder := wod.myParent;
				if workOrder.isWorkOrderTi() then
					workOrder.CM_WorkOrderTI.allTIs.add(ti);
				endif;
				
			endif;
		endif;
		
		if wodTodo &lt;&gt; null then
			wodTodo.allSelectedTIs.addNoDuplicates(ti,false);
			wodTodo.allActionedTIs.addNoDuplicates(ti,false);				//30.01.2023 navhl20 #62239
			self.updateObjectEdition(wodTodo);								//30.01.2023 navhl20 #62239
			todoJob	:= wodTodo.allJobs.first.CM_WorkOrderJob;				//30.01.2023 navhl20 #62239
			
			if not transTypeIsWO and todoJob &lt;&gt; null then					//30.01.2023 navhl20 #62239
				todoJob.splitWleForTodo(ti);
				
			elseif todoJob &lt;&gt; null then
				todoJob.allTrackedItems.add(ti);
				
			endif;
		endif;
	endforeach;
epilog
	
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveSelection" usage="input"/>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateStevedore" id="d1d46132-70dd-4118-b2c2-29ed9d70a24b">
        <source>utlUpdateStevedore(pProxyStevedore:CM_Stevedore; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave:Boolean;
	realStevedore:CM_Stevedore;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	pProxyStevedore.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyStevedore.pxyGetRealObjectAndEdition(realStevedore, expectedEdition);
	
	if realStevedore = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Stevedore.name, null, null);
		return;
	endif;

	app.myValUA.valStevedore(realStevedore, pProxyStevedore);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realStevedore);

	if _passport.noErrors and realStevedore.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Stevedore', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realStevedore, true);
	endif;
	
	if _passport.noErrors then
		realStevedore.setForUpdate(pProxyStevedore);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realStevedore, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyStevedore" type="CM_Stevedore"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
