    <JadeMethod name="setFromVoyAllocationCriteria" id="fd4f4a09-08c3-48bc-b172-eadc171b0f7c">
        <updating/>
        <source>setFromVoyAllocationCriteria(_criteria : CM_YACriteria) updating;
//
// 21 Mar 2012	cnwrs1	Par 29308
//
vars
	yaData : CM_YAData;
	obj : Object;
begin
	yaData := _criteria.myYAData;
	if yaData.isKindOf(CM_YADataObjects) then
		obj := yaData.CM_YADataObjects.allObjects.first;
		if _criteria.myYACriteriaType.type = YACriteriaType_BookingRef then
			self.bookingRef := obj.CM_BookingRef.bookingReference;
		elseif _criteria.myYACriteriaType.type = YACriteriaType_CargoType then
			self.cargoType := obj.CM_CargoType.type;
			self.cargoTypeDescr := obj.CM_CargoType.description;
		elseif _criteria.myYACriteriaType.type = YACriteriaType_Commodity then
			self.commodity := obj.CM_Commodity.code;
		elseif _criteria.myYACriteriaType.type = YACriteriaType_CommodityGroup then
			self.commodity := obj.CM_CommodityGroup.code;
		elseif _criteria.myYACriteriaType.type = YACriteriaType_DestinationPort then
			self.destinationPort := obj.CM_Port.code;
		elseif _criteria.myYACriteriaType.type = YACriteriaType_DischargePort then
			self.dischargePort := obj.CM_Port.code;
		elseif _criteria.myYACriteriaType.type = YACriteriaType_Hazardous then
		elseif _criteria.myYACriteriaType.type = YACriteriaType_IsTransShip then
			self.isTranshipItem := true;
		elseif _criteria.myYACriteriaType.type = YACriteriaType_ISO then
			self.isoType := obj.CM_ISOType.code;
		elseif _criteria.myYACriteriaType.type = YACriteriaType_ISOGroup then
			self.isoTypeGroup := obj.CM_ISOTypeGroup.code;
		elseif _criteria.myYACriteriaType.type = YACriteriaType_LoadPort then
			self.loadPort := obj.CM_Port.code;
		elseif _criteria.myYACriteriaType.type = YACriteriaType_OperatorItem then
			self.operatorCode := obj.CM_Operator.code;
		elseif _criteria.myYACriteriaType.type = YACriteriaType_Weight then
	//		self.weight := obj.CM_Port.code;
		elseif _criteria.myYACriteriaType.type = YACriteriaType_RequiresPower then
		endif;
	elseif yaData.isKindOf(CM_YADataBoolean) then
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;yaData.String&amp;' '&amp;yaData.getDataValue.String;
		if _criteria.myYACriteriaType.type = YACriteriaType_IsHazardous then
			if yaData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE then
				self.imCodes.add("1.0");
			endif;
		elseif _criteria.myYACriteriaType.type = YACriteriaType_IsOverDimension then
			if yaData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE then
				self.width := 1;
				self.height := 1;
				self.length := 1;
			endif;
		elseif _criteria.myYACriteriaType.type = YACriteriaType_RequiresPower then
			if yaData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE then
				self.temperature := -20;
			endif;
		endif;
	elseif yaData.isKindOf(CM_YADataString) then
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;yaData.String&amp;' '&amp;yaData.getDataValue.String;
	endif;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
    </JadeMethod>
    <JadeMethod name="setImCodes" id="18ae48ad-2ca2-4c68-a883-ef394aff37b7">
        <updating/>
        <source>setImCodes(_codes : String) updating;
// ---------------------------------------------------------------------------
// Created:		08 April 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
vars
	tmpIMCodes : StringArray;
begin
	create tmpIMCodes transient;
	self.addImCodes(_codes, tmpIMCodes);			// MES1008 allow imCodes in toehr classes. Was typecasting to _ediTI.CM_EDIPrenoteTI.imCodes.add(_processedValue);
	self.imCodes.clear();							// 17/03/2014 cnwmh5 #33648
	tmpIMCodes.copy(self.imCodes);
epilog    
	delete tmpIMCodes;
end;</source>
        <Parameter name="_codes" type="String"/>
    </JadeMethod>
    <JadeMethod name="setLoadCC" id="be70993a-bf61-4038-abde-55058249de7a">
        <source>setLoadCC(_loadCC: CMIF_LoadColorCode input);
//----------------------------------------------------------------
//	Created:	03 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 05 Apr 2012	cnwrs1		Par 29391 - EDI RORO Stowage Advice hazard codes
// 11 Aor 2012	cnwrs1		Par 29391 - EDI set requires Power from Temp
// 25/Jul 2012	cnwcs5		par 29124 - remarks on stowage advice
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	realSlotReq		: CM_SlotRequest;
	workedDT		: TimeStamp;
	aPort			: CM_Port;
	aPortCode		: String;
	isoType			: CM_ISOType;
	cmdtyCode,msg	: String;
	cmdty			: CM_Commodity;
	theBay			: CM_BayVoyage;
	noLength		: Boolean;
	terminal		: CM_Terminal;
begin
	//reset everything
	_loadCC.clear();

	terminal 			:= self.getMyTerminal;
	_loadCC.myCargoType := app.myRoot.allCargoTypesById[self.cargoType].CM_CargoType ;	// AKB PAR 28479 ISO only for containers
	_loadCC.quantity 	:= self.quantity.max(1);										// AKB PAR 28479 for RORO General Cargo
	_loadCC.remarks		:= self.remarks;												// par 29124 July 2012
	
	if self.cargoType = TI_CargoType_Container then 									// AKB PAR 28479 ISO only for containers
		isoType := app.myRoot.allISOTypes[self.isoType];
	
		if isoType = null then
			if self.isoType = null then
				noLength := true;
			else
				if self.isoType[1:1].trimBlanks = "4" then
					msg := "assuming 40 ft";
				elseif self.isoType[1:1] = "2" then
					msg := "assuming 20 ft";
				else
					noLength := true;
				endif;
				app.raiseCMWarning3(ERR_INVALID_ISOTYPE, self.isoType, self.stowageId, msg, 'isoType', self, self);
			endif;
			if noLength then
				app.raiseCMException3(ERR_INVALID_ISOTYPE, "null", 'the item in position', self.stowageId, 'isoType', self);
				return;	
			endif;
		else
			// PAR 28479
			_loadCC.myISOType 		:= isoType;
			_loadCC.myISOTypeGroup 	:= isoType.myISOTypeGroup;
			
			// 08 Apr 2010	NDL Par 22526
			if isoType.is40ftLong then
				_loadCC.isForty := true;
			elseif isoType.is45ftLong then
				_loadCC.isFortyFive := true;
			elseif isoType.is30ftLong then
				_loadCC.isThirty := true;
			elseif isoType.is53ftLong then
				_loadCC.isFiftyThree := true;
			endif;
		endif;
	endif;
	
	_loadCC.myCargoType	:=	self.myCargoType;
	_loadCC.weight		:=	self.weight;		// cnwdad1 30/07/2010 - PAR #24045.

	if _loadCC.myCargoType &lt;&gt; null and _loadCC.myCargoType.id = TI_CargoType_Container then
		if (self.width + self.height + self.length) &gt; 0 then
			_loadCC.overDimension := true;
		endif;
	endif;
	
	aPortCode := self.dischargePort.trimBlanks();
	
	if aPortCode = null then
		aPortCode := terminal.getConfig(PortDestCode).String.trimBlanks();
	endif;

	_loadCC.myDischargePort := app.myRoot.allPorts[aPortCode];
	_loadCC.isEmpty 		:= (self.fullOrMT = "E");
	
	cmdtyCode 	:= self.commodity.trimBlanks();
	cmdty 		:= app.myRoot.allCommodities[cmdtyCode];
	
	if cmdty &lt;&gt; null then
		_loadCC.myCommodityGroup := cmdty.myCommodityGroup;
	else
		if _loadCC.isEmpty then
			cmdtyCode 	:= terminal.getDefaultEmptyCommodity();
			cmdty 		:= app.myRoot.allCommodities[cmdtyCode];
			
			if cmdty &lt;&gt; null then
				_loadCC.myCommodityGroup := cmdty.myCommodityGroup;
			endif;
		endif;
	endif;
	
	//what do we check?
	if self.imCodes.isNotEmpty() then
		_loadCC.isHazardous := true;
		_loadCC.hazardCodes := self.getDisplayStringForAttribute(ETRow_ImCodes, false)[1:60];	//05 Apr 2012	cnwrs1		Par 29391 - EDI RORO Stowage Advice hazard codes
	endif;
	
	if isoType &lt;&gt; null then 
		_loadCC.requiresPower	:= (self.temperature &lt;&gt; NULL_TEMPERATURE) and isoType.isPowered();	//11 Apr 2012	cnwrs1	Par 29391 Requires Power
		_loadCC.highCube		:= isoType.is9ft6High();
		_loadCC.halfHeight	 	:= isoType.isHalfHeight();
	else
		_loadCC.requiresPower := self.temperature &lt;&gt; NULL_TEMPERATURE;
	endif;

	if _loadCC.requiresPower then
		_loadCC.waterCooled := (self.cooledType = ContainerWaterCooled);
	endif;
end;</source>
        <Parameter name="_loadCC" type="CMIF_LoadColorCode" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setLocationId" id="f589e589-0c02-4697-a9a8-b89085fb5009">
        <updating/>
        <source>setLocationId(_value: String) updating;
//----------------------------------------------------------------
//	Created:	24 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//19 Mar 2012	cnwrs1	Par29268 fixup EDI Stow Advice editing
//10 Aug 2012	cnwrs1	Par30132 change to 792 incorrect copied to 811
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars

begin
	if self.myEDIData.isKindOf(CM_EDIDataDeckStowageAdvice) then
		self.stowageId := _value;	//10 Aug 2012	cnwrs1	code missing from wmast and dmast
	else
		self.stowageId := _value.padLeadingZeros(7);
	endif;
epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementTypeValue" id="1bcf2590-2160-4a5d-9407-5e152240d456">
        <updating/>
        <source>setMeasurementTypeValue(_columnName: String; _value: String) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2014	cnwmc5	Initial creation	PAR 34533

*/

vars
	rowName,
	measureType		: String;
	
begin

	if not inheritMethod(_columnName, _value) then
		return false;
	endif;
	
	_columnName.getRowNameMeasureType(rowName, measureType);
	
	if rowName = ETRow_TotalWeight then
		self.weight := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT());
		return true;
	endif;
	
	if self.class.getPropertyInHTree(rowName) &lt;&gt; null then
		self.setPropertyValue(rowName, app.convertMeasurementForStorage(measureType, _value.asDecimalJMT()));
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMode" id="f9a86ee6-1d50-4572-bc9c-ab5fa4b04a05">
        <updating/>
        <source>setMode(_mode: String) updating;
//----------------------------------------------------------------
//	Created:	09 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.mode := _mode;
	
	if self.mode = CM_EDIStowAdviceTI.MODE_DIS then
		self.loadOrder := 1;
	elseif self.mode = CM_EDIStowAdviceTI.MODE_RES then
		self.loadOrder := 2;
	elseif self.mode = CM_EDIStowAdviceTI.MODE_SHI then
		self.loadOrder := 2;
	else
		self.loadOrder := 3;
	endif;	
	
end;</source>
        <Parameter name="_mode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setNewStowageId" id="9ed3f4f3-ce07-404c-a865-7ca1f116e6ea">
        <updating/>
        <source>setNewStowageId(_value : String) updating;
/* ---------------------------------------------------------------------------
Created:	09 June 2009	by cnwvu1

Purpose:	PAR 19333. When saving Restow field, we should set leading zero(s)
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	valStr		: String;
	
begin

	if _value = null then
		self.newStowageId := null;
		
	else
		valStr := _value;
		if valStr.length() &gt;= 7 then	//need to take 6 chars from the right and add leading zero
			valStr := valStr[ valStr.length()-7 +2 : 6 ];
		endif;
		self.newStowageId := valStr.padLeadingZeros(7);	//adding zero
		
	endif;

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setVoyageCode" id="5c58119a-bf09-4aaf-b9c1-9907ce0eb1a9">
        <updating/>
        <source>setVoyageCode(_value: String) updating;
//
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
//
//15 Feb 2012	cnwrs1	Par 29124 Fix up Messina RORO Stowage advice in EDI
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediData	:CM_EDIData;
begin
	ediData := self.myEDIData;
	
	if ediData.isKindOf(CM_EDIDataStowAdvice) then
		if ediData.CM_EDIDataStowAdvice.voyageCode = null then
			ediData.CM_EDIDataStowAdvice.voyageCode := _value;
		endif;
	endif;
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="translateCommodity" id="ed2aad09-1151-4c55-aa65-c79bf0fee15f">
        <updating/>
        <source>translateCommodity(_xlationOperator: CM_Operator) updating, protected;
//
// 01 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	mtCmdty : String;
	defCmdty : String;
	refCmdty : String;
	hazCmdty : String;
begin
	inheritMethod(_xlationOperator);

	if self.commodity = null then 
		app.getTerminalDefCmdty(mtCmdty, defCmdty, refCmdty, hazCmdty);	
		if self.fullOrMT = "E" then
			self.commodity := mtCmdty;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="updateExtraDataFields811" id="59943631-cf25-4639-b0d0-c3bea1afdafb">
        <updating/>
        <source>updateExtraDataFields811() updating;
/*

Purpose:	Move isTranshipItem and booking to real fields		

Parameters:			

Return Value:		

Date		    Who		Reason
23 March 2012	cnwgb1	29303

*/

vars
    isTranshipStr : String;
    bookingRefStr : String;
    inTransaction : Boolean;
begin
	if self.allExtraData.size &gt; 0 then
		global.getExtraData(self.allExtraData, ExtraDataIsTranshipItem, isTranshipStr);
		if isTranshipStr &lt;&gt; null then
			beginTransaction;
			self.isTranshipItem := (isTranshipStr = true.asStringJMT);
			global.setExtraData(self.allExtraData, self, ExtraDataIsTranshipItem, null);
			inTransaction := true;
		endif;
		global.getExtraData(self.allExtraData, ExtraDataBookingRef, bookingRefStr);
		if bookingRefStr &lt;&gt; null then
            if not inTransaction then
                beginTransaction;
            endif;
			self.bookingRef := bookingRefStr;
			global.setExtraData(self.allExtraData, self, ExtraDataBookingRef, null);
			inTransaction := true;
		endif;
	endif;    
    if inTransaction then
        commitTransaction;
    endif;
epilog

end;</source>
    </JadeMethod>
</Class>
