    <JadeMethod name="btn_OK_click" id="92e96496-e17e-4c5c-9159-4d93e5e92821">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btn_OK_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadTable" id="cbde1544-b130-45d2-8d79-bf598fc60586">
        <source>loadTable(tbl : CM_MobTable input);
// ---------------------------------------------------------------------------
// Created:     13 May 2008 by cnwaer1
//
// Purpose:     Make sure to increrment the number of rows in the setupDisplayTable() if you are adding rows to the table
//				default current tbl.rows := 5;
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 05/04/2013	cnwdap1		PAR #31378 CCMS PNL 2247 Use F10 key as shortcut to Order Enquiry screen
vars

begin

	tbl.accessCell(1,1).text := "F1 - Help";
	tbl.accessCell(2,1).text := "F2 - Return to parent form";
	tbl.accessCell(3,1).text := "F3 - Open the damage form for a selected item";
	tbl.accessCell(4,1).text := "F4 - Remove the selected item from the table";
	tbl.accessCell(5,1).text := "F5 - Open a selected item in the Cargo Enquiry form";
	tbl.accessCell(6,1).text := "F6 - Allocate storage for the selected item";
	tbl.accessCell(7,1).text := "F7 - Open the Locations Maintenance form";
	tbl.accessCell(8,1).text := "F8 - Close location and replan";
	tbl.accessCell(9,1).text := "F9 - Open the Location Summary form";
	tbl.accessCell(10,1).text := "F10 - View Order details for the selected item";				// PAR #31378
	//tbl.accessCell(7,1).text := "F7  - HELP";
	//tbl.accessCell(8,1).text := "F8  - HELP";
	//tbl.accessCell(9,1).text := "F9  - HELP";
	//tbl.accessCell(10,1).text:= "F10 - HELP";

end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupDisplayTable" id="759ad89e-54eb-4b56-ad75-18d7356684a0">
        <source>setupDisplayTable(tbl : CM_MobTable input);
// ---------------------------------------------------------------------------
// Created:     12 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 05/04/2013	cnwdap1		PAR #31378 CCMS PNL 2247 Use F10 key as shortcut to Order Enquiry screen
vars
	intColumns 		: Integer;
	strHeader 		: String;
begin		
	tbl.setMargins();
	tbl.selectMode := tbl.SelectMode_Row;
	tbl.accessedSheet.marginLeft := 5;
	tbl.fontSize := 14;
	tbl.height := 370;
	tbl.columns := 1;
	tbl.rows := 10;													// PAR #31378
	tbl.defaultRowHeight := (tbl.height/tbl.rows).Integer-1;
//	tbl.autoSize := tbl.AutoSize_Row;
	tbl.gridLines := false;
	tbl.setFixedColours();
end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3588d77b-f245-4961-9af2-4b25a7937876">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	self.setupDisplayTable(self.tbl_Display);
	self.loadTable(self.tbl_Display);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="56f69de6-bf40-4e23-a389-d85adec3a966">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017609, locale);
	btn_OK.translateCaption(Xlat_0013164, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
