    <DbClassMap file="query"/>
    <JadeMethod name="displayNull" id="a8771862-2d09-45bf-a522-43a123e19fc3">
        <methodInvocation>mapping</methodInvocation>
        <source>displayNull(set: Boolean; _value: Boolean io) mapping;
//----------------------------------------------------------------
//	Created:	07 May 2009 cnwjo3
//----------------------------------------------------------------
begin
	_value := true;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="6d0aa395-b23a-4e1e-a63d-c24b1697b3f3">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     07 May 2009 cnwjo3
//
vars

begin
	if _value.Integer &lt;&gt; NULL_INTEGER then
		return _value.String;
	endif;
	
	return null;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
