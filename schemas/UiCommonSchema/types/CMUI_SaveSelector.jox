		if menuUserQry &lt;&gt; null then
			self.txtQueryName.text := menuUserQry.heading;
			self.txtQueryDesc.text := menuUserQry.description;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9c2ff44d-9f25-4820-9a02-a552d21c2651">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60763: UI - Cargo Review Ui changes

*/

vars

begin
	inheritMethod();

	self.doPopulateFolder();
	self.doPopulateQuery();
epilog

end;</source>
