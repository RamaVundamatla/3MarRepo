    <JadeMethod name="getKPINetRate" id="c2597f7f-a095-42d0-a6c5-fa5e60bf381c">
        <source>getKPINetRate(_jsStats : CMIF_JobSheetStats): Decimal;
/*
Purpose:			
Date		Who		Reason
20 April 2017	cnwab1	Initial creation
*/

vars
	crane : CM_Crane;
	tmpTS, tmpTSend : TimeStamp;
	returnNotSet : Boolean;
	measure		: CM_MeasurementType;
	unit		: String;
	converted	: String;
	actualTime :TimeStamp;
	completeDiffMins : Integer;
	wle : CM_WorkListEntry;
	delayCol : CM_DelayByStartDTDict;
	delayHours, netrate : Real;

begin
			actualTime:=_jsStats.getActualTime;
			if _jsStats.liftsIncomplete = 0 and _jsStats.movesIncomplete = 0 and not _jsStats.myJobSheet.allCompletedWLEsByDate.isEmpty then // must be complete
				wle := _jsStats.myJobSheet.allCompletedWLEsByDate.last;
				if wle.completedDate.Date.isValid then
					actualTime := wle.completedDate; // so populate with the time it completed.
				endif;
			endif;
			
			completeDiffMins:=actualTime.getDifferenceInMinutes(_jsStats.workStarted);
			
			tmpTS := _jsStats.myJobSheet.CM_VoyageJobSheet.getStartDateFromReceiveRelease();
			tmpTSend := _jsStats.myJobSheet.CM_VoyageJobSheet.getEndDateFromReceiveRelease();
			create delayCol transient;
			delayHours := _jsStats.myJobSheet.CM_VoyageJobSheet.getShiftDelayHoursRoRoHold(tmpTS, tmpTSend, delayCol);

			if delayHours &gt; 0 then
				netrate :=  ( _jsStats.completeWeight /(completeDiffMins - (delayHours * 60)) * 60);		
			else
				netrate := _jsStats.actualRate;
			endif;

			return netrate;
epilog

end;</source>
        <Parameter name="_jsStats" type="CMIF_JobSheetStats"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
