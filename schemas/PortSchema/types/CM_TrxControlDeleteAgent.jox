    <JadeMethod name="trxDeleteVoyageJobs" id="3db78b66-79b3-4046-aa14-c3ae6268077e">
        <updating/>
        <source>trxDeleteVoyageJobs(_voyageJobs : CM_VoyageJobSet io; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
// 10 Dec  2021    navma1	Bug 52539: SAL - Hold Planning Split Work - Delete Job
// ---------------------------------------------------------------------------

vars
	aJob 	  : CM_VoyageJob;
	theVoyage : CM_Voyage;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	foreach aJob in _voyageJobs discreteLock do
		
		if theVoyage = null then
			theVoyage := aJob.myVoyage;
		endif;
		
		app.myUtilityDA.utlDeleteVoyageJob(aJob, _passport, true);
		
		if _passport.hasErrors then
			break;
		endif;
		
	endforeach;
	
	if not _passport.hasErrors  then
		if theVoyage &lt;&gt; null then
			
			if theVoyage.myCellularVoyageStructure&lt;&gt; null  then     //10.12.2021 navma1 #52539
				theVoyage.myCellularVoyageStructure.causeEvent(theVoyage.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE), true, theVoyage.myCellularVoyageStructure);
			elseif theVoyage.myGeneralCargoVoyage &lt;&gt; null  then		//10.12.2021 navma1 #52539
				theVoyage.causeEvent(theVoyage.myTerminal.getTerminalEvent(WLE_Delete_Event), true, theVoyage);
			endif;
			
		endif;
	endif;
epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_voyageJobs" type="CM_VoyageJobSet" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
