Purpose:			
Date		Who		Reason
18 September 2013	cnwab1	Initial creation
*/

vars

begin

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateCompareSelectedPoints" id="8183334c-d1a3-40af-ba18-3c41e8278392">
        <source>validateCompareSelectedPoints(_messageStr : String; _pointName : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:     03 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpObj	: Object;
	selPoints, 
	altPoints : Integer;
	sameAmount : Boolean;
	aMessage, 
	selPointLabels, 
	altPointLabels  : String;
begin

	altPoints := self.allSelectedObjectsAlt.size;

	if altPoints = 0 then
		return true;
	endif;

	selPoints := self.allSelectedObjects.size;

	foreach tmpObj in self.allSelectedObjects do
		if selPointLabels = null then
			selPointLabels := tmpObj.getNiceName();
		else
			selPointLabels := selPointLabels &amp; ", " &amp; tmpObj.getNiceName();
		endif;
	endforeach;

	foreach tmpObj in self.allSelectedObjectsAlt do
		if altPointLabels = null then
			altPointLabels := tmpObj.getNiceName();
		else
			altPointLabels := altPointLabels &amp; ", " &amp; tmpObj.getNiceName();
		endif;
	endforeach;

	sameAmount := (selPoints = altPoints);
	if not sameAmount then
		aMessage :="Please select the same number of " &amp; _pointName &amp; " and ALT " &amp; _pointName &amp; "." &amp; Cr;
		aMessage := aMessage &amp; "You have " &amp; selPoints.String &amp; " selected " &amp; _pointName &amp; " (" &amp; selPointLabels &amp; ")" &amp; ", " &amp; Cr;
		aMessage := aMessage &amp; "and " &amp; altPoints.String &amp; " ALT " &amp; _pointName&amp; " (" &amp; altPointLabels &amp; ")";
		app.msgBox(aMessage,_messageStr &amp; " Draw Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	endif;
	return sameAmount;

end;</source>
        <Parameter name="_messageStr" type="String"/>
        <Parameter name="_pointName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
