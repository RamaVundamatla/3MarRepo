    <JadeMethod name="setTempFromMinMax" id="86548199-5286-45ee-8776-932e01e62535">
        <updating/>
        <source>setTempFromMinMax(_min: String; _max: String) updating;
//----------------------------------------------------------------
//	Created:	19 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	temp	: Real;
begin
	
	if _min.isReal and _max.isReal then
		temp := (_min.Real + _max.Real)/2;
	elseif _min.isReal then
		temp := _min.Real;
	elseif _max.isReal then
		temp := _max.Real;
	else	//neither
		temp := NULL_TEMPERATURE;
	endif;

	self.temperature := temp;

end;</source>
        <Parameter name="_min" type="String"/>
        <Parameter name="_max" type="String"/>
    </JadeMethod>
