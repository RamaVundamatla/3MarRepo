    <JadeMethod name="setForCreate" id="ce1e76c7-765e-45f7-833d-2e69ca09c629">
        <updating/>
        <source>setForCreate(_id : String; _isAvailable: Boolean; _myWagon: CM_Wagon; _myPreviousController : CM_WagonController input) updating;
/*
 ------------------------------------------------------------------------
Created:			16 July 2001 by cnwdwq1
Purpose:			!     
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	rlLen : Integer;
begin
//Par 17428
	if (_id.length &lt; 20)  then 
		self.id := _id;
		self.ident := _id;
		self.isAvailable := _isAvailable;
		self.myWagon := _myWagon;
		self.myPreviousController := _myPreviousController;
		
		if _myWagon.myRailLine &lt;&gt; null then
			self.myTerminalArea := _myWagon.myRailLine.myRailArea;
		endif;
			
	else
	
		app.raiseCMException(WAGON_LOCATION_ID_TOO_BIG, null, self);
		//app.raiseCMException2(ERR_INVALID_VALUE,"The wagon id cannot be saved as the  combined length of the id and one or more of the wagon class (class code) is greater than length 20","Please change the wagon id and/or location ids!",null,null);
				//	app.setContinueCMExceptions(false);
				//	app.raiseCMException2(ERR_KEY_NOT_FOUND, wagonClassId, "Wagon  Id is greater than 20 ,please change it", null, null);
				//app.raiseCMException1(ERR_INVALID_WAGONNO, _id, null, null);
	endif;
		
	// All Done
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isAvailable" type="Boolean"/>
        <Parameter name="_myWagon" type="CM_Wagon"/>
        <Parameter name="_myPreviousController" type="CM_WagonController" usage="input"/>
    </JadeMethod>
