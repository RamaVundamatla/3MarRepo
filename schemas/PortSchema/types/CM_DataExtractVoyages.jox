    <JadeMethod name="initDataExtractFields_HMSVoy" id="6dc9bda7-22cb-446e-9764-0fc121cb41ed">
        <source>initDataExtractFields_HMSVoy(_fields: CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2011	#cnwdz2	 

*/

vars
	fieldName : String;
begin
	fieldName := "code";
	self.initDataExtractField(_fields, CM_Voyage.name, "code", fieldName, STRING, "Code", "A unique code for the visit of the selected vessel.", STRING, "A unique code made up from letters and numbers.");

	fieldName := "inwardCode";
	self.initDataExtractField(_fields, CM_Voyage.name, "inwardCode", fieldName, STRING, "Inward Code", "A reference code that represents the inward part of the vessel's visit.", STRING, "A unique code made up from letters and numbers.");

	fieldName := "createdTime";
	self.initDataExtractField(_fields, CM_Voyage.name, "createdTime", fieldName, TIMESTAMP, "Creation Date/Time", "Time the voyage was created in the system.", TIMESTAMP, TIMESTAMP_POSSIBLEVAL);

	//fieldName := "arrives"; the same as eta
	//self.initDataExtractField(_fields, CM_Voyage.name, "arrives", fieldName, STRING, "Arrival Date/Time", "**** fill in with field description ****", STRING, "**** fill in with possible values description ****");

	//fieldName := "departs"; the same as etd
	//self.initDataExtractField(_fields, CM_Voyage.name, "departs", fieldName, STRING, "Departure Date/Time", "**** fill in with field description ****", STRING, "**** fill in with possible values description ****");

	fieldName := "archived";
	self.initDataExtractField(_fields, CM_Voyage.name, "archived", fieldName, BOOLEAN, "Archived", "Is this voyage archived.", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "archivedDT";
	self.initDataExtractField(_fields, CM_Voyage.name, "archivedDT", fieldName, TIMESTAMP, "Archived Date/Time", "Date that the voyage was archived.", TIMESTAMP, TIMESTAMP_POSSIBLEVAL);

	fieldName := "bank";
	self.initDataExtractField(_fields, CM_Voyage.name, "bank", fieldName, STRING, "Discharge Company", "Billing business unit to use for invoice charges.", STRING, TIME_POSSIBLEVAL);

//	fieldName := "berthPriority";
//	self.initDataExtractField(_fields, CM_Voyage.name, "berthPriority", fieldName, STRING, "Berth Priority", "**** fill in with field description ****", STRING, "**** fill in with possible values description ****");

	fieldName := "bridgeAfterBay";
	self.initDataExtractField(_fields, CM_Voyage.name, "bridgeAfterBay", fieldName, STRING, "Bridge After Bay", "Position of the bridge/accomodation in respect to a LOLO bay.", STRING, "A valid bay ID for the current voyage.");

	fieldName := "callSign";
	self.initDataExtractField(_fields, CM_Voyage.name, "callSign", fieldName, STRING, "Call Sign", "Offical call sign for the voyage.", STRING, "Any combination of letters and numbers.");

//	fieldName := "cargoToDischarge";
//	self.initDataExtractField(_fields, CM_Voyage.name, "cargoToDischarge", fieldName, BOOLEAN, "Cargo To Discharge", "**** fill in with field description ****", BOOLEAN, BOOLEAN_POSSIBLEVAL);

//	fieldName := "cargoToLoad";
//	self.initDataExtractField(_fields, CM_Voyage.name, "cargoToLoad", fieldName, BOOLEAN, "Cargo To Load", "**** fill in with field description ****", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "coastalServiceVessel";
	self.initDataExtractField(_fields, CM_Voyage.name, "coastalServiceVessel", fieldName, BOOLEAN, "Coastal Service Vessel", "Voyage doing short run trips", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "colour";
	self.initDataExtractField(_fields, CM_Voyage.name, "colour", fieldName, STRING, "Colour", "Colour that represents this voyage in graphical parts of the system", STRING, "Any valid colour");

	fieldName := "craneClearance";
	self.initDataExtractField(_fields, CM_Voyage.name, "craneClearance", fieldName, INTEGER, "Crane Clearance", "The number of bays that a crane should have as clearance to another crane.", INTEGER, INTEGER_POSSIBLEVAL);

	fieldName := "excludeReport";
	self.initDataExtractField(_fields, CM_Voyage.name, "excludeReport", fieldName, BOOLEAN, "excludeReport", "Visits are Confidential. Exclude from reports.", BOOLEAN, BOOLEAN_POSSIBLEVAL);

//	fieldName := "hasBowThrust";
//	self.initDataExtractField(_fields, CM_Voyage.name, "hasBowThrust", fieldName, BOOLEAN, "Has Bow Thrusters", "**** fill in with field description ****", BOOLEAN, BOOLEAN_POSSIBLEVAL);

//	fieldName := "hasFixedProp";
//	self.initDataExtractField(_fields, CM_Voyage.name, "hasFixedProp", fieldName, STRING, "Propeller Type", "**** fill in with field description ****", STRING, "**** fill in with possible values description ****");

//	fieldName := "hasHoldTanks";
//	self.initDataExtractField(_fields, CM_Voyage.name, "hasHoldTanks", fieldName, BOOLEAN, "Has Holding Tanks", "**** fill in with field description ****", BOOLEAN, BOOLEAN_POSSIBLEVAL);

//	fieldName := "hasRamp";
//	self.initDataExtractField(_fields, CM_Voyage.name, "hasRamp", fieldName, BOOLEAN, "Ship has ramp(s)", "**** fill in with field description ****", BOOLEAN, BOOLEAN_POSSIBLEVAL);

//	fieldName := "hasSternThrust";
//	self.initDataExtractField(_fields, CM_Voyage.name, "hasSternThrust", fieldName, BOOLEAN, "Has Stern Thrusters", "**** fill in with field description ****", BOOLEAN, BOOLEAN_POSSIBLEVAL);

//	fieldName := "iSOVessel";
//	self.initDataExtractField(_fields, CM_Voyage.name, "iSOVessel", fieldName, BOOLEAN, "ISO Half Heights", "**** fill in with field description ****", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "isNonPlannedVoyage";
	self.initDataExtractField(_fields, CM_Voyage.name, "isNonPlannedVoyage", fieldName, BOOLEAN, "Will Be Planned", "The voyage is to be recorded in the system, but will not be formal planned.", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "isNonWorkedVoyage";
	self.initDataExtractField(_fields, CM_Voyage.name, "isNonWorkedVoyage", fieldName, BOOLEAN, "Will be Worked", "The voyage is to be recorded in the system, but not worked with formal jobs and machine tasks. ", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "effectiveDT";
	self.initDataExtractField(_fields, CM_Voyage.name, "effectiveDT", fieldName, STRING, "effectiveDT", "Non Planned Effective Date/Time", STRING, "**** fill in with possible values description ****");

//	fieldName := "isPilotExempt";
//	self.initDataExtractField(_fields, CM_Voyage.name, "isPilotExempt", fieldName, BOOLEAN, "Pilot Exempt", "**** fill in with field description ****", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "lloydsNumber";
	self.initDataExtractField(_fields, CM_Voyage.name, "lloydsNumber", fieldName, STRING, "Lloyds Number", "Reference field to record a listing number", STRING, "Any combination of letters and numbers.");

	fieldName := "myDefaultLineGroupDebtor";
	self.initDataExtractField(_fields, CM_Voyage.name, "myDefaultLineGroupDebtor", fieldName, STRING, "DefaultLineGroupDebtor", "Default Line Group Debtor", STRING, "Combination of shipping line code, port group code and debtor code");

	fieldName := "myDischargeCompany";
	self.initDataExtractField(_fields, CM_Voyage.name, "myDischargeCompany", fieldName, STRING, "Business Unit", "Business unit to be used for voyage based invoicing", STRING, "A code of a valid business unit in the system.");

	fieldName := "myOperator";
	self.initDataExtractField(_fields, CM_Voyage.name, "myOperator", fieldName, STRING, "Voyage Operator", "Owner /Operator of the vessel", STRING, "A valid operator code in the system.");

	fieldName := "myPortFrom";
	self.initDataExtractField(_fields, CM_Voyage.name, "myPortFrom", fieldName, STRING, "Port Arriving From", "Previous port of call", STRING, "A valid code of a port in the system.");

	fieldName := "myPortTo";
