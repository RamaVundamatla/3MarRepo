    <JadeMethod name="mnuWorkOrder_click" id="20ee6b25-c624-4297-b568-9f3ea6934608">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuWorkOrder_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jun 2023	navhl20	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
28 Nov 2023 navhl20 ChangeRequest 61508: EUP | Ship Operations in DD - [54176.010] - [Release] Ship Job List 
18 Jan 2024 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
13/11/2024	navkc1 JIRA Story MTN-33012: EUP | WO Transaction Billing Change of Debtor
18 Dec 2024	navbs1	Bug MTN-33554: EUP | 53729 - Show Work Order for multiple Work Orders
*/

vars
	woForm 			: YRD_WorkOrder;
	pxyWorkOrder,
	realWorkOrder 	: CM_WorkOrder;
	selObj			: Object;
	voyage			: CM_Voyage;	
	task,
	selectedTask	: CM_WorkOrderDtl;
	mode			: Integer; //13/11/2024	navkc1 JIRA Story MTN-33012
begin

	//18.12.2024 navbs1 #33554 START
	/*selObj := self.mnuWorkOrder.userObject.CM_DataTable.allSelectedObjects.first;
	
	if selObj = null then
		app.msgBox(app.getErrorString(Please_select_work_order), app.getErrorString(No_Work_order_selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	task := selObj.CM_Job.getMyWorkOrderDtl();								//28.11.2023 navhl20 #61508
	if task &lt;&gt; null then													//18.01.2024 navhl20 #62066
		realWorkOrder 	:= task.myParent;
	endif;
	*/
	
	realWorkOrder := menuItem.userObject.CM_WorkOrder;
	if realWorkOrder = null then 
		return;
	endif;
	
	task := realWorkOrder.allWoDtls.first;
	
	//18.12.2024 navbs1 #33554 END
	if realWorkOrder &lt;&gt; null and realWorkOrder.isVoyageWorkOrder then				
		voyage := realWorkOrder.CM_WorkOrderVoyage.getMyVoyageObject();				
	endif;	
	
	if realWorkOrder.pxyGetProxyObject() &lt;&gt; null then
		/*In case of a failure before*/
		pxyWorkOrder :=  realWorkOrder.pxyGetProxyObject();
		delete pxyWorkOrder;
	endif;
	
	mode := YRD_WorkOrder.MODE_UPDATE; //13/11/2024	navkc1 JIRA Story MTN-33012
	
	//13/11/2024	navkc1 JIRA Story MTN-33012 - New mode for updating completed work order
	if realWorkOrder.isComplete() then
		mode := YRD_WorkOrder.MODE_UPDATECOMPLETED;
	endif;
	
	pxyWorkOrder 	 := app.createUpdateProxy(realWorkOrder).CM_WorkOrder;
	app.mousePointer := MousePointer_HourGlass;
	
	
	woForm 			 := app.getForm(YRD_WorkOrder.name).YRD_WorkOrder;
	
	if woForm = null then
		woForm := app.loadForm(YRD_WorkOrder, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrder;
	endif;
	
	if woForm = null then
		return;
	endif;
	
	selectedTask := pxyWorkOrder.getProxyTask(task);										//18.01.2024 navhl20 #62066
	
	if selectedTask = null then																//18.01.2024 navhl20 #62066
		selectedTask := pxyWorkOrder.getProxyTask(task.CM_WodToDo.myWorkOrderDetail);
	endif;
	
	woForm.centreWindow;
	woForm.setMyTerminal(self.myTerminal);
	//woForm.initialise( self, pxyWorkOrder, YRD_WorkOrder.MODE_UPDATE, selectedTask, pxyWorkOrder.getWorkOrderMode, voyage );		//18.01.2024 navhl20 #62066
	woForm.initialise( self, pxyWorkOrder, YRD_WorkOrder.MODE_UPDATECOMPLETED, selectedTask, pxyWorkOrder.getWorkOrderMode, voyage );		//13/11/2024	navkc1 JIRA Story MTN-33012
	woForm.setDeleteProxy(true);
	woForm.show;
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resetTables" id="864b7109-4d57-4089-a1e3-4ba6c6f008c3">
        <source>resetTables();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
29 Aug 2023 navhl20 ChangeRequest 59216: EUP | Delivery Dispatch - Adding Splitter to resize tables
25 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
*/

vars

begin
	self.dkbAllocTop.height   		 := 310;
	self.dkbAllocBottom.height 	     := 234;
	self.dkbUnAllocBottom.height   	 := 222;
	self.dkbUnAllocTop.height 		 := 320;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="rowPostprocess" id="fc42d057-26da-428b-8823-2af761c972bc">
        <updating/>
        <source>rowPostprocess(_dataTable: CM_DataTable io; _idx: Integer; _obj: Object) : Boolean updating;
/*

Purpose:			

Parameters:			
	
Return Value:		

Date		Who		Reason
13 May 2024	navra1	Initial creation - //navra1 - TFS 63751/Task 63752 - 13th May 2024
25 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
25 Aug 2025 navhl20 Story MTN-35317: MTN | Pagination - Work Order Operations
*/

vars
	job : CM_Job;
	wle : CM_WorkListEntry;	
begin	

	if _dataTable.name =  self.tblJobsUnallocated.name then															//25.03.2025 navhl20 #34425
		if _obj.isKindOf(CM_Job) then	
			job :=_obj.CM_Job;
		
			if _idx &gt; 0 then
				_dataTable.accessRow(_idx).backColor := job.getRowColourForWorkPoint(true);	
			endif;
		endif;
	elseif _dataTable.name =  self.tblJobsAllocated.name then														//25.03.2025 navhl20 #34425
		if _obj.isKindOf(CM_Job) then	
			job :=_obj.CM_Job;
			
			if _idx &gt; 0 then
				_dataTable.accessRow(_idx).backColor := job.getRowColourForWorkPoint(false);
			endif;
		endif;
	//navra1 - TFS 63751/Task 64183 - 17th May 2024 - start
	elseif _dataTable.name =  self.tblWlesAllocated.name or _dataTable.name = self.tblWlesUnallocated.name then		//25.03.2025 navhl20 #34425
		if _obj.isKindOf(CM_WorkListEntry) then
			wle :=_obj.CM_WorkListEntry;
			if wle.status = WLE_COMPLETED and _idx &gt; 0 then
				_dataTable.accessRow(_idx).foreColor := White;														//25.08.2025 navhl20 #35317
				_dataTable.accessRow(_idx).backColor := Grey;														//25.08.2025 navhl20 #35317
			endif;
		endif;
	//navra1 - TFS 63751/Task 64183 - 17th May 2024 - end		
		
	endif;


	return true;	
epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="io"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rowPreprocess" id="edd32679-f918-4fbb-80b7-2730c86dce07">
        <updating/>
        <source>rowPreprocess(_dataTable: CM_DataTable; _obj: Object): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2024	navra1	Initial creation - //navra1 - TFS 63751/Task 64183 - 17th May 2024
25 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
13 Nov 2025	jlizm1	MTN 35927 Filter Issues on paginated forms
*/

vars
	wle : CM_WorkListEntry;
	filterText : String;
	tmpString : String;
	
begin
	if _dataTable.name = self.tblWlesAllocated.name or _dataTable.name = self.tblWlesUnallocated.name then //25.03.2025 navhl20 #34425
		if _obj.isKindOf(CM_WorkListEntry) then
			wle := _obj.CM_WorkListEntry;			
			
			if wle.myTrackedItem &lt;&gt; null and wle.myTrackedItem.isKindOf(CM_TILC) then
				return false;
			endif;
			
			if _dataTable.name = self.tblWlesUnallocated.name and wle.myRequest &lt;&gt; null and					//25.03.2025 navhl20 #34425
					wle.myRequest.isKindOf(CM_DeliveryRequest) and
					wle.myRequest.CM_DeliveryRequest.myCargoType &lt;&gt; null and
					wle.myRequest.CM_DeliveryRequest.myCargoType.isTrailer() then							//29.01.2023 navhl20 #62166
				return false;
			endif;
		endif;	
	endif;
	
	// MTN 35927
	if _dataTable.isPaginated then
		if _dataTable.name = self.tblJobsAllocated.name then
			filterText := self.frmTableFilterAllocated.txtFilterBox.text.toUpper();
		elseif _dataTable.name = self.tblJobsUnallocated.name then
			filterText := self.frmTableFilterUnallocated.txtFilterBox.text.toUpper();
		endif;
		
		if filterText &lt;&gt; null then
			tmpString := _obj.getAttributeStringForDefArray(_dataTable.allTblDataEntRows).toUpper;

			if tmpString.pos(filterText, 1) = 0 then
				return false;
			endif;
		endif;
	endif;
	
	return inheritMethod(_dataTable, _obj);

epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveXMLStrForTblColumns" id="28b087dd-528a-4542-a6ac-96d0b05fe258">
        <updating/>
        <source>saveXMLStrForTblColumns(table: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023	navhl20	ChangeRequest 57766:[57767] EUP - Delivery Dispatch – Define Job Sheet
18 Sep 2025 navhl20 Bug MTN-36084: MTN | Work Order Operations Pagination column issue with view
*/

vars
	xmlStr : String;
begin
	if table = self.tblJobSheet then
		xmlStr := self.tblJobSheet.getXmlStrForColumns(true);
		self.defJobSheet := xmlStr;
	elseif table = self.tblJobsAllocated then
		xmlStr := self.tblJobsAllocated.getXmlStrForColumns(true);
		self.defJobAllocatted := global.formatAsXML(self.operationMode.String, xmlStr);		//18.09.2025 navhl20 #36084
	elseif table = self.tblJobsUnallocated then
		xmlStr := self.tblJobsUnallocated.getXmlStrForColumns(true);
		self.defJobUnAllocatted := global.formatAsXML(self.operationMode.String, xmlStr);	//18.09.2025 navhl20 #36084
	elseif table = self.tblWlesUnallocated then
		xmlStr := self.tblWlesUnallocated.getXmlStrForColumns(true);
		self.defWleUnallocated := global.formatAsXML(self.operationMode.String, xmlStr);	//18.09.2025 navhl20 #36084
	elseif table = self.tblWlesAllocated then
		xmlStr := self.tblWlesAllocated.getXmlStrForColumns(true);
		self.defWleAllocated := global.formatAsXML(self.operationMode.String, xmlStr);		//18.09.2025 navhl20 #36084
	endif;
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDefaultVisiblity" id="44d9db65-2038-4289-a0c7-aa7a53b28c37">
        <source>setDefaultVisiblity();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.

*/

vars

begin
	self.mnuSetPriority.visible 	:= false;
	self.mnuWorkOrder.visible 		:= false;
	self.mnuInspect.visible 		:= false;
	self.mnuShiftJobs.visible 		:= false;
	self.mnuSplitJob.visible 		:= false;
	self.mnuAddJobSheet.visible 	:= false;
	self.mnuUnAllocateJobs.visible  := false;
	self.mnuLegendAllocated.visible   := false;
	self.mnuLegendUnAllocated.visible := false;
	self.mnuAllocateJobSheet.visible  := false;
	self.mnuReport.visible 			:= false;
	self.mnuReportAll.visible 		:= false;
	self.mnuReportSelected.visible 	:= false;
	self.mnuUpdateJob.visible 	    := false;
	self.mnuCompleteJob.visible    	:= false;
	self.mnuMaintainSeal.visible    := false;
	self.mnuCheckSeal.visible    	:= false;
	self.mnuRetroDT.visible			:= false;
	self.mnuReprintDI.visible 		:= false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setRowColourForWorkPoint" id="76bb9a56-aa4a-4ca3-a3cf-49ac732e377f">
        <updating/>
        <source>setRowColourForWorkPoint(_tbl : CM_DataTable input; _job : CM_Job input; _idx : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Sep 2023 navlc30 ChangeRequest 60211: EUP | Delivery Dispatch Colour Legend
21 Nov 2023	navmd1	TFS 61353 Moved row selection into this method
*/

vars

begin
	if _idx &lt;= _tbl.fixedRows then
		return;
	endif;
	
	if _tbl.name = tblJobsUnallocated.name then
		_tbl.accessRow(_idx).backColor := _job.getRowColourForWorkPoint(true);
	else
		_tbl.accessRow(_idx).backColor := _job.getRowColourForWorkPoint(false);
	endif;
	
epilog

end;</source>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
        <Parameter name="_job" type="CM_Job" usage="input"/>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setShowMenus" id="105e7179-83b5-4235-b146-2b71af9d1058">
        <source>setShowMenus(_table : CM_DataTable);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.

*/

vars
	selectedJobSize : Integer;
	firstObj		: Object;
	job				: CM_VoyageJob;
begin
	selectedJobSize := _table.allSelectedObjects.size;								//01.09.2023 navma1 #60213
	
	firstObj := _table.allSelectedObjects.first;	
	if _table.allSelectedObjects.isNotEmpty() then
		self.mnuReport.visible 			:= true;
		self.mnuReport.userObject 		:= _table;
		self.mnuReportAll.visible 		:= true;
		self.mnuReportSelected.visible 	:= true;
	endif;
	if _table.allSelectedObjects.isNotEmpty() and selectedJobSize = 1 and firstObj.CM_Job.isLinkedToWorkOrder &lt;&gt; null then
		self.mnuWorkOrder.visible    := true;
		self.doBuildMenuWorkOrders(firstObj);
	endif;
	if selectedJobSize = 1 and firstObj.isKindOf(CM_RoadJob) then
		self.mnuReprintDI.visible := true;
		self.mnuReprintDI.userObject := firstObj;
	endif;
	
	if selectedJobSize = 1 and 
	firstObj.CM_Job.status &lt;&gt; JOB_COMPLETE and 
	firstObj.CM_Job.isWorkOrderJob() and
	not firstObj.CM_Job.isShipJob() then
		self.mnuSplitJob.visible	:= true;
		self.mnuSplitJob.userObject := _table;
		if firstObj.isKindOf(CM_WOPackJob) then
			if not firstObj.CM_WOPackJob.canSplitPackJob() then
				self.mnuSplitJob.visible	:= false;
				self.mnuSplitJob.userObject := null;
			endif;
		endif;
	endif;
	
	if _table = self.tblJobsAllocated then
		self.doBuildMnuUnAllocate(_table.allSelectedObjects);
		self.doBuildMnuShiftJobs(_table);											//20.7.2023 navhl20 #58333
		if firstObj.isKindOf(CM_VoyageJob) then										//01.11.2023 navhl20 #60091
			job := firstObj.CM_VoyageJob;
			if selectedJobSize = 1 then												//16.01.2023 navhl20 #62066
				self.mnuUpdateJob.visible 	 := true;
				self.mnuUpdateJob.userObject := job;
				if job.status = JOB_UNACTIONED then
					self.mnuUnAllocateJobs.visible := true;
				endif;
			endif;
		endif;
		
		self.mnuLegendAllocated.visible   := true;
		if _table.allSelectedObjects.isNotEmpty() and selectedJobSize = 1 then			//09.02.2023 navhl20 #62093
			if firstObj.isKindOf(CM_RoadJob) and
			firstObj.CM_RoadJob.isRetrospective then
				if firstObj.CM_RoadJob.status = JOB_COMPLETE then						//20.02.2024 navhl20 #62525
					self.mnuMaintainSeal.visible    := true;
					self.mnuMaintainSeal.userObject := _table;
					self.mnuCheckSeal.visible    	:= true;
					self.mnuCheckSeal.userObject 	:= _table;
				endif;
			endif;
			if firstObj.CM_Job.status &lt;&gt; JOB_COMPLETE then								//11.03.2024 navhl20 #60097	//26.09.2024 navhl20 #14712
				self.mnuCompleteJob.visible    := true;
				self.mnuCompleteJob.userObject := _table;
				if firstObj.isKindOf(CM_WOToDoTaskJob) then								//27.03.2024 navhl20 #63197
					self.mnuCompleteJob.visible    := firstObj.CM_Job.canCompleteToDoJob();
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="setShtCaption" id="98982ce7-b2d6-48a1-8f6f-6c86f87001b8">
        <source>setShtCaption(_tbl : CM_DataTable);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Jun 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
25 Aug 2025 navhl20 Story MTN-35317: MTN | Pagination - Work Order Operations
*/

vars

begin
	if _tbl = self.tblJobsUnallocated then
		self.shtUnAllocated.caption := self.shtUnAllocateCap &amp; " [" &amp; self.allUnAllocatedJobs.size.String &amp; "]";	//25.08.2025 navhl20 #35317
	else
		self.shtAllocated.caption := self.shtAllocateCaption &amp; " [" &amp; self.allAllocatedJobs.size.String &amp; "]";		//25.08.2025 navhl20 #35317
	endif;
epilog

end;</source>
        <Parameter name="_tbl" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="00641445-0089-473e-b2cf-20fe4774b0a4">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2023 navhl20	ChangeRequest 57766:[57767] EUP - Delivery Dispatch – Define Job Sheet
22 May 2023 navhl20 ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
01 Jun 2023 navhl20 ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
04 Jul 2023 navhl20 Defect 58906: MTN - The Allocated and Unallocated list is not refreshing correctly using the filter criteria
29 Aug 2025 navhl20 Story MTN-35317: MTN | Pagination - Work Order Operations
*/

vars

begin
	self.doRefresh();
	self.saveXMLStrForTblColumns(_theTable);
	if _theTable = self.tblJobSheet then
		self.loadTblJobSheets();
	elseif _theTable = self.tblJobsAllocated then
		self.loadTblAllocated();									//04.7.2023 navhl20 #58906
	elseif _theTable = self.tblJobsUnallocated then
		self.loadTblUnAllocated();									//04.7.2023 navhl20 #58906
	elseif _theTable = self.tblWlesUnallocated then
		self.tblJobsUnallocated_click(self.tblJobsUnallocated);		//22.5.2023 navhl20 #57714[57764]
	elseif _theTable = self.tblWlesAllocated then					//01.6.2023 navhl20 #57747[57748]
		self.tblJobsAllocated_click(self.tblJobsAllocated);
	endif;
epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setToDoTaskComplete" id="27e06564-d968-4ed5-8968-2ced1d58fc3a">
        <updating/>
        <source>setToDoTaskComplete(_wle : CM_WorkListEntry input) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 27SEP2023
ADO - CR 60699 TASK 60700 
05 Jul 2024 navbs1  CR 64901 Task 64903: UI - Show Cargo Ids in To Do Complete Thin Client
06 Mar 2025 navma1 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars

	wle 				: CM_WorkListEntry;
	wleArray 			: CM_WLEArray;
	tiTask 				: CM_ToDoTask;
	realTiSet 			: CM_TISet;
	pxyTiSet 			: CM_TISet;
	ti 					: CM_TrackedItem;
	taskDescCode 		: Integer;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	theResult 			: Integer;	
	resourceUsageResult : Boolean; 
	tbl 				: CM_DataTable;
	job					: CM_Job;
begin
	
	tbl := self.mnuCompleteJob.userObject.CM_DataTable;
	if tbl = null or tbl.allSelectedObjects.isEmpty() then
		return;
	endif;

	if _wle = null or not _wle.isKindOf(CM_WOToDoWLE) then
		app.msgBox(app.getErrorString(Select_work_entry_complete),app.getErrorString(Make_selection), MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;	
	endif;
	
	tiTask := self.getToDoTask(_wle.CM_WOToDoWLE);
	taskDescCode := tiTask.toDoTaskDescCode;

	if _wle.isForToDoWOTransaction() then
		if not tiTask.toDoTaskDesc.allResourceTypes.isEmpty then
			create resourceUsageProxys transient;	// will be populated with template versions of the resources to apply..
			resourceUsageResult := self.myAssistant.showResourceTypeUsageForTxn(null, null, tiTask.toDoTaskDesc, null, resourceUsageProxys, true, _wle.job.CM_WorkOrderJob);	//05.07.2024  navbs1  CR 64901 Task 64903
			if resourceUsageResult = false then
				// failed to create the form or was cancelled.
				app.msgBox(app.getErrorString(Resource_Usage_Form_Not_shown),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
				return;
			endif;
		endif;
		
		while true do
			app.myTrxUA.trxUpdateWODTIToDoNoTIComplete(_wle.CM_WOToDoWLE,tiTask.CM_TiToDoTask,resourceUsageProxys,app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
			theResult := app.showErrorWarningDialog("Complete", app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;

			break;
		endwhile;
		return;
	endif;
	
	ti   := _wle.myTrackedItem;
	job  := tbl.allSelectedObjects.first.CM_Job;			//06.03.2025 navma1 #MTN-34179
	
	create wleArray transient;
	foreach wle in job.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
		if wle = null or not wle.isKindOf(CM_WOToDoWLE) then
			continue;
		endif;		
		if wle = null then
			// wle is set to null by the ex handler if it is not found / deleted
			continue;
		endif;
		wleArray.add(wle);
	endforeach;
	
	create realTiSet transient;
	foreach wle in wleArray where self.canCompleteToDoWLE(wle.CM_WOToDoWLE) do
		if wle.myTrackedItem &lt;&gt; null then 
			if not realTiSet.includes(wle.myTrackedItem) then
				realTiSet.add(wle.myTrackedItem);
			endif;
		endif;	
		
	endforeach;

	create pxyTiSet transient;
	
	if not self.myAssistant.doTaskProxySetForComplete( taskDescCode, pxyTiSet, ti, realTiSet, resourceUsageProxys) = IDOK then
		return;
	endif;
	
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(tiTask.toDoTaskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog("Complete", app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
epilog

	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;
	delete realTiSet;
	delete wleArray;
	

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9e3fdb01-2497-4b9c-bf71-a95e23f2f8a6">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023 navma1  ChangeRequest 57878: EUP - Delivery Dispatch – Screen Design
19 May 2023 navhl20	ChangeRequest 57766:[57767] EUP - Delivery Dispatch – Define Job Sheet
29 May 2023 navhl20 ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
02 Jun 2023 navlw1 	CHangeRequest 58294: EUP | Delivery Dispatch Screen - Setting Priority
04 Jul 2023 navhl20 Defect 58906: MTN - The Allocated and Unallocated list is not refreshing correctly using the filter criteria
17 Jul 2023	navma1	ChangeRequest 59151: EUP | Delivery Dispatch - Hide Job Details
29 Aug 2023 navhl20 ChangeRequest 59216: EUP | Delivery Dispatch - Adding Splitter to resize tables
04 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
05 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
27 Sep 2024	navnk30	Bug 66107: MTN | Work Order Operations Permissions
05 Mar 2025 navbs1	Story MTN-34213: MTN - Work Order Operations screen loading data twice on start-up
25 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
*/

vars

begin
	
	inheritMethod();
	
	self.tblData.visible    := false;
	self.splMain.visible    := false;
	self.minimumWidth       := 1450;
	self.minimumHeight      := 850;
	self.fldJobs.topSheet   := self.shtUnAllocated;
	self.shtAllocateCaption := self.shtAllocated.caption;																									//01.6.2023 navhl20 #57747[57748]
	self.shtUnAllocateCap 	:= self.shtUnAllocated.caption;																									//01.6.2023 navhl20 #57747[57748]
	
	self.doPermissionsCheck();									//27.09.2024 navnk30 #66107
	
	/*
	Load Filter Criteria 
	*/
	self.loadFliterCriteria();
	/*
	Load Screen Modes
	*/
	self.buildCmbMode();
	
	// ### TFS 62859 (62860) 03Apr2024 NAVPW1
	//Moved the below because of the way forms load its better to load this in setupForm rather than YRD_WorkOrderOperation::initFromUserWindow
	//Due to the fact that an app restart with this window open loads in a different order as opposed to opening this window from the navigator
	self.buildJobsheet();											//05.03.2025 navbs1 #34213
	self.buildCmbTransport(self.chkCurrentVoyage.value);			//05.03.2025 navbs1 #34213
	// ### TFS 62859 (62860) 03Apr2024 NAVPW1
	
	self.initMnuPriority(); 										// ### TFS 58294 02June2023 navlw1		//01.6.2023 navhl20 #57747[57748
	
	/*
	Show/Hide Wles Tables
	*/
	
	if self.chkJobDetail.value then									//17.07.2023 navma1 #59151
		self.doShowJobDetails();
	else
		self.doHideJobDetails();
	endif;
	
	if self.chkFilterCriteria.value then							//29.8.2023 navhl20 #59216
		self.doShowCriteria();
	else
		self.doHideCriteria();
	endif;
	
	self.setupNotifications();
	
	self.frmTableFilterAllocated.setupControl(self.tblJobsAllocated, null);		//05/06/2024	navkc1 CR 63736 Task 63770
	self.frmTableFilterJobSheet.setupControl(self.tblJobSheet, null);			//05/06/2024	navkc1 CR 63736 Task 63770
	self.frmTableFilterUnallocated.setupControl(self.tblJobsUnallocated, null);	//05/06/2024	navkc1 CR 63736 Task 63770
	
	if app.myRoot.isPaginated then
		// MTN 35927
		// If paginated override table filtering to use version compatable with paginated tables
		self.frmTableFilterAllocated.setSkipControlFilter(true);
		self.frmTableFilterAllocated.setCallbackMethod(YRD_WorkOrderOperation::filterTblJobsAllocated.name);
		
		self.frmTableFilterUnallocated.setSkipControlFilter(true);
		self.frmTableFilterUnallocated.setCallbackMethod(YRD_WorkOrderOperation::filterTblJobsUnallocated.name);
	endif;
	
	self.btnSearch_click(self.btnSearch);										//05.03.2025 navbs1 #34213 
	
	//18/03/2025	navkc1 JIRA Story MTN-34154 - Starts
	self.frmBtnNotification.visible := true;
	self.btnNotifications.parent    := self.frmBtnNotification;
	self.btnNotifications.visible   := true;
	self.btnNotifications.left      := 0;
	self.btnNotifications.top       := 0;
	self.btnNotifications.autoSize  := Button.AutoSize_Picture;
	//18/03/2025	navkc1 JIRA Story MTN-34154 Ends
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupNotifications" id="6df39e31-4e3e-46ea-aea1-2ae6501bc2e2">
        <updating/>
        <source>setupNotifications() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Nov 2023	navmd1	Initial creation TFS 61353 Move notification set-up code to a single method
14 Oct 2024	navnk30	JIRA 12385: MTN - Work Order Operation Screen notifications restricts user
12 Mar 2025	jlier1	MTN-34200 - changed to terminal notes for jobs and wles 
24 Mar 2025	navbs1	Defect Sub-task MTN-34463: Ship gang got disappeared when unchecking the Job Sheet checkbox on the WO Operations form
*/

vars
	terminal : CM_Terminal;
begin
	terminal:= self.myTerminal;

	// Always listen for CM_Job notes, so only set on first open
	if not self.isFirstActivateComplete then		
		self.beginClassNotification(CM_Job, false, terminal.getTerminalEvent(WorkOrderJob_Update_Event), Response_Continuous, null);
		self.beginClassNotification(CM_Job, false, terminal.getTerminalEvent(WorkOrderJob_Delete_Event), Response_Continuous, null);
	endif;
	
	if self.chkJobSheet.value then
		self.beginClassNotification(CM_WorkPointJobSheet, false, terminal.getTerminalEvent(Event_JobSheet_WP_Create), Response_Continuous, 0);
		self.beginClassNotification(CM_WorkPointJobSheet, false, terminal.getTerminalEvent(Event_JobSheet_WP_Update), Response_Continuous, 0);
		self.beginClassNotification(CM_WorkPointJobSheet, false, terminal.getTerminalEvent(Event_JobSheet_WP_Delete), Response_Continuous, 0);
		self.isJobShtsNotfsStarted := true;															//24.03.2025 navbs1 #34463
	else
		if self.isFirstActivateComplete and self.isJobShtsNotfsStarted then							//24.03.2025 navbs1 #34463
			self.endClassNotification(CM_WorkPointJobSheet, false, terminal.getTerminalEvent(Event_JobSheet_WP_Create));
			self.endClassNotification(CM_WorkPointJobSheet, false, terminal.getTerminalEvent(Event_JobSheet_WP_Update));
			self.endClassNotification(CM_WorkPointJobSheet, false, terminal.getTerminalEvent(Event_JobSheet_WP_Delete));
			self.isJobShtsNotfsStarted := false;													//24.03.2025 navbs1 #34463
		endif;
	endif;
	
	if self.chkJobDetail.value then
		self.beginClassNotification(CM_WorkListEntry, false, terminal.getTerminalEvent(WLE_Create_Event), Response_Continuous, null);
		self.beginClassNotification(CM_WorkListEntry, false, terminal.getTerminalEvent(WLE_Update_Event), Response_Continuous, null);
		self.beginClassNotification(CM_WorkListEntry, false, terminal.getTerminalEvent(WLE_Delete_Event), Response_Continuous, null);
		self.isJobDtlsNotfsStarted := true;															//24.03.2025 navbs1 #34463
	else
		if self.isFirstActivateComplete and self.isJobDtlsNotfsStarted then							//24.03.2025 navbs1 #34463
			self.endClassNotification(CM_WorkListEntry, false, terminal.getTerminalEvent(WLE_Create_Event));
			self.endClassNotification(CM_WorkListEntry, false, terminal.getTerminalEvent(WLE_Update_Event));
			self.endClassNotification(CM_WorkListEntry, false, terminal.getTerminalEvent(WLE_Delete_Event));
			self.isJobDtlsNotfsStarted := false;													//24.03.2025 navbs1 #34463
		endif;
	endif;
	self.beginClassNotification(CM_Job, false, Voyage_WO_Bulk_Move_Started, Response_Continuous, 0);		//14.10.2024 navnk30 JIRA #12385
	self.beginClassNotification(CM_Job, false, Voyage_WO_Bulk_Move_Completed, Response_Continuous, 0);		//14.10.2024 navnk30 JIRA #12385
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showColourLegendForWOOperation" id="d3e368ef-199a-48d8-9b4d-a2b258e6cafc">
        <source>showColourLegendForWOOperation(isForUnallocatedTbl : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Sep 2023 navlc30 ChangeRequest 60211: EUP | Delivery Dispatch Colour Legend
*/

vars
	colLegend	: CMUI_ColourLegend;
begin

	create colLegend;
	colLegend.centreWindow;
	
	if isForUnallocatedTbl then
		colLegend.addLegendItem("Job Over Time Limit", Black, LightRed, null, false);
	else	
		colLegend.addLegendItem("Truck Pending Entry", Black, LightBlue, null, false);
		colLegend.addLegendItem("Job Not Started", 	   Black, LightOrange, null, false);
		colLegend.addLegendItem("Job In Progress",     Black, LightYellow, null, false);
		colLegend.addLegendItem("Job Completed", 	   Black, PaleGreen, null, false);
		colLegend.addLegendItem("Job Over Time Limit", Black, LightRed, null, false);
	endif;	
	colLegend.width   := 400;
	colLegend.height  := 150;
	colLegend.showModal;


epilog
	delete colLegend;
end;</source>
        <Parameter name="isForUnallocatedTbl" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="0675c908-c441-4752-b87b-8cd6d29aecfb">
        <source>showColumnOrganiser();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023 navma1  ChangeRequest 57878: EUP - Delivery Dispatch – Screen Design
22 May 2023 navhl20 ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
01 Jun 2023 navhl20 ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
*/

vars

begin
	if self.mnuColOrganiser.userObject = self.tblJobSheet then					//22.5.2023 navhl20 #57714[57764]
		self.tblJobSheet.showColumnOrganiserFrm(self.myTerminal,null);
	elseif self.mnuColOrganiser.userObject = self.tblJobsAllocated then
		self.tblJobsAllocated.showColumnOrganiserFrm(self.myTerminal,null);
	elseif self.mnuColOrganiser.userObject = self.tblJobsUnallocated then
		self.tblJobsUnallocated.showColumnOrganiserFrm(self.myTerminal,null);
	elseif self.mnuColOrganiser.userObject = self.tblWlesUnallocated then
		self.tblWlesUnallocated.showColumnOrganiserFrm(self.myTerminal,null);
	elseif self.mnuColOrganiser.userObject = self.tblWlesAllocated then				//01.6.2023 navhl20 #57747[57748]
		self.tblWlesAllocated.showColumnOrganiserFrm(self.myTerminal,null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showCompleteJobform" id="04524f0c-216e-4d31-ad6a-a02d3f786f11">
        <source>showCompleteJobform(_job : CM_Job);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2023 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
02 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
27 Sep 2024	navnk30	Bug 66108: MTN | WO Job Complete Permissions
*/

vars
	form	: YRD_WorkOrderCompleteJob;

begin
	form := app.loadForm(YRD_WorkOrderCompleteJob, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrderCompleteJob;
	
	if form = null then
		return;
	endif;

	if self.chkBulkMode.visible then						//02.04.2024 navhl20 #63302
		form.setIsBulkMode(self.chkBulkMode.value);
	endif;
	form.setMyJob(_job);
	form.showModal();
epilog
	if form &lt;&gt; null then		//27.09.2024 navnk30 #66108
		form.unloadForm();		//22.07.2024 navbs1 #64884
	endif;
	delete form;
end;</source>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
