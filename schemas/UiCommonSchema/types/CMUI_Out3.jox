    <JadeMethod name="noWinner" id="bfe0d738-5392-48b4-a048-a565eed50057">
        <source>noWinner() : Boolean;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
begin
	foreach idx in 1 to 9 do
		if self.positions[idx] = null then
			return false;
		endif;
	endforeach;
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setWinningLineCoords" id="0ff1f3d4-e6e6-40b2-afc3-7a30aa435032">
        <updating/>
        <source>setWinningLineCoords( _int : Integer)  : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	if _int = 123 then
		self.x1 := X1;
		self.y1 := Y1;
		self.x2 := X3;
		self.y2 := Y1;
		return true;
	elseif _int = 456 then
		self.x1 := X1;
		self.y1 := Y2;
		self.x2 := X3;
		self.y2 := Y2;
		return true;
	elseif _int = 789 then
		self.x1 := X1;
		self.y1 := Y3;
		self.x2 := X3;
		self.y2 := Y3;
		return true;
	elseif _int = 147 then
		self.x1 := X1;
		self.y1 := Y1;
		self.x2 := X1;
		self.y2 := Y3;
		return true;
	elseif _int = 258 then
		self.x1 := X2;
		self.y1 := Y1;
		self.x2 := X2;
		self.y2 := Y3;
		return true;
	elseif _int = 369 then
		self.x1 := X3;
		self.y1 := Y1;
		self.x2 := X3;
		self.y2 := Y3;
		return true;
	elseif _int = 159 then
		self.x1 := X1;
		self.y1 := Y1;
		self.x2 := X3;
		self.y2 := Y3;
		return true;
	elseif _int = 357 then
		self.x1 := X3;
		self.y1 := Y1;
		self.x2 := X1;
		self.y2 := Y3;
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_int" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testCoords" id="e12092ea-dec2-4a85-8670-61246c40bba5">
        <updating/>
        <source>testCoords() updating;
// ---------------------------------------------------------------------------
// Created:     16 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin


	self.autoRedraw := true;
	self.drawWidth := 12;
	self.drawPoint(X1,Y1, Red);
	self.drawPoint(X1,Y2, Red);
	self.drawPoint(X1,Y3, Red);

	self.drawPoint(X2,Y1, Red);
	self.drawPoint(X2,Y2, Red);
	self.drawPoint(X2,Y3, Red);

	self.drawPoint(X3,Y1, Red);
	self.drawPoint(X3,Y2, Red);
	self.drawPoint(X3,Y3, Red);

epilog

end;</source>
    </JadeMethod>
</GUIClass>
