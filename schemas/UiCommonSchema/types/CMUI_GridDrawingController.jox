    </JadeMethod>
    <JadeMethod name="canUserAccessSelf" id="acd0e289-429a-468b-a385-90d71540772c">
        <source>canUserAccessSelf() : Boolean;
// ---------------------------------------------------------------------------
// Created:     03 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

	failedDAC  :CM_DataAccessController;
	
begin

	if self.myLocationsController &lt;&gt; null then
		return self.myLocationsController.canUserAccessSelf(null, failedDAC, app.myPassport);
	endif;
	
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearAllSelectedObjects" id="b7f3bb3a-5545-4619-86b6-2e8c9b8985a1">
        <updating/>
        <source>clearAllSelectedObjects() updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSet	: ObjectSet;
	obj		: Object;
begin
	tmpSet := self.allTempObjects;
	tmpSet.clear;

	self.allSelectedObjects.copy(tmpSet);
	self.allSelectedObjects.clear;
	self.allObjectEditions.clear;
	self.stopHighlighter();
	
	foreach obj in tmpSet do
		self.drawObject(null, obj);
	endforeach;

	tmpSet.clear;

	self.allSelectedObjectsAlt.copy(tmpSet);
	self.allSelectedObjectsAlt.clear;

	foreach obj in tmpSet do
		self.drawObject(null, obj);
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="clearAllSelectedObjectsAlt" id="bb21d282-ed01-44ef-83bf-3e5786136d70">
        <updating/>
        <source>clearAllSelectedObjectsAlt() updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSet	: ObjectSet;
	obj		: Object;
begin
	tmpSet := self.allTempObjects;
	tmpSet.clear;

	self.allSelectedObjectsAlt.copy(tmpSet);
	self.allSelectedObjectsAlt.clear;

	foreach obj in tmpSet do
		self.drawObject(null, obj);
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="cloneSelf" id="80c7a662-2cf2-4741-ab7c-134a7d7fb3ed">
        <source>cloneSelf(_transient: Boolean): SelfType;
// ---------------------------------------------------------------------------
// Created:		April 2005 By cnwrs1//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theClone : SelfType;
begin
	theClone :=  inheritMethod(_transient);
	self.allDrawingAttributes.copy(theClone.allDrawingAttributes);
	return theClone;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="create" id="5eda3f5b-d2a8-4854-81b7-8a163995311b">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     13 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpRoot	: CM_Root;
begin
	create self.myDrawingAttrController transient;
	self.beginNotification(self.myDrawingAttrController, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);

	self.defaultFontName := Font_MicrosoftSansSerif;
	self.defaultFontSize := 8;

	self.labelFontName := Font_MicrosoftSansSerif;
	self.labelFontSize := 8;

	self.rowHeight	 := RowHeightDefault;
	self.columnWidth := ColumnWidthDefault;
	
	self.setScale(ScaleFactor_2, true, true);
	
	tmpRoot := app.myRoot;
	if tmpRoot &lt;&gt; null then
		tmpRoot.allDrawingAttributes.copy(self.allDrawingAttributes);
	endif;


end;</source>
