    <JadeMethod name="updateAutoWarningItemsList" id="82b39556-325d-4d9d-973f-b260ece155f1">
        <source>updateAutoWarningItemsList(_proxyObj:CMIF_BGPManagerChildren) protected;
// --------------------------------------------------------------------------------
// Created:		01 March 2006 by cnwdad1
//
// Purpose:		Updates the transient CM_AutoWarningItem objects in the AutoWarning
//				field's table, from the details on the Auto Warning controller's
//				request objects.
//
// Parameters:	_proxyObj - A reference to the proxy data object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	requestObj	: CM_AutoWarningRequest;
	itemObj		: CM_AutoWarningItem;
	tableObj	: CMUI_BGPListTable;
	rowPointer	: Integer;
	startRow	: Integer;
	maxRow		: Integer;
	
begin
	tableObj	:=	tblWarnList;
	startRow	:=	tableObj.fixedRows + 1;
	maxRow		:=	tableObj.rows;
	
	foreach rowPointer in startRow to maxRow do
		itemObj	:=	tableObj.accessRow(rowPointer).itemObject.CM_AutoWarningItem;
		
		foreach requestObj in _proxyObj.allWarningRequests do
			if requestObj.className = itemObj.className then
				itemObj.set(requestObj.minutesBeforeAlert, requestObj.alertFrequency, requestObj.className, requestObj.webSiteConfigName);
				break;
			endif;
		endforeach;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_proxyObj" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
</GUIClass>
