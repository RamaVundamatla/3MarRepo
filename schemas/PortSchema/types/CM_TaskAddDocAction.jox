    <JadeMethod name="getDisplayStringForAttribute" id="13294b08-fa5d-4846-9cf0-776a9ab41b77">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2016	cnwndl1	Initial creation

*/

vars

	lDetail : String;
	returnStr : String;

begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
		//	lDetail := app.getErrorString(TransType_185);
		//	lDetail := lDetail &amp; ": " &amp; self.todoTaskDesc &amp; " (x" &amp; self.amount.String &amp; ")";
			
			//09 Nov 2016	NDL	TFS 2928
			lDetail := app.getErrorString( TransType_185 ) &amp; ColonAndSpace &amp; self.todoTaskDesc &amp; " (x" &amp; self.amount.String &amp; ") - " &amp; self.parentDocId &amp; ", " &amp; self.documentId;
	
			return lDetail;
			
		endif;
		
	elseif _attrName = ETRow_TransactionType or _attrName = ETRow_Type then
		
		returnStr := inheritMethod(ETRow_Type, _short);
		returnStr := returnStr &amp; " " &amp; app.getErrorString(Document_action);
		
		return returnStr;
		
	elseif _attrName = ETRow_Amount then	//28 Sep 2016	NDL	TFS 2649 / 2001
		return amount.String;
		
	endif;	
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
