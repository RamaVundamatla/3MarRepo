	self.tblData.text := "Rehandles";
	self.tblData.row := 32;
	self.tblData.text := "Crane Moves";
	self.tblData.row := 34;
	self.tblData.text := "Import O/D O/H";
	self.tblData.row := 36;
	self.tblData.text := "Export O/D O/H";
	self.tblData.row := 38;
	self.tblData.text := "Rehandle O/D O/H";
	self.tblData.row := 40;
	self.tblData.text := "Shift O/D O/H";
	self.tblData.row := 42;
	self.tblData.text := "Lash (with Cage)";
	self.tblData.row := 43;
	self.tblData.text := "Lash (without Cage)";
	self.tblData.row := 44;
	self.tblData.text := "Surcharge (Late Rcv)";
	self.tblData.row := 46;
	self.tblData.text := "Hatchcover Moves";
	self.tblData.row := 47;
	self.tblData.text := "Hatch Cover Moves (&lt;5)";
	self.tblData.row := 48;
	self.tblData.text := "Timber Packs Loaded";
	self.tblData.row := 49;
	self.tblData.text := "BB Items Loaded";
	self.tblData.row := 50;
	self.tblData.text := "BB Items Discharged";
	self.tblData.row := 51;
	self.tblData.text := "Sunday Shifts Worked";
	self.tblData.row := 52;
	self.tblData.text := "Holiday Shifts Worked";
	self.tblData.row := 53;
	self.tblData.text := "Crane Labour Splits";
	self.tblData.row := 54;
	self.tblData.text := "3rd Shift Surcharge";
	self.tblData.row := 55;
	self.tblData.text := "Meat rebate";

	self.tblData.column := 2;
	i := 2;
	while i &lt; 42 do
		self.tblData.row := i;
		if i mod 2 &gt; 0 then
			self.tblData.text := "40'";
		else
			self.tblData.text := "20'";
		endif;
		i := i + 1;
	endwhile;
	self.tblData.row := 44;
	self.tblData.text := "20'";
	self.tblData.row := 45;
	self.tblData.text := "40'";

end;</source>
