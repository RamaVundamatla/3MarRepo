    <JadeMethod name="verifyAll" id="494fff08-e1a9-420f-a238-a03a2b16db35">
        <updating/>
        <source>verifyAll() updating;
//
// par 26223 30 Nov 2010 
//
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 29 Nov 2017	jlgrs1	TFS 5705A - SNO - EDIDataBooking Prenote release Req
vars

begin
	app.myPassport.clearErrorsWarnings();
	if self.allErrorWarnings.size &gt; 0 then
		beginTransaction;
		self.allErrorWarnings.purge();
		commitTransaction;
	endif;
	self.verifyEDIDataTIs(app.myPassport);
	
	// status gets set in CM_EDIDataGateDoc processEDITIs
end;
</source>
    </JadeMethod>
