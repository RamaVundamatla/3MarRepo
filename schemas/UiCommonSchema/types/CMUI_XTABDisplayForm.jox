    <JadeMethod name="mnuPopupCargoEnquiry_click" id="65c2ad99-8488-4cc1-a376-dd8baff90fc5">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuPopupCargoEnquiry_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     03 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30 Nov 2009	NDL			CCMS 1028 - allow for bookings and bookimg items
// 16/12/2009	cnwcs5		ccms 1023 - summary snapshots
// 09/08/2010	cnwcs5		par 23706 - small optimisation
// ---------------------------------------------------------------------------
vars

	coll 			: Collection;
	firstObj,obj	: Object;
	any				: Any;
	tiSet : ObjectSet;
	ti : CM_TrackedItem;
	iter : Iterator;
begin
	// Use self.myCollectionForDrillDown as we know it was populated during 
	// the contextMenu event
	//coll := self.getCollectionForDrillDown;
	coll := self.myCollectionForDrillDown;		// 09/08/2010 cnwcs5 par 23706 
	
	if coll = null or coll.isEmpty then
		return;
	endif;

	firstObj := coll.first.Object;
// cnwcs5 16/12/2009 - start	
	if firstObj.isKindOf (CM_DynamicObject_Snapshot) then
		self.getSnapshotObjectsFromColl (coll);
		
		if self.mySnapshotDrillDownColl.isEmpty then
			return;
		endif;
		
		coll 		:= self.mySnapshotDrillDownColl;
		firstObj	:= coll.first.Object;
	endif;
// cnwcs5 16/12/2009 - finish

	//07 Nov 2013	NDL	Par 32654
	if firstObj.isKindOf(CM_TITransaction) then
		create tiSet transient;
		iter := coll.createIterator;
		while iter.next( obj ) do
			if obj.isKindOf(CM_TITransaction) then
				ti := obj.CM_TITransaction.myTrackedItem;
				tiSet.addNoDuplicates (ti, false);
			endif;
		endwhile;
		if tiSet.isEmpty then
			return;
		else
			coll := tiSet;
			firstObj := coll.first.Object;
		endif;
	endif;
	
	if firstObj.isKindOf(CM_TrackedItem) then
		self.doCargoEnquiry(coll);
	elseif firstObj.isKindOf(CM_BookingRef) or firstObj.isKindOf(CM_BookingRefItem) then
		self.doBookingEnquiry(coll);
	endif;
	
epilog

	delete iter;
	delete tiSet;
	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuPopupSendTo_click" id="7d2c5e7b-5908-4609-996f-4d43fa4ed74e">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuPopupSendTo_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     02 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/12/2009	cnwcs5		ccms 1023 - snapshot summaries
// 09/08/2010	cnwcs5		par 23706 - small optimisation
// ---------------------------------------------------------------------------
vars
	coll	:Collection;
begin
	// Use self.myCollectionForDrillDown as we know it was populated during 
	// the contextMenu event
	//coll := self.getCollectionForDrillDown;
	coll := self.myCollectionForDrillDown;		// 09/08/2010 cnwcs5 par 23706 
	
	// cnwcs5 16/12/2009 - start	
	if self.myProxyOutputFormat.isSnapshotMode then
		self.getSnapshotObjectsFromColl (coll);
		
		if self.mySnapshotDrillDownColl.isEmpty then
			return;
		endif;
		
		coll := self.mySnapshotDrillDownColl; 
	endif;
// cnwcs5 16/12/2009 - finish

	self.doSendToScreen_ShowPopup (coll, null, tblScreens, self.allDefaultForms);
epilog
	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
