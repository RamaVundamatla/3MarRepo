    <JadeMethod name="mnuCreateReefJobSelected_click" id="07a0e410-90eb-4d70-946d-80055b6fe5fe">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCreateReefJobSelected_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2025	navsp1	Initial creation JIRA-34514

*/

vars
	form : YRD_ReeferJobAdd;
    obj  : Object;
begin
    form := app.loadForm(YRD_ReeferJobAdd, CMUI_Assistant, false, false, true, self.myTerminal, null).YRD_ReeferJobAdd;
	if form &lt;&gt; null then
        foreach obj in self.tblData.allSelectedObjects do
			if obj.isKindOf(CM_TrackedItem) and obj.CM_TrackedItem.isReefer then
				form.allDisplayedReefers.add( obj.CM_TrackedItem );
			endif;
		endforeach;
        
		form.show;
	endif;
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
