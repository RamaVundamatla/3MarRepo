        <source>unload() updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod();
	delete self.myPxySegregationCond;
	if self.mySegregationMatrixAgent &lt;&gt; null then
		self.mySegregationMatrixAgent.allSegMatrixTransByRowCol.purge();
	endif;
	
	delete self.mySegregationMatrixAgent;
end;


</source>
