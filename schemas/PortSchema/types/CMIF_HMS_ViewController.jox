    <JadeMethod name="voyage_AddToRange" id="e84aca27-2783-4591-af1f-76f791f531bc">
        <updating/>
        <source>voyage_AddToRange(_hmsVoyage : HMS_VoyageData) : CMIF_HMS_WorkingVoyage updating;
//--------------------------------------------------
// Created:	08 July 2005 By: cnwgd1
//--------------------------------------------------
vars
begin
	return self.voyage_AddToView(_hmsVoyage);
end;</source>
        <Parameter name="_hmsVoyage" type="HMS_VoyageData"/>
        <ReturnType type="CMIF_HMS_WorkingVoyage"/>
