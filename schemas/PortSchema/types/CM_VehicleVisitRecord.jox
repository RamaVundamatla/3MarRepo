    <JadeMethod name="getAllGateEntities" id="53b9149d-7bd7-43bd-b443-62a86f501211">
        <source>getAllGateEntities():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	gte : CMGTE_Entity;
	oidStrings : String;

begin

	foreach gte in self.allGateEntities discreteLock do
		if oidStrings = "" then		
			oidStrings := gte.getOidString; 
		else
			oidStrings := oidStrings &amp; "," &amp; gte.getOidString; 
		endif;
	endforeach;
	
	return oidStrings;

epilog

end;</source>
