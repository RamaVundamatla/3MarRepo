    <JadeMethod name="setupCargo" id="8ef3a5f6-fd17-4b9a-8878-920c347ed1d2">
        <updating/>
        <source>setupCargo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005
30 Aug     2016 TFS #2597:PEN - Truck Warehouse Release Loader not showing all Rel Req lines

*/

vars
	requestCount : Integer;
	request : CM_Request;
	wle : CM_WorkListEntry;
	allCargoTextboxes : ObjectArray;
	textbox : TextBox;
	addTIs : Boolean;
	ti : CM_TrackedItem;
	allReservesWithCargoLoader : ObjectSet;
begin
	self.lblRelease.caption:=self.getReserveDesciption;
	self.clearFields;
	if  self.myMobileGenericAgent.allConfirmedTis &lt;&gt; null then
		if self.myMobileGenericAgent.allConfirmedTis.size &gt; 0 then
			self.myCargo1:=self.myMobileGenericAgent.allConfirmedTis[1];
		endif;
		if self.myMobileGenericAgent.allConfirmedTis.size &gt; 1 then
			self.myCargo2:=self.myMobileGenericAgent.allConfirmedTis[2];
		endif;
	endif;
	
	self.setupOnTruck();
	
	
	create allCargoTextboxes transient;
	allCargoTextboxes.add(self.txtCargo1);
	allCargoTextboxes.add(self.txtCargo2);
	
	//epr TFS 3094 9/12/16
	create allReservesWithCargoLoader transient;
	allMatchingTIs.clear;
	
	foreach wle in self.myMobileGenericAgent.allWlesToLoad do	
		if wle.status = WLE_COMPLETED then
			continue;
		endif;
		request:=wle.myRequest;
	
		if request.isComplete then
			continue;
		endif;
			
		//epr TFS 3094 9/12/16
		if request.myReserveDetail.isKindOf(CM_ReserveSelection) and not allReservesWithCargoLoader.includes(request.myReserveDetail) then
			request.myReserveDetail.CM_ReserveSelection.getAllCargoMatchingRelease(self.allMatchingTIs,self.minCargoLength);
			allReservesWithCargoLoader.add(request.myReserveDetail);
		endif;
		
		ti  :=  wle.myTrackedItem;
		if  ti &lt;&gt; null then
			if self.minCargoLength = 0 then
				self.minCargoLength:=ti.id.length;
			else
				self.minCargoLength:=self.minCargoLength.min(ti.id.length);
			endif;
			//epr TFS 5719 28/8/17
			allMatchingTIs.addNoDuplicates(ti,false);
		endif;
		
		if requestCount = 2 then
			
			continue;
		endif;
			
		requestCount :=requestCount +1;
		
		textbox:=allCargoTextboxes[requestCount].TextBox;
		textbox.visible:=true;
		if requestCount = 1 then
			self.myWLE1:=wle;
		else
			self.myWLE2:=wle;
		endif;
				
		if app.myMobileCargoFindAgent.myTrackedItemToProcess &lt;&gt; null and wle = app.myMobileCargoFindAgent.myWLE then
			if requestCount = 1 then
				self.myCargo1 :=app.myMobileCargoFindAgent.myTrackedItemToProcess ;
			else
				self.myCargo2 :=app.myMobileCargoFindAgent.myTrackedItemToProcess ;
			endif;
		endif;
		
		if  requestCount = 1 and self.myCargo1 &lt;&gt; null then
			textbox.text:=self.myCargo1.id;
			textbox.lostFocus(textbox);
		endif;
		
		if requestCount = 2 and self.myCargo2 &lt;&gt; null then
			textbox.text:=self.myCargo2.id;
			textbox.lostFocus(textbox);
		endif;
	endforeach;
	
	self.lblCargo2.visible:= self.txtCargo2.visible;
	
	self.showAmounts();
	self.setupForNotifications();
	self.doResizeControls(true);
	
	self.shtInYard.setFocus();
	self.txtCargo1.setFocus();
epilog
	delete allCargoTextboxes;
	delete allReservesWithCargoLoader;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForNotifications" id="2ae82855-fcb3-47c6-8117-331f481b6bf0">
        <source>setupForNotifications() protected;
/*

Date		Who		Reason
22 September 2015	cnwer1	Initial creation PAR

*/

vars
	obj : Object;	
	wle : CM_WorkListEntry;
begin
	
	self.endNotifications();
	foreach wle in self.myMobileGenericAgent.allLoadedWles do
		self.beginNotification( wle, wle.getMyTerminal.getTerminalEvent(WLE_Status_Event), Response_Continuous, 0 );
	endforeach;
	
	foreach wle in self.myMobileGenericAgent.allWlesToLoad do
		self.beginNotification( wle, wle.getMyTerminal.getTerminalEvent(WLE_Status_Event), Response_Continuous, 0 );
	endforeach;
	

	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1fa8b8c7-d8e9-4dfa-8313-fecb8b2830f4">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	truck : CM_Vehicle;
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	truck := self.myMobileGenericAgent.myTruck;

	if truck &lt;&gt; null then
		self.caption := self.caption &amp; " " &amp; truck.getDisplayDetails(true);
	endif;
	
	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Complete), app.getErrorString(Back), null, null, null );
	self.lblCargo1.foreColor:=Blue;
	self.lblCargo2.foreColor:=Blue;
		
	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;	
	
	self.setupCargo();
	
	app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
	app.myMobileCargoFindAgent.setMyWLE(null);
	
	
	
	//self.txtDoor.text:= self.myHandHeldCheckerAgent.stringField1;
	

	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupMoveController" id="5fed0a03-6559-49e3-b730-6367fc77de7b">
        <source>setupMoveController(_allMoveControllers : ObjectSet input;
					_cargo : CM_TrackedItem input) : CMIF_MoveController protected;
/*

Date		Who		Reason
07 October 2015	cnwer1	Initial creation PAR
30 Aug     2016 TFS #2597:PEN - Truck Warehouse Release Loader not showing all Rel Req lines
22 Aug	2017	cnwma1	TFS #5673 PAR38692 PEN - More cargo allowed to be selected than on the release request.
*/

vars
	
	moveController : CMIF_MoveController;
	usedWLE, 
	wle : CM_WorkListEntry;
	reason : String;
	cargoId : String;
begin
	
	create moveController transient;
	//epr TFS 3094 9/12/16
	if _allMoveControllers.size = 1 then
		usedWLE:= _allMoveControllers.first.CMIF_MoveController.myWorkListEntry;
	endif;
	
	foreach wle in 	self.myMobileGenericAgent.allWlesToLoad discreteLock do  //30/08/2016 cnwma1 TFS #2597
		if usedWLE &lt;&gt; null and wle = usedWLE then
			continue;
		endif;
		
		
		if wle.myRequest.myReserveDetail.isKindOf(CM_ReserveSelection) then 
			if _cargo.testAgainstReserveSelection(wle.myRequest.myReserveDetail.CM_ReserveSelection,reason,true, null) then
				moveController.setMyWorkListEntry(wle);
				break;
			endif;
		else
			if wle.myTrackedItem = _cargo then
				moveController.setMyWorkListEntry(wle);
				break;
			endif;
		
		endif;
	endforeach;
	
	if moveController.myWorkListEntry &lt;&gt; null then    //22.08.2017 TFS #5673
		moveController.setMyToPrimaryLocation(self.myMobileGenericAgent.myTruck.getMyVehicleMachineController); //set to location will move the cargo in trx
		moveController.setMyTrackedItem(_cargo);
	
		_allMoveControllers.add(moveController);
		return moveController;
	else
		if _cargo &lt;&gt; null then
			cargoId := _cargo.id;
		endif;
		app.myPassport.clearErrorsWarnings;
		self.msgBox(app.getErrorString1(Follo_cargo_item_will_not_load,cargoId),app.getErrorString(Warning),MsgBox_OK_Only,true);
		return null;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allMoveControllers" type="ObjectSet" usage="input"/>
        <Parameter name="_cargo" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="setupOnTruck" id="48ee1794-ace6-4c49-8d99-a752b7f2cc3a">
        <updating/>
        <source>setupOnTruck() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005
22 May 2013	NDL	- CCMS 2274 Break Bulk
*/

constants

	TAB_INDEX_START = 1000;
	
vars

	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	tiArray: CM_TIArray;
	ti : CM_TrackedItem;
	size : Integer;
	buttonHeight : Integer;	
begin

	self.myMobileGenericAgent.setTruckCollections(self.myMobileGenericAgent.myReserveSelection &lt;&gt; null);
	//if self.myHandHeldCheckerAgent.myReserveSelection = null then
	//	self.myHandHeldCheckerAgent.myTruck.getCurrentRoadJob.getWLEsMatchingReserveDetail(
	//endif;
	
	
	tiArray := self.myMobileGenericAgent.allLoadedTis;
	size := tiArray.size;
	
	while self.onTruckButtonCount &gt; size do
		menuButton:= self.btnOnTruckTemp.getControl(self.onTruckButtonCount).MOB_Button;
		if menuButton &lt;&gt; null then
			delete menuButton;
		endif;
		self.onTruckButtonCount:=self.onTruckButtonCount -1;
	endwhile;
	
	buttonHeight := self.getScrollingButtonHeight();
	self.btnOnTruckTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmCargoOnTruck, self.btnOnTruckTemp.height, self.scrCargoOnTruck );

	self.onTruckButtonCount := 0;
	foreach ti in tiArray do
		
		buttonNumber := buttonNumber + 1;
		menuButton:= self.btnOnTruckTemp.getControl(buttonNumber).MOB_Button;
		if menuButton = null then
			menuButton := self.btnOnTruckTemp.loadControl( buttonNumber ).MOB_Button;
		endif;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" ;
		elseif ti.isBulkByWeight and ti.isBulkByVolume then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")"; 
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id ;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, CrLf ); //30 May 2017	NDL	TFS 4587
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
	endforeach;
	
	self.onTruckButtonCount := buttonNumber;
	
	self.btnOnTruckTemp.visible := false;
	self.frmCargoOnTruck.caption := null;
	
	if size = 0 then
		lblNoCargoTruck.visible := true;
	else
		lblNoCargoTruck.visible := false;
	endif;
	
epilog


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showAmounts" id="953a4697-0650-4b37-9fa6-314645d9850a">
        <source>showAmounts() protected;
/*

Date		Who		Reason
15 September 2015	cnwer1	Initial creation PAR

*/

vars
	truck : CM_Vehicle;
	ti : CM_TrackedItem;
	weight : Decimal[14,4];
	totWeight : Decimal[18,4];
begin
	truck := self.myMobileGenericAgent.myTruck;
	
	if truck = null then
		lblWeightValue.caption := app.getErrorString(CM_Load_Weight) &amp; " : ";
		lblCountValue.caption := app.getErrorString(Count) &amp; " : ";
	else
		foreach ti in self.myMobileGenericAgent.allLoadedTis do
			weight := ti.totalWeight;
			totWeight := totWeight + weight;
		endforeach;
		lblWeightValue.caption := app.getErrorString(CM_Load_Weight) &amp; " : " &amp; self.myMobileDataAgent.getMeasureConvertedForDisplay(null,Type_Weight,totWeight) &amp; self.myMobileDataAgent.getMeasureLabelUnit(null,Type_Weight);
		lblCountValue.caption := app.getErrorString(Count) &amp; " : " &amp; self.myMobileGenericAgent.getOnTruckCargoCount().String;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0af1e88f-c508-4e44-8b9e-89b3ac3e8746">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 September 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020920, locale);
	//btnOnTruckTemp.translateCaption(Xlat_0020973, locale);
	//frmCargoOnTruck.translateCaption(Xlat_0020974, locale);
	//lblCountValue.translateCaption(Xlat_0020975, locale);
	lblDoor.translateCaption(Xlat_0020950, locale);
	//lblNoCargoTruck.translateCaption(Xlat_0020977, locale);
	//lblWeightValue.translateCaption(Xlat_0020978, locale);
	shtInYard.translateCaption(Xlat_0020960, locale);
	shtOnTruck.translateCaption(Xlat_0020929, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargo1_change" id="6140280c-1978-45bf-bf70-4739f7fc0671">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargo1_change(textbox: TextBox input) updating;
/*

Date		Who		Reason
14 September 2015	cnwer1	Initial creation PAR

*/

vars
	cargoId : String;
begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275
	
	cargoId:=textbox.text;
	if cargoId.length &lt; self.minCargoLength then
		self.myCargo1:=null;
		return;
	endif;
	
	self.myCargo1:=self.getMatchingCargo(cargoId, self.myWLE1,false);
	
	if self.myCargo1 &lt;&gt; null then
		
		if self.txtCargo2.visible then
			txtCargo2.setFocus();
		else
			if self.txtDoor.text = null then
				self.txtDoor.setFocus();		
			else
				self.btnOne.setFocus();			
			endif;
		endif;
	endif;
	
epilog
	
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargo1_lostFocus" id="b0c7938b-3e58-4e3f-a135-5f46d49c32f7">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargo1_lostFocus(textbox: TextBox input) updating;
/*

Date		Who		Reason
16 September 2015	cnwer1	Initial creation PAR

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275
	
	if textbox.text.trimBlanks &lt;&gt; null and (self.myCargo1 = null or self.myCargo1.id &lt;&gt; textbox.text.trimBlanks) then
		self.myCargo1:=self.getMatchingCargo(textbox.text.trimBlanks,self.myWLE1,true);
	endif;
	
	if self.myCargo1 &lt;&gt; null then
		self.lblCargo1.caption:= self.myCargo1.getProductOrISODescr &amp; " " &amp;  self.myCargo1.getPrimaryLocationId(REAL_MODE);
	else
		self.lblCargo1.caption:=null;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
