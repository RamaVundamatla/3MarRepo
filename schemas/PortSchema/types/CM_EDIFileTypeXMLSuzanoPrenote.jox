vars

begin
	
	return self.EDI_Bundle_SUZANO;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="b2a4eb3d-f1dc-435a-8c25-bbad40229554">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
//----------------------------------------------------------------
//11 Jul 2014	cnwrs1	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
//01 Oct 2014	cnwgb1	par 34883 Changes to Specification
//15 Oct 2014   cnwgb1  par 35050 Quantities and Weights
//11 Nov 2014   cnwgb1  PAr 35122 Zero Supress the Cargo Sub Types    
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//16 Apr 2015	cnwrs1	Par 36065 Check cargotype and subtype
//17 Apr 2015	cnwgb1	Par 35988 Imex status not being set correctly  
//04 Sep 2015	cnwrs1	Par 36865 dont create multiple EDI File Received if file reloaded
//----------------------------------------------------------------
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	ediPrenote : CM_EDIPrenoteTI;
	operator : CM_Operator;
	operatorCode : String;
	message	: String;
	ediData	: CM_EDIData;
	passport : CM_Passport;
	terminal : CM_Terminal;
	xmlDoc : CM_XMLDocument;
	xmlElement1 : JadeXMLElement;
	xmlElement2 : JadeXMLElement;
	xmlElement3 : JadeXMLElement;
	xmlElement4 : JadeXMLElement;
	subXMLElement1 : JadeXMLElement;
	subXMLElement2 : JadeXMLElement;
	subXMLElement3 : JadeXMLElement;
	theXMLStr : String;
	bolID : String;
	contID : String;
	sealNum : String;
	barCode : String;
	dataType : Integer;
	elements : JadeXMLElementArray;
	subElements1 : JadeXMLElementArray;
	subElements2 : JadeXMLElementArray;
	subCargoTypeStr : String;
	subCargoTypeCode : String;
	subCargoType : CM_Product;
	cargoType : CM_CargoType;
	cargoTypeStr : String;
	cargoTypeId : Integer;
	ediDataTypes : IntegerArray;
	found : Boolean;
	thisPort : String;
	commodity : String;
	newEvent : CMEVT_EDIFileReceived;
	fileID : String;
	itemOrder : String;
	volumn : String;
	orderNumber : String;
	invoiceNumber : String; // cnwgb1 PAR 34883 1.10.2014
	id : String;
    shippingID : String; // cnwgb1 PAR 34883 1.10.2014
	mtCmdty, defCmdty, refCmdty, hazCmdty : String;	//01 Mar 2021	NDL	TFS 50740
	cmifEventCtrl : CMIF_EDIFileReceiveEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	passport := app.myPassport;	
	terminal := passport.myTerminal;
	operatorCode := app.myRoot.getXlationSystemCode("SUZANO", XLATION_TYPE_OPERATOR, found);
	operator := app.myRoot.allOperators[operatorCode];
	ediData := _ediFile.ediData;
	thisPort := terminal.getConfig(PortDestCode).String;
	app.getTerminalDefCmdty( mtCmdty, defCmdty, refCmdty, hazCmdty );	//01 Mar 2021	NDL	TFS 50740
//	commodity := terminal.getConfig(DefCommodity).String;
	commodity := defCmdty;	//01 Mar 2021	NDL	TFS 50740
	create xmlDoc transient;
	create elements transient;
	create subElements1 transient;
	create subElements2 transient;
	create ediDataTypes transient;

 
	if passport.myCMIFMonitor &lt;&gt; null then
		passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", 4, 3, "Loading EDI file Step 3 of 3.");
	endif;
	message := _ediFile.getRawDataString();
	//Actually process the XML
    theXMLStr := message.extractXML();
    if theXMLStr &lt;&gt; null then
		ediData.getEDIChildDataTypes(ediDataTypes);
		foreach dataType in ediDataTypes do
			if dataType &lt;&gt; EDIDataType_Prenote then
				continue;
			endif;
			xmlDoc.parseString(theXMLStr);
			xmlElement2 := xmlDoc.getElementByTagName("ID");
			if xmlElement2 &lt;&gt; null then
				fileID := xmlElement2.textData;
			endif;
			xmlElement2 := xmlDoc.getElementByTagName("Shipping_ID");
			if xmlElement2 &lt;&gt; null then
				shippingID := xmlElement2.textData;
			endif;
			xmlElement2 := xmlDoc.getElementByTagName("Bill_Lading");
			if xmlElement2 &lt;&gt; null then
				bolID := xmlElement2.textData;
			endif;
			xmlDoc.findElementsByTagName("PackList", elements);
			foreach xmlElement1 in elements do
				xmlElement2 := xmlElement1.getElementByTagName("Order_Number");
				if xmlElement2 &lt;&gt; null then
					orderNumber := xmlElement2.textData;
				endif;
				xmlElement2 := xmlElement1.getElementByTagName("Invoice_Number");
				if xmlElement2 &lt;&gt; null then
					invoiceNumber := xmlElement2.textData;
				endif;
				xmlElement2 := xmlElement1.getElementByTagName("Transport_ID");
				if xmlElement2 &lt;&gt; null then
					contID := xmlElement2.textData;
				endif;
				xmlElement2 := xmlElement1.getElementByTagName("Stuffing");
				if xmlElement2 &lt;&gt; null then
					xmlElement3 := xmlElement2.getElementByTagName("Seals");
					if xmlElement3 &lt;&gt; null then
						xmlElement4 := xmlElement3.getElementByTagName("Seal");
						if xmlElement4 &lt;&gt; null then
							sealNum := xmlElement4.textData;
						endif;
					endif;
				endif;
				xmlElement1.getElementsByTagName("Detail", subElements1);
				foreach subXMLElement1 in subElements1 do
					if subXMLElement1 &lt;&gt; null then
						xmlElement2 := subXMLElement1.getElementByTagName("Material_Type");
						if xmlElement2 &lt;&gt; null then
							cargoTypeStr := xmlElement2.textData;
							if cargoTypeStr &lt;&gt; null then
								cargoType := app.myRoot.allCargoTypesById[cargoTypeStr.Integer];
								if cargoType = null then
									cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(cargoTypeStr);
								endif;
								if cargoType &lt;&gt; null then
									cargoTypeId := cargoType.id;
								endif;
								if cargoTypeId = null then
									if operator &lt;&gt; null then
										cargoTypeId := operator.getXlationSystemCode(cargoTypeStr, XLATION_TYPE_CARGOTYPE_BYOP, found).Integer;
									endif;
								endif;
							endif;
						endif;
						xmlElement2 := subXMLElement1.getElementByTagName("Material_Code");
						if xmlElement2 &lt;&gt; null then
							subCargoTypeStr := xmlElement2.textData;
							if subCargoTypeStr &lt;&gt; null then
								cargoType := app.myRoot.allCargoTypesById[cargoTypeId];
								if cargoType &lt;&gt; null then
									subCargoType := cargoType.getProductFromCode(subCargoTypeStr);
									if subCargoType = null then
										subCargoType := cargoType.getProductFromCode(subCargoTypeStr.asIntegerJMT().asStringJMT());
									endif;
								endif;
								if subCargoType &lt;&gt; null then
									subCargoTypeCode := subCargoType.code;
								endif;
								if subCargoTypeCode = null then
									if operator &lt;&gt; null then
										subCargoTypeStr := xmlElement2.textData.asIntegerJMT().asStringJMT();  //35122 24.10.2014 cnwgb1
										subCargoTypeCode := operator.getXlationSystemCode_CargoSubT(subCargoTypeStr, cargoType, found);
									endif;
								endif;
							endif;
						endif;
						xmlElement2 := subXMLElement1.getElementByTagName("Item_Order");
						if xmlElement2 &lt;&gt; null then
							itemOrder := xmlElement2.textData;
						endif;
						subXMLElement1.getElementsByTagName("Batches", subElements2);
						foreach subXMLElement2 in subElements2 do
							xmlElement2 := subXMLElement2.getElementByTagName("Volumn");
							if xmlElement2 &lt;&gt; null then
								volumn := xmlElement2.textData;
							endif;
							xmlElement2 := subXMLElement2.getElementByTagName("BarCode");
							if xmlElement2 &lt;&gt; null then
								barCode := xmlElement2.textData;
								create ediPrenote persistent;
								ediPrenote.setForCreateNew(ediData);
								id := orderNumber.Integer.String.padZeros(9)&amp;'-'&amp;itemOrder.Integer.String.padZeros(5)&amp;'-'&amp;volumn.Integer.String.padZeros(4);
								ediPrenote.setId(id);
								ediPrenote.alternativeId := barCode[1:30];
								ediPrenote.setCargoType(cargoTypeId);
								ediPrenote.product := subCargoTypeCode;
								ediPrenote.bol := bolID;
								ediPrenote.operatorCode := operatorCode[1:4];
								ediPrenote.dischargePort := thisPort;
								ediPrenote.imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE].description;//cnwgb1 17.4.2015 PAR 35988
								ediPrenote.orderNumber := orderNumber;
								ediPrenote.invoiceNumber := invoiceNumber;
                                ediPrenote.clientRef := contID; // PAR 34883 cnwgb1 23.9.2014
                                ediPrenote.remarks := shippingID; // PAR 34883 cnwgb1 1.
							endif;
							xmlElement2 := subXMLElement2.getElementByTagName("Gross_weight");
							if xmlElement2 &lt;&gt; null then
								ediPrenote.weight := xmlElement2.textData.Integer; //*0.453592; //Par 35050 cnwgb1 15.10.2014 It turns out weight is in kg!
							endif;
                            subXMLElement3 := subXMLElement2.getElementByTagName("Batch_Caract");
                            if subXMLElement3 &lt;&gt; null then
                                xmlElement3 := subXMLElement3.getElementByTagName("Box_Quant"); //Par 35050 cnwgb1 15.10.2014
                                if xmlElement3 &lt;&gt; null then
                                    ediPrenote.productQuantity := xmlElement3.textData.Integer;
                                endif;
                            endif;
							// 06 Dec 2018	jlgrs1	DFH TFS 42379
							 xmlElement2 := subXMLElement2.getElementByTagName("Net_weight");
							if xmlElement2 &lt;&gt; null then
								ediPrenote.cargoWeight := xmlElement2.textData.Integer; 
							endif;
  						endforeach;
					endif;
				endforeach;
			endforeach;
		endforeach;
	endif;
	
    // Create Event for the Ack to be sent
	if not self.findEDIFileReceivedEvent(fileID, _ediFile, terminal) then
		/* //17/02/2025	navkc1 JIRA Bug MTN-33582
		newEvent := app.createEvent(EVT_EDIFileReceived, app.actualTimeServer, terminal, app.myPassport.userCode, false, false, 0).CMEVT_EDIFileReceived;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if newEvent &lt;&gt; null then
			newEvent.set(app.actualTimeServer, fileID, self.type);// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		*/
		
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - Starts
		create cmifEventCtrl transient;
		cmifEventCtrl.type := EVT_EDIFileReceived;
		cmifEventCtrl.dateTime := app.actualTimeServer();
		cmifEventCtrl.myTerminal := terminal;
		cmifEventCtrl.userCode := app.myPassport.userCode;
		cmifEventCtrl.dateTimeReceived := app.actualTimeServer();
		cmifEventCtrl.fileNumber := fileID;
		cmifEventCtrl.fileType := self.type;
		
		newEvent := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_EDIFileReceived;
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - Ends
	endif;
epilog
	delete xmlDoc;
	delete elements;
	delete subElements1;
	delete subElements2;
	delete ediDataTypes;
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
