    <JadeMethod name="auditId" id="46c7ff49-5edb-461d-b4e0-891ccf0a8d53">
        <source>auditId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2019	jlgndl1	Initial creation	TFS 47013

*/

vars

	invalidObject : Boolean;
	edition : Integer;

begin

	if self.rate &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, self.rate, invalidObject );
		edition := self.rate.edition;
		if invalidObject then
			return null;
		endif;
		return self.rate.getCode();
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="auditIdDisplay" id="b190df64-8d70-42fd-8f5f-789510e22d87">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2019	jlgndl1	Initial creation	TFS 47013

*/

vars

	returnStr : String;

begin

	if self.auditId() &lt;&gt; null then
		returnStr := self.rate.auditIdDisplay()
					&amp; Space &amp; app.getErrorString(CM_Service_GC) &amp; ": " &amp; self.rate.service.name
					&amp; Space &amp; app.getErrorString(CM_Start) &amp; ": " &amp; app.systemToLocalTime( self.startTimestamp).cnFormat_DDMMYY_hhmm();
				
		return returnStr;
					
	else
		return app.getErrorString(INV_Rate_Entry);
		
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
