    <JadeMethod name="drawHotspot" id="77f4407e-88b7-43b5-b278-8a50a01647d0">
        <updating/>
        <source>drawHotspot(pControl:Control;pColour:Integer)updating, protected;

vars

begin
	first := false;
	picBackground.clearGraphics;
	picBackground.drawWidth		:= 4;
	picBackground.drawFillStyle := DrawFillStyle_Transparent;		
	picBackground.drawEllipse(pControl.left,pControl.top,pControl.left + pControl.width,pControl.top + pControl.height,pColour);
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="Control"/>
        <Parameter name="pColour" type="Integer"/>
    </JadeMethod>
