    <JadeMethod name="getPriorDetail" id="0f07bb69-4fab-45d4-b5b5-5d0499d2d526">
        <source>getPriorDetail() : CM_GlobalProcessDetail;
// ---------------------------------------------------------------------------
// Created:     16 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	priorDtl	: CM_GlobalProcessDetail;
	iter	: Iterator;
	idx		: Integer;
begin

	idx := self.myGlobalProcessRoot.allGlobalProcessDetails.indexOf(self);
	idx := idx - 1;
	if idx &lt;= 0 then
		return null;
	endif;
	


	iter := self.myGlobalProcessRoot.allGlobalProcessDetails.createIterator;
	iter.startAtIndex(idx);
	iter.next(priorDtl);
	
	return priorDtl;

epilog
	delete iter;
end;</source>
        <ReturnType type="CM_GlobalProcessDetail"/>
    </JadeMethod>
    <JadeMethod name="getStats" id="dee1d4b3-2545-43e2-9e1e-719e9a490229">
        <updating/>
        <source>getStats() updating, protected;
/*
------------------------------------------------------------------------
Created:			16 October 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
4/12/2014		cnwjre1			35315 Integer overflow in getStatistics when server up for a long time, changed to Integer64
---------------------------------------------------------------------------
*/
vars
	pvDet : CM_GlobalProcessDetail;
begin
	system.getStatistics64(self.statsNumCommittedTrans, 
											self.statsNumAbortedTrans, 
											self.statsGetObjects, 
											self.statsQueuedLocks, 
											self.statsCreateObjects, 
											self.statsDeleteObjects, 
											self.statsUpdateObjects, 
											self.statsLockObjects, 
											self.statsUnlockObjects, 
											self.statsBeginNotes,
											self.statsEndNotes,
											self.statsDeliveredNotes,
											self.statsServerExecutions);
	
	pvDet := self.myPreviousDetail;
	if pvDet = null then
		return;
	endif;
	//------------------------
	//Set the difference in minutes between this sample, and the previous one.
	//We use this heavily for the average calcs.
	//------------------------
	self.sampleTimeDifference := pvDet.sampledDT.minutesDiff(self.sampledDT);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="numAvailableDev" id="b181bf2d-ec30-4718-bf8f-ba671a098acf">
