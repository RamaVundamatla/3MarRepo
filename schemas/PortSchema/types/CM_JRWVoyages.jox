    <JadeMethod name="delete" id="46a4ed75-f886-4a51-a48a-c598d74f15b9">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 March 2017	cnwma1	Initial creation

*/

vars

begin
	if self.allCMIFVoyageActivity &lt;&gt; null then
		self.allCMIFVoyageActivity.purge();
	endif;
	
	if self.allCMIFUnloadsDetails &lt;&gt; null then
		self.allCMIFUnloadsDetails.purge();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getArriveTsFromLocalTZ" id="db2176fc-5738-4d38-9952-2499eca86860">
        <source>getArriveTsFromLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.arriveTsFrom);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
