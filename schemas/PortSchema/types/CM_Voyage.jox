    <JadeMethod name="setMyTerminal" id="1f3c2e29-e837-48cf-ab8d-a7f91d880b95">
        <updating/>
        <source>setMyTerminal(_terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     26 September 2001 by cnwrs2
//
// Purpose:     This is only to set the terminal on the null voyage
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
10 Apr 2008	cnwkpd1	PAR #16378 - Need to remove and add from parent Global Voyage(s) because
					myTerminal is a key to this manual collection
16 Jul 2024 navlw1	ChangeRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code 
26 Nov 2024	navdap1	MTN-33516 NSW | OnePort - Voyage Already Exists With External Code Error
06 Dec 2024	navdap1	MTN-33625 MTN - 1090 exception on the Log Voyage Operations form when editing a voyage
*/

vars
	saveTerm	: CM_Terminal;
	allowDupInOut : Boolean;			// MTN-33625

begin

	exclusiveLock(self);
	
	saveTerm := self.myTerminal;

	if (not self.isTransient) and 
	   saveTerm &lt;&gt; null and
	   saveTerm &lt;&gt; _terminal then
		// the terminal has changed so have to remove
		// from old terminal dict
		saveTerm.removeVoyageFromDict(self, true);
	endif;
	
	self.removeFromGlobalAllVoyages();				// PAR #16378
    
	self.myTerminal := _terminal;
	
	self.addToGlobalAllVoyages();					// PAR #16378
	
	allowDupInOut := _terminal &lt;&gt; null and _terminal.getConfig(AllowDupVoyageInOutCodes).Boolean;	// MTN-33625

	if self.archived then
		self.myTerminalArchived 		:= _terminal;	
		self.myTerminalActive			:= null;
		self.myTerminalForInwardCode	:= null;
		//navlw1 #63839
		//if self.isAutomaticProcess() then										// MTN-33516
		if self.myTerminal.getConfig(AllowDupVoyageInOutCodes).Boolean then		// MTN-33516
			self.myTerminalForInwardCodeAuto := null;
		endif;
		// navlw1 #63839
		if (not self.isTransient) and 
		   saveTerm &lt;&gt; null and
		   saveTerm = _terminal then
			// the terminal dict only has active voyages (not archived)
			saveTerm.removeVoyageFromDict(self, true);
		endif;

	else
		self.myTerminalActive := _terminal;
		self.myTerminalArchived	:= null;
		// Start navlw1 #63839
		//if self.isAutomaticProcess() then										// MTN-33516
		if allowDupInOut then													// MTN-33625
			if self.inwardCodeAuto &lt;&gt; null and
				self.inwardCodeAuto &lt;&gt; self.code then
				self.myTerminalForInwardCodeAuto := _terminal;
			else
				self.myTerminalForInwardCodeAuto := null;
			endif;
		else
			if self.inwardCode &lt;&gt; null and
				self.inwardCode &lt;&gt; self.code then
				self.myTerminalForInwardCode := _terminal;
			else
				self.myTerminalForInwardCode := null;
			endif;
		endif;
		// End navlw1 #63839
	endif;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
