/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 August 2008	cnwrd1	Initial creation

*/

vars

begin
	return self.myAssistant.displayEntryISOType(obj.CM_ISOType);
epilog

end;</source>
