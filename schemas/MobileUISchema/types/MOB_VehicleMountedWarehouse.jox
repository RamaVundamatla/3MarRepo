    <JadeMethod name="if_doRTQueueEntryChanged" id="31144d1d-e8e2-4a4e-a4da-fa6843ed573f">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::doRTQueueEntryChanged"/>
        </interfaceImplements>
        <source>if_doRTQueueEntryChanged(_rtQueueEntry : CM_RTQueueEntry);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements for the IF_VehicleMountedDetails interface 
	*/
/*

Date		Who		Reason
05 August 2014	cnwer1	Initial creation PAR

*/

vars
	theEdition : Integer;
	isWorkingEntry,
	invalidObject : Boolean;
	row : Integer;
	dtoEntry : DTO_RTQueueEntry;
	selectedWorkingEntry,
	rtQueueEntry : CM_RTQueueEntry;
	selectedEntries  : CM_RTQueueEntryArray;
begin

	if _rtQueueEntry &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,_rtQueueEntry,invalidObject);
		if _rtQueueEntry &lt;&gt; null then
			theEdition:= _rtQueueEntry.edition;
		endif;
		create selectedEntries transient;
		if self.tblSelectTasks.visible then
			self.getSelectedRTQueueEntries(selectedEntries);
		else
			selectedWorkingEntry:=	self.getSelectedWorkingRTEntry();
			if selectedWorkingEntry &lt;&gt; null then
				selectedEntries.add(selectedWorkingEntry);
			endif;
		endif;
	
		app.myVMAgent.refreshTableEntry(self.tblSelectTasks,_rtQueueEntry);

		on Exception do app.handleDeletedObject(exception,dtoEntry,invalidObject);
		row:=1;
		while row &lt;= self.tblWorkingTasks.rows do
			dtoEntry:=self.tblWorkingTasks.accessRow(row).itemObject.DTO_RTQueueEntry;
			if dtoEntry &lt;&gt; null then
				
		
				theEdition:= dtoEntry.edition;
				if invalidObject then
					isWorkingEntry:=true;
					break;
				endif;
				if dtoEntry.myRealQueueEntry = _rtQueueEntry then
					isWorkingEntry:=true;
					break;
				endif;
			endif;
			row:=row +1;
		endwhile;
		
		rtQueueEntry:=_rtQueueEntry;
		if isWorkingEntry or app.myVMAgent.hasCurrentTask(rtQueueEntry) then
			
			self.clearTableData(self.tblWorkingTasks);
			app.myVMAgent.loadRTTaskTable(self.tblWorkingTasks,null);
		endif;
		
		if self.tblSelectTasks.visible then
			self.reselectRTQueueEntries(selectedEntries,self.tblSelectTasks);
			self.btnWorking.visible:=self.myVMAgent.myMachine.allCurrentQueueTasks.size &gt; 0;
		else
			if selectedEntries.size = 0 then
				if  self.tblWorkingTasks.rows &gt; 1 then
					self.tblWorkingTasks.row:=2;
					self.tblWorkingTasks.click(self.tblWorkingTasks);
				endif;
			else
				self.reselectRTQueueEntries(selectedEntries,self.tblWorkingTasks);
			endif;
			self.refreshWorkingButtons();
		endif;
		
		
	endif;
epilog
	delete selectedEntries;
end;</source>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
    </JadeMethod>
