<Class name="Node">
    <JadeMethod name="cnEcGetMemory" id="68878da3-c7cc-4ae7-b0c3-d8acf6cbada4">
        <source>cnEcGetMemory(pTotalMemory:Integer output; pAvailableMemory:Integer output);
// --------------------------------------------------------------------------------
// Created:		27 November 2001 by cnwdad1
//
// Purpose:		Returns the client node's total and available memory.
//
// Parameters:	pTotalMemory - The total amount memory.
//				pAvailableMemory - The amount of available memory.
//
// Returns:		The above parameter values.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	statusStructure	: Binary;
	
begin
	statusStructure[1:256]	:=	0.Binary;

	// Get the memory status for the local machine. If we're running thin
	// client, this call will get the memory status for the app server.
	call cnEcGlobalMemoryStatus(statusStructure);
	
	pTotalMemory		:=	statusStructure[9:4].Integer;
	pAvailableMemory	:=	statusStructure[13:4].Integer;
end;</source>
        <Parameter name="pTotalMemory" type="Integer" usage="output"/>
        <Parameter name="pAvailableMemory" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetServerMemory" id="4b2da9c6-f6dd-4652-9e51-b8349802db36">
        <executionLocation>server</executionLocation>
        <source>cnEcGetServerMemory(pTotalMemory:Integer output; pAvailableMemory:Integer output) serverExecution;
// -----------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Returns the server node's total and available memory.
//
// Parameters:	pTotalMemory - The total amount memory.
//				pAvailableMemory - The amount of available memory.
//
// Returns:		The above parameter values.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.cnEcGetMemory(pTotalMemory, pAvailableMemory);
end;</source>
        <Parameter name="pTotalMemory" type="Integer" usage="output"/>
        <Parameter name="pAvailableMemory" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetTableDisplay" id="d603c5c6-8b70-4fdf-adea-e731c510f53b">
        <source>cnEcGetTableDisplay():String;
// --------------------------------------------------------------------------------
// Created:		27 May 2000 by cnwdad1
//
// Purpose:		Returns a 3-column display of node information for a table control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowDisplay		: String;
	platformName	: String;

begin
	if self.isServerNode then
		rowDisplay	:=	self.name &amp; " (SERVER)";
	elseif self.isApplicationServer then
		rowDisplay	:=	self.name &amp; " (APP SERVER)";
	else
		rowDisplay	:=	self.name;
	endif;

	rowDisplay	:=	rowDisplay &amp; Tab &amp; self.processes.size().String;

	// Get the platform on which the node is running.
	
	platformName	:=	self.cnEcOSDescription();

	rowDisplay	:=	rowDisplay &amp; Tab &amp; platformName;
epilog
	return rowDisplay;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcOSDescription" id="751514ce-8bea-435a-af49-40de9710e6a3">
        <source>cnEcOSDescription():String;
// --------------------------------------------------------------------------------
// Created:		23 November 2005 by cnwdad1
//
// Purpose:		Returns a description of the OS on which the receiver is running.
//
// Parameters:	None
//
// Returns:		A description of the OS.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue		: String;
	location		: String;
	osPlatform		: Integer;
	osVersion		: String;
	osArchitecture	: Integer;
	platformName	: String;

begin
		// Get the location where the node is running.
		
	if self.isServerNode() then
		location	:=	"(Server)";
	elseif self.isApplicationServer() then
		location	:=	"(App Server)";
	else
		location	:=	"(Client)";
	endif;
	
	// Get the platform on which the node is running.
	
	osPlatform	:=	self.getOSPlatform(osVersion, osArchitecture);
	
	if osPlatform.bitAnd(self.OSWindows) &lt;&gt; 0 then
		// Operating system is Windows family (98, Me, 2000, or XP).
		if osPlatform = self.OSWindowsHome then
			// Version is one of Windows 95 or Windows 98.
			platformName	:=	"Windows " &amp; osVersion;
		elseif osPlatform = self.OSWindowsEnterprise then
			// Version is one of Windows 2003 Server, Windows 2000, or Windows XP.
			platformName	:=	"Windows NT " &amp; osVersion;
		endif;
	elseif osPlatform.bitAnd(self.OSUnix) &lt;&gt; 0 then
		// Operating system is unix (aix, linux, solaris, etc).
		if osPlatform = Node.OSUnixAIX then  
			// Version is 4.3, for all releases of AIX 4.3.
			platformName	:=	"IBM AIX " &amp; osVersion;
		endif;
	else
		platformName	:=	"Unknown platform: " &amp; osPlatform.String &amp; " Version: " &amp; osVersion;
	endif;

	returnValue	:=	platformName &amp; " " &amp; location;
epilog
	return returnValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
