    <JadeMethod name="utlCreateDutyDocItem" id="5e495e43-0540-49ca-9db9-cacba74c5336">
        <source>utlCreateDutyDocItem(	_proxyDutyDocItem : CM_DutyDocItem;
						_newDutyDocItem : CM_DutyDocItem output;
						_passport : CM_Passport input
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2012	cnwndl1	Initial creation	Par 30901
31 July     2014    cnwma1 PAR 34408 Credit Customer current charges
*/

vars

	ti : CM_TrackedItem;
	controller : CMIF_TiTransactionResync;
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCM_Object(_proxyDutyDocItem, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);

	if _proxyDutyDocItem.isCar then
		create _newDutyDocItem as CM_DutyDocCarItem persistent;
	else
		create _newDutyDocItem persistent;
	endif;
	
	_newDutyDocItem.setForCreate( _proxyDutyDocItem);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newDutyDocItem);
	endif;
	
	//22 Apr 2013	NDL	Par 31424
	if _passport.noErrors then
		ti := _newDutyDocItem.getMyTrackedItem;
		if ti &lt;&gt; null and not ti.allTransactions.isEmpty then
			create controller transient;
			controller.setForFullResyncOf(ti);
			controller.force := true;
			//app.myUtilityUA.utlUpdateResyncTrans( controller, _passport );  // 31-JUL-2014 cnwma1 PAR 34408 Credit Customer current charges
		endif;
	endif;
	
epilog

	delete controller;

end;</source>
