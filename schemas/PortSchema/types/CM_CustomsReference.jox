    <JadeMethod name="getDisplayStringForAttribute" id="4be86394-8de9-4015-85c2-7bedd5d8af88">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2022	navpw1	Initial creation TFS: 55215

*/

begin
	if _attrName = ETRow_ReferenceType then
		return self.referenceType;
	elseif _attrName = ETRow_ReferenceNumber then
		return self.referenceNumber;
	elseif _attrName = ETRow_PositionNumber then
		return self.positionNumber.asStringJMT();
	elseif _attrName = ETRow_Status then
		return self.status;
	elseif _attrName = ETRow_ObjectName then
		return self.objectName;
	elseif _attrName = ETRow_TotalPackages then
		return self.packagesTotal.asStringJMT();
	elseif _attrName = ETRow_PackagesRemaining then
		return self.packagesRemaining.asStringJMT();
	elseif _attrName = ETRow_CustomsControl then
		return self.customsContol;
	else
		return inheritMethod(_attrName, _short);
	endif;
	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEditTransactionString" id="88c90c78-d52d-43d9-bd09-e7174c0c1082">
        <source>getEditTransactionString(strArray: StringArray io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2024	navcs2	Defect 62587: CUX | POST/CustomsStatus Method Does not create any Transaction

*/
vars
	string		: String;
begin		
	if self.referenceNumber &lt;&gt; null then
		string := CM_CustomsReference::referenceNumber.name &amp; ' ' &amp; Space &amp; ' =&gt; ' &amp; self.referenceNumber  &amp; CrLf;
		strArray.add(string);
	endif;
	
	if self.referenceType &lt;&gt; null then
		string := CM_CustomsReference::referenceType.name &amp; ' ' &amp; Space &amp; ' =&gt; ' &amp; self.referenceType  &amp; CrLf;
		strArray.add(string);
	endif;
	
	if self.positionNumber &lt;&gt; null then
		string := CM_CustomsReference::positionNumber.name &amp; ' ' &amp; Space &amp; ' =&gt; ' &amp; self.positionNumber.asStringJMT  &amp; CrLf;
		strArray.add(string);
	endif;
	
	if self.status &lt;&gt; null then
		string := CM_CustomsReference::status.name &amp; ' ' &amp; Space &amp; ' =&gt; ' &amp; self.status  &amp; CrLf;
		strArray.add(string);
	endif;
	
	if self.customsContol &lt;&gt; null then
		string := CM_CustomsReference::customsContol.name &amp; ' ' &amp; Space &amp; ' =&gt; ' &amp; self.customsContol  &amp; CrLf;
		strArray.add(string);
	endif;
epilog
	
end;</source>
        <Parameter name="strArray" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="07bcb294-fc9f-4f34-be56-8b96699e8f22">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2022	navpw1	Initial creation TFS: 55215

*/

vars
	pxy : CM_CustomsReference;
begin
	pxy := inheritMethod();
	pxy.myTrackedItem := self.myTrackedItem;
	
	return pxy;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2a48fd27-fe7a-4757-9626-774e30b925d0">
        <updating/>
        <source>setForCreate(_pxyCustomsReferenceInfo : CM_CustomsReference) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2022	navpw1	Initial creation TFS: 55215

*/

begin
	self.setForUpdate(_pxyCustomsReferenceInfo);
	self.myTrackedItem := _pxyCustomsReferenceInfo.myTrackedItem;
	
end;</source>
        <Parameter name="_pxyCustomsReferenceInfo" type="CM_CustomsReference"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="67e39d6a-5a7c-4ed0-b869-8ae13ebdf4eb">
        <updating/>
        <source>setForUpdate(_pxyCustomsReferenceInfo	: CM_CustomsReference) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2022	navpw1	Initial creation TFS: 55215

*/

begin
	self.referenceType		:= _pxyCustomsReferenceInfo.referenceType;
	self.referenceNumber	:= _pxyCustomsReferenceInfo.referenceNumber;
	self.positionNumber		:= _pxyCustomsReferenceInfo.positionNumber;
	self.status				:= _pxyCustomsReferenceInfo.status;
	self.objectName			:= _pxyCustomsReferenceInfo.objectName;
	self.packagesTotal		:= _pxyCustomsReferenceInfo.packagesTotal;
	self.packagesRemaining	:= _pxyCustomsReferenceInfo.packagesRemaining;
	self.customsContol		:= _pxyCustomsReferenceInfo.customsContol;
	self.retentionPeriod	:= _pxyCustomsReferenceInfo.retentionPeriod;
	
end;</source>
        <Parameter name="_pxyCustomsReferenceInfo" type="CM_CustomsReference"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="ca6bc6ee-9005-4050-8cd3-b6f17d1473b6">
        <updating/>
        <source>setProxy(_referenceType, _referenceNumber : String; _position : Integer; _status, _objectName : String; _totalPackages, 
		 _packagesRemaining : Integer; _customsControl : String; _retentionPeriod : Date) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2022	navpw1	Initial creation TFS: 55215

*/

begin
	self.referenceType		:= _referenceType;
	self.referenceNumber	:= _referenceNumber;
	self.positionNumber		:= _position;
	self.setProxyForUpdate(_status, _objectName, _totalPackages, _packagesRemaining, _customsControl, _retentionPeriod);
	
end;</source>
        <Parameter name="_referenceType" type="String"/>
        <Parameter name="_referenceNumber" type="String"/>
        <Parameter name="_position" type="Integer"/>
        <Parameter name="_status" type="String"/>
        <Parameter name="_objectName" type="String"/>
        <Parameter name="_totalPackages" type="Integer"/>
        <Parameter name="_packagesRemaining" type="Integer"/>
        <Parameter name="_customsControl" type="String"/>
        <Parameter name="_retentionPeriod" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setProxyForUpdate" id="69cfc222-fdd0-4f7d-9c67-ccd522c6fb50">
        <updating/>
        <source>setProxyForUpdate(_status, _objectName : String; _totalPackages, _packagesRemaining : Integer; _customsControl : String; _retentionPeriod : Date) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2022	navpw1	Initial creation TFS: 55215

*/

begin
	self.status				:= _status;
	self.objectName			:= _objectName;
	self.packagesTotal		:= _totalPackages;
	self.packagesRemaining	:= _packagesRemaining;
	self.customsContol		:= _customsControl;
	self.retentionPeriod	:= _retentionPeriod;
	
end;</source>
        <Parameter name="_status" type="String"/>
        <Parameter name="_objectName" type="String"/>
        <Parameter name="_totalPackages" type="Integer"/>
        <Parameter name="_packagesRemaining" type="Integer"/>
        <Parameter name="_customsControl" type="String"/>
        <Parameter name="_retentionPeriod" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setTrackedItem" id="609fc209-8522-44ac-9abd-e55d5aa9e623">
        <updating/>
        <source>setTrackedItem(_trackedItem : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
