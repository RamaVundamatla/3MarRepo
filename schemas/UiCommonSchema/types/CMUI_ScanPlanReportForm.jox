	self.optColComm.value := (xmlText = "true").Boolean;
	xmlText := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.optColISO.name );
	self.optColISO.value := (xmlText = "true").Boolean;
	xmlText := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.optColLPort.name );
	self.optColLPort.value := (xmlText = "true").Boolean;
	
	xmlText := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.optSlotAct.name );
