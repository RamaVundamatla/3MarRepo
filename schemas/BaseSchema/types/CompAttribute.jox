<Class name="CompAttribute">
    <JadeMethod name="cnEcIsPrimitiveArray" id="aa3aeb00-c58f-4c74-aafd-03edf6fefbe2">
        <source>cnEcIsPrimitiveArray() : Boolean;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is a
//				primitive array object.
//
// Parameters:	None
//
// Returns:		True if the receiver is a primitive array, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
