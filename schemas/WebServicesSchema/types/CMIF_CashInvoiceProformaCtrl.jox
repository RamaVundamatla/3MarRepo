<Class name="CMIF_CashInvoiceProformaCtrl">
    <JadeMethod name="genReportBinaryForWeb" id="365c9400-84c5-470d-8703-06ec304e71a3">
        <source>genReportBinaryForWeb() : Binary;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//11/07/2024	navkc1 CR 64838 Task 64853: Jade - New Cash API putProformaStatus

*/

vars
	reportBinary : Binary;
	voyage			: CM_Voyage;
	ti 				: CM_TrackedItem;
	voyProcess		: CM_VoyageProcess;
	reportToRun		: String;
	reportAgent 	: WebService_ReportAgent;
	failedDAC 		: CM_DataAccessController;
	cashReceipt 	: CM_CashReceipt;
	noOutput		: Boolean;
	report 			: CM_QryReport;
	filterObject	: CMQF_FilterReports;
	cmqfCashRec 	: CMQF_CashReceipt;
begin
	cashReceipt := self.myNewCashReceipt;
	app.writeLog(method.qualifiedName &amp; Tab,   LogINFO);
	if cashReceipt = null then	
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Cash Receipt = null", LogINFO);
		return null;
	endif;
	
	if cashReceipt.allCashPayments.isEmpty() then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Cash Payments empty", LogINFO);
		return null;
	endif;
	
	if not cashReceipt.getDebtor().canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Can't access debtor", LogINFO);
		return null;
	endif;
	
	voyage := self.myVoyage;
	if voyage = null then
		ti := self.allTis.first();
		
		if ti = null then
			ti := cashReceipt.allTrackedItems.first();
		endif;
		
		if ti &lt;&gt; null then
			voyage := ti.myVoyage;
		endif;
	endif;
	
	if voyage = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Voyage null", LogINFO);
		return null;
	endif;
	
	voyProcess := voyage.myVoyageProcess;
	
	if voyProcess = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Voyage process null", LogINFO);
		return null;
	endif;
	
	reportToRun := voyProcess.reportInvoiceEstimate;
	
	if reportToRun = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Voyage estimate report null", LogINFO);
		return null;
	endif;
	
	create reportAgent transient;
	
	//jlier1 TFS 66233 23/9/24
	//06/12/2024	navkc1 JIRA Bug MTN-33566 - Wont be needing this, doesn't make sense
	/*
	report := self.getFirstQryReport(reportToRun);
	if report &lt;&gt; null then
		reportAgent.initQryReportForRunner(report);
	endif;
	*/
	//jlier1 TFS 66233 23/9/24 -removed the need to have a qry report
	reportAgent.initRunnerForCashReceipt(cashReceipt);
	if reportAgent.myJRWReport = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "JRW Report is null", LogINFO);
		return null;
	endif;
	
	//06/12/2024	navkc1 JIRA Bug MTN-33566 - Wont be needing this, doesnt make sense
	//Create filter object - We only want the receipt we created
	/*
	if report &lt;&gt; null then
		filterObject := report.createFilter();
		if filterObject &lt;&gt; null then
			cmqfCashRec := filterObject.CMQF_CashReceipt;
			cmqfCashRec.initialize();
			cmqfCashRec.allQueryReportParams.clear();
			cmqfCashRec.allTerminals.add(self.myNewCashReceipt.myTerminal);
			if self.myNewCashReceipt.paymentStatus &gt;= CM_CashReceipt.API_RECEIPT_HOLD and self.myNewCashReceipt.externalInvoiceNumber &lt;&gt; null then
				cmqfCashRec.cashReceiptNumber := self.myNewCashReceipt.externalInvoiceNumber.String;
			else
				cmqfCashRec.cashReceiptNumber := self.myNewCashReceipt.sequenceNum.String;
			endif;
		endif;	
		// Set the filter to the report agent
		reportAgent.setMyFilterObject(cmqfCashRec);
	endif;
	*/
	
	reportAgent.runReportForWeb(noOutput);
	
	if noOutput then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "NO OUTPUT", LogINFO);
		return null;
	endif;
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Report Length = " &amp; reportAgent.reportBinary.length.String, LogINFO);
	return reportAgent.reportBinary;
epilog

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="genReportBinaryForWebAsString" id="7562ed0c-9b5c-4cc8-93f7-ca67a15af268">
        <source>genReportBinaryForWebAsString() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/07/2024	navkc1 CR 64838 Task 64853: Jade - New Cash API putProformaStatus

*/

vars
	reportBinary : Binary;
	binaryAsString : String;
begin
	
	//return null;
	
	reportBinary := self.genReportBinaryForWeb();
	
	binaryAsString := reportBinary.base64EncodeNoCrLf();
	
	return binaryAsString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstQryReport" id="670f7216-e052-4e8b-8cfe-9fcffeffd460">
        <source>getFirstQryReport(_reportToRun : String) : CM_QryReport;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//11/07/2024	navkc1 CR 64837 Task 64852: Jade - Cash API Binary PDF

*/

vars
	qryReport 					: CM_QryReport;
	menuItemDict				: CM_MenuItemByTypeMenuIdDict;
	menuItem					: CM_MenuItem;
	qry							: CM_QryReport;
begin
	menuItemDict := app.myRoot.myReportMenuRoot.allMenuItems;
	
	foreach menuItem in menuItemDict do
		if not menuItem.isKindOf(CM_QryReport) then
			continue;
		endif;
		
		qry := menuItem.CM_QryReport;
		
		if qry.jrwReportName.includes(_reportToRun) and qry.isAvailableToWeb() then
			qryReport := menuItem.CM_QryReport;
			break;
		endif;
	endforeach;
	
	return qryReport;
	
epilog

end;</source>
        <Parameter name="_reportToRun" type="String"/>
        <ReturnType type="CM_QryReport"/>
    </JadeMethod>
</Class>
