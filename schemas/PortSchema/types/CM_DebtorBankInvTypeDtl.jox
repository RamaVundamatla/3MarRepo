    <JadeMethod name="getDescription" id="b1bac317-5988-43d5-85fd-87ddf9a02039">
        <source>getDescription() : String;

vars

begin
	return self.getDebtorString() &amp; "/" &amp; self.getInvoiceTypeString() &amp; "/" &amp; getPeriodString();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
