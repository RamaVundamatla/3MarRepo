    <JadeMethod name="setComboValues" id="fdcd1f9e-beae-41f9-8f04-fc3c3f37952b">
        <source>setComboValues(comboBox 				: ComboBox input; 
			   queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder; 
			   queryOperator			: CM_QueryOperator; 
			   passport					: CM_Passport);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 29 August 2018
TFS#		: 40200
Function	: Populate comboBox List.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	carrier			: CM_Carrier;
	selectStr		: String;
	storeIdx		: Integer;
	idx				: Integer;
	selectedCarrier : CM_Carrier;
begin
	comboBox.clear();	
	comboBox.sorted := true;
	
	if CM_QStringLookup.hasInstance(queryOperator) then
		selectStr := queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(queryOperator) then
		selectStr := queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;

	foreach carrier in CM_Carrier.instances do
	
		idx := comboBox.addItem(carrier.code &amp; Tab &amp; ' (' &amp; carrier.description.toUpper() &amp; ')');
		comboBox.itemObject[idx] := carrier;
					
		if carrier.code = selectStr then
			selectedCarrier := carrier;
		endif;		
	endforeach;
	
	storeIdx  := comboBox.findObject(selectedCarrier);
	
	if storeIdx &gt; 0 and storeIdx &lt; comboBox.listCount then
		comboBox.listIndex := storeIdx;
	endif;

end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="c0acad36-950b-400f-906a-dae7720584fc">
        <source>setListValues(table						: Table input; 
			  queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder;
			  queryOperator				: CM_QueryOperator; 
			  passport					: CM_Passport);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 29 August 2018
TFS#		: 40200
Function	: Populate Selection List.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	carrier			: CM_Carrier;
	selectionValue	: Integer;
	idx				: Integer;
	array			: ObjectArray;
begin
	
	table.rows := table.fixedRows;
	table.sortColumn[1] := 2;
	table.sortAsc[1] := true;
	
	array := table.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	foreach carrier in CM_Carrier.instances do	
	
		selectionValue := 0;
		if queryOperator &lt;&gt; null and  queryOperator.CM_QStringIsOneOf.allSelectionValues.includes(carrier.code) then
			selectionValue := 1;
			array.add(carrier);
		endif;
	
		idx := table.addItem(selectionValue.String &amp; Tab  &amp; carrier.code &amp; Tab &amp; ' (' &amp; carrier.description.toUpper() &amp; ')');
		table.accessRow(idx).itemObject := carrier;
	endforeach;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="5195e2b9-7065-402d-ae89-147e4e93e096">
        <source>setValuesFromList(table: Table input; queryOperator: CM_QueryOperator input);

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 29 August 2018
TFS#		: 40200

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	carrier		: CM_Carrier;
	str			: String;
	numRows		: Integer;
	idx			: Integer;
	strArray	: StringArray;

begin

	create strArray transient;
	
	numRows := table.rows;
	foreach idx in (table.fixedRows + 1) to numRows do
		str := table.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			carrier := table.accessRow(idx).itemObject.CM_Carrier;
			strArray.add(carrier.code);
		endif;
	endforeach;
	
	queryOperator.setSearchValue(strArray);

epilog
	delete strArray;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryOperator" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="f99eee6a-e4d8-454d-b892-260b7b601290">
        <source>translateToDisplayValue(_value: Any): String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 22 August 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _value.isKindOf(CM_Carrier) then
		if _value &lt;&gt; null then
			return _value.CM_Carrier.code;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;
	
	return null;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="7eef8ca5-cdd0-4b72-b05d-dc951e4d377f">
        <source>translateToSearchValue(value : Any) : Any;

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 22 August 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	invalidObj 	: Boolean;
	carrier		: CM_Carrier;
	returnVal	: String;
	
begin
	if value &lt;&gt; null then
		if value.isKindOf(Collection) then			
			return value;
		endif;

		if value.isKindOf(CM_Carrier) then
			carrier := value.CM_Carrier;
		endif;
	endif;
	
	if carrier &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, carrier, invalidObj);
		
		returnVal := carrier.code;
	endif;
	
	return returnVal;	
end;
</source>
        <Parameter name="value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="2486878b-2aea-4338-9b0f-38cd6877d88d">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	str, rtnVal : String;
	strArray : StringArray;

begin
	if _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			rtnVal := rtnVal &amp; str &amp; CNEC_COMMA &amp; Space;
		endforeach;
		rtnVal := rtnVal[1:rtnVal.length-2];
		return rtnVal;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			str := _value.String;
			create strArray transient;
			str.getTokensForDelimiter("|", strArray);
			return strArray;
		endif;
		
		return _value.String;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
