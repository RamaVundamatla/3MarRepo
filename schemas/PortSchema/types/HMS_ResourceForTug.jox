    <JadeMethod name="setProxy" id="589625dd-366b-4744-940f-33e7ce8565a1">
        <updating/>
        <source>setProxy(_obj: HMS_Object; _harbour: HMS_Harbour; _arrivalResource: HMS_Resource; _departResource: HMS_Resource; _shiftResource: HMS_Resource) updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tug		: HMS_Tug;
begin
	inheritMethod(_obj, _harbour, _arrivalResource, _departResource, _shiftResource);

	tug := _obj.HMS_Tug;
	
	self.myTug := tug;
	self.myHMSObject := tug;
		
	if tug &lt;&gt; null and not self.allTugs.includes(tug) then 
		self.allTugs.add(tug);
	endif;
end;</source>
        <Parameter name="_obj" type="HMS_Object"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_arrivalResource" type="HMS_Resource"/>
        <Parameter name="_departResource" type="HMS_Resource"/>
        <Parameter name="_shiftResource" type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="setTug" id="d82cb469-5b79-4a77-9612-4831594b9bd0">
        <updating/>
        <source>setTug(_tug	: HMS_Tug)updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myTug := _tug;
	self.myHMSObject := _tug;
	
	if _tug &lt;&gt; null and not self.allTugs.includes(_tug) then 
		self.allTugs.add(_tug);
	endif;
end;</source>
        <Parameter name="_tug" type="HMS_Tug"/>
    </JadeMethod>
</Class>
