    <JadeMethod name="isReserveSelectionTest" id="0247a788-1edc-40f5-9d5b-953bfc8e24bc">
        <source>isReserveSelectionTest():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

begin

	if self.myCMIFYAAutoPlan &lt;&gt; null then
		if self.myCMIFYAAutoPlan.isKindOf(CMIF_YARequest) and self.myCMIFYAAutoPlan.CMIF_YARequest.myReserveSelection &lt;&gt; null then
			return true;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSingleProcessing" id="e7bb84cf-4850-4527-b916-38d48e71b193">
        <source>isSingleProcessing() : Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if	self.agentUsage = self.Normal_Usage or 
		self.agentUsage = self.TestSingleTI or 
		self.agentUsage = self.TestSingleTI_Verbose then
		return true; 
	else
		return false;
	endif;
		


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processSenarioCounter" id="9c10c012-6098-43c0-b36d-2368722dc92d">
        <updating/>
        <source>processSenarioCounter(_cell : CM_YALocationCell) updating;

vars

begin

	if self.myCurrentCMIFYAAutoPlan.allUsedYACells.includes(_cell) then
		return;
	endif;
	
	self.addLogEntry(AP_Log_YA_Default,_cell.myYardController.getFullId() &amp; ' height ' &amp; _cell.height.String &amp; ' is an appropriate location', false);
	self.numberOfLocationsFound := self.numberOfLocationsFound + 1;
	
	self.myCurrentCMIFYAAutoPlan.allUsedYACells.add(_cell);
end;</source>
        <Parameter name="_cell" type="CM_YALocationCell"/>
    </JadeMethod>
    <JadeMethod name="removeAutoYardAllocation" id="09556e40-e073-4eaa-b7ee-1bcf9e2f060b">
        <updating/>
        <source>removeAutoYardAllocation(_terminalArea : CM_TerminalArea; _yardAllocation : CM_YardAllocation io) : Boolean updating;
// -------------------------------------------
// Created 05 October 2005 by cnwdvb1
// -------------------------------------------
vars
	pxyAllocation		: CM_YardAllocation;
	allBlocksInObj		: CM_YABlockArray;
	blockObj		: CM_YABlock;
	set					: ObjectSet;
	obj					: Object;
	terminal			: CM_Terminal;
	aTA					: CM_TerminalArea;
	

begin
	if _yardAllocation = null then
		return false;
	endif;
	
	// Par 12297
	//if not _yardAllocation.isAutomatic then
//		return false;
//	endif;
	if not _yardAllocation.includeInYardDisplays() then
		return false;
	endif;
	
	terminal := _terminalArea.myTerminal;
	
	create	allBlocksInObj transient;
	create set transient;
	
	pxyAllocation := app.createUpdateProxy(_yardAllocation).CM_YardAllocation;
	pxyAllocation.allYABlocksIn.copy(allBlocksInObj);
	
	foreach blockObj in allBlocksInObj do
		if blockObj.myTerminalArea = _terminalArea then
			delete blockObj;
//			set.add(blockObj);
		endif;
	endforeach;
	

	if allBlocksInObj.isEmpty() then
		app.myUtilityDA.utlDeleteYardAllocation(_yardAllocation, app.myPassport);
	else
//		pxyAllocation.setNewBlocks(allBlocksInObj,	allBlocksInObj);
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_yardAllocation, true);
		_yardAllocation.setForUpdate(pxyAllocation);
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_yardAllocation, false);

		terminal.causeEvent(terminal.getTerminalEvent(Event_YardAllocationUpdate),false, _yardAllocation);
		
		foreach aTA in _yardAllocation.allTerminalAreas do
			aTA.causeEvent(terminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,null);
		endforeach;
	endif;
epilog
	delete allBlocksInObj;
	delete pxyAllocation;
	delete set;
end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_yardAllocation" type="CM_YardAllocation" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeFromPassedLocations" id="cb35ed34-daf7-4af4-b282-e4d88ff3df38">
        <source>removeFromPassedLocations(_passedLocation : CM_LocationsController);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2008	cnwer1	Initial creation

*/

vars

begin
	if self.myCurrentCMIFYAAutoPlan.allPassedLocations.includes(_passedLocation) then
		self.myCurrentCMIFYAAutoPlan.allPassedLocations.remove(_passedLocation);
	endif;
	
	//cnwrd1 par 29269 14.4.2012 LOB queueing
	if self.myCurrentCMIFYAAutoPlan.allPassedLocationsRestricted.includes(_passedLocation) then
		self.myCurrentCMIFYAAutoPlan.allPassedLocationsRestricted.remove(_passedLocation);
	endif;
	

epilog

end;</source>
        <Parameter name="_passedLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="resetCMIFTerminal" id="92a828cf-3184-4f18-9b77-ee548ef59cc4">
        <source>resetCMIFTerminal(_cmifTerm : CMIF_YATerminal input) protected;
// -------------------------------------------
// Created 16 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	_cmifTerm.allYAPriorities.clear();
		
	// Bit of a hit but necessary.
	// Each priority will be automatically locked and latest copy dragged across.
	_cmifTerm.myTerminal.allYAPriorities.copy(_cmifTerm.allYAPriorities);

end;</source>
        <access>protected</access>
        <Parameter name="_cmifTerm" type="CMIF_YATerminal" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resetTempLastResort" id="07cccc06-151b-4206-940e-bb95c89db23b">
        <source>resetTempLastResort();
// -------------------------------------------
// Created 14 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.myCurrentCMIFYAAutoPlan &lt;&gt; null then
		self.myCurrentCMIFYAAutoPlan.allLCsTempLastResort.clear();
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="resetTestLocations" id="4f7ae8a7-dae7-4cf6-bcad-ab4d619242a9">
        <updating/>
        <source>resetTestLocations() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2013	cnwndl1	Initial creation	Par 32049

*/

vars

	dict : CM_YATestLocations;

begin

	self.allYATestLocations.deleteData();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="searchAllocationIn" id="40f77fe0-f194-45c2-b917-da8c94e47d28">
        <updating/>
        <source>searchAllocationIn(_terminal : CM_Terminal; _terminalArea : CM_TerminalArea; _job : CM_Job) : Boolean updating, protected;
// -------------------------------------------
// Created 31 May 2005 by cnwdvb1
// -------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------------
// 10/03/2021	navdap1		TFS 50889 PRP Yard Allocation Performance Improvement
// 05/10/2022	navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// 06/11/2024	navdap1		MTN-18897 EUP | FR 53485 EUP - Warehouse Yard Allocation
vars

	priorityValue		  : Real;
	yardAllocation,
	twinYardAllocation	  : CM_YardAllocation;
	iter				  : Iterator;
	allocationDict		  : CM_YAByPriorityDict;
	okToSearchIn		  : Boolean;
	locsFoundForThisAlloc : Integer;
	foundPrior 		      : Integer;
	noSpaceMsg 			  : Boolean;
	lc 					  : CM_LocationsController;
	ti 					  : CM_TrackedItem;				// TFS 50889
	autoPlanCmif		  : CMIF_YAAutoPlan;
begin

	autoPlanCmif := self.myCurrentCMIFYAAutoPlan;		//05.10.2022 navma1 #52967
	
	if self.isForDirectDelivery() then					//30 Jan 2013	NDL	Par 31102
		self.addLogEntry(AP_Log_YA_Global, autoPlanCmif.getID() &amp; " is marked as 'Direct Delivery' cargo - Auto plan aborted.", false);
		return true;
	endif;
	
	if _terminalArea &lt;&gt; null then
		self.addLogEntry(AP_Log_YA_Default,'Using specified terminal area - ' &amp; _terminalArea.id, false);	
		if _terminalArea.myTerminal &lt;&gt; _terminal then
			self.addLogEntry(AP_Log_YA_Global,'Specified terminal area is not located in selected terminal', false);
			self.setHadError(true);
			app.raiseCMException2(AutoPlanningYAError, autoPlanCmif.getID(), 'Specified terminal area is not located in selected terminal', null, null);
			return false;
		endif;
	endif;
	
	if self.isOnlyCheckRealCargo then
		self.addLogEntry(AP_Log_YA_Default,'Only Check real Cargo is - ' &amp; self.isOnlyCheckRealCargo.String, false);	
	endif;
	
	self.numControllers := autoPlanCmif.calculateMoveLCs();
	
	// 27/04/2009 cnwar2 #19401, #19524, #19522
	if myCMIFYAAutoPlan &lt;&gt; null then
       myCMIFYAAutoPlan.myJob := _job;
    endif;
		
	// TFS 50889 PRP Special - if TI has a Mark, use new collection on Terminal to find an allocation
	ti := self.myCMIFYAAutoPlan.getMyTrackedItem;
	if ti &lt;&gt; null and ti.mark &lt;&gt; null then
		if self.checkMarkDictSpecial(ti.mark, ti.getImExStatus, _terminal) then
			return true;
		endif;
	endif;
	// TFS 50889 end
	
	// Get priority value of tracked item.
	priorityValue := self.getYAPriorityValueForCMIF(_terminal, autoPlanCmif);
		
	yardAllocation := self.getYardAllocation(_terminal, _terminalArea, priorityValue);
	
	if yardAllocation = null then
		if _terminalArea &lt;&gt; null then
			// Need an allocation.
			self.addLogEntry(AP_Log_YA_Global,'Cannot locate yard allocation in area ' &amp; _terminalArea.id, false);
			self.setHadError(true);
			app.raiseCMWarning2(AutoPlanningYAError, autoPlanCmif.getID(), 'cannot locate appropriate yard allocation in area ' &amp; _terminalArea.id, null, null,_terminalArea);
		else
			// Need an allocation.
			self.addLogEntry(AP_Log_YA_Global,'Cannot locate yard allocation in terminal ' &amp; _terminal.code, false);
			self.setHadError(true);
			app.raiseCMWarning2(AutoPlanningYAError, autoPlanCmif.getID(), 'cannot locate appropriate yard allocation in terminal ' &amp; _terminal.code, null, null, _terminal);
		endif;
		return false;
	endif;
	
	if _terminalArea &lt;&gt; null then
		allocationDict := _terminalArea.allYardAllocations;
	else
		allocationDict := _terminal.allYardAllocations;
	endif;
	
	if self.isForTwinDeck then
		self.doAutoPlanOfTwinTI(twinYardAllocation,self.myLinkedYAAutoPlan.allLogging, self.myLinkedYAAutoPlan.allVerboseLogging);
		if twinYardAllocation = null then
			self.myLinkedYAAutoPlan.allVerboseLogging.add('Could not find a yard allocation with more than one twinnable location.');
			self.setHadError(true);
			return false;
		else
			self.myLinkedYAAutoPlan.allVerboseLogging.add('**TWIN Allocation** - ' &amp; twinYardAllocation.code &amp; '/Priority - ' &amp; twinYardAllocation.priorityValue.String);
		endif;
	endif;
	locsFoundForThisAlloc:=0;
	iter := allocationDict.createIterator();
	
	iter.startAtObject(yardAllocation);
	while iter.next(yardAllocation) do
		self.sharedLock(yardAllocation);
		
		// CCMS 1013
		if yardAllocation.isDisabled or not yardAllocation.includeInYardDisplays() then
			// PAR 27800 - do not log disabled yard allocations
			//self.addLogEntry('**Allocation** - ' &amp; yardAllocation.code &amp; '/Priority - ' &amp; yardAllocation.priorityValue.String &amp; ' **DISABLED**', false);
			self.unlock(yardAllocation);
			continue;
		endif;
		
		//self.addLogEntry(AP_Log_YA_Name,'**Allocation** - ' &amp; yardAllocation.code &amp; '/Priority - ' &amp; yardAllocation.priorityValue.String, false);
		self.addLogEntry(AP_Log_YA_Name,'Allocation - [' &amp; yardAllocation.priorityValue.String.padLeadingZeros(6) &amp; '] ' &amp; yardAllocation.code, false);
		
		if self.isForTwinDeck then
			//if the found twin allocation priority value is greater than the found allocation there is really no point in continuing
			if twinYardAllocation.priorityValue &gt; yardAllocation.priorityValue then
				self.addLogEntry(AP_Log_YA_Global,'Further searching has been stopped as the twin allocation - ' &amp; twinYardAllocation.code &amp; ' has a higher priorty than found allocation - ' &amp; yardAllocation.code , false);
				self.setHadError(true);
				return false;
			endif;
		endif;
		
		if yardAllocation.compareCriteriaToCMIF(self, autoPlanCmif) then 
			// Time to search for some locations.
			self.initializeForNextAllocation(yardAllocation);
			foundPrior := self.numberOfLocationsFound;	//25 Jul 2013	NDl	Par 31706
			
			//epr par 19133 CCMS 1032 15/3/09			
			okToSearchIn:=true;
			if self.isForTwinDeck then
				okToSearchIn:= twinYardAllocation = yardAllocation;
				if not okToSearchIn then
					self.addLogEntry(AP_Log_YA_Default,'Can not use allocation - ' &amp; yardAllocation.code &amp; " as this does not match the twin container's found allocation of - " &amp; twinYardAllocation.code, false);
			
				endif;
			endif;
			
			if okToSearchIn and  yardAllocation.searchLocationsIn(self,_terminalArea) then //epr par 35377 22/12/14 
				self.addLogEntry(AP_Log_YA_Global,'Located position within allocation - ' &amp; yardAllocation.code &amp; ' (' &amp; self.getFoundLocationDesc() &amp; ')', false);
				self.isPlannedToFullGCArea := yardAllocation.isFullGCArea;	// MTN-18897
				return true;
			
			endif;
			
			
			if self.agentUsage = self.Scenario_Twin then
				//epr par 20017 19/6/09 could be only one lc found if it is a block stack
				if autoPlanCmif.allFoundLCs.size = 1 then
					if autoPlanCmif.allFoundLCs.first.isKindOf(CM_BlockController) then
						self.addLogEntry(AP_Log_YA_Global,'Further searching has been stopped as allocation - ' &amp; yardAllocation.code &amp; ' has found a Block Stack with twinable locations', false);
						return true;
					endif;
				endif;
				locsFoundForThisAlloc:=self.numberOfLocationsFound - locsFoundForThisAlloc;
				if locsFoundForThisAlloc &gt; 1 then
					self.addLogEntry(AP_Log_YA_Global,'Further searching has been stopped as allocation - ' &amp; yardAllocation.code &amp; ' has found ' &amp; locsFoundForThisAlloc.asStringJMT &amp;' twinable locations', false);
					return true;
				endif;
			endif;
			
			// CCMS1030 Save the first YA to fail due to lack of space
			self.setFirstYAFailure(yardAllocation);
			
			// Check sometimes and last resort locations.
			if self.getNestedAllocationLC() then
				self.addLogEntry(AP_Log_YA_Global,'Located nested position in allocation - ' &amp; yardAllocation.code &amp; ' (' &amp; self.getFoundLocationDesc() &amp; ')', false);
				return true;
			endif;
			
			if yardAllocation.noLocationOption = YANoLocation_Stop then
				// allocation does not allow any further searching.
				self.addLogEntry(AP_Log_YA_Default,'Further searching has been stopped by allocation - ' &amp; yardAllocation.code, false);
				break;
			endif;
		// Continue searching.
			if foundPrior = self.numberOfLocationsFound then	//25 Jul 2013	NDL	Par 31706
				noSpaceMsg := true;
				if autoPlanCmif.allLocations &lt;&gt; null then 
					foreach lc in autoPlanCmif.allLocations do
						if autoPlanCmif.allFailedLocations.includes(lc) then
							noSpaceMsg := false;
							self.addLogEntry(AP_Log_YA_Default,'Finished searching, cargo already in (' &amp; yardAllocation.code &amp; ')', false);
							break;
						endif;
					endforeach;
				endif;
				if noSpaceMsg then
					self.addLogEntry(AP_Log_YA_No_Space,'Finished searching, no space (' &amp; yardAllocation.code &amp; ')', false);	//01 Mar 2012	NDL	Par 29195
				endif;
			endif;
		endif;
		
		//self.addLogEntry(AP_Log_YA_Default,'Finished searching allocation . . . ' &amp; yardAllocation.code, false);
		self.unlock(yardAllocation);
	endwhile;
	
	if self.isSingleProcessing() then
	
		//15 Jun 2016	NDL	TFS 2172
		if self.myCMIFYAAutoPlan.tiIsSplittable() and not self.myCMIFYAAutoPlan.allLocationsForSplit.isEmpty then
			//we might be able to split over several locations, check the total available space.
			self.addLogEntry(AP_Log_YA_Global,'Auto planning failed to find a single location big enough, now considering splitting over multiple locations', false);
			if self.myCMIFYAAutoPlan.hasSpaceIfSplit( self ) then
				self.addLogEntry(AP_Log_YA_Global,'Auto planning located enough space using split moves over multiple locations. [YA Multi Range option]', false);
				return self.createSplitMoveCMIFs();
				//The main caller "app.autoPlanJobTiYA" will use cmif move controllers for the split moves or remove them
			else
				self.addLogEntry(AP_Log_YA_Global,'Auto planning failed to find space using split moves over multiple locations. [YA Multi Range option]', false);
			endif;
		endif;
	
		if autoPlanCmif.allPassedLocationsRestricted.isEmpty then	
			self.addLogEntry(AP_Log_YA_Global,'Auto planning failed to find location', false);
			self.setHadError(true);			
		else //cnwrd1 par 29269 14.3.2012
			self.addLogEntry(AP_Log_YA_Global,'Auto planning failed to find unrestricted location, but found restricted location ' &amp; self.getFoundLocationDesc(), false);
			self.setHadError(true);
			return true;
		endif;
	else
		self.addLogEntry(AP_Log_YA_Global,'Auto planning found ' &amp; self.numberOfLocationsFound.String &amp; ' location(s)', false);
	endif;
	
	return false;
		
epilog

	executeWhen JMTDevelopmentEnvironment;
		app.writeStatement(self.getLoggingString);
	endExecuteWhen;


	if yardAllocation &lt;&gt; null then
		self.unlock(yardAllocation);
	endif;
	
	self.createLoggingAlert();
	self.agentUsage := self.Normal_Usage;

	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_job" type="CM_Job"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchAllocationsOut" id="5c076671-ec02-47dd-bd37-5a0232ea8a83">
        <updating/>
        <source>searchAllocationsOut(_terminal : CM_Terminal; _terminalArea : CM_TerminalArea) : Boolean updating, protected;
// -------------------------------------------
// Created 31 May 2005 by cnwdvb1
// -------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 10/03/2021	navdap1		TFS 50889 PRP Yard Allocation Performance Improvement
vars

	priorityValue	: Real;
	yardAllocation	: CM_YardAllocation;
	locationsArray	: CM_LCArray;
	iter			: Iterator;
	allocationDict	: CM_YAByPriorityDict;
	yaRequest		: CMIF_YARequest;				// TFS 50889

begin

	if _terminalArea &lt;&gt; null then
		self.addLogEntry(AP_Log_YA_Default,'Using specified terminal area - ' &amp; _terminalArea.id, false);	
		if _terminalArea.myTerminal &lt;&gt; _terminal then
			self.addLogEntry(AP_Log_YA_Default,'Specified terminal area is not located in selected terminal', false);
			self.setHadError(true);
			app.raiseCMException2(AutoPlanningYAError, self.myCurrentCMIFYAAutoPlan.getID(), 'Specified terminal area is not located in selected terminal', null, null);
			return false;
		endif;
	endif;
	
	self.forOutput := true;
	self.bestPickOverstowedTI := null;
	self.lastOverstowLevel := 99999;
	
	// TFS 50889 PRP Special - if TI has a Mark, use new collection on Terminal to find an allocation
	if self.myCurrentCMIFYAAutoPlan.isKindOf(CMIF_YARequest) then
		yaRequest := self.myCurrentCMIFYAAutoPlan.CMIF_YARequest;
		if yaRequest.mark &lt;&gt; null then
			if self.checkMarkDictSpecial(yaRequest.mark, yaRequest.imexStatus, _terminal) then
				return true;
			endif;
		endif;
	endif;
	// TFS 50889 end
	
	// Get priority value of tracked item.
	priorityValue := self.getYAPriorityValueForCMIF(_terminal, self.myCurrentCMIFYAAutoPlan);
	yardAllocation := self.getYardAllocation(_terminal, _terminalArea, priorityValue);
	
	// 18/02/2010	cnwjre1	CCMS 1101 don't raise an error if no yard allocations, just return false
	//	as the call to this method is now followed by a 'best-pick' location search.
	if yardAllocation = null then
		return false;
	endif;
	
	if _terminalArea &lt;&gt; null then
		allocationDict := _terminalArea.allYardAllocations;
	else
		allocationDict := _terminal.allYardAllocations;
	endif;
	
	iter := allocationDict.createIterator();

	iter.startAtObject(yardAllocation);
	while iter.next(yardAllocation) do
		self.sharedLock(yardAllocation);
		
		
		// CCMS 1013
		if yardAllocation.isDisabled or not yardAllocation.includeInYardDisplays() then
			self.unlock(yardAllocation);
			continue;
		endif;
		
		//self.addLogEntry(AP_Log_YA_Name,'**Allocation** - ' &amp; yardAllocation.code &amp; '/Priority - ' &amp; yardAllocation.priorityValue.String, false);
		self.addLogEntry(AP_Log_YA_Name,'Allocation - [' &amp; yardAllocation.priorityValue.String.padLeadingZeros(6) &amp; '] ' &amp; yardAllocation.code, false);
		
		if yardAllocation.compareCriteriaToCMIF(self, self.myCurrentCMIFYAAutoPlan) then 
			self.initializeForNextAllocation(yardAllocation);
			//epr par 35377 22/12/14
			if yardAllocation.searchLocationsOut(self,_terminalArea) then
				self.addLogEntry(AP_Log_YA_Global,'Located position within allocation - ' &amp; yardAllocation.code &amp; ' (' &amp; self.getFoundLocationDesc() &amp; ')', false);
				return true;
			endif;
			if yardAllocation.noLocationOption = YANoLocation_Stop then
				// allocation does not allow any further searching.
				self.addLogEntry(AP_Log_YA_Global,'Further searching has been halted by allocation - ' &amp; yardAllocation.code, false);	
				self.addLogEntry(AP_Log_YA_Global,'Auto planning failed to find location', false);
				self.setHadError(true);
				return false;
			endif;
		endif;	
		self.addLogEntry(AP_Log_YA_Default,'Finished searching allocation . . . ' &amp; yardAllocation.code, false);
		self.unlock(yardAllocation);
	endwhile;
	
	self.addLogEntry(AP_Log_YA_Global,'Auto planning failed', false);
	self.setHadError(true);
	return false;

epilog
	if yardAllocation &lt;&gt; null then
		self.unlock(yardAllocation);
	endif;
	
	self.forOutput := false;
//	self.createLoggingAlert();		// TFS 3172 12/1/17 moved to caller
	self.agentUsage := self.Normal_Usage;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchForOverstowLocation" id="7dddf21d-4a11-4cbf-a96b-be8658c77c3c">
        <updating/>
        <source>searchForOverstowLocation(_ti : CM_TrackedItem; _terminal	: CM_Terminal; _terminalArea : CM_GridArea) : Boolean updating;
// -------------------------------------------
// Created 15 September 2005 by cnwdvb1
// -------------------------------------------
vars

	yaCMIF			: CMIF_YAAutoPlan;

begin

	if _ti = null then
		// Raise exception.
		app.raiseCMException2(AutoPlanningYAError, null, 'tracked item has not been specified', null, null);
		return false;
	endif;
	
	if _terminalArea = null then
		// Raise exception.
		app.raiseCMException2(AutoPlanningYAError, null, 'terminal area has not been specified', null, null);
		return false;
	endif;
	
	self.initialiseSearchForOverstow(_ti, _terminal, _terminalArea);
	
	yaCMIF := self.myCMIFYAAutoPlan;
	
	self.sharedLock(_ti);
	
	yaCMIF.attachTI(_ti);
	
	// CCMS 1012
	self.setNumberOfFreeSpacesReq();
	
	// Must set number of controllers here as used all over the place.
//	if process.isCnwab1() then
		self.numControllers := yaCMIF.calculateMoveLCsFromTA(_terminalArea);
//	else
//	self.numControllers := yaCMIF.calculateMoveLCs();
//	endif;

	return _terminalArea.testLocationsForOverstow(self);
			
epilog

	if _ti &lt;&gt; null then
		self.unlock(_ti);
	endif;
	
	self.createLoggingAlert();
	self.agentUsage := self.Normal_Usage;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_GridArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchOnsite" id="313e8b92-6980-4611-8b02-4a3b718d3263">
        <updating/>
        <source>searchOnsite(_terminal: CM_Terminal): Boolean updating;
//04 June 2010	cnwdw1	PAR 23677
// Search the OnSite Mt dictionary to find cargo that matches the request 
// The request needs to have at least an operator and an ISO Type
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 20/11/2014	cnwdap1		PAR #35236 Check ISO Group substitutions as well
vars
	operator: CM_Operator;
	operatorTerminal: CM_OperatorTerminal;
	isoType: CM_ISOType;
	ta: CM_TerminalArea;
	checkedTAs: CM_TerminalAreaSet;
	request: CMIF_YARequest;
	groupIter: Iterator;
	ti: CM_Container;
	isoGroup: CM_ISOTypeGroup;
	result: Boolean;
	terminalAreas: CM_TerminalAreaArray;
	yardDeliveryRequest : CM_YardDeliveryRequest;		// PAR #35236
	subGroup : CM_ISOTypeGroup;							// PAR #35236
begin
	request := self.myCurrentCMIFYAAutoPlan.CMIF_YARequest;
	if request = null then
		return false;
	endif;
	operator := _terminal.myRoot.allOperators[request.operatorCode];
	if operator = null then
		return false;
	endif;
	operatorTerminal := operator.getOperatorTerminal(_terminal, false);
	if operatorTerminal = null then
		return false;
	endif;
	
	self.addLogEntry(AP_Log_YA_Default,'Search Onsite MT Dict operator: ' &amp; operator.code, false);
	if request.allTerminalAreas.size &gt; 0 then
		create terminalAreas transient;
		request.allTerminalAreas.copy(terminalAreas);
		self.addLogEntry(AP_Log_YA_Default,'TerminalAreas: ' &amp; terminalAreas.first.id, false);
	endif;
	self.addLogEntry(AP_Log_YA_Default,'Request Details: ' &amp; request.display, false);
	
	// need to null these out as hasAvailableMatchingTI uses the yaautoplanagent
	// and resets it back to request saved above
	self.setCurrentYAAutoPlanToNull();
	self.setYAAutoPlanToNull();
	
	create checkedTAs transient;
	if request.isoType &lt;&gt; null then
		result := self.searchOnsiteByISOType(request, terminalAreas, operatorTerminal, request.isoType, checkedTAs);
	endif;
	
	if not result and request.isoGroup &lt;&gt; null then
		// If the request is for a group, need to loop through all the iso types in the group
		isoGroup := app.myRoot.allISOTypeGroups[request.isoGroup];
		groupIter := isoGroup.allISOTypes.createIterator;
		while groupIter.next(isoType) do
			if request.isoType &lt;&gt; null and request.isoType = isoType.code then
				continue;
			endif;
			result := self.searchOnsiteByISOType(request, terminalAreas, operatorTerminal, isoType.code, checkedTAs);
			if result then
				break;
			endif;
		endwhile;
		
		// PAR #35236 need to look at ISO group subs here.
		if request.myDeliveryRequest &lt;&gt; null and request.myDeliveryRequest.isKindOf(CM_YardDeliveryRequest) then
			yardDeliveryRequest := request.myDeliveryRequest.CM_YardDeliveryRequest;
		endif;
		
		if yardDeliveryRequest &lt;&gt; null and yardDeliveryRequest.myRelease &lt;&gt; null and yardDeliveryRequest.myRelease.canBeHiLoCube then
			foreach subGroup in isoGroup.allSubstitutingISOGroups do
				delete groupIter;
				groupIter := subGroup.allISOTypes.createIterator;
				self.addLogEntry(AP_Log_YA_Default,'searchOnsite request has ISO Group Substitutes ('&amp; subGroup.code &amp;') searching ISO Type for group', false);
				while groupIter.next(isoType) do
					self.addLogEntry(AP_Log_YA_Default,'searchOnsite request Substitute ISO Group by ISO Type(' &amp; isoType.code &amp; '), searching first for that ISO Type in searchOnsite', false);
					result := self.searchOnsiteByISOType(request, terminalAreas, operatorTerminal, isoType.code, checkedTAs);
					self.addLogEntry(AP_Log_YA_Default,'searchOnsite request Substitute ISO Group by ISO Type(' &amp; isoType.code &amp; '), searching first for that ISO Type in searchOnsite result :' &amp; result.asStringJMT, false);
					if result then
						break;
					endif;
				endwhile;		
			endforeach;
		endif;
		// PAR #35236 end
		
	endif;
	self.setCurrentYAAutoPlan(request);
	self.addLogEntry(AP_Log_YA_Default,'Search Onsite MT Dict return: ' &amp; result.String, false);
	return result;
epilog
//	self.createLoggingAlert();	// TFS 3172 12/1/17 moved to caller
	delete groupIter;
	delete checkedTAs;	
	delete terminalAreas;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchOnsiteBestPick" id="49ba80ba-8131-4761-ad66-a72285b905ab">
        <updating/>
        <source>searchOnsiteBestPick(_terminal: CM_Terminal): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2011	cnwrd1	Initial creation

*/

vars
	request				: CMIF_YARequest;
	anAllocation 		: CM_YardAllocation;
	result				: Boolean;
begin
	request := self.myCurrentCMIFYAAutoPlan.CMIF_YARequest;
	if request = null then
		return false;
	endif;
	
	anAllocation := request.myAllocation;

	if anAllocation &lt;&gt; null then	
		result := self.searchOnsiteBestPickAlloc( _terminal , anAllocation);
	else
		result := self.searchOnsiteBestPickStd(_terminal);
	endif;
	
	return result;
epilog
	if not result then				
		self.createLoggingAlert();
	endif;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchOnsiteBestPickAlloc" id="5bb0b40d-98c1-4d9a-9ea6-11e920259e87">
        <updating/>
        <source>searchOnsiteBestPickAlloc( _terminal : CM_Terminal; _anAlloc : CM_YardAllocation) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 January 2013	cnwrd1	Initial creation

*/

vars
	operator: CM_Operator;
	operatorTerminal: CM_OperatorTerminal;
	isoType: CM_ISOType;
	ta: CM_TerminalArea;
	request: CMIF_YARequest;
	groupIter: Iterator;
	ti: CM_Container;
	isoGroup,
	subGroup : CM_ISOTypeGroup;
	isoTypeString : String;
	result: Boolean;
	terminalAreas: CM_TerminalAreaArray;
	terminalAreaGridObjects : CM_GridObjectArray;
	anAllocation 			: CM_YardAllocation;
	yaData : CM_YAData;
	yaCriteria : CM_YACriteria;	
	obj : Object;
	aVoyage : CM_Voyage;
begin
	request := self.myCurrentCMIFYAAutoPlan.CMIF_YARequest;
	if request = null then
		return false;
	endif;
	
	/*
	
	if request.myAllocation exist we need a different aproach here.
	
	loop round the operators until we find a location
	
	if no operators we'll go for a voyage collection.
	
	*/
	
	anAllocation := _anAlloc;

	if anAllocation = null then	
		return false;
	endif;
	
	if request.allTerminalAreas.size &gt; 0 then
		create terminalAreas transient;
		request.allTerminalAreas.copy(terminalAreas);
		create terminalAreaGridObjects transient;
		request.allTerminalAreaGridObjects.copy(terminalAreaGridObjects);
		self.addLogEntry(AP_Log_YA_Default,'TerminalAreas: ' &amp; terminalAreas.first.id, false);
	endif;
	self.addLogEntry(AP_Log_YA_Default,'Request Details: ' &amp; request.display, false);
	
	// we have an allocation so we need to check if it has operators ( request.myoperator will have been set from this anyhow)
	yaCriteria := anAllocation.getCriteriaOfTypeValue(YACriteriaType_OperatorItem);
	
	if yaCriteria &lt;&gt; null then
		//we should have operators
		yaData := yaCriteria.myYAData;
			
		foreach obj in yaData.CM_YADataObjects.allObjects do
	
			if result then
				break;
			endif;
			
			operator := obj.CM_Operator;
			
			operatorTerminal := operator.getOperatorTerminal(_terminal, false);
			if operatorTerminal = null then
				continue;
			endif;
			
			self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick(least overstowed): ' &amp; operator.code, false);
			self.setCurrentYAAutoPlanToNull();
			self.setYAAutoPlanToNull();
		
			if request.isoType = null and request.isoGroup = null then
				self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick(No ISO Type): ', false);
				result := self.searchOnsiteByBestPick(request, terminalAreas, terminalAreaGridObjects, operatorTerminal, null);
			elseif request.isoType &lt;&gt; null then
				result := self.searchOnsiteByBestPick(request, terminalAreas, terminalAreaGridObjects, operatorTerminal, request.isoType);
				
				if not result and request.myDeliveryRequest &lt;&gt; null and request.myDeliveryRequest.myOriginatingBulkRelease &lt;&gt; null and request.myDeliveryRequest.myOriginatingBulkRelease.canBeHiLoCube then
				// we are using ISO group substitution here.				
					isoGroup := app.myRoot.allISOTypeGroups[request.isoGroup];
					if isoGroup &lt;&gt; null then
					
						groupIter := isoGroup.allISOTypes.createIterator;
						while groupIter.next(isoType) do
							result := self.searchOnsiteByBestPick(request, terminalAreas,terminalAreaGridObjects, operatorTerminal, isoType.code);
							if result then
								break;
							endif;
						endwhile;
						
						if not result then 
							foreach subGroup in isoGroup.allSubstitutingISOGroups do
								groupIter := subGroup.allISOTypes.createIterator;
								while groupIter.next(isoType) do
									result := self.searchOnsiteByBestPick(request, terminalAreas,terminalAreaGridObjects, operatorTerminal, isoType.code);
									if result then
										break;
									endif;
								endwhile;		
							endforeach;
						endif;
					endif;
				endif;
				
			elseif request.isoGroup &lt;&gt; null then
				isoGroup := app.myRoot.allISOTypeGroups[request.isoGroup];
				groupIter := isoGroup.allISOTypes.createIterator;
				while groupIter.next(isoType) do
					result := self.searchOnsiteByBestPick(request, terminalAreas,terminalAreaGridObjects, operatorTerminal, isoType.code);
					if result then
						break;
					endif;
				endwhile;
				
				//cnwrd1 par 31536 need to look at ISO group subs here.
				if request.myDeliveryRequest &lt;&gt; null and request.myDeliveryRequest.myOriginatingBulkRelease &lt;&gt; null and request.myDeliveryRequest.myOriginatingBulkRelease.canBeHiLoCube then
					foreach subGroup in isoGroup.allSubstitutingISOGroups do
						groupIter := subGroup.allISOTypes.createIterator;
						while groupIter.next(isoType) do
							result := self.searchOnsiteByBestPick(request, terminalAreas,terminalAreaGridObjects, operatorTerminal, isoType.code);
							if result then
								break;
							endif;
						endwhile;		
					endforeach;
				endif;
			endif;

		endforeach;

	else
	//ok no operator we need to see if we want to look at a voyage.	
		if anAllocation.isKindOf(CM_VoyageAllocation) or request.voyageCode &lt;&gt; null then		
		
			if request.voyageCode &lt;&gt; null then
				aVoyage := _terminal.allVoyagesByCode.getAtKeyGeq(request.voyageCode, null);
			else
				aVoyage := anAllocation.CM_VoyageAllocation.myVoyage;
			endif;
			
			result := self.searchOnsiteByBestPickVoyage(request, terminalAreas,terminalAreaGridObjects, aVoyage);			
		endif;		
	endif;
	

	
	self.setCurrentYAAutoPlan(request);
	self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick(least overstowed) returned: ' &amp; result.String, false);
	return result;
epilog
	delete groupIter;
	delete terminalAreas;
	delete terminalAreaGridObjects;
end;
</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_anAlloc" type="CM_YardAllocation"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchOnsiteBestPickStd" id="502f69b1-3d01-408c-8c1e-939194988b0b">
        <updating/>
        <source>searchOnsiteBestPickStd(_terminal: CM_Terminal): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2011	cnwrd1	Initial creation

*/

vars
	operator: CM_Operator;
	operatorTerminal: CM_OperatorTerminal;
	isoType: CM_ISOType;
	ta: CM_TerminalArea;
	request: CMIF_YARequest;
	groupIter: Iterator;
	ti: CM_Container;
	isoGroup: CM_ISOTypeGroup;
	result: Boolean;
	terminalAreas: CM_TerminalAreaArray;
	terminalAreaGridObjects : CM_GridObjectArray;
	subGroup : CM_ISOTypeGroup;
	aYardDeliveryRequest : CM_YardDeliveryRequest; 	
begin
	request := self.myCurrentCMIFYAAutoPlan.CMIF_YARequest;
	if request = null then
		return false;
	endif;
	operator := _terminal.myRoot.allOperators[request.operatorCode];
	if operator = null then
		return false;
	endif;
	operatorTerminal := operator.getOperatorTerminal(_terminal, false);
	if operatorTerminal = null then
		return false;
	endif;
	
	self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick(least overstowed): ' &amp; operator.code, false);
	if request.allTerminalAreas.size &gt; 0 then
		create terminalAreas transient;
		request.allTerminalAreas.copy(terminalAreas);
		create terminalAreaGridObjects transient;
		request.allTerminalAreaGridObjects.copy(terminalAreaGridObjects);
		self.addLogEntry(AP_Log_YA_Default,'TerminalAreas: ' &amp; terminalAreas.first.id, false);
	endif;
	self.addLogEntry(AP_Log_YA_Default,'Request Details: ' &amp; request.display, false);
	
	// need to null these out as hasAvailableMatchingTI uses the yaautoplanagent
	// and resets it back to request saved above
	self.setCurrentYAAutoPlanToNull();
	self.setYAAutoPlanToNull();
	
	if request.isoType &lt;&gt; null then
		self.addLogEntry(AP_Log_YA_Default,'searchOnsiteBestPick request has ISO Type(' &amp; request.isoType &amp; '), searching first for that ISO Type in searchOnsiteByBestPick', false);
		
		
		/*self.addLogEntry(AP_Log_YA_Default,'searchOnsiteBestPick operator onsite MT list start', false); 
		foreach ti in operatorTerminal.allOnsiteMTContsByISOType do			
			self.addLogEntry(AP_Log_YA_Default,ti.id &amp; ', '&amp; ti.isoType, false);		
		endforeach;
		self.addLogEntry(AP_Log_YA_Default,'searchOnsiteBestPick operator onsite MT list end', false);*/
		
		
		result := self.searchOnsiteByBestPick(request, terminalAreas, terminalAreaGridObjects, operatorTerminal, request.isoType);
		self.addLogEntry(AP_Log_YA_Default,'searchOnsiteBestPick request has ISO Type(' &amp; request.isoType &amp; '), searching first for that ISO Type in searchOnsiteByBestPick result :' &amp; result.asStringJMT, false);
	endif;
	
	if not result and request.isoGroup &lt;&gt; null then
		// If the request is for a group, need to loop through all the iso types in the group
		isoGroup := app.myRoot.allISOTypeGroups[request.isoGroup];
		groupIter := isoGroup.allISOTypes.createIterator;
		
		self.addLogEntry(AP_Log_YA_Default,'searchOnsiteBestPick request has ISO GRoup('&amp; isoGroup.code &amp;') searching ISO Type for group', false);
		while groupIter.next(isoType) do
			self.addLogEntry(AP_Log_YA_Default,'searchOnsiteBestPick request ISO Group by ISO Type(' &amp; isoType.code &amp; '), searching first for that ISO Type in searchOnsiteByBestPick', false);
			result := self.searchOnsiteByBestPick(request, terminalAreas,terminalAreaGridObjects, operatorTerminal, isoType.code);
			self.addLogEntry(AP_Log_YA_Default,'searchOnsiteBestPick request ISO Group by ISO Type(' &amp; isoType.code &amp; '), searching first for that ISO Type in searchOnsiteByBestPick result :' &amp; result.asStringJMT, false);
			if result then
				break;
			endif;
		endwhile;
		
		//cnwrd1 par 32336
		if request.myDeliveryRequest &lt;&gt; null and request.myDeliveryRequest.isKindOf(CM_YardDeliveryRequest) then
			aYardDeliveryRequest := request.myDeliveryRequest.CM_YardDeliveryRequest;
		endif;
		
		//cnwrd1 par 31536 need to look at ISO group subs here.
		if aYardDeliveryRequest &lt;&gt; null and aYardDeliveryRequest.myRelease &lt;&gt; null and  aYardDeliveryRequest.myRelease.canBeHiLoCube then
			foreach subGroup in isoGroup.allSubstitutingISOGroups do
				groupIter := subGroup.allISOTypes.createIterator;
				self.addLogEntry(AP_Log_YA_Default,'searchOnsiteBestPick request has ISO Group Substitutes ('&amp; subGroup.code &amp;') searching ISO Type for group', false);
				while groupIter.next(isoType) do
					self.addLogEntry(AP_Log_YA_Default,'searchOnsiteBestPick request Substitute ISO Group by ISO Type(' &amp; isoType.code &amp; '), searching first for that ISO Type in searchOnsiteByBestPick', false);
					result := self.searchOnsiteByBestPick(request, terminalAreas,terminalAreaGridObjects, operatorTerminal, isoType.code);
					self.addLogEntry(AP_Log_YA_Default,'searchOnsiteBestPick request Substitute ISO Group by ISO Type(' &amp; isoType.code &amp; '), searching first for that ISO Type in searchOnsiteByBestPick result :' &amp; result.asStringJMT, false);
					if result then
						break;
					endif;
				endwhile;		
			endforeach;
		endif;	
		
	endif;
	self.setCurrentYAAutoPlan(request);
	self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick(least overstowed) returned: ' &amp; result.String, false);
	return result;
epilog
	if not result then				// PAR 26671
		self.createLoggingAlert();
	endif;
	delete groupIter;
	delete terminalAreas;
	delete terminalAreaGridObjects;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchOnsiteBulkReleaseAlloc" id="a0f2975f-aae7-4d59-8a7d-a4e413b23cd9">
        <updating/>
        <source>searchOnsiteBulkReleaseAlloc( _request : CM_Request ) : Boolean updating;

/*

Purpose: 	Attempt to find a source location for one of a list of allocated cargo items on a bulk release. 
			Here we dont care about yard allocations etc, we know the list of cargo we ultimatly will pick up, just not the exact individual item

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2013	cnwrd1	Initial creation
//cnwrd1 par 32041 bulk release by type with assigned cargo should go here
*/

vars
	result : Boolean;
	request: CMIF_YARequest;	
	aTI,
	ti: CM_TrackedItem;
	tiTASet,
	allBRTIs : CM_TIArray;
	aBulkRelease, 
	taskBulkRelease : CM_BulkRelease;
	aReserveDetail,
	taskReserveDetail : CM_ReserveDetail;
	aTA : CM_TerminalArea;
	iter : Iterator;
	rtqTask : CM_RTQueueTask;
	count : Integer;
	skipped : Boolean;
	allTis	: CM_TISet; 
begin

	request := self.myCurrentCMIFYAAutoPlan.CMIF_YARequest;
	create allBRTIs transient;
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	//cnwrd1 par 33213
	aBulkRelease := _request.getBulkRelease;
	aReserveDetail := _request.getBulkReleaseReserveDetail;
	
	if aBulkRelease = null then
		self.addLogEntry(AP_Log_YA_Default,'No Bulk Release found.', false);
		return false;
	endif;
	
	//assume release by type with assigned cargo...	
	if aReserveDetail &lt;&gt; null then
		//we grab the list of allocated from here
		aReserveDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//aReserveDetail.allTrackedItems.copy(allBRTIs);
		allTis.copy(allBRTIs); //23/06/2023	navkc1	CR 58406 Task 58408
		//23 Apr 2020	NDL	TFS 49095 - some may be already on the wagon(s) waiting for the train to be released
		if aBulkRelease &lt;&gt; null and aBulkRelease.isRailType then
			self.addLogEntry(AP_Log_YA_Default,'Skipping Cargo assigned but already loaded to rail.' , false);
			//foreach ti in aReserveDetail.allTrackedItems do
			foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
				if ti.myPrimaryActualLocation &lt;&gt; null and ti.myPrimaryActualLocation.isWagon then
					if ti.jobRailRelease &lt;&gt; null then
						allBRTIs.remove(ti);
						self.addLogEntry(AP_Log_YA_Default, ti.id &amp; ' already has rail release job and on wagon!', false);
					endif;
				endif;
			endforeach;
		endif;
	else 
		//otherwise just go for the BR allocated
//		aBulkRelease.allTrackedItemsAssigned.copy(allBRTIs);
		aBulkRelease.getAvailableAssignedTis(allBRTIs, request.myDeliveryRequest);	//24 Apr 2020	NDL	TFS 49095  // ### TFS 52721 16NOV2022 NAVAB1
	endif;
	
	if allBRTIs.isEmpty then
		if skipped then
			self.addLogEntry(AP_Log_YA_Default,"All Assigned Cargo found already loaded.", false);
		else
			self.addLogEntry(AP_Log_YA_Default,"No Assigned Cargo found.", false);	//02 Sep 2014	NDL
		endif;
		return false;
	else
		self.addLogEntry(AP_Log_YA_Default, allBRTIs.size.String &amp; ' Cargo items found to check.', false);	//02 Sep 2014	NDL
	endif;
	
	create tiTASet transient;
	
	while not allBRTIs.isEmpty do
		aTI := allBRTIs.first;
		aTA := aTI.myTerminalArea;
		allBRTIs.remove(aTI);
		tiTASet.clear;
		
		//the TI may be on a machine or something
		if aTA = null then
			self.addLogEntry(AP_Log_YA_Default, aTI.id &amp; ' not on-site!', false);	//02 Sep 2014	NDL
		else
			tiTASet.add(aTI);			
			foreach ti in allBRTIs do
				if ti.myTerminalArea = aTA then
					tiTASet.add(ti);
				endif;
			endforeach;
			self.addLogEntry(AP_Log_YA_Default,'Checking Cargo queued in area ' &amp; aTA.id, false);
			foreach ti in tiTASet do
				if allBRTIs.includes(ti) then
					allBRTIs.remove(ti);
				endif;
				self.addLogEntry(AP_Log_YA_Default,ti.id ,  false);
			endforeach;
			
			//now should have a set of all ti's in the same terminal area.	
			//now we go through the terminal areas rtq entires and back track those to a bulk release (if possible) and check that against our bulk release
			// if we find one then we knock off a TI		
			//once we are done if we have a TI left then we have one available for the move.
			
			count := tiTASet.size;
			
			iter := aTA.allRTQueueTasks.createIterator;	
			aTA.allRTQueueTasks.startKeyGeq( TASK_DIRECTOR, TASK_UNACTIONED ,iter);
			while iter.next(rtqTask) do
	
				if rtqTask.status &lt;&gt; TASK_UNACTIONED or rtqTask.taskType &lt;&gt; TASK_DIRECTOR then
					break;
				endif;
				
				//epr par 33248 12/10/14  //epr par 35702 CCMS 2457 17/2/15
				if rtqTask.myEntry.getPreviousRelatedEntry() &lt;&gt; null then
					continue;
				endif;
									
				//there is an issue where th director tasks could of been created before cargo was assigned 
				//see par 35021
				// in which case it will -1 even though it wasn't for cargo in tiTASet and can cause autoplan to fail
				
				taskBulkRelease := rtqTask.myEntry.myWorkListEntry.myRequest.getBulkRelease;
				taskReserveDetail := rtqTask.myEntry.myWorkListEntry.myRequest.getBulkReleaseReserveDetail;	
				
				//epr par 33248 7/10/14
				if aReserveDetail &lt;&gt; null then
					if aReserveDetail = taskReserveDetail then
						count := count -1;
					endif;
				else
					if aBulkRelease = taskBulkRelease then
						count := count -1;
					endif;
				endif;
				
				if count = 0 then
					break;
				endif;
			endwhile;
					
			if count &gt; 0 then
				// we still have some cargo left here so this is a good location.
				request.addToFoundLocations(aTA.allLocationsControllers.first);
				result := true;
			else
				self.addLogEntry(AP_Log_YA_Default,'No cargo remain that are not queued to the bulk release', false);
			endif;
			
		endif;			
	endwhile;
	
	return result;	

epilog
	delete tiTASet;
	delete allBRTIs;
	delete iter;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_request" type="CM_Request"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchOnsiteByBestPick" id="0117f226-0202-4955-bece-c67ddb87e4f3">
        <updating/>
        <source>searchOnsiteByBestPick(_request: CMIF_YARequest input; _terminalAreas: CM_TerminalAreaArray; _terminalAreaGridObjects: CM_GridObjectArray; _operatorTerminal: CM_OperatorTerminal; _isoType: String): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 Nov 2011	cnwrd1	Initial creation
31 Jan 2014	cnwah9  PAR33410
20 Feb 2025 navma1	MTN-34072	TPT| Remove Cargo Once the Truck has been Completed via the Handheld
*/

vars
	ta					: CM_TerminalArea;
	gridObj 			: CM_GridObject;
	onsiteIter			: Iterator;
	ti					: CM_Container;
	aTI,
	resultTI 			: CM_TrackedItem;
	checkedTAs 			: CM_TerminalAreaSet;
	lastOverstowLevel,
	thisOverstow,
	sideAccessDirection	: Integer;
	agent  				: CM_YAAutoplanAgent;
	allOverstowedTIs	: CM_TIArray;
	count 				: Integer;
	lc					: CM_LocationsController;
begin
	
	create checkedTAs transient;
	lastOverstowLevel := 999999;
	create allOverstowedTIs transient;

	agent := app.myYAAgent;
	
	if _terminalAreas = null then
		self.addLogEntry(AP_Log_YA_Default,'searchOnsiteByBestPick _terminalAreas null', false);
	else
		self.addLogEntry(AP_Log_YA_Default,'searchOnsiteByBestPick _terminalAreas "' &amp; _terminalAreas.asStringJMT , false);
	endif;
	
	if _terminalAreaGridObjects = null then
		self.addLogEntry(AP_Log_YA_Default,'searchOnsiteByBestPick _terminalAreaGridObjects null', false);
	else
		self.addLogEntry(AP_Log_YA_Default,'searchOnsiteByBestPick _terminalAreaGridObjects "' &amp; _terminalAreaGridObjects.asStringJMT , false);
	endif;	
	
	if _operatorTerminal = null then
		self.addLogEntry(AP_Log_YA_Default,'searchOnsiteByBestPick _operatorTerminal null', false);
	else
		self.addLogEntry(AP_Log_YA_Default,'searchOnsiteByBestPick _operatorTerminal "' &amp; _operatorTerminal.displayCode , false);
	endif;	
	
	if _isoType = null then
		self.addLogEntry(AP_Log_YA_Default,'searchOnsiteByBestPick _isoType null', false);
	else
		self.addLogEntry(AP_Log_YA_Default,'searchOnsiteByBestPick _isoType "' &amp; _isoType , false);
	endif;	
		
	//here we want to step through all the terminal areas and look for the least overstowed compatable , available, TI.
	
	if _terminalAreas = null or _terminalAreas.isEmpty then
		self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick(everywhere - _terminalAreas empty).', false);
		//check the whole terminal.

	 	onsiteIter := _operatorTerminal.allOnsiteMTContsByISOType.createIterator;
		_operatorTerminal.allOnsiteMTContsByISOType.startKeyGeq(_isoType, onsiteIter);

		while onsiteIter.next(ti) do
			self.addLogEntry(AP_Log_YA_Default,'searchOnsiteByBestPick operator onsite MT next TI :' &amp; ti.id, false);
			
			self.addLogEntry(AP_Log_YA_Default,'searchOnsiteByBestPick TI ' &amp; ti.id &amp; ' ISO Type :' &amp; ti.isoType, false);
			if _isoType &lt;&gt; null and ti.isoType &lt;&gt; _isoType then
				self.addLogEntry(AP_Log_YA_Default,'searchOnsiteByBestPick ISO TYPE change break ', false);
				break;
			endif;
	
			lc := ti.myPrimaryActualLocation;
			
			//cnwjo3 par 23677
			if lc = null then
				self.addLogEntry(AP_Log_YA_Default,'searchOnsiteByBestPick TI ' &amp; ti.id &amp; ' myPrimaryActualLocation = null ', false);	
				continue;
			endif;
			
			//cnwjo3 par 23677
			if not lc.isKindOf(CM_YardController) and not lc.isKindOf(CM_TILCController) then
				self.addLogEntry(AP_Log_YA_Default,'searchOnsiteByBestPick TI ' &amp; ti.id &amp; ' myPrimaryActualLocation = not yard controller ', false);	
				continue;
			endif;		
			
			ta := lc.myTerminalArea;

			if ta &lt;&gt; null then  //cnwrd1 33380 to can be on vehicle etc and not have a terminalarea
				self.addLogEntry(AP_Log_YA_Default,'Terminal area from TA: '&amp; ta.id , false);
				
				if checkedTAs.includes(ta) then
					self.addLogEntry(AP_Log_YA_Default,'Terminal area from TA already processed ', false);
					continue;
				endif;
				checkedTAs.add(ta);
			endif;
			
			if ta &lt;&gt; null then //cnwah9 33410
				if self.myCurrentTerminal &lt;&gt; null and ta.isGridArea then
					self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick , TA is Grid area', false);
					//least overstowed best fit box in this ta
					aTI := ta.getAvailableMatchingTI(_request, null, null);							
					if aTI &lt;&gt; null then
						self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick ,found best matching TI = ' &amp; aTI.id, false);
						allOverstowedTIs.clear;
						sideAccessDirection:=null;
						
						agent.setCurrentYAAutoPlanToNull();	
						agent.setYAAutoPlanToNull();
						
						aTI.getAllOverstowedTIs(allOverstowedTIs,true,sideAccessDirection,null); // &lt;- this kills  _yaRequest
						thisOverstow := allOverstowedTIs.size;
						if thisOverstow &gt; 0 then
							self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick , ' &amp; aTI.id &amp; ' is overstowed by ' &amp; thisOverstow.asStringJMT() , false);
							if thisOverstow &lt; lastOverstowLevel then
								resultTI := aTI;
								lastOverstowLevel := thisOverstow;
							endif;
							continue;
						else
							self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick , ' &amp; aTI.id &amp; ' is not overstowed', false);
							// not overstowed, ideal box,  lets get out here!
							resultTI := aTI;
							break;
						endif;			
					else
						self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick , Area ' &amp; ta.id &amp; ' no appropriate cargo' , false);
					endif;
				else
					self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick , TA is NOT Grid area', false);
					if ta.hasAvailableMatchingTI(_request) then		
						//if we find a non grided area box we dont know how overstowed it is so we can assume its the best?
						self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick , TA has found available cargo', false);
						_request.clearAllFoundLocations();
						_request.addToFoundLocations(ta.allLocationsControllers.first);
					endif;
					//break;
				endif;
			endif;
		endwhile;
	 
	 if resultTI &lt;&gt; null and _request.allFoundLCs.isEmpty then
		self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick ,found best overall matching TI = ' &amp; resultTI.id, false);
		_request.addToFoundLocations(resultTI.getMyCurrentGridObject().getFirstLocationController() );
	 endif;
	 
	else
	//check those areas/sub areas we have 
		count := 0;
		foreach ta in _terminalAreas do
		self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick TA:' &amp; ta.id, false);
			if self.myCurrentTerminal &lt;&gt; null and ta.isGridArea then
				//least overstowed best fit box in this ta
				count := count +1;
				if _terminalAreaGridObjects.size &gt;= count then
					gridObj := _terminalAreaGridObjects[count];
					if gridObj &lt;&gt; null then
						self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick , TA is Grid area, grid = ' &amp; gridObj.label, false);					
					else
						self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick , TA is Grid area, no Grid Object', false);
					endif;
				else
					gridObj	:= null;
					self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick , TA is Grid area, no Grid Object', false);
				endif;
				
				aTI := ta.getAvailableMatchingTI(_request, null,gridObj);			
				
				if aTI &lt;&gt; null then
					self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick ,found best matching TI = ' &amp; aTI.id, false);
					allOverstowedTIs.clear;
					sideAccessDirection:=null;
					
					agent.setCurrentYAAutoPlanToNull();	
					agent.setYAAutoPlanToNull();
					
					aTI.getAllOverstowedTIs(allOverstowedTIs,true,sideAccessDirection,null); // &lt;- this kills  _yaRequest
					thisOverstow := allOverstowedTIs.size;
					
					if thisOverstow &gt; 0 then
						self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick , ' &amp; aTI.id &amp; ' is overstowed by ' &amp; thisOverstow.asStringJMT() , false);
						if thisOverstow &lt; lastOverstowLevel then
							resultTI := aTI;
							lastOverstowLevel := thisOverstow;
						endif;
						continue;
					else
						// not overstowed, ideal box,  lets get out here!
						self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick , ' &amp; aTI.id &amp; ' is not overstowed', false);
						resultTI := aTI;
						break;
					endif;			
				else
					self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick , Area ' &amp; ta.id &amp; ' no appropriate cargo' , false);
				endif;
			else
				self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick , TA is NOT Grid area', false);
				if ta.hasAvailableMatchingTI(_request) then		
					self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick , TA has found available cargo', false);
					//if we find a non grided area box we dont know how overstowed it is so we can assume its the best?
					_request.clearAllFoundLocations();
					_request.addToFoundLocations(ta.allLocationsControllers.first);
					break; //cnwrd1 par 31069 moved to here from below!
				endif;
			
			endif;		
		endforeach;
		
		if resultTI &lt;&gt; null and _request.allFoundLCs.isEmpty then
			self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick ,found best overall matching TI = ' &amp; resultTI.id, false);
			_request.addToFoundLocations(resultTI.getMyCurrentGridObject().getFirstLocationController() );		
		endif;
	endif;
	

	
	return not _request.allFoundLCs.isEmpty();
epilog
	delete onsiteIter;
	delete checkedTAs;
	delete allOverstowedTIs;
end;</source>
        <Parameter name="_request" type="CMIF_YARequest" usage="input"/>
        <Parameter name="_terminalAreas" type="CM_TerminalAreaArray"/>
        <Parameter name="_terminalAreaGridObjects" type="CM_GridObjectArray"/>
        <Parameter name="_operatorTerminal" type="CM_OperatorTerminal"/>
        <Parameter name="_isoType" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchOnsiteByBestPickVoyage" id="d775c8cc-8631-409b-b553-c67707bfbabc">
        <updating/>
        <source>searchOnsiteByBestPickVoyage(_request: CMIF_YARequest input; _terminalAreas: CM_TerminalAreaArray; _terminalAreaGridObjects: CM_GridObjectArray; _voyage: CM_Voyage): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Jan 2013	cnwrd1	Initial creation
20 Feb 2025 navma1	MTN-34072	TPT| Remove Cargo Once the Truck has been Completed via the Handheld
*/


vars
	ta					: CM_TerminalArea;
	gridObj				: CM_GridObject;
	onsiteIter			: Iterator;
	ti,
	aTI,
	resultTI 			: CM_TrackedItem;
	checkedTAs 			: CM_TerminalAreaSet;
	lastOverstowLevel,
	thisOverstow,
	sideAccessDirection	: Integer;
	agent  				: CM_YAAutoplanAgent;
	allOverstowedTIs	: CM_TIArray;
	count 				: Integer;
	lc					: CM_LocationsController;
begin
	
	create checkedTAs transient;
	lastOverstowLevel := 999999;
	create allOverstowedTIs transient;

	agent := app.myYAAgent;
		
	//here we want to step through all the terminal areas and look for the least overstowed compatable , available, TI.
	
	if _terminalAreas = null or _terminalAreas.isEmpty then
		self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick(Voyage).', false);
		//check the whole voyage.
	 	onsiteIter := _voyage.allOnsiteTIsByCargoTypeId.createIterator;
		while onsiteIter.next(ti) do
			
			lc := ti.myPrimaryActualLocation;					//21.02.2024 navma1 #MTN-34072
			
			//cnwjo3 par 23677
			if lc = null then
				continue;
			endif;
			
			//cnwjo3 par 23677
			if not lc.isKindOf(CM_YardController) and not lc.isKindOf(CM_TILCController) then
				continue;
			endif;		
			
			ta := lc.myTerminalArea;

			if checkedTAs.includes(ta) then
				continue;
			endif;
			
			checkedTAs.add(ta);

			if self.myCurrentTerminal &lt;&gt; null and ta.isGridArea then
				self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage , TA is Grid area', false);
				//least overstowed best fit box in this ta
				aTI := ta.getAvailableMatchingTI(_request, null, null);							
				if aTI &lt;&gt; null then
					self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage,found best matching TI = ' &amp; aTI.id, false);

					allOverstowedTIs.clear;
					sideAccessDirection:=null;
					
					agent.setCurrentYAAutoPlanToNull();	
					agent.setYAAutoPlanToNull();
					
					aTI.getAllOverstowedTIs(allOverstowedTIs,true,sideAccessDirection,null); // &lt;- this kills  _yaRequest
					thisOverstow := allOverstowedTIs.size;
					if thisOverstow &gt; 0 then
						self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage, ' &amp; aTI.id &amp; ' is overstowed by ' &amp; thisOverstow.asStringJMT() , false);
						if thisOverstow &lt; lastOverstowLevel then
							resultTI := aTI;
							lastOverstowLevel := thisOverstow;
						endif;
						continue;
					else
						self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage, ' &amp; aTI.id &amp; ' is not overstowed', false);
						// not overstowed, ideal box,  lets get out here!
						resultTI := aTI;
						break;
					endif;			
				else
					self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage, Area ' &amp; ta.id &amp; ' no appropriate cargo' , false);
				endif;
			else
				self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage, TA is NOT Grid area', false);
				if ta.hasAvailableMatchingTI(_request) then		
					//if we find a non grided area box we dont know how overstowed it is so we can assume its the best?
					self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage, TA has found available cargo', false);
					_request.clearAllFoundLocations();
					_request.addToFoundLocations(ta.allLocationsControllers.first);
				endif;
				
			endif;
		endwhile;
	 
	 if resultTI &lt;&gt; null and _request.allFoundLCs.isEmpty then
		self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage,found best overall matching TI = ' &amp; resultTI.id, false);
		_request.addToFoundLocations(resultTI.getMyCurrentGridObject().getFirstLocationController() );
	 endif;
	 
	else
	//check those areas/sub areas we have 
		count := 0;
		foreach ta in _terminalAreas do
		self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick TA by voyage:' &amp; ta.id, false);
			if self.myCurrentTerminal &lt;&gt; null and ta.isGridArea then
				//least overstowed best fit box in this ta
				count := count +1;
				if _terminalAreaGridObjects.size &gt;= count then
					gridObj := _terminalAreaGridObjects[count];
					if gridObj &lt;&gt; null then
						self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage, TA is Grid area, grid = ' &amp; gridObj.label, false);					
					else
						self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage, TA is Grid area, no Grid Object', false);
					endif;
				else
					gridObj	:= null;
					self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage, TA is Grid area, no Grid Object', false);
				endif;
				
				aTI := ta.getAvailableMatchingTI(_request, null,gridObj);			
				
				if aTI &lt;&gt; null then
					self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage,found best matching TI = ' &amp; aTI.id, false);

					allOverstowedTIs.clear;
					sideAccessDirection:=null;
					
					agent.setCurrentYAAutoPlanToNull();	
					agent.setYAAutoPlanToNull();
					
					aTI.getAllOverstowedTIs(allOverstowedTIs,true,sideAccessDirection,null); // &lt;- this kills  _yaRequest
					thisOverstow := allOverstowedTIs.size;
					
					if thisOverstow &gt; 0 then
						self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage, ' &amp; aTI.id &amp; ' is overstowed by ' &amp; thisOverstow.asStringJMT() , false);
						if thisOverstow &lt; lastOverstowLevel then
							resultTI := aTI;
							lastOverstowLevel := thisOverstow;
						endif;
						continue;
					else
						// not overstowed, ideal box,  lets get out here!
						self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage, ' &amp; aTI.id &amp; ' is not overstowed', false);
						resultTI := aTI;
						break;
					endif;			
				else
					self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage, Area ' &amp; ta.id &amp; ' no appropriate cargo' , false);
				endif;
			else
				self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage, TA is NOT Grid area', false);
				if ta.hasAvailableMatchingTI(_request) then		
					self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage, TA has found available cargo', false);
					//if we find a non grided area box we dont know how overstowed it is so we can assume its the best?
					_request.clearAllFoundLocations();
					_request.addToFoundLocations(ta.allLocationsControllers.first);
				endif;
				break;
			endif;		
		endforeach;
		 
		if resultTI &lt;&gt; null and _request.allFoundLCs.isEmpty then
			self.addLogEntry(AP_Log_YA_Default,'Search Onsite Best Pick by voyage,found best overall matching TI = ' &amp; resultTI.id, false);
	
			_request.addToFoundLocations(resultTI.getMyCurrentGridObject().getFirstLocationController() );
		endif;
	endif;
	

	
	return not _request.allFoundLCs.isEmpty();
epilog
	delete onsiteIter;
	delete checkedTAs;
	delete allOverstowedTIs;
end;</source>
        <Parameter name="_request" type="CMIF_YARequest" usage="input"/>
        <Parameter name="_terminalAreas" type="CM_TerminalAreaArray"/>
        <Parameter name="_terminalAreaGridObjects" type="CM_GridObjectArray"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searchOnsiteByISOType" id="9c4d0dd3-8cf3-4466-adef-f7606405ac94">
        <updating/>
        <source>searchOnsiteByISOType(_request: CMIF_YARequest input; _terminalAreas: CM_TerminalAreaArray; _operatorTerminal: CM_OperatorTerminal; _isoType: String; _checkedTAs: CM_TerminalAreaSet input): Boolean updating;
//04 June 2010	cnwdw1	PAR 23677
// Search the OnSite Mt dictionary to find cargo that matches the request ISO Type
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------
// 18/11/2014	cnwdap1		PAR #35236 If we have specific terminal areas, ignore "can terminal area have empties" check
//							- the user has told us to use a specific area, so we need to check it
// 20 Feb 2025 navma1	MTN-34072	TPT| Remove Cargo Once the Truck has been Completed via the Handheld
vars
	ta								: CM_TerminalArea;
	onsiteIter						: Iterator;
	ti								: CM_Container;
	aTI 							: CM_TrackedItem;
	lc 								: CM_LocationsController;
	isAutoPlanUseBestPickDirector	: Boolean;
begin
	
	onsiteIter 	:= _operatorTerminal.allOnsiteMTContsByISOType.createIterator;
	_operatorTerminal.allOnsiteMTContsByISOType.startKeyGeq(_isoType, onsiteIter);
	
	if self.myCurrentTerminal &lt;&gt; null   then															//21.02.2024 navma1 #MTN-34072
		isAutoPlanUseBestPickDirector := self.myCurrentTerminal.isAutoPlanUseBestPickDirector;
	endif;
	
	while onsiteIter.next(ti) do
		if ti.isoType &lt;&gt; _isoType then
			break;
		endif;

		//cnwjo3 par 23677
		lc := ti.myPrimaryActualLocation;																//21.02.2024 navma1 #MTN-34072
		
		if lc = null then
			continue;
		endif;
		
		//cnwjo3 par 23677
		if not lc.isKindOf(CM_YardController) and not lc.isKindOf(CM_TILCController) then
			continue;
		endif;		
		
		ta := lc.myTerminalArea;
		//if not self.canTerminalAreaHaveEmpties(ta) then																// PAR #35236
		if not self.canTerminalAreaHaveEmpties(ta) and (_terminalAreas = null or not _terminalAreas.includes(ta)) then	// PAR #35236
			continue;
		endif;
		if _terminalAreas &lt;&gt; null and _terminalAreas.size &gt; 0 and not _terminalAreas.includes(ta) then		// only look at ti if in specified area
			continue;
		endif;
		if _checkedTAs.includes(ta) then
			continue;
		endif;
		_checkedTAs.add(ta);

		if isAutoPlanUseBestPickDirector and ta.isGridArea then												//21.02.2024 navma1 #MTN-34072
			//least overstowed best fit box in this ta
			aTI := ta.getAvailableMatchingTI(_request, null, null);			
			if aTI &lt;&gt; null then
				_request.addToFoundLocations(aTI.getMyCurrentGridObject().getFirstLocationController() );
				break;
			endif;
		else
			if ta.hasAvailableMatchingTI(_request) then		
				_request.addToFoundLocations(ta.allLocationsControllers.first);
				break;
			endif;			
		endif;
	endwhile;
	
	return not _request.allFoundLCs.isEmpty();
epilog
	delete onsiteIter;
end;</source>
        <Parameter name="_request" type="CMIF_YARequest" usage="input"/>
        <Parameter name="_terminalAreas" type="CM_TerminalAreaArray"/>
        <Parameter name="_operatorTerminal" type="CM_OperatorTerminal"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_checkedTAs" type="CM_TerminalAreaSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCurrentYAAutoPlan" id="dae25240-10d3-405b-b544-dcfc759f001f">
        <updating/>
        <source>setCurrentYAAutoPlan(_cmifYAAutoPlan : CMIF_YAAutoPlan) updating;
vars
	invalidCurrentCMIFAutoPlan : Boolean;
begin
	if self.myCurrentCMIFYAAutoPlan &lt;&gt; _cmifYAAutoPlan then
		
		on Exception do app.handleDeletedObject(exception, self.myCurrentCMIFYAAutoPlan, invalidCurrentCMIFAutoPlan); //cnwas3 par 26706
		
		if self.myCMIFYAAutoPlan = self.myCurrentCMIFYAAutoPlan then
			self.myCMIFYAAutoPlan := null;
		endif;
		delete self.myCurrentCMIFYAAutoPlan;
		self.myCurrentCMIFYAAutoPlan:=_cmifYAAutoPlan;
	endif;
epilog

end;</source>
        <Parameter name="_cmifYAAutoPlan" type="CMIF_YAAutoPlan"/>
    </JadeMethod>
    <JadeMethod name="setCurrentYAAutoPlanToNull" id="31678b5d-6719-4160-bbf0-a1845fcff5a4">
        <updating/>
        <source>setCurrentYAAutoPlanToNull() updating;
// Set current YAAutoPlan cmif to null and do not delete an existing value 
// PAR 26671
begin
	self.myCurrentCMIFYAAutoPlan := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFirstYAFailure" id="352ba649-27cb-45e4-bbe3-b5afdf63e9ff">
        <updating/>
        <source>setFirstYAFailure(_ya: CM_YardAllocation) updating;
//04 December 2008	cnwdw1	
// CCMS 1030 The first YA to fail due to lack of space is saved
vars

begin
	if self.myFirstYAFailure = null then
		self.myFirstYAFailure := _ya;
		if self.myCMIFYAAutoPlan &lt;&gt; null then  // PAR 19412
			self.myCMIFYAAutoPlan.myFirstYAFailure := _ya;
		endif;
	endif;
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
    </JadeMethod>
