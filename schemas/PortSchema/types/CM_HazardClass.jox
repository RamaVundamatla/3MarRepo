    <JadeMethod name="setProxy" id="8afff7c5-d548-48b9-85d4-1b9622c8f836">
        <updating/>
        <source>setProxy(pCode,pDescription,pAlternateCode:String; pColour:Integer; _isNotAvailableForEntry  : Boolean) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.code := pCode[1:9];
	self.description := pDescription[1:40];
	self.alternateCode := pAlternateCode[1:9];
	self.colour := pColour;
	self.isNotAvailableForEntry := _isNotAvailableForEntry;
	self.myRoot := app.myRoot;
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pAlternateCode" type="String"/>
        <Parameter name="pColour" type="Integer"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
