    <JadeMethod name="cnwdad1_ListAllTranslatableStr" id="d9bf1b0b-d1c0-4afb-9de4-9de9200e03bd">
        <source>cnwdad1_ListAllTranslatableStr() protected;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
