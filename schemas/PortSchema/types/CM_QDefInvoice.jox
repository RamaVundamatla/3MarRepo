<Class name="CM_QDefInvoice" id="8c0fdeae-2afd-46bd-8b5b-8f0bf1030f5e">
    <superclass name="CM_QueryDefinition"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="useStaticInvoiceValues" id="a44229de-79c3-4b25-a8e8-c6e85e560501">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="45903541-6a19-4a0a-85fd-165c8575db64">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2014	cnwndl1	Initial creation	CCMS QNS 2348

*/

vars

begin

	self.className := CM_Invoice.name;
	
	//12/06/2024	navkc1 CR 64563 Task 64599
	if app.myRoot &lt;&gt; null and app.myRoot.isClientEuroPorts() then
		self.useStaticInvoiceValues := true;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createProperties" id="8e29256d-7a11-46c3-b15c-4f42ab54e1af">
        <source>createProperties();
/*

Purpose:			

Parameters:			

Return Value:		

/****Changes

Date		Name	TFS#			Description
============================================================================
13 May 2014	cnwndl1	CCMS QNS 2348	Initial creation	
16/06/2014	cnwjre1	34364 			rename some of the attributes
22/05/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
11/10/2017  cnwma1	TFS #7139 		JMT - Adding Invoice End Date to Selector Query
07/11/2018	jlgka1	TFS 40670		Add Consignee / Consignor Group.
03/06/2020  cnwma1  ChangeRequest   49400: ASPA - Invoice Enhancements for Barges
16/12/21 	navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link
06/12/22    navmv20 TFS CR 55309   Task 55556: Jade - Add all the new invoice attributes to the selector query
31/03/2023  navmv20 Bug 57023: EUP - inconsistent search behaviour with external number
16 October 2023	navmv20	Bug 60677: FR | EUP 54086 - Invoicing Maintenance enhancements - Selector Query - Invoice mode
15/01/2023	navkc1 ChangeRequest 59145 Task 61330: Jade - Selector Query
============================================================================*/

vars
	tmpProp		: CM_QueryProperty;
begin

	inheritMethod();
	
	//business unit
	create tmpProp as CM_QRefBankProperty persistent;
	tmpProp.set('Business Unit', CM_Invoice::bank.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//status
	create tmpProp as CM_QInvoiceStatusLookupMethod persistent;
	tmpProp.set('Invoice Status', CM_Invoice::getInvStatus.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//site
	create tmpProp as CM_QTiSiteLookupMethod persistent;
	tmpProp.set('Cargo Site', CM_Invoice::getCargoSite.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//cargo type
	//create tmpProp as CM_QCargoTypeLookupMethod persistent; //16/10/2023	navmv20	Bug 60677
	create tmpProp as CM_QCargoTypesLookupMethod persistent; //16/10/2023	navmv20	Bug 60677
	//tmpProp.set('Cargo Type', CM_Invoice::getCargoType.name, self.className); //16/10/2023	navmv20	Bug 60677
	tmpProp.set('Cargo Type', CM_Invoice::getCargoTypes.name, self.className); //16/10/2023	navmv20	Bug 60677
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//cargo id
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Cargo ID', CM_Invoice::getCargoId.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//posted invoice id
	create tmpProp as CM_QStringMethod persistent;
	//tmpProp.set('External Invoice Number', CM_Invoice::getExternalInvoiceNumber.name, self.className); //31/03/2023 navmv20 Bug 57023
	tmpProp.set('External Invoice Number', CM_Invoice::getExtInvNumberUpper.name, self.className); //31/03/2023 navmv20 Bug 57023
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//debtor name
	create tmpProp as CM_QRefDebtorMethod persistent;
	tmpProp.set('Debtor', CM_Invoice::getDebtor.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//financial period
	create tmpProp as CM_QDateMethod persistent;
	tmpProp.set('Financial Period', CM_Invoice::getPostedFinancialPeriod.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//vessel name
	create tmpProp as CM_QStrVesselProperty persistent;
	tmpProp.set('Vessel Name', CM_Invoice::vesselName.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//voyage no
	create tmpProp as CM_QStrVoyageProperty persistent;
	tmpProp.set('Voyage Code', CM_Invoice::voyageCode.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//posted invoice amount
	//12/06/2024	navkc1 CR 64563 Task 64599
	if self.useStaticInvoiceValues then
		create tmpProp as CM_QDecimalProperty persistent;
		tmpProp.set('Invoice Amount', CM_Invoice::totalAmount.name, self.className);
		tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
		self.allQueryProperties.add(tmpProp);
	else
		create tmpProp as CM_QDecimalMethod persistent;
		tmpProp.set('Invoice Amount', CM_Invoice::getTotalAmount.name, self.className);
		tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
		self.allQueryProperties.add(tmpProp);
	endif;
	
	//sailing date
	create tmpProp as CM_QDateMethod persistent;
	tmpProp.set('Voyage Departure Date', CM_Invoice::getVoyageSailingDate.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//arriving date
	create tmpProp as CM_QDateMethod persistent;
	tmpProp.set('Voyage Arrival Date', CM_Invoice::getVoyageArrivalDate.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//posting date
	create tmpProp as CM_QDateMethod persistent;
	tmpProp.set('Invoice Posted Date', CM_Invoice::getPostedDate.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//invoice type
	create tmpProp as CM_QRefInvTypeMethod persistent;
	tmpProp.set('Invoice Type', CM_Invoice::getInvoiceType.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//system invoice no
	create tmpProp as CM_QIntegerProperty persistent;
	tmpProp.set('Invoice Number', CM_Invoice::sequenceNum.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//is storage
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Invoice is Storage', CM_Invoice::isStorage.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//debtor account code
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Debtor Account Code', CM_Invoice::getDebtorAccountCode.name, self.className);
	tmpProp.needToUpperCase := true;
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	// debtor external reference
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Debtor External Reference', CM_Invoice::getDebtorExtRef.name, self.className);
	tmpProp.needToUpperCase := true;
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//invoice start date
	create tmpProp as CM_QDateProperty persistent;
	tmpProp.set('Invoice Start Date', CM_Invoice::fromDT.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//bill of lading
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Bill of Lading', CM_Invoice::getTrackedItemBOL.name, self.className);
	tmpProp.needToUpperCase := true;
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//consignee
	create tmpProp as CM_QRefConsignMethod persistent;
	tmpProp.CM_QRefConsignMethod.type := CONSIGNEE;
	tmpProp.set('Cargo Consignee', CM_Invoice::getTrackedItemConsignee.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	// voyage external code
	create tmpProp as CM_QStringMethod persistent;														// TFS 4050
	tmpProp.set('Voyage External Code', CM_Invoice::getVoyageExternalCode.name, self.className);		// TFS 4050
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//invoice End date
	create tmpProp as CM_QDateProperty persistent;                                 //cnwma1 11.10.2017 TFS #7139
	tmpProp.set('Invoice End Date', CM_Invoice::toDT.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStrConsigneeGroupMethod persistent;									// jlgka1 TFS 40670 --&gt;
	tmpProp.set('Cargo Consignee Group', CM_Invoice::getConsignGroupCode.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);													// jlgka1 TFS 40670 &lt;--
	
	// voyage group code
	create tmpProp as CM_QStringProperty persistent;		                                        //03/06/2020 cnwma1 Tfs #49400											
	tmpProp.set('Voyage Group Code', CM_Invoice::voyageGroupCode.name, self.className);		
	tmpProp.needToUpperCase := true;
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	
	self.allQueryProperties.add(tmpProp);
	
	//11 Aug 2021	NDL	TFS 51702
	create tmpProp as CM_QDateProperty persistent;                                
	tmpProp.set('Invoice Posted Date', CM_Invoice::postedDT.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//16.12.2021 navma1 #52580
	create tmpProp as CM_QCollWorkOrdersProperty persistent;
	tmpProp.set('Work Orders', CM_Invoice::allWorkOrders.name, self.className);
  	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	// ### TFS 52752 04Feb2022 NAVPW1
	create tmpProp as CM_QStringMethodEllipsis persistent;
	tmpProp.set('Invoice Notes', CM_Invoice::getInvoiceNote.name, self.className);
	tmpProp.needToUpperCase := true;
  	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	// ### TFS 52752 04Feb2022 NAVPW1
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Notes - Internal Only', CM_Invoice::getInvoiceInternalOnly.name, self.className);
  	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//06/12/2022 navmv20 TFS CR 55309 Task 55556 - START
	create tmpProp as CM_QInvCategoryLookupMethod persistent;
	tmpProp.set('Category', CM_Invoice::getCategoryInt.name, self.className);
	tmpProp.needToUpperCase := true;
  	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set('External Number', CM_Invoice::externalNumber.name, self.className);
  	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	//06/12/2022 navmv20 TFS CR 55309 Task 55556 - END
	
	//15/01/2023	navkc1 ChangeRequest 59145 Task 61330
	create tmpProp as CM_QDateProperty persistent;
	tmpProp.set('Invoice Due Date', CM_Invoice::dueDate.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//15/01/2023	navkc1 ChangeRequest 59145 Task 61330
	create tmpProp as CM_QDateProperty persistent;
	tmpProp.set('Invoice Date', CM_Invoice::invoiceDate.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//09/08/2024	navkc1 CR 64894 Task 65268
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Other Invoices', CM_Invoice::otherInvoices.name, self.className);
  	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//09/08/2024	navkc1 CR 64894 Task 65268
	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set('Tax Code', CM_Invoice::taxCodes.name, self.className);
  	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//09/08/2024	navkc1 CR 64894 Task 65268
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Copied From Invoice', CM_Invoice::getInvoiceCopiedFromStr.name, self.className);
  	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//09/08/2024	navkc1 CR 64894 Task 65268
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Copied To Invoices', CM_Invoice::getInvoicesCopiedToStr.name, self.className);
  	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//09/08/2024	navkc1 CR 64894 Task 65268
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Copied From Credit', CM_Invoice::getCNotesCopiedFromStr.name, self.className);
  	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//09/08/2024	navkc1 CR 64894 Task 65268
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Copied To Credits', CM_Invoice::getCNotesCopiedToStr.name, self.className);
  	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//09/08/2024	navkc1 CR 64894 Task 65268
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Copied From Invoice Ext', CM_Invoice::getInvoiceCopiedFromExtStr.name, self.className);
  	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//09/08/2024	navkc1 CR 64894 Task 65268
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Copied To Invoices Ext', CM_Invoice::getInvoicesCopiedToExtStr.name, self.className);
  	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//09/08/2024	navkc1 CR 64894 Task 65268
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Copied From Credit Ext', CM_Invoice::getCNotesCopiedFromExtStr.name, self.className);
  	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//09/08/2024	navkc1 CR 64894 Task 65268
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Copied To Credits Ext', CM_Invoice::getCNotesCopiedToExtStr.name, self.className);
  	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
end;</source>
    </JadeMethod>
    <JadeMethod name="getSelectorVisibleColumns" id="bbc20ca3-c6e5-40c4-bbf6-fb410bcabaaa">
        <source>getSelectorVisibleColumns(_sa: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars
	qProp	: CM_QueryProperty;
begin
	inheritMethod(_sa);
	
	
	qProp := self.allQueryProperties[CM_Invoice::myTerminal.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_Invoice::bank.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_Invoice::getDebtor.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_Invoice::sequenceNum.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_Invoice::getInvoiceType.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	
	qProp := self.allQueryProperties[CM_Invoice::getTotalAmount.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	


epilog

end;</source>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isInvoiceType" id="bc74f00a-70a1-49a1-b757-20f7458333bc">
        <source>isInvoiceType(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2014	cnwndl1	Initial creation	CCMS QNS 2348

*/

vars

begin

	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
