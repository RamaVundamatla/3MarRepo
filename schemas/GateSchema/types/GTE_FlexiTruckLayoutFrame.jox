    <JadeMethod name="removeContainer" id="e16dd933-b1df-4f47-a83f-fc23c225de3e">
        <updating/>
        <source>removeContainer(_gateEntity : CMGTE_Entity) updating;   //_containerId : String) updating;	// 17/12/2010 cnwmh5 #26635

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2009	cnwas3	Initial creation

*/

vars
	contFrm	: GTE_FlexiContainerFrame;
	found	: Boolean;
	max,
	idx		: Integer;
begin
	
	found:=false;
	max := self.allFlexiContainerFrames.size;
	foreach idx in 1 to max do
		contFrm := self.allFlexiContainerFrames[idx];
		///if contFrm.id = _containerId then
		if contFrm.myContainer = _gateEntity then		// 17/12/2010 cnwmh5 #26635
			found := true;
			break;
		endif;
	endforeach;
	if found then
		contFrm.visible:=false;
		if self.myFlexiSelectedContainer = contFrm then			
			self.deselectContainer();			
		endif;
		self.allFlexiContainerFrames.remove(contFrm);
		delete contFrm;
		self.cnEcResizeContents();	
	endif;
	
	if self.countContainers() &gt; 1 then
		self.setMoveButtons(true);
	else
		self.setMoveButtons(false);
	endif;
end;</source>
        <Parameter name="_gateEntity" type="CMGTE_Entity"/>
    </JadeMethod>
    <JadeMethod name="selectContainer" id="5e88ffc6-96ba-4eee-825d-48e0adf1ec11">
        <updating/>
        <source>selectContainer(pContainer : GTE_FlexiContainerFrame) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	if self.myFlexiSelectedContainer &lt;&gt; null then
		self.myFlexiSelectedContainer.deSelect();
	endif;

	self.myFlexiSelectedContainer := pContainer;
	//self.myFlexiSelectedContainer.select(); cnwas3
	self.myFlexiSelectedContainer.backColor := self.myFlexiSelectedContainer.selectedBackColor; //cnwas3
	// set selected container to be dragged
	self.myFlexiDraggedContainer := pContainer;
	
end;</source>
        <Parameter name="pContainer" type="GTE_FlexiContainerFrame"/>
    </JadeMethod>
    <JadeMethod name="setContainer" id="779e6c04-571b-42dc-9f92-12c042fc420b">
        <updating/>
        <source>setContainer(pIdx : Integer; pId : String;  pDoors : Boolean; _container : CMGTE_Entity) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contFrm	: GTE_FlexiContainerFrame;
	found	: Boolean;
	max,
	idx		: Integer;

begin
	if pIdx = 0 then
		// find a free one
		max := self.allFlexiContainerFrames.size;
		
		foreach idx in 1 to max do
			contFrm := self.allFlexiContainerFrames[idx];
			if contFrm.myContainer = null then
				found := true;
				break;
			endif;
		endforeach;

		if found then
			if self.addToFront then
				if idx &lt;&gt; 1 then
					// move found one to first position
					self.allFlexiContainerFrames.remove(contFrm);
					self.allFlexiContainerFrames.insert(1, contFrm);
				endif;
			else
				if idx &lt;&gt; max then
					// move found one to end
					self.allFlexiContainerFrames.remove(contFrm);
					self.allFlexiContainerFrames.add(contFrm);		// this will add at the end
				endif;
			endif;
		else
			// create a new container frame  cnwas3
			contFrm := createContainerFrame();
			if self.addToFront then
				self.allFlexiContainerFrames.insert(1, contFrm);
			else
				self.allFlexiContainerFrames.add(contFrm);
			endif;
		endif;
	else
		
		idx:=self.allFlexiContainerFrames.getIdxByEntity(_container);						// 14/11/2012 cnwmh5 #30733
		if idx&lt;&gt;0 then
			contFrm := self.allFlexiContainerFrames[idx];	
		else
			setContainer(0, pId,  pDoors, _container);
			return;
		endif;
	endif;
	
	contFrm.setDetails(pId, pDoors, _container);

// Always select the new container (RJS - 23/4/01)
//	if self.mySelectedContainer = null then
	if self.myFlexiSelectedContainer &lt;&gt; null then
		self.myFlexiSelectedContainer.deSelect();
	endif;
		self.myFlexiSelectedContainer := contFrm;
		self.myFlexiSelectedContainer.select();
//	endif;
	
	if (not found) then
		// a container must have been added
		contFrm.top := self.myTruckCabPicture.top;		
	endif;	
	//self.setLengths();
	if self.countContainers() &gt; 1 then
		self.setMoveButtons(true);
	else
		self.setMoveButtons(false);
	endif;
	
	self.cnEcResizeContents();
	
	//self.displayContainers();

end;</source>
        <Parameter name="pIdx" type="Integer"/>
        <Parameter name="pId" type="String"/>
        <Parameter name="pDoors" type="Boolean"/>
        <Parameter name="_container" type="CMGTE_Entity"/>
    </JadeMethod>
    <JadeMethod name="setDoorsVisible" id="13b6257e-a819-4f7c-a35b-cbad783b38df">
        <source>setDoorsVisible(pValue : Boolean);
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contFrm	: GTE_FlexiContainerFrame;
	
begin

	foreach contFrm in self.allFlexiContainerFrames do
		if pValue then
			contFrm.showDoorsDirBtn();
		else
			contFrm.hideDoorsDirBtn();
		endif;
	endforeach;
	
end;</source>
        <Parameter name="pValue" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLengths" id="687760dc-93b0-4d56-bc11-ee0f9c8a510e">
        <updating/>
        <source>setLengths() updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	numSlots,
	stdLength	: Integer;

begin

	// numSlots is visible * factor
	numSlots := self.numVisibleContainers;

	if numSlots &lt; StdNumContainers then
		numSlots := StdNumContainers;
	endif;

	// calculate the lenth of the currently displayed truckbed
	stdLength := (self.myTruckBedLeftPic.width + self.myTruckBedMiddlePic.width + self.myTruckBedRightPic.width).Integer;

	// Divide by number of containers to display
	stdLength := (stdLength / numSlots).Integer;

/*	
	if numSlots &gt; StdNumContainers then
		// as more than 4 containers set lengths to be minimum
		self.length10 := stdLength;
		self.length20 := stdLength;
		self.length40 := stdLength;
	else
*/
		self.length10 := stdLength;
		self.length20 := stdLength * 2;
		self.length40 := stdLength * 4;
//	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
