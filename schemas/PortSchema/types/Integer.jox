    <JadeMethod name="asStringJMTWithOptionalCommas" id="0fd2786c-4606-4ac6-8b24-bc3d86f94911">
        <source>asStringJMTWithOptionalCommas( _useSeperator : Boolean; blankIfZero : Boolean ) : String;

/*

Purpose:		This method with return the integer (self) as a string with thousandSeparator if required.
Parameters:		_useSeperator if true will display with thousandSeparator else not.
Return Value:	

Date				Who		Reason
05 March 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	//10 Sep 2009	NDL	SFW CCMS 1094
	if self = 0 and blankIfZero then
		return null;
	endif;
	if _useSeperator then
		return self.userNumberFormat( $CNEC_NO_DECIMALS );
	else
		return self.asStringJMT;
	endif;
	
epilog
	
end;
</source>
