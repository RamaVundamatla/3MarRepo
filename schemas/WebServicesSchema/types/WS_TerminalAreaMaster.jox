    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="ba62ebbe-2262-4962-93dc-2b5d5d3ed0d4">
        <updating/>
        <source>setProxyFromObject(_object: CM_TerminalAreaMaster) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 September 2008	cnwkao1	Initial creation
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
*/

vars

begin
	inheritMethod(_object);
	self.id				:= _object.id;
	self.description	:= self.id &amp; Tab &amp; _object.typeString;
	self.type           := _object.type;                        					 
	self.hasSubLocations:= _object.hasSubLocations() ;				//29.09.2021 navma1 #51925
epilog

end;</source>
        <Parameter name="_object" type="CM_TerminalAreaMaster"/>
    </JadeMethod>
</Class>
