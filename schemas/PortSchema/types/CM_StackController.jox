    <JadeMethod name="testControllerHeightAccess" id="15b9dc5a-3ad0-43a6-b57d-b1ab78fcfa75">
        <source>testControllerHeightAccess(_autoMovePlan: CMIF_AutoMovePlan input): Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lHeight	: Real;
	aStr : String;
	plnLC : CM_LocationsController;
	pTI: CM_TrackedItem;
//	fls : CM_FForkLiftStack;
begin
	pTI := _autoMovePlan.myTrackedItem;
	plnLC := pTI.myPrimaryPlannedLocation;
	if plnLC = self then
		return true;
	elseif plnLC &lt;&gt; null and plnLC.isKindOf(CM_StackController) then
		if plnLC.CM_StackController.getNextControllerOfType(CM_StackController) = self then
			return true;
		endif;
	endif;

	return self.myTerminalArea.testHeightAccess(_autoMovePlan, self);
end;</source>
        <Parameter name="_autoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testForFreeSpaceYA_OLD" id="502c9854-3793-4b93-8a83-39841b822f95">
        <source>testForFreeSpaceYA_OLD(_yaAgent: CM_YAAutoplanAgent input): Integer;

// Created by cnwdvb1 on 08 May 2006

vars

	totalInThisStack,
	totalQueueInThisStack,
	totalPlanInThisStack,
	result,
	maxHeight				: Integer;
	
begin

	if not self.isSuitableForTIYA(_yaAgent) then
		return 0;
	endif;
	
	maxHeight := self.getMaxStackingHeight() * 2;
	
	totalInThisStack		:= self.getStackHeightOfTIs(REAL_MODE, null);
	totalQueueInThisStack	:= self.getStackHeightOfTIs(QUEUE_MODE, null);
	totalPlanInThisStack	:= self.getStackHeightOfTIs(PLANNING_MODE, null);
	
	result := (maxHeight - (totalInThisStack + totalQueueInThisStack + totalPlanInThisStack)).max(0); 
	
	if result = 0 then
		return 0;
	endif;
	
	return (result / 2).Integer;

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="testIs30YA" id="9899798f-4b27-429d-ad49-4b986cf16d19">
        <source>testIs30YA(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
// ---------------------------------------------------------------------------
// Created:		May 2008 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 16415
//
// ---------------------------------------------------------------------------
//Test to see if this TI matches 30.
vars
	locnId	:	String;
begin
	
	locnId := self.getFullId;

	if (not _yaAgent.myCurrentCMIFYAAutoPlan.isAttributeTrue(TI_Attrib_IsThirty)) then
		//----------------
		//TI is NOT 30 foot long...
		//----------------
		return false;
	endif;
	//----------------
	//TI IS 30
	//----------------
	/*if not self.is30ft then
		_yaAgent.addLogEntry(locnId &amp; " is not defined for 30's.", true);
		return true;
	
	endif;

	if self.offset30 = CM_LocationsController.Offset30_Unavailable then
		_yaAgent.addLogEntry(locnId &amp; " cannot be a primary location for a 30.", true);
		return true;
	
	endif;*/
	
	//cnwrd1 19.3.09
	if self.is30ft then
		if self.offset30 = CM_LocationsController.Offset30_Unavailable then
			_yaAgent.addLogEntry(AP_Log_YA_Default,locnId &amp; " cannot be a primary location for a STRICT 30 grid.", true);
			return true;
		
		endif;
	else
		return false;
	endif;	

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIs45YA" id="051cc692-8d29-4294-a1a3-8f992beb3bca">
        <source>testIs45YA(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
//Test to see if this TI matches 45.
vars
	locnId	:	String;
begin

	//cnwrd1 par 28295 18.10.2011
	/*
	if not self.myTerminalArea.autoPlanTest.test45 then
//		return false;
	endif;*/
	
	locnId := self.getFullId;

	if (not _yaAgent.myCurrentCMIFYAAutoPlan.isAttributeTrue(TI_Attrib_IsFortyFive)) then
		//----------------
		//TI is NOT 45 foot long...
		//----------------
		return false;
	endif;
	//----------------
	//TI IS 45
	//----------------
	/*
	if not self.is45ft then
		_yaAgent.addLogEntry(locnId &amp; " is not defined for 45's.", true);
		return true;
	
	endif;

	if self.offset45 = CM_LocationsController.Offset45_Unavailable then
		_yaAgent.addLogEntry(locnId &amp; " cannot be a primary location for a 45.", true);
		return true;
	
	endif;
	
	*/
	
	if self.is45ft then
		if self.offset45 = CM_LocationsController.Offset45_Unavailable then
			_yaAgent.addLogEntry(AP_Log_YA_Default,locnId &amp; " cannot be a primary location for a STRICT 45 grid.", true);
			return true;
		
		endif;
	else
		return false;
	endif;

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIs53YA" id="f87e8716-f903-466d-a7c4-d44873e0f04e">
        <source>testIs53YA(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
// ---------------------------------------------------------------------------
// Created:		May 2008 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 16415
//
