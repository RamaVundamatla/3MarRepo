    <JadeMethod name="tmpdap" id="1427d06c-de74-4a2f-8e79-5543999115b9">
        <source>tmpdap();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27 January 2021	jlgdap1		Initial creation TFS 
//
vars
	ya : CM_YardAllocation;
	crit : CM_YACriteria;
	voyageArray : StringArray;
	monthArray : StringArray;
	countArray : IntegerArray;
	obj : Object;
	month : String;
	idx : Integer;
begin
	create voyageArray transient;
	create monthArray transient;
	create countArray transient;
	foreach ya in CM_YardAllocation.instances discreteLock do
		if ya.isKindOf(CM_InvoiceCargoAllocation) then
			continue;
		endif;
		foreach crit in ya.allCriteria where crit.code = "Voyage" and crit.myYAData.isKindOf(CM_YADataObjects) do
			obj := crit.myYAData.CM_YADataObjects.allObjects.first;
			if obj.isKindOf(CM_Voyage) then
				if not voyageArray.includes(obj.CM_Voyage.code) then
					voyageArray.add(obj.CM_Voyage.code);
				endif;
			endif;
		endforeach;
		month := ya.creationTime.date.month.String &amp; ya.creationTime.date.year.String;
		if not monthArray.includes(month) then
			idx := monthArray.size + 1;
			monthArray.atPut(idx, month);
			countArray.atPut(idx, 1);
		else
			idx := monthArray.indexOf(month);
			countArray[idx] := countArray[idx] + 1;
		endif;
	endforeach;
	
	voyageArray.inspectModal;
	foreach idx in 1 to monthArray.size do
		month := monthArray[idx]&amp; Tab &amp; countArray[idx].String &amp; CrLf;
	endforeach;
	app.msgBox(month, "Result", MsgBox_OK_Only);
epilog
	delete voyageArray;
	delete monthArray;
	delete countArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateWordTest" id="a9e4a3e0-a904-44b7-95cf-b44fb2eea522">
        <source>translateWordTest();
// ---------------------------------------------------------------------------
// Created:     13 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cn : DEV_Http;
	dll	:String;
	headers,
	parms : String;
	binData : Binary;
	wordToTranslate	: String;
	rtnStr,
	server : String;
	ts		: TimeStamp;
	xmlDoc	: JadeXMLDocument;
	xmlElem	: JadeXMLElement;

begin

// http://www.webservicex.net/TranslateService.asmx/Translate?LanguageMode=EnglishTOSpanish&amp;Text=bird

//	server := 'asbdofx.cnw.co.nz';
//	dll	:= 'jadehttp.dll?OFXLISTEN';

//	server := 'www.webservicex.net/TranslateService.asmx/';
//	dll	:= 'Translate?';

	server := 'www.webservicex.net';
	dll	:= '/TranslateService.asmx/Translate';

	create cn transient;
	cn.setServerName(server);
	cn.setSecure(false);	
	cn.cnConnect;        // connect to sever


//	wordToTranslate	:= 'From Date';
	wordToTranslate	:= 'Date';

	parms := 'LanguageMode=EnglishTOSpanish&amp;Text=' &amp; wordToTranslate;

	headers :=	"Content-Type:application/x-www-form-urlencoded" &amp; CrLf &amp;
				"Content-Length:" &amp; parms.length.String &amp; CrLf;

	binData := parms.asANSI(0);// 10/3/16  cnwns1 PAR 36286 unicode version
	rtnStr := cn.ebpPostConnect(dll, binData, headers);  // send data and get reply
	
	create xmlDoc transient;
	xmlDoc.parseString(rtnStr);
	xmlElem := xmlDoc.getElementByTagName('string');
	if xmlElem &lt;&gt; null then
		app.writeStatement( 'Translation of ' &amp; wordToTranslate &amp; ' is ' &amp; xmlElem.textData);
	endif;

	cn.ebpCloseConnect;

epilog
	delete xmlDoc;
	delete cn;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateCargoTypeEntTables" id="5eb65424-a5b9-409f-8b68-d9b2eb97fb7a">
        <source>updateCargoTypeEntTables();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2023 CR 58250 Task 58253: UI - Cargo Enquiry New Sheet

*/

vars
	iter : Iterator;
	cargoType : CM_CargoType;
	root : CM_Root;
	
begin
	root := CM_Root.firstInstance;
	
	iter:=root.allCargoTypesById.createIterator;
	
	while iter.next(cargoType) do	
		if cargoType.allEnquiryEntTableDefs.indexOf(ETDef_StorageExpDetails) = 0 then
			beginTransaction;
			cargoType.allEnquiryEntTableDefs.add(ETDef_StorageExpDetails);
			commitTransaction;
			write cargoType.abbreviation;
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
    </JadeMethod>
