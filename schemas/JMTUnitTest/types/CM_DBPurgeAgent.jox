    <JadeMethod name="doDevInvoiceItems" id="11a80d3d-dc9b-452a-b104-6c3553138605">
        <source>doDevInvoiceItems();
//
//26 June 2018	jlgrs1	Initial creation
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	bank: CM_Bank;
	invoice: CM_Invoice;
	charge: CM_Charge;
	audit : CM_Audit;
	iter : Iterator;
	size : String;
    dict, objArray : ObjectArray;
    obj: Object;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting Invoice..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
    create objArray transient;

	foreach bank in CM_Bank.instances do
		foreach invoice in bank.allInvoices do
			count := count + 1;
//			if count mod 10000  = 0 then
			now := app.relativeMachineTime();
			if now - lastCommit &gt; MaxTransactionTime then
				lastCommit := app.relativeMachineTime();
				self.monitor("Invoice checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; bank.allInvoices.size.userNumberFormat($CNEC_NO_DECIMALS)
					&amp; ". Invoice to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
				if self.abortStatus = true then
					return;							//Exits here can just go straight back
				endif;
			endif;
	
			if invoice.postedDT  = null or not invoice.postedDT.isValid then
				dict.add(invoice);
			elseif invoice.postedDT.date  &lt; self.date then			//No point in checking further
				dict.add(invoice);
			endif;
		endforeach;
	endforeach;
	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.objEraseExceptionHandler(exception);
	while iter.next(invoice) do
//		if count mod 100 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased Invoice: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;invoice.String&amp;" "&amp;invoice.String,0); 
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		invoice.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " Invoice erased ");
	if self.abortStatus = true then
		return;
	endif;

	dict.clear;

	CM_Audit.allInstances(objArray,0,true); 
	size := objArray.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " Audit for items to delete...");
	if self.abortStatus = true then
		return;
	endif;
	lastCommit := app.relativeMachineTime();
	foreach obj in objArray do
		audit := obj.CM_Audit;
		count := count + 1;
//		if count mod 1000  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("Audit checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". Audit to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if audit.clearedDateTime = null then
			dict.add(audit);
		elseif audit.clearedDateTime.date &lt; self.date then			//No point in checking further
			dict.add(audit);
		endif;
	endforeach;
	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	delete iter;
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.objEraseExceptionHandler(exception);
	while iter.next(audit) do
//		self.monitor("Deleting " &amp; audit.String); 
		if count mod 10000 = 0 then
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased Audit: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		audit.erase(NORMAL_ERASE);

//		btnStop.doWindowEvents(0);			//Check the cancel button
		count := count + 1;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " Audit erased ");
	if self.abortStatus = true then
		return;
	endif;

epilog
	delete dict;
	on Exception do null;
	delete objArray;
	delete iter;			// PAR #26678
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevJMTV6Objects" id="665acbcb-cdd4-47dd-b7ec-acab206fc61a">
        <source>doDevJMTV6Objects();
//
//26 June 2018	jlgrs1	Initial creation
//
// no self.date use
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	object : CM_Object;
	iter : Iterator;
	size : String;
    dict, objArray : ObjectArray;
    obj: Object;
	invalid : Boolean;
	str : String;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting JMTV6Objects..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
    create objArray transient;

//	CM_Application.allInstances(objArray,0,true); 
//	CM_BayPlans.allInstances(objArray,0,true); 
//	CM_BayBayPlan.allInstances(objArray,0,true); 
//	CM_BayColourCode.allInstances(objArray,0,true);
//	CM_CamConfig.allInstances(objArray,0,true); 
//	CM_CamsData.allInstances(objArray,0,true); 
//	CM_Config.allInstances(objArray,0,true); 
//	CM_ConfigRefCon.allInstances(objArray,0,true); 
//	CM_ColourCode.allInstances(objArray,0,true);
//	CM_EDIDataGenericCSV.allInstances(objArray,0,true); 
//	CM_EDIDataReeferManifest.allInstances(objArray,0,true); 
//	CM_EDIFileCSVMSKManifest.allInstances(objArray,0,false);
//	CM_EDIOperator.allInstances(objArray,0,false);
//	CM_CAOperatorGroup.allInstances(objArray,0,false);
//	CM_LCList.allInstances(objArray,0,false);
//	CM_MailBox.allInstances(objArray,0,false);
//	CM_ModemData.allInstances(objArray,0,false);
//	CM_ModemVendor.allInstances(objArray,0,false);
//	CM_NoteProxy.allInstances(objArray,0,false);
//	CM_PdqConfiguration.allInstances(objArray,0,false);
//	CM_PdqScript.allInstances(objArray,0,false);
//	CM_PdqScriptPlayer.allInstances(objArray,0,false);
//	CM_PdqSettings.allInstances(objArray,0,false);
//	CM_PdqModem.allInstances(objArray,0,false);
//	CM_PdqPort.allInstances(objArray,0,false);
//	CM_PdqTerminal.allInstances(objArray,0,false);
//	CM_PdqXfer.allInstances(objArray,0,false);
//	CM_AutoPlanConfig.allInstances(objArray,0,false);
//	CM_ProcessController.allInstances(objArray,0,false);
//	CM_SQLServerUpdateController.allInstances(objArray,0,false);
//	CM_ProcessMessenger.allInstances(objArray,0,false);
//	CM_ReportDefn.allInstances(objArray,0,false);
//	CM_ReportRun.allInstances(objArray,0,false);
	CM_SlotDefn.allInstances(objArray,0,false);
//	CM_Status.allInstances(objArray,0,false);
//	CM_TIStorageProcessor.allInstances(objArray,0,false);
//	CM_SubForkStack.allInstances(objArray,0,false);
	CM_ToDoTask.allInstances(objArray,0,false);
//	CM_TIGhost.allInstances(objArray,0,false);
//	CM_TIGhost_TO_BE_REMOVED.allInstances(objArray,0,false);
//	CM_UserClass.allInstances(objArray,0,false);
//	CM_WindowAccess.allInstances(objArray,0,false);
//	Cm_WindowAccess.allInstances(objArray,0,false);
	CMGTE_Entity.allInstances(objArray,0,true);
	size := objArray.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " JMTV6Objects for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	lastCommit := app.relativeMachineTime();
	foreach obj in objArray do
		count := count + 1;
//		if count mod 100000  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("JMTV6Objects checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". JMTV6Objects to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		dict.add(obj);
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.objEraseExceptionHandler(exception);
	on Exception do app.handleDeletedObject(exception, obj, invalid); 
	while iter.next(obj) do
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased JMTV6Objects: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;tempReading.String&amp;" "&amp;tempReading.String,0); 
		invalid := false;
		str := obj.CM_Object.getOidString;
		if not invalid then
			if not process.isInTransactionState then
				beginTransaction;
			endif;
			obj.CM_Object.erase(NORMAL_ERASE);
			if process.isInTransactionState then
				count := count + 1;
			endif;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " JMTV6Objects erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete dict;
	on Exception do null;
	delete objArray;
	delete iter;			// PAR #26678
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevMachineHistory" id="4c89e959-bd7c-4955-ac68-84fe34c338ea">
