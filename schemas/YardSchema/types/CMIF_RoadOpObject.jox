    <JadeMethod name="sysNotification" id="66907bb1-5278-44d8-a079-08a2b7cc7a90">
        <updating/>
        <source>sysNotification(_eventType: Integer; _object: Object; _eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2010 by cnwcs5
// Purpose:     par 23193 - tracked item notifications
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _eventType = Object_Update_Event then
		if CM_TrackedItem.hasInstance(_object) then
			self.doNotableTIRefresh(_object.CM_TrackedItem);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateDataTableObject" id="2f013956-dc17-4049-8879-0a956268fd6b">
        <source>updateDataTableObject(_obj : CM_Object input);
/*
Date		Who		Reason
16 Aug 2006	cnwer1	Initial creation - PAR#xxxx
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
23 Oct 2012	cnwcs5	par 29653 - minor rework
*/

vars
	table	: CM_DataTable; 
	rowIdx 	: Integer;	
begin	
	table	:= self.myDataTable;
	rowIdx	:= table.updateItemObject(_obj, null, null, app.myPassport);	// 25/05/2010 cnwmh5 24059

	self.setTableRowColour(_obj, rowIdx);
		
	if table.tag = true.String then
		table.tag := null;
		
		table.resort();		// 07/06/2010 cnwmh5 #24059  // 21/05/2010 commented out for the moment
	endif;
epilog
	
	
end;</source>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateElapsedTimes" id="7a600867-169e-4cf3-9335-290fd00ad3a5">
        <source>updateElapsedTimes();
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

row,
	cnt,
	pos,
	colElapsed,
	colElapsedStage : Integer;
	cell : JadeTableCell;
	maxElapsedMins : Integer;
	int : Integer;
	tableRow : JadeTableRow;
	rowObj		: Object;
begin

	if self.myDataTable = null then
		return;
	endif;
	
	colElapsed := self.myDataTable.getColumnByRowName(ETRow_ElapsedTime);
	colElapsedStage := self.myDataTable.getColumnByRowName(ETRow_ElapsedTimeArea);	
	if colElapsed +  colElapsedStage &lt; 1 then
		// Dwell TIme column is not visible
		return;
	endif;
	
	//05 Sep 2012	NDL	Par 29717
	if colElapsed &gt; 0 then
		//epr TFS 7828 24/11/17
		maxElapsedMins := self.myRoadOpController.maxElapsedMins;	
	endif;
	
	cnt := self.myDataTable.rows;
	pos :=self.myDataTable.fixedRows+1;
	
	foreach row in pos to cnt do
		//epr TFS 7828 24/11/17
		rowObj:=self.myDataTable.accessRow(row).itemObject;
		if rowObj = null then
			continue;
		endif;
		if rowObj.isKindOf(CM_TerminalArea) then
			continue;
		endif;
		
		if colElapsed &gt; 0 then
			cell:=self.myDataTable.accessCell(row, colElapsed);
			
			if cell.text &lt;&gt; null then
				int := cell.text.Integer + 1;
				cell.text:=(int).String;
				//05 Sep 2012	NDL	Par 29717
				cell.fontBold := false;
				if maxElapsedMins &gt; 0 then
					tableRow := self.myDataTable.accessRow(row);
					if int &gt; maxElapsedMins then
						cell.fontBold := true;
						if tableRow.backColor = Red then
							cell.foreColor := White;
						else
							cell.foreColor := Red;
						endif;
					endif;
				endif;
				
			endif;
		endif;
		if colElapsedStage &gt; 0 then
			cell:=self.myDataTable.accessCell(row, colElapsedStage);
			if cell.text &lt;&gt; null then
				int := cell.text.Integer + 1;
				cell.text:=(int).String;
			endif;
		endif;
	endforeach;


epilog

end;</source>
    </JadeMethod>
</Class>
