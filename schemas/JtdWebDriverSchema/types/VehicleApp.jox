    <JadeMethod name="doSetdown" id="7ee4dbac-02d8-41af-8209-5dd003992e07">
        <updating/>
        <source>doSetdown() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2019	jlger1	Initial creation

*/

vars
	allPropertyNames,
	allPropertyValues : StringArray ;
	cmbService :ComboBox;
	cmbOperation :ComboBox;
begin
	if self.currentTask = null then
		return;
	endif;
	cmbService := self.myWebServiceTestForm.cmbService;
	cmbService.gotFocus(cmbService);
	cmbService.listIndex:=app.atcgGetComboStringIndex(cmbService, 1, 'JMTUserInterfaceService', 3);
	cmbService.click(cmbService); 
	
	app.doWindowEvents(shortPause);
	cmbOperation := self.myWebServiceTestForm.cmbOperation;
	cmbOperation.gotFocus(cmbOperation);
	cmbOperation.listIndex:=app.atcgGetComboStringIndex(cmbOperation, 1, 'machineDoSetdown', 295);
	cmbOperation.click(cmbOperation);

	create allPropertyNames transient;
	create allPropertyValues transient;
	allPropertyNames.add(WS_MachineSetdownTaskRequest::taskOid.name);
	allPropertyNames.add(WS_MachineSetdownTaskRequest::setdownLocation.name);
	allPropertyValues.add(self.currentTask);
	allPropertyValues.add(self.targetLocation);
	
	self.myWebServiceTestForm.createEmptyInputMessage(allPropertyNames,allPropertyValues);
	self.sendWebService();
	
	self.getCurrentTask();
	
epilog
	delete allPropertyNames;
	delete allPropertyValues;
end;</source>
    </JadeMethod>
    <JadeMethod name="getCurrentTask" id="c1f9ccb1-97d7-4932-b346-7b5087a6906e">
        <updating/>
        <source>getCurrentTask() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2019	jlger1	Initial creation

*/

vars
	statusResponse : WS_MachineStatus;
begin
	self.currentTask:=null;
	if  self.myWebServiceTestForm.myLastOutput = null then
		return;
	endif;
	
	if self.myWebServiceTestForm.myLastOutput.isKindOf(MachineDoAcceptResponse) then
		statusResponse := self.myWebServiceTestForm.myLastOutput.MachineDoAcceptResponse.machineDoAcceptResult.myMachineStatus;
	elseif self.myWebServiceTestForm.myLastOutput.isKindOf(MachineDoPickupResponse) then
		statusResponse := self.myWebServiceTestForm.myLastOutput.MachineDoPickupResponse.machineDoPickupResult.myMachineStatus;
	elseif self.myWebServiceTestForm.myLastOutput.isKindOf(MachineDoGetNextResponse) then
		statusResponse := self.myWebServiceTestForm.myLastOutput.MachineDoGetNextResponse.machineDoGetNextResult.myMachineStatus;
	elseif self.myWebServiceTestForm.myLastOutput.isKindOf(MachineDoSetdownResponse) then
		statusResponse := self.myWebServiceTestForm.myLastOutput.MachineDoSetdownResponse.machineDoSetdownResult.myMachineStatus;
	endif;
	
	if statusResponse &lt;&gt; null and statusResponse.allCurrentTasks.first &lt;&gt; null then
		self.currentTask:=statusResponse.allCurrentTasks.first.cmObjectId;
	endif;

epilog

end;</source>
    </JadeMethod>
