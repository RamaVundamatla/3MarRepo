    <JadeMethod name="trxImportUNLocodeFile" id="bf753ce3-054c-4d2f-9cce-1b8801aebf78">
        <updating/>
        <source>trxImportUNLocodeFile(_objSet : DynaDictionary input; _passport : CM_Passport input) updating;
//
// Created by cnwdvb1 on 06 April 2006
//
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	sorter	: Object;
	count	: Integer;
	root	: CM_Root;
	cmifMonitor : CMIF_Monitor;
	size	: Integer;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin

	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	cmifMonitor	:= app.myPassport.myCMIFMonitor;

//	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
//	on Exception do agtPassportExHandler(exception, _passport);
//	on LockException do agtPassportLockExHandler(exception, _passport);

	root := app.myRoot;
	size := _objSet.size;
	beginTransaction;
	
	foreach sorter in _objSet do	
		count := count + 1;
			
		sorter.CMIF_PortSorter.doProcessing(root);
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if progressInt.getMilliseconds &gt;= ProgressBarRefresh then
			commitTransaction;
			if cmifMonitor &lt;&gt; null then
				cmifMonitor.updateProgress ("Writing UN port/country codes to database", size, count);
			endif;
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			beginTransaction;
		endif;
	endforeach;

epilog

	if process.isInTransactionState then
		commitTransaction;
	endif;

end;</source>
        <Parameter name="_objSet" type="DynaDictionary" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxImportXMLDocROROVessel" id="e2051bf0-882a-4447-b591-b5a4267ff097">
        <updating/>
        <source>trxImportXMLDocROROVessel(	_roroVessel : CM_ROROVesselStructure input; 
							_pxyObject 	: CM_Object input;
							_passport : CM_Passport input) updating;
/*

Purpose:		Import XML file and load the ROROVesselStructure
				will wipe all existing roroVesselStructure details create a new from the file


Date		Who		Reason
05 Apr 2011	cnwer1	Initial creation CCMS 1031
22 Apr 2013	cnwer1	31289
*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	self.raiseExceptionIfNull(_roroVessel, "RORO Vessel");
	self.raiseExceptionIfNull(_pxyObject, "Proxy RORO Vessel");
	
	beginTransaction;
	
	if _pxyObject.isKindOf(CM_ROROVesselStructure) then
		
		app.myUtilityUA.utlImportXMLDocROROVessel(_roroVessel,_pxyObject.CM_ROROVesselStructure,_passport);
	elseif _pxyObject.isKindOf(CM_DeckVessel) then
		_pxyObject.CM_DeckVessel.setMyROROStructure(_roroVessel);
		app.myUtilityUA.utlImportXMLDocRORODeck(_roroVessel,_pxyObject.CM_DeckVessel,_passport);
	else
		app.raiseCMException1(ERR_Parsing_XML,"Root Element should have a type of either CM_ROROVesselStructure or CM_DeckVessel",null,null);
		return;
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_roroVessel" type="CM_ROROVesselStructure" usage="input"/>
        <Parameter name="_pxyObject" type="CM_Object" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
