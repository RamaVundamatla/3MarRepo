    <JadeMethod name="setMoveControllerSource" id="51d6fda4-e222-4bd7-9e44-fad68a3eeece">
        <updating/>
        <source>setMoveControllerSource(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	moveController	: CMIF_MoveController;
	tmpTI : CM_TrackedItem;
begin

	tmpTI := _ti;
	
	create moveController transient;
	
	moveController.setMyTrackedItem(tmpTI);
	
	if app.isValidObject(app.myMoveController) then
		delete app.myMoveController;
	endif;
	
	app.myMoveController := moveController;
	moveController.setMyOriginatingLocation(tmpTI.getPrimaryLocation(self.moveModeForm));	//REAL_MODE));
	moveController.setMoveMode(self.moveModeForm);	
	moveController.isRehandleMove := tmpTI.isRehandle;
	moveController.myOriginatingForm := self;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
