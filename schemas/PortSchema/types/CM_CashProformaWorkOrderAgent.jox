    <JadeMethod name="setForCashPaymentCreation" id="a8879451-07a8-438f-8309-c1f2e0d2eb32">
        <updating/>
        <source>setForCashPaymentCreation(_wo : CM_WorkOrder; _transInvLine : CM_InvoiceLine) updating;
/*

Purpose:		PELINDO 1 WEB PORTAL ONLY	

Parameters:			TFS 38524
	

Return Value:		

Date		Who		Reason
21 March 2018	jlgab1	Initial creation

*/

vars

begin
			self.initialise(_wo, null);
			self.allProformaInvLines.add(_transInvLine);
			self.allOwingInvoicedLines.add(_transInvLine); // TFS 39349
			
			self.setEstimatedCashCharges();

epilog

end;</source>
        <Parameter name="_wo" type="CM_WorkOrder"/>
        <Parameter name="_transInvLine" type="CM_InvoiceLine"/>
    </JadeMethod>
</Class>
