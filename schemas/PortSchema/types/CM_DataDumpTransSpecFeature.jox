    <JadeMethod name="getFeatureValueForObj" id="b7a61901-8028-4f34-a37b-42ab82f222dd">
        <source>getFeatureValueForObj(_extractFormat: Integer; _obj: Object;
		_featureName: String output; _featureValue: Any output);
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
//PAR19114 DSS speed up cnwrs1 apr 2009
vars
//	edbTranslateToType : Type;
//	length : Integer;
begin

	if _extractFormat = CM_DataDumpExtractDef.FmtExternalDatabase then
		if self.myDataDumpFeature.newName = null then  //DSS speed up cnwrs1 apr 2009
			_featureName := self.myDataDumpFeature.featureName; //DSS speed up cnwrs1 apr 2009
		else
			_featureName := self.myDataDumpFeature.newName;
		endif;
//		_featureName := self.myDataDumpFeature.getExternalDatabaseFeatureName(
//				_obj.class, edbTranslateToType, length);
	else//CNWTH2A  - may translation for XML tags?? here would where to do it.
		_featureName := self.myDataDumpFeature.featureName;
	endif;

	if self.myFeature = null then
		if _extractFormat = CM_DataDumpExtractDef.FmtExternalDatabase and
				self.mySubClassFeatureType &lt;&gt; null then
			// Can't store an attribute of type Any - so create one.
			_featureValue := self.mySubClassFeatureType.getDataDumpDefaultFeatureValue;
		else
			// Use the cached default feature string
			_featureValue := self.defaultFeatureString;
		endif;
	elseif self.isProperty then
		_featureValue := _obj.getPropertyValue(self.featureName);
	elseif self.isMethod then
		/*
		if self.featureName = DataDumpGetOidStringMethod then
			if _extractFormat = CM_DataDumpExtractDef.FmtExternalDatabase then
				_featureValue := global.dataDumpFormatBin(_obj);
			else
				_featureValue := global.dataDumpFormat(_obj);
			endif;
		else
			_featureValue := _obj.sendMsg(self.featureName);
		endif;
		*/
		_featureValue := _obj.sendMsg(self.featureName);
		
	endif;
	
	if self.myDataDumpFeature.newType &lt;&gt; null then //DSS speed up cnwrs1 apr 2009
//	if edbTranslateToType &lt;&gt; null then
		// There is a different data type in the External Database than
		// in the JADE class.
		_featureValue := _featureValue.typeCastForSQLServer(self.myDataDumpFeature.newType); //DSS speed up cnwrs1 apr 2009
//		_featureValue := _featureValue.typeCastForSQLServer(edbTranslateToType);
	endif;

	if self.isFeatureProtected then
		// Don't allow protected feature to be extracted.  Must assume
		// that an accessor method should be called instead, or that the
		// data is now obsolete.
		app.raiseCMException2(DataDumpProtectedFeature,
				self.myTransSpecClass.myClass.name, _featureName, null, null);
	endif;
	
end;</source>
        <Parameter name="_extractFormat" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_featureName" type="String" usage="output"/>
        <Parameter name="_featureValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="4d1de409-46ba-452a-8b11-8a9ebdce73cb">
        <updating/>
        <source>setForCreate(_dataDumpFeature: CM_DataDumpFeature; _realFeature: Feature;
		_subClassFeatureType: Type) updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	featureType : Type;
	
begin
	self.myDataDumpFeature := _dataDumpFeature;
	self.myFeature := _realFeature;
	self.mySubClassFeatureType := _subClassFeatureType;
	self.isFeatureProtected := _dataDumpFeature.isFeatureProtected;

	if self.myFeature = null then
		self.defaultFeatureString := self.myDataDumpFeature.getDefaultFeatureStr;
	else
		self.featureName := self.myFeature.name;
		featureType := self.myFeature.type;
		
		if self.myFeature.isKindOf(Property) then
			self.isProperty := true;
			self.maxLength := self.myFeature.Property.getLength() - 1;
			if self.maxLength &lt; 0 then
				self.maxLength := 0;
			endif;
		elseif self.myFeature.isKindOf(Method) then
			self.isMethod := true;
		endif;
	endif;
end;</source>
        <Parameter name="_dataDumpFeature" type="CM_DataDumpFeature"/>
        <Parameter name="_realFeature" type="Feature"/>
        <Parameter name="_subClassFeatureType" type="Type"/>
    </JadeMethod>
</Class>
