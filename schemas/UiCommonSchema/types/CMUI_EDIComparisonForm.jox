    <JadeMethod name="doBaseFormCancel" id="ae731c4f-0d1e-44e7-b4a9-0539a016fd75">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
/*

Date		Who		Reason
08 September 2016	cnwer1	Initial creation TFS

*/

vars
	changedCol : Integer;
	intRow : Integer;
	obj		: Object;
	str		: String;
begin
	
	changedCol := self.tblData.getColumnByRowName(ETRow_HasChanged);
	foreach intRow in 2 to self.tblData.rows do
		if self.tblData.accessCell(intRow, changedCol).text = CMUI_EDIForm.HAS_CHANGED then
			obj := self.tblData.accessRow(intRow).itemObject;
		
			str := null.String &amp; Tab &amp; self.SOURCE_EDI &amp; Tab &amp;  obj.CM_EDITrackedItem.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);	// par 29842 Sep 2012
			self.tblData.accessCell(intRow, 1).text 	:= str;
		endif;
	endforeach;
	//inheritMethod();
	self.doEdit(false);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
