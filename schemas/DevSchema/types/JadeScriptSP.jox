    <JadeMethod name="imageLibraryTest" id="e5eb6d12-cdc2-4a2b-bb02-894e8ebdfac1">
        <source>imageLibraryTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2025	navsp1	Initial creation

*/


/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2025	Shanu.Paul	Initial creation

*/

vars
	ti : CM_TrackedItem;
	origImage , origBinImage: Binary;
	 
	convertedImage : Binary;
	photo :CM_Photo;
	//imageProcessingHelper : MTNImageProcessingHelper;
	oldImgSize, convertedImgSize : Integer;
        imageHelper : CMIF_ImageProcessingHelper;
    thumbnailImage  : Binary;
    originalImage   : Binary;
    size : Integer;
    error : StringUtf8;
begin
        create imageHelper transient;
    
	//create imageProcessingHelper transient;
	ti := "2367.64223260".asOid.CM_TrackedItem;
	if ti &lt;&gt; null then
		photo	:= ti.allAttachments.first.CM_Photo;
		if photo &lt;&gt; null then
            originalImage := photo.getPhotoContent();
            size := imageHelper.getImageSizeInKb(originalImage, error);
            write "Actual Image size : "&amp;size.String;
            thumbnailImage := photo.getThumbnailContent();
            size := imageHelper.getImageSizeInKb(thumbnailImage, error);
          
            write "Thumbnail Image size : "&amp;size.String;
            if originalImage &lt;&gt; null then
                //thumbnailImage := imageHelper.getImageDataByQuality(originalImage, 30);
                thumbnailImage := imageHelper.getImageDataByDimension(originalImage, 120, error);
                  write error.String;
               // beginTransaction;
                //photo.setThumbnailContent(thumbnailImage);
               // commitTransaction;
                 size := imageHelper.getImageSizeInKb(thumbnailImage, error);
                write "Thumbnail Image size : "&amp;size.String;
               // _proxyPhoto.setThumbnailContent(thumbnailImage);
            endif;
			
		endif;
	endif;
epilog
	//delete imageProcessingHelper;
end;</source>
    </JadeMethod>
    <JadeMethod name="imageLibraryTestPhoto" id="5c86f7a1-7681-47db-8d49-5f72abc68787">
        <source>imageLibraryTestPhoto();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 November 2025	navsp1	Initial creation

*/

vars
   
    	ti : CM_TrackedItem;
	origImage , origBinImage: Binary;
	 
	convertedImage : Binary;
	photo :CM_Photo;
	//imageProcessingHelper : MTNImageProcessingHelper;
	oldImgSize, convertedImgSize : Integer;
        imageHelper : CMIF_ImageProcessingHelper;
    thumbnailImage  : Binary;
    originalImage   : Binary;
    size : Integer;
    error : StringUtf8;
begin
     create imageHelper transient;
    photo := "10707.34459".asOid.CM_Photo;
    if photo &lt;&gt; null then
            originalImage := photo.getPhotoContent();
            size := imageHelper.getImageSizeInKb(originalImage, error);
            write "Actual Image size : "&amp;size.String;
            thumbnailImage := photo.getThumbnailContent();
            size := imageHelper.getImageSizeInKb(thumbnailImage, error);
          
            write "Thumbnail Image size : "&amp;size.String;
            if originalImage &lt;&gt; null then
                //thumbnailImage := imageHelper.getImageDataByQuality(originalImage, 30);
                thumbnailImage := imageHelper.getImageDataByDimension(originalImage, 120, error);
                  write error.String;
               // beginTransaction;
                //photo.setThumbnailContent(thumbnailImage);
               // commitTransaction;
                 size := imageHelper.getImageSizeInKb(thumbnailImage, error);
                write "Thumbnail Image size : "&amp;size.String;
               // _proxyPhoto.setThumbnailContent(thumbnailImage);
            endif;
			
		endif;
epilog
delete imageHelper;
end;</source>
    </JadeMethod>
