// delete to avoid reorg
vars
	moveTI	: CM_EDIMoveTI;
	count	: Integer;
begin
	beginTransaction;
	foreach moveTI in CM_EDIMoveTI.instances do
		delete moveTI;
		count := count + 1;
	endforeach;
	commitTransaction;
	write count;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreDeleteFutureStorage" id="e00ab5b3-4654-4b12-a742-c8fc5bc3f072">
        <source>jreDeleteFutureStorage();

vars
	fs	: CM_FutureStorage;
	line	: CM_InvoiceLine;
	count	: Integer;
begin
	beginTransaction;
	foreach fs in CM_FutureStorage.instances do
		foreach line in fs.allInvoiceLines do
			delete line;
		endforeach;
		delete fs;
		count := count + 1;
	endforeach;
	commitTransaction;
	write count;	// 17
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreDeleteProformaInvoiceLines" id="cd4053bc-68ba-4288-ad32-bb017708d427">
        <source>jreDeleteProformaInvoiceLines();

vars
	oa	: ObjectArray;
	obj	: Object;
	invLine	: CM_InvoiceLine;
	count	: Integer;
begin
	create oa transient;
	foreach invLine in CM_InvoiceLine.instances do
		if invLine.status = 2 then
			count := count + 1;
			oa.add(invLine);
		endif;	
	endforeach;
	write count;
	beginTransaction;
	foreach obj in oa do
		invLine := obj.CM_InvoiceLine;
		invLine.zDeleteLine();
	endforeach;
	commitTransaction;
epilog
	delete oa;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreDeleteStorageConfig" id="71958e01-eed8-489d-b93e-ef86198e1b5c">
        <source>jreDeleteStorageConfig();
/*

Purpose:			Delete storage config to clean up and avoid reorg.

Parameters:			

Return Value:		


Date		Who		Reason
16 October 2012	cnwjre1	Initial creation

*/

