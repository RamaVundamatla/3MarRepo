    <JadeMethod name="setupForm" id="ac0eaf56-ea22-4a31-b291-508c6ff99795">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     09 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod();
	
	self.sptMain.setDistanceFromBottom(33);

	self.btnBackground.value := false;
	//self.chkBackground.value := false;//par11486
	//if app.myRoot.getConfig(BackgroundReportsAvailable).Boolean then
	//	self.chkBackground.enabled := true;
	//else
	//	self.chkBackground.enabled := false;
	//endif;
	if app.myRoot.getConfig(BackgroundReportsAvailable).Boolean then
		self.btnBackground.enabled := true;
	else
		self.btnBackground.enabled := false;
	endif;
	self.cargoType := TI_CargoType_Log;
	self.setupControls();
	self.initTblAll();
	self.initTblItem();
	self.initTblActionData();
	self.centreWindow();
	self.btnAdd.default := true;
	self.sptMain.setLeftToRightRatioAndResize(25);
	self.setNavigatorHeading(self.caption);	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNextT.enabled:= false;
		self.btnSaveBase.enabled:= false;
		self.btnAdd.enabled:= false;
		self.btnUpdate.enabled:= false;
		self.btnRemove.enabled:= false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d3025937-74f0-4e83-bf98-e85fce14bf8c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006337, locale);
	btnBackground.translateCaption(Xlat_0006338, locale);
	btnNextT.translateBubbleHelp(Xlat_0002438, locale);
	btnNextT.translateCaption(Xlat_0002439, locale);
	chkBackground.translateCaption(Xlat_0002440, locale);
end;</source>
    </JadeMethod>
