    <JadeMethod name="displaySelectorResults" id="abf2bfda-e5f9-4fff-bd4b-190278b36afa">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2012	cnwrd1	Initial creation

*/

vars
	tiArray : CM_TIArray;
begin
	if _mode &gt; TI_CargoType_Max then
		app.msgBox( app.getErrorString1(ReqInternalMove_cant_display, _mode.String ),  app.getErrorString(Invalid_selector_mode) , MsgBox_Exclamation_Mark_Icon);
		
		return;
	endif;
	
	create tiArray transient;
	
	//self.allSelectedTIs.clear;
	
	_resultCollection.copy(tiArray);	
	tiArray.copyNoDuplicates(self.allSelectedCargo);
	self.displaySelectedTIs();

epilog
	delete tiArray;
end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doAddSelected" id="c5a1e365-763d-4a69-9df6-503b19ee4df7">
        <source>doAddSelected();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2012	cnwrd1	Initial creation

*/

vars
	aTI 		: CM_TrackedItem;
	lstCnt		: Integer;
	cnt			: Integer;
begin

	lstCnt := self.tblResults.rows;
	while cnt &lt; lstCnt do
		cnt := cnt+1;			
		
		if self.tblResults.accessRow(cnt).selected then
			aTI :=  self.tblResults.accessRow(cnt).itemObject.CM_TrackedItem;				
			self.tblResults.removeItem(cnt);
			self.allSelectedCargo.addNoDuplicates(aTI, false);
			lstCnt := lstCnt-1;
			cnt := cnt -1;
		endif;	
	endwhile;

	self.displaySelectedTIs();
epilog

end;</source>
    </JadeMethod>
