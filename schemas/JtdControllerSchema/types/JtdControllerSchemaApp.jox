    <JadeMethod name="abortActionExHandler" id="58de552b-e419-4b5c-82bd-f14952d2886b">
        <source>abortActionExHandler(exObj : Exception) : Integer;

begin
	abortTransaction;
	return Ex_Abort_Action;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createDriverProfilesFromMethod" id="ae4ba838-631a-4ee0-ba74-a075e5110c28">
        <source>createDriverProfilesFromMethod(mth : Method; dpDict : JtdDriverProfileNameDict input;
	includeMethodsWithZeroCalls : Boolean);
	
// it is the caller's responsibility to clear dpDict if required
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	dp : JtdDriverProfile;
	n, len : Integer;
	s : String;
	
begin
	if mth = null then
		return;
	endif;
	
	s := mth.text.trimBlanks;
	
	len := s.length;
	
	if len &lt; 1 then
		return;
	endif;

	n := 1;
		
	while true do
		n := s.pos(JtdDriverProfile.JtdTagBeginProfile, n);
		
		if n &lt; 1 then
			break;
		endif;
		
		create dp transient;
		dp.jtdSetFromString(s[n : end], includeMethodsWithZeroCalls);
		dpDict.add(dp);
		
		n := n + JtdDriverProfile.JtdTagBeginProfile.length;
		
		if n &gt;= len then
			break;
		endif;
	endwhile;
end;</source>
        <Parameter name="mth" type="Method"/>
        <Parameter name="dpDict" type="JtdDriverProfileNameDict" usage="input"/>
        <Parameter name="includeMethodsWithZeroCalls" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCommandFini" id="8c70ce53-21dd-439d-b6d5-312cb45e0f6a">
