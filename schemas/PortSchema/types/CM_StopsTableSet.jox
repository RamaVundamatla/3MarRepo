<CollClass name="CM_StopsTableSet" id="6ea2351e-fb3a-47ff-aaf3-1a931551a471">
    <memberType name="CM_StopsTable"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="containr"/>
    <JadeMethod name="auditIdDisplay" id="78fcbdb6-4bde-46ba-877d-da54bf2ee752">
        <source>auditIdDisplay() : String;
/*
Purpose - 	
Who - NAVAB1
Date - 30AUG2023
ADO - CR 59942 TASK 59943 
*/

vars
	stop	: CM_StopsTable;
	rtnStr	: String;
begin

	foreach stop in self do
		if rtnStr = null then
			rtnStr := stop.auditId();
		else
			rtnStr := rtnStr &amp; ', ' &amp; stop.auditId();
		endif;
	endforeach;

	return rtnStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
