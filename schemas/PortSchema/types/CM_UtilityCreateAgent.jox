        <Parameter name="_realWagon" type="CM_Wagon" usage="output"/>
        <Parameter name="_isValidate" type="Boolean"/>
        <Parameter name="_isInitialise" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
