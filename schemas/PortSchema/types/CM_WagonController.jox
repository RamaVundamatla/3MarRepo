        <source>canPlanOverstow(_moveItem: CM_Object; _otherLoc: CM_LocationsController input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

begin

	return false;

epilog

end;</source>
        <Parameter name="_moveItem" type="CM_Object"/>
        <Parameter name="_otherLoc" type="CM_LocationsController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canSwapTiWithTis" id="9e1349c2-f54b-48cd-9742-e49940e733bf">
        <source>canSwapTiWithTis(	_existingTi : CM_TrackedItem;
					_newTi1 : CM_TrackedItem;
					_newTi2 : CM_TrackedItem;
					_newPrimaryLocCont_1 : CM_WagonController output;
					_newPrimaryLocCont_2 : CM_WagonController output
					) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2009	cnwndl1	Initial creation CCMS 1094

*/

vars
	extraBays : Decimal [4,1];
	prevCont : CM_WagonController;
	forwardMost : CM_WagonController;
	nextCont : CM_WagonController;
	rearwardMost : CM_WagonController;
	extraPosFound : Integer;
	newTi1BayLength : Decimal [4,1];
	pos : Integer;
begin

	if _newTi1 = null then
		// nothing to swap in ??
		_newPrimaryLocCont_1 := null;
		_newPrimaryLocCont_2 := null;
		return false;
	elseif not self.allTrackedItems.includes(_existingTi) then
		// the existing one isn't in this position
		_newPrimaryLocCont_1 := null;
		_newPrimaryLocCont_2 := null;
		return false;
	endif;
	
	newTi1BayLength := _newTi1.getActualLength / 10;
	
	if _newTi2 = null then
		if _newTi1.getActualLength &lt;= _existingTi.getActualLength then
			_newPrimaryLocCont_1 := self;
			_newPrimaryLocCont_2 := null;
			return true;
		endif;
		//OK its longer, how many more bays do I need?
		extraBays := ( _newTi1.getActualLength - _existingTi.getActualLength )/10;
	else
		if ( _newTi1.getActualLength + _newTi2.getActualLength ) &lt;= _existingTi.getActualLength then
			_newPrimaryLocCont_1 := self;
			return true;
		endif;
		//OK colectively they are longer, how many more bays do I need?
		extraBays := ( ( _newTi1.getActualLength + _newTi2.getActualLength ) - _existingTi.getActualLength )/10;
	endif;

	// look forward first....
	forwardMost := self;
	while true do
		prevCont := forwardMost.myPreviousController;
		if prevCont = null or not prevCont.allTrackedItems.isEmpty then
			// no more forward space.
			break;
		endif;
		forwardMost := prevCont;
		extraPosFound := extraPosFound + 1;
	endwhile;
	
	if extraPosFound &gt;= extraBays then
		_newPrimaryLocCont_1 := forwardMost;
		return true;
	endif;
	
	// not yet, OK check backward.
	rearwardMost := self;
	while true do
		nextCont := rearwardMost.myNextController;
		if nextCont = null then
			// no more backward positions.
			break;
		endif;
		rearwardMost := nextCont;
		if nextCont.allTrackedItems.includes(_existingTi) then
			//still in a position that the existing ti overlaps
			continue;
		endif;
		if not nextCont.allTrackedItems.isEmpty then
			// found a position behind this TI but its used.
			break;
		else
			// ok got an extra available slot here
			extraPosFound := extraPosFound + 1;
		endif;
		if extraPosFound &gt;= extraBays then
			// got enough now.
			_newPrimaryLocCont_1 := forwardMost;
			return true;
		endif;
		
	endwhile;
	
	_newPrimaryLocCont_1 := null;
	_newPrimaryLocCont_2 := null;
	return false;
	
epilog

	if _newTi2 &lt;&gt; null then
		//find the new prime location for this ti too.
		if _newPrimaryLocCont_1 &lt;&gt; null then
			pos := 0;
			_newPrimaryLocCont_2 := _newPrimaryLocCont_1;
			while pos &lt; newTi1BayLength do
				pos := pos + 1;
				_newPrimaryLocCont_2 := _newPrimaryLocCont_2.myNextController;
			endwhile;
		endif;
	endif;
end;</source>
        <Parameter name="_existingTi" type="CM_TrackedItem"/>
        <Parameter name="_newTi1" type="CM_TrackedItem"/>
        <Parameter name="_newTi2" type="CM_TrackedItem"/>
        <Parameter name="_newPrimaryLocCont_1" type="CM_WagonController" usage="output"/>
        <Parameter name="_newPrimaryLocCont_2" type="CM_WagonController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canSwapTisWithTi" id="fe890c39-6dc3-455a-801c-f646c1321c65">
        <source>canSwapTisWithTi(	_existingTi1 : CM_TrackedItem;
					_existingTi2 : CM_TrackedItem;
					_newTi : CM_TrackedItem;
					_newPrimaryLocCont : CM_WagonController output
					) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwndl1	Initial creation	CCMS 1094

*/

vars
	startBayLength : Decimal [4,1];
	startTi : CM_TrackedItem;
	newBayLength : Decimal [4,1];
	prevCont : CM_WagonController;
	forwardMost : CM_WagonController;
	nextCont : CM_WagonController;
	rearwardMost : CM_WagonController;
	extraPosFound : Integer;
begin

	if _newTi = null then
		// nothing to swap in ??
		_newPrimaryLocCont := null;
		return false;
	elseif ( not self.allTrackedItems.includes(_existingTi1) and not self.allTrackedItems.includes(_existingTi2) ) then
		// neither of the existing ti's in this position
		_newPrimaryLocCont := null;
		return false;
	elseif self.allTrackedItems.includes(_existingTi1) then
		startBayLength := _existingTi1.getActualLength /10;
		startTi := _existingTi1;
	elseif self.allTrackedItems.includes(_existingTi2) then
		startBayLength := _existingTi2.getActualLength /10;
		startTi := _existingTi2;
	endif;
	
	//OK how many bays do I need?
	newBayLength := _newTi.getActualLength /10;
		
	// look forward first....
	forwardMost := self;
	while true do
		prevCont := forwardMost.myPreviousController;
		if prevCont = null then
			// nothing forward of here.
			break;
		endif;
		if not prevCont.allTrackedItems.isEmpty then
			// there are container(s) are they the ones we are swapping out
			if ( not prevCont.allTrackedItems.includes(_existingTi1) and not prevCont.allTrackedItems.includes(_existingTi2) ) then
				// no more forward space.
				break;
			endif;
		endif;
		forwardMost := prevCont;
		extraPosFound := extraPosFound + 1;
	endwhile;
	
	if extraPosFound + startBayLength &gt;= newBayLength then
		_newPrimaryLocCont := forwardMost;
		return true;
	endif;
	
	// not enough space found yet, OK check backward.
	rearwardMost := self;
	while true do
		nextCont := rearwardMost.myNextController;
		if nextCont = null then
			// no more backward positions.
			break;
		endif;
		rearwardMost := nextCont;
		if nextCont.allTrackedItems.includes(startTi) then
			//still in a position that the existing ti overlaps
			continue;
		endif;
		if not nextCont.allTrackedItems.isEmpty then
			// there are container(s) are they the ones we are swapping out
			if ( not nextCont.allTrackedItems.includes(_existingTi1) and not nextCont.allTrackedItems.includes(_existingTi2) ) then
				// no more rearward space.
				break;
			else
				//this is a slot used by the other ti ( i.e. not the startTi) so is a bay that should be counted
				extraPosFound := extraPosFound + 1;
			endif;
		else
			// ok got an extra available slot here
			extraPosFound := extraPosFound + 1;
		endif;

		if extraPosFound + startBayLength &gt;= newBayLength then
			// got enough now.
			_newPrimaryLocCont := forwardMost;
			return true;
		endif;
		
	endwhile;
	
	_newPrimaryLocCont := null;

	return false;
	
epilog

end;</source>
        <Parameter name="_existingTi1" type="CM_TrackedItem"/>
        <Parameter name="_existingTi2" type="CM_TrackedItem"/>
        <Parameter name="_newTi" type="CM_TrackedItem"/>
        <Parameter name="_newPrimaryLocCont" type="CM_WagonController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canTwinLiftWithLocation" id="7fad1b07-5243-44c3-808e-a01c20883f54">
        <source>canTwinLiftWithLocation(_nextLocation: CM_LocationsController; _myTrackedItem: CM_TrackedItem; _nextLocationTrackedItem: CM_TrackedItem; _mode: Integer; _direction: Integer output; _errorString: String io): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2009	cnwer1	Initial creation par 19956

*/

vars
	posOnWagonSelf,
	posOnWagonNext	 : Integer;
 	wagonUnits,
	lenTIUnits 	: Real;
	nextWagonController		: CM_WagonController;
	railNoTwinLiftMoves : Boolean;
	topOfStackIndex : Integer;
begin

	if not inheritMethod(_nextLocation,_myTrackedItem,_nextLocationTrackedItem,_mode,_direction,_errorString) then
		return false;
	endif;
	
	if self.myTerminal &lt;&gt; null then // PAR 19913
		railNoTwinLiftMoves := self.myTerminal.getConfig(RailNoTwinLiftMoves).Boolean; // PAR 19913
		if railNoTwinLiftMoves then // PAR 19913
			_direction:=CM_RTQueueEntry.TWIN_NONE; // PAR 21444
			return false; // PAR 19913
		endif;
	endif;
	
	_direction:=CM_RTQueueEntry.TWIN_NONE;
	
	if not _nextLocation.isKindOf(CM_WagonController) then
		return false;
	endif;
	
	nextWagonController:=_nextLocation.CM_WagonController;
	if self.myWagon = null or nextWagonController.myWagon = null then
		return false;
	endif;
	
	if self.myWagon &lt;&gt; nextWagonController.myWagon then
		return false;
	endif;
	
	//on the same wagon find out where abouts
	//posOnWagonSelf:=self.myWagon.allLocationsControllers.indexOf(self);
	//posOnWagonNext:=self.myWagon.allLocationsControllers.indexOf(nextWagonController);
	posOnWagonSelf:=self.myWagon.allLocationsControllersArray.indexOf(self);	//04 Dec 2014	NDL	Par 35345
	posOnWagonNext:=self.myWagon.allLocationsControllersArray.indexOf(nextWagonController);	//04 Dec 2014	NDL	Par 35345
	
	//can only assume if this happens they are stacked ontop of each other so can't twin lift - don't think this is a real life situation
	if posOnWagonSelf = posOnWagonNext then
		return false;
	endif;
	
	wagonUnits:=self.myWagon.myWagonClass.getLenInUnits;
	
	if posOnWagonSelf &lt; posOnWagonNext then
		
		if _myTrackedItem &lt;&gt; null then
			lenTIUnits:=_myTrackedItem.getLengthInUnits;
			if posOnWagonNext &lt;&gt; posOnWagonSelf + lenTIUnits then
				return false;
			endif;
		endif;
	else
		if _nextLocationTrackedItem &lt;&gt; null then
			lenTIUnits:=_nextLocationTrackedItem.getLengthInUnits;
			if posOnWagonSelf &lt;&gt; posOnWagonNext + lenTIUnits then
				return false;
			endif;
		endif;
	endif;
	//at this stage there is a presumption that containers are 20 ft to be twin lifted
	
	//13 Oct 2014	NDL	Par 35040 - stack height.
	if self.myWagon.myWagonClass.maxNumInStack &gt; 1 then
		//Can be stacked on the flat car, make sure they are on top, and at the same stack height.
		if _myTrackedItem &lt;&gt; null and _nextLocationTrackedItem &lt;&gt; null then	//31 Mar 2015	NDL	Par 35961
			topOfStackIndex := _myTrackedItem.myPrimaryActualLocation.allTrackedItems.size;
			if _myTrackedItem.myPrimaryActualLocation.allTrackedItems.last &lt;&gt; _myTrackedItem then
				//I'm not on the top of the stack.
				return false;
			endif;
			if _nextLocationTrackedItem.myPrimaryActualLocation.allTrackedItems.size &lt;&gt; topOfStackIndex then
				//The stacks are different heights.
				return false;
			endif;
			//Par 35346 / CCMS 1408
			if _myTrackedItem.myPrimaryActualLocation.isKindOf(CM_WagonController) then
				if _nextLocationTrackedItem.myPrimaryActualLocation.CM_WagonController.getStackHeight
					&lt;&gt; _myTrackedItem.myPrimaryActualLocation.CM_WagonController.getStackHeight then
					//The stacks are different heights.
					return false;
				endif;
			endif;
			if _nextLocationTrackedItem.myPrimaryActualLocation.allTrackedItems.last &lt;&gt; _myTrackedItem then
				//he's not on the top of the stack.
				return false;
			endif;
		endif;
	endif;
	
	_direction:=CM_RTQueueEntry.TWIN_BOTH;

	return true;
epilog

end;</source>
        <Parameter name="_nextLocation" type="CM_LocationsController"/>
        <Parameter name="_myTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_nextLocationTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_direction" type="Integer" usage="output"/>
        <Parameter name="_errorString" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeTrackedItemSize" id="4006e388-a358-4ad5-871f-ef926523ce7d">
        <updating/>
        <source>changeTrackedItemSize(moveMode : Integer; ti : CM_TrackedItem input; 
				originalHeight, originalLength : Integer;
				_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2001 by cnwdwq1
// Purpose: 
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	newHeight	: Integer;
	newLength 	: Real;
	control : CMIF_MoveController;
begin

	inheritMethod(moveMode, ti, originalHeight, originalLength, _passport);
	
	//13 Oct 2014	NDL	Par 35040
	if self.allTrackedItems.size &gt; 1 then
		app.raiseCMException(No_Chg_OverStowed_or_ing, null, null);
	endif;
	
	// PAR 16415 CCMS 1029
//	newLength := _ti.getLengthInUnits();
	newLength := ti.getActualLength();
	newHeight := ti.getHeightOfTI();
	//----------------------
	// If there is no height or length size change then ...nothing to do...
	//----------------------
	if ( (newHeight = originalHeight) and (newLength = originalLength) ) then
		return;
	endif;
	//------------------
	//We need to create a moveController to do the work
	//------------------
	create control transient;
	control.setMyToPrimaryLocation(self);
	control.setMoveMode(moveMode);
	control.setMyTrackedItem(ti);
	control.setMyOriginatingLocation(self);
	control.isSystemMove := true;
	control.isResizing := true;
	//cnwth2a added this to ignore same position warning
	control.isForcedMove := true;
	
	if newLength &gt; originalLength then // if extending
// PAR 22750		if not self.getSpannedToLCs(control) then
		if  self.getSpannedToLCsNEW( control) &lt;&gt; null then
						//Not enough space!
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_NO_SPACE, control.myTrackedItem.id, self.myWagon.id, null, null);
			return;	
		endif;
	elseif newLength &lt; originalLength then 	//Retracting
		if not self.getSpannedToLCs(control) then
			//----------------
			//Not enough space! This is IMPOSSIBLE, cos we need LESS!!! Gulp. If you see this, panic! DQ
			//----------------
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_NO_SPACE, control.myTrackedItem.id, self.myWagon.id, null, null);
			return;	
		endif;
	endif;
	if newHeight &gt; originalHeight then
		//----------------
		//Test to be sure we are not going to bust it.
		//----------------
		if self.isStackFull(moveMode, null) then
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_GTMAX_HEIGHT, null, null);
		endif;
	endif;
	//----------------
	//Do the move.	
	//----------------
	control.warningsHaveBeenAcknowledged := true;
	control.executeMove(_passport);
epilog
	//Cleanup
	delete control;
end;</source>
        <Parameter name="moveMode" type="Integer"/>
        <Parameter name="ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="originalHeight" type="Integer"/>
        <Parameter name="originalLength" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayEntry" id="c2ca8d16-1c3c-4e8d-b4bf-d97bed448fab">
        <source>displayEntry(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	//Par 35346 / CCMS 1408

*/

vars

begin
	return self.getFullIdTI(null);

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="executeDisplayNotesForMove" id="9e132e58-a444-47e7-8a5e-db1431fcf634">
        <source>executeDisplayNotesForMove(_controller : CMIF_MoveController);
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	theWagon : CM_Wagon;
	theTerminal : CM_Terminal;
	theEvent : Integer;	
	theTI : CM_TrackedItem;
	theVoyage : CM_Voyage;
	theTrain : CM_Train;
begin

	theTI := _controller.myTrackedItem;


	theTerminal := self.myTerminal;
	
	theWagon := self.myWagon;
	
	theEvent := theTerminal.getTerminalEvent(Wagon_Update_Event);

// PAR 20329	if self &lt;&gt; _controller.myOriginatingLocation then
		app.myEventManager.createSingleObjInfoNoteEvt(theWagon, theEvent, theWagon);
// PAR 20329	endif;

	// update the load list
	if self.myTerminalArea &lt;&gt; null then
	
		//08 Dec 2011	NDL	Par 28797
		if _controller.isUndoMove and _controller.moveMode = PLANNING_MODE and theTI.intendedReleaseMode = TI_IntendedReleaseMode_RAIL then
			//unplanning on the Rail load list.
			app.myEventManager.createSingleObjInfoNoteEvt( theTI, theTerminal.getTerminalEvent(EVENT_PLANNING_TI_UNPLANNED), theTI );
		endif;
		
		if not _controller.isUndoMove and _controller.moveMode = PLANNING_MODE then
			// this is used in the load list
			app.myEventManager.createSingleObjInfoNoteEvt(self.myTerminalArea,theTerminal.getTerminalEvent(EVENT_PLANNING_TI_PLANNED),theTI);
		endif;
		
		// calling this event whether unplanning or not means that the TI is added to the load list as it arrives in the yard
		// this is used in the load list
		theVoyage := theTI.myVoyage;
		if theVoyage &lt;&gt; null then
			// PAR 33644 if theVoyage.isNonPlannedVoyage or theVoyage.isNonWorkedVoyage then
			if theVoyage.isHOLDSorSHIP() then
			
				app.myEventManager.createSingleObjInfoNoteEvt(theVoyage,theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
					theVoyage);								
			elseif (_controller.isUndoMove 
					// ### Just arrived by road/rail.
					or (_controller.isSystemMove and _controller.isForcedMove and _controller.myOriginatingLocation = null ) ) then 
				app.myEventManager.createSingleObjInfoNoteEvt(theVoyage,theTerminal.getTerminalEvent(EVENT_PLANNING_TI_UNPLANNED),theTI);
			endif;
		endif;
		
		// Update stats on the Train Maint form
		theTrain := theWagon.myTrainInwards;
		if theTrain &lt;&gt; null then
		//jlier1 JIRA#33496 5/12/24
			app.myEventManager.createSingleObjInfoNoteEvt(theTrain,theTerminal.getTerminalEvent(EVENT_TRAIN_REFRESH),null);
			//self.updateObjectEdition(theTrain);	// par 30292
			
			if theTrain &lt;&gt; theWagon.myTrainOutwards then
				theTrain := theWagon.myTrainOutwards;
				if theTrain &lt;&gt; null then
					app.myEventManager.createSingleObjInfoNoteEvt(theTrain,theTerminal.getTerminalEvent(EVENT_TRAIN_REFRESH),null);
				//	self.updateObjectEdition(theTrain);	// par 30292
				endif;
			endif;
		else
			theTrain := theWagon.myTrainOutwards;
			
			if theTrain &lt;&gt; null then
				app.myEventManager.createSingleObjInfoNoteEvt(theTrain,theTerminal.getTerminalEvent(EVENT_TRAIN_REFRESH),null);
			//	self.updateObjectEdition(theTrain);	// par 30292
			endif;
		endif;
		
	endif;
		
end;</source>
        <Parameter name="_controller" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="executePostMoveForOrigLocation" id="85ab8e20-d475-4db9-88db-9735cb19112d">
        <updating/>
        <source>executePostMoveForOrigLocation(_control : CMIF_MoveController; _passport : CM_Passport input)updating;
//--------------------------------------------------
// Created:	04 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	cnt : Integer;
	railJob : CM_RailJob;
	tmpJob : CM_Job;
	tmpWagon2,
	tmpWagon : CM_Wagon;
	moveTI,
	tmpTI : CM_TrackedItem;
	jobFound : Boolean;
	maxNumInStack : Integer;
	ti : CM_TrackedItem;
begin
	inheritMethod(_control, _passport);
	self.updateTwistLocksForMove(_control, _passport,true);
	
	//PAR 9452 from here -----------------------&gt;
	moveTI := _control.myTrackedItem;
	if moveTI = null then
		return;
	endif;
	
	tmpWagon := self.myWagon;
	if moveTI.getMyWagon = tmpWagon then
		//Still on the same wagon
		return;
	endif;
	
	//17 Feb 2015	NDL	Par 35710 - Make sure 'locationId' on the cargo correctly reflects the location height
	if _control.moveMode = REAL_MODE then
		maxNumInStack := self.myWagon.myWagonClass.maxNumInStack;
		if maxNumInStack &lt;&gt; 1 then
			foreach  ti in self.allTrackedItems do
				ti.refreshLocationId(REAL_MODE);
			endforeach;
		endif;
	endif;
	
	// Remove wagon from rail job if TI has been shifted to another wagon
	foreach tmpJob in tmpWagon.allRailJobs do
		if (not CM_RailJob.hasInstance(tmpJob)) then
			//This should not happen, but you never know
			continue;
		endif;
		railJob := tmpJob.CM_RailJob;
		if railJob.allReleaseTrackedItems.includes(moveTI) then
			//This job includes the TI that is being moved
			jobFound := true;
			foreach tmpTI in railJob.allReleaseTrackedItems do
				if tmpTI = moveTI then
					continue;
				endif;
				//Check to see if any of the other TI for this job are still on this wagon
				tmpWagon2 := tmpTI.getMyWagon();
				if tmpWagon2 &lt;&gt; null
				and tmpWagon2 = tmpWagon then
					//There is a TI for this job still on the wagon so don't remove wagon from the job
					railJob := null;
					break;
				endif;
			endforeach;
		endif;
		if jobFound then
			break;
		endif;
		railJob := null;
	endforeach;

	if jobFound
	and railJob &lt;&gt; null then
		railJob.removeWagon(tmpWagon);
	endif;
	
	//PAR9452 to here &lt;------------------
	
end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executePostMoveForToLocation" id="707470e8-e529-4e8c-ab85-c558e2ea70fe">
        <updating/>
        <source>executePostMoveForToLocation(control: CMIF_MoveController; _passport : CM_Passport input) updating;
/*
 ------------------------------------------------------------------------
Created:			17 December 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On			Changed By			Reason
--------------		--------------		-----------------------------------------
18/05/2023			jlizm1				TFS 57945 need new any amount wle to continue loading wagon
11/11/2024			navpw1				JIRA: MTN-33361 - Refactored code and fixed multiple dereferencing of the same properties. Split these into useful variables
10/12/2024			navpw1				JIRA: MTN-33528 - Made changes so that last wle created will be linked to the work order in the case where another wle is not created.
---------------------------------------------------------------------------
*/
vars
	maxNumInStack : Integer;
	ti : CM_TrackedItem;
	wle : CM_WorkListEntry;
	nextAnyAmountWle : CM_YardWLE;
	resDet : CM_ReserveDetail;
	newRRP : CM_TrackedItem;
	yardRequest : CM_YardRequest;
	
begin
	inheritMethod(control, _passport);
	
	//17 Feb 2015	NDL	Par 35710 - Make sure 'locationId' on the cargo correctly reflects the location height
	if control.moveMode = REAL_MODE then
		maxNumInStack := self.myWagon.myWagonClass.maxNumInStack;
		if maxNumInStack &lt;&gt; 1 then
			foreach  ti in self.allTrackedItems do
				ti.refreshLocationId(REAL_MODE);
			endforeach;
		endif;
		
		wle := control.myWorkListEntry;
		if wle &lt;&gt; null and wle.isKindOf(CM_YardWLE) and wle.isAnyAmount() then
			if  wle.myRequest.isKindOf(CM_YardRequest) then
				yardRequest :=  wle.myRequest.CM_YardRequest;
			endif;
			
			if yardRequest &lt;&gt; null and yardRequest.myReserveDetail &lt;&gt; null then
				resDet := yardRequest.myReserveDetail;
				
				if not resDet.isFullyLoaded then
					// create new anyAmount wle so more cargo can be loaded to wagon as needed
					create nextAnyAmountWle as wle.class;
					nextAnyAmountWle.setForCreate(wle.job, wle.myRequest);
					wle.CM_YardWLE.allLocationControllers.copy(nextAnyAmountWle.allLocationControllers);
					newRRP := resDet.createPlanningTrackedItem( null, null, false );
					nextAnyAmountWle.setMyTrackedItem(newRRP);
					// ### JIRA: MTN-33361 11Oct2024 NAVPW1
					if nextAnyAmountWle &lt;&gt; null and yardRequest.canLinkWorkOrderJobs(wle) then
						yardRequest.doCreateAndLinkWoWle(yardRequest, wle, wle.myTrackedItem);
					endif;
					// ### JIRA: MTN-33361 11Oct2024 NAVPW1
					app.myEventManager.createSingleObjInfoNoteEvt(nextAnyAmountWle, _passport.myTerminal.getTerminalEvent(WLE_Update_Event), nextAnyAmountWle);
				// ### JIRA: MTN-33528 12Dec2024 NAVPW1
				elseif wle.myWorkOrderWLE = null then
					//Link last wle created to the work order
					if yardRequest.canLinkWorkOrderJobs(wle) then
						yardRequest.doCreateAndLinkWoWle(yardRequest, wle, wle.myTrackedItem);
					endif;
				// ### JIRA: MTN-33528 12Dec2024 NAVPW1
				endif;
			endif;
		endif;
	endif;
	
	if control.isUndoMove then
		return;
	endif;	
	ti := control.myTrackedItem;
	ti.setPostMoveToWagon(control, _passport);
	ti.setPostMoveToTransport(control, _passport);
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getActualTIsForValidateMove" id="f91f8a24-85aa-4f5a-a74e-c871c6900c7e">
        <source>getActualTIsForValidateMove(_control : CMIF_MoveController input; 
							_allTIs : CM_TIArray input);
/*

Date		Who		Reason
22 January 2016	cnwer1	Initial creation PAR 37324
//22 Nov 2016 cnwrs1	Par 37738 TFS 2949 incorrect UPSP rail location being displayed
*/

vars
	ti : CM_TrackedItem;
	isROBorLoaded : Boolean;
begin
	//there is a config that says you can plan/queue cargo onto the wago if th cargo is already queued out 
	// this method gets the cargo that will actually be on the wagon - This setting is irrelevant its either queued or its not
	
	if _control &lt;&gt; null and _control.moveMode &lt;&gt; REAL_MODE then	//and self.myTerminal.getConfig(RailDisallowOutwardQueue).Boolean then
		foreach ti in self.allTrackedItems discreteLock do
				if ti.myPrimaryQueuedLocation = null then
					//17 Oct 2014	NDL	Par 35040 - DMAST only...
					isROBorLoaded := ti.isROB or not self.myWagon.allReportTIsInwards.includes(ti);  // it is a remain on board or was just loaded
					if not isROBorLoaded then
						_allTIs.add(ti);
					endif;
				endif;
		endforeach;
	else
		self.allTrackedItems.copy(_allTIs);
	endif;

epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_allTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllAssignedDelRequests" id="0bb7433b-9e84-4a9f-a7e6-d8ae19cf23cd">
        <source>getAllAssignedDelRequests(_allRequests : CM_DeliveryRequestSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
04 November 2022		jlizm1	Initial creation TFS 54118 Assigning Releases to Wagons

*/

vars
	
	iter : Iterator;
	wle : CM_WorkListEntry;
	req : CM_Request;
	invalid: Boolean;
	
begin

	iter := self.allRailWLELoad.createIterator;
	
	on Exception do app.handleDeletedObject( exception, req, invalid );
	while iter.next( wle ) do
		req := wle.myRequest;
		invalid := false;
		if req = null or not req.isKindOf( CM_DeliveryRequest ) then
			continue;
		endif;

		_allRequests.addNoDuplicates(req.CM_DeliveryRequest, false);
	endwhile;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_allRequests" type="CM_DeliveryRequestSet" usage="input"/>
    </JadeMethod>
