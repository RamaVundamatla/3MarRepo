    <JadeMethod name="setImCodes" id="a7db2b60-1c88-40ce-824e-081b52e2726f">
        <updating/>
        <source>setImCodes(_codes: String) updating;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     MES1008 

 Parameters:  None

 Returns:     Nothing

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 
 ---------------------------------------------------------------------------
*/
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
vars
	tmpIMCodes : StringArray;
begin
	create tmpIMCodes transient;
	self.addImCodes(_codes, tmpIMCodes);			// MES1008 allow imCodes in toehr classes. Was typecasting to _ediTI.CM_EDIPrenoteTI.imCodes.add(_processedValue);
	self.imCodes.clear();							// 17/03/2014 cnwmh5 #33648
	tmpIMCodes.copy(self.imCodes);
epilog    
	delete tmpIMCodes;
end;</source>
        <Parameter name="_codes" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementTypeValue" id="2b3392e9-db23-44f9-a735-e805495ca032">
        <updating/>
        <source>setMeasurementTypeValue(_columnName: String; _value: String) : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/09/2014	cnwmc5	Initial creation	PAR 34533
11/05/2015	cnwdap1	PAR #35924 Invalid parameter error when trying to save edits in EDI operations window
*/
vars
	rowName,
	measureType		: String;
	
begin

	if not inheritMethod(_columnName, _value) then
		return false;
	endif;
	
	_columnName.getRowNameMeasureType(rowName, measureType);
	
	if rowName = ETRow_TotalWeight then
		self.weight := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT());
		return true;
		
	elseif rowName = ETRow_ProductVolume then																// PAR #35924
		self.productVolume := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT.Real);		// PAR #35924
		return true;																						// PAR #35924
	endif;
	
	if self.class.getPropertyInHTree(rowName) &lt;&gt; null then
		self.setPropertyValue(rowName, app.convertMeasurementForStorage(measureType, _value.asDecimalJMT()));
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setOxygen" id="d04b10c9-9ec6-4364-85a3-959707be8acb">
        <updating/>
        <source>setOxygen(_oxygen : Decimal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2020	jlgndl1	Initial creation	TFS 47985
*/
vars

begin

	self.oxygen := _oxygen;

epilog
	
end;</source>
        <Parameter name="_oxygen" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setRawVoyageCode" id="b182a5e8-bcbb-4a86-aa20-86b5c7e0555a">
        <updating/>
        <source>setRawVoyageCode( _value : String ) updating;

/*
Date			Who		Reason
11 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
*/
	
vars
	
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	
	// remove the previous non-null value from this collection
	if self.rawVoyageCode &lt;&gt; null and self.myEDIConfig &lt;&gt; null then
		if self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( self.rawVoyageCode.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.removeKeyEntry( self.rawVoyageCode.toUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	self.rawVoyageCode	:= _value[ 1 : self.rawVoyageCode.maxLength ];
	if self.rawVoyageCode &lt;&gt; null and self.myEDIConfig &lt;&gt; null then
		if not self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( self.rawVoyageCode.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.putAtKey( self.rawVoyageCode.toUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setVoyageCode" id="fc5db21c-ca48-41bc-a785-afcd2f88810c">
        <updating/>
        <source>setVoyageCode( _value : String ) updating;
/*
Date			Who		Reason
09 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
11 April 2013	cnwcs5	Make use of local variables
// 20 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
*/
vars
	config			:CM_EDIConfig;
	coll			:CM_EDITIsByVoyageCodeDict;
	code, codeUpper	:String;
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	config := self.myEDIConfig;
	
	if config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
	endif;
	
	code := self.voyageCode;
	
	// remove the previous non-null value from this collection
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if coll.includesKey( codeUpper, self ) then
			coll.removeKeyEntry( codeUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	code			:= _value[ 1 : self.voyageCode.maxLength ];
	self.voyageCode	:= code;
	
	if not self.isTransient and
	   code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if not coll.includesKey( codeUpper, self ) then
			coll.putAtKey( codeUpper, self, self );
		endif;
	endif;
	
epilog
	
end;

</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="translateCommodity" id="71a36998-3f0c-4821-86be-87cb2719cb70">
        <updating/>
        <source>translateCommodity(_xlationOperator: CM_Operator) updating, protected;
//
// 18 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	mtCmdty : String;
	defCmdty : String;
	refCmdty : String;
	hazCmdty : String;
begin
	inheritMethod(_xlationOperator);
//	self.translateCommodityWithDescr(_xlationOperator);
	if self.commodity = null then 
		if self.getMyTerminal.getConfig(EdiBookingCommodity).Boolean then
			app.getTerminalDefCmdty(mtCmdty, defCmdty, refCmdty, hazCmdty);	
			if self.fullOrMT = "E" then
				self.commodity := mtCmdty;
			endif;
			if self.isHazardous then
				self.commodity := hazCmdty;
			endif;
			if self.temperature &lt;&gt; NULL_TEMPERATURE then
				// if we don't have a commodity xlation by now it is a reefer 
				self.commodity := refCmdty;
			endif;
			if self.commodity = null then
				self.commodity := defCmdty;
			endif;
		else
			self.commodity := self.commodityDescription[1:4];
		endif;
	endif;
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
</Class>
