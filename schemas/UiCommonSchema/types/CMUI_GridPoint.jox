    <JadeMethod name="drawBlankSpace" id="d492a367-bb51-417c-86ae-d764f58b9cd5">
        <updating/>
        <source>drawBlankSpace(pColor, pHeight : Integer; pFrame: CMUI_GridAreaFrame input;
		pX1, pY1, pX2, pY2 : Real) updating ,protected;
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	lDisplayMode, idx, lSize : Integer;
	lFactor : Real;
begin
	lFactor := self.myGridArea.scaleXFactor;
	lDisplayMode := self.myGridArea.mySDF.displayMode;

//	self.myLocationsController.getDrawingAttributes(0,0,pHeight, self.colour, self.letter);
	if self.colour = NULL_COLOURCODE then	
		self.colour := Gray;
	endif;
	if self.letter = "B" or self.letter = "R" or self.letter = "L" or self.letter = "SUB" then
		return;
	endif;

	if myGridArea.allSelectedPoints.indexOf(self) &lt;&gt; 0 then
		self.setSelectedDrawingAttributes(false, pFrame);
	else
		self.setUnselectedDrawingAttributes(false, pFrame, Gray);	// _isTI
	endif;

	pFrame.drawFillColor := self.colour;
	pFrame.drawFilledRectangle(pX1, pY1, pX2, pY2, self.colour); //DarkGray);
	// because we check the display mode and whether there is a TI in that mode in the calling method 
	// we know that only one of these is correct. 
	// e.g. If we are in actual mode and there is also something queued here then the drawing of that will be done in the 
	// drawing of the TI - with a Q icon. If we are here there are no TIs to display in that mode only P, Q or A, building, light tower etc.
	if self.colour = Black then
		self.colour := White;
	else
		self.colour := Black;
	endif;
	if self.letter = "X" then
		self.drawHeight(self.letter,Red,pFrame, pX1, pY1, pX2, pY2);
	elseif self.letter &lt;&gt; null then
		pFrame.drawTextAt(self.letter, pX1+((pX2-pX1)/2)-5, pY1+((pY2-pY1)/2)-6, self.colour);
	endif;

epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="pColor" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="pX1" type="Real"/>
        <Parameter name="pY1" type="Real"/>
        <Parameter name="pX2" type="Real"/>
        <Parameter name="pY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawBuilding" id="3c157f62-e321-461b-ad77-c1e3f8d0011e">
        <source>drawBuilding(_frame : CMUI_GridAreaFrame input);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawFMLetter" id="7cd6debb-7514-477f-8137-e364b7923d25">
        <source>drawFMLetter(_theFrame: CMUI_GridAreaFrame input; _theLetter : String; _isP40,_isQ40,_isA40 : Boolean;
				_theX1, _theY1, _theX2, _theY2: Real;_theFill, _mode, _tiIndex : Integer);
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------

vars
	is40, hasA, hasQ, hasP : Boolean;
	xOffset, yOffset,yOffsetFnt,xOffsetFnt,xWidth : Integer;
	aReal : Real;
	aGridAttribute : CMIF_GridAttributes;
	theLetter : String;
begin
	if _mode = 1 then
		hasP := true;
	elseif _mode = 2 then
		hasQ := true;
	elseif _mode = 6 then
		hasA := true;
	elseif _mode = 3 then
		hasP := true;
		hasQ := true;
	elseif _mode = 7 then
		hasP := true;
		hasA := true;
	elseif _mode = 8 then
		hasQ := true;
		hasA := true;
	elseif _mode = 9 then
		hasQ := true;
		hasP := true;
		hasA := true;
	else
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. UNKNOWN MODE " &amp; _mode.String);
		return;
	endif;
	
	_theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	if _mode = 6 then
		aGridAttribute := self.allTrackedItemAttributes[_tiIndex];
	elseif _mode = QUEUE_MODE then
		aGridAttribute := self.allQueuedTrackedItemAttributes[_tiIndex];
	elseif _mode = PLANNING_MODE then
		aGridAttribute := self.allPlanTrackedItemAttributes[_tiIndex];
	else
		return;
	endif;
	theLetter := _theLetter.trimBlanks;
	if aGridAttribute &lt;&gt; null then
		is40 := (aGridAttribute.width = 2) or (aGridAttribute.width = 4);
	endif;
	
	_theFrame.drawFontName := "Arial";
	_theFrame.drawStyle := Frame.DrawStyle_Dash;
	_theFrame.drawFillColor := _theFill;
	_theFrame.drawFilledRectangle(_theX1, _theY1, _theX2, _theY2,  Black);

	_theFrame.drawWidth := 2;
	xWidth := 0;
	if self.myGridArea.scaleXFactor = 1 then
		xWidth := 4;
		_theFrame.drawWidth := 1;
		xOffset := 2;
		yOffset :=3;
		yOffsetFnt := -1;

		if theLetter.length = 1 then
			xOffsetFnt := 7;
		else
			xOffsetFnt := 4;
		endif;
		_theFrame.drawFontSize := 8;
		_theFrame.drawFontBold := true;
	elseif self.myGridArea.scaleXFactor = 1.5 then
		xWidth := 4;
		_theFrame.drawWidth := 1;
		xOffset := 2;
		yOffset :=6;
		yOffsetFnt := 0;
		if theLetter.length = 1 then
			xOffsetFnt := 10;
		else
			xOffsetFnt := 3;
		endif;
		_theFrame.drawFontSize := 10;
		_theFrame.drawFontBold := true;
	elseif self.myGridArea.scaleXFactor = 2 then
		xWidth := 6;
		xOffset := 2;
		yOffset := 8;
		yOffsetFnt := 0;
		if theLetter.length = 1 then
			xOffsetFnt := 14;
		else
			xOffsetFnt := 8;
		endif;
		if theLetter.length &gt; 2 then
			yOffsetFnt := 0;
			_theFrame.drawFontSize := 12;
		else
			yOffsetFnt := 0;
			_theFrame.drawFontSize := 16;
		endif;
	elseif self.myGridArea.scaleXFactor = 3 then
		xWidth := 8;
		xOffset := 6;
		yOffset := 12;
		yOffsetFnt := 4;
		if theLetter.length = 1 then
			xOffsetFnt := 22;
		else
			xOffsetFnt := 11;
		endif;
		if theLetter.length &gt; 2 then
			yOffsetFnt := 4;
			_theFrame.drawFontSize := 18;
		else
			yOffsetFnt := 0;
			_theFrame.drawFontSize := 24;
		endif;
	elseif self.myGridArea.scaleXFactor = 4 then
		xWidth := 10;
		xOffset := 8;
		yOffset := 15;
		if theLetter.length = 1 then
			xOffsetFnt := 30;
		else
			xOffsetFnt := 15;
		endif;
		if theLetter.length &gt; 2 then
			yOffsetFnt := 6;
			_theFrame.drawFontSize := 24;
		else
			yOffsetFnt := 0;
			_theFrame.drawFontSize := 32;
		endif;
	endif;
	_theFrame.drawStyle := Frame.DrawStyle_Solid;
	_theFrame.drawFillColor := White;

	aReal :=  _theX1 + ((_theX2 - _theX1) / 2);
	xOffsetFnt := aReal.Integer;

	if _isQ40 or _isP40 or _isA40  then // the dummy side of a 40
		_theFrame.drawFilledRectangle(_theX1 + xOffset, _theY1 + yOffset, _theX2 - xOffset, _theY2 - yOffset,  Black);
		_theFrame.drawTextAt(theLetter, xOffsetFnt, _theY1 + yOffsetFnt, Black); 
/*
		if not self.myGridArea.flipHorizontal  then
			_theFrame.drawFilledRectangle(_theX1 - xWidth , _theY1 + yOffset, _theX2 - xOffset, _theY2 - yOffset,  Black);
			_theFrame.drawFilledRectangle(_theX1 - xWidth - _theFrame.drawWidth , _theY1 + yOffset + _theFrame.drawWidth, _theX1 - xWidth + _theFrame.drawWidth, _theY2 - yOffset - _theFrame.drawWidth,  White);
			_theFrame.drawTextAt(theLetter, _theX1 + xOffsetFnt, _theY1 + yOffsetFnt, Black); 
		else
			_theFrame.drawFilledRectangle(_theX1 + xWidth , _theY1 + yOffset, _theX2 , _theY2 - yOffset,  Black);
			_theFrame.drawFilledRectangle(_theX2  - _theFrame.drawWidth , _theY1 + yOffset + _theFrame.drawWidth, _theX2 + _theFrame.drawWidth, _theY2 - yOffset - _theFrame.drawWidth,  White);
			_theFrame.drawTextAt(theLetter, _theX1 + xOffsetFnt, _theY1 + yOffsetFnt, Black); 
		
		endif;
*/
	else
		if is40 then
			_theFrame.drawFilledRectangle(_theX1 + xOffset, _theY1 + yOffset, _theX2 - xOffset, _theY2 - yOffset,  Black);
/*
			if not self.myGridArea.flipHorizontal  then
				_theFrame.drawFilledRectangle(_theX1 + xOffset, _theY1 + yOffset, _theX2 + 2, _theY2 - yOffset,  Black);
				_theFrame.drawFilledRectangle(_theX2 - _theFrame.drawWidth , _theY1 + yOffset + _theFrame.drawWidth,
					 _theX2 + 2 , _theY2 - yOffset - _theFrame.drawWidth,  White);
			else
				_theFrame.drawFilledRectangle(_theX1, _theY1 + yOffset, _theX2 - xOffset, _theY2 - yOffset,  Black);
				_theFrame.drawFilledRectangle(_theX1 + _theFrame.drawWidth , _theY1 + yOffset + _theFrame.drawWidth,
					 _theX1 - _theFrame.drawWidth , _theY2 - yOffset - _theFrame.drawWidth,  White);
			
			endif;
			*/
		else
			_theFrame.drawFilledRectangle(_theX1 + xOffset, _theY1 + yOffset, _theX2 - xOffset, _theY2 - yOffset,  Black);
		endif;
		_theFrame.drawTextAt(theLetter, xOffsetFnt, _theY1 + yOffsetFnt, Black); 
	endif;
epilog
	_theFrame.drawWidth := 1;
	_theFrame.drawFontBold := false;

end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theLetter" type="String"/>
        <Parameter name="_isP40" type="Boolean"/>
        <Parameter name="_isQ40" type="Boolean"/>
        <Parameter name="_isA40" type="Boolean"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
        <Parameter name="_theFill" type="Integer"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_tiIndex" type="Integer"/>
    </JadeMethod>
