    <JadeMethod name="setFormData" id="16a4e559-8317-46ad-808f-96b4417abdec">
        <updating/>
        <source>setFormData() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 March 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/

vars
	currentTransition : CM_IMEXTransitionCriteria;
begin
	currentTransition := self.myParentForm.CMUI_CargoIMEXTransitionList.myCurrentTransition;
	if currentTransition &lt;&gt; null then
		self.txtDescr.text := currentTransition.description;
		self.txtName.text := currentTransition.name;
		self.cmbIMEX.listObject := app.myRoot.allImexStatuses[currentTransition.transitionIMEX];
	endif;	
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setPreEditDetails" id="199bef7e-bd3d-4103-a56a-97ee99e1ee04">
        <updating/>
        <source>setPreEditDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 March 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/

vars
	transitionProxy : CM_IMEXTransitionCriteria;
begin
	transitionProxy := self.myProxyObject.CM_IMEXTransitionCriteria;
	self.transName := transitionProxy.name; // keep pre-edit transition details
	self.transDescription := transitionProxy.description;
	self.transIMEXstatus := transitionProxy.transitionIMEX;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="05491b8e-436f-4314-a1dd-c99bfbba0ea1">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 August 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason	
----------   ----------  --------------------------------------------------
28 March 2018	jlgsl4	 TFS 37410 Import MTs IMEX transition status
*/
vars
	caption : String;
begin
	
	inheritMethod();
	self.setPreEditDetails;
	caption := self.transName;
	if caption &lt;&gt; null then
		caption := "'" &amp; caption &amp; "'";
	endif;
	caption := self.Caption &amp; caption;
	self.setCaption(caption);
	self.populateIMEX;
	self.txtName.setFocus;
	self.setFormData;

end;


</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="af223768-2ff4-4a9c-a151-5b3e34a5335f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 May 2018 11:53:20.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	//self.translateCaption(Xlat_0022421, locale);
	btnCancel.translateBubbleHelp(Xlat_0005006, locale);
	btnCancel.translateCaption(Xlat_0005007, locale);
	btnCriteria.translateCaption(Xlat_0022378, locale);
	btnOK.translateBubbleHelp(Xlat_0005008, locale);
	btnOK.translateCaption(Xlat_0005009, locale);
	grpCriteria.translateCaption(Xlat_0022379, locale);
	lblCriteria.translateCaption(Xlat_0022380, locale);
	lblIMEX.translateCaption(Xlat_0022381, locale);
	lblName.translateCaption(Xlat_0022382, locale);
end;</source>
    </JadeMethod>
