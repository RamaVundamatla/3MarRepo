    <JadeMethod name="create" id="f2755ab4-0498-4f89-b371-7af2445a0d22">
        <updating/>
        <source>create() updating;

begin
	self.createDbServerMachineDesc;
	
	beginNotification(system, CmdPingResponseEventNumber, Response_Continuous, 0);
	beginNotification(system, CmdTrxPingResponseEventNumber, Response_Continuous, 0);
	beginNotification(system, CmdProfileMthResponseEventNo, Response_Continuous, 0);
	beginNotification(system, CmdDriverStopResponseEventNo, Response_Continuous, 0);

	self.cloneAppServerPort := 0;

	beginClassNotification(Process, false, Object_Delete_Event, Response_Continuous, 0);
end;</source>
    </JadeMethod>
    <JadeMethod name="createDbServerMachineDesc" id="9e196d07-5c3e-48fc-bb38-db96e9749a21">
        <updating/>
        <source>createDbServerMachineDesc() updating, protected;

vars
	totalMem, errNo : Integer;
	s, cpu, errTxt : String;
	md : MachineDescriptor;
	
begin
	if self.myDbServerMachineDescriptor &lt;&gt; null and
	   global.isValidObject(self.myDbServerMachineDescriptor)
	then
		delete self.myDbServerMachineDescriptor;
	endif;
	
	system.getDbServerNameAndTotalMemory(s, totalMem);

	// arm an exception handler to guard against something going wrong
	// in getDbServerCPUDetails (eg: external functions not available)
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);
	
//	cpu := system.getDbServerCPUDetails;
	
	// if getDbServerCPUDetails gets an exception, we'll resume here
	on Exception do null; // disarm our handler armed above
	
	create md transient;
	md.updateForCreate(s, totalMem, 0, cpu, self);
	self.myDbServerMachineDescriptor := md;
	
	self.getDbServerFreeDiskAndMemory;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="delete" id="1aa62d51-35f1-419f-a017-8bc2c0fd33a5">
        <updating/>
        <source>delete() updating;

begin
	endNotificationForSubscriber(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmdClear" id="d550b677-6b8a-416f-815f-5e0dd99abd24">
        <source>doCmdClear(target : Object);

vars
	errNo : Integer;
	errTxt : String;
	
begin
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);

	if target = null then	
		system.causeEvent(CmdEventNumber, true, CmdClear);
	else
		target.causeEvent(CmdEventNumber, true, CmdClear);
	endif;
end;</source>
        <Parameter name="target" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doCmdClone" id="4d9ada10-9fd2-4899-891a-b1f8f690e71f">
        <source>doCmdClone(target : Object; clones : Integer);

vars
	s, errTxt : String;
	errNo : Integer;
	
begin
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);

	if clones &lt;= 0 then
		s := '1';
	else
		s := clones.String;
	endif;
	
	s := s &amp; ';' &amp; self.cloneFatClientsExternally.String &amp; ';' &amp;
		self.cloneAppServer &amp; ';' &amp; self.cloneAppServerPort.String &amp; ';';

	if target = null then
		system.causeEvent(CmdEventNumber, true, CmdClone &amp; ':' &amp; s);
	else
		target.causeEvent(CmdEventNumber, true, CmdClone &amp; ':' &amp; s);
	endif;
end;</source>
        <Parameter name="target" type="Object"/>
        <Parameter name="clones" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doCmdCloneMachine" id="a1d6b7d2-4fe3-47a5-8588-93667feb799c">
        <source>doCmdCloneMachine(md : MachineDescriptor; numClones : Integer);

vars
	pd : ProcessDescriptor;
	
begin
	if md = null or numClones &lt; 1 or numClones &gt; MaxClones then
		return;
	endif;
	
	foreach pd in md.allProcessDescriptors do
		if pd.myProcess &lt;&gt; null then
			self.doCmdClone(pd.myProcess, numClones);
		endif;
	endforeach;
end;</source>
        <Parameter name="md" type="MachineDescriptor"/>
        <Parameter name="numClones" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doCmdCloneSpecify" id="042ba0f3-74d4-473c-915f-be2b3c25ab81">
        <source>doCmdCloneSpecify(target : Object);

vars
	n, errNo : Integer;
	s, errTxt : String;
	
begin
	if app.readInteger("Enter the number of times each driver is to be cloned:",
		true, 1, MaxClones, n)
	then
		s := n.String &amp; ';' &amp; self.cloneFatClientsExternally.String &amp; ';' &amp;
			self.cloneAppServer &amp; ';' &amp; self.cloneAppServerPort.String &amp; ';';

		on Exception do app.resumeNextExHandler(exception, errNo, errTxt);

		if target = null then
			system.causeEvent(CmdEventNumber, true, CmdClone &amp; ':' &amp; s);
		else
			target.causeEvent(CmdEventNumber, true, CmdClone &amp; ':' &amp; s);
		endif;
	endif;
end;</source>
        <Parameter name="target" type="Object"/>
    </JadeMethod>
