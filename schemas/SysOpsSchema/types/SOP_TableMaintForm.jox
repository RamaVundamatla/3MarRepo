    <JadeMethod name="populateFillOptionCombo" id="ce4771bf-6214-40e5-9baf-2a8ed937969a">
        <source>populateFillOptionCombo(pComboboxObj:ComboBox input; _val : String) ;
/*
----------   ----------  --------------------------------------------------
Created:	07 December 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	listPointer		: Integer;
	idx		: Integer;
begin
	pComboboxObj.clear;
	listPointer	:=	pComboboxObj.addItem(YAFillOption_InOrderStr);
	pComboboxObj.itemData[listPointer]	:=	YAFillOption_InOrder;
	
	listPointer	:=	pComboboxObj.addItem(YAFillOption_AlternatingStr);
	pComboboxObj.itemData[listPointer]	:=	YAFillOption_Alternating;
	
	listPointer	:=	pComboboxObj.addItem(YAFillOption_FIFOStr);
	pComboboxObj.itemData[listPointer]	:=	YAFillOption_FIFO;
	
	idx := pComboboxObj.findStringExact(1,_val);
	
	pComboboxObj.listIndex := idx;
	
end;</source>
        <Parameter name="pComboboxObj" type="ComboBox" usage="input"/>
        <Parameter name="_val" type="String"/>
    </JadeMethod>
