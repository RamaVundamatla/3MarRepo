    <JadeMethod name="addToCollectionForNotes" id="ce441a59-e05e-4c62-840c-958936240128">
        <source>addToCollectionForNotes( _voyage : CM_Voyage; setOfObjects  : HMS_VoyageDataSet io);

//-----------------------------------
//	Created:	21 September 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	tmpVoyage	: CM_Voyage;
begin

	foreach tmpVoyage in self.allVoyages do
		if tmpVoyage.arrivedDT &lt;= _voyage.arrivedDT then
			continue;
		endif;
		if tmpVoyage.myHMSVoyageData &lt;&gt; null then
			setOfObjects.add (tmpVoyage.myHMSVoyageData);
		endif;
	endforeach;
	
	if self.mySubsVoyageGlobal &lt;&gt; null then
		self.mySubsVoyageGlobal.addToCollectionForNotes (self.allVoyages.last, setOfObjects);
	endif;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="setOfObjects" type="HMS_VoyageDataSet" usage="io"/>
    </JadeMethod>
