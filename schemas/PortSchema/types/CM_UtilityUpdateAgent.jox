    <JadeMethod name="utlUpdateHMSWorkingVoyages" id="1a8e4578-074b-4357-b02c-57df10386f9a">
        <updating/>
        <source>utlUpdateHMSWorkingVoyages(_cmifViewController : CMIF_HMS_ViewController input; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
// 22 Aug 2023 navma1 	Bug 59061: LNX - Updating ETA/ETD and ATA/ATD dates vis Graphical View are not creating an audit
// 22 Aug 2023 navhl20 	Bug 59061: LNX - Updating ETA/ETD and ATA/ATD dates vis Graphical View are not creating an audit
//-----------------------------------------
vars
	expectedEdition : Integer;
	voyage			: CM_Voyage;
	voyageSet		: CM_VoyageSet;
	obj				: CMIF_Object;
	cmifChange		: CMIF_HMS_MovementEdit;
	cmifMove 		: CMIF_HMS_WorkingMovement;
	itemAudit		: CM_UpdateTransactionAuditAgent;
	allAudits		: ObjectArray;
	index			: Integer;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	self.raiseExceptionIfNull(_cmifViewController, '_cmifViewController');

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	/*
	22.08.2023 navma1 #59061
	*/
	create voyageSet transient;	
	create allAudits transient;
	
	foreach obj in _cmifViewController.allChanges do
		if obj.isKindOf(CMIF_HMS_MovementEdit) then
		   cmifMove := obj.CMIF_HMS_MovementEdit.getMyWorkingMovement;
		   if cmifMove &lt;&gt; null then
			   voyage :=  cmifMove.getVoyage();
			    if voyage &lt;&gt; null then
					voyageSet.addNoDuplicates(voyage,false);
				endif;
			endif;
		endif;
	endforeach;

	/*
	22.08.2023 navma1 #59061
	*/
	if _passport.noErrors then	
		foreach voyage in voyageSet do							//22.8.2023 navhl20 #59061
			create itemAudit transient;
			itemAudit.audUpdateGeneric(voyage, true);
			allAudits.add(itemAudit);
		endforeach;
	endif;
		
	_cmifViewController.saveChangesToDatabase(_passport);
		
	/*
	22.08.2023 navma1 #59061
	*/
	if _passport.noErrors then
		foreach voyage in voyageSet do							//22.8.2023 navhl20 #59061
			index += 1;
			itemAudit := allAudits[index].CM_UpdateTransactionAuditAgent;
			itemAudit.audUpdateGeneric(voyage, false);
			delete itemAudit;
		endforeach;
	endif;
	
epilog
	delete allAudits;
	delete voyageSet;
end;</source>
        <Parameter name="_cmifViewController" type="CMIF_HMS_ViewController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateHandlingType" id="4ca4bfb4-b6b3-4542-87ef-c8a41f2b7415">
