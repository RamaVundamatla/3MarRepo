    <JadeMethod name="matchBooleanValues" id="d0e2ea05-4867-4fb7-95aa-2cb8987c5b12">
        <source>matchBooleanValues(_attribute : String; _value : Boolean) : Boolean protected;
/*

Date		Who		Reason
02 October 2015	cnwer1	Initial creation PAR 37018

*/

vars

begin
	if _attribute &lt;&gt; null and _attribute &lt;&gt; "Any" and _attribute &lt;&gt; Any_String then
		if _attribute.asBooleanJMT then
			if  not _value then
				return false;
			endif;
		else 
			if  _value then
				return false;
			endif;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_value" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="matchLogGrade" id="ebafcadb-b6af-4997-aad2-b6783fb05a09">
        <source>matchLogGrade(_restriction :  CM_LocationRestrictLog input) : Boolean protected;
/*

Date		Who		Reason
02 October 2015	cnwer1	Initial creation PAR 37018

*/

vars
	code : CM_Code;
begin
	if self.logGrade = null then
		return true;
	endif;
	
	if _restriction = null then
		return false;
	endif;
	
	foreach code in _restriction.allLogGrades do
		if code.code.cnEcIsMatch( self.logGrade ) then
			return true;
		endif;
	endforeach;
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_restriction" type="CM_LocationRestrictLog" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="matchLogLength" id="c2ab0215-af05-4274-b692-8c69c79d899a">
        <source>matchLogLength(_restriction :  CM_LocationRestrictLog input) : Boolean protected;
/*

Date		Who		Reason
02 October 2015	cnwer1	Initial creation PAR 37018

*/

vars
	code : CM_Code;
	doesMatch,
	invalidCode : Boolean;
	tmpStr : String;
	theLogLength : Decimal[12,2];

begin
	if self.logLength = null then
		return true;
	endif;
	
	if _restriction = null then
		return false;
	endif;
	
	
	doesMatch := false;	
	on Exception do app.handleDeletedObject(exception, code, invalidCode);
	foreach code in _restriction.allLogLengths do
			tmpStr := code.code;
			if invalidCode then
				invalidCode := false;
				continue;
			endif;
			if not tmpStr.isDecimal then
				continue;
			endif;
			theLogLength := tmpStr.Decimal;
			
			if self.logLengthSign = "=" then
				if theLogLength = self.logLength then
					doesMatch := true;
					break;
				endif;
			elseif self.logLengthSign = "&gt;" then
				if theLogLength &gt; self.logLength then
					doesMatch := true;
					break;
				endif;
			elseif self.logLengthSign = "&lt;" then
				if theLogLength &lt; self.logLength then
					doesMatch := true;
					break;
				endif;
			elseif self.logLengthSign = "&gt;=" then
				if theLogLength &gt;= self.logLength then
					doesMatch := true;
					break;
				endif;
			elseif self.logLengthSign = "&lt;=" then
				if theLogLength &lt;= self.logLength then
					doesMatch := true;
					break;
				endif;
			elseif self.logLengthSign = "&lt;&gt;" then
				if theLogLength &lt;&gt; self.logLength then
					doesMatch := true;
					break;
				endif;
			endif;
	
	endforeach;
		
	return doesMatch;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_restriction" type="CM_LocationRestrictLog" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="matchLogSpecies" id="62f6e25b-9a68-43f0-980a-410036f09ef8">
        <source>matchLogSpecies(_restriction :  CM_LocationRestrictLog input) : Boolean protected;
/*

Date		Who		Reason
02 October 2015	cnwer1	Initial creation PAR 37018

*/

vars
	tmpStr : String;
	code : CM_Code;
	invalidCode : Boolean;
begin
	if self.logSpecies = null then
		return true;
	endif;
	
	if _restriction = null then
		return false;
	endif;
	
	on Exception do app.handleDeletedObject(exception, code, invalidCode);
	foreach code in _restriction.allLogSpecies do
		tmpStr := code.code;
		if invalidCode then
			invalidCode := false;
			continue;
		endif;
		if tmpStr.cnEcIsMatch( self.logSpecies ) then
				return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_restriction" type="CM_LocationRestrictLog" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
