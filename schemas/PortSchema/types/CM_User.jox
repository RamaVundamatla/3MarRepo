    <JadeMethod name="canDeleteStop" id="9560be20-5f16-49ff-8fba-5d739eaf4922">
        <source>canDeleteStop(_terminal : CM_Terminal; _stopTable : CM_StopsTable) : Boolean;
// --------------------------------------------------------------------------------
// Created:		03 June 2010 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver can delete
//				the specified Stop.
//
// Parameters:	_terminal - A reference to the current Terminal.
//				_stopTable - A reference to the Stop to delete.
//
// Returns:		True if the receiver can delete the Stop, otherwise false.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09 Sep 2019	jlgdi1		45802 Added condition check for JMTSupport user 
// ---------------------------------------------------------------------------
vars
	userTerminal	: CM_UserTerminal;
	
begin
	if _stopTable = null then
		return false;
	endif;
	
	if app.isSpecial() then
		return true;
	endif;
	
	if _terminal = null then
		return false;
	endif;
	
	// 45802
	if self.isJmtSupportUser() then 
		return false;
	endif;
	
	userTerminal	:=	self.getUserTerminal(_terminal);
	
	if userTerminal = null then
		return false;
	endif;
	
// cnwdad1 03/06/2010 - CCMS 1129.
	if userTerminal.mySecurityRole &lt;&gt; null
	and userTerminal.mySecurityRole.allStopsCancel.includes(_stopTable)
	then
	   	return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDo" id="2793aafd-d6b4-4770-ad8a-db29e05b4d4f">
        <source>canDo(_terminal : CM_Terminal; _doWhat : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:			26 March 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// 
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09 Sep 2019	jlgdi1		45802 Added condition check for JMTSupport user 
// 31 May 2021  navma1 		ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
// 30 Oct 2023	navma1 		ChangeRequest 60841: MTN - Improve Performance of Cargo Bulk Edit - First Enhancement
// ---------------------------------------------------------------------------
vars
	tmpTerminal		: CM_Terminal;
	tmpUT			: CM_UserTerminal;
	obj				: Object;
	tmpNum			: Integer;
	termStr 		: String;
	doWhatString 	: String;
	hasPermission	: Boolean;
	passport		: CM_Passport;
	root			: CM_Root;
	securityRole    : CM_SecurityRole;
begin

	if _terminal &lt;&gt; null then							
		tmpTerminal := _terminal;							//30.10.2023 navma1 #60841
	endif;

	passport := app.myPassport;								//30.10.2023 navma1 #60841
	if passport &lt;&gt; null then
		passport.myActivityCapture.logSecurity('For terminal "' &amp; tmpTerminal.String &amp; ', ' &amp; _doWhat.String);
	endif;
	
	// this supports the mapping method in Base Form for JMTSUPPORT user
	if _doWhat = -1 
		or (self.isJmtSupportUser() and not isViewFormType(_doWhat))
	then
		return false;
	endif;
	
	root 	:= app.myRoot;
	
	if _doWhat &gt; Mod_BaseView then
		tmpNum  := _doWhat - Mod_BaseView;
		// need to call into license key schema
		obj 	:= app.myCheckerObject;
		
		
		if obj = null then
			return false;
		endif;
		
		if tmpTerminal = null or root.canDo(PmSite) then			//30.10.2023 navma1 #60841
			//doing myRoot.canDo here now - this picks up the sys/terminals combined license - at the system level we 
			//need to be able to administer things licensed at terminal level (even when not licensed at the system level)
			hasPermission := root.canDo(_doWhat);					//30.10.2023 navma1 #60841
			return hasPermission;
		elseif tmpTerminal.licenseName &lt;&gt; null then
			// assume that if licenseName is null then terminal is not licensed
			hasPermission := obj.sendMsgWithParams('isLicensed', tmpTerminal.licenseName, 'JMT', tmpNum).Boolean;
			return hasPermission;
		endif;
		return false;
	endif;
	
	if _doWhat &lt;= 0 then
		return false;
	endif;
	
	if not root.isLicensedForPermission(_doWhat) then
		return false;
	endif;

	// do this after checking what is licensed
	if app.isSpecial() and app.getMyUser() = self then
		hasPermission := true;
		return hasPermission;
	endif;
	
	securityRole := self.mySystemSecurityRole;					//30.10.2023 navma1 #60841
	
	if securityRole &lt;&gt; null then
		if securityRole.canDo(_doWhat) then
			hasPermission := true;
			return hasPermission;
		endif;
	endif;

	if tmpTerminal = null then
		return false;
	endif;

	tmpUT := self.getUserTerminal(tmpTerminal);
	if tmpUT = null then
		return false;
	endif;

	hasPermission := tmpUT.canDo(_doWhat);
	return hasPermission;
	
epilog
	
	if app.myLoggingForm &lt;&gt; null then
		if tmpTerminal &lt;&gt; null then
			termStr := tmpTerminal.code;
		endif;
		doWhatString := self.getPermissionNameFromInteger(_doWhat);
		if termStr = null then
			app.doFormLogging( method, "System permission check for '" &amp; doWhatString &amp; "' returned '" &amp; hasPermission.String &amp; "'", null );
		else
			app.doFormLogging( method, "Terminal permission check on '" &amp; termStr &amp; "', for '" &amp; doWhatString &amp; "' returned '" &amp; hasPermission.String &amp; "'", null );
		endif;
	endif;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_doWhat" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDoSomewhere" id="858e5959-2ae3-4793-ab5a-35a9027aa104">
        <source>canDoSomewhere(_doWhat : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:			26 March 2001 by cnwdwq1
// Purpose:			returns true if user can do at any terminal they have access to
//					(should be replaced when web app becomes terminal aware     
// ---------------------------------------------------------------------------
vars
	tmpUT	: CM_UserTerminal;
	obj		: Object;
	tmpNum	: Integer;
	licName	: String;
	
begin

	if app.myPassport &lt;&gt; null then
		app.myPassport.myActivityCapture.logSecurity('At any terminal, ' &amp; _doWhat.String);
	endif;
	
	if _doWhat &gt; Mod_BaseView then

		tmpNum := _doWhat - Mod_BaseView;
		
		// need to call into license key schema
		obj := app.myCheckerObject;
		if obj = null then
			return false;
		endif;
		if app.myRoot.canDo(PmSite) then
			//doing myRoot.canDo here now - this picks up the sys/terminals combined license - at the system level we 
			//need to be able to administer things licensed at terminal level (even when not licensed at the system level)
			return app.myRoot.canDo(_doWhat);
			//return obj.sendMsgWithParams('isLicensed', app.myRoot.licenseName, 'JMT', tmpNum).Boolean;
		else
			// assume that if licenseName is null then terminal is not licensed
			foreach tmpUT in self.allUserTerminals do
				licName := tmpUT.getMyTerminal.licenseName;
				if licName &lt;&gt; null and
				   obj.sendMsgWithParams('isLicensed', licName, 'JMT', tmpNum).Boolean then
					return true;
				endif;
			endforeach;
		endif;
		return false;
	endif;
	
	if _doWhat &lt;= 0 then
		return false;
	endif;

	// do this after checking what is licensed
	if app.isSpecial() and app.getMyUser() = self then
		return true;
	endif;
	
	if self.mySystemSecurityRole &lt;&gt; null then
		if self.mySystemSecurityRole.canDo(_doWhat) then
			return true;
		endif;
	endif;
		
	foreach tmpUT in self.allUserTerminals do
		if tmpUT.canDo(_doWhat) then
			return true;
		endif;
	endforeach;

	return false;

end;</source>
        <Parameter name="_doWhat" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canHaveAudits" id="d21ae6bf-c4f1-4836-9756-cf2df14edac7">
