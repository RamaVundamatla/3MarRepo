    <JadeMethod name="doSave" id="07cd3dfb-8703-4033-97be-4528d8477eb1">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	navObject	: CMUI_NavigatorObject;
	errObj		: CM_Error;
	rtnValue	: Boolean;

begin

	if self.mode = Mode_Add then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to add a Docket - This is not permitted');
		return false;
	elseif self.mode = Mode_Update then
		if self.myProxyObject = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
			return false;
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled mode (' &amp; self.mode.String &amp; ')');
		return false;
	endif;

	if self.myProxyObject.CM_BOL.bolType = BOLType_Log then
		rtnValue := self.doSaveLogDocket();
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled boltype (' &amp; self.myProxyObject.CM_BOL.bolType.String &amp; ')');
		return false;
	endif;

	return rtnValue;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveLogDocket" id="ce724c50-5ab2-4697-90f6-c2b38d592fcc">
        <updating/>
        <source>doSaveLogDocket() : Boolean updating, protected;
//--------------------------------------------------------------
//Created: 24 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	intFaceObj	: CMIF_BOLIn;
	pxyBOL 		: CM_BOL;
	pxyBOLIn	: CM_BOLIn;
	
	result		: Integer;
	pxyDocketError : CM_DocketError;
	tmpDocketErrorType	: CM_DocketErrorType;
	
begin

	pxyBOL := self.myProxyObject.CM_BOL;
	create intFaceObj as CMIF_BOLIn transient;
	//epr TFS 2889 2/11/16
	tblMain.setObjectFromTable(intFaceObj, CMUI_DocketForm::saveEntTblSpecial.name, false);

	intFaceObj.myTerminal			:=	self.myTerminal;
	intFaceObj.mySubTerminal		:=	pxyBOL.mySubTerminal;
	intFaceObj.bolType				:=	pxyBOL.bolType;
	intFaceObj.myOperator			:=	self.cmbSupplier.myObject.CM_Operator;
	intFaceObj.myPlannedLocation	:=	cmbLogLocation.listObject.CM_LocationsController;
	
	// #24817 1/07/2010 - we need to retrieve value from UI combobox
	tmpDocketErrorType := self.cmbDocketError.listObject.CM_DocketErrorType;
	if tmpDocketErrorType = null then	// no docket errors in UI screen
		pxyBOL.allDocketErrors.purge;
	else	// there is a docket error in UI screen
		pxyDocketError := pxyBOL.allDocketErrors.first;	// if proxy docket error exists, then we will update existing real docket error
		if pxyDocketError = null then	// if proxy docket error = null, it means - user created a new docket error
			create pxyDocketError as CM_DocketError transient;
			pxyDocketError.setMyBol(pxyBOL);
		endif;
		pxyDocketError.setMyDocketErrorType(tmpDocketErrorType);	// setting docket error type according to UI screen
		
	endif;
	
	
	// ccms1089. Docket Correction, when BOL has been matched today. We can edit it today still.
	if intFaceObj.myPlannedLocation = null then
		// For Docket Correction - if cmbLogLocation is untouched on the screen, then we have cmbLogLocation value = null.
		// It is because myPlannedLocation is null when there is Docket Correction case
		pxyBOLIn := pxyBOL.CM_BOLIn;
		if pxyBOLIn.isMatchedTodayForDocketCorrect() then
			intFaceObj.myPlannedLocation := self.getLocationById( intFaceObj.logLocation );
		endif;
	endif;
	

	intFaceObj.transportMode		:= pxyBOL.transportMode;
	intFaceObj.sourceLocation		:= intFaceObj.forest;
	intFaceObj.sourceSubLocation	:= intFaceObj.compartment;
	intFaceObj.sourceSubSubLocation	:= intFaceObj.stand;		

	
	if self.cmbConsignor.listObject &lt;&gt; null then
		intFaceObj.consignorCode := self.cmbConsignor.listObject.CM_ConsigneeConsignor.code;
	endif;

	if self.pressedButtonEditDocketCorrect &lt;&gt; null then	// when Docket Correction case
		if self.pressedButtonEditDocketCorrect &lt;&gt; self.systemToLocalTime(app.actualTimeServer()).Date then	// 26/4/16 cnwmp6 TFS 488 - Multi timezone support
			if pxyBOLIn.matchTime.date &lt;&gt; app.actualTimeServer().date then // when a user was waiting too long in edit mode and the following day has come.
				app.raiseCMException( ERR_DocketCorrectionExpired, null, self);
				return false;
			endif;
		endif;
	endif;
	
	// Par 8865. 27/08/04 What was this for. Ended up getting twice as many sequences.
	// Ext is directly accessed.
//	pxyBOL.myExtension.CM_BOLExtLogIn.allTicketSequences.copy(intFaceObj.allTicketSequences);
	pxyBOL.allTrackedItems.copy(intFaceObj.allTrackedItems);
	pxyBOL.allDocketErrors.copy(intFaceObj.allDocketErrors);	// #24817 1/07/20104
	
	pxyBOL.setPxyFromCMIF_BOL(intFaceObj, app.myPassport);
	

	while true do
		app.myTrxUA.trxUpdateBOL(pxyBOL, false, null, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Docket Maintenance', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings); 
			//+ ErrWarnMode_CanAckWarnings added par11523
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
	endwhile;

	return true;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findBOLItems" id="baf928ab-f0e1-4768-88ff-10682ddc14ad">
        <source>findBOLItems():Collection;
//14 January 2010	cnwml2
// 27881 cnwjre1 Aug 2011 this method is no longer called

vars
	bol : CM_BOL;
	bolDtl : CM_BOLDtl;
	oa : ObjectArray;
begin
	create oa transient;
	foreach bol in self.myTerminal.allBOLsReceivedByDTType do
		foreach bolDtl in bol.allBOLDtls do
			oa.add(bolDtl);
		endforeach;
	endforeach;
	return oa;
epilog

end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getLocationById" id="dbb9efbb-3523-4c12-b1bd-5d374d9511c8">
        <source>getLocationById( _locationId : String) : CM_LocationsController protected;
//--------------------------------------------------------------
//Created: 09 Jan 2008 By: cnwvu1
//--------------------------------------------------------------

vars
	location	: CM_LocationsController;
	
begin

	foreach location in self.allLogLocations do
		if location.getID().trimBlanks() &lt;&gt; _locationId then
			continue;
		else
			break;
		endif;
	endforeach;
	
	if location = null then
		return null;
	endif;

	return location;
	
end;</source>
        <access>protected</access>
        <Parameter name="_locationId" type="String"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
