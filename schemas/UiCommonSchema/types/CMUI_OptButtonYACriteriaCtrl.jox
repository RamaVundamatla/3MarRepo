    <JadeMethod name="click" id="bd85b9c6-a3b9-400a-8793-311ff856dde3">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(optionbutton: OptionButton input) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
20 August 2008	consw1	Initial creation

*/

vars

begin
	inheritMethod(optionbutton);

	self.parent.CMUI_YACriteriaCntl.doCriteriaChanged();

epilog

end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
