    <JadeMethod name="setInvoiceValues" id="077fe634-fa3a-4d32-9ecb-552b7e5bb19a">
        <source>setInvoiceValues(_inv: CM_Invoice input);
// ---------------------------------------------------------------------------
// Created:     30 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(_inv);
	
	_inv.decfinGLPeroid := self.glPeriod;
	_inv.decfinGLYear := self.glYear;

end;</source>
