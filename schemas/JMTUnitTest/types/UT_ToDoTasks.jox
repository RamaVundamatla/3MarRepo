    <JadeMethod name="tVerifyAutoApplyToDoResource" id="e34f784f-e2a7-42c2-a0d6-d19489e3c5f4">
        <source>tVerifyAutoApplyToDoResource();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Dec 2023 navlc30 ChangeRequest 60748: EUP | VAS Mobile App - [53813.070] [BackEnd] Automatic VAS Resources

*/
constants
	CNTR1                      = "TestCntr0001";
	ToDoDesc                   = "UT TO Do Desc1";
	ToShortDesc				   = "UTDesc1";
	ExpectedUsageResourceStr   = "UTRES2, UTRES1";
vars
	 resourceType1,
	 resourceType2					: CM_ResourceType;
	 toDoTaskDesc,toDoTaskDescToDel : CM_ToDoTaskDesc ;
	 ti1      						: CM_TrackedItem;
	 tiSet		  					: CM_TISet;
	 tiTask1 						: CM_ToDoTask;
	 selectedResourceTypes 			: CM_ObjectSet;
	 resourceUsageProxys 			: CM_ResourceTypeUsageSet;
	 proxyResourceTypeUsage 		: CM_ResourceTypeUsage;
	 newTrans               		: CM_Transaction;
	 resourceUsageStr       		: String;
begin
	self.deleteContainer(CNTR1);
	
	//Create resourceType1
	resourceType1 := self.basicCreateCM_ResourceType("UTRES1", null);
	self.assertNotNull(resourceType1);
	
	//Create resourceType2 With Auto apply resource resourceType1
	resourceType2 := self.basicCreateCM_ResourceType("UTRES2", resourceType1);
	self.assertNotNull(resourceType2);
	
	
	foreach toDoTaskDesc in app.myRoot.allToDoTaskDescsByShortDesc do
		if toDoTaskDesc.description = ToDoDesc then
			toDoTaskDescToDel := toDoTaskDesc;
			break;
		endif;
	endforeach;
	if toDoTaskDescToDel &lt;&gt; null then
		self.deleteToDoTaskDescription( toDoTaskDescToDel );
	endif;
	toDoTaskDesc := self.basicCreateCM_ToDoTaskDesc(ToDoDesc, ToShortDesc, null, null, resourceType2);
	
	//Add Container
	ti1 := createContainer(	CNTR1,	//id: String;
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator("APL"),	//_operator: CM_Operator
							false
							);
	self.assertNotNull(ti1);
	
	//Add task to container
	beginTransaction;
	tiTask1 := ti1.addToDoTask( toDoTaskDesc.description.trimBlanks , app.myPassport );
	commitTransaction;
	
	self.assertEqual(ti1.allToDoTasksToDo.first.toDoTaskDescShort,"UTDesc1");
	
	create tiSet transient;
	tiSet.add(ti1);
	
	//Complete task with resourceType2
	create proxyResourceTypeUsage transient;
	create resourceUsageProxys transient;
	proxyResourceTypeUsage.setProxy(	resourceType2,	//_resourceType : CM_ResourceType;
										null,	//_transaction : CM_TITransaction;
										false,	//_noCharge : Boolean;
										5.0,	//_quantity : Decimal;
										"Auto Apply Test",	//_remarks : String;
										CM_InvoiceLine.STATUS_NORMAL,	//_status : Integer;
										null, null,null,null,null);		
	resourceUsageProxys.add(proxyResourceTypeUsage);
	self.completeToDoTask(toDoTaskDesc,tiSet,resourceUsageProxys);	
	self.assertNoTrxErrorsOrWarnings();
	
	
	newTrans := ti1.allTransactions.last;
	self.assertTrueMsg(newTrans &lt;&gt; null, "New transaction should have been created.");
	self.assertTrueMsg(newTrans.CM_TITransaction.myToDoTask = tiTask1, "New transaction should be related to the tiTask1.");
	
	// validate the usage string to see UTRES1 is auto applied on completion of task with Resource UTRES2
	 resourceUsageStr := newTrans.CM_TITransaction.getAllResourceUsageAsString();
	 self.assertTrueMsg(resourceUsageStr = ExpectedUsageResourceStr, "Expected UTRES1 be to Auto applied on completion of task with Resource UTRES2");
	 
epilog
	delete selectedResourceTypes;
	delete proxyResourceTypeUsage;
	delete resourceUsageProxys;
	delete tiSet;
	
	self.deleteContainer(CNTR1);
	
	if toDoTaskDesc &lt;&gt; null then
		toDoTaskDesc.validateForDelete();
		beginTransaction;
		delete toDoTaskDesc;
		commitTransaction;
	endif;
	
	
	if resourceType2 &lt;&gt; null then
		if resourceType2.hasBeenUsed and resourceType2.allUsageContexts.isEmpty then
			beginTransaction;
			resourceType2.setPropertyValue(CM_ResourceType::hasBeenUsed.name, false);
			commitTransaction;
		endif;
		resourceType2.validateForDelete();
		beginTransaction;
		delete resourceType2;
		commitTransaction;
	endif;		
	
	if resourceType1 &lt;&gt; null then
		if resourceType1.hasBeenUsed and resourceType1.allUsageContexts.isEmpty then
			beginTransaction;
			resourceType1.setPropertyValue(CM_ResourceType::hasBeenUsed.name, false);
			commitTransaction;
		endif;
		resourceType1.validateForDelete();
		beginTransaction;
		delete resourceType1;
		commitTransaction;
	endif;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tVerifyTodoTasks" id="02eea9bc-dd5d-4fc4-ad4e-95bbc8bca22b">
        <source>tVerifyTodoTasks();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 January 2023	navds21	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
01 Dec 2023 navlc30 ChangeRequest 60748: EUP | VAS Mobile App - [53813.070] [BackEnd] Automatic VAS Resources

*/

constants
	CNTR1 ="HarryTest111";
	ToDoDesc = "UTMAT1";
vars
	 resourceType : CM_ResourceType;
	 toDoTaskDesc,toDoTaskDescToDel :CM_ToDoTaskDesc ;
	 ti1      : CM_TrackedItem;
	 tiSet		  : CM_TISet;
	 tiTask1 : CM_ToDoTask;
	 selectedResourceTypes : CM_ObjectSet;
	 resourceUsageProxys : CM_ResourceTypeUsageSet;
	 proxyResourceTypeUsage : CM_ResourceTypeUsage;
begin
	self.deleteContainer(CNTR1);
	
	//Add Resourcetype
	self.opts.purge();
	self.opts.addAssoc("IsMandatory",true);
	//resourceType := self.basicCreateCM_ResourceType("UTHLRES");										//01.12.2023 navlc30 #60748
	resourceType := self.basicCreateCM_ResourceType("UTHLRES", null);									//01.12.2023 navlc30 #60748
	self.assertNotNull(resourceType);
	
	foreach toDoTaskDesc in app.myRoot.allToDoTaskDescsByShortDesc do
		if toDoTaskDesc.description = ToDoDesc then
			toDoTaskDescToDel := toDoTaskDesc;
			break;
		endif;
	endforeach;
	if toDoTaskDescToDel &lt;&gt; null then
		self.deleteToDoTaskDescription( toDoTaskDescToDel );
	endif;
	toDoTaskDesc := self.basicCreateCM_ToDoTaskDesc(ToDoDesc, null, null, null, resourceType);
	
	//Add Container
	ti1 := createContainer(	CNTR1,	//id: String;
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator("APL"),	//_operator: CM_Operator
							false
							);
	self.assertNotNull(ti1);
	
	//Add task to container
	beginTransaction;
	tiTask1 := ti1.addToDoTask( toDoTaskDesc.description.trimBlanks , app.myPassport );
	commitTransaction;
	
	self.assertEqual(ti1.allToDoTasksToDo.first.toDoTaskDescShort,"UT_Test");
	
	create tiSet transient;
	tiSet.add(ti1);
	
	//Complete task
	create proxyResourceTypeUsage transient;
	create resourceUsageProxys transient;
	proxyResourceTypeUsage.setProxy(	resourceType,	//_resourceType : CM_ResourceType;
										null,	//_transaction : CM_TITransaction;
										false,	//_noCharge : Boolean;
										5.0,	//_quantity : Decimal;
										"Cheaper shot",	//_remarks : String;
										CM_InvoiceLine.STATUS_NORMAL,	//_status : Integer;
										null, null,null,null,null);		
	resourceUsageProxys.add(proxyResourceTypeUsage);
	self.completeToDoTask(toDoTaskDesc,tiSet,resourceUsageProxys);	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti1.allToDoTasksCompleted.size,1);
	self.assertEqual(ti1.allToDoTasksCompleted.first.toDoTaskDescShort,"UT_Test");
epilog
	delete selectedResourceTypes;
	delete proxyResourceTypeUsage;
	delete resourceUsageProxys;
	delete tiSet;
	
	self.deleteContainer(CNTR1);
	
	if toDoTaskDesc &lt;&gt; null then
		toDoTaskDesc.validateForDelete();
		beginTransaction;
		delete toDoTaskDesc;
		commitTransaction;
	endif;
	
	if resourceType &lt;&gt; null then
		if resourceType.hasBeenUsed and resourceType.allUsageContexts.isEmpty then
			beginTransaction;
			resourceType.setPropertyValue(CM_ResourceType::hasBeenUsed.name, false);
			commitTransaction;
		endif;
		resourceType.validateForDelete();
		beginTransaction;
		delete resourceType;
		commitTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tWashToDoTaskCompleteSet" id="26d3d514-f390-4984-b24e-a2e67bd33872">
        <source>tWashToDoTaskCompleteSet();

/*

Purpose:		Create a container with a wash to do task complete and then re-add wash to do

Date			Who		Reason
13/05/2014		cnwmh5	Initial creation - #31990
23 Jan 2023		navma1	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources

*/
constants

	ContainerId					: String = "UTMHCCC0001";

vars

	container					: CM_Container;
	toDoTaskDesc				: CM_ToDoTaskDesc;
	tiSet						: CM_TISet;
begin

	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["WASH"];
	self.assertNotNull(toDoTaskDesc);
	
	self.deleteContainer(ContainerId);
	container := self.addContainerOpts(ContainerId, "2200", "GENL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString)).CM_Container;
	self.assertNotNull(container);
	
	create tiSet transient;
	tiSet.add(container);
	self.addToDoTask(toDoTaskDesc, tiSet);
	assertEqual(container.allToDoTasksToDo.size, 1);
	self.assertEqual(container.washDT.date, null);
	self.assertEqual(container.isClean, false);
	
	self.completeToDoTask(toDoTaskDesc, tiSet,null);			//23.01.2023 navma1 #54349[54262]
	self.assertEqual(container.allToDoTasksToDo.size, 0);
	self.assertNotEqual(container.washDT, null);
	self.assertEqual(container.isClean, true);
	
	self.addToDoTask(toDoTaskDesc, tiSet);
	assertEqual(container.allToDoTasksToDo.size, 1);
	self.assertEqual(container.washDT.date, null);
	self.assertEqual(container.isClean, false);	

epilog

	delete tiSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="updateToDoTaskDescription" id="396ce10f-e9e1-41f3-8631-758e146198ae">
        <source>updateToDoTaskDescription(_task :CM_ToDoTaskDesc; _shortDesc :String) protected;
/*
Date		Who		Reason
14 November 2011	cnwcs5	Initial creation - par 28574
*/
vars
	proxy	:CM_ToDoTaskDesc;
begin
	beginLoad;
	proxy := _task.pxyCreateUpdateProxy;
	endLoad;
	
	proxy.setPropertyValue (CM_ToDoTaskDesc::shortDescription.name, _shortDesc);
	
	app.myTrxUA.trxUpdateToDoTaskDesc (proxy, app.myPassport);
epilog
	endLoad;													// 19/04/2013 cnwmh5 #31457
	delete proxy;
end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_ToDoTaskDesc"/>
        <Parameter name="_shortDesc" type="String"/>
    </JadeMethod>
</Class>
