    <JadeMethod name="addYACriteria" id="3889d623-1ab7-4dca-b1b3-3ffbb9a16854">
        <source>addYACriteria(criteriaType : Integer; combo : CMUI_ComboBox input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 July 2009	cnwmd1	Initial creation

*/

vars
	criteria : CM_YACriteriaType;
begin
	criteria := app.myRoot.allYACriteriaTypes[criteriaType].CM_YACriteriaType;
	if criteria = null then
		app.raiseCMException1(Follow_criter_type_does_exist, criteriaType.String, null, null);
		return;
	endif;
	combo.addItemObject(criteria.description, criteria);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="criteriaType" type="Integer"/>
        <Parameter name="combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
