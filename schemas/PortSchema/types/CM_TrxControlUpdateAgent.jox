    <JadeMethod name="trxMachineHasAvailableTasks" id="5b5076c5-e204-4830-9871-060f75fd3a8d">
        <updating/>
        <source>trxMachineHasAvailableTasks(_machine : CM_Machine input;
						_passport : CM_Passport input) :Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2017	jlger1	Initial creation 5254

*/

vars
	task : CM_RTQueueTask;
	queue : CM_RadioTelemetryQueue;
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	self.raiseExceptionIfNull(_machine,app.getErrorString(Machine));
	if _passport.hasErrors() then
		return false ;
	endif;
	
	if _machine.hasAllocatedQueueTasks then
		return true;
	endif;
		
	
	beginTransaction;
	

	_machine.myPrimaryQueue.getATaskForMachine(task,_machine,null);
	if task &lt;&gt; null then
		 return true;
	else
		foreach queue in _machine.allQueues discreteLock do
			queue.getATaskForMachine(task, _machine, null);
			if task &lt;&gt; null then
				 return true;
			endif;
		endforeach;
	endif;
			
	return false;
	
epilog
	//needs to abort so overstow tasks are deleted
	abortTransaction;
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
