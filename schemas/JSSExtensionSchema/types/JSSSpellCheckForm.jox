        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optSoundex_click(optionbutton: OptionButton input) updating;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
