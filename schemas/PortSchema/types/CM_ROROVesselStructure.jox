    <JadeMethod name="cloneMySelf" id="b376a026-113f-4428-ac39-4e2c8e7a4a82">
        <source>cloneMySelf(_transient: Boolean): SelfType;
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars
	newVessel:CM_ROROVesselStructure;	
	aDeck, newDeck : CM_DeckVessel;
	//aRamp, newRamp : CM_RORORampExternalVessel;
begin
	
	newVessel := inheritMethod(_transient);
	
	// ### Clone the decks
	foreach aDeck in self.allDecks do
		newDeck := aDeck.cloneMySelf(newVessel, false, false);
	endforeach;
		
	// ### the LaneDefn, LocnDefn and SlotDef are all done in the deck layer clone

	// ### Clone the external ramps
/*	foreach aRamp in self.allRamps discreteLock do
		newRamp := aRamp.cloneMySelf(newVessel);
	endforeach;
	*/

	return newVessel;
	
epilog

end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocIgnoreAttr" id="43391d80-5ff3-4de4-b1bc-5e9e2512c402">
        <source>exportAsXMLDocIgnoreAttr(_property: Property input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 April 2011	cnwer1	Initial creation

*/

vars
	
begin

	//we have 2 collections of the same objects only use the 
	// allDecks collection which is by ordinal
	if _property = CM_ROROVesselStructure::allDecksByCode then
		return true;
	elseif _property = CM_ROROVesselStructure::allROROLaneDefnByCode then
		return true;
	elseif _property = CM_ROROVesselStructure::allROROLocnDefnByCode then
		return true;
	elseif _property = CM_ROROVesselStructure::allROROSlotDefnByDeckCode then
		return true;
	endif;
	
	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="3cb94501-19d8-47e1-b61d-a0fc80fb7ffc">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 April 2011	cnwer1	Initial creation

*/

vars

begin
	//we have 2 collections of the same objects only use the 
	// allDecks collection which is by ordinal
	if _property = CM_ROROVesselStructure::allDecks then
		return ExportAsParent;
	elseif _property = CM_ROROVesselStructure::allROROLaneDefnByOrdinal then
		return NoExport;
	elseif _property = CM_ROROVesselStructure::allROROLocnDefnByOrdinal then
		return NoExport;
	elseif _property = CM_ROROVesselStructure::allROROSlotDefnByDeckOrdinal then
		return NoExport;
	elseif _property = CM_ROROVesselStructure::allRamps then
		return ExportAsParent;
	endif;
	


	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="6b7e3501-e3bf-4c05-80c5-813ecfa83c2a">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	auditText, tmpStr : String;
	ramp  		: CM_RORORampExternalVessel;
begin
	auditText:= inheritMethod();

	
/*	foreach ramp in self.allRamps do
		if tmpStr = null then
			tmpStr := ramp.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; ramp.code;
		endif;	
		
	endforeach;
	
	auditText := auditText &amp; 'Vessel Ramps ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
*/
	return auditText;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocnDefnByCode" id="5eca33ff-9996-4a97-901a-888b6dfc711b">
        <source>getLocnDefnByCode(_code : String) : CM_ROROLocnDefnVessel;
/*
Purpose:			
Date		Who		Reason
20 August 2012	cnwab1	Initial creation
*/

vars
	deck : CM_Deck;
	locn : CM_ROROLocnDefnVessel;
begin

	foreach deck in self.allDecks discreteLock do
		locn := self.allROROLocnDefnByCode[deck, _code].CM_ROROLocnDefnVessel;
		
		if locn &lt;&gt; null then
			return locn;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_ROROLocnDefnVessel"/>
    </JadeMethod>
    <JadeMethod name="getNextSectionCode" id="ed8c1cc8-a72c-4f98-b74b-f75b12e3bf5a">
        <source>getNextSectionCode() : String;
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars
	idx : Integer;
begin
	idx := self.myVessel.myStructuralElements.allSections.size; //cnwrd1 par 31874
	
	idx := idx + 1;
	
	return idx.padLeadingWith("0",2);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSectionByPosition" id="b4dad858-2fdb-4f05-8079-27145f5baf97">
        <source>getSectionByPosition(_pos: Decimal; _variance: Decimal): CM_VesselSection;
/*
Purpose:			
Date		Who		Reason
28 April 2011	cnwab1	Initial creation
*/

vars

begin
	//return self.myVessel.myCellularVesselStructure.getSectionByPosition(_pos, _variance);
	return self.myVessel.myStructuralElements.getSectionByPosition(_pos, _variance); //cnwrd1 par 31874

epilog

end;</source>
        <Parameter name="_pos" type="Decimal"/>
        <Parameter name="_variance" type="Decimal"/>
        <ReturnType type="CM_VesselSection"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="9dfe67e5-73dd-4432-907e-c3631e274463">
        <updating/>
        <source>importFromXMLDocReference(	_property: Property;
							_xmlElement : JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2011	cnwer1	Initial creation

*/

vars
	
	xmlElement,deckElement  : JadeXMLElement;
	allDeckElements : JadeXMLElementArray;
	proxyDeck 		: CM_DeckVessel;
begin
	//we should be transient 
	if _property = CM_ROROVesselStructure::allDecks then
		create allDeckElements transient;
		_xmlElement.getAllElementsByTagName(CM_DeckVessel.name,allDeckElements);
		
		foreach deckElement in  allDeckElements do
			create proxyDeck transient;
			proxyDeck.setMyROROStructure(self);
			proxyDeck.importFromXMLDoc(deckElement);
		endforeach;
	
	endif;

epilog
	delete allDeckElements;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="e1be3959-6dd7-4c31-8a8b-064e296b10f4">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
23 March 2011	cnwer1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	deck, pxyDeck : CM_DeckVessel;
	pxyROROVesselStructure : CM_ROROVesselStructure;
	completedOK		: Boolean;
begin
	pxyROROVesselStructure:= inheritMethod();

	foreach deck in self.allDecks do
		pxyDeck := deck.pxyCreateUpdateProxy();
		pxyDeck.setMyROROStructure(pxyROROVesselStructure);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyROROVesselStructure;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyROROVesselStructure;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8e30fe48-1d05-486c-99a3-6d2a904a1287">
        <updating/>
        <source>setForCreate(_proxyVessel: CM_ROROVesselStructure; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	proxyDeck,realDeck		: CM_DeckVessel;
begin
	inheritMethod(_proxyVessel, _passport);
	
	foreach proxyDeck in _proxyVessel.allDecks discreteLock do
		
		create realDeck persistent;
		realDeck.setMyROROStructure(self);
		realDeck.setForCreateImport(proxyDeck,_passport);	
	
		if _passport.hasErrors then
			break;
		endif;
		
	endforeach;

epilog

end;</source>
        <Parameter name="_proxyVessel" type="CM_ROROVesselStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="88c79e43-57ce-4491-93fd-81223d639be0">
        <updating/>
        <source>setForUpdate(_proxyVessel: CM_ROROVesselStructure; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 March 2011	cnwer1	Initial creation

*/

vars
	
begin
	inheritMethod(_proxyVessel,_passport);
	
	self.type:=CellularStructureRORO;
	self.totalLengthWithRamp:=_proxyVessel.totalLengthWithRamp;



epilog
	
end;</source>
        <Parameter name="_proxyVessel" type="CM_ROROVesselStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyROROVesselStructure" id="7e647002-4a83-4459-88b4-1b4d489d651e">
        <updating/>
        <source>setProxyROROVesselStructure(_totalLengthWithRamp : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 March 2011	cnwer1	Initial creation

*/

vars

begin
	
	self.totalLengthWithRamp:=_totalLengthWithRamp;
epilog

end;</source>
        <Parameter name="_totalLengthWithRamp" type="Integer"/>
    </JadeMethod>
