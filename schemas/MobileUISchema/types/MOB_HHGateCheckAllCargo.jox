        <controlMethod name="ScrollBar::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>scrCargo_change(scroll: ScrollBar input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	self.setMenuScrollStart( scroll, self.btnMenuTemplate, self.frmCargo, self.myMobileGenericAgent.allTruckTis.size );
	
epilog

