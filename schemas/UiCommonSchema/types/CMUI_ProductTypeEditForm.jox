    <JadeMethod name="unload" id="12ef555b-c2b9-4584-8868-43d7fe6dde19">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/* ---------------------------------------------------------------------------
Created:	03 July 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.isCodesEdited then
		self.myForm.setIsCodesEdited();
