    <JadeMethod name="pxyCreateUpdateProxy" id="75b00024-6b98-4e29-ab72-b96f7a5101fb">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	#cnwdz2	 

*/

vars
	pxyField      : CM_DataExtractCollectionField;
	realChildField, 
	pxyChildField    : CM_DataExtractField;
	completedOK	  : Boolean;
	
begin
	pxyField := inheritMethod;
	
	foreach realChildField in self.allChildFields do
		pxyChildField := realChildField.pxyCreateUpdateProxy;
		pxyField.allChildFields.add(pxyChildField);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyField;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyField;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setCommon" id="8a96425b-2782-4b77-b4d7-ee8d9d25cf82">
        <updating/>
        <source>setCommon(_proxyField: CM_DataExtractField) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	#cnwdz2	 

*/

vars
	colField : CM_DataExtractCollectionField;
begin	
	inheritMethod(_proxyField);
	
	colField := _proxyField.CM_DataExtractCollectionField;
	self.initCollectionFieldProperties(colField.childFieldClass, colField.name, colField.niceName);
	self.extractOrder.clear();
	colField.extractOrder.copy(self.extractOrder);	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_proxyField" type="CM_DataExtractField"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="3c5538a2-bb44-4601-8931-4818e1577d7d">
        <updating/>
        <source>setForCreate(_proxyField: CM_DataExtractField) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	#cnwdz2	 

*/

vars
	colField : CM_DataExtractCollectionField;
	child,
    newChild : CM_DataExtractField;
begin
	inheritMethod(_proxyField);
	colField := _proxyField.CM_DataExtractCollectionField;
	
	foreach child in colField.allChildFields do
		newChild := child.createPersistentField();
		self.allChildFields.add(newChild);
	endforeach;
epilog

end;</source>
        <Parameter name="_proxyField" type="CM_DataExtractField"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d725054b-aa31-4ec3-bb5b-4044f9189988">
        <updating/>
        <source>setForUpdate(_proxyField: CM_DataExtractField) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	#cnwdz2	 

*/

vars
	colField : CM_DataExtractCollectionField;
	proxyChildField,
    realChildField : CM_DataExtractField;
	toDelete : CM_DataExtractFieldSet;
	expectedEdition : Integer;  
begin
	inheritMethod(_proxyField);
	colField := _proxyField.CM_DataExtractCollectionField;
	
	create toDelete transient;
	exclusiveLock(self.allChildFields);
	self.allChildFields.copy(toDelete);
	
	// 1. Create new features, update existing ones
	foreach proxyChildField in colField.allChildFields do
		proxyChildField.pxyGetRealObjectAndEdition(realChildField, expectedEdition);
		if realChildField = null then
			realChildField := proxyChildField.createPersistentField();
			self.allChildFields.add(realChildField);
		else
			toDelete.removeIfPresent(realChildField);
			exclusiveLock(realChildField);
			if realChildField.edition &lt;&gt; expectedEdition then
				app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'dataExtractField', null, null);
				return;
			endif;
			realChildField.setForUpdate(proxyChildField);
		endif;

	endforeach;
	
	// 2. Delete missing features
	foreach realChildField in toDelete do
		delete realChildField;
	endforeach;
	
epilog
	delete toDelete;
end;</source>
        <Parameter name="_proxyField" type="CM_DataExtractField"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="e9254516-3dc6-4bd0-8442-4b2054122786">
        <updating/>
        <source>setProxy(_name: String; _field: CM_DataExtractField) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	#cnwdz2	 

*/

vars
	colField : CM_DataExtractCollectionField;
	child,
    newChild : CM_DataExtractField;
	toDelete : CM_DataExtractFieldSet;
begin
	inheritMethod(_name, _field);
	colField := _field.CM_DataExtractCollectionField;
	
	create toDelete transient;
	self.allChildFields.copy(toDelete);
		
	foreach child in colField.allChildFields do
		newChild := self.allChildFields[child.name];
		if newChild = null then		
			newChild := child.createTransientFieldWithName(child.name);
			self.allChildFields.add(newChild);
		else
			toDelete.removeIfPresent(newChild);
			newChild.setProxy(child.name, child);
		endif;
	endforeach;
	
	// 2. Delete missing features
	foreach child in toDelete do
		self.allChildFields.removeIfPresent(child);
	endforeach;
	
epilog
	delete toDelete;

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_field" type="CM_DataExtractField"/>
    </JadeMethod>
</Class>
