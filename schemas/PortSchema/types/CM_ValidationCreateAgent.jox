    <JadeMethod name="valHumidityReading" id="852f7b02-eaf5-4ce3-91ac-ff341b8e6f93">
        <source>valHumidityReading(_humidityParams : CMIF_HumidReading);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars

begin
	if _humidityParams.myTrackedItem = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'tempParams.myContainer', 'myContainer', null);
		return;
	endif;

	if not _humidityParams.dateTime.isValid then
		app.raiseCMException2(ERR_INVALID_VALUE, "date/time", "Make sure the date and time fields are valid.", 'dateTime',null);
		return;
	endif;
	
	if not _humidityParams.dateTime.date &lt;= app.actualTimeServer().date then
		app.raiseCMException2(ERR_INVALID_VALUE, "date", "You cannot add a temperature reading later than today.", 'dateTime',null);
		return;
	endif;

epilog

end;</source>
        <Parameter name="_humidityParams" type="CMIF_HumidReading"/>
    </JadeMethod>
