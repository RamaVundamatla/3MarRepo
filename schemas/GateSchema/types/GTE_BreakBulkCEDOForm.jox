    <JadeMethod name="setFilterDefaults" id="82fc7596-61d3-4c47-bf10-3e6d95ef790d">
        <source>setFilterDefaults() protected;
//----------------------------------------------------------------
//	Created:	06 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	today	: Date;
	tbl		: CM_EntryTable;
	intRow	: Integer;
begin
	today := self.systemToLocalTime(app.actualTimeServer()).Date;	// 18/4/16 cnwmp6 TFS 488 - Multi timezone support
	self.cmbVoyage.listIndex := 1;

	self.txtEndDate.setDate(today);
	self.txtStartDate.setDate(today-28);
	
	tbl	:= self.tblSearchText;
	foreach intRow in tbl.fixedRows+1 to tbl.rows do
		tbl.accessCell(intRow, self.UpdateColumn).text := null;
	endforeach;	


end;</source>
        <access>protected</access>
