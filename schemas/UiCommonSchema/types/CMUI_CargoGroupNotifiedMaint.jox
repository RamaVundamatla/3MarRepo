    <JadeMethod name="populateCargoIdsTbl" id="10cc47a4-e785-4c69-b230-dbec138661d3">
        <source>populateCargoIdsTbl( cg : CM_CargoGroup );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2018	jlgndl1	Initial creation	TFS 39186
13 Aug 2018		NDL		TFS 40116

*/

vars

	cargoId : String;
	obj : Object;
	iter : Iterator;
	heading : String;
	scannedStr : String;
	notScannedStr : String;
	rowIndex : Integer;
	cargoGroupId : String;
	
	allPreAssignedCargoIdsDict : CM_ObjectByStringDict;
	allPreAssignedCargoIds : StringArray;
	assignment : CM_CargoGroupAssignment;

begin

	self.tblCGNid.rows := 1;
	self.tblCGNid.columns := 2;
	self.tblCGNid.fixedRows := 1;
	self.tblCGNid.fixedColumns := 0;
	
	scannedStr := app.getErrorString(Scanned);
	notScannedStr := app.getErrorString(Not_scanned);
	
	heading := app.getErrorString(Cargo_Id_s) &amp; Tab &amp; app.getErrorString(Status);
	
	if cg &lt;&gt; null then
	
		create allPreAssignedCargoIdsDict transient;
		create allPreAssignedCargoIds transient;
		
		cg.getAllPreAssignedCargoIdsDict( allPreAssignedCargoIdsDict );
		if allPreAssignedCargoIdsDict.isEmpty then
			cg.getAllPreAssignedCargoIds( allPreAssignedCargoIds );
		endif;
		
		assignment := cg.getMyCargoGroupAssignment();

		if not allPreAssignedCargoIdsDict.isEmpty then
			heading := app.getErrorString(Preassigned) &amp; " " &amp; app.getErrorString(Cargo_Id_s) &amp; Tab &amp; app.getErrorString(Status);
			iter := allPreAssignedCargoIdsDict.createIterator;
		elseif cg.isTransient and not allPreAssignedCargoIds.isEmpty then
			heading := app.getErrorString(Preassigned) &amp; " " &amp; app.getErrorString(Cargo_Id_s) &amp; Tab &amp; app.getErrorString(Status);
			foreach cargoId in allPreAssignedCargoIds do
				if cargoId &lt;&gt; null then
					self.tblCGNid.addItem( cargoId );
				endif;
			endforeach;
		elseif assignment &lt;&gt; null and not assignment.allCargoIdsDict.isEmpty then
			heading := app.getErrorString(Selectable) &amp; " " &amp; app.getErrorString(Cargo_Id_s) &amp; Tab &amp; app.getErrorString(Status);
			iter := assignment.allCargoIdsDict.createIterator;
		endif;
		
	endif;
	
	self.tblCGNid.setCellText( 1, 1, heading );
		
	if assignment &lt;&gt; null and iter &lt;&gt; null then
		while iter.next( obj ) do
			cargoId := iter.getCurrentKey( 1 ).String;
			if cargoId &lt;&gt; null then
				rowIndex := self.tblCGNid.addItem( cargoId );
				if assignment.tiHasBeenScanned( null, cargoId, cargoGroupId ) then
					self.tblCGNid.setCellText( rowIndex, 2, scannedStr &amp; " - " &amp; cargoGroupId);
				else
					self.tblCGNid.setCellText( rowIndex, 2, notScannedStr );
				endif;
			endif;
		endwhile;
	endif;
	
	self.tblCGNid.colourRows(self.colorRow1, self.colorRow2);

epilog

	delete iter;
	delete allPreAssignedCargoIdsDict;
	delete allPreAssignedCargoIds;

end;</source>
        <Parameter name="cg" type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="populateEditCombos" id="264c11af-ac84-4b64-86de-dfc8564ec246">
        <source>populateEditCombos();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	bolType : CM_CargoBOLType;
	cargoType : CM_CargoType;
	index : Integer;
	operTerm : CM_OperatorTerminal;
	operator : CM_Operator;

begin

	self.cmbCargoType.clear();
	
	self.cmbCargoType.sorted := true;
	
	foreach bolType in self.myTerminal.allCargoBOLTypes do
		if not bolType.isCargoType then
			continue;
		endif;
		if not bolType.isCargoGroup then // must be a cargo group type...
			continue;
		endif;
		cargoType := bolType.CM_CargoType;
		index := self.cmbCargoType.addItem( cargoType.description );
		self.cmbCargoType.itemObject[index] := cargoType;
	endforeach;
	
	self.populateProducts( null );
	
	self.cmbOperator.clear();
	
	self.cmbOperator.sorted := true;
	
	foreach operTerm in self.myTerminal.allOperatorTerminals do
		operator := operTerm.myOperator;
		index := self.cmbOperator.addItem( operator.code );
		self.cmbOperator.itemObject[index] := operator;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateProducts" id="c4c38400-0cf0-4b8f-a0c6-90efce65fc11">
        <source>populateProducts( _cargoType : CM_CargoType );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	prod : CM_Product;
	index : Integer;

begin

	self.cmbSubCargoType.clear();
	if _cargoType = null or _cargoType.allProducts.isEmpty then
		self.cmbSubCargoType.enabled := false;
		
	else
		self.cmbSubCargoType.enabled := true;
		self.cmbSubCargoType.sorted := true;
		
		foreach prod in _cargoType.allProducts do
			index := self.cmbSubCargoType.addItem( prod.description );
			self.cmbSubCargoType.itemObject[index] := prod;
		endforeach;
		
	endif;

epilog

end;
</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="02d1eaf4-8c84-4a2b-8596-9c0986dbaac7">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	entTableDef	: EntTableDef;
	weightType : CM_MeasurementType;

begin

	self.tblCGNInput.visible := true;
	self.tblThumb.visible := false;
	
	self.btnEditTV.enabled := false;
	self.btnDeleteTV.enabled := false;
	
	weightType := app.getDefaultMeasurementForType(Type_Weight);
	
	entTableDef := app.myController.getEntTableDef(ETDef_CGNData);
	self.tblCGNInput.setEntTableDef(entTableDef,null,null);
	self.resetMeasurementRows(self.tblCGNInput);
	self.loadMeasurementTypes(self.tblCGNInput, self.tblCGNInput.myEntTableDef.name, self.tblCGNInput.myEntTableDef.allEntTableRows, true);
	self.setConvertedDisplayValue( self.tblCGNInput, ETRow_MinWeight, 0.0, weightType );
	self.setConvertedDisplayValue( self.tblCGNInput, ETRow_MaxWeight, 0.0, weightType );
	
	//non-maintainable
	self.tblCGNInput.hideRowByName( ETRow_CargoCargoType, false );
	self.tblCGNInput.hideRowByName( ETRow_CargoCargoSubType, false );
	self.tblCGNInput.hideRowByName( ETRow_IsCompleted, false );
	self.tblCGNInput.hideRowByName( ETRow_ScannedCount, false );
	
	if self.myCurrentObject &lt;&gt; null then
		self.populateProducts( self.myCurrentObject.CM_CargoGroup.myCargoType );
	endif;
	self.tblCGNInput.setTableFromObject( self.myCurrentObject, CMUI_CargoGroupNotifiedMaint::setTableFromObjectSpecial.name );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="58830003-1d48-46a7-9883-b54975582189">
        <updating/>
        <source>setControlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	canUpdate : Boolean;

begin

	inheritMethod();
	
	canUpdate := self.tblData.row &gt; self.tblData.fixedRows;
	
	self.btnEditTV.enabled := canUpdate and self.allowUpdate;
	self.btnDeleteTV.enabled := canUpdate and self.allowUpdate;

epilog

end;</source>
