    <JadeMethod name="addToolbarControls" id="64abb050-6fbb-4c85-9eea-474058b51690">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:	10 September 2008 By Graeme Black cnwgb1
// Purpose:	CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCSVExp, CMUI_Toolbar.Control_Alignment_Left); // CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	toolbar.addButton(self.btnCSVImport, CMUI_Toolbar.Control_Alignment_Left); // CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	toolbar := self.frmSearchToolbar;
	toolbar.addButton(self.btnSearchSearch, CMUI_Toolbar.Control_Alignment_Left); // CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	toolbar.addButton(self.btnSearchCancel, CMUI_Toolbar.Control_Alignment_Right); // CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
