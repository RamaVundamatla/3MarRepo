    <JadeMethod name="displayHMSBerthageDetails" id="a8cbc8e9-708a-4855-86a8-8b48ea33d98c">
        <updating/>
        <source>displayHMSBerthageDetails(_vesselDataHarbour : HMS_VesselDataHarbour) updating, protected;
//-----------------------------------------
// Created: August 2005 By: cnwgd1
//-----------------------------------------
vars
	tmpPriority : Integer;
begin

	// Berthage Details
	
	if (not self.shtHMSBerthage.visible) then
		return;
	endif;
	
	if _vesselDataHarbour = null then
		
		self.ckbPilotExempt.value := null;
		self.ckbVisitConfiden.value := null;
		
		self.cmbBerth.listIndex := -1;
		self.cmbBerthPriority.listIndex := 1;
		self.txtNumVisits.text := null;		
		self.txtCrewTieUp.text := null;
		self.txtCrewLetGo.text := null;
		self.txtEstTieUpTime.text := null;
		self.txtTugsArrive.text := null;
		self.txtTugsDepart.text := null;
		self.txtRemarksPilot.text := null;
				
		self.loadBerthPreferences(null);
	
	elseif _vesselDataHarbour &lt;&gt; null then
	
		self.txtNumVisits.text := _vesselDataHarbour.initialVoyageCount.asStringJMT;
		self.txtRemarksPilot.text := _vesselDataHarbour.remarksPilotOnly;
		self.ckbPilotExempt.value := _vesselDataHarbour.isPilotExempt;	
		self.ckbVisitConfiden.value := _vesselDataHarbour.excludeReport;						
		self.loadBerthPreferences(_vesselDataHarbour);

		tmpPriority := _vesselDataHarbour.berthPriority;
		if tmpPriority &gt;= 2 and tmpPriority &lt;= 4
		or tmpPriority &gt;= 6 and tmpPriority &lt;= 9 then
			self.cmbBerthPriority.listIndex := self.cmbBerthPriority.findString(1, tmpPriority.String);
		elseif tmpPriority = 5 then
			self.cmbBerthPriority.listIndex := self.cmbBerthPriority.findString(1, '5 - Medium');	
		elseif tmpPriority = 10 then
			self.cmbBerthPriority.listIndex := self.cmbBerthPriority.findString(1, '10 - Low');			
		else
			self.cmbBerthPriority.listIndex := self.cmbBerthPriority.findString(1, '1 - High');		
		endif;								
		
		self.txtCrewTieUp.text := _vesselDataHarbour.numLCrewTieUp.asStringJMT;
		self.txtCrewLetGo.text := _vesselDataHarbour.numLCrewLetGo.asStringJMT;
		self.txtEstTieUpTime.text := _vesselDataHarbour.estTieUpTime.asStringJMT;
		self.txtTugsArrive.text := _vesselDataHarbour.numTugsIn.asStringJMT;
		self.txtTugsDepart.text := _vesselDataHarbour.numTugsOut.asStringJMT;
		
	endif;				
	
	self.shtHMSBerthage.enabled := true;

end;</source>
        <access>protected</access>
        <Parameter name="_vesselDataHarbour" type="HMS_VesselDataHarbour"/>
    </JadeMethod>
    <JadeMethod name="displayHMSMovementResources" id="ee896a0f-a086-4d4f-98de-3e9088e65109">
        <source>displayHMSMovementResources(_vesselDataHarbour : HMS_VesselDataHarbour)protected;
//-----------------------------------------
// Created: September 2005 By: cnwgd1
//-----------------------------------------
vars
	movementResource : HMS_ResourceTypeForMovement;
	resourceType		: HMS_ResourceType;
	int 				: Integer;
begin
	
	if (not self.shtHMSMoveRes.visible) then
		return;
	endif;
		
	self.txtTugsMArrival.text := null;
	self.txtTugsMShift.text := null;
	self.txtTugsMDepart.text := null;

	self.resetLstResourceTables();

	if _vesselDataHarbour = null then
		return;
	endif;	

	foreach movementResource in _vesselDataHarbour.allMovementResourcesByMovement do	
		if movementResource.movementType = HMSMovementTypeArrival then
			self.txtTugsMArrival.text := movementResource.numTugsForMovement.asStringJMT;
			foreach resourceType in movementResource.allResourceTypes discreteLock do 
				if resourceType.isNotAvailableForEntry then // will need to be added to table as will not be in table collection
					if not self.lstResTypeArriva.findObject(resourceType, int) then // final check not already there
						self.lstResTypeArriva.addItemObject(self.myAssistant.displayEntryHMSResourceType(resourceType), resourceType);
					endif;
				endif;
			endforeach;
			self.lstResTypeArriva.setSelected(movementResource.allResourceTypes);
		elseif movementResource.movementType = HMSMovementTypeShift then
			self.txtTugsMShift.text := movementResource.numTugsForMovement.asStringJMT;
			foreach resourceType in movementResource.allResourceTypes discreteLock do 
				if resourceType.isNotAvailableForEntry then // will need to be added to table as will not be in table collection
					if not self.lstResTypeShift.findObject(resourceType, int) then // final check not already there
						self.lstResTypeShift.addItemObject(self.myAssistant.displayEntryHMSResourceType(resourceType), resourceType);
					endif;
				endif;
			endforeach;
			self.lstResTypeShift.setSelected(movementResource.allResourceTypes);					
		elseif movementResource.movementType = HMSMovementTypeDeparture then
			self.txtTugsMDepart.text := movementResource.numTugsForMovement.asStringJMT;
			foreach resourceType in movementResource.allResourceTypes discreteLock do 
				if resourceType.isNotAvailableForEntry then // will need to be added to table as will not be in table collection
					if not self.lstResTypeDepart.findObject(resourceType, int) then // final check not already there
						self.lstResTypeDepart.addItemObject(self.myAssistant.displayEntryHMSResourceType(resourceType), resourceType);
					endif;
				endif;
			endforeach;
			self.lstResTypeDepart.setSelected(movementResource.allResourceTypes);					
		endif;						
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_vesselDataHarbour" type="HMS_VesselDataHarbour"/>
    </JadeMethod>
    <JadeMethod name="displayHMSVesselData" id="438b3858-1012-4fcc-a259-ea57c3f1a7e2">
        <updating/>
        <source>displayHMSVesselData(_theVessel : CM_Vessel) updating, protected;
//--------------------------------------------------
// Created:	12 March 2004 By: cnwgd1
//--------------------------------------------------
//Also called when a vessel is selected when adding a new vessel
vars
	tmpHarbour : HMS_Harbour;
	tmpVesselData : HMS_VesselData;
	tmpVDH : HMS_VesselDataHarbour;
	
begin
	if (not self.shtHMSHarbour.visible) then
		//Not licenced for HMS
		return;
	endif;
	
	if _theVessel &lt;&gt; null then
		tmpVesselData := _theVessel.myHMSVesselData;
	endif;

	if tmpVesselData = null then
		//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
		// Remarks
		self.txtRemarkGeneral.text		:=	null;
		self.txtRemarksPilot.text		:=	null;
		self.txtPreviousNames.text		:=	null;
		
		// Vessel characteristics
		self.optPropFixed.value			:=	false;
		self.optPropVariable.value		:=	(not self.optPropFixed.value);
		self.ckbBowThrusters.value		:=	false;
		self.ckbSternThruster.value		:=	false;
		self.ckbHasRamps.value			:=	false;
		self.ckbHoldTanks.value			:=	false;
		
		self.ckbCoastalVessel.value		:=	false;
		self.cmbShipType.listIndex		:=	CNEC_NULL_INDEX;
		self.cmbCountryFlag.setObject(null);
		self.ckbCreateHMSData.enabled	:=	true;
		self.ckbCreateHMSData.value		:=	false;
		self.ckbRequiresTow.value		:=	false;	//21 Aug 2018	NDL	TFS 40347
		self.ckbIsTramper.value			:=	false;	//11 Sep 2018	NDL	TFS 40778
		
		
		self.cmbShippingLine.setObject(null);
	
	else
		//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
		self.ckbCoastalVessel.value		:=	tmpVesselData.coastalServiceVessel;
		self.cmbCountryFlag.setObject(app.myRoot.allCountries[tmpVesselData.countryCode]);
		
		// The HMS voyage data has already been created
		self.ckbCreateHMSData.enabled	:=	false;
// PAR 36959		self.ckbCreateHMSData.value		:=	true;
		self.ckbCreateHMSData.value		:=	tmpVesselData.hasHarbourDetails(); // PAR 36959
		
		// Remarks
		self.txtRemarkGeneral.text		:=	tmpVesselData.remarksGeneral;
		self.txtPreviousNames.text		:=	tmpVesselData.remarksPreviousNames;
		
		// Vessel characteristics
		self.optPropFixed.value			:=	tmpVesselData.hasFixedProp;
		self.optPropVariable.value		:=	(not self.optPropFixed.value);
		self.ckbBowThrusters.value		:=	tmpVesselData.hasBowThrust;
		self.ckbSternThruster.value		:=	tmpVesselData.hasSternThrust;
		self.ckbHasRamps.value			:=	tmpVesselData.hasRamp;
		self.ckbHoldTanks.value			:=	tmpVesselData.hasHoldTanks;
		
		self.cmbShipType.listIndex		:=	self.cmbShipType.findObject(tmpVesselData.myVesselType);
		self.cmbShippingLine.setObject(tmpVesselData.myDefaultShippingLine);
		
		self.ckbRequiresTow.value		:=	tmpVesselData.requiresTow;	//21 Aug 2018	NDL	TFS 40347
		self.ckbIsTramper.value			:=	tmpVesselData.isTramper;	//11 Sep 2018	NDL	TFS 40778
		
	endif;
	
	// Dimensions and distances
	self.loadDimensionsTbl(tmpVesselData);

	// Vessel data for selected harbour
	self.displayHMSVesselDataHarbour(tmpVesselData, self.myCurrentHarbour);
	self.setEnableHMSData(self.ckbCreateHMSData.value);
end;</source>
        <access>protected</access>
        <Parameter name="_theVessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="displayHMSVesselDataHarbour" id="03f42eb1-e210-4fd3-b974-9940e55892b5">
        <updating/>
        <source>displayHMSVesselDataHarbour(_vesselData : HMS_VesselData input; _harbour : HMS_Harbour)updating, protected;
//-----------------------------------------
// Created: August 2005 By: cnwgd1
// 03/07/2014   cnwma1		CCMS SFW1328  HMS Not Available For Entry  
//-----------------------------------------
vars
	tmpVDH			: HMS_VesselDataHarbour;
	terminalObj		: CM_Terminal;
	
begin
	//epr TFS 3614 removed some voy commidity stuff while here
	
	// vessel data for selected harbour
	if (not self.shtHMSHarbour.visible)  then
		return;
	endif;
	
	// check for update to last selected harbour
	if self.myCurrentHarbour &lt;&gt; _harbour then
		if self.mode &gt; self.Mode_View then
			self.setPxyVesselDataForHarbour();
		endif;
	endif;

	// set caption and current harbour for new selected harbour
	self.setCaptionsForHarbour(_harbour);

	if self.myCurrentHarbour &lt;&gt; null then
		if self.mode &lt; self.Mode_Add then
			if _vesselData &lt;&gt; null then
				tmpVDH := _vesselData.allVesselDataForHarbour[self.myCurrentHarbour];
			endif;
		else
			// add/update mode get proxy
			tmpVDH := self.getPxyVesselDataHarbour();
		endif;
	endif;
	
	
	if tmpVDH = null then
		self.cmbLineCompany.listIndex	:=	-1;
		self.cmbShippingAgent.setObject(null);
		self.cmbTidalClassAr.listIndex	:=	-1;
		self.cmbTidalClassDpt.listIndex	:=	-1;
		
		self.cmbCatArrive.listIndex		:=	-1;
		self.cmbCatDepart.listIndex		:=	-1;
		
	else
//		self.myAssistant.comboBoxHMSBerth(cmbBerthPref, _harbour, prefBerthObj, true);
		self.cmbShippingAgent.setObject(tmpVDH.myShippingAgent);
		
			
		self.cmbLineCompany.listIndex	:=	self.cmbLineCompany.findObject(tmpVDH.myLineCompany);    				 // CNWMA1 4/7/2014   CCMS SFW 1328
		if self.cmbLineCompany.listIndex = -1 and tmpVDH.myLineCompany &lt;&gt; null then				    				//  CNWMA1 3/7/2014   CCMS SFW 1328
			self.cmbLineCompany.addItemObject(tmpVDH.myLineCompany.description,tmpVDH.myLineCompany);
			self.cmbLineCompany.listIndex := self.cmbLineCompany.findObject(tmpVDH.myLineCompany);
		endif;
		
		self.cmbTidalClassAr.listIndex	:=	self.cmbTidalClassAr.findObject(tmpVDH.myTidalClassArrival);			// CNWMA1 4/7/2014   CCMS SFW 1328
		if self.cmbTidalClassAr.listIndex = -1 and tmpVDH.myTidalClassArrival &lt;&gt; null then							// CNWMA1 3/7/2014   CCMS SFW 1328
			self.cmbTidalClassAr.addItemObject(tmpVDH.myTidalClassArrival.description,tmpVDH.myTidalClassArrival);
			self.cmbTidalClassAr.listIndex := self.cmbTidalClassAr.findObject(tmpVDH.myTidalClassArrival);
		endif;
		
		self.cmbTidalClassDpt.listIndex	:=	self.cmbTidalClassDpt.findObject(tmpVDH.myTidalClassDeparture);			// CNWMA1 4/7/2014   CCMS SFW 1328
		if self.cmbTidalClassDpt.listIndex = -1 and tmpVDH.myTidalClassDeparture &lt;&gt; null then						// CNWMA1 3/7/2014   CCMS SFW 1328
			self.cmbTidalClassDpt.addItemObject(tmpVDH.myTidalClassDeparture.description,tmpVDH.myTidalClassDeparture); 
			self.cmbTidalClassDpt.listIndex := self.cmbTidalClassDpt.findObject(tmpVDH.myTidalClassDeparture);
		endif;
		
		self.cmbCatArrive.listIndex		:=	self.cmbCatArrive.findObject(tmpVDH.myVesselCategoryIn);
		self.cmbCatDepart.listIndex		:=	self.cmbCatDepart.findObject(tmpVDH.myVesselCategoryOut);
	endif;
		
	self.displayHMSBerthageDetails(tmpVDH);
	self.displayHMSMovementResources(tmpVDH);

	// arrival and departure tidal info
	self.loadTidalClassTbl();
end;</source>
        <access>protected</access>
        <Parameter name="_vesselData" type="HMS_VesselData" usage="input"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="displayVesselAlloc" id="a2d7ae71-5370-4854-9a94-148419847edd">
        <source>displayVesselAlloc(_ct : CM_YACriteriaType) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/06/2025	navkc1 JIRA 34963 MTN | Missing Text Filter Box in Vessel Definition Form

*/

vars

begin

	if _ct = null or not _ct.isVoyageAllocationCT() then
		return null;
	else
		return _ct.description;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_ct" type="CM_YACriteriaType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayVesselDetails" id="df5397fc-9936-411e-88b6-a2994a9fdc4b">
        <updating/>
        <source>displayVesselDetails() updating, protected;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
/* Changes

Date		Name	TFS#		Description
============================================================================
06/03/2012	PJS		PAR#  31232 
01/05/2017	cnwdap1	TFS 4214 	SSL Shipping Line not shown if HMS not licensed
04/03/2019	jlgka1	37102		STWR CAMS STANDARD CODECO Add isBarge Flag.
10/09/2019 	JLGNS1	Bug 46446: ADP - RE: JMT Error
============================================================================*/
vars
	tmpVessel	: CM_Vessel;
	tmpStr		: String;
	tmpVesselData : HMS_VesselData;

	
begin
	tmpVessel			:=	self.myCurrentVessel;

	self.allClonedControls.purge();
	newIndex	:=	0;
	self.btnBayDefinition.enabled	:=	false;
	//10 July 2013	NDL	Par 31965
	self.btnRoRoDeckDef.enabled	:=	false;
	self.btnHoldDef.enabled	:=	false;
	self.btnEventAlloc.enabled := true;	//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
	
	self.initVesselAllocSheet();
	//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
	
	if tmpVessel = null then
		// clear data
		self.caption	:=	app.getErrorString(Vessel_Definition); //&lt;-- don't call setCaption as no terminal set for system items

		self.cmbVessel.setObject(null);
		self.cmbAccessType.listIndex	:=	-1;
		
		// 31232
	//	if self.cmbStructureType.listCount &gt; 0 then	
	//		self.cmbStructureType.listIndex	:=	1;
	//
	//	endif;
		
		tblVesselStruct.setValueByName(ETRow_IncludesLOLO,true);	// 31232
		
	
		self.txtVesselCode.text			:=	null;
		self.cmbTrade.setObject(null); //epr 27/4/09 CCMS 105
		self.cmbShippingLine.setObject(null);	
		self.txtVesselName.text			:=	null;
		self.txtVesselCode.text			:=	null;
		self.txtCallSign.text			:=	null;
		self.txtClass.text				:=	null;
		self.txtLloydsNum.text			:=	null;	
		self.txtCraneClearanc.text		:=	null;	
		self.txtRemarksVessel.text		:=	null;
		self.picVesselBitmap.picture	:=	null;
		self.txtNumVisits.text			:=	null;
		self.txtYearOfBuild.text		:=  null; //cnwas3 par 27454
		self.txtClonedVessel.text		:=  null; //epr TFS 3614 10/4/17 
		self.ckbCreateVoyages.value		:=	false;
		self.chkIsBarge.value			:=  false; // jlgka1 TFS 37102
		//self.shtVesselAlloc.enabled		:=  false;		//cnwas3 par 27749
	else
		tmpStr			:=	self.cmbVessel.text.removeTabCrLfs();
		self.caption	:=	(tmpStr &amp; ' ' &amp; app.getErrorString(Vessel_Definition));	

	//	self.cmbStructureType.listIndex	:=	self.cmbStructureType.findString(0, app.vesselStructureTypeEnumToStr(tmpVessel.structureType));
		
		// 31232 - reworked how structure is shown
		tblVesselStruct.setValueByName(ETRow_IncludesLOLO,tmpVessel.structureIncludesLOLO);	// 31232
		tblVesselStruct.setValueByName(ETRow_IncludesRORO,tmpVessel.structureIncludesRORO);	// 31232
		tblVesselStruct.setValueByName(ETRow_IncludesHolds,tmpVessel.structureIncludesHolds);	// 31232		
		
		
		if self.mode = self.Mode_View
		and tmpVessel.myCellularVesselStructure &lt;&gt; null
		then
			self.btnBayDefinition.enabled	:=	true;	
		endif;
		
		//10 July 2013	NDL	Par 31965
		if self.mode = self.Mode_View
		and app.myCurrentUserCan(self.myTerminal, Mod_VesselRORO)
		and tmpVessel.myROROVesselStructure &lt;&gt; null
		then
			self.btnRoRoDeckDef.enabled	:=	true;	
		endif;
		if self.mode = self.Mode_View
		and tmpVessel.myGeneralCargoVesselStructure &lt;&gt; null
		then
			self.btnHoldDef.enabled	:=	true;	
		endif;
		
		// Vessel Type - LOLO or RORO
		self.cmbAccessType.listIndex	:=	self.cmbAccessType.findString(1, app.vesselAccessTypeEnumToStr(tmpVessel.vesselType));
		
		// set operator field
		self.cmbOperatorNew.setObject(tmpVessel.myOperator);

		self.txtVesselCode.text			:=	tmpVessel.code;
		self.txtVesselName.text			:=	tmpVessel.name;
		self.txtCallSign.text			:=	tmpVessel.callSign;
		self.txtClass.text				:=	tmpVessel.classLabel;	
		//epr TFS 42606 17/12/18 don't  default to 0 if blank
		self.txtLloydsNum.text			:=	tmpVessel.lloydsNumber.stripAlpha;	//Bug 46446
		self.txtCraneClearanc.text		:=	tmpVessel.craneClearance.asStringJMT;
		self.txtRemarksVessel.text		:=	tmpVessel.remarks;
		self.picVesselBitmap.picture	:=	tmpVessel.bitmap;
		self.ckbCreateVoyages.value		:=	tmpVessel.canCreateVoyages;
		self.cmbTrade.setObject(tmpVessel.myDefaultTrade); //epr 27/4/09 CCMS 1058
		self.txtYearOfBuild.text		:= 	tmpVessel.yearOfBuild.asStringOrBlank();	//cnwas3 par 27498	
		self.txtClonedVessel.text		:=  tmpVessel.clonedFromVessel;  //epr TFS 3614 10/4/17 
		self.chkIsBarge.value			:=  tmpVessel.isBarge; // jlgka1 TFS 37102
		//self.shtVesselAlloc.enabled		:=  true; //cnwas3 par 27749
	endif;

	self.loadTankTable();
	self.loadSectionsTable();
	self.loadExternalRampTable();
	
	
	
	if  self.shtHMSHarbour.visible then
		// licensed for harbour module, populate harbour tables
		self.displayHMSVesselData(tmpVessel);
	elseif tmpVessel &lt;&gt; null then
		tmpVesselData:= tmpVessel.myHMSVesselData;
		self.loadDimensionsTbl(tmpVesselData);
		if tmpVesselData &lt;&gt; null then	//27 Mar 2018	NDL	TFS 36471
			self.cmbShippingLine.setObject(tmpVesselData.myDefaultShippingLine);		// TFS 4214
		endif;
	endif;		

	self.btnExtractImage.enabled	:=	self.picVesselBitmap.picture &lt;&gt; null;
	
	if tblVesselStruct.getValueByName(ETRow_IncludesLOLO).Boolean or
 	    tblVesselStruct.getValueByName(ETRow_IncludesRORO).Boolean then
				
		self.shtVesselStruct.enabled:=true;
		
	//	self.grpExtRamps.visible:=self.cmbStructureType.text = CellularStructureROROStr ;
		self.grpExtRamps.visible:= tblVesselStruct.getValueByName(ETRow_IncludesRORO).Boolean;
	else
		self.shtVesselStruct.enabled:=false;
	endif;
	
epilog	
	self.setNavigatorHeading(self.caption);
	

	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="154a32ff-66ec-4762-9312-e493293b373e">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
//--------------------------------------------------
// Created:	06 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	userResponse	: Integer;
	
begin
	if self.isFormChanged then
		userResponse	:=	app.msgBox(	app.getErrorString(EditChangedAndClosing),
										self.caption &amp; " Window Closing !",
										MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		
		if userResponse &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;			
	endif;
	
	if self.myCurrentVessel &lt;&gt; null then
		if self.myCurrentVessel.isTransient then
			delete self.myCurrentVessel;
		endif;
	endif;	
		
	self.setToViewMode();				
	self.setMyCurrentVessel(self.cmbVessel.myObject.CM_Vessel);

	self.allProxies.purge();
	self.allProxyVessDataHarbour.purge();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="d27d6b89-60a4-4077-8c31-4d751cc74657">
        <updating/>
        <source>doBaseFormSave() updating, protected;
//--------------------------------------------------
// Created:	20 September 2005 By: cnwgd1
//
// 26 Mar 2013	PJS		PAR #31232
//--------------------------------------------------
vars

begin
	inheritMethod();
	
	// 31232
	//if cmbStructureType.text = GeneralCargoStructureStr
	//and txtHatches.cnEcInteger() = 0 then
	//	app.msgBox(app.getString(Hatches_Required_General_Cargo), app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
	//	return;
	//endif;
	
   	// update ship details

	if self.doSave() then
		if self.mode = self.Mode_Update then
			//self.doBaseFormCancel();
		else

			if self.myCurrentVessel &lt;&gt; null then
				if self.myCurrentVessel.isTransient then
					delete self.myCurrentVessel;
				endif;
			endif;	
				
			self.setToViewMode();				
			self.allProxyVessDataHarbour.purge();
		endif;		
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnEdit" id="3a7e362f-eb9d-402c-9e53-cf0a32c4ca6d">
        <updating/>
        <source>doBtnEdit()updating;
//--------------------------------------------------
// Created:	05 September 2005 By: cnwgd1
//--------------------------------------------------
begin
	if self.myCurrentVessel = null then
		app.msgBox('Cannot perform edit as there is no vessel selected.', 'Error', MsgBox_Stop_Icon  + MsgBox_OK_Only);	
		self.cmbVessel.setFocus();
		return;
	endif;

	self.mode := self.Mode_Update;
	
	self.setControlsForAddEdit();
	self.resetFirstChangeFlag();
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnEventAlloc" id="62cfa33b-d4f9-4302-89ff-49b820462eb0">
        <source>doBtnEventAlloc();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2017	cnwns1	Initial creation
25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
*/

vars
	form : Form;
	
begin
	
	form := app.loadForm(SHP_EventAllocationSystemForm, CMUI_Assistant, false, false, false, self.myTerminal, null);
	if form = null or self.myCurrentVessel = null then
		return;
	endif;	
	form.SHP_EventAllocationSystemForm.setVessel(self.myCurrentVessel);
	form.SHP_EventAllocationSystemForm.cmbVessel.checkCanCreateVoyages := false;

	form.show;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnExportClick" id="f2f563d5-abd9-4eb3-90ab-71206dd1fab5">
        <updating/>
        <source>doBtnExportClick() updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	fileXML : CMDFileSave;  // PAR #17167  11/08/2008 cnwdz2 Exporting a file to the disk should use save as dialogue.
	fileName : String;
begin
	on FileException do app.fileExceptionHandler(exception);

	if self.myCurrentVessel = null then
		return;
	endif;
	create fileXML;
// removed old JTV in 812	fileXML.filter := "JMT Vessel Definition  (*.jtv;*.xml)|*.jtv;*.xml";
	fileXML.filter := "JMT Vessel Definition  (*.xml)|*.xml";
	fileXML.fileName := self.myCurrentVessel.code &amp; ".xml";
	if fileXML.open &lt;&gt; 0 then
		return;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	fileName:=fileXML.fileName;

	app.myTrxUA.trxExportAsXMLDoc(self.myCurrentVessel,fileName,app.myPassport);


epilog

	delete fileXML;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnExtractImage" id="5bfb2eae-0f4c-42ca-bc4e-992e892b88d6">
        <source>doBtnExtractImage();
//----------------------------------------------------------------
// Created:	07 October 2005 By: cnwgd1
// RBarr #11806 4/7/06 - changed from CMDFileOpen to CMDFileSave
//----------------------------------------------------------------
vars
	tmpFileSave : CMDFileSave;
	tmpFile : File;
begin
	
	if self.picVesselBitmap.picture = null then
		return;
	endif;
	
	create tmpFileSave;
	tmpFileSave.filter := "JMT Vessel Definition (*.jpg)";//|(*.bmp)|*.bmp|(*.tif)|*.tif|(*.tga)|*.tga|(*.png)|*.png";
	tmpFileSave.fileName := self.cmbVessel.text &amp; ".jpg";
	
	if tmpFileSave.open = 0 then
		
		app.mousePointer := Window.MousePointer_HourGlass;
		
		create tmpFile;
		tmpFile.fileName := tmpFileSave.fileName;

		// use these if compressed		
		tmpFile.kind := File.Kind_Binary;
		tmpFile.writeBinary(self.picVesselBitmap.picture);

		global.beep;		
	else
		return;
	endif;

epilog
	if tmpFile &lt;&gt; null then
		delete tmpFile;
	endif;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnHoldDef" id="1c6577c0-6e1d-405f-a5da-fea4ad4fcf9f">
        <source>doBtnHoldDef();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

	form : SHP_GCHoldLocationVessDefnForm;

begin

	if self.myCurrentVessel = null or self.myCurrentVessel.myGeneralCargoVesselStructure = null then
		return;
	endif;

	form := app.getForm(SHP_GCHoldLocationVessDefnForm.name).SHP_GCHoldLocationVessDefnForm;
	if form = null then
		form := app.loadForm(SHP_GCHoldLocationVessDefnForm, CMUI_Assistant, false, false, false, self.myTerminal, null).SHP_GCHoldLocationVessDefnForm;
	endif;
	if form &lt;&gt; null then
		form.setMyVessel( self.myCurrentVessel );
		form.setParentForm(self);
		form.showModal;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnImportClick" id="a3d1026f-80d3-4c5f-830b-a0a4bc82ac39">
        <updating/>
        <source>doBtnImportClick() updating, protected;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	pxyObj : CM_Object;
	deletePxy : Boolean;
	fileName : String;
	form : SHP_RORODeckImport;
begin
	 app.mousePointer := Window.MousePointer_HourGlass;
	pxyObj:=app.importVesselDefnXMLCreateProxy(true,
												self.myCurrentVessel &lt;&gt; null and self.myCurrentVessel.myCellularVesselStructure &lt;&gt; null,
												self.myCurrentVessel &lt;&gt; null and self.myCurrentVessel.myROROVesselStructure &lt;&gt; null,
												fileName);
	app.mousePointer := Window.MousePointer_Default;
	if fileName = null then	//14 Jul 2016	NDL	TFS 2236
		return;
	endif;
	if pxyObj = null then
		app.raiseCMException1(Invalid_XML_need_tag,CM_Vessel.name,null,null);
		return;
	endif;
 
	if pxyObj.isKindOf(CM_Vessel) then
	
		self.doImport(pxyObj.CM_Vessel);
	elseif pxyObj.isKindOf(CM_CellularVesselStructure) then
		if self.myCurrentVessel &lt;&gt; null and self.myCurrentVessel.myCellularVesselStructure &lt;&gt; null then
			self.myAssistant.SHP_Assistant.showLOLOBayImport(self.myCurrentVessel.myCellularVesselStructure,pxyObj,fileName);
		else
			deletePxy:=true;
		endif;
	elseif pxyObj.isKindOf(CM_ROROVesselStructure) or
			pxyObj.isKindOf(CM_DeckVessel) then
		if self.myCurrentVessel &lt;&gt; null and self.myCurrentVessel.myROROVesselStructure &lt;&gt; null then
			self.myAssistant.SHP_Assistant.showRORODeckImport(self.myCurrentVessel.myROROVesselStructure,pxyObj,fileName);
		else
			deletePxy:=true;
		endif;
	endif;

epilog
	 app.mousePointer := Window.MousePointer_Default;
	 if deletePxy then
		delete pxyObj;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnNew" id="cab98806-0900-44c0-8786-3788bbdcd003">
        <updating/>
        <source>doBtnNew()updating;
//--------------------------------------------------
// Created:	05 September 2005 By: cnwgd1
//--------------------------------------------------
begin
	self.mode := self.Mode_Add;

	self.cmbVessel.setObject(null);
	self.myCurrentVessel := null;
	self.myCurrentVesselData := null;

	self.displayVesselDetails();
	self.setControlsForAddEdit();
	
	self.btnShippingAgent.enabled	:=	self.cmbShippingAgent.listObject &lt;&gt; null;
	self.btnShippingLine.enabled	:=	self.cmbShippingLine.listObject &lt;&gt; null;
	
	//epr 19 may 2011 par 27587
	//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
	self.fldVessel.topSheet	:=	self.shtVesselDetails;
	
	self.doResizeShtVesselDetails(self.shtVesselDetails);
	self.txtVesselName.setFocus();
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboVessel" id="a48ac3c3-53e3-4025-9e65-adea136b2d1d">
        <source>doBuildComboVessel(_theBox : CMUI_ComboBox input);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aVessel		: CM_Vessel;
	passportObj	: CM_Passport;
	rowPointer	: Integer;
	failedDAC  :CM_DataAccessController;
	
begin
	_theBox.clear();
	rowPointer	:=	_theBox.addItem(null);
	passportObj	:=	app.myPassport;
	
	foreach aVessel in app.myRoot.allVessels do
		if aVessel.canCreateVoyages and aVessel.canUserAccessSelf(null, failedDAC, passportObj) then
			rowPointer	:=	_theBox.addItem(aVessel.code &amp; " - " &amp; aVessel.name);
			_theBox.itemObject[rowPointer]	:=	aVessel;
		endif;
	endforeach;
end;</source>
        <Parameter name="_theBox" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildComboVesselAccessType" id="2b531f7a-9f57-4b21-a508-a930863dc998">
        <source>doBuildComboVesselAccessType();
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.cmbAccessType.clear;
	self.cmbAccessType.addItem(null);
	//self.cmbAccessType.addItem(VESSEL_TYPE_LOLO_DESCR);
	//self.cmbAccessType.addItem(VESSEL_TYPE_RORO_DESCR);
	//12 Mar 2018	NDL	TFS 37444
	self.cmbAccessType.addItem( app.vesselAccessTypeEnumToStr(VESSEL_TYPE_LOLO) );
	self.cmbAccessType.addItem( app.vesselAccessTypeEnumToStr(VESSEL_TYPE_RORO) );

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildCombosHarbour" id="2027cc57-def5-4a0c-8f76-d9c8964cacaf">
        <updating/>
        <source>doBuildCombosHarbour()updating;
//--------------------------------------------------
// Created:	09 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	assistant : CMUI_Assistant;
begin
	if (not self.shtHMSHarbour.visible) then
		// not licensed for HMS
		return;
	endif;
	
	assistant	:=	self.myAssistant;
	
	//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366

	assistant.comboBoxHMSTidalClass(self.cmbTidalClassAr, null);
	assistant.comboBoxHMSTidalClass(self.cmbTidalClassDpt, null);
	assistant.comboBoxHMSLineCompany(self.cmbLineCompany, null);
	assistant.comboBoxHMSVesselCategory(self.cmbCatArrive, null);	
	assistant.comboBoxHMSVesselCategory(self.cmbCatDepart, null);		
	
	assistant.listTableResouceType(self.lstResTypeArriva);
	assistant.listTableResouceType(self.lstResTypeShift);
	assistant.listTableResouceType(self.lstResTypeDepart);

	// Load Berth Booking Priority list
	self.cmbBerthPriority.sorted := false;
	self.cmbBerthPriority.addItemAt('1 - High', 1);
	self.cmbBerthPriority.addItemAt('2', 2);
	self.cmbBerthPriority.addItemAt('3', 3);
	self.cmbBerthPriority.addItemAt('4', 4);
	self.cmbBerthPriority.addItemAt('5 - Medium', 5);
	self.cmbBerthPriority.addItemAt('6', 6);
	self.cmbBerthPriority.addItemAt('7', 7);
	self.cmbBerthPriority.addItemAt('8', 8);
	self.cmbBerthPriority.addItemAt('9', 9);
	self.cmbBerthPriority.addItemAt('10 - Low', 10);

	
	assistant.comboBoxHMSVesselType(self.cmbShipType, null);
	
	
	self.setCaptionsForHarbour(self.cmbHarbourVD.listObject.HMS_Harbour);
	
	if self.aMySavedHarbour &lt;&gt; null then
		assistant.comboBoxHMSHarbour(self.cmbHarbourVD, self.aMySavedHarbour);
	else
		assistant.comboBoxHMSHarbour(self.cmbHarbourVD, app.myRoot.allHarbours.first);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doComboBerthClick" id="28c0a62c-de88-4952-adc5-7a93675cf148">
        <updating/>
        <source>doComboBerthClick() updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 06 July 2006
//
//----------------------------------------------------------------------

//Copied from control click method
vars
	bow : Decimal[12,2];
	tmpCellR : JadeTableCell;
begin

	tmpCellR := self.tblPrefBerth.accessCell(self.tblPrefBerth.row, self.tblPrefBerth.getColumnByRowName(ETRow_MyBerth));
	tmpCellR.text := tmpCellR.cellControl.CMUI_ComboBox.text;
	tmpCellR.itemObject := tmpCellR.cellControl.CMUI_ComboBox.listObject;

	if self.mode &lt;&gt; self.Mode_View then
		if self.lastValidRow &gt; 0 then
			bow := self.tblPrefBerth.accessCell(self.lastValidRow, self.tblPrefBerth.getColumnByRowName(ETRow_DefaultBowMark)).cellControl.TextBox.text.asDecimalJMT();	//01 APR 2010	NDL	Par 23556
			self.setMeterMarks(bow, self.lastValidRow, true);
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doControlEvent" id="28210d34-15fa-448f-be2e-8cc473858008">
        <updating/>
        <source>doControlEvent(_control: Control) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/06/2025	navkc1 JIRA MTN 34963 MTN | Missing Text Filter Box in Vessel Definition Form

*/

vars
	msg 		: CMUI_MultiSelectFilterGroupBox;
	
begin
	
	msg := self.msgVesselAlloc;
	
	if _control.isKindOf(Button) then
		if 	_control = msg.myAddSelectedBtn or
			_control = msg.myRemoveSelectedBtn or
			_control = msg.myAddAllBtn or
			_control = msg.myRemoveAllBtn
			then
			
			self.doRebuildCmbDefColour();
			
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doCopyVessel" id="39f28be3-9f41-4fe1-bf5f-7c366a3d5899">
        <updating/>
        <source>doCopyVessel() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		NOTE this is used to copy the selected vessel
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theReturn : Integer;
	lForm : CMUI_GetData;
begin

	if self.myCurrentVessel = null then
		app.msgBox("Please select a vessel to copy.", "Copy Error", MsgBox_OK_Only);
		return;
	endif;
	
	theReturn := app.msgBox("Do you want to make a copy of " &amp; self.myCurrentVessel.name &amp; "?", "Copy Confirmation", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	if theReturn = MsgBox_Return_Yes then
		create lForm;
		lForm.centreWindow;
		app.mousePointer := MousePointer_Default;
		
		lForm.lblTextCaption := "New Vessel Code";
		lForm.txtData.text := null;
		lForm.txtData.maxLength := 25; // AKB was 5 no PAR
		lForm.txtData.dataType := TextBox.DataType_AlphaNumeric;
		lForm.txtData.case := TextBox.Case_Upper;		
		lForm.myCaller := self;
		lForm.formCaption := "Copy Of " &amp; self.myCurrentVessel.name;
		lForm.type := self.GetData_CopyVessel;
		lForm.show;
	endif;
	
epilog
	mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="068f88d3-0998-4317-97b1-c3747bcde1ec">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	msgStr		: String;
	result		: Integer;
	response	: Integer;
	
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	if self.myCurrentVessel = null then
		return false;
	endif;
	
	msgStr := app.getErrorString2(ConfirmDelete, 'the selected', 'vessel ' &amp; self.myCurrentVessel.name);
	
	if app.msgBox(msgStr, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return false;
	endif;
	
	//epr 19/3/2008 par 16198 - although not directly related to this par, fixed this so if you get warnings you will actually be able to continue and delete if you click ok to the warnings
	while true do
		app.myTrxDA.trxDeleteVessel(self.myCurrentVessel, app.myPassport); 
		if app.myPassport.trxCompletedOK then
			
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;	
	
	self.cmbVessel.setObject(null);
	global.beep();
	
	return true;
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDeleteBerthPref" id="71180a16-2064-4b07-b075-3b77f5b1931c">
        <updating/>
        <source>doDeleteBerthPref() updating;
//--------------------------------------------------
// Created:	23 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	berthPref :	HMS_BerthPreference;
	msgBoxType : Integer;
	msgStr : String;
begin 
	if self.tblPrefBerth.row &lt;= self.tblPrefBerth.fixedRows then
		return;
	endif;

	if self.mode &lt;&gt; self.Mode_Update
	and self.mode &lt;&gt; self.Mode_Add then
		return;
	endif;	
	// get selected berthPref;
	// Movement object associated with first column of the table
	self.tblPrefBerth.column := 1;
	
	msgBoxType := MsgBox_Yes_No+MsgBox_Question_Mark_Icon+MsgBox_Default_Second;
	msgStr := app.getErrorString2(ConfirmDelete, 'the selected', 'berth preference ' &amp; self.tblPrefBerth.accessCell(self.tblPrefBerth.row,1).text);	
	if app.msgBox(msgStr, self.caption, msgBoxType) = MsgBox_Return_Yes then
		// OK Clicked: Proceed with delete
		// delete berthPref from collection (this is automatic with inv references)
		// Delete row from table
		self.tblPrefBerth.deleteRow(self.tblPrefBerth.row);
		// update table
		self.setRowTblPrefBerth;
	endif;	

end;</source>
    </JadeMethod>
    <JadeMethod name="doImport" id="ae323ce3-8082-45dc-bd16-ea1c6f347c43">
        <updating/>
        <source>doImport(aProxyVessel : CM_Vessel) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	
begin



	if aProxyVessel = null then
		return;
	endif;

	self.doBtnNew();
	
	if aProxyVessel.myHMSVesselData &lt;&gt; null then
		self.allProxyVessDataHarbour.purge();
		aProxyVessel.myHMSVesselData.allVesselDataForHarbour.copy(self.allProxyVessDataHarbour);
	endif;
	
	self.setMyCurrentVessel(aProxyVessel);
	
	if aProxyVessel.myOperator = null then
		app.msgBox(app.getErrorString(Enter_A_Vessel_Code), app.getErrorString(Information), MsgBox_OK_Only + MsgBox_Information_Icon);
	else
		app.msgBox(app.getErrorString(SHP_Enter_A_Vessel_Code), app.getErrorString(Information), MsgBox_OK_Only + MsgBox_Information_Icon);		
	endif;
	
	self.fldVessel.topSheet := self.shtVesselDetails;					
	self.doResizeShtVesselDetails(self.shtVesselDetails);
	self.txtVesselCode.setFocus();
epilog

end;</source>
        <Parameter name="aProxyVessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="doInitVesselAllocMsg" id="32f1be62-9837-4d11-a2b4-bf30f020d52a">
        <updating/>
        <source>doInitVesselAllocMsg() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/06/2025	navkc1 JIRA 34963 MTN | Missing Text Filter Box in Vessel Definition Form

*/

vars
	msg 			: CMUI_MultiSelectFilterGroupBox;
	ctForColor,
	ct 				: CM_YACriteriaType;
	idx 			: Integer;
	voyAllocsConfig : CM_VoyageAllocationConfig;
	cmb				: CMUI_ComboBox;
	voyAllocsCT,
	col				: CM_YACritetriaTypeByTypeDict;
	vessel 			: CM_Vessel;
	
begin
	
	vessel := self.myCurrentVessel;
	if vessel &lt;&gt; null and vessel.myVoyageAllocationConfig &lt;&gt; null then
		self.myVoyageAllocConfig := vessel.myVoyageAllocationConfig;
		voyAllocsConfig := self.myVoyageAllocConfig;
	else
		self.myVoyageAllocConfig := null;
	endif;
	
	create voyAllocsCT transient;
	
	// Resize the Multi select groupbox on startup
	self.resizeMsgVesselAllocs();
	cmb := self.cmbDefaultColour;
	cmb.clear();
	self.grpVesselAllocsNew.visible := true;
	
	msg 							:= self.msgVesselAlloc;
	msg.caption 					:= null;
	msg.multiSelect 				:= ListBox.MultiSelect_Extended;
	msg.formDisplayEntryMethodName 	:= "displayVesselAlloc";
	msg.availableHeading 			:= app.getErrorString(Available);
	msg.selectedHeading 			:= app.getErrorString(Selected);
	msg.mySelectedListBox.sorted 	:= false;
	msg.readOnly 					:= self.mode = self.Mode_View;
	msg.myBaseForm 					:= self;
	msg.txtFilterBoxLeft.text		:= null;
	msg.txtFilterBoxRight.text		:= null;
	
	col := app.myRoot.allYACriteriaTypes;
	
	foreach ct in col discreteLock where ct.isVoyageAllocationCT() do
		voyAllocsCT.add(ct);
	endforeach;
	
	// Set available criteria type
	msg.setAvailable(voyAllocsCT, true);
	
	// Set selected criteria type
	if voyAllocsConfig &lt;&gt; null then
		msg.setSelected(voyAllocsConfig.allOpCriteria);
		
		// Populate the color combo
		foreach ct in voyAllocsConfig.allOpCriteria where ct.hasColourOption() do			
			idx := cmb.addItemObject(ct.description, ct);	
		endforeach;
		
		// Get what we have saved and select it in the combo
		ctForColor := voyAllocsConfig.myYACriteriaTypeForColour;
		
		idx := cmb.findObject(ctForColor);
		
		if idx &gt; null then
			cmb.listIndex := idx;
		endif;
		
	endif;
epilog
	delete voyAllocsCT;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryUnload" id="2932a7a9-ebc4-478f-b5a1-b72ff9088c06">
        <updating/>
        <source>doQueryUnload(cancel: Integer io; reason: Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		27 March 2008 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	CANCEL_UNLOAD	: Integer = 1;
	
vars
	userResponse	: Integer;
	
begin
	if (self.mode = self.Mode_Add or self.mode = self.Mode_Update)
	and self.isFormChanged
	then
		if reason = Form.QueryUnload_User 
		or reason = Form.QueryUnload_UnloadMethod
		or reason = Form.QueryUnload_MdiChild
		then
			userResponse	:=	app.msgBox(	app.getErrorString(EditChangedAndClosing),
											self.caption &amp; " Window Closing !",
											MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
			
			if userResponse = MsgBox_Return_No then
				cancel	:=	CANCEL_UNLOAD;	//Do not close form
			endif;			
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doRampAdd" id="2fd42a9c-23fa-4cc8-b7ed-59ae3923d3ef">
        <source>doRampAdd() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if self.myCurrentVessel = null then
		return;
	endif;
	
	if self.myCurrentVessel.myStructuralElements = null then
		return;
	endif;
	
	self.myAssistant.SHP_Assistant.showVesselRampForm(self.myCurrentVessel.myStructuralElements,null,SHP_ParentChildForm.Mode_New);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRampDelete" id="e3d9bd52-ae57-4cd2-a4f0-6e304bfbe056">
        <source>doRampDelete() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	result : Integer;
	deckItem : CM_DeckItem;
begin

	if self.tblExtRamps.accessRow(self.tblExtRamps.row) = null then
		return;
	endif;
	deckItem:=self.tblExtRamps.accessRow(self.tblExtRamps.row).itemObject.CM_DeckItem;

	if deckItem = null then
		return;
	endif;
	if app.msgBox(app.getErrorString2(ConfirmDelete,app.getErrorString(Vessel_external_ramp),deckItem.code.String),app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt;  MsgBox_Return_Yes then
		return;
	endif;

	while true do
	
		app.myTrxDA.trxDeleteRORODeckItem(deckItem,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Vessel_external_ramp), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		
		break;
	endwhile;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRampEdit" id="e1222013-01f7-4d80-9dac-bed49a3e1353">
        <source>doRampEdit() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	ramp : CM_RORORampExternal;
begin
	if self.myCurrentVessel = null then
		return;
	endif;
	
	if self.myCurrentVessel.myStructuralElements = null then
		return;
	endif;
	
	// PAR 27469
	if self.tblExtRamps.row &lt;= self.tblExtRamps.fixedRows then
		return;
	endif;
	
	if self.tblExtRamps.accessRow(self.tblExtRamps.row) = null then
		return;
	endif;
	ramp:=self.tblExtRamps.accessRow(self.tblExtRamps.row).itemObject.CM_RORORampExternal;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.myAssistant.SHP_Assistant.showVesselRampForm(self.myCurrentVessel.myStructuralElements,ramp,SHP_ParentChildForm.Mode_View);
	else
		self.myAssistant.SHP_Assistant.showVesselRampForm(self.myCurrentVessel.myStructuralElements,ramp,SHP_ParentChildForm.Mode_Edit);

	endif;


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRebuildCmbDefColour" id="a972559f-0a7d-4353-83ba-d586df32ff0b">
        <source>doRebuildCmbDefColour();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/06/2025	navkc1 JIRA MTN 34963 MTN | Missing Text Filter Box in Vessel Definition Form

*/

vars
	msg 		: CMUI_MultiSelectFilterGroupBox;
	cmb 		: CMUI_ComboBox;
	myCT,
	ct			: CM_YACriteriaType;
	idx			: Integer;
begin
	msg 	:= self.msgVesselAlloc;
	cmb 	:= self.cmbDefaultColour;
	myCT 	:= cmb.listObject.CM_YACriteriaType;
	
	cmb.clear();
	
	foreach ct in msg.parentCollectionRight as CM_YACriteriaType do
		if ct.hasColourOption() then
			cmb.addItemObject(ct.description, ct);
		endif;
	endforeach;
	
	if myCT &lt;&gt; null then
		idx := cmb.findObject(myCT);
	endif;
	
	if idx &gt; null then
		cmb.listIndex := idx;
	endif;

epilog

end;</source>
    </JadeMethod>
