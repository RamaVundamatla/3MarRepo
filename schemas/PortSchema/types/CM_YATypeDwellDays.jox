    </JadeMethod>
    <JadeMethod name="getObjects" id="5810f056-92ad-4431-bc2f-bafb437d330f">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2015	cnwmc5	Initial creation

*/

vars
	dwellDay		: CM_DwellDayRange;
	
begin
	
	foreach dwellDay in app.myRoot.allDwellDayRanges do
		objects[dwellDay.getYAIdentifier] := dwellDay;
	endforeach;

epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
