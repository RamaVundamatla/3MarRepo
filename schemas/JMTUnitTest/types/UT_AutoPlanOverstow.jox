    <JadeMethod name="unitTestBeforeClass" id="aa80b0ce-fa61-4c9a-ba1b-9779dda2cc23">
        <updating/>
        <source>unitTestBeforeClass() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2010	cnwer1	Initial creation

*/

vars

begin
	inheritMethod();
	beginTransaction;
	self.getTerminal.setAutoPlanUseOverstowRules(true);
	commitTransaction;
	app.mySaveDataObjsToRestore.saveStateData("AutoPlanUseOverstowRules", method, self.currentMethodBeingRun, self, self.getTerminal());		// 12/12/2014 cnwmh5
epilog

end;</source>
        <access>protected</access>
