    <JadeMethod name="setControlsForAddEdit" id="794274cb-55e3-4ced-b162-812eab8307aa">
        <updating/>
        <source>setControlsForAddEdit() updating;

// cnwdvb1 22 April 2003 

vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_PhysicalPrinterName);
		theForm.tblInput1.enableRowByName(ETRow_LogicalPrinterName);
		theForm.tblInput1.enableRowByName(ETRow_PrinterIsPDF);
//		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_PrinterDef);
		// cannot update code		
		theForm.tblInput1.enableRowByName(ETRow_LogicalPrinterName);
		theForm.tblInput1.enableRowByName(ETRow_PhysicalPrinterName);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_PrinterIsPDF);
	endif;
    theForm.tblInput1.cnEcResizeContents;


end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="1ca9e700-252f-4421-8ea8-3fadd052ebdc">
        <updating/>
        <source>setCtrlsForView() updating;

// cnwdvb1 22 April 2003 

vars

	theForm : SOP_TableMaintForm;

begin
	//cnwmc5 - 17 Oct 2013 - PAR 32622
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput1.cnEcResizeContents;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="9eb83d5f-1a3f-40d6-839c-28c2065a1011">
        <source>setupThumbnailDetails();

// cnwdvb1 22 April 2003 
vars

	theForm : SOP_TableMaintForm;

begin

  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_PrinterDefs);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_LogicalPrinterName, false);
	 
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_PrinterDefsMaint);
	theForm.shtTblInput1.visible := true;
	
//	if not app.getMyUser.canDo(app.getMyTerminalDO_NOT_USE, PmPDFBackground) then
//		theForm.tblInput1.hideRowByName(ETRow_PrinterIsPDF, false);
//	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="83bf638f-1cae-45a8-9cb1-94ea3dffdf03">
        <source>showThumbnail(_printerDef : CM_PrinterDef);

// cnwdvb1 22 April 2003 

vars

	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Description,	_printerDef.description);
	theForm.tblInput1.setValueByName(ETRow_LogicalPrinterName,	_printerDef.logicalPrinterName);
	theForm.tblInput1.setValueByName(ETRow_PhysicalPrinterName,	_printerDef.physicalPrinterName);
	theForm.tblInput1.setValueByName(ETRow_PrinterIsPDF, _printerDef.printerIsPDF);
	
	
end;</source>
        <Parameter name="_printerDef" type="CM_PrinterDef"/>
    </JadeMethod>
</Class>
