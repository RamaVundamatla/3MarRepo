    <JadeMethod name="utlCreateOwnershipChange" id="c24892a6-5e25-4c0d-8756-1cd7b457493e">
        <source>utlCreateOwnershipChange(_pxyOwnerShipChange : CM_OwnershipChange input;
					  _realOwnerShipChange : CM_OwnershipChange output;
					  _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2023 navtnr20	TFS CR 58507	Task 58209: Jade - TRX CM_OwnershipChange

*/

vars
	theTerminal: CM_Terminal;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCreateOwnershipChange(_pxyOwnerShipChange);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	
	create _realOwnerShipChange persistent;
	_realOwnerShipChange.setForCreate(_pxyOwnerShipChange);
	
	if _passport.noErrors then
		// only required if the class is audited
		self.myCreateAuditAgent.audCreateGeneric(_realOwnerShipChange);
	endif;
	if _passport.noErrors then
		//navtnr20 4-07-2023 TFS 58229
		 theTerminal := _realOwnerShipChange.myTerminal;
		app.myEventManager.createSingleObjInfoNoteEvt(theTerminal,theTerminal.getTerminalEvent(Event_COOCreate),_realOwnerShipChange);	
	endif;
epilog

end;</source>
        <Parameter name="_pxyOwnerShipChange" type="CM_OwnershipChange" usage="input"/>
        <Parameter name="_realOwnerShipChange" type="CM_OwnershipChange" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
