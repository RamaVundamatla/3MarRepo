    <JadeMethod name="setListValues" id="3b195e8c-de25-4003-93b5-df7aefa9a76f">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryCollectionOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2013	cnwpjs1	Initial creation  PAR # 31327

*/




vars
	selectionValue, idx		: Integer;
	specialLift				: CM_SpecialLift;
	liftDict				: CM_SpecialLiftByCodeDict;
begin
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	liftDict := app.myRoot.allSpecialLifts;
	foreach specialLift in liftDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(specialLift) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; specialLift.code &amp; '   ' &amp; specialLift.description);
		_tbl.accessRow(idx).itemObject := specialLift;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryCollectionOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="c09abe32-7b62-483c-9dcf-5af31f5792cf">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2013	cnwpjs1	Initial creation  PAr # 31327

*/

vars
	str				: String;
	numRows,
	idx				: Integer;
	os				: CM_ObjectSet;
	specialLift		: CM_SpecialLift;
begin

	create os transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			specialLift := _tbl.accessRow(idx).itemObject.CM_SpecialLift;
			os.add(specialLift);
		endif;
	endforeach;
	
	_op.setSearchValue(os);

epilog
	delete os;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="cd9a2e3b-716e-4c65-ac10-01cc1ce4b9d9">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Apr 2013	cnwpjs1	Initial creation  PAR #31327

*/

vars

	lift : CM_SpecialLift;
	str : String;

begin

	if _value &lt;&gt; null then
		if _value.isKindOf(CM_SpecialLift) then	//04 Mar 2015	NDL	Par 35737
			return _value.CM_SpecialLift.code;
			
		//04 Mar 2015	NDL	Par 35737
		elseif _value.isKindOf(CM_SpecialLiftByCodeDict) then
			foreach lift in _value.CM_SpecialLiftByCodeDict do
				if str &lt;&gt; null then
					str := str &amp; ", ";
				endif;
				str := str &amp; lift.code;
			endforeach;
			return str;
		endif;
		
	endif;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="7b1336c4-1b8f-4a2f-9d75-b5d32d402145">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	objSet : ObjectSet;
	object : Object;
	lift : CM_SpecialLift;
	result : String;

begin
	if _value.isKindOf(ObjectSet) then
		objSet := _value.ObjectSet;
		foreach object in objSet do
			lift := object.CM_SpecialLift;
			result := result &amp; lift.code &amp; CNEC_COMMA &amp; Space;
		endforeach;
		result := result[1:result.length-2];
		return result;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
