    <JadeMethod name="translateToSearchValueForWeb" id="3a6f693d-37f2-4ec0-9607-41151991b620">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	int : Integer;
	rtnValue, collStr, str : String;
	strArray : StringArray;
	intArray : IntegerArray;

begin
	if _value.isKindOf(Integer) then
		return app.voltageTypeENumToString(_value.Integer, false);
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			collStr := _value.String;
			create strArray transient;
			create intArray transient;
			collStr.getTokensForDelimiter("|", strArray);
			foreach str in strArray do
				intArray.add(app.voltageTypeStringToENum(str));
			endforeach;
			return intArray;
		endif;
		
		if not _sending then
			return app.voltageTypeStringToENum(_value.String);
		endif;
		
		return _value.String;
		
	elseif _value.isKindOf(IntegerArray) then
		foreach int in _value.IntegerArray do
			rtnValue := rtnValue &amp; app.voltageTypeENumToString(int, false) &amp; CNEC_COMMA &amp; Space;
		endforeach;
		rtnValue := rtnValue[1:rtnValue.length-2];
		return rtnValue;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
