    </JadeMethod>
    <JadeMethod name="setupForm" id="7adfb829-cbf9-4082-b28d-821c55d284f4">
        <updating/>
        <source>setupForm() updating;
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars


begin

	self.btnOk.visible := false;
	self.btnCancel.visible := false;
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;

	inheritMethod();
	
	self.alwaysOnTop(false);
	
	self.setSizes();
	
	self.initTable(self.tblInOptions);
	self.initTable(self.tblOutOptions);
	
	self.doInitControlsForObject();
	self.setTablesFromCurrentDeckOpts();
	self.setCmbOptionValue();

	self.caption := self.caption &amp; " - " &amp; self.myProxyDeckingOptions.getDisplayString(); 

	self.setOutControlsForReverseOfIn();

	self.initCustomFrame();

end;</source>
    </JadeMethod>
    <JadeMethod name="setupLocnCellOrderForArea" id="5a87e144-d46b-4dd2-92d3-3a0fbbdeec31">
        <updating/>
        <source>setupLocnCellOrderForArea(_deckingOptions: CM_YADeckingOptions; _inDecking: Boolean) updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	locnCellArray		: CM_YALocationCellArray;
begin

	self.lstDeckingLocns.clear;
	self.allLocnCellsCustomOrdered.clear;
	self.customDeckingForIn := _inDecking;
	
//	_deckingOptions.getLocationCellArray(true).copy(self.myDeckingInterface.allYALocnCellsInCustom);
//	_deckingOptions.getLocationCellArray(false).copy(self.myDeckingInterface.allYALocnCellsOutCustom);
	
	if _inDecking then
		locnCellArray := self.myProxyDeckingOptions.allYALocationCellsIn;
	else
		locnCellArray := self.myProxyDeckingOptions.allYALocationCellsOut;
	endif;
	
	if locnCellArray = null
	or locnCellArray.isEmpty then
		app.raiseUnexpectedProgramError(class.name, method.name, 'block area has no YA location cells - save as default first or');
		return;
	endif;
	
	self.copyCellsToLocationList(locnCellArray, self.chkShowHeights.value);
	
end;</source>
        <Parameter name="_deckingOptions" type="CM_YADeckingOptions"/>
        <Parameter name="_inDecking" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showCustomList" id="798bc937-b609-4ce6-860a-c621965bfa70">
        <updating/>
        <source>showCustomList(_in: Boolean) updating;
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
begin

	if self.myProxyDeckingOptions = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'no current decking options object');
		return;
	endif;

	self.lblCustomSetting.caption := "Custom Settings ";

	if _in then
		self.lblCustomSetting.caption := self.lblCustomSetting.caption &amp; "- IN";
	else
		self.lblCustomSetting.caption := self.lblCustomSetting.caption &amp; "- OUT";
	endif;
	
	app.mousePointer := MousePointer_HourGlass;

	self.setupLocnCellOrderForArea(self.myProxyDeckingOptions, _in);

	self.setCustomOrderHasChanged(false);
	
	self.disableInOptions(true);
	self.disableOutOptions(true);
	
	self.frmCustomSetting.visible := true;
	self.frmCustomSetting.zOrder(1);
			
epilog
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="_in" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideHeightsForCurrentList" id="a0843f55-29a9-4117-8fa2-692c56a441bd">
        <source>showHideHeightsForCurrentList();
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx			: Integer;
	tmpLocnCell,
	yaLocnCell	: CM_YALocationCell;
begin

	if self.chkShowHeights.value then
		//want to now show heights
		idx := 1;
		while idx &lt;= self.lstDeckingLocns.listCount do
			yaLocnCell := self.lstDeckingLocns.itemObject[idx].CM_YALocationCell;
			if yaLocnCell &lt;&gt; null 
			and yaLocnCell.height = 1 then
				//add this one's friends
				self.lstDeckingLocns.removeItem(idx);
				foreach tmpLocnCell in yaLocnCell.myYardController.allYAYardLocationCells reversed do
					self.lstDeckingLocns.addItemAt(tmpLocnCell.getListDisplayWithHeight, idx);
					self.lstDeckingLocns.itemObject[idx] := tmpLocnCell;
				endforeach;
			endif;
			idx := idx + 1;
		endwhile;
	else
		//want to now hide heights
		idx := 1;
		while idx &lt;= self.lstDeckingLocns.listCount do
			yaLocnCell := self.lstDeckingLocns.itemObject[idx].CM_YALocationCell;
			if yaLocnCell.height = 1 then
				self.lstDeckingLocns.itemText[idx] := yaLocnCell.getListDisplay;
				idx := idx + 1;
			else
				self.lstDeckingLocns.removeItem(idx);
				//don't increment
			endif;
		endwhile;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showLocnCellHeights" id="e671ade8-40db-4c65-bbfe-9702444e8641">
        <updating/>
        <source>showLocnCellHeights() updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	//are you sure?
	if self.chkShowHeights.value = false
	and self.customOrderHasChanged 
	and app.msgBox(app.getErrorString(WarningRemovingHeightEntries) &amp; CrLf &amp; app.getErrorString(AreYouSure), app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		self.chkShowHeights.value := true;
		return;
	endif;

	if self.customOrderHasChanged then
		self.showHideHeightsForCurrentList();
	else
		self.setupLocnCellOrderForArea(self.myProxyDeckingOptions, self.customDeckingForIn);
	endif;
end;</source>
    </JadeMethod>
