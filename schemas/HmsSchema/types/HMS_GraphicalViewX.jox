    <JadeMethod name="resetResourceButtons" id="4a2afa28-5230-4bb2-a63f-ce86d9b79cd2">
        <source>resetResourceButtons() protected;

vars
	int, size : Integer;
	cntrl	  : Control;
begin
	// deselect all resource buttons
	int := 1;
	size:= allResourceIdArray.size;
	while int &lt;= size do
		cntrl := self.btnResource.getControl(allResourceIdArray[int]);
		cntrl.Button.value := true;
		int := int + 1;
	endwhile;	
end;</source>
        <access>protected</access>
    </JadeMethod>
