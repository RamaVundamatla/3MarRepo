    <JadeMethod name="tCargoForecastUpdate" id="bfcfbb86-dfc5-4b6c-aa62-e71c01db8e6a">
        <source>tCargoForecastUpdate();
/*

Purpose:			Tests that a Cargo Forecast can be updated

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
08 April 2022	navpw1	Initial creation TFS: 53132

*/

constants
	Ref						: String		= UT_DSL.TFS53132;
	TrainCode 				: String 		= "UT-T" &amp; Ref;
	WagonCode1 				: String 		= "JX" &amp; Ref;
	WagonClassCode 			: String 		= "JX";
	RailAreaId 				: String 		= "UT" &amp; Ref;
	TOTALQUANTITY 			: Integer 		= 12;
	TOTALWEIGHT				: Decimal[23,6] = 23.345;
	TOTALVOLUME				: Decimal[23,6] = 24.345;
	
	UPDTOTALQUANTITY 		: Integer 		= 15;
	UPDTOTALWEIGHT			: Decimal[23,6] = 26.345;
	UPDTOTALVOLUME			: Decimal[23,6] = 27.345;
	
vars
	train					: CM_Train;
	railArea 				: CM_Rail;
	wagon 					: CM_Wagon;
	wagonClass 				: CM_WagonClass;
	errorMess 				: String;
	railLine 				: CM_RailLine;
	
	pxyCargoForecast,
	realCargoForecast		: CM_CargoForecast;
	cargoType				: CM_CargoType;
	commodity				: CM_Commodity;
	operator				: CM_Operator;
	
	error					: CM_Error;
	cargoTypeCommodityError, 
	imexStatusError,
	totalWeightError		: Boolean;
	mode					: String;
	terminal				: CM_Terminal;
	requiredFields			: String;

begin
	terminal := self.getMyTerminal();
	requiredFields := self.setTerminalConfig(CargoForecastReqdFields, ETRow_Quantity &amp; "," &amp; ETRow_Volume &amp; "," &amp; ETRow_Weight).String;
	
	// ****** DELETE EVERYTHING FROM LAST TEST
	self.deleteRailArea(RailAreaId);
	
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;

	self.deleteTrain(TrainCode, null);
	
	// ****** ADD NEW TRAIN
	train := self.addTrain(TrainCode, null);
	self.assertNotNull(train);
	
	// ****** ADD NEW WAGON CLASS AND WAGON
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4500".Decimal);
	self.opts.addAssoc("MaxPosiHeight", "100".Decimal);
	wagonClass := self.addWagonClass(WagonClassCode);
	
	// ****** ADD NEW RAIL AREA
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNull(railArea);
	railLine := railArea.allRailLines.first;
	
	//ATTACH WAGON TO TRAIN
	wagon := train.createOrUpdateWagon(WagonCode1, 3, railLine, errorMess);
	self.assertNull(errorMess);
	self.assertNotNull(wagon);
	self.assertEqual(railLine.allWagons[3], wagon);

	/*
	**	Setup Test Update - Normal Happy Day Scenario
	*/
	operator 	:= app.myRoot.allOperators["****"];
	self.assertNotNullMsg(operator, "Operator is null");
	
	cargoType 	:= app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CONT");
	self.assertNotNullMsg(cargoType, "Cargo type is null");
	
	commodity 	:= app.myRoot.allCommodities["GENL"];
	self.assertNotNullMsg(commodity, "Commodity is null");
	
	mode 	:= CM_CargoForecast.Mode_Discharge;
	
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, commodity, mode, operator, TOTALQUANTITY, TOTALWEIGHT, TOTALVOLUME, train);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Run Test Update - Normal Happy Day Scenario
	*/
	delete pxyCargoForecast;
	
	pxyCargoForecast := app.createUpdateProxy(realCargoForecast).CM_CargoForecast;
	
	pxyCargoForecast.setProxyForUpdate(cargoType, commodity, mode, operator, UPDTOTALQUANTITY, UPDTOTALWEIGHT, UPDTOTALVOLUME, train);
	
	app.myTrxUA.trxUpdateCargoForecast(pxyCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Update - Normal Happy Day Scenario
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realCargoForecast.myParent &lt;&gt; null, "Cargo Forecast: Parent Object is null");
	self.assertTrueMsg(realCargoForecast.myCargoType &lt;&gt; null, "Cargo Forecast: Cargo Type Object is null");
	self.assertTrueMsg(realCargoForecast.myCommodity &lt;&gt; null, "Cargo Forecast: Commodity Object is null");
	self.assertTrueMsg(realCargoForecast.mode &lt;&gt; null, "Cargo Forecast: Mode is null");
	self.assertTrueMsg(realCargoForecast.myOperator &lt;&gt; null, "Cargo Forecast: Operator Object is null");
	
	self.assertTrueMsg(realCargoForecast.myParent = train, "Cargo Forecast: Parent Object does not match expected parent object");
	self.assertTrueMsg(realCargoForecast.myCargoType = cargoType, "Cargo Forecast: Cargo Type Object does not match expected cargo type");
	self.assertTrueMsg(realCargoForecast.myCommodity = commodity, "Cargo Forecast: Commodity Object does not match expected commodity");
	self.assertTrueMsg(realCargoForecast.mode = mode, "Cargo Forecast: Mode does not match expected mode");
	self.assertTrueMsg(realCargoForecast.myOperator = operator, "Cargo Forecast: Operator Object does not match expected operator");
	
	self.assertTrueMsg(realCargoForecast.totalQuantity = UPDTOTALQUANTITY, "The total quantity on the Cargo Forecast does not match expected value: " &amp; UPDTOTALQUANTITY.asStringJMT());
	self.assertTrueMsg(realCargoForecast.totalWeight = UPDTOTALWEIGHT, "The total weight on the Cargo Forecast does not match expected value: " &amp; UPDTOTALWEIGHT.asStringJMT());
	self.assertTrueMsg(realCargoForecast.totalVolume = UPDTOTALVOLUME, "The total volume on the Cargo Forecast does not match expected value: " &amp; UPDTOTALVOLUME.asStringJMT());
	
	/*
	**	Setup Test Update - Test Mandatory fields not specified gives errors
	*/
	delete pxyCargoForecast;
	
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, commodity, mode, operator, TOTALQUANTITY, TOTALWEIGHT, TOTALVOLUME, train);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Run Test Update - Test Mandatory fields not specified gives errors
	*/
	delete pxyCargoForecast;
	
	pxyCargoForecast := app.createUpdateProxy(realCargoForecast).CM_CargoForecast;
	
	pxyCargoForecast.setProxyForUpdate(null, null, null, null, null, null, null, null);
	
	app.myTrxUA.trxUpdateCargoForecast(pxyCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Update - Test Mandatory fields not specified gives errors
	*/
	if app.myPassport.allErrors.size &lt; 1 then
		self.assertTrueMsg(false, "Expected: This trx should result in an error | Actual: No error exists");
	endif;
	
	foreach error in app.myPassport.allErrors do
		if error.text.cnContains("Cargo Type or Commodity") then
			self.assertTrueMsg(error.errorCode = Input_req_cargo_type_commodity, "Expected Error Code:" &amp; Input_req_cargo_type_commodity.String &amp; " | Actual: " &amp; error.errorCode.String); 					//Check Error Code Matches Expected
			self.assertTrueMsg(error.text.cnContains("Cargo Type or Commodity"), "Expected: error message to contain 'Cargo Type or Commodity' | Actual: " &amp; error.text);	//Check Error Message Contains cargo-type or commodity
			cargoTypeCommodityError := true;
			
		elseif error.text.cnContains("mode") then
			self.assertTrueMsg(error.errorCode = REQUIRED_FIELD, "Expected Error Code:" &amp; REQUIRED_FIELD.String &amp; " | Actual: " &amp; error.errorCode.String); 					//Check Error Code Matches Expected
			self.assertTrueMsg(error.text.cnContains("mode"), "Expected: error message to contain 'mode' | Actual: " &amp; error.text);											//Check Error Message Contains mode
			imexStatusError := true;
			
		endif;
		
	endforeach;
	
	if not cargoTypeCommodityError then
		self.assertTrueMsg(cargoTypeCommodityError, "Expected: error to be raised for required field (Cargo Type or Commodity) | Actual: No Error Raised"); 				//Check Error Code Matches Expected
		
	elseif not imexStatusError then
		self.assertTrueMsg(imexStatusError, "Expected: error to be raised for required field (mode) | Actual: No Error Raised"); 									//Check Error Code Matches Expected
		
	endif;
	
	/*
	**	Setup Test Update - Test Mandatory fields only specified
	*/
	delete pxyCargoForecast;
	
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, commodity, mode, operator, TOTALQUANTITY, TOTALWEIGHT, TOTALVOLUME, train);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Run Test Update - Test Mandatory fields only specified
	*/
	self.setTerminalConfig(CargoForecastReqdFields, ETRow_Volume &amp; "," &amp; ETRow_Weight);
	delete pxyCargoForecast;
	
	pxyCargoForecast := app.createUpdateProxy(realCargoForecast).CM_CargoForecast;
	
	pxyCargoForecast.setProxyForUpdate(cargoType, null, mode, null, null, TOTALWEIGHT, TOTALVOLUME, train);
	
	app.myTrxUA.trxUpdateCargoForecast(pxyCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Update - Test Mandatory fields only specified
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realCargoForecast.myParent &lt;&gt; null, "Cargo Forecast: Parent Object is null");
	self.assertTrueMsg(realCargoForecast.myCargoType &lt;&gt; null, "Cargo Forecast: Cargo Type Object is null");
	self.assertTrueMsg(realCargoForecast.mode &lt;&gt; null, "Cargo Forecast: Mode is null");
	
	self.assertTrueMsg(realCargoForecast.myParent = train, "Cargo Forecast: Parent Object does not match expected parent object");
	self.assertTrueMsg(realCargoForecast.myCargoType = cargoType, "Cargo Forecast: Cargo Type Object does not match expected cargo type");
	self.assertTrueMsg(realCargoForecast.mode = mode, "Cargo Forecast: Mode does not match expected mode");
	
	self.assertTrueMsg(realCargoForecast.totalWeight = TOTALWEIGHT, "The total weight on the Cargo Forecast does not match expected value: " &amp; TOTALWEIGHT.asStringJMT());
	self.assertTrueMsg(realCargoForecast.totalVolume = TOTALVOLUME, "The total volume on the Cargo Forecast does not match expected value: " &amp; TOTALVOLUME.asStringJMT());
	
	/*
	**	Setup Test Create - Test Mandatory fields only specified 2
	*/
	delete pxyCargoForecast;
	
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, commodity, mode, operator, TOTALQUANTITY, TOTALWEIGHT, TOTALVOLUME, train);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Run Test Create - Test Mandatory fields only specified 2
	*/
	delete pxyCargoForecast;
	
	pxyCargoForecast := app.createUpdateProxy(realCargoForecast).CM_CargoForecast;
	
	pxyCargoForecast.setProxyForUpdate(null, commodity, mode, null, null, TOTALWEIGHT, TOTALVOLUME, train);
	
	app.myTrxUA.trxUpdateCargoForecast(pxyCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Create - Test Mandatory fields only specified 2
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realCargoForecast.myParent &lt;&gt; null, "Cargo Forecast: Parent Object is null");
	self.assertTrueMsg(realCargoForecast.myCommodity &lt;&gt; null, "Cargo Forecast: Commodity Object is null");
	self.assertTrueMsg(realCargoForecast.mode &lt;&gt; null, "Cargo Forecast: Mode is null");
	
	self.assertTrueMsg(realCargoForecast.myParent = train, "Cargo Forecast: Parent Object does not match expected parent object");
	self.assertTrueMsg(realCargoForecast.myCommodity = commodity, "Cargo Forecast: Commodity Object does not match expected commodity");
	self.assertTrueMsg(realCargoForecast.mode = mode, "Cargo Forecast: Mode does not match expected mode");
	
	self.assertTrueMsg(realCargoForecast.totalWeight = TOTALWEIGHT, "The total weight on the Cargo Forecast does not match expected value: " &amp; TOTALWEIGHT.asStringJMT());
	self.assertTrueMsg(realCargoForecast.totalVolume = TOTALVOLUME, "The total volume on the Cargo Forecast does not match expected value: " &amp; TOTALVOLUME.asStringJMT());
	
	//finished clean up
	self.deleteRailArea(RailAreaId);	
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;	
	self.deleteTrain(TrainCode,null);
	
epilog
	delete pxyCargoForecast;
	self.setTerminalConfig(CargoForecastReqdFields, requiredFields);
end;</source>
    </JadeMethod>
    <JadeMethod name="tConfirmTrainWagonToRail" id="a1224cbb-9447-43fc-a3d6-b50b4363accc">
        <source>tConfirmTrainWagonToRail();
// cnwrs1
// 
// --------------------------------------------------------------------------------
// Created:		20 April 2010 by cnwdad1
//
// Purpose:		Creates a Rail, Train and Wagons, with some cargo, then confirms
//				the Wagons onto the Rail.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	TRAIN_CODE			: String = "UT-TRAINJ2";
//	WAGON_CODE			: String = "JX_002";
	WAGON_CLASS			: String = "JX";
	WAGON_MASTER_CODE	: String = "UT_WM_J1";
	RAIL_AREA_ID		: String = "UT_JRA2";
	CARGO_ID			: String = "UT000000006";
	STOP_CSI			: Integer = 5;
	DO_AUTO_PLAN		: Boolean = true;
	
vars
	passportObj		: CM_Passport;
	trainObj		: CM_Train;
	railAreaObj		: CM_Rail;
	wagonObj		: CM_Wagon;
	wagonClass		: CM_WagonClass;
	allTrackedItems	: CM_TIByIdDups;
	tiObj			: CM_TrackedItem;
	pxyMasterObj	: CM_WagonMaster;
	wagonMasterObj	: CM_WagonMaster;
	wagMoveControl	: CMIF_WagonMoveController;
	railLineObj		: CM_RailLine;
	allWagons		: CM_WagonArray;
	railReceive : CM_ReceiveRail;
	wle : CM_WorkListEntry;
	
begin
	passportObj	:=	app.myPassport;
	
	// ****** DELETE EVERYTHING FROM LAST TEST.
	
	wagonClass	:=	app.myRoot.allWagonClasses[WAGON_CLASS];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	
	self.deleteTrain(TRAIN_CODE,null);

	wagonMasterObj	:=	self.getRoot.allWagonMasters[WAGON_MASTER_CODE];
	if wagonMasterObj &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMasterObj);
	endif;
	
	self.deleteContainer(CARGO_ID);
	self.deleteRailArea(RAIL_AREA_ID);
	
	// ****** ADD NEW TRAIN
	trainObj	:=	self.addTrain(TRAIN_CODE, null);
	self.assertNotNull(trainObj);
	
	// ****** ADD NEW RAIL AREA
	railAreaObj	:=	self.addRailArea(RAIL_AREA_ID, 4, 5);
	self.assertNotNull(railAreaObj);
	railLineObj	:=	railAreaObj.allRailLinesByIndex[1];
	
	// ****** ADD NEW WAGON CLASS AND WAGON, THEN ATTACH TO TRAIN
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4500".Decimal);
	self.opts.addAssoc("MaxPosiHeight", "250".Decimal);
	wagonClass := self.addWagonClass(WAGON_CLASS);
	/*wagon := self.addWagonInRailArea(WagonCode1, WagonClassCode, railArea, train);
	self.assertNotNull(wagon);*/
	
	// ****** CREATE MASTER FOR SOME REASON
	create allWagons transient;
	create pxyMasterObj transient;
	pxyMasterObj.setProxy(	WAGON_MASTER_CODE,	//_id : String;
							wagonClass,	//_myWagonClass : CM_WagonClass;
							CM_Carrier.firstInstance(),	//_myCarrier : CM_Carrier;
							450,	//_maxCargoHeight	: Decimal; 
							60000,	//_maxCargoWeight	: Decimal;
							15000);	//_tareWeight	: Decimal
	
	pxyMasterObj.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster(pxyMasterObj, wagonMasterObj, passportObj);
	
	// ****** ADD PLACE CONTAINERS ON WAGONS
	
	self.opts.addAssoc( UTTI_State, 0 );
	
	create allTrackedItems transient;
								
	self.opts.addAssoc(UTTI_State,TI_STATE_NOTIFIED ); // Make this a PRENOTE - AKB
	tiObj := self.addContainerOpts(CARGO_ID, "2200", "GENL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.addStopById(tiObj, STOP_CSI);
	allTrackedItems.add(tiObj);
	
	wagonObj	:=	self.addWagonToTrainOption2(trainObj, wagonMasterObj, allTrackedItems, false);
	allWagons.add(wagonObj);
	app.myTrxUA.trxUpdateWagonPosition(railLineObj, wagonObj, 1, passportObj);
	
	// Now set to the Confirm stuff.

	create wagMoveControl transient;
	wagMoveControl.myTargetRailLine	:=	railLineObj;
	wagMoveControl.targetPosition	:=	1;
	allWagons.copy(wagMoveControl.allWagons);
	wagMoveControl.doAutoPlanOfCargo	:=	DO_AUTO_PLAN;
	self.ignoreTrxWarnings(true);
	
	
	app.myTrxUA.trxUpdateWagonConfirmToRail(wagMoveControl, passportObj);
	self.assertTrueMsg(passportObj.trxCompletedOK(), "Train/Wagon confirm to Rail failed.");
	self.checkTIForTxnOfType(tiObj, TRANS_TYPE_REC_RAIL);		// 16/08/2012 cnwmh5

	self.assertTrueMsg(tiObj.getNumOfTransOfType(TRANS_TYPE_REC_RAIL) = 1, "Cargo " &amp; tiObj.id &amp; " should have 1 receive rail transaction " &amp; tiObj.getNumOfTransOfType(TRANS_TYPE_REC_RAIL).String);

	//14 May 2020	TFS 49202
	railReceive := tiObj.getTransReceive.CM_ReceiveRail;
	wle := tiObj.allWorklistEntries.first();
	
	self.assertTrueMsg( railReceive.locationRail = wagonObj.allLocationsControllersArray.first.getFullId, "Receive locationRail s/be '" &amp; wagonObj.allLocationsControllersArray.first.getFullId &amp; "' is '" &amp; railReceive.locationRail &amp; "'");
// code in CM_Wagon::confirmWagonInwards doesnt autoplan until after the receive trx is created.... (in CM_TrackedItem::confirmWagon)
//	self.assertTrueMsg( railReceive.locationYard = wle.locationTarget, "Receive locationYard s/be '" &amp; wle.locationTarget &amp; "' is '" &amp; railReceive.locationYard &amp; "'");	
	self.assertTrueMsg( railReceive.trainCode = TRAIN_CODE, "Receive locationRail s/be '" &amp; TRAIN_CODE &amp; "' is '" &amp; railReceive.trainCode &amp; "'");	
	self.assertTrueMsg( railReceive.wagonCode = WAGON_MASTER_CODE, "Receive locationRail s/be '" &amp; WAGON_MASTER_CODE &amp; "' is '" &amp; railReceive.wagonCode &amp; "'");
	
	//Finished clecn up
	wagonClass	:=	app.myRoot.allWagonClasses[WAGON_CLASS];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	self.deleteTrain(TRAIN_CODE,null);
	wagonMasterObj	:=	self.getRoot.allWagonMasters[WAGON_MASTER_CODE];
	if wagonMasterObj &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMasterObj);
	endif;
	self.deleteContainer(CARGO_ID);
	self.deleteRailArea(RAIL_AREA_ID);
	
epilog

	delete pxyMasterObj;
	delete allWagons;
	delete wagMoveControl;
	delete allTrackedItems;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateBoxcarWagonClass" id="6eacd6b1-a43b-4929-b874-6dfb1cd1e0cc">
        <source>tCreateBoxcarWagonClass();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	wagonClassId : String;
	existingWagonClass : CM_WagonClass;
	wagonClassZX : CM_WagonClass;
	
begin

	// creates and deletes a basic CM_WagonClass object that is the definition of a Box car
	wagonClassId := "ZX";
	self.opts.purge();
	self.opts.addAssoc("WagonType", CM_WagonClass.Wagon_Boxcar);
	self.opts.addAssoc("InternalHeight", 200.Decimal);
	self.opts.addAssoc("InternalLength", 200.Decimal);
	self.opts.addAssoc("InternalWidth", 200.Decimal);
	self.opts.addAssoc("ExternalHeight", 201.Decimal);
	self.opts.addAssoc("ExternalLength", 201.Decimal);
	self.opts.addAssoc("ExternalWidth", 201.Decimal);
	self.opts.addAssoc("Tare", "5443".Decimal);
	self.opts.addAssoc("MaxLoadWeight", "50000".Decimal);
	self.opts.addAssoc("DeckHeight", "100".Decimal);	// should not be used, as its a box car.
	self.opts.addAssoc("MaxPosiWeight", "100".Decimal);	// should not be used, as its a box car.
	self.opts.addAssoc("MaxPosiHeight", "100".Decimal);	// should not be used, as its a box car.
	self.opts.addAssoc("AcceptsGenerator", true);	// should not be used, as its a box car.
	self.opts.addAssoc("DoorsAccessible", true);	// should not be used, as its a box car.
	self.opts.addAssoc("LengthInUnits", 5.Integer);	// should not be used, as its a box car.
	self.opts.addAssoc("Carrier", CM_Carrier.firstInstance);
	self.opts.addAssoc("NotAvailableForEntry",true);
	
	wagonClassZX := addWagonClass(wagonClassId);
	
	self.assertTrueMsg(wagonClassZX &lt;&gt; null, "Wagon Class '" &amp; wagonClassId &amp; "' not created!");
	self.assertTrueMsg(wagonClassZX.code = wagonClassId, "Wagon Class 'code' not populated correctly.");
	self.assertTrueMsg(not wagonClassZX.acceptsGenerator, "Wagon Class 'acceptsGenerator' not populated correctly.");
	self.assertTrueMsg(not wagonClassZX.doorsAccessible, "Wagon Class 'doorsAccessible' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.isNotAvailableForEntry, "Wagon Class 'isNotAvailableForEntry' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.maxLoadWeight = 50000, "Wagon Class 'maxLoadWeight' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.maxNumInStack = 1, "Wagon Class 'maxNumInStack' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.getLenInUnits = 1, "Wagon Class 'lenInUnits' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.deckHeight = 0, "Wagon Class 'deckHeight' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.maxCargoHeight = 0, "Wagon Class 'maxCargoHeight' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.tareWeight = 5443, "Wagon Class 'tareWeight' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.myCarrier = CM_Carrier.firstInstance, "Wagon Class 'myCarrier' not populated correctly.");
	
	self.assertTrueMsg(wagonClassZX.allWagonPositionalRules.isEmpty, "Wagon Positional Rule created for a Boxcar!");
	
	self.assertTrueMsg(wagonClassZX.wagonType = CM_WagonClass.Wagon_Boxcar, "Wagon Class 'wagonType' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.internalHeight = 200, "Wagon Class 'internalHeight' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.internalLength = 200, "Wagon Class 'internalLength' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.internalWidth = 200, "Wagon Class 'internalWidth' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.overallHeight = 201, "Wagon Class 'overallHeight' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.overallLength = 201, "Wagon Class 'overallLength' not populated correctly.");
	self.assertTrueMsg(wagonClassZX.overallWidth = 201, "Wagon Class 'overallWidth' not populated correctly.");
	
	
epilog
	
	self.deleteWagonClassAndWagons(wagonClassZX);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateBoxcarWagonVisit" id="62fec40a-912d-4eb8-ae41-ca484f61a93b">
        <source>tCreateBoxcarWagonVisit();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 March 2013	cnwndl1	Initial creation

*/

constants
	TrainCode : String = "UT-TRAINBX";
	WagonCode1 : String = "ZX666";
	WagonClassCode : String = "ZX";
	RailAreaId : String = "UT_BXRA";
	TIOneID : String = "BARRELL1";
	TITwoID : String = "BARRELL2";
	SealType : String = "UT_WS";
vars
	existingWagonClass : CM_WagonClass;
	wagonClassZX : CM_WagonClass;
	pxyWagonClass : CM_WagonClass;
	decValue : Decimal [16,4];
	length : Integer;
	doorPosArray : IntegerArray;
	loadState : Boolean;
	
	train: CM_Train;
	railArea : CM_Rail;
	wagon : CM_Wagon;
	wagonCont : CM_WagonController;
	operator : CM_Operator;
	
	term : CM_Terminal;
	cargoType : CM_CargoType;
	commodity : CM_Commodity;
	pxyTI : CM_TrackedItem;
	ti1 : CM_TrackedItem;
	railLine : CM_RailLine;
	ti2 : CM_TrackedItem;
	job : CM_Job;
	wagonMaster : CM_WagonMaster;
	receive : CM_Receive;
	cargoTypeID : Integer;
	
	sealType : CM_SealType;
	wagonSealAddTrx : CMEVT_WagonTransaction;
	wagonSealDelTrx : CMEVT_WagonTransaction;
	oldWagonSealTrx : CMEVT_WagonTransaction;
	
	sealCheckWagonDischarge : Integer;
	sealCheckWagonLoad : Integer;
	wagonSealCheckInTrx : CMEVT_WagonTransaction;
	wagonSealCheckOutTrx : CMEVT_WagonTransaction;
	
	description : String;
	
begin

	term := app.myPassport.myTerminal;
	
	sealCheckWagonDischarge := term.sealCheckWagonDischarge;
	sealCheckWagonLoad := term.sealCheckWagonLoad;
	
	cargoTypeID := app.myRoot.getCargoTypeIDFromAbbrev("BARRELS");
	cargoType := app.myRoot.allCargoTypesById.getAtKey(cargoTypeID).CM_CargoType;
	commodity := cargoType.allCommodities.getAtKey("RUM");
	sealType := app.myRoot.allSealTypes.getAtKey(SealType);
	
	self.assertTrueMsg(sealType &lt;&gt; null, "System Admin, Seal Type '" &amp; SealType &amp; "' not found!");
	
	ti1 := term.lookupTrackedItem(TIOneID, cargoType.id, TI_STATE_UNDEFINED, null, false);
	ti2 := term.lookupTrackedItem(TITwoID, cargoType.id, TI_STATE_UNDEFINED, null, false);
	if ti1 &lt;&gt; null and app.isValidObject(ti1) then
		beginTransaction;
		if ti1.jobRailReceive &lt;&gt; null then
			job := ti1.jobRailReceive;
			delete job;
		endif;
		if ti1.jobRailRelease &lt;&gt; null then
			job := ti1.jobRailRelease;
			delete job;
		endif;
		commitTransaction;
		self.deleteTrackedItem(ti1,false);
	endif;
	if ti2 &lt;&gt; null and app.isValidObject(ti2) then
		beginTransaction;
		if ti2.jobRailReceive &lt;&gt; null then
			job := ti2.jobRailReceive;
			delete job;
		endif;
		if ti2.jobRailRelease &lt;&gt; null then
			job := ti2.jobRailRelease;
			delete job;
		endif;
		commitTransaction;
		self.deleteTrackedItem(ti2,false);
	endif;
	wagonMaster := self.getRoot.allWagonMasters[WagonCode1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	existingWagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if existingWagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(existingWagonClass);
	endif;
	self.deleteTrain(TrainCode,null);
	self.deleteRailArea(RailAreaId);

	// creates and deletes a basic CM_WagonClass object that is the definition of a Box car
	self.opts.purge();
	self.opts.addAssoc("WagonType", CM_WagonClass.Wagon_Boxcar);
	self.opts.addAssoc("InternalHeight", "305".Decimal);
	self.opts.addAssoc("InternalLength", "1829".Decimal);
	self.opts.addAssoc("InternalWidth", "244".Decimal);
	self.opts.addAssoc("ExternalHeight", "450".Decimal);
	self.opts.addAssoc("ExternalLength", "2078".Decimal);
	self.opts.addAssoc("ExternalWidth", "259".Decimal);
	self.opts.addAssoc("MaxLoadWeight", "26308".Decimal);
	self.opts.addAssoc("Tare", "5443".Decimal);
	self.opts.addAssoc("SealType", SealType);
	wagonClassZX := addWagonClass(WagonClassCode);
	
	self.assertTrueMsg(wagonClassZX &lt;&gt; null, "Wagon Class '" &amp; WagonClassCode &amp; "' not created!");
	
	//validation checks
	//internal versus external dimensions...
	pxyWagonClass := app.createUpdateProxy(wagonClassZX).CM_WagonClass;
	pxyWagonClass.setPropertyValue("internalLength","2079".Decimal);
	
	app.myTrxUA.trxUpdateWagonClass(pxyWagonClass, app.myPassport);
	self.assertTrueMsg( not app.myPassport.trxCompletedOK(), "Internal length dimension exceeds external length dimension, but no error generated");
	
	pxyWagonClass.setPropertyValue("internalLength","1829".Decimal);
	pxyWagonClass.setPropertyValue("internalHeight","451".Decimal);
	
	app.myTrxUA.trxUpdateWagonClass(pxyWagonClass, app.myPassport);
	self.assertTrueMsg( not app.myPassport.trxCompletedOK(), "Internal height dimension exceeds external height dimension, but no error generated");
	
	pxyWagonClass.setPropertyValue("internalHeight","305".Decimal);
	pxyWagonClass.setPropertyValue("internalWidth","260".Decimal);
	
	app.myTrxUA.trxUpdateWagonClass(pxyWagonClass, app.myPassport);
	self.assertTrueMsg( not app.myPassport.trxCompletedOK(), "Internal width dimension exceeds external width dimension, but no error generated");
	
	delete pxyWagonClass;
	
	
	
	//check the special box car calls.
	decValue := wagonClassZX.getBoxCarMaxVolume();
	self.assertTrueMsg(decValue = 136.1142, "Volume in cubic metres s/be 136.1142");
	create doorPosArray transient;
	wagonClassZX.getBoxcarLengthAndDoorPosition(length,doorPosArray);
	self.assertTrueMsg(length = 6, "length in units s/be 6");
	self.assertTrueMsg(doorPosArray.includes(3), "Position 3 not marked as a door");
	self.assertTrueMsg(doorPosArray.includes(4), "Position 4 not marked as a door");
	self.assertTrueMsg(wagonClassZX.getDisplayStringForAttribute(ETRow_OverallHeight,false) &lt;&gt; null, "getDisplayStringForAttribute not returning value for " &amp; ETRow_OverallHeight);
	self.assertTrueMsg(wagonClassZX.getDisplayStringForAttribute(ETRow_OverallLength,false) &lt;&gt; null, "getDisplayStringForAttribute not returning value for " &amp; ETRow_OverallLength);
	self.assertTrueMsg(wagonClassZX.getDisplayStringForAttribute(ETRow_OverallWidth,false) &lt;&gt; null, "getDisplayStringForAttribute not returning value for " &amp; ETRow_OverallWidth);
	self.assertTrueMsg(wagonClassZX.getDisplayStringForAttribute(ETRow_InternalHeight,false) &lt;&gt; null, "getDisplayStringForAttribute not returning value for " &amp; ETRow_InternalHeight);
	self.assertTrueMsg(wagonClassZX.getDisplayStringForAttribute(ETRow_InternalLength,false) &lt;&gt; null, "getDisplayStringForAttribute not returning value for " &amp; ETRow_InternalLength);
	self.assertTrueMsg(wagonClassZX.getDisplayStringForAttribute(ETRow_InternalWidth,false) &lt;&gt; null, "getDisplayStringForAttribute not returning value for " &amp; ETRow_InternalWidth);
	decValue := wagonClassZX.getMaxBoxcarInternalDimension;
	self.assertTrueMsg(decValue = 1829, "Longest dimension s/be 1829");
	self.assertTrueMsg(CM_BoxcarVisit = wagonClassZX.getWagonVisitClassToCreate, "Wrong Visit class returned. S/Be " &amp; CM_BoxcarVisit.name);
	self.assertTrueMsg(wagonClassZX.isBoxcar, "Wagon class set as a 'Boxcar', but 'isBoxcar' returns false");
	self.assertTrueMsg(wagonClassZX.isFlatcar = false, "Wagon class set as a 'Boxcar', but 'isFlatcar' returns true");
	self.assertTrueMsg(not wagonClassZX.allSelectedSealTypes.isEmpty, "Wagon class has no seal types set up");
	self.assertTrueMsg(wagonClassZX.allSelectedSealTypes.includes(sealType), "Wagon class has wrong seal type set up");
	
	
	//create a wagon using the class
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);						
	
	// ****** ADD NEW TRAIN
	train := self.addTrain(TrainCode,null);
	self.assertNotNull(train);
	
	// ****** ADD NEW RAIL AREA
	railArea := self.addRailArea(RailAreaId, 4, 10);
	self.assertNotNull(railArea);
	
	
	// ****** ADD NEW WAGON CLASS AND WAGON, THEN ATTACH TO TRAIN
	wagon := self.addWagonInRailArea(WagonCode1, WagonClassCode, railArea, train);
	self.assertNotNull(wagon);
	self.assertTrueMsg(wagon.isBoxcar, "Wagon Visit created as a 'Boxcar', but 'isBoxcar' returns false");
	self.assertTrueMsg(wagon.isBoxcarVisit, "Wagon Visit created as a 'Boxcar', but 'isBoxcarVisit' returns false");
	self.assertTrueMsg(wagon.getLocationContClassToCreate = CM_BoxcarWagonController, "Wrong Wagon Controller class returned. S/Be " &amp; CM_BoxcarWagonController.name);
	self.assertTrueMsg(wagon.allLocationsControllersArray.size = 1, "Wagon Visit created as a 'Boxcar', should have one locations controller, but doesn't.");
	wagonCont := wagon.allLocationsControllersArray[1];
	self.assertTrueMsg(wagonCont.isBoxcarCont, "Locations controller of Wagon Visit created as a 'Boxcar', return s false to 'isBoxcarCont()'.");
	
	wagonSealAddTrx := wagon.getLastTransactionOfType(EVT_WagonSealAdd);
	self.assertTrueMsg( wagonSealAddTrx = null, "Should not be any 'Wagon Seal Add' Event Transactions until seals are created!");
	wagonSealDelTrx := wagon.getLastTransactionOfType(EVT_WagonSealDelete);
	self.assertTrueMsg( wagonSealDelTrx = null, "Should not be any 'Wagon Seal Delete' Event Transactions until seals are updated or deleted!");
	
	//Add a seal to the wagon
	self.addOrUpdateWagonSeal( wagon, sealType, "seal42,seal44" );
	self.assertTrueMsg( not wagon.allWagonSeals.isEmpty, "Wagon Visit should have " &amp; sealType.sealType &amp; " seals");
	self.assertTrueMsg( wagon.allWagonSeals.first.allSealNums.size = 2, "Wagon Visit " &amp; sealType.sealType &amp; " seal should have 2 values");
	
	//check that a sealed transaction has been created
	wagonSealAddTrx := wagon.getLastTransactionOfType(EVT_WagonSealAdd);
	self.assertTrueMsg( wagonSealAddTrx &lt;&gt; null, "Event Transaction for 'Wagon Seal Add' not found!");
	wagonSealDelTrx := wagon.getLastTransactionOfType(EVT_WagonSealDelete);
	self.assertTrueMsg( wagonSealDelTrx = null, "Should not be any 'Wagon Seal Delete' Event Transactions yet, nothing deleted!");
	self.assertTrueMsg( wagonSealAddTrx.extraDescription.pos("seal42",1) &gt; 1, "Should have found seal number [seal42] in the 'extraDescription' of Add" );
	self.assertTrueMsg( wagonSealAddTrx.extraDescription.pos("seal44",1) &gt; 1, "Should have found seal number [seal44] in the 'extraDescription' of Add" );
	
	//OK we now have a train offsite with an empty wagon on board.
	//Add a pre-noted barrell of rum.
	
	pxyTI := app.myPassport.myTerminal.createTI(cargoType, true);
	pxyTI.setPxyFromDefaultTI( app.myPassport.myTerminal, cargoType.id, TIOneID, null, null );
	pxyTI.zSetPxyImexStatus( TI_IMEX_STATUS_EXPORT );
	pxyTI.setCommodity( commodity.code );
	pxyTI.zSetPxyDestinationPort( "NZAKL" );
	pxyTI.zSetPxyDischargePort( "NZAKL" );
	pxyTI.zSetPxyOperator( operator );
	pxyTI.zSetPxyVoyage( term.getNullVoyage, null );
	pxyTI.setReceiptTransportMode( TI_TRANSMODE_RAIL );
	//pxyTI.setWagon( wagon.id, wagon );
	//pxyTI.setWagon( wagon.id, wagon, wagon.myWagonClass );	//12 May 2014	NDL	Par 33615
	pxyTI.setWagon( wagon.id, wagon, wagon.myWagonClass, false );	//12 Jan 2018 MPD TFS 36406
	
	app.myTrxCA.trxCreateTrackedItem( pxyTI, ti1, app.myPassport );
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Errors creating pre-note barrell&gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	self.moveTiToWagon(ti1, wagonCont);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Errors in move Ti to Wagon&gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	// pre-note barrell should now be on wagon
	
	railLine := railArea.allRailLinesByIndex.first;
	railLine.switchPositions(wagon, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Wagon set rail position Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);  //in
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	
	//30 Jul 2015	NDL	Par 36658
	//Check that Wagon Seal Checks produce transactions - Set terminal seal config value for inward to "View" mode and outward to "Full" mode
	beginTransaction;
	term.setPropertyValue( "sealCheckWagonDischarge", SEAL_CHECK_VIEW );
	term.setPropertyValue( "sealCheckWagonLoad", SEAL_CHECK_FULL );
	commitTransaction;
	self.performSealChecks( wagon, WAGON_CHECK_CONTEXT_PLACE_IN );
	wagonSealCheckInTrx := wagon.getLastTransactionOfType(EVT_WagonSealCheck);
	self.assertTrueMsg( wagonSealCheckInTrx &lt;&gt; null, "Event Transaction for 'Wagon Seal Check' (placement in) not found at all!");
	description := wagonSealCheckInTrx.getDescription;
	self.assertTrueMsg( description.pos("View",1) &gt; 0, "Event Transaction for 'Wagon Seal Check' (placement in) NOT view mode!");
	self.assertTrueMsg( description.pos("'seal42, seal44'",1) &gt; 0, "Event Transaction for 'Wagon Seal Check' (placement in) NOT recording seal value(s)!");
	self.assertTrueMsg( description.pos("'Not Viewed'",1) &gt; 0, "Event Transaction for 'Wagon Seal Check' (placement in) NOT recording 'viewed' value!");
	
	//OK now the train is onsite with one barrell on board.
	//Create a second barrell of rum on the fly.
	pxyTI := app.myPassport.myTerminal.createTI(cargoType, true);
	pxyTI.setPxyFromDefaultTI( app.myPassport.myTerminal, cargoType.id, TITwoID, null, null );
	pxyTI.zSetPxyImexStatus( TI_IMEX_STATUS_EXPORT );
	pxyTI.setCommodity( commodity.code );
	pxyTI.zSetPxyDestinationPort( "NZAKL" );
	pxyTI.zSetPxyDischargePort( "NZAKL" );
	pxyTI.zSetPxyOperator( operator );
	pxyTI.zSetPxyVoyage( term.getNullVoyage, null );
	pxyTI.setReceiptTransportMode( TI_TRANSMODE_RAIL );
	//pxyTI.setWagon( wagon.id, wagon );
	//pxyTI.setWagon( wagon.id, wagon, wagon.myWagonClass );	//12 May 2014	NDL	Par 33615
	pxyTI.setWagon( wagon.id, wagon, wagon.myWagonClass, false );	//12 Jan 2018 MPD TFS 36406
	
	app.myTrxCA.trxReceiveExtraCargoFromBoxcar(pxyTI, ti2, wagon.CM_BoxcarVisit, null, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Add cargo on the fly Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertTrueMsg(wagonCont.allTrackedItems.size = 2, "Cargo on the fly, not on the wagon.");
	receive := ti1.getTransReceiveFirst();
	self.assertTrueMsg(receive &lt;&gt; null, "Receive trx not created for TI1");
	receive := ti2.getTransReceiveFirst();
	self.assertTrueMsg(receive &lt;&gt; null, "Receive trx not created for TI2");
	
	self.assertTrueMsg( not wagon.allWagonSeals.isEmpty, "Wagon Visit should still have " &amp; sealType.sealType &amp; " seals");
	self.assertTrueMsg( wagon.allWagonSeals.first.allSealNums.size = 2, "Wagon Visit " &amp; sealType.sealType &amp; " seal should still have 2 values");
	
	//update seals
	self.addOrUpdateWagonSeal( wagon, sealType, "seal46" );
	
	//check that a sealed transaction has been created
	oldWagonSealTrx := wagonSealAddTrx;
	wagonSealAddTrx := wagon.getLastTransactionOfType(EVT_WagonSealAdd);
	self.assertTrueMsg( wagonSealAddTrx &lt;&gt; null, "Event Transaction for 'Wagon Seal Add' (during update) not found at all!");
	self.assertTrueMsg( wagonSealAddTrx &lt;&gt; oldWagonSealTrx, "Latest Event Transaction for 'Wagon Seal Add' (during update) not found!");
	self.assertTrueMsg( wagonSealAddTrx.extraDescription.pos("seal46",1) &gt; 1, "Should have found seal number [seal46] in the 'extraDescription' of Add" );
	
	wagonSealDelTrx := wagon.getLastTransactionOfType(EVT_WagonSealDelete);
	self.assertTrueMsg( wagonSealDelTrx &lt;&gt; null, "Event Transaction for 'Wagon Seal Delete' (during update to new value) not found!");
	self.assertTrueMsg( wagonSealDelTrx.extraDescription.pos("seal42",1) &gt; 1, "Should have found seal number [seal42] in the 'extraDescription' of Del" );
	self.assertTrueMsg( wagonSealDelTrx.extraDescription.pos("seal44",1) &gt; 1, "Should have found seal number [seal44] in the 'extraDescription' of Del" );
	
	//30 Jul 2015	NDL	Par 36658
	self.performSealChecks( wagon, WAGON_CHECK_CONTEXT_PLACE_OUT );
	wagonSealCheckOutTrx := wagon.getLastTransactionOfType(EVT_WagonSealCheck);
	self.assertTrueMsg( wagonSealCheckOutTrx &lt;&gt; null, "Event Transaction for 'Wagon Seal Check' (placement out) not found at all!");
	self.assertTrueMsg( wagonSealCheckInTrx &lt;&gt; wagonSealCheckOutTrx, "Event Transaction for 'Wagon Seal Check' placement 'in' same as placement 'out'! - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	description := wagonSealCheckOutTrx.getDescription;
	self.assertTrueMsg( description.pos("Full",1) &gt; 0, "Event Transaction for 'Wagon Seal Check' (placement out) NOT full mode!");
	self.assertTrueMsg( description.pos("'seal46'",1) &gt; 0, "Event Transaction for 'Wagon Seal Check' (placement out) NOT recording before value!");
	self.assertTrueMsg( description.pos("'seal46a'",1) &gt; 0, "Event Transaction for 'Wagon Seal Check' (placement out) NOT recording after value!");
	
	
	//clear seals
	self.addOrUpdateWagonSeal( wagon, sealType, null );
	self.assertTrueMsg( wagon.allWagonSeals.isEmpty, "Wagon Visit should NO longer have " &amp; sealType.sealType &amp; " seals");
	
	//check that a sealed transaction has been created
	oldWagonSealTrx := wagonSealDelTrx;
	wagonSealDelTrx := wagon.getLastTransactionOfType(EVT_WagonSealDelete);
	self.assertTrueMsg( wagonSealDelTrx &lt;&gt; null, "Event Transaction for 'Wagon Seal Delete' (during update to null) not found at all!");
	self.assertTrueMsg( wagonSealDelTrx &lt;&gt; oldWagonSealTrx, "Latest Event Transaction for 'Wagon Seal Delete' (during update to null) not found!");
	self.assertTrueMsg( wagonSealDelTrx.extraDescription.pos("seal46",1) &gt; 1, "Should have found seal number [seal46] in the 'extraDescription' of Del" );
		
epilog

	beginTransaction;
	term.setPropertyValue("sealCheckWagonDischarge",sealCheckWagonDischarge);
	term.setPropertyValue("sealCheckWagonLoad", sealCheckWagonLoad);
	commitTransaction;
	
	if ti1 &lt;&gt; null and app.isValidObject(ti1) then
		beginTransaction;
		if ti1.jobRailReceive &lt;&gt; null then
			job := ti1.jobRailReceive;
			delete job;
		endif;
		if ti1.jobRailRelease &lt;&gt; null then
			job := ti1.jobRailRelease;
			delete job;
		endif;
		commitTransaction;
		self.deleteTrackedItem(ti1,false);
	endif;
	if ti2 &lt;&gt; null and app.isValidObject(ti2) then
		beginTransaction;
		if ti2.jobRailReceive &lt;&gt; null then
			job := ti2.jobRailReceive;
			delete job;
		endif;
		if ti2.jobRailRelease &lt;&gt; null then
			job := ti2.jobRailRelease;
			delete job;
		endif;
		commitTransaction;
		self.deleteTrackedItem(ti2,false);
	endif;
	wagonMaster := self.getRoot.allWagonMasters[WagonCode1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	self.deleteWagonClassAndWagons(wagonClassZX);
	self.deleteRailArea(RailAreaId);
	self.deleteTrain(TrainCode,null);
	
	delete doorPosArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tMoveWagonsDefer" id="8af6afcd-d9ea-4d2c-8211-8e6eac49792e">
        <source>tMoveWagonsDefer();
/*
 
Purpose:	to validate deferred update enabled trxMoveWagons 		
 
Parameters:			
 
Return Value:		
 
Date		Who		Reason
19 May 2025	navbs1	Initial creation Story MTN-34762: MTN - Add Deferred Updates Rail Operation
 
*/
 
constants
	TRAIN_CODE			: String = "T34762_1";
	WagonClassCode		: String = "UTSB";
	WAGON_MASTER_CODE	: String = "UT_WM_S1";
	RAIL_AREA_ID		: String = "UT_JRA1";
vars
	passportObj		: CM_Passport;
	trainObj		: CM_Train;
	railAreaObj		: CM_Rail;
	wagonObj		: CM_Wagon;
	wagonClass		: CM_WagonClass;
	pxyMasterObj	: CM_WagonMaster;
	wagonMasterObj	: CM_WagonMaster;
	wagonMoveController	: CMIF_WagonMoveController;
	railLineObj		: CM_RailLine;
	allWagons		: CM_WagonArray;
	pxyWagon		: CM_Wagon;
	wagonMoveEvt,
	evtToCheck 		: CM_EventTransaction;
begin
	passportObj	:=	app.myPassport;
	// ****** DELETE EVERYTHING FROM LAST TEST.
	wagonClass	:=	app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	self.deleteTrain(TRAIN_CODE,null);
 
	wagonMasterObj	:=	self.getRoot.allWagonMasters[WAGON_MASTER_CODE];
	if wagonMasterObj &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMasterObj);
	endif;

 
	self.deleteRailArea(RAIL_AREA_ID);
	// ****** ADD NEW TRAIN
	trainObj	:=	self.addTrain(TRAIN_CODE, null);
	self.assertNotNull(trainObj);
	// ****** ADD NEW RAIL AREA
	railAreaObj	:=	self.addRailArea(RAIL_AREA_ID, 4, 5);
	self.assertNotNull(railAreaObj);
	railLineObj	:=	railAreaObj.allRailLinesByIndex[1];
	// ****** ADD NEW WAGON CLASS AND WAGON, THEN ATTACH TO TRAIN
	self.opts.purge();
	self.opts.addAssoc( "WagonType", CM_WagonClass.Wagon_Flatcar );
	wagonClass := self.addWagonClass(WagonClassCode);
 
	
	// ****** CREATE WAGON MASTER
	create allWagons transient;
	create pxyMasterObj transient;
	pxyMasterObj.setProxy(	WAGON_MASTER_CODE,	//_id : String;
							wagonClass,	//_myWagonClass : CM_WagonClass;
							CM_Carrier.firstInstance(),	//_myCarrier : CM_Carrier;
							450,	//_maxCargoHeight	: Decimal; 
							60000,	//_maxCargoWeight	: Decimal;
							15000);	//_tareWeight	: Decimal
	pxyMasterObj.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster(pxyMasterObj, wagonMasterObj, passportObj);
	wagonObj	:=	self.addWagonToTrainOption2(trainObj, wagonMasterObj, null, false);
	allWagons.add(wagonObj);
	app.myTrxUA.trxUpdateWagonPosition(railLineObj, wagonObj, 1, passportObj);
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, trainObj, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	create wagonMoveController transient;
	wagonMoveController.myTargetRailLine := railLineObj;
	wagonMoveController.isInwardTarget := true;
	wagonMoveController.targetPosition := 3;
	wagonMoveController.allWagons.add(wagonObj);
	
	app.myTrxUA.trxMoveWagons(wagonMoveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	wagonMoveEvt :=wagonObj.getLastTransactionOfType(EVT_WagonMoved);
	assertNotNullMsg(wagonMoveEvt," Expected Wagon Move event is not found");
	//check for events  in terminal::allEventsByTypeDateTime
	evtToCheck := self.getTerminal.allEventsByTypeDateTime[EVT_WagonMoved,wagonMoveEvt.dateTime];
	assertNotNullMsg(evtToCheck,"Wagon Move event transaction is not found in terminal allEventsByTypeDateTime dictionary");
	assertTrueMsg(wagonMoveEvt = evtToCheck ,"Wagon Move event found is not the expected one");

 
epilog
	delete pxyMasterObj;
	delete allWagons;
	delete wagonMoveController ;
	delete pxyWagon;
 
end;</source>
    </JadeMethod>
    <JadeMethod name="tPosiLoadingOnWagon1" id="acb3bf14-9b3d-4f3f-8cd7-760744af1f9f">
        <source>tPosiLoadingOnWagon1();
// cnwndl1
/*

Purpose:			
		Builds , train, wagon class, wagon master, wagon and containers.  Adds the containers onto the wagon
		and then runs the positional validation on the train and the wagon.
		Checks that a weight errors are detected.
Parameters:			

Return Value:		


Date		Who		Reason
13 July 2009	cnwndl1	Initial creation
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
17/08/2022		jlika1	TFS 53741 EUP  - Max Wagon Payload
*/
constants

	TrainCode : String = "UT-TRAIN1";

vars

	wagonClass : CM_WagonClass;
	pxyRule : CM_WagonPositionalRule;
	pxyPosi : CM_WagonPosition;
	rule : CM_WagonPositionalRule;
	
	pxyMaster : CM_WagonMaster;
	wagonMaster : CM_WagonMaster;
	id : String;
	carrier : CM_Carrier;
	maxCHeight : Decimal [12,2];
	maxCWeight : Decimal [12,2];
	tareWeight : Decimal [12,2];
	
	terminal : CM_Terminal;
	train : CM_Train;
	
	wagon : CM_Wagon;

	ti : CM_TrackedItem;
	ti1 : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	ti3 : CM_TrackedItem;
	ti4 : CM_TrackedItem;
	allTrackedItems : CM_TIByIdDups;
	
	maxPosiWeight : Decimal [12,2];
	maxPosiHeight : Decimal [12,2];
	error : CM_Error;
	rulesMet : CM_WagonPositionalRuleSet;
	
begin

	terminal := app.myPassport.myTerminal;
	
	//Just in case some one has been testing during the day and not cleaned up again....
	wagonClass := app.myRoot.allWagonClasses.getAtKey("ZZ");
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	
/*	train := app.myPassport.myTerminal.allTrainsOnTerminal.getAtKeyGeq(TrainCode,null);
	foreach wagon in train.allWagonsByIdInward do
		if wagon.confirmed then
			beginTransaction;
			wagon.erase(0);
			commitTransaction;
			continue;
		endif; 
		app.myTrxDA.trxDeleteWagon(wagon, false, app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());	
	endforeach; */

	//add train
	self.deleteTrain(TrainCode,null);
	train := self.addTrain(TrainCode,null);
	self.assertNotNull(train);
	
	//Just in case some one has been testing during the day and not cleaned up again....
//	wagonClass := app.myRoot.allWagonClasses.getAtKey("ZZ");
//	if wagonClass &lt;&gt; null then
//		self.deleteWagonClassAndWagons(wagonClass);
//	endif;
	
	// Set up the basic wagon class
	maxPosiWeight := 3900.00;
	maxPosiHeight := 300.00;
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", maxPosiWeight);
	self.opts.addAssoc("MaxPosiHeight", maxPosiHeight);
	wagonClass := addWagonClass("ZZ");
	
	//Add a few more sets of positional rules to the basic wagon class
	create pxyRule transient;
	pxyRule.setProxy(	wagonClass,	//_myWagonClass : CM_WagonClass;
						4,	//_numberOfPositions : Integer;
						null	//_allWagonPositions : CM_WagonPositionDict
						);
						
	foreach pxyPosi in pxyRule.allWagonPositions do
		if pxyPosi.position = 1 then
			pxyPosi.setProxy(	40,	//_cargoLength : Integer;
								45,	//_deckHeight : Decimal;
								maxPosiWeight * 2,	//_maxWeight : Decimal;
								pxyPosi.position,	//_position : Integer;
								pxyRule	//_myWagonPositionalRule : CM_WagonPositionalRule
								);
		elseif pxyPosi.position = 2 then
			pxyPosi.setProxy(	0,	//_cargoLength : Integer;
								0,	//_deckHeight : Decimal;
								0,	//_maxWeight : Decimal;
								pxyPosi.position,	//_position : Integer;
								pxyRule	//_myWagonPositionalRule : CM_WagonPositionalRule
								);
		elseif pxyPosi.position = 3 then
			pxyPosi.setProxy(	20,	//_cargoLength : Integer;
								45,	//_deckHeight : Decimal;
								maxPosiWeight,	//_maxWeight : Decimal;
								pxyPosi.position,	//_position : Integer;
								pxyRule	//_myWagonPositionalRule : CM_WagonPositionalRule
								);
		elseif pxyPosi.position = 4 then
			pxyPosi.setProxy(	20,	//_cargoLength : Integer;
								45,	//_deckHeight : Decimal;
								maxPosiWeight,	//_maxWeight : Decimal;
								pxyPosi.position,	//_position : Integer;
								pxyRule	//_myWagonPositionalRule : CM_WagonPositionalRule
								);
		endif;
	endforeach;
	app.myTrxCA.trxCreateWagonPositionalRule( pxyRule, rule, app.myPassport );
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete pxyRule;
	
	
	create pxyRule transient;
	pxyRule.setProxy(	wagonClass,	//_myWagonClass : CM_WagonClass;
						4,	//_numberOfPositions : Integer;
						null	//_allWagonPositions : CM_WagonPositionDict
						);
						
	foreach pxyPosi in pxyRule.allWagonPositions do
		if pxyPosi.position = 1 then
			pxyPosi.setProxy(	20,	//_cargoLength : Integer;
								45,	//_deckHeight : Decimal;
								maxPosiWeight,	//_maxWeight : Decimal;
								pxyPosi.position,	//_position : Integer;
								pxyRule	//_myWagonPositionalRule : CM_WagonPositionalRule
								);
		elseif pxyPosi.position = 2 then
			pxyPosi.setProxy(	20,	//_cargoLength : Integer;
								45,	//_deckHeight : Decimal;
								maxPosiWeight,	//_maxWeight : Decimal;
								pxyPosi.position,	//_position : Integer;
								pxyRule	//_myWagonPositionalRule : CM_WagonPositionalRule
								);
		elseif pxyPosi.position = 3 then
			pxyPosi.setProxy(	40,	//_cargoLength : Integer;
								45,	//_deckHeight : Decimal;
								maxPosiWeight * 2,	//_maxWeight : Decimal;
								pxyPosi.position,	//_position : Integer;
								pxyRule	//_myWagonPositionalRule : CM_WagonPositionalRule
								);
		elseif pxyPosi.position = 4 then
			pxyPosi.setProxy(	0,	//_cargoLength : Integer;
								0,	//_deckHeight : Decimal;
								0,	//_maxWeight : Decimal;
								pxyPosi.position,	//_position : Integer;
								pxyRule	//_myWagonPositionalRule : CM_WagonPositionalRule
								);
		endif;
	endforeach;
	app.myTrxCA.trxCreateWagonPositionalRule( pxyRule, rule, app.myPassport );
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete pxyRule;
	
	create pxyRule transient;
	pxyRule.setProxy(	wagonClass,	//_myWagonClass : CM_WagonClass;
						4,	//_numberOfPositions : Integer;
						null	//_allWagonPositions : CM_WagonPositionDict
						);
						
	foreach pxyPosi in pxyRule.allWagonPositions do
		if pxyPosi.position = 1 then
			pxyPosi.setProxy(	20,	//_cargoLength : Integer;
								45,	//_deckHeight : Decimal;
								maxPosiWeight,	//_maxWeight : Decimal;
								pxyPosi.position,	//_position : Integer;
								pxyRule	//_myWagonPositionalRule : CM_WagonPositionalRule
								);
		elseif pxyPosi.position = 2 then
			pxyPosi.setProxy(	40,	//_cargoLength : Integer;
								45,	//_deckHeight : Decimal;
								maxPosiWeight * 2,	//_maxWeight : Decimal;
								pxyPosi.position,	//_position : Integer;
								pxyRule	//_myWagonPositionalRule : CM_WagonPositionalRule
								);
		elseif pxyPosi.position = 3 then
			pxyPosi.setProxy(	0,	//_cargoLength : Integer;
								0,	//_deckHeight : Decimal;
								0,	//_maxWeight : Decimal;
								pxyPosi.position,	//_position : Integer;
								pxyRule	//_myWagonPositionalRule : CM_WagonPositionalRule
								);
		elseif pxyPosi.position = 4 then
			pxyPosi.setProxy(	20,	//_cargoLength : Integer;
								45,	//_deckHeight : Decimal;
								maxPosiWeight,	//_maxWeight : Decimal;
								pxyPosi.position,	//_position : Integer;
								pxyRule	//_myWagonPositionalRule : CM_WagonPositionalRule
								);
		endif;
	endforeach;
	app.myTrxCA.trxCreateWagonPositionalRule( pxyRule, rule, app.myPassport );
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete pxyRule;
	
	//create a WagonMaster
	id := "ZZ12345678";
	wagonMaster := app.myRoot.allWagonMasters.getAtKey(id);
	self.deleteWagonMasterAndWagons( wagonMaster ); // in case it was already there.
	
	carrier := CM_Carrier.firstInstance;
	maxCHeight := 450; 	//cm
	maxCWeight := 60000;	//kg
	tareWeight := 15000;	//kg
	
	create pxyMaster transient;
	pxyMaster.setProxy(	id,	//_id : String;
						wagonClass,	//_myWagonClass : CM_WagonClass;
						carrier,	//_myCarrier : CM_Carrier;
						maxCHeight,	//_maxCargoHeight	: Decimal; 
						maxCWeight,	//_maxCargoWeight	: Decimal;
						tareWeight	//_tareWeight	: Decimal
						);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertTrueMsg(wagonMaster &lt;&gt; null, "Wagon Master '" &amp; id &amp; "' not created.");
	self.assertTrueMsg(wagonMaster.myWagonClass = wagonClass, "Wagon Master 'myWagonClass' not populated correctly.");
	self.assertTrueMsg(wagonMaster.myCarrier = carrier, "Wagon Master 'myCarrier' not populated correctly.");
// Changed as a result of Par 21924 NDL 24 feb 2010 - should now use the WagonClass values	
//	self.assertTrueMsg(wagonMaster.maxCargoHeight = maxCHeight, "Wagon Master 'maxCargoHeight' not populated correctly.");
//	self.assertTrueMsg(wagonMaster.maxCargoWeight = maxCWeight, "Wagon Master 'maxCargoWeight' not populated correctly.");
//	self.assertTrueMsg(wagonMaster.tareWeight = tareWeight, "Wagon Master 'tareWeight' not populated correctly.");
	self.assertTrueMsg(wagonMaster.maxCargoHeight = wagonClass.maxCargoHeight, "Wagon Master 'maxCargoHeight' not populated correctly.");
	
	//jlika1 TFS 53741 --&gt;
	//self.assertTrueMsg(wagonMaster.maxCargoWeight = wagonClass.maxLoadWeight, "Wagon Master 'maxCargoWeight' not populated correctly.");
	//self.assertTrueMsg(wagonMaster.tareWeight = wagonClass.tareWeight, "Wagon Master 'tareWeight' not populated correctly.");
	
	self.assertEqualMsg(wagonMaster.maxCargoWeight, maxCWeight, "Wagon Master 'maxCargoWeight' not populated correctly.");
	self.assertEqualMsg(wagonMaster.tareWeight, tareWeight, "Wagon Master 'tareWeight' not populated correctly.");
	//jlika1 TFS 53741 &lt;--
	
	
	//create some containers
	create allTrackedItems transient;
	
	id := "ZZ123456_1";
	self.deleteContainer(id);
	ti1 := createContainer(	id,	//id: String;
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	beginTransaction;
	ti1.setReceiptTransportMode( TI_TRANSMODE_RAIL );
	commitTransaction;
	allTrackedItems.add(ti1);
							
	id := "ZZ123456_2";
	self.deleteContainer(id);
	ti2 := createContainer(	id,	//id: String;
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	beginTransaction;
	ti2.setReceiptTransportMode( TI_TRANSMODE_RAIL );
	commitTransaction;
	allTrackedItems.add(ti2);
							
	id := "ZZ123456_3";
	self.deleteContainer(id);
	ti3 := createContainer(	id,	//id: String;
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	beginTransaction;
	ti3.setReceiptTransportMode( TI_TRANSMODE_RAIL );
	commitTransaction;
	allTrackedItems.add(ti3);
							
	id := "ZZ123456_4";
	self.deleteContainer(id);
	ti4 := createContainer(	id,	//id: String;
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	beginTransaction;
	ti4.setReceiptTransportMode( TI_TRANSMODE_RAIL );
	commitTransaction;
	allTrackedItems.add(ti4);
	

	
	// create Wagon on WagonMaster
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	wagon := self.addWagonToTrainOption2(train, wagonMaster, allTrackedItems, true);
	self.assertTrueMsg(wagon &lt;&gt; null, "Wagon '" &amp; wagonMaster.id &amp; "' not created.");
	self.assertTrueMsg(wagon.findTi(ti1.id) &lt;&gt; null, "Container '" &amp; ti1.id &amp; "' not on wagon.");
	self.assertTrueMsg(wagon.findTi(ti2.id) &lt;&gt; null, "Container '" &amp; ti2.id &amp; "' not on wagon.");
	self.assertTrueMsg(wagon.findTi(ti3.id) &lt;&gt; null, "Container '" &amp; ti3.id &amp; "' not on wagon.");
	self.assertTrueMsg(wagon.findTi(ti4.id) &lt;&gt; null, "Container '" &amp; ti4.id &amp; "' not on wagon.");	
	
	//run positional loading validation.
	on Exception do exHandlerAddWarningToPassport(exception,app.myPassport);
	app.myPassport.clearErrorsWarnings;
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	wagon.getPositionalLoadError( null, rulesMet );
	error := app.myPassport.getFirstErrorWarning();
	self.assertTrueMsg(error &lt;&gt; null, "No warning raised during move.");
	self.assertTrueMsg(error.errorCode = Positional_loading_error, "Transaction warning should be a Positional Load error");

	app.myPassport.clearErrorsWarnings;
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	train.getPositionalLoadErrors( true );
	error := app.myPassport.getFirstErrorWarning();
	self.assertTrueMsg(error &lt;&gt; null, "No warning raised on trains wagon.");
	self.assertTrueMsg(error.errorCode = Positional_loading_error, "Train did not produce a Positional Load error.");

	
epilog

	delete pxyRule;

	//delete containers
	if allTrackedItems &lt;&gt; null then
		foreach ti in allTrackedItems do
			app.myPassport.clearErrorsWarnings;
			app.myTrxDA.trxDeleteTI(ti, false, app.myPassport);
		endforeach;
	endif;
	delete allTrackedItems;
	
	delete pxyMaster;
	self.deleteWagonMasterAndWagons( wagonMaster );
	
	self.deleteWagonClassAndWagons(wagonClass);
	
	self.deleteTrain(TrainCode,null);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tPosiLoadingOnWagon2" id="4b60773b-1070-4fcd-82ca-a11295d6ad04">
        <source>tPosiLoadingOnWagon2();
// cnwndl1
/*

Purpose:			

Parameters:			
		Builds , train, wagon class, wagon and a container.  Adds the container onto the wagon
		and then runs the positional validation on the train and the wagon.
		Checks that a height errors are detected, and that a Wagon master is automatically created.
Return Value:		


Date		Who		Reason
14 July 2009	cnwndl1	Initial creation
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
*/

constants

	TrainCode : String = "UT-TRAIN1";

vars

	wagonClass : CM_WagonClass;
	wagonMaster : CM_WagonMaster;
	id : String;	
	terminal : CM_Terminal;
	train : CM_Train;
	wagon : CM_Wagon;		
	ti : CM_TrackedItem;
	error : CM_Error;
	rulesMet : CM_WagonPositionalRuleSet;
	
begin

	terminal := app.myPassport.myTerminal;
	
	//create train
	self.deleteTrain(TrainCode,null);
	train := self.addTrain(TrainCode,null);
	self.assertNotNull(train);
	
	//Just in case some one has been testing during the day and not cleaned up again....
	wagonClass := app.myRoot.allWagonClasses.getAtKey("ZZ");
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	
	// Set up the basic wagon class
	self.opts.purge();
	self.opts.addAssoc("MaxPosiHeight", "200".Decimal);
	wagonClass := addWagonClass("ZZ");
	
	//ensure we have no WagonMaster
	id := "ZZ12345678";
	wagonMaster := app.myRoot.allWagonMasters.getAtKey(id);
	self.deleteWagonMasterAndWagons( wagonMaster ); // in case it was already there.
	
	//create a container
	self.deleteContainer("ZZ123456_1");
	ti := createContainer(	"ZZ123456_1",	//id: String;
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	beginTransaction;
	ti.setReceiptTransportMode( TI_TRANSMODE_RAIL );
	commitTransaction;
	// create Wagon ( WagonMaster s/be created automatically )
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	wagon := self.addWagonToTrainOption3(	train, id, wagonClass, ti, true, true);
	self.assertTrueMsg(wagon &lt;&gt; null, "Wagon '" &amp; id &amp; "' not created.");
	
	wagonMaster := app.myRoot.allWagonMasters.getAtKey(id);
	self.assertTrueMsg(wagonMaster &lt;&gt; null, "Wagon master '" &amp; id &amp; "' not created.");
	
	self.assertTrueMsg(wagon.findTi(ti.id) &lt;&gt; null, "Container '" &amp; ti.id &amp; "' not on wagon.");
	
	
	//run positional loading validation.
	on Exception do exHandlerAddWarningToPassport(exception,app.myPassport);
	app.myPassport.clearErrorsWarnings;
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(false);
	wagon.getPositionalLoadError( null, rulesMet);
	error := app.myPassport.getFirstErrorWarning();
	self.assertTrueMsg(error &lt;&gt; null, "Positional Load validation for Wagon did not produce an error.");
	self.assertTrueMsg(error.errorCode = Positional_loading_error, "Error for Wagon was not a Positional Load error.");
	
	
	app.myPassport.clearErrorsWarnings;
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	train.getPositionalLoadErrors( true );
	error := app.myPassport.getFirstErrorWarning();
	self.assertTrueMsg(error &lt;&gt; null, "Positional Load validation for Train did not produce an error.");
	self.assertTrueMsg(error.errorCode = Positional_loading_error, "Error for Train was not a Positional Load error.");
	
epilog

	//delete containers
	if ti &lt;&gt; null then
		app.myTrxDA.trxDeleteTI(ti, false, app.myPassport);
	endif;
	
	self.deleteWagonMasterAndWagons( wagonMaster );
	
	self.deleteWagonClassAndWagons(wagonClass);
	
	self.deleteTrain(TrainCode,null);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTestQueuedLocation" id="f98a23a4-2b86-471a-a82c-f16f5ab72d45">
        <source>tTestQueuedLocation();
/*

Purpose:			TFS 1783

Date		Who		Reason
06 April 2016	cnwmk3	Initial creation
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
constants
	TrainCode 		: String 	= "UT-TRAIN10";
	WagonClassCode 	: String 	= "MODULO";
	WagonMasterCode1: String	= "UT_WM01";
	RailAreaId 		: String 	= "UT_RA01";
	TiCode						= "CONTR001";
	TiCode2						= "CONTR002";
vars
	train			: CM_Train;
	pxyTrain 		: CM_Train;
	railArea 		: CM_Rail;
	wagon 			: CM_Wagon;
	wagonClass 		: CM_WagonClass;
	allTrackedItems : CM_TIByIdDups;
	pxyMaster 		: CM_WagonMaster;
	wagonMaster 	: CM_WagonMaster;
	now 			: TimeStamp;
	railLine 		: CM_RailLine;
	ti, ti2			: CM_TrackedItem;
	bs1				: CM_BlockStack;
	wle				: CM_WorkListEntry;
begin
	// ****** DELETE EVERYTHING FROM LAST TEST
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	wagon := self.getTerminal.allWagons["UT_WM01", now];
	if wagonClass &lt;&gt; null then
		deleteWagonAndAssociatedObjs(wagon);
		wagon := self.getTerminal.allWagons["UT_WM01", now];
		self.assertNull(wagon);
	endif;

	wagonMaster := self.getRoot.allWagonMasters[WagonMasterCode1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	
	self.deleteRailArea(RailAreaId);
	
	self.deleteTrain(TrainCode,null);
	
	// ****** ADD NEW TRAIN
	train := self.addTrain(TrainCode,null);
	self.assertNotNullMsg(train, "For some reason couldn't create train");
	
	// ****** ADD NEW RAIL AREA
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
	
	railLine := railArea.allRailLinesByIndex.first;  //hope this works
	
	// ****** ADD NEW WAGON, THEN ATTACH TO TRAIN
	wagonClass := app.myRoot.allWagonClasses["MODULO"];
	// ****** CREATE MASTER WAGON
	create pxyMaster transient;
	pxyMaster.setProxy(	WagonMasterCode1, wagonClass,CM_Carrier.firstInstance, 450,60000, 15000);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	
	
	// ****** ADD AND PLACE CONTAINERS ON WAGONS
	create allTrackedItems transient;
	//not going to bother with any tracked items on the wagon.  the train is just coming in and going out.
	
	// ***** ATTACH WAGON TO TRAIN
	wagon := self.addWagonToTrainOption2(train, wagonMaster, allTrackedItems, false);
	self.assertNotNullMsg(wagon,"Couldn't create a wagon");
	
	// ****** LETS ARRIVE
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	now := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	pxyTrain.setProxyDetails(now);
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Update Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	railLine.switchPositions(wagon, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);  //in
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	
	// ADD CONTAINERS
	self.deleteTerminalArea("BS01");
	bs1 := self.addBlockStack("BS01", 5, null);
	self.assertNotNull(bs1);
	
	self.deleteTrackedItem(self.getTrackedItem(TiCode), false);
	ti := self.createContainer(	TiCode,
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	move(ti, bs1);
	self.deleteTrackedItem(self.getTrackedItem(TiCode2), false);
	ti2 := self.createContainer(	TiCode2,
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	self.assertNotNull(ti2);
	move(ti2, bs1);
	
	// QUEUE CONTAINERS TO WAGONS
	self.planQueueTiToWagon(ti, wagon.allLocationsControllers.first, QUEUE_MODE);
	self.planQueueTiToWagon(ti2, wagon.allLocationsControllers.first, QUEUE_MODE);
	
	// actual test
	wle := ti.allWorklistEntries.first;
	self.assertEqual(wle.getTargetLocation().getFullId(), railArea.allLocationsControllers.first.getFullId());
	self.assertEqual(ti.queuedLocnId, railArea.allLocationsControllers.first.getFullId());
	
	//Finished clean up
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	wagon := self.getTerminal.allWagons["UT_WM01", now];
	if wagonClass &lt;&gt; null then
		deleteWagonAndAssociatedObjs(wagon);
		wagon := self.getTerminal.allWagons["UT_WM01", now];
		self.assertNull(wagon);
	endif;
	wagonMaster := self.getRoot.allWagonMasters[WagonMasterCode1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	self.deleteRailArea(RailAreaId);
	self.deleteTrain(TrainCode,null);
	
epilog
	delete allTrackedItems;
	delete pxyMaster;
	delete pxyTrain;
	self.ignoreTrxWarnings(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tTrackClearanceValidation" id="287f94de-9170-4911-a876-9a95183d6b73">
        <updating/>
        <source>tTrackClearanceValidation() updating;
// cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwndl1	Initial creation
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
*/

constants

	TrainCode : String = "UT-TRAIN1";

vars

	wagonClass : CM_WagonClass;
	wagonClass2 : CM_WagonClass;
	wagonMaster : CM_WagonMaster;
	wagonMaster2 : CM_WagonMaster;
	id : String;
	id2 : String;
	terminal : CM_Terminal;
	train : CM_Train;
	wagon : CM_Wagon;
	wagon2 : CM_Wagon;
	ti1 : CM_TrackedItem;
	trackClearance : CM_TrackClearance;
	
	ti2 : CM_TrackedItem;
	error : CM_Error;

begin

	terminal := app.myPassport.myTerminal;
	
	//Just in case some one has been testing during the day and not cleaned up again....
	wagonClass := app.myRoot.allWagonClasses.getAtKey("ZZ");
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;

	// set basic gauge clearance;
	trackClearance := addTrackClearance("ZZ");
	self.assertNotNull(trackClearance);

	// Set up the basic wagon class
	self.opts.purge();
	self.opts.addAssoc("MaxPosiHeight", "200".Decimal);
	wagonClass := addWagonClass("ZZ");
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "5000".Decimal);
	self.opts.addAssoc("MaxPosiHeight", "450".Decimal);
	wagonClass2 := addWagonClass("ZX");
	
	//ensure we have no pre-existing WagonMaster s
	id := "ZZ12345678";
	wagonMaster := app.myRoot.allWagonMasters.getAtKey(id);
	self.deleteWagonMasterAndWagons( wagonMaster ); // in case it was already there.
	id2 := "ZZ12345679";
	wagonMaster2 := app.myRoot.allWagonMasters.getAtKey(id2);
	self.deleteWagonMasterAndWagons( wagonMaster2 ); // in case it was already there.

	//create a container
	self.deleteContainer("ZZ123456_1");
	ti1 := createContainer(	"ZZ123456_1",	//id: String;
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
							
	//create train with gauge clearance
	self.deleteTrain(TrainCode,null);
	train := self.addTrain(TrainCode,trackClearance);
	self.assertNotNull(train); 
	
	// shouldn't be able to delete a gauge clearance that is still attached to a train.
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxDA.trxDeleteTrackClearance(trackClearance, app.myPassport);
	self.assertTrueMsg(not app.myPassport.trxCompletedOK(), "No error raised that the Track clearance is still in use by a train");
	self.assertTrueMsg(app.isValidObject(trackClearance), "Track Clearance deletion should have failed");

	
	// create Wagon ( WagonMaster s/be created automatically )
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	wagon := self.addWagonToTrainOption3(	train, id, wagonClass, ti1, true, false);	
	self.assertTrueMsg(wagon &lt;&gt; null, "Wagon '" &amp; id &amp; "' not created.");
	wagonMaster := app.myRoot.allWagonMasters.getAtKey(id);
	self.assertTrueMsg(wagon.findTi(ti1.id) &lt;&gt; null, "Container '" &amp; ti1.id &amp; "' not on wagon.");
	
	//run train gauge clearance validation.
	train.validateUsingGaugeClearance(REAL_MODE);
	
	on Exception do self.exHandlerAssertException(exception);
	
	//alter the gaugeClearance height.
	updateTrackClearance( 	trackClearance,	//_gaugeClearance : CM_GaugeClearance io;
							280,	//_maxHeight : Decimal;
							trackClearance.maxWeightWagon,	//_maxWeightWagon : Decimal;
							trackClearance.maxWidth	//_maxWidth : Decimal;
							);
	self.assertTrueMsg(trackClearance.maxHeight = 280, "Track Clearance 'maxHeight' not updated.");
	app.myPassport.clearErrorsWarnings;
	train.validateUsingGaugeClearance(REAL_MODE);	//run train gauge clearance validation with new values, should error.
	assertExceptionRaised(Track_clearance_exceeded, "Track clearance didn't find the over height");
	
	
	
	//alter the gaugeClearance weight.
	updateTrackClearance( 	trackClearance,	//_gaugeClearance : CM_GaugeClearance io;
							450,	//_maxHeight : Decimal;
							8000,	//_maxWeightWagon : Decimal;
							trackClearance.maxWidth	//_maxWidth : Decimal;
							);
	self.assertTrueMsg(trackClearance.maxWeightWagon = 8000, "Track Clearance 'maxWeightWagon' not updated.");
	app.myPassport.clearErrorsWarnings;
	train.validateUsingGaugeClearance(REAL_MODE);	//run train gauge clearance validation with new values, should error.
	assertExceptionRaised(Track_clearance_exceeded, "Track clearance didn't find the over weight");
	
	
	
	//alter the gaugeClearance width.
	updateTrackClearance( 	trackClearance,	//_gaugeClearance : CM_GaugeClearance io;
							trackClearance.maxHeight,	//_maxHeight : Decimal;
							20000,	//_maxWeightWagon : Decimal;
							240	//_maxWidth : Decimal;
							);
	self.assertTrueMsg(trackClearance.maxWidth = 240, "Track Clearance 'maxWidth' not updated.");
	app.myPassport.clearErrorsWarnings;
	train.validateUsingGaugeClearance(REAL_MODE);		//run train gauge clearance validation with new values, should error.
	assertExceptionRaised(Track_clearance_exceeded, "Track clearance didn't find the over width");
	
	
	// make sure we create a warning when doing a move of a container to a wagon.
	//create another container for the second wagon
	self.deleteContainer("PONU0121332");
	ti2 := createContainer(	"PONU0121332",	//id: String;
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
							
	// initiate the create of the second Wagon
	app.myPassport.clearErrorsWarnings;
	
	wagon2 := self.addWagonToTrainOption3(	train, id2, wagonClass2, ti2, false, false);
	self.assertTrueMsg(not app.myPassport.trxCompletedOK(), "Transaction shouldn't have completed as move should have caused a Track clearance warning");
	error := app.myPassport.getFirstErrorWarning();
	self.assertTrueMsg(error &lt;&gt; null, "No warning raised during move.");
	self.assertTrueMsg(error.errorCode = Track_clearance_exceeded, "Transaction warning should be a Track clearance exceeded warning");

	
epilog

	//delete containers
	if ti1 &lt;&gt; null then
		app.myTrxDA.trxDeleteTI(ti1, false, app.myPassport);
	endif;
	if ti2 &lt;&gt; null then
		app.myTrxDA.trxDeleteTI(ti2, false, app.myPassport);
	endif;
	
	//delete wagon masters
	self.deleteWagonMasterAndWagons( wagonMaster );
	self.deleteWagonMasterAndWagons( wagonMaster2 );
	
	
	self.deleteWagonClassAndWagons(wagonClass);
	self.deleteWagonClassAndWagons(wagonClass2);
	
	self.deleteTrain(TrainCode,null);
	
	self.deleteTrackClearance(trackClearance);

	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTrainAddOrUpdateWagon" id="5e36185f-e5fa-4dc8-8c4b-58eacf9686c2">
        <source>tTrainAddOrUpdateWagon();
/*

Date		Who		Reason
21 April 2017	cnwer1	Initial creation TFS 3760

*/
constants
	TrainCode : String = "UT-TRAINJ2";
	WagonCode1 : String = "JX002";
	WagonClassCode : String = "JX";
	RailAreaId : String = "UT_JRA2";
vars
			train: CM_Train;
	railArea : CM_Rail;
	wagon : CM_Wagon;
		wagonClass : CM_WagonClass;
	errorMess : String;
	railLine : CM_RailLine;
	details : StringArray;
	summary : JadeDynamicObjectArray;
	obj : Object;
begin
	// ****** DELETE EVERYTHING FROM LAST TEST
	self.deleteRailArea(RailAreaId);
	
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	
	self.deleteTrain(TrainCode,null);
	
	// ****** ADD NEW TRAIN
	train := self.addTrain(TrainCode,null);
	self.assertNotNull(train);
	
	// ****** ADD NEW WAGON CLASS AND WAGON, THEN ATTACH TO TRAIN
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4500".Decimal);
	self.opts.addAssoc("MaxPosiHeight", "100".Decimal);
	wagonClass := self.addWagonClass(WagonClassCode);
	
	// ****** ADD NEW RAIL AREA
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNull(railArea);
	railLine:=railArea.allRailLines.first;
	wagon := train.createOrUpdateWagon(WagonCode1, 3,railLine , errorMess);
	self.assertNull(errorMess);
	self.assertNotNull(wagon);
	self.assertEqual(railLine.allWagons[3],wagon);

	details :=train.getPopulateListRakes(true,null,null);
	self.assertNotNull(details);
	self.assertEqual(details.size, 1);
	self.assertEqual(details.first,railLine.getOidAsString() &amp; ";" &amp; 1.String &amp; ";" &amp; 0.String &amp; ";" &amp; 0.String &amp; ";" &amp; 0.String); // states has 1 wagon on rail line

	summary :=railLine.getWagonSummary(true,train,null,null);
	self.assertNotNull(summary);
	//sjould be a jade dynamic object for each position on the rail line
	self.assertEqual(summary.size, 5);
	obj := summary[3].getPropertyValue("object").Object;
	self.assertNotNull(obj);
	self.assertEqual(obj,wagon);
	
	//finished clean up
	self.deleteRailArea(RailAreaId);	
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;	
	self.deleteTrain(TrainCode,null);
	
epilog
	delete details;
	if summary &lt;&gt; null then
		summary.purge;
	endif;
	
	delete summary;

end;</source>
    </JadeMethod>
    <JadeMethod name="tTrainArriveDepartEvents" id="10fc3a52-55f0-49a7-8ce7-b29533a6ebf2">
        <source>tTrainArriveDepartEvents();
// CNWNDL1
//03 November 2009	cnwjo3
//Purpose:	To verify that Arrival and Departure transactions are created
//			on the CM_Train transaction object array and in the right order.
//			CCMS MSL 1031
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support

constants
	TrainCode : String = "UT-TRAINJ4";
	WagonCode1 : String = "JX_004";
	WagonClassCode : String = "JX";
	WagonMasterCode1 : String = "UT_WM_J4";
	RailAreaId : String = "UT_JRA5";

	EventName : String = "UT_ET4";
vars
	train: CM_Train;
	pxyTrain : CM_Train;
	railArea : CM_Rail;
	wagon : CM_Wagon;
	wagonClass : CM_WagonClass;
	allTrackedItems : CM_TIByIdDups;
	
	pxyMaster : CM_WagonMaster;
	wagonMaster : CM_WagonMaster;
	eventType : CM_EventType;
	trans : CM_EventTransaction;
	foundTransaction : Boolean;
	now : TimeStamp;
	railLine : CM_RailLine;
	trainSet : CM_TrainSet;
	
	foundArrival,
	foundDeparture	: Boolean;
	postdatedTime : TimeStamp;
begin
	// ****** DELETE EVERYTHING FROM LAST TEST
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	
	self.deleteTrain(TrainCode,null);

	wagonMaster := self.getRoot.allWagonMasters[WagonMasterCode1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	
	self.deleteRailArea(RailAreaId);
	
	
	
	// ****** ADD NEW TRAIN
	train := self.addTrain(TrainCode,null);
	self.assertNotNullMsg(train, "For some reason couldn't create train");
	
	// ****** ADD NEW RAIL AREA
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
	
	railLine := railArea.allRailLinesByIndex.first;  //hope this works
	
	// ****** ADD NEW WAGON CLASS AND WAGON, THEN ATTACH TO TRAIN
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4500".Decimal);
	self.opts.addAssoc("MaxPosiHeight", "250".Decimal);
	wagonClass := self.addWagonClass(WagonClassCode);
	
	// ****** CREATE MASTER WAGON
	create pxyMaster transient;
	pxyMaster.setProxy(	WagonMasterCode1, wagonClass,CM_Carrier.firstInstance, 450,60000, 15000);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	
	
	// ****** ADD AND PLACE CONTAINERS ON WAGONS
	create allTrackedItems transient;
	//not going to bother with any tracked items on the wagon.  the train is just coming in and going out.
	
	// ***** ATTACH WAGON TO TRAIN
	wagon := self.addWagonToTrainOption2(train, wagonMaster, allTrackedItems, false);
	self.assertNotNullMsg(wagon,"Couldn't create a wagon");
	
	// ****** LETS ARRIVE
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	now := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	pxyTrain.setProxyDetails(now);
	
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Update Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	railLine.switchPositions(wagon, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);  //in
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, true, app.myPassport);  //out
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm OUT Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	create trainSet transient;  //everyone loves train sets.
	trainSet.add(train);
	app.myTrxUA.trxUpdateTrainsDeparture(trainSet, app.myPassport);  //lets use the transaction thing
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Depart Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	postdatedTime := postdatedTime.addMinutes(-4);
//	self.updateTrainEvent(train, EVT_TrainDepart, postdatedTime);	//test event update
	
	
	//ok.  time to check Arrival and Departures.
	foreach trans in train.allTransactions do
		if trans.type = EVT_TrainArrive then
			if foundDeparture = false then
				foundArrival := true;
			else
				assertTrueMsg(false,"Arrival Transanction found but Departure has already occured.");
			endif;
		elseif trans.type = EVT_TrainDepart then
			if foundArrival = true then
				foundDeparture := true;
			else
				assertTrueMsg(false,"Departure Transanction found but Arrival has not occurred.");
			endif;
		endif;
	endforeach;
	
	self.assertTrueMsg(foundArrival,"No Arrival Transanction found on train");
	self.assertTrueMsg(foundDeparture,"No Departure Transanction found on train");
	
	//finished clean up
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;	
	self.deleteTrain(TrainCode,null);
	wagonMaster := self.getRoot.allWagonMasters[WagonMasterCode1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;	
	self.deleteRailArea(RailAreaId);
	
epilog
	delete pxyMaster;
	delete trainSet;
	delete pxyTrain;
	delete allTrackedItems;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTrainDepatureReferences" id="3f0b8851-148d-4a1d-99cb-fe8ddad96121">
        <source>tTrainDepatureReferences();
// cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519
13 June 2011		cnwjre1	add receive and release train tests, par 27711
*/

constants

	TrainCode1 : String = "UT-TRNDEP";
	RailAreaId : String = "UT_RA45";
	WagonClassId : String = "ZZ";
	WagonId1 : String = "ZZ12345678";
	WagonId2 : String = "ZZ12345679";
	TiId1 : String = "TEST0000001";
	TiId2 : String = "TEST0000002";
	TiId3 : String = "TEST0000003";
	TiId4 : String = "TEST0000004";
	TiId5 : String = "TEST0000005";
	TiId6 : String = "TEST0000006";
	TiId7 : String = "TEST0000007";
	TiId8 : String = "TEST0000008";
	IsoType : String = "2200";
	Commodity1 : String = "GB1";
	Commodity2 : String = "APPL";
	
vars

	terminal : CM_Terminal;
	railArea : CM_Rail;
	railLine : CM_RailLine;
	train1 : CM_Train;
	wagonClass : CM_WagonClass;
	wagonMaster1 : CM_WagonMaster;
	wagonMaster2 : CM_WagonMaster;
	ti1 : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	ti3 : CM_TrackedItem;
	ti4 : CM_TrackedItem;
	ti5 : CM_TrackedItem;
	ti6 : CM_TrackedItem;
	ti7 : CM_TrackedItem;
	ti8 : CM_TrackedItem;
	wagon1 : CM_Wagon;
	wagon2 : CM_Wagon;
	
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	cmifToReturnWagon : CMIF_WagonMoveController;
	count : Integer;

	cmifToDepartTrain : CMIF_RakeRegion;
	cmifToDepartWagon : CMIF_RakeRegion;
	obj : Object;
	outRake : CM_RailJSInOutRake;
	nullTi : CM_TrackedItem;
	trainCode	: String;

begin
	

	terminal := app.myPassport.myTerminal;
	railArea := terminal.allTerminalAreasByTypeId.getAtKey(TA_TYPE_RAILWAY_TRACK,RailAreaId).CM_Rail;

	if railArea = null then
		railArea := self.addRailArea(RailAreaId, 4, 4);
		self.assertNotNull(railArea);
	endif;
	railLine := railArea.allRailLinesByIndex.first;
	foreach obj in railArea.allRailJSInOut do
		if obj.isKindOf(CM_RailJSInOutRake) and obj.CM_RailJSInOutRake.inOut.outwards = Rail_JSIO_Type_Out then
			outRake := obj.CM_RailJSInOutRake;
			break;
		endif;
	endforeach;

	// Set up the basic wagon class
	wagonClass := app.myRoot.allWagonClasses.getAtKey(WagonClassId);
	if wagonClass = null then
		wagonClass := addWagonClass(WagonClassId);
	endif;
	self.assertNotNull(wagonClass);
	
	//ensure we have no duplicate containers
	self.deleteContainer(TiId1);
	self.deleteContainer(TiId2);
	self.deleteContainer(TiId3);
	self.deleteContainer(TiId4);
	self.deleteContainer(TiId5);
	self.deleteContainer(TiId6);
	self.deleteContainer(TiId7);
	self.deleteContainer(TiId8);
	
	//ensure we have no WagonMasters for our wagons
	wagonMaster1 := app.myRoot.allWagonMasters.getAtKey(WagonId1);
	self.deleteWagonMasterAndWagons( wagonMaster1 ); // in case it was already there.
	wagonMaster2 := app.myRoot.allWagonMasters.getAtKey(WagonId2);
	self.deleteWagonMasterAndWagons( wagonMaster2 ); // in case it was already there.
	
	//add train1
	self.deleteTrain(TrainCode1,null);
	train1 := self.addTrain(TrainCode1,null);
	self.assertNotNull(train1);
	
	//create wagons
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	wagon1 := self.addWagonToTrainOption3(	train1, WagonId1, wagonClass, nullTi, true, false);
	wagon2 := self.addWagonToTrainOption3(	train1, WagonId2, wagonClass, nullTi, true, false);
	wagonMaster1 := wagon1.myWagonMaster;
	wagonMaster2 := wagon2.myWagonMaster;
	self.assertNotNull(wagonMaster1);
	self.assertNotNull(wagonMaster2);

	// set up container options 
	opts.addAssoc("IMEX", TI_IMEX_STATUS_REMAINONBOARD);
	opts.addAssoc("Wagon", WagonId1);
	opts.addAssoc("IntendedReleaseMode",TI_IntendedReleaseMode_RAIL);
	opts.addAssoc( UTTI_State, 0 );
	
	//create containers
	ti1 := self.addContainerOpts(TiId1, IsoType, Commodity1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti2 := self.addContainerOpts(TiId2, IsoType, Commodity1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti3 := self.addContainerOpts(TiId3, IsoType, Commodity2, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti4 := self.addContainerOpts(TiId4, IsoType, Commodity2, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	// set up container options
	self.opts.purge();
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_REMAINONBOARD);
	self.opts.addAssoc("Wagon", WagonId2);
	self.opts.addAssoc("IntendedReleaseMode",TI_IntendedReleaseMode_RAIL);
	self.opts.addAssoc( UTTI_State, 0 );
	
	//create containers
	ti5 := self.addContainerOpts(TiId5, IsoType, Commodity1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti6 := self.addContainerOpts(TiId6, IsoType, Commodity1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti7 := self.addContainerOpts(TiId7, IsoType, Commodity2, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	ti8 := self.addContainerOpts(TiId8, IsoType, Commodity2, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.assertNotNull(ti1);
	self.assertNotNull(ti2);
	self.assertNotNull(ti3);
	self.assertNotNull(ti4);
	self.assertNotNull(ti5);
	self.assertNotNull(ti6);
	self.assertNotNull(ti7);
	self.assertNotNull(ti8);
	
	create tiArray transient;
	tiArray.add(ti1);
	tiArray.add(ti2);
	tiArray.add(ti3);
	tiArray.add(ti4);
	tiArray.add(ti5);
	tiArray.add(ti6);
	tiArray.add(ti7);
	tiArray.add(ti8);
	
	// move containers to wagons
	moveTiToWagon(ti1, wagon1.allLocationsControllersArray[1]);
	moveTiToWagon(ti2, wagon1.allLocationsControllersArray[3]);
	moveTiToWagon(ti3, wagon1.allLocationsControllersArray[5]);
	moveTiToWagon(ti4, wagon1.allLocationsControllersArray[7]);
	moveTiToWagon(ti5, wagon2.allLocationsControllersArray[1]);
	moveTiToWagon(ti6, wagon2.allLocationsControllersArray[3]);
	moveTiToWagon(ti7, wagon2.allLocationsControllersArray[5]);
	moveTiToWagon(ti8, wagon2.allLocationsControllersArray[7]);
	
	//check that the tis are on the specified wagon controllers
	self.assertTrueMsg(ti1.myPrimaryActualLocation = wagon1.allLocationsControllersArray[1], ti1.id &amp; " container not associated with its wagon location controller.");
	self.assertTrueMsg(ti2.myPrimaryActualLocation = wagon1.allLocationsControllersArray[3], ti2.id &amp; " container not associated with its wagon location controller.");
	self.assertTrueMsg(ti3.myPrimaryActualLocation = wagon1.allLocationsControllersArray[5], ti3.id &amp; " container not associated with its wagon location controller.");
	self.assertTrueMsg(ti4.myPrimaryActualLocation = wagon1.allLocationsControllersArray[7], ti4.id &amp; " container not associated with its wagon location controller.");
	self.assertTrueMsg(ti5.myPrimaryActualLocation = wagon2.allLocationsControllersArray[1], ti5.id &amp; " container not associated with its wagon location controller.");
	self.assertTrueMsg(ti6.myPrimaryActualLocation = wagon2.allLocationsControllersArray[3], ti6.id &amp; " container not associated with its wagon location controller.");
	self.assertTrueMsg(ti7.myPrimaryActualLocation = wagon2.allLocationsControllersArray[5], ti7.id &amp; " container not associated with its wagon location controller.");
	self.assertTrueMsg(ti8.myPrimaryActualLocation = wagon2.allLocationsControllersArray[7], ti8.id &amp; " container not associated with its wagon location controller.");
	
	// Move wagons to a rake
	railLine.switchPositions(wagon1, 01);
	railLine.switchPositions(wagon2, 02);
	
	// confirm train in
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train1, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	trainCode := train1.getCodeDate();
	//check that the cargo is all on site now.
	foreach ti in tiArray do
		self.assertTrueMsg(ti.site = TI_SITE_ONSITE, ti.id &amp; " should be onsite after arrival!");
		self.assertTrueMsg(ti.getReceiveTrainCode() = trainCode, ti.id &amp; " receive train");
		self.checkTIForTxnOfType(ti, TRANS_TYPE_REC_RAIL);		// 16/08/2012 cnwmh5
	endforeach;
	
	
	// make the train depart
	//confirm train out..
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train1, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	// clear the entire train.
	create cmifToDepartTrain transient;	
	cmifToDepartTrain.myTrain := train1;
	
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateRailClearRake(cmifToDepartTrain, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete cmifToDepartTrain;
	
	//check that the cargo is all off site now.
	foreach ti in tiArray do
		self.assertTrueMsg(ti.site = TI_SITE_OFFSITE, ti.id &amp; " should be offsite after departure!");
		self.assertTrueMsg(ti.getReleaseTrainCode() = trainCode, ti.id &amp; " release train");
		self.checkTIForTxnOfType(ti, TRANS_TYPE_REL_RAIL);		// 16/08/2012 cnwmh5
	endforeach;
	
	//check that the wagon controllers still reference their individual pieces of cargo
	self.assertTrueMsg(ti1.myPrimaryActualLocation = wagon1.allLocationsControllersArray[1], ti1.id &amp; " container lost its reference to wagon location controller after departure.");
	self.assertTrueMsg(ti2.myPrimaryActualLocation = wagon1.allLocationsControllersArray[3], ti2.id &amp; " container lost its reference to wagon location controller after departure.");
	self.assertTrueMsg(ti3.myPrimaryActualLocation = wagon1.allLocationsControllersArray[5], ti3.id &amp; " container lost its reference to wagon location controller after departure.");
	self.assertTrueMsg(ti4.myPrimaryActualLocation = wagon1.allLocationsControllersArray[7], ti4.id &amp; " container lost its reference to wagon location controller after departure.");
	self.assertTrueMsg(ti5.myPrimaryActualLocation = wagon2.allLocationsControllersArray[1], ti5.id &amp; " container lost its reference to wagon location controller after departure.");
	self.assertTrueMsg(ti6.myPrimaryActualLocation = wagon2.allLocationsControllersArray[3], ti6.id &amp; " container lost its reference to wagon location controller after departure.");
	self.assertTrueMsg(ti7.myPrimaryActualLocation = wagon2.allLocationsControllersArray[5], ti7.id &amp; " container lost its reference to wagon location controller after departure.");
	self.assertTrueMsg(ti8.myPrimaryActualLocation = wagon2.allLocationsControllersArray[7], ti8.id &amp; " container lost its reference to wagon location controller after departure.");
	
	//check that the train and wagons are 'departed'
	self.assertTrueMsg(train1.myTerminal = null, "Trains 'terminal' reference should be null after departure!");
	self.assertTrueMsg(wagon1.myTerminal = null, "Wagon1's 'terminal' reference should be null after departure!");
	self.assertTrueMsg(wagon2.myTerminal = null, "Wagon2's 'terminal' reference should be null after departure!");
	self.assertTrueMsg(train1.myTerminalDeparted = app.myPassport.myTerminal, "Trains 'departed terminal' reference should be set after departure!");
	self.assertTrueMsg(wagon1.myTerminalDeparted = app.myPassport.myTerminal, "Wagon1's 'departed terminal' reference should be set after departure!");
	self.assertTrueMsg(wagon2.myTerminalDeparted = app.myPassport.myTerminal, "Wagon2's 'departed terminal' reference should be set after departure!");
	
	// Set up a cmif to Return wagon2 to the terminal
	create cmifToReturnWagon transient;
	cmifToReturnWagon.myTargetRailLine := railLine;
	cmifToReturnWagon.targetPosition := 1;
	cmifToReturnWagon.allWagons.add( wagon2 );
	cmifToReturnWagon.doAutoPlanOfCargo := false;
	cmifToReturnWagon.returnWagon := true;

	// Return wagon2 to the terminal
	app.myTrxUA.trxUpdateWagonReturn(cmifToReturnWagon,  app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete cmifToReturnWagon;
	
	// the train and wagon1 shouldn't have come back, and they should still be departed
	self.assertTrueMsg(wagon1.myTerminal = null, "Wagon1's 'terminal' reference should be null after return of wagon2!");
	self.assertTrueMsg(wagon1.myTerminalDeparted = app.myPassport.myTerminal, "Wagon1's 'departed terminal' reference should be set after return of wagon2!");
	
	// but wagon2 and the train should be back.
	self.assertTrueMsg(train1.myTerminal = app.myPassport.myTerminal, "Trains 'terminal' reference should be set again after the return of a wagon!");
	self.assertTrueMsg(train1.myTerminalDeparted = null, "Trains 'departed terminal' reference should be null after the return of a wagon!");
	self.assertTrueMsg(wagon2.myTerminal = app.myPassport.myTerminal, "Wagon2's 'terminal' reference should be set again after return of wagon2!");
	self.assertTrueMsg(wagon2.myTerminalDeparted = null, "Wagon2's 'departed terminal' reference should be null after return of wagon2!");
	
	foreach ti in tiArray do
		count := count + 1;
		if count &lt;= 4 then
			//wagon1's cargo, should still be off site
			self.assertTrueMsg(ti.site = TI_SITE_OFFSITE, ti.id &amp; " on (wagon1) should still be offsite after return of wagon2!");
		else
			//wagon2's cargo, should still be ON site
			self.assertTrueMsg(ti.site = TI_SITE_ONSITE, ti.id &amp; " on (wagon2) should now be onsite again after return of wagon2!");
		endif;
	endforeach;
	
	
	// now make the last wagon depart
	//confirm wagon2 out..
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateWagonConfirmOut(null, wagon2, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	// clear an individual position (wagon)
	create cmifToDepartWagon transient;	
	cmifToDepartWagon.myRailArea := railArea;
	cmifToDepartWagon.myRailJSIORake := outRake;
	cmifToDepartWagon.clearAll := false;
	cmifToDepartWagon.allRailLines.add(railLine);
	cmifToDepartWagon.startPosition := 1;
	cmifToDepartWagon.endPosition := 1;
	
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateRailClearRake(cmifToDepartWagon, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete cmifToDepartWagon;
	
	//check that the cargo is all off site again.
	foreach ti in tiArray do
		self.assertTrueMsg(ti.site = TI_SITE_OFFSITE, ti.id &amp; " should be offsite after departure!");
	endforeach;
	
	//check that the train and wagon2 should both be departed again
	self.assertTrueMsg(train1.myTerminal = null, "Trains 'terminal' reference should be null after departure!");
	self.assertTrueMsg(wagon2.myTerminal = null, "Wagon2's 'terminal' reference should be null after departure!");
	self.assertTrueMsg(train1.myTerminalDeparted = app.myPassport.myTerminal, "Trains 'departed terminal' reference should be set after departure!");
	self.assertTrueMsg(wagon2.myTerminalDeparted = app.myPassport.myTerminal, "Wagon2's 'departed terminal' reference should be set after departure!");
	
epilog
	delete cmifToDepartTrain;
	delete cmifToReturnWagon;
	delete cmifToDepartWagon;
/*	
	//delete containers
	self.deleteContainer(TiId1);
	self.deleteContainer(TiId2);
	self.deleteContainer(TiId3);
	self.deleteContainer(TiId4);
	self.deleteContainer(TiId5);
	self.deleteContainer(TiId6);
	self.deleteContainer(TiId7);
	self.deleteContainer(TiId8);
	*/
	delete tiArray;
	
	self.deleteWagonMasterAndWagons( wagonMaster1 );
	self.deleteWagonMasterAndWagons( wagonMaster2 );
	
	self.deleteWagonClassAndWagons(wagonClass);
	
	self.deleteTrain(TrainCode1,null);
		
end;</source>
    </JadeMethod>
    <JadeMethod name="tTrainEvent" id="ee427440-9206-47be-bbe6-dd28eb8f1dbf">
        <source>tTrainEvent();
// CNWNDL1
//03 November 2009	cnwjo3
//Purpose:	To verify that the new Event type: Train Event can be successfully
//			added to the CM_Trains 'allTransaction' property.
//			CCMS MSL 1031

constants
	TrainCode : String = "UT-TRAINJ3";
	WagonCode1 : String = "JX_003";
	WagonClassCode : String = "JX";
	WagonMasterCode1 : String = "UT_WM_J3";
	RailAreaId : String = "UT_JRA3";
	TiCode : String = "UT_T_TI3";
	EventName : String = "UT_ET1";
vars
	train: CM_Train;
	railArea : CM_Rail;
	wagon : CM_Wagon;
	wagonClass : CM_WagonClass;
	allTrackedItems : CM_TIByIdDups;
	ti : CM_TrackedItem;
	
	pxyMaster : CM_WagonMaster;
	wagonMaster : CM_WagonMaster;
	eventType : CM_EventType;
	trans : CM_EventTransaction;
	foundTransaction : Boolean;
	now : TimeStamp;
begin

	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	// ****** DELETE EVERYTHING FROM LAST TEST
	self.deleteRailArea(RailAreaId);
	
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	
	self.deleteTrain(TrainCode,null);

	wagonMaster := self.getRoot.allWagonMasters[WagonMasterCode1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	
	self.deleteContainer(TiCode);
	
	//DELETE USER EVENT
	self.deleteEventType(CM_EventType.TRAIN_EVENT,EventName);  //don't worry about success at this point
	
	
	
	
	// ****** ADD TRAIN EVENT
	eventType := self.addEventType(CM_EventType.TRAIN_EVENT,EventName,"Description: " &amp; EventName,Red, null);
	self.assertNotNullMsg(eventType, "Event Type: Train User Event could not be created");
	
	// ****** ADD NEW TRAIN
	train := self.addTrain(TrainCode,null);
	self.assertNotNullMsg(train, "For some reason couldn't create train");
	
	// ****** ADD NEW RAIL AREA
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
	
	// ****** ADD NEW WAGON CLASS AND WAGON, THEN ATTACH TO TRAIN
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4500".Decimal);
	self.opts.addAssoc("MaxPosiHeight", "250".Decimal);
	wagonClass := self.addWagonClass(WagonClassCode);
	
	// ****** CREATE MASTER WAGON
	create pxyMaster transient;
	pxyMaster.setProxy(	WagonMasterCode1, wagonClass,CM_Carrier.firstInstance, 450,60000, 15000);
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	
	
	// ****** ADD AND PLACE CONTAINERS ON WAGONS
	create allTrackedItems transient;
	ti := self.createContainer(TiCode, "2200", "GB1",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),true);
	allTrackedItems.add(ti);
	
	// ***** ATTACH WAGON TO TRAIN
	wagon := self.addWagonToTrainOption2(train, wagonMaster, allTrackedItems,false);
	self.assertNotNullMsg(wagon,"Couldn't create a wagon");
	
	// ***** ADD TRAIN USER EVENT
	self.addTrainUserEvent(train, eventType.type);
	self.updateTrainEvent(train, eventType.type, now);	//test event update
	
	// ****** FINAL CHECKING
	
	//was a transaction created?
	self.assertTrueMsg((train.allTransactions.size &gt; 0), "no transaction created");
	
	//Train User Event created ?
	foreach trans in train.allTransactions do
		if trans.type = eventType.type then
			foundTransaction := true;
		endif;
	endforeach;
	self.assertTrueMsg(foundTransaction,"No Train User Event transaction on train");
	
	//finished clean up
	self.deleteRailArea(RailAreaId);	
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	self.deleteTrain(TrainCode,null);
	wagonMaster := self.getRoot.allWagonMasters[WagonMasterCode1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	self.deleteContainer(TiCode);
	
	
epilog
	if allTrackedItems &lt;&gt; null then
		allTrackedItems.purge();
		delete allTrackedItems;
	endif;
	delete pxyMaster;
	
	//Event is a system wide setting, should delete it so it doesn't hang around
	//unfortunately when this is deleted the event type is removed off train.  need to do some code verification
	self.deleteEventType(CM_EventType.TRAIN_EVENT,EventName);
end;</source>
    </JadeMethod>
    <JadeMethod name="tTrainRRPs" id="7aca5744-c3e2-46cb-a9bf-9ff5fdb0f4f8">
        <source>tTrainRRPs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2020	jlgndl1	Initial creation	TFS 47004

*/

constants

	TRAIN_CODE : String = "UT-TRNRRP";
	WAGON_CLASS : String = "JX";
	RAIL_AREA_ID : String = "UT_RRP";
	CARGO_ID_PREFIX : String = "URRP47004";
	WAGON_CODE : String = "JX47004";
	BlockStack1 : String = "BS_RRP";
	RailAreaRelease : String = "47004TRN";
	TrainRelease : String = "47004RAIL";
	
vars
	
	train : CM_Train;
	railArea : CM_Rail;
	wagon : CM_Wagon;
	wagonClass : CM_WagonClass;
	allTrackedItems : CM_TIByIdDups;
	ti : CM_TrackedItem;
	wagMoveControl : CMIF_WagonMoveController;
	railLine : CM_RailLine;
	allWagons : CM_WagonArray;
	pxyMaster : CM_WagonMaster;
	wagonMaster : CM_WagonMaster;
	tiId : String;
	index : Integer;
	bs : CM_BlockStack;
	lc : CM_LocationsController;
	railAreaRelease : CM_BulkRelease;
	trainRelease : CM_BulkRelease;
	operator : CM_Operator;
	cmifObjects : ObjectArray;
	intFaceBP : CMIF_BuildPriority;
	railIORake : CM_RailJSInOutRake;
	anObject : Object;
	agent : CM_RailProcessingAgent;
	wleArray : CM_WLEArray;
	wagonArray : CM_WagonArray;
	wle : CM_WorkListEntry;
	railJob : CM_RailJob;
	moveController : CMIF_MoveController;
	tiArray : CM_TIArray;
	
begin
	
	// ****** DELETE EVERYTHING FROM LAST TEST.
	foreach index in 1 to 4 do
		tiId := CARGO_ID_PREFIX  &amp; index.String.padZeros(2);
		self.deleteContainer( tiId );
	endforeach;
	self.deleteReleaseRequest(RailAreaRelease);
	self.deleteReleaseRequest(TrainRelease);
	self.deleteTerminalArea(BlockStack1);
	self.cleanUpRail(WAGON_CODE,"",TRAIN_CODE,RAIL_AREA_ID);
	wagonClass	:=	app.myRoot.allWagonClasses[WAGON_CLASS];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;

	self.setTerminalConfig(ShowRelReqOnRailLoadList, true);
	
	//add blockstack and cargo
	
	self.opts.purge;
	bs := self.addBlockStack(BlockStack1, 20, null);
	lc := bs.allLocationsControllers.first;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	create tiArray transient;
	foreach index in 1 to 4 do
		tiId := CARGO_ID_PREFIX  &amp; index.String.padZeros(2);
		ti := self.addContainer( tiId, operator, "2200", "MT", TI_IMEX_STATUS_STORAGE );
		self.move( ti, lc );
		tiArray.add( ti );
		beginTransaction;
		ti.setIntendedReleaseModeFromStr( TI_TRANSMODE_RAIL_STR );
		commitTransaction;
	endforeach;
	
	// ****** ADD NEW TRAIN
	train	:=	self.addTrain(TRAIN_CODE, null);
	self.assertTrueMsg( train &lt;&gt; null, "No Train created in pre-test" );
	
	//Now add a Rail release for 2 x 20's
	// Create the Release
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", false);
	self.opts.addAssoc("Number",2.Integer);
	self.opts.addAssoc("Operator",operator);
	self.opts.addAssoc("Train",train);
	trainRelease := self.addReleaseByTypeRequestOpts(TrainRelease, BR_TYPE_RAIL, TI_CargoType_Container);
	self.assertTrueMsg( trainRelease &lt;&gt; null, "No Train Release created in pre-test" );
	
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", false);
	self.opts.addAssoc("Number",2.Integer);
	self.opts.addAssoc("Operator",operator);
	railAreaRelease := self.addReleaseByTypeRequestOpts(RailAreaRelease, BR_TYPE_RAIL, TI_CargoType_Container);
	self.assertTrueMsg( railAreaRelease &lt;&gt; null, "No Rail Area Release created in pre-test" );
	
	// ****** ADD NEW RAIL AREA
	railArea	:=	self.addRailArea(RAIL_AREA_ID, 2, 5);  // two lines 5 positions
	self.assertTrueMsg( railArea &lt;&gt; null, "No Rail Area created in pre-test" );
	railLine	:=	railArea.allRailLinesByIndex[1];
	
	// ****** ADD NEW WAGON CLASS AND WAGON, THEN ATTACH TO TRAIN
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4500".Decimal);
	self.opts.addAssoc("MaxPosiHeight", "250".Decimal);
	wagonClass := self.addWagonClass(WAGON_CLASS);
	
	// ****** CREATE MASTER FOR SOME REASON
	create allWagons transient;
	create pxyMaster transient;
	pxyMaster.setProxy(	WAGON_CODE,	//_id : String;
						wagonClass,	//_myWagonClass : CM_WagonClass;
						CM_Carrier.firstInstance(),	//_myCarrier : CM_Carrier;
						450,	//_maxCargoHeight	: Decimal; 
						60000,	//_maxCargoWeight	: Decimal;
						15000);	//_tareWeight	: Decimal
	
	app.myTrxCA.trxCreateWagonMaster(pxyMaster, wagonMaster, app.myPassport);
	
	// ****** ADD PLACE CONTAINERS ON WAGONS
	create allTrackedItems transient;
	wagon := self.addWagonToTrainOption2(train, wagonMaster, allTrackedItems, false);
	allWagons.add(wagon);
	app.myTrxUA.trxUpdateWagonPosition(railLine, wagon, 1, app.myPassport);
	
	// Now set to the Confirm stuff.
	create wagMoveControl transient;
	wagMoveControl.myTargetRailLine	:=	railLine;
	wagMoveControl.targetPosition	:=	1;
	allWagons.copy(wagMoveControl.allWagons);
	self.ignoreTrxWarnings(true);
	
	app.myTrxUA.trxUpdateWagonConfirmToRail(wagMoveControl, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), "Train/Wagon confirm to Rail failed - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	//Assign the releases to rail (same way as from the Release request form)
	
	railIORake := railArea.getRailJSInOutRake( Rail_JSIO_Type_Out );
	self.assertTrueMsg( railIORake &lt;&gt; null, "No Rail Area IO Rake not found in pre-test");
	create cmifObjects transient;
	create intFaceBP transient;
	cmifObjects.add(intFaceBP);
	intFaceBP.mode := 1;
	intFaceBP.allReservesToProcess.add( railAreaRelease.allReserveDetails.first );
	railAreaRelease.setInterfaceBP(intFaceBP, railIORake);
		
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), "Assign of release 'railAreaRelease' to Rail failed - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	if cmifObjects &lt;&gt; null then
		foreach anObject in cmifObjects do
			intFaceBP := anObject.CMIF_BuildPriority;
			
			delete intFaceBP.myProxyRailJob;
			intFaceBP.allCMIFRequests.purge;
			delete intFaceBP;
	
		endforeach;
		cmifObjects.purge;
	endif;
	delete cmifObjects;
	
	create cmifObjects transient;
	create intFaceBP transient;
	cmifObjects.add(intFaceBP);
	intFaceBP.mode := 1;
	intFaceBP.allReservesToProcess.add( trainRelease.allReserveDetails.first );
	trainRelease.setInterfaceBP(intFaceBP, railIORake);
		
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), "Assign of release 'railAreaRelease' to Rail failed - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	if cmifObjects &lt;&gt; null then
		foreach anObject in cmifObjects do
			intFaceBP := anObject.CMIF_BuildPriority;
			
			delete intFaceBP.myProxyRailJob;
			intFaceBP.allCMIFRequests.purge;
			delete intFaceBP;
	
		endforeach;
		cmifObjects.purge;
	endif;
	delete cmifObjects;
	
	//Check Wles have RRPS on them
	
	create wleArray transient;
	foreach railJob in railIORake.railJobs do
		foreach wle in railJob.workListEntries do
			wleArray.add( wle );
			ti := wle.myTrackedItem;
			self.assertTrueMsg( ti &lt;&gt; null, "Rail Job Wle has no assigned tracked item" );
			self.assertTrueMsg( ti.isRRP, "Rail Job Wle tracked item should be an RRP" );
		endforeach;
	endforeach;
	
	//Now assign the WLE with their RRPs to the Wagon.  Same way as from Rail Ops. This should give us assigned load wles. 
	
	create agent transient;
	create wagonArray transient;
	wagonArray.add( wagon );
	agent.initialise( self.getTerminal );
	agent.doAssignReleasesToWagons( wleArray, wagonArray, false, true );
	
	self.assertTrueMsg( not wagon.allLocationsControllersArray.first.allRailWLELoad.isEmpty, "First controller has no assigned wle" );
	
	// assign one of the real TIs to the first wle 
	wle := wleArray.first();
	create moveController transient;
	moveController.setMyTrackedItem( tiArray[1] );
	moveController.setMyToPrimaryLocation( wle.CM_YardWLE.allLocationControllers.first );
	moveController.setMyWorkListEntry(wle);
	moveController.setMoveMode( PLANNING_MODE );
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), "Assign of first TI to WLE linked to RRP failed - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	/////////////////////
	
	//Check LoadList form here by adding debug
	
	///////
	beginTransaction;
	railAreaRelease.setStatus( BR_COMPLETE, false, true );
	commitTransaction;
	self.assertTrueMsg(railAreaRelease.allReserveDetails.first.allRRPs.isEmpty, "All RRPs should be deleted from reserve detailonce the release is marked as complete" );
	
	//Clean up, all has gone well
	foreach index in 1 to 4 do
		tiId := CARGO_ID_PREFIX  &amp; index.String.padZeros(2);
		self.deleteContainer( tiId );
	endforeach;
	self.deleteReleaseRequest(RailAreaRelease);
	self.deleteReleaseRequest(TrainRelease);
	self.deleteTerminalArea(BlockStack1);
	self.cleanUpRail(WAGON_CODE,"",TRAIN_CODE,RAIL_AREA_ID);
	wagonClass	:=	app.myRoot.allWagonClasses[WAGON_CLASS];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	
epilog

	delete pxyMaster;
	delete allWagons;
	delete wagMoveControl;
	delete allTrackedItems;
	if cmifObjects &lt;&gt; null then
		foreach anObject in cmifObjects do
			intFaceBP := anObject.CMIF_BuildPriority;
			
			delete intFaceBP.myProxyRailJob;
			intFaceBP.allCMIFRequests.purge;
			delete intFaceBP;
	
		endforeach;
		cmifObjects.purge;
	endif;
	delete cmifObjects;
	delete agent;
	delete wleArray;
	delete wagonArray;
	delete tiArray;
	delete moveController;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTrainStatusCreate" id="43b078bf-5cf2-4697-9887-c2cf06fe3bd9">
        <source>tTrainStatusCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	navsp1	Initial creation TFS#53619

*/
constants
	TrainCode 				: String 		= "UT-T53619";	
vars
	carrier : CM_Carrier;
	proxyTrain : CM_Train;
	realTrain	: CM_Train;
begin
	carrier := app.myRoot.allCarriers.first.CM_Carrier;
	
	create proxyTrain transient;
	
	proxyTrain.setProxy(TrainCode,
						TrainCode,
						null,
						null,
						null,
						null,
						app.myPassport.myTerminal,
						null,
						TrainStatus_Created,
						null,
						null,
						null,
						null,
						null,
						null,
						null,
						carrier,
						app.actualTimeServer,	
						null,
						null,
						null,
						null,
						null,	
						false,
						null,               
						null);              
						
	
	app.myTrxCA.trxCreateTrain(proxyTrain, realTrain, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(realTrain.status = TrainStatus_Created, "The status of the train does not match the value: " &amp; TrainStatus_Created.asStringJMT());
	self.deleteTrain(TrainCode,null);
epilog
	delete proxyTrain;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTrainStatusUpdate" id="53ebcea5-729b-4820-96bc-d7f8171e0166">
        <source>tTrainStatusUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	navsp1	Initial creation TFS#53619

*/

constants
	TrainCode 				: String 		= "UT-T53619";	
vars
	carrier : CM_Carrier;
	proxyTrain : CM_Train;
	realTrain	: CM_Train;
begin
	carrier := app.myRoot.allCarriers.first.CM_Carrier;
	
	create proxyTrain transient;
	
	proxyTrain.setProxy(TrainCode,
						TrainCode,
						null,
						null,
						null,
						null,
						app.myPassport.myTerminal,
						null,
						TrainStatus_Created,
						null,
						null,
						null,
						null,
						null,
						null,
						null,
						carrier,
						app.actualTimeServer,	
						null,
						null,
						null,
						null,
						null,	
						false,
						null,               
						null);              
						
	
	app.myTrxCA.trxCreateTrain(proxyTrain, realTrain, false, app.myPassport);
	
	
	delete proxyTrain;
	
	proxyTrain := app.createUpdateProxy(realTrain).CM_Train;
	
	proxyTrain.setProxy(TrainCode,
						TrainCode,
						null,
						null,
						null,
						null,
						app.myPassport.myTerminal,
						null,
						TrainStatus_Departed,
						null,
						null,
						null,
						null,
						null,
						null,
						null,
						carrier,
						app.actualTimeServer,	
						null,
						null,
						null,
						null,
						null,	
						false,
						null,               
						null);              
						
	app.myTrxUA.trxUpdateTrain(proxyTrain, false,app.myPassport);
	
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(realTrain.status = TrainStatus_Departed, "The status of the train does not match the value: " &amp; TrainStatus_Departed.asStringJMT());
	self.deleteTrain(TrainCode,null);
epilog
	delete proxyTrain;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateAssignBulkOutRailDefer" id="508eef16-9bd9-4dce-a9d0-f98715a0c020">
        <source>tUpdateAssignBulkOutRailDefer();
/*

Purpose:	to validate deferred update enabled trxUpdateAssignBulkOutRail 		

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2025	navbs1	Initial creation Story MTN-34762: MTN - Add Deferred Updates Rail Operation

*/

constants
	TRAIN_CODE			: String = "T34762_1";
	WagonClassCode		: String = "UTSB";
	WAGON_MASTER_CODE	: String = "UT_WM_S1";
	RAIL_AREA_ID		: String = "UT_JRA1";
	TerminalAreaId		: String = "UTBS1";
	ContainerId			: String = "UUT00000001";
	Container1Id		: String = "UUT00000002";
	RailReleaseId		: String = "UTRRail";
vars
	passportObj		: CM_Passport;
	trainObj		: CM_Train;
	railAreaObj		: CM_Rail;
	wagonObj		: CM_Wagon;
	wagonClass		: CM_WagonClass;
	pxyMasterObj	: CM_WagonMaster;
	wagonMasterObj	: CM_WagonMaster;
	railLineObj		: CM_RailLine;
	allWagons		: CM_WagonArray;
	releaseRequest	: CM_BulkRelease;
	ti,phTI	,ti1	: CM_TrackedItem;
	bs				: CM_BlockStack;	
	tis				: CM_TISet;
	intFaceBP		: CMIF_BuildPriority;
	railIORake 		: CM_RailJSInOutRake;
	tmpReq     		: CMIF_Request;
	wleArray 		: CM_WLEArray;
	editedTrans,
	tiTransToCheck  :CM_TITransaction;
	
begin

	passportObj	:=	app.myPassport;
	// ****** DELETE EVERYTHING FROM LAST TEST.
	wagonClass	:=	app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	self.deleteTrain(TRAIN_CODE,null);
 
	wagonMasterObj	:=	self.getRoot.allWagonMasters[WAGON_MASTER_CODE];
	if wagonMasterObj &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMasterObj);
	endif;

 
	self.deleteRailArea(RAIL_AREA_ID);
	
	deleteTerminalArea(TerminalAreaId);
	
	// ****** ADD NEW TRAIN
	trainObj	:=	self.addTrain(TRAIN_CODE, null);
	self.assertNotNull(trainObj);
	// ****** ADD NEW RAIL AREA
	railAreaObj	:=	self.addRailArea(RAIL_AREA_ID, 4, 5);
	self.assertNotNull(railAreaObj);
	
	railLineObj	:=	railAreaObj.allRailLinesByIndex[1];
	// ****** ADD NEW WAGON CLASS AND WAGON, THEN ATTACH TO TRAIN
	self.opts.purge();
	self.opts.addAssoc( "WagonType", CM_WagonClass.Wagon_Flatcar );
	wagonClass := self.addWagonClass(WagonClassCode);
 
	
	// ****** CREATE WAGON MASTER
	create allWagons transient;
	create pxyMasterObj transient;
	pxyMasterObj.setProxy(	WAGON_MASTER_CODE,	//_id : String;
							wagonClass,	//_myWagonClass : CM_WagonClass;
							CM_Carrier.firstInstance(),	//_myCarrier : CM_Carrier;
							450,	//_maxCargoHeight	: Decimal; 
							60000,	//_maxCargoWeight	: Decimal;
							15000);	//_tareWeight	: Decimal
	pxyMasterObj.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster(pxyMasterObj, wagonMasterObj, passportObj);
	wagonObj	:=	self.addWagonToTrainOption2(trainObj, wagonMasterObj, null, false);
	allWagons.add(wagonObj);
	app.myTrxUA.trxUpdateWagonPosition(railLineObj, wagonObj, 1, passportObj);
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, trainObj, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	// create the bs
	bs := self.addBlockStack(TerminalAreaId, 100, null);
	self.assertNotNull(bs);
	
	// create the containers to add set
	create tis transient;	
	
	// create the containers
	ti := self.addContainer(ContainerId, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.assertNotNull(ti);
	self.move(ti, bs);
	
	ti1 := self.addContainer(Container1Id, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.assertNotNull(ti1);
	self.move(ti1, bs);
	
	// add the tis to the set
	tis.add(ti);
	tis.add(ti1);
		
	// create the release request by type
	self.opts.purge();
	self.deleteReleaseRequest(RailReleaseId);
	releaseRequest := addReleaseByTypeRequest(RailReleaseId, BR_TYPE_RAIL, TI_CargoType_Container, "2200");
	self.assertNotNull(releaseRequest);
	self.assertEqual(releaseRequest.status, BR_ACTIVE);
	
	railIORake := wagonObj.getRailJSInOutRake(false);
	create intFaceBP transient;
	intFaceBP.mode := 1;
	releaseRequest.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	releaseRequest.setInterfaceBP(intFaceBP, railIORake);
	

	app.myTrxUA.trxUpdateAssignBulkOutRail(intFaceBP, railIORake, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	create wleArray transient;
	foreach tmpReq in intFaceBP.allCMIFRequests do
			if tmpReq.myNewJob &lt;&gt; null then
				tmpReq.myNewJob.workListEntries.copyNoDups(wleArray);
			endif;
	endforeach;
	
	self.assertEqualMsg(wleArray.size, 1, "Expected the wle array to ony contain 1 wle");
	phTI := wleArray.first.myTrackedItem;
	
	self.assertNotNull(phTI);
	editedTrans := phTI.getFirstTransOfType(TRANS_TYPE_EDIT);
	
	self.assertNotNull(editedTrans);
	
	//check for this transaction in CM_Terminal::allTITransactions
	tiTransToCheck := self.getTerminal.allTITransactions[editedTrans.dateTime,editedTrans.type];
	assertNotNullMsg(tiTransToCheck,"Edited transaction is not found in terminal TITransactions dictionary");
	assertTrueMsg(tiTransToCheck = editedTrans ,"The Edited transaction is not the expected one");
	
	
epilog
	delete allWagons;
	if intFaceBP &lt;&gt; null then
		intFaceBP.allCMIFRequests.purge;
		delete intFaceBP.myProxyRailJob;
	endif;
	delete intFaceBP;
	delete pxyMasterObj;
	delete tis;
	delete wleArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateWagonFromCMIFDefer" id="c58f9729-c8b5-4ab0-9310-e7df6bcc370d">
        <source>tUpdateWagonFromCMIFDefer();
// cnwrs1
// 
// --------------------------------------------------------------------------------
// Purpose:		:to validate deferred update enabled trxUpdateWagonFromCMIF 
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//19 May 2025	navbs1	Initial creation Story MTN-34762: MTN - Add Deferred Updates Rail Operation
// --------------------------------------------------------------------------------
constants
	TRAIN_CODE			: String = "T34762_2";
	WagonClassCode		: String = "UTMH";
	WAGON_MASTER_CODE	: String = "UT_WM_J1";
	RAIL_AREA_ID		: String = "UT_JRA2";
	CARGO_ID			: String = "UT000000006";
	DO_AUTO_PLAN		: Boolean = true;
vars
	passportObj		: CM_Passport;
	trainObj		: CM_Train;
	railAreaObj		: CM_Rail;
	wagonObj		: CM_Wagon;
	wagonClass		: CM_WagonClass;
	allTrackedItems	: CM_TIByIdDups;
	tiObj,
	tiToCheck		: CM_TrackedItem;
	pxyMasterObj	: CM_WagonMaster;
	wagonMasterObj	: CM_WagonMaster;
	wagUpdControl	: CMIF_WagonUpdateController;
	railLineObj		: CM_RailLine;
	allWagons		: CM_WagonArray;
	railReceive 	: CM_ReceiveRail;
	loadState		: Boolean;
	pxyWagon		: CM_Wagon;
	tiTrans			: CM_TITransaction;
	cargoReceiveEvt,
	evtToCheck 		: CM_EventTransaction;
begin
	passportObj	:=	app.myPassport;
	// ****** DELETE EVERYTHING FROM LAST TEST.
	wagonClass	:=	app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	
	wagonMasterObj	:=	self.getRoot.allWagonMasters[WAGON_MASTER_CODE];
	if wagonMasterObj &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMasterObj);
	endif;
	
	self.deleteTrain(TRAIN_CODE,null);
 

	self.deleteContainer(CARGO_ID);
	self.deleteRailArea(RAIL_AREA_ID);
	// ****** ADD NEW TRAIN
	trainObj	:=	self.addTrain(TRAIN_CODE, null);
	self.assertNotNull(trainObj);
	// ****** ADD NEW RAIL AREA
	railAreaObj	:=	self.addRailArea(RAIL_AREA_ID, 4, 5);
	self.assertNotNull(railAreaObj);
	railLineObj	:=	railAreaObj.allRailLinesByIndex[1];
	// ****** ADD NEW WAGON CLASS AND WAGON, THEN ATTACH TO TRAIN
	self.opts.purge();
	self.opts.addAssoc( "WagonType", CM_WagonClass.Wagon_Flatcar );
	wagonClass := self.addWagonClass(WagonClassCode);
 
	
	// CREATE WAGON MASTER
	create allWagons transient;
	create pxyMasterObj transient;
	pxyMasterObj.setProxy(	WAGON_MASTER_CODE,	//_id : String;
							wagonClass,	//_myWagonClass : CM_WagonClass;
							CM_Carrier.firstInstance(),	//_myCarrier : CM_Carrier;
							450,	//_maxCargoHeight	: Decimal; 
							60000,	//_maxCargoWeight	: Decimal;
							15000);	//_tareWeight	: Decimal
	pxyMasterObj.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster(pxyMasterObj, wagonMasterObj, passportObj);
	// ****** ADD PLACE CONTAINERS ON WAGONS
	self.opts.addAssoc( UTTI_State, 0 );
	create allTrackedItems transient;
	self.opts.addAssoc(UTTI_State,TI_STATE_NOTIFIED ); // Make this a PRENOTE - AKB
	tiObj := self.addContainerOpts(CARGO_ID, "2200", "GENL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	allTrackedItems.add(tiObj);
	wagonObj	:=	self.addWagonToTrainOption2(trainObj, wagonMasterObj, allTrackedItems, false);
	allWagons.add(wagonObj);
	app.myTrxUA.trxUpdateWagonPosition(railLineObj, wagonObj, 1, passportObj);
	// Now set to the Confirm stuff.
 
	create wagUpdControl transient;
	app.cmsBeginLoad(loadState);
	pxyWagon := app.createUpdateProxy(wagonObj).CM_Wagon;
	app.cmsEndLoad(loadState);
	wagUpdControl.setBasicDetails( CMIF_WagonUpdateController.Mode_Update,
		railLineObj,
		trainObj,
		1, 
		true);
	self.ignoreTrxWarnings(true);
	wagUpdControl.confirmWagonInwards := true;
	wagUpdControl.confirmWagonOutwards := false;
	wagUpdControl.myProxyWagon := pxyWagon;
	wagUpdControl.expectedEditionWagon := wagonObj.edition;
	wagUpdControl.doAutoPlan := DO_AUTO_PLAN;
	wagUpdControl.populateFromExistingWagonAddTi( wagonObj, tiObj, 1 );
	app.myTrxUA.trxUpdateWagonFromCMIF(wagUpdControl, false, passportObj);
	self.assertTrueMsg(passportObj.trxCompletedOK(), "Train/Wagon confirm to Rail failed.");
	self.checkTIForTxnOfType(tiObj, TRANS_TYPE_REC_RAIL);
 
	railReceive := tiObj.getTransReceive.CM_ReceiveRail;
 
	
	self.assertTrueMsg( railReceive.locationRail = wagonObj.allLocationsControllersArray.first.getFullId, "Receive locationRail s/be '" &amp; wagonObj.allLocationsControllersArray.first.getFullId &amp; "' is '" &amp; railReceive.locationRail &amp; "'");
	self.assertTrueMsg( railReceive.trainCode = TRAIN_CODE, "Receive locationRail s/be '" &amp; TRAIN_CODE &amp; "' is '" &amp; railReceive.trainCode &amp; "'");	
	self.assertTrueMsg( railReceive.wagonCode = WAGON_MASTER_CODE, "Receive locationRail s/be '" &amp; WAGON_MASTER_CODE &amp; "' is '" &amp; railReceive.wagonCode &amp; "'");
	cargoReceiveEvt :=wagonObj.getLastTransactionOfType(EVT_WagonCargoReceive);
	assertNotNullMsg(cargoReceiveEvt," Expected Cargo Received Wagon event is not found");
	
	//Deferred Update check 
	//check for this transaction in CM_Terminal::allTITransactions
	tiTrans := self.getTerminal.allTITransactions[railReceive.dateTime,railReceive.type];
	assertNotNullMsg(tiTrans,"CM_Move transaction is not found in terminal TITransactions dictionary");
	assertTrueMsg(tiTrans = railReceive ,"The Rail Receive transaction is not the expected one");
	
	//check for trackedItem  in CM_Terminal::allOnsiteTIsByCargoTypeId
	tiToCheck := self.getTerminal.allOnsiteTIsByCargoTypeId[tiObj.myCargoType.id,tiObj.id];
	assertNotNullMsg(tiToCheck,tiObj.id &amp;" TrackedItem is not found in terminal allOnsiteTIsByCargoTypeId dictionary");
	assertTrueMsg(tiObj = tiToCheck ,"The TrackedItem found "&amp;tiObj.id &amp;" is not the expected one");
	
	//check for events  in terminal::allEventsByTypeDateTime
	evtToCheck := self.getTerminal.allEventsByTypeDateTime[EVT_WagonCargoReceive,cargoReceiveEvt.dateTime];
	assertNotNullMsg(evtToCheck,"Cargo Received Wagon event transaction is not found in terminal allEventsByTypeDateTime dictionary");
	assertTrueMsg(cargoReceiveEvt = evtToCheck ,"Cargo Received Wagon event found is not the expected one");
	
	//Finish clean up
	wagonClass	:=	app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	self.deleteTrain(TRAIN_CODE,null);
	wagonMasterObj	:=	self.getRoot.allWagonMasters[WAGON_MASTER_CODE];
	if wagonMasterObj &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMasterObj);
	endif;
	self.deleteContainer(CARGO_ID);
	self.deleteRailArea(RAIL_AREA_ID);
epilog
 
	delete pxyMasterObj;
	delete allWagons;
	if wagUpdControl &lt;&gt; null and wagUpdControl.allWagonPositions.size &gt;0 then
		wagUpdControl.allWagonPositions.purge;
	endif;
	 delete wagUpdControl ;
	delete allTrackedItems;
	app.cmsEndLoad(loadState);
	delete pxyWagon;
end;</source>
    </JadeMethod>
    <JadeMethod name="tWagonClassHookCode" id="ffe7a4d4-4beb-4b6d-bd49-8005a2f7a63d">
        <source>tWagonClassHookCode();
// cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2009	cnwndl1	Initial creation

*/

vars
	hookConstant : Integer;
	hookType : CM_HookType;
	hookCode : CM_HookCode;
	hookLink : CM_HookLink;
	
	returnString1 : String;
	returnString2 : String;
	
	term : CM_Terminal;
	wagonId : String;
	carrier : CM_Carrier;
	
	realHookCode : CM_HookCode;
	proxyHookCode : CM_HookCode;
	cmif : CMIF_HookCode;
	
	loadState : Boolean;
	
	currentHookCode : CM_HookCode;
	restoreProxyHookCode : CM_HookCode;
	restoreCmif : CMIF_HookCode;
	
begin

	hookConstant := HookType_WagonClass;
	self.assertTrueMsg(hookConstant = 10, "Hook Constant not found.");
	
	hookType := app.myRoot.allHookTypes[hookConstant];
	self.assertTrueMsg(hookType &lt;&gt; null, "Hook type object for 'HookType_WagonClass' not found.");
	
	//need to copy the existing hook code set up if there is one (so we can restore it) and create an empty state to test from...
	hookLink := app.myRoot.myWagonClassHookLink;
	if hookLink &lt;&gt; null then
		currentHookCode := app.myRoot.myWagonClassHookCode;
		if currentHookCode &lt;&gt; null then
			//create the hook code cmif object to restore with.
			app.cmsBeginLoad(loadState);
			create restoreCmif transient;
			restoreCmif.code := currentHookCode.code;
			restoreCmif.allLinkObjects.add(CM_Root.firstInstance);
			restoreCmif.myHookType := currentHookCode.myHookType;
			restoreCmif.jadeCode := currentHookCode.allHookCodeHistory.first.jadeCode;
			app.cmsEndLoad(loadState);
			// delete the existing hook code to get to std.
			self.ignoreTrxWarnings(true);
			//app.myPassport.setWarningsIgnored(true);
			app.myTrxDA.trxDeleteHookCode(currentHookCode, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
			self.ignoreTrxWarnings(false);
			//app.myPassport.setWarningsIgnored(false);
		endif; 
	endif;
	
	
	//There should now be no current hookCode linked for this HookType
	hookLink := app.myRoot.myWagonClassHookLink;
	
	if hookLink &lt;&gt; null then
		realHookCode := app.myRoot.myWagonClassHookCode;
	endif;
	
	self.assertTrueMsg(hookLink = null, "There should be no current Wagon Class Hook Link on root.");
	hookCode := app.myRoot.myWagonClassHookCode;
	self.assertTrueMsg(hookCode = null, "There should be no current Wagon Class Hook Code on root.");
	
	term := CM_Terminal.firstInstance;
	wagonId := "ZY12345";
	carrier := CM_Carrier.firstInstance;
	
	//default behaviour is contained in 'app.myRoot.getWagonClassId' which should also be called by the
	//method 'app.myHookAgent.runHookLinkPublic' via 'CM_Root.getWagonClassViaHookCode' if 'app.myRoot.myWagonClassHookCode' is null.
	// default behaviour is to return the aplha characters from the string.
	returnString1 := app.myRoot.getWagonClassId( term, wagonId, carrier );
	self.assertTrueMsg(returnString1 = "ZY", "Default root method call behaviour incorrect. Should be 'ZY' but returned '" &amp; returnString1 &amp; "'");
	
	returnString1 := app.myRoot.getWagonClassViaHookCode( term, wagonId, carrier );
	self.assertTrueMsg(returnString1 = "ZY", "Default 'HookType_WagonClass' call via the hook agent incorrect. Should be 'ZY' but returned '" &amp; returnString1 &amp; "'");
	
	//create a hook code using the default code.
	create proxyHookCode transient;
	create cmif transient;
	cmif.myProxyHookCode := proxyHookCode;
	cmif.code := "Wagon Class Test";
	cmif.allLinkObjects.add(CM_Root.firstInstance);
	cmif.myHookType := hookType;
	
	cmif.jadeCode := "getWagonClassId(_term : CM_Terminal; _wagonId : String; carrier : CM_Carrier):String;" &amp; CrLf &amp; "vars" &amp;
						CrLf &amp; "begin" &amp; CrLf &amp; "return _term.getWagonClassFromId(_wagonId);" &amp; CrLf &amp; "end;";
	app.myTrxCA.trxCreateHookCode(cmif, realHookCode, app.myPassport);

	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	// Root reference should now be populated. (I.e. a hook code should be linked.)
	hookLink := app.myRoot.myWagonClassHookLink;
	self.assertTrueMsg(hookLink &lt;&gt; null, "No Hook Link found on Root for the current 'HookType_WagonClass' Hook code.");
	hookCode := app.myRoot.myWagonClassHookCode;
	self.assertTrueMsg(hookCode &lt;&gt; null, "No Hook Code found on Root for the current 'HookType_WagonClass' Hook code.");
	
	// Does it return the right value still.
	returnString2 := app.myRoot.getWagonClassViaHookCode( term, wagonId, carrier );
	self.assertTrueMsg(returnString2 = returnString1, "Specific hook code using example code incorrect. Should be '" &amp; returnString1 &amp; "' but returned '" &amp; returnString2 &amp; "'");
	
	delete proxyHookCode;
	delete cmif;
	
	// make changes to the hook code.
	app.cmsBeginLoad(loadState);
	proxyHookCode := realHookCode.pxyCreateUpdateProxy();
	create cmif transient;
	cmif.myProxyHookCode := proxyHookCode;
	cmif.code := realHookCode.code;
	cmif.allLinkObjects.add(CM_Root.firstInstance);
	cmif.myHookType := hookType;
	cmif.jadeCode := "getWagonClassId(_term : CM_Terminal; _wagonId : String; carrier : CM_Carrier):String;" &amp; CrLf &amp; "vars" &amp;
						CrLf &amp; "begin" &amp; CrLf &amp; "return _wagonId[3:end];" &amp; CrLf &amp; "end;";
	app.myTrxUA.trxUpdateHookCode(cmif, app.myPassport);

	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	app.doWindowEvents(0);	// refresh cache so the tranisent hook method is rebuilt.
	
	returnString2 := app.myRoot.getWagonClassViaHookCode( term, wagonId, carrier );
	self.assertTrueMsg(returnString2 = "12345", "Specific hook code using example code incorrect. Should be '12345' but returned '" &amp; returnString2 &amp; "'");
		
epilog

	app.cmsEndLoad(loadState);
	delete proxyHookCode;
	delete cmif;
	
	// get rid of created hook code set back to default, of no hook code.
	if realHookCode &lt;&gt; null then
		self.ignoreTrxWarnings(true);
		//app.myPassport.setWarningsIgnored(true);
		app.myTrxDA.trxDeleteHookCode(realHookCode, app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	endif; 
	
	//if restore needed
	if restoreCmif &lt;&gt; null then
		app.cmsBeginLoad(loadState);
		create restoreProxyHookCode transient;
		restoreCmif.myProxyHookCode := restoreProxyHookCode;
		app.myTrxCA.trxCreateHookCode(restoreCmif, currentHookCode, app.myPassport);
		app.cmsEndLoad(loadState);
		delete restoreProxyHookCode;
		delete restoreCmif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tWagonMultiStack" id="6be9e376-0797-4d79-bbdd-7ee7bb2b1410">
        <source>tWagonMultiStack();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 October 2014	cnwndl1	Initial creation	Par 35040
23 Nov 2023		navlw1	ChangeRequest 60874 [Task:60878]: MTN | Jade Upgrade - Unit Test Review
*/

constants

	TrainCode : String = "MS01TRAIN";
	TrainCode2 : String = "MS02TRAIN";
	WagonClassCode : String = "MS";
	RailAreaId : String = "MSRA";
	BlockStack : String = "UT_BS";
	WagonId1 : String = "MS01";
	WagonId2 : String = "MS02";
	WagonId3 : String = "MS03";
	RailReleaseRqId22 : String = "MS012200REQ";
	RailReleaseRqId42 : String = "MS014200REQ";
	
vars

	wagonClassId : String;
	wagonClass : CM_WagonClass;
	id : String;
	allTis : CM_TIArray;
	ti : CM_TrackedItem;
	ti401 : CM_TrackedItem;
	ti402 : CM_TrackedItem;
	ti201 : CM_TrackedItem;
	ti202 : CM_TrackedItem;
	ti203 : CM_TrackedItem;
	ti204 : CM_TrackedItem;
	nullTrain : CM_Train;
	train : CM_Train;
	wagon1 : CM_Wagon;
	wagon2 : CM_Wagon;
	wagon3 : CM_Wagon;
	railArea : CM_Rail;
	railLine : CM_RailLine;
	index : Integer;
	wc : CM_WagonController;
	blockStack : CM_BlockStack;
	location : CM_LocationsController;
	releaseRequest22 : CM_BulkRelease; 
	releaseRequest42 : CM_BulkRelease;
	cmifObjects22 : ObjectArray;
	cmifObjects42 : ObjectArray;
	intFaceBP22 : CMIF_BuildPriority;
	intFaceBP42 : CMIF_BuildPriority;
	cmifRequest22 : CMIF_Request;
	cmifRequest42 : CMIF_Request;
	obj : Object;
	railIORake : CM_RailJSInOutRake;
	agent : CM_RailProcessingAgent;
	wle : CM_WorkListEntry;
	allWleArray : CM_WLEArray;
	wleArray : CM_WLEArray;
	wagonArray : CM_WagonArray;
	wagonMaster : CM_WagonMaster;
	slotNumber : String;
	job : CM_Job;

begin

	beginTransaction;
	self.getTerminal.setConfig(ShowRelReqOnRailLoadList,false);
	commitTransaction;
	
	create allTis transient;

	blockStack := self.getTerminal.allTerminalAreaMastersById.getAtKey( BlockStack ).CM_BlockStack;
	location := blockStack.myLocationsController;
	self.deleteReleaseRequest(RailReleaseRqId22);
	self.deleteReleaseRequest(RailReleaseRqId42);

	//setup rail area
	self.deleteRailArea(RailAreaId);
	
	railArea := self.addRailArea(RailAreaId, 1, 5);
	self.assertTrueMsg(railArea &lt;&gt; null, "Rail Area '" &amp; RailAreaId &amp; "' not created.");
	railLine := railArea.allRailLinesByIndex.first;
	self.assertTrueMsg(railLine &lt;&gt; null, "Rail Line in  '" &amp; RailAreaId &amp; "' not found.");
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	self.assertTrueMsg(railIORake &lt;&gt; null, "Rail Rake not found during setup.");

	// Setup a wagon class that is allowed multi stack cargo ( Flat car with max stack height set to 2 ) and make it an 80 footer.
	// creates and deletes a basic CM_WagonClass object that is the definition of a Box car
	
	wagonClassId := "MS";
	wagonClass := app.myRoot.allWagonClasses[wagonClassId];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	wagonMaster	:=	self.getRoot.allWagonMasters[WagonId1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	wagonMaster	:=	self.getRoot.allWagonMasters[WagonId2];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	wagonMaster	:=	self.getRoot.allWagonMasters[WagonId3];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	
	// delete train after we have deleted the master wagons/wagons
	self.deleteTrain(TrainCode,null); // #60874 Task#60878
		
	self.opts.purge();
	self.opts.addAssoc("WagonType", CM_WagonClass.Wagon_Flatcar);
	self.opts.addAssoc("DeckHeight", "150".Decimal);
	self.opts.addAssoc("LengthInUnits", 8.Integer);
	self.opts.addAssoc("MaxPosiHeight", "540".Decimal);
	self.opts.addAssoc("MaxLoadWeight", "80000".Decimal);
	self.opts.addAssoc("MaxNumInStack", 2.Integer);
	self.opts.addAssoc("Tare", "20000".Decimal);
	wagonClass := addWagonClass(wagonClassId);
	self.assertTrueMsg(wagonClass &lt;&gt; null, "Wagon Class '" &amp; wagonClassId &amp; "' not created.");
	
	
	// Pre-note cargo to a wagon of the multistack class that has not arrived. This creates
	// a pre-note wagon, ensure a mix of 4 x 20's and 2 x 40's ( enough to fill the wagon ). 
	
	self.opts.purge();
	
	id := "UTMS0022001";
	self.deleteContainer(id);
	ti201 := addRailPreNote( WagonId1, WagonClassCode, id );
	self.assertTrueMsg(ti201 &lt;&gt; null, "Container '" &amp; id &amp; "' not created.");
	allTis.add(ti201);
	
	self.opts.purge();
	self.opts.addAssoc( "ISOType", "4200" );
	
	id := "UTMS0042001";
	self.deleteContainer(id);
	ti401 := addRailPreNote( WagonId1, WagonClassCode, id );
	self.assertTrueMsg(ti401 &lt;&gt; null, "Container '" &amp; id &amp; "' not created.");
	allTis.add(ti401);
	
	id := "UTMS0042002";
	self.deleteContainer(id);
	ti402 := addRailPreNote( WagonId1, WagonClassCode, id );
	self.assertTrueMsg(ti402 &lt;&gt; null, "Container '" &amp; id &amp; "' not created.");
	allTis.add(ti402);
	
	self.opts.purge();
	
	id := "UTMS0022002";
	self.deleteContainer(id);
	ti202 := addRailPreNote( WagonId1, WagonClassCode, id );
	self.assertTrueMsg(ti202 &lt;&gt; null, "Container '" &amp; id &amp; "' not created.");
	allTis.add(ti202);
		
	id := "UTMS0022003";
	self.deleteContainer(id);
	ti203 := addRailPreNote( WagonId1, WagonClassCode, id );
	self.assertTrueMsg(ti203 &lt;&gt; null, "Container '" &amp; id &amp; "' not created.");
	allTis.add(ti203);
	
	id := "UTMS0022004";
	self.deleteContainer(id);
	ti204 := addRailPreNote( WagonId1, WagonClassCode, id );
	self.assertTrueMsg(ti204 &lt;&gt; null, "Container '" &amp; id &amp; "' not created.");
	allTis.add(ti204);
	
	
	//Check pre-note wagon exists (on the null train) and has all of the pre-note cargo on board in appropriate positions
	nullTrain := self.getTerminal().getNullTrain;
	self.assertTrueMsg(nullTrain &lt;&gt; null, "Null Train not found.");
	wagon1 := nullTrain.allWagonsByIdInward.getAtKey(WagonId1);
	self.assertTrueMsg(wagon1 &lt;&gt; null, "Pre-note Wagon '" &amp; WagonId1 &amp; "' not created.");
	
	foreach index in 1 to 8 do
		wc := wagon1.allLocationsControllersArray[index];
		if index = 1 then
			self.assertTrueMsg(ti201.myPrimaryActualLocation = wc, "Container '" &amp; ti201.id &amp; "' NOT in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.first  = ti201, "Container '" &amp; ti201.id &amp; "' NOT on the bottom in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(ti203.myPrimaryActualLocation = wc, "Container '" &amp; ti203.id &amp; "' NOT in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.last  = ti203, "Container '" &amp; ti203.id &amp; "' NOT on the top in position " &amp; index.String &amp; ".");
		elseif index = 2 then
			self.assertTrueMsg(wc.allTrackedItems.first  = ti201, "Container '" &amp; ti201.id &amp; "' NOT on the bottom in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.last  = ti203, "Container '" &amp; ti203.id &amp; "' NOT on the top in position " &amp; index.String &amp; ".");
		elseif index = 3 then
			self.assertTrueMsg(ti401.myPrimaryActualLocation = wc, "Container '" &amp; ti401.id &amp; "' NOT in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.first  = ti401, "Container '" &amp; ti401.id &amp; "' NOT on the bottom in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(ti402.myPrimaryActualLocation = wc, "Container '" &amp; ti402.id &amp; "' NOT in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.last  = ti402, "Container '" &amp; ti402.id &amp; "' NOT on the top in position " &amp; index.String &amp; ".");
		elseif index = 4 then
			self.assertTrueMsg(wc.allTrackedItems.first  = ti401, "Container '" &amp; ti401.id &amp; "' NOT on the bottom in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.last  = ti402, "Container '" &amp; ti402.id &amp; "' NOT on the top in position " &amp; index.String &amp; ".");
		elseif index = 5 then
			self.assertTrueMsg(wc.allTrackedItems.first  = ti401, "Container '" &amp; ti401.id &amp; "' NOT on the bottom in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.last  = ti402, "Container '" &amp; ti402.id &amp; "' NOT on the top in position " &amp; index.String &amp; ".");
		elseif index = 6 then
			self.assertTrueMsg(wc.allTrackedItems.first  = ti401, "Container '" &amp; ti401.id &amp; "' NOT on the bottom in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.last  = ti402, "Container '" &amp; ti402.id &amp; "' NOT on the top in position " &amp; index.String &amp; ".");
		elseif index = 7 then
			self.assertTrueMsg(ti202.myPrimaryActualLocation = wc, "Container '" &amp; ti202.id &amp; "' NOT in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.first  = ti202, "Container '" &amp; ti202.id &amp; "' NOT on the bottom in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(ti204.myPrimaryActualLocation = wc, "Container '" &amp; ti204.id &amp; "' NOT in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.last  = ti204, "Container '" &amp; ti204.id &amp; "' NOT on the top in position " &amp; index.String &amp; ".");
		elseif index = 8 then
			self.assertTrueMsg(wc.allTrackedItems.first  = ti202, "Container '" &amp; ti202.id &amp; "' NOT on the bottom in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.last  = ti204, "Container '" &amp; ti204.id &amp; "' NOT on the top in position " &amp; index.String &amp; ".");
		endif;
	endforeach;
	
	//Create a real train, associate the pre-note wagon with it and arrive it.
	self.deleteTrain(TrainCode,null);
	train := self.addTrain(TrainCode,null);
	self.assertTrueMsg(train &lt;&gt; null, "Train '" &amp; TrainCode &amp; "' not created.");
	beginTransaction;
	wagon1.setMyTrain(false, train);
	wagon1.setMyTrain(true, train);
	commitTransaction;
	
	railLine.switchPositions(wagon1, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Wagon set rail position Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, false, app.myPassport);  //in - NO auto planning
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "First Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	// plan and queue to our block stack.
	foreach ti in allTis do
		wle := ti.allWorklistEntries.first;
		if wle &lt;&gt; null then
			beginTransaction;
			wle.setNewLocationTarget(location);
			commitTransaction;
			self.movePlanned(ti,location);
			self.queueWLE(wle);
		endif;
	endforeach;
	
	
	//Work the cargo off.
	self.doOpsFormEquivalentMove( ti204 );
	self.assertTrueMsg(ti204.myPrimaryActualLocation = location, "Container '" &amp; ti204.id &amp; "' in '" &amp; ti204.myPrimaryActualLocation.getFullId &amp; "' should be in " &amp; location.getFullId &amp; ".");
	self.doOpsFormEquivalentMove( ti203 );
	self.assertTrueMsg(ti203.myPrimaryActualLocation = location, "Container '" &amp; ti203.id &amp; "' in '" &amp; ti203.myPrimaryActualLocation.getFullId &amp; "' should be in " &amp; location.getFullId &amp; ".");
	self.doOpsFormEquivalentMove( ti202 );
	self.assertTrueMsg(ti202.myPrimaryActualLocation = location, "Container '" &amp; ti202.id &amp; "' in '" &amp; ti202.myPrimaryActualLocation.getFullId &amp; "' should be in " &amp; location.getFullId &amp; ".");
	self.doOpsFormEquivalentMove( ti201 );
	self.assertTrueMsg(ti201.myPrimaryActualLocation = location, "Container '" &amp; ti201.id &amp; "' in '" &amp; ti201.myPrimaryActualLocation.getFullId &amp; "' should be in " &amp; location.getFullId &amp; ".");
	self.doOpsFormEquivalentMove( ti402 );
	self.assertTrueMsg(ti402.myPrimaryActualLocation = location, "Container '" &amp; ti402.id &amp; "' in '" &amp; ti402.myPrimaryActualLocation.getFullId &amp; "' should be in " &amp; location.getFullId &amp; ".");
	self.doOpsFormEquivalentMove( ti401 );
	self.assertTrueMsg(ti401.myPrimaryActualLocation = location, "Container '" &amp; ti401.id &amp; "' in '" &amp; ti401.myPrimaryActualLocation.getFullId &amp; "' should be in " &amp; location.getFullId &amp; ".");
	
	//Depart the train.
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, true, app.myPassport);  //out
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train1 Confirm OUT Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	
	//Create a 2nd train with 2 more wagons for the class (use different ids to make it more obvious if we have problems) arrive the train empty.
	self.deleteTrain(TrainCode2,null);
	train := self.addTrain(TrainCode2,null);
	self.assertTrueMsg(train &lt;&gt; null, "Train '" &amp; TrainCode2 &amp; "' not created.");
	
	
	wagon2 := self.addWagon(WagonId2, WagonClassCode, train);
	self.assertNotNull(wagon2);
	app.myTrxUA.trxUpdateWagonPosition(railLine, wagon2, 2, app.myPassport);
	
	wagon3 := self.addWagon(WagonId3, WagonClassCode, train);
	self.assertNotNull(wagon3);
	app.myTrxUA.trxUpdateWagonPosition(railLine, wagon3, 3, app.myPassport);
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, false, app.myPassport);  //in
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Second Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	
	
	//Create a rail 'release by type' of  2 x 40 's   and another of 4 x 20's, assign both to rail.
	// create rail release request
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("Number", 4.Integer);
	
	releaseRequest22 := self.addReleaseByTypeRequestOpts(RailReleaseRqId22, BR_TYPE_RAIL, TI_CargoType_Container);
	self.assertNotNull(releaseRequest22);
	
	create cmifObjects22 transient;
	create intFaceBP22 transient;
	cmifObjects22.add(intFaceBP22);
	intFaceBP22.mode := 1;
	releaseRequest22.allReserveDetails.copy(intFaceBP22.allReservesToProcess);
	releaseRequest22.setInterfaceBP(intFaceBP22, railIORake);
	cmifRequest22 := intFaceBP22.allCMIFRequests.first;
	self.assertNotNull(cmifRequest22);
	cmifRequest22.quantityTxt := releaseRequest22.allReserveDetails.first.totalRequested;
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects22, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.opts.purge();
	self.opts.addAssoc("ISOType", "4200");
	self.opts.addAssoc("Number", 2.Integer);
	
	releaseRequest42 := self.addReleaseByTypeRequestOpts(RailReleaseRqId42, BR_TYPE_RAIL, TI_CargoType_Container);
	self.assertNotNull(releaseRequest42);
	
	create cmifObjects42 transient;
	create intFaceBP42 transient;
	cmifObjects42.add(intFaceBP42);
	intFaceBP42.mode := 1;
	releaseRequest42.allReserveDetails.copy(intFaceBP42.allReservesToProcess);
	releaseRequest42.setInterfaceBP(intFaceBP42, railIORake);
	cmifRequest42 := intFaceBP42.allCMIFRequests.first;
	self.assertNotNull(cmifRequest42);
	cmifRequest42.quantityTxt := releaseRequest42.allReserveDetails.first.totalRequested;
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects42, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	//Load the cargo that arrived onto the first train across the wagons so as to leave spaces to allow auto assigning of release
	//to have to find the space not just get the first gap.  (I.e some gaps, some double stacked.)
	
	self.moveTiToWagon(ti204, wagon2.allLocationsControllersArray[1]);
	self.assertNoTrxErrorsOrWarnings();
	self.moveTiToWagon(ti203, wagon2.allLocationsControllersArray[1]);
	self.assertNoTrxErrorsOrWarnings();
	self.moveTiToWagon(ti202, wagon2.allLocationsControllersArray[3]);
	self.assertNoTrxErrorsOrWarnings();
	self.moveTiToWagon(ti402, wagon3.allLocationsControllersArray[3]);
	self.assertNoTrxErrorsOrWarnings();
	self.moveTiToWagon(ti401, wagon3.allLocationsControllersArray[3]);
	self.assertNoTrxErrorsOrWarnings();
	self.moveTiToWagon(ti201, wagon3.allLocationsControllersArray[7]);
	self.assertNoTrxErrorsOrWarnings();
	
	create allWleArray transient;
	railIORake.getAllWLEs( allWleArray );
	//Auto assign both releases ( 40's first )
	create wleArray transient;
	foreach wle in allWleArray do
		if wle.myRequest.myOriginatingBulkRelease = releaseRequest42 then
			wleArray.add( wle );
		endif;
	endforeach;
	
	create wagonArray transient;
	wagonArray.add(wagon2);
	wagonArray.add(wagon3);
	
	create agent transient;
	agent.initialise( self.getTerminal );
	agent.doAssignReleasesToWagons( wleArray, wagonArray, false, false );
	self.assertNoTrxErrorsOrWarnings();
	delete agent;
	
	//now do 20's
	wleArray.clear();
	foreach wle in allWleArray do
		if wle.myRequest.myOriginatingBulkRelease = releaseRequest22 then
			wleArray.add( wle );
		endif;
	endforeach;
	
	create agent transient;
	agent.initialise( self.getTerminal );
	agent.doAssignReleasesToWagons( wleArray, wagonArray, false, false );
	self.assertNoTrxErrorsOrWarnings();
	delete agent;
	
	//Check that release items are in the appropriate places.
	wc := wagon2.allLocationsControllersArray[3];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.first.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest22 then
		self.assertTrueMsg(false, "Release for 20 NOT planned to top in position " &amp; wc.getFullId &amp; ".");
	endif;
	wc := wagon2.allLocationsControllersArray[4];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.first.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest22 then
		self.assertTrueMsg(false, "Release for 20 NOT planned to top in position " &amp; wc.getFullId &amp; ".");
	endif;
	
	wc := wagon2.allLocationsControllersArray[5];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.first.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest42 then
		self.assertTrueMsg(false, "Release for 40 NOT planned to any positions in " &amp; wc.getFullId &amp; ".");
	elseif wc.allRailWLELoad.size &lt; 2 or wc.allRailWLELoad.last.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest42 then
		self.assertTrueMsg(false, "Release for 40 NOT planned to top in position " &amp; wc.getFullId &amp; ".");
	endif;
	wc := wagon2.allLocationsControllersArray[8];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.first.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest42 then
		self.assertTrueMsg(false, "Release for 40 NOT planned to any positions in " &amp; wc.getFullId &amp; ".");
	elseif wc.allRailWLELoad.size &lt; 2 or wc.allRailWLELoad.last.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest42 then
		self.assertTrueMsg(false, "Release for 40 NOT planned to top in position " &amp; wc.getFullId &amp; ".");
	endif;
	
	wc := wagon3.allLocationsControllersArray[1];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.first.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest22 then
		self.assertTrueMsg(false, "Release for 20 NOT planned to any positions in " &amp; wc.getFullId &amp; ".");
	elseif wc.allRailWLELoad.size &lt; 2 or wc.allRailWLELoad.last.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest22 then
		self.assertTrueMsg(false, "Release for 20 NOT planned to top in position " &amp; wc.getFullId &amp; ".");
	endif;
	wc := wagon3.allLocationsControllersArray[2];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.first.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest22 then
		self.assertTrueMsg(false, "Release for 20 NOT planned to any positions in " &amp; wc.getFullId &amp; ".");
	elseif wc.allRailWLELoad.size &lt; 2 or wc.allRailWLELoad.last.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest22 then
		self.assertTrueMsg(false, "Release for 20 NOT planned to top in position " &amp; wc.getFullId &amp; ".");
	endif;
	
	wc := wagon3.allLocationsControllersArray[7];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.first.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest22 then
		self.assertTrueMsg(false, "Release for 20 NOT planned to top in position " &amp; wc.getFullId &amp; ".");
	endif;
	wc := wagon3.allLocationsControllersArray[8];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.first.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest22 then
		self.assertTrueMsg(false, "Release for 20 NOT planned to top in position " &amp; wc.getFullId &amp; ".");
	endif;
	
	
	//Unassign releases.
	app.myTrxUA.trxUnAssignWleFromWagon(allWleArray,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Depart train.
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, true, app.myPassport);  //out
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train2 Confirm OUT Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	
epilog

	beginTransaction;
	self.getTerminal.setConfig(ShowRelReqOnRailLoadList,false);
	commitTransaction;

	delete agent;
	delete wleArray;
	delete wagonArray;
	delete allWleArray;

	//clean up cargo
	//clean up releases
	if cmifObjects22 &lt;&gt; null then
		foreach obj in cmifObjects22 do
			intFaceBP22 := obj.CMIF_BuildPriority;
			
			delete intFaceBP22.myProxyRailJob;
			intFaceBP22.allCMIFRequests.purge;
			delete intFaceBP22;
	
		endforeach;
		cmifObjects22.purge;
	endif;
	delete cmifObjects22;
	
	if cmifObjects42 &lt;&gt; null then
		foreach obj in cmifObjects42 do
			intFaceBP42 := obj.CMIF_BuildPriority;
			
			delete intFaceBP42.myProxyRailJob;
			intFaceBP42.allCMIFRequests.purge;
			delete intFaceBP42;
	
		endforeach;
		cmifObjects42.purge;
	endif;
	delete cmifObjects42;
	
	if allTis &lt;&gt; null and not allTis.isEmpty then
		foreach ti in allTis do
			self.deleteContainer(ti.id);
		endforeach;
	endif;
	delete allTis;
	
	//clean up trains and wagons.
	wagonClass := app.myRoot.allWagonClasses[wagonClassId];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
		wagonMaster	:=	self.getRoot.allWagonMasters[WagonId1];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
		wagonMaster	:=	self.getRoot.allWagonMasters[WagonId2];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
		wagonMaster	:=	self.getRoot.allWagonMasters[WagonId3];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endif;
	
	self.deleteRailArea(RailAreaId);
	self.deleteTrain(TrainCode,null);

end;</source>
    </JadeMethod>
    <JadeMethod name="tWagonRestrictedCargo" id="1f858dde-8d39-44ad-a7d4-41df0389c64c">
        <source>tWagonRestrictedCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 February 2014	cnwndl1	Initial creation	Par 33439 / CCMS POL 2311 - Effectively colour coding that is set on the Wagon Master,
												and cloned to a wagon (visit) when the visist is confirmed on-site.
												The 'colour coding' is permitted to be changed only by a user with the Security Role 'PmWagonCargoRestrict'
												Any attempt to move cargo or assign a wle ( for a release ) that doesn't match the wagons 'Restrictions' (colour coding)
												will raise a warning / error.
												Normal colour coding can co-exist with this, and wil NOT produce an error.
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
constants

	TRAIN_CODE			: String = "UT-TRAINRC";
	WAGON_CLASS			: String = "RC";
	WAGON_MASTER_CODE	: String = "RC001";
	RAIL_AREA_ID		: String = "UT_RC1";
	CARGO_ID1			: String = "UTRC0000001";
	CARGO_ID2			: String = "UTRC0000002";
	ConsignorCode		: String = "UTRCC";
	ReleaseId1			: String = "UTRC1";
	ReleaseId2			: String = "UTRC2";
	
vars

	train : CM_Train;
	railArea : CM_Rail;
	wagon : CM_Wagon;
	wagonClass : CM_WagonClass;
	ti1 : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	pxyWagonMaster : CM_WagonMaster;
	wagonMaster : CM_WagonMaster;
	wagMoveControl : CMIF_WagonMoveController;
	railLine : CM_RailLine;
	allWagons : CM_WagonArray;
	pxyCargoRestrict : CM_CargoRestrictionCriteria;
	cargoRestrict : CM_ObjectMatchCriteria;
	allTransientCriteriaObj	: CMIF_Array;
	cmifCriteria : CMIF_YACriteriaPriority;
	proxyCriteria : CM_YACriteria;
	objSet : ObjectSet;
	consignor : CM_ConsigneeConsignor;
	wagCont : CM_WagonController;
	railReleaseRequest1 : CM_BulkRelease;
	railReleaseRequest2 : CM_BulkRelease;
	obj : Object;
	outRake : CM_RailJSInOutRake;
	intFaceBP1 : CMIF_BuildPriority;
	cmifObjects1 : ObjectArray;
	railJob1 : CM_Job;
	wle1 : CM_WorkListEntry;
	intFaceBP2 : CMIF_BuildPriority;
	cmifObjects2 : ObjectArray;
	railJob2 : CM_Job;
	wle2 : CM_WorkListEntry;
	cm_Error : CM_Error;
	bs : CM_BlockStack;
	moveController	: CMIF_MoveController;
	now : TimeStamp;
	railAllocation : CM_RailAllocation;
	trainSet : CM_TrainSet;

begin

	//clean up before we start
	wagonClass	:=	app.myRoot.allWagonClasses[WAGON_CLASS];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	self.deleteTrain(TRAIN_CODE,null);
	wagonMaster	:=	self.getRoot.allWagonMasters[WAGON_MASTER_CODE];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	self.deleteContainer(CARGO_ID1);
	self.deleteContainer(CARGO_ID2);
	self.deleteRailArea(RAIL_AREA_ID);
	self.deleteReleaseRequest(ReleaseId1);
	self.deleteReleaseRequest(ReleaseId2);
	
	self.deleteTerminalArea("UTBS1");
	bs := addBlockStack("UTBS1", 1, null);
	self.assertTrueMsg( bs &lt;&gt; null, "Block Stack Not created : " &amp; app.myPassport.getAllErrorsWarningsAsString);

	// General set up of a rake, a train, a wagonMaster and a wagon ( but not confirmation in yet )
	train := self.addTrain(TRAIN_CODE, null);
	self.assertNotNull(train);
	railArea :=	self.addRailArea(RAIL_AREA_ID, 4, 5);
	self.assertNotNull(railArea);
	railLine :=	railArea.allRailLinesByIndex[1];
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4500".Decimal);
	self.opts.addAssoc("MaxPosiHeight", "250".Decimal);
	wagonClass := self.addWagonClass(WAGON_CLASS);
	
	create pxyWagonMaster transient;
	pxyWagonMaster.setProxy(	WAGON_MASTER_CODE,	//_id : String;
							wagonClass,	//_myWagonClass : CM_WagonClass;
							CM_Carrier.firstInstance(),	//_myCarrier : CM_Carrier;
							450,	//_maxCargoHeight	: Decimal; 
							60000,	//_maxCargoWeight	: Decimal;
							15000);	//_tareWeight	: Decimal
	
	pxyWagonMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster(pxyWagonMaster, wagonMaster, app.myPassport);
	self.assertTrueMsg( wagonMaster &lt;&gt; null, "Wagon Master Not created : " &amp; app.myPassport.getAllErrorsWarningsAsString);
	
	wagon := self.addWagonToTrainOption2(train, wagonMaster, null, false);
	create allWagons transient;
	allWagons.add(wagon);
	app.myTrxUA.trxUpdateWagonPosition(railLine, wagon, 1, app.myPassport);
	self.assertTrueMsg( wagon &lt;&gt; null, "Wagon Not created : " &amp; app.myPassport.getAllErrorsWarningsAsString);
	
	
	//apply restrictions to wagon master ( prior to confirming wagon in )
	consignor := app.myRoot.allConsigneeConsignors[ConsignorCode];
	now := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	if consignor = null then
		self.opts.purge;
		self.opts.addAssociation(ETRow_License, "3425");
		self.opts.addAssociation(ETRow_LicenseExpiryDate, now.Date.String);
		consignor := self.addConsigneeConsignor(ConsignorCode, "Cargo Restrict Consignor", false, true, false);
	else
		beginTransaction;
		consignor.setPropertyValue( CM_ConsigneeConsignor::isConsignor.name, true);
		consignor.setPropertyValue( CM_ConsigneeConsignor::license.name, "3425");
		consignor.setPropertyValue( CM_ConsigneeConsignor::licenseExpiryDate.name, now.Date);
		commitTransaction;
	endif;
	self.assertTrueMsg( consignor &lt;&gt; null, "Consignor Not found : " &amp; ConsignorCode);
	
	create allTransientCriteriaObj transient;
	
	create objSet transient;
	objSet.add(consignor);
	
	create proxyCriteria transient;
	proxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_Consignor], objSet, null);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(false, true, false);
	allTransientCriteriaObj.add(cmifCriteria);
	create pxyCargoRestrict transient;
	pxyCargoRestrict.setProxy( 	allTransientCriteriaObj,	//_criterias: CMIF_Array;
								1	//_priority : Integer
								);
	pxyCargoRestrict.setProxyBaseData(	Red,	//_colour : Integer;	
										wagonMaster,	//_wagonMaster : CM_WagonMaster;
										self.getTerminal// : CM_Terminal
										);
	
	app.myTrxCA.trxCreateObjMatchCrit( pxyCargoRestrict, cargoRestrict, app.myPassport );
	self.assertTrueMsg( cargoRestrict &lt;&gt; null, "Cargo restriction Not created : " &amp; app.myPassport.getAllErrorsWarningsAsString);
	self.assertTrueMsg( not wagonMaster.allCargoRestrictionCriteria.isEmpty, "Cargo restriction Not associated with Wagon Master" );
	
	//confirm wagon to rake. and check that colour coding off the wagon master has been cloned correctly ( CM_RailAllocation )
	create wagMoveControl transient;
	wagMoveControl.myTargetRailLine := railLine;
	wagMoveControl.targetPosition := 1;
	allWagons.copy(wagMoveControl.allWagons);
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWagonConfirmToRail(wagMoveControl, app.myPassport);
	wagCont := wagon.allLocationsControllersArray[1];
	self.assertTrueMsg( wagCont.myRailAllocation &lt;&gt; null, "Wagon Cargo restriction Not created : " &amp; app.myPassport.getAllErrorsWarningsAsString);
	
	
	// find the outward rake job sheet. 
	foreach obj in railArea.allRailJSInOut do
		if obj.isKindOf(CM_RailJSInOutRake) and obj.CM_RailJSInOutRake.inOut.outwards = Rail_JSIO_Type_Out then
			outRake := obj.CM_RailJSInOutRake;
			break;
		endif;
	endforeach;
	self.assertTrueMsg( outRake &lt;&gt; null, "Outward Rail Job Sheet Not found");
	
	
	// Create a Rail release request that does NOT match the criteria added earlier (i.e. no specified consignor)
	// and assign the release to the rake (i.e. make teh rail jobs).
	// Then attempt to assign wle to the wagon, should raise warning/error
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", false);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	railReleaseRequest1 := addReleaseByTypeRequestOpts(ReleaseId1, BR_TYPE_RAIL, TI_CargoType_Container);
	assertNotNull(railReleaseRequest1);
	
	create cmifObjects1 transient;
	create intFaceBP1 transient;
	cmifObjects1.add(intFaceBP1);
	intFaceBP1.mode := 1; // Mode_add 
	railReleaseRequest1.allReserveDetails.copy(intFaceBP1.allReservesToProcess);
	railReleaseRequest1.setInterfaceBP(intFaceBP1, outRake);
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects1, outRake, app.myPassport);
	self.assertTrueMsg( app.myPassport.noErrors, "Assign of Bulk Relase to Outward Rail failed : " &amp; app.myPassport.getAllErrorsWarningsAsString);
	railJob1 := outRake.railJobs.first();
	self.assertTrueMsg( railJob1 &lt;&gt; null, "Rail Job 1 not created / found for release : " &amp; ReleaseId1);
	wle1 := railJob1.workListEntries.first;
	self.assertTrueMsg( wle1 &lt;&gt; null, "Rail WLE 1 not created / found for Rail Job 1");
	
	app.myTrxUA.trxAssignWleToWagonController(wle1.CM_YardWLE, 1, wagCont, false, app.myPassport);
	self.assertTrueMsg( not app.myPassport.allErrorWarnings.isEmpty, "No error produced when assigning mis-matched release to wagon " &amp; ReleaseId1);
	cm_Error := app.myPassport.allErrorWarnings.first;
	self.assertTrueMsg(cm_Error.errorCode = Wagon_cargo_restrict or cm_Error.errorCode = 84366, "Incorrect error produced s/be 88529 or 84366, but was " &amp; cm_Error.errorCode.String);

	
	//create a Rail release that matches, and attempt assign, should be OK.
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", false);
	self.opts.addAssoc("Grade", CM_MTGrade.lastInstance);		// test 35012
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssociation(UTTI_Consignor, consignor.code);
	railReleaseRequest2 := addReleaseByTypeRequestOpts(ReleaseId2, BR_TYPE_RAIL, TI_CargoType_Container);
	assertNotNull(railReleaseRequest2);
	
	create cmifObjects2 transient;
	create intFaceBP2 transient;
	cmifObjects2.add(intFaceBP2);
	intFaceBP2.mode := 1; // Mode_add 
	railReleaseRequest2.allReserveDetails.copy(intFaceBP2.allReservesToProcess);
	railReleaseRequest2.setInterfaceBP(intFaceBP2, outRake);
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects2, outRake, app.myPassport);
	self.assertTrueMsg( app.myPassport.noErrors, "Assign of Bulk Relase to Outward Rail failed : " &amp; app.myPassport.getAllErrorsWarningsAsString);
	railJob2 := outRake.railJobs.last();
	self.assertTrueMsg( railJob2 &lt;&gt; null, "Rail Job 2 not created / found for release : " &amp; ReleaseId2);
	wle2 := railJob2.workListEntries.first;
	self.assertTrueMsg( wle2 &lt;&gt; null, "Rail WLE 2 not created / found for Rail Job 2");
	
	app.myTrxUA.trxAssignWleToWagonController(wle2.CM_YardWLE, 1, wagCont, false, app.myPassport);
	self.assertTrueMsg( app.myPassport.allErrorWarnings.isEmpty, "Error produced when assigning matched release to wagon for " &amp; ReleaseId2 &amp; " " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	
	//attempt to move cargo that does NOT match to wagon - check not successfull
	self.opts.purge;
	ti1 := self.addContainerOpts( CARGO_ID1, "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.move( ti1, bs );
	
	create moveController transient;
	moveController.setMyTrackedItem( ti1 );
	moveController.setMyToPrimaryLocation(wagCont);
	moveController.setMoveMode(REAL_MODE);
	moveController.isForcedMove := true;

	app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
	self.assertTrueMsg( not app.myPassport.allErrorWarnings.isEmpty, "No error produced when assigning mis-matched cargo to wagon " &amp; ti1.id);
	cm_Error := app.myPassport.allErrorWarnings.first;
	self.assertTrueMsg(cm_Error.errorCode = Wagon_cargo_restrict or cm_Error.errorCode = 84366, "Incorrect error produced s/be 88529 or 84366 ,but was " &amp; cm_Error.errorCode.String);
	delete moveController;
	
	//attempt to move cargo that matches to wagon - check successfull
	self.opts.purge;
	self.opts.addAssociation(UTTI_Consignor, consignor.code);
	ti2 := self.addContainerOpts( CARGO_ID2, "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.move( ti2, bs );
	
	create moveController transient;
	moveController.setMyTrackedItem( ti2 );
	moveController.setMyToPrimaryLocation(wagCont);
	moveController.setMoveMode(REAL_MODE);
	moveController.isForcedMove := true;

	app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
	self.assertTrueMsg( app.myPassport.allErrorWarnings.isEmpty, "Error produced when assigning matched cargo to wagon for " &amp; ti2.id &amp; " " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	// Extensions for par 35164
	// depart the wagon and ensure that the CM_RailAllocation ( which no longer has any wagon controllers associated with it, removes itself.)
	
	railAllocation := wagCont.myRailAllocation;
	self.assertTrueMsg( railAllocation &lt;&gt; null, "Rail Allocation not found.");
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, true, app.myPassport);  //out
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm OUT Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	
	self.assertTrueMsg( global.isValidObject(railAllocation), "Rail Allocation deleted before train departure.");
	
	create trainSet transient;  //everyone loves train sets.
	trainSet.add(train);
	app.myTrxUA.trxUpdateTrainsDeparture(trainSet, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Depart Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	self.assertTrueMsg( not global.isValidObject(railAllocation), "Rail Allocation not deleted during train departure.");
	
epilog

	//clean up
	delete trainSet;
	delete moveController;
	delete pxyCargoRestrict;
	delete pxyWagonMaster;
	delete allWagons;
	delete wagMoveControl;
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	self.deleteContainer(CARGO_ID1);
	self.deleteContainer(CARGO_ID2);
	self.deleteRailArea(RAIL_AREA_ID);
	self.deleteReleaseRequest(ReleaseId1);
	self.deleteReleaseRequest(ReleaseId2);
	if allTransientCriteriaObj &lt;&gt; null and not allTransientCriteriaObj.isEmpty then
		allTransientCriteriaObj.purge;
	endif;
	delete allTransientCriteriaObj;
	delete objSet;
	
	if railJob1 &lt;&gt; null and global.isValidObject(railJob1) then
		self.deleteJob( railJob1 );
	endif;
	if railJob2 &lt;&gt; null and global.isValidObject(railJob2) then
		self.deleteJob( railJob2 );
	endif;
	
	if cmifObjects1 &lt;&gt; null then
		foreach obj in cmifObjects1 do
			intFaceBP1 := obj.CMIF_BuildPriority;		
			delete intFaceBP1.myProxyRailJob;
			intFaceBP1.allCMIFRequests.purge;
			delete intFaceBP1;
		endforeach;
		cmifObjects1.purge;
		delete cmifObjects1;
	endif;
	
	if cmifObjects2 &lt;&gt; null then
		foreach obj in cmifObjects2 do
			intFaceBP2 := obj.CMIF_BuildPriority;		
			delete intFaceBP2.myProxyRailJob;
			intFaceBP2.allCMIFRequests.purge;
			delete intFaceBP2;
		endforeach;
		cmifObjects2.purge;
		delete cmifObjects2;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tWagonTransactions" id="ef1ccc3c-3d87-4a4b-aede-185278e8a201">
        <updating/>
        <source>tWagonTransactions() updating;
// cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 July 2009	cnwndl1	Initial creation

*/
constants

	TrainCode1 : String = "UT-TRAIN1";
	TrainCode2 : String = "UT-TRAIN2";
	RailAreaId : String = "UT_RA45";
	WagonClassId : String = "ZZ";
	WagonId1 : String = "ZZ12345678";
	WagonId2 : String = "ZZ12345679";
	TiId1 : String = "TEST0000001";
	TiId2 : String = "TEST0000002";
	TiId3 : String = "TEST0000003";
	
vars

	terminal : CM_Terminal;
	railArea : CM_Rail;
	railLine : CM_RailLine;
	train1 : CM_Train;
	train2 : CM_Train;
	wagonClass : CM_WagonClass;
	wagonMaster1 : CM_WagonMaster;
	wagonMaster2 : CM_WagonMaster;
	ti1 : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	ti3 : CM_TrackedItem;
	wagon1 : CM_Wagon;
	wagon2 : CM_Wagon;
	trx : CM_EventTransaction;
	wagonController : CM_WagonController;
	moveController : CMIF_MoveController;	
	wagonMoveController : CMIF_WagonMoveController;
	firstWagonInPreMove : CM_Wagon;
	firstWagonInPostMove : CM_Wagon;
	firstWagonOutPreMove : CM_Wagon;
	firstWagonOutPostMove : CM_Wagon;	
	trainSet : CM_TrainSet;
	wagMoveController : CMIF_WagonMoveController;
	nullTi : CM_TrackedItem;
	qdLocnString : String;

begin
	

	terminal := app.myPassport.myTerminal;
	railArea := terminal.allTerminalAreasByTypeId.getAtKey(TA_TYPE_RAILWAY_TRACK,RailAreaId).CM_Rail;

	if railArea = null then	// doesn't get deleted, shouldn't need this bit again....
		railArea := self.addRailArea(RailAreaId, 4, 4);
		self.assertNotNull(railArea);
	endif;
	railLine := railArea.allRailLinesByIndex.first;

	self.opts.addAssoc( UTTI_State, 0 );
	self.opts.addAssoc( UTTI_ReceiptMode, TI_TRANSMODE_RAIL);

	//add train1
	self.deleteTrain(TrainCode1,null);
	train1 := self.addTrain(TrainCode1,null);
	self.assertNotNull(train1);
	
	//crap float around from another test that uses the same train.
	train2 := app.myPassport.myTerminal.allTrainsOnTerminal.getAtKeyGeq(TrainCode2,null);
	foreach wagon2 in train2.allWagonsByIdInward do
		if wagon2.confirmed then
			beginTransaction;
			wagon2.erase(0);
			commitTransaction;
			continue;
		endif; 
		app.myTrxDA.trxDeleteWagon(wagon2, false, app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());	
	endforeach;
	
	//add train2
	self.deleteTrain(TrainCode2,null);
	train2 := self.addTrain(TrainCode2,null);
	self.assertNotNull(train2);

	// Set up the basic wagon class
	wagonClass := app.myRoot.allWagonClasses.getAtKey(WagonClassId);
	if wagonClass = null then
		wagonClass := addWagonClass(WagonClassId);
	endif;
	
	//ensure we have no WagonMaster1
	wagonMaster1 := app.myRoot.allWagonMasters.getAtKey(WagonId1);
	self.deleteWagonMasterAndWagons( wagonMaster1 ); // in case it was already there.
	//ensure we have no WagonMaster2
	wagonMaster2 := app.myRoot.allWagonMasters.getAtKey(WagonId2);
	self.deleteWagonMasterAndWagons( wagonMaster2 ); // in case it was already there.

	//create container1
	self.deleteContainer(TiId1);
	ti1 := self.addContainerOpts(TiId1, "2200", "GB1", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));

	self.ignoreTrxWarnings(true);
	wagon1 := self.addWagonToTrainOption3(	train1, WagonId1, wagonClass, ti1, true, false);
	self.assertTrueMsg(wagon1 &lt;&gt; null, "Wagon1 '" &amp; WagonId1 &amp; "' not created.");
	wagonMaster1 := wagon1.myWagonMaster;
	
	self.assertTrueMsg(wagon1.findTi(ti1.id) &lt;&gt; null, "Container1 '" &amp; ti1.id &amp; "' not on wagon.");

	// check for a 'Wagon create' transaction event (Wagon has been created). 
	trx := wagon1.allTransactions.getAtKeyGeq(EVT_WagonCreate,null);
	self.assertTrueMsg(trx &lt;&gt; null and trx.myEventType.type = EVT_WagonCreate, "'Wagon create' transaction event not found. Global constant = 'EVT_WagonCreate'");
	
	// check for a 'Wagon add' transaction event (Wagon has been added to a train). 
	trx := wagon1.allTransactions.getAtKeyGeq(EVT_WagonAdd,null);
	self.assertTrueMsg(trx &lt;&gt; null and trx.myEventType.type = EVT_WagonAdd, "'Wagon add' transaction event not found. Global constant = 'EVT_WagonAdd'");
	
	// check for a 'Wagon Cargo Confirmed' transaction event (Cargo has been added to a wagon).
	trx := wagon1.allTransactions.getAtKeyGeq(EVT_WagonCargoConfirmed,null);
	self.assertTrueMsg(trx &lt;&gt; null and trx.myEventType.type = EVT_WagonCargoConfirmed, "'Wagon cargo confirmed' transaction event not found. Global constant = 'EVT_WagonCargoConfirmed'");

	//create a second wagoon on the train and add a container to it.
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	wagon2 := self.addWagonToTrainOption3(	train1, WagonId2, wagonClass, nullTi, true, false);
	self.assertTrueMsg(wagon2 &lt;&gt; null, "Wagon2 '" &amp; WagonId2 &amp; "' not created.");
	wagonMaster2 := wagon2.myWagonMaster;
	self.deleteContainer(TiId2);
	ti2 := self.addContainerOpts(TiId2, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	move(ti2, wagon2.allLocationsControllersArray[1]);
	
	// now move the container2 from wagon2 to wagon1, i.e. perform a location move of the cargo. 
	create moveController transient;
	moveController.setMyTrackedItem(ti2);
	moveController.setMyToPrimaryLocation(wagon1.allLocationsControllersArray[3]);
	moveController.setMyOriginatingLocation(wagon2.allLocationsControllersArray[1]);
	moveController.setMoveMode(REAL_MODE);
	moveController.isForcedMove := true;
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete moveController;
	
	// check for a 'Wagon Cargo Moved' transaction event (Cargo has been moved to a wagon).
	trx := wagon1.allTransactions.getAtKeyGeq(EVT_WagonCargoMoved,null);
	self.assertTrueMsg(trx &lt;&gt; null and trx.myEventType.type = EVT_WagonCargoMoved, "'Wagon cargo moved' transaction event not found. Global constant = 'EVT_WagonCargoMoved'");
	
	// Move train to a rail area, then confirm the wagons, i.e. receive the cargo.
	railLine.switchPositions(wagon1, 01);
	railLine.switchPositions(wagon2, 02);
	
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train1, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	// check for a 'Wagon Cargo Receive' transaction event (Cargo has been received from a wagon).
	trx := wagon1.allTransactions.getAtKeyGeq(EVT_WagonCargoReceive,null);
	self.assertTrueMsg(trx &lt;&gt; null and trx.myEventType.type = EVT_WagonCargoReceive, "'Cargo received from a wagon' transaction event not found. Global constant = 'EVT_WagonCargoReceive'");
	qdLocnString := ti1.myPrimaryQueuedLocation.getFullId;	//12 Mar 2021	NDL	TFS 50835
	self.assertTrueMsg(trx.CMEVT_WagonTransaction.sourceLocn = "UT_RA45 01 01", "Cargo '1' Received source location s/be 'UT_RA45 01 01', but is '" &amp; trx.CMEVT_WagonTransaction.sourceLocn&amp; "'" );	//12 Mar 2021	NDL	TFS 50835
	self.assertTrueMsg(trx.CMEVT_WagonTransaction.getSourceTA = railArea, "Not returning correct source location Terminal Area");	//24 Mar 2021	NDL	TFS 50835
	self.assertTrueMsg(trx.CMEVT_WagonTransaction.targetLocn = qdLocnString, "Cargo '1' Received target location s/be '" &amp; qdLocnString&amp; "', but is '" &amp; trx.CMEVT_WagonTransaction.targetLocn&amp; "'" );	//12 Mar 2021	NDL	TFS 50835
	
	// move wagon in train
	firstWagonInPreMove := train1.allWagonsByOrderInward.first;
	firstWagonOutPreMove := train1.allWagonsByOrderOutward.first;
	
	create wagonMoveController transient;
	wagonMoveController.myTargetTrain := train1;
	wagonMoveController.myTargetRailLine := null;
	wagonMoveController.isInwardTarget := true;
	wagonMoveController.targetPosition := 3;
	wagonMoveController.allWagons.add(wagon1);
	
	app.myTrxUA.trxMoveWagons(wagonMoveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete wagonMoveController;

	firstWagonInPostMove := train1.allWagonsByOrderInward.first;
	firstWagonOutPostMove := train1.allWagonsByOrderOutward.first;
	self.assertTrueMsg(firstWagonInPreMove &lt;&gt; firstWagonInPostMove, "Inward 'Wagon move' does not seem to have occurred'");
	self.assertTrueMsg(firstWagonInPreMove &lt;&gt; firstWagonInPostMove, "Outward 'Wagon move' does not seem to have occurred'");

	// check for a 'Wagon Moved' transaction event (Wagon has moved position in train).
	trx := wagon1.allTransactions.getAtKeyGeq(EVT_WagonMoved,null);
	self.assertTrueMsg(trx &lt;&gt; null and trx.myEventType.type = EVT_WagonMoved, "'Wagon moved' transaction event not found. Global constant = 'EVT_WagonMoved'");
	
	// Remove wagon2 from train1 by moving it to train2.
	create wagonMoveController transient;
	wagonMoveController.myTargetTrain := train2;
	wagonMoveController.myTargetRailLine := null;
	wagonMoveController.isInwardTarget := true;
	wagonMoveController.targetPosition := 0;
	wagonMoveController.allWagons.add(wagon2);
	
	app.myTrxUA.trxMoveWagons(wagonMoveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete wagonMoveController;
	
	// check for a 'Wagon Remove' transaction event (Wagon has been removed from train).
	trx := wagon2.allTransactions.getAtKeyGeq(EVT_WagonRemove,null);
	self.assertTrueMsg(trx &lt;&gt; null and trx.myEventType.type = EVT_WagonRemove, "'Wagon removed from train' transaction event not found. Global constant = 'EVT_WagonRemove'");
	
	// add container3 to wagon2
	self.deleteContainer(TiId3);
	ti3 := self.addContainerOpts(TiId3, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertTrueMsg(ti3 &lt;&gt; null, "Container 3 not created");
	move(ti3, ti1.myPrimaryQueuedLocation );	//12 Mar 2021	NDL	TFS 50835
	move(ti3, wagon2.allLocationsControllersArray[1]); 
	
	// make train2 depart (with wagon2)...
	create trainSet transient;
	trainSet.add(train2);
	app.myTrxUA.trxUpdateTrainsDeparture( trainSet, app.myPassport );
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	// check for a 'Wagon Departed' transaction event (Wagon has departed the terminal).
	trx := wagon2.allTransactions.getAtKeyGeq(EVT_WagonDeparted,null);
	self.assertTrueMsg(trx &lt;&gt; null and trx.myEventType.type = EVT_WagonDeparted, "'Wagon departed' transaction event not found. Global constant = 'EVT_WagonDeparted'");
	
	// check for a 'Wagon Cargo Release' transaction event (Cargo has been released to a wagon).
	trx := wagon2.allTransactions.getAtKeyGeq(EVT_WagonCargoRelease,null);
	self.assertTrueMsg(trx &lt;&gt; null and trx.myEventType.type = EVT_WagonCargoRelease, "'Wagon cargo released' transaction event not found. Global constant = 'EVT_WagonCargoRelease'");
	
	self.assertTrueMsg(trx.CMEVT_WagonTransaction.sourceLocn = qdLocnString, "Cargo '3' Received source location s/be '" &amp; qdLocnString &amp; "', but is '" &amp; trx.CMEVT_WagonTransaction.sourceLocn&amp; "'" );	//12 Mar 2021	NDL	TFS 50835
	self.assertTrueMsg(trx.CMEVT_WagonTransaction.targetLocn = "UT_RA45 01", "Cargo '3' Received target location s/be 'UT_RA45 01', but is '" &amp; trx.CMEVT_WagonTransaction.targetLocn&amp; "'" );	//12 Mar 2021	NDL	TFS 50835
	self.assertTrueMsg(trx.CMEVT_WagonTransaction.getTargetTA = railArea, "Not returning correct target location Terminal Area");	//24 Mar 2021	NDL	TFS 50835
	
	
	// Return wagon2 to the terminal ( possibly from GOAS or GOAF...)
	create wagMoveController transient;
	wagMoveController.myTargetRailLine := railArea.allRailLinesByIndex.last;
	wagMoveController.targetPosition := 1;
	wagMoveController.allWagons.add( wagon2 );
	wagMoveController.doAutoPlanOfCargo := false;
	wagMoveController.returnWagon := true;

	app.myTrxUA.trxUpdateWagonReturn(wagMoveController,  app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	// check for a 'WagonReturned' transaction event (Wagon returned to terminal)
	trx := wagon2.allTransactions.getAtKeyGeq(EVT_WagonReturned,null);
	self.assertTrueMsg(trx &lt;&gt; null and trx.myEventType.type = EVT_WagonReturned, "'Wagon returned' transaction event not found. Global constant = 'EVT_WagonReturned'");
	
	//25 Feb 2021	NDL	TFS 50835
	self.assertTrueMsg( ti1.getMyWagonReceive &lt;&gt; null, "Failed to derive the IN ward wagon for rail received cargo");
	self.assertTrueMsg( ti1.getMyTrainReceive &lt;&gt; null, "Failed to derive the IN ward train for rail received cargo");
	self.assertTrueMsg( ti3.getMyWagonRelease &lt;&gt; null, "Failed to derive the OUT ward wagon for rail released cargo");
	self.assertTrueMsg( ti3.getMyTrainRelease &lt;&gt; null, "Failed to derive the OUT ward train for rail released cargo");
	
epilog

	delete moveController;
	delete wagonMoveController;
	delete trainSet;
	delete wagMoveController;

	//delete containers
	self.deleteContainer(TiId1);
	self.deleteContainer(TiId2);
	self.deleteContainer(TiId3);
	
	self.deleteWagonMasterAndWagons( wagonMaster1 );
	self.deleteWagonMasterAndWagons( wagonMaster2 );
	
	self.deleteWagonClassAndWagons(wagonClass);
	
	self.deleteTrain(TrainCode1,null);
	self.deleteTrain(TrainCode2,null);
		
end;</source>
    </JadeMethod>
    <JadeMethod name="tWellcarAdditionalTests" id="4cf828c2-8f4f-4128-a019-4011a24c5642">
        <source>tWellcarAdditionalTests();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/02/2016	cnwmh5	Initial creation	
//22 Nov 2016 cnwrs1	Par 37738 TFS 2949 incorrect UPSP rail location being displayed
*/

constants

	TrainCode : String = "WL01ATRAIN";
	WagonClassCode : String = "WLA";
	RailAreaId : String = "WLRAA";
	BlockStack : String = "UT_BS6";
	WagonId1 : String = "WL01A";
	
vars

	wagonClass 					: CM_WagonClass;
	ti 							: CM_TrackedItem;
	ti201 						: CM_TrackedItem;
	ti201A 						: CM_TrackedItem;
	nullTrain 					: CM_Train;
	train 						: CM_Train;
	wagon1 						: CM_Wagon;
	railArea 					: CM_Rail;
	railLine 					: CM_RailLine;
	blockStack 					: CM_BlockStack;
	location 					: CM_LocationsController;
	obj 						: Object;
	railIORake 					: CM_RailJSInOutRake;
	agent 						: CM_RailProcessingAgent;
	wle 						: CM_WorkListEntry;
	wagonMaster 				: CM_WagonMaster;

	allTis 						: CM_TIArray;
	allWleArray 				: CM_WLEArray;
	wleArray 					: CM_WLEArray;
	wagonArray 					: CM_WagonArray;
	
	wagonClassId 				: String;
	id 							: String;

begin

	create allTis transient;

	//blockStack := self.getTerminal.allTerminalAreaMastersById.getAtKey( BlockStack ).CM_BlockStack;
	blockStack := self.addBlockStack(BlockStack, 999, null);
	self.assertNotNull(blockStack);
	location := blockStack.myLocationsController;

	//clean up trains and wagons.
	wagonClassId := WagonClassCode;
	wagonClass := app.myRoot.allWagonClasses[wagonClassId];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
		wagonMaster	:=	self.getRoot.allWagonMasters[WagonId1];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endif;
	
	// Set up rail area
	self.deleteRailArea(RailAreaId);
	self.deleteTrain(TrainCode,null);
	
	railArea := self.addRailArea(RailAreaId, 1, 5);
	self.assertTrueMsg(railArea &lt;&gt; null, "Rail Area '" &amp; RailAreaId &amp; "' not created.");
	railLine := railArea.allRailLinesByIndex.first;
	self.assertTrueMsg(railLine &lt;&gt; null, "Rail Line in  '" &amp; RailAreaId &amp; "' not found.");
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	self.assertTrueMsg(railIORake &lt;&gt; null, "Rail Rake not found during setup.");
	
	self.opts.purge();
	self.opts.addAssoc("WagonType", CM_WagonClass.Wagon_Wellcar);
	self.opts.addAssoc("LengthInUnits", 8.Integer);
	self.opts.addAssoc("MaxNumInStack", 2.Integer);
	self.opts.addAssoc("WellDeckHeight", "150".Decimal);
	self.opts.addAssoc("WellMaxCargoHeight", "540".Decimal);
	self.opts.addAssoc("WellCargoWeight", "80000".Decimal);
	self.opts.addAssoc("WellTare", "20000".Decimal);
	self.opts.addAssoc("WellLength", "2000".Decimal);
	self.opts.addAssoc("WellWidth", "300".Decimal);
	self.opts.addAssoc("TierIds", "BA".String);

	wagonClass := addWagonClass(wagonClassId);
	self.assertTrueMsg(wagonClass &lt;&gt; null, "Wagon Class '" &amp; wagonClassId &amp; "' not created.");
	
	// Pre-note cargo to a wagon of the wellcar class that has not arrived. This creates
	// a pre-note wagon, ensure a mix of 4 x 20's and 1 x 40 and 1 x 53 ( enough to fill the wagon ).
	// add the prenotes in an order that forces the finding of the next available position to need to reject some positions due to not enough space or 
	// bridging wells etc.

	id := "UTWLAA22001";
	self.deleteContainer(id);
	self.opts.purge();
	self.opts.addAssoc("ISOType", "4200");
	ti201 := addRailPreNote( WagonId1, WagonClassCode, id );
	self.assertTrueMsg(ti201 &lt;&gt; null, "Container '" &amp; id &amp; "' not created.");
	allTis.add(ti201);
	
	//Check pre-note wagon exists (on the null train) and has all of the pre-note cargo on board in appropriate positions
	nullTrain := self.getTerminal().getNullTrain;
	self.assertTrueMsg(nullTrain &lt;&gt; null, "Null Train not found.");
	wagon1 := nullTrain.allWagonsByIdInward.getAtKey(WagonId1);
	self.assertTrueMsg(wagon1 &lt;&gt; null, "Pre-note Wagon '" &amp; WagonId1 &amp; "' not created.");
	
	//Create a real train, associate the pre-note wagon with it and arrive it.
	self.deleteTrain(TrainCode,null);
	train := self.addTrain(TrainCode,null);
	self.assertTrueMsg(train &lt;&gt; null, "Train '" &amp; TrainCode &amp; "' not created.");
	beginTransaction;
	wagon1.setMyTrain(false, train);
	wagon1.setMyTrain(true, train);
	commitTransaction;
		
	railLine.switchPositions(wagon1, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Wagon set rail position Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, false, app.myPassport);  //in - NO auto planning
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "First Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	///*
	// plan and queue al of teh cargo to our block stack.
	foreach ti in allTis do
		wle := ti.allWorklistEntries.first;
		if wle &lt;&gt; null then
			beginTransaction;
			wle.setNewLocationTarget(location);
			commitTransaction;
			self.movePlanned(ti,location);
			self.queueWLE(wle);
		endif;
	endforeach;
	
	id := "UTWLAA22002";
	self.deleteContainer(id);
	ti201A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "2200", "GENL", TI_IMEX_STATUS_IMPORT, 
		blockStack.allLocationsControllers.first);
	self.assertNotNull(ti201A);
	self.deleteStops(ti201A);	
	
	self.setTerminalConfig(RailDisallowOutwardQueue, true);
	self.planQueueTiToWagon(ti201A, wagon1.allLocationsControllers.first, QUEUE_MODE);
	
	id := "UTWLAA22003";
	self.deleteContainer(id);
	ti201A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "2200", "GENL", TI_IMEX_STATUS_IMPORT, 
		blockStack.allLocationsControllers.first);
	self.assertNotNull(ti201A);
	self.deleteStops(ti201A);
	
	self.setTerminalConfig(RailDisallowOutwardQueue, false);
	self.planQueueTiToWagon(ti201A, wagon1.allLocationsControllers.first, QUEUE_MODE);
	
	self.unqueueTI(ti);
	
	id := "UTWLAA22004";
	self.deleteContainer(id);
	ti201A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "2200", "GENL", TI_IMEX_STATUS_IMPORT, 
		blockStack.allLocationsControllers.first);
	self.assertNotNull(ti201A);
	self.deleteStops(ti201A);	
	
	//self.clearExpectedTrxErrors();
	//self.expectedTrxErrors.add(Cargo_that_locat_not_queue_WAG);	
	self.opts.purge();
	self.opts.addAssoc("ExpectErrors",true);
	self.setTerminalConfig(RailDisallowOutwardQueue, true);
	self.planQueueTiToWagon(ti201A, wagon1.allLocationsControllers.first, QUEUE_MODE);
	self.assertTrueMsg( not ti201A.myPrimaryQueuedLocation = wagon1.allLocationsControllers.first, ti201A.id &amp; " Should have got warnings to stop the queuing");
	
	
	id := "UTWLAA22005";
	self.deleteContainer(id);
	ti201A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "2200", "GENL", TI_IMEX_STATUS_IMPORT, 
		blockStack.allLocationsControllers.first);
	self.assertNotNull(ti201A);
	self.deleteStops(ti201A);
	
	self.setTerminalConfig(RailDisallowOutwardQueue, false);
	self.planQueueTiToWagon(ti201A, wagon1.allLocationsControllers.first, QUEUE_MODE);
	
	//finished clean up
	wagonClassId := WagonClassCode;
	wagonClass := app.myRoot.allWagonClasses[wagonClassId];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
		wagonMaster	:=	self.getRoot.allWagonMasters[WagonId1];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endif;
	self.deleteRailArea(RailAreaId);
	self.deleteTrain(TrainCode,null);
	id := "UTWLAA22001";
	self.deleteContainer(id);
	self.deleteTrain(TrainCode,null);
	id := "UTWLAA22002";
	self.deleteContainer(id);
	id := "UTWLAA22003";
	self.deleteContainer(id);
	id := "UTWLAA22004";
	self.deleteContainer(id);	
	id := "UTWLAA22005";
	self.deleteContainer(id);
	
epilog

	delete agent;
	delete wleArray;
	delete wagonArray;
	delete allWleArray;
	
	delete allTis;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tWellcarAdditionalTests2" id="bb8d813a-d620-4a9f-a9e6-ca65b528b88c">
        <source>tWellcarAdditionalTests2();
//
//16 Nov 2016 cnwrs1	Par 37738 TFS 2949 incorrect UPSP rail location being displayed
//
// plan/que 8 2200's onto a wagon that has an inward 2200 queued off, check the first containers in each location are on the bottom and the second is on the top 
//
constants
	TrainCode : String = "WL01ATRAIN";
	WagonClassCode : String = "WLA";
	RailAreaId : String = "WLRAA";
	BlockStack : String = "UT_BS6";
	WagonId1 : String = "WL01A";
vars
	wagonClass 					: CM_WagonClass;
	ti 							: CM_TrackedItem;
	ti201 						: CM_TrackedItem;
	ti202A 						: CM_TrackedItem;
	ti203A 						: CM_TrackedItem;
	ti204A 						: CM_TrackedItem;
	ti205A 						: CM_TrackedItem;
	ti212A 						: CM_TrackedItem;
	ti213A 						: CM_TrackedItem;
	ti214A 						: CM_TrackedItem;
	ti215A 						: CM_TrackedItem;
//	ti201A 						: CM_TrackedItem;
	nullTrain 					: CM_Train;
	train 						: CM_Train;
	wagon1 						: CM_Wagon;
	railArea 					: CM_Rail;
	railLine 					: CM_RailLine;
	blockStack 					: CM_BlockStack;
	location 					: CM_LocationsController;
	obj 						: Object;
	railIORake 					: CM_RailJSInOutRake;
	agent 						: CM_RailProcessingAgent;
	wle 						: CM_WorkListEntry;
	wagonMaster 				: CM_WagonMaster;
	allTis 						: CM_TIArray;
	allWleArray 				: CM_WLEArray;
	wleArray 					: CM_WLEArray;
	wagonArray 					: CM_WagonArray;
	wagonClassId 				: String;
	id 							: String;
//	locationStr : String;
begin
	
	self.setTerminalConfig(RailDefaultWCIdFormat, Rail_UPSP_Int);
	self.setTerminalConfig(RailDisallowOutwardQueue, true);

	create allTis transient;

	//blockStack := self.getTerminal.allTerminalAreaMastersById.getAtKey( BlockStack ).CM_BlockStack;
	blockStack := self.addBlockStack(BlockStack, 999, null);
	self.assertNotNull(blockStack);
	location := blockStack.myLocationsController;

	//clean up trains and wagons.
	wagonClassId := WagonClassCode;
	wagonClass := app.myRoot.allWagonClasses[wagonClassId];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
		wagonMaster	:=	self.getRoot.allWagonMasters[WagonId1];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endif;
	
	// Set up rail area
	self.deleteRailArea(RailAreaId);
	self.deleteTrain(TrainCode,null);
	
	railArea := self.addRailArea(RailAreaId, 1, 5);
	self.assertTrueMsg(railArea &lt;&gt; null, "Rail Area '" &amp; RailAreaId &amp; "' not created.");
	railLine := railArea.allRailLinesByIndex.first;
	self.assertTrueMsg(railLine &lt;&gt; null, "Rail Line in  '" &amp; RailAreaId &amp; "' not found.");
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	self.assertTrueMsg(railIORake &lt;&gt; null, "Rail Rake not found during setup.");
	
	self.opts.purge();
	self.opts.addAssoc("WagonType", CM_WagonClass.Wagon_Wellcar);
	self.opts.addAssoc("LengthInUnits", 8.Integer);
	self.opts.addAssoc("MaxNumInStack", 2.Integer);
	self.opts.addAssoc("WellDeckHeight", "150".Decimal);
	self.opts.addAssoc("WellMaxCargoHeight", "540".Decimal);
	self.opts.addAssoc("WellCargoWeight", "80000".Decimal);
	self.opts.addAssoc("WellTare", "20000".Decimal);
	self.opts.addAssoc("WellLength", "2000".Decimal);
	self.opts.addAssoc("WellWidth", "300".Decimal);
	self.opts.addAssoc("TierIds", "BT".String);

	wagonClass := addWagonClass(wagonClassId);
	self.assertTrueMsg(wagonClass &lt;&gt; null, "Wagon Class '" &amp; wagonClassId &amp; "' not created.");
	
	// Pre-note cargo to a wagon of the wellcar class that has not arrived. This creates
	// a pre-note wagon, ensure a mix of 4 x 20's and 1 x 40 and 1 x 53 ( enough to fill the wagon ).
	// add the prenotes in an order that forces the finding of the next available position to need to reject some positions due to not enough space or 
	// bridging wells etc.

	id := "UTWLAA22001";
	self.deleteContainer(id);
	self.opts.purge();
	self.opts.addAssoc("ISOType", "4200");
	ti201 := addRailPreNote( WagonId1, WagonClassCode, id );
	self.assertTrueMsg(ti201 &lt;&gt; null, "Container '" &amp; id &amp; "' not created.");
	allTis.add(ti201);
	
	//Check pre-note wagon exists (on the null train) and has all of the pre-note cargo on board in appropriate positions
	nullTrain := self.getTerminal().getNullTrain;
	self.assertTrueMsg(nullTrain &lt;&gt; null, "Null Train not found.");
	wagon1 := nullTrain.allWagonsByIdInward.getAtKey(WagonId1);
	self.assertTrueMsg(wagon1 &lt;&gt; null, "Pre-note Wagon '" &amp; WagonId1 &amp; "' not created.");
	
	//Create a real train, associate the pre-note wagon with it and arrive it.
	self.deleteTrain(TrainCode,null);
	train := self.addTrain(TrainCode,null);
	self.assertTrueMsg(train &lt;&gt; null, "Train '" &amp; TrainCode &amp; "' not created.");
	beginTransaction;
	wagon1.setMyTrain(false, train);
	wagon1.setMyTrain(true, train);
	commitTransaction;
		
	railLine.switchPositions(wagon1, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Wagon set rail position Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, false, app.myPassport);  //in - NO auto planning
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "First Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	///*
	// plan and queue al of the cargo to our block stack.
	foreach ti in allTis do
		wle := ti.allWorklistEntries.first;
		if wle &lt;&gt; null then
			beginTransaction;
			wle.setNewLocationTarget(location);
			commitTransaction;
			self.movePlanned(ti,location);
			self.queueWLE(wle);
		endif;
	endforeach;
	
	id := "UTWLAA22002";
	self.deleteContainer(id);
	ti202A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "2200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti202A);
	self.deleteStops(ti202A);	
	self.planQueueTiToWagon(ti202A, wagon1.allLocationsControllers["A1"], PLANNING_MODE);
	self.queueWLE(ti202A.allWorklistEntries.first);

	id := "UTWLAA22012";
	self.deleteContainer(id);
	ti212A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "2200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti212A);
	self.deleteStops(ti212A);	
	self.planQueueTiToWagon(ti212A, wagon1.allLocationsControllers["A1"], PLANNING_MODE);
	self.queueWLE(ti212A.allWorklistEntries.first);

	id := "UTWLAA22003";
	self.deleteContainer(id);
	ti203A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "2200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti203A);
	self.deleteStops(ti203A);
	self.planQueueTiToWagon(ti203A, wagon1.allLocationsControllers['B1'], PLANNING_MODE);
	self.queueWLE(ti203A.allWorklistEntries.first);
	
	id := "UTWLAA22013";
	self.deleteContainer(id);
	ti213A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "2200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti213A);
	self.deleteStops(ti213A);
	self.planQueueTiToWagon(ti213A, wagon1.allLocationsControllers['B1'], PLANNING_MODE);
	self.queueWLE(ti213A.allWorklistEntries.first);
	
//	self.doOpsFormEquivalentMove(ti201);
//	self.assertTrueMsg(ti201.myPrimaryActualLocation = location, "Container '" &amp; ti201.id &amp; "' in '" &amp; ti201.myPrimaryActualLocation.getFullId &amp; "' should be in " &amp; location.getFullId &amp; ".[L1]");
//	self.unqueueTI(ti);
	
	id := "UTWLAA22004";
	self.deleteContainer(id);
	ti204A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "2200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti204A);
	self.deleteStops(ti204A);	
	self.planQueueTiToWagon(ti204A, wagon1.allLocationsControllers['A3'], PLANNING_MODE);
	self.queueWLE(ti204A.allWorklistEntries.first);
	
	id := "UTWLAA22014";
	self.deleteContainer(id);
	ti214A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "2200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti214A);
	self.deleteStops(ti214A);	
	self.planQueueTiToWagon(ti214A, wagon1.allLocationsControllers['A3'], PLANNING_MODE);
	self.queueWLE(ti214A.allWorklistEntries.first);
	
	id := "UTWLAA22005";
	self.deleteContainer(id);
	ti205A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "2200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti205A);
	self.deleteStops(ti205A);
	self.planQueueTiToWagon(ti205A, wagon1.allLocationsControllers['B3'], PLANNING_MODE);
	self.queueWLE(ti205A.allWorklistEntries.first);

	id := "UTWLAA22015";
	self.deleteContainer(id);
	ti215A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "2200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti215A);
	self.deleteStops(ti215A);
	self.planQueueTiToWagon(ti215A, wagon1.allLocationsControllers['B3'], PLANNING_MODE);
	self.queueWLE(ti215A.allWorklistEntries.first);
	

	self.assertTrueMsg(ti202A.myPrimaryQueuedLocation.getFullIdTI(ti202A) = "WL01A A B1", "Container '" &amp; ti202A.id &amp; "' in '" &amp; ti202A.myPrimaryQueuedLocation.getFullIdTI(ti202A) &amp; "' should be in " &amp; "WL01A A B1");
	self.assertTrueMsg(ti203A.myPrimaryQueuedLocation.getFullIdTI(ti203A) = "WL01A B B1", "Container '" &amp; ti203A.id &amp; "' in '" &amp; ti203A.myPrimaryQueuedLocation.getFullIdTI(ti203A) &amp; "' should be in " &amp; "WL01A B B1");
	self.assertTrueMsg(ti204A.myPrimaryQueuedLocation.getFullIdTI(ti204A) = "WL01A A B2", "Container '" &amp; ti204A.id &amp; "' in '" &amp; ti204A.myPrimaryQueuedLocation.getFullIdTI(ti204A) &amp; "' should be in " &amp; "WL01A A B2");
	self.assertTrueMsg(ti205A.myPrimaryQueuedLocation.getFullIdTI(ti205A) = "WL01A B B2", "Container '" &amp; ti205A.id &amp; "' in '" &amp; ti205A.myPrimaryQueuedLocation.getFullIdTI(ti205A) &amp; "' should be in " &amp; "WL01A B B2");
	self.assertTrueMsg(ti212A.myPrimaryQueuedLocation.getFullIdTI(ti212A) = "WL01A A T1", "Container '" &amp; ti212A.id &amp; "' in '" &amp; ti212A.myPrimaryQueuedLocation.getFullIdTI(ti212A) &amp; "' should be in " &amp; "WL01A A T1");
	self.assertTrueMsg(ti213A.myPrimaryQueuedLocation.getFullIdTI(ti213A) = "WL01A B T1", "Container '" &amp; ti213A.id &amp; "' in '" &amp; ti213A.myPrimaryQueuedLocation.getFullIdTI(ti213A) &amp; "' should be in " &amp; "WL01A B T1");
	self.assertTrueMsg(ti214A.myPrimaryQueuedLocation.getFullIdTI(ti214A) = "WL01A A T2", "Container '" &amp; ti214A.id &amp; "' in '" &amp; ti214A.myPrimaryQueuedLocation.getFullIdTI(ti214A) &amp; "' should be in " &amp; "WL01A A T2");
	self.assertTrueMsg(ti215A.myPrimaryQueuedLocation.getFullIdTI(ti215A) = "WL01A B T2", "Container '" &amp; ti215A.id &amp; "' in '" &amp; ti215A.myPrimaryQueuedLocation.getFullIdTI(ti215A) &amp; "' should be in " &amp; "WL01A B T2");

	//finished clecan up
	wagonClassId := WagonClassCode;
	wagonClass := app.myRoot.allWagonClasses[wagonClassId];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
		wagonMaster	:=	self.getRoot.allWagonMasters[WagonId1];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endif;
	self.deleteRailArea(RailAreaId);
	self.deleteTrain(TrainCode,null);
	id := "UTWLAA22001";
	self.deleteContainer(id);
	self.deleteTrain(TrainCode,null);
	id := "UTWLAA22002";
	self.deleteContainer(id);
	id := "UTWLAA22012";
	self.deleteContainer(id);
	id := "UTWLAA22003";
	self.deleteContainer(id);
	id := "UTWLAA22013";
	self.deleteContainer(id);
	id := "UTWLAA22004";
	self.deleteContainer(id);
	id := "UTWLAA22014";
	self.deleteContainer(id);
	id := "UTWLAA22005";
	self.deleteContainer(id);
	id := "UTWLAA22015";
	self.deleteContainer(id);
	
epilog
	delete agent;
	delete wleArray;
	delete wagonArray;
	delete allWleArray;
	delete allTis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tWellcarAdditionalTests3" id="99999b2e-2b7e-4459-95a1-182159e0c8bf">
        <source>tWellcarAdditionalTests3();
//
//21 Nov 2016 cnwrs1	Par 37738 TFS 2949 incorrect location being displayed
//
// plan/que 4 2200's and 2 40's onto a wagon that has no inward ti, check the first containers in each location are on the bottom and the second is on the top 
//
constants
	TrainCode : String = "WL01ATRAIN";
	WagonClassCode : String = "WLA";
	RailAreaId : String = "WLRAA";
	BlockStack : String = "UT_BS6";
	WagonId1 : String = "WL01A";
vars
	wagonClass 					: CM_WagonClass;
	ti 							: CM_TrackedItem;
	ti201 						: CM_TrackedItem;
	ti202A 						: CM_TrackedItem;
	ti203A 						: CM_TrackedItem;
	ti204A 						: CM_TrackedItem;
	ti205A 						: CM_TrackedItem;
	ti212A 						: CM_TrackedItem;
//	ti213A 						: CM_TrackedItem;
	ti214A 						: CM_TrackedItem;
//	ti215A 						: CM_TrackedItem;
//	ti201A 						: CM_TrackedItem;
	nullTrain 					: CM_Train;
	train 						: CM_Train;
	wagon1 						: CM_Wagon;
	railArea 					: CM_Rail;
	railLine 					: CM_RailLine;
	blockStack 					: CM_BlockStack;
	location 					: CM_LocationsController;
	obj 						: Object;
	railIORake 					: CM_RailJSInOutRake;
	agent 						: CM_RailProcessingAgent;
	wle 						: CM_WorkListEntry;
	wagonMaster 				: CM_WagonMaster;
	allTis 						: CM_TIArray;
	allWleArray 				: CM_WLEArray;
	wleArray 					: CM_WLEArray;
	wagonArray 					: CM_WagonArray;
	wagonClassId 				: String;
	id 							: String;
begin

	self.setTerminalConfig(RailDefaultWCIdFormat, Rail_UPSP_Int);
	self.setTerminalConfig(RailDisallowOutwardQueue, true);

	create allTis transient;

	//blockStack := self.getTerminal.allTerminalAreaMastersById.getAtKey( BlockStack ).CM_BlockStack;
	blockStack := self.addBlockStack(BlockStack, 999, null);
	self.assertNotNull(blockStack);
	location := blockStack.myLocationsController;

	//clean up trains and wagons.
	wagonClassId := WagonClassCode;
	wagonClass := app.myRoot.allWagonClasses[wagonClassId];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
		wagonMaster	:=	self.getRoot.allWagonMasters[WagonId1];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endif;
	
	// Set up rail area
	self.deleteRailArea(RailAreaId);
	self.deleteTrain(TrainCode,null);
	
	railArea := self.addRailArea(RailAreaId, 1, 5);
	self.assertTrueMsg(railArea &lt;&gt; null, "Rail Area '" &amp; RailAreaId &amp; "' not created.");
	railLine := railArea.allRailLinesByIndex.first;
	self.assertTrueMsg(railLine &lt;&gt; null, "Rail Line in  '" &amp; RailAreaId &amp; "' not found.");
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	self.assertTrueMsg(railIORake &lt;&gt; null, "Rail Rake not found during setup.");
	
	self.opts.purge();
	self.opts.addAssoc("WagonType", CM_WagonClass.Wagon_Wellcar);
	self.opts.addAssoc("LengthInUnits", 8.Integer);
	self.opts.addAssoc("MaxNumInStack", 2.Integer);
	self.opts.addAssoc("WellDeckHeight", "150".Decimal);
	self.opts.addAssoc("WellMaxCargoHeight", "540".Decimal);
	self.opts.addAssoc("WellCargoWeight", "80000".Decimal);
	self.opts.addAssoc("WellTare", "20000".Decimal);
	self.opts.addAssoc("WellLength", "2000".Decimal);
	self.opts.addAssoc("WellWidth", "300".Decimal);
	self.opts.addAssoc("TierIds", "BT".String);

	wagonClass := addWagonClass(wagonClassId);
	self.assertTrueMsg(wagonClass &lt;&gt; null, "Wagon Class '" &amp; wagonClassId &amp; "' not created.");
	
	// Pre-note cargo to a wagon of the wellcar class that has not arrived. This creates
	// a pre-note wagon, ensure a mix of 4 x 20's and 1 x 40 and 1 x 53 ( enough to fill the wagon ).
	// add the prenotes in an order that forces the finding of the next available position to need to reject some positions due to not enough space or 
	// bridging wells etc.

	id := "UTWLAA22001";
	self.deleteContainer(id);
	self.opts.purge();
	self.opts.addAssoc("ISOType", "4200");
	ti201 := addRailPreNote( WagonId1, WagonClassCode, id );
	self.assertTrueMsg(ti201 &lt;&gt; null, "Container '" &amp; id &amp; "' not created.");
	allTis.add(ti201);
	
	//Check pre-note wagon exists (on the null train) and has all of the pre-note cargo on board in appropriate positions
	nullTrain := self.getTerminal().getNullTrain;
	self.assertTrueMsg(nullTrain &lt;&gt; null, "Null Train not found.");
	wagon1 := nullTrain.allWagonsByIdInward.getAtKey(WagonId1);
	self.assertTrueMsg(wagon1 &lt;&gt; null, "Pre-note Wagon '" &amp; WagonId1 &amp; "' not created.");
	
	//Create a real train, associate the pre-note wagon with it and arrive it.
	self.deleteTrain(TrainCode,null);
	train := self.addTrain(TrainCode,null);
	self.assertTrueMsg(train &lt;&gt; null, "Train '" &amp; TrainCode &amp; "' not created.");
	beginTransaction;
	wagon1.setMyTrain(false, train);
	wagon1.setMyTrain(true, train);
	commitTransaction;
		
	railLine.switchPositions(wagon1, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Wagon set rail position Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, false, app.myPassport);  //in - NO auto planning
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "First Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	///*
	// plan and queue al of the cargo to our block stack.
	foreach ti in allTis do
		wle := ti.allWorklistEntries.first;
		if wle &lt;&gt; null then
			beginTransaction;
			wle.setNewLocationTarget(location);
			commitTransaction;
			self.movePlanned(ti,location);
			self.queueWLE(wle);
		endif;
	endforeach;
//	self.doOpsFormEquivalentMove(ti201);
//	self.assertTrueMsg(ti201.myPrimaryActualLocation = location, "Container '" &amp; ti201.id &amp; "' in '" &amp; ti201.myPrimaryActualLocation.getFullId &amp; "' should be in " &amp; location.getFullId &amp; ".[L1]");
	
	id := "UTWLAA22002";
	self.deleteContainer(id);
	ti202A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "2200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti202A);
	self.deleteStops(ti202A);	
	self.planQueueTiToWagon(ti202A, wagon1.allLocationsControllers['A1'], PLANNING_MODE);
	self.queueWLE(ti202A.allWorklistEntries.first);

	id := "UTWLAA22003";
	self.deleteContainer(id);
	ti203A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "2200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti203A);
	self.deleteStops(ti203A);
	self.planQueueTiToWagon(ti203A, wagon1.allLocationsControllers['A3'], PLANNING_MODE);
	self.queueWLE(ti203A.allWorklistEntries.first);

	id := "UTWLAA22012";
	self.deleteContainer(id);
	ti212A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "4200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti212A);
	self.deleteStops(ti212A);	
	self.planQueueTiToWagon(ti212A, wagon1.allLocationsControllers['A1'], PLANNING_MODE);
	self.queueWLE(ti212A.allWorklistEntries.first);

	id := "UTWLAA22014";
	self.deleteContainer(id);
	ti214A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "4200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti214A);
	self.deleteStops(ti214A);	
	self.planQueueTiToWagon(ti214A, wagon1.allLocationsControllers['B1'], PLANNING_MODE);
	self.queueWLE(ti214A.allWorklistEntries.first);
	
	id := "UTWLAA22004";
	self.deleteContainer(id);
	ti204A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "2200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti204A);
	self.deleteStops(ti204A);	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Not_stack_smallOnLarge);	
	self.planQueueTiToWagon(ti204A, wagon1.allLocationsControllers['B1'], PLANNING_MODE);
//	self.queueWLE(ti204A.allWorklistEntries.first);

	id := "UTWLAA22005";
	self.deleteContainer(id);
	ti205A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "2200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti205A);
	self.deleteStops(ti205A);
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Not_stack_smallOnLarge);	
	self.planQueueTiToWagon(ti205A, wagon1.allLocationsControllers['B3'], PLANNING_MODE);
//	self.queueWLE(ti205A.allWorklistEntries.first);


	self.assertTrueMsg(ti202A.myPrimaryQueuedLocation.getFullIdTI(ti202A) = "WL01A A B1", "Container '" &amp; ti202A.id &amp; "' in '" &amp; ti202A.myPrimaryQueuedLocation.getFullIdTI(ti202A) &amp; "' should be in " &amp; "WL01A A B1");
	self.assertTrueMsg(ti203A.myPrimaryQueuedLocation.getFullIdTI(ti203A) = "WL01A A B2", "Container '" &amp; ti203A.id &amp; "' in '" &amp; ti203A.myPrimaryQueuedLocation.getFullIdTI(ti203A) &amp; "' should be in " &amp; "WL01A A B2");
	self.assertTrueMsg(ti204A.myPrimaryQueuedLocation = null, "Container '" &amp; ti204A.id &amp; "' in '" &amp;  "' should be in " &amp; "null");
	self.assertTrueMsg(ti205A.myPrimaryQueuedLocation = null, "Container '" &amp; ti205A.id &amp; "' in '" &amp;  "' should be in " &amp; "null");
	self.assertTrueMsg(ti212A.myPrimaryQueuedLocation.getFullIdTI(ti212A) = "WL01A A T1", "Container '" &amp; ti212A.id &amp; "' in '" &amp; ti212A.myPrimaryQueuedLocation.getFullIdTI(ti212A) &amp; "' should be in " &amp; "WL01A A T1");
//	self.assertTrueMsg(ti213A.myPrimaryQueuedLocation.getFullIdTI(ti213A) = "WL01A B T1", "Container '" &amp; ti213A.id &amp; "' in '" &amp; ti213A.myPrimaryQueuedLocation.getFullIdTI(ti213A) &amp; "' should be in " &amp; "WL01A B T1");
	self.assertTrueMsg(ti214A.myPrimaryQueuedLocation.getFullIdTI(ti214A) = "WL01A B B1", "Container '" &amp; ti214A.id &amp; "' in '" &amp; ti214A.myPrimaryQueuedLocation.getFullIdTI(ti214A) &amp; "' should be in " &amp; "WL01A B B1");
//	self.assertTrueMsg(ti215A.myPrimaryQueuedLocation.getFullIdTI(ti215A) = "WL01A B T2", "Container '" &amp; ti215A.id &amp; "' in '" &amp; ti215A.myPrimaryQueuedLocation.getFullIdTI(ti215A) &amp; "' should be in " &amp; "WL01A B T2");
//	self.planQueueTiToWagon(ti205A, wagon1.allLocationsControllers['B3'], QUEUE_MODE);

	//finished clean up
	wagonClassId := WagonClassCode;
	wagonClass := app.myRoot.allWagonClasses[wagonClassId];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
		wagonMaster	:=	self.getRoot.allWagonMasters[WagonId1];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endif;
	self.deleteRailArea(RailAreaId);
	self.deleteTrain(TrainCode,null);
	id := "UTWLAA22001";
	self.deleteContainer(id);
	self.deleteTrain(TrainCode,null);
	train := self.addTrain(TrainCode,null);
	id := "UTWLAA22002";
	self.deleteContainer(id);
	id := "UTWLAA22003";
	self.deleteContainer(id);
	id := "UTWLAA22012";
	self.deleteContainer(id);
	id := "UTWLAA22014";
	self.deleteContainer(id);
	id := "UTWLAA22004";
	self.deleteContainer(id);
	id := "UTWLAA22005";
	self.deleteContainer(id);
	
epilog
	delete agent;
	delete wleArray;
	delete wagonArray;
	delete allWleArray;
	delete allTis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tWellcarAdditionalTests4" id="84dede82-a196-4ede-962d-5cf6257914ed">
        <source>tWellcarAdditionalTests4();
//
//16 Nov 2016 cnwrs1	Par 37738 TFS 2949 incorrect location being displayed
//
// plan/que 4 4200's onto a wagon that has an inward 4200 queued off, check the first containers in each location are on the bottom and the second is on the top 
//
constants
	TrainCode : String = "WL01ATRAIN";
	WagonClassCode : String = "WLA";
	RailAreaId : String = "WLRAA";
	BlockStack : String = "UT_BS6";
	WagonId1 : String = "WL01A";
vars
	wagonClass 					: CM_WagonClass;
	ti 							: CM_TrackedItem;
	ti201 						: CM_TrackedItem;
	ti202A 						: CM_TrackedItem;
	ti203A 						: CM_TrackedItem;
//	ti204A 						: CM_TrackedItem;
//	ti205A 						: CM_TrackedItem;
	ti212A 						: CM_TrackedItem;
	ti213A 						: CM_TrackedItem;
//	ti214A 						: CM_TrackedItem;
//	ti215A 						: CM_TrackedItem;
//	ti201A 						: CM_TrackedItem;
	nullTrain 					: CM_Train;
	train 						: CM_Train;
	wagon1 						: CM_Wagon;
	railArea 					: CM_Rail;
	railLine 					: CM_RailLine;
	blockStack 					: CM_BlockStack;
	location 					: CM_LocationsController;
	obj 						: Object;
	railIORake 					: CM_RailJSInOutRake;
	agent 						: CM_RailProcessingAgent;
	wle 						: CM_WorkListEntry;
	wagonMaster 				: CM_WagonMaster;
	allTis 						: CM_TIArray;
	allWleArray 				: CM_WLEArray;
	wleArray 					: CM_WLEArray;
	wagonArray 					: CM_WagonArray;
	wagonClassId 				: String;
	id 							: String;
begin
	
	self.setTerminalConfig(RailDefaultWCIdFormat, Rail_UPSP_Int);
	self.setTerminalConfig(RailDisallowOutwardQueue, true);

	create allTis transient;

	//blockStack := self.getTerminal.allTerminalAreaMastersById.getAtKey( BlockStack ).CM_BlockStack;
	blockStack := self.addBlockStack(BlockStack, 999, null);
	self.assertNotNull(blockStack);
	location := blockStack.myLocationsController;

	//clean up trains and wagons.
	wagonClassId := WagonClassCode;
	wagonClass := app.myRoot.allWagonClasses[wagonClassId];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
		wagonMaster	:=	self.getRoot.allWagonMasters[WagonId1];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endif;
	
	// Set up rail area
	self.deleteRailArea(RailAreaId);
	self.deleteTrain(TrainCode,null);
	
	railArea := self.addRailArea(RailAreaId, 1, 5);
	self.assertTrueMsg(railArea &lt;&gt; null, "Rail Area '" &amp; RailAreaId &amp; "' not created.");
	railLine := railArea.allRailLinesByIndex.first;
	self.assertTrueMsg(railLine &lt;&gt; null, "Rail Line in  '" &amp; RailAreaId &amp; "' not found.");
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	self.assertTrueMsg(railIORake &lt;&gt; null, "Rail Rake not found during setup.");
	
	self.opts.purge();
	self.opts.addAssoc("WagonType", CM_WagonClass.Wagon_Wellcar);
	self.opts.addAssoc("LengthInUnits", 8.Integer);
	self.opts.addAssoc("MaxNumInStack", 2.Integer);
	self.opts.addAssoc("WellDeckHeight", "150".Decimal);
	self.opts.addAssoc("WellMaxCargoHeight", "540".Decimal);
	self.opts.addAssoc("WellCargoWeight", "80000".Decimal);
	self.opts.addAssoc("WellTare", "20000".Decimal);
	self.opts.addAssoc("WellLength", "2000".Decimal);
	self.opts.addAssoc("WellWidth", "300".Decimal);
	self.opts.addAssoc("TierIds", "BT".String);

	wagonClass := addWagonClass(wagonClassId);
	self.assertTrueMsg(wagonClass &lt;&gt; null, "Wagon Class '" &amp; wagonClassId &amp; "' not created.");
	
	// Pre-note cargo to a wagon of the wellcar class that has not arrived. This creates
	// a pre-note wagon, ensure a mix of 4 x 20's and 1 x 40 and 1 x 53 ( enough to fill the wagon ).
	// add the prenotes in an order that forces the finding of the next available position to need to reject some positions due to not enough space or 
	// bridging wells etc.

	id := "UTWLAA22001";
	self.deleteContainer(id);
	self.opts.purge();
	self.opts.addAssoc("ISOType", "4200");
	ti201 := addRailPreNote( WagonId1, WagonClassCode, id );
	self.assertTrueMsg(ti201 &lt;&gt; null, "Container '" &amp; id &amp; "' not created.");
	allTis.add(ti201);
	
	//Check pre-note wagon exists (on the null train) and has all of the pre-note cargo on board in appropriate positions
	nullTrain := self.getTerminal().getNullTrain;
	self.assertTrueMsg(nullTrain &lt;&gt; null, "Null Train not found.");
	wagon1 := nullTrain.allWagonsByIdInward.getAtKey(WagonId1);
	self.assertTrueMsg(wagon1 &lt;&gt; null, "Pre-note Wagon '" &amp; WagonId1 &amp; "' not created.");
	
	//Create a real train, associate the pre-note wagon with it and arrive it.
	self.deleteTrain(TrainCode,null);
	train := self.addTrain(TrainCode,null);
	self.assertTrueMsg(train &lt;&gt; null, "Train '" &amp; TrainCode &amp; "' not created.");
	beginTransaction;
	wagon1.setMyTrain(false, train);
	wagon1.setMyTrain(true, train);
	commitTransaction;
		
	railLine.switchPositions(wagon1, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Wagon set rail position Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, false, app.myPassport);  //in - NO auto planning
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "First Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	///*
	// plan and queue al of the cargo to our block stack.
	foreach ti in allTis do
		wle := ti.allWorklistEntries.first;
		if wle &lt;&gt; null then
			beginTransaction;
			wle.setNewLocationTarget(location);
			commitTransaction;
			self.movePlanned(ti,location);
			self.queueWLE(wle);
		endif;
	endforeach;
	
	id := "UTWLAA22002";
	self.deleteContainer(id);
	ti202A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "4200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti202A);
	self.deleteStops(ti202A);	
	self.planQueueTiToWagon(ti202A, wagon1.allLocationsControllers['A1'], PLANNING_MODE);
	self.queueWLE(ti202A.allWorklistEntries.first);
	
	id := "UTWLAA22003";
	self.deleteContainer(id);
	ti203A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "4200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti203A);
	self.deleteStops(ti203A);
	self.planQueueTiToWagon(ti203A, wagon1.allLocationsControllers['B1'], PLANNING_MODE);
	self.queueWLE(ti203A.allWorklistEntries.first);
	
//	self.doOpsFormEquivalentMove(ti201);
//	self.assertTrueMsg(ti201.myPrimaryActualLocation = location, "Container '" &amp; ti201.id &amp; "' in '" &amp; ti201.myPrimaryActualLocation.getFullId &amp; "' should be in " &amp; location.getFullId &amp; ".[L1]");
//	self.unqueueTI(ti);
	
	id := "UTWLAA22012";
	self.deleteContainer(id);
	ti212A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "4200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti212A);
	self.deleteStops(ti212A);	
	self.planQueueTiToWagon(ti212A, wagon1.allLocationsControllers['A1'], PLANNING_MODE);
	self.queueWLE(ti212A.allWorklistEntries.first);
	
	id := "UTWLAA22013";
	self.deleteContainer(id);
	ti213A := self.addContainerAtLocation(id, self.getOperator(UT_Profile.P_OPERATOR), "4200", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	self.assertNotNull(ti213A);
	self.deleteStops(ti213A);
	self.planQueueTiToWagon(ti213A, wagon1.allLocationsControllers['B1'], PLANNING_MODE);
	self.queueWLE(ti213A.allWorklistEntries.first);


	self.assertTrueMsg(ti202A.myPrimaryQueuedLocation.getFullIdTI(ti202A) = "WL01A A B1", "Container '" &amp; ti202A.id &amp; "' in '" &amp; ti202A.myPrimaryQueuedLocation.getFullIdTI(ti202A) &amp; "' should be in " &amp; "WL01A A B1");
	self.assertTrueMsg(ti203A.myPrimaryQueuedLocation.getFullIdTI(ti203A) = "WL01A B B1", "Container '" &amp; ti203A.id &amp; "' in '" &amp; ti203A.myPrimaryQueuedLocation.getFullIdTI(ti203A) &amp; "' should be in " &amp; "WL01A B B1");
//	self.assertTrueMsg(ti204A.myPrimaryQueuedLocation.getFullIdTI(ti204A) = "WL01A A B2", "Container '" &amp; ti204A.id &amp; "' in '" &amp; ti204A.myPrimaryQueuedLocation.getFullIdTI(ti204A) &amp; "' should be in " &amp; "WL01A A B2");
//	self.assertTrueMsg(ti205A.myPrimaryQueuedLocation.getFullIdTI(ti205A) = "WL01A B B2", "Container '" &amp; ti205A.id &amp; "' in '" &amp; ti205A.myPrimaryQueuedLocation.getFullIdTI(ti205A) &amp; "' should be in " &amp; "WL01A B B2");
	self.assertTrueMsg(ti212A.myPrimaryQueuedLocation.getFullIdTI(ti212A) = "WL01A A T1", "Container '" &amp; ti212A.id &amp; "' in '" &amp; ti212A.myPrimaryQueuedLocation.getFullIdTI(ti212A) &amp; "' should be in " &amp; "WL01A A T1");
	self.assertTrueMsg(ti213A.myPrimaryQueuedLocation.getFullIdTI(ti213A) = "WL01A B T1", "Container '" &amp; ti213A.id &amp; "' in '" &amp; ti213A.myPrimaryQueuedLocation.getFullIdTI(ti213A) &amp; "' should be in " &amp; "WL01A B T1");
//	self.assertTrueMsg(ti214A.myPrimaryQueuedLocation.getFullIdTI(ti214A) = "WL01A A T2", "Container '" &amp; ti214A.id &amp; "' in '" &amp; ti214A.myPrimaryQueuedLocation.getFullIdTI(ti214A) &amp; "' should be in " &amp; "WL01A A T2");
//	self.assertTrueMsg(ti215A.myPrimaryQueuedLocation.getFullIdTI(ti215A) = "WL01A B T2", "Container '" &amp; ti215A.id &amp; "' in '" &amp; ti215A.myPrimaryQueuedLocation.getFullIdTI(ti215A) &amp; "' should be in " &amp; "WL01A B T2");

//	self.doOpsFormEquivalentMove(ti205A);
//	self.assertTrueMsg(ti205A.myPrimaryActualLocation = location, "Container '" &amp; ti201A.id &amp; "' in '" &amp; ti201A.myPrimaryActualLocation.getFullId &amp; "' should be in " &amp; location.getFullId &amp; ".[L1]");

	//finished clean up
	wagonClassId := WagonClassCode;
	wagonClass := app.myRoot.allWagonClasses[wagonClassId];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
		wagonMaster	:=	self.getRoot.allWagonMasters[WagonId1];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endif;
	self.deleteRailArea(RailAreaId);
	self.deleteTrain(TrainCode,null);
	id := "UTWLAA22001";
	self.deleteContainer(id);
	self.deleteTrain(TrainCode,null);
	id := "UTWLAA22002";
	self.deleteContainer(id);
	id := "UTWLAA22003";
	self.deleteContainer(id);
	id := "UTWLAA22012";
	self.deleteContainer(id);
	id := "UTWLAA22013";
	self.deleteContainer(id);
	
epilog
	delete agent;
	delete wleArray;
	delete wagonArray;
	delete allWleArray;
	delete allTis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tWellcarBaseTest" id="2f39a082-83e6-4bce-be97-b738967d3275">
        <source>tWellcarBaseTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 December 2014	cnwndl1	Initial creation	Par 35346

*/

constants

	TrainCode : String = "WL01TRAIN";
	TrainCode2 : String = "WL02TRAIN";
	WagonClassCode : String = "WL";
	RailAreaId : String = "WLRA";
	BlockStack : String = "UT_BS";
	WagonId1 : String = "WL01";
	WagonId2 : String = "WL02";
	WagonId3 : String = "WL03";
	RailReleaseRqId22 : String = "WLREQ20";
	RailReleaseRqId42 : String = "WLREQ40";
	RailReleaseRqId53 : String = "WLREQ53";
	
vars

	wagonClassId : String;
	wagonClass : CM_WagonClass;
	id : String;
	allTis : CM_TIArray;
	ti : CM_TrackedItem;
	ti401 : CM_TrackedItem;
	ti501 : CM_TrackedItem;
	ti201 : CM_TrackedItem;
	ti202 : CM_TrackedItem;
	ti203 : CM_TrackedItem;
	ti204 : CM_TrackedItem;
	nullTrain : CM_Train;
	train : CM_Train;
	wagon1 : CM_Wagon;
	wagon2 : CM_Wagon;
	wagon3 : CM_Wagon;
	railArea : CM_Rail;
	railLine : CM_RailLine;
	index : Integer;
	wc : CM_WagonController;
	blockStack : CM_BlockStack;
	location : CM_LocationsController;
	releaseRequest22 : CM_BulkRelease; 
	releaseRequest42 : CM_BulkRelease;
	releaseRequest53 : CM_BulkRelease;
	cmifObjects22 : ObjectArray;
	cmifObjects42 : ObjectArray;
	cmifObjects53 : ObjectArray;
	intFaceBP22 : CMIF_BuildPriority;
	intFaceBP42 : CMIF_BuildPriority;
	intFaceBP53 : CMIF_BuildPriority;
	cmifRequest22 : CMIF_Request;
	cmifRequest42 : CMIF_Request;
	cmifRequest53 : CMIF_Request;
	obj : Object;
	railIORake : CM_RailJSInOutRake;
	agent : CM_RailProcessingAgent;
	wle : CM_WorkListEntry;
	allWleArray : CM_WLEArray;
	wleArray : CM_WLEArray;
	wagonArray : CM_WagonArray;
	wagonMaster : CM_WagonMaster;
	slotNumber : String;
	job : CM_Job;
	wagWellDef : CM_WagonWellDefinition;
	locId : String;

begin

	beginTransaction;
	self.getTerminal.setConfig(ShowRelReqOnRailLoadList,false);
	commitTransaction;

	create allTis transient;

	blockStack := self.getTerminal.allTerminalAreaMastersById.getAtKey( BlockStack ).CM_BlockStack;
	location := blockStack.myLocationsController;
	self.deleteReleaseRequest(RailReleaseRqId22);
	self.deleteReleaseRequest(RailReleaseRqId42);
	self.deleteReleaseRequest(RailReleaseRqId53);

	//setup rail area
	self.deleteRailArea(RailAreaId);
	self.deleteTrain(TrainCode,null);
	
	railArea := self.addRailArea(RailAreaId, 1, 5);
	self.assertTrueMsg(railArea &lt;&gt; null, "Rail Area '" &amp; RailAreaId &amp; "' not created.");
	railLine := railArea.allRailLinesByIndex.first;
	self.assertTrueMsg(railLine &lt;&gt; null, "Rail Line in  '" &amp; RailAreaId &amp; "' not found.");
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	self.assertTrueMsg(railIORake &lt;&gt; null, "Rail Rake not found during setup.");

	// Setup a Well car wagon class that is allowed multi stack cargo
	
	wagonClassId := WagonClassCode;
	wagonClass := app.myRoot.allWagonClasses[wagonClassId];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
	endif;
	wagonMaster	:=	self.getRoot.allWagonMasters[WagonId1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	wagonMaster	:=	self.getRoot.allWagonMasters[WagonId2];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	wagonMaster	:=	self.getRoot.allWagonMasters[WagonId3];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
		
	self.opts.purge();
	self.opts.addAssoc("WagonType", CM_WagonClass.Wagon_Wellcar);
	self.opts.addAssoc("LengthInUnits", 8.Integer);
	self.opts.addAssoc("MaxNumInStack", 2.Integer);
	self.opts.addAssoc("WellDeckHeight", "150".Decimal);
	self.opts.addAssoc("WellMaxCargoHeight", "540".Decimal);
	self.opts.addAssoc("WellCargoWeight", "80000".Decimal);
	self.opts.addAssoc("WellTare", "20000".Decimal);
	self.opts.addAssoc("WellLength", "2000".Decimal);
	self.opts.addAssoc("WellWidth", "300".Decimal);
	self.opts.addAssoc("TierIds", "BA".String);

	wagonClass := addWagonClass(wagonClassId);

	self.assertTrueMsg(wagonClass &lt;&gt; null, "Wagon Class '" &amp; wagonClassId &amp; "' not created.");
	wagWellDef := wagonClass.allWagonWellDefArray.first;
	self.assertTrueMsg(wagWellDef &lt;&gt; null, "Wagon Well Defintions not created for '" &amp; wagonClassId &amp; "'");
	self.assertTrueMsg(wagonClass.allWagonWellDefArray.size = 2, "Should be 2 Wagon Well Defintions created for '" &amp; wagonClassId &amp; "'");
	self.assertTrueMsg(wagWellDef.wellId = "A", "Wagon Well Defintion id incorrect '" &amp; wagWellDef.wellId &amp; "' should be 'A'");
	self.assertTrueMsg(wagWellDef.wellLocationIds.first = "1", "Wagon Well first location id incorrect '" &amp; wagWellDef.wellLocationIds.first &amp; "' should be '1'");
	self.assertTrueMsg(wagWellDef.overallLength = 2000, "Wagon Well overall length incorrect '" &amp; wagWellDef.overallLength.String &amp; "' should be '2000'");
	self.assertTrueMsg(wagWellDef.overallWidth = 300, "Wagon Well overall width incorrect '" &amp; wagWellDef.overallWidth.String &amp; "' should be '300'");
	self.assertTrueMsg(wagWellDef.deckHeight = 150, "Wagon Well deck height incorrect '" &amp; wagWellDef.deckHeight.String &amp; "' should be '150'");
	self.assertTrueMsg(wagWellDef.maxCargoHeight = 540, "Wagon Well max cargo height incorrect '" &amp; wagWellDef.maxCargoHeight.String &amp; "' should be '540'");
	self.assertTrueMsg(wagWellDef.maxLoadWeight = 80000, "Wagon Well max cargo weight incorrect '" &amp; wagWellDef.maxLoadWeight.String &amp; "' should be '80000'");
	self.assertTrueMsg(wagWellDef.tareWeight = 20000, "Wagon Well tare weight incorrect '" &amp; wagWellDef.tareWeight.String &amp; "' should be '20000'");
	
	// Pre-note cargo to a wagon of the wellcar class that has not arrived. This creates
	// a pre-note wagon, ensure a mix of 4 x 20's and 1 x 40 and 1 x 53 ( enough to fill the wagon ).
	// add the prenotes in an order that forces the finding of the next available position to need to reject some positions due to not enough space or 
	// bridging wells etc.

	self.opts.purge();
	
	id := "UTWL0022001";
	self.deleteContainer(id);
	ti201 := addRailPreNote( WagonId1, WagonClassCode, id );
	self.assertTrueMsg(ti201 &lt;&gt; null, "Container '" &amp; id &amp; "' not created.");
	allTis.add(ti201);
	
	self.opts.purge();
	self.opts.addAssoc( "ISOType", "4200" );
	
	id := "UTWL0042001";
	self.deleteContainer(id);
	ti401 := addRailPreNote( WagonId1, WagonClassCode, id );
	self.assertTrueMsg(ti401 &lt;&gt; null, "Container '" &amp; id &amp; "' not created.");
	allTis.add(ti401);
	
	self.opts.purge();
	self.opts.addAssoc( "ISOType", "53FT" );
	
	id := "UTWL0053002";
	self.deleteContainer(id);
	ti501 := addRailPreNote( WagonId1, WagonClassCode, id );
	self.assertTrueMsg(ti501 &lt;&gt; null, "Container '" &amp; id &amp; "' not created.");
	allTis.add(ti501);
	
	self.opts.purge();
	
	id := "UTWL0022002";
	self.deleteContainer(id);
	ti202 := addRailPreNote( WagonId1, WagonClassCode, id );
	self.assertTrueMsg(ti202 &lt;&gt; null, "Container '" &amp; id &amp; "' not created.");
	allTis.add(ti202);
		
	id := "UTWL0022003";
	self.deleteContainer(id);
	ti203 := addRailPreNote( WagonId1, WagonClassCode, id );
	self.assertTrueMsg(ti203 &lt;&gt; null, "Container '" &amp; id &amp; "' not created.");
	allTis.add(ti203);
	
	id := "UTWL0022004";
	self.deleteContainer(id);
	ti204 := addRailPreNote( WagonId1, WagonClassCode, id );
	self.assertTrueMsg(ti204 &lt;&gt; null, "Container '" &amp; id &amp; "' not created.");
	allTis.add(ti204);
	
	
	//Check pre-note wagon exists (on the null train) and has all of the pre-note cargo on board in appropriate positions
	nullTrain := self.getTerminal().getNullTrain;
	self.assertTrueMsg(nullTrain &lt;&gt; null, "Null Train not found.");
	wagon1 := nullTrain.allWagonsByIdInward.getAtKey(WagonId1);
	self.assertTrueMsg(wagon1 &lt;&gt; null, "Pre-note Wagon '" &amp; WagonId1 &amp; "' not created.");
	
	foreach index in 1 to 8 do
		wc := wagon1.allLocationsControllersArray[index];
		if index = 1 then
			self.assertTrueMsg(ti201.myPrimaryActualLocation = wc, "Container '" &amp; ti201.id &amp; "' NOT in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.first  = ti201, "Container '" &amp; ti201.id &amp; "' NOT on the bottom in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(ti203.myPrimaryActualLocation = wc, "Container '" &amp; ti203.id &amp; "' NOT in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.last  = ti203, "Container '" &amp; ti203.id &amp; "' NOT on the top in position " &amp; index.String &amp; ".");
		elseif index = 2 then
			self.assertTrueMsg(wc.allTrackedItems.first  = ti201, "Container '" &amp; ti201.id &amp; "' NOT on the bottom in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.last  = ti203, "Container '" &amp; ti203.id &amp; "' NOT on the top in position " &amp; index.String &amp; ".");
		elseif index = 3 then
			self.assertTrueMsg(ti202.myPrimaryActualLocation = wc, "Container '" &amp; ti202.id &amp; "' NOT in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.first  = ti202, "Container '" &amp; ti202.id &amp; "' NOT on the bottom in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(ti204.myPrimaryActualLocation = wc, "Container '" &amp; ti204.id &amp; "' NOT in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.last  = ti204, "Container '" &amp; ti204.id &amp; "' NOT on the top in position " &amp; index.String &amp; ".");
		elseif index = 4 then
			self.assertTrueMsg(wc.allTrackedItems.first  = ti202, "Container '" &amp; ti202.id &amp; "' NOT on the bottom in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.last  = ti204, "Container '" &amp; ti204.id &amp; "' NOT on the top in position " &amp; index.String &amp; ".");
		elseif index = 5 then
			self.assertTrueMsg(ti401.myPrimaryActualLocation = wc, "Container '" &amp; ti401.id &amp; "' NOT in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.first  = ti401, "Container '" &amp; ti401.id &amp; "' NOT on the bottom in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(ti501.myPrimaryActualLocation = wc, "Container '" &amp; ti501.id &amp; "' NOT in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.last  = ti501, "Container '" &amp; ti501.id &amp; "' NOT on the top in position " &amp; index.String &amp; ".");
		elseif index = 6 then
			self.assertTrueMsg(wc.allTrackedItems.first  = ti401, "Container '" &amp; ti401.id &amp; "' NOT on the bottom in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.last  = ti501, "Container '" &amp; ti501.id &amp; "' NOT on the top in position " &amp; index.String &amp; ".");
		elseif index = 7 then
			self.assertTrueMsg(wc.allTrackedItems.first  = ti401, "Container '" &amp; ti401.id &amp; "' NOT on the bottom in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.last  = ti501, "Container '" &amp; ti501.id &amp; "' NOT on the top in position " &amp; index.String &amp; ".");
		elseif index = 8 then
			self.assertTrueMsg(wc.allTrackedItems.first  = ti401, "Container '" &amp; ti401.id &amp; "' NOT on the bottom in position " &amp; index.String &amp; ".");
			self.assertTrueMsg(wc.allTrackedItems.last  = ti501, "Container '" &amp; ti501.id &amp; "' NOT on the top in position " &amp; index.String &amp; ".");
		endif;
	endforeach;
	
	//Create a real train, associate the pre-note wagon with it and arrive it.
	self.deleteTrain(TrainCode,null);
	train := self.addTrain(TrainCode,null);
	self.assertTrueMsg(train &lt;&gt; null, "Train '" &amp; TrainCode &amp; "' not created.");
	beginTransaction;
	wagon1.setMyTrain(false, train);
	wagon1.setMyTrain(true, train);
	commitTransaction;
	
	railLine.switchPositions(wagon1, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Wagon set rail position Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, false, app.myPassport);  //in - NO auto planning
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "First Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	// plan and queue al of teh cargo to our block stack.
	foreach ti in allTis do
		wle := ti.allWorklistEntries.first;
		if wle &lt;&gt; null then
			beginTransaction;
			wle.setNewLocationTarget(location);
			commitTransaction;
			self.movePlanned(ti,location);
			self.queueWLE(wle);
		endif;
	endforeach;
	
	
	//Work the cargo off.
	self.doOpsFormEquivalentMove( ti204 );
	self.assertTrueMsg(ti204.myPrimaryActualLocation = location, "Container '" &amp; ti204.id &amp; "' in '" &amp; ti204.myPrimaryActualLocation.getFullId &amp; "' should be in " &amp; location.getFullId &amp; ".[L1]");
	self.doOpsFormEquivalentMove( ti203 );
	self.assertTrueMsg(ti203.myPrimaryActualLocation = location, "Container '" &amp; ti203.id &amp; "' in '" &amp; ti203.myPrimaryActualLocation.getFullId &amp; "' should be in " &amp; location.getFullId &amp; ".[L2]");
	self.doOpsFormEquivalentMove( ti202 );
	self.assertTrueMsg(ti202.myPrimaryActualLocation = location, "Container '" &amp; ti202.id &amp; "' in '" &amp; ti202.myPrimaryActualLocation.getFullId &amp; "' should be in " &amp; location.getFullId &amp; ".[L3]");
	self.doOpsFormEquivalentMove( ti201 );
	self.assertTrueMsg(ti201.myPrimaryActualLocation = location, "Container '" &amp; ti201.id &amp; "' in '" &amp; ti201.myPrimaryActualLocation.getFullId &amp; "' should be in " &amp; location.getFullId &amp; ".[L4]");
	self.doOpsFormEquivalentMove( ti401 );
	self.assertTrueMsg(ti401.myPrimaryActualLocation = location, "Container '" &amp; ti401.id &amp; "' in '" &amp; ti401.myPrimaryActualLocation.getFullId &amp; "' should be in " &amp; location.getFullId &amp; ".[L5]");
	self.doOpsFormEquivalentMove( ti501 );
	self.assertTrueMsg(ti501.myPrimaryActualLocation = location, "Container '" &amp; ti501.id &amp; "' in '" &amp; ti501.myPrimaryActualLocation.getFullId &amp; "' should be in " &amp; location.getFullId &amp; ".[L6]");
	
	//Depart the train.
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, true, app.myPassport);  //out
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train1 Confirm OUT Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	
	//Create a 2nd train with 2 more wagons for the class (use different ids to make it more obvious if we have problems) arrive the train empty.
	self.deleteTrain(TrainCode2,null);
	train := self.addTrain(TrainCode2,null);
	self.assertTrueMsg(train &lt;&gt; null, "Train '" &amp; TrainCode2 &amp; "' not created.");
	
	
	wagon2 := self.addWagon(WagonId2, WagonClassCode, train);
	self.assertNotNull(wagon2);
	app.myTrxUA.trxUpdateWagonPosition(railLine, wagon2, 2, app.myPassport);
	
	wagon3 := self.addWagon(WagonId3, WagonClassCode, train);
	self.assertNotNull(wagon3);
	app.myTrxUA.trxUpdateWagonPosition(railLine, wagon3, 3, app.myPassport);
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, false, app.myPassport);  //in
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Second Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	
	
	//Create a rail 'release by type's of  1 x 40, 1 x 53  and 4 x 20's, assign all to rail.
	// create the rail release requests and assign them to the rake.
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("Number", 4.Integer);
	
	releaseRequest22 := self.addReleaseByTypeRequestOpts(RailReleaseRqId22, BR_TYPE_RAIL, TI_CargoType_Container);
	self.assertNotNull(releaseRequest22);
	
	create cmifObjects22 transient;
	create intFaceBP22 transient;
	cmifObjects22.add(intFaceBP22);
	intFaceBP22.mode := 1;
	releaseRequest22.allReserveDetails.copy(intFaceBP22.allReservesToProcess);
	releaseRequest22.setInterfaceBP(intFaceBP22, railIORake);
	cmifRequest22 := intFaceBP22.allCMIFRequests.first;
	self.assertNotNull(cmifRequest22);
	cmifRequest22.quantityTxt := releaseRequest22.allReserveDetails.first.totalRequested;
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects22, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.opts.purge();
	self.opts.addAssoc("ISOType", "4200");
	self.opts.addAssoc("Number", 1.Integer);
	
	releaseRequest42 := self.addReleaseByTypeRequestOpts(RailReleaseRqId42, BR_TYPE_RAIL, TI_CargoType_Container);
	self.assertNotNull(releaseRequest42);
	
	create cmifObjects42 transient;
	create intFaceBP42 transient;
	cmifObjects42.add(intFaceBP42);
	intFaceBP42.mode := 1;
	releaseRequest42.allReserveDetails.copy(intFaceBP42.allReservesToProcess);
	releaseRequest42.setInterfaceBP(intFaceBP42, railIORake);
	cmifRequest42 := intFaceBP42.allCMIFRequests.first;
	self.assertNotNull(cmifRequest42);
	cmifRequest42.quantityTxt := releaseRequest42.allReserveDetails.first.totalRequested;
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects42, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.opts.purge();
	self.opts.addAssoc("ISOType", "53FT");
	self.opts.addAssoc("Number", 1.Integer);
	
	releaseRequest53 := self.addReleaseByTypeRequestOpts(RailReleaseRqId53, BR_TYPE_RAIL, TI_CargoType_Container);
	self.assertNotNull(releaseRequest53);
	
	create cmifObjects53 transient;
	create intFaceBP53 transient;
	cmifObjects53.add(intFaceBP53);
	intFaceBP53.mode := 1;
	releaseRequest53.allReserveDetails.copy(intFaceBP53.allReservesToProcess);
	releaseRequest53.setInterfaceBP(intFaceBP53, railIORake);
	cmifRequest53 := intFaceBP53.allCMIFRequests.first;
	self.assertNotNull(cmifRequest53);
	cmifRequest53.quantityTxt := releaseRequest53.allReserveDetails.first.totalRequested;
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects53, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	//Load the cargo that arrived onto the first train across the wagons so as to leave spaces to allow auto assigning of release
	//to have to find the space not just get the first gap.  (I.e some gaps, some double stacked.)
	
	beginTransaction;
	self.getTerminal.setConfig(RailDefaultWCIdFormat,Rail_UPSP_Int);
	commitTransaction;
	
	self.moveTiToWagon(ti204, wagon2.allLocationsControllersArray[1]);
	self.assertNoTrxErrorsOrWarnings();
	self.moveTiToWagon(ti203, wagon2.allLocationsControllersArray[1]);
	self.assertNoTrxErrorsOrWarnings();
	self.moveTiToWagon(ti202, wagon2.allLocationsControllersArray[3]);
	self.assertNoTrxErrorsOrWarnings();
	self.moveTiToWagon(ti401, wagon3.allLocationsControllersArray[1]);
	self.assertNoTrxErrorsOrWarnings();
	self.moveTiToWagon(ti501, wagon3.allLocationsControllersArray[1]);
	self.assertNoTrxErrorsOrWarnings();
	self.moveTiToWagon(ti201, wagon2.allLocationsControllersArray[7]);
	self.assertNoTrxErrorsOrWarnings();
	
	//Check that the location naming convention for UP/SP on rail works
	// UP/SP format = wagonId &amp; space &amp; wellId &amp; space &amp; trierId &amp; logicalColumnId
    // Where the logicalColumn id is the count from the front of the well of number of containers plus number of contiguous spaces 
	
	locId := ti204.myPrimaryActualLocation.getFullIdTI(ti204);
	self.assertTrueMsg( locId = "WL02 A B1", Rail_UPSP_Str &amp; " location id for " &amp; ti204.id &amp; " should be '" &amp; "WL02 A B1" &amp; "', but was '" &amp; locId &amp; "'[F1]");  // first on bottom in well A, wagon 2
	locId := ti203.myPrimaryActualLocation.getFullIdTI(ti203);
	self.assertTrueMsg( locId = "WL02 A A1", Rail_UPSP_Str &amp; " location id for " &amp; ti203.id &amp; " should be '" &amp; "WL02 A A1" &amp; "', but was '" &amp; locId &amp; "'[F2]");	// first on top in well A, wagon 2
	locId := ti202.myPrimaryActualLocation.getFullIdTI(ti202);
	self.assertTrueMsg( locId = "WL02 A B2", Rail_UPSP_Str &amp; " location id for " &amp; ti202.id &amp; " should be '" &amp; "WL02 A B2" &amp; "', but was '" &amp; locId &amp; "'[F3]");	 // seocnd on bottom in well A, wagon 2  (container conatiner)
	locId := ti401.myPrimaryActualLocation.getFullIdTI(ti401);
	self.assertTrueMsg( locId = "WL03 A B1", Rail_UPSP_Str &amp; " location id for " &amp; ti401.id &amp; " should be '" &amp; "WL03 A B1" &amp; "', but was '" &amp; locId &amp; "'[F4]");  // first on bottom in well A, wagon 3
	locId := ti501.myPrimaryActualLocation.getFullIdTI(ti501);
	self.assertTrueMsg( locId = "WL03 A A1", Rail_UPSP_Str &amp; " location id for " &amp; ti501.id &amp; " should be '" &amp; "WL03 A A1" &amp; "', but was '" &amp; locId &amp; "'[F5]");  // first on top in well A, wagon 3
	locId := ti201.myPrimaryActualLocation.getFullIdTI(ti201);
	self.assertTrueMsg( locId = "WL02 B B2", Rail_UPSP_Str &amp; " location id for " &amp; ti201.id &amp; " should be '" &amp; "WL02 B B2" &amp; "', but was '" &amp; locId &amp; "'[F6]");	 // seocnd on bottom in well B, wagon 2  (space conatiner)
	
	//Par 35710
	locId := ti204.locationId;
	self.assertTrueMsg( locId = "WL02 A B1", Rail_UPSP_Str &amp; " location id for " &amp; ti204.id &amp; " should be '" &amp; "WL02 A B1" &amp; "', but was '" &amp; locId &amp; "'[F1a]");  // first on bottom in well A, wagon 2
	locId := ti203.locationId;
	self.assertTrueMsg( locId = "WL02 A A1", Rail_UPSP_Str &amp; " location id for " &amp; ti203.id &amp; " should be '" &amp; "WL02 A A1" &amp; "', but was '" &amp; locId &amp; "'[F2a]");	// first on top in well A, wagon 2
	locId := ti202.locationId;
	self.assertTrueMsg( locId = "WL02 A B2", Rail_UPSP_Str &amp; " location id for " &amp; ti202.id &amp; " should be '" &amp; "WL02 A B2" &amp; "', but was '" &amp; locId &amp; "'[F3a]");	 // seocnd on bottom in well A, wagon 2  (container conatiner)
	locId := ti401.locationId;
	self.assertTrueMsg( locId = "WL03 A B1", Rail_UPSP_Str &amp; " location id for " &amp; ti401.id &amp; " should be '" &amp; "WL03 A B1" &amp; "', but was '" &amp; locId &amp; "'[F4a]");  // first on bottom in well A, wagon 3
	locId := ti501.locationId;
	self.assertTrueMsg( locId = "WL03 A A1", Rail_UPSP_Str &amp; " location id for " &amp; ti501.id &amp; " should be '" &amp; "WL03 A A1" &amp; "', but was '" &amp; locId &amp; "'[F5a]");  // first on top in well A, wagon 3
	locId := ti201.locationId;
	self.assertTrueMsg( locId = "WL02 B B2", Rail_UPSP_Str &amp; " location id for " &amp; ti201.id &amp; " should be '" &amp; "WL02 B B2" &amp; "', but was '" &amp; locId &amp; "'[F6a]");	 // seocnd on bottom in well B, wagon 2  (space conatiner)
	
	//Check that the JMT default location naming convention for rail works
	// JMT default format is Railrake  &amp; space &amp; rake position &amp; space &amp; wagonLocationId &amp; space &amp; tierHeight  (On well wagons wagonLocationId is wellid &amp; wellLocationId ) wagonLocationId is teh name of the 10 foot position
	beginTransaction;
	self.getTerminal.setConfig(RailDefaultWCIdFormat,Rail_JMT_Int);
	commitTransaction;
	
	locId := ti204.myPrimaryActualLocation.getFullIdTI(ti204);
	self.assertTrueMsg( locId = "WLRA 0102 A1 1", Rail_JMT_Str &amp; " location id for " &amp; ti204.id &amp; " should be '" &amp; "WLRA 0102 A1 1" &amp; "', but was '" &amp; locId &amp; "'[F7]");  // first on bottom in well A, wagon 2
	locId := ti203.myPrimaryActualLocation.getFullIdTI(ti203);
	self.assertTrueMsg( locId = "WLRA 0102 A1 2", Rail_JMT_Str &amp; " location id for " &amp; ti203.id &amp; " should be '" &amp; "WLRA 0102 A1 2" &amp; "', but was '" &amp; locId &amp; "'[F8]");	// first on top in well A, wagon 2
	locId := ti202.myPrimaryActualLocation.getFullIdTI(ti202);
	self.assertTrueMsg( locId = "WLRA 0102 A3 1", Rail_JMT_Str &amp; " location id for " &amp; ti202.id &amp; " should be '" &amp; "WLRA 0102 A3 1" &amp; "', but was '" &amp; locId &amp; "'[F9]");	 // third 10 foot on bottom in well A, wagon 2  (container conatiner)
	locId := ti401.myPrimaryActualLocation.getFullIdTI(ti401);
	self.assertTrueMsg( locId = "WLRA 0103 A1 1", Rail_JMT_Str &amp; " location id for " &amp; ti401.id &amp; " should be '" &amp; "WLRA 0103 A1 1" &amp; "', but was '" &amp; locId &amp; "'[F10]");  // first on bottom in well A, wagon 3
	locId := ti501.myPrimaryActualLocation.getFullIdTI(ti501);
	self.assertTrueMsg( locId = "WLRA 0103 A1 2", Rail_JMT_Str &amp; " location id for " &amp; ti501.id &amp; " should be '" &amp; "WLRA 0103 A1 2" &amp; "', but was '" &amp; locId &amp; "'[F11]");  // first on top in well A, wagon 3
	locId := ti201.myPrimaryActualLocation.getFullIdTI(ti201);
	self.assertTrueMsg( locId = "WLRA 0102 B3 1", Rail_JMT_Str &amp; " location id for " &amp; ti201.id &amp; " should be '" &amp; "WLRA 0102 B3 1" &amp; "', but was '" &amp; locId &amp; "'[F12]");	 // third 10 foot pos on bottom in well B, wagon 2  (space conatiner)
	
	//to check the 'locationId' we have to simulate what happens when "executePostMoveForToLocation" does at the time of teh move, to reset the
	// 'locationId" value based on the current "RailDefaultWCIdFormat" setting.
	//Par 35710
	foreach wc in wagon2.allLocationsControllersArray do
		foreach  ti in wc.allTrackedItems do
			beginTransaction;
			ti.refreshLocationId(REAL_MODE);
			commitTransaction;
		endforeach;
	endforeach;
	foreach wc in wagon3.allLocationsControllersArray do
		foreach  ti in wc.allTrackedItems do
			beginTransaction;
			ti.refreshLocationId(REAL_MODE);
			commitTransaction;
		endforeach;
	endforeach;
	locId := ti204.locationId;
	self.assertTrueMsg( locId = "WLRA 0102 A1 1", Rail_JMT_Str &amp; " location id for " &amp; ti204.id &amp; " should be '" &amp; "WLRA 0102 A1 1" &amp; "', but was '" &amp; locId &amp; "'[F7]");  // first on bottom in well A, wagon 2
	locId := ti203.locationId;
	self.assertTrueMsg( locId = "WLRA 0102 A1 2", Rail_JMT_Str &amp; " location id for " &amp; ti203.id &amp; " should be '" &amp; "WLRA 0102 A1 2" &amp; "', but was '" &amp; locId &amp; "'[F8]");	// first on top in well A, wagon 2
	locId := ti202.locationId;
	self.assertTrueMsg( locId = "WLRA 0102 A3 1", Rail_JMT_Str &amp; " location id for " &amp; ti202.id &amp; " should be '" &amp; "WLRA 0102 A3 1" &amp; "', but was '" &amp; locId &amp; "'[F9]");	 // third 10 foot on bottom in well A, wagon 2  (container conatiner)
	locId := ti401.locationId;
	self.assertTrueMsg( locId = "WLRA 0103 A1 1", Rail_JMT_Str &amp; " location id for " &amp; ti401.id &amp; " should be '" &amp; "WLRA 0103 A1 1" &amp; "', but was '" &amp; locId &amp; "'[F10]");  // first on bottom in well A, wagon 3
	locId := ti501.locationId;
	self.assertTrueMsg( locId = "WLRA 0103 A1 2", Rail_JMT_Str &amp; " location id for " &amp; ti501.id &amp; " should be '" &amp; "WLRA 0103 A1 2" &amp; "', but was '" &amp; locId &amp; "'[F11]");  // first on top in well A, wagon 3
	locId := ti201.locationId;
	self.assertTrueMsg( locId = "WLRA 0102 B3 1", Rail_JMT_Str &amp; " location id for " &amp; ti201.id &amp; " should be '" &amp; "WLRA 0102 B3 1" &amp; "', but was '" &amp; locId &amp; "'[F12]");	 // third 10 foot pos on bottom in well B, wagon 2  (space conatiner)
	
	
	//Get a collection of all of the rail release jobs associated with the rake.
	create allWleArray transient;
	railIORake.getAllWLEs( allWleArray );
	
	// create a new collection ensuring obly the ones we just added are included ( belt and braces, in case someone else has left some lying around)
	create wleArray transient;
	foreach wle in allWleArray do
		if wle.myRequest.myOriginatingBulkRelease = releaseRequest22 then
			wleArray.add( wle );
		endif;
	endforeach;
	foreach wle in allWleArray do
		if wle.myRequest.myOriginatingBulkRelease = releaseRequest42 then
			wleArray.add( wle );
		endif;
	endforeach;
	foreach wle in allWleArray do
		if wle.myRequest.myOriginatingBulkRelease = releaseRequest53 then
			wleArray.add( wle );
		endif;
	endforeach;
	
	// get a collection of the wagons we want to assign the release jobs to
	create wagonArray transient;
	wagonArray.add(wagon2);
	wagonArray.add(wagon3);
	
	//use the agent to assign the collection of jobs to the collection of wagons.
	create agent transient;
	agent.initialise( self.getTerminal );
	agent.doAssignReleasesToWagons( wleArray, wagonArray, false, false );
	self.assertNoTrxErrorsOrWarnings();
	delete agent;

	//Check that release items are in the appropriate places.
	wc := wagon2.allLocationsControllersArray[3];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.first.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest22 then
		self.assertTrueMsg(false, "Release for 20 NOT planned to top in position " &amp; wc.getFullId &amp; ".[R1]");
	endif;
	wc := wagon2.allLocationsControllersArray[4];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.first.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest22 then
		self.assertTrueMsg(false, "Release for 20 NOT planned to top in position " &amp; wc.getFullId &amp; ".[R2]");
	endif;
	
	wc := wagon2.allLocationsControllersArray[5];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.first.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest22 then
		self.assertTrueMsg(false, "Release for 20 NOT planned to any positions in " &amp; wc.getFullId &amp; ".[R3]");
	elseif wc.allRailWLELoad.size &lt; 2 or wc.allRailWLELoad.last.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest22 then
		self.assertTrueMsg(false, "Release for 20 NOT planned to top in position " &amp; wc.getFullId &amp; ".[R4]");
	endif;
	wc := wagon2.allLocationsControllersArray[7];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.first.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest22 then
		self.assertTrueMsg(false, "Release for 20 NOT planned to any positions in " &amp; wc.getFullId &amp; ".[R5]");
	endif;
	
	wc := wagon3.allLocationsControllersArray[5];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.last.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest53 then
		self.assertTrueMsg(false, "Release for 53 NOT planned to any positions in " &amp; wc.getFullId &amp; ".[R6]");
	endif;
	wc := wagon3.allLocationsControllersArray[6];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.last.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest53 then
		self.assertTrueMsg(false, "Release for 53 NOT planned to any positions in " &amp; wc.getFullId &amp; ".[R7]");
	endif;
	wc := wagon3.allLocationsControllersArray[7];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.last.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest53 then
		self.assertTrueMsg(false, "Release for 53 NOT planned to any positions in " &amp; wc.getFullId &amp; ".[R8]");
	endif;
	wc := wagon3.allLocationsControllersArray[8];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.last.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest53 then
		self.assertTrueMsg(false, "Release for 53 NOT planned to any positions in " &amp; wc.getFullId &amp; ".[R9]");
	endif;
	wc := wagon3.allLocationsControllersArray[5];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.first.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest42 then
		self.assertTrueMsg(false, "Release for 40 NOT planned to any positions in " &amp; wc.getFullId &amp; ".[R10]");
	endif;
	wc := wagon3.allLocationsControllersArray[6];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.first.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest42 then
		self.assertTrueMsg(false, "Release for 40 NOT planned to top in position " &amp; wc.getFullId &amp; ".[R11]");
	endif;
	wc := wagon3.allLocationsControllersArray[7];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.first.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest42 then
		self.assertTrueMsg(false, "Release for 40 NOT planned to top in position " &amp; wc.getFullId &amp; ".[R12]");
	endif;
	wc := wagon3.allLocationsControllersArray[8];
	if wc.allRailWLELoad.isEmpty or wc.allRailWLELoad.first.myRequest.myOriginatingBulkRelease &lt;&gt; releaseRequest42 then
		self.assertTrueMsg(false, "Release for 40 NOT planned to top in position " &amp; wc.getFullId &amp; ".[R13]");
	endif;
	
	//Unassign releases.
	app.myTrxUA.trxUnAssignWleFromWagon(allWleArray,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Depart train.
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, true, app.myPassport);  //out
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train2 Confirm OUT Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
epilog

	delete agent;
	delete wleArray;
	delete wagonArray;
	delete allWleArray;
	
	beginTransaction;
	self.getTerminal.setConfig(RailDefaultWCIdFormat, null);
	self.getTerminal.setConfig(ShowRelReqOnRailLoadList,true);
	commitTransaction;

	//clean up cargo
	//clean up releases
	if cmifObjects22 &lt;&gt; null then
		foreach obj in cmifObjects22 do
			intFaceBP22 := obj.CMIF_BuildPriority;
			
			delete intFaceBP22.myProxyRailJob;
			intFaceBP22.allCMIFRequests.purge;
			delete intFaceBP22;
	
		endforeach;
		cmifObjects22.purge;
	endif;
	delete cmifObjects22;
	
	if cmifObjects42 &lt;&gt; null then
		foreach obj in cmifObjects42 do
			intFaceBP42 := obj.CMIF_BuildPriority;
			
			delete intFaceBP42.myProxyRailJob;
			intFaceBP42.allCMIFRequests.purge;
			delete intFaceBP42;
	
		endforeach;
		cmifObjects42.purge;
	endif;
	delete cmifObjects42;
	
	if cmifObjects53 &lt;&gt; null then
		foreach obj in cmifObjects53 do
			intFaceBP53 := obj.CMIF_BuildPriority;
			
			delete intFaceBP53.myProxyRailJob;
			intFaceBP53.allCMIFRequests.purge;
			delete intFaceBP53;
	
		endforeach;
		cmifObjects53.purge;
	endif;
	delete cmifObjects53;
	
	if allTis &lt;&gt; null and not allTis.isEmpty then
		foreach ti in allTis do
			self.deleteContainer(ti.id);
		endforeach;
	endif;
	delete allTis;
	
	//clean up trains and wagons.
	wagonClass := app.myRoot.allWagonClasses[wagonClassId];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
		wagonMaster	:=	self.getRoot.allWagonMasters[WagonId1];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
		wagonMaster	:=	self.getRoot.allWagonMasters[WagonId2];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endif;
	
	self.deleteRailArea(RailAreaId);
	self.deleteTrain(TrainCode,null);

end;</source>
    </JadeMethod>
    <JadeMethod name="uCargoForYRDLoadList" id="aa298726-dd82-42cf-a71d-b2d76c3485e9">
        <source>uCargoForYRDLoadList();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 December 2011	cnwndl1	Initial creation	Par 28797

*/

constants
	TiCode = "NDLA0000";
	BlockStack = "UT_BS";
vars

	allTrackedItems : CM_TIArray;
	tiId : String;
	pxyTi : CM_TrackedItem;
	ti : CM_TrackedItem;
	int : Integer;
	blockStack : CM_BlockStack;
	location : CM_LocationsController;

begin

	create allTrackedItems transient;
	
	blockStack := self.getTerminal.allTerminalAreaMastersById.getAtKey( BlockStack ).CM_BlockStack;
	location := blockStack.myLocationsController;

	foreach int in 1 to 600 do
	
		tiId := TiCode &amp; int.String.padLeadingZeros(3);
		self.deleteContainer(tiId);
		
	//	continue;
		
		pxyTi := self.createContainer(	tiId,
										"2200",	//_isoType: String;
										"GB1",	//_commodity: String;
										self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
										true
										);
										
		pxyTi.setTotalWeight(2000, null, null);				
		pxyTi.setWeightTare(400);
		pxyTi.zSetPxyImexStatus(TI_IMEX_STATUS_IMPORT);
		pxyTi.setReceiptTransportMode(TI_TRANSMODE_SHIP);
		pxyTi.zSetPxyCustomsEntryNumber("ab12");
		pxyTi.setIntendedReleaseModeFromStr( TI_TRANSMODE_RAIL_STR );
	
		app.myPassport.clearErrorsWarnings();
		app.myPassport.warningsAcknowledged := true;
		app.myTrxCA.trxCreateTrackedItem(pxyTi, ti, app.myPassport);
		
		self.move(ti, location);
		if app.myPassport.hasErrors or ti = null then
			self.assertTrueMsg(false, app.myPassport.getAllErrorsWarningsAsString);
		endif;
		
		allTrackedItems.add(ti); 
		
	endforeach;


epilog

	if allTrackedItems &lt;&gt; null then
		foreach ti in allTrackedItems do
			self.deleteContainer(ti.id);
		endforeach;
		delete allTrackedItems;
	endif;

	if allTrackedItems &lt;&gt; null then
		delete allTrackedItems;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="uTrainReleasePerfSTW" id="3afeafa1-5b4b-4d2d-bf44-cdf9eda11139">
        <source>uTrainReleasePerfSTW();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 February 2019	jlgndl1	Initial creation	TFS 43356
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level	
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight																
*/

constants
	TrainCode : String = "STWRTRAIN";
	Wagonnn : String = "BX43356";
	RailAreaId : String = "UT_JRA1";	
	RailReleaseRqId1 : String = "STWRREQ175A";
	RailReleaseRqId2 : String = "STWRREQ175B";
	RailReleaseRqId3 : String = "STWRREQ175C";
	RailReleaseRqId4 : String = "STWRREQ175D";
	CargoTypeAbbrev : String = "UTFRUITVEG";
	CargoBaseId : String = "STWRSPUD";
	BlockStackId1 : String = "43356";
vars
	railArea : CM_Rail;
	railLine : CM_RailLine;
	obj : Object;
	railIORake : CM_RailJSInOutRake;
	index : Integer;
	wagonMaster : CM_WagonMaster;
	wagonId : String;
	train: CM_Train;
	wagon : CM_Wagon;
	cargoType : CM_CargoType;
	product : CM_Product;
	cargoId : String;
	oper : CM_Operator;
	bulkRelease : CM_BulkRelease;
	allCargoToAssign : CM_TISet;
	ti : CM_TrackedItem;
	pxyReleaseRequest : CM_BulkRelease;
	pxyReleaseMatchCrit : CM_ReleaseByTypeCriteria;
	pxyCriteria : CM_YACriteria;
	pxyReserveSelection : CM_ReserveSelection;
	bs1 : CM_BlockStack;
	term : CM_Terminal;
begin
	railArea := self.addRailArea(RailAreaId, 4, 10);
	railLine := railArea.allRailLinesByIndex.first;
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	term := self.getTerminal;
	self.assertTrueMsg(term &lt;&gt; null, "Terminal not found during setup.");
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	self.assertTrueMsg(railIORake &lt;&gt; null, "Rail Rake not found during setup.");
	
	
	//delete old stuff
	write "Deleteing old Releases x4..." &amp; app.actualTimeAppServer.String;
	deleteReleaseRequest(RailReleaseRqId1);
	deleteReleaseRequest(RailReleaseRqId2);
	deleteReleaseRequest(RailReleaseRqId3);
	deleteReleaseRequest(RailReleaseRqId4);
	
	write "Deleteing old cargo x700..." &amp; app.actualTimeAppServer.String;
	foreach index in 1 to 700 do
		self.deleteTrackedItem( CargoBaseId &amp; index.padLeadingWith('0',3), false);
	endforeach;
	
	write "Deleteing old wagons and masters x4..." &amp; app.actualTimeAppServer.String;
	foreach index in 1 to 4 do
		wagonMaster	:=	self.getRoot.allWagonMasters[Wagonnn &amp; index.String];
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endforeach;
	
	write "Deleteing old train..." &amp; app.actualTimeAppServer.String;
	self.deleteTrain(TrainCode,null);
	
return;
	
	//add new stuff
	write "Add new Train..." &amp; app.actualTimeAppServer.String;
	train := self.addTrain(TrainCode,null);
	self.assertNotNull(train);
	
	write "Add new Wagons..." &amp; app.actualTimeAppServer.String;
	foreach index in 1 to 4 do
		wagon := self.addWagonInRailArea(Wagonnn &amp; index.String, "BX", railArea, train);
	endforeach;
	
write "Return";
return;

	cargoType := self.getCargoType( CargoTypeAbbrev );
	product := cargoType.allProducts.findProductByCode("Spud");
	bs1 := self.addBlockStack(BlockStackId1, 1000, null);
	self.assertTrueMsg(bs1 &lt;&gt; null, BlockStackId1 &amp; " not created during setup.");
	
	write "Add new Cargo x700..." &amp; app.actualTimeAppServer.String;
	create allCargoToAssign transient;
	foreach index in 1 to 700 do
		cargoId := CargoBaseId &amp; index.padLeadingWith('0',3);
		ti := self.addCargoAtLocation(cargoId, product, oper, bs1.myLocationsController);
		self.assertTrueMsg( ti &lt;&gt; null , " Cargo '" &amp; cargoId &amp; "' not created pre-test");
		allCargoToAssign.add(ti);
		beginTransaction;
		ti.setTotalWeightWithoutTrans(5);
		commitTransaction;
	endforeach;
	
	write "Add new Release proxy..." &amp; app.actualTimeAppServer.String;
	create pxyReleaseRequest transient;
	pxyReleaseRequest.setProxy(RailReleaseRqId1,
								BR_TYPE_RAIL,	//BR_TYPE_SHIP,
								true,
								BR_ACTIVE,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,//consign voyage
								app.actualTimeServer(),		// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
								null, //today,		// cnwdad1 30/05/2007 - PAR #14132: Do not default required date to today.
								null,
								null,
								null,
								null, //door dir
								null,
								null,
								term.getDefaultPort,//load port
								null,//_destinationPort
								null,
								null,//freightForwarder
								null,
								term,
								oper,
								null,
								term.getNullVoyage,//voyage
								null,
								true,
								null,null,null,
								term.allSubTerminals.first,
								term.allSubTerminals.first, // subterm target//cnwrd1 par 23219 17.3.2010
								null, 	//_assignedTrain : CM_Train
								false,
								null,				// cnwrl1 19/02/2010 PAR 22393
								false,				// cnwrl1 19/02/2010 PAR 22393
								false, false,				// May 2011 cnwjre1 27097 POL CCMS 2043
								false, // par 29480 April 2012
								null, 	//CCMS POL 2122 / PAR 28696 cnwrs1
								null,
								null,	// jlgka1 TFS 41708
								null	// ### TFS 53953 27June2022 NAVPW1
								);
	
	
	write "Add new Reserve detail proxies x700..." &amp; app.actualTimeAppServer.String;
	foreach ti in allCargoToAssign do
	
		create pxyReleaseMatchCrit transient;
		create pxyCriteria transient;
		pxyReleaseMatchCrit.allCriteria.add(pxyCriteria);
		pxyCriteria.setProxy(	CM_YATypeID.firstInstance,	//pCriteriaTypeObj:CM_YACriteriaType;
								ti.id,	//pDataValue:Any;
								"Id"	//pCode:String
								);
	
		create pxyReserveSelection transient;
		pxyReserveSelection.setMyHeader(pxyReleaseRequest);
		pxyReserveSelection.setPxyDefaults();
	
		pxyReserveSelection.setProxy(0, 
									cargoType,
									null,
									null,
									null,
									product,
									null,
									null,
									1,
									null, //avail grades
									null,//clean
									null, //iso check
									false, //heavy rated
									null, //mask ids
									0,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,				
									null,
									null,
									null,
									null,
									null,		 // 01/07/2015 cnwma1 PAR #36555
									null,
									false,
									null,null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
									null,	// ### TFS 53953 11July2022 NAVPW1
									null,null,  //12-07-2022 navtnr20 53974
									null, //28/06/2023 navmv20 CR 58410 Task 58411
									false,	// 6/12/2023 navcs2 ChangeRequest 57537
									false,	//19/02/2023	navkc1 CR 60078 Task 62450
									null,  //24/04/2025	navrv30	MTN 34319
									null);
		
			pxyReleaseMatchCrit.setProxyBaseData(pxyReserveSelection);
		

	endforeach;
	
	write "Persisting Release..." &amp; app.actualTimeAppServer.String;
	app.myTrxCA.trxCreateBulkRelease(pxyReleaseRequest, bulkRelease, null, app.myPassport);
	self.assertTrueMsg( bulkRelease &lt;&gt; null , " Bulk Release '" &amp; RailReleaseRqId1 &amp; "' not created pre-test");
	
	write "Test Data ready to go..." &amp; app.actualTimeAppServer.String;
epilog

	delete allCargoToAssign;
	delete pxyReleaseRequest;

end;</source>
    </JadeMethod>
    <JadeMethod name="uWagonTrackPlanning" id="f1743205-dd4c-4265-bed6-76c2c47d0ffb">
        <source>uWagonTrackPlanning();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/
constants
	MyTrain = "TRAIN1424";
	MyWagon1 = "UK1424_1";
	MyWagon2 = "UK1424_2";
	MyWagon3 = "UK1424_3";
	Rakes = 2;
	RakeLength = 3;
	RailAreaId: String = "UTMP_RA";
vars
	wagon,
	wagon1, 
	wagon2,
	wagon3: CM_Wagon;
	railArea: CM_Rail;
	railLine: CM_RailLine;
	train: CM_Train;
	moveController : CMIF_WagonMoveController;
	allWagons:CM_WagonArray;
begin
	self.deleteRailArea(RailAreaId);
	self.deleteTrainAndWagons(MyTrain);
	
	// ****** ADD NEW TRAIN
	train := self.addTrain(MyTrain, null);
	self.assertNotNull(train);
	
	// ****** ADD NEW RAIL AREA
	railArea := self.addRailArea(RailAreaId, Rakes, RakeLength);
	railLine := railArea.allRailLines.first();
	self.assertNotNull(railArea);
	
	// ****** ADD NEW WAGONS
	wagon1 := self.addWagon(MyWagon1, "UK", train);
	self.assertNotNull(wagon1);
	wagon2 := self.addWagon(MyWagon2, "UK", train);
	self.assertNotNull(wagon2);
	wagon3 := self.addWagon(MyWagon3, "UK", train);
	self.assertNotNull(wagon3);
	
	// ****** PLANNING WAGONS
	create allWagons transient;
	allWagons.add(wagon1);
	allWagons.add(wagon2);
	allWagons.add(wagon3);
	self.planWagon(allWagons,railLine);
	foreach wagon in allWagons do
		self.assertEqual(wagon.getPlannedLocation,railArea.id &amp; Space &amp; railLine.id);
	endforeach;
	
	// ****** MOVING WAGONS TO PLANNED LOCATION
	self.planWagonsToMove(allWagons,railLine);
	foreach wagon in allWagons do
		self.assertEqual(wagon.myPrimaryPlannedLocation,null);
	endforeach;
epilog
	delete allWagons;
end;</source>
    </JadeMethod>
</Class>
