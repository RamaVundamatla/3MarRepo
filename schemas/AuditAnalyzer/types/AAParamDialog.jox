    <JadeMethod name="btnBrowse_1_click" id="f631bc4a-c3eb-4f18-ac95-6cb0e2070198">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBrowse_1_click(btn: Button input) updating;
vars
	fd				: CMDFileSave;
	result			: Integer;
begin

	create fd;
	fd.dialogTitle := 'Select Extract File Name';
	fd.hideReadOnly := true;
	fd.fileName := '*.csv';
	fd.filter := "CSV files (*.csv)|*.csv|All files|*.*";
	result := fd.open;
	if result = 0 then
		outputFileName := fd.fileName;
		txtOutputFile.text := outputFileName;
	endif;

end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnBrowse_click" id="ba16eb1b-32ca-4168-981b-875f4cc8b513">
        <controlMethod name="Button::click"/>
        <final/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBrowse_click(btn: Button input) updating, final;
vars
	f 	: FileFolder;
	dir	: String;
begin
	create f;

	dir := f.browseForServerFolder("Select Journal Directory", "");
	if dir &lt;&gt; null then
		txtJournalDir.text := dir;
	endif;

epilog
	delete f;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
