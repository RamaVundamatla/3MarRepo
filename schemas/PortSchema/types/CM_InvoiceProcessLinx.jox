/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Oct 2018	jlgsl4	TFS 39618 - Initial creation

*/

vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
