        <source>getJobSheetsForVoyage(_request : WS_JobSheetsRequest) : WS_JobSheetResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
14 Oct 2021	jlizm1	Initial creation TFS 52028 Work hold jobs in handheld app
30 Nov 2021	jlizm1	TFS 52456 Job Lander SOB job cargo not found
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

