    <JadeMethod name="create" id="81e5902e-507e-4718-a241-088ddecc548a">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	25 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.name	:= "Toll NZ PreAdvice XML Message";
	self.type	:= EDIFileType_XML_TOLL_PREADVICE;
end;</source>
    </JadeMethod>
    <JadeMethod name="createEDIData" id="3e474d53-b778-4b24-b452-c7dbbac5d250">
        <source>createEDIData(_transient: Boolean): CM_EDIData;
//----------------------------------------------------------------
//	Created:	26 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	xmlPrenote	: CM_EDIDataPrenote;
begin

	if _transient then
		create xmlPrenote transient;
	else
		create xmlPrenote persistent;
	endif;

	return xmlPrenote;

end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="extractFile" id="b237d054-c71b-47e9-b6e7-f01bad94aef9">
        <updating/>
        <source>extractFile(_ediFile: CM_EDIFile input; _number: Integer; _recipient: CM_Operator) updating;
//----------------------------------------------------------------
//	Created:	16 Jan 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
constants
	HDR1 : String = '&lt;?xml version="1.0" encoding="UTF-8"?&gt;';
	HDR2 : String = "";
	EOT : String = "";
vars
	ediDataPrenote	: CM_EDIDataPrenote;
	ediTI			: CM_EDITrackedItem;
//	tisByLocation	: CM_EDITIByLocation;
	xlOperator		: CM_Operator;
	voyageOid		: CM_Voyage;
	now				: TimeStamp;
	terminal		: CM_Terminal;
	fileStr			: String;
	strTime			: String;
	ediData			: CM_EDIData;
begin

	terminal := app.myPassport.myTerminal;
	ediData := _ediFile.ediData;
	
	strTime := now.date.shortYearEDI() &amp; now.time.shortFormatEDI();

	if (not CM_EDIDataPrenote.hasInstance(ediData)) then
		app.raiseCMException2(ERR_INVALID_EDI_FORMAT, self.name, ediData.class.name, null, null);
		return;
	endif;
	
	ediDataPrenote := ediData.CM_EDIDataPrenote;

	if _recipient = null then
		xlOperator := app.myRoot.allOperators[ediDataPrenote.operatorCode];
	else
		xlOperator := _recipient;
	endif;
	
	if xlOperator = null and _recipient &lt;&gt; null then
		xlOperator := _recipient;
	endif;

	// Header
	fileStr := fileStr &amp; HDR1 &amp; CrLf;
	fileStr := fileStr &amp; '&lt;Message&gt;' &amp; CrLf;
	fileStr := fileStr &amp; self.getMessageHeader(null);
	fileStr := fileStr &amp; self.getMessageBody(ediDataPrenote);
	fileStr := fileStr &amp; '&lt;/Message&gt;' &amp; CrLf;

	_ediFile.setNumContainers(ediDataPrenote.allEDITrackedItems.size);
	_ediFile.setRawDataString(fileStr);
	_ediFile.writeFile();
	
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_recipient" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="bd691eae-4df5-4d65-ac8d-d515ca170863">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//	Created:	27 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	_ediDataClass := CM_EDIDataPrenote;
	_dataType := EDIFileType_XML_TOLL_PREADVICE;
	_fileTypeCode := self.type;

end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDGRecords" id="bbbfb992-fa08-4bd9-88b0-e9ee2587c83a">
        <source>getDGRecords(_ediDataPrenote: CM_EDIData): String protected;
//----------------------------------------------------------------
//	Created:	29 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	hazStr,
	str			: String;
	ediTI		: CM_EDITrackedItem;
	pos			: Integer;
begin

	str := str &amp; '&lt;DGRecords&gt;' &amp; CrLf;
	
	foreach ediTI in _ediDataPrenote.allEDITrackedItems do
		foreach hazStr in ediTI.CM_EDIPrenoteTI.imCodes do
			pos := hazStr.pos(':+',1);
			if pos &lt; 1 then
				str := str &amp; '&lt;HazardousClass&gt;' &amp; hazStr &amp; '&lt;/HazardousClass&gt;' &amp; CrLf;
				str := str &amp; '&lt;UNNumber&gt;' &amp; '' &amp; '&lt;/UNNumber&gt;' &amp; CrLf;	
			else
				str := str &amp; '&lt;HazardousClass&gt;' &amp; hazStr[1:pos-1] &amp; '&lt;/HazardousClass&gt;' &amp; CrLf;
				if (pos+2) &lt;= hazStr.length then
					str := str &amp; '&lt;UNNumber&gt;' &amp; hazStr[pos+2:end] &amp; '&lt;/UNNumber&gt;' &amp; CrLf;
				endif;
			endif;
		endforeach;
		
	endforeach;
	
	str := str &amp; '&lt;/DGRecords&gt;' &amp; CrLf;

	return str;
end;</source>
        <access>protected</access>
        <Parameter name="_ediDataPrenote" type="CM_EDIData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIBundle" id="919be461-55ae-4be3-9fd5-49db4c61eaa7">
