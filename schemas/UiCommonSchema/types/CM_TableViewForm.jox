    <JadeMethod name="zSetRowAfterDelete" id="c18480e6-9985-4ebe-87c8-e3c04d3e47f8">
        <updating/>
        <source>zSetRowAfterDelete(_currentRow : Integer): Object protected, updating;
//********************************************************************
// Created by: cnwsh3
//
// Date: 21 November 2003
//********************************************************************
vars
	idx : Integer;
	selectedObj : Object;
begin
	if self.numItemsShown &gt; 0 then
		//Find the row immediately above the current row.
		idx := _currentRow - 1;
		if (idx &lt;= tblData.fixedRows) then
			// must have deleted the first row so set to
			// the new first row.
			idx := tblData.fixedRows + 1;
		elseif (idx &gt; tblData.rows) then
			// must have deleted the last row so set to
			// the new last row
			idx := tblData.rows;
		endif;
		
		// Ensure we have a valid row.  If not then we must
		// have deleted the last row
		if idx &lt;= tblData.rows then
			tblData.row := idx;
			selectedObj := tblData.accessRow(idx).itemObject;
			tblData.selectRow(idx, true);
		endif;
	endif;
	return selectedObj;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="_currentRow" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="zSetRowAfterMultiDelete" id="b7cc463a-3603-4a58-9170-94dd59e0c6c6">
        <updating/>
        <source>zSetRowAfterMultiDelete(_currentRow : Integer): Object protected, updating;

/*

Purpose:			
to scan the table , 1st up then down from _currentRow and return the closest row that is still valid
Parameters:			

Return Value:		


Date		Who		Reason
16 October 2009	cnwrd1	Initial creation
 //cnwrd1 par 21358 16.10.09
*/

vars
	invalidObj : Boolean;
	idx : Integer;
	selectedObj : CM_Object;
	time : TimeStamp;
begin

	on Exception do app.handleDeletedObject(exception, selectedObj, invalidObj); 

	idx := _currentRow - 1;
	
	while idx &gt; tblData.fixedRows do
	
		selectedObj := tblData.accessRow(idx).itemObject.CM_Object;
		time := selectedObj.createdTime;
	
		if not invalidObj then
			tblData.row := idx;
			tblData.selectRow(idx, true);
			return selectedObj;
		endif;
	
		idx := idx -1;
	
	endwhile;
	
	idx := _currentRow + 1;
	
	while idx &lt; tblData.rows  do
	
		selectedObj := tblData.accessRow(idx).itemObject.CM_Object;
		time := selectedObj.createdTime;
	
		if not invalidObj then
			tblData.row := idx;
			tblData.selectRow(idx, true);
			return selectedObj;
		endif;
	
		idx := idx + 1;
	
	endwhile;
	
	return null;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_currentRow" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="zSetXMLStrForTblColumns" id="8c6dd00c-228c-4df1-98ea-9ceeaad76a8c">
        <updating/>
        <source>zSetXMLStrForTblColumns(_table: CM_DataTable input; _includeColumnWidths : Boolean; _xml :String io) updating, protected;
//--------------------------------------------------
// Created:	13 November 2003 By: cnwgd1
//--------------------------------------------------
// 25/02/2010 	cnwcs5	par 21894 - replaced incorrect use of scanWhile with pos method
//								 	method now inserts new entTableDef settings prior to the &lt;/tablename=&lt;name&gt; tag
//									instead of at the beginning
// 04/03/2013	cnwcs5	par 31087 - add parameter for string containing XML.  Now we can use this method for other tables e.g. CMUI_EDIForm::tblEDITI etc
vars
	tagPrefix, tagSuffix, tmpStr, defName, replaceStr,	tmpDefStr,
	tmpXMLStr 	: String;
	startPos	: Integer;
begin
	//_table.setXMLStrForTblColumns(_includeColumnWidths ,_xml);
	// Get XML for the table as it is being displayed now
	tmpXMLStr := _table.getXmlStrForColumns(_includeColumnWidths);
	
	if _xml = null then
		_xml := tmpXMLStr;
		return;
	endif;
	
	defName 	:= _table.myEntTableDef.name;
	tagPrefix 	:= J_key_LessThan.Character &amp; _table.XMLTag_EntTblDef &amp; defName &amp; J_key_GreaterThan.Character;
	tagSuffix 	:= global.formatAsXMLSuffix(_table.XMLTag_EntTblDef &amp; defName).trimBlanks;

	startPos 	:= 1;
	tmpDefStr 	:= _xml.cnEcGetNextTagValueOfName(_table.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks;	

	if tmpDefStr &lt;&gt; null then
		// there is already xml for the table/entTableDef combination
		startPos 	:= 1;
		tmpStr 		:= tmpXMLStr.cnEcGetNextTagValueOfName(_table.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks;
		replaceStr	:= tagPrefix &amp; tmpStr &amp; tagSuffix;
		startPos 	:= 1;
		tmpDefStr 	:= tagPrefix &amp; _xml.cnEcGetNextTagValueOfName(_table.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks &amp; tagSuffix;
		_xml 		:= _xml.replaceString(tmpDefStr, replaceStr);
	else
		// adding a new table/entTableDef combination - find the value to put between the prefix 7 suffix tage
		startPos 	:= 1;
		tmpDefStr 	:= tagPrefix &amp; tmpXMLStr.cnEcGetNextTagValueOfName(_table.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks &amp; tagSuffix;
		// we want to insert it before the &lt;/table name = &lt;name&gt;&gt; tag
		startPos 	:= 1;
		//self.xmlStrTblData.scanWhile('&lt;'&amp; _table.XMLTag_Table &amp; _table.name &amp; '&gt;', startPos);
		startPos 	:= _xml.pos('&lt;/'&amp; _table.XMLTag_Table &amp; _table.name &amp; '&gt;', startPos);
		
		if startPos &lt;&gt; 0 then
			_xml := _xml.cnEcInsertInto(tmpDefStr, startPos, startPos);
		else
			// should not happen but if it does we will append at the end
			_xml := tmpDefStr;
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_includeColumnWidths" type="Boolean"/>
        <Parameter name="_xml" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="zShowSearcher" id="e6ed087c-4e20-42a8-9ae5-ffea9fd05e3b">
        <updating/>
        <source>zShowSearcher() updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	self.isSearcherVisible := true;
	self.btnShowSearchTV.caption := app.getErrorString(HideSearcher);
	self.btnShowSearchTV.bubbleHelp := self.btnShowSearchTV.caption;

	if self.isSearcherFloating then
		//self.mode := self.Mode_Search; //cnwdz2 - associated with par17352
		tblSearch.adjustHeight(2000);
		tblSearch.adjustHeight(self.clientHeight - tblSearch.top);
		frmSearch.height := tblSearch.height + tblSearch.top + 25;

		if frmSearch.width &lt; self.FrmSearchStdWidth then //PAR#8605 may already be resized larger due to toolbar.showCaptions
			frmSearch.width := FrmSearchStdWidth;
		endif;
		frmSearch.cnEcResizeContents();
		frmSearch.centreWindow();

		self.searcherShowHideControls(false);
	
		frmSearch.visible := true;
		frmSearch.zOrder(1);
	else

		self.isSearcherFloating := false;

		sptDataFilter.showLeftControl(sptDataFilter.leftToRightRatio, true);

		tblSearch.adjustHeight(2000);
		self.zResetDataFilterRatio();
	endif;

	tblSearch.moveFirst();
	tblSearch.setFocus();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zShowThumbnailData" id="83376eaf-d1f3-4965-8435-d50a93e6f557">
        <updating/>
        <source>zShowThumbnailData(obj : Object) updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	invalidObj : Boolean;
begin
	
	if self.useTblThumb and (not tblThumb.visible) then
		return;
	endif;

	if obj = null then

		self.myCurrentObject := null;
		self.clearThumbnailData();
	else
		//epr TFS 1894 22/4/16 - this use to hides the dump and gave a message to contact developer
		on Exception do app.handleDeletedObject(exception,obj,invalidObj); //  zShowThumbnailDataExHandler(exception);
		if obj &lt;&gt; self.myProxyObject then
			self.myCurrentObject := obj;
		endif;
		self.showThumbnailData(obj);
		
		if invalidObj then
			self.myCurrentObject:=null;
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="zShowThumbnailDataExHandler" id="a2b6d44a-fb96-451a-9ea1-b37d160d14a5">
        <updating/>
        <source>zShowThumbnailDataExHandler(exObj : Exception) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	ObjectNotFound	: Integer = 4;
	
vars

begin
	if exObj.errorCode = 4 then
		if app.passBackAllExceptions then
			return Ex_Pass_Back;
		endif;
			
		
		app.msgBox('An object or one of its components has been deleted, contact developer', 'Error', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.myCurrentObject := null;
		// changed 11/9/2006 by cnwmo1
		//self.zTblDataSortAndShow(true);
		return Ex_Abort_Action;
		
		
	endif;

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zTblDataColorRows" id="eccc1092-466b-4769-bfdc-e3c6f32143d6">
        <source>zTblDataColorRows() protected;
/*

Date		Who		Reason
15 April 2016	cnwer1	Initial creation PAR

*/

vars
	idx2,
	startRow,
	endRow	: Integer;
	obj : Object;
begin
	startRow := self.tblData.fixedRows + 1;
	endRow := self.tblData.rows;
	foreach idx2 in startRow to endRow do
			if (idx2 mod 2 = 0) then
				self.tblData.accessRow(idx2).backColor := self.colorRow1;
			else
				self.tblData.accessRow(idx2).backColor := self.colorRow2;
			endif;
			obj := self.tblData.accessRow(idx2).itemObject;
			if obj &lt;&gt; null then
				self.tblDataShowDataSpecial(idx2, obj);
			endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zTblDataDisplayRow" id="5059f4d1-1f43-4bfc-9ef7-4c61c586167c">
        <updating/>
        <source>zTblDataDisplayRow(table: Table input; obj: Object):String updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
begin

	if obj = null then
		return null;
	endif;
	
	on Exception do zTblDataDisplayRowExHandler(exception);
	
	return tblDataDisplayRow(table, obj);
	
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zTblDataDisplayRowExHandler" id="edd559ad-9824-4b22-b315-ae32b5d80ad1">
        <updating/>
        <source>zTblDataDisplayRowExHandler(exObj : Exception) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
	
vars

begin

	if exObj.errorCode = ObjectNotFound or
	   exObj.errorCode = ObjectDeleted then
	   	return Ex_Abort_Action;
	endif;
	
	return Ex_Continue;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zTblDataFindObject" id="8288b88a-ade8-4cda-a8a4-3c779aacba86">
        <source>zTblDataFindObject(pObject : Object) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     11 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// 11 Jun 25  jlier1  JIRA MTN-34771 - using display collection if the obj is not in the shown view will never find it - need to check the collection
vars
	idx,
	rows,
	theRow	: Integer;
	
begin

	if (not self.useTblData) then
		return theRow;
	endif;
	
	if self.tblData.isPaginated then
		if self.tblData.getCollection &lt;&gt; null then
			return self.tblData.getCollection.indexOf(pObject);
		endif;
		return null;
	endif;
	
	self.tblData.findObjectInRow(pObject, theRow);
	
	return theRow;
	
end;</source>
        <access>protected</access>
        <Parameter name="pObject" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zTblDataRemoveItem" id="bde22edb-53e0-4441-b0f6-b59a06385398">
        <updating/>
        <source>zTblDataRemoveItem( _obj : Object) updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 11 Jun 25  jlier1  JIRA MTN-34771 - using display collection need to remove by looking up obj 
vars
	newRow	: Integer;
	isCurrentRow	: Boolean;

begin
	
	if self.tblData.row &gt; self.tblData.fixedRows and  self.tblData.row &lt; self.tblData.rows and self.myCurrentObject &lt;&gt; null then
		isCurrentRow :=  self.tblData.accessRow(self.tblData.row) &lt;&gt; null and self.tblData.accessRow(self.tblData.row).itemObject = self.myCurrentObject; //MTN-35286
	endif;

	self.tblData.removeItemObject(_obj);
	
	if self.mode = Mode_Add then
		// in this case the current row will be the
		// placeholder row so can just ...
		return;
	endif;

	if isCurrentRow then
		// reselect the new row
		newRow := self.tblData.row;
		if newRow &gt; self.tblData.fixedRows then
			self.tblData.selectRow(newRow, false);
			self.zTblDataSelectRow(newRow);
		else
			self.zClearThumbnailData();
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="zTblDataResort" id="bb138df9-1d93-4493-85a1-e2ff04489221">
        <updating/>
        <source>zTblDataResort() updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,
	startRow,
	endRow,
	sortColNo	: Integer;
	sortColName	: String;
	descending	: Boolean;
	obj			: Object;
begin

	if (not self.useTblData) then
		return;
	endif;

	sortColNo := tblData.column;
	
	if sortColNo &lt;= 0
	or sortColNo &gt; tblData.columns then
		return;
	endif;
	
	//if (not self.tblData.allTblDataColPropertyNames.isEmpty) then
	if self.tblData.allTblDataColPropertyNames.size &gt;= sortColNo then	
		// look in the data table collection
		sortColName := tblData.allTblDataColPropertyNames[sortColNo];
	endif;

	if sortColName = null then
		app.msgBox(app.getErrorString(Not_Able_To_Sort_By_Column), app.getErrorString(Info), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	// DVB changed 18/01/2005 to use data table sorting. Although time stamp doesn't seem
	// to work anymore. Looking into it.
	
/*	if (not self.tblData.allTblDataSortColumns.isEmpty) and 
	   self.tblData.allTblDataSortColumns[1] = sortColName then
		descending := (not self.tblData.allTblDataSortDescending[1]);
	else
		descending := false;
	endif;

	self.zClearSortColumns();
	self.zAddSortColumn(sortColName, descending);

	tblData.sortColumn[1] 	:= sortColNo;
	tblData.sortAsc[1]		:= (not descending);*/
	self.tblData.resortTableByColumn(sortColNo);
//	tblData.resort;
	startRow := self.tblData.fixedRows + 1;
	endRow	:= self.tblData.rows;
	foreach idx in startRow to endRow do
		if (idx mod 2 = 0) then
			self.tblData.accessRow(idx).backColor := self.colorRow1;
		else
			self.tblData.accessRow(idx).backColor := self.colorRow2;
		endif;
		obj := self.tblData.accessRow(idx).itemObject;
		if obj &lt;&gt; null then
			self.tblDataShowDataSpecial(idx, obj);
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zTblDataSelectObject" id="6207882a-c823-4c8f-9ec7-c1a17ffbaabd">
        <updating/>
        <source>zTblDataSelectObject(pObject : Object) updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpObject,
	theObject	: Object;
	savePointer,
	tmpRow,
	tmpCol,
	idx			: Integer;
	tmpStr		: String;
	tmpContinue	: Boolean;
	
begin

	savePointer := app.mousePointer;
	app.mousePointer := MousePointer_HourGlass;

	if (not self.useTblData) then
		if self.myCurrentObject &lt;&gt; null then
			self.zShowThumbnailData(self.myCurrentObject);
		endif;
		return;
	endif;

	tblData.clearAllSelected();

	if pObject &lt;&gt; null  then
		theObject := pObject;
	else
		if tblData.rows &gt; tblData.fixedRows then
			theObject := tblData.accessRow(tblData.fixedRows + 1).itemObject;
		endif;
	endif;
	
	if theObject &lt;&gt; null and theObject.isKindOf(self.myDataClass) then
		tblData.selectObject(theObject, true);
		if theObject &lt;&gt; self.myPlaceHolderObject then
			self.zShowThumbnailData(theObject);
		endif;
	else
		self.zClearThumbnailData();
	endif;

epilog
	app.mousePointer := savePointer;
	
end;</source>
        <access>protected</access>
        <Parameter name="pObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="zTblDataSelectRow" id="bb081540-e5a9-4a5c-8186-c8151964c3a8">
        <updating/>
        <source>zTblDataSelectRow(_row : Integer) updating, protected;
//--------------------------------------------------
// Created:	29 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	theObject	: Object;
	theRow		: Integer;
begin

	theRow	:= self.tblData.rows.min(_row);

	theObject := self.tblData.accessRow(theRow).itemObject;
	
	//26 Feb 2014	NDL	Par 33483 - unselected row is still 'myCurrentObject'
	//					so gets picked up as being selected in some forms.
	if not self.tblData.allSelectedObjects.isEmpty then
		//we have multiple rows selected
		if not self.tblData.accessRow(theRow).selected then
			// we have just unselected this row so display one of teh selected
			// ones and have a crack at re-setting the myCurrentObject
			theObject := self.tblData.allSelectedObjects.first;
		endif;
	endif;
	
	if theObject &lt;&gt; null then
		self.zShowThumbnailData(theObject);
	else
		self.zClearThumbnailData();
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zTblDataShowDataExHandler" id="a587f273-3f77-4058-bb7d-c14b73e90298">
        <updating/>
        <source>zTblDataShowDataExHandler(exObj : Exception; obj : Object io) : Integer updating, protected;

constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;

vars 
	msg : String;
	errorObj : Object;
begin

	if exObj.errorCode = ObjectNotFound or
	   exObj.errorCode = ObjectDeleted then
		
	   //08 Apr 2016	NDL	- extra logging for data display so items don't go missing...
	   errorObj := exObj.errorObject;
	   if errorObj &lt;&gt; null and errorObj &lt;&gt; obj then
			app.cnStartTransaction( method.qualifiedName );
			app.cnEndTransaction();
			msg := method.qualifiedName &amp; ", Data display exception " &amp; exObj.errorCode.String;
			app.writeLog(msg, LogERROR);	//26 Nov 2019	NDL	TFS 47053
			if obj &lt;&gt; null then
				msg := obj.String &amp; " was trying to display data about " &amp; errorObj.String;
				app.writeLog(msg, LogERROR);	//26 Nov 2019	NDL	TFS 47053
			endif;
	   endif;
	   
		obj := null;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;
	
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="obj" type="Object" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zTblDataShowDataForObject" id="1f76b816-6a88-43cc-9969-a2e2090529e3">
        <updating/>
        <source>zTblDataShowDataForObject(_obj : Object io; _numItems : Integer io; _breakOut : Boolean io) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 September 2002 by cnwrs2
//
// Purpose:     Returns true if the object was added to the table
// ---------------------------------------------------------------------------
vars
	str		: String;
	idx		: Integer;
	tmpContinue	: Boolean;
	colNoAutoTareCargoWeightCalc : Integer;
	colNoUseTareCargoWeight : Integer;
	
	
begin
	if _obj = self.myPlaceHolderObject and self.myPlaceHolderObject &lt;&gt; null then
		// add a dummy row.  We add as an object so that it can be
		// selected and we can find again regardless of sort
		idx := tblData.addItemObject(_obj, '....');
		return true;
	endif;

	on Exception do zTblDataShowDataExHandler(exception, _obj);
	// below is deliberately an isKindOf as this dereferences the object which
	// will cause the exhandler to fire if it has been deleted
	if _obj = null then
		// if deleted object the obj is set to null in the ex handler so ignore
		return false;
	endif;
	
	//This was causing the item to be added to the table at the top rather than the sort order
	//and someone had added code to resort the table each time a new item was created
	//which is totally mad, let jade do it.
	//No longer needed as all accessing of cell/rows is done below
	// in self.tblDataShowDataSpecial(idx, _obj);
	// we need to add a blank row first as for some sub-classes
	// the tblDataDisplayRow method access cells in the row
	// to set colour's etc.
	
	//Only get the string
	str := self.tblDataDisplayRow(tblData, _obj);	

	if str = null then
		// remove the row just added.  In most cases this should not
		// happen as the object should have been excluded earlier
		
		//Row not added?  this falls over as idx not set yet   JC 17/06/2004
		
		//tblData.deleteRow(idx);
		return false;
	endif;
	
	
	//Now
	idx := tblData.addItemObject(_obj, str);
	// TFS 1788 6/4/2016 cnwjre1 after handling the &gt;32000 exception rowIdx is zero so exit the rest of the processing.
	if idx = 0 then
		_breakOut := true;
		return false;
	endif;

	self.doPostAddItem(idx, _obj);
	_numItems	:= _numItems + 1;
	
	if self.frmModalDialog.visible then
// cnwdad1 27/05/2010 - PAR #24304.
//		if idx mod 100 = 0 then
		if idx mod 1000 = 0 then
			self.zTblDataShowDataUpdateProgress(_numItems, idx, _breakOut);
		endif;
	endif;

	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object" usage="io"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zTblDataShowDataUpdateProgress" id="0c532842-0e0e-41c3-a39b-e49d50982b3e">
        <source>zTblDataShowDataUpdateProgress(_numItems, _idx : Integer; _breakOut : Boolean output) protected;
// ---------------------------------------------------------------------------
// Created:     26 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.modalDialogUpdateInfo("Loaded " &amp; _numItems.String &amp; " Items");
	self.pbProgressBar.partsDone := _idx;
	self.frmModalDialog.refreshNow;
	self.btnModalDefault.doWindowEvents(0);
	if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
		_breakOut := true;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="zTblDataSortAndShow" id="a2a9dcc2-0181-403d-af99-24eb3261e863">
        <updating/>
        <source>zTblDataSortAndShow(pClearFirst : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2000 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	self.numItemsShown	:= 0;
	
	self.tblData.clearAllData();

	if self.isFirstActivateComplete then
		self.zGetDataForTable(null);
		
	elseif self.amInitialisingWithObject and self.myCurrentObject &lt;&gt; null then
		self.zGetDataForTable(self.myCurrentObject);
		
	else
		self.zGetDataForTable(null);	
	endif;
		
epilog
	endLoad;
end;</source>
        <access>protected</access>
        <Parameter name="pClearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zTblDataSysNotifyCreate" id="da98f91f-3a60-4b6d-8100-ec40fbd7b62e">
        <updating/>
        <source>zTblDataSysNotifyCreate(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 May 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theRow		: Integer;
	breakOut	: Boolean;
begin

	if (not self.includeObject(theObject, app.myPassport)) then
		return;
	endif;

	//jlier1 11/6/25 MTN-34711
	theRow :=self.zTblDataFindObject(theObject);
	if theRow &lt;= 0 then
		self.addObjectToTable(theObject, theRow, breakOut);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zTblDataSysNotifyDelete" id="07777294-e087-4d2e-94f3-6f3e07996b4d">
        <updating/>
        <source>zTblDataSysNotifyDelete(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// 11 Jun 25  jlier1  JIRA MTN-34771 - using display collection need to remove by looking up obj rather than idx
vars
	theRow	: Integer;
begin

	if (not self.useTblData) then
		if self.mode = Mode_Update and theObject = self.myCurrentObject then
			app.msgBox(app.getErrorString1(ObjectDeletedByOtherUser, self.caption), 'Warning', MsgBox_OK_Only + MsgBox_Information_Icon);
			self.myCurrentObject := null;
			self.zDoCancel();
		endif;
		return;
	endif;

	theRow := self.zTblDataFindObject(theObject);

	if theRow &gt; 0 then
		if self.mode = Mode_Add then
			self.zTblDataRemoveItem(theObject);

		elseif self.mode = Mode_Update then
			if theObject = self.myCurrentObject then
				app.msgBox(app.getErrorString1(ObjectDeletedByOtherUser, self.caption), 'Warning', MsgBox_OK_Only);
				self.myCurrentObject := null;
				self.zDoCancel();
				self.zTblDataRemoveItem(theObject);				
			elseif self.doingMultiEdit and self.tblData.allSelectedObjects.includes(theObject) then
				app.msgBox(app.getErrorString1(ObjectDeletedByOtherUser, self.caption), 'Warning', MsgBox_OK_Only);
				self.tblData.allSelectedObjects.remove(theObject);
				self.zDoCancel();
			else
				self.zTblDataRemoveItem(theObject);
			endif;

		elseif self.mode = Mode_View then
			self.zTblDataRemoveItem(theObject);
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zTblDataSysNotifyUpdate" id="cda35e4e-8c92-40e5-8ba9-162f7464f6a7">
        <updating/>
        <source>zTblDataSysNotifyUpdate(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 May 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
24 Sep 2009	cnwkpd1	PAR #20728 - replace isValidObject with exception handler
24 Nov 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
09 Apr 2024	navdap1	TFS 63307 EUP | Performance - Cargo Enquiry Bulk Updates
07 Oct 2024	jlizm1	TFS 65881 Cargo enquiry table sometimes not updating on notify
11 Jun 25  jlier1  JIRA MTN-34771 - using display collection need to remove by looking up obj rather than idx
*/

vars
	objEdition,
	rtnCode,
	theRow			: Integer;
	invalidObject,
	tmpInclude,
	breakOut		: Boolean;
	isSelected,
	doProgressive	: Boolean;				// TFS 63307
begin 
	// PAR #20728 - need to arm an exception handler, then dereference the object explicitly 
	// to force an exception if it is invalid, to allow unconditional isValidObject call to be replaced
	on Exception do app.handleDeletedObject(exception, theObject, invalidObject);
	if theObject &lt;&gt; null then
		objEdition := theObject.edition;
	endif;
	
//	if (not global.isValidObject(theObject)) then - removed PAR #20728
	if invalidObject then 
		//An update note has arrived before the delete notification
		self.zTblDataSysNotifyDelete(eventType, theObject, eventTag);
		return;
	endif;
	
	if self.getMyTerminal &lt;&gt; null then													// TFS 63307
		doProgressive := self.getMyTerminal.getConfig(AllowProgressiveUpdates).Boolean;	// TFS 63307
	endif;																				// TFS 63307
	
	if (not self.useTblData) then
		if theObject = self.myCurrentObject then
			if self.mode = Mode_View or
			   self.addUpdateTransactionComplete then
			   
			   	//22 Dec 2020	NDL	TFS 50549
				if self.isDelayNotifications then
					return;
					//do nothing the timer will handle the update to the Cam Protocol soon...
				elseif theObject &lt;&gt; null and CM_CamProtocol.hasInstance( theObject ) and not theObject.CM_CamProtocol.onHold then
					//This is used for CamProtocols when thousands of updates can be pumped out very quickly in catch up mode...
					self.beginCamProtocolTimer();
					return;
				else 
					self.zShowThumbnailData(theObject);
				endif;
				
			elseif self.mode = Mode_Update then
				// user is editting the object that has just been changed.
				rtnCode := app.msgBox(app.getErrorString1(ObjectUpdatedByAnotherUserEdit, self.caption), 'Warning', MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon);

				if rtnCode = MsgBox_Return_OK then
					self.zDoCancel();
					self.zDoEdit();
				else
					self.zDoCancel();
				endif;
			endif;
		endif;
		return;
	endif;

	tmpInclude := self.includeObject(theObject, app.myPassport);

	if self.mode = Mode_Add then
		// do nothing as the Save/Cancel will do a refresh
		if tmpInclude then
			self.needTblDataRefresh := true;
		endif;
		return;
	endif;

	// See if the object updated is currently loaded into tblData
	theRow := self.zTblDataFindObject(theObject);

	if tmpInclude and theRow &lt;= 0 then
		// should be included but not found so add
		self.addObjectToTable(theObject, theRow, breakOut);
		return;
	elseif (not tmpInclude) and theRow &gt; 0 then
		// The object should no longer be in the table based upon
		// the selection criteria
		if self.mode = Mode_Update and 
		   (theObject = self.myCurrentObject or
		   (self.doingMultiEdit and self.tblData.allSelectedObjects.includes(theObject) and not doProgressive)) then	// TFS 63307
			// user is editting the object that has just been changed.
			rtnCode := app.msgBox(app.getErrorString1(ObjectUpdByAnotherUserNoAccess, self.caption), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Stop_Icon);
			self.zDoCancel();
			// belts and braces to ensure the row has not changed in the doCancel
			theRow := self.zTblDataFindObject(theObject);
		endif;	//jlier1 11/6/25 MTN-24771 - if the object is not included - we want to remove from table   //24.11.2022 navtnr20 54967
		
		if theRow &gt; 0 then	//24.11.2022 navtnr20 54967
			self.zTblDataRemoveItem(theObject);
		endif;
		return;
	endif;

	if theRow &gt; 0 then
		if self.mode = Mode_View  then
		   	if tmpInclude then
				if not tblData.isPaginated then
					tblData.doRefreshTblDataObj(theObject);
					tblData.accessCell(theRow, 1).text := self.tblDataDisplayRow(self.tblData, theObject);
					self.tblDataShowDataSpecial(theRow, theObject);
				else
					if self.tblData.allSelectedObjects.includes(theObject) then
						isSelected:=true;
					endif;
					
					self.tblData.removeItemObject(theObject);
					
					theRow:=self.tblData.addItemObject(theObject,null);
					if isSelected and theRow = NULLINDEX then
						self.tblData.setCollectionObject(theObject); //makes the object visible in the view - because it was before
						self.tblData.findObjectInRow(theObject,theRow);
					endif;
					if isSelected and theRow &gt; 0 then
						self.tblData.selectRow(theRow,false);  //jlier1 35762 19/8/25
					endif;
					
				endif;
				if theObject = self.myCurrentObject then
					
					//22 Dec 2020	NDL	TFS 50549
					if self.isDelayNotifications then
						return;
						//do nothing the timer will handle the update to the Cam Protocol soon...
					elseif theObject &lt;&gt; null and CM_CamProtocol.hasInstance( theObject ) and not theObject.CM_CamProtocol.onHold then
						//This is used for CamProtocols when thousands of updates can be pumped out very quickly in catch up mode...
						self.beginCamProtocolTimer();
						return;
					else 
						//jlier1 MTN-34671 23/4/25 was causing showThumbnailData to be called x2 when saving
						if not self.addUpdateTransactionComplete then
							self.showThumbnailData(theObject);
						else
							self.addUpdateTransactionComplete := false;
						endif;
					endif;
					
				endif;
			else
				self.zBeginTimerForRefresh();
			endif;

		elseif self.mode = Mode_Update then
			if theObject = self.myCurrentObject or
			   (self.doingMultiEdit and self.tblData.allSelectedObjects.includes(theObject) and not doProgressive) then		// TFS 63307

   				// user is editting the object that has just been changed.
				rtnCode := app.msgBox(app.getErrorString1(ObjectUpdatedByAnotherUserEdit, self.caption), app.getErrorString(Warning), MsgBox_OK_Cancel + MsgBox_Stop_Icon);
				if rtnCode = MsgBox_Return_OK then
					self.zDoCancel();
					self.zDoEdit();
				else
					self.zDoCancel();
				endif;
			else
			   	if tmpInclude then
					if not tblData.isPaginated then
						// just redisplay the row changed
						tblData.accessCell(theRow, 1).text := self.tblDataDisplayRow(self.tblData, theObject);
						self.tblDataShowDataSpecial(theRow, theObject);
					endif;
				else
					self.zBeginTimerForRefresh();
				endif;
			endif;
		endif;
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zTimerEvent" id="7e9ce5f1-61eb-408b-aaa7-5f59846021b4">
        <updating/>
        <source>zTimerEvent(eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,
	startRow,
	endRow	: Integer;
	obj : Object;
begin

	if eventTag = Timer_Refresh then
		self.timerRefreshActive := false;
		self.zDoTblDataRefresh();
		self.zClearThumbnailData(); // XPOSE 1594 AKB2002FEB
	endif;
	if eventTag = Timer_Scrolled then
		startRow := self.tblData.fixedRows + 1;
		endRow := self.tblData.rows;
		foreach idx in startRow to endRow do		
				obj := self.tblData.accessRow(idx).itemObject;
				if obj &lt;&gt; null  then
					self.tblDataShowDataSpecial(idx, obj);
				endif;		
		endforeach;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
