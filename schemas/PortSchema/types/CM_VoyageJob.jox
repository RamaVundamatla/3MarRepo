    <JadeMethod name="pxyCreateUpdateProxy" id="a2528f76-e04d-41a2-a675-16797b9b3a6e">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 23 April 2003 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxyJob	: CM_VoyageJob;
	completedOK		: Boolean;
begin
	proxyJob := inheritMethod();
	
	proxyJob.myVoyage := self.myVoyage;
	proxyJob.myVoyageJobSheet := self.myVoyageJobSheet;

	if self.jobType = JOB_TYPE_USER then
		proxyJob.myUserJobType := self.myUserJobType;
	endif;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyJob;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyJob;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="reSeqWLEForAutoSeq" id="03d980a7-c125-44f7-8311-cae4f7af30a7">
        <source>reSeqWLEForAutoSeq(_wle : CM_VoyageWLE);
// ---------------------------------------------------------------------------
// Created:		04 June 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aWLE :CM_WorkListEntry;
	slotReq : CM_SlotRequest;
	idx : Integer;
	reqs : CM_SlotRequestArray;
	voy : CM_Voyage;
begin
	foreach aWLE in self.workListEntries discreteLock do
		if aWLE.myFutureMove.isKindOf(CM_FutureMovePlanned) then
			idx := idx + 1;
		endif;
	endforeach;
	slotReq := 	_wle.myRequest.CM_SlotRequest;
	voy := slotReq.getVoyage;
	slotReq.setCustomSeqNumber(idx,voy.starboardBerthed);
	
	
	create reqs transient;
	//self.allRequests.copy(reqs);
	self.doSortReqsInToSeqOrder(reqs);

	foreach slotReq in reqs discreteLock do
		aWLE := slotReq.allWorkListEntries.first;
		if aWLE = null then
			continue;
		endif;
		// if WLE is not planned then, bump up the seq number
		if not aWLE.myFutureMove.isKindOf(CM_FutureMovePlanned) then
			idx := idx + 1;
			slotReq.setCustomSeqNumber(idx,slotReq.getVoyage.starboardBerthed);
			// This will update the display on screen of this slot
			voy.causeEvent(voy.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), false, slotReq.mySlotController);
		endif;
	endforeach;
epilog
	delete reqs;
end;</source>
        <Parameter name="_wle" type="CM_VoyageWLE"/>
    </JadeMethod>
    <JadeMethod name="removeRequest" id="53dc7fbb-3070-4710-862b-f9aa17d075b7">
        <updating/>
        <source>removeRequest(pRequest : CM_Request io) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
//   Method      : 
//
//   Description : Method to remove a slot request object from a VoyageJob
//
//   Requests have the following relationships
//
//   Request(s) - ColourCode
//   Request(s) - Job
//   Request    - WLE(s)
//   Request    - Location - TI(s)
//
//
//   NB. First order relationships are maintained by the method directly
//   		 Second order are farmed off to an event method.

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09 Apr 2002	DQ			Fixed code so it would compile with removal of self.wlebyTI dict.
// 19 May 2010	cnwkpd1		PAR #20728 - remove isValidObject calls for performance
// 04 Aug 2011 cnwer1		CCMS 1033 - removed references to allAssociatedRequests - redundant collection never used
// ---------------------------------------------------------------------------

vars
	lRequests : CM_RequestSet;
	lTI : CM_TrackedItem;
	lWLE : CM_WorkListEntry;
begin

	if pRequest = null then		//  or not global.isValidObject(pRequest) then
		app.raiseCMException2(MethodWithNullParam, method.name, 'Request ref',null, null);
		return;
	endif;
	exclusiveLock(self);

	if self.jobType &lt;&gt; JOB_TYPE_DISCHARGE and 
	   self.jobType &lt;&gt; JOB_TYPE_LOAD and 
	   self.jobType &lt;&gt; JOB_TYPE_SOB then
		app.raiseCMException(ERR_NON_REQ_JOB, null, null);
		return;
	endif;
	
	lRequests := self.allRequests;

	if lRequests = null then
		return;
	endif;

	pRequest.setJob(null);
	
	if lRequests &lt;&gt; null then
		if lRequests.includes(pRequest) then
			lRequests.remove(pRequest);	
		endif;
	endif;
	
	if self.allRequests.isEmpty then
		self.ordinalDeck := NULL_INTEGER;
	endif;
epilog

end;</source>
        <Parameter name="pRequest" type="CM_Request" usage="io"/>
    </JadeMethod>
    <JadeMethod name="removeTI" id="27a170ec-95de-46b0-b458-2597ab9d8834">
        <updating/>
        <source>removeTI(_ti : CM_TrackedItem input; req : CM_Request) updating;

vars
	wle	:	CM_WorkListEntry;
begin
	exclusiveLock(self);

	
	if self.status = JOB_UNACTIONED then
		return;
	endif;
	//-----------------------------------------------
	// Fixup any TI dependancies and remove all wles
	//-----------------------------------------------
	wle := self.getWLEForTI(_ti);

	if wle = null then
		return;
	endif;

	// PAR 8084 wle.erase(NORMAL_ERASE); - removed
	wle.unassignTI(); // PAR 8084. Remove the TI from the WLE do not erase the WLE
	self.setRemarks(null); // pass in null will get auto remarks
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="req" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="removeWLE" id="bf846ce5-2da5-442f-8579-3a886106348c">
        <updating/>
        <source>removeWLE(wle: CM_WorkListEntry io; _reason : String ) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------
vars

begin
	if wle = null then
		return;
	endif;
	if self.workListEntries.includes(wle) then
		wle.setJob(null);
	endif;
	
	//21/09/2020 cnwma1 TFS #49906
	if app.myPassport.isOpsViewEnabled(self.getMyTerminal()) then // ### TFS 50669 28JUL2021 NAVAB1
		if not wle.isSOBLoad() then // ### TFS 51855 01FEB2022 NAVAB1
			wle.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE,
									BGP_OpsViewWSRequest.OPS_TYPE_WLE,
									wle);
									
			if wle.myTrackedItem &lt;&gt; null then	 // TFS 53009 anantra - 7th March 2022
				wle.myTrackedItem.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE, 
														BGP_OpsViewWSRequest. OPS_TYPE_TRACKEDITEM, 
														wle.myTrackedItem  );
			endif;
			
		endif;
	endif;
	//21/09/2020 cnwma1 TFS #49906
	
end;</source>
        <Parameter name="wle" type="CM_WorkListEntry" usage="io"/>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="seqSheetIssued" id="a6152b8e-4167-423f-a574-87fb4123fef4">
        <updating/>
        <source>seqSheetIssued() updating;
//   Method      : int CM_VoyageJob::seqSheetIssued()
//
//   Description : Method to set the seqSheet issued flag, called on a job.
//									If the job is NOT loaded, the flag is NOT set.
vars

begin

	exclusiveLock(self);

	if self.isLoadedToOperations then
		self.sequenceSheetIssued := true;
	endif;
epilog
	unlock(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="sequenceNumber" id="1d864fa7-8d08-4627-a08b-8e049bb23395">
        <source>sequenceNumber(ti : CM_TrackedItem): String;
//Given a TI, return its job number for display.
vars
	wle 			: CM_WorkListEntry;
	
begin


	wle := self.getWLEForTI(ti);
	if wle = null then
		return null;
	endif;
	
	if self.myVoyage &lt;&gt; null and self.myVoyage.starboardBerthed then
		if self.isTwinLift then
			// With twin lifts the custom is either the same as the 
			// standard twin number or a custom number.
			return wle.CM_VoyageWLE.numSeqStarboardTwinCustom.String.padLeadingZeros(4);
		else
			return wle.CM_VoyageWLE.seqNumCustomStarboard.String.padLeadingZeros(4);
		endif;
	else
		if self.isTwinLift then
			// With twin lifts the custom is either the same as the 
			// standard twin number or a custom number.
			return wle.CM_VoyageWLE.numSeqPortTwinCustom.String.padLeadingZeros(4);
		else
			return wle.CM_VoyageWLE.seqNumCustomPort.String.padLeadingZeros(4);
		endif;
	endif;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setBayId" id="3ba544d8-8593-4ec0-9c83-8464c5e884d9">
        <updating/>
        <source>setBayId(_theJobParams:CMIF_VoyageJobParams) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTIs : CM_TISet;
	tiIs40 : Boolean;
	theBay : CM_Bay;
	aSR : CM_SlotRequest;
begin
	aSR := self.allRequests.first.CM_SlotRequest;
	if aSR = null then
		self.bayId := null;
		return;
	endif;
	theBay := aSR.mySlotController.myBayVoyage;
	
	if theBay = null then
		self.bayId := null;
		return;
	endif;

	if not self.allReceiveTrackedItems.isEmpty then
		theTIs := self.allReceiveTrackedItems;
	elseif not self.allReleaseTrackeditems.isEmpty then
		theTIs := self.allReleaseTrackeditems;
	else
		theTIs := self.allSOBTrackedItems;
	endif;

	if not  theTIs.isEmpty then
		tiIs40 := theTIs.first.isAttributeTrue(TI_Attrib_IsForty);
		if tiIs40 then
			self.bayId := theBay.idBay40;
		endif;
	endif;

	if self.bayId = null then
		// if it is still null and it is a load, this will be because the TIs are not planned yet, so use the colour coding
		if aSR.isLoad then
// PAR 21746			if aSR.getAttrIs40() or aSR.fortyBack then
			if aSR.getAttrIs40() or aSR.getAttrIsBackend() then // PAR 21746
				self.bayId := theBay.idBay40;
			endif;
		endif;
		if self.bayId = null then
			self.bayId := theBay.id;
		endif;
	endif;


end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams"/>
    </JadeMethod>
    <JadeMethod name="setCrane" id="26d2bc87-3042-48af-942e-30543a9a5c1b">
        <updating/>
        <source>setCrane(_theJobParams:CMIF_VoyageJobParams input; newCraneId : String) updating;
//
// Description : This method is used to specify which cranes order of work the job appears
//               on. A string parameter specifies the new crane.
//

vars
	theQueue		: CM_RadioTelemetryQueue;
	workPointObject : CM_Object;
	reqs : CM_RequestArray;
	request : CM_Request;
	aWLE : CM_WorkListEntry;
	newJobSheet: CM_VoyageJobSheet;
	tmpJob	: CM_Job;
	voyJob	: CM_VoyageJob;
	idx,
	insIndex: Integer;
	tmpJobNum	: Real;
begin
	exclusiveLock(self);

	if self.status = JOB_COMPLETE then
		app.raiseCMException1(ERR_JOB_COMPLETE, self.jobNum, null, null);
		return;	
	endif;
	
	// if craneId is null then job is not assigned to a crane yet, so let them set the crane.
	if self.craneId &lt;&gt; null and self.status = JOB_PART_COMPLETE then
		app.raiseCMException1(ERR_JOB_PART_COMPLETE, self.jobId, null, null);
		return;			
	endif;	
	
	if newCraneId.trimBlanks = null then
		app.raiseCMException(ERR_INVALID_CRANE, null, null);
		return;		
	endif;

	if self.craneId = newCraneId then
		// 19/05/2010 cnwmh5 #22275 - Start
		if self.myVoyageJobSheet = null then
			newJobSheet := self.myVoyage.allJobSheets[newCraneId];
			if newJobSheet &lt;&gt; null then
				newJobSheet.removeJob(self);
				newJobSheet.addJob(self, 0);
			endif;
			self.myVoyageJobSheet := newJobSheet;
		endif;
		// 19/05/2010 cnwmh5 #22275 - End
		// If the same do not bother doing anything else.
	 	return;
	endif;

	sharedLock(self.myVoyage);
	
	// remove me from my current job sheets
	if self.myVoyageJobSheet &lt;&gt; null then // unassigned job do not have a jobSheet
		self.myVoyageJobSheet.removeJob(self);
	endif;
	if self.myJobSheet &lt;&gt; null then // unassigned job do not have a jobSheet
		self.myJobSheet.removeJob(self);
	endif;	

	// get the new job sheet
	if _theJobParams &lt;&gt; null then
		newJobSheet := _theJobParams.myJobSheet;
	endif;
	
	if newJobSheet = null then
		newJobSheet := self.myVoyage.allJobSheets[newCraneId];
		if newJobSheet = null then
			app.raiseCMException(ERR_INVALID_CRANE, null, null);
			return;		
		endif;
	endif;

	// new code for numeric test - PAR 12318
	if self.jobNum.length &gt; 1 and self.jobNum[1].isNumeric then
		// need to see if can slot in numerical order
		insIndex := 0;
		tmpJobNum := self.jobNum.extractNumber();
		foreach tmpJob in newJobSheet.allJobsByOrder do
			voyJob := tmpJob.CM_VoyageJob;
			idx := idx + 1;
			if voyJob.jobNum.extractNumber() &gt; tmpJobNum then
				insIndex := idx;
				break;
			endif;
		endforeach;
	else
		voyJob := newJobSheet.allJobsByJobNum.getAtKeyLss(self.jobNum);
	
		if voyJob &lt;&gt; null	then
			insIndex := newJobSheet.allJobsByOrder.indexOf(voyJob);
			insIndex := insIndex +1;
		else
			insIndex := 1;
		endif;
	endif;
	// to here - PAR 12318
	
	newJobSheet.removeJob(self);

	// Lets add in lexical order	
	newJobSheet.addJob(self, insIndex);
	//----------------------
	//Update the voyageJobSheet reference back to the voyageJob. (so we know this IS in a job sheet)
	//----------------------	
	if _theJobParams = null or (_theJobParams &lt;&gt; null and not _theJobParams.isTransientJob) then
		self.myVoyageJobSheet := newJobSheet;
	endif;
	
	
	if self.myVoyageJobSheet &lt;&gt; null
	and self.myVoyageJobSheet.crane.trimBlanks &lt;&gt; newCraneId.trimBlanks then
		// Something has gone wrong abort
		app.raiseUnexpectedProgramError(class.name, method.name, "Crane ID mismatch. &gt;&gt;" &amp; myVoyageJobSheet.crane &amp; "&lt;&lt; &gt;&gt;" &amp; newCraneId &amp; "&lt;&lt; Contact Developer.");
		return;
	endif;
	
	self.craneId := newCraneId;


	// PAR 11144 sort the wles into the sequence order, else RTQs get stuffed up
	// new job is only created if there are requests to split off
	create reqs transient;
	//self.allRequests.copy(reqs);
	self.doSortReqsInToSeqOrder(reqs);

	foreach request in reqs do
		// PAR 11144
		foreach aWLE in request.allWorkListEntries do
			if aWLE.isQueued then
				aWLE.changeQueueForEntry();
			endif;
		endforeach;	
	endforeach;

	// CCMS 1033 2/8/11 epr changed can be associated with either a crane or work point
	workPointObject:=self.getMyWorkPointObject;
	
	if workPointObject &lt;&gt; null then
		theQueue := workPointObject.IF_VoyageWorkPoint.getWorkPointQueueForVoyage(self.myVoyage);
	endif;
	if theQueue &lt;&gt; null then
		theQueue.causeEvent(self.myTerminal.getTerminalEvent(RTQueue_Update_Event), true,null);
	endif;

epilog
	delete reqs;
end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="newCraneId" type="String"/>
    </JadeMethod>
    <JadeMethod name="setDefaultLoadLanes" id="7b172541-6902-4832-b3b0-e9efca9706e1">
        <updating/>
        <source>setDefaultLoadLanes(_startFromLC : CM_BlockController; _startFromWLE	:	CM_VoyageWLE)	updating;
//This method looks at the crane supplied for this job, asks it for its
//load lanes, and applies a revolving sequence of the lanes to each wle in the job.
//They can optionally pass in the startFromLane, if so, the first lane is the one supplied,
//and we go from there on in.
//Optional parameter of a startFromWLE as well.
// epr par 31205 3/4/13
vars
	lastWle, startWLE : CM_VoyageWLE;
	wle	:	CM_WorkListEntry;
	lane	:	String;
	crane : CM_Crane;
	loadIndex,
	laneIndex : Integer;
	numLanes:	Integer;
	wles	:	CM_WLEArray;
	allLoadLanes : CM_LCArray;
	startLane : CM_BlockController;
	iter : Iterator;
begin

	if self.isDischargeOrSOB then
		return;
	endif;

	exclusiveLock(self);

	//Grab the crane	
	crane := self.getJobCrane();
	if crane = null  then
		app.raiseCMException(ERR_INVALID_CRANE, null, null);	
		return;
	endif;

	if crane.transferArea = null then
		app.raiseCMException1(Crane_no_CTA, self.craneId, null, null);
	endif;
	
	//The loadLanes in the crane transfer area are in THE ORDER the users wish to use.
	//ie, they have sorted them how they want them. Simply apply.
	create allLoadLanes transient;
	crane.getLoadLanes(allLoadLanes);
	
	if allLoadLanes.isEmpty then
		app.raiseCMException1(CTA_No_Load_Lanes, crane.transferArea.id,  null, null);
		return;
	endif;
	
	//if it is a twin lift job must have lanes with a cage
	if self.isTwinLift and crane.transferArea.getNextCraneLaneForTwin(0) = 0 then
		app.raiseCMException1(CTA_No_Twin_Lift_Lanes, crane.transferArea.id, null, null);	
		return;
	endif;
	
	create wles transient;
	self.getSequenceSortedWLEs(wles);	
	
	startLane:=_startFromLC;
	startWLE:=_startFromWLE;
	if startLane = null then
		if startWLE = null then
			startWLE:=wles.first.CM_VoyageWLE;
		endif;
		
		// 13/10/2014 cnwmh5 #34971
		if startWLE &lt;&gt; null and startWLE.isTwinLift then
			loadIndex:=crane.transferArea.getNextCraneLaneForTwin(0);
			startLane:=crane.transferArea.lanes[loadIndex].CM_BlockController;
		else
			startLane:=allLoadLanes.first.CM_BlockController;
		endif;
			
	endif;
	
	
	if not allLoadLanes.includes(startLane) then
		app.raiseCMException2(ERR_NOT_LANE, startLane.getID(), "Load lane", null, null);	
		return;
	endif;
	
	numLanes := 	allLoadLanes.size;
	lane := startLane.getLaneId();
	laneIndex := lane.Integer;
	loadIndex := allLoadLanes.indexOf(startLane);
	
	iter :=wles.createIterator;
	if startWLE &lt;&gt; null then
		iter.startAtObject(startWLE);
	endif;
	
	while iter.next(wle) do
		if wle.status = WLE_COMPLETED then
			continue;
		endif; 
		//--------------
		//Get next lane
		//--------------
		
		if self.isTwinLift then
			if lastWle &lt;&gt; null then
				if lastWle.getSeqNum &lt;&gt; wle.CM_VoyageWLE.getSeqNum or not wle.CM_VoyageWLE.isTwinLift then
					//get new num
					if wle.CM_VoyageWLE.isTwinLift then
						laneIndex := self.getNextCraneLaneForTwin(true, laneIndex);
						lane := laneIndex.String;
					else
						loadIndex:=allLoadLanes.indexOf(crane.transferArea.lanes[laneIndex]);
						loadIndex := loadIndex + 1;
						if loadIndex &gt; numLanes then
							loadIndex := 1;	//Start again..
						endif;
						lane := allLoadLanes[loadIndex].CM_BlockController.getLaneId();
						laneIndex := lane.Integer;
					endif;
				endif;
			endif;
			wle.CM_VoyageWLE.setDefaultCraneLoadLane(laneIndex);		
		else
			wle.CM_VoyageWLE.setDefaultCraneLoadLane(laneIndex);		
			loadIndex := loadIndex + 1;
			if loadIndex &gt; numLanes then
				loadIndex := 1;	//Start again..
			endif;
			lane := allLoadLanes[loadIndex].CM_BlockController.getLaneId();
			laneIndex := lane.Integer;
		endif;
		
		lastWle := wle.CM_VoyageWLE;
	endwhile;
	//--------------
	//Thats it..
	//--------------
epilog
	delete allLoadLanes;
	delete wles;
	delete iter;
end;</source>
        <Parameter name="_startFromLC" type="CM_BlockController"/>
        <Parameter name="_startFromWLE" type="CM_VoyageWLE"/>
    </JadeMethod>
    <JadeMethod name="setEntryOverrideFlag" id="47d9ecdc-4cb8-477b-8e06-5e72bf8f0070">
        <source>setEntryOverrideFlag();
//See CM_Job description...
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	wle	:	CM_WorkListEntry;
	flags	:	Integer;
	rtqe : CM_RTQueueEntry;
begin

	//-----------------
	//We only set the over-ride flag for discharge jobs
	//-----------------
	if not self.isDischarge then 
		return;
	endif;
	flags := 0;
	flags := flags.bitOr(MP_RT_AUTOPLAN );
	flags := flags.bitOr(MP_RT_IGNORE_WARNINGS );

	foreach wle in self.workListEntries do
		foreach rtqe in wle.allRTQueueEntries do
			rtqe.overRideFlags := flags;
		endforeach;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEstimatedCompletionTime" id="d7bce652-be6a-4ace-a84a-1f5a64eb047b">
        <updating/>
        <source>setEstimatedCompletionTime(_timeInMinutes : Integer) updating;
// -------------------------------------------
// Created 24 August 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.estimatedTimeToCompleteMins := _timeInMinutes;


end;</source>
        <Parameter name="_timeInMinutes" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreateSlotRequests" id="ba1adcd5-a572-465b-a491-c1fe4ff26f07">
        <updating/>
        <source>setForCreateSlotRequests(	_theJobParams : CMIF_VoyageJobParams input;
							_passport : CM_Passport input) protected, updating;
/*
Date		Who		Reason
03 Aug 2011	cnwer1	Initial creation CCMS MES 1033 - moved block of code from setForCreateVoyage
30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/

vars
	aSlotReq : CM_SlotRequest;
	theTI : CM_TrackedItem;
	theTIs : CM_TIArray;
	tmpSlotController	: CM_SlotController;
	theOrdinalDeck : Integer;
	doAutoJobCreate ,
	autoLinkSlotJobCreateSOB,
	autoLinkSlotJobCreate: Boolean;
	newVJob : CM_VoyageJob;
	theTerminal : CM_Terminal;
begin
	if 	_theJobParams.allSlotRequests.isEmpty then
		return;
	endif;
	
	theTerminal := _passport.myTerminal;
	if _theJobParams.usedByOOWCreation then // PAR 15831 if using OOWc to create jobs then do not link DLR loads to the DLR discharge as will mess up the jobs being created.
		autoLinkSlotJobCreate := false;
	else
		autoLinkSlotJobCreate := theTerminal.getConfig(AutoLinkSlotJobCreate).Boolean;
	endif;
	autoLinkSlotJobCreateSOB := theTerminal.getConfig(AutoLinkSlotJobCreateSOB).Boolean;
	
	create theTIs transient;
	
	foreach aSlotReq in _theJobParams.allSlotRequests do
		aSlotReq.setJob(self);
		aSlotReq.createWLEs();
		
		// ################################
		// This will update the display on screen of this slot
		tmpSlotController := aSlotReq.mySlotController;
		
		self.updateObjectEdition (tmpSlotController);			// par 30292
		
		if theOrdinalDeck = null then
			theOrdinalDeck := tmpSlotController.ordinalDeck;
		endif;
		if aSlotReq.isSOB then
			doAutoJobCreate := autoLinkSlotJobCreateSOB;
		elseif aSlotReq.isRehandle then
			doAutoJobCreate := autoLinkSlotJobCreate;
		else
			doAutoJobCreate := false;
		endif;

		// if this baby is linked to another request, cos of DLR and SOB, then add this into the job as well
		if doAutoJobCreate then
			self.setForCreateVoyageCheckLinked(newVJob,_theJobParams,aSlotReq,_passport);
		endif;	
		// attach the the cargo to us
		aSlotReq.getAllTrackedItems(theTIs);	// this clears the array
		foreach theTI in theTIs do
			if theTI &lt;&gt; null then
				self.updateTICollections(theTI, null);// 01/04/2010 cnwcs5 par 23383
				
				if self.isExportReturn then
					if theTI.getImExStatus &lt;&gt; TI_IMEX_STATUS_TRANSHIP then //cnwrd1 par 29239 13.3.2012
						theTI.setImExStatus(TI_IMEX_STATUS_EXPORT);	
					endif;
				endif;
			endif;
		endforeach;
	endforeach;
	
	self.ordinalDeck := theOrdinalDeck;
	
	// PAR7385 AKB2004JAN added from here 
	// We have auto created a linked job so it needs some basic setting up after  adding requests and TIs
	if doAutoJobCreate and newVJob &lt;&gt; null then
		newVJob.setRequestSeqNumbers(_theJobParams);
		if self.canBeTwinLiftVoyageJob() then
			newVJob.isTwinLift := true;
		endif;
		if not newVJob.allRequests.isEmpty then
			newVJob.setBayId(null);
			aSlotReq := newVJob.allRequests.first.CM_SlotRequest;
			if aSlotReq &lt;&gt; null then
				newVJob.ordinalDeck := aSlotReq.mySlotController.ordinalDeck;		
			endif;
		endif;
		if newVJob.remarks = null then
			newVJob.remarks := newVJob.getAutoRemarks();
		endif;
	endif; 
epilog
	delete theTIs;
end;</source>
        <access>protected</access>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateVoyage" id="6f586b42-2881-4abb-afd3-9ba3c77dd0ab">
        <updating/>
        <source>setForCreateVoyage(_theJobParams:CMIF_VoyageJobParams input;_allWLEs : CM_WLEArray; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/04/2010	cnwcs5	par 23383 - pass context info (null) to updateTICollections 
//									via new parameter (_extra)
// 09/02/2017	cnwdap1		TFS 3219 LNX Voyage Operations Enhancements
// 20/02/2017	cnwdap1		TFS 3489 LNX DLR/SOB
// 07/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 06 Dec 2023  navhl20 	ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
// ---------------------------------------------------------------------------

vars

	theProxyJob : CM_VoyageJob;
	tmpVoyage		: CM_Voyage;
	craneID		: String;
	jobSheet	: CM_VoyageJobSheet;
begin

	
	tmpVoyage := _theJobParams.myVoyage;
	theProxyJob := _theJobParams.myProxyJob;

	// auto job number. Get the next job number
	self.myVoyage := tmpVoyage;
	self.myTerminal:=self.myVoyage.myTerminal;
	
	craneID := _theJobParams.craneID.trimBlanks;
	jobSheet := _theJobParams.myJobSheet;
	if jobSheet = null
	and craneID &lt;&gt; null then
		jobSheet := self.myVoyage.allJobSheets[craneID];
	endif;
		
	if theProxyJob.id = null then
		// Crane must have been set my here.
		theProxyJob.id := tmpVoyage.getNextJobNumber(jobSheet, null).String;
		theProxyJob.jobNum := theProxyJob.id;
	endif;
	
	if self.isVoyageHoldJob and _theJobParams.isDischarge then													// TFS 3489
		self.setTITransitStatus(_theJobParams, _theJobParams.myProxyJob.allReceiveTrackedItems, _passport);		// TFS 3489
	endif;																										// TFS 3489
	
	self.setForCreate(theProxyJob, self.myTerminal);
	
	self.setJobNum(theProxyJob.jobNum);
	// they do not have to set the crane. They can allocate jobs to cranes elsewhere

	if craneID &lt;&gt; null then
		self.setCrane(_theJobParams,craneID);
	endif;
	self.isDischarge := theProxyJob.isDischarge;
	self.isExportReturn := theProxyJob.isExportReturn;
	self.isChargeable := theProxyJob.isChargeable;
	self.systemRemarks := theProxyJob.systemRemarks;
	
	//epr CCMS 1033 3/8/11 refactored code block into method below
	self.setForCreateSlotRequests(_theJobParams, _passport);
	
	if not self.isVoyageHoldJob then									// TFS 3219
		self.setBayId(_theJobParams);
		self.setRequestSeqNumbers(_theJobParams);
		self.isTwinLift := self.canBeTwinLiftVoyageJob();
	endif;																// TFS 3219
	
	///epr par 31205 3/4/13
	if not self.isKindOf(CM_VoyageWorkPointJob) then						//06.12.2023 navhl20 #58400[61617]
		self.setDefaultLoadLanes(null,null); 
	endif;
	
	if not self.isVoyageHoldJob then									// TFS 3219
		self.check20TLWeightLimits(_theJobParams, _passport); // CCMS 1061 CentrePort
		self.check20TLHeightLimits(_theJobParams, _passport); // CCMS 1061 CentrePort
	endif;																// TFS 3219
	
	if self.jobType = JOB_TYPE_USER then
		self.myUserJobType := theProxyJob.myUserJobType;
		if self.myUserJobType &lt;&gt; null then
			if _theJobParams.remarks &lt;&gt; null then
				self.remarks := _theJobParams.remarks;
			else
				self.remarks := self.myUserJobType.name;
			endif;
		endif;
	elseif self.jobType = JOB_TYPE_SOB then
		//epr CCMS 1033 8/3/11 refacted code block into own method
		self.autoLinkSlotsSOB(_theJobParams,_passport);	
 	endif;

	if self.remarks = null then
		self.remarks := self.getAutoRemarks();
	endif;
	
	self.setSidesAndNumHatches();
	
	//epr par 33070 30/12/13
	if self.isDischarge then
		self.allowOutOfOrderLoading := false;
	else
		self.allowOutOfOrderLoading := _theJobParams.allowOutOfOrderLoading; //cnwrd1 par 30626 ccms 2209 23.10.12
	endif;
	app.writeVoyageLog(self, "Job Create");  // PAR 31878 - logging
	
	if jobSheet &lt;&gt; null then // ### TFS 53105 30JUN2022 NAVAB1
		jobSheet.setETC(); // ### TFS 53105 30JUN2022 NAVAB1
	endif;

epilog
	

end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_allWLEs" type="CM_WLEArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateVoyageCheckLinked" id="31b285a0-c39a-4ef4-9388-69b83e603f25">
        <updating/>
        <source>setForCreateVoyageCheckLinked(_newVJob : CM_VoyageJob io;_theJobParams:CMIF_VoyageJobParams;_theSlotReq : CM_Request;_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/04/2010	cnwcs5	par 23383 - pass context info (null) to updateTICollections 
//									via new parameter (_extra)
// ---------------------------------------------------------------------------

vars
	 theSlotReq : CM_SlotRequest;
	 aLinkedSlotReq : CM_Request;
	theJobID : String;
	theBay : CM_Bay;
	theOrdinalDeck,theJobType : Integer;
	theProxyVJob : CM_VoyageJob;
	theJobParams : CMIF_VoyageJobParams;
	aRealVJob : CM_VoyageJob;
	theTIs : CM_TIArray;
	theTI : CM_TrackedItem;
begin
	
	// if this baby is linked to another request, cos of DLR and SOB, then add this into the job as well
	aLinkedSlotReq := _theSlotReq.getLinkedRequest(_theSlotReq.isReleaseType); // PAR 28968 getDLRSOBRequestLink();
	if aLinkedSlotReq &lt;&gt; null then
		// PAR 28968 we can not auto put RORO slots in a LOLO JOB
		if not aLinkedSlotReq.isKindOf(CM_SlotRequest) then
			return;
		endif;
		// this req is linked to our DLR and has no job so create a auto job for it
		if aLinkedSlotReq.myJob = null then
			if _theSlotReq.CM_SlotRequest.isRehandle then
	
				if _newVJob = null then
					create theJobParams transient;
					create theProxyVJob transient;
					if not aLinkedSlotReq.isReleaseType then // PAR 28968 isDischarge then
						theJobType :=JOB_TYPE_DISCHARGE; 
					else
						theJobType := JOB_TYPE_LOAD;
					endif;
					theProxyVJob.setProxy(_theJobParams.jobNumLinkedLoad, theJobType); 
					theJobParams.myVoyage := self.myVoyage;
					theJobParams.myProxyJob := theProxyVJob;
					theJobParams.craneID := _theJobParams.craneID;
					theProxyVJob.setProxyVoyage(theJobParams.myVoyage);
					app.myUtilityCA.utlCreateVoyageJob(theJobParams, aRealVJob, _passport);
					_newVJob := aRealVJob;
	
				endif;
	
				aLinkedSlotReq.setJob(_newVJob);
				aLinkedSlotReq.createWLEs();
				// attach the TIS to the new auto  created job
				create theTIs transient;
				// this is auto linking stuff. If this is a discharge linking to the load then get the discharge's TIs and attach them to the load job
				theSlotReq := _theSlotReq.CM_SlotRequest;
				theSlotReq.getAllTrackedItems(theTIs);
				foreach theTI in theTIs do
					if theTI &lt;&gt; null then
						_newVJob.updateTICollections(theTI, null);	// 01/04/2010 cnwcs5 par 23383
					endif;
				endforeach;
				delete theTIs;
				_newVJob.setRemarks(null); // pass in null will get auto remarks
	
			// THIS WILL BE SOBs
			else
				aLinkedSlotReq.setJob(self);
				aLinkedSlotReq.createWLEs();
			endif;
			// ################################
			// This will update the display on screen of this slot
// PAR 28968			aLinkedSlotReq.mySlotController.myBayVoyage.myCellularVoyageStructure.myVoyage.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), false, aLinkedSlotReq.mySlotController);
			aLinkedSlotReq.getVoyage.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), false, aLinkedSlotReq.getLC());
		endif;
	endif;
epilog
	delete theProxyVJob;
	delete theJobParams;
	delete theTIs;
end;</source>
        <Parameter name="_newVJob" type="CM_VoyageJob" usage="io"/>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams"/>
        <Parameter name="_theSlotReq" type="CM_Request"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1fecc456-44f4-42c2-8edb-76c2402bdb35">
        <updating/>
        <source>setForUpdate(proxyJob: CM_VoyageJob; _theTerminal: CM_Terminal) updating;
//--------------------------------------------------------------
//Created: 24 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	changeTLtoSL, changeSLtoTL : Boolean;
	aSR : CM_Request;
	realShift : CM_Shift;
begin
	inheritMethod(proxyJob, _theTerminal);

	// PAR 30637 self.isDischarge := (proxyJob.jobType = JOB_TYPE_DISCHARGE);
	self.isDischarge := (proxyJob.jobType &lt;&gt; JOB_TYPE_LOAD); // PAR 30637
	self.isExportReturn := proxyJob.isExportReturn;
	self.isChargeable := proxyJob.isChargeable;
		
	changeTLtoSL := (self.isTwinLift and not proxyJob.isTwinLift); // PAR 16566 AKB2008MAY
	changeSLtoTL := (not self.isTwinLift and proxyJob.isTwinLift);  // PAR 18445 AKB2008NOV
	

	// PAR 19416 18613
	if changeSLtoTL then
		// 19416 if they have used Job Maint to manually change the Twin LIft status we need to re do the evaluation of the sequencing, this is then looked at in the method canBeTwinLiftVoyageJob
		self.setRequestSeqNumbers(null);
	endif;
	
	// PAR 13082. if the job physically cannot be a TL then NO
	if not self.canBeTwinLiftVoyageJob() then
		self.isTwinLift := false;
	else
		self.isTwinLift := proxyJob.isTwinLift; // let the user set from the GUI.
	endif;

	if changeTLtoSL then// PAR 16566 AKB2008MAY
	// PAR 19416 18613 removed as already done  a few lines up
//	PAR 19416 or changeSLtoTL then // PAR 18445 AKB2008NOV
		foreach aSR in self.allRequests discreteLock do
			aSR.setTwinLift(self.isTwinLift,true);
			aSR.setTwinLift(self.isTwinLift,false);
		endforeach;
		
		
	endif;
	
	if changeSLtoTL or changeTLtoSL then
		//epr par 31205 3/4/13
		self.setDefaultLoadLanes(null,null); // PAR 25270
		
	endif;
	
	self.remarks := proxyJob.remarks;
	self.systemRemarks := proxyJob.systemRemarks;
	self.estimatedTimeToCompleteMins := proxyJob.estimatedTimeToCompleteMins;
	self.actualStartTs	:= proxyJob.actualStartTs;
	self.actualEndTs	:= proxyJob.actualEndTs;

	self.jobNum := self.id;
	//shift to a new crane ?
	if proxyJob.craneId.trimBlanks &lt;&gt; null then // do not have to have a crane ID
		self.setCrane(null,proxyJob.craneId.trimBlanks); // PAR 16566 AKB2008MAY
	endif;
	
	proxyJob.allAssignedCargoForAlloc.copy(self.allAssignedCargoForAlloc);
	
	// TFS 3472		
	if proxyJob.myShift&lt;&gt; null then
		if proxyJob.myShift.isTransient then
			realShift := app.myProxyManager.getRealObject(proxyJob.myShift).CM_Shift;
			if realShift = null then
				// a real shift was just created from a proxy - in this case there's no proxy link
				realShift := self.myTerminal.allShiftsDay[proxyJob.myShift.startDateTime, proxyJob.myShift.code];
			endif;
		else
			realShift := proxyJob.myShift;
		endif;
		self.myShift := realShift;
		

	endif;
	
	self.setTransferType( proxyJob.getTransferType );	//12 Mar 2018	NDL	TFS 37444
	self.setNumOfGangs( proxyJob.numOfGangs );	//16 Mar 2018	NDL	TFS 37447
	
end;</source>
        <Parameter name="proxyJob" type="CM_VoyageJob"/>
        <Parameter name="_theTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateSlotRequests" id="f1b349a9-af92-405c-a677-b02757c5b871">
        <updating/>
        <source>setForUpdateSlotRequests(_theJobParams:CMIF_VoyageJobParams input;_passport : CM_Passport input) updating, protected;
/*
Date		Who		Reason
03 Aug 2011	cnwer1	Initial creation CCMS MES 1033
							refactored code block out of setForUpdateVoyage
30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/

vars
	aReq : CM_Request;
	aSlotReq : CM_SlotRequest;
	tmpSlotController	: CM_SlotController;
	voyageUpdateEvent	: Integer;
	theTI : CM_TrackedItem;
	theTIs : CM_TIArray;
	isLoad : Boolean;
begin


	voyageUpdateEvent := self.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);
	aSlotReq := _theJobParams.allSlotRequests.first;
	if aSlotReq &lt;&gt; null then
		isLoad :=  aSlotReq.isLoad;
	endif;
		// clear out allthe requests
	foreach aReq in self.allRequests do
		aSlotReq := aReq.CM_SlotRequest;
		if aSlotReq.isLoad = isLoad then // only clear out of same type
			if not _theJobParams.allSlotRequests.includes(aSlotReq) then
				aSlotReq.setJob(null);

				// ################################
				// This will update the display on screen of this slot
				tmpSlotController := aSlotReq.mySlotController;
				
				self.updateObjectEdition (tmpSlotController);	// par 30292
				
				self.myVoyage.causeEvent(voyageUpdateEvent, false, tmpSlotController);
			endif;
		endif;
	endforeach;
	
	create theTIs transient;
	foreach aSlotReq in _theJobParams.allSlotRequests do
		if not self.allRequests.includes(aSlotReq) then
			aSlotReq.setJob(self);
			// ################################
			// This will update the display on screen of this slot
			tmpSlotController := aSlotReq.mySlotController;
			
			self.updateObjectEdition (tmpSlotController);	// par 30292
			self.myVoyage.causeEvent(voyageUpdateEvent, false, tmpSlotController);
		endif;
		// attach the the cargo to us
		aSlotReq.getAllTrackedItems(theTIs);
		foreach theTI in theTIs do
			if theTI &lt;&gt; null then
				self.updateTICollections(theTI, null);// 01/04/2010 cnwcs5 par 23383
			endif;
		endforeach;
	endforeach;

epilog
	delete theTIs;
end;</source>
        <access>protected</access>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateVoyage" id="b3689f5e-275e-43c6-bb64-b9e9b1bddbbd">
        <updating/>
        <source>setForUpdateVoyage(_theJobParams:CMIF_VoyageJobParams input;_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/04/2010	cnwcs5	par 23383 - pass context info (null) to updateTICollections 
//									via new parameter (_extra)
// 09/02/2017	cnwdap1		TFS 3219 LNX Voyage Operations Enhancements
// 21/02/2017	cnwdap1		TFS 3489 LNX DLR/SOB
// ---------------------------------------------------------------------------

vars
	jobID : String;
	cta : CM_BlockController;
begin
	
	jobID := self.id;
	if self.isVoyageHoldJob and _theJobParams.isDischarge then													// TFS 3489
		self.setTITransitStatus(_theJobParams, _theJobParams.myProxyJob.allReceiveTrackedItems, _passport);		// TFS 3489
	endif;																										// TFS 3489
	self.setForUpdate(_theJobParams.myProxyJob, _passport.myTerminal);
	self.myUserJobType := _theJobParams.myProxyJob.myUserJobType;


	if not self.isVoyageHoldJob then								// TFS 3219
		//epr CCMS 1033 refactored code block into below method
		self.setForUpdateSlotRequests(_theJobParams,_passport);
		self.setBayId(_theJobParams);
	endif;															// TFS 3219

	if jobID &lt;&gt; self.id then
		if self.myJobSheet &lt;&gt; null and _theJobParams.autoSortIntoOOW then
			self.myJobSheet.removeInsertJobWithNewId(self);
		endif;
	endif;

// PAR 8378 removed moved up /\	self.remarks := self.getAutoRemarks();
	if _theJobParams.myJobType &lt;&gt; null then
		if _theJobParams.remarks &lt;&gt; null then
			self.remarks := _theJobParams.remarks;
		else
			self.remarks := _theJobParams.myJobType.name;
		endif;
	else
		self.setRemarks(_theJobParams.myProxyJob.remarks); // PAR 8378 added
	endif;
	
	if 	_theJobParams.resquence = true then
		self.setRequestSeqNumbers(_theJobParams);
		self.isTwinLift := self.canBeTwinLiftVoyageJob();
		///epr par 31205 3/4/13
		self.setDefaultLoadLanes(null,null); 
		
	endif;
	if not self.isVoyageHoldJob then								// TFS 3219
		self.check20TLWeightLimits(_theJobParams, _passport); // CCMS 1061 CentrePort
		self.check20TLHeightLimits(_theJobParams, _passport); // CCMS 1061 CentrePort
		
		self.setSidesAndNumHatches();
	endif;															// TFS 3219

	//epr par 33070 30/12/13
	if self.isDischarge then
		self.allowOutOfOrderLoading := false;
	else
		self.allowOutOfOrderLoading := _theJobParams.allowOutOfOrderLoading; //cnwrd1 par 30626 ccms 2209 23.10.12
	endif;
	app.writeVoyageLog(self, "Job Update");  // PAR 31878 - logging
	
	if self.myJobSheet &lt;&gt; null then // ### TFS 53105 30JUN2022 NAVAB1
		self.myJobSheet.setETC(); // ### TFS 53105 30JUN2022 NAVAB1
	endif;
	
epilog
	
end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setIsLoaded" id="f5e55b02-1bdd-4374-957b-969fa7d41a56">
        <updating/>
        <source>setIsLoaded(_loaded : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	//epr CCMS 2323 28/11/13
	if _loaded &lt;&gt; self.isLoadedToOperations then
		self.myVoyage.incrementPlanningVersion();
	endif;
	
	self.isLoadedToOperations := _loaded;

end;</source>
        <Parameter name="_loaded" type="Boolean"/>
