    <JadeMethod name="setForUpdate" id="ef1c9923-c25d-41d7-83aa-bef847fb177b">
        <updating/>
        <source>setForUpdate(_pxyEndpoint : SelfType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/04/2023	navdap1		Initial creation TFS 57207 EUP - Refactor Inspection App API Message
//
vars

begin
	self.defName := _pxyEndpoint.defName;
	self.endpoint := _pxyEndpoint.endpoint;
	self.verb := _pxyEndpoint.verb;
	
	self.myExternalWebServiceDef := _pxyEndpoint.myExternalWebServiceDef;
epilog

end;</source>
