    <JadeMethod name="writeOutputToMyForm" id="9faaf52e-bef6-45b3-88d8-8239690610d8">
        <source>writeOutputToMyForm( _str : String ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	cnwndl1	Initial creation	Par 27438

*/

vars

begin

	if myForm &lt;&gt; null then
		//myForm will be a "CMUI_FixupHandlerForm" form in UiCommonSchema.
		myForm.sendMsgWithParams("addOutput", _str);
	endif;

epilog

end;</source>
