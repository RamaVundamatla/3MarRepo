    <JadeMethod name="updateVoyage" id="f01d23b3-4338-4b03-88f5-e984ec2c2b8b">
        <updating/>
        <source>updateVoyage():Boolean updating;
// 10/12/2014  cnwdb2	PAR 35364

vars
	newSelectedVoyage:	CMIF_HMS_WorkingVoyage;
	workingMovement:	CMIF_HMS_WorkingMovement;
	clonedMovement:		CMIF_HMS_WorkingMovement;
	newClonedMovement:	CMIF_HMS_WorkingMovement;
	addVoyageChange:	CMIF_HMS_VoyageAdd;
	editVoyageChange:	CMIF_HMS_VoyageEdit;
	previousVoyage:		CMIF_HMS_WorkingVoyage;
	workingDelay:		CMIF_HMS_VoyageDelay;
	checkClearances,
	isNewVoyage:		Boolean;
	count:				Integer;
	cargo:				CM_Commodity;
	arrivedDT:			TimeStamp;
	departedDT:			TimeStamp;
	msgBoxType:			Integer;
	saveCode,
	msgString:			String;
	stevedore:			CM_Stevedore;
	tmpTerm:			CM_Terminal;
	arrivedLocal,
	departedLocal:		TimeStamp;
begin

	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();	
	
	if self.myHarbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, self.myTerminal.name, null, null);
	endif;

	if (not self.checkSecurity(PmHMSVoyageMaint,"HMS Voyage")) then
		return false;
	endif;
	
	if self.myCurrentWorkingVoyage = null then
		if self.myCurrentVessel = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Ship Name', null, null);
			app.raiseCMException(Input_required_field_shpName, null, null); // cnwdb2	PAR 35364
			
			return false;		// cnwdad1 21/06/2007 - PAR #14236.
		endif;
	endif;

	tmpTerm := self.cmbTerminalHMS.listObject.CM_Terminal;
	if tmpTerm = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', null, null);
		app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364

	endif;

	arrivedLocal.setDate(self.txtDateArrival.getDate());	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
	arrivedLocal.setTime(self.txtTimeArrival.getTime());
	arrivedDT := self.localToSystemTime(arrivedLocal);
	departedLocal.setDate(self.txtDateDepart.getDate());	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
	departedLocal.setTime(self.txtTimeDepart.getTime());
	departedDT := self.localToSystemTime(departedLocal);

	if arrivedDT &gt;= departedDT then
		// Display error message - the arrived date must be before the departed date
		self.fldVoyageMaint.topSheet := self.shtMovements;
		self.txtDateArrival.setFocus;
		app.raiseCMException2(HMSMovementDateTime, HMSMovementTypeArrival, 'before', null, null);
		return false;
	else
		self.myCurrentWorkingVoyage.arrivedDT := arrivedDT;
		self.myCurrentWorkingVoyage.departedDT := departedDT;			
	endif;			

	self.myCurrentWorkingVoyage.code := self.tbxVoyageCode.text;
	if (not self.myCurrentWorkingVoyage.checkForSameShipInPort(arrivedDT, departedDT)) then 
		// A booking already exists for this ship at this time
		self.fldVoyageMaint.topSheet := shtShip;
		self.cmbVessel.setFocus;		
	endif;
	
//	checkClearances := true;
	if self.myHarbour &lt;&gt; null then
		checkClearances	:=	self.myHarbour.isDoClearanceCheck;
	else
		checkClearances	:=	false;
	endif;
	
	if self.cbxPrefBerth.enabled = false 
	and self.cbxOtherBerth.enabled = false then
		// Do not set marks for berth
	else
		// Set marks for berth
		//self.check_PreferredBerth(false);

		// Set marks for berth		  
		if self.check_PreferredBerth(false) = false then
			// Berth not valid -choose another
			return false;
		endif;
		checkClearances := false;
	endif;
	
	/*epr 19/12/07 par 15467
		removed this saveCode stuff all it did was if the duplicate check failed it set the code back to the first voyage in the combo which 
		was in most cases not the same voyage selected.
	*/
	//saveCode := self.myCurrentWorkingVoyage.code;
	//self.myCurrentWorkingVoyage.code := self.tbxVoyageCode.text;
	if self.myCurrentWorkingVoyage.checkForDuplicateInCurrentView() then
		
		// Invalid voyage code - set focus to voyage code
		//self.myCurrentWorkingVoyage.code := saveCode;
		//self.tbxVoyageCode.text := saveCode;
		self.fldVoyageMaint.topSheet := self.shtShip;
		self.tbxVoyageCode.setFocus;
	endif;

	if app.myPassport.hasErrorsOrWarnings then
		if app.showErrorWarningDialog('Add Voyage', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings) = IDOK then
			//Carry on warning accepted
		else
			self.setAllErrorWarnings(app.myPassport);
			return false;
		endif;
	endif;
	self.clearErrorWarnings();

	// Set flag to denote that voyage is not yet saved to the database
	self.myCurrentWorkingVoyage.notYetSaved := true;

	self.myCurrentWorkingVoyage.ofTerminal := tmpTerm;
	
	//self.myCurrentWorkingVoyage.ofPortFrom := self.cbxPortFrom.listObject.CM_Port;
	self.myCurrentWorkingVoyage.ofPortFrom := self.cbxPortFrom.myObject.CM_Port;
	if self.myCurrentWorkingVoyage.ofPortFrom = null then
		//self.myCurrentWorkingVoyage.ofPortFrom := app.myRoot.allPorts.first;
		self.myCurrentWorkingVoyage.ofPortFrom := app.myRoot.allActivePorts.first;
	endif;
	
	//self.myCurrentWorkingVoyage.ofPortTo := self.cbxPortTo.listObject.CM_Port;
	self.myCurrentWorkingVoyage.ofPortTo := self.cbxPortTo.myObject.CM_Port;
	if self.myCurrentWorkingVoyage.ofPortTo = null then
		//self.myCurrentWorkingVoyage.ofPortTo := app.myRoot.allPorts.first;
		self.myCurrentWorkingVoyage.ofPortTo := app.myRoot.allActivePorts.first;
	endif;
	
	self.myCurrentWorkingVoyage.ofClassIn := cbxClassIn.listObject.HMS_VesselCategory;
	self.myCurrentWorkingVoyage.ofClassOut := cbxClassOut.listObject.HMS_VesselCategory;

	// Update discharge cargo list.
	count := 1;
	self.myCurrentWorkingVoyage.allCargoDischarge.clear;
	while count &lt;= lbxCargoForDis.listCount do
		cargo := lbxCargoForDis.itemObject[count].CM_Commodity;
		self.myCurrentWorkingVoyage.allCargoDischarge.add(cargo);
		count := count + 1;
	endwhile;

	// Update load cargo list.
	count := 1;
	self.myCurrentWorkingVoyage.allCargoLoad.clear;
	while count &lt;= lbxCargoForLoad.listCount do
		cargo := lbxCargoForLoad.itemObject[count].CM_Commodity;
		self.myCurrentWorkingVoyage.allCargoLoad.add(cargo);
		count := count + 1;
	endwhile;

	// Modified by Russell 04/05/99
	// --------------------------------------------------------------
	// Update discharge stevedore list.
	count := 1;
	self.myCurrentWorkingVoyage.allStevedoresDischarge.clear;
	while count &lt;= lbxSteveForDis.listCount do
		stevedore := lbxSteveForDis.itemObject[count].CM_Stevedore;
		self.myCurrentWorkingVoyage.allStevedoresDischarge.add(stevedore);
		count := count + 1;
	endwhile;

	// Update load stevedore list.
	count := 1;
	self.myCurrentWorkingVoyage.allStevedoresLoad.clear;
	while count &lt;= lbxSteveForLoad.listCount do
		stevedore := lbxSteveForLoad.itemObject[count].CM_Stevedore;
		self.myCurrentWorkingVoyage.allStevedoresLoad.add(stevedore);
		count := count + 1;
	endwhile;
	// ----------------------------------------------------------------

	// Modified by Russell 25/05/99
    // -------------------------------------------
    // Update comments
    self.myCurrentWorkingVoyage.shortComment := tbxComments.text;
    // -------------------------------------------

    //	Validate voyage
	if (not self.myCurrentWorkingVoyage.validateVoyage(checkClearances)) then
		return false;
	endif;

	if app.myPassport.hasErrorsOrWarnings() then
		if app.showErrorWarningDialog('Add Voyage', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings) = IDOK then
			//Warnings have been accepted
		else
			self.setAllErrorWarnings(app.myPassport);
			return false;
		endif;
	endif;
	self.clearErrorWarnings();
	// disarm the validation ex handler	
	on CM_Exception do null;	

	// Update views following the result of the validation
	self.hasSavedChanges := true;	
	newSelectedVoyage := self.myCurrentWorkingVoyage.createWorkingVoyage();	

	// Delete clonedVoyage, delays and movements
	foreach clonedMovement in myCurrentWorkingVoyage.allClonedMovements do
		clonedMovement.allWorkingResUsed.purge;
	endforeach;
	self.myCurrentWorkingVoyage.allCMIFVoyageDelays.purge;
	self.myCurrentWorkingVoyage.allClonedMovements.purge;
	delete myCurrentWorkingVoyage;
	// Reset selected voyage for 'APPLY' mode
	self.setMyCurrentWorkingVoyage(newSelectedVoyage);
	self.myViewController.systemVoyageCodeRoot := self.myViewController.systemVoyageCodeRoot+1;

	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
