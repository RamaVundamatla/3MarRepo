    <JadeMethod name="initializeForActivity" id="e5f5e21c-b68a-41f3-be93-c894a665da7c">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
04 May 2022	navab1	TFS 53569
*/

vars
	cargoEntity : CMIF_RefBizunitScoped;
	n4Carrier	: CMIF_RefCarrierService;
begin

	if _opsViewTable.isKindOf(CMIF_RefBizunitScoped) then
		cargoEntity := _opsViewTable.CMIF_RefBizunitScoped;
		cargoEntity.tableName := cargoEntity.Ref_bizunit_scoped;
		
		cargoEntity.gkey := cargoEntity.generateFullGKey(self, "");
	
		cargoEntity.id := self.code;
		cargoEntity.name := self.description;
		cargoEntity.life_cycle_state := cargoEntity.n4LifeCycleState(self);
	elseif _opsViewTable.isKindOf(CMIF_RefCarrierService) then // ### TFS 53105 21JUN2022 NAVAB1
		n4Carrier					:=	_opsViewTable.CMIF_RefCarrierService;
		n4Carrier.gkey		   		:= n4Carrier.generateFullGKey(self, "");
		n4Carrier.id                := n4Carrier.generateFullGKey(self, "").String;
		n4Carrier.name				:= self.description;
		n4Carrier.carrier_mode  	:= n4Carrier.Carrier_mode_Vessel;
		n4Carrier.life_cycle_state	:= n4Carrier.n4LifeCycleState(self);

	endif;
	

epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
