        <source>removeButton(_menuItem : MenuItem) updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	toolbarButton			: CMUI_ToolbarButton;
	control					: CMUI_ToolbarControl;
	toolbarArray			: CMUI_ToolbarControlArray;
	referenceType			: Integer;
begin

/*
	toolbarArray := self.allLeftControls;
	referenceType := CMUI_ToolbarButton.ReferenceType_MenuItem;
	
	foreach control in toolbarArray do
		toolbarButton := control.CMUI_ToolbarButton;
		if toolbarButton.referenceType = referenceType and toolbarButton.myMenuItem = _menuItem then
