    <JadeMethod name="getProgressString" id="d2a049e4-bf65-4cb1-a0b8-741a29ce81a4">
        <source>getProgressString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Nov 2023	naviv1	Bug 61241: EUP | Receive Cargo Work order progress not based on the Total Quantity of the cargo items
09 Dec 2024	navhl20 Bug MTN-33643: EUP - Partial move by weight is not working in Work Order Operation screen - Receive
*/

vars
	required,
	completed	: Any;
	ti			: CM_TrackedItem;
	invalidTI   : Boolean;
begin
	on Exception do app.handleDeletedObject(exception,ti,invalidTI);

	if self.getMyTerminal.isUseYardJobsForCargoWo then	
		ti := self.allSelectedTIs.first;												//09.12.2024 navhl20 #33643
		if ti &lt;&gt; null and ti.isBulkCargo then											//09.12.2024 navhl20 #33643
			required	:= self.getTotalRequest(false);
			completed	:= self.getTotalCompleted(false);
		else
			required	:= self.getTotalRequest(true).Integer;
			completed	:= self.getTotalCompleted(true).Integer;
		endif;
		return app.getErrorString2(N_of_n_Complete, completed.String, required.String);
	else
		return inheritMethod();
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReference" id="6cf1a719-e519-40a3-9bbb-cc79a9b11836">
        <source>getReference(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023	navhl20	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate

*/

vars

begin
	if self.myBookingRef &lt;&gt; null then
		return self.myBookingRef.bookingReference;
	endif;
	if self.myBillOfLading &lt;&gt; null then
		return self.myBillOfLading.number;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalRequest" id="63754f87-27ab-46e9-bc38-eac5054d3995">
        <source>getTotalRequest(_qty: Boolean) : Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Nov 2023	naviv1	Bug 61241: EUP - Receive Cargo Work order progress not based on the Total Quantity of the cargo items
17 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/
vars
	ti		: CM_TrackedItem;
	total	: Integer;
	wt   	: Decimal[14,4];
	invalid	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	if _qty then
		foreach  ti in self.allSelectedTIs discreteLock do  		//28.05.2024 navma1 #64224
			invalid := false;
			ti.edition;
			if invalid then
				continue;
			endif;
			
			total := total + ti.totalQuantity;
		endforeach;
		return total;
	else
		foreach  ti in self.allSelectedTIs discreteLock do   		//28.05.2024 navma1 #64224	
			invalid := false;
			ti.edition;
			if invalid then
				continue;
			endif;
			
			wt := wt + ti.totalWeight;
		endforeach;
		return wt;
	endif;
epilog

end;</source>
        <Parameter name="_qty" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getTrains" id="54d11b87-cb9a-4156-b347-a655ae6c60ca">
