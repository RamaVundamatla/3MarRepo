    <JadeMethod name="hasChildren" id="d0927adb-62a6-4653-bb5a-901c3b24ef8d">
        <source>hasChildren():Boolean;
// --------------------------------------------------------------------------------
// Created:		31 October 2005 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver has child
//				menu entities.
//
// Parameters:	None
//
// Returns:		True if the receiver has children, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.allChildren.cnEcIsNotEmpty();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasWebReports" id="9239c037-0cbf-4e8e-92e2-d63f43919386">
        <source>hasWebReports() : Boolean;
// -------------------------------------------
// Created 01 November 2004 by cnwdvb1
// -------------------------------------------
vars

	menuEnt	: CM_MenuEntity;

	

begin

	foreach menuEnt in self.allChildren do
		if menuEnt.hasWebReports() then
			return true;
		endif;
	endforeach;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
