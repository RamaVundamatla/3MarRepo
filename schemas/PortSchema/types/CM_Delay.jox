    <JadeMethod name="getNiceName" id="26cee1ba-c943-4b3e-aad4-d3134c812eb4">
        <source>getNiceName(): String;
/*
Purpose:			
Date		Who		Reason
03 April 2014	cnwab1	Initial creation
*/

vars
	str : String;
begin


	if self.myDelayType &lt;&gt; null then
		str := self.myDelayType.description;
		
		if self.myVoyage &lt;&gt; null then
			str := str &amp; " - " &amp; self.myVoyage.code;
		endif;
		if self.myMachine &lt;&gt; null then
			str := str &amp; " - " &amp; self.myMachine.code;
		endif;
	endif;

	
	if str &lt;&gt; "" then
		return str;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOverlapInterval" id="f6157995-656c-41f2-8475-394263e3e848">
        <source>getOverlapInterval( _startTS : TimeStamp; _endTS : TimeStamp ):TimeStampInterval;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	startOverlap : TimeStamp;
	endOverlap : TimeStamp;
	returnInterval :TimeStampInterval;

begin

	if _endTS &lt; self.startDT then
		// range ends before I start
		return null;
	endif;
	
	if _startTS &gt; self.getEndDT then
		// range starts after I End
		return null;
	endif;
	
	// establish the first time and we overlap with the range.
	if self.startDT &lt;= _startTS then
		startOverlap := _startTS;
	else
		startOverlap := self.startDT;
	endif;
	
	//establish the last minute that overlapped.
	if self.getEndDT &lt;= _endTS then
		endOverlap := self.getEndDT;
	else
		endOverlap := _endTS;
	endif;
	
	returnInterval := endOverlap - startOverlap;
	return returnInterval;

epilog

end;</source>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <ReturnType type="TimeStampInterval"/>
    </JadeMethod>
    <JadeMethod name="getShiftMinutesForADelay" id="d93041eb-f97a-43f0-a7d0-0478b923c656">
        <source>getShiftMinutesForADelay(_from, _to : TimeStamp) : Real;
// ---------------------------------------------------------------------------
// Created:		03 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aDelay : CM_Delay;
	numHoursDelaid : Real;
	fromTS, toTS : TimeStamp;
	rfromTS, rtoTS : TimeStamp;
	delayIsOnShift : Boolean;
	posNeg, numOfDays : Integer;
begin
	
	aDelay := self;
	delayIsOnShift := false;
	
	fromTS := aDelay.startDT;
	toTS := aDelay.endDT;
	if not toTS.isValid() then
		toTS := aDelay.estEndDT;
	endif;
	rfromTS := fromTS;
	rtoTS := toTS;
	
	if fromTS &gt;= _from and fromTS &lt;= _to then // delay begins within shift
		delayIsOnShift := true;
		if toTS &gt; _to then // delay ends after shift
			toTS := _to;
		endif;
	elseif toTS &gt;= _from and toTS &lt;= _to then // delay ends within shift
		delayIsOnShift := true;
		fromTS := _from;
	elseif _from &gt;= fromTS and _to &lt;= toTS  then // delay if for the whole shift
		delayIsOnShift := true;
		fromTS := _from;
		toTS := _to;
	endif;

	if delayIsOnShift then
			numHoursDelaid := fromTS.differenceAsTime(toTS,posNeg, numOfDays).getTotalMilliseconds/ 60000;
	endif;

	return numHoursDelaid;
end;</source>
        <Parameter name="_from" type="TimeStamp"/>
        <Parameter name="_to" type="TimeStamp"/>
        <ReturnType type="Real"/>
    </JadeMethod>
