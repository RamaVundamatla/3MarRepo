    <JadeMethod name="getMovesOnSelectedDate" id="de4556b2-950a-4540-8440-90d975f323b4">
        <source>getMovesOnSelectedDate( _selectedDate : Date; _allHistoryMoves : CM_MachineHistoryByDateTime io );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	
	firstHistory : CM_MachineHistory; 
	startTime : Time;
	startTimeStamp : TimeStamp;
	history : CM_MachineHistory;
	iter : Iterator;
	
begin

	
	if self.history.isEmpty then
		return;
	endif;
	
	startTime.setTime(00,00,00,001);
	startTimeStamp.setDate(_selectedDate);
	startTimeStamp.setTime(startTime);
	
	firstHistory := self.history.getAtKeyGeq(startTimeStamp);
	
	if firstHistory = null or firstHistory.dateTime.Date &lt;&gt; _selectedDate then
		return;
	endif;
	
	iter := self.history.createIterator;
	iter.startAtObject(firstHistory);
	while iter.next( history ) do
		if history.dateTime.Date &lt;&gt; _selectedDate then
			break;
		endif;
		if not history.isMoveHistory then
			continue;
		endif;
		_allHistoryMoves.add(history);
	endwhile;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_selectedDate" type="Date"/>
        <Parameter name="_allHistoryMoves" type="CM_MachineHistoryByDateTime" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMultiMoveCargoAsJSON" id="5196f420-2f6f-4335-a161-2de9e7ef6714">
        <source>getMultiMoveCargoAsJSON() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2022	jlier1	Initial creation 53023
20 Mar 2023 jlier1  57064       Refactored JSON returned - changes so numbers are returned as numbers, timestamp and  measurement fields as objects
*/

vars
	response			: String;	
	cargo	: CM_TrackedItem;
	allCargo : CM_TISet;
	task : CM_RTQueueTask;
	allEntTableRows : EntTableRowArray;
	machConfig 			: CM_RTVehicleConfig;
	cmifVehicleAppJSON : CMIF_VehicleAppJSON;
begin
	create allCargo transient;
	foreach task in self.allCurrentQueueTasks discreteLock do 
		if task.ti = null then
			continue;
		endif;
		if task.myEntry.isMachineInitiatedMove then
			allCargo.add(task.ti);			
		endif;
	endforeach;
	
	create cmifVehicleAppJSON transient;
	return cmifVehicleAppJSON.getDirectorCargoAsJSON(self,allCargo);
	
	return response;
epilog
	delete allCargo;
	delete cmifVehicleAppJSON;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
