    <JadeMethod name="exportAsXMLDocGetChildRefKey" id="77bec012-b086-42c8-9040-36a8f593dc90">
        <source>exportAsXMLDocGetChildRefKey(_property: Property input) : Property;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	
begin

	if _property = CM_ROROLocnDefn::myAdjacentSlotAft then
		return CM_ROROLocnDefn::code;
	elseif  _property = CM_ROROLocnDefn::myAdjacentSlotFwd then
		return CM_ROROLocnDefn::code;
	endif;
	
	return inheritMethod(_property);
	

epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Property"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="cc1c1abb-d279-496d-8877-b14fc0b01acd">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	cnwer1	Initial creation CCMS 1031
28 Sep 2011 cnwer1	PAR 28276
*/

vars

begin
	if _property = CM_ROROLocnDefn::allROROSlotDefnByOrdinal then
		return ExportAsParent;
	elseif  _property = CM_ROROLocnDefn::myAdjacentSlotAft then
		return ExportAsChild;
	elseif  _property = CM_ROROLocnDefn::myAdjacentSlotFwd then
		return ExportAsChild;
	elseif _property = CM_ROROLocnDefn::allHazardsAllowed then
		return ExportAsParent;
	endif;
	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="fixRotatedLinked" id="7d5fbfa6-eb0e-493a-a17f-57b2cea4ce34">
        <updating/>
        <source>fixRotatedLinked() updating;
/*
Purpose:			set new inverse in the 811 upgrade
Date		Who		Reason
05 March 2012	cnwab1	Initial creation
*/

vars
	locn : CM_ROROLocnDefn;
begin
	if self.voltageType = 0 then 
		return;
	endif;
	if self.myLayout.myDeckLayer.type &lt;&gt; ROROLayerType_CCLoad then // I AM THE CLONE
		return;
	endif;

	if self.myRotateDischarge &lt;&gt; null or self.myRotateLoad &lt;&gt; null then
		return;
	endif;
	
	locn :=  self.myDeck.allROROLocnDefnByOrdinal[self.voltageType];
	if locn &lt;&gt; null then
		self.myRotateDischarge := locn;
		self.voltageType := 0;
		self.hasBeenRotatedForLoad := true;
		locn.hasBeenRotatedForLoad := true;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAft40LocnInRotateGroup" id="253fb47e-2a48-4db0-b2b8-4a3deee28ac8">
        <source>getAft40LocnInRotateGroup() : CM_VoyageROROController;
/*
Purpose:	if we have a 1X5 right next to another 1X5 in actual view, and in load view we have 40' colour coding across both of the rotated areas, 
				then see if the aft is not in our group, if it is not return the aft so that it's group can be rotated as well.		
Date		Who		Reason
20 March 2012	cnwab1	Initial creation
*/

vars
	actualLocn, aftLocn : CM_ROROLocnDefn;
	roroReq, aftReq : CM_ROROSlotRequest;
begin
	foreach actualLocn in self.allPlannedRotatedLocnDefns discreteLock do

		// has this location got any front end 40 CC
		roroReq :=  actualLocn.myRotateLoad.getColourCoding40(LOAD_MOVETYPE, false);
		
		if roroReq &lt;&gt; null then
			aftReq := roroReq.mySlotRequestAft;
			// yes so get the aft request
			if aftReq &lt;&gt; null then
				// get the aft location
				aftLocn := aftReq.myROROController.getDefn().CM_ROROLocnDefn;
				if aftLocn &lt;&gt; null then
					// if the aft's actual location is not in our rotated group then pass it back
					if not aftLocn.myRotateDischarge = null // PAR 31110 during testing
					and not self.allPlannedRotatedLocnDefns.includes(aftLocn.myRotateDischarge) then
						if aftLocn.myRotateDischarge.isPlannedRotated then
							return aftReq.myROROController;
						endif;
					endif;
				endif;
			endif;
		endif;
	
	endforeach;

	return null;
epilog

end;</source>
        <ReturnType type="CM_VoyageROROController"/>
    </JadeMethod>
    <JadeMethod name="getAftLocnDefn" id="eb2e25b7-b7e1-48fc-addc-27347af3d8d7">
