	self.mulVolDescReasons.readOnly 		:= true;		// 30/4/19 MAP TFS41707
	self.mulWorkOrderStatus.readOnly 		:= true;   		// 23/09/2022 navds20 TFS 54253
	self.mulEventTypes.readOnly				:= true;		//09 Mar 2020	TFS 48784
