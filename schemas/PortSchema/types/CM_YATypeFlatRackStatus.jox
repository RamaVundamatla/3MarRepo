    <JadeMethod name="getDataDisplay" id="88fd6d43-7ed6-42f0-95e7-e8e0f63618d3">
        <source>getDataDisplay(_dataObj : CM_YAData): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG on LOLO Planning Screen
//
vars
	int : Integer;
	displayString : String;

begin
	if _dataObj.isKindOf(CM_YADataPattern) then
		return _dataObj.CM_YADataPattern.getDataDisplay(self);
	endif;

	foreach int in _dataObj.CM_YADataInteger.allValues do
		if displayString = null then
			displayString := app.flatRackEndsEnumToString(int);	//19 Nov 2020	NDL	TFS 50347
		else
			displayString := displayString &amp; ", " &amp; app.flatRackEndsEnumToString(int);
		endif;
	endforeach;
	
	return displayString;
epilog

end;</source>
        <Parameter name="_dataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
