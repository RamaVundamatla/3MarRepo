<PrimType name="Date">
    <JadeMethod name="jssAddDays" id="f83f149e-ae98-4422-b0a6-6e6a98aa8cbe">
        <source>jssAddDays(pDays:Integer):Date;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of days to the
//				receiver date.
//
// Parameters:	pDays (Integer) - The number of days to add (or subtract).
//
// Returns:		The resulting date.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self + pDays;
end;</source>
        <Parameter name="pDays" type="Integer"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssAddMonths" id="9df72af4-de8c-4e5a-bfac-33fa4b2f1f81">
        <source>jssAddMonths(pMonths:Integer) : Date;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of months to the
//				receiver date.
//
// Parameters:	pMonths (Integer) - The number of months to add (or subtract).
//
// Returns:		The resulting date.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dayNum		: Integer;
	monthNum	: Integer;
	yearNum		: Integer;
	daysInMonth : Integer;
	dateResult	: Date;
    
begin
	// Copy year, month and day attributes from self to local variables for computation.
	
	yearNum		:=	self.year();
	monthNum	:=	self.month();
	dayNum		:=	self.day();

	// Handle negative months parameters by going backwards in time.
	
	if monthNum + pMonths &lt; 1 then
		yearNum	:=	yearNum + (monthNum + pMonths - 12) div 12;
	else
		yearNum	:=	yearNum + (monthNum + pMonths - 1) div 12;
	endif;

	monthNum	:=	(monthNum + pMonths - 1) mod 12 + 1;
    
	if monthNum &lt; 1 then
		monthNum	:=	monthNum + 12;
	endif;

    // If end day exceeds last day of month, set day equal to the last day of the month.
    
	daysInMonth	:=	monthNum.jssDaysInMonth(yearNum.jssIsLeapYear());
    
	if dayNum &gt; daysInMonth then
		dayNum	:=	daysInMonth;
	endif;

	dateResult.setDate(dayNum, monthNum, yearNum);

	return dateResult;
end;</source>
        <Parameter name="pMonths" type="Integer"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssAddYears" id="7c9749ac-c106-4c09-9345-f3ccb809f8e7">
        <source>jssAddYears(pYears:Integer):Date;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of years to the
//				receiver date.
//
// Parameters:	pYears (Integer) - The number of years to add (or subtract).
//
// Returns:		The resulting date.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
    dayNum		: Integer;
    monthNum	: Integer;
    yearNum		: Integer;
    dateResult	: Date;

begin
	// Copy year, month and day attributes from self to local variables for computation.

	yearNum		:=	self.year() + pYears;
	monthNum	:=	self.month();
	dayNum		:=	self.day();

	// Handle special case where we end up with 29 Feb on non leap year, round down to 28th.
    
	if monthNum = 2 and dayNum = 29 and not yearNum.jssIsLeapYear() then
		dayNum	:=	28;
	endif;

	dateResult.setDate(dayNum, monthNum, yearNum);

	return dateResult;
end;</source>
        <Parameter name="pYears" type="Integer"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssCurrentAge" id="dab2c122-4d46-4183-bef2-033e931cceb7">
        <source>jssCurrentAge():String;
// --------------------------------------------------------------------------------
// Created:		03 January 2002 by cnwdad1
//
// Purpose:		Returns a string showing the age difference between the receiver and
//				the current date.  The returned value will be in the format of YYY:MM:DD,
//				where YYY = years, MM = months, and DD = days.
//
//				If a valid date supplied, return current age in the format years:months:days .
//				If invalid date format or a date in the future return null.
//
//				This method also requires the jssIsInFuture method.
//
// Parameters:	None
//
// Returns:		The current age as a string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// --------------------------------------------------------------------------------
vars
	birthday	: String;			// Birth date
	today		: String;			// Today
	workArea	: String;			// Work area to carry this years birthday date
	age			: String;          	// Return Value  years:months:days
	ageYears	: Integer;			// Work area for years portion of the result
	ageMonths	: Integer;			// Work area for months portion of the result
	ageDays		: Integer;			// Work area for days portion of the result		

begin
	// Invalid date or date format, return null and stop.
	
	if self.Date = null or not self.Date.isValid() then
		return null;
	endif;

	birthday	:= self.format("dd-MM-yyyy");   
	today		:= app.actualTimeServer().Date.format("dd-MM-yyyy");// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

	// If the date is in the future, return null and stop.
	
	if birthday.Date.jssIsInFuture() then
		return null;
	endif;

	// We have a valid date to work with.

   	workArea		:= birthday;
   	workArea[7:4]	:= today[7:4];						// Modify the year to become the actual date of this year's Birthday.

	if workArea.Date.jssIsInFuture() then
		ageYears	:= today[7:4].Integer - birthday[7:4].Integer - 1;	
	else
		ageYears	:= today[7:4].Integer - birthday[7:4].Integer;
	endif;

	age[1:3]	:= ageYears.String;						// Set the years value.
	age[4:1]	:= ":";

	if birthday[1:2] &lt;= today[1:2] then      			// Birthday 'day of the month' has occurred 
		if birthday[4:2] &gt; today[4:2] then   			// Birthday 'month' hasn't occurred yet.      
			ageMonths	:= 12 + today[4:2].Integer - birthday[4:2].Integer;
		else											// Birthday 'month' has occurred.
			ageMonths	:= today[4:2].Integer - birthday[4:2].Integer;
		endif;

		ageDays	:= today[1:2].Integer - birthday[1:2].Integer;       	
	endif;

	if birthday[1:2] &gt; today[1:2] then     				// Birthday 'day of the month' hasn't occurred yet.
		if birthday[4:2] &gt;= today[4:2] then   			// Birthday 'month' or before.
			ageMonths := 12  + today[4:2].Integer - birthday[4:2].Integer -1 ;
		else  	
			ageMonths := today[4:2].Integer - birthday[4:2].Integer - 1;
		endif;

		ageDays	:= 31;									// How many days between the relevant day last month and this month. Initially assume 31.

		// If last month was Apr, Jun, Sep or Nov change it to 30.
		
		if today[4:2].Integer - 1 = 4 or today[4:2].Integer - 1 = 6 or today[4:2].Integer - 1 = 9 or today[4:2].Integer - 1 = 11 then
			ageDays	:= 30;
		endif;

		if today[4:2].Integer - 1 = 2 then				// Last month was February.
			ageDays	:= 28;

			if today.Date.isLeapYear() then
				ageDays	:= 29;
			endif;
		endif;

		ageDays	:= ageDays - birthday[1:2].Integer + today[1:2].Integer;
	endif;

	age[5:2]	:= ageMonths.String;					// Set the months value.
	age[7:1]	:= ":";
	age[8:2]	:= ageDays.String;						// Set the days value.

	// Correct any alignment problems caused by going from Integer to String during calculations.
	
	if age[3:1] = " " then
		age[2:2]	:= age[1:2];
		age[1:1]	:= " ";
	endif;

	if age[3:1] = " " then
		age[2:2]	:= age[1:2];
		age[1:1]	:= " ";
	endif;

	if age[6:1] = " " then
		age[6:1]	:= age[5:1];
		age[5:1]	:= " ";
	endif;

	if age[9:1] = " " then
		age[9:1]	:= age[8:1];
		age[8:1]	:= " ";
	endif;

	return age;									//  Return value and stop.
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssDaysInMonth" id="3d56ac0a-9191-4921-9a49-b08e8b5ea6df">
        <source>jssDaysInMonth():Integer;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns the number of days in the month of the receiver.
//
// Parameters:	None
//
// Returns:		The number of the days.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.month().jssDaysInMonth(self.year().jssIsLeapYear());
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssDaysInYear" id="2d2fa386-212c-450c-936a-f98ffbbc8641">
        <source>jssDaysInYear():Integer;
// --------------------------------------------------------------------------------
// Created:		09 April 2002 by cnwdad1
//
// Purpose:		Returns the number of days in the year of the receiver.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theMonth	: Integer;
	daysInYear	: Integer;

begin
	foreach theMonth in 1 to 12 do
		daysInYear	:=	daysInYear + theMonth.jssDaysInMonth(self.year().jssIsLeapYear());
	endforeach;

	return daysInYear;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssGetCentury" id="51fbba9a-616d-43fc-986e-5d16b038d943">
        <source>jssGetCentury():Integer;
// --------------------------------------------------------------------------------
// Created:		16 August 2001 by cnwdad1
//
// Purpose:		Returns the receiver's century.  If the receiver is not valid, then
//				a value of zero will be returned.
//
// Parameters:	None
//
// Returns:		The two-digit century as an integer.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self &lt;&gt; null and self.isValid() then
		return (self.year() - self.format("yy").Integer) div 100;
	else
		return 0;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssGetLastMonday" id="248c00fd-301c-45ea-88a7-493e773a3b88">
        <source>jssGetLastMonday():Date;
// --------------------------------------------------------------------------------
// Created:		30 August 2001 by cnwdad1
//
// Purpose:		Returns the date of the last Monday prior to the date of the
//				receiver.  If the receiver is already a Monday, then the previous
//				Monday will be returned.
//
// Parameters:	None
//
// Returns:		The date of the next Monday.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.dayOfWeek() = 1 then
		return self - 7;
	else
		return self - self.dayOfWeek() + 1;
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssGetLastSunday" id="b2391b62-3803-4428-9c27-72bcacb18589">
        <source>jssGetLastSunday():Date;
// --------------------------------------------------------------------------------
// Created:		30 August 2001 by cnwdad1
//
// Purpose:		Returns the date of the last Sunday prior to the date of the
//				receiver.  If the receiver is already a Sunday, then the previous
//				Sunday will be returned.
//
// Parameters:	None
//
// Returns:		The date of the next Monday.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self - self.dayOfWeek();
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssGetNextMonday" id="9ba0288d-6777-4752-b10d-2b9ac3446992">
        <source>jssGetNextMonday():Date;
// --------------------------------------------------------------------------------
// Created:		30 August 2001 by cnwdad1
//
// Purpose:		Returns the date of the next Monday following the date of the
//				receiver.  If the receiver is already a Monday, then the following
//				Monday will be returned.
//
// Parameters:	None
//
// Returns:		The date of the next Monday.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self - self.dayOfWeek() + 8;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssGetNextSunday" id="5fe30028-5235-41bd-b838-5a5f83580fcd">
        <source>jssGetNextSunday():Date;
// --------------------------------------------------------------------------------
// Created:		30 August 2001 by cnwdad1
//
// Purpose:		Returns the date of the next Sunday following the date of the
//				receiver.  If the receiver is already a Sunday, then the following
//				Sunday will be returned.
//
// Parameters:	None
//
// Returns:		The date of the next Monday.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.dayOfWeek() = 7 then
		return self + 7;
	else
		return self - self.dayOfWeek() + 7;
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssGetPreviousWeekDay" id="e55ad8ad-7b76-4a0e-a04f-dd530b71ae9e">
        <source>jssGetPreviousWeekDay():Date;
// --------------------------------------------------------------------------------
// Created:		30 August 2001 by cnwdad1
//
// Purpose:		Returns the previous week day to the receiver.
//
// Parameters:	None
//
// Returns:		The date of the previous week day.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	previousDay	: Date;
	
begin
	previousDay	:=	(self - 1);
	
	if previousDay.dayOfWeek() &gt; 5 then
		return previousDay - (previousDay.dayOfWeek() - 5);
	else
		return previousDay;
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssGetWeek" id="c79e1e7f-a911-4543-850d-d0109fd42140">
        <source>jssGetWeek():Integer;
// --------------------------------------------------------------------------------
// Created:		19 December 2000 by cnwdad2
//
// Purpose:		Returns the Year's week number for the receiver.
//
// Parameters:	None
//
// Returns:		Integer - The week number.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.dayOfWeek() = 7 then
		return (self.dayOfYear() div 7);
	else
		return ((self.dayOfYear() div 7) + 1);
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssIsBetween" id="12d23624-ea27-4ce9-962b-0dda1f22633c">
        <source>jssIsBetween(pStartDate:Date; pEndDate:Date):Boolean;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Check to see whether the receiver is within the range of the dates
//				passed in.  A null receiver is treated as always in the range.
//
// Parameters:	pStartDate (Date) - The starting (lower range) date.
//				pEndDate (Date) - The ending (upper range) date.
//
// Returns:		True if the receiver is between the specified dates, otherwise false.
//				NOTE: False is returned if the receiver is null or not a valid date.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self = null then
		return false;
	elseif not self.isValid() then
		return false;
	endif;

	if pStartDate &lt;&gt; null then
		if pStartDate &gt; self then
			return false;
		endif;
	endif;

	if pEndDate &lt;&gt; null then
		if pEndDate &lt; self then
			return false;
		endif;
	endif;

	return true;
end;</source>
        <Parameter name="pStartDate" type="Date"/>
        <Parameter name="pEndDate" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsInFuture" id="9053014a-5834-460a-b942-da54b6431f16">
        <source>jssIsInFuture():Boolean;
// --------------------------------------------------------------------------------
// Created:		03 January 2002 by cnwdad1
//
// Purpose:		Returns true if the receiver is in the future.
//
// Parameters:	None
//
// Returns:		True if the receiver is in the future, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// --------------------------------------------------------------------------------
vars
	testDate	: String;					// Date given
	today		: String;					// Today

begin
	// If Invalid Date or Date format, return false and break.
	
	if self.Date = null
	or not self.Date.isValid()
	then
		return null;
	endif;

	testDate	:= self.format("dd-MM-yyyy");   
	today		:= app.actualTimeServer().Date.format("dd-MM-yyyy");// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

	if testDate[7:4] &gt; today[7:4] then		// Year is in the future, return true and break.
		return true;
	endif;

	// Current Year and Month is in the future, return true and break.
	
	if testDate[7:4] = today[7:4]
	and testDate[4:2] &gt; today[4:2]
	then
		return true;
	endif;

	// If Current Year and Current Month and day is in the future, return true and break.
	
	if testDate[7:4] = today[7:4]
	and testDate[4:2] = today[4:2]
	and testDate[1:2] &gt; today[1:2]
	then
		return true;
	endif;

	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsWeekDay" id="b30479a6-6252-4c28-acf9-59a2a6d24987">
        <source>jssIsWeekDay():Boolean;
// --------------------------------------------------------------------------------
// Created:		31 August 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is a week
//				day.
//
// Parameters:	None
//
// Returns:		True if the receiver is a week day, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.dayOfWeek &lt;= 5);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</PrimType>
