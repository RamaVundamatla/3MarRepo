    <JadeMethod name="isToBeApplied" id="9d03da8a-7758-4cad-96ff-d3a38a933c3a">
        <source>isToBeApplied(_stopType : Integer; _ti : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:		26 February 2003  by Jason Chapman  (cnwjc2)
// should this stop be applied for this area and cargo type
// ---------------------------------------------------------------------------
vars
	result : Boolean;
begin
	if self.isStopApply(_stopType, _ti.myTerminal) then
//		result := self.isStopRelevant(_ti.cargoType, _ti) and self.isStopProcessActionOK( _ti); //par 17724 Sept 2008 //cnwrd1 4.11.08 CCMS JMT 1743/1764 	// cnwrl1 10/02/2010 PAR 22307 - what it was
		result := self.isStopRelevant( _ti ) and self.isStopProcessActionOK( _ti ) and self.isStopCEDOApplicable(_ti);		 // isStopCEDOApplicable cnwrd1 29.3.2010 par 22903
	else
		result := false;
	endif;
	return result;
end;</source>
        <Parameter name="_stopType" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isToBeAppliedBOL" id="4d429fde-4690-4abe-8659-2556d99b3e73">
        <source>isToBeAppliedBOL(_stopType : Integer; _bol : CM_BOL) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 April 2014	cnwmc5	Initial creation	CCMS 2352

*/

vars
	
begin
	if self.isStopApply(_stopType, _bol.myTerminal) then
		return self.isStopRelevantBOL(_bol);
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_stopType" type="Integer"/>
        <Parameter name="_bol" type="CM_BOL"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isToBePrevented" id="7ec157cf-c487-4749-819a-54dfe9123142">
        <source>isToBePrevented(_stopType : Integer; _ti : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:		26 February 2003  by Jason Chapman  (cnwjc2)
// should this stop be prevent the action for this area and cargo type
// ---------------------------------------------------------------------------
// 01/07/2010	cnwcs5	par 24341 - remove method call to self.isValidForTranshipSetting
// 01 Oct 2010  cnwrs1  par25912 allow for tranship coastals
// 20 Oct 2022	navsj20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
vars
	isStopPrevent, isValidForStopCriteria, isValidForCoastalSetting,isValidForChildSetting, isOKMTFULL  : Boolean;
	term : CM_Terminal;
begin

	/*
	For Debugging 
	
	if process.isJLGAB1() then
		isStopPrevent 			 := self.isStopPrevent(_stopType, _ti.myTerminal);
		isValidForStopCriteria   :=  self.isValidForStopCriteria(_ti);
		isValidForCoastalSetting :=  self.isValidForCoastalSetting(_ti.isCoastalInbound, _ti.isCoastalOutbound, _ti.myTerminal);
		isValidForChildSetting   := self.isValidForChildSetting(_ti.isChild, _ti.myTerminal);
		isOKMTFULL 				 :=   (self.isValidForMTs(_ti.isEmpty(), _ti.myTerminal) or  self.isValidForFulls(_ti.isEmpty(), _ti.myTerminal));
		
		if isStopPrevent
		and isValidForStopCriteria
		and isValidForCoastalSetting
		and isValidForChildSetting
		and isOKMTFULL then
			return true;
		else
			return false;
		endif;
	*/
	
	term := _ti.myTerminal;
	
	if self.isStopPrevent(_stopType, term) and  			 //cnwrs1 par 17129 June 2008
	   self.isValidForStopCriteria(_ti) and	   				 //20.10.2022	navsj20	TFS 53862
	   self.isValidForCoastalSetting(_ti.isCoastalInbound, _ti.isCoastalOutbound, term) and //cnwrs1 par 17129 June 2008  //cnwrs1 par25912 1 Oct 2010
	   self.isValidForChildSetting(_ti.isChild, term) and 	 //cnwrs1 par 17129 June 2008
	   (self.isValidForMTs(_ti.isEmpty(), term) or 		 	 //cnwrs1 par 17129 June 2008
		self.isValidForFulls(_ti.isEmpty(), term)) then   	 //cnwrs1 par 17129 June 2008
		return true;
	else
		return false;
	endif;

end;</source>
        <Parameter name="_stopType" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isToBePreventedBOLStop" id="6fe8cd28-d825-4fb1-a8d5-e0865bf2d26c">
        <source>isToBePreventedBOLStop(_stopType : Integer; _bol : CM_BOL; _terminal : CM_Terminal) : Boolean;
// ---------------------------------------------------------------------------
// Created:		Aug 2007 cnwrs1 ccms 1017
// should this stop be prevent the action for this area and cargo type
// ---------------------------------------------------------------------------
vars

begin
	if self.isStopPrevent(_stopType, _terminal) and  //cnwrs1 par 17129 June 2008
	   self.isValidForCargoType(_bol.bolType) then
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="_stopType" type="Integer"/>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isToBeProcessed" id="b2610523-da4f-4430-8d7a-a6864930be89">
        <source>isToBeProcessed(_stopType : Integer; _ti : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:		Apr 2007 cnwrs1
// should this stop de removed for this area and cargo type
// ---------------------------------------------------------------------------
// 01/07/2010	cnwcs5	par 24341 - remove method call to self.isValidForTranshipSetting
// 01 Oct 2010  cnwrs1      par25912 allow for tranship coastals
// 20 Oct 2022	navsj20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
vars

begin
	if self.isStopProcess(_stopType, _ti.myTerminal) and  //cnwrs1 par 17129 June 2008
	   //self.isValidForCargoType(_ti.cargoType) and		//20.10.2022	navsj20	TFS 53862
	   self.isValidForStopCriteria(_ti) and		//20.10.2022	navsj20	TFS 53862
	   self.isValidForCoastalSetting(_ti.isCoastalInbound, _ti.isCoastalOutbound, _ti.myTerminal) and //cnwrs1 par 17129 June 2008  //cnwrs1 par25912 1 Oct 2010
	   // par 24341 self.isValidForTranshipSetting(_ti.isTranshipItem, _ti.myTerminal) and //cnwrs1 Jan 2010
	   self.isValidForChildSetting(_ti.isChild, _ti.myTerminal) then //cnwrs1 par 17129 June 2008
		if self.isValidForMTs(_ti.isEmpty(), _ti.myTerminal) or //cnwrs1 par 17129 June 2008
			self.isValidForFulls(_ti.isEmpty(), _ti.myTerminal) then //cnwrs1 par 17129 June 2008
			return true;
		endif;
	else
		return false;
	endif;
end;</source>
        <Parameter name="_stopType" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTranshipStop" id="c80c50a0-a3d6-428c-8621-9642c972b097">
        <source>isTranshipStop(_terminal :CM_Terminal):Boolean;
// ---------------------------------------------------------------------------
// Created:     01 July 2010 by cnwcs5
// Purpose:     
// Parameters:  _terminal
// Returns:     true if the stop table is auto applied for tranship items
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.isStopApply(StopApplyTranship, _terminal);
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
