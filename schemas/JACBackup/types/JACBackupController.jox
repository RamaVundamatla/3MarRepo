    <JadeMethod name="backupException" id="0caa1ba3-912b-404b-b192-fcbb12ee6950">
        <updating/>
        <source>backupException(_ex:Exception) :Integer updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	subject,message:String;

begin

	on Exception do app.horribleExceptionHandler(_ex);

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' &gt;&gt; Error ' &amp; _ex.errorCode.String, LogAlways);

	abortTransaction;
	abortTransientTransaction;

	if (not _ex.resumable) then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' &gt;&gt; Error ' &amp; _ex.errorCode.String &amp; ' - Not Resumable', LogDebug);
		beginTransientTransaction;
		self.failed := true;
		self.finalMessage := self.finalMessage &amp; CrLf &amp; "Fatal error. Check logs for details.";
		if self.dbInBackupMode then
			self.dbInBackupMode := false;
			app.myDBA.abortBackup;
		endif;
		commitTransientTransaction;
		self.mySchedule.setFinalMessageNotify(self.finalMessage);
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' &gt;&gt; Error ' &amp; _ex.errorCode.String &amp; ' - Returning Ex_Pass_Back', LogDebug);
		return Ex_Pass_Back;	
	endif;

	// Check for any Server and Database Errors and abort/report
	if _ex.errorCode = 3036 then
		// 3036 = Missing file. Should not be a problem but record.
		beginTransientTransaction;
		self.failed := true;
		self.finalMessage := self.finalMessage &amp; CrLf &amp; "Some files missing. Check backup.log for details";
		self.mySchedule.setFinalMessageNotify(self.finalMessage);
		if self.dbInBackupMode then
			self.dbInBackupMode := false;
			app.myDBA.abortBackup;
		endif;
		commitTransientTransaction;		
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' &gt;&gt; Error ' &amp; _ex.errorCode.String &amp; ' - Returning Ex_Resume_Next', LogDebug);
		return Ex_Resume_Next;
	endif;

	if _ex.errorCode = 1227 or _ex.errorCode = 1066 then
		// 1227 = Notification subscriber not found which can happen when multiple splits all
		// 			finish close together. Ignore
		// 1066 = Notification not set for this OID. Ignore.
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' &gt;&gt; Error ' &amp; _ex.errorCode.String &amp; ' - Returning Ex_Resume_Next', LogDebug);
		return Ex_Resume_Next;
	endif;

	if _ex.errorCode = 1242 then
		// 1242 = A method executing in another node was aborted// File already exists and overwrite not allowed
		beginTransientTransaction;
		self.failed := true;
		finalMessage := finalMessage &amp; CrLf &amp; "File existed and Overwrite not set. Check backup.log for details"
			&amp; CrLf &amp; "Backup failed.";
		self.mySchedule.setFinalMessageNotify(self.finalMessage);
		if self.dbInBackupMode then
			self.dbInBackupMode := false;
			app.myDBA.abortBackup;
		endif;
		commitTransientTransaction;
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' &gt;&gt; Error ' &amp; _ex.errorCode.String &amp; ' - Returning Ex_Resume_Next', LogDebug);
		return Ex_Resume_Next;
	endif;

	if (not self.failed) then
		beginTransientTransaction;
		self.failed := true;
		if self.dbInBackupMode then
			self.dbInBackupMode := false;
			app.myDBA.abortBackup;
		endif;
		commitTransientTransaction;
	endif;

	// Pass all other exceptions to the next handler in the chain
	// after seting our status.
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' &gt;&gt; Error ' &amp; _ex.errorCode.String &amp; ' - Returning Ex_Pass_Back', LogDebug);
	return Ex_Pass_Back;
end;</source>
        <Parameter name="_ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="34602403-3083-483f-85ad-a032300e76d9">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.status := JACControllerActivated;

	app.writeLog(class.name&amp;method.name&amp;" "&amp;class.name&amp;" created.",LogDebug);
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="419436e1-9f4f-4859-8cfd-02547cf9eef4">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// July 2009    cnwrs1      to replace the data being copied par 20382
// ---------------------------------------------------------------------------

vars
	canDeleteSchedule, complete: Boolean;
	spl: JACBackupSplitInfo;
	currLog, message, backupPath: String;
	ts: TimeStamp;
	file: File;	
	kc : CnKarmaCntrl;
begin
	on Exception do deleteExceptionHandler(exception);
	//cnwrs1 29 Mar 2010 par23288 wrapup replaces delete and terminate
/*	kc := app.myCnKarmaCntrl;
	complete := true;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Attempting to delete '&amp;self.String, LogDebug);
	if self.mySchedule.status = JACBackupAborted then
		complete := false;
	endif;

	endNotificationForSubscriber(self);

	// Make sure all splits are complete
	foreach spl in self.allSplits do
		if not spl.status = SplitComplete then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"Split not complete.", LogDebug);
			complete := false;
			break;
		endif;
	endforeach;

	// check if the binary backup should be done
	if app.isSDSSecondaryBackup then
		backupPath := app.myServerAppObject.binarySecBackupPath;
	else
		backupPath := app.myServerAppObject.binaryBackupPath;
	endif;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"Backup binary to "&amp;backupPath&amp;'.', LogDebug);
	if backupPath &lt;&gt; null then
		if not app.myServerAppObject.copyFolder(app.getJadeInstallDir, backupPath) then
			complete := false;
			return;
		endif;
		create file transient;
		file.fileName := app.getIniFileName;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;" Copy "&amp;file.fileName&amp;' to '&amp;backupPath&amp;'\..\', LogDebug);
//		file.cnEcCopy(backupPath&amp;'\..\jmtjade.ini');
		kc.copyFile(file.fileName, backupPath&amp;'\..\jmtjade.ini', false); //cnwrs1 par 20382 july 2009
		delete file;
	endif;	
	// Finish the backup off if we were split
	if app.myDBA &lt;&gt; null and 
	   global.isValidObject(app.myDBA) and 
	   self.dbInBackupMode then
		if complete then
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Attempting to delete ' &amp; self.String &amp; ' - committing backup', LogDebug);
			app.myDBA.commitBackup;	
			currLog := app.myDBA.getCurrentLogName();
			if not app.isSDSSecondaryBackup then //Jade 6.1.12 causes exception
				app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Attempting to close current log (' &amp; currLog &amp; ')', LogDebug);
				app.myDBA.closeCurrentJournal();
			endif;
			if app.myServerAppObject.binaryBackupPath &lt;&gt; null then
				if not app.myServerAppObject.copyFolder(app.getJadeInstallDir, app.myServerAppObject.binaryBackupPath) then
					complete := false;
					return;
				endif;
				create file transient;
				file.fileName := app.getIniFileName;
//				file.cnEcCopy(app.myServerAppObject.binaryBackupPath);
				kc.copyFile(file.fileName, app.myServerAppObject.binaryBackupPath, false); //cnwrs1 par 20382 july 2009
				delete file;
			endif;	
		endif;
	endif;
	if app.isSDSSecondaryBackup then
		// if running on secondary db cleanup its journal directory
		app.myServerAppObject.secLogFileCleanup;
	endif;
epilog
	if complete and
	   not self.failed then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Attempting to delete ' &amp; self.String &amp; ' OK.', LogDebug);
	else
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Attempting to delete ' &amp; self.String &amp; ' failed - aborting backup', LogAlways);
		app.myDBA.abortBackup;	
	endif;
	// Update the schedule object with the status and do any recur
	if self.mySchedule &lt;&gt; null and 
	   global.isValidObject(self.mySchedule) then

		// This code is deliberately done in small transaction chunks and in
		// seperate methods so that if any one method causes an exception then
		// the exception handler can return "Ex_Resume_Next" to try and 
		// complete the task.

		if (not complete) or 
		   self.failed then
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Attempting to delete ' &amp; self.String &amp; ' - setStatus failed complete', LogDebug);
			message := self.finalMessage &amp; CrLf &amp; "Failed at " &amp; ts.String;
			if self.mySchedule.status &lt;&gt; JACBackupAborted then
				self.mySchedule.setStatusNotify(JACBackupFailed);
			endif;
		else
			message := self.finalMessage &amp; CrLf &amp; "Completed at " &amp; ts.String;
			self.mySchedule.setStatusNotify(JACBackupComplete);
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Attempting to delete ' &amp; self.String &amp; ' - setStatus ok complete', LogDebug);
		endif;

		self.mySchedule.setFinalMessageNotify(message);
		self.mySchedule.backupFinishedNotify;
	endif;
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteExceptionHandler" id="6ee5a52b-3290-4ca4-9bce-69ec40e83bd3">
        <updating/>
        <source>deleteExceptionHandler(_ex: Exception) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	on Exception do app.horribleExceptionHandler(exception);

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' *** ERROR *** ' &amp; _ex.errorCode.String, LogAlways);

	app.doDumpStack(_ex);

	abortTransaction;
	// do NOT abortTransientTransaction here as only called from
	// "delete" method which must be all in transientTransaction state
	//abortTransientTransaction;

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Attempting to Resume Next for ' &amp; _ex.errorCode.String, LogAlways);

	return Ex_Resume_Next;

end;</source>
        <Parameter name="_ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handle3036Exception" id="58023993-68dc-41ab-bd72-11b599ceef38">
        <source>handle3036Exception(exObj : Exception) : Integer;
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if exObj.errorCode = 3036 then
		app.writeLog("3036 exception : db file not found", LogAlways);
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleFileBackedUp" id="00420417-5d83-4d26-8dc6-52d391a13972">
        <updating/>
        <source>handleFileBackedUp(_file: DbFile) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	beginTransientTransaction;
	self.doneMegs := self.doneMegs + (_file.getFileLength / 1000000).Integer;
	self.doneFiles := self.doneFiles + 1;
	commitTransientTransaction;	

	app.writeLog(class.name&amp;'::'&amp;method.name&amp;" File ("&amp;_file.name&amp;") backed up. "&amp; 
		" Done "&amp;self.doneMegs.String&amp;" of "&amp;self.numMegs.String&amp;" Mbs, "&amp;
		self.doneFiles.String&amp;" of "&amp;self.numFiles.String&amp;' Files', LogNormal);
end;</source>
        <Parameter name="_file" type="DbFile"/>
    </JadeMethod>
    <JadeMethod name="handleSplitStatusChange" id="1c4c4873-d1fb-4ecc-92f8-d46f9cd66e98">
        <updating/>
        <source>handleSplitStatusChange(_splitInfo: JACBackupSplitInfo) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	allStarted,	complete: Boolean;
	obj: Object;
	fileFolder: FileFolder;
begin
	app.writeLog(class.name&amp;'::'&amp;method.name, LogDebug);
	create fileFolder transient;
	if self.status = JACControllerTerminating then
		// Already terminating so ignore
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' already terminating!', LogDebug);
		return;
	endif;

	if _splitInfo.status = SplitComplete or
	   _splitInfo.status = SplitFailed then
		complete := true;
		foreach obj in self.allSplits do
			if (not (obj.JACBackupSplitInfo.status = SplitComplete or obj.JACBackupSplitInfo.status = SplitFailed)) then
				complete := false;
				break;
			endif;
		endforeach;
		if complete then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;'  All splits are complete - terminating', LogNormal);

			// This is done in a seperate transaction to ensure it is committed before
			// calling the "delete" method as the delete method has a "doWindowEvents"
			// when sending off the email so other notifications may get in and
			// cause problems at that point (RJS 14/11/2001)
			beginTransientTransaction;
			self.status := JACControllerTerminating;
			commitTransientTransaction;	

			self.wrapup(); //cnwrs1 29 Mar 2010 par23288 replace delete and terminate

//			beginTransientTransaction;
//			delete self;
//			commitTransientTransaction;	
//			terminate;
		endif;

	elseif _splitInfo.status = SplitStarted then
		allStarted := true;
		foreach obj in self.allSplits do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;'  '&amp;obj.String&amp;" "&amp;obj.JACBackupSplitInfo.status.String, LogDebug);
			if not obj.JACBackupSplitInfo.status = SplitStarted then
				allStarted := false;
				break;
			endif;
		endforeach;	
		if allStarted then
			if self.status &lt;&gt; JACControllerRunning then
				app.writeLog(class.name&amp;'::'&amp;method.name&amp;' JACBackupController backup running', LogNormal);
				app.myDBA.beginBackup(self.backupPath, self.quiesce);
				beginTransientTransaction;
				self.status := JACControllerRunning;
				commitTransientTransaction;
			endif;

			beginTransientTransaction;
			self.dbInBackupMode := true;
			commitTransientTransaction;	

			foreach obj in self.allSplits do
				fileFolder.fileName := obj.JACBackupSplitInfo.myPath;
				if not fileFolder.isAvailable then
					fileFolder.make;
					if not fileFolder.isAvailable then
						app.writeLog("Creation of directory "&amp;obj.JACBackupSplitInfo.myPath&amp;" failed.", LogAlways); 
						return;
					endif;
				endif;
				app.writeLog(class.name&amp;'::'&amp;method.name&amp;' causeEvent NotifySplitGo='&amp;NotifySplitGo.String, LogDebug);
				obj.causeEvent(NotifySplitGo, true, null);
				app.writeLog(class.name&amp;'::'&amp;method.name&amp;" do go for split "&amp;obj.String, LogDebug);
			endforeach;				
		endif;
	endif;
epilog
	delete fileFolder;
end;</source>
        <Parameter name="_splitInfo" type="JACBackupSplitInfo"/>
    </JadeMethod>
    <JadeMethod name="moreFinalMessage" id="2ae9c317-973f-43eb-931d-b3cb1cfeacd1">
