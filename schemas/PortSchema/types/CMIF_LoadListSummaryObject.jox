    <JadeMethod name="getBulkReleaseTotal" id="9842954e-0760-484c-b220-294883e322ae">
        <source>getBulkReleaseTotal(_sumObj : CMIF_LoadListSummaryObject) : Integer;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/12/2010	cnwdap1	Initial creation PAR #26477 Correct totals calculation for bulk releases
07/12/2010	cnwdap1	PAR #26426 Add invalid object check
20/07/2018	jlgmd1	TFS #39261 SNO - Show Reserve Detail lines on Load List
*/
vars
	releaseTotal	: Integer;
	detail			: CM_ReserveDetail;
	invalidRD		: Boolean;
	ed				: Integer;
	
begin
	on Exception do app.handleDeletedObject(exception, detail, invalidRD);	

	foreach detail in _sumObj.allReserveDetails discreteLock do
	
		invalidRD := false;
		ed := detail.edition;
		
		
		if not invalidRD then
			releaseTotal := releaseTotal + detail.getTotalRequested;
		endif;
	
	endforeach;
	
	return releaseTotal;
epilog

end;</source>
        <Parameter name="_sumObj" type="CMIF_LoadListSummaryObject"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getGrpSumDisplay" id="58a5f66e-4c12-47ba-a963-cff04eeaef6d">
        <updating/>
        <source>getGrpSumDisplay(_objectSet: ObjectSet): String updating;
//----------------------------------------------------------------
//	Created:	15 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
29 Mar 2010	cnwkpd1	PAR #23479 - Improve performance of Load List
08 Nov 2010	cnwdap1	PAR #23794 CCMS MES 1102 Include Release Requests in Rail Load List
26 Nov 2010 cnwdap1	PAR #26426 CCMS MES 1102 Include Release Requests in Ship Load List
01 Dec 2010	cnwdap1	PAR #26477 Correct calculation of release request totals
21 Jun 2013	cnwdap1	PAR #31740 Break-Bulk changes to show total quantity of break bulk items
21 Jan 2014	cnwer1	par 33323 error 4s
20 Jul 2018	jlgmd1	TFS #39261 SNO - Show Reserve Detail lines on Load List
*/

vars
	obj			: Object;
	tmpSumObj	: SelfType;
	str			: String;
	relTotal	: Integer;
	showRR		: Boolean;				// PAR #26426
	relItemsPlanned : Integer;
	relItemsAssigned : Integer;
	ti				: CM_TrackedItem;	// PAR #31740
	invalidTI 		: Boolean;
	tiQuantity 		: Integer;
begin

	self.totColourCode			:= 0;
	self.totLoadCargo			:= 0;
	self.totLoadCargoPlanned	:= 0;
	self.totLoadCargoToPlan		:= 0;
	self.dischargePort			:= null;
	self.isoGroupingCode		:= null;
	self.imexStatusDescription	:= null;
	self.allTrackedItems.clear;
	self.allLoadRequests.clear;
	self.allReserveDetails.clear;
	self.allWorkListEntries.clear;			// PAR #23794
	self.totReleaseRequests			:= 0;	// PAR #23794
	self.totReleaseRequestsPlanned	:= 0;	// PAR #23794
	self.totReleaseRequestsToPlan	:= 0;	// PAR #23794
	self.totReleaseRequestsAssigned	:= 0;	// PAR #23794
	
	foreach obj in _objectSet do
		tmpSumObj := obj.CMIF_LoadListSummaryObject;
		if self.dischargePort = null then
			self.dischargePort := tmpSumObj.dischargePort;
		elseif self.dischargePort &lt;&gt; tmpSumObj.dischargePort then
			self.dischargePort := "All";
		endif;
		if self.imexStatusDescription = null then
			self.imexStatusDescription := tmpSumObj.imexStatusDescription;
		elseif self.imexStatusDescription &lt;&gt; tmpSumObj.imexStatusDescription then
			self.imexStatusDescription := "All";
		endif;
		if self.isoGroupingCode = null then
			self.isoGroupingCode := tmpSumObj.isoGroupingCode;
		elseif self.isoGroupingCode &lt;&gt; tmpSumObj.isoGroupingCode then
			self.isoGroupingCode := "All";
		endif;
		
		self.totColourCode			:= self.totColourCode		+ tmpSumObj.totColourCode;
		
		on Exception do app.handleDeletedObject(exception,ti,invalidTI);
		
		foreach ti in tmpSumObj.allTrackedItems do	
			//epr par 33323
			invalidTI:=false;
			tiQuantity:=ti.totalQuantity.max(1);
			if invalidTI then
				continue;
			endif;
			// PAR #31740
			self.totLoadCargo	:= self.totLoadCargo + 	tiQuantity;// PAR #31740
		endforeach;																							// PAR #31740
		// PAR #23794 include release request totals if required
		if tmpSumObj.showReleaseRequests then												// PAR #26426
			showRR := true;																	// PAR #26426
			relTotal := self.getBulkReleaseTotal(tmpSumObj);								// PAR #26477
			self.totReleaseRequests := self.totReleaseRequests 	+ relTotal;					// PAR #26477
		endif;
		// PAR #23794 end
		foreach ti in tmpSumObj.allLoadCargoPlannedTis do													// PAR #31740														// PAR #31740
			self.totLoadCargoPlanned := self.totLoadCargoPlanned +  ti.totalQuantity.max(1);// PAR #31740																					// PAR #31740
		endforeach;																							// PAR #31740
		foreach ti in tmpSumObj.allLoadCargoToPlanTis do													// PAR #31740
			self.totLoadCargoToPlan := self.totLoadCargoToPlan + ti.totalQuantity.max(1);	// PAR #31740																						// PAR #31740
		endforeach;																							// PAR #31740
		
		// PAR #23794 include release request details if required
		if tmpSumObj.showReleaseRequests then
			//13 May 2013	NDL Par 31471 - changed to reflect teh statements in MES CCMS 1102
			relItemsPlanned := tmpSumObj.getNumRelPlannedItems();
			relItemsAssigned := tmpSumObj.getNumRelAssignedItems();
			self.totReleaseRequestsPlanned	:= self.totReleaseRequestsPlanned	+ relItemsPlanned;
			self.totReleaseRequestsAssigned	:= self.totReleaseRequestsAssigned	+ relItemsAssigned;
			self.totReleaseRequestsToPlan := self.totReleaseRequests - self.totReleaseRequestsPlanned;
		endif;
		// PAR #23794 end

		//////////////
		tmpSumObj.allLoadRequests.copy(self.allLoadRequests);
		tmpSumObj.allTrackedItems.copy(self.allTrackedItems);
		tmpSumObj.allWorkListEntries.copy(self.allWorkListEntries);	// PAR #23794
		//tmpSumObj.allBulkReleases.copy(self.allBulkReleases);		// PAR #23794
		tmpSumObj.allReserveDetails.copy(self.allReserveDetails);	// TFS #39261
	endforeach;
	
	str := 	Tab &amp; self.totColourCode.String &amp;						// PAR #23794
			Tab &amp; self.totLoadCargo.String &amp;
			Tab &amp; self.totLoadCargoPlanned.String &amp;
			Tab &amp; self.totLoadCargoToPlan.String;
			
	if showRR then																	// PAR #26426 // PAR #23794
		str := str &amp; Tab &amp; self.totReleaseRequests.String &amp; 						// PAR #23794
					Tab &amp; self.totReleaseRequestsPlanned.String &amp; 					// PAR #23794
					Tab &amp; self.totReleaseRequestsToPlan.String &amp; 					// PAR #23794
					Tab &amp; self.totReleaseRequestsAssigned.String;					// PAR #23794
	endif;																			// PAR #23794
	
	return str;																		// PAR #23794
end;</source>
        <Parameter name="_objectSet" type="ObjectSet"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumRelAssignedItems" id="313f45c5-8bc5-4079-9089-a8a228610cbc">
        <source>getNumRelAssignedItems():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2013	cnwndl1	Initial creation	Par 31471
20/07/2018	jlgmd1	TFS #39261 SNO - Show Reserve Detail lines on Load List
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars

	release 		: CM_BulkRelease;
	invalidRelease 	: Boolean;
	assignedTot		: Integer;
	detail			: CM_ReserveDetail;
	releases		: CM_BulkReleaseSet;
	invalidRD		: Boolean;
	ed				: Integer;
	ti				: CM_TrackedItem;	
	allTis			: CM_TISet; 
begin

	if self.allReserveDetails.size = 0 then
		return 0;
	endif;
	
	on Exception do app.handleDeletedObject(exception, release, invalidRelease);
	on Exception do app.handleDeletedObject(exception, detail, invalidRD);
	
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	// Now that we are down at the detail level, its a little more complicated
	// But we just need to check if any of our items are in the Bulk Releases allTrackedItemsAssigned collection
	
	// First, make sure we are dealing with valid objects (invalid ones will be removed later)
	detail := self.allReserveDetails.first;
	release := detail.myReserveHeader;
	if release &lt;&gt; null then
		ed := release.edition;
	endif;
	
	if invalidRD or invalidRelease or release = null then
		return 0;
	endif;
	
	foreach detail in self.allReserveDetails discreteLock do
		invalidRD := false;
		ed := detail.edition;
		
		if invalidRD or invalidRelease then
			break;
		endif;
		
		if not invalidRD then
			detail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
			//foreach ti in detail.allTrackedItems discreteLock do
			foreach ti in allTis discreteLock do //23/06/2023	navkc1	CR 58406 Task 58408
				if release.allTrackedItemsAssigned.includes(ti) then
					assignedTot := assignedTot + 1;
				endif;
			endforeach;
		endif;
	endforeach;
	
	return assignedTot;
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumRelPlannedItems" id="b6b114dd-6ad1-4e27-99a6-531a5c43de82">
        <source>getNumRelPlannedItems():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2013	cnwndl1	Initial creation	Par 31471
20/07/2018	jlgmd1	TFS #39261 SNO - Show Reserve Detail lines on Load List

*/

vars

	detail			: CM_ReserveDetail;
	ed				: Integer;
	invalidRD		: Boolean;
	plannedTot		: Integer;

begin

	on Exception do app.handleDeletedObject(exception, detail, invalidRD);
	
	foreach detail in self.allReserveDetails discreteLock do
		invalidRD := false;
		ed := detail.edition;
		if not invalidRD then
			plannedTot := plannedTot + detail.allSlotRequestsAssigned.size;
		endif;
	endforeach;
	
	return plannedTot;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReportTableDisplay" id="0c1a8bea-5a3b-4a05-8767-04ecbfbbe9b2">
        <source>getReportTableDisplay(): String;
//----------------------------------------------------------------
//	Created:	15 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 05/11/2010	cnwdap1		PAR #23794 CCMS MES 1102 Release Requests on rail load list
// 26/11/2010	cnwdap1		PAR #26426 CCMS MES 1102 Release Requests on ship load list
//13 May 2013	NDL			Par 31471 - Rewrite to reflect description in CCMS MES 1102 for voayage with TBAs
// 21/06/2013	cnwdap1		PAR #31740 Break Bulk totals on Load List
vars
	str 				: String;			// PAR #23794
	loadTotal			: Integer;			// PAR #23794
	rrtotal				: Integer;			// PAR #23794
	unplanned			: Integer;			// PAR #26426
	relItemsPlanned 	: Integer;
	relItemsAssigned 	: Integer;
	ti 					: CM_TrackedItem;	// PAR #31740
	loadPlanned			: Integer;			// PAR #31740
	loadUnplanned 		: Integer;			// PAR #31740
	invalidTI			: Boolean;
begin

	on Exception do app.handleDeletedObject(exception, ti, invalidTI);		// 29/10/2013 cnwar2 #32707

	//loadTotal := self.allTrackedItems.size;										// PAR #31740
	foreach ti in self.allTrackedItems do											// PAR #31740
		loadTotal := loadTotal + ti.totalQuantity.max(1);			// PAR #31740											
	endforeach;																		// PAR #31740
	foreach ti in self.allLoadCargoPlannedTis do									// PAR #31740
		loadPlanned := loadPlanned + ti.totalQuantity.max(1);		// PAR #31740																
	endforeach;																		// PAR #31740
	foreach ti in self.allLoadCargoToPlanTis do										// PAR #31740									// PAR #31740
		loadUnplanned := loadUnplanned + ti.totalQuantity.max(1);	// PAR #31740																	
	endforeach;																		// PAR #31740

	if self.showReleaseRequests then																	// PAR #26426
		rrtotal := self.getBulkReleaseTotal(self);
		relItemsPlanned := self.getNumRelPlannedItems();
		relItemsAssigned := self.getNumRelAssignedItems();
	endif;
	// PAR #23794 end
	
	str :=  self.getTableSort &amp; Tab &amp; Tab						// PAR #23794
				&amp; Tab &amp; self.isoGroupingCode
				&amp; Tab &amp; self.totColourCodeDisplay
				&amp; Tab &amp; loadTotal.String						// PAR #23794
				//&amp; Tab &amp; self.allLoadCargoPlannedTis.size.String					// PAR #31740
				//&amp; Tab &amp; self.allLoadCargoToPlanTis.size.String					// PAR #31740
				&amp; Tab &amp; loadPlanned.String											// PAR #31740
				&amp; Tab &amp; loadUnplanned.String										// PAR #31740
				;
				
	if self.showReleaseRequests then																	// PAR #26426
		// PAR #26426 if we're a voyage load summary, unplanned release request items don't exist 
		// have to calculate them from the release request total and planned total
		if self.train &lt;&gt; null then
			unplanned := self.allWorkListEntriesToPlan.size;
		else
			unplanned := rrtotal - relItemsPlanned;
		endif;
		// PAR #26426 end
		str := str &amp; Tab &amp; rrtotal.String
				&amp; Tab &amp; relItemsPlanned.String
				&amp; Tab &amp; unplanned.String																// PAR #26426
				&amp; Tab &amp; relItemsAssigned.String
				;
	endif;			
	
	str := str &amp; Tab &amp; self.totSpecialStowsOnSite
				&amp; Tab &amp; self.totColourCodedSpecialStowSlots		//18 Nov 2009	NDL	CCMS 1864 Par 21652 
				&amp; Tab &amp; self.totSpecialStowsPlanned		//18 Nov 2009	NDL	CCMS 1864 Par 21652 
				;
				
	return str;
	// PAR #23794 end
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSpecialStowStringOnSiteTI" id="62c49c3a-138c-4f04-b8f0-83bf6500e687">
        <source>getSpecialStowStringOnSiteTI(): String protected;
//----------------------------------------------------------------
//	Created:	14 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ti				: CM_TrackedItem;
	comGrp			: CM_CommodityGroup;
	strSS			: String;
//	intCounts		: IntegerArray;
//	strCodes		: StringArray;
	idx				: Integer;
	strReturn		: String;
	sc				: CM_SlotController;
	invalidObject	: Boolean;
	
begin
	on Exception do app.handleDeletedObject (exception, ti, invalidObject);		// 12/02/2013 cnwar2 #27655

	intCounts.clear();
	strCodes.clear();
	foreach ti in self.allSpecialStowsToOnsiteTis do
		
		invalidObject := false;
		strSS := ti.getSpecialStowString();
		if invalidObject then	// 12/02/2013 cnwar2 #27655
			continue;
		endif;
			
		if strSS = null then
		/* PAR 26515
			if ti.requiresPower then// PAR 23906
				strSS := "REQ PWR";
			endif;
			*/
			if strSS = null then
				// Last check
				continue;
			endif;
		endif;
		
		idx := strCodes.indexOf(strSS);
		if idx = 0 then
			strCodes.add(strSS);
			intCounts.add(1);
		else
			intCounts[idx] := intCounts[idx] + 1;
		endif;
	endforeach;
	
	foreach idx in 1 to intCounts.size do
		if strReturn = null then
			strReturn := strCodes[idx] &amp; " " &amp; intCounts[idx].String;
		else
			strReturn := strReturn &amp; ", " &amp; strCodes[idx] &amp; " " &amp; intCounts[idx].String;
		endif;
	endforeach;
	
	return strReturn;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSpecialStowStringPlannedTI" id="33a6864a-4088-4e84-ad96-6e3f916d1487">
        <source>getSpecialStowStringPlannedTI(): String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwndl1	Initial creation	CCMS 1864 Par 21652 

*/

vars

	ti			: CM_TrackedItem;
	comGrp		: CM_CommodityGroup;
	strSS		: String;
	idx			: Integer;
	strReturn	: String;
	
begin

	intCounts.clear();
	strCodes.clear();
	foreach ti in self.allSpecialStowsPlannedTis do
		strSS := ti.getSpecialStowString();
		if strSS = null then
		/* PAR 26515
			if ti.requiresPower then// PAR 23906
				strSS := "REQ PWR";
			endif;
			
			if strSS = null then
				// Last check
				*/
				continue;
			//endif;
		endif;
		
		idx := strCodes.indexOf(strSS);
		if idx = 0 then
			strCodes.add(strSS);
			intCounts.add(1);
		else
			intCounts[idx] := intCounts[idx] + 1;
		endif;
	endforeach;
	
	foreach idx in 1 to intCounts.size do
		if strReturn = null then
			strReturn := strCodes[idx] &amp; " " &amp; intCounts[idx].String;
		else
			strReturn := strReturn &amp; ", " &amp; strCodes[idx] &amp; " " &amp; intCounts[idx].String;
		endif;
	endforeach;
	
	return strReturn;
	
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSpecialStowsString" id="d3fae4c8-75d1-4be8-8100-b9a60b7a5eb8">
        <source>getSpecialStowsString(): String protected;
//----------------------------------------------------------------
//	Created:	14 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ti			: CM_TrackedItem;
//	sr			: CM_SlotRequest;
	req			: CM_Request;	//20 Nov 2012	NDL	Par 30754
	comGrp		: CM_CommodityGroup;
	strSS		: String;
	intCounts	: IntegerArray;
	strCodes	: StringArray;
	idx			: Integer;
	strReturn	: String;
	
begin

	
	create intCounts transient;
	create strCodes transient;
	
	foreach req in self.allLoadRequests do
		if not global.isValidObject(req) then
			continue;
		endif;

		strSS := req.getSpecialStowStr();
		if strSS = null then
			continue;
		endif;
		
		ti := req.getTrackedItem();
		if ti &lt;&gt; null
		and (ti.plannedSite = TI_SITE_ONSHIP or ti.site = TI_SITE_ONSHIP) then
			continue;
		endif;
		
		idx := strCodes.indexOf(strSS);
		if idx = 0 then
			strCodes.add(strSS);
			intCounts.add(1);
		else
			intCounts[idx] := intCounts[idx] + 1;
		endif;
	endforeach;
	
	foreach idx in 1 to intCounts.size do
		if strReturn = null then
			strReturn := strCodes[idx] &amp; " " &amp; intCounts[idx].String;
		else
			strReturn := strReturn &amp; ", " &amp; strCodes[idx] &amp; " " &amp; intCounts[idx].String;
		endif;
	endforeach;
	
	return strReturn;
	
epilog

	delete intCounts;
	delete strCodes;
	
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableSort" id="891260ef-479c-4562-9628-61cba17ee1f0">
        <source>getTableSort():String;
//----------------------------------------------------------------
//	Created:	21 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	dischPort	: String;
begin
	
	if self.dischargePort = null then
		dischPort := '0';
	else
		dischPort := self.dischargePort;
	endif;

	return self.imexStatus.String &amp; dischPort &amp; self.isoGroupingKey; 

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="redoTotalsForSR" id="e7c238b0-e553-40fe-a02d-8df2617e1a7a">
        <updating/>
        <source>redoTotalsForSR() updating;
//----------------------------------------------------------------
//	Created:	21 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	sr		: CM_SlotRequest;
	req : CM_Request;
	total : Integer;
	invalidObject : Boolean;
	
begin

//	self.totColourCode			:= self.allLoadRequests.size;
//	return;
	
	on Exception do app.handleDeletedObject( exception, req, invalidObject );	//26 Nov 2012	NDL	Par 30754
	foreach req in self.allLoadRequests do
		if req.isVoyageRequest then
			total := total + req.CM_VoyageRequest.quantity.Integer;
		else
			total := total + 1;
		endif;
	endforeach;
	
	self.totColourCode := total;

end;</source>
    </JadeMethod>
    <JadeMethod name="redoTotalsForTI" id="2a8a514b-0184-4e4b-bda4-947b264fb3f8">
        <updating/>
        <source>redoTotalsForTI() updating;
//----------------------------------------------------------------
//	Created:	21 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ti		: CM_TrackedItem;
	sc		: CM_SlotController;
begin

	// This method has been phased out. Replaced with totalsForTi
	return;
	/*self.totLoadCargo			:= 0;
	self.totLoadCargoPlanned	:= 0;
	self.totLoadCargoToPlan		:= 0;
//	self.totSpecialStowsToPlan	:= 0; - virtual
	
	foreach ti in self.allTrackedItems do
		if not global.isValidObject(ti) then // maybe a TI being made NOT tranship
			self.allTrackedItems.remove(ti);
			continue;
		endif;

		self.totLoadCargo			:= self.totLoadCargo + 1;
		if ti.hasFutureMoveLoad(PLANNING_MODE) then //plannedSite = TI_SITE_ONSHIP then
			self.totLoadCargoPlanned := self.totLoadCargoPlanned + 1;
		else
			sc := null;
			if CM_SlotController.hasInstance(ti.myPrimaryActualLocation) then
				sc := ti.myPrimaryActualLocation.CM_SlotController;
			endif;
	
			if sc &lt;&gt; null
			and sc.mySlotRequestLoad &lt;&gt; null
			and sc.mySlotRequestLoad.sequenced
			and ti.allPlannedFutureMoves.isEmpty then
				self.totLoadCargoPlanned := self.totLoadCargoPlanned + 1;
			elseif ti.isExport and sc &lt;&gt; null then
				self.totLoadCargoPlanned := self.totLoadCargoPlanned + 1;
			else
				self.totLoadCargoToPlan := self.totLoadCargoToPlan + 1;
			endif;
			
		endif;
		/*
		if ti.plannedSite = TI_SITE_ONSHIP then
			self.totLoadCargoPlanned := self.totLoadCargoPlanned + 1;
		else
			self.totLoadCargoToPlan := self.totLoadCargoToPlan + 1;
		endif;
		
	endforeach;*/
end;</source>
    </JadeMethod>
    <JadeMethod name="removeDeletedTi" id="a459aac6-8602-4f5d-be11-380186aef95a">
        <source>removeDeletedTi( _ti : CM_TrackedItem ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2011	cnwndl1	Initial creation	Par 28797

*/

vars

	retValue : Boolean;

begin

	if self.allTrackedItems.includes( _ti ) then
		self.allTrackedItems.remove( _ti );
		retValue := true;
	endif;
	if self.allLoadCargoPlannedTis.includes( _ti ) then
		self.allLoadCargoPlannedTis.remove( _ti );
		retValue := true;
	endif;
	if self.allLoadCargoTis.includes( _ti ) then
		self.allLoadCargoTis.remove( _ti );
		retValue := true;
	endif;
	if self.allLoadCargoToPlanTis.includes( _ti ) then
		self.allLoadCargoToPlanTis.remove( _ti );
		retValue := true;
	endif;
	if self.allSpecialStowsPlannedTis.includes( _ti ) then
		self.allSpecialStowsPlannedTis.remove( _ti );
		retValue := true;
	endif;
	if self.allSpecialStowsToOnsiteTis.includes( _ti ) then
		self.allSpecialStowsToOnsiteTis.remove( _ti );
		retValue := true;
	endif;
	
	return retValue;
	
epilog	

end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromSR" id="bd013440-fb4c-4c36-aaa3-2010502b08ac">
        <updating/>
        <source>setFromSR(_slotRequest: CM_SlotRequest; _imexKey: Integer) updating;
//----------------------------------------------------------------
//	Created:	21 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	transStatus		: CM_TransitStatus;
begin

	self.imexStatus := _imexKey;
	if self.imexStatus = TI_IMEX_STATUS_REMAINONBOARD then
		transStatus := app.myRoot.allTransitStatuses[TI_TransitStatusDLR];
		if transStatus &lt;&gt; null then
			self.imexStatusDescription := transStatus.description;
		else
			self.imexStatusDescription := "DLR";
		endif;
	else
		self.imexStatusDescription := app.getIMEXStringFromIMEXStatus(self.imexStatus);
	endif;

	self.dischargePort := _slotRequest.dischargePort;
	self.isoGroupingKey := _slotRequest.getPlannersGroup;
	self.isoGroupingCode := _slotRequest.getPlannersGroupDesc;

end;</source>
        <Parameter name="_slotRequest" type="CM_SlotRequest"/>
        <Parameter name="_imexKey" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFromTI" id="ff118aa1-9bce-4f98-af0b-736697ffb4a6">
        <updating/>
        <source>setFromTI(_ti: CM_TrackedItem; _imex: Integer) updating;
//----------------------------------------------------------------
//	Created:	21 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 26/08/2010	cnwdap1		PAR #25371 If ti is a tranship, use the discharge port from its tranship details
vars
	imx : CM_IMEXStatus;
	disPort	: String;		// PAR #25371
begin

	self.imexStatus := _imex;
	
	if self.imexStatus = TI_IMEX_STATUS_REMAINONBOARD then
		//self.imexStatus := self.IMEX_KEY_DLR;
		self.imexStatusDescription := _ti.getTransitStatusDescription;
	else
		//19/08/2010 cnwdz2 25460 _ti.getImExStatusStringDesc(true); does not use _imex
		imx := _ti.getRoot.allImexStatuses[_imex];
		if imx &lt;&gt; null then
			self.imexStatusDescription := imx.description;
		else
			self.imexStatusDescription := app.getErrorString(Unknown);
		endif;
	endif;
	
	// TFS 2122 add null test
	if _ti.isTranshipItem and												// PAR #25371
	   _ti.myTranshipDetail &lt;&gt; null then
		self.dischargePort := _ti.myTranshipDetail.dischargePort();	// from 30138, checking other usage of myDischargePort.code, Aug 2012
	else																	// PAR #25371
		self.dischargePort := _ti.dischargePort;
	endif;																	// PAR #25371
	self.isoGroupingKey := _ti.getPlannerReportGroup();
	self.isoGroupingCode := _ti.getPlannerReportGroupDesc();

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_imex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFromVoyReq" id="d9303942-334f-4a06-b91c-15ffc5d771fa">
        <updating/>
        <source>setFromVoyReq(_voyRequest: CM_VoyageRequest; _imexKey: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 November 2012	cnwndl1	Initial creation	Par 30754

*/

vars
	transStatus		: CM_TransitStatus;
begin

	self.imexStatus := _imexKey;
	if self.imexStatus = TI_IMEX_STATUS_REMAINONBOARD then
		transStatus := app.myRoot.allTransitStatuses[TI_TransitStatusDLR];
		if transStatus &lt;&gt; null then
			self.imexStatusDescription := transStatus.description;
		else
			self.imexStatusDescription := "DLR";
		endif;
	else
		self.imexStatusDescription := app.getIMEXStringFromIMEXStatus(self.imexStatus);
	endif;
	
	if _voyRequest.getAttrDischargePort &lt;&gt; null then
		self.dischargePort := _voyRequest.getAttrDischargePort.code;
	else
		self.dischargePort := null;
	endif;
	self.isoGroupingKey := _voyRequest.getPlannersGroup;
	self.isoGroupingCode := _voyRequest.getPlannersGroupDesc;

end;</source>
        <Parameter name="_voyRequest" type="CM_VoyageRequest"/>
        <Parameter name="_imexKey" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFromWLE" id="7b6f9148-aba9-4832-95ae-94a07163e4c3">
        <updating/>
        <source>setFromWLE(_wle : CM_WorkListEntry; _imex : Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2010	cnwdap1	Initial creation PAR #26426 CCMS MES 1102 Release Requests on Ship Load List
*/
vars
	imx 	: CM_IMEXStatus;
	disPort	: String;
	
begin
	self.imexStatus := _imex;
	
	imx := app.myRoot.allImexStatuses[_imex];
	if imx &lt;&gt; null then
		self.imexStatusDescription := imx.description;
	else
		self.imexStatusDescription := app.getErrorString(Unknown);
	endif;
	
	if _wle.myRequest &lt;&gt; null then
		self.dischargePort := _wle.myRequest.getDischargePort;
	endif;
	self.isoGroupingKey := _wle.getPlannerReportGroup();
	self.isoGroupingCode := _wle.getPlannerReportGroupDesc();
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_imex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setReportGroupFromSelf" id="6bb85798-6e38-41dc-a2c4-eb49f69ca2f6">
        <source>setReportGroupFromSelf(_reportGroup: CM_ReportGroup input);
//----------------------------------------------------------------
//	Created:	09 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	int			: Integer;
	str			: String;
	keyStr		: String;
begin
	
	if _reportGroup.label = CMIF_LoadListSummaryObject::extraKey.name then
		keyStr := self.extraKey.toUpper;
		_reportGroup.sortOrder := 1;//keyStr.getIntegerSortValue(4);
		_reportGroup.heading := "Summary ";
		_reportGroup.description := "Summary ";
		
	elseif _reportGroup.label = CMIF_LoadListSummaryObject::train.name then
		keyStr := self.train.toUpper;
		_reportGroup.sortOrder := keyStr.getIntegerSortValue(4);
		_reportGroup.heading := "Train ";
		_reportGroup.description := self.train.String;
		
	elseif _reportGroup.label = CMIF_LoadListSummaryObject::imexStatus.name then
		_reportGroup.sortOrder := self.imexStatus;
		_reportGroup.heading := "Type ";
		_reportGroup.description := self.imexStatusDescription.String;
		
	elseif _reportGroup.label = CMIF_LoadListSummaryObject::dischargePort.name then
		keyStr := self.dischargePort.toUpper;

		_reportGroup.sortOrder := keyStr.getIntegerSortValue(4);
		_reportGroup.heading := "Discharge Port ";
		_reportGroup.description := Tab &amp; self.dischargePort;
		
	elseif _reportGroup.label = CMIF_LoadListSummaryObject::isoGroupingKey.name then
		_reportGroup.sortOrder := self.isoGroupingKey.Integer;
		_reportGroup.heading := "ISO Grouping ";
		_reportGroup.description := self.isoGroupingCode;
		
	elseif _reportGroup.label = CMIF_LoadListSummaryObject::destinationPort.name then
		keyStr := self.destinationPort.toUpper;
		_reportGroup.sortOrder := keyStr.getIntegerSortValue(4);
		_reportGroup.heading := "Destination Port ";
		_reportGroup.description := Tab &amp; self.destinationPort;
		
	endif;
	

end;</source>
        <Parameter name="_reportGroup" type="CM_ReportGroup" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showReleaseRequests" id="04847ce4-e292-4b35-9dcf-8f8adc2d4192">
        <source>showReleaseRequests() : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/11/2010	cnwdap1	Initial creation PAR #26426 Release Requests on Ship Load List
*/
vars

begin
	if app.getMyTerminalDO_NOT_USE = null then
		return false;
	endif;
	
	return (self.train &lt;&gt; null and app.getMyTerminalDO_NOT_USE.getConfig(ShowRelReqOnRailLoadList).Boolean)		// Rail release requests
		or (self.train = null and app.getMyTerminalDO_NOT_USE.getConfig(ShowRelReqOnShipLoadList).Boolean);		// Ship release requests
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="totColourCodeDisplay" id="6827f5bd-3f58-40e0-bc3d-cf49f72f2f2f">
        <source>totColourCodeDisplay(): String;
//----------------------------------------------------------------
