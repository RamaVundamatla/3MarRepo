    <JadeMethod name="auditIdDisplay" id="2976f0aa-031e-419a-8611-56c53569c37d">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2019	jlgndl1	Initial creation	TFS 47013

*/

vars
	auditIdStr : String;
begin

	auditIdStr := self.auditId();
	if auditIdStr &lt;&gt; null then
		return app.getErrorString(Rate) &amp; Space &amp; Hyphen &amp; Space &amp; app.getErrorString(Berth) &amp; ": " &amp; auditIdStr;
	else
		return app.getErrorString(Rate);
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCode" id="f95fe5c5-145f-49bc-9411-3b3d68e17371">
        <source>getCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types

*/

vars

	invalidObject : Boolean;
	edition : Integer;

begin
	if self.myBerth &lt;&gt; null then	//16 Oct 2019	NDL	TFS 47013
		on Exception do app.handleDeletedObject( exception, self.myBerth, invalidObject );
		edition := self.myBerth.edition;
		if invalidObject then
			return null;
		endif;
		return self.myBerth.code;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
