    <JadeMethod name="sysNotify" id="c8c8ae8b-3eaf-48dd-8a90-3684b54ed1c2">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2013	cnwer1	Initial creation HAT 2189
02/09/2014        cnwma1 PAR#34046 Consignee duplicates
*/

vars
	idx : Integer;
	str : String;
begin


	if eventType = Object_Update_Event   then
		if theObject.isKindOf(CM_DutyDocItem) then
			if theObject.CM_DutyDocItem.myDutyDoc &lt;&gt; null then
				self.tblData.removeItemObject(theObject);
				self.endNotification(theObject,Any_System_Event);
			else
				self.tblData.updateItemObject(theObject.CM_Object, self.colorRow1, self.colorRow2, app.myPassport);
				self.endNotification(theObject,Any_System_Event);
			endif;
		endif;
	endif;
		
	
	if eventType = Object_Delete_Event then
		if theObject.isKindOf(CM_DutyDocItem) then
				self.tblData.removeItemObject(theObject);
				self.endNotification(theObject,Any_System_Event);
		endif;
	endif;
	

	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9e6a3ef3-4ca1-4c35-92fd-5141fd6029f3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018634, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="zDoAdd" id="0a951a59-8a23-46b6-afb1-82cda8d3f5fa">
        <updating/>
        <source>zDoAdd() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189

*/

vars
	dutyItemForm : CMUI_DutyDocItemMaintForm;
begin

	app.mousePointer := Window.MousePointer_Default;
	dutyItemForm := app.loadForm(CMUI_DutyDocItemMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_DutyDocItemMaintForm;
	dutyItemForm.setBaseData( null, null, null,self );
	dutyItemForm.showModal();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoEdit" id="2b65c154-d051-43ed-b4f8-341e10785f73">
        <updating/>
        <source>zDoEdit() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189

*/

vars
	dutyDocItem : CM_DutyDocItem;
	dutyItemForm : CMUI_DutyDocItemMaintForm;
	allDutyDocItems : CM_DutyDocItemSet;
begin
	//inheritMethod();
	if self.tblData.allSelectedObjects.isEmpty then
		return;
	endif;
	
	create allDutyDocItems transient;
	self.tblData.allSelectedObjects.copy(allDutyDocItems);
	
	dutyDocItem := allDutyDocItems.first; //self.tblData.allSelectedObjects.first.CM_DutyDocItem;
	app.mousePointer := Window.MousePointer_Default;
	dutyItemForm := app.loadForm(CMUI_DutyDocItemMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_DutyDocItemMaintForm;
	dutyItemForm.setBaseData( dutyDocItem.myDutyDoc, dutyDocItem,allDutyDocItems, self );
	dutyItemForm.showModal();
epilog
	delete allDutyDocItems;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
