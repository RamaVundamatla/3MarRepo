    <JadeMethod name="unload" id="6ecd8521-50e5-4afb-991f-79c846d9b693">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwas3	Initial creation
03/02/2010	cnwjre1	clean up transients

*/

vars

begin
	// if this is an attachment form, don't delete the transient
	// the parent form will take care of this
	if not self.isAttachmentForm then
		if self.myIntFacePreNote &lt;&gt; null and not global.isValidObject(self.myIntFacePreNote.myProxyTrackedItem) then
			self.myIntFacePreNote.setMyProxyTrackedItem(null);
		endif;
		delete self.myIntFacePreNote;
	endif;
	inheritMethod();
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="updateAttachments" id="3a9b396e-1dec-4041-9b88-6a8cc5edbff5">
        <updating/>
        <source>updateAttachments(_attachment : Object) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/08/2009	cnwdap1	Initial creation
24/02/2010	cnwdap1	PAR #21827 Correct handling of attachments when editing an existing tracked item
25/03/2010	cnwdap1	PAR #22938 Correct updating of attachment if ID of the attachment has changed
28/07/2016	cnwdap1	TFS #2384 Don't put hazardous children in the attachments combo if we're using the Hazardous Children form
*/
vars
	idx	: Integer;
	id	: String;
	obj	: Object;
	hazardous : Boolean;					// TFS #2384

begin
	if not self.allAttachments.includes(_attachment) then
		self.allAttachments.add(_attachment);
	endif;
	if CMIF_Receival.hasInstance(_attachment) then
		id := _attachment.CMIF_Receival.id;
		if not _attachment.CMIF_Receival.allTIHazards.isEmpty then							// TFS #2384
			hazardous := true;																// TFS #2384
		endif;																				// TFS #2384
	elseif CMGTE_Receival.hasInstance(_attachment) then
		id := _attachment.CMGTE_Receival.id;
		if not _attachment.CMGTE_Receival.allTIHazards.isEmpty then							// TFS #2384
			hazardous := true;																// TFS #2384
		endif;																				// TFS #2384
	// PAR #21827 added tracked item handling
	elseif CM_TrackedItem.hasInstance(_attachment) then
		id := _attachment.CM_TrackedItem.id;
		if not _attachment.CM_TrackedItem.allTIHazards.isEmpty then							// TFS #2384
			hazardous := true;																// TFS #2384
		endif;																				// TFS #2384
		// if the tracked item attachment is persistent, we need to refresh the proxy tracked item on the form
		if not _attachment.isTransient and self.myProxyTrackedItem &lt;&gt; null and self.myTI &lt;&gt; null then
			self.myProxyTrackedItem.erase(NORMAL_ERASE);
			self.myProxyTrackedItem := null;
			self.myProxyTrackedItem := app.createUpdateProxy(self.myTI).CM_TrackedItem;
		endif;
	endif;
	obj := _attachment;
	
	if not self.myTerminal.getConfig(UseDetailedHazEntry).Boolean or not hazardous then		// TFS #2384
		idx := self.cmbAttachments.findStringExact(1, id);
		if idx &lt;= 0 then
			// PAR #22938 if we didn't find the attachment id, try looking for a matching object
			idx := self.cmbAttachments.findObject(obj);
			if idx &gt; 0 then
				// update the text
				self.cmbAttachments.listIndex := idx;
				self.cmbAttachments.itemText[idx] := id;
			else
				// add as new
				idx := self.cmbAttachments.addItem(id);
			endif;
		endif;
		self.cmbAttachments.itemObject[idx] := _attachment;
		self.cmbAttachments.listIndex := idx;
	endif;																					// TFS #2384

epilog

end;</source>
        <Parameter name="_attachment" type="Object"/>
    </JadeMethod>
    <JadeMethod name="updateHazardsFromDetailForm" id="85209512-ecbc-40eb-b21e-61861cef6d26">
        <updating/>
        <source>updateHazardsFromDetailForm(_hazDict: CM_HazardByCodeDict): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17 November 2016	cnwdap1		Initial creation PAR #
//
vars
	str : String;

begin
	self.lstHazardList.setSelected(_hazDict);
	str := self.lstHazardList.getSelectedString();
	if str.length &gt; 37 then
		self.txtHazards.text := str[1:37] &amp; '...';
	else
		self.txtHazards.text := str;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_hazDict" type="CM_HazardByCodeDict"/>
        <ReturnType type="Boolean"/>
