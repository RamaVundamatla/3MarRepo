        <source>setEventData(_eventDataDict: CM_EventDataByTypeDict) updating;
// ---------------------------------------------------------------------------
// Created:     23 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.setEventDataInternal(_eventDataDict);
end;</source>
        <Parameter name="_eventDataDict" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
</Class>
