<Class name="CM_DisplayVersionChecker" id="0016694d-d3b7-4626-968a-b28fe573313e">
    <superclass name="CM_Transient"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="allChangedProperties" id="2f1bab56-1cb5-4f96-b95c-58a550dd14b6">
        <memberTypeInverse/>
        <type name="CM_DisplayPropertyByNiceName"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myDisplayObjectToCheck" id="034fde89-aa5f-4d77-ac47-7f3e71b3d15f">
        <embedded/>
        <type name="CM_DisplayObject"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myPrimaryObject" id="767d19b6-4028-471c-abca-0bc334c6c647">
        <embedded/>
        <type name="CM_Object"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="mySecondaryObject" id="71002f6a-4d34-4e53-be74-2105648a009e">
        <embedded/>
        <type name="CM_Object"/>
    </ImplicitInverseRef>
    <JadeMethod name="compare" id="427e1a26-a2bb-4210-83af-e6aad2903c59">
        <source>compare();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2008	cnwer1	Initial creation

*/

vars

	displayProperty : CM_DisplayProperty;
	iter : Iterator;
	primaryPropValue,
	secondaryPropValue : Any;
begin
	self.allChangedProperties.clear;
	iter:=self.myDisplayObjectToCheck.allDisplayProperties.createIterator;
	while iter.next(displayProperty) do
		primaryPropValue:=null;
		secondaryPropValue:=null;
		if displayProperty.myDisplayMethod = null then
			primaryPropValue:=self.myPrimaryObject.getPropertyValue(displayProperty.myDisplayProperty.name);
			secondaryPropValue:=self.mySecondaryObject.getPropertyValue(displayProperty.myDisplayProperty.name);
		else
			primaryPropValue:=self.myPrimaryObject.sendMsg(displayProperty.myDisplayMethod.name);
			secondaryPropValue:=self.mySecondaryObject.sendMsg(displayProperty.myDisplayMethod.name);
		endif;
		
		if displayProperty.myDisplayProperty.getType = StringArray then
			if not primaryPropValue.StringArray.membersSame(secondaryPropValue.StringArray) then
				self.allChangedProperties.add(displayProperty);
			endif;
		else
			if primaryPropValue &lt;&gt; secondaryPropValue then
				self.allChangedProperties.add(displayProperty);
			endif;
		endif;
	endwhile;
	
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="cd2008f4-c457-40a9-bd0f-436327273f70">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2008	cnwer1	Initial creation

*/

vars

begin
	self.deleteDisplayObjects();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteDisplayObjects" id="1b0b2ec8-c6ba-4ee6-80b9-4ab015b2670d">
        <updating/>
        <source>deleteDisplayObjects() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2008	cnwer1	Initial creation

*/

vars

begin
	if self.myDisplayObjectToCheck &lt;&gt; null then
		delete self.myDisplayObjectToCheck;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllChangedProperties" id="33c2fec2-023b-4c64-9732-a2f0ed5914b6">
        <source>getAllChangedProperties(_allChangedProperties : PropertySet io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2008	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	displayProperty : CM_DisplayProperty;
begin
	if _allChangedProperties = null then
		return;
	endif;
	iter:=self.allChangedProperties.createIterator;
	
	while iter.next(displayProperty) do
		if displayProperty.myDisplayProperty &lt;&gt; null then
			_allChangedProperties.add( displayProperty.myDisplayProperty);
		endif;
	
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_allChangedProperties" type="PropertySet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getFirstChangedProperty" id="5501f17e-9623-452b-a9d0-365c99dc9997">
        <source>getFirstChangedProperty() : Property;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2008	cnwer1	Initial creation

*/

vars

begin
	if self.allChangedProperties.size &gt; 0 then
		return self.allChangedProperties.first.CM_DisplayProperty.myDisplayProperty;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="Property"/>
    </JadeMethod>
    <JadeMethod name="init" id="39320bb6-eaff-457b-b603-9341cfb300f7">
        <updating/>
        <source>init(_primaryObject,
		_secondaryObject : CM_Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2008	cnwer1	Initial creation

*/

vars

begin
	self.myPrimaryObject:=null;
	self.mySecondaryObject:=null;
	
	self.deleteDisplayObjects();
	self.allChangedProperties.clear;
	if _primaryObject = null or _secondaryObject = null then
		return;
	endif;
	
	if _primaryObject.class &lt;&gt; _secondaryObject.class then
		return;
	endif;
	
	self.myPrimaryObject:=_primaryObject;
	self.mySecondaryObject:=_secondaryObject;
	
	self.myDisplayObjectToCheck:=self.myPrimaryObject.getDisplayObject;
	
	self.compare;
epilog

end;</source>
        <Parameter name="_primaryObject" type="CM_Object"/>
        <Parameter name="_secondaryObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="writeChangedProperties" id="60c35828-7e8a-4a7b-b1d3-968a528cff4a">
        <source>writeChangedProperties();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2008	cnwer1	Initial creation

*/

vars

	iter : Iterator;
	displayProperty : CM_DisplayProperty;
begin

	iter:=self.allChangedProperties.createIterator;
	
	while iter.next(displayProperty) do
		write displayProperty.propertyNiceName;
	
	endwhile;
epilog
	delete iter;

end;</source>
    </JadeMethod>
</Class>
