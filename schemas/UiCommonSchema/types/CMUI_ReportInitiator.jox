    <JadeMethod name="printExtraFrames" id="c308fcdb-b761-473e-96b4-d28200b83a6d">
        <updating/>
        <source>printExtraFrames() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2012	cnwndl1	Initial creation	Par 29120

*/

vars

	form : Form;
	frmArray : CMUI_ControlArray;
	control : Control;
	frm : CMUI_Frame;
	result : Integer;
	newFrame : CMUI_Frame;
	newPicture : CMUI_Picture;
	p : Printer;
	p2 : Picture;
	maxHeight : Integer;
	maxWidth : Integer;

begin

	if self.myDataTable = null then
		return;
	endif;
	
	form := self.myDataTable.form;
	if form = null then
		return;
	endif;
	if form.name &lt;&gt; "HMS_BerthUsageForm" then
		return;
	endif;
	
	create frmArray transient;
	form.sendMsgWithIOParams("getExtraFramesToPrint",frmArray);
	
	if frmArray.isEmpty then
		return;
	endif;
	
	foreach control in frmArray do
		frm := control.CMUI_Frame;
		if not app.printer.frameFits(frm) then
			app.printer.newPage();
			if not app.printer.frameFits(frm) then
				maxHeight := ( app.printer.pageHeight - ( app.printer.getHeader.height + 5 )).Integer;
				maxWidth := app.printer.pageWidth - 5;
				
				create newFrame transient;
				newFrame.height := maxHeight;
				newFrame.width := maxWidth;
				newFrame.borderStyle := 0;
				newFrame.bevelInner := 0;
				newFrame.bevelInnerWidth := 0;
				newFrame.bevelOuter := 0;
				newFrame.bevelOuterWidth := 0;
				newFrame.boundaryBrush := 0;
				newFrame.boundaryWidth := 0;
				self.addControl( newFrame );
				
				create newPicture transient;
				newPicture.height := maxHeight;
				newPicture.width := maxWidth;
				newPicture.top := 0;
				newPicture.left := 0;
				newPicture.stretch := 3;  //Stretch_Proportional
				newPicture.picture := frm.createPictureAsType(false,true,24,Window.PictureType_Png);
				newPicture.parent := newFrame;
				self.addControl( newPicture );
				
				frm := newFrame;
			endif;
		endif;
	

		result := app.printer.print(frm);
		
		if newFrame &lt;&gt; null then
			newFrame.visible := false;
		endif;
		
		if result &gt; 0 then
			break;
		endif;
	endforeach;

epilog

	delete frmArray;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sendEmailRequest" id="9476bf15-7e70-43f4-8388-af4e6cebea67">
        <updating/>
        <source>sendEmailRequest(_fileName : String) : Boolean updating, protected;
//--------------------------------------------------
// Created:	22 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	allFilePaths	: HugeStringArray;
	emailTemplate	: CM_EmailTemplate;
	theJadeReport	: JadeReport;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin

	if (not self.chkEmailFile.value)
	and (not self.chkEmailReport.value) then
		return true;
	endif;
	
	if self.txtToAddress.text = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Email To Address', null, null);	
		app.raiseCMException(Input_required_field_email2Add, null, null);		 // cnwdb2	PAR 35364
		return false;
	endif;
	
	create emailTemplate transient;
	emailTemplate.setProxy(null, null, null,
						   self.cmbFromAddress.listObject.CM_EmailEntity,
						   self.txtToAddress.text, 
						   self.txtCcAddress.text, 
						   self.txtBccAddress.text, 
						   self.txtSubject.text, 
						   self.txtMessage.text, 
						   false);
						   
	emailTemplate.validate();						   
	
	create allFilePaths transient;	
	if _fileName &lt;&gt; null then		
		allFilePaths.add(_fileName);
	endif;
	
	if self.chkEmailReport.value then
		self.setJadeReport();
		theJadeReport := self.myJadeReport;
	endif;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreatePDFEmailFileRequest(app.getMyUser(),
											 self.myTerminal,
											 self.reportDescription,
											 theJadeReport,
											 emailTemplate,
											 allFilePaths,
										  	 app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theResult := app.showErrorWarningDialog('Sending Email Request', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;

epilog
	delete allFilePaths;
	delete emailTemplate;			
end;</source>
        <access>protected</access>
        <Parameter name="_fileName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setJadeReport" id="d0b4bb58-1c98-43a3-a664-12c0720298bd">
        <updating/>
        <source>setJadeReport() updating, protected;
//--------------------------------------------------
// Created:	22 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	progress	: CMS_Progress;
	nowStr		: String;
	genTblPrint			: CM_GenericTablePrint;
begin

	if self.myJadeReport = null then
		create self.myJadeReport transient;
	else
		self.myJadeReport.printArray.purge;
	endif;
	
	self.myJadeReport.description := self.reportDescription;	
	
	nowStr := self.systemToLocalTime(app.actualTimeServer()).shortCurrentLocaleFormat();	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support

	app.printer.setMargins(Print_Landscape,5,5,10,10);
	app.printer.topOfPage := 1;
	app.printer.bottomOfPage := 1;
	app.printer.setReport(self.myJadeReport);	//Capture for print preview.

	create genTblPrint transient;
	genTblPrint.setHeaders(self.reportDescription, app.getMyUserCode &amp; " - " &amp; nowStr);	
	app.printer.setHeader(genTblPrint.frHeader);
	app.printer.setFooter(null);
	
	genTblPrint.frFooter.width := app.printer.pageWidth;
	genTblPrint.lblTheUser.caption := app.getMyUserCode;
	genTblPrint.lblTheDatePrinted.caption := self.systemToLocalTime(app.actualTimeServer()).shortCurrentLocaleFormat();	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
			
	create progress transient;
	genTblPrint.printTable(self.myDataTable, true, progress);
	
	self.printExtraFrames();	//22 Feb 2012	NDL	Par 29120
		
	app.printer.close;
	
epilog
	app.printer.close;
	delete progress;
	delete genTblPrint;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f19f7050-7d49-46cd-8006-b405b508fee4">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	user : CM_User;
begin
	inheritMethod();

	user := app.myPassport.myUser;
	
	if user &lt;&gt; null
	and user.myEmailEntity &lt;&gt; null then
		self.cmbFromAddress.addItemObject(user.getEmailAddress(), user.myEmailEntity);
	endif;
	self.cmbFromAddress.addItem(app.myRoot.getConfig(AutoSendersEmailAddress).String);
	/*if self.cmbFromAddress.listCount &gt; 0 then
		self.cmbFromAddress.listIndex := 1;
	endif;*/
	// 20/12/2010 cnwar2 #23071 - replaced above, default to user address or blank if none exists
	if user &lt;&gt; null
	and user.myEmailEntity &lt;&gt; null then
		self.cmbFromAddress.listIndex := self.cmbFromAddress.findObject(user.myEmailEntity);
	endif;

	if self.myDataTable = null then
		//Not called directly for a table
		self.optPrintPreview.value := false;
		self.optPrintPreview.visible := false;
		self.optPrintToFile.click(self.optPrintToFile);		
	else
		self.optPrintPreview.click(self.optPrintPreview);
	endif;
	
	self.txtSubject.text := self.reportDescription;
	
	self.cmbFileFormat.addItem('CSV');
	self.cmbFileFormat.listIndex := 1;
	
	self.btnOk.default := false;	
	self.optPrintToFile.setFocus();	

	// check permission
//	if app.getMyUser.canDo(self.myTerminal, PmPDFBackground) then
		self.optEmailReport.visible := true;
		self.chkEmailReport.visible := true;
//	endif;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="showSelectRecipients" id="3671bb40-278a-42cc-b384-fce19356a351">
        <updating/>
        <source>showSelectRecipients(_mode : Integer)updating, protected;
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	form : CMUI_RecipientSelector;
begin
	if self.myEmailController = null then
		create self.myEmailController transient;
	endif;
	
	create form;
	self.setNavigatorHeading(form.caption);
	form.myEmailController := self.myEmailController;
	form.mode := _mode;
	form.setMyTerminal(self.getMyTerminal());	// 16/8/17 MAP TFS6531
	form.centreWindow;
	form.showModal;

	if form.modalResult = IDOK then
		self.txtToAddress.text := self.myEmailController.allToAddresses.getAddresses();
		self.txtCcAddress.text := self.myEmailController.allCcAddresses.getAddresses();
		self.txtBccAddress.text := self.myEmailController.allBccAddresses.getAddresses();				
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="249d027c-b10d-43a9-a477-28ff2450cc63">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008039, locale);
	btnBccAddress.translateBubbleHelp(Xlat_0000776, locale);
	btnBccAddress.translateCaption(Xlat_0000778, locale);
	btnBrowse.translateCaption(Xlat_0000790, locale);
	btnCcAddress.translateBubbleHelp(Xlat_0000779, locale);
	btnCcAddress.translateCaption(Xlat_0000784, locale);
	btnToAddress.translateBubbleHelp(Xlat_0000780, locale);
	btnToAddress.translateCaption(Xlat_0000785, locale);
	chkEmailFile.translateBubbleHelp(Xlat_0000781, locale);
	chkEmailFile.translateCaption(Xlat_0000786, locale);
	chkEmailReport.translateBubbleHelp(Xlat_0000769, locale);
	chkEmailReport.translateCaption(Xlat_0000772, locale);
	lblFileForm.translateCaption(Xlat_0000787, locale);
	lblFileName.translateCaption(Xlat_0000788, locale);
	lblFromAddress.translateCaption(Xlat_0000773, locale);
	lblMessage.translateCaption(Xlat_0000791, locale);
	lblSubject.translateCaption(Xlat_0000792, locale);
	optEmailReport.translateBubbleHelp(Xlat_0000770, locale);
	optEmailReport.translateCaption(Xlat_0000774, locale);
	optPrintPreview.translateBubbleHelp(Xlat_0000767, locale);
	optPrintPreview.translateCaption(Xlat_0000768, locale);
	optPrintToFile.translateBubbleHelp(Xlat_0000771, locale);
	optPrintToFile.translateCaption(Xlat_0000775, locale);
	txtBccAddress.translateBubbleHelp(Xlat_0000777, locale);
	txtCcAddress.translateBubbleHelp(Xlat_0000782, locale);
	txtSubject.translateBubbleHelp(Xlat_0000789, locale);
	txtToAddress.translateBubbleHelp(Xlat_0000783, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="95351a3f-c89e-4d9a-bb85-141fe81baa6b">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
//--------------------------------------------------
// Created:	25 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	delete self.myEmailController;
	delete self.myJadeReport;
	inheritMethod();
end;</source>
    </JadeMethod>
</GUIClass>
