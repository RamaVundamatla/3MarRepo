<Class name="WS_CargoGroupAssign" id="ddf3d9d9-efe4-4b31-b990-c6800f2f4ae9">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allCargoGroups" id="4dde1a77-d230-4135-bff9-efd69c47a927">
        <memberTypeInverse/>
        <type name="WS_CargoGroupArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="id" id="7ddefa93-6805-445c-810b-aa814af84834">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="isCargoGroupSelectable" id="74c8d5dc-ce5d-4fb4-806c-d3234ab96685">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="selectedCargoGroupOid" id="6ed73daa-4523-4e3d-9975-23b54298e12a">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="totalCargo" id="11ebd073-4539-40da-b012-5f26a6207f11">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="totalProcessedCargo" id="b762f3c7-8942-41e1-940b-d460bca231e2">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="delete" id="906916f6-b7fa-46aa-8e4c-6b50a854019f">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2021	jlier1	Initial creation 51683

*/

vars

begin
	self.allCargoGroups.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAllCargoGroups" id="dcf36179-3e46-40ca-b5cd-221510dd5cd2">
        <updating/>
        <source>setAllCargoGroups(_object: CM_CargoGroupAssignment) updating , protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2021	jlier1	Initial creation

*/

vars
	allCargoGroupsByIdDict : CM_TIByIdCargoTypeDict;	
	ti : CM_TrackedItem;
	cargoGroup : CM_CargoGroup;
	wsCargoGroup : WS_CargoGroup;
begin
	create allCargoGroupsByIdDict transient;
	_object.getAllCargoGroupsByIdDict( allCargoGroupsByIdDict );
	foreach ti in allCargoGroupsByIdDict discreteLock do
		cargoGroup:=ti.CM_CargoGroup;
		create wsCargoGroup transient;
		wsCargoGroup.setProxyFromObject(cargoGroup);
		
		self.allCargoGroups.add(wsCargoGroup);
		if _object.isSelectable and self.selectedCargoGroupOid = null   then
			if not cargoGroup.isComplete and cargoGroup.allPreAssignedCargoIdsDict.first = null  then
				self.selectedCargoGroupOid:=ti.getOidAsString;
			endif;
		endif;
	endforeach;
epilog
	delete allCargoGroupsByIdDict;

end;</source>
        <access>protected</access>
        <Parameter name="_object" type="CM_CargoGroupAssignment"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="3721c3dd-f48f-4371-8054-654b9a817d47">
        <updating/>
        <source>setProxyFromObject(_object: CM_CargoGroupAssignment) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2021	jlier1	Initial creation 51683

*/

vars

begin
	inheritMethod(_object);
		self.id:=_object.id;
	self.totalProcessedCargo:=_object.allProcessedTis.size;
	self.totalCargo := _object.totalTIcount;
	self.isCargoGroupSelectable	:=_object.isSelectable;	
	self.setAllCargoGroups(_object);
epilog

end;</source>
        <Parameter name="_object" type="CM_CargoGroupAssignment"/>
    </JadeMethod>
</Class>
