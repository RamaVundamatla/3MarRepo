    <JadeMethod name="buildTEUMultiplierCombo" id="feeaa5bc-bd8f-40f5-aeeb-bd386023daa5">
        <source>buildTEUMultiplierCombo();
/*
Purpose:			
Date		Who		Reason
05 March 2015	cnwab1	Initial creation
*/

vars

begin
	self.cmbTEUMulti.clear();
	self.cmbTEUMulti.addItemAt(app.getErrorString(ValueOfOne),1);
	self.cmbTEUMulti.addItemAt(app.getErrorString(CM_Quantity),2);
	self.cmbTEUMulti.addItemAt(app.getErrorString(CM_Weight),3);
epilog

end;</source>
