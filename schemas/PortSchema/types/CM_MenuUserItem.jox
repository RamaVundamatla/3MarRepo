    <JadeMethod name="setForCreate" id="cd5f50cd-087b-4a80-9f39-5d0975c1bf28">
        <updating/>
        <source>setForCreate(_proxy : SelfType; _parent : CM_MenuEntity input; _pos : Integer) updating;

vars

begin

	self.heading				:= _proxy.heading;
	self.pictureStringButton 	:= _proxy.pictureStringButton;
	self.pictureStringButtonDown := _proxy.pictureStringButtonDown;
	self.toolTip 				:= _proxy.toolTip;
	self.pictureStringIcon	 	:= _proxy.pictureStringIcon;
	self.myMenuItem				:= _proxy.myMenuItem;
	self.myMenuRoot				:= _proxy.myMenuRoot;
	
	if _proxy.myTerminal &lt;&gt; null then
		self.myTerminal := _proxy.myTerminal;
	elseif _proxy.myMenuRoot &lt;&gt; null and _proxy.myMenuRoot.isKindOf(CM_MenuRootUserTerminal) then
		self.myTerminal := _proxy.myMenuRoot.CM_MenuRootUserTerminal.myUserTerminal.getMyTerminal;
	else
		self.myTerminal := null;
	endif;
	
	_parent.addChild(self, _pos);
	
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_parent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_pos" type="Integer"/>
    </JadeMethod>
