    <JadeMethod name="doBtnVoyInvStatus" id="4019e341-bf51-4674-83c3-21a49ba57387">
        <updating/>
        <source>doBtnVoyInvStatus() updating;
// ---------------------------------------------------------------------------
// Created:		17 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	theReturn : Integer;
	pxyVoy : CM_Voyage;
	ls : Boolean;
begin
	if self.myCurrentVoyage = null then
		app.msgBox("Please select a voyage","Harbour Invoice Generation Error",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if self.myCurrentVoyage.statusInvoice = Voyage_Invoice_Status_FullGen then
		if app.msgBox("Invoices for voyage " &amp; self.myCurrentVoyage.code &amp; " have already been generated." &amp; Cr
						&amp; " are you sure that you want to continue?", "Harbour Invoice Generation", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	else
		if app.msgBox("Are you sure that you want to"  &amp; Cr 
				&amp; "GENERATE INVOICES"  &amp; Cr  &amp;"for voyage "&amp; self.myCurrentVoyage.code &amp; "?", "Harbour Invoice Generation", 
				MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	endif;
	app.mousePointer := Window.MousePointer_HourGlass;
	app.cmsBeginLoad(ls);
	pxyVoy := app.createUpdateProxy(self.myCurrentVoyage).CM_Voyage;
	app.cmsEndLoad(ls);
	
	while true do
		app.myTrxUA.trxUpdateVoyageInvoiceGen(pxyVoy, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Generate Harbour Invoicing", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	if pxyVoy &lt;&gt; null then
		delete pxyVoy.myShipBlockStack;
	endif;
	delete pxyVoy;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildCmbStatus" id="9f7c7bb5-4fc5-423d-96f0-627dc229b797">
        <source>doBuildCmbStatus( _setFromSaved : Boolean );
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
// 02 Jun 2020	NDL			TFS 49417
// 18/02/2022	NAVCS2		ChangeRequest 52897: MTN - Voyage Enq Query Statuses
//
vars
	obj 					: Object;
	terminal 				: CM_Terminal;
	voyageProcess 			: CM_VoyageProcess;
	defaultVoyageProcess 	: CM_VoyageProcess; 		// 52897
	allStatuses 			: CM_ObjectArrayActual;
	status 					: CM_VoyageStatus;
	cmObj 					: CM_Object; 				// 52897
begin
	
	self.lstStatus.clear();
	self.lstStatus.rows := 0;
	
	create allStatuses transient;
	foreach obj in self.lstTerminals.allSelectedObjects do
		terminal := obj.CM_Terminal;
		defaultVoyageProcess := terminal.getDefaultVoyageProcess();
		if defaultVoyageProcess &lt;&gt; null then
		defaultVoyageProcess.allStatuses.copy(allStatuses);
		endif;
	endforeach;
	
	// Relying on the fact that voyage processes are in priority order
	foreach voyageProcess in app.myRoot.allVoyageProcesses where voyageProcess &lt;&gt; defaultVoyageProcess do 	// 52897
		voyageProcess.allStatuses.copy(allStatuses); 														// 52897
	endforeach; 																							// 52897
	
	foreach status in allStatuses as CM_VoyageStatus do
//		self.cmbVoyageStatus.addItemObject(status.description, status);
		if _setFromSaved and savedVoyageStatuses.includes( status.id ) then
			self.lstStatus.accessRow(self.lstStatus.addItem('1' &amp; Tab &amp; status.description &amp; Tab &amp; '(' &amp; status.myProcess.code.String &amp; ')')).itemObject := status;
		else
			self.lstStatus.accessRow(self.lstStatus.addItem('0' &amp; Tab &amp; status.description &amp; Tab &amp; '(' &amp; status.myProcess.code.String &amp; ')')).itemObject := status;
		endif;
	endforeach;
	
epilog
	delete allStatuses;
end;</source>
        <Parameter name="_setFromSaved" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCopyAsNewVoyage" id="b60fc203-b090-4e9f-8e9c-8476775b371e">
