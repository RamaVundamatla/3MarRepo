	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, _passport);

	app.setContinueCMExceptions(false);
	
	beginTransaction;

	app.myUtlRT.utlUpdateMediatorTimeStamp(_mediator, _passport);

	if _passport.hasErrors() then
		return;
	endif;
	
	// Do wrap up processing method for calling interface
	if _trxHook &lt;&gt; null then
		_trxHook.doProcessingForInterface(_passport);
	endif;
	
epilog
