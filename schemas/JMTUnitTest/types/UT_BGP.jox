    "secureBerthTime":null,
    "movementType": "Departure",
    "status": "Completed",
    "createdTime": "2024-08-02T02:42:05.2430509",
    "lastModifiedTime": "2024-08-05T10:47:04.3473873",
	"commercialOperator" : "'&amp;Ref&amp;'"
  }]';
 CompleteArrivalString = '[{
    "movementID": 10982,
    "sourceMovementID": 10982,
    "visitID": '&amp;VoyCode&amp;',
    "sourceVisitID": '&amp;VoyCode&amp;',
    "voyageNoIn": "V. 2464",
    "voyageNoOut": "V. 2464",
    "port": "AUPKL",
    "vesselIMO": '&amp;VessCode&amp;',
    "vesselName": "'&amp;VessCode&amp;'",
    "fromLocation": "",
    "toLocation": "106",
    "purpose": "D",
    "agentCode": "WSS",
    "vesselOperator": "",
    "expectedStartTime": "2024-08-04T17:00:00",
    "clearBerthTime":null,
    "secureBerthTime": "2024-08-04T17:55:00",
    "movementType": "Arrival",
    "status": "Completed",
    "createdTime": "2024-08-02T02:42:04.7962951",
    "lastModifiedTime": "2024-08-04T18:11:41.4068009",
	"commercialOperator" : "'&amp;Ref&amp;'"
  }]';
vars
	terminal 				: CM_Terminal;
	terminalCode			: String;
	extWebServiceDef		: CM_ExternalWebServiceDef;
	activeWebServiceDef 	: CM_APIEndpointServiceDef;
	agent 					: CM_APIConsumerAgent;
	resultString 			: String;
	edifile					: CM_EDIFile;
	bgp						: BGP_OnePortRequest;
	lastSuccessfullTS 		: TimeStamp;
	harbour					: HMS_Harbour;
	wharf					: HMS_Wharf;
	berth					: HMS_Berth;		
	berthArray				: StringArray;
	startingPos 			: Integer;
	berthCode				: String;
	ediData 				: CM_EDIData;
	defVoyageProcess 		: String;
	utVoyProcess 			: CM_VoyageProcessDefault;
	autoVoyProcess 			: CM_VoyageProcessAutomatic;
	vessel					: CM_Vessel;
	operator 				: CM_Operator;
	root 					: CM_Root;
	harbourData				: HMS_VesselDataHarbour;
	tidalClassArr,
	tidalClassDep			: HMS_TidalClass;
	shippingLine 			: CM_ShippingLine;
	trade 					: CM_Trade;
	logLevel				: Integer;
	voyage 					: CM_Voyage;
	hmsData					: HMS_VoyageData;
	hmsMovementArrival,
	hmsMovementDep,
	hmsMovementShift		: HMS_VoyageMovement;
    mtnMovementStatus	    : Integer;  //MTN-35997
begin
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	terminal := app.myRoot.allTerminals[terminalCode];
	self.assertNotNullMsg(terminal, "No terminal set, unable to run test");		
	
	root := self.getRoot();
	operator := root.allOperators[OperatorCode];
	if operator = null then
		operator := self.addOperator(OperatorCode, "UT_" &amp; OperatorCode &amp; " Desc", false, null, null, null, false, false, false, false, false, false, false, false, false, false, null, null, null, null, false, false, null, null, null, null, false, false);
		self.assertTrueMsg(operator &lt;&gt; null,"Operator is null");
	endif;
	
	// Delete things first
	self.deleteVessel(VessCode);
	self.opts.purge();
	
	operator := app.myRoot.allOperators.getAtKey("DOUG");
	trade	 := app.myRoot.allTradesByDescription.getAtKey("Doug World");
	shippingLine := app.myRoot.allShippingLines.getAtKey("DOUG");
	
	//Add Vessel
	self.opts.purge();
	self.opts.addAssoc("isBarge",true);
	self.opts.addAssoc("VesselTrade",trade);
	self.opts.addAssoc(ETRow_LloydsNumber,VessCode);
	self.opts.addAssoc("ShippingLine",shippingLine);
	self.opts.addAssoc(ETRow_CallSign,"Doofus");
	self.opts.addAssoc("YearOfBuild",2020);
	
	vessel := self.addVesselGeneralCargo(VessCode, self.getOperator("MSK"), 10);
	self.assertNotNullMsg(vessel, "Vessel " &amp; VessCode);
	self.assertNotNullMsg(vessel.myHMSVesselData, "Vessel " &amp; VessCode &amp; " HMS Data");
	
	// Check the vessel has tidal classes
	harbour := terminal.myHarbour;
	harbourData := vessel.myHMSVesselData.allVesselDataForHarbour[harbour];
	tidalClassArr := root.allTidalClasses["E"];
	tidalClassDep := root.allTidalClasses["C"];
	self.assertEqualMsg(tidalClassArr , harbourData.myTidalClassArrival, "tidal class arrival mismatch");
	self.assertEqualMsg(tidalClassDep , harbourData.myTidalClassDeparture, "tidal class departure mismatch");
	
	//set to what the unit test needed
	utVoyProcess := CM_VoyageProcessDefault.firstInstance;
	defVoyageProcess := self.setTerminalConfig(DefaultVoyageProcess, utVoyProcess.code).String;	
	
	//extWebServiceDef := app.myRoot.getFirstActiveEWSForEndpoint( ETRow_NswVesselMovements );		//JIRA-34249
	extWebServiceDef := app.myRoot.allExternalWebServices["NSW 'Old' OnePort Vessel Movements"];	//JIRA-34249
	if extWebServiceDef &lt;&gt; null then																//JIRA-34249
		beginTransaction;																			//JIRA-34249
		extWebServiceDef.setActive(true);															//JIRA-34249
		commitTransaction;																			//JIRA-34249
	endif;																							//JIRA-34249
	self.assertNotNullMsg(extWebServiceDef, "(NSW 'Old' OnePort Vessel Movements) external webservice is null/ not available/ changed");
	self.assertTrueMsg(extWebServiceDef.isAPIDef, "extWebServiceDef.isAPIDef");
	activeWebServiceDef := extWebServiceDef.CM_APIEndpointServiceDef;

	// wharf
	wharf := harbour.allWharves["WF01"].HMS_Wharf;
	if wharf = null then
		wharf := self.addWharf("WF01","OnePort Test wharf", harbour, 1600, 100);
	endif;
	
	// berth Just incase the berth is missing
	create berthArray transient;	
	berthArray.add("105");
	berthArray.add("106");
	berthArray.add("107");
	berthArray.add("108");	
	startingPos := 0;
	foreach berthCode in berthArray do
		berth := harbour.allBerths[berthCode];
		if berth = null then	
			addBerth(berthCode, berthCode, harbour, startingPos, 100, 2.5, false, wharf);
		endif;
		startingPos += 100;
	endforeach;
	
	resultString := MovementString;

	//Process response string
	lastSuccessfullTS := activeWebServiceDef.getLastSuccessfulTS(terminal);   //lastSuccessfullTS;  //MTN-36366
	create bgp transient;
	edifile := bgp.processOnePortResponse(resultString, null, activeWebServiceDef, lastSuccessfullTS, terminal);
	self.assertNotNullMsg(edifile,"EDI File is null");
	self.assertNoTrxErrorsOrWarnings();
	ediData := edifile.ediData;
	self.assertNotNullMsg(ediData, "No edidata has been created.");	
	
	ediData.verifyEDIDataTIs(app.myPassport);
	self.assertIsOneOf(ediData.status, "Status should be Verified - " &amp; ediData.status.String, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, CM_EDIFile.EDI_STATUS_VERIFIED );
	self.assertEqualMsg(ediData.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	ediData.loadDB(true, app.myPassport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");	
	delete bgp;
	
	voyage := terminal.allVoyagesByCode.getAtKeyGeq(VoyCode, null);
	self.assertNotNullMsg(voyage, "Voyage should not be null");
	self.assertEqualMsg(voyage.displayOption, VoyageDisplayDefault, "The display option should be the default one");//JIRA-34340
	
	//Verify HMS movements
	hmsData	:= voyage.myHMSVoyageData;
	self.assertNotNullMsg(hmsData, "HMS data should not be null");
	self.assertEqualMsg(hmsData.allVoyageMovements.size, 3, "Voyage movement size should be 3");
	
	hmsMovementArrival 	:= hmsData.getMovementForMoveType(HMSMovementTypeArrival);
	self.assertNotNullMsg(hmsMovementArrival, "No Arrival movemnet");
	self.assertTrueMsg(hmsMovementArrival.chargeForMove, "The movement should be enabled to be chargeable");	//JIRA-34037
	
	hmsMovementDep 		:= hmsData.getMovementForMoveType(HMSMovementTypeDeparture);
	self.assertNotNullMsg(hmsMovementDep, "No Departure Movement");
	self.assertTrueMsg(hmsMovementDep.chargeForMove, "The movement should be enabled to be chargeable");		//JIRA-34037
	
	hmsMovementShift 	:= hmsData.getMovementForMoveType(HMSMovementTypeShift);
	self.assertNotNullMsg(hmsMovementShift, "No Shift Movement");
	self.assertTrueMsg(hmsMovementShift.chargeForMove, "The movement should be enabled to be chargeable");		//JIRA-34037
	
    self.assertTrueMsg(terminal.isOnePortStatusToBeProcessed("Confirmed", mtnMovementStatus), "Oneport Movement status 'Confirmed' should be configured in MTN");   //MTN-35997
    self.assertEqualMsg(mtnMovementStatus, 0, "Oneport Movement status for 'Confirmed' should be configured as 'Planned' in MTN");                                  //MTN-35997
    
	//CANCEL SHIFT MOVEMENT:
	//Process the cancel shift movement	
	resultString := CancelShiftMovement;
	
	lastSuccessfullTS := activeWebServiceDef.getLastSuccessfulTS(terminal);//lastSuccessfullTS; //MTN-36366
	create bgp transient;
	edifile := bgp.processOnePortResponse(resultString, null, activeWebServiceDef, lastSuccessfullTS, terminal);
	self.assertNotNullMsg(edifile,"EDI File is null");
	ediData := edifile.ediData;
	self.assertNotNullMsg(ediData, "No edidata has been created.");	
	
	ediData.verifyEDIDataTIs(app.myPassport);
	self.assertIsOneOf(ediData.status, "Status should be Verified - " &amp; ediData.status.String, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, CM_EDIFile.EDI_STATUS_VERIFIED );
	self.assertEqualMsg(ediData.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	ediData.loadDB(true, app.myPassport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	delete bgp;
	
	//Verify HMS movements
	hmsData	:= voyage.myHMSVoyageData;
	self.assertNotNullMsg(hmsData, "HMS data should not be null");
	self.assertEqualMsg(hmsData.allVoyageMovements.size, 2, "Voyage movement size should be 3");
	
	hmsMovementArrival 	:= hmsData.getMovementForMoveType(HMSMovementTypeArrival);
	self.assertNotNullMsg(hmsMovementArrival, "No Arrival movemnet");
	self.assertTrueMsg(hmsMovementArrival.chargeForMove, "The movement should be enabled to be chargeable");		//JIRA-34037
	
	hmsMovementDep 		:= hmsData.getMovementForMoveType(HMSMovementTypeDeparture);
	self.assertNotNullMsg(hmsMovementDep, "No Departure Movement");
	self.assertTrueMsg(hmsMovementDep.chargeForMove, "The movement should be enabled to be chargeable");			//JIRA-34037
	
	hmsMovementShift 	:= hmsData.getMovementForMoveType(HMSMovementTypeShift);
	self.assertNullMsg(hmsMovementShift, "Shift Movement should be removed from the HMS voyage data");

	//Removal/ Shift Movement - 																									//JIRA-34249 START &gt;&gt;&gt;&gt;
	//Check the movement uses the actual voyage arrival time for updating the voyage, -												//JIRA-34249
	//if the movement message time(expectedStartTime in this case) is greater than the voyage departed date.						//JIRA-34249
	resultString := UpdateShiftMovement34249;
	
	lastSuccessfullTS := activeWebServiceDef.getLastSuccessfulTS(terminal);//lastSuccessfullTS; //MTN-36366
	create bgp transient;
	edifile := bgp.processOnePortResponse(resultString, null, activeWebServiceDef, lastSuccessfullTS, terminal);
	self.assertNotNullMsg(edifile,"EDI File is null");
	ediData := edifile.ediData;
	self.assertNotNullMsg(ediData, "No edidata has been created.");	
	
	ediData.verifyEDIDataTIs(app.myPassport);
	self.assertIsOneOf(ediData.status, "Status should be Verified - " &amp; ediData.status.String, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, CM_EDIFile.EDI_STATUS_VERIFIED );
	self.assertEqualMsg(ediData.getNumErrors, 0, "No error's or warning should occurs");	//MTN-35997
	app.myPassport.clearErrorsWarnings();                                                   //MTN-35997
    self.ignoreTrxWarnings(true);                                                           //MTN-35997
    
	ediData.loadDB(true, app.myPassport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	delete bgp;
	
	//Cancel Removal/Shift movement		-  JIRA-34249
	resultString := UpdateShiftMovement34249Cancel;
	lastSuccessfullTS := activeWebServiceDef.getLastSuccessfulTS(terminal);//lastSuccessfullTS; //MTN-36366
	create bgp transient;
	edifile := bgp.processOnePortResponse(resultString, null, activeWebServiceDef, lastSuccessfullTS, terminal);
	self.assertNotNullMsg(edifile,"EDI File is null");
	ediData := edifile.ediData;
	self.assertNotNullMsg(ediData, "No edidata has been created.");	
	
	ediData.verifyEDIDataTIs(app.myPassport);
	self.assertIsOneOf(ediData.status, "Status should be Verified - " &amp; ediData.status.String, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, CM_EDIFile.EDI_STATUS_VERIFIED );
	self.assertEqualMsg(ediData.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	ediData.loadDB(true, app.myPassport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	delete bgp;																												        //JIRA-34249 END &lt;&lt;&lt;&lt;
	
	//CANCEL DEPARTURE MOVEMENT:
	//Process the cancel Departure movement	
	resultString := CancelDepartureMovement;
	
	lastSuccessfullTS := activeWebServiceDef.getLastSuccessfulTS(terminal);//lastSuccessfullTS; //MTN-36366
	create bgp transient;
	edifile := bgp.processOnePortResponse(resultString, null, activeWebServiceDef, lastSuccessfullTS, terminal);
	self.assertNotNullMsg(edifile,"EDI File is null");
	ediData := edifile.ediData;
	self.assertNotNullMsg(ediData, "No edidata has been created.");	
	
	ediData.verifyEDIDataTIs(app.myPassport);
	self.assertIsOneOf(ediData.status, "Status should be Verified - " &amp; ediData.status.String, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, CM_EDIFile.EDI_STATUS_VERIFIED );
	self.assertEqualMsg(ediData.getNumErrors, 0, "No error's or warning should occurs");	//MTN-35997
    app.myPassport.clearErrorsWarnings();                                                   //MTN-35997
    self.ignoreTrxWarnings(true);                                                           //MTN-35997
	
	ediData.loadDB(true, app.myPassport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	delete bgp;
	
	//Verify HMS movements
	hmsData	:= voyage.myHMSVoyageData;
	self.assertNotNullMsg(hmsData, "HMS data should not be null");
	self.assertEqualMsg(hmsData.allVoyageMovements.size, 2, "Voyage movement size should be 3");
	
	hmsMovementArrival 	:= hmsData.getMovementForMoveType(HMSMovementTypeArrival);
	self.assertNotNullMsg(hmsMovementArrival, "No Arrival movemnet");
	self.assertTrueMsg(hmsMovementArrival.chargeForMove, "The movement should be enabled to be chargeable");	//JIRA-34037
	
	hmsMovementDep 		:= hmsData.getMovementForMoveType(HMSMovementTypeDeparture);
	self.assertNotNullMsg(hmsMovementDep, "No Departure Movement");	
	self.assertNotNullMsg(hmsMovementDep.myCancelledMovement, "Cancelled movement reference should not be null");
	self.assertTrueMsg(hmsMovementDep.chargeForMove, "The movement should be enabled to be chargeable");		//JIRA-34037
	
	//CANCEL ARRIVAL MOVEMENT:
	//Process the Arrival cancel message	
	resultString := CancelArrivalMovement;
	
	lastSuccessfullTS := activeWebServiceDef.getLastSuccessfulTS(terminal);//lastSuccessfullTS; //MTN-36366
	create bgp transient;
	edifile := bgp.processOnePortResponse(resultString, null, activeWebServiceDef, lastSuccessfullTS, terminal);
	self.assertNotNullMsg(edifile,"EDI File is null");
	ediData := edifile.ediData;
	self.assertNotNullMsg(ediData, "No edidata has been created.");	
	
	ediData.verifyEDIDataTIs(app.myPassport);
	self.assertIsOneOf(ediData.status, "Status should be Verified - " &amp; ediData.status.String, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, CM_EDIFile.EDI_STATUS_VERIFIED );
	self.assertEqualMsg(ediData.getNumErrors, 0, "No error's or warning should occurs");        //MTN-35997
	app.myPassport.clearErrorsWarnings();                                                       //MTN-35997
    self.ignoreTrxWarnings(true);                                                               //MTN-35997
	
	ediData.loadDB(true, app.myPassport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");
	delete bgp;
	
	//Verify HMS movements
	self.assertEqualMsg(voyage.status, Voyage_Status_Cancelled, "Voyage status should be cancelled");
	hmsData	:= voyage.myHMSVoyageData;
	self.assertNotNullMsg(hmsData, "HMS data should not be null");
	self.assertEqualMsg(hmsData.allVoyageMovements.size, 2, "Voyage movement size should be 3");
	
	hmsMovementArrival 	:= hmsData.getMovementForMoveType(HMSMovementTypeArrival);
	self.assertNotNullMsg(hmsMovementArrival, "No Arrival movemnet");
	self.assertTrueMsg(hmsMovementArrival.chargeForMove, "The movement should be enabled to be chargeable");	//JIRA-34037
	
	hmsMovementDep 		:= hmsData.getMovementForMoveType(HMSMovementTypeDeparture);
	self.assertNotNullMsg(hmsMovementDep, "No Departure Movement");	
	self.assertNotNullMsg(hmsMovementDep.myCancelledMovement, "Cancelled movement reference should not be null");
	self.assertTrueMsg(hmsMovementDep.chargeForMove, "The movement should be enabled to be chargeable");		//JIRA-34037
	
    //Change the voyage status back to "Arrived" to process the remaining messages.     //MTN-35997
    beginTransaction;                                                                   //MTN-35997
	voyage.setStatusFromObject(app.myRoot.allVoyageStatuses[Voyage_Status_Arrived]);    //MTN-35997
	commitTransaction;                                                                  //MTN-35997
    
	// JIRA-34486 - to test voyage status aligns with the voyage process selection
	
	//set to voyage process to non-default (automatic) voyage process
	autoVoyProcess := CM_VoyageProcessAutomatic.firstInstance;
	voyage := terminal.allVoyagesByCode.getAtKeyGeq(VoyCode, null);
	beginTransaction;
	voyage.setVoyageProcess(autoVoyProcess);
	commitTransaction;
	self.assertNotNullMsg(voyage.myVoyageProcess, "Voyage should not be null");
	self.assertTrueMsg(voyage.isAutomaticProcess,"Voyage Process is not automatic");//JIRA-34340
	
	resultString := CompleteArrivalString;

	//Process response string
	lastSuccessfullTS := activeWebServiceDef.getLastSuccessfulTS(terminal);//lastSuccessfullTS; //MTN-36366
	create bgp transient;
	edifile := bgp.processOnePortResponse(resultString, null, activeWebServiceDef, lastSuccessfullTS, terminal);
	self.assertNotNullMsg(edifile,"EDI File is null");
	ediData := edifile.ediData;
	self.assertNotNullMsg(ediData, "No edidata has been created.");	
	
	ediData.verifyEDIDataTIs(app.myPassport);
	self.assertIsOneOf(ediData.status, "Status should be Verified - " &amp; ediData.status.String, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, CM_EDIFile.EDI_STATUS_VERIFIED );
	self.assertEqualMsg(ediData.getNumErrors, 0, "No error's or warning should occurs");	    //MTN-35997
    app.myPassport.clearErrorsWarnings();                                                       //MTN-35997
    self.ignoreTrxWarnings(true);                                                               //MTN-35997
	
	ediData.loadDB(true, app.myPassport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");	
	delete bgp;
	
	
	hmsData := voyage.myHMSVoyageData;	
	hmsMovementArrival 	:= hmsData.getMovementForMoveType(HMSMovementTypeArrival);
	self.assertNotNullMsg(hmsMovementArrival, "No Arrival movemnet");
	self.assertEqualMsg(hmsMovementArrival.moveStatusNEW,MovementStatus_Actual, "The movement is not actual");	//JIRA-34037
	self.assertEqualMsg(voyage.status,Voyage_Status_Arrived_Auto, "Voyage Stauts is not arrived automatic");
	
	resultString := CompleteDepartureString;

	//Process response string
	lastSuccessfullTS := activeWebServiceDef.getLastSuccessfulTS(terminal);//lastSuccessfullTS; //MTN-36366
	create bgp transient;
	edifile := bgp.processOnePortResponse(resultString, null, activeWebServiceDef, lastSuccessfullTS, terminal);
	self.assertNotNullMsg(edifile,"EDI File is null");
	ediData := edifile.ediData;
	self.assertNotNullMsg(ediData, "No edidata has been created.");	
	
	ediData.verifyEDIDataTIs(app.myPassport);
	self.assertIsOneOf(ediData.status, "Status should be Verified - " &amp; ediData.status.String, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, CM_EDIFile.EDI_STATUS_VERIFIED );
	self.assertEqualMsg(ediData.getNumErrors, 0, "No error's or warning should occurs");	    //MTN-35997
    app.myPassport.clearErrorsWarnings();                                                       //MTN-35997
    self.ignoreTrxWarnings(true);                                                               //MTN-35997
	
	ediData.loadDB(true, app.myPassport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");	
	delete bgp;

	hmsData := voyage.myHMSVoyageData;	
	hmsMovementDep 	:= hmsData.getMovementForMoveType(HMSMovementTypeDeparture);
	self.assertNotNullMsg(hmsMovementDep, "No Depart movemnet");
	self.assertEqualMsg(hmsMovementDep.moveStatusNEW,MovementStatus_Actual, "The movement is not actual");	//JIRA-34037
	self.assertEqualMsg(voyage.status,Voyage_Status_Depart_Auto, "Voyage Stauts is not departure automatic");
	

epilog
	delete agent;
	delete bgp;
	delete berthArray;
	//self.setTerminalConfig( DefaultVoyageProcess, defVoyageProcess );
	app.changeLogLevel(logLevel);
	beginTransaction;
	app.allExtOAuthTokens.purge();
	extWebServiceDef.setActive(false);	//JIRA-34249 - QShip UT failes otherwise
	commitTransaction;
	// ### JIRA: MTN-34813 21May2025 NAVPW1 - If we fail the unit test at any stage the voyage may be null
	if voyage &lt;&gt; null then
		beginTransaction;
		voyage.setVoyageProcess(utVoyProcess);
		commitTransaction;
	endif;
	// ### JIRA: MTN-34813 21May2025 NAVPW1
end;</source>
    </JadeMethod>
    <JadeMethod name="tPhotoGarbageCollection" id="13d1a236-3e0d-409c-8f55-c6f4e84ed01c">
        <source>tPhotoGarbageCollection();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Apr 2025	navhl20 Bug MTN-34530: MTN - Large Number of trxDeleteDBCargoPhotosForTI during garbage collection
20 Nov      2025	navsp1	MTN-36650 Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client
*/
vars
	tI1, tI2,tI3		: CM_TrackedItem;
	photoDesc 			: String;
	photo 				: Binary;
	resourcesForm 		: PictureResourcesForm;
	result				: CM_Photo;
    thumbPhoto          : Binary;                                        //MTN-36650	   
begin
	self.deleteContainer("UTCNT01");
	self.deleteContainer("UTCNT02");
	
	tI1 := self.addContainerOpts("UTCNT01", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI2 := self.addContainerOpts("UTCNT02", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	tI3 := self.addContainerOpts("UTCNT03", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	photoDesc := "a photo descrption for UUT34520";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	photo := resourcesForm.picExamplePhoto.picture;
    thumbPhoto  := self.createThumbnailContent(photo);                  //MTN-36650
	
	result := self.addCargoPhoto(tI1, photoDesc, photo);
	
	self.assertEqual(result.description, "a photo descrption for UUT34520");
	self.assertEqual(result.getPhotoContent(), photo);
	self.assertEqual(result.getThumbnailContent(), thumbPhoto);
	
	self.assertTrue(tI1.allAttachments.size &gt; 0);
	self.assertTrue(tI1.allAttachments.includes(result));
	self.assertTrue(tI1.numAttachments(CM_Attachment.Type_Photo) = 1);
	
	result := self.addCargoPhoto(tI2, photoDesc, photo);
	
	self.assertEqual(result.description, "a photo descrption for UUT34520");
	self.assertEqual(result.getPhotoContent(), photo);
	self.assertEqual(result.getThumbnailContent(), thumbPhoto);         //MTN-36650
	
	self.assertTrue(tI2.allAttachments.size &gt; 0);
	self.assertTrue(tI2.allAttachments.includes(result));
	self.assertTrue(tI2.numAttachments(CM_Attachment.Type_Photo) = 1);
	
	self.opts.purge;
	self.opts.addAssoc('CARGOPHOTO', true);
	
	self.runGarbageCollection(app.actualTimeServer.date.addDays(1), self.getTerminal());
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqualMsg(tI1.allAttachments.size , 0, "Attched photo not purged");
	self.assertEqualMsg(tI2.allAttachments.size , 0, "Attched photo not purged");
epilog
	delete resourcesForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRunBgpDeferredCharging" id="4f445a6b-6e96-45e0-916e-ec39a55997e4">
        <source>tRunBgpDeferredCharging();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2021	navndl1	Initial creation	TFS 51443

*/

vars

	bgpCont : BGP_DeferredChargingController;
	initiated : Boolean;
	req : BGP_DeferredChargingRequest;
	trx : CM_TITransaction;
	
	qDef : CM_QueryDefinition;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	myEnqController : CM_EnqControllerCargoTrans;
	now : TimeStamp;
	tType :  CM_TransactionType;
	startObject : CM_TITransaction;
	iter : Iterator;
	count : Integer;
	trxSet : CM_TITransactionSet;

begin

	bgpCont := BGP_DeferredChargingController.firstInstance;
	if bgpCont = null then
		self.assertTrueMsg( bgpCont &lt;&gt; null, "No BGP_DeferredChargingController found!" );
	endif;
	
	create trxSet transient;
	
	now := app.actualTimeServer;
	tType := app.myRoot.allTransactionTypes.getAtKey(5);  //Moved transaction.
	
	
	
	//find some transactions that are chargeable
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Transaction_Query_Type,CM_QueryDefinition.CargoTransaction_Query_Mode];
	create myEnqController;
	create myEnqController.allObjects as CM_TITransactionByDateDict transient;
	create criteriaHolder transient;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	self.doCreateCriteriaLine( qDef, criteriaHolder, CM_TITransaction::dateTime.name, CM_QueryOperator.Operator_Equal, now.date );
	self.doCreateCriteriaLine( qDef, criteriaHolder, CM_TITransaction::myTerminal.name, CM_QueryOperator.Operator_Equal, self.getMyTerminal );
	self.doCreateCriteriaLine( qDef, criteriaHolder, CM_TITransaction::noCharge.name, CM_QueryOperator.Operator_Equal, false );
	self.doCreateCriteriaLine( qDef, criteriaHolder, CM_TITransaction::getTransactionType.name, CM_QueryOperator.Operator_Equal, tType );
	
	myEnqController.doQuery( qDef );

	iter := myEnqController.allObjects.CM_TITransactionByDateDict.createIterator;
	startObject := myEnqController.allObjects.CM_TITransactionByDateDict.getAtKeyLeq( now );
	if startObject &lt;&gt; null then
		iter.startAtObject( startObject );
		while iter.back( trx ) do
			count := count + 1;
			if count &gt; 20 then
				break;
			endif;
			trxSet.add(trx);
		endwhile;
	endif;
	
	//and a couple more, two from terminal NDL and one that has been deleted i.e. invalid
	trx := "2393.59844887".asOid.CM_TITransaction;// NDL Moved
	trxSet.add(trx);
	
	trx := "2387.237492275".asOid.CM_TITransaction; // invalid one.
	trxSet.add(trx);
	
	trx := "12568.8350".asOid.CM_TITransaction; // NDL CM_BBDiscrepancy.
	trxSet.add(trx);
	
	//Arbitarilly create requests fior these 22 trxs
	beginTransaction;
	foreach trx in trxSet do
		create req persistent;
		req.setTransaction(trx);
	endforeach;
	commitTransaction;
	
	self.assertTrueMsg( bgpCont.myDeferredChargesRoot.allNewDeferredReqs.size &gt;= 23, "BGP_DeferredChargingRoot hasn't got the requests on it!" );
	
	//turn on processing for Unit Test terminal, so any new trxs created will generate (bgp deferred charging) requests instead of just creating (in line) invoice lines.
	self.setTerminalConfig( DeferredCharging, true );

	if not bgpCont.isRunning() then
		app.startApplicationWithParameter(bgpCont.schemaName, bgpCont.appName, bgpCont);
		initiated := true;
	endif;
	
	process.sleep(1000); // to allow some processing to occur
	
	self.assertTrueMsg( bgpCont.myDeferredChargesRoot.allNewDeferredReqs.isEmpty, "BGP should have processed all those, but still " &amp; bgpCont.myDeferredChargesRoot.allNewDeferredReqs.size.String &amp; " requests left");

epilog

	if initiated then
		bgpCont.terminateProcessing( app.myPassport.getUserCode );
	endif;
	
	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	
	delete myEnqController;
	delete trxSet;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="tVoyageGarbageCollect" id="13194c64-2748-4b08-b928-0441001d9264">
        <updating/>
        <source>tVoyageGarbageCollect() updating;
// cnwmh5
//cnwrd1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2012	cnwrd1	Initial creation
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

vars

	voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	q : CM_VoyageQueue;
	cq : CM_VoyageCraneQueue;
begin
	voyage := self.createVesselVoyage(null,null,null);

	self.createCargoOnSite();
	
	voyageJob := self.createVoyageLoadJobsVA(); 
	self.planLoadItems();
	self.loadAllJobsToOps(self.getVoyage("UTGARBAGE1"), true);
	self.moveCargoForVoyageJob(voyageJob, QUEUE_MODE);

	q := self.getQueue("UTGARBAGE1").CM_VoyageQueue;
	cq := q.allSubQueuesById["UTGARBAGE1 CRN1"].CM_VoyageCraneQueue;
	
	beginTransaction;
	//cq.setPropertyValue("loadMachinesMode", CM_VoyageCraneQueue.UseShipLanderApp);
	cq.setPropertyValue("loadMachinesMode", CM_VoyageCraneQueue.ActAsShipLander);
	commitTransaction;

	self.addMachineAndQCargo(voyageJob);
	
	self.opts.purge;
	self.archiveVoyage("UTGARBAGE1");
	
	self.opts.purge;
	self.opts.addAssoc('VOYAGE', true);
	
	self.runGarbageCollection(app.actualTimeServer.date, self.getTerminal());// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	self.assertNoTrxErrorsOrWarnings();
epilog
	self.opts.purge();
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tWOJobSheetGC" id="92ccd54b-dda1-4257-a2b5-f6e29828eab5">
        <source>tWOJobSheetGC();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Aug 2023 navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection

*/

constants
	REF: String  =  "TFS58158";
	MyTrain: String = "TFS58158T";
vars
	workorder 				: CM_WorkOrder;
	useYardJobsSetting 		: Any;
	train1,
	train2 					: CM_Train;
	trainSet 				: CM_TrainSet;
	toDoTaskDesc 			: CM_ToDoTaskDesc;
	taskID					: Integer;
	transaction 			: CM_Transaction;
	toDoTaskDescSet     	: CM_ToDoTaskDescBySortKey;
	toDoTask				: CM_ToDoTask;
	proxyResourceTypeUsage, 
	resourcetypeUsage 		: CM_ResourceTypeUsage;
	newTrans 				: CM_Transaction;
	myPxyWorkPointJobSheet,
	realJobSheet,
	jobSheet				: CM_WorkPointJobSheet;
	allJobArr				: CM_JobSet;
	wod						: CM_WorkOrderDtl;
	date					: TimeStamp;
begin
	/*
	** Setup Section, create the work order with a ToDo train task with multiple trains
	*/
	
	// Set the config to use yard jobs for the terminal
	useYardJobsSetting := self.getTerminal.getConfig(AllowAutoActionToDoWO);
	
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, true);
	commitTransaction;
	
	
	// Add to do task to the work order detail
	toDoTaskDesc := self.xAddToDoTaskTrain(); 
	taskID := toDoTaskDesc.code;
	
	create toDoTaskDescSet transient;
	
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );
	
	// Setup the work order options
	self.opts.purge();
	self.opts.addAssoc('DtRequired', app.actualTimeServer.date.addYears(-12).String);
	self.opts.addAssoc('DtStart', app.actualTimeServer.date.addYears(-12).String);	
	self.opts.addAssoc('TaskType',WO_TASK_ToDo_TRAIN);	
	
	self.opts.addAssoc('toDoTaskID', taskID);
	
	// Create Trains and add to proxy
	self.deleteTrainAndWagons(MyTrain &amp; "1");
	self.deleteTrainAndWagons(MyTrain &amp; "2");
	train1 := self.addTrain(MyTrain &amp; "1" , null);
	train2 := self.addTrain(MyTrain &amp; "2", null);

	create trainSet transient;
	
	trainSet.add(train1);
	trainSet.add(train2);
	
	self.deleteWorkOrderNoValidation('UTWO'&amp;REF);
	
	// Create the work order and check it is not null	
	workorder := self.addWorkOrderVas('UTWO'&amp;REF, WO_STATUS_PENDING, trainSet);
	
	wod := workorder.allWoDtls.first;

	self.assertNotNullMsg(workorder, "The work order is null");
	
	// Check the work order task has the correct status
	self.assertEqualMsg(workorder.taskStatus ,  WO_STATUS_PENDING, "The work order task status should be user entry");
	
	// Approve and action, will create a transaction each
	self.xApproveWorkOrder(workorder);
	
	// Check the status of the work order detail is "actioned"
	self.assertEqualMsg(workorder.allWoDtls.first.status, WO_STATUS_ACTIONED, "The work order task state is not actioned");
	
	if realJobSheet = null then
		realJobSheet := self.xCreateJobSheet();
	endif;
	
	//Allocate job to jobSheet
	create allJobArr transient;
	allJobArr.addNoDuplicates(workorder.allWoDtls.first.CM_WorkOrderToDoDtl.allJobs.first,false);
	if realJobSheet &lt;&gt; null then
		myPxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	endif;
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr,myPxyWorkPointJobSheet,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	date.setDate(app.actualTimeServer.date.addYears(-12));
	beginTransaction;
	realJobSheet.setPropertyValue(CM_WorkPointJobSheet::startDateTime.name,date);
	commitTransaction;
	/*
	 * Complete the to do tasks
	*/	
	
	// Complete the toDo task on the first train
	app.myTrxUA.trxUpdateVasToDoTaskComplete(train1, taskID, app.myPassport, null, workorder.allWoDtls.first.CM_WorkOrderToDoDtl);
	
	// Check the work order has been part completed
	self.assertEqualMsg(workorder.taskStatus, WO_STATUS_PARTCOMPLETE, "The work order has not been part completed");
	
	// Complete the toDo task on the second train
	app.myTrxUA.trxUpdateVasToDoTaskComplete(train2, taskID, app.myPassport, null, workorder.allWoDtls.first.CM_WorkOrderToDoDtl);
	
	// Check the work order has been completed
	self.assertEqualMsg(workorder.taskStatus, WO_STATUS_COMPLETE, "The work order has not been completed");
	
	self.opts.purge;
	self.opts.addAssoc('WOJOBSHEET', true);
	
	self.runGarbageCollection(app.actualTimeServer.date.addYears(-10), self.getTerminal());
	self.assertNoTrxErrorsOrWarnings();
epilog
	beginTransaction;
	self.getTerminal.setConfig(AllowAutoActionToDoWO, useYardJobsSetting);
	commitTransaction;
	delete allJobArr;
	delete trainSet;
	delete toDoTaskDescSet;
	delete myPxyWorkPointJobSheet;
end;</source>
    </JadeMethod>
    <JadeMethod name="uNSWOnePortCancel" id="806f4266-ce21-47f8-b811-1160a74165f9">
