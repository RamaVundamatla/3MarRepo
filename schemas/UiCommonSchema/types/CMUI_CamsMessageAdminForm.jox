		self.searcherShowHideControls (false);
		self.frmQuery.centreHorizontallyInParent();	
		self.frmQuery.centreVerticallyInParent();
	endif;
		
	inheritMethod();
	
	self.caption := self.Title &amp; Space &amp; self.myTerminal.code;
	
	self.frmTblFilter.setupControl(self.tblData, null);

	self.frmTblFilter.setCallbackMethod(CMUI_CamsMessageAdminForm::doFilterTable.name);
epilog

end;</source>
