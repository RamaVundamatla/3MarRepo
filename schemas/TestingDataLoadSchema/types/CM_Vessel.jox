<Class name="CM_Vessel">
    <JadeMethod name="unitTestDeleteObject" id="dea41ba7-d756-47df-99d0-aa7cc2fa16b5">
        <updating/>
        <source>unitTestDeleteObject(_dsl: UT_DSL io) updating;

/*

Purpose:			

Date			Who		Reason
11/08/2015		cnwmh5	Initial creation

*/

vars
	fileXML						: File;
	fileFolder					: FileFolder;
begin
	
	//write self.String &amp; Tab &amp; self.code &amp; Tab &amp; self.creationTime.String;
	app.writeLog(self.String &amp; Tab &amp; self.code &amp; Tab &amp; self.creationTime.String, LogINFO);
	
	create fileFolder transient;
	fileFolder.usePresentationFileSystem := false;
	fileFolder.fileName := app.cnGetServerMiscPath() &amp; "\VesselDefinitions";
	if not fileFolder.isAvailable then
		fileFolder.make();
	endif;
	
	create fileXML transient;
	fileXML.mode := File.Mode_Output;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	//fileXML.fileName := "\\cnwchcm24\cnwpod$\Implementation\Vessel Definitions\" &amp; vesselCode &amp; ".xml";
	fileXML.fileName := fileFolder.fileName &amp; "\" &amp; self.code &amp; ".xml";
	fileFolder.usePresentationFileSystem := false;
	if fileXML.isAvailable() then
		fileXML.purge();
	endif;
	//app.myTrxUA.trxExportAsXMLDoc(self, fileXML.fileName, app.myPassport);
	fileXML.writeLine('&lt;?xml version="1.0"?&gt;');
	fileXML.writeLine(J_key_LessThan.Character &amp; self.class.name &amp; " " &amp; 'type="' &amp;  self.class.name &amp; '"'&amp;J_key_GreaterThan.Character);
	self.exportAsXMLDoc(fileXML);
	fileXML.writeString(self.formatAsXMLSuffix(self.class.name));
	_dsl.sendMsgWithParams("deleteVessel", self.code);	

epilog
	delete fileXML;
	delete fileFolder;
end;</source>
        <Parameter name="_dsl" type="UT_DSL" usage="io"/>
    </JadeMethod>
</Class>
