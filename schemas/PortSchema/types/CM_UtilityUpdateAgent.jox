    <JadeMethod name="utlUpdateROROLocnAlignment" id="aa0ab0b6-f674-42e5-ab0f-1dd0cb2d6f2d">
        <updating/>
        <source>utlUpdateROROLocnAlignment(_locns : ObjectArray; _position : Integer; _passport : CM_Passport input) updating;

vars
	alignor : CMIF_RectangleAlignor;
	obj : Object;
	tmpDeckItemLayout : CM_Graphic;
begin
	
	create alignor transient;

	foreach obj in _locns discreteLock do
		tmpDeckItemLayout := obj.CM_Graphic;
		alignor.addGraphic(tmpDeckItemLayout);
	endforeach;
	
	alignor.doAlignment(_position);


epilog
	delete alignor;
	
end;</source>
