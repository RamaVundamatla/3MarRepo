    <JadeMethod name="editIMEXStatus" id="6aaa7256-3ef2-4907-86a8-eb75d66077f9">
        <source>editIMEXStatus(_ti : CM_TrackedItem; _status : Integer; _ignoreWarnings : Boolean );
// ---------------------------------------------------------------------------
// Created:     13 October 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyTI 			: CM_TrackedItem;
begin
	
	pxyTI := app.createUpdateProxy(_ti).CM_TrackedItem;
	pxyTI.setImExStatus(_status);
	
	while true do
		app.myTrxUA.trxUpdateTrackedItem(pxyTI,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
		if app.myPassport.trxCompletedOK() then
			break;
		elseif _ignoreWarnings and app.myPassport.noErrors then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	delete pxyTI;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_ignoreWarnings" type="Boolean"/>
    </JadeMethod>
