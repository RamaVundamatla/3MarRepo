    </JadeMethod>
    <JadeMethod name="setProxyGTEBookingForJob" id="6a1213c5-a790-4053-bcca-4295177f11e7">
        <source>setProxyGTEBookingForJob(	arrayOfProxies	: CMGTE_EntityArray input;
							jobQueueNum		: Integer; 	
							pxyGTEReceival 	: CMGTE_ReceivalByType input;
							bookItem		: CM_BookingRefItem;
							booking			: CM_BookingRef;
							ct				: CM_CargoType	
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 November 2025	navcs2	MTN-36557 MTN | Booking with Release Empties Issue when clicking on Create Jobs for Selected from Picker

*/

vars
	flexiController : CMIF_FlexiGateController;
	
begin
	pxyGTEReceival.setPXYFromBooking( bookItem );
	
	pxyGTEReceival.setWeight(bookItem.getWeight);
	
	create flexiController transient;
	if ct.isContainer then
		
		if not booking.noEmptiesOut then
			flexiController.mtOnly := true;
			flexiController.jobType 	:= CMGTE_Entity.JobType_EmptyIN;
		else 
			flexiController.jobType 	:= CMGTE_Entity.JobType_FullIN;
		endif;
	elseif ct.isTrailer then
		flexiController.jobType 		:= CMGTE_Entity.JobType_ChassisIN;
	else					
		flexiController.jobType 		:= CMGTE_Entity.JobType_GeneralIN;
	endif;
	flexiController.myTerminal := booking.myTerminal;
	if self.myCallingForm &lt;&gt; null and self.myCallingForm.class.name = "GTE_FlexiGateForm" then
	flexiController.myVehicleVisitRecord := self.myCallingForm.getPropertyValue('myRealVVR').CM_VehicleVisitRecord;
	endif;
	
	flexiController.numItems := bookItem.getQuantity();
	
	if ct.isBulkMulti then
		flexiController.weight := bookItem.getWeight();
	endif;
	
	flexiController.myBookingRefItem := bookItem;
	flexiController.operatorCode := booking.operatorCode;
	flexiController.isoTypeCode := bookItem.getISOTypeCode;
	flexiController.isoGroup := bookItem.getISOTypeGroupForISOType();
	flexiController.cargoType := ct.id;
	flexiController.myProduct := bookItem.myProduct;
	flexiController.voyageCode := bookItem.getVoyageCode;
	
	flexiController.remarks := bookItem.remarks;
	flexiController.myBookingRefItem := bookItem;
	if bookItem &lt;&gt; null then
		flexiController.bookingNumber := bookItem.myBookingReference.bookingReference;
	endif;
	flexiController.freightForwarderCode := booking.getFreightForwarderCode;
	
	pxyGTEReceival.setPXYFromController( flexiController );
	
	pxyGTEReceival.setJobQueueNum( jobQueueNum + arrayOfProxies.size );
	arrayOfProxies.add(pxyGTEReceival);
	
epilog
	delete flexiController;
	
end;</source>
        <Parameter name="arrayOfProxies" type="CMGTE_EntityArray" usage="input"/>
        <Parameter name="jobQueueNum" type="Integer"/>
        <Parameter name="pxyGTEReceival" type="CMGTE_ReceivalByType" usage="input"/>
        <Parameter name="bookItem" type="CM_BookingRefItem"/>
        <Parameter name="booking" type="CM_BookingRef"/>
        <Parameter name="ct" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setProxyGTEForJobCreation" id="cb4533e4-8c23-4f1e-9879-c1c52f39f391">
        <source>setProxyGTEForJobCreation(	arrayOfProxies	: CMGTE_EntityArray input;
							jobQueueNum		: Integer; 	
							pxyGTERelease 	: CMGTE_Release input;
							br				: CM_BulkRelease;
							resDet			: CM_ReserveDetail;
							ct				: CM_CargoType	
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 October 2019		jlgndl1	Initial creation	TFS 47021 - Split out of 'doClickCreateJobsSelected'
19 July 2023		jlizm1	TFS 58461 Change release mark number to string
22 January 2025		navpw1	JIRA: MTN-33825 - Added code to set whether this is an "Any ID" "Any Amount" Load
*/

vars
	flexiController : CMIF_FlexiGateController;
	
begin
	pxyGTERelease.setPXYFromBulkRelease( br, resDet );
	
	pxyGTERelease.setWeight(resDet.getWeightOutstanding);
	
	create flexiController transient;
	if ct.isContainer then
		
		if br.isForMTs then
			flexiController.mtOnly := true;
			flexiController.jobType 	:= CMGTE_Entity.JobType_EmptyOUT;
		else 
			flexiController.jobType 	:= CMGTE_Entity.JobType_FullOUT;
		endif;
	elseif ct.isTrailer then
		flexiController.jobType 		:= CMGTE_Entity.JobType_ChassisOut;
	else					
		flexiController.jobType 		:= CMGTE_Entity.JobType_GeneralOUT;
	endif;
	flexiController.myTerminal := br.myTerminal;
	if self.myCallingForm &lt;&gt; null and self.myCallingForm.class.name = "GTE_FlexiGateForm" then
	flexiController.myVehicleVisitRecord := self.myCallingForm.getPropertyValue('myRealVVR').CM_VehicleVisitRecord;
	endif;
	
	if ct.isBreakBulkMulti then
		flexiController.numItems := resDet.getQuantityRemaining();
	elseif ct.isBulkMulti then
		flexiController.weight := resDet.getWeightOutstanding;
	endif;
	
	flexiController.myBulkRelease := br;
	flexiController.myReserveDetail := resDet;
	flexiController.operatorCode := resDet.getOperatorCode;
	flexiController.operatorGroupCode := resDet.getOperatorGroupCode;
	flexiController.isoTypeCode := resDet.getISOTypeCode;
	flexiController.isoGroup := resDet.getISOGroupCode;
	flexiController.cargoType := ct.id;
	flexiController.myProduct := resDet.getMyProduct;
	flexiController.voyageCode := resDet.getVoyageCode;
	flexiController.yardInstructions := resDet.yardInstruction;
	
	flexiController.remarks := resDet.remarks;
	flexiController.myBookingRefItem := resDet.myBookingRefItem;
	if resDet.myBookingRefItem &lt;&gt; null then
		flexiController.bookingNumber := resDet.myBookingRefItem.myBookingReference.bookingReference;
	endif;
	flexiController.freightForwarderCode := resDet.getFreightForwarderCode;
	flexiController.consigneeCode := resDet.getConsigneeCode;
	flexiController.consignorVoyageCode := resDet.getConsignorVoyageCode;
	flexiController.density := resDet.getDensity;	// ### TFS 52193 22Nov2021 NAVPW1
	flexiController.billOfLading := resDet.getBOLNumber;
	if br.mySubTerminal &lt;&gt; null then
		flexiController.subTerminalCode := br.mySubTerminal.code;
	endif;
	
	if resDet.isKindOf( CM_ReserveSelection ) then
		flexiController.clean := resDet.CM_ReserveSelection.clean;
		flexiController.colour := resDet.CM_ReserveSelection.colour;
		flexiController.heavyRated := resDet.CM_ReserveSelection.heavyRated;
		flexiController.markNumber := resDet.CM_ReserveSelection.markNumber;
		flexiController.mark := resDet.CM_ReserveSelection.markSelection;
		if not resDet.CM_ReserveSelection.allAvailabilityGrades.isEmpty then
			resDet.CM_ReserveSelection.allAvailabilityGrades.copy(flexiController.allAvailabilityGrades);
		endif;
	endif;
	
	flexiController.setIsAnyIdAnyAmt(resDet, ct);	// ### JIRA: MTN-33825 22Jan2025 NAVPW1
	
	pxyGTERelease.setPXYFromController( flexiController );
	
	// ### JIRA: MTN-33961 13Feb2025 NAVPW1
	
	//Maybe look into refactoring these into pxyGTERelease.setPXYFromController.
	//The reason I did not was because pxyGTERelease.setPXYFromController is called in multiple places inside CMUI_ReleaseCargoForm::doSave
	pxyGTERelease.setIsAnyId(flexiController.isAnyId);
	pxyGTERelease.setIsAnyAmount(flexiController.isAnyAmount);
	
	// ### JIRA: MTN-33961 13Feb2025 NAVPW1
	
	pxyGTERelease.setJobQueueNum( jobQueueNum + arrayOfProxies.size );
	arrayOfProxies.add(pxyGTERelease);
	
epilog
	delete flexiController;
	
end;</source>
        <Parameter name="arrayOfProxies" type="CMGTE_EntityArray" usage="input"/>
        <Parameter name="jobQueueNum" type="Integer"/>
        <Parameter name="pxyGTERelease" type="CMGTE_Release" usage="input"/>
        <Parameter name="br" type="CM_BulkRelease"/>
        <Parameter name="resDet" type="CM_ReserveDetail"/>
        <Parameter name="ct" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="12b29ede-b68d-483b-8eaf-0816b3829ab0">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2017	cnwndl1	Initial creation	TFS 3758
*/

vars

	objects : CM_ObjectArrayActual;
	entTableName : String;
	rowIndex : Integer;
	obj : CM_Object;

begin

	create objects transient;

	entTableName := self.tblList.myEntTableDef.name;
	foreach rowIndex in 1 to self.tblList.rows do
		obj := self.tblList.accessRow( rowIndex ).itemObject.CM_Object;
		if obj &lt;&gt; null then
			objects.add(obj);
		endif;
	endforeach;
	
	//jlier1 TFS 64592 20/6/24
	self.xmlSavedSettings := self.getXMLSettingsForSave();
	self.setListTableUsingEntTable(	objects, entTableName, 0, false ); 
	self.resize();
epilog

	delete objects;

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
