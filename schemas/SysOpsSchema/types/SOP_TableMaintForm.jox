    <JadeMethod name="modeSystemOrTerminal" id="c5b4b9e6-3fb2-4785-b7df-9b441160d7dd">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>modeSystemOrTerminal(set: Boolean; _value: String io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     12 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not set) then
		return;
	endif;

	self.modeSystemOrTerminal := _value;
	if self.modeSystemOrTerminal = Mode_System then
		self.permissionView := PmAdmSystemTableView;
	elseif self.modeSystemOrTerminal = Mode_Harbour then
		self.permissionView := PmHMSHarbourTblView;		
	endif;

	// do not do this here as it causes this to be redone - now donw once in init method
//	self.setAllTblItems(_value);

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
