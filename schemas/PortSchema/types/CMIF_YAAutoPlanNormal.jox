    <JadeMethod name="isAvGrade_Match" id="cd966224-4808-4407-abd2-66f5cf9d2abd">
        <source>isAvGrade_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 26 May 2005 by cnwdvb1
// -------------------------------------------
vars
	grade		: Integer;
	ti			: CM_TrackedItem;
begin
	
	ti := self.myTrackedItem;
	
	if not ti.canSetAvailabilityGrade() then
		return false;
	endif;
		
	grade := ti.getAvailabilityGrade;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanNormal::isAvGrade_Compare, grade);

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
