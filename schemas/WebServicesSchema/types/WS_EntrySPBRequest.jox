    <JadeMethod name="processMessage" id="25f7d212-e5ed-4f4d-8cb1-f4866cd4e456">
        <source>processMessage( voyage : CM_Voyage io );
/*

Purpose:			

Parameters:	
"	This is the INAPORTNET Web Service process to notify JMT that the departure process has been approved by INAPORTNET.
"	Voyage must be able to be identified by PKK number.
"	Voyage must be at the "Departure Marine Services Requested" status, otherwise the request will be rejected.
"	Update if everything is OK is to move the Voyage on to the "Departure Marine Services Approved" status.
		

Return Value:		

Date		Who		Reason
23 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars
	workOrderDtl : CM_WorkOrderVoyageDtl;	
	movement : HMS_VoyageMovement;
begin
	workOrderDtl:=voyage.findWorkOrderDtlNotApproved(WO_TASK_MARINEDEPART);
	if workOrderDtl &lt;&gt; null then
		app.myTrxUA.trxUpdateWorkOrderPPK(workOrderDtl,null,true,app.myPassport);
	endif;
	
	self.doUpdateVoyageStatus(voyage);
	
	//epr TFS 40847 14/9/18
	movement:=voyage.getMovementDeparture;
	app.myTrxUA.trxUpdateInaportnetSPOG(movement,self.nomorSPB,app.myPassport);
	
epilog


end;</source>
        <Parameter name="voyage" type="CM_Voyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateForVoyageUpdate" id="9ea0c5f2-8580-4f85-a6a8-1da226d62a81">
        <source>validateForVoyageUpdate( _voyage : CM_Voyage output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2018	jlgndl1	Initial creation

*/

vars

	term : CM_Terminal;
	
begin

	on Exception do self.handleCMExcDuringValidation(exception);	//So we don't bail on the first exception we raise.

	term := app.myPassport.myTerminal;
	
	//3. self.nomorPkk
	_voyage := term.allVoyagesByExternalCode.getAtKey( self.nomorPkk);
	if _voyage = null then
		app.raiseCMException3(Value_field_not_resolve, self.nomorPkk, WS_EntrySPBRequest::nomorPkk.name, app.getErrorString(Voyage), null, null);
		return false;
	endif;
	
	self.validateVoyageStatusForMsg( _voyage );
	
	//if self.status &lt;&gt; null then
		if not self.status.Integer.isOneOf(2,3,4,5) then
			app.raiseCMException3(Value_field_not_resolve, self.status, WS_EntrySPBRequest::status.name, "'2,3,4 or 5'", null, null);
		endif;
//	endif;

epilog

	return not app.myPassport.hasErrors;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMandFieldsPresent" id="e108833c-646e-445f-99a0-4fb87d421bbb">
        <source>validateMandFieldsPresent():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

begin

	on Exception do self.handleCMExcDuringValidation(exception);	//So we don't bail on teh first exception we raise.

	//1. self.user - Checked in superClass ::validareCredentials
	
	//2. self.password - Checked in superClass ::validareCredentials
	
	//3. Number of PKK, Mandatory
	if self.nomorPkk = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntrySPBRequest::nomorPkk.name, null, null);
	endif;
	
	//4. Number of PPKB (request for vessel service), Optional
	//self.nomorSPB
	
	
	//5. Unknown
	//self.dermagaTolak
	
	//6. Unknown - moght be code of destiation berth
	//self.pelabuhanTujuan
	
	//7. Unknown TimeStamp value
	//self.waktuTolak
	
	//8. Status int.
	//self.status
	
	
	//9. self.portCode - Checked in superClass ::validareCredentials
	
	
epilog

	return not app.myPassport.hasErrors;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
