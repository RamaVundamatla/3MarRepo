    <JadeMethod name="loadOnsiteTable" id="4da36c5e-2987-471f-bf91-796f73a0fd6c">
        <updating/>
        <source>loadOnsiteTable(_startingTI : CM_TrackedItem;	// 08/12/2022	navkc1	#55409
				_next		: Boolean			// 08/12/2022	navkc1	#55409
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			eason
22 Apr 2022		navnk20		Initial creation
22 Jun 2022		navsrk20	Bug 53887: EUP - Items Cargo Type to be shown instead of Cargo Group Type
12 Jul 2022		navdap1		TFS 53889 EUP Collapsed view not kept when moving or updating cargo
25 Oct 2022		navkc1		Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened
08 Nov 2022		navmd1		TFS 55379 Refactor VoyageOpsCG Form
28 Nov 2022	    navkc1		ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
08 Dec 2022		navkc1		ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
16 Jan 2023		navmp20		Bug 56062: EUP - #3, #4 Incorrect Cargo grouping/heading values
20 Apr 2023		navmd1		TFS 56062 Fix Cargo Group Detail headers not updating correctly
20/02/2024 		navcs2		MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/
vars
	rowIdx, colIdx	 		: Integer;
	ti 						: CM_TrackedItem;
 // ### TFS BUG 58853 10JUL2023 NAVAB1	dynaDict 				: DynaDictionary;
	currentVoyage 			: CM_Voyage;
	currentTable 			: CM_FilterTable;
	cmifMonitor 			: CMIF_Monitor;
	noMonitor 				: Boolean;
	idx, totalParts,
	currentPart, site		: Integer;
	maxStr					: String;
	iter					: Iterator;
	tis						: CM_TIByCargoGroupIdDict;
	cgDetails				: CM_CargoGroupDetail;
	cargoGroup				: CM_CargoGroup;
	plus					: Character;
	progressStr				: String;
begin
	if not self.isInCargoGrouping then
		inheritMethod(_startingTI, _next);
		return;
	endif;

	on Exception do self.handleExceptionVoyage(exception, currentVoyage);
	currentVoyage := self.myCurrentVoyage;
	if currentVoyage &lt;&gt; null then
		currentVoyage.fetchLatest();
	endif;
	
	// Exception handler sets voyage to null if its been deleted
	if currentVoyage = null then
		return;
	endif;
	
	//17Jan2023 navsp1 TFS 56045 / position changed
	currentTable := self.tblOnsite;
	currentTable.clearSort();	
	currentTable.rows := currentTable.fixedRows;
	currentTable.clearAllViewObjects( Any_System_Event );
	
	// 28/11/2022	navkc1	#55408
	tis := currentVoyage.allOnsiteTIsByCargoGroupId;
	if tis.isEmpty() then 
		return; 
	endif;
	
	self.myCargoGroup := null;
	
	// We're now in our special cargo grouping mode, so lets do things a bit differently
	
	// 28/11/2022	navkc1	#55408 - Copy the cargo group details to dynamic dictionary and have them sorted so they don't get displayed in random order
	/* // ### TFS BUG 58853 10JUL2023 NAVAB1
	create dynaDict transient;
	dynaDict.setMembership(CM_CargoGroupDetail);
	dynaDict.addMemberKey(CM_CargoGroupDetail::myCargoGroup.name &amp; "." &amp; CM_CargoGroup::id.name, false, true);
	dynaDict.endKeys(true); 
	currentVoyage.allCargoGroupDetails.copy(dynaDict);
	maxStr := dynaDict.size().String;
	*/
	
	maxStr := currentVoyage.allCargoGroupDtlBySiteCargoGrp.size.String; // ### TFS BUG 58853 10JUL2023 NAVAB1
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		// This should never be a thing, but instead of breaking because we can't show progress, lets just create a dummy one and not link it anywhere
		noMonitor := true;
		create cmifMonitor transient;
	endif;
	totalParts := cmifMonitor.partsInJob;
	currentPart := cmifMonitor.partsDone;
	
	// 28/11/2022	navkc1	#55408
	site := self.getSiteForTable(currentTable);
	plus := J_key_Plus.Character;
	
	// When in cargo grouping mode, the display is locked to ACTUAL
	//if self.displayModeOnShip = DISPLAY_MODE_ACTUAL then	
	
	progressStr := app.getErrorString(Loading_onsite_cargo);	// Loading On Site Cargo
 // ### TFS BUG 58853 10JUL2023 NAVAB1	foreach cgDetails in dynaDict as CM_CargoGroupDetail discreteLock where cgDetails.site = site do
	foreach cgDetails in currentVoyage.allCargoGroupDtlBySiteCargoGrp discreteLock where cgDetails.site = site do
	
		idx += 1;
		cmifMonitor.updateProgress(progressStr &amp; ' [' &amp; idx.String &amp; '/' &amp; maxStr &amp; ']', totalParts, currentPart);
		
		if cargoGroup = null or cargoGroup &lt;&gt; cgDetails.myCargoGroup then
			cargoGroup := cgDetails.myCargoGroup;
			rowIdx := 0;
		else
			// Already added this Cargo Group Detail, skip to the next one
			continue;
		endif;
		
		ti := cgDetails.getFirstTIForVoyage(currentVoyage);
		self.loadCargoForTable(ti, rowIdx, currentTable, false, true);
		
		// ### TFS BUG 58853 06JUL2023 NAVAB1  self.loadDetailForTable(cgDetails, rowIdx,currentTable,true,false); // ### TFS BUG 58853 06JUL2023 NAVAB1 

		 // ### TFS BUG 58853 03JUL2023 NAVAB1 break;	// Just need to do the first one, as we're combing them in populateCargoGroupDetails
	endforeach;
	
	// Now we find out is there any cargo items has unknown cargo group for this table, add Unknown row if there is.
	iter := tis.createIterator();
	tis.startKeyGeq(null, null, iter);
	iter.next(ti);
	// 28/11/2022	navkc1	#55408
	if ti.myCargoGroup = null then
		rowIdx := currentTable.addItem("");
		if currentTable.getColumnByRowName(ETRow_Id) &lt;&gt; null then
			colIdx := currentTable.getColumnByRowName(ETRow_Id);
			currentTable.accessCell(rowIdx, colIdx).text := " " &amp; app.getErrorString(Unknown);
		endif;
		if currentTable.getColumnByRowName(ETRow_CargoType) &lt;&gt; null then
			colIdx := currentTable.getColumnByRowName(ETRow_CargoType);
			currentTable.accessCell(rowIdx, colIdx).text := app.getErrorString(Unknown_cargo_group);
		endif; 	
		currentTable.accessCell(rowIdx, 1).text := plus &amp; " " &amp; currentTable.accessCell(rowIdx, 1).text;
		currentTable.accessRow(rowIdx).itemObject := ti.myCargoGroup;
		currentTable.accessedRow.backColor := LightYellow;
	endif;
	// 28/11/2022	navkc1	#55408
	
	self.colourTableRows(currentTable);
	
	/* //30/07/2025	navkc1 JIRA MTN 35478
	if self.performRefresh = RefreshCurrentViewOnly then
		currentTable.setCurrentViewObjects();
	endif;
	*/
	
	self.restoreCollapseState(currentTable);		// TFS 53889
	
epilog
 // ### TFS BUG 58853 10JUL2023 NAVAB1	delete dynaDict;	
	delete iter;
	if noMonitor then
		delete cmifMonitor;
	endif;
end;</source>
