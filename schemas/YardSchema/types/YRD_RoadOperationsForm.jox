    <JadeMethod name="mnuSwapCargo_click" id="d117d428-123f-4ad4-ad0e-df9cd6db1846">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuSwapCargo_click(menuItem: MenuItem input) updating;
/*

Date		Who		Reason
21 May 2014	cnwer1	Initial creation PAR

*/

vars
	ti : CM_TrackedItem;
	result : Integer;
begin
	if self.myCurrentWLE = null then
		return;
	endif;
	
	ti:=self.myAssistant.showAssignCargo(self.myCurrentWLE);
	
	if ti &lt;&gt; null then
		while true do
			app.myTrxUA.trxUpdateSwapReleaseTI(self.myCurrentWLE ,ti ,app.myPassport);	
			if not app.myPassport.trxCompletedOK then
				result := app.showErrorWarningDialog('Swap Release Cargo', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	
	endif;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
