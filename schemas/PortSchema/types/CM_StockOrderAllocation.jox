    <JadeMethod name="validateMe" id="9b0773fa-0c7a-461f-b581-172987817ae1">
        <source>validateMe() protected;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	//shifted to validateForCreate so self can be erase if null or zero if updating.
	/*if self.allocQuantity = null and self.allocType = self.AllocType_Quantity then
		app.raiseCMException1(REQUIRED_FIELD, 'Allocate Quantity', ETRow_Quantity, null);
	endif;*/
	if self.myLocationsController = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Location', ETRow_Location, null);
		app.raiseCMException(Input_required_field_locn, ETRow_Location, null);
	endif;
	if self.mySOHLocation = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'SOH Location', ETRow_Location, null);
		app.raiseCMException(Input_required_field_SOHlocn, ETRow_Location, null); // cnwdb2	PAR 35364
	endif;		
end;</source>
        <access>protected</access>
    </JadeMethod>
