    <JadeMethod name="stripCarriageReturns" id="71b19351-5092-4565-a10b-7cbe9e883007">
        <source>stripCarriageReturns(	_attrName 	: String ;
						_strValue 	: String ;
						_cmif 		: CMIF_BOL input;
						_tbl 		: CM_EntryTable input
						) : Boolean protected;
/*
Date			Who		Reason
23 October 2014	cnwar2	#35094

*/

vars

begin
	if not _cmif.isKindOf(CMIF_BOLIn) then
		return false;
	endif;
	//epr TFS 2889 1/11/16
	if _cmif.CMIF_BOLIn.stripCarriageReturns(_attrName,_strValue) then
		return true;
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_cmif" type="CMIF_BOL" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
