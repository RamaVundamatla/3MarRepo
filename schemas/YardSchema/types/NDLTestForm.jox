    <JadeMethod name="comboSelect" id="f20f1837-a3e6-4290-b5a5-52e308f20c95">
        <source>comboSelect();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2010	cnwndl1	Initial creation

*/

vars

	index : Integer;
	baseX : Real;
	baseY : Real;
	point : Point;
	pointX : Integer;
	pointY : Integer;
	fullX : Real;
	fullY : Real;
	newBaseX : Integer;
	newBaseY : Integer;

begin

	index := cmbTA.listIndex;
	if index &lt; 1 then
		return;
	endif;
	
	point := self.mapLocations[index];
	if point = null or point.x = 0 and point.y = 0 then
		return;
	else
		pointX := point.x;
		pointY := point.y;
	endif;
	
	baseX := picMap.scrollHorzPos;
	baseY := picMap.scrollVertPos;
	
	fullX := baseX + picMap.width;
	fullY := baseY + picMap.height;
	
	if baseX &lt; pointX and pointX &lt; fullX and baseY &lt; pointY and pointY &lt; fullY then
		return;
	else
		if pointX &lt; ( picMap.width / 2 ) then
			newBaseX := 0;
		else
			newBaseX := ( pointX - ( picMap.width / 2 ) ).Integer;
			if newBaseX + ( picMap.width / 2 ) &gt; picMap.pictureWidth then
				newBaseX := (( picMap.pictureWidth - ( picMap.width / 2 ) ) - 10 ).Integer;
			endif;
		endif;
		if pointY &lt; ( picMap.height / 2 ) then
			newBaseY := 0;
		else
			newBaseY := ( pointY - ( picMap.height / 2 ) ).Integer;
			if newBaseY + ( picMap.height ) &gt; picMap.pictureHeight then
				newBaseY := ( picMap.pictureHeight - picMap.height ).Integer;
			endif;
		endif;
		picMap.scrollHorzPos := newBaseX;
		picMap.scrollVertPos := newBaseY;
	endif;

epilog

end;</source>
    </JadeMethod>
