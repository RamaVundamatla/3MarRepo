begin
	self.setTerminalConfig(EdiBookingCommodity, false);
	operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	operator := self.getOperator (operatorCode);
	
	self.deleteEDIInwardXlation ("COD", XLATION_TYPE_COMMODITY_BYOP, operator, null);
	
	self.deleteVoyage(VoyageName);
	self.deleteVessel(Vessel);
	vessel := self.addVesselCellular(Vessel, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	voyage := self.addVoyageWithContainerStructur(VoyageName, Vessel, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.deleteBooking(BookingId1);
	self.deleteBooking(BookingId2);
	self.deleteBooking(BookingId3);
