    <JadeMethod name="addBookingSlotToTable" id="f878a43a-9275-4c9b-b95a-77eb9376d0bb">
        <source>addBookingSlotToTable( _vvsBooking : CM_VehicleBookingTimeSlot; _insert : Boolean; _indexLine : Integer output ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	dataLine : String;
	index : Integer;
	rowBooking : CM_VehicleBookingTimeSlot;

begin

	dataLine := _vvsBooking.getAttributeStringForDefArray(self.tblBookings.allTblDataEntRows);
			
	if _insert then
		foreach index in self.tblBookings.fixedRows to self.tblBookings.rows do
			rowBooking := self.tblBookings.accessRow(index).itemObject.CM_VehicleBookingTimeSlot;
			if rowBooking = null then
				continue;
			endif;
			if rowBooking.bookingTSstart &gt; _vvsBooking.bookingTSstart then
				_indexLine := index;
				break;
			elseif rowBooking.bookingTSstart = _vvsBooking.bookingTSstart then
				if rowBooking.bookingTSend &gt; _vvsBooking.bookingTSend then
					_indexLine := index;
					break;
				endif;
			endif;
		endforeach;
		if _indexLine = 0 then
			_indexLine := self.tblBookings.rows + 1;
		endif;
	else
		_indexLine := self.tblBookings.rows + 1;
	endif;
	
	self.tblBookings.addItemAt(dataLine,_indexLine);
	self.tblBookings.accessRow(_indexLine).itemObject := _vvsBooking;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vvsBooking" type="CM_VehicleBookingTimeSlot"/>
        <Parameter name="_insert" type="Boolean"/>
        <Parameter name="_indexLine" type="Integer" usage="output"/>
    </JadeMethod>
