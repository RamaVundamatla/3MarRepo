	self.assertTrueMsg( tiArray.size = 3, "Agent method 'getCargoBasedOnSTW12Rules' should have 3 containers, for Rule 1.");
	
	//Delete all cargo and the release , and add it back fresh but with 2 reserve details
	foreach index in 1 to 9 do
		self.deleteCargo( BaseTiId &amp; index.String,  childCargoType1 );
	endforeach;
	foreach index in 1 to 9 do
		if index &lt; 5 then
			ti := self.addCargoAtLocation(BaseTiId &amp; index.String, childCargoType2, oper, bs.allLocationsControllers.first);
		else
			ti := self.addCargoAtLocation(BaseTiId &amp; index.String, childCargoType1, oper, bs.allLocationsControllers.first);
		endif;
	endforeach;
	cont := self.addContainer( BaseTiId &amp; "A", oper, "2200", "MT", TI_IMEX_STATUS_STORAGE );
	
	self.deleteReleaseRequest(ReleaseCode);

	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("Number", 1.Integer );
	self.opts.addAssoc("Operator", oper );
	br := self.addReleaseByTypeRequestOpts(ReleaseCode, BR_TYPE_PACKING, TI_CargoType_Container);
	self.assertTrueMsg( br &lt;&gt; null and br.status = BR_ACTIVE, "Second bulk release not created, or not active");
	
	self.opts.purge;
	self.opts.addAssoc("Operator", oper);
	self.opts.addAssoc("Number", 3.Integer );
	self.addReserveSelectionOpts( br, CM_ReserveDetail.PackType_Child, childCargoType1.id);
	self.assertTrueMsg( br.allReservePackingChildren.size = 1, ReleaseCode &amp; " Second Bulk Release 1st child reserve details not created - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	reserveDetail1 := br.allReservePackingChildren.first;
	self.assertTrueMsg( reserveDetail1 &lt;&gt; null , " Second Bulk Release, 1st Child Reserve Detail not created");
	
	self.opts.purge;
	self.opts.addAssoc("Operator", oper);
	self.opts.addAssoc("Number", 3.Integer );
	self.addReserveSelectionOpts( br, CM_ReserveDetail.PackType_Child, childCargoType2.id);
	self.assertTrueMsg( br.allReservePackingChildren.size = 2, ReleaseCode &amp; " Second Bulk Release 2nd child reserve details not created - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	reserveDetail1 := br.allReservePackingChildren.last;
	self.assertTrueMsg( reserveDetail1 &lt;&gt; null , " Second Bulk Release, 2nd Child Reserve Detail not created");
	
	self.doStwStageCargo( cont, br.allReserveDetails.first, ic2.allLocationsControllers.first );
	
	//Rule 12  Nothing staged, (Parents don't count) one selected
	selectedResDetail := br.allReservePackingChildren.first;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
