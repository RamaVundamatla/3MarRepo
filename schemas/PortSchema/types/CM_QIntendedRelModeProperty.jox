    <JadeMethod name="translateToSearchValue" id="e491dc6b-188a-4717-a492-b6d11fa7548a">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason

*/

vars
	
begin
	return app.intendedReleaseModeString2Enum(_value.String);	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="e3ec7f29-0e41-4300-9b5c-130b2c7ed5df">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	int : Integer;
	strValue, collStr : String;
	strArray : StringArray;
	intArray : IntegerArray;

begin
	if _value.isKindOf(Integer) then
		return app.intendedReleaseModeEnum2String(_value.Integer);
		
	elseif _value.isKindOf(IntegerArray) then
		foreach int in _value.IntegerArray do
			strValue := strValue &amp; app.intendedReleaseModeEnum2String(int) &amp; CNEC_COMMA &amp; Space;
		endforeach;
		strValue := strValue[1:strValue.length-2];
		return strValue;
		
	elseif _value.isKindOf(String) and _value.String.cnContains("|") then
		collStr := _value.String;
		create strArray transient;
		create intArray transient;
		collStr.getTokensForDelimiter("|", strArray);
		foreach strValue in strArray do
			intArray.add(app.intendedReleaseModeString2Enum(strValue));
		endforeach;
		return intArray;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
