    <JadeMethod name="eprTestXMLHelper" id="b9f359be-d028-4a59-bab6-1cbe396cb2ec">
        <source>eprTestXMLHelper();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2018	jlger1	Initial creation

*/

vars

	xml 			: JadeXMLDocument;
	responseTag,reply : String;
	xmlHelper 		: CM_XmlHelperAgent;
	documentChanged : Boolean;
	elements		: JadeXMLElementArray;
	element			: JadeXMLElement;
	attribute :	JadeXMLAttribute;
begin

		reply:='
	&lt;soap:Envelope xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/"&gt;
   &lt;soap:Body&gt;
      &lt;entryPKKResponse xmlns="urn:JadeWebServices/JMTExternalInterfaceService/"&gt;
         &lt;entryPKKResult xsi:type="WS_EntryPKKResponse"&gt;
            &lt;portCode&gt;NZPOE&lt;/portCode&gt;
            &lt;statusCode&gt;02&lt;/statusCode&gt;
            &lt;statusMessage&gt;Code :90661. Voyage AGAS has incorrect status Voyage Requested INAPORTNET for this action.&lt;/statusMessage&gt;
            &lt;nomorPKK&gt;PKK.PEL1.27082018.TESTPKK&lt;/nomorPKK&gt;
         &lt;/entryPKKResult&gt;
      &lt;/entryPKKResponse&gt;
   &lt;/soap:Body&gt;
&lt;/soap:Envelope&gt;';

create xml transient;
	xml.parseString(reply);
	
	create xmlHelper transient;
	// The child of the main response will be named &lt;methodName&gt;Result
	responseTag := "entryPKKResult";
	
	create elements transient;
	
	xml.findElementsByTagName(responseTag, elements);
		
	foreach element in elements do
		element.tagName :=  "return";
		element.localName :=  "return";
		attribute:=element.getAttributeByName("xsi:type");
		if attribute  &lt;&gt; null then
			delete attribute;
		endif;
		//_documentChanged := true;
	endforeach;
	
	// Firstly convert INAPORTNET names to JMT names
	//xmlHelper.translateElementNames(xml, responseTag,  "return", documentChanged);
	
	delete xml;
	delete xmlHelper;

end;</source>
    </JadeMethod>
    <JadeMethod name="findDates" id="140e7bad-9f65-499f-bfb4-031838814295">
        <source>findDates();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 October 2012	cnwndl1	Initial creation

*/

vars

	schema : Schema;
	class : Class;
	subClass : Class;
	classes : ClassNDict;
	meths : MethodNDict;
	meth : Method;
	source : String;

begin

	schema := currentSchema.getSchema("WebServicesSchema");
//	class := schema.getClass("WS_ProxyObject");
	class := schema.getClass("WS_WebServiceProvider");
	
	create classes transient;
	create meths transient;
	class.getAllSubclassesAnywhere( classes );
	
	foreach subClass in classes do
		meths.clear();
		subClass.getMethods( meths );
		foreach meth in meths do
		/*	if meth.name = "getAlertDetail" then
				continue;
			endif;
			source := meth.getSource;
			if source.pos(".asString",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asString";
			endif;
			if source.pos(".asStringWeightJMT",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asStringWeightJMT";
			endif;
			if source.pos(".asStringJMT",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asStringJMT";
			endif; */
			if meth.name = "getMovements" then
				//write meth.qualifiedName;
				continue;
			endif;
			if meth.name = "getSnapshots" then
				//write meth.qualifiedName;
				continue;
			endif;
			if meth.name = "getVisits" then
				//write meth.qualifiedName;
				continue;
			endif;
			if meth.name = "getTIsForCargoQuickView" then
				continue;
			endif;
			source := meth.getSource;
			if source.pos(".asDateJMT",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asDateJMT";
			endif;
			if source.pos(".asDecimalJMT",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asDecimalJMT";
			endif;
			if source.pos(".asRealJMT",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asRealJMT";
			endif;
			if source.pos(".asTimeStampJMT",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asTimeStampJMT";
			elseif source.pos(".asTimeJMT",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asTimeJMT";
			endif;
			if source.pos(".Date",1) &gt; 0 then
				write meth.qualifiedName &amp; " - .Date";
			endif;
			if source.pos(".Real",1) &gt; 0 then
				write meth.qualifiedName &amp; " - .Real";
			endif;
			if source.pos(".Decimal",1) &gt; 0 then
				write meth.qualifiedName &amp; " - .Decimal";
			endif;
			if source.pos(".Time",1) &gt; 0 then
				write meth.qualifiedName &amp; " - .Time";
			endif;
			if source.pos(".TimeStamp",1) &gt; 0 then
				write meth.qualifiedName &amp; " - .TimeStamp";
			endif;
			if source.pos(".shortCurrentLocaleFormatSecs",1) &gt; 0 then
				write meth.qualifiedName &amp; " - .shortCurrentLocaleFormatSecs";
			endif;
		endforeach;
	endforeach;
	
	classes.clear();
	class := schema.getClass("WS_ProxyObject");
	
	class.getAllSubclassesAnywhere( classes );
	
	foreach subClass in classes do
		meths.clear();
		subClass.getMethods( meths );
		foreach meth in meths do
			if meth.name = "getAlertDetail" then
				continue;
			endif;
			source := meth.getSource;
		/*	if source.pos(".asString",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asString";
			endif;
			if source.pos(".asStringWeightJMT",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asStringWeightJMT";
			endif;
			if source.pos(".asStringJMT",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asStringJMT";
			endif; 
			if source.pos(".String",1) &gt; 0 then
				write meth.qualifiedName &amp; " - .String";
			endif; */
			if source.pos(".shortCurrentLocaleFormatSecs",1) &gt; 0 then
				write meth.qualifiedName &amp; " - .shortCurrentLocaleFormatSecs";
			endif;
		endforeach;
	endforeach;
	
	classes.clear();
	class := schema.getClass("WS_Response");
	
	class.getAllSubclassesAnywhere( classes );
	
	foreach subClass in classes do
		meths.clear();
		subClass.getMethods( meths );
		foreach meth in meths do
		//	if meth.name = "getAlertDetail" then
		//		continue;
		//	endif;
			source := meth.getSource;
			if source.pos(".asString",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asString";
			endif;
			if source.pos(".asStringWeightJMT",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asStringWeightJMT";
			endif;
			if source.pos(".asStringJMT",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asStringJMT";
			endif; 
			if source.pos(".String",1) &gt; 0 then
				write meth.qualifiedName &amp; " - .String";
			endif; 
			if source.pos(".shortCurrentLocaleFormatSecs",1) &gt; 0 then
				write meth.qualifiedName &amp; " - .shortCurrentLocaleFormatSecs";
			endif;
		endforeach;
	endforeach;
	
	classes.clear();
	class := schema.getClass("WS_Request");
	
	class.getAllSubclassesAnywhere( classes );
	
	foreach subClass in classes do
		meths.clear();
		subClass.getMethods( meths );
		foreach meth in meths do
			if meth.name = "setupIterator" then
				continue;
			endif;
			source := meth.getSource;
			if source.pos(".asDateJMT",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asDateJMT";
			endif;
			if source.pos(".asDecimalJMT",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asDecimalJMT";
			endif;
			if source.pos(".asRealJMT",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asRealJMT";
			endif;
			if source.pos(".asTimeStampJMT",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asTimeStampJMT";
			elseif source.pos(".asTimeJMT",1) &gt; 0 then
				write meth.qualifiedName &amp; " - asTimeJMT";
			endif;
			if source.pos(".Date",1) &gt; 0 then
				write meth.qualifiedName &amp; " - .Date";
			endif;
			if source.pos(".Real",1) &gt; 0 then
				write meth.qualifiedName &amp; " - .Real";
			endif;
			if source.pos(".Decimal",1) &gt; 0 then
				write meth.qualifiedName &amp; " - .Decimal";
			endif;
			
			if source.pos(".TimeStamp",1) &gt; 0 then
				write meth.qualifiedName &amp; " - .TimeStamp";
			elseif source.pos(".Time",1) &gt; 0 then
				write meth.qualifiedName &amp; " - .Time";
			endif;
			if source.pos(".shortCurrentLocaleFormatSecs",1) &gt; 0 then
				write meth.qualifiedName &amp; " - .shortCurrentLocaleFormatSecs";
			endif;
			
		endforeach;
	endforeach;


epilog

	delete classes;
	delete meths;

end;</source>
    </JadeMethod>
    <JadeMethod name="getClassDocumentationStatus" id="f7e4f607-896f-46fb-a928-3d5fb20ab596">
        <source>getClassDocumentationStatus();
/*

Purpose:		

Identify which subclasses of WS_ProxyObject has text for all its attributes	

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2014	cnwjr2	Initial creation

*/
vars

	cls 			: Class;
	subs			: ClassColl;
	props			: PropertyNDict;
	prop			: Property;
	count			: Integer;	
	file			: File;
	status			: String;

begin

	create subs transient;
	create props transient;
	create file;
	file.mode 			:= File.Mode_Output; // 1/3/16  cnwns1 PAR 36286 unicode version
	file.fileName 		:= "C:\temp\ClassDocumentationStatus.csv";
	file.open;
	file.writeLine("Class Name" &amp; "," &amp; "Number of Properties" &amp; "," &amp; "Number of Properties Documented" &amp; "," &amp; "Status" &amp; "," &amp; "Assigned To");
	WS_ProxyObject.getSubclasses(subs);
	foreach cls in subs do
		write cls.name &amp; "  " &amp; cls.text;
		props		:= cls.getProperties;
		status		:= "Not Completed";
		count 		:= 0;
		foreach prop in props do
			if prop.text.length &gt; 0 then
				count	:= count + 1;
			endif;
		endforeach;
		if count = props.size then
			status		:= "Completed";
		endif;
		file.writeLine(cls.name &amp; "," &amp; props.size.String &amp; "," &amp; count.String &amp; "," &amp; status);
	endforeach;
	file.close;

epilog

	delete subs;
	delete file;


end;
</source>
    </JadeMethod>
    <JadeMethod name="getPurposeForText" id="71c4d004-522b-4f18-9122-fb7d811db29f">
        <source>getPurposeForText();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2014	cnwmc5	Initial creation

*/

vars
	mthDict			: MethodNDict;
	allLines		: HugeStringArray;
	
	cls 			: Class;
	mth				: Method;
	
	source			: String;
	line			: String;
	lineToWrite		: String;
	foundPurpose	: Boolean;
begin
	cls := currentSchema.getClass("JMTUserInterfaceService");
	
	//Setup
	create mthDict transient;
	create allLines transient;
	cls.getMethods(mthDict);
	
	foreach mth in mthDict do
		//Reset stuff for new Method
		allLines.clear();
		foundPurpose := false;
		lineToWrite := '';
		
		//Scan each method line by line to pull out its purpose
		source := mth.getSource();
		source.getTokensForDelimiterHuge(Cr, allLines);
		foreach line in allLines do
			if line.cnContains("Purpose:") then
				foundPurpose := true;
			endif;
			if foundPurpose then
				if line &lt;&gt; Lf and line &lt;&gt; Cr and line &lt;&gt; CrLf and line &lt;&gt; '//' &amp; Lf then
					lineToWrite := lineToWrite &amp; line;
				else
					break;
				endif;
			endif;
		endforeach;
		
		//Strip out all the unwanted stuff..
		lineToWrite := lineToWrite.replaceString("Purpose:", "");
		lineToWrite := lineToWrite.replaceString(Cr, '');
		lineToWrite := lineToWrite.replaceString(Lf, '');
		lineToWrite := lineToWrite.replaceString(Tab, '');
		while lineToWrite.cnContains('  ') do
			lineToWrite := lineToWrite.replaceString('  ', ' ');
		endwhile;
		
		//if lineToWrite.cnContains('RIA') then
		//	write mth.name &amp; ':' &amp; Tab &amp; lineToWrite;
		//endif;
		//continue;
		
		//Check to make sure its not null
		if lineToWrite &lt;&gt; null then
			beginTransaction;
			mth.cnEcSetText(lineToWrite);
			commitTransaction;
			write mth.name &amp; ':' &amp; Tab &amp; lineToWrite;
		endif;
	endforeach;
epilog
	//Clean up
	delete mthDict;
	delete allLines;
end;</source>
    </JadeMethod>
