    <JadeMethod name="createCMIFCargoLabels" id="29fe61da-2534-4336-aace-58580d0e9c01">
        <updating/>
        <source>createCMIFCargoLabels( _msg : String output) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004
01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
*/

vars

	obj : CM_Object;
	
	copies : Integer;
	idsPerObject : Integer;
	genIds : Boolean;
	isTrackedItem : Boolean;
	isGTEReceival : Boolean;
	isGTEReceivalByType : Boolean;
	index : Integer;
	pos : Integer;
	cargoId : String;
	
	cargoLabelRequest : CMIF_CargoLabel;
	user : CM_User;
	
	noIdLabelCount : Integer;
	noIdIndex : Integer;
	
	recInfo : CM_GTEReceivalInfo;
	recReqInfo : CM_ReceivalRequestInfo;
	quantity : Integer;
	
	bbkSuffix : Boolean;
	
begin

	copies := self.txtNumCopys.text.Integer;
	if copies &lt; 1 then
		self.txtNumCopys.setFocus();
		return;
	endif;
	genIds := self.chkAuto.value;
	user := app.getMyUser;
	bbkSuffix := self.chkAddSuffix.visible and self.chkAddSuffix.value; 
	
	if bbkSuffix then
			self.createCMIFCargoLabelsBBK( _msg );
			if _msg.trimBlanks &lt;&gt; null then
				 app.msgBox(_msg, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
				 _msg := null;
				 return;
			endif;
		
	elseif not self.allSelectedObjects.isEmpty then
		// printing based on selected object(s).
	
		isTrackedItem := self.allSelectedObjects.first.isKindOf(CM_TrackedItem);
		isGTEReceival := self.allSelectedObjects.first.isKindOf(CMGTE_Receival);
		isGTEReceivalByType := self.allSelectedObjects.first.isKindOf(CMGTE_ReceivalByType);	//06 Aug 2010	NDL	Par 25335
		
		if isTrackedItem or isGTEReceival then
			foreach obj in self.allSelectedObjects do
				foreach index in 1 to copies do
					if index = 1 then
						if isTrackedItem then
							cargoId := obj.CM_TrackedItem.id;
						elseif isGTEReceival and not genIds then	
							cargoId := obj.CMGTE_Receival.getID;
						endif;
					endif;
					create cargoLabelRequest transient;
					self.allCargoLabelsRequested.add(cargoLabelRequest);
					cargoLabelRequest.setDetails( 	obj,	//_cargoObject : CM_Object;
													cargoId,	//_cargoId : String;
													self.myTerminal,	//_myTerminal : CM_Terminal;
													null,	//_myQryReport : CM_QryReport;
													user	//_myUser : CM_User
													);
					
				endforeach;
			endforeach;
			
		elseif isGTEReceivalByType then	//06 Aug 2010	NDL	Par 25335
			foreach obj in self.allSelectedObjects do
				idsPerObject := 1;
				//-cnwml2 PAR25613  don't need to calculate it just get it from the form
				quantity := self.txtNumIds.text.Integer;
				/*recInfo := obj.CMGTE_ReceivalByType.myReceivalInfo;
				if recInfo &lt;&gt; null then
					recReqInfo := recInfo.myReceivalRequestInfo;
					quantity := recInfo.getQuantity;
				endif;
				if quantity = 0 and recReqInfo &lt;&gt; null then
					quantity := recReqInfo.getQuantity;
				endif;*/
				if quantity &gt; 1 then
					idsPerObject := quantity;
				endif;
				
				foreach pos in 1 to idsPerObject do	// i.e. 10 unique numbered items for this Receival by type.
					foreach index in 1 to copies do	// with 2 labels per item
						if index = 1 then
							//cargoId := self.myTerminal.generateNextCargoId(false,false); // 1 Sept 2022 navmv20 TFS 54610
							cargoId := self.myTerminal.generateNextCargoId(false,false,null); //1 Sept 2022 navmv20 TFS 54610
							if cargoId = null then
								_msg := app.getErrorString(Failed_CargoId_Create);
								return;
							endif;
						endif;
						create cargoLabelRequest transient;
						self.allCargoLabelsRequested.add(cargoLabelRequest);
						cargoLabelRequest.setDetails( 	obj,	//_cargoObject : CM_Object;
														cargoId,	//_cargoId : String;
														self.myTerminal,	//_myTerminal : CM_Terminal;
														null,	//_myQryReport : CM_QryReport;
														user	//_myUser : CM_User
														);
						
					endforeach;
				endforeach;
			endforeach;
			
		elseif genIds then
			idsPerObject := self.txtNumIds.text.Integer;
			if idsPerObject &lt; 1 then
				idsPerObject := 1;
			endif;
			
			foreach obj in self.allSelectedObjects do
				foreach pos in 1 to idsPerObject do	// i.e. 10 unique numbered labels for a single Booking.
					foreach index in 1 to copies do	// with 2 labels per item
						if index = 1 then
							//cargoId := self.myTerminal.generateNextCargoId(false,false);      // 1 Sept 2022 navmv20 TFS 54610
							cargoId := self.myTerminal.generateNextCargoId(false,false,null);  //1 Sept 2022 navmv20 TFS 54610
							if cargoId = null then
								_msg := app.getErrorString(Failed_CargoId_Create);
								return;
							endif;
						endif;
						create cargoLabelRequest transient;
						self.allCargoLabelsRequested.add(cargoLabelRequest);
						cargoLabelRequest.setDetails( 	obj,	//_cargoObject : CM_Object;
														cargoId,	//_cargoId : String;
														self.myTerminal,	//_myTerminal : CM_Terminal;
														null,	//_myQryReport : CM_QryReport;
														user	//_myUser : CM_User
														);
						
					endforeach;
				endforeach;
			endforeach;
			
		else
			_msg := "Option not coded for!!";
			return;
		
		endif;
	
	else
		// printing based on a user request only (no associated objects).
		noIdLabelCount := self.txtNumIds.text.Integer;
		if noIdLabelCount &lt; 1 then
			self.txtNumIds.setFocus();
			return;
		endif;
	
		foreach noIdIndex in 1 to noIdLabelCount do
			foreach index in 1 to copies do
				if index = 1 then
					if genIds then 
						//cargoId := self.myTerminal.generateNextCargoId(false,false); // 1 Sept 2022 navmv20 TFS 54610
						cargoId := self.myTerminal.generateNextCargoId(false,false,null);  //1 Sept 2022 navmv20 TFS 54610
						if cargoId = null then
							_msg := app.getErrorString(Failed_CargoId_Create);
							return;
						endif;
					endif;
				endif;
				create cargoLabelRequest transient;
				self.allCargoLabelsRequested.add(cargoLabelRequest);
				cargoLabelRequest.setDetails( 	null,	//_cargoObject : CM_Object;
												cargoId,	//_cargoId : String;
												self.myTerminal,	//_myTerminal : CM_Terminal;
												null,	//_myQryReport : CM_QryReport;
												user	//_myUser : CM_User
												);
				
			endforeach;
		endforeach;
		
	endif;
	
epilog

end;</source>
        <Parameter name="_msg" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="createCMIFCargoLabelsBBK" id="1d9af5d3-0586-431a-aa05-fbbabbc4d53c">
        <updating/>
        <source>createCMIFCargoLabelsBBK( _msg : String output) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2013	cnwndl1	Initial creation

*/

vars

	baseCargoIdValue : String;
	separator : String;
	suffix : Integer;
	suffixLength : Integer;
	endSuffix : Integer;
	labelsPerObject : Integer;
	totNumLabels : Integer;
	msg : String;
	index : Integer;
	labelCount : Integer;
	cargoLabelRequest : CMIF_CargoLabel;
	cargoId : String;
	user : CM_User;

begin

	user := app.getMyUser;

	baseCargoIdValue := txtMainIdValue.text.trimBlanks.toUpper;
	if baseCargoIdValue = null then
		_msg := app.getErrorString(Main_cargo_value_must_entere);
		return;
	endif;
	separator := txtSeparator.text.trimBlanks.toUpper;
	if separator = null then
		_msg := app.getErrorString(Must_enter_separat_charact);
		return;
	endif;
	suffix := txtFirstSuffix.text.Integer;
	suffixLength := txtFirstSuffix.text.trimBlanks.length;
	if suffixLength = 0 then
		_msg := app.getErrorString(First_suffix_must_entered);
		return;
	elseif suffixLength &lt;&gt; txtLastSuffix.text.trimBlanks.length then
		_msg := app.getErrorString(Both_suffi_value_must_same_num);
		return;
	endif;
	endSuffix := txtLastSuffix.text.Integer;
	if endSuffix &lt; suffix then
		_msg := app.getErrorString(Last_suffi_not_less_than_first);
		return;
	endif;
	labelsPerObject := self.txtNumCopys.text.Integer;
	if labelsPerObject &lt; 1 then
		labelsPerObject := 1;
	endif;
	
	totNumLabels := labelsPerObject * ((endSuffix - suffix) + 1);
	
	if totNumLabels &gt; 50 then
		msg := app.getErrorString1(This_will_creat_label_want_con, totNumLabels.String);
		if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No ) &lt;&gt; MsgBox_Return_Yes then
			_msg := app.getErrorString(VB_USER_CANCELED_TRANS);
			return;
		endif;
	endif;
	
	if baseCargoIdValue.length + separator.length + suffixLength &gt; 30 then
		_msg := app.getErrorString(Combi_value_creat_that_long_le);
		return;
	endif;
	
	//Validation done, should be all go.
	
	foreach index in suffix to endSuffix do
		labelCount := 0;
		cargoId := baseCargoIdValue &amp; separator &amp; index.padLeadingWith("0",suffixLength);  
		while labelCount &lt; labelsPerObject do
			labelCount := labelCount + 1;
			create cargoLabelRequest transient;
			self.allCargoLabelsRequested.add(cargoLabelRequest);
			cargoLabelRequest.setDetails( 	null,	//_cargoObject : CM_Object;
											cargoId,	//_cargoId : String;
											self.myTerminal,	//_myTerminal : CM_Terminal;
											null,	//_myQryReport : CM_QryReport;
											user	//_myUser : CM_User
											);
		endwhile;
	endforeach;

epilog

end;</source>
        <Parameter name="_msg" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doBtnConfig" id="abbe4ffe-68f8-4084-ba37-a4c148f45f4c">
        <updating/>
        <source>doBtnConfig() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004
04/01/2023		navkc1	TFS CR 55300 TASK 55525 UI - Business Unit Maint changes  for auto id
*/

vars

	form : CMUI_AutoIdConfiguration;
	
begin

	//create form; // 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	form := app.loadForm(CMUI_AutoIdConfiguration, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_AutoIdConfiguration;
	
	if form = null then
		return;
	endif;
	
	app.mousePointer := MousePointer_Default;
	form.setForIdType( CM_AutoIdGenerator.CargoIdType, self.myTerminal );
	//form.showModal();
	form.myParentForm := self;
	form.show(); // 04/01/2023	navkc1	TFS CR 55300 TASK 55525

	self.checkAutoCargoIdConfigure();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="545274e5-311d-4d85-8cab-8b1b727cbb85">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

	obj : CM_Object;
	
	copies : Integer;
	genIds : Boolean;
	isTrackedItem : Boolean;
	index : Integer;
	cargoId : String;
	
	cargoLabelRequest : CMIF_CargoLabel;
	user : CM_User;
	
	noIdLabelCount : Integer;
	noIdIndex : Integer;
	
	msg : String;
	
begin

	if not self.checkAutoCargoIdConfigure() then
		return;
	endif;

	// create the label requests based on the user enterd details.
	self.createCMIFCargoLabels(msg);
	
	if msg.trimBlanks &lt;&gt; null then
		 msg := msg &amp; CrLf &amp; app.getErrorString1(Please_check, self.btnConfig.caption);
		 app.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
	endif;
	
	// None requested...
	if self.allCargoLabelsRequested.isEmpty then
		return;
	endif;
	
	// Send the requests to the report writer.
	self.doPrintReportRequests();
	

	//now close the form.
	inheritMethod();

epilog

	if not self.allCargoLabelsRequested.isEmpty then
		self.allCargoLabelsRequested.purge;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintReportRequests" id="84a99072-e3d0-43f3-b97b-6043226d2b21">
        <source>doPrintReportRequests() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 Jan 2010	cnwndl1	Initial creation	CCMS MES 1004
17 Mar 2010	consw1	PAR #22886 - Leaking report transients
*/

vars

	termDict 	: CM_TerminalByCodeDict;
	jrwManager : JadeReportWriterManager;
	jrwReport : JadeReportWriterReport;
	reportString : String;
	jrwTransient : CM_JRWCargoLabelRequests;
	jadeReport : JadeReport;
	physicalPrinterName : String;
	resetPrinterTo : String;
	autoIdGen : CM_AutoCargoIdGen;
	
begin

	resetPrinterTo := app.printer.getPrinterName;	//31 July 2013	NDL	Par 31821
	
	physicalPrinterName := self.cmbPrinter.text;
	if physicalPrinterName = app.getErrorString(Default_printer) then
		physicalPrinterName := null;
	endif;
	app.printer.setPrinter(physicalPrinterName);

	// create the report writer manager.
	jrwManager := app.createReportWriterManager();
	
	// find the report write report we want to use
	autoIdGen := self.myTerminal.getMyAutoIdGenerator( CM_AutoCargoIdGen ).CM_AutoCargoIdGen;
	if autoIdGen &lt;&gt; null then
		reportString := autoIdGen.getCargoLabelFormat;
	else
		reportString := CM_AutoCargoIdGen.DefaultFormat;
	endif;
	
	jrwReport := jrwManager.getReport(reportString);
	if jrwReport = null then
		app.msgBox(app.getErrorString1(Report_Not_Found, reportString), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );	// 29/08/2014 cnwar2 #34840
		return;
	endif;
	
	//create and populate the transients used in the report
	jrwTransient := app.myQAFilter.createJRWTransient(CM_JRWCargoLabelRequests).CM_JRWCargoLabelRequests;
	self.allCargoLabelsRequested.copy(jrwTransient.allCargoLabelRequests);
	if jrwTransient = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(JRW_Transient_Failed));
		return;
	endif;
	// added for TFS 978 to get the port logo
	create termDict transient;
	termDict.add(self.myTerminal);
	jrwTransient.setAllTerminals(termDict);
	
	//do the actual printing via the reportwriter.
	create jadeReport transient;
	
	app.printer.printPreview := chkPrintPreview.value;

	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	jadeReport.description := jrwReport.name;
	
	jrwReport.run();
	
epilog
	delete jrwManager;
	delete jrwReport;
	delete jadeReport;
	delete termDict;
	app.printer.setPrinter(resetPrinterTo);	//31 July 2013	NDL	Par 31821
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="ab7934b2-cc62-4a1d-a988-288c1faf1bf7">
