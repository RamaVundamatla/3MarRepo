    <JadeMethod name="onRectPaint" id="d3bfac96-7778-4225-9876-e82c977ed72b">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_RectangleHandler::onRectPaint"/>
        </interfaceImplements>
        <source>onRectPaint(_rect: CMUI_ResizableRectFrame input);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwer1	Initial creation

*/

vars
	x1, y1, x2, y2 : Real;
	cmifMachineWorkzone,
	currentMachineWorkzone: CMIF_MachineWorkzone;
	workzoneFrame : Frame;
	theColour : Integer;
	invalidCMIFMachWZ : Boolean;
begin

	if _rect.name = self.frmResizableRect.name then
		_rect.drawWidth := _rect.thickness;
		if _rect.isSelected then
			_rect.drawStyle := Window.DrawStyle_Dash;
		else
			_rect.drawStyle := Window.DrawStyle_Solid;	
		endif;
		
		x1 := 0;
		x2 := _rect.width;
		y1 := 0;
		y2 := _rect.height;
			
		_rect.drawRectangle(x1, y1, x2, y2, _rect.colour);
		
		if not _rect.isSelected then //cnwrd1 par 28447 20.10.2011
			_rect.drawFilledRectangle(x1,y1,x2,y2,_rect.colour);
		endif;
	
		// cnwjk3
		// TODO - need to make this more generic if we want to allow re-use of this class.  Probably want to make myObject a
		// reference to a class that implements and interface.  For example the interface could declare a method called 
		// getRectDisplayText().  We can then call getRectDisplayText() on the reference to get whatever text we want displaying
		// in the rectangle.  i.e. CMIF_YABlock::getRectDisplayText() would return numSlots.String
		if not _rect.isInPainter() then
			if _rect.myObject &lt;&gt; null and _rect.myObject.isKindOf(CMIF_YABlock) and not _rect.isLocked() then  // CCMS CPL 2052
				_rect.drawTextAt(_rect.myObject.CMIF_YABlock.numSlots.String,2,2, _rect.colour);
			endif;
		endif;
	elseif _rect.name = self.frmWorkZone.name then
		//epr par 21674 24/11/09
		on Exception do app.handleDeletedObject(exception, currentMachineWorkzone,invalidCMIFMachWZ);
		cmifMachineWorkzone:=_rect.userObject.CMIF_MachineWorkzone;
		currentMachineWorkzone:=cmifMachineWorkzone;
		if currentMachineWorkzone = null then
			return;
		endif;
		workzoneFrame:=currentMachineWorkzone.myWorkzoneFrame;
		if invalidCMIFMachWZ then
			return;
		endif;
		//cmifMachineWorkzone.
		self.doMachWorkzonePaint(currentMachineWorkzone);
		
		currentMachineWorkzone:=currentMachineWorkzone.myLinkedMachineWorkzone;
		if currentMachineWorkzone &lt;&gt; null then
			workzoneFrame:=currentMachineWorkzone.myWorkzoneFrame;
			if invalidCMIFMachWZ then
				cmifMachineWorkzone.myLinkedMachineWorkzone:=null;
				return;
			endif;
			self.doMachWorkzonePaint(currentMachineWorkzone);
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_rect" type="CMUI_ResizableRectFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="onRectResizing" id="1ace6f20-e3ed-446d-a150-1453d07f4b9e">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_RectangleHandler::onRectResizing"/>
        </interfaceImplements>
        <updating/>
        <source>onRectResizing(_rect: CMUI_ResizableRectFrame input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2009	cnwjk3	SFW1030

*/

vars

begin
	if _rect.name = self.frmResizableRect.name then
		self.myCurrentDrawingController.getOverlayEditFrame().onRectResizing(_rect);
	elseif _rect.name = self.frmWorkZone.name then
