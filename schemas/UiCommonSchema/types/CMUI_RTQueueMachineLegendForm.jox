    <JadeMethod name="addToolbarControls" id="7c6f6139-2f3f-472a-b021-087e79716960">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2011	#cnwdz2	 

*/

vars
	toolbar	: CMUI_Toolbar;

begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnFind, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExtract, CMUI_Toolbar.Control_Alignment_Left);
end;</source>
