    <JadeMethod name="comboSQLVersionBuild" id="b9da88c3-f548-45c6-b1bc-e1329fd5d050">
        <source>comboSQLVersionBuild() protected;
// ---------------------------------------------------------------------------
// Created:		27/04/2010 cnwdz2 24641
// ---------------------------------------------------------------------------
vars
	iter : Iterator;
	str : String;
	row : Integer;
begin
	self.cmbSQLVersion.clear;
	self.cmbSQLVersion.sorted := false;
	
	//self.cmbSQLVersion.addItem(CM_DataDumpExtractDef.SQLVersion2000);		
	self.cmbSQLVersion.addItem(CM_DataDumpExtractDef.SQLVersion2005);
	self.cmbSQLVersion.addItem(CM_DataDumpExtractDef.SQLVersion2008);
	
	self.cmbSQLVersion.listIndex := self.cmbSQLVersion.findString(1,CM_DataDumpExtractDef.SQLVersion2008);
	
	self.comboSQLVersionSelect();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="comboSQLVersionSelect" id="34244df7-0141-4ac0-a9fb-ea8a2e1d267b">
