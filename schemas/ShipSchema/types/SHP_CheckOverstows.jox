    <JadeMethod name="addToolbarControls" id="537074fe-6361-4841-9265-ade6de541b20">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="create" id="1d4c0ad1-2a60-4866-bddc-21a5c12d081e">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
//--------------------------------------------------
// Created:	15 July 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.permissionView  := PmShipVoyageEnquiryView;
	self.permissionMaint := PmShipVoyageEnquiryMain;
	self.helpFileName := HelpFile_Voyage;

end;</source>
    </JadeMethod>
    <JadeMethod name="displayAllJobs" id="79f137f2-c39e-47cd-b1ce-f9332b426c75">
        <source>displayAllJobs();

vars
	vJob : CM_VoyageJob;
	aJob : CM_Job;
	aJS : CM_JobSheet;
	idx : Integer;
begin
	self.tblJobs.rows := self.tblJobs.fixedRows;
	
	foreach aJS in self.myCurrentVoyage.allJobSheets do
		foreach aJob in aJS.allJobsByOrder discreteLock do
			vJob := aJob.CM_VoyageJob;
			idx := self.tblJobs.addItem(vJob.id &amp; " " &amp; vJob.getDescription());
			
			self.tblJobs.accessRow(idx).itemObject := vJob;
		endforeach;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="displayJobSheets" id="83e55bc3-fc23-43fb-aaf5-e674897c00c6">
        <source>displayJobSheets();

vars
	idx : Integer;
	aJS : CM_JobSheet;
begin
	self.tblJobsJS1.rows := self.tblJobsJS1.fixedRows;
	self.tblJobsJS2.rows := self.tblJobsJS2.fixedRows;
	self.tblJobsJS3.rows := self.tblJobsJS3.fixedRows;
	
	foreach aJS in self.myCurrentVoyage.allJobSheets do
		idx := idx + 1;
		if idx = 1 then
			self.grpJS1.caption := "Crane " &amp; aJS.CM_VoyageJobSheet.crane;
		elseif idx = 2 then
			self.grpJS2.caption := "Crane " &amp; aJS.CM_VoyageJobSheet.crane;
		elseif idx = 3 then
			self.grpJS3.caption := "Crane " &amp; aJS.CM_VoyageJobSheet.crane;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="displayResults" id="8da3ccb4-a447-49cb-aa9d-6606448062e1">
        <source>displayResults(_controller : CMIF_ShipOverstowController);

vars
	cranesSTR : String;
begin
	self.tblResults.rows := self.tblResults.fixedRows;
	
	cranesSTR := _controller.getCraneString();
	
	self.tblResults.addItem("This spread of jobs across cranes " &amp; cranesSTR &amp; " results in .");
	self.tblResults.addItem("Absolute Overstowed : " &amp; _controller.osMoveTotals[CMIF_ShipOverstowController.Mode_Absolute].String);
	self.tblResults.addItem("As Worked Overstowed : " &amp; _controller.osMoveTotals[CMIF_ShipOverstowController.Mode_AsWorked].String);
	self.tblResults.addItem("Real Time Estimated Overstowed : " &amp; _controller.osMoveTotals[CMIF_ShipOverstowController.Mode_RealTimeEstimated].String);
	self.tblResults.addItem("Real Time Actual Overstowed : " &amp; _controller.osMoveTotals[CMIF_ShipOverstowController.Mode_RealTimeActual].String);
	self.tblResults.addItem("");
	self.tblResults.addItem("Absolute Overstowed - Are overstowed by different jobsheet." );
	self.tblResults.addItem("As Worked Overstowed - Are overstowed by different jobsheet and ." );
	self.tblResults.addItem("Real Time Estimated Overstowed - Compare overstow with order in crane's jobsheet using cranes estimate rate per hour." );
	self.tblResults.addItem("Real Time Actual Overstowed - Compare overstow with order in crane's jobsheet using cranes actual rate per hour, if available for this voyage, else will use estimated." );
end;
</source>
        <Parameter name="_controller" type="CMIF_ShipOverstowController"/>
    </JadeMethod>
