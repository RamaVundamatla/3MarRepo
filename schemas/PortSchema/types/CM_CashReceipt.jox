    <JadeMethod name="validateMe" id="d993c856-f6d5-4368-8fee-d32eeca2e309">
        <source>validateMe();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	// 33520 don't do the inheritMethod test - just check the date as a zero payment is valid where it is using a pre-payment
	//inheritMethod();
	if not self.dateTime.Date.isValid then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Transaction_date), null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.myDebtorTerminal = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Debtor_GC), null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.myPaymentMethod = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Payment_method), null, null); // cnwdb2	PAR 35364
	endif;

	if self.myUser = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(User), null, null); // cnwdb2	PAR 35364
	endif;

epilog

end;</source>
    </JadeMethod>
