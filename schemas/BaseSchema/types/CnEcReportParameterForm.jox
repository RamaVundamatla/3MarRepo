    <JadeMethod name="cmbType_displayEntry" id="3d8c169e-f791-460d-9814-1b3452d5175b">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbType_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;

