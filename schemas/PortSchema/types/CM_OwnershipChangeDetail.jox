    <JadeMethod name="pxyCreateUpdateProxy" id="883db2c2-59e3-4bbb-ac65-5fb1f6d54a29">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 June 2023 navtnr20	TFS CR 58507	Task 58210: Jade - TRX CM_OwnershipChangeDetail

*/

vars
	_proxy : SelfType;
begin
	_proxy := inheritMethod();

	_proxy.myOwnershipChange	:= self.myOwnershipChange;
	_proxy.myParentOwnershipChangeDetail	:= self.myParentOwnershipChangeDetail;
	_proxy.myTrackedItem		:= self.myTrackedItem;
	return _proxy;
epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="raiseExceptionForReserved" id="4117d73d-812a-403e-8e40-dd77f2a24e47">
        <source>raiseExceptionForReserved(_tiId,_reserved,_otherOwnesrhip,_transferred:String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2023	navmv20	CR 59440 Task 59441: Jade - Ownership Change Release Request Validation

*/

vars
	errorMsg : Integer;
begin
	
	if self.pxyIsProxy() 
	or self.myParentOwnershipChangeDetail &lt;&gt; null
	or self.myOwnershipChange.pxyIsProxy() then
		if _reserved &lt;&gt; null and _otherOwnesrhip &lt;&gt; null then
			app.raiseCMException4(Item_reser_plus_curr_ow_tran,_tiId,_reserved, _otherOwnesrhip,_transferred,null,null);
		elseif _reserved &lt;&gt; null then
			app.raiseCMException3(Item_curre_relea_reque_canno_t,_tiId,_reserved,_transferred,null,null);
		elseif _otherOwnesrhip &lt;&gt; null then
			app.raiseCMException3(Item_alrea_owner_chang_canno_t,_tiId,_otherOwnesrhip,_transferred,null,null);
		endif;
	else
		if _reserved &lt;&gt; null and _otherOwnesrhip &lt;&gt; null then
			//app.raiseCMWarning4(Item_reser_plus_curr_ow_tran,_tiId,_reserved, _otherOwnesrhip,_transferred,null,null,null);
			app.raiseCMException4(Item_reser_plus_curr_ow_tran,_tiId,_reserved, _otherOwnesrhip,_transferred,null,null); //21/05/2024	navkc1 Bug 64182
		elseif _reserved &lt;&gt; null then
			//app.raiseCMWarning3(Item_curre_relea_reque_canno_t,_tiId,_reserved,_transferred,null,null,null);
			app.raiseCMException3(Item_curre_relea_reque_canno_t,_tiId,_reserved,_transferred,null,null); //21/05/2024	navkc1 Bug 64182
		elseif _otherOwnesrhip &lt;&gt; null then
			//app.raiseCMWarning3(Item_alrea_owner_chang_canno_t,_tiId,_otherOwnesrhip,_transferred,null,null,null);
			app.raiseCMException3(Item_alrea_owner_chang_canno_t,_tiId,_otherOwnesrhip,_transferred,null,null); //21/05/2024	navkc1 Bug 64182
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_reserved" type="String"/>
        <Parameter name="_otherOwnesrhip" type="String"/>
        <Parameter name="_transferred" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="03c441a9-8d5a-405a-a768-76bd2ed7928c">
