begin
	inheritMethod(_proxyObj);
	
	// Set any non-key properties, and non-inverse references.
	
	// Set any key property values.
	
	// Set any inverse references.
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2500e0e2-e045-4d01-a3ac-6d273d0ff9fd">
        <updating/>
        <source>setForUpdate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Standard method that is invoked from a transaction when the receiver
//				is created.
//
// Parameters:	_proxyObj - A reference to a proxy of the receiver.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyLinkObj	: CM_HookLink;
	
begin
	inheritMethod(_proxyObj);
	
	// Set any non-key properties, and non-inverse references.
	
	self.applicationCopies	:=	_proxyObj.applicationCopies;
	self.localAddress		:=	_proxyObj.localAddress;
	self.localPortNumber	:=	_proxyObj.localPortNumber;
	self.sessionTimeout		:=	_proxyObj.sessionTimeout;
	self.tcpTimeout			:=	_proxyObj.tcpTimeout;
	
	// Set any key property values.
	
	// Set any inverse references.
	
	if _proxyObj.myContainerXlateHookCode = null then
		delete self.myContainerXlateHookCode;
	else
		proxyLinkObj	:=	_proxyObj.getUserHookLink(HookType_ContainerAttributes);
		
		if proxyLinkObj &lt;&gt; null then
			// need to set to the new persistent object
			proxyLinkObj.setLinkObject(self);
		endif;
		
		if self.myContainerXlateHookCode = null then
			create self.myContainerXlateHookCode persistent;
			self.myContainerXlateHookCode.setForCreate(_proxyObj.myContainerXlateHookCode);
		else
			self.myContainerXlateHookCode.setForUpdate(_proxyObj.myContainerXlateHookCode);
		endif;
	endif;
	
	//29 Mar 2011	NDL	Par 27290
	if _proxyObj.myUniqueContainerHookCode = null then
		delete self.myUniqueContainerHookCode;
	else
		proxyLinkObj	:=	_proxyObj.getUserHookLink(HookType_ContainerUnique);
		
		if proxyLinkObj &lt;&gt; null then
			// need to set to the new persistent object
			proxyLinkObj.setLinkObject(self);
		endif;
		
		if self.myUniqueContainerHookCode = null then
			create self.myUniqueContainerHookCode persistent;
			self.myUniqueContainerHookCode.setForCreate(_proxyObj.myUniqueContainerHookCode);
		else
			self.myUniqueContainerHookCode.setForUpdate(_proxyObj.myUniqueContainerHookCode);
		endif;
	endif;
	
	
	if _proxyObj.myLocationXlateHookCode = null then
		delete self.myLocationXlateHookCode;
	else
		proxyLinkObj	:=	_proxyObj.getUserHookLink(HookType_LocationTranslation);
		
		if proxyLinkObj &lt;&gt; null then
			// need to set to the new persistent object
			proxyLinkObj.setLinkObject(self);
		endif;
		
		if self.myLocationXlateHookCode = null then
			create self.myLocationXlateHookCode persistent;
			self.myLocationXlateHookCode.setForCreate(_proxyObj.myLocationXlateHookCode);
		else
			self.myLocationXlateHookCode.setForUpdate(_proxyObj.myLocationXlateHookCode);
		endif;
	endif;
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="66440359-186d-441d-9b14-84291a066ff8">
        <updating/>
        <source>setProxy(	_name:String;
			_applicationCopies:Integer;
			_localAddress:String;
			_localPortNumber:Integer;
			_sessionTimeout:Integer;
			_tcpTimeout:Integer;
			_localeObj:CM_Locale;
			_terminalObj:CM_Terminal;
			_containerXlateCode:String;
			_locationXlateCode:String;
			_containerUnique:String	//29 Mar 2011	NDL	Par 27290
			) updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Purpose:		Standard method for setting a proxy object's properties.
//
// Parameters:	A list of the proxy's property values.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	userName	: String;
	
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.name						:=	_name;
	self.applicationCopies			:=	_applicationCopies;
	self.localAddress				:=	_localAddress;
	self.localPortNumber			:=	_localPortNumber;
	self.sessionTimeout				:=	_sessionTimeout;
	self.tcpTimeout					:=	_tcpTimeout;
	self.myLocale					:=	_localeObj;
	self.myTerminal					:=	_terminalObj;
	
	userName	:=	app.getMyUser().userName.cnEcUpto(10);
	
	if self.myContainerXlateHookCode = null then
		create self.myContainerXlateHookCode transient;
		self.myContainerXlateHookCode.setForProxy(self.name, app.myRoot.allHookTypes[HookType_ContainerAttributes]);
		self.myContainerXlateHookCode.createProxyHookLinkForParent(HookType_ContainerAttributes, self);
		self.myContainerXlateHookCode.setJadeCodeForProxy(_containerXlateCode, userName);
	else
		self.myContainerXlateHookCode.setForProxy(self.name, app.myRoot.allHookTypes[HookType_ContainerAttributes]);
		self.myContainerXlateHookCode.setJadeCodeForProxy(_containerXlateCode, userName);
	endif;
	
	
	//29 Mar 2011	NDL	Par 27290
	if self.myUniqueContainerHookCode = null then
		create self.myUniqueContainerHookCode transient;
		self.myUniqueContainerHookCode.setForProxy(self.name, app.myRoot.allHookTypes[HookType_ContainerUnique]);
		self.myUniqueContainerHookCode.createProxyHookLinkForParent(HookType_ContainerUnique, self);
		self.myUniqueContainerHookCode.setJadeCodeForProxy(_containerUnique, userName);
	else
		self.myUniqueContainerHookCode.setForProxy(self.name, app.myRoot.allHookTypes[HookType_ContainerUnique]);
		self.myUniqueContainerHookCode.setJadeCodeForProxy(_containerUnique, userName);
	endif;
	
	
	if self.myLocationXlateHookCode = null then
		create self.myLocationXlateHookCode transient;
		self.myLocationXlateHookCode.setForProxy(self.name, app.myRoot.allHookTypes[HookType_LocationTranslation]);
		self.myLocationXlateHookCode.createProxyHookLinkForParent(HookType_LocationTranslation, self);
		self.myLocationXlateHookCode.setJadeCodeForProxy(_locationXlateCode, userName);
	else
		self.myLocationXlateHookCode.setForProxy(self.name, app.myRoot.allHookTypes[HookType_LocationTranslation]);
		self.myLocationXlateHookCode.setJadeCodeForProxy(_locationXlateCode, userName);
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_applicationCopies" type="Integer"/>
        <Parameter name="_localAddress" type="String"/>
        <Parameter name="_localPortNumber" type="Integer"/>
        <Parameter name="_sessionTimeout" type="Integer"/>
        <Parameter name="_tcpTimeout" type="Integer"/>
        <Parameter name="_localeObj" type="CM_Locale"/>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_containerXlateCode" type="String"/>
        <Parameter name="_locationXlateCode" type="String"/>
        <Parameter name="_containerUnique" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="3de65d16-5368-4fbc-a3df-37adc3e9b175">
        <source>validateMe(_realDefinitionObj: SelfType; _passportObj: CM_Passport input) protected;
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Purpose:		Standard validation method to validate the receiver's property values,
//				and raises an exception if any of the data is not valid.
//
// Parameters:	_realDefinitionObj - A reference to the real (i.e. not a proxy) object.
//				_passportObj - A reference to the current user's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_realDefinitionObj, _passportObj);
	
	if self.localPortNumber = 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, "TCP/IP Port", null, null);
		app.raiseCMException(Input_required_field_tcpIpPrt, null, null); // cnwdb2	PAR 35364


	endif;
	
	if self.applicationCopies &lt; 1 then
	//	app.raiseCMException1(REQUIRED_FIELD, "Application Copies", null, null);
		app.raiseCMException(Input_required_field_appCopies, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_realDefinitionObj" type="SelfType"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="xMessinasHookcodeAsAt180814" id="4d9e232b-7078-4161-ac2a-5ab3d4558a0f">
        <source>xMessinasHookcodeAsAt180814(_interfaceDef:CM_InterfaceDefinition; _locationParams:CMIF_LocationTransParams):String;

//translateLocn(_interfaceDef:CM_InterfaceDefinition; _locationParams:CMIF_LocationTransParams):String;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2014	cnwndl1	Initial creation - This method is NOT actually called anywhere. 
									This is so we have a copy of Messinas Hook Code should they lose it.....
											

*/

vars
	returnVal : String;
	wle : CM_WorkListEntry;
	request : CM_Request;
	deliveryReq : CM_DeliveryRequest;
	slotRequest : CM_SlotRequest;
	roroRequest : CM_ROROSlotRequest;
	reserveDetail : CM_ReserveDetail;
	reserveSelection : CM_ReserveSelection;
	reserveHeader : CM_BulkRelease;
	gradesStr : String;
	location : CM_LocationsController;
	
begin
	returnVal := _locationParams.defaultDescription;
	
	if _locationParams.isSource then
		wle := _locationParams.myWorkListEntry;
		if wle &lt;&gt; null then
			request := wle.myRequest;
			if request &lt;&gt; null then
				// Internal Yard requests
				if request.isKindOf(CM_DeliveryRequest) then
					deliveryReq := request.CM_DeliveryRequest;
					
					// Start with Terminal Area ID of source
					location := _locationParams.myLocation;
					if location &lt;&gt; null then
						returnVal := location.terminalAreaId;
					endif;
					
					// Now build the description with Operator, isoGroup and Availability Grades
					if deliveryReq.operatorCode &lt;&gt; null then
						returnVal := returnVal &amp; " " &amp; deliveryReq.operatorCode;
					endif;
					
					if deliveryReq.isoGroup &lt;&gt; null then
						returnVal := returnVal &amp; " " &amp; deliveryReq.isoGroup;
					endif;
					
					gradesStr := deliveryReq.getAvailabilityGrades();
					if gradesStr &lt;&gt; null then
						returnVal := returnVal &amp; " " &amp; gradesStr;
					endif;
				
				// Release requests to Ship
				elseif request.isKindOf(CM_SlotRequest) then
					slotRequest := request.CM_SlotRequest;
					
					reserveDetail := slotRequest.myBulkReleaseReserveDetail;
					
					if reserveDetail &lt;&gt; null and reserveDetail.isKindOf(CM_ReserveSelection) then
						reserveSelection := reserveDetail.CM_ReserveSelection;
						
						// Start with Terminal Area ID of source
						location := _locationParams.myLocation;
						if location &lt;&gt; null then
							returnVal := location.terminalAreaId;
						endif;
						
						// Now build the description with Operator, isoGroup and Availability Grades
						reserveHeader := reserveSelection.myReserveHeader;
						if reserveHeader &lt;&gt; null then
							if reserveHeader.myOperator &lt;&gt; null then
								returnVal := returnVal &amp; " " &amp; reserveHeader.myOperator.code;
							endif;
						endif;
						
						if reserveSelection.myISOGroup &lt;&gt; null then
							returnVal := returnVal &amp; " " &amp; reserveSelection.myISOGroup.code;
						endif;
						
						gradesStr := reserveSelection.getAvailabilityGradesDescr();
						if gradesStr &lt;&gt; null then
							returnVal := returnVal &amp; " " &amp; gradesStr;
						endif;
					endif;
				elseif request.isKindOf(CM_ROROSlotRequest) then
					roroRequest := request.CM_ROROSlotRequest;
					
					reserveDetail := roroRequest.myBulkReleaseReserveDetail;
					
					if reserveDetail &lt;&gt; null and reserveDetail.isKindOf(CM_ReserveSelection) then
						reserveSelection := reserveDetail.CM_ReserveSelection;
						
						// Start with Terminal Area ID of source
						location := _locationParams.myLocation;
						if location &lt;&gt; null then
							returnVal := location.terminalAreaId;
						endif;
						
						// Now build the description with Operator, isoGroup and Availability Grades
						reserveHeader := reserveSelection.myReserveHeader;
						if reserveHeader &lt;&gt; null then
							if reserveHeader.myOperator &lt;&gt; null then
								returnVal := returnVal &amp; " " &amp; reserveHeader.myOperator.code;
							endif;
						endif;
						
						if reserveSelection.myISOGroup &lt;&gt; null then
							returnVal := returnVal &amp; " " &amp; reserveSelection.myISOGroup.code;
						endif;
						
						gradesStr := reserveSelection.getAvailabilityGradesDescr();
						if gradesStr &lt;&gt; null then
							returnVal := returnVal &amp; " " &amp; gradesStr;
						endif;
					endif;					
				endif;
			endif;
		endif;
	endif;
	
	return returnVal;
   
end;</source>
        <Parameter name="_interfaceDef" type="CM_InterfaceDefinition"/>
        <Parameter name="_locationParams" type="CMIF_LocationTransParams"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
