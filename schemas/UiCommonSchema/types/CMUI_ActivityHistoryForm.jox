    <JadeMethod name="tableRowLimitException" id="7dc616cb-c7c3-42aa-bf5e-ded6df9e36b7">
        <updating/>
        <source>tableRowLimitException(_exObj: Exception; _table: CM_BaseTable; _exOccurred : Boolean output): Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2010	cnwndl1	Initial creation	Par 17868

*/

vars

begin

	if _table = self.tblActivity then
		if _exObj.errorCode = 14049 or _table.rows = JadeTableRowLimit.Integer then
			_exOccurred := true;
			if not haveToldUserTableActivityFull then
				self.haveToldUserTableActivityFull := true;
				
				app.msgBox(app.getErrorString1(MaxTablesRowsReached, JadeTableRowLimit.String)
						,app.getErrorString(TableRowLimitReached),MsgBox_OK_Only + MsgBox_Information_Icon);
						
			endif;
			if _exObj.resumable then
				return Ex_Resume_Next;
			else
				return Ex_Abort_Action;
			endif;
		endif;
	endif;
	
	return inheritMethod(_exObj, _table, _exOccurred);

epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_table" type="CM_BaseTable"/>
        <Parameter name="_exOccurred" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
