//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	cmbTerminal.displayCollection (app.myRoot.allTerminals, false, null, null, Any_String);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="aa98c881-acf2-47ce-886b-5618f4b87bcd">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     02 September 2008 by concms1:1
//
// Purpose:     User definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.showToolbar := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	
	inheritMethod();
	
	self.loadTerminals;
	self.loadForms;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="00e2ad2f-34b0-4556-bcde-a6b59f3e5cc1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009652, locale);
	lblForm.translateCaption(Xlat_0009653, locale);
	lblTerminal.translateCaption(Xlat_0009654, locale);
end;</source>
    </JadeMethod>
</GUIClass>
