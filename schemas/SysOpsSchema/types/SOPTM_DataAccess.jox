    <JadeMethod name="clearThumbnailData" id="6ab0dfc4-c7d1-4ce8-bf12-8c0fa873c784">
        <updating/>
        <source>clearThumbnailData() updating;
// ---------------------------------------------------------------------------
// Created:     24 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.txtName.text 	:= null;
	theForm.optAllow.value	:= true;
	theForm.chkIncludeNotSet.value := true;
	theForm.setMSHeadingsForDataAccess();
	theForm.mulSelect1.setSelected(null);
end;</source>
    </JadeMethod>
