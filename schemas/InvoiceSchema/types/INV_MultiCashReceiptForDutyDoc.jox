    <JadeMethod name="initPaymentsTable" id="0a538b0e-951d-48d4-b9da-9818da3a1953">
        <source>initPaymentsTable() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2013	cnwndl1	Initial creation

*/

vars

	colWidth : Integer;
	headings : String;

begin

	

	self.tblPayments.clear();
	self.tblPayments.columns := ColumnPayAmount;
	self.tblPayments.rows := 1;
	self.tblPayments.fixedRows := 1;
	self.tblPayments.accessRow(1).fontBold:=true;
	
	colWidth := (self.tblPayments.clientWidth / self.tblPayments.columns ).Integer;
	
	headings := app.getErrorString(Payment_method) &amp; Tab
				&amp; app.getErrorString(Cheque_date) &amp; Tab
				&amp; app.getErrorString(Cheque_bank) &amp; Tab
				&amp; app.getErrorString(Cheque_branch) &amp; Tab
				&amp; app.getErrorString(Cheque_number) &amp; Tab
				&amp; app.getErrorString(Amount);
	
	self.tblPayments.setCellText(1,1,headings);
	
	self.tblPayments.accessColumn(ColumnPayMethod).width := colWidth;
	self.tblPayments.accessColumn(ColumnPayAmount).alignment:=Table.Alignment_Right_Top;
	
epilog

end;</source>
        <access>protected</access>
