		return;
	endif;
	
	// create cargo in the wagon...
	//self.myAssistant.showCargoReceiptFromRailCargo(	self, true, 1, 180, null, null );					//10.4.2023 navhl20	#56628[54992]
	self.myAssistant.showCargoReceiptFromRailCargo(	self, true, 1, 180, null, null,null,null,null );		//10.4.2023 navhl20	#56628[54992]

