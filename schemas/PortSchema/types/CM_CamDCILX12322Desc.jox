    <JadeMethod name="changeEnhancedGensetInfo" id="d156455a-4114-4cdb-8489-789c800e10c4">
        <source>changeEnhancedGensetInfo(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2019	jlgsl4	TFS 43706 - PEN - output Enhanced Genset segment details

*/

vars

begin
	return true; // can output Enhanced Genset info -&gt; allow setting to be changed
epilog

end;</source>
        <ReturnType type="Boolean"/>
