    <JadeMethod name="persistFromProxy" id="c265e08b-fb53-4b99-a008-657a39247eb7">
        <updating/>
        <source>persistFromProxy(_pxyMe : CM_1StopExtVehicleBookingSlot; _vvr : CM_VehicleVisitRecord) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/01/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS Integration
//
vars

begin
	self.raiseExceptionIfTransient(method);
	
	self.carrierCode := _pxyMe.carrierCode;
	self.reference := _pxyMe.reference;
	self.slotEndTime := _pxyMe.slotEndTime;
	self.slotStartTime := _pxyMe.slotStartTime;
	
	self.myVehicleVisitRecord := _vvr;
	self.myReleaseRequest := _pxyMe.myReleaseRequest;
	self.myTerminal := _pxyMe.myTerminal;
epilog

end;</source>
        <Parameter name="_pxyMe" type="CM_1StopExtVehicleBookingSlot"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIFDetail" id="d6643adb-61ec-478b-af34-7b0ba6a9047e">
        <updating/>
        <source>setFromCMIFDetail(_carrier : String; _terminal : CM_Terminal; _vvr : CM_VehicleVisitRecord; _detail : CMIF_1StopBookingData) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/01/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS Integration
//
vars

begin
	self.carrierCode := _carrier;
	
	self.slotStartTime := _detail.timeslotDateTime.asTimeStampFromWebInterface;
	self.reference := _detail.bookingReference;
	
	self.myTerminal := _terminal;
	self.myVehicleVisitRecord := _vvr;
epilog

end;</source>
        <Parameter name="_carrier" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_detail" type="CMIF_1StopBookingData"/>
    </JadeMethod>
</Class>
