    <JadeMethod name="setForLogon" id="f062a9d0-15be-4167-8ad8-563e9f1ca074">
        <updating/>
        <source>setForLogon(_med: CM_RadioTelemetryMediator; _dev: CM_RadioTelemetryDevice; _term: CM_Terminal; _user: CM_User) updating;
// ---------------------------------------------------------------------------
// Created:		12 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod(_med, _dev, _term, _user);
	
	self.doBuildAltIDCollection();
	
end;</source>
        <Parameter name="_med" type="CM_RadioTelemetryMediator"/>
        <Parameter name="_dev" type="CM_RadioTelemetryDevice"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="51d3a664-3ab2-477a-83e2-df49b950fa24">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		12 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	event : Integer;
	theTI : CM_TrackedItem;
begin

	event := self.myTerminal.getEventFromTerminalEvent(eventType);

	if event = EVENT_TI_ALTID_UPDATE and userInfo.isKindOf(CM_Car) then
		theTI := userInfo.CM_TrackedItem;
		
		if self.allTIByAltID.includes(theTI) then
			self.allTIByAltID.remove(theTI);
		endif;
		
		if theTI.site = TI_SITE_OFFSITE then
			return;
		endif;
		if theTI.alternativeId = null then
			return;
		endif;
		if theTI.isTranshipOnInboundVoyage then
			return;
		endif;
		
		if theTI.alternativeId &lt;&gt; null then
			self.allTIByAltID.add(theTI);
		endif;
	
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
