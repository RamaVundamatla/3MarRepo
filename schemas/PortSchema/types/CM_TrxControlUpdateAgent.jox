    <JadeMethod name="trxMoveMultiTrackedItems" id="942d8089-e69f-4f86-a0a0-a4286b0600a4">
        <updating/>
        <source>trxMoveMultiTrackedItems( _cmifArray : ObjectArray input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	obj : Object;
	moveController : CMIF_MoveController;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	
	beginTransaction;
	
	foreach obj in _cmifArray do
	
		moveController := obj.CMIF_MoveController;
		app.myUtilityUA.utlUpdateMoveTrackedItem( moveController, _passport );
		
		if _passport.hasErrors then
			break;
		endif;
	
	endforeach;
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();	
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_cmifArray" type="ObjectArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveTIsAUTOAssignToJob" id="196979ef-fda6-4112-99fa-c1aa6702eb25">
        <updating/>
        <source>trxMoveTIsAUTOAssignToJob(_tis : CM_TIArray; _lcs : CM_LCArray;_moveControl : CMIF_MoveController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		OCT 2006 By Andrew Bishop cnwab1
//
// Purpose:		Multi TI LOAD to SHIP ONLY FULL AUTO LOAD PLANNING ONLY
//
// ---------------------------------------------------------------------------
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	tmpVoy : CM_Voyage;
	oSource, oTarget : CM_LocationsController;
	started : TimeStamp;
	idx, totTIs, count	: Integer;
	theTI : CM_TrackedItem;
	aSlotRequest : CM_SlotRequest;
	allErrors : CM_ErrorSet;
	anFM : CM_FutureMove;
	message : String;
	hasErrors, isLOLO : Boolean;
	tmpMonitor : CMIF_Monitor;
	aVoyRequest : CM_VoyageRequest;
	aJob : CM_Job;
	jobs : CM_JobSet;
	wlesInOrder : ObjectArray;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	create allErrors transient;
	create jobs transient;
	tmpMonitor := app.myPassport.myCMIFMonitor;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	if _passport.hasErrors then
		return;
	endif;

	if _moveControl.moveMode &lt;&gt; PLANNING_MODE then
		return;
	endif;
	aSlotRequest := _moveControl.mySlotRequest;
	aVoyRequest := _moveControl.myVoyageRequest;
	
	if aSlotRequest &lt;&gt; null then
		aJob := aSlotRequest.myJob;
		isLOLO := true;
		// we drag drop SOB in LOAD mode. Which means that this slot req is a discharge SOB
		// We need the load Request so that The TI is associated with the load wle and job.
		// null this out
		if aSlotRequest.isSOB then
			return;
		endif;
		if aSlotRequest.isDischarge then
			return;
		endif;
	endif;
	if aVoyRequest &lt;&gt; null then
		aJob := aVoyRequest.myJob;
		isLOLO := false;
		// we drag drop SOB in LOAD mode. Which means that this slot req is a discharge SOB
		// We need the load Request so that The TI is associated with the load wle and job.
		// null this out
		if aVoyRequest.isSoB then
			return;
		endif;
		if aVoyRequest.isDischarge then
			return;
		endif;
	endif;
	

	// ##############################
	// ## normal move no ship stuff
	if aJob = null then //aSlotRequest = null and aVoyRequest = null then
		return; // ONLY SHIP STUFF
	else
		// PAR 27749 WAS    if aSlotRequest.myJob &lt;&gt; null  and not _passport.hasErrorsOrWarnings  then		
		if aJob &lt;&gt; null  and not _passport.hasErrorsOrWarnings  then
			idx := 0;

			if tmpMonitor &lt;&gt; null then
				tmpMonitor.partsInJob := _tis.size;
			endif;

			totTIs := _tis.size;

			// only if more than 50 TIs
			if totTIs &gt; 50 then
				if aSlotRequest &lt;&gt; null then
					tmpVoy := aSlotRequest.getVoyage();
				elseif aVoyRequest &lt;&gt; null then // PAR 27749
					tmpVoy := aVoyRequest.getVoyage();
				
				endif;
			endif;
			if tmpVoy &lt;&gt; null then
				tmpVoy.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_FULL_PLAN_START), true, null);		// must be immediate					
			endif;
			
			if aVoyRequest &lt;&gt; null then
				if aVoyRequest.allWorkListEntries.size &gt; 1 then
					create wlesInOrder transient;
					aVoyRequest.allWorkListEntries.copy(wlesInOrder);
				endif;
			
			endif;
			
			
			foreach theTI in _tis do
				idx := idx + 1;
				count := count + 1;

				if idx &gt; _lcs.size then
					if wlesInOrder = null or wlesInOrder.size &lt; idx then
						break;
					endif;
				endif;


				
				message := "Planning " &amp; theTI.id;
				if tmpMonitor &lt;&gt; null then
					progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
					if progressInt.getMilliseconds &gt;= ProgressBarRefresh then
						if tmpMonitor.partsInJob &gt; 0 then
							message := message &amp; " " &amp; _moveControl.getEstimateFinString(started,tmpMonitor.partsInJob, idx);
						endif;
						if (not tmpMonitor.updateProgress(message, tmpMonitor.partsInJob, idx)) then
							abortTransaction;
							return;
						endif;
						progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
					endif;
				endif;
				_moveControl.setMyTrackedItem(theTI);
				if _lcs.size = 1 then
					_moveControl.setMyToPrimaryLocation(_lcs.first);
				else
					_moveControl.setMyToPrimaryLocation(_lcs[idx]);
				endif;
				_moveControl.setMyOriginatingLocation(theTI.myPrimaryActualLocation);
				oSource := _moveControl.myOriginatingLocation;
				oTarget := _moveControl.myToPrimaryLocation;		

				if isLOLO then
					aSlotRequest := oTarget.CM_SlotController.mySlotRequestLoad;
					_moveControl.mySlotRequest := aSlotRequest;
					_moveControl.myVoyageRequest := null;
					_moveControl.isRehandleMove := aSlotRequest.isRehandle(); // PAR 11600 ADDED AKB2006APR
					_moveControl.setMyWorkListEntry(aSlotRequest.allWorkListEntries.first);  // PAR 11267
					
					jobs.addNoDuplicates(aSlotRequest.myJob, false); // PAR 13166
				else
					aVoyRequest := oTarget.CM_VoyageROROController.myRORORequestLoad;
					_moveControl.mySlotRequest := null;
					_moveControl.myVoyageRequest := aVoyRequest;
					_moveControl.isRehandleMove := aVoyRequest.isRehandle; 
					if wlesInOrder &lt;&gt; null then
						_moveControl.setMyWorkListEntry(wlesInOrder[idx].CM_WorkListEntry);
					else
						_moveControl.setMyWorkListEntry(aVoyRequest.allWorkListEntries.first);  
					endif;
					jobs.addNoDuplicates(aVoyRequest.myJob, false); 
				
				endif;
				// ### 742 testing. Setting the from location to be the current actual location is correct most of the time, 
				//		but when testing planning DLR discharge and then DLR load planning on bulk items, the originating 
				//		location being on ship was wrong as this upsets the Determine Move Type method on the controller.
				if _moveControl.isRehandleMove 
				and _moveControl.moveMode = PLANNING_MODE then
					anFM := theTI.getFutureMoveOfType(PLANNING_MODE, TIFutureMoveDLRDischarge);
					if anFM &lt;&gt; null then
						_moveControl.setMyOriginatingLocation(anFM.CM_FutureMovePlanned.allLocationsControllers.first);
					endif;
				endif;

				hasErrors := false;
				beginTransaction;
				app.myUtilityUA.utlUpdateWLEAssignTI(_moveControl, _passport); // &lt;&lt;&lt;&lt; This moves the ti as well AND Assigns to JOB
				if process.isInTransactionState() then
					if _moveControl.moveMode = PLANNING_MODE then
						if aSlotRequest &lt;&gt; null and (aSlotRequest.isRehandle or aSlotRequest.isSOB) then
							aSlotRequest.setSequenced(true);
						elseif aVoyRequest &lt;&gt; null and (aVoyRequest.isRehandle or aVoyRequest.isSoB) then
							aVoyRequest.setSequenced(true);
						endif;
					endif;
				endif;
				if  app.myPassport.warningsIgnored then
					if _passport.hasErrors() then // TRANSACTION HAS BEEN ABORTED
						hasErrors := true;
						_passport.moveErrorsToSet(allErrors);
						app.cmsAbortTransaction();
					endif;
				else
					if _passport.hasErrorsOrWarnings() then // TRANSACTION HAS BEEN ABORTED
						hasErrors := true;
						_passport.moveErrorsToSet(allErrors);
						app.cmsAbortTransaction();
					endif;
				endif;
				if not hasErrors then
					_passport.doDeferredUpdates();
					app.cmsCommitTransaction(_passport);
				endif;
				
			endforeach;
		endif;


		// we are doing a multi transaction TRX so if the last TI happens to error the transaction will abort 
		//    and the deferred updates do not fire if we are not in transaction state.
		// No deferred updates = no notifications
		if not process.isInTransactionState() then
			beginTransaction;
		endif;

			// PAR 13264 this was before the 'beginTransaction', was moved to here
		foreach aJob in jobs do // PAR 13166
			aJob.setRemarks(null); // PAR 13166
			if aJob.isKindOf(CM_VoyageJob) and not aJob.CM_VoyageJob.isTwinLift then		// 01/11/2011 cnwmh5 #28616    // 02/12/2011 cnwmh5 #28780
				aJob.CM_VoyageJob.setSeqWorkOrderNum();	
			endif;
		endforeach; // PAR 13166
		
		_passport.doDeferredUpdates();
	endif;
	_passport.warningsAcknowledged := true;
	
	// 12/03/2014 cnwmh5 #33709 - Moved here finaliseActivityWithPassport
	if _passport.warningsIgnored then
		if _passport.hasErrors and not _passport.hasWarnings then // ERRORS ONLY
			_passport.addErrorsFromSet(allErrors); // SHOW THE ERRORS in the GUI
		else
			_passport.clearErrorsWarnings(); // Warnings only so clear out
		endif;
	else
		_passport.addErrorsFromSet(allErrors);
	endif;

epilog
	delete wlesInOrder;
	if tmpMonitor &lt;&gt; null then
		tmpMonitor.updateProgress("Finished", 100,100);
	endif;
	
	self.finaliseActivityWithPassport(_passport);
	/*
	// 12/03/2014 cnwmh5 #33709 - Moved before epilog and finaliseActivityWithPassport
	if _passport.warningsIgnored then
		if _passport.hasErrors and not _passport.hasWarnings then // ERRORS ONLY
			_passport.addErrorsFromSet(allErrors); // SHOW THE ERRORS in the GUI
		else
			_passport.clearErrorsWarnings(); // Warnings only so clear out
		endif;
	else
		_passport.addErrorsFromSet(allErrors);
	endif;
	*/
	delete allErrors;

	if tmpVoy &lt;&gt; null then
			tmpVoy.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_FULL_PLAN_STOP), true, null);		// must be immediate					
	endif;
	delete jobs;
end;</source>
        <Parameter name="_tis" type="CM_TIArray"/>
        <Parameter name="_lcs" type="CM_LCArray"/>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveTrackedItem" id="d04c1989-ea54-4c48-94c7-08ed068f61a0">
        <updating/>
        <source>trxMoveTrackedItem(control : CMIF_MoveController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 Oct 2024 navma1 MTN-33231 MTN - Enable Deferred Updates For Train and Wagon Events 
// 17 Mar 2025 navma1 MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
// ---------------------------------------------------------------------------
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	_passport.useTIDictDeferUpdate 		  	:= true;
	_passport.useTITransactionDeferUpdate 	:= true;
	_passport.useEventDeferUpdate		  	:= true;			//25.10.2024 navma1 #MTN-33231
	_passport.useOfflineFutureActorDeferDel	:= true;			//17.03.2025 navma1 #MTN-34120
	
	beginTransaction;

	app.myUtilityUA.utlUpdateMoveTrackedItem(control, _passport);
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();	
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveTrackedItemAndUnQueue" id="4409fc55-046e-49b1-ab59-f7d8f2407e86">
        <updating/>
        <source>trxMoveTrackedItemAndUnQueue(control 		: CMIF_MoveController input; 
							_futureMove 	: CM_FutureMove io;
							_context 		: Object input; 
							_passport 		: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Mar 2010	cnwndl1	Initial creation	Par 22657
27 Oct 2011 cnwer1	Par 28529
22 Jan 2018 cnwer1	TFS 36605 - issues with any id and truck loader undo
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
18 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
21 Dec 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
04 Jan 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
19 Jan 2024 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
18 Oct 2024	navnk30	JIRA 19927: EUP - Error 1081 When using Rail Lander
25 Oct 2024 navma1 MTN-33231 MTN - Enable Deferred Updates For Train and Wagon Events 
17 Mar 2025 navma1 MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
*/

vars

	unQueueMoveCont		 : CMIF_MoveController;
	fmIndex 			 : Integer;
	ti					 : CM_TrackedItem;
	wle 				 : CM_WorkListEntry;
	tmpRecShip 			 : CM_ReceiveShip;
	isTruckReceiveReLoad : Boolean;	
	completeWle 		 : CM_WorkListEntry;
	refreshWle			 : CM_WorkListEntry;	
	rtQEntry 			 : CM_RTQueueEntry;	
	ed 					 : Integer;
	invalidObj  		 : Boolean;
	reserveDetail 		 : CM_ReserveDetail;	
	checkAssign 		 : Boolean;	
	resDetContext 		 : CM_ReserveDetail;	
	bulkRelContext 		 : CM_BulkRelease;	
	reserveSelection 	 : CM_ReserveSelection;	
	originalTi 			 : CM_TrackedItem;		
	roadJob 			 : CM_RoadJob;
	machine 			 : CM_Machine;
	imvTask	 			 : CM_RTQueueTask;
	imvHistory 			 : CM_MachineHistory;
	request 			 : CM_Request;
	wod					 : CM_WorkOrderDtl;
	transport			 : Integer;
	docAction			 : CM_DocumentActions;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	_passport.useTIDictDeferUpdate 		  	:= true;
	_passport.useTITransactionDeferUpdate 	:= true;
	_passport.useWOTransactionDeferUpdate 	:= true;		//18.10.2024 navnk30 JIRA #19927
	_passport.useEventDeferUpdate		  	:= true;		//25.10.2024 navma1 #MTN-33231
	_passport.useOfflineFutureActorDeferDel	:= true;		//17.03.2025 navma1 #MTN-34120
	
	//01 Dec 2015	NDL	Par 36987
	if control &lt;&gt; null then
		//epr tfs 1842 28/4/16
		isTruckReceiveReLoad := control.isTruckReceiveReLoad();
		if isTruckReceiveReLoad  then
			completeWle := control.myWorkListEntry;
			roadJob		:= completeWle.job.CM_RoadJob;
		endif;
	endif;
	
	originalTi := control.myTrackedItem;		//27 Nov 2017	NDL	TFS 8026
	
	beginTransaction;
	
	//epr TFS 43478 18/2/19
	if originalTi.myPrimaryActualLocation.isKindOf(CM_MachineController) then
		machine:=originalTi.myPrimaryActualLocation.CM_MachineController.myMachine;
		if machine.isIMV then
			imvTask:=machine.getTaskForTI(originalTi);
			if imvTask &lt;&gt; null then
				imvHistory := machine.addMoveToHistoryTask(imvTask);
			endif;
		endif;
	endif;
	
	app.myUtilityUA.utlUpdateMoveTrackedItem(control, _passport);
	
	if imvHistory &lt;&gt; null then
		
	endif;
	//epr par 28529 make sure I return if a get an error before calling another util
	if _passport.hasErrors then
		_passport.clearDeferUpdatesCollections();	//04 Jul 2017	NDL	TFS 5238
		return;
	endif;
	
	ti := control.myTrackedItem;
	
	//20 Mar 2017	NDL	TFS 3667
	if app.isCargoGroupEnabled then
		checkAssign := true;
	endif;
	
	if checkAssign then
		docAction := control.myDocumentActions;									//17.03.2025 navma1 #MTN-34120
		if docAction &lt;&gt; null and docAction.isReserveDetailAction then
			reserveDetail := docAction.CM_ReserveDetailActions.myReserveDetail;
			if reserveDetail &lt;&gt; null and not reserveDetail.includeTrackedItem( ti , false) then //23/06/2023	navkc1	CR 58406 Task 58408
				app.myUtilityUA.utlAddToReserveDetail(reserveDetail, ti, _passport);
			endif;
		endif;
	endif;
		
	if _passport.noErrors then	// 28 Apr 2010	NDL Par 23822
		if ti &lt;&gt; null then
			wle := ti.getVoyageWLEUnactioned(false);
			tmpRecShip := ti.getLastTransOfTypeClass(CM_ReceiveShip).CM_ReceiveShip;
		endif;
		if tmpRecShip &lt;&gt; null and wle &lt;&gt; null then
			tmpRecShip.setJSFromWLE(wle);
		endif;
	endif;
	
	//cnwrd1 par 28893 5.1.2012
	// We want to return to the user if we have some warnings (or errors..) so they can aknowledge them and then proceed through the code again.
	if _passport.hasErrorsOrWarnings and not _passport.warningsAcknowledged and not _passport.warningsIgnored then 
		_passport.clearDeferUpdatesCollections();	//04 Jul 2017	NDL	TFS 5238
		return;
	endif;
	
	if ti &lt;&gt; null then
	
		if _futureMove &lt;&gt; null then
		
			//27 Apr 2016	NDL	TFS 1809
			fmIndex := ti.allQueuedFutureMoves.indexOf(_futureMove);
			if 	fmIndex &gt; 0 then
				refreshWle := _futureMove.myWorkListEntry;
				if refreshWle &lt;&gt; null and CM_WorkListEntry.hasInstance(refreshWle) then
					if not refreshWle.allRTQueueEntries.isEmpty then
						rtQEntry := refreshWle.allRTQueueEntries.last;
					endif;
					if rtQEntry &lt;&gt; null and CM_RTQueueEntry.hasInstance(rtQEntry) then
						app.myEventManager.createSingleObjInfoNoteEvt( rtQEntry,app.myPassport.myTerminal.getTerminalEvent(RTQueueEntry_Update_Event), null);
					endif;
				endif;
			endif;
			
			create unQueueMoveCont transient;
			unQueueMoveCont.setMoveMode(QUEUE_MODE);
			
			//fmIndex := ti.allQueuedFutureMoves.indexOf(_futureMove); // moved up
			//have to unqueue if the _ti is still queued i.e. it was moved to a location it was not queued to
			//if _ti.myPrimaryQueuedLocation &lt;&gt; null and _ti.myPrimaryQueuedLocation &lt;&gt; _toLocation then
			if 	fmIndex &gt; 0 then
				unQueueMoveCont.setMoveIndex(fmIndex);
				unQueueMoveCont.isFullyUnplan:=true;
				unQueueMoveCont.setMyTrackedItem(ti);
				app.myUtilityUA.utlUpdateMoveTIUndo(unQueueMoveCont, _passport);
			endif;
			delete unQueueMoveCont;
		endif;
		
	endif;
	
	//01 Dec 2015	NDL	Par 36987
	if _passport.hasErrorsOrWarnings and not _passport.warningsAcknowledged and not _passport.warningsIgnored then 
		_passport.clearDeferUpdatesCollections();	//04 Jul 2017	NDL	TFS 5238
		return;
	endif;
	//01 Dec 2015	NDL	Par 36987
	if (isTruckReceiveReLoad ) and completeWle &lt;&gt; null then
		//epr tfs 1842 28/4/16
		on Exception do app.handleDeletedObject(exception,completeWle,invalidObj);
	
		ed:=completeWle.edition;
		if invalidObj then
			_passport.clearDeferUpdatesCollections();	//04 Jul 2017	NDL	TFS 5238
			return;
		endif;	
		
		if not completeWle.isCompleteForJob() then	
			app.myUtilityUA.utlUpdateWLEStatusDirectWLE( completeWle, WLE_UNACTIONED, _passport);		
		endif;
	endif;
	
	//27 Nov 2017	NDL	TFS 8026
	if _passport.noErrors then
		if _context &lt;&gt; null then
			if _context.isKindOf( CM_ReserveDetail ) then //Splitable ti being loaded to ship
				resDetContext := _context.CM_ReserveDetail;
			elseif _context.isKindOf( CM_BulkRelease ) then// Splitable ti being Discharged from ship
				bulkRelContext := _context.CM_BulkRelease;	
			endif;
		endif;
	
		if resDetContext &lt;&gt; null then
			// Might have been split off.. if so would have lost its reserve detail ref.
			app.myUtilityUA.utlAddToReserveDetail( resDetContext, ti, app.myPassport );
			
		elseif bulkRelContext &lt;&gt; null then
			//If its been merged and zombied, remove it from the assigned... otherwise don't 
			if originalTi.hasBeenMerged then
				foreach resDetContext in bulkRelContext.allReserveDetails do
					if not resDetContext.isKindOf( CM_ReserveSelection ) then
						continue;
					endif;
					reserveSelection := resDetContext.CM_ReserveSelection;
					app.myUtilityUA.utlRemoveReserveDetail( reserveSelection, originalTi, _passport);
					if _passport.hasErrors then
						break;
					endif;
				endforeach;
			endif;
			
		endif;
	endif;
	
	if _passport.noErrors then																		//21.12.2023 navhl20 #61092[61621]
		wle := control.myWorkListEntry;
		if wle.isKindOf(CM_WOReleaseCargoWLE) then
			wod 	  := wle.CM_WOReleaseCargoWLE.getWorkOrderTIDtl();
			transport := wod.CM_WorkOrderTIDtl.getTransport();
			
			if transport = TI_TRANSMODE_SHIP then
				request 	  := wle.CM_WOReleaseCargoWLE.myRequest;
				reserveDetail := request.myReserveDetail;
				
				if reserveDetail &lt;&gt; null then
					app.myUtilityUA.utlAddToReserveDetail( reserveDetail, ti, app.myPassport );		//19.01.2024 navhl20 #62066
					reserveDetail.addTIReleased(ti);
					
					bulkRelContext := reserveDetail.myReserveHeader;
					if bulkRelContext &lt;&gt; null then
						bulkRelContext.addCargoItemMoved(ti);
						bulkRelContext.updateStatus();
					endif;
				endif;
			endif;
		endif;
	endif;
	
	if _passport.noErrors then			//25.10.2024 navma1 #MTN-33231
		_passport.doDeferredUpdates();	//04 Jul 2017	NDL	TFS 5238 - Moved from above to potentially lessen lock times
	endif;
	
epilog
	delete unQueueMoveCont;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_futureMove" type="CM_FutureMove" usage="io"/>
        <Parameter name="_context" type="Object" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveTrackedItemAssignToJob" id="7bef05f5-62ec-4fd7-b128-7d975b6ab119">
        <updating/>
        <source>trxMoveTrackedItemAssignToJob(_moveControl : CMIF_MoveController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		This assigns the ti to the job and the WLE and then moves it
// ---------------------------------------------------------------------------
// 17/06/2011	cnwmh5	#27207 - For a rehandle need to cleanup the discharge
// 29/07/2015	cnwdap1	PAR #36589 If TI is a rehandle, make sure move controller is set to rehandle
// 21/05/2019	jlgzm1	TFS 42840 MSL Direct Release between Voyages and Rail
// 05/07/2019	jlgzm1	TFS 42863 MSL Direct Release between Voyages and Rail - Break Bulk
// 28/08/2019	jlgzm1	TFS 42878 Direct Release Between Road and Voyage
vars
	theSource, theTarget : CM_LocationsController;
	oSource, oTarget : CM_LocationsController;
	theSlotController : CM_SlotController;
	theSlotRequest : CM_SlotRequest;
	theSlotReqLoadLINKED : CM_Request;
	theLinkedTarget : CM_LocationsController;
	theTI : CM_TrackedItem;
	aSlotRequest,theDslotRequest : CM_SlotRequest;
	aProxyJob : CM_VoyageJob;
	aSlotController : CM_SlotController;
	unPlanMoveControl : CMIF_MoveController;
	doAutoPlan : Boolean;
	oWLE, linkedWLE : CM_WorkListEntry;
	aROROController, theLinkedROROTarget : CM_VoyageROROController;
	aRORORequest, aDRORORRequest, theROROReqLoadLINKED : CM_RORORequest;
	theJob 	: CM_Job; 		// tfs42840
	vwle 	: CM_VoyageWLE; // tfs42840
	ywle 	: CM_YardWLE; 	// tfs42840
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	oSource := _moveControl.myOriginatingLocation;
	oTarget := _moveControl.myToPrimaryLocation;		
	oWLE := _moveControl.myWorkListEntry;
	
	// tfs42840
	if _moveControl.myWorkListEntry.isKindOf(CM_YardWLE) then
		ywle := _moveControl.myWorkListEntry.CM_YardWLE;
	elseif _moveControl.myDDWorkListEntry &lt;&gt; null and _moveControl.myDDWorkListEntry.isKindOf(CM_YardWLE)then
		ywle := _moveControl.myDDWorkListEntry.CM_YardWLE;
	endif;

	theTI := _moveControl.myTrackedItem;
	if theTI = null then
		app.raiseUnexpectedProgramError(class.name, method.name, '_moveControl.myTrackedItem = null');
		return;
	endif;
	
	aSlotRequest := _moveControl.mySlotRequest;
	
	if aSlotRequest &lt;&gt; null then
		// we drag drop SOB in LOAD mode. Which means that this slot req is a discharge SOB
		// We need the load Request so that The TI is associated with the load wle and job.
		// null this out
		if aSlotRequest.isSOB then
			if aSlotRequest.isDischarge then
				theDslotRequest := aSlotRequest;
				aSlotRequest := null;
			endif;
		endif;
	else
		aRORORequest := _moveControl.myVoyageRequest.CM_RORORequest;
		if aRORORequest &lt;&gt; null then
			// we drag drop SOB in LOAD mode. Which means that this slot req is a discharge SOB
			// We need the load Request so that The TI is associated with the load wle and job.
			// null this out
			if aRORORequest.isSOB then
				if aRORORequest.isDischarge then
					aDRORORRequest := aRORORequest;
					aRORORequest := null;
				endif;
			endif;
		endif;
	endif;
	
	
	// if this was dragged dropped in the yard the slot request will not have been set up so get it from 
	// theslot controller or drag dropped in SHIP in LOAD view for a SOB job
	if aSlotRequest = null and aRORORequest = null and _moveControl.moveMode = PLANNING_MODE then
		if CM_SlotController.hasInstance(_moveControl.myToPrimaryLocation) then
			aSlotController := _moveControl.myToPrimaryLocation.CM_SlotController;
			aSlotRequest := aSlotController.mySlotRequestLoad;
		endif;
		if aSlotRequest = null and aRORORequest = null and _moveControl.moveMode = PLANNING_MODE then
			if CM_VoyageROROController.hasInstance(_moveControl.myToPrimaryLocation) then
				aROROController := _moveControl.myToPrimaryLocation.CM_VoyageROROController;
				aRORORequest := aROROController.myRORORequestLoad;
			endif;
		endif;
	endif;

	if aSlotRequest &lt;&gt; null then
		if aSlotRequest.isSOB then
			doAutoPlan := app.myPassport.myTerminal.getConfig(AutoLinkSlotPlanSOB).Boolean;
		elseif aSlotRequest.isRehandle then
			doAutoPlan := app.myPassport.myTerminal.getConfig(AutoLinkSlotPlan).Boolean;
		else
			doAutoPlan := false;
		endif;
		vwle := aSlotRequest.allWorkListEntries.first.CM_VoyageWLE; // tfs42840
		
	elseif aRORORequest &lt;&gt; null then
		if aRORORequest.isSOB then
			doAutoPlan := app.myPassport.myTerminal.getConfig(AutoLinkSlotPlanSOB).Boolean;
		elseif aRORORequest.isRehandle then
			doAutoPlan := app.myPassport.myTerminal.getConfig(AutoLinkSlotPlan).Boolean;
		else
			doAutoPlan := false;
		endif;
		vwle := aRORORequest.getFirstUnusedWLE.CM_VoyageWLE; // tfs42863
	endif;

	// tfs42840
	if vwle &lt;&gt; null and ywle &lt;&gt; null then
		if ywle.isReceipt and ywle.myFutureMove &lt;&gt; null then	// TFS 42878
			app.raiseCMException1(Alread_planne_unplan_replan_ne, ywle.myTrackedItem.id, null, null);	// TFS 42878
			return;	// TFS 42878
		endif;
		// link WLEs for direct release
		_moveControl.setMyWorkListEntry(vwle);
		_moveControl.myDDWorkListEntry := ywle;
		_moveControl.myDDJob := ywle.job;
	endif;
	
	beginTransaction;
	
	// split the vwle if it needs to be done
	_moveControl.doDRSplitCreateNewWLE(false); // tfs42863
	if _moveControl.isReplanAnExport and _moveControl.isDirectReleaseMove then	// tfs42863
		if oWLE.isKindOf(CM_VoyageWLE) and ywle &lt;&gt; null then					// tfs42863
			// for export replans, _moveControl is expected to have myWorkListEntry be the "old" wle
			// will have been passed to this method like this.
			// we needed to assign the "new" wles so they could be split if needed
			// but now we want to set it back
			_moveControl.setMyWorkListEntry(oWLE);	// tfs42863
			_moveControl.myDDWorkListEntry := ywle;	// tfs42863
			_moveControl.myDDJob := ywle.job;		// tfs42863
		endif;										// tfs42863
	endif;											// tfs42863
	
	// ##############################
	// ## normal move no ship stuff
	if aSlotRequest = null and aRORORequest = null then
		app.myUtilityUA.utlUpdateMoveTrackedItem(_moveControl,_passport);
	else
		// ##############################
		// ### VOYAGE STUFF. Basically we need to assign the TI in this planned move to the voyage job and the voyage WLE
		// ### We do the assigning first cos this validates and stops. This is becuase it validates the planning state and if we do the planned move first 
		// ### it says that it is already planned
		// ### do we need to unplan first

		// ### Switch these around incase we are linked, used below...
		if (aSlotRequest &lt;&gt; null and aSlotRequest.isRehandle) or (aRORORequest &lt;&gt; null and aRORORequest.isRehandle) then
			_moveControl.isRehandleMove := true; // see CMIF__moveControl::setMyToSecondaryLocations
			theTarget := _moveControl.myOriginatingLocation;
			theSource := _moveControl.myToPrimaryLocation;
		elseif theTI.isRehandle or theTI.isROBPlannedBackToShip(_moveControl) then	// PAR #36589
			_moveControl.isRehandleMove := true;									// PAR #36589
			theTarget := _moveControl.myToPrimaryLocation;							// PAR #36589
			theSource := _moveControl.myOriginatingLocation;						// PAR #36589
		else
			theTarget := _moveControl.myToPrimaryLocation;
			theSource := _moveControl.myOriginatingLocation;
		endif;
			
		if _moveControl.myWorkListEntry = null then // AKB2003OCT6 added, a new WLE may have been created in trxMoveTrackedItemAssignToJobU
			if aSlotRequest &lt;&gt; null then
				_moveControl.setMyWorkListEntry(aSlotRequest.getWLEForTI(theTI)); // AKB2004APR2 - allow for multiple discharges in one slot
				if _moveControl.myWorkListEntry = null then
					// RJS 19May2004 - if no specific wle for TI then get first wle with no ti
					_moveControl.setMyWorkListEntry(aSlotRequest.getWLEForTI(null));
				endif;
			elseif aRORORequest &lt;&gt; null then
				_moveControl.setMyWorkListEntry(aRORORequest.getWLEForTI(theTI)); // AKB2004APR2 - allow for multiple discharges in one slot
				if _moveControl.myWorkListEntry = null then
					// RJS 19May2004 - if no specific wle for TI then get first wle with no ti
					_moveControl.setMyWorkListEntry(aRORORequest.getWLEForTI(null));
				endif;
			endif;
		endif;
		// ### LOLO
		if  aSlotRequest &lt;&gt; null and aSlotRequest.myJob &lt;&gt; null and (not _passport.hasErrors) then
			app.myUtilityUA.utlUpdateWLEAssignTI(_moveControl, _passport); // &lt;&lt;&lt;&lt; This moves the ti as well AND Assigns to JOB
			if _passport.hasErrors then
				// have had an error in utl
				return;
			endif;
			if _moveControl.moveMode = PLANNING_MODE and (aSlotRequest.isRehandle or aSlotRequest.isSOB) then
				aSlotRequest.setSequenced(true);
			endif;
			if theDslotRequest &lt;&gt; null and _moveControl.moveMode = PLANNING_MODE and (theDslotRequest.isRehandle or theDslotRequest.isSOB) then
				theDslotRequest.setSequenced(true);
			endif;
		// ### RORO
		elseif  aRORORequest &lt;&gt; null and (not _passport.hasErrors) then //and aRORORequest.myJob &lt;&gt; null 
			app.myUtilityUA.utlUpdateWLEAssignTI(_moveControl, _passport); // &lt;&lt;&lt;&lt; This moves the ti as well AND Assigns to JOB
			if _passport.hasErrors then
				// have had an error in utl
				return;
			endif;
			if _moveControl.moveMode = PLANNING_MODE and (aRORORequest.isRehandle or aRORORequest.isSOB) then
				aRORORequest.setSequenced(true);
			endif;
			if aDRORORRequest &lt;&gt; null and _moveControl.moveMode = PLANNING_MODE and (aDRORORRequest.isRehandle or aDRORORRequest.isSOB) then
				aDRORORRequest.setSequenced(true);
			endif;

		endif;
		
		if doAutoPlan then

			if theTarget.isKindOf(CM_SlotController) and (aSlotRequest &lt;&gt; null and aSlotRequest.isRehandle or aSlotRequest.isSOB) then
				theSlotController := theTarget.CM_SlotController;
				theSlotRequest := theSlotController.mySlotRequestDischarge;
				if theSlotRequest  &lt;&gt; null then

					if theSlotRequest.moveType &lt;&gt; NULL_MOVETYPE then
						// this slot has a discharge request that is linked to  a load request!
						// let's try to do the planning back to the ship
						//theSlotReqLoadLINKED := theSlotRequest.getLinkedRequest(true); // PAR 28968 mySlotRequestDLRSOBLoad;
						theSlotReqLoadLINKED := theSlotRequest.myRequestLinkedLoad;	//27 Mar 2018	NDL	TFS 37569
						if theSlotReqLoadLINKED &lt;&gt; null 
						and theSlotReqLoadLINKED.myJob &lt;&gt; null then
							linkedWLE := theSlotReqLoadLINKED.allWorkListEntries.first; // PAR 15834
							// PAR 15834 check if the load part is already planned if so do nuthin
							if linkedWLE &lt;&gt; null then
								if linkedWLE.myFutureMove = null then
									// #### this is the AUTO part, ping the TI back to the LOAD colour coded slot
									theLinkedTarget := theSlotReqLoadLINKED.getLC(); // PAR 28968 mySlotController;
									// switch the same location around. All the other details are still OK
									_moveControl.setMyToPrimaryLocation(theLinkedTarget); //theTarget
									_moveControl.setMyOriginatingLocation(theSource);
									_moveControl.setMyWorkListEntry(linkedWLE);
									
									theSlotReqLoadLINKED.setSequenced(true);
									app.myUtilityUA.utlUpdateWLEAssignTI(_moveControl, _passport); // &lt;&lt;&lt;&lt; This moves the ti as well AND Assigns to JOB
								endif;
							endif;
							
						endif;
					endif;
				endif;

			elseif theTarget.isKindOf(CM_VoyageROROController) and (aRORORequest &lt;&gt; null and aRORORequest.isRehandle or aRORORequest.isSOB) then
				aROROController := theTarget.CM_VoyageROROController;
				aRORORequest := aROROController.myRORORequestDischarge;
				if aRORORequest  &lt;&gt; null then
	
					if aRORORequest.moveType &lt;&gt; NULL_MOVETYPE then
						// this slot has a discharge request that is linked to  a load request!
						// let's try to do the planning back to the ship
						theROROReqLoadLINKED := aRORORequest.myRequestLinkedLoad.CM_RORORequest;
						if theROROReqLoadLINKED &lt;&gt; null 
						and theROROReqLoadLINKED.myJob &lt;&gt; null then
							linkedWLE := theROROReqLoadLINKED.allWorkListEntries.first;
							// PAR 15834 check if the load part is already planned if so do nuthin
							if linkedWLE &lt;&gt; null then
								if linkedWLE.myFutureMove = null then
									// #### this is the AUTO part, ping the TI back to the LOAD colour coded slot
									theLinkedROROTarget := theROROReqLoadLINKED.myROROController;
									// switch the same location around. All the other details are still OK
									_moveControl.setMyToPrimaryLocation(theLinkedROROTarget); //theTarget
									_moveControl.setMyOriginatingLocation(theSource);
									_moveControl.setMyWorkListEntry(linkedWLE);
									
									theROROReqLoadLINKED.setSequenced(true);
									app.myUtilityUA.utlUpdateWLEAssignTI(_moveControl, _passport); // &lt;&lt;&lt;&lt; This moves the ti as well AND Assigns to JOB
								endif;
							endif;
							
						endif;
					endif;
				endif;
			endif;
		endif;		
	endif;

	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog
	// we possibly switch the source and target IF we are auto linked DLRs. If there was validation raised the put the original locations back
	// for when we come in again after the warnings have been acknowledged
	_moveControl.setMyToPrimaryLocation(oTarget);
	_moveControl.setMyOriginatingLocation(oSource);
	// TFS 42863
	// It is possile for oWLE to get deleted during the move, so trying to use it here will raise a 1072
	// Will need to be reset in the calling method
	//_moveControl.setMyWorkListEntry(oWLE); // PAR 15834

	delete unPlanMoveControl;
	delete aProxyJob;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveTrackedItemNewRailJob" id="73e6c9e0-5a6f-4dc3-b81a-83964b427d5c">
        <updating/>
        <source>trxMoveTrackedItemNewRailJob(control : CMIF_MoveController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     May 2009 ANDREW BISHOP
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 21/05/2019	jlgzm1		TFS 42840 MSL Direct Release between Voyages and Rail
// 05/07/2019	jlgzm1		TFS 42863 MSL Direct Release Bulk, Break-bulk
// 19/08/2019	jlgzm1		TFS 42872 Direct Delivery Between HOLD Voyages and Rail
// 28/08/2019	jlgzm1		TFS 42878 Direct Delivery Between Road and Voyage
// ---------------------------------------------------------------------------

vars
	tmpTi : CM_TrackedItem;
	theJob : CM_Job;
	tranArea : String;
	train : CM_Train;
	wagon2wagonMove : Boolean;
	request : CM_Request;
	wle : CM_WorkListEntry;
	vwle : CM_VoyageWLE; //tfs42840
	origWle 	: CM_WorkListEntry; //tfs42863
	wleArray 	: CM_WLEArray; 		//tfs42863
	tmpFM		: CM_FutureMove;	//tfs42872
	
	railJob : CM_RailJob;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	_passport.useTIDictDeferUpdate := false;
	_passport.useTITransactionDeferUpdate := false;

	beginTransaction;
	
	origWle := control.myWorkListEntry; //tfs42863
	
	tmpTi := control.myTrackedItem;
	if tmpTi.myPrimaryActualLocation &lt;&gt; null then
		wagon2wagonMove := tmpTi.myPrimaryActualLocation.isWagon() and control.isWagonMove(); // PAR 21955
	endif;
	
	if control.isDirectReleaseMove and origWle &lt;&gt; null then 
		if origWle.job.isKindOf(CM_VoyageHoldJob) then	// TFS 42872
			if control.myToPrimaryLocation &lt;&gt; null then									// TFS 42872
				app.raiseCMWarning2(WARN_REPLAN_CONFIRM, tmpTi.id,control.myToPrimaryLocation.getFullId, null, null, tmpTi);	// TFS 42872
			endif;
			if control.isReplan and	not origWle.isDRLinkedByFM then	// TFS 42872
				// Move is technically a replan, but we want it to do all the setup for a normal plan
				control.isReplan := false;	// TFS 42872
			endif;
		elseif origWle.myFutureMove &lt;&gt; null then	// TFS 42878
			// already planned, can't replan as direct release
			app.raiseCMException1(Alread_planne_unplan_replan_ne, tmpTi.id, null, null); // TFS 42878
			return; // TFS 42878
		endif;
	endif;
	
	if control.moveMode &lt;&gt; REAL_MODE 
	and not wagon2wagonMove  // PAR 21955  no need for a job if Qing from wagon to wagon
	and not control.isReplan then // PAR 20681
	
		theJob := tmpTi.jobRailRelease;
		//16 Sep 2013	NDL	Par 32479
		if theJob &lt;&gt; null and tmpTi.canMergeBreakBulk and control.myWorkListEntry &lt;&gt; null then
			if theJob &lt;&gt; null then
				if control.myWorkListEntry.job &lt;&gt; theJob then
					theJob := control.myWorkListEntry.job;
				endif;
			endif;
		endif;
		
		if theJob = null then
			if control.isWagonMove() then
				 // ### TFS 54010 28JUN2022 NAVAB1 - need a job sheet. This is EITHER the train job sheet or the rail areas job sheet. The train job sheet is only used whilst the wagon is not confirmed
				if control.myToPrimaryLocation.CM_WagonController.myWagon.myRailLine &lt;&gt; null then
					// tranArea can be null if train has not arrived in terminal (has not been confirmed)
					tranArea := control.myToPrimaryLocation.CM_WagonController.myWagon.myRailLine.myRailArea.id;
/*TFS 54004// ### TFS 51855 24MAY2022 NAVAB1*/					else
/*TFS 54004// ### TFS 51855 24MAY2022 NAVAB1*/						train := control.myToPrimaryLocation.CM_WagonController.myWagon.myTrainOutwards;
				endif;

//TFS 54004				train := control.myToPrimaryLocation.CM_WagonController.myWagon.myTrainOutwards; // ### TFS 51855 24MAY2022 NAVAB1 always set the train.
	
				theJob := tmpTi.createRailReleaseJob(tranArea, train);
				if _passport.hasErrorsOrWarnings() 
				and not _passport.warningsAcknowledged then // PAR 20028
					return;
				endif;
				
				//10 Apr 2014	NDL	CCMS 1633
				if tmpTi.isBulkByVolume or tmpTi.isBulkByWeight then
					if control.weight &gt; 0 and control.weight &lt;= tmpTi.totalWeight then
						request := theJob.allRequests.first;
						if request &lt;&gt; null then
							request.setWeightRequested( control.weight );
						endif;
						wle := theJob.getWLEForTI(tmpTi);
						if wle &lt;&gt; null then
							wle.setWeight( control.weight );
						endif;
					endif;
				// tfs42863 start
				elseif tmpTi.isKindOf(CM_BreakBulkGeneric) and
				   tmpTi.canMergeBreakBulk then
					if control.quantity &gt; 0 and control.quantity &lt;= tmpTi.totalQuantity then
						request := theJob.allRequests.first;
						wle := theJob.getWLEForTI(tmpTi);
						if wle &lt;&gt; null then
							wle.setQuantity( control.quantity );
						endif;
					endif;
				endif;

			endif;
		elseif not theJob.isKindOf(CM_RailJob) then
			// if this is a direct release, the WLE on the controller could have a voyage job. need the rail job.
			if control.isWagonMove() then			
				theJob := tmpTi.jobRailRelease;
				request := tmpTi.createTiRequest(theJob, control.quantity, control.weight, app.myPassport);
				if theJob &lt;&gt; null and theJob.allRequests.isNotEmpty then
					request.setMyOriginatingBulkRelease(theJob.getMyBulkRelease());
					if request.myOriginatingBulkRelease &lt;&gt; null then
						request.CM_YardRequest.setDeliveryNumber(request.myOriginatingBulkRelease.code.trimRight);
					endif;
				endif;
				
				create wleArray transient;
				theJob.getWLEsForTI(tmpTi, wleArray);
				wle := wleArray.last;
				if wle &lt;&gt; null then
					wle.setWeight(control.weight);
					wle.setQuantity(control.quantity);
					request.CM_YardRequest.isReceipt := false;
					theJob.updateTICollections(tmpTi, wle);
				endif;
			endif;
		// tfs 42863 end
		elseif theJob.CM_RailJob.requestNum = null then
			app.raiseCMException2(Alrea_rail_relea_job_canno_co, tmpTi.id, theJob.jobId, null, tmpTi); // PAR 20028
		endif;
	endif;
	
	if _passport.hasErrorsOrWarnings() 
	and not _passport.warningsAcknowledged then // PAR 20028
		return;
	endif;

	// 07/12/2010 cnwmh5 #26452 - Start
	if theJob = null and control.isWagonMove() then
		if tmpTi.checkNotRecvdForInwardsWagon(control.myToPrimaryLocation.CM_WagonController.myWagon) then
			app.raiseCMWarning1(ERR_Cargo_Received, tmpTi.id, null, null, null);
		endif;
	endif;	
	
	if _passport.hasErrorsOrWarnings() 
			and not _passport.warningsAcknowledged then // PAR 20028
		return;
	endif;
	// 07/12/2010 cnwmh5 #26452 - End
	
	//14 Dec 2010	NDL	Par 26549
	if not control.userSpecifiedTheWle then	//20 Sep 2013	NDL	Par 32479 - userSpecifiedWle
		if theJob = null and control.moveMode = REAL_MODE then 
			if control.isWagonMove() then
				theJob := tmpTi.jobRailRelease;
			endif;
		endif;
		
		if theJob &lt;&gt; null then
			// check we havn't alreay found our wle
			if wleArray = null then		// tfs42863
				wle := theJob.getWLEForTI(tmpTi);
			endif;
			// TFS 42840 start
			// Link voyageWLE/voyage job for Direct Release
			// if we already have the voyageWLE use that else get it from the request
			if origWle &lt;&gt; null and origWle.isKindOf(CM_VoyageWLE) then		// tfs42863
				control.myDDWorkListEntry := origWle;						// tfs42863
				control.myDDJob := origWle.job;								// tfs42863
			else
				if control.mySlotRequest &lt;&gt; null then
					vwle := control.mySlotRequest.allWorkListEntries.first.CM_VoyageWLE;
					if vwle &lt;&gt; null then
						control.myDDWorkListEntry := vwle;
						control.myDDJob := vwle.job;
					endif;
				elseif control.myVoyageRequest &lt;&gt; null then
					vwle:= control.myVoyageRequest.allWorkListEntries.last.CM_VoyageWLE; // tfs42863
					if vwle &lt;&gt; null then
						control.myDDWorkListEntry := vwle;
						control.myDDJob := vwle.job;
					endif;
				endif;
			endif;	
			// TFS 42840 end
			control.setMyWorkListEntry(wle);
			
			// split the vwle if it needs to be done
			// TFS 42872 start
			if not control.doDRSplitCreateNewWLE(false) then
				if origWle.isKindOf(CM_VoyageWLE) and origWle.myFutureMove &lt;&gt; null then
					// Voyage hold jobs require cargo to be planned at the creation of the job
					// if setting that cargo for direct release, 
					// then need to clear the the exitsting planned move
					tmpFM := origWle.myFutureMove;
					delete tmpFM;
					control.setMoveIndex(0);
				endif;
			endif;
			// TFS 42872 End
		endif;
	endif;

	app.myUtilityUA.utlUpdateMoveTrackedItem(control, _passport);
	
	//29 Sep 2009	NDL	Wasn't passing back warnings to user.
	if _passport.hasErrorsOrWarnings() 
	and not _passport.warningsAcknowledged then
		_passport.setWarningsIgnored(false);
		return;
	endif;
	
	// PAR 19913
	if _passport.noErrors then
		if theJob &lt;&gt; null and theJob.isKindOf(CM_RailJob)then
			railJob := theJob.CM_RailJob; // ### TFS 54010 28JUN2022 NAVAB1
			 // ### TFS 54010 28JUN2022 NAVAB1theJob.CM_RailJob.addWagon(tmpTi);
			railJob.CM_RailJob.addWagon(tmpTi); // ### TFS 54010 28JUN2022 NAVAB1
			
			 // ### TFS 54010 28JUN2022 NAVAB1 The job needs to send the train code, this can only be done after the job is linked to the wagon.
			if app.myPassport.isOpsViewEnabled(railJob.myTerminal) then // ### TFS 54010 28JUN2022 NAVAB1
			
				railJob.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB, railJob);	 // ### TFS 54010 28JUN2022 NAVAB1
			endif;
		endif;
	endif;
	if _passport.noErrors then
		_passport.doDeferredUpdates();	
	endif;
	

epilog

	delete wleArray; //tfs42863
	// if we've changed the wle on the verification step, want to set it back for the real action
	if control.myWorkListEntry &lt;&gt; origWle then	//tfs42863
		control.setMyWorkListEntry(origWle);	//tfs42863
	endif;
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveTrackedItemShift" id="30aa70c9-2294-4f52-b274-f10e6f707752">
        <updating/>
        <source>trxMoveTrackedItemShift(control : CMIF_MoveController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     January 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
// ---------------------------------------------------------------------------

vars
	swapLC, origSource, origTarget, tmpLC : CM_LocationsController;
	tmpTA : CM_TerminalArea;
	origTI, tmpTI : CM_TrackedItem;
	rtTask : CM_RTQueueTask;
	anFM : CM_FutureMove;
	origLocnStr : String;
	origLCs : CM_LCArray;
	allTIs : CM_TISet;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	origTI := control.myTrackedItem;
	origSource := control.myOriginatingLocation;
	origTarget := control.myToPrimaryLocation;
	
	beginTransaction;
	
	// ### QUEUED SHIFT - use the existing 'change target area code'
	if control.moveMode = QUEUE_MODE then
		create allTIs transient;
		control.allOtherTrackedItems.copy(allTIs);
		allTIs.addNoDuplicates(origTI, false);
		foreach tmpTI in allTIs discreteLock do
		
			anFM := tmpTI.allQueuedFutureMoves[control.moveIndex];
			rtTask := anFM.getRTQueueTask(TASK_PICKUP);
			app.myUtilityUA.utlUpdateRTTaskTargetLocation(origTarget, rtTask,null, _passport);
		endforeach;
		
		return;
	// ### PLANNED SHIFT - refrsh the FM's locations
	elseif control.moveMode = PLANNING_MODE then
		create origLCs transient;
		create allTIs transient;
		control.allOtherTrackedItems.copy(allTIs);
		allTIs.addNoDuplicates(origTI, false);
		control.doUpdateDisplayEvent(control.myToPrimaryLocation);		
		origTarget.CM_GridController.getSpannedToLCsNEW(control);
			
		foreach tmpTI in allTIs discreteLock do

			anFM := tmpTI.allPlannedFutureMoves[control.moveIndex];
			origLocnStr := anFM.getPrimaryLocationId();
			
			if origLCs.isEmpty() then
				anFM.CM_FutureMovePlanned.allLocationsControllers.copy(origLCs);
			endif;
			anFM.resetLocations(control);
			tmpTI.refreshMyFutureLocations(PLANNING_MODE,null);

			app.createEditTransaction(tmpTI,"Planned move shifted from " &amp; origLocnStr &amp; " to " &amp; anFM.getPrimaryLocationId(),null,_passport); // AKB2003DEC added			//20.02.2024 navhl20 #62525
		endforeach;

		foreach tmpLC in origLCs discreteLock do
			control.doUpdateDisplayEvent(tmpLC);
		endforeach;
	
		return;
	endif;

	// ### ACTUAL SHIFT - move items to a swap stack and then to the shift location
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	

	tmpTA := origSource.myTerminalArea;
	swapLC := tmpTA.swapStack.myLocationsController;
	
	control.setMyToPrimaryLocation(swapLC);
	

	app.myUtilityUA.utlUpdateMoveTrackedItem(control, _passport);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	
	if _passport.allWarnings.size = 0 or  _passport.warningsAcknowledged then
		control.setMyOriginatingLocation(swapLC);
		control.setMyToPrimaryLocation(origTarget);
		control.setMyTrackedItem(origTI);
		
		app.myUtilityUA.utlUpdateMoveTrackedItem(control, _passport);
	endif;
	if _passport.noErrors then
		_passport.doDeferredUpdates();	
	endif;

epilog
	
	self.finaliseActivityWithPassport(_passport);

	// This is incase of a warning. Leave here incase transaction is aborted
	control.setMyOriginatingLocation(origSource);
	control.setMyToPrimaryLocation(origTarget);
	control.setMyTrackedItem(origTI);
	delete origLCs;
	delete allTIs;
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveTrackedItems" id="8a1fb7c2-c3a9-4c62-bf27-6f98f6b6e3d0">
        <updating/>
        <source>trxMoveTrackedItems(_tis : CM_TISet; _control : CMIF_MoveController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 Oct 2024  navma1 		MTN-33231 MTN - Enable Deferred Updates For Train and Wagon Events 
// ---------------------------------------------------------------------------
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate 		  := true;
	_passport.useEventDeferUpdate		  := true;		//25.10.2024 navma1 #MTN-33231

	beginTransaction;

	app.myUtilityUA.utlUpdateMoveTrackedItems(_tis, _control, _passport);

	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveTrackedItemsAssignToJob" id="522a4533-8902-4e3e-abea-ced48d338e20">
        <updating/>
        <source>trxMoveTrackedItemsAssignToJob(_tis : CM_TIArray; _lcs : CM_LCArray;_moveControl : CMIF_MoveController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2005 By Andrew Bishop cnwab1
//
// Purpose:		Multi TI LOAD to SHIP ONLY
//
// ---------------------------------------------------------------------------
// PAR 27449 changes to  use RORO Requests and ROROLocation Controllers
vars
	oSource, oTarget : CM_LocationsController;
	idx, totTIs	: Integer;
	theTI : CM_TrackedItem;
	aSlotRequest : CM_SlotRequest;
	aVoyReq : CM_VoyageRequest;
	theVJob : CM_VoyageJob;
	allErrors : CM_ErrorSet;
	anFM : CM_FutureMove;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	if _moveControl.moveMode &lt;&gt; PLANNING_MODE then
		return;
	endif;
	
	aSlotRequest := _moveControl.mySlotRequest;
	
	if aSlotRequest &lt;&gt; null then
		theVJob := aSlotRequest.myJob.CM_VoyageJob;
		// we drag drop SOB in LOAD mode. Which means that this slot req is a discharge SOB
		// We need the load Request so that The TI is associated with the load wle and job.
		// null this out
		if aSlotRequest.isSOB then
			return;
		endif;
		if aSlotRequest.isDischarge then
			return;
		endif;
	else	// PAR 27449
		aVoyReq := _moveControl.myVoyageRequest;
		
		if aVoyReq &lt;&gt; null then
			theVJob := aVoyReq.myJob.CM_VoyageJob;
			// we drag drop SOB in LOAD mode. Which means that this slot req is a discharge SOB
			// We need the load Request so that The TI is associated with the load wle and job.
			// null this out
			if aVoyReq.isSoB then
				return;
			endif;
			if aVoyReq.isDischarge then
				return;
			endif;
		endif;
	endif;
	
	
	// ##############################
	// ## normal move no ship stuff
	if aSlotRequest = null and aVoyReq = null then
		return; // ONLY SHIP STUFF
	else
		beginTransaction;
		if theVJob &lt;&gt; null  and not _passport.hasErrorsOrWarnings  then
			idx := 0;
			
			create allErrors transient;
			totTIs := _tis.size;
			foreach theTI in _tis do
				idx := idx + 1;
				if idx &gt; _lcs.size then
					break;
				endif;
				
				_moveControl.setMyTrackedItem(theTI);
				_moveControl.setMyToPrimaryLocation(_lcs[idx]);
				_moveControl.setMyOriginatingLocation(theTI.myPrimaryActualLocation);
				oSource := _moveControl.myOriginatingLocation;
				oTarget := _moveControl.myToPrimaryLocation;		

				if oTarget.isKindOf(CM_SlotController) then
					aSlotRequest := oTarget.CM_SlotController.mySlotRequestLoad;
					_moveControl.mySlotRequest := aSlotRequest;
					_moveControl.myVoyageRequest := null;
					_moveControl.isRehandleMove := aSlotRequest.isRehandle(); // PAR 11600 ADDED AKB2006APR
					_moveControl.setMyWorkListEntry(aSlotRequest.allWorkListEntries.first);  // PAR 11267
				elseif oTarget.isKindOf(CM_VoyageROROController) then
					aVoyReq := oTarget.CM_VoyageROROController.myRORORequestLoad;
					_moveControl.mySlotRequest := null;
					_moveControl.myVoyageRequest := aVoyReq;
					_moveControl.isRehandleMove := aVoyReq.isRehandle;
					_moveControl.setMyWorkListEntry(aVoyReq.getFirstUnusedWLE()); 

				
				endif;
				// ### 742 testing. Setting the from location to be the current actual location is correct most of the time, 
				//		but when testing planning DLR discharge and then DLR load planning on bulk items, the originating 
				//		location being on ship was wrong as this upsets the Determine Move Type method on the controller.
				if _moveControl.isRehandleMove 
				and _moveControl.moveMode = PLANNING_MODE then
					anFM := theTI.getFutureMoveOfType(PLANNING_MODE, TIFutureMoveDLRDischarge);
					if anFM &lt;&gt; null then
						_moveControl.setMyOriginatingLocation(anFM.CM_FutureMovePlanned.allLocationsControllers.first);
					endif;
				endif;
				app.myUtilityUA.utlUpdateWLEAssignTI(_moveControl, _passport); // &lt;&lt;&lt;&lt; This moves the ti as well AND Assigns to JOB
				//if process.isInTransactionState() then
				if not _passport.hasErrors() then
					if _moveControl.moveMode = PLANNING_MODE then
						if aSlotRequest&lt;&gt; null and (aSlotRequest.isRehandle or aSlotRequest.isSOB) then
							aSlotRequest.setSequenced(true);
						elseif aVoyReq &lt;&gt; null and (aVoyReq.isRehandle or aVoyReq.isSoB) then
							aVoyReq.setSequenced(true);
						endif;
					endif;
				else
					return; //20/08/2010 cnwdz2 25516
				endif;
				
			endforeach;
			if _passport.noErrors then
				if aSlotRequest&lt;&gt; null	then
					aSlotRequest.myJob.setRemarks(null); // PAR 13166
				elseif aVoyReq&lt;&gt; null	then
					aVoyReq.myJob.setRemarks(null); 
				
				endif;
				_passport.doDeferredUpdates();
			else
				return; //20/08/2010 cnwdz2 25516
			endif;
		endif;
		
	endif;


epilog
	self.finaliseActivityWithPassport(_passport);
	delete allErrors;
end;</source>
        <Parameter name="_tis" type="CM_TIArray"/>
        <Parameter name="_lcs" type="CM_LCArray"/>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveTrackedItemsInOrder" id="c3dbeb6a-f355-47f5-bbc8-10283f5cef27">
        <updating/>
        <source>trxMoveTrackedItemsInOrder( _tis : CM_TIArray; _control : CMIF_MoveController input; _plannedLoc : CM_LocationsController input; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 June 2021	navndl1	Initial creation	TFS 51231 - Essentially a copy of 'trxMoveTrackedItems' using an Array
														so that the moves are performed in the order requested.
														But also allows for a plpanned location to be recorded when queuing
														Barge moves to the interchange instead of teh actual on barge location

*/

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate := true;

	beginTransaction;

	app.myUtilityUA.utlUpdateMoveTIsInOrder( _tis, _control, _plannedLoc, _passport );

	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_tis" type="CM_TIArray"/>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_plannedLoc" type="CM_LocationsController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveTrackedItemsMoveContext" id="65888409-722a-463b-acec-bcbdafa6c23f">
        <updating/>
        <source>trxMoveTrackedItemsMoveContext(_tiset: CM_TISet; _movedTiSet : CM_TISet io; _moveController: CMIF_MoveController io; _time, _count : Integer; _isCargoGrp, _load : Boolean; _job : CM_Job; _passport: CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Apr 2024 navma1	ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
02 Apr 2024 navhl20	ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
05 Apr 2024 navhl20 Bug 63513: EUP - Planning the cargo creates extra work list entry
10 Apr 2024 navra1  Bug 63625 Deadlock(1081) and subsequent 1026 while performing bulk discharge
25 Apr 2024 navhl20 ChangeRequest 63857: EUP - Bulk Load ship in retrospective mode
06 May 2024 navma1	Bug 64001: MTN - Dead lock when bulk discharging cargo and bulk editing onsite cargo for the same voyage
08 May 2024 navma1	Bug 64039: MTN - Error 1090 when using Bulk Discharge
17 May 2024 navhl20 Bug 64191: EUP - Lock and Freeze issue
27 May 2024 navhl20 ChangeRequest 64271: EUP - Improve Bulk Discharge - Retrospective Screen
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
28 May 2024 navhl20 Bug 64275: MTN - Work Order Enquiry Screen Freeze due to notifications - Phase 2 
29 May 2024 navhl20 Bug 64345: EUP - Retrospective Partial Discharge not wokring.
14 Oct 2024	navnk30	JIRA 12385: MTN - Work Order Operation Screen notifications restricts user
13 Feb 2025	navhl20 Bug MTN-33648: EUP - Partial move by weight is not working in Work Order Operation screen - Release
19 Feb 2025	navhl20 Bug MTN-19298: MTN - Performance issue when discharging the cargo items on the Complete job form for Ship jobs
17 Mar 2025 navma1  MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/
vars
	progess 		: TimeStampInterval;
	ti				: CM_TrackedItem;
	progressTS  	: TimeStamp;
	count,
	idx				: Integer;
	wle				: CM_WorkListEntry;
	cmifMonitor		: CMIF_Monitor;
	wodtl			: CM_WorkOrderTIDtl;
	request			: CM_Request;
	reserveDetail	: CM_ReserveDetail;
	bulkRelContext	: CM_BulkRelease;
	wleOidsStrToken	: String;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	progressTS := app.actualTimeAppServer();						//19.02.2025 navhl20 #19298
	
	_moveController.suppressCargoGroupDetailUpdate  := not _isCargoGrp;
	_passport.useTIDictDeferUpdate					:= true;		//06.05.2024 navma1 #64001
	_passport.useTITransactionDeferUpdate			:= true;		//23.04.2024 navma1 #64001
	_passport.useOfflineFutureActorDeferUpd			:= true;		//28.05.2024 navma1 #64224
	_passport.useOfflineFutureActorDeferDel			:= true;		//17.03.2025 navma1 #MTN-34120
	_passport.warningsAcknowledged					:= true;		//22.05.2024 navma1	#64191
	_passport.setWarningsIgnored(true);								//23.05.2024 navma1 #64224

	beginTransaction;
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	
	if _moveController.myVoyageWPJob &lt;&gt; null then					//17.05.2024 navhl20 #64191
		_moveController.myVoyageWPJob.setPlannedLocation(_moveController.myToPrimaryLocation);
		_moveController.myVoyageWPJob.causeEvent(Voyage_WO_Bulk_Move_Started, false, null);		//14.10.2024 navnk30 JIRA #12385
	endif;
	
	foreach ti in _tiset do
		idx := idx + 1;
		
		if _load then												//25.05.2024 navhl20 #63857
			if ti.isOnShip then
				continue;
			endif;
			
			wle := ti.getIncompleteReleaseWle();
			
			if wle = null and _job &lt;&gt; null then
				wle := _job.getFirstWle();
			endif;
		else
			if ti.isOnSite then
				continue;
			endif;
			
			wle := ti.getIncompleteReceiveWle();
		endif;
		
		//08.05.2024 navma1 #64039
		_moveController.setMyTrackedItem(ti);

		if wle &lt;&gt;  null then
			_moveController.setMyWorkListEntry(wle);
			if  wle.locationTarget &lt;&gt; null and _moveController.myToPrimaryLocationString &lt;&gt; wle.locationTarget then		//05.04.2024 navhl20 #63513
				_moveController.priority := 999;
			endif;
		endif;
	
		app.myUtilityUA.utlUpdateMoveTrackedItem(_moveController, _passport);
		
		//navra1 - BUG 63625 - 10th Apr 2024 - start
		//TODO: The list of tis that were skipped are listed in the log file, but it would be good to add it in a pop-up in the screen and let the user know
		if _passport.hasErrors() then
			if not process.isInTransactionState() then
				beginTransaction;
			endif;
			
			continue;
		endif;
		//navra1 - BUG 63625 - 10th Apr 2024 - end
		
		progess := app.actualTimeAppServer() - progressTS;											//19.02.2025 navhl20 #19298
		
		count := count + 1;
		
		if _time &lt;&gt; null and progess.getMilliseconds &gt;= _time then
			
			if cmifMonitor &lt;&gt; null and not app.isSpecial then										//27.05.2024 navhl20 #64271						
				cmifMonitor.partsDone := idx;
				cmifMonitor.updateProgress('Bulk Cargo Move', cmifMonitor.partsInJob, cmifMonitor.partsDone);
				if (cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
					break;
				endif;
			endif;
		
			_passport.doDeferredUpdates();
			
			_passport.useTIDictDeferUpdate			:= true;		//23.04.2024 navma1 
			_passport.useTITransactionDeferUpdate	:= true;		//23.04.2024 navma1 
			_passport.useOfflineFutureActorDeferUpd	:= true;		//28.05.2024 navma1 #64224
			_passport.useOfflineFutureActorDeferDel	:= true;		//17.03.2025 navma1 #MTN-34120
			
			//navra1 - BUG 63625 - 10th Apr 2024 - start
			//there could be a deadlock, or a different exception, try continuing with the next ti
			//TODO: The list of tis that were skipped are listed in the log file, but it would be good to add it in a pop-up in the screen and let the user know
			if _passport.hasErrors() then
				if not process.isInTransactionState() then
					beginTransaction;
				endif;
			
				continue;
			endif;
			//navra1 - BUG 63625 - 10th Apr 2024 - end
			
			commitTransaction;
			process.sleep(100);
			progressTS := app.actualTimeAppServer();				//19.02.2025 navhl20 #19298
			beginTransaction;
			
		elseif _count &lt;&gt; 0 and _count = count then
			_passport.doDeferredUpdates();
			_passport.useTIDictDeferUpdate			:= true;		//23.04.2024 navma1 
			_passport.useTITransactionDeferUpdate	:= true;		//23.04.2024 navma1 
			_passport.useOfflineFutureActorDeferUpd	:= true;		//28.05.2024 navma1 #64224
			_passport.useOfflineFutureActorDeferDel	:= true;		//17.03.2025 navma1 #MTN-34120
			//navra1 - BUG 63625 - 10th Apr 2024 - start
			//there could be a deadlock, or a different exception, try continuing with the next ti
			//TODO: The list of tis that were skipped are listed in the log file, but it would be good to add it in a pop-up in the screen and let the user know
			if _passport.hasErrors() then
				if not process.isInTransactionState() then
					beginTransaction;
				endif;
			
				continue;
			endif;
			//navra1 - BUG 63625 - 10th Apr 2024 - end
			
			commitTransaction;
			process.sleep(100);
			count := 0;
			beginTransaction;
			
		endif;
		
		if _load and _tiset.size = 1 then												//29.05.2024 navhl20 #64345
			ti := _moveController.myTrackedItem;
			request 	  := wle.CM_WOReleaseCargoWLE.myRequest;
			reserveDetail := request.myReserveDetail;
			
			if reserveDetail &lt;&gt; null then
				if not reserveDetail.isKindOf( CM_ReserveSelection ) then
					continue;
				endif;
				app.myUtilityUA.utlAddToReserveDetail( reserveDetail, ti, app.myPassport );
				reserveDetail.addTIReleased(ti);
				
				bulkRelContext := reserveDetail.myReserveHeader;
				if bulkRelContext &lt;&gt; null then
					bulkRelContext.addCargoItemMoved(ti);
					bulkRelContext.updateStatus();
				endif;
			endif;
		endif;
		
		if ti.myPrimaryActualLocation = _moveController.myTargetLocation then
			_movedTiSet.tryAdd(ti);
		endif;
	endforeach;
	
	if _moveController.myVoyageWPJob &lt;&gt; null then					//17.05.2024 navhl20 #64191
		_moveController.myVoyageWPJob.setPlannedLocation(null);
	endif;
	
	
	//if _time &gt; progess.getMilliseconds() then						//20.05.2024 navhl20 #64191
	if _time &gt; progess.getMilliseconds() or _tiset.size = 1 then	//13.02.2025 navhl20 #33648
		_passport.doDeferredUpdates();
	endif;
	
	//navra1 - BUG 63625 - 10th Apr 2024 - start
	//there could be a deadlock, or a different exception, get back in trx state for finalize to do its job
	if _passport.hasErrors() then
		//app.writeLog("Errors encountered while performing deferred updates" &amp; CrLf &amp; "Errors were : " &amp; _passport.getAllErrorsAndWarnsFullAsStr(), LogERROR); //08.05.2024 navma1 #64039
		if not process.isInTransactionState() then
			beginTransaction;		//because finalize in the epilog will try to commit the trx
		endif;	
	endif;
	//navra1 - BUG 63625 - 10th Apr 2024 - end
	
	if _passport.noErrors then										//28.05.2024 navhl20 #64275
		wodtl := _moveController.myVoyageWPJob.getMyWorkOrderDtl().CM_WorkOrderTIDtl;
		wodtl.causeEvent(wodtl.getMyTerminal.getTerminalEvent(Event_WODtl_Update), false, wodtl);
	endif;
	
	
	/* //27/05/2025	navkc1 JIRA MTN 34904 - The idea of this was to send a list of WLEs' Oid to the Work Order Operation screen, and add them to the allocated WLE table.
	We found that it is creating a VoyageWLE as the move is completed and the WLE is sent to the WO Operation screen. Instead of having this, we can handle the VoyageWLE that got sent
	to the Work Order Operation form. So this is no longer required.
	if _moveController.myVoyageWPJob &lt;&gt; null then		//14.10.2024 navnk30 JIRA #12385
		_moveController.myVoyageWPJob.causeEvent(Voyage_WO_Bulk_Move_Completed, false, wleOidsStrToken);
	endif;
	*/
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_tiset" type="CM_TISet"/>
        <Parameter name="_movedTiSet" type="CM_TISet" usage="io"/>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="io"/>
        <Parameter name="_time" type="Integer"/>
        <Parameter name="_count" type="Integer"/>
        <Parameter name="_isCargoGrp" type="Boolean"/>
        <Parameter name="_load" type="Boolean"/>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveTrackedItemsNewRailJob" id="89459cd8-4fbd-49b4-b4e1-f319d0d5c4f0">
        <updating/>
        <source>trxMoveTrackedItemsNewRailJob(_wagons : CM_WagonArray input; _tis : CM_TIArray input; _control : CMIF_MoveController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 consw1
//
// Purpose:		Multi TI LOAD to WAGON
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	availableSpace : Integer;
	neededSpace : Integer;
	insufficientSpace : Boolean;
	lc : CM_LocationsController;
	tmpTi : CM_TrackedItem;
	theJob : CM_Job;
	theWLE : CM_WorkListEntry;
	tranArea : String;
	train : CM_Train;
	theWagon : CM_Wagon;
	wagons : CM_WagonArray;
	wagon2wagonMove : Boolean;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	create wagons transient;
	
	_wagons.copy(wagons);
	beginTransaction;

	foreach tmpTi in _tis do
	
		while true do
			theWagon := _wagons.first;
			if theWagon = null then
				break;
			endif;
			lc := theWagon.getNextFreeWagonControllerPN(tmpTi, _control.moveMode);
			if lc = null then
				_wagons.remove(theWagon);
			else
				break;
			endif;
		endwhile;
		
//		lc := _wagon.getNextFreeWagonControllerPN(tmpTi, _control.moveMode);
//		if lc = null then
		if _wagons.isEmpty or theWagon = null then
			if availableSpace = 0 then
				app.raiseCMException2(ERR_NO_SPACE, tmpTi.id, "wagons", null, null);
				return;
			endif;
			insufficientSpace := true;
			break;
		endif;
		_control.setMyTrackedItem(tmpTi);
		_control.setMyToPrimaryLocation(lc);
	
		theWLE := null;
		wagon2wagonMove := false;
		if tmpTi.myPrimaryActualLocation &lt;&gt; null then
			wagon2wagonMove := tmpTi.myPrimaryActualLocation.isWagon() and _control.isWagonMove(); // PAR 21955
		endif;
		
		if _control.moveMode &lt;&gt; REAL_MODE 
		and not wagon2wagonMove then // PAR 21955
			theJob := tmpTi.jobRailRelease;
			
			if theJob = null then
				if _control.isWagonMove() then
					if _control.myToPrimaryLocation.CM_WagonController.myWagon.myRailLine &lt;&gt; null then
						// tranArea can be null if train has not arrived in terminal (has not been confirmed)
						tranArea := _control.myToPrimaryLocation.CM_WagonController.myWagon.myRailLine.myRailArea.id;
/*TFS 54004// ### TFS 51855 24MAY2022 NAVAB1*/					else
/*TFS 54004// ### TFS 51855 24MAY2022 NAVAB1*/						train := _control.myToPrimaryLocation.CM_WagonController.myWagon.myTrainOutwards;
					endif;

//TFS 54004					train := _control.myToPrimaryLocation.CM_WagonController.myWagon.myTrainOutwards; // ### TFS 51855 24MAY2022 NAVAB1 always set the train.
		
					theJob := tmpTi.createRailReleaseJob(tranArea, train);
					if _passport.hasErrors() then
						return;
					endif;
				endif;
			elseif theJob.CM_RailJob.requestNum = null then
				app.raiseCMException2(Alrea_rail_relea_job_canno_co, tmpTi.id, theJob.jobId, null, tmpTi);
			endif;
		endif;
		if _passport.hasErrors() then
			return;
		endif;
			
		if theJob &lt;&gt; null then
			theWLE := theJob.getWLEForTI(tmpTi);
		endif;

		_control.setMyWorkListEntry(theWLE);

		app.myUtilityUA.utlUpdateMoveTrackedItem(_control, _passport);
		if _passport.hasErrors() then
			return;
		endif;
		
		 // ### TFS 54010 28JUN2022 NAVAB1 The job needs to send the train code, this can only be done after the TI is planned to a wagon. see Rail Job.getMyTrain().
		if theJob &lt;&gt; null and app.myPassport.isOpsViewEnabled(theJob.getMyTerminal()) then // ### TFS 54010 28JUN2022 NAVAB1
		
			theJob.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB, theJob);	 // ### TFS 54010 28JUN2022 NAVAB1
		endif;

		availableSpace := availableSpace + 1;
	endforeach;
	
	if insufficientSpace then
		//  Trim back tracked items collection to space available
		neededSpace := _tis.size;
		while _tis.size &gt; availableSpace do
			_tis.removeAt(_tis.size);
		endwhile;
		app.raiseCMWarning3(Warn_wagon_ti_space_limited, availableSpace.asStringJMT(), 
								neededSpace.asStringJMT(), "wagons", null, null, null);
	endif;
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();	
	endif;

epilog
	_wagons.clear;
	wagons.copy(_wagons);
	delete wagons;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_wagons" type="CM_WagonArray" usage="input"/>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveTrackedItemsToPlannedLC" id="516325d7-b1ff-41d9-8192-4ce6842a173e">
        <updating/>
        <source>trxMoveTrackedItemsToPlannedLC(_tis : CM_TISet; _moveMode : Integer; _effectiveTimeStampOverride : TimeStamp; _passport : CM_Passport input; _transferType : Integer) updating;
//-----------------------------------------
//Created: May 2003 By: cnwgd1
//-----------------------------------------
vars
	alertCreated : Boolean;
	control : CMIF_MoveController;
	ti		: CM_TrackedItem;
	newLocn : CM_LocationsController;
begin

//	process.profilerStart();

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);
	
	if _moveMode = PLANNING_MODE then
	//	app.raiseCMException(ERR_INVALID_MODE, null, null);
		app.raiseCMException1( Invalid_move_mode_passed, method.qualifiedName, null, null );	//13 Apr 2021	NDL	TFS 50906
		return;
	endif;


	create control transient;
	control.setMoveMode(_moveMode);	
	control.isSystemMove := true;
	control.transferType := _transferType;
	
	if _moveMode = REAL_MODE and _effectiveTimeStampOverride &lt;&gt; null then
		control.setEffectiveTimeStampOverride(_effectiveTimeStampOverride);
	endif;
	
		
	foreach ti in _tis do
//		self.initialiseActivityWithPassport(_passport, method);
		exclusiveLock(ti);
		if _moveMode = REAL_MODE then	
			newLocn := ti.getPrimaryLocation(QUEUE_MODE);
		endif;
		if newLocn = null then
			newLocn := ti.getPrimaryLocation(PLANNING_MODE);		
		endif;
		if newLocn = null then
			continue;
		endif;
		control.setMyTrackedItem(ti);
		control.setMyToPrimaryLocation(newLocn);
		beginTransaction;		
		app.myUtilityUA.utlUpdateMoveTrackedItem(control, _passport);
		if _passport.noErrors then
			_passport.doDeferredUpdates();
		endif;		
		if _passport.hasErrors then
			alertCreated := true;
			app.convertErrorsWarningsToAlert('Tracked item ' &amp; ti.id &amp; ' could not be moved', _passport.allErrorWarnings);
			app.cmsAbortTransaction();
		else
			app.cmsCommitTransaction(_passport);
		endif;
	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	
	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'Moving Tracked Items', null, self);
	endif;
		
epilog
	delete control;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_effectiveTimeStampOverride" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_transferType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxMoveTrackedItemsToShip" id="7505b7fb-a05f-4796-8fc1-3eaea90e1d1c">
        <updating/>
        <source>trxMoveTrackedItemsToShip(	_trackedItems : CM_TIArray input; _job : CM_VoyageJob input; 
							_slotControllers : CM_LCArray;
							_passport : CM_Passport input) updating;
/*

Date		Who		Reason
16 May 2017	cnwer1	Initial creation TFS 995 refactored out of mobileserverschema

*/

vars

begin
	
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	app.myPassport.setWarningsIgnored(app.myPassport.warningsAcknowledged);
	
	beginTransaction;
	
	app.myUtilityUA.utlMoveTrackedItemsToShip(_trackedItems,_job,_slotControllers,_passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_trackedItems" type="CM_TIArray" usage="input"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_slotControllers" type="CM_LCArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveTrackedItemsWithSplit" id="2a4736ee-b375-47b2-b103-80d24807c17f">
        <updating/>
        <source>trxMoveTrackedItemsWithSplit(_tis : CM_TISet; _errTis : CM_TISet input; 
			_control : CMIF_MoveController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti		: CM_TrackedItem;
//	tiSet	: CM_TISet;
	setNo,
	totStart,
	startTime,
	endTime	: Integer;
	
begin

	self.initialiseActivityWithPassport(_passport, method);
	
	// Multi Transaction trx.  This is the type of transaction where we
	// commitTransaction/beginTransaction multiple times for efficiency
	// and concurrency reasons.  We want to dispatch event notifications
	// after the final commit/abort, as we delay all notifications until
	// then.  They will be sent as immediate notifications.
	app.myEventManager.setMultiTransactionTrx;

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	self.doMoveTrackedItemsWithSplit(_tis, _errTis, _control, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);

	if _control &lt;&gt; null then
		// need to do this once out of transaction state
		_control.doSessionUnlockForAll();	// belts and braces here
	endif;
	
end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_errTis" type="CM_TISet" usage="input"/>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveUserReport" id="e7618da5-7908-41f6-9eec-af973f212df5">
        <updating/>
        <source>trxMoveUserReport(_userReport : CM_MenuUserReport input; _passport : CM_Passport input) updating;

// cnwdvb1 31 October 2002 

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
		
	beginTransaction;

	app.myUtilityUA.utlMoveUserReport(_userReport);

epilog	
