    <JadeMethod name="validateForm" id="c4b8d436-a8ce-486a-b80c-3deac75d441d">
        <source>validateForm():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		03 June 2008 by cnwdad1
//
// Purpose:		Validates the users inputs/selections.
//
// Parameters:	None
//
// Returns:		True if the user inputs/selections are valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controllerObj	: CM_LocationsController;
	errorMsg		: String;
	message			: String;
	
begin
	controllerObj	:=	self.aMyLocationsController;
	
	if controllerObj = null then
		message	:=	"Please enter the Location of the Yard Allocation.";
	endif;
	
	if message &lt;&gt; null then
		errorMsg	:=	errorMsg.appendErrorMsg(message);
		message		:=	null;
	endif;
	
	if self.aAllRemovedAllocations.isEmpty()
	and controllerObj.status = self.getSelectedStatus()
	then
		message	:=	"There are no changes to save.";
	endif;
	
	if message &lt;&gt; null then
		errorMsg	:=	errorMsg.appendErrorMsg(message);
		message		:=	null;
	endif;
	
	if not optAvailable.value and not optClosed.value then
		message	:=	"Please choose whether the Location should be made available or closed.";
	endif;
	
	if message &lt;&gt; null then
		errorMsg	:=	errorMsg.appendErrorMsg(message);
		message		:=	null;
	endif;
	
	if errorMsg = null then
		return true;
	else
		app.msgBox(errorMsg, app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
