    <JadeMethod name="setLogSpecies" id="d22afdcb-b107-4843-9f80-fac01371056e">
        <source>setLogSpecies(_operator : CM_Operator;
			_species : CM_LogSpecies;
			_grade : CM_LogGrade;
			_type : CM_LogType;
			_treatment : CM_LogTreatment;
			_length : CM_LogLength;
			_table : CM_EntryTable input; 
			_speciesCmb : ComboBox input;
			_gradeCmb : ComboBox input; 
			_typeCmb : ComboBox input; 
			_treatmentCmb : ComboBox input; 
			_lengthCmb : ComboBox input			
			);
//--------------------------------------------------------------
//Created: 13 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpCodeGroup	: CM_CodesByCodeDict;
begin
	if _operator &lt;&gt; null then
		tmpCodeGroup := _operator.getAllLogSpecies();
		if _species &lt;&gt; null then
			_table.setValueByControlName(_speciesCmb.name, _species.code);
		else
			_table.setValueByControlName(_speciesCmb.name, null);
		endif;
	endif;
	self.comboBoxAddCode(_speciesCmb, tmpCodeGroup, _species, false);
	
	self.setLogGrade(_species, _grade, _type, _treatment, _length,
					_table, _gradeCmb, _typeCmb, _treatmentCmb, _lengthCmb);
end;</source>
