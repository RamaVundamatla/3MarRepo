    <JadeMethod name="btnStagedTemp_click" id="25a5a3b0-9470-4966-b7d8-e08e501c4061">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStagedTemp_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	lc : CM_LocationsController;
	foundHeight : Integer;
	reserveDetail : CM_ReserveDetail;

begin

	return;	// STW no longer want to do this.... 06 Apr 2016 NDL	TFS 1667
	// which is actually a good thing, because now we use a machine
	//the prior position was on a machine...So we
	//wont know where to take it back to anyway.
/*
	if btn.userObject &lt;&gt; null then
		ti := btn.userObject.CM_TrackedItem;
	endif;
	if ti = null or  ti.priorLocation.trimBlanks = null then
		return;
	endif;
	self.myTerminal.findLocationFromString( ti.priorLocation, true, lc, foundHeight );
	if lc = null then
		return;
	endif;
	
	if self.myBulkRelease.isRoadType and self.myBulkRelease.allReserveDetails.size = 1 then	//08 Dec 2015	NDL	Par 37288
		reserveDetail := self.myBulkRelease.allReserveDetails.first;
	else
		reserveDetail := self.cmbRelItems.listObject.CM_ReserveDetail;
	endif;

	if self.clickStagedButton( ti, lc ) then
	
		self.setupStaged(  reserveDetail );
		self.setupSelected();
		self.setupAvailable( reserveDetail );
	
	endif;
*/
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clickAvailableButton" id="6d5fd2e0-9ece-47ca-9475-95994958c9b8">
        <updating/>
        <source>clickAvailableButton( obj : Object ) updating, protected;
/*

Purpose:			

Parameters:			// we are moving this sucker to the machine controller

Return Value:		

Date		Who		Reason
06 April 2016	cnwndl1	Initial creation	TFS 1667

*/

vars

	ti : CM_TrackedItem;
	moveController : CMIF_MoveController;
	quantity : Integer;
	weight : Decimal [16,4];
	volume : Decimal [16,4];
	errMess : String;
	reserveDetail : CM_ReserveDetail;
	tmpWle : CM_WorkListEntry;
	wle : CM_WorkListEntry;
	amountForm : MOB_HHCargoAmountForm;
	unStage : Boolean;
	futureMove : CM_FutureMove;
	tmpTi : CM_TrackedItem;
	foundAnotherRelease : Boolean;
	warning : String;
	stagedAreas : CM_LCSet;

begin

	if obj &lt;&gt; null then
		ti := obj.CM_TrackedItem;
	endif;
	if ti = null then
		errMess := app.getErrorString(NO_Cargo_found);
	endif;
	if self.myMachine = null then
		errMess := app.getErrorString(Machine_identified);
		return;
	endif;
	if self.myBulkRelease = null then
		errMess := app.getErrorString(No_release_item_selected);
		return;
	endif;
	
	reserveDetail := self.getReserveDetail();
	if reserveDetail = null then
		errMess := app.getErrorString(No_release_item_selected);
		return;
	endif;
	
	if not self.warnedMultiRel then	//05 May 2016	NDL	TFS 1936 (reset if target area changes)
		if self.myTargetLocation &lt;&gt; null then
			foreach tmpTi in self.myTargetLocation.allTrackedItems do
				if not self.myBulkRelease.allTrackedItemsAssigned.includes(tmpTi) then
					foundAnotherRelease := true;
					break;
				endif;
			endforeach;
			if not foundAnotherRelease then
				foreach futureMove in self.myTargetLocation.allQueuedFutureMoves do
					tmpTi := futureMove.getTrackedItem;
					if tmpTi &lt;&gt; null then
						if not self.myBulkRelease.allTrackedItemsAssigned.includes(tmpTi) then
							foundAnotherRelease := true;
							break;
						endif;
					endif;
				endforeach;
			endif;
			if foundAnotherRelease then
				warning := app.getErrorString(Stagi_area_alrea_conta_cargo_a);
			/*	if self.msgBox( warning, app.getErrorString(Continue), MsgBox_Yes_No + MsgBox_Default_Second, true ) &lt;&gt; MsgBox_Return_Yes then
					return;
				endif; */
				if not self.acceptedWarning( warning , self.warnedMultiRel ) then	//05 May 2016	NDL	TFS 1936
					return;
				endif;
			endif;
		endif;
	endif;
	
	if not self.warnedFullyStaged and not self.warnedOverStaged then	//09 May 2016	TFS 1936
		if reserveDetail.isFullyStaged then
			warning := app.getErrorString(Relea_item_alrea_fully_stage_w );
		//	if self.msgBox( warning, app.getErrorString(Continue), MsgBox_Yes_No + MsgBox_Default_Second, true ) &lt;&gt; MsgBox_Return_Yes then
		//		return;
		//	endif;
			if not self.acceptedWarning( warning , self.warnedFullyStaged ) then	//05 May 2016	NDL	TFS 1936
				return;
			endif;
		endif;
	endif;
		
	if ( ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti ) and ( ti.totalQuantity &gt; 1 or not ti.myCargoType.isBulkByQuantity ) then	
		create amountForm transient;
		amountForm.lblInfo.caption := app.getErrorString2( MoveToTarget , ti.id, self.myMachine.id );
		amountForm.myTrackedItem := ti;
		if amountForm.showModal = IDOK then
			if amountForm.byQuantity then
				quantity := amountForm.getQuantity;
			else
				weight := amountForm.getWeightMovedKgs;
			endif;
		else
			return;
		endif;
	endif;
			
	create moveController transient;
	moveController.setMyTrackedItem( ti );
	moveController.setMoveMode( REAL_MODE );
	if ti.isBulkByQuantity then	
		if quantity &lt;&gt; 0 then
			moveController.setQuantity(quantity);
		elseif ti.totalQuantity &lt;&gt; 0 then
			moveController.setQuantity(ti.totalQuantity);
		endif;
	elseif ti.isBulkByWeight or ti.isBulkByVolume then
		if weight &lt;&gt; 0 then
			moveController.setWeight(weight);
		elseif ti.totalWeight &lt;&gt; 0 then
			moveController.setWeight(ti.totalWeight);
		endif;
	endif;
		
	moveController.setMyToPrimaryLocation( self.myMachine.myMachineController );
	//23 Sep 2016	NDL	TFS 2648 / 2001
	if reserveDetail &lt;&gt; null then
		moveController.setMyDocumentActions( reserveDetail.myReserveDetailActions );
	endif;
		
	app.myPassport.setWarningsIgnored(true);
	
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	if app.myPassport.trxCompletedOK then
		self.setupStaged(  reserveDetail );
		self.setupSelected( reserveDetail );
		self.setupAvailable( reserveDetail );
		self.doResizeControls(false);	//08 Jul 2016	NDL	TFS 2275 / 2216
		errMess := null;
	else
		errMess := app.myPassport.getAllErrorsWarningsAsString;	
			
	endif;
	
epilog

	delete moveController;
	delete stagedAreas;

	if errMess &lt;&gt; null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
	else
		//09 Nov 2015	NDL	Par 37152
		self.txtCargoId.text := null;
		self.convertedAltId := null;	//08 Jul 2016	NDL	TFS 2275 / 2216
		self.convertedCargoId := null;	//08 Jul 2016	NDL	TFS 2275 / 2216					
		self.txtCargoId.setFocus();
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="clickSelectedButton" id="296111e8-9d83-415e-b361-3193338538f9">
        <updating/>
        <source>clickSelectedButton( obj : Object; _unSelect : Boolean; _isMultiProcess : Boolean ):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2016	cnwndl1	Initial creation	TFS 1667
					Moving from the machine.
					if _unSelect = true, then was erroneously scanned, and just putting it back (i.e. from machine to yard area).
					if _unSelect = false, then moving to the stage area and assigning to the reserve selection.

*/

vars

	ti : CM_TrackedItem;
	lc : CM_LocationsController;
	foundHeight : Integer;
	
	moveController : CMIF_MoveController;
	quantity : Integer;
	weight : Decimal [16,4];
	volume : Decimal [16,4];
	errMess : String;
	reserveDetail : CM_ReserveDetail;
	tmpWle : CM_WorkListEntry;
	wle : CM_WorkListEntry;
	amountForm : MOB_HHCargoAmountForm;
	futureMove : CM_FutureMove;
	tmpTi : CM_TrackedItem;
	foundAnotherRelease : Boolean;
	warning : String;
	stagedAreas : CM_LCSet;
	reason : String;
	skipAttributes : IntegerArray;	//11 Jan 2016	NDL	TFS 3189/2876

begin

	if obj &lt;&gt; null then
		ti := obj.CM_TrackedItem;
	endif;
	if ti = null then
		errMess := app.getErrorString(NO_Cargo_found);
	endif;

	reserveDetail := self.getReserveDetail();

	if _unSelect then
		
		if ti = null or  ti.priorLocation.trimBlanks = null then
			errMess := app.getErrorString(No_Target_location_found);
			return false;
		endif;
		self.myTerminal.findLocationFromString( ti.priorLocation, true, lc, foundHeight );
		if lc = null then
			errMess := app.getErrorString(No_Target_location_found);
			return false;
		endif;
	
		self.myMobileGenericAgent.moveTI( ti, null, lc, null, false, ti.totalQuantity, ti.totalWeight, null );
		
		
		
	else
		
		if self.myTargetLocation = null then
			errMess := app.getErrorString(No_Target_location_found);
			return false;
		endif;
		if self.myBulkRelease = null then
			errMess := app.getErrorString(No_release_item_selected);
			return false;
		endif;
		
		if reserveDetail = null then
			errMess := app.getErrorString(No_release_item_selected);
			return false;
		endif;
		
		if reserveDetail.isKindOf(CM_ReserveSelection) then
			//11 Jan 2017	NDL	TFS 3189/2876
			if self.myBulkRelease.isShipType then
				//testing against the reserve selection needs to ignore Voyage, Discharge Port and IMEX,
				//because these are unconditionally reset when assigned to the ship release during staging
				create skipAttributes transient;
				skipAttributes.add( YACriteriaType_Voyage );
				skipAttributes.add( YACriteriaType_DischargePort );
				skipAttributes.add( YACriteriaType_ImexStatus );
			endif;
			if not ti.testAgainstReserveSelection( reserveDetail.CM_ReserveSelection, reason, false, skipAttributes ) then
				errMess := app.getErrorString2(Warn_Request_Line_Match, reason, ti.id);
				return false;
			endif;
		endif;
		
		if not self.warnedMultiRel then	//05 May 2016	NDL	TFS 1936 (reset if target area changes)
			foreach tmpTi in self.myTargetLocation.allTrackedItems do
				if not self.myBulkRelease.allTrackedItemsAssigned.includes(tmpTi) then
					foundAnotherRelease := true;
					break;
				endif;
			endforeach;
			if not foundAnotherRelease then
				foreach futureMove in self.myTargetLocation.allQueuedFutureMoves do
					tmpTi := futureMove.getTrackedItem;
					if tmpTi &lt;&gt; null then
						if not self.myBulkRelease.allTrackedItemsAssigned.includes(tmpTi) then
							foundAnotherRelease := true;
							break;
						endif;
					endif;
				endforeach;
			endif;
				
			if foundAnotherRelease then
				warning := app.getErrorString(Stagi_area_alrea_conta_cargo_a);
				//if self.msgBox( warning, app.getErrorString(Continue), MsgBox_Yes_No, true ) &lt;&gt; MsgBox_Return_Yes then
				//09 Nov 2015	NDL	Par 37152
				//if self.msgBox( warning, app.getErrorString(Continue), MsgBox_Yes_No + MsgBox_Default_Second, true ) &lt;&gt; MsgBox_Return_Yes then
				//	return;
				//endif;
				if not self.acceptedWarning( warning , self.warnedMultiRel ) then	//05 May 2016	NDL	TFS 1936
					return false;
				endif;	
			endif;
		endif;
		create stagedAreas transient;
		
		if not self.myBulkRelease.validateStagedToOneArea( stagedAreas ) then		// need this to build the 'stagedAreas' even if 'warnedMultiArea' already set
			if not self.warnedMultiArea and not self.warnedNoPrimArea then	//05 &amp; 09  May 2016	NDL	TFS 1936
				warning := app.getErrorString(Releas_staged_multip_areas_con);
			//	if self.msgBox( warning, app.getErrorString(Continue), MsgBox_Yes_No, true ) &lt;&gt; MsgBox_Return_Yes then
			//		return;
			//	endif;
				if not self.acceptedWarning( warning, self.warnedMultiArea ) then	//05 May 2016	NDL	TFS 1936
					return false;
				endif;
			endif;
		endif;
		
		if not self.warnedNoPrimArea and not self.warnedMultiArea then	//05 &amp; 09 May 2016	NDL	TFS 1936
			if stagedAreas.size = 1 and stagedAreas.first &lt;&gt; self.myTargetLocation then
				warning := app.getErrorString2(This_relea_curre_stage_into_su, stagedAreas.first.getFullId, self.myTargetLocation.getFullId);
			//	if self.msgBox( warning, app.getErrorString(Continue), MsgBox_Yes_No, true ) &lt;&gt; MsgBox_Return_Yes then
			//		return;
			//	endif;
				if not self.acceptedWarning( warning, self.warnedNoPrimArea ) then	//05 May 2016	NDL	TFS 1936
					return false;
				endif;
			endif;
		endif;
			
		if not self.warnedFullyStaged and not self.warnedOverStaged then	//05 &amp; 09 May 2016	TFS 1936
			if reserveDetail.isFullyStaged then
				warning := app.getErrorString(Relea_item_alrea_fully_stage_w );
				//if self.msgBox( warning, app.getErrorString(Continue), MsgBox_Yes_No, true ) &lt;&gt; MsgBox_Return_Yes then
				//09 Nov 2015	NDL	Par 37152
			//	if self.msgBox( warning, app.getErrorString(Continue), MsgBox_Yes_No + MsgBox_Default_Second, true ) &lt;&gt; MsgBox_Return_Yes then
			//		return;
			//	endif;
				if not self.acceptedWarning( warning , self.warnedFullyStaged ) then	//05 May 2016	NDL	TFS 1936
					return false;
				endif;
			endif;
		endif;
			
		if ( ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti ) and ( ti.totalQuantity &gt; 1 or not ti.myCargoType.isBulkByQuantity ) then	//08 Dec 2015	NDL	Par 37288
			create amountForm transient;
			amountForm.lblInfo.caption := app.getErrorString2( MoveToTarget , ti.id, self.myTargetLocation.getFullId );
			amountForm.myTrackedItem := ti;
			if amountForm.showModal = IDOK then
				if amountForm.byQuantity then
					quantity := amountForm.getQuantity;
				else
					weight := amountForm.getWeightMovedKgs;
				endif;
			else
				return false;
			endif;
		endif;
		
		if not self.warnedFullyStaged and not self.warnedOverStaged then	//05 &amp; 09 May 2016	TFS 1936
			if reserveDetail.wouldBeOverStaged( ti, quantity, weight ) then
				warning := app.getErrorString1(Will_OverStage, reserveDetail.getDescription );
			//	if self.msgBox( warning, app.getErrorString(Continue), MsgBox_Yes_No + MsgBox_Default_Second, true ) &lt;&gt; MsgBox_Return_Yes then
			//		return;
			//	endif;
				if not self.acceptedWarning( warning , self.warnedOverStaged ) then	//05 May 2016	NDL	TFS 1936
					return false;
				endif;
			endif;
		endif;
		
		create moveController transient;
		moveController.setMyTrackedItem( ti );
		moveController.setMoveMode( REAL_MODE );
		if ti.isBulkByQuantity then	
			if quantity &lt;&gt; 0 then
				moveController.setQuantity(quantity);
			elseif ti.totalQuantity &lt;&gt; 0 then
				moveController.setQuantity(ti.totalQuantity);
			endif;
		elseif ti.isBulkByWeight or ti.isBulkByVolume then
			if weight &lt;&gt; 0 then
				moveController.setWeight(weight);
			elseif ti.totalWeight &lt;&gt; 0 then
				moveController.setWeight(ti.totalWeight);
			endif;
		endif;
			
		moveController.setMyToPrimaryLocation( self.myTargetLocation );
			
		app.myPassport.setWarningsIgnored(true);
		app.myTrxUA.trxStageCargoForRelease(moveController, reserveDetail, false, app.myPassport);
		
		
	endif;
	if app.myPassport.trxCompletedOK then
		if not _isMultiProcess then	//01 Dec 2017	NDL	TFS 7812	- handled by the calling method when all done
			self.setupStaged(  reserveDetail );
			self.setupSelected( reserveDetail );
			self.setupAvailable( reserveDetail );
			self.doResizeControls(false);	//08 Jul 2016	NDL	TFS 2275 / 2216
		endif;
		errMess := null;
		return true;
	else
		errMess := app.myPassport.getAllErrorsWarningsAsString;	
		return false;	
	endif;
epilog

	delete moveController;
	delete stagedAreas;
	delete skipAttributes;

	if errMess &lt;&gt; null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
	else
		//09 Nov 2015	NDL	Par 37152
		self.txtCargoId.text := null;
		self.convertedAltId := null;	//08 Jul 2016	NDL	TFS 2275 / 2216
		self.convertedCargoId := null;	//08 Jul 2016	NDL	TFS 2275 / 2216					
		self.txtCargoId.setFocus();
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="obj" type="Object"/>
        <Parameter name="_unSelect" type="Boolean"/>
        <Parameter name="_isMultiProcess" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clickStageAll" id="7a69779a-10b3-47eb-ac13-3fe95e85ff7d">
        <updating/>
        <source>clickStageAll() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2016	cnwndl1	Initial creation
// 15 May 2018	jlgrh7 TFS #38573 STWR - "Stage all" function in staging app takes a long time processing items

*/

vars

	tiSet : CM_TISet;
	reserveDetail : CM_ReserveDetail;
	index : Integer;
	menuButton : MOB_Button;
	ti : CM_TrackedItem;

begin

	reserveDetail := self.getReserveDetail();

	create tiSet transient;
	foreach index in 1 to selectedCount do
		menuButton := self.btnSelectedTemp.getControl( index ).MOB_Button;
		if menuButton &lt;&gt; null then
			ti := menuButton.userObject.CM_TrackedItem;
			if ti &lt;&gt; null then						// PAR #37488
				tiSet.addNoDuplicates(ti,false);
			endif;
		endif;
	endforeach;
	
	/*foreach ti in tiSet do																//-TFS38573
		if not self.clickSelectedButton( ti, false, true ) then
			break;
		endif;
	endforeach;*/
	
	//+TFS38573 Whole Set in one transaction
	self.doStageAll(reserveDetail, tiSet);
	
	
	self.setupStaged(  reserveDetail );
	self.setupSelected( reserveDetail );
	self.setupAvailable( reserveDetail );
	self.doResizeControls(false);	//01 Dec 2017	NDL	TFS 7812

epilog

	delete tiSet;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clickStagedButton" id="900e72fc-a12f-4d77-b8db-62e69f867ec8">
        <updating/>
        <source>clickStagedButton( obj : Object; _toLocn : CM_LocationsController ):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation - Un stages cargo

*/

vars

	ti : CM_TrackedItem;
	moveController : CMIF_MoveController;
	quantity : Integer;
	weight : Decimal [16,4];
	volume : Decimal [16,4];
	errMess : String;
	reserveDetail : CM_ReserveDetail;
	tmpWle : CM_WorkListEntry;
	wle : CM_WorkListEntry;
	amountForm : MOB_HHCargoAmountForm;
	unStage : Boolean;
	futureMove : CM_FutureMove;
	tmpTi : CM_TrackedItem;
	foundAnotherRelease : Boolean;
	warning : String;
	stagedAreas : CM_LCSet;

begin

	return false;  //Unstaging no longer required.
/*
	if obj &lt;&gt; null then
		ti := obj.CM_TrackedItem;
	endif;
	if ti = null then
		errMess := app.getErrorString(NO_Cargo_found);
	endif;
	if _toLocn = null then
		errMess := app.getErrorString(No_Target_location_found);
		return false;
	endif;
	if self.myBulkRelease = null then
		errMess := app.getErrorString(No_release_item_selected);
		return false;
	endif;
	
	if self.myBulkRelease.isRoadType and self.myBulkRelease.allReserveDetails.size = 1 then
		reserveDetail := self.myBulkRelease.allReserveDetails.first;
	else
		reserveDetail := self.cmbRelItems.listObject.CM_ReserveDetail;
	endif;
	
	if reserveDetail = null then
		errMess := app.getErrorString(No_release_item_selected);
		return false;
	endif;
	
	unStage := true;
	
//	if ( ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti ) and ti.totalQuantity &gt; 1 then	//09 Nov 2015	NDL	Par 37152
	if ( ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti ) and ( ti.totalQuantity &gt; 1 or not ti.myCargoType.isBulkByQuantity ) then	//08 Dec 2015	NDL	Par 37288
		create amountForm transient;
		amountForm.lblInfo.caption := app.getErrorString2( MoveToTarget , ti.id, _toLocn.getFullId );
		amountForm.myTrackedItem := ti;
		if amountForm.showModal = IDOK then
			if amountForm.byQuantity then
				quantity := amountForm.getQuantity;
			else
				weight := amountForm.getWeightMovedKgs;
			endif;
		else
			return false;
		endif;
	endif;
	
		
	create moveController transient;
	moveController.setMyTrackedItem( ti );
	moveController.setMoveMode( REAL_MODE );
	if ti.isBulkByQuantity then	
		if quantity &lt;&gt; 0 then
			moveController.setQuantity(quantity);
		elseif ti.totalQuantity &lt;&gt; 0 then
			moveController.setQuantity(ti.totalQuantity);
		endif;
	elseif ti.isBulkByWeight or ti.isBulkByVolume then
		if weight &lt;&gt; 0 then
			moveController.setWeight(weight);
		elseif ti.totalWeight &lt;&gt; 0 then
			moveController.setWeight(ti.totalWeight);
		endif;
	endif;
		
	moveController.setMyToPrimaryLocation( _toLocn );
		
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxStageCargoForRelease(moveController, reserveDetail, unStage, app.myPassport);
	
	if app.myPassport.trxCompletedOK then
		errMess := null;
		return true;
	else
		errMess := app.myPassport.getAllErrorsWarningsAsString;	
		return false;
	endif;
*/	
epilog
/*
	delete moveController;
	delete stagedAreas;

	if errMess &lt;&gt; null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
	else
		//09 Nov 2015	NDL	Par 37152
		self.txtCargoId.text := null;
		self.txtCargoId.setFocus();
	endif;
*/
end;</source>
        <access>protected</access>
        <Parameter name="obj" type="Object"/>
        <Parameter name="_toLocn" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cmbRelItems_change" id="582af6e4-0b1e-4932-bbe8-bf0190507a58">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbRelItems_change(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation

*/

vars

	obj : Object;
	reserveDetail : CM_ReserveDetail;

begin

	if self.cmbRelItems.listIndex &gt; 0 then
		obj := self.cmbRelItems.itemObject[self.cmbRelItems.listIndex];
		if obj &lt;&gt; null then
			reserveDetail := obj.CM_ReserveDetail;
		endif;
	endif;

	self.setupStaged(  reserveDetail );
	self.setupSelected( reserveDetail );
	self.setupAvailable( reserveDetail );
	
	 //21 Sep 2016	NDL	TFS 2647 / 2001
	// if reserveDetail &lt;&gt; null and reserveDetail.myReserveDetailActions &lt;&gt; null then
	//	self.btnDocActions.visible := reserveDetail.myReserveDetailActions.hasActions();
	//endif;
	self.btnDocActions.visible := false;
	if self.myBulkRelease &lt;&gt; null then
		foreach reserveDetail in self.myBulkRelease.allReserveDetails do
			if reserveDetail &lt;&gt; null and reserveDetail.myReserveDetailActions &lt;&gt; null then
				if reserveDetail.myReserveDetailActions.hasActions() then
					self.btnDocActions.visible := true;
					break;
				endif;
			endif;
		endforeach;
		//27 Jan 2017	NDL	TFS 3157
		if not self.btnDocActions.visible then
			foreach reserveDetail in self.myBulkRelease.allReservePackingChildren do
				if reserveDetail &lt;&gt; null and reserveDetail.myReserveDetailActions &lt;&gt; null then
					if reserveDetail.myReserveDetailActions.hasActions() then
						self.btnDocActions.visible := true;
						break;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	
	self.doResizeControls(true);
	
	self.txtCargoId.setFocus();
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbRelItems_click" id="8d22228b-1d55-4466-b9c9-45d4034197eb">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbRelItems_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation

*/

vars

	obj : Object;
	reserveDetail : CM_ReserveDetail;

begin

	if self.cmbRelItems.listIndex &gt; 0 then
		obj := self.cmbRelItems.itemObject[self.cmbRelItems.listIndex];
		if obj &lt;&gt; null then
			reserveDetail := obj.CM_ReserveDetail;
		endif;
	endif;

	self.setupStaged(  reserveDetail );
	self.setupSelected( reserveDetail );
	self.setupAvailable( reserveDetail );
	
	 //21 Sep 2016	NDL	TFS 2647 / 2001
	// if reserveDetail &lt;&gt; null and reserveDetail.myReserveDetailActions &lt;&gt; null then
	//	self.btnDocActions.visible := reserveDetail.myReserveDetailActions.hasActions();
	//endif;
	self.btnDocActions.visible := false;
	if self.myBulkRelease &lt;&gt; null then
		foreach reserveDetail in self.myBulkRelease.allReserveDetails do
			if reserveDetail &lt;&gt; null and reserveDetail.myReserveDetailActions &lt;&gt; null then
				if reserveDetail.myReserveDetailActions.hasActions() then
					self.btnDocActions.visible := true;
					break;
				endif;
			endif;
		endforeach;
		//27 Jan 2017	NDL	TFS 3157
		if not self.btnDocActions.visible then
			foreach reserveDetail in self.myBulkRelease.allReservePackingChildren do
				if reserveDetail &lt;&gt; null and reserveDetail.myReserveDetailActions &lt;&gt; null then
					if reserveDetail.myReserveDetailActions.hasActions() then
						self.btnDocActions.visible := true;
						break;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	
	self.doResizeControls(true);
	
	self.txtCargoId.setFocus();
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
