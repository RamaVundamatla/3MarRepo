	expectedEdition : Integer;
	aTA : CM_TerminalArea;
begin

	self.initialiseActivity();

	_prxTerminalSubArea.raiseExceptionIfNotProxy(method);
	_prxTerminalSubArea.pxyGetRealObjectAndEdition(realTermSubArea, expectedEdition);

	if realTermSubArea = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TerminalSubArea.name, null, null);
		return;
	endif;

	if expectedEdition &lt; 1 then
		app.raiseCMException2(ExpectedEditionInvalid, expectedEdition.String, method.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
