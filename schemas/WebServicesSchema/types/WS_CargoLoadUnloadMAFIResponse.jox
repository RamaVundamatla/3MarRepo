    <JadeMethod name="setDetailsFromMAFI" id="c68134f9-6ae8-40ad-b34d-de80e0b5310d">
        <updating/>
        <source>setDetailsFromMAFI(_mafi : CM_TILC) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2023	jlier1	Initial creation 61160

*/

vars

begin
	if _mafi  = null then
		return;
	endif;
	self.weightLoaded:= app.getWeightForDefaultDisplay(_mafi.weightCargo);
	self.contentsStatus:=_mafi.getContentsStatus;
	self.contentsStatusDesc:=_mafi.getContentsStatusDesc(true);
epilog

end;</source>
        <Parameter name="_mafi" type="CM_TILC"/>
    </JadeMethod>
