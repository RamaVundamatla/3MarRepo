    <JadeMethod name="validateConsignee" id="cdc4161b-b379-436b-acb0-f06d5750b587">
        <source>validateConsignee(pUserObject : Object) protected;
// ---------------------------------------------------------------------------
// Created:     15 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/07/2013	cnwdap1		PAR #30344 CCMS GTL 2226 Consignee is required if new terminal config flag is set
// ---------------------------------------------------------------------------
vars
	tmpConsignee	: CM_ConsigneeConsignor;
	
begin
	if self.isReceipt then
		return;
	endif;
	if self.consignee = null then
		// PAR #30344 if terminal config flag set, raise an error							// PAR #30344
		if self.myTerminal.getConfig(GateOutConsigneeReqd).Boolean then						// PAR #30344
			app.raiseCMException(Consignee_reqd_for_release, ETRow_Consignee, pUserObject);	// PAR #30344
		endif;																				// PAR #30344
		return;
	endif;
	
	if not app.myRoot.getConfig(Consignor_ee_AsText).Boolean then // dh 5/9/2008 for APM changes - made this coinditional on config
		tmpConsignee := app.myRoot.allConsigneeConsignors[self.consignee];
		if tmpConsignee = null then
			app.raiseCMException1(ERR_INVALID_CONSIGN, self.consignee, ETRow_Consignee, pUserObject);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
</Class>
