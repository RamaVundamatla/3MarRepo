epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doReadUntil" id="369ef348-7f23-4665-ae46-6452e0b1a1e2">
        <source>doReadUntil();
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	data,
		delimiter: Binary;
	delimiterStr : String;
begin
	if self.txtBuffer.text.Integer = null then
		app.msgBox("Read buffer must be &gt; 0","Read Buffer", MsgBox_OK_Only);
		return;
	endif;
	if self.txtDelimiter.text = null and self.cmbSpecial.index = -1 then
		app.msgBox("Delimter can't be null","Read Delimiter", MsgBox_OK_Only);
		return;
	endif;
	if self.txtDelimiter.text &lt;&gt; null then
		delimiter:=self.txtDelimiter.text.asANSI(0);// 14/3/16  cnwns1 PAR 36286 unicode version
	else
		delimiter:=self.getSpecialDelimter;
		
	endif;
	
	data:=self.myConnection.readUntil(delimiter ,self.txtBuffer.text.Integer);

	self.txtWrite.text:=data.ansiToString();// 14/3/16  cnwns1 PAR 36286 unicode version
	self.txtWrite.setFocus;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doWrite" id="d953ea1c-3b8d-4117-b4b2-5619080c6030">
        <source>doWrite();
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if txtWrite.text = null then
		app.msgBox("You must input something to write","Write",MsgBox_OK_Only);
		return;
	endif;
	
	self.myConnection.writeBinary(txtWrite.text.asANSI(0));// 14/3/16  cnwns1 PAR 36286 unicode version
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getSpecialDelimter" id="4b73f910-272c-4645-b545-c6a24a415983">
        <source>getSpecialDelimter() : Binary;
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	delimiterStr : String;
begin
	delimiterStr:=self.cmbSpecial.itemText[cmbSpecial.listIndex];

	if delimiterStr = EOL then
		return EOLBinary;
	endif;
epilog

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="load" id="41cd1c38-f663-4aea-a1f7-1da59d00c287">
