    <JadeMethod name="getFirstAvailableExitLane" id="29442101-f579-4604-ab46-2c5623a895a2">
        <source>getFirstAvailableExitLane( gate : CM_Gate ) : CM_GateAreaLaneController;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	iter : Iterator;
	laneColl : CM_ObjectArray;
	gateAreaUsage : CM_GateAreaUsage;
	gateArea : CM_GateArea;
	obj : Object;
	glc	: CM_GateAreaLaneController;
	
begin
	//all outward gate areas.
	create laneColl transient;
	iter := gate.allGateAreas_OUT.createIterator;
	while iter.next( gateAreaUsage ) do
		gateArea := gateAreaUsage.myGateArea;
		if gateArea &lt;&gt; null then
			laneColl.clear();
			gateArea.CM_GateArea.getAllLaneControllers (laneColl);
			foreach obj in laneColl discreteLock do
				glc	:= obj.CM_GateAreaLaneController;
				if glc.isUnavailable then
					continue;
				endif;
				if glc.laneDirection &lt;&gt; CM_GateAreaLaneController.Is_Out_Lane then
					continue;
				endif;
				if glc.hasVehicles then
					continue;
				endif;
				return glc;
			endforeach;
		endif;
	endwhile;
	
	return null;
	
epilog

	delete laneColl;
	delete iter;
	
end;</source>
        <Parameter name="gate" type="CM_Gate"/>
        <ReturnType type="CM_GateAreaLaneController"/>
    </JadeMethod>
