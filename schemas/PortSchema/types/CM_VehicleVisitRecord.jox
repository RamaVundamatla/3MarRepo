    <JadeMethod name="getFirstTrackedItemCommodity" id="85450099-f061-4273-85cc-29a1cf798407">
        <source>getFirstTrackedItemCommodity() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2022	navam1	Initial creation 
TFS 53176, AjitM, navam1

*/

vars
	gateEntity 	: CMGTE_Entity;		
	ti 			: CM_TrackedItem;
begin

	if self.allReceivedTrackedItems.size &gt; 0 then
		ti := self.allReceivedTrackedItems.first;
		
	elseif self.allReleasedTrackedItems.size &gt; 0 then	
		ti := self.allReleasedTrackedItems.first;		
		
	elseif self.allGateEntities.size &gt; 0 then
		foreach gateEntity in self.allGateEntities do
			if gateEntity.isRelease() and gateEntity.CMGTE_Release.myTrackedItem &lt;&gt; null and not gateEntity.isTrailer() then
				ti := gateEntity.CMGTE_Release.myTrackedItem;
				break;
			elseif not gateEntity.isTrailer() and not gateEntity.isRecievalByType() and not gateEntity.isRelease() and gateEntity.CMGTE_Receival.myTrackedItem &lt;&gt; null then
				ti := gateEntity.CMGTE_Receival.myTrackedItem;
				break;
			endif;
		endforeach;
		
	else
		ti := null;
		
	endif;
	
	if ti &lt;&gt; null and ti.commodity &lt;&gt; null then
		return ti.commodity;
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstTrackedItemId" id="4e38657a-6c3c-4ac3-b3ce-826c4742e9bd">
        <source>getFirstTrackedItemId() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 January 2017	cnwns1	Initial creation

*/

vars

begin
    if self.allReceivedTrackedItems.size &gt; 0 then
		return self.allReceivedTrackedItems.first.id;
	elseif self.allGateEntities.size &gt; 0  and self.allGateEntities.first.isRelease then
		return self.allGateEntities.first.CMGTE_Release.myTrackedItem.id;
	else
		return null;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstTrackedItemObj" id="8ee3eb38-378f-42d2-8715-e2d1434a91e4">
        <source>getFirstTrackedItemObj() : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/05/2024	navkc1 Bug 64295: FR - 53715 - Customs clearance - Road exit Cargo review Option

*/

vars

begin
    if self.allReceivedTrackedItems.size &gt; 0 then
		return self.allReceivedTrackedItems.first;
	elseif self.allGateEntities.size &gt; 0  and self.allGateEntities.first.isRelease then
