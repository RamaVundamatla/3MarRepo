    <JadeMethod name="doDeleteRequest" id="2f25baad-0733-4ae6-a1b9-0348f96d7de8">
        <updating/>
        <source>doDeleteRequest() updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 25 June 2007
//
//----------------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	result,
	row : Integer;
	wle : CM_WorkListEntry;
	tbl : CM_DataTable;
begin
  	app.mousePointer := MousePointer_HourGlass;
  	
	if self.myCurrentWLE = null then
		return;
	else
		wle := self.myCurrentWLE;
	endif;
	
	if wle.isReceipt then
		tbl := self.tblReceivals;
	else
		tbl := self.tblReleases;
	endif;
	
	tbl.findObjectInRow(wle, row);
	
	if row &lt;&gt; null then
	endif;
	
	while true do
		app.myTrxDA.trxDeleteJobEntry(wle, null, app.myPassport); // cnwrd1 par 22624 3.5.2010
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			
			break;
		else
			result := app.showErrorWarningDialog('Road Ops', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

	if app.myPassport.trxCompletedOK then
		tbl.deleteRow(row);
		self.myCurrentWLE := null;
	endif;
	
epilog
	app.mousePointer := MousePointer_Default;  	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMoveTrackedItem" id="1ca5c3e9-2cec-42f0-9c55-bfb175a0fba3">
        <updating/>
        <source>doMoveTrackedItem(_toLocation : CM_LocationsController ; _wle : CM_WorkListEntry) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 27 June 2007
//
//----------------------------------------------------------------------

vars
	moveController	: CMIF_MoveController;
	result		: Integer;
begin

	if app.myMoveController = null then
		return;
	endif;

	if _toLocation = null then
		app.raiseCMException1(INVALID_MOVE_REQUEST, 'No Target Location found.', null, null);	
		return;
	endif;

	moveController := app.myMoveController;
	
	if _wle &lt;&gt; null then
		moveController.setMyWorkListEntry(_wle);
		//moveController.setJobForMove(_wle.job);
	endif;

	moveController.setMyToPrimaryLocation(_toLocation);
		
	while true do
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	app.myMoveController := null;
	if moveController &lt;&gt; null then
		delete moveController;
	endif;
	self.tblReceivals.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="doQueryRowColumnChange" id="c4ee12bb-653f-4413-8a56-5956efd866e7">
        <updating/>
        <source>doQueryRowColumnChange(table: Table input; newRow: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theRow,
	cols,
	idx,
	col : Integer;
begin

	theRow := table.row;

	cols := table.columns;
	col := table.column+1;
	
	if col &gt; cols then
		//end of row
		foreach idx in theRow+1 to table.rows do
			if table.accessRow(idx).enabled then
				return;
			endif;
		endforeach;				
		//self.doDetailAdd();
		return;
	endif;		
	
	while col &lt;= cols do
		if table.accessCell(theRow, col).enabled then
			break;
		endif;
		if col+1 &gt; cols then
			foreach idx in theRow+1 to table.rows do
				if table.accessRow(idx).enabled then
					return;
				endif;
			endforeach;		
			//end of row
			//self.doDetailAdd();
			return;
		endif;
		col := col+1;			
	endwhile;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="4cd9a2a8-0637-4803-ae4c-3c68a6d6f719">
        <updating/>
        <source>doSave() : Boolean updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 19 June 2007
//
//----------------------------------------------------------------------

vars
	result 			:  Integer;
	ti 				: CM_TrackedItem;
	wle 			: CM_WorkListEntry;
	release 		: CMIF_ReleaseById;
	wleArr 			: CM_WLEArray;
	tiArr 			: CM_TIArray;
	cmifArray 		: CM_ObjectArray;
	printReceipt 	: Boolean;
	copies 			: Integer;
	visit 			: CM_VehicleVisitRecord;
	preview 		: Boolean;
begin
	if not app.myCurrentUserCan(self.myTerminal, PmGteRoadExitUpdate) then
		app.msgBox("You do not have permission to perform this task", "Road Exit", MsgBox_OK_Only);
		return false;
	endif;
	
	if not global.isValidObject(self.myJob) then // PAR 16251 testing 761 beta, open this screen twice and save in both 
		return true;
	endif;
	//CHECK IF WE WANT TO PRINT A RECEIPT FOR THE DEPARTURE.
	printReceipt := self.chkPrintReceipt.value;
	preview := self.chkPrintPreview.value;
	copies := self.cmbCopies.text.Integer;
	
	//SETUP CHASSIS AND NEW WLE TO JOB IF REQUIRED
	if self.cmbTrailers.listObject &lt;&gt; null then
		ti := self.cmbTrailers.listObject.CM_TIMaster.getCurrentTi;
		
		//WE HAVE ONE BUT WE NEED TO CHECK THAT IT IS NOT ALREADY IN A RELEASE WORK ENTRY
		if ti &lt;&gt; null and not self.isChassisWorkEntryPresent(ti.CM_TILC) then
			create release transient;
			release.setForTypeChassis(ti.cargoType, ti.id, ti.consignee, ti.consignorVoyageCode, ti.deliveryRelease, self.myJob.getMyTerminal());
		endif;
	endif;
	
	//GET THE USER INPUT VALUES READY TO PASS IN TO THE TRX
	create cmifArray transient;
	self.getWorkEntriesToComplete(cmifArray);
	
	//CHECK WORK ENTRIES HAVE TIS, MOVE THEM IF NECESSARY AND THEN PROCESS EXIT
	while true do
		if self.myJob &lt;&gt; null and global.isValidObject(self.myJob) then
			//GET THE VISIT OBJECT OF THE JOB BEFORE WE DELETE THE JOB IN THE TRX
			visit := self.myJob.CM_RoadJob.myVehicleVisit;
			
			app.myTrxUA.trxUpdateJobInstantComplete(self.myJob.CM_RoadJob, cmifArray, release, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				if visit &lt;&gt; null and printReceipt then
					//visit.printReceipt(copies, preview, self.myTerminal, self.myTerminal.getRoadReceiptReport().String, null, null);
					//12 Dec 2013	NDL	Par 33184
					visit.printRoadReceipt(	copies,	//_copies : Integer;
											preview,	//_printPreview : Boolean;
											null	//_printerLogicalName : String
											);
				endif;
				global.beep;
				return true;
			else
				result := app.showErrorWarningDialog('Road Exit Complete', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and result = IDOK then
					app.myPassport.warningsAcknowledged := true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
			endif;
	
			return false;
		endif;
		break;
	endwhile;
epilog
	if release &lt;&gt; null then
		delete release;
	endif;
	if wleArr &lt;&gt; null then
		delete wleArr;
	endif;
	if tiArr &lt;&gt; null then
		delete tiArr;
	endif;
	
	delete cmifArray;
end;
	</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowColorLegend" id="fe850ac0-86d7-4548-883e-8798856047a1">
        <updating/>
        <source>doShowColorLegend() updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 27 June 2007
//
//----------------------------------------------------------------------

vars
//	cLegend	: CMUI_ColourLegendForm;
	colLegend	: CMUI_ColourLegend;

begin

	create colLegend;
	self.setNavigatorHeading(colLegend.caption); 
	colLegend.centreWindow;

	colLegend.addLegendItem("Unactioned Receipt Job",			CM_Job.Colour_ReceiptUnactioned,		White,				null, false);
	colLegend.addLegendItem("Unactioned Release Job",			CM_Job.Colour_ReleaseUnactioned,				White,				null, false);
	colLegend.addLegendItem("Partially Worked Receipt Job",		CM_Job.Colour_ReceiptPartComplete, White, null, false);
	colLegend.addLegendItem("Partially Worked Release Job",		CM_Job.Colour_ReleasePartComplete,			White,				null, false);
	colLegend.addLegendItem("Completed Receipt Job",			White,				CM_Job.Colour_ReceiptComplete,				null, false);
	colLegend.addLegendItem("Completed Release Job",			White,				CM_Job.Colour_ReleaseComplete, null, false);
	colLegend.addLegendItem("Job is Overstowed",				White,				Red,				null, true);		
	colLegend.addLegendItem("Matched up to a TBA Contaner",		Black,				 LightGreen,		null, false);
	colLegend.addLegendItem("Returned Job",						Black,				Red,				null, false);
	colLegend.addLegendItem("Voyage Job Unassigned",			Black,				ColourYellowDark,	null, false);
	colLegend.addLegendItem("Voyage Job Unassigned",			Black,				ColourYellowLight,	null, false);
	colLegend.addLegendItem("Voyage Job Loaded to Operations",	Black,				CM_VoyageJob.Colour_JobLoaded, null, false);
	colLegend.addLegendItem("Voyage Job Not Loaded to Operations", Black,			CM_VoyageJob.Colour_JobNotLoaded, null, false);
	colLegend.addLegendItem("Ship nonPlan/nonWork Cargo and Log Dockets", Black,	self.colorRow1,		null, false);
	colLegend.addLegendItem("Ship nonPlan/nonWork Cargo and Log Dockets", Black,	self.colorRow2,		null, false);
	colLegend.addLegendItem("Other",							White,				Mauve,				null, false);
	
	colLegend.showModal;


epilog
	delete colLegend;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowHideContextMnuItems" id="1b3a6181-97c7-4617-bc94-2789971499e7">
        <updating/>
        <source>doShowHideContextMnuItems(_table : CM_DataTable) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 21 August 2007
//
//----------------------------------------------------------------------

vars

begin
	if _table.name = self.tblReceivals.name then
