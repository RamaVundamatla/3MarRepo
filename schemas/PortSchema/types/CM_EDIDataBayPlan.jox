    <JadeMethod name="updateParentAndChildFlatRacks" id="eedfe31c-21c0-45a0-8a0f-69174dd3d692">
        <source>updateParentAndChildFlatRacks(_voyage : CM_Voyage; _passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/01/2021	jlgdap1		Initial creation TFS 50553 PNL Handling of Nested Child Cargo in BAPLIE EQA Segment
//
vars
	ediTi : CM_EDITrackedItem;
	ti : CM_EDIBayPlanTI;
	parentTi, childTi : CM_TrackedItem;
	children : CM_TISet;
	eqdCnPos, eqaCnPos : Integer;
	isoType : CM_ISOType;
	id : String;

begin
	create children transient;
	foreach ediTi in self.allEDITrackedItems discreteLock do
		ti := ediTi.CM_EDIBayPlanTI;
		if ti.cargoType &lt;&gt; TI_CargoType_Container then
			continue;
		endif;
		isoType := app.myRoot.allISOTypes[ti.isoType];
		if isoType = null or not isoType.isFlat then
			continue;
		endif;
		
		eqdCnPos := ti.rawEDIData.pos("EQD+CN", 1);
		if eqdCnPos &lt;&gt; null then
			// got a parent, find the children
			children.clear;
			eqaCnPos := null;
			while true do
				eqaCnPos := ti.rawEDIData.pos("EQA+CN", eqaCnPos + 1);
				if eqaCnPos &lt;&gt; null then
					id := ti.rawEDIData[eqaCnPos+7:11];
					childTi := _voyage.allOnshipTIsByCargoTypeId[TI_CargoType_Container, id];
					if childTi &lt;&gt; null then
						children.add(childTi);
					endif;
				else
					break;
				endif;
			endwhile;
			
			parentTi := _voyage.allOnshipTIsByCargoTypeId[TI_CargoType_Container, ti.id];
			if parentTi &lt;&gt; null then
				parentTi.setChildrenForCreate(children, _passport);
			endif;
		endif;
		
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
	
epilog
	delete children;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForWrite" id="e66610bd-136b-4f0e-a3ff-7016073bf5c0">
        <source>validateForWrite();
//----------------------------------------------------------------
//	Created:	19 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	voyage	: CM_Voyage;
begin
	inheritMethod();
	
	voyage := self.ediConfig.myTerminal.lookupVoyage (self.voyageCode, null, false);
	
	if voyage = null then
		app.raiseCMException1(ERR_INVALID_VALUE, 'Voyage code', 'voyageCode', null);
	endif; 


end;</source>
    </JadeMethod>
    <JadeMethod name="verifyEDIData" id="7c6f149f-c6f4-4075-b884-a70d605f45e1">
        <updating/>
        <source>verifyEDIData(): Integer updating;


vars
	voyage		: CM_Voyage;
begin
	
	on Exception do validationExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);

	voyage 	:= self.getMyTerminal().lookupVoyage(self.voyageCode, null, true);
	if voyage = null then
		
		app.raiseCMException1(Voyage_code_invalid, voyageCode, "Voyage Code", self);
	else
		if voyage.archived then
			app.raiseCMException1(Voyage_already_archived,voyageCode,"Voyage Code", self);
		elseif voyage.hasDeparted  then
			//epr par 37090 23/10/15 CCMS 2538 EDI Admin Improvements
			if self.getMyTerminal.getConfig(EdiAddVoyageDepartError).Boolean then	
				app.raiseCMException1(Voyage_departed,voyageCode,"Voyage Code", self);
			endif;
		endif;
		
	endif;

epilog
	return app.myPassport.allErrors.size;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="e5dc8013-e289-4c89-a602-40e1133bdba9">
        <updating/>
        <source>verifyEDIDataTIs(_passport : CM_Passport input): Integer updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwrs1
/* Changes

Date		Name	TFS#		Description
============================================================================
18 Apr 2013	cnwcs5		par 31255 - arm exception handle for errors that are trapped in context that has no ediT
24 Apr 2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
08 Oct 2015	cnwrs1		Par 36863 - make EDI consistant times when refreshing progress bar
13 May 2016	cnwns1		TFS 488 - Multi Timezone Support
03 Sep 2019 jlgka1 		TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1		TFS 50204	Refactor progress updates to superclass method
============================================================================*/
vars
	proxyContainer		: CM_TrackedItem;
	ediTI				: CM_EDITrackedItem;
	updCntrl			: CMIF_TIUpdateController;
	terminal			: CM_Terminal;
	newTIs				: CM_EDITIById;	//for duplicate checking
	totalTIs, 
	tiCount				: Integer;
	passport			: CM_Passport;
	iter				: Iterator;	
	progressTS 			: TimeStamp;
begin
	passport := _passport;
	
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);

	progressTS := app.actualTimeServer();	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	terminal := self.getMyTerminal();
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
	endif;
	
	create newTIs transient;
	

	app.setContinueCMExceptions(true);
	updCntrl := app.createTIUpdateControl(TI_UPDMODE_BAYPLAN, null, null);
	
	totalTIs := self.allEDITrackedItems.size;
	self.updateProgress(progressTS, "Verifying cargo", totalTIs, 0, true, _passport);
	
	iter := self.allEDITrackedItems.createIterator();

	on CM_Exception do self.xHandlerCMExceptionUserObject (exception, ediTI);	// par 31255
	
	while iter.next(ediTI) do
		tiCount := tiCount + 1;
		self.updateProgress(progressTS, "Verifying cargo", totalTIs, tiCount, false, _passport);

		//check for duplicate
		if newTIs.includesKey(ediTI.id) then
			//error
			app.raiseCMException3(ERR_DUPLICATED_LABEL, 'cargo id', 'EDI tracked item', ediTI.id, 'id', ediTI);
		endif;
		newTIs.add(ediTI);	//add anyway - doop's ok
		
		//only create/delete if we absolutely have to
		if proxyContainer = null then
			proxyContainer := terminal.createTI(ediTI.myCargoType, true);
		elseif proxyContainer.cargoType &lt;&gt; ediTI.myCargoType.id then
			delete proxyContainer;
			proxyContainer := terminal.createTI(ediTI.myCargoType, true);
		else
			proxyContainer.setPxyClear(passport);
		endif;
		
		updCntrl.setMyUserObject(ediTI);
		ediTI.CM_EDIBayPlanTI.setProxy(proxyContainer, updCntrl, passport);
		proxyContainer.validateTrackedItem(updCntrl, passport);

	endwhile;
	
	self.updateProgress(progressTS, "Verifying cargo", totalTIs, tiCount, true, _passport);
	
	return passport.allErrorWarnings.size;
epilog
	delete iter;
	delete newTIs;
	delete updCntrl;
	delete proxyContainer;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="warnOnDBLoad" id="9d3f3d87-fd33-4a88-ba96-c40f2fee711b">
        <source>warnOnDBLoad(_message: String output; _flags: Integer output; _intCancel: Integer output);
//----------------------------------------------------------------
//	Created:	03 October 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	voy		: CM_Voyage;
begin

	voy := self.getVoyageFromCode(self.voyageCode);//getMyVoyage();
	
	if voy = null then
		return;
	endif;
	
// PAR 33644	if voy.isNonPlannedVoyage then
	if voy.isHOLDSorSHIP() then
		//non planned warning
		_message	:= "You are about to create new cargo on-ship for " &amp; voy.code &amp; "." &amp; CrLf &amp; CrLf &amp; app.getErrorString(AreYouSure);
		_flags		:= MsgBox_Yes_No + MsgBox_Question_Mark_Icon;
		_intCancel	:= MsgBox_Return_No;
	endif;
	
end;</source>
        <Parameter name="_message" type="String" usage="output"/>
        <Parameter name="_flags" type="Integer" usage="output"/>
        <Parameter name="_intCancel" type="Integer" usage="output"/>
    </JadeMethod>
</Class>
