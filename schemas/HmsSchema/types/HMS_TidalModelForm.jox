		y := (((_currentArray[int] * _multiplier) * -1) + c);// - highestPlot;
		tbl.drawPoint(int, y, _colour);
		int := int + 1;
	endwhile;
	*/
epilog
	tbl.visible := true;
end;</source>
        <Parameter name="_tidalModel" type="HMS_TidalModelDefinition"/>
