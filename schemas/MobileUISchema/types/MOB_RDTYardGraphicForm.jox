    <JadeMethod name="setupForm" id="f632e2ce-3811-4c3f-849c-265fc3183e8e">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2010	cnwjk3	Initial creation

*/

vars
	height   : Integer;
	terminal : CM_Terminal;
	lcId	 : String;
	lc	     : CM_LocationsController;
	tiSet	 : ObjectSet;
begin
	inheritMethod();
	// This is all temporary, just to get the ball rolling...
	create self.myDrawingController transient;
	
	create tiSet transient;
	
	terminal := self.getTerminal();
	self.myDrawingController.setTerminal(terminal);
	//lcId := 'RAIL01 0106 01';
	lcId := 'JKSTRAD1 0205';
	
	terminal.findLocationFromString(lcId, true, lc, height);


	self.txtLocation.text := lc.getFullId();
	self.mode := self.getConfiguredDefaultView();
	//self.mode := CMIF_RDTDrawElement.MODE_SIDE;
	self.myDrawingController.init(self.mode, self.frmDrawing, self.frmTI, self.frmViewport);
	
	/*
	if lc.myTerminalArea.isKindOf(CM_Rail) then
		self.setDisplayForRail();
	elseif lc.myTerminalArea.isKindOf(CM_StraddleStack) then
		self.setDisplayForStraddle();		
	else		
		self.setDisplayForRTG();
	endif;
	*/
	
	// Temp test
	tiSet.add(terminal.allOnsiteTIsByIdCargoType["KPDX2000010", TI_CargoType_Container]);
	tiSet.add(terminal.allOnsiteTIsByIdCargoType["MAT14090901", TI_CargoType_Container]);
	tiSet.add(terminal.allOnsiteTIsByIdCargoType["DUG09081704", TI_CargoType_Container]);
	tiSet.add(terminal.allOnsiteTIsByIdCargoType["KPDX2000015", TI_CargoType_Container]);
	self.myDrawingController.setHighlightLCs(tiSet);
	//
	
	
	self.myDrawingController.gotoLocationByString(lcId, mode, true);
	self.updateCaption();
epilog
	delete tiSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ab527e22-2638-41ac-9500-f3d8d65d5ef7">
