    <JadeMethod name="addToolbarControls" id="f95299ae-3e3e-4066-b9cd-0bad5ee85874">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	toolbar		: CMUI_Toolbar;
	showCaptions	: Boolean;

begin
	inheritMethod();

	toolbar := self.frmToolBarPopup;
	toolbar.addButton(self.btnPopupClose, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPopupPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPopupEnq, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;

	//============================================================
	// Now setup the Positioning Frame toolbar
	//============================================================

	toolbar := self.frmPosToolbar;
	toolbar.showCaptions := false;
	
	//toolbar.addButton(self.btnFlipHVPos, CMUI_Toolbar.Control_Alignment_Left);
	//toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveTopLeftPs, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveTopRightP, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveBotLeftPs, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveBotRighPs, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.positionToolbarControls();
	toolbar.visible := true;	

end;</source>
        <access>protected</access>
    </JadeMethod>
