    <JadeMethod name="doBaseFormSave" id="b2198a5f-f5fb-4979-8b37-18e6fbc83303">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Date		    Who			Reason
16 June 2010	cnwas3	  ccms 1134

*/

vars	
	
	theReturn : Integer;
	
begin
	
	app.mousePointer := Window.MousePointer_HourGlass;
	
	if self.myCurrentVoyage = null then
		return;
	endif;	

	self.doSaveExtraMoves();	
	
	while true do		
		app.myTrxUA.trxSetVoyageExtraMoveDtls(self.myExtraMoveDtl, app.myPassport);		
		if app.myPassport.trxCompletedOK then
		 	
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Extra move details", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
	//app.msgBox("KPI details for '" &amp; self.myCurrentVoyage.code &amp; "' have been updated.", "KPI Details Update", MsgBox_Information_Icon);	

epilog	
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClearTxtFields" id="3021039c-1013-425a-a192-343232e35fbd">
