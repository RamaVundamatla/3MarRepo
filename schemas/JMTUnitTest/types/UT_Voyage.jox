    <JadeMethod name="tCargoForecastUpdate" id="9a1dc5f4-1cc9-4f2c-88ae-8d7250e34619">
        <source>tCargoForecastUpdate();
/*

Purpose:			Tests that a Cargo Forecast can be updated

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
07 April 2022	navpw1	Initial creation TFS: 53132

*/

constants
	Ref						: String		= UT_DSL.TFS53132;
	TOTALQUANTITY 			: Integer 		= 12;
	TOTALWEIGHT				: Decimal[23,6] = 23.345;
	TOTALVOLUME				: Decimal[23,6] = 24.345;
	
	UPDTOTALQUANTITY 		: Integer 		= 15;
	UPDTOTALWEIGHT			: Decimal[23,6] = 26.345;
	UPDTOTALVOLUME			: Decimal[23,6] = 27.345;
	
	VESSELID				: String 		= "UTVES" &amp; Ref;
	VOYAGEID				: String 		= "UTVOY" &amp; Ref;
vars
	pxyCargoForecast,
	realCargoForecast		: CM_CargoForecast;
	cargoType				: CM_CargoType;
	commodity				: CM_Commodity;
	operator				: CM_Operator;
	
	vessel					: CM_Vessel;
	voyage					: CM_Voyage;
	
	error					: CM_Error;
	cargoTypeCommodityError, 
	imexStatusError,
	totalWeightError		: Boolean;
	mode					: String;
	terminal				: CM_Terminal;
	requiredFields			: String;
	
begin
	terminal := self.getMyTerminal();
	requiredFields := self.setTerminalConfig(CargoForecastReqdFields, ETRow_Quantity &amp; "," &amp; ETRow_Volume &amp; "," &amp; ETRow_Weight).String;
	
	/*
	** Clean Up After Last test
	*/
	// delete voyage
	self.deleteVoyage(VOYAGEID);
	self.assertNoTrxErrorsOrWarnings();
	
	//Delete Vessel
	self.deleteVessel(VESSELID);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	**	Setup Test Update - Normal Happy Day Scenario
	*/
	operator 	:= app.myRoot.allOperators["****"];
	self.assertNotNullMsg(operator, "Operator is null");
	
	cargoType 	:= app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CONT");
	self.assertNotNullMsg(cargoType, "Cargo type is null");
	
	commodity 	:= app.myRoot.allCommodities["GENL"];
	self.assertNotNullMsg(commodity, "Commodity is null");
	
	mode 		:= CM_CargoForecast.Mode_Discharge;
	
	//Create Vessel
	vessel := self.addVesselCellular(VESSELID, operator);
	self.assertNotNull(vessel);
	
	//Create voyage
	voyage 		:= self.addVoyageWithContainerStructur(VOYAGEID, VESSELID, operator.code,  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, "Voyage is null");
	
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, commodity, mode, operator, TOTALQUANTITY, TOTALWEIGHT, TOTALVOLUME, voyage);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Run Test Update - Normal Happy Day Scenario
	*/
	delete pxyCargoForecast;
	
	pxyCargoForecast := app.createUpdateProxy(realCargoForecast).CM_CargoForecast;
	
	pxyCargoForecast.setProxyForUpdate(cargoType, commodity, mode, operator, UPDTOTALQUANTITY, UPDTOTALWEIGHT, UPDTOTALVOLUME, voyage);
	
	app.myTrxUA.trxUpdateCargoForecast(pxyCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Update - Normal Happy Day Scenario
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realCargoForecast.myParent &lt;&gt; null, "Cargo Forecast: Parent Object is null");
	self.assertTrueMsg(realCargoForecast.myCargoType &lt;&gt; null, "Cargo Forecast: Cargo Type Object is null");
	self.assertTrueMsg(realCargoForecast.myCommodity &lt;&gt; null, "Cargo Forecast: Commodity Object is null");
	self.assertTrueMsg(realCargoForecast.mode &lt;&gt; null, "Cargo Forecast: Mode is null");
	self.assertTrueMsg(realCargoForecast.myOperator &lt;&gt; null, "Cargo Forecast: Operator Object is null");
	
	self.assertTrueMsg(realCargoForecast.myParent = voyage, "Cargo Forecast: Parent Object does not match expected parent object");
	self.assertTrueMsg(realCargoForecast.myCargoType = cargoType, "Cargo Forecast: Cargo Type Object does not match expected cargo type");
	self.assertTrueMsg(realCargoForecast.myCommodity = commodity, "Cargo Forecast: Commodity Object does not match expected commodity");
	self.assertTrueMsg(realCargoForecast.mode = mode, "Cargo Forecast: Mode does not match expected mode");
	self.assertTrueMsg(realCargoForecast.myOperator = operator, "Cargo Forecast: Operator Object does not match expected operator");
	
	self.assertTrueMsg(realCargoForecast.totalQuantity = UPDTOTALQUANTITY, "The total quantity on the Cargo Forecast does not match expected value: " &amp; UPDTOTALQUANTITY.asStringJMT());
	self.assertTrueMsg(realCargoForecast.totalWeight = UPDTOTALWEIGHT, "The total weight on the Cargo Forecast does not match expected value: " &amp; UPDTOTALWEIGHT.asStringJMT());
	self.assertTrueMsg(realCargoForecast.totalVolume = UPDTOTALVOLUME, "The total volume on the Cargo Forecast does not match expected value: " &amp; UPDTOTALVOLUME.asStringJMT());
	
	/*
	**	Setup Test Update - Test Mandatory fields not specified gives errors
	*/
	delete pxyCargoForecast;
	
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, commodity, mode, operator, TOTALQUANTITY, TOTALWEIGHT, TOTALVOLUME, voyage);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Run Test Update - Test Mandatory fields not specified gives errors
	*/
	delete pxyCargoForecast;
	
	pxyCargoForecast := app.createUpdateProxy(realCargoForecast).CM_CargoForecast;
	
	pxyCargoForecast.setProxyForUpdate(null, null, null, null, null, null, null, null);
	
	app.myTrxUA.trxUpdateCargoForecast(pxyCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Update - Test Mandatory fields not specified gives errors
	*/
	if app.myPassport.allErrors.size &lt; 1 then
		self.assertTrueMsg(false, "Expected: This trx should result in an error | Actual: No error exists");
	endif;
	
	foreach error in app.myPassport.allErrors do
		if error.text.cnContains("Cargo Type or Commodity") then
			self.assertTrueMsg(error.errorCode = Input_req_cargo_type_commodity, "Expected Error Code:" &amp; Input_req_cargo_type_commodity.String &amp; " | Actual: " &amp; error.errorCode.String); 					//Check Error Code Matches Expected
			self.assertTrueMsg(error.text.cnContains("Cargo Type or Commodity"), "Expected: error message to contain 'Cargo Type or Commodity' | Actual: " &amp; error.text);	//Check Error Message Contains cargo-type or commodity
			cargoTypeCommodityError := true;
			
		elseif error.text.cnContains("mode") then
			self.assertTrueMsg(error.errorCode = REQUIRED_FIELD, "Expected Error Code:" &amp; REQUIRED_FIELD.String &amp; " | Actual: " &amp; error.errorCode.String); 					//Check Error Code Matches Expected
			self.assertTrueMsg(error.text.cnContains("mode"), "Expected: error message to contain 'mode' | Actual: " &amp; error.text);											//Check Error Message Contains mode
			imexStatusError := true;
			
		endif;
		
	endforeach;
	
	if not cargoTypeCommodityError then
		self.assertTrueMsg(cargoTypeCommodityError, "Expected: error to be raised for required field (cargo-type or commodity) | Actual: No Error Raised"); 				//Check Error Code Matches Expected
		
	elseif not imexStatusError then
		self.assertTrueMsg(imexStatusError, "Expected: error to be raised for required field (mode) | Actual: No Error Raised"); 									//Check Error Code Matches Expected
		
	endif;
	
	/*
	**	Setup Test Update - Test Mandatory fields only specified
	*/
	delete pxyCargoForecast;
	
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, commodity, mode, operator, TOTALQUANTITY, TOTALWEIGHT, TOTALVOLUME, voyage);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Run Test Update - Test Mandatory fields only specified
	*/
	self.setTerminalConfig(CargoForecastReqdFields, ETRow_Volume &amp; "," &amp; ETRow_Weight);
	delete pxyCargoForecast;
	
	pxyCargoForecast := app.createUpdateProxy(realCargoForecast).CM_CargoForecast;
	
	pxyCargoForecast.setProxyForUpdate(cargoType, null, mode, null, null, TOTALWEIGHT, TOTALVOLUME, voyage);
	
	app.myTrxUA.trxUpdateCargoForecast(pxyCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Update - Test Mandatory fields only specified
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realCargoForecast.myParent &lt;&gt; null, "Cargo Forecast: Parent Object is null");
	self.assertTrueMsg(realCargoForecast.myCargoType &lt;&gt; null, "Cargo Forecast: Cargo Type Object is null");
	self.assertTrueMsg(realCargoForecast.mode &lt;&gt; null, "Cargo Forecast: Mode is null");
	
	self.assertTrueMsg(realCargoForecast.myParent = voyage, "Cargo Forecast: Parent Object does not match expected parent object");
	self.assertTrueMsg(realCargoForecast.myCargoType = cargoType, "Cargo Forecast: Cargo Type Object does not match expected cargo type");
	self.assertTrueMsg(realCargoForecast.mode = mode, "Cargo Forecast: Mode does not match expected mode");
	
	self.assertTrueMsg(realCargoForecast.totalWeight = TOTALWEIGHT, "The total weight on the Cargo Forecast does not match expected value: " &amp; TOTALWEIGHT.asStringJMT());
	self.assertTrueMsg(realCargoForecast.totalVolume = TOTALVOLUME, "The total volume on the Cargo Forecast does not match expected value: " &amp; TOTALVOLUME.asStringJMT());
	
	/*
	**	Setup Test Create - Test Mandatory fields only specified 2
	*/
	delete pxyCargoForecast;
	
	create pxyCargoForecast transient;
	pxyCargoForecast.setProxyForCreate(cargoType, commodity, mode, operator, TOTALQUANTITY, TOTALWEIGHT, TOTALVOLUME, voyage);
	app.myTrxCA.trxCreateCargoForecast(pxyCargoForecast, realCargoForecast, app.myPassport);
	
	/*
	**	Run Test Create - Test Mandatory fields only specified 2
	*/
	delete pxyCargoForecast;
	
	pxyCargoForecast := app.createUpdateProxy(realCargoForecast).CM_CargoForecast;
	
	pxyCargoForecast.setProxyForUpdate(null, commodity, mode, null, null, TOTALWEIGHT, TOTALVOLUME, voyage);
	
	app.myTrxUA.trxUpdateCargoForecast(pxyCargoForecast, app.myPassport);
	
	/*
	**	Assert Test Create - Test Mandatory fields only specified 2
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realCargoForecast.myParent &lt;&gt; null, "Cargo Forecast: Parent Object is null");
	self.assertTrueMsg(realCargoForecast.myCommodity &lt;&gt; null, "Cargo Forecast: Commodity Object is null");
	self.assertTrueMsg(realCargoForecast.mode &lt;&gt; null, "Cargo Forecast:Mode is null");
	
	self.assertTrueMsg(realCargoForecast.myParent = voyage, "Cargo Forecast: Parent Object does not match expected parent object");
	self.assertTrueMsg(realCargoForecast.myCommodity = commodity, "Cargo Forecast: Commodity Object does not match expected commodity");
	self.assertTrueMsg(realCargoForecast.mode = mode, "Cargo Forecast: Mode does not match expected mode");
	
	self.assertTrueMsg(realCargoForecast.totalWeight = TOTALWEIGHT, "The total weight on the Cargo Forecast does not match expected value: " &amp; TOTALWEIGHT.asStringJMT());
	self.assertTrueMsg(realCargoForecast.totalVolume = TOTALVOLUME, "The total volume on the Cargo Forecast does not match expected value: " &amp; TOTALVOLUME.asStringJMT());
	
	/*
	** Clean Up After test
	*/
	// delete voyage
	self.deleteVoyage(VOYAGEID);
	self.assertNoTrxErrorsOrWarnings();
	
	//Delete Vessel
	self.deleteVessel(VESSELID);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete pxyCargoForecast;
	self.setTerminalConfig(CargoForecastReqdFields, requiredFields);
end;</source>
    </JadeMethod>
    <JadeMethod name="tChangeVoyageCodes" id="5db7e5e8-504a-4574-ace6-cab579f83ab0">
        <source>tChangeVoyageCodes();
// CNWMA1
//23 September 2010	cnwas3 testing 25784

constants
	Cargo_Id = "XYZ987";
	VesselCodeString = "ARES";
	VoyageCodeString = "ARES01";
	VoyageNewCodeString = "ARES02";
	VoyageInwardCodeString = "WAR";
vars
	vessel 		: CM_Vessel;
	voyage 		: CM_Voyage;
	cargo		: CM_TrackedItem;
begin
	//Reset the Data
	self.deleteVoyage(VoyageCodeString);
	self.deleteVoyage(VoyageNewCodeString);
	self.deleteVessel(VesselCodeString);
	self.deleteCargo(Cargo_Id,getRoot.allCargoTypesById[TI_CargoType_BreakBulk]);
	
	//Create a general cargo vessel
	vessel := self.addVesselGeneralCargo(VesselCodeString, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), 10);
	self.assertNotNullMsg(vessel, "Add vessel failed");
	
	//Create a general cargo voyage 
	voyage := self.addVoyageWithGeneralCargoStruc(VoyageCodeString, 
												  VesselCodeString,
												  self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
												  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString,
												  10);
	self.assertNotNullMsg(voyage, "Add voyage failed");	
	
	// create a cargo item for this voyage
	cargo := self.addCargoForVoyage(voyage, Cargo_Id);
	self.assertNotNullMsg(cargo, "Add cargo failed");
	self.assertEqualMsg(voyage.allOnshipTIsByCargoTypeId.includes(cargo), true, "Voyage includes cargo");
	self.assertEqualMsg(voyage.myShipBlockStack.allTrackedItems.includes(cargo), true, "Voyage includes cargo");
	
	//update the voyage's inward code, meaning the cargo's voyage code should be the same
	self.updateVoyageCodes(voyage,voyage.code,VoyageInwardCodeString);
	self.assertEqualMsg(voyage.allOnshipTIsByCargoTypeId.includes(cargo), true, "Voyage includes cargo");
	self.assertEqualMsg(voyage.myShipBlockStack.allTrackedItems.includes(cargo), true, "Voyage includes cargo");
	self.assertEqualMsg(cargo.voyageCode,VoyageCodeString,"Cargo voyage code left unchanged");
	self.assertEqualMsg(cargo.voyageCode,voyage.code,"Cargo voyage code same with voyage code");	
	
	//update the voyage's code, meaning the cargo's voyage code should be the same as the new voyage's code
	self.updateVoyageCodes(voyage,VoyageNewCodeString,null);
	self.assertEqualMsg(voyage.allOnshipTIsByCargoTypeId.includes(cargo), true, "Voyage includes cargo");
	self.assertEqualMsg(voyage.myShipBlockStack.allTrackedItems.includes(cargo), true, "Voyage includes cargo");
	self.assertEqualMsg(cargo.voyageCode,VoyageNewCodeString,"Cargo voyage code has changed");
	self.assertEqualMsg(cargo.voyageCode,voyage.code,"Cargo voyage code same with voyage code");
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckVoyageMyVesselRef" id="eaa4152a-8704-4fad-993f-84db9938b486">
        <updating/>
        <source>tCheckVoyageMyVesselRef() updating;

/*

Purpose:		

Date			Who		Reason
23/01/2014		cnwmh5	Initial creation

*/

constants

	VesselId					: String = "UTVES30558";
	VesselId2					: String = "UTVES30558CHG";
	VoyageId					: String = "UTVOY30558";
	VoyageId2					: String = "UTVOY30558V2";

vars

	vessel						: CM_Vessel;
	voyage						: CM_Voyage;
	voyage2						: CM_Voyage;
	proxyVoyage					: CM_Voyage;
	operator					: CM_Operator;
	pxyVoyage 					: CM_Voyage;
	
	
begin

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNull(operator);

	// delete voyage
	self.deleteVoyage(VoyageId);
	self.assertNoTrxErrorsOrWarnings();
	self.deleteVoyage(VoyageId2);
	self.assertNoTrxErrorsOrWarnings();	
	
	// create vessel
	self.deleteVessel(VesselId2);
	self.assertNoTrxErrorsOrWarnings();
	self.deleteVessel(VesselId);
	self.assertNoTrxErrorsOrWarnings();
	
	vessel := self.addVesselCellular(VesselId, operator);
	self.assertNotNull(vessel);
	
	// create voyage
	voyage := self.addVoyageWithContainerStructur(VoyageId, VesselId, operator.code,  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(voyage);
	
	// check myVessel
	self.assertEqualMsg(voyage.myVessel, vessel, "Voyage (" &amp; voyage.code &amp; ") myVessel &lt;&gt; Vessel");
	
	// Edit vessel name
	self.opts.purge();
	self.opts.addAssoc("VesselCode", VesselId2);
	self.updateVessel(vessel);
	self.assertNoTrxErrorsOrWarnings();
	
	// Edit Voyage
	self.opts.purge();
	self.opts.addAssoc("YearOfBuild", 1999);
	self.updateVoyageCodes(voyage, voyage.code, null);
	self.assertNoTrxErrorsOrWarnings();
	
	// check myVessel
	self.assertEqualMsg(voyage.myVessel, vessel, "Voyage (" &amp; voyage.code &amp; ") myVessel &lt;&gt; Vessel");
	
	// copy voyage
	create proxyVoyage transient;
	self.setupVoyageCopyProxy(proxyVoyage, VoyageId2, voyage);
	self.assertNoTrxErrorsOrWarnings();
	app.myTrxCA.trxCreateVoyage(proxyVoyage, voyage2, vessel, null, true, app.myPassport);
	self.assertNotNull(voyage2);
	
	// check copied myVessel
	self.assertEqualMsg(voyage2.myVessel, vessel, "Voyage (" &amp; voyage2.code &amp; ") myVessel &lt;&gt; Vessel");	
	
	beginLoad;
	pxyVoyage := app.createUpdateProxy(voyage).CM_Voyage;
	voyage.myCellularVoyageStructure.pxyCreateUpdateProxyStructure(pxyVoyage.myCellularVoyageStructure);
	endLoad;
	
	pxyVoyage.myCellularVoyageStructure.setProxyCellularVoyage("09", true,true,true);// vessel.myCellularVesselStructure.useBayCellTierNumbering);
	
	
	app.myTrxUA.trxUpdateCellularVoyStructure(pxyVoyage.myCellularVoyageStructure,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(voyage.myCellularVoyageStructure.bridgeAfterBay, "09");
	
epilog

	delete pxyVoyage;
	delete proxyVoyage;

end;</source>
    </JadeMethod>
    <JadeMethod name="tEtaEtdMandatory" id="403c8c9b-a279-4de1-9a24-caf393cd9759">
        <source>tEtaEtdMandatory();
/*

Purpose:			
/****Changes

Date		Name	TFS#		Description
============================================================================
16/06/2016	cnwmk3				Initial creation
11/04/2017	cnwdap1	TFS 4050 	LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102	STWR - Add isBarges Flag.
// 10 Sep 2019	cnwrs1	TFS 46030
============================================================================*/
constants
	VoyCode						= "UT_VOY2140";
	VesselCode					= "DIAM";
vars
	proxyVoyage, voyage			: CM_Voyage;
	conflictManager 			: CMIF_HMS_ConflictsManager;
	arrivalDate					: TimeStamp;
	departureDate, now			: TimeStamp;
	isDoClearanceCheck : Boolean;
	startTime : TimeStamp;
	endTime : TimeStamp;
	allowableTimeDiff : TimeStampInterval;
	actualTimeDiff : TimeStampInterval;
begin
	startTime := app.actualTimeAppServer;
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.deleteVoyage(VoyCode);
	voyage := self.addVoyageWithContainerStructur(VoyCode, VesselCode, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(voyage);
	
	self.setTerminalConfig("EtaEtdMandatory", true);
	
	beginLoad;
	proxyVoyage := voyage.pxyCreateUpdateProxy();
	endLoad;
	
	proxyVoyage.setProxyVoyage(	voyage.bitmap,
							voyage.callSign,
							VoyCode,	//the new codes
							null,	//the new codes
							voyage.remarks,
							voyage.vesselCode,
							voyage.vesselName,
							voyage.lloydsNumber,
							voyage.archived,
							voyage.isTransferable,
							voyage.starboardBerthed,
							voyage.craneClearance,
							voyage.displayOption,
							voyage.colour,
							voyage.status,
							voyage.vesselType,
							voyage.archivedDT,
							voyage.arrivedDT,
							voyage.departedDT,
							voyage.loadStartDT,
							voyage.loadEndDT,
							voyage.nonPlannedEffectiveDT,
							voyage.cutOffDT,
							null,
							null,
							voyage.myOperator,
							voyage.myTrade,
							voyage.myShippingLine,
							voyage.myTerminal,
							voyage.myVoyageGlobalArrival,
							null,
							null,
							null,
							null,
							null,
							voyage.voyageNumber,
							voyage.overrideDefaults,
							voyage.allOperators,
							null,
							voyage.useVoyageAllocations,
							voyage.externalRef,
							null,
							null,
							null,
							null,
							null,
							null,
							null,null,null,
							null,null,
							null,
							null,			// TFS 4050
							voyage.paymentType,
							voyage.isBarge,			//jlgka1 TFS 37102
							voyage.voyageGroupCode,  //03/06/2020 cnwma1 Tfs #49400
							false	// 31.Aug.2023 navsp1 TFS 57809
							);										
	// an error will be raised if an attempt is made to save a voyage without both of these dates populated.
	self.expectTrxError(Terminal_config_option_set);
	app.myTrxUA.trxUpdateVoyage(true,false,proxyVoyage,conflictManager,null,false,app.myPassport);
	delete proxyVoyage;
	
	beginLoad;
	proxyVoyage := voyage.pxyCreateUpdateProxy();
	endLoad;
	arrivalDate.setDate(now.date());
	arrivalDate.setTime(now.time());
	departureDate := arrivalDate.addDays(5);
	proxyVoyage.setProxyVoyage(	voyage.bitmap,
							voyage.callSign,
							VoyCode,	//the new codes
							null,	//the new codes
							voyage.remarks,
							voyage.vesselCode,
							voyage.vesselName,
							voyage.lloydsNumber,
							voyage.archived,
							voyage.isTransferable,
							voyage.starboardBerthed,
							voyage.craneClearance,
							voyage.displayOption,
							voyage.colour,
							voyage.status,
							voyage.vesselType,
							voyage.archivedDT,
							null,
							null,
							voyage.loadStartDT,
							voyage.loadEndDT,
							voyage.nonPlannedEffectiveDT,
							voyage.cutOffDT,
							null,
							null,
							voyage.myOperator,
							voyage.myTrade,
							voyage.myShippingLine,
							voyage.myTerminal,
							voyage.myVoyageGlobalArrival,
							null,
							null,
							null,
							null,
							null,
							voyage.voyageNumber,
							voyage.overrideDefaults,
							voyage.allOperators,
							null,
							voyage.useVoyageAllocations,
							voyage.externalRef,
							null,
							null,
							null,
							null,
							null,
							null,
							null,null,null,
							arrivalDate,
							departureDate,
							null,
							null,			// TFS 4050
							voyage.paymentType,
							voyage.isBarge,		 	//jlgka1 TFS 37102
							voyage.voyageGroupCode,  //03/06/2020 cnwma1 Tfs #49400
							false	// 31.Aug.2023 navsp1 TFS 57809
							);										
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateVoyage(true,false,proxyVoyage,conflictManager,null,false,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//  if the 'Actual Arrival' and/or 'Actual departure' fields are not populated, then the values from the 'Estimated Arrival' and 'Estimated Departure' field(s) will be used to populate their respective 'Actual' equivalent(s). 
	voyage := self.getVoyage(VoyCode);
	
	endTime := app.actualTimeAppServer;
	allowableTimeDiff := endTime - startTime;
	
	actualTimeDiff := voyage.arrivedDT - voyage.estimatedArrivalDT;
	self.assertTrueMsg(actualTimeDiff &lt;= allowableTimeDiff, "Arrival, Est Arrival time difference should not be greater than teh time taked to run thw test");
	
	actualTimeDiff := voyage.departedDT - voyage.estimatedDepartureDT;
	self.assertTrueMsg(actualTimeDiff &lt;= allowableTimeDiff, "Departure, Est Departure time difference should not be greater than teh time taked to run thw test");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	self.setTerminalConfig("EtaEtdMandatory", false);
	self.ignoreTrxWarnings(false);
	delete proxyVoyage;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tHookCodeTest" id="8435fc54-fa2c-4281-8ee2-b7cf24446c66">
        <source>tHookCodeTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2018	jlgndl1	Initial creation	TFS 37562

*/

vars

	root : CM_Root;
	term : CM_Terminal;
	voyage : CM_Voyage;
	bank : CM_Bank;
	taxExempt : Boolean;
	
	realHookCode : CM_HookCode;
	proxyHookCode : CM_HookCode;
	cmif : CMIF_HookCode;
	
	testBank : CM_Bank;

begin

	root := app.myRoot;
	term := self.getTerminal();
	voyage := term.allVoyagesSet.first;
	
	//no hook code set up, should still work. 
	
	bank := root.getVoyageBusUnit( term, voyage ).CM_Bank;
	self.assertTrueMsg( bank &lt;&gt; null, "No bank returned in default mode for Voyage Bus Unit Hook Code.");
	
	testBank := CM_Bank.lastInstance;
											
	//create a hook code using the default code.
	create proxyHookCode transient;
	create cmif transient;
	cmif.myProxyHookCode := proxyHookCode;
	cmif.code := "Voyage Bus Unit UT";
	cmif.allLinkObjects.add( term );
	cmif.myHookType := app.myRoot.allHookTypes[ HookType_VoyageBusUnit ];
	
	cmif.jadeCode := "getVoyageBusUnit(_term : CM_Terminal; _voyage : CM_Voyage):CM_Bank;" &amp; CrLf &amp; "vars" &amp;
						CrLf &amp; "begin" &amp; CrLf &amp; "return CM_Bank.lastInstance;" &amp; CrLf &amp; "end;";
	app.myTrxCA.trxCreateHookCode(cmif, realHookCode, app.myPassport);
	
	delete proxyHookCode;
	delete cmif;
	
	self.assertTrueMsg( realHookCode &lt;&gt; null, "Voyage Bus Unit hook code not created " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	testBank := CM_Bank.lastInstance;
	bank := root.getVoyageBusUnit( term, voyage ).CM_Bank;
	
	self.assertTrueMsg( bank &lt;&gt; null, "No bank returned in configured mode.");
	self.assertTrueMsg( bank = testBank, "Incorrect bank returned in configured mode for Voyage Bus Unit Hook Code.");
	
	
	app.myTrxDA.trxDeleteHookCode(realHookCode, app.myPassport);
	realHookCode := null;
	
	
	//no hook code set up, should still work. 
	
	taxExempt := root.getVoyageTaxExempt( term, voyage ).Boolean;
	self.assertTrueMsg( taxExempt = false, "Should be false in default mode Tax Exempt Hook Code.");
	
	//create a hook code using the default code.
	create proxyHookCode transient;
	create cmif transient;
	cmif.myProxyHookCode := proxyHookCode;
	cmif.code := "Voyage Tax Exempt UT";
	cmif.allLinkObjects.add( term );
	cmif.myHookType := app.myRoot.allHookTypes[ HookType_VoyageTaxExempt ];
	
	cmif.jadeCode := "getVoyageTaxExempt(_term : CM_Terminal; _voyage : CM_Voyage):Boolean;" &amp; CrLf &amp; "vars" &amp;
						CrLf &amp; "begin" &amp; CrLf &amp; "return true;" &amp; CrLf &amp; "end;";
	app.myTrxCA.trxCreateHookCode(cmif, realHookCode, app.myPassport);
	
	self.assertTrueMsg( realHookCode &lt;&gt; null, "Tax Exempt hook code not created " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	taxExempt := root.getVoyageTaxExempt( term, voyage ).Boolean;
	self.assertTrueMsg( taxExempt = true, "Should be true in configured mode for Tax Exempt Hook Code.");
	
	app.myTrxDA.trxDeleteHookCode(realHookCode, app.myPassport);
	realHookCode := null;


epilog

	delete proxyHookCode;
	delete cmif;
	
	if realHookCode &lt;&gt; null then
		self.ignoreTrxWarnings(true);
		app.myTrxDA.trxDeleteHookCode(realHookCode, app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	endif; 

end;</source>
    </JadeMethod>
    <JadeMethod name="tReceivalCutOff" id="a02372eb-0ef3-4580-b1fd-6b7d441bcd7b">
        <updating/>
        <source>tReceivalCutOff() updating;

/*

Purpose:			

Parameters:			

Return Value:		

/****Changes

Date		Name	TFS#			Description
============================================================================
20/11/2015	cnwmk3					Initial creation
12/05/2016	cnwns1	TFS 488  		Multi Timezone Support
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
// 10 Sep 2019	cnwrs1	TFS 46030
============================================================================*/
constants
	VesselId			: String = "AOR";
	VoyageId			: String = "UT_URORA123";
	ShipLine			: String = "CMA";
	TruckId				: String = "UTMHTRUCK";
	CutOffCode			: String = "PRENOTE2";
vars
	voyage, pxyVoyage	: CM_Voyage;
	operator			: CM_Operator;
	booking				: CM_BookingRef;
	ti1, ti2, ti3		: CM_TrackedItem;
	vvr					: CM_VehicleVisitRecord;
	
	allRecRestrictions	: CM_RecCutoffVoyByCodeOp;
	recCutoff	 		: CM_ReceivalCutoffVoyage;
	code				: String;
	cutoffTS			: TimeStamp;
	earliestTS			: TimeStamp;
	date				: Date;
	conflictManager 	: CMIF_HMS_ConflictsManager;
	proxy, cutoff		: CM_ReceivalCutoffTermDef;
	arrivalDate, 
	departureDate 		: TimeStamp;
	trade				: CM_Trade;
	time				: Time;
	sort				: Integer;
	cmif				: CMIF_Array;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	// Delete tracked items if already exists
	ti1 := self.getTrackedItem("UUT00000001");
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, false);
	endif;
	
	ti2 := self.getTrackedItem("UUT00000002");
	if ti2 &lt;&gt; null then
		self.deleteTrackedItem(ti2, false);
	endif;
	
	ti3 := self.getTrackedItem("UUT00000003");
	if ti3 &lt;&gt; null then
		self.deleteTrackedItem(ti3, false);
	endif;
	
	// Enable the config "Voyage Cut-offs Produce Error on Receival"
	self.setTerminalConfig(ShipCutoffsShowError, true);
	self.assertEqual(getTerminalConfig(ShipCutoffsShowError).Boolean, true);
	
	operator := self.getOperator("MSL");
	self.assertNotNull(operator);
	
	//Delete Voyage if already exist
	voyage := self.getVoyage(VoyageId);
	if voyage &lt;&gt; null then
		self.deleteVoyage(VoyageId);
		voyage := self.getVoyage(VoyageId);
		self.assertNull(voyage);
	endif;
	
	// Create Voyage with no cut-offs
	voyage := self.addVoyageWithContainerStructur(VoyageId,VesselId,operator.code,ShipLine);
	self.assertNotNull(voyage);
	
	// Create booking for prenote containers
	booking := self.addBookingForContainer("UT_BOOKING", operator, voyage, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	// add prenotes before cutoff
	ti1 := self.addPrenotedContainer(booking.allBookingRefItems.first,  "UUT00000001");
	
	
	// Set a Voyage cut-off for the same operator as the Pre-Notes
	arrivalDate.setDate(date - 7);
	departureDate.setDate(date + 1);
	
	self.tAddVoyageCutOff(); //11/03/2025	navkc1 JIRA Story MTN-34228
	
	beginLoad;
	pxyVoyage := voyage.pxyCreateUpdateProxy();
	endLoad;
	
	process.sleep(5000);
	
	create allRecRestrictions transient;
	code := self.getTerminal.allReceivalCutoffDefs[CutOffCode].code;
	cutoffTS := app.actualTimeServer();// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	earliestTS.setDate(date - 3);
	
	// add prenotes after cutoff
	ti2 := self.addPrenotedContainer(booking.allBookingRefItems.first,  "UUT00000002"); 
	
	create recCutoff transient;
	recCutoff.setProxy(code, cutoffTS, earliestTS, pxyVoyage, operator, 
						null, 	//04/03/2025	navkc1 JIRA Story MTN-34227
						null, 	//04/03/2025	navkc1 JIRA Story MTN-34227
						null,null,null,null,null);
	allRecRestrictions.add(recCutoff);
	trade := getTrade;
	pxyVoyage.setProxyVoyage(null,
								"",
								VoyageId,
								"",
								"",
								VesselId,
								voyage.myVessel.code,
								"",
								true,
								false,
								false,
								0,
								VoyageDisplayAlways,
								0,
								pxyVoyage.status,
								voyage.myVessel.vesselType,
								null,
								arrivalDate,
								departureDate,
								pxyVoyage.loadStartDT,
								pxyVoyage.loadEndDT,
								null,
								null,
								null,
								null,
								voyage.myOperator,
								trade,
								voyage.myShippingLine,
								self.getTerminal,
								pxyVoyage.myVoyageGlobalArrival,
								null,
								null,
								null,
								null,
								null,
								0,
								true,									
								pxyVoyage.allOperators,
								allRecRestrictions,	
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,null,null,
								null,null,
								null,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407
								null, 			// TFS 4050
								null,
								pxyVoyage.isBarge,		   //jlgka1 TFS 37102
								pxyVoyage.voyageGroupCode,  //03/06/2020 cnwma1 Tfs #49400
								false	// 31.Aug.2023 navsp1 TFS 57809
								);
	app.myTrxUA.trxUpdateVoyage(true, true, pxyVoyage, conflictManager, null, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// time to gate in the existing prenote
	vvr := self.gateInPrenote(TruckId, "", "", ti1, self.getProfileSetting(UT_Profile.P_DGATE).asString);
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// create a new Pre-Note (should NOT work, should get error)
	self.expectTrxError(Receival_Outside_Cutoff);
	self.expectTrxError(ERR_CONTAINER_NO);
	self.expectTrxError(Book_item_already_has);
	
	ti3 := self.addPrenotedContainer(booking.allBookingRefItems.first,  "UUT00000003");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete proxy;
	delete cmif;
	delete recCutoff;
	delete allRecRestrictions;
	delete pxyVoyage;
	self.setTerminalConfig(ShipCutoffsShowError, false);
	self.deleteVoyageCutoff(code); //11/03/2025	navkc1 JIRA Story MTN-34228
end;</source>
    </JadeMethod>
    <JadeMethod name="tReceivalCutoffPreNote" id="6168cc08-b936-49d1-9990-f6a85a1857b4">
        <updating/>
        <source>tReceivalCutoffPreNote() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//11/03/2025	navkc1 JIRA Story MTN-34228: MTN | Prenote Voyage Cut Offs - Unit Tests Cargo Prenote Cutoffs

*/
constants
	TI1ID	= "34228TIUT1";
	TI2ID	= "34228TIUT2";
	VOYID	= "UTVOY34228";
	VESSID	= "UTVESS34228";
	BOOKING = "UTBOOK34228";
	BOOKING2 = "UTBOOK342282";
	TERMCUTOFF = "TCUTOFF34228";
	OPCUTOFF = "OCUTOFF34228";
	TRUCKID = "UTGMB849";
vars
	shipLineStr			: String;
	
	now,
	arrivalTS,
	departureTS			: TimeStamp;
	
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	operator			: CM_Operator;
	ti1, ti2		: CM_TrackedItem;
	booking1			: CM_BookingRef;
	pxyTermCutoff,
	termCutoff			: CM_ReceivalCutoffTermDef;
	cmif				: CMIF_Array;
	vvr					: CM_VehicleVisitRecord;
	ifPreNote			: CMIF_PreNote;
	ifArray				: CMIF_PrenoteSet;
	ediData				: CM_EDIDataPrenote;
begin
	
	create ifPreNote transient;
	create ifArray transient;
	create ediData transient;
	
	// Delete Truck
	self.deleteVehicle(TRUCKID);
	
	// Delete TI 1
	ti1 := self.getTrackedItem(TI1ID);
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, false);
	endif;
	
	// Delete TI 2
	ti2 := self.getTrackedItem(TI2ID);
	if ti2 &lt;&gt; null then
		self.deleteTrackedItem(ti2, false);
	endif;
	
	// Delete Term Cutoff
	self.deleteVoyageCutoff(TERMCUTOFF);

	// Set Config
	self.setTerminalConfig(ShipCutoffsShowError, true);
	//self.setTerminalConfig(ShipCutoffsForPrenotes, true);
	
	// Get Operator
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(operator, "Failed to get operator");
	
	// Delete Voyage
	voyage := self.getVoyage(VOYID);
	if voyage &lt;&gt; null then
		self.deleteVoyage(VOYID);
	endif;
	
	// Delete Vessel
	vessel := self.getVessel(VESSID);
	if vessel &lt;&gt; null then
		self.deleteVessel(VESSID);
	endif;
	
	// Create Vessel
	vessel := self.addVesselBasic(VESSID, operator, false, true, true, true);
	self.assertNotNullMsg(vessel, "Failed to create vessel");
	
	// Get Shipping Line code
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	
	// Create voyage
	// Set Arrival and Departure date
	arrivalTS.setTime(now.time().addHours(-2));
	departureTS.setTime(now.time().addHours(3));
	self.opts.purge();
	self.opts.addAssoc("tsArrival", arrivalTS);
	self.opts.addAssoc("tsDeparture", departureTS);
	voyage := self.addVoyageWithContainerStructur(VOYID, VESSID, operator.code, shipLineStr);
	self.assertNotNullMsg(voyage, "Failed to create voyage");
	
	// Set check pre note cutoff True
	beginTransaction;
		voyage.setPropertyValue("shipCutoffsForPrenotes", true);
	commitTransaction;
	
	// Delete booking
	self.deleteBooking(BOOKING);
	
	// Create Booking 1
	booking1 := self.addBookingForContainer(BOOKING, operator, voyage, "NZAKL", "2200", "MT");
	self.assertNotNullMsg(booking1, "Failed to create booking 1");
	
	// Create Prenote 1
	ti1 := self.addPrenotedContainer(booking1.allBookingRefItems.first, TI1ID);
	
	/* =====================
	Scenario 1 - Should fail due to item earliest cutoff time
	=========================*/
		
		// Create Term Cutoff
		create pxyTermCutoff transient;
		create cmif transient;
		pxyTermCutoff.setValues(TERMCUTOFF, TERMCUTOFF, 34228, DefaultRelativeTo_Departure, 1, 2, true, CM_ReceivalCutoffTermDef.CriteriaType_CARGO, self.getTerminal(), 1, 2);
		app.myTrxCA.trxCreateRecRestrictionDef(pxyTermCutoff, cmif, termCutoff, app.myPassport);
		self.assertNotNullMsg(termCutoff, "Failed to create term cutoff"); 
		
		// Test scenario - Should fail due to the earliest cutoff time
		process.sleep(5000);
		self.clearExpectedTrxErrors();
		self.expectTrxError(Receival_Outside_EarliestPN);
		self.expectTrxError(ERR_CONTAINER_NO);
		self.expectTrxError(ERR_No_Items_Entered);
		vvr := self.gateInPrenote(TRUCKID, "", "", ti1, self.getProfileSetting(UT_Profile.P_DGATE).asString());
		self.assertNotNullMsg(vvr, "VVR should not be null");
		self.assertTrueMsg(vvr.allReceivedTrackedItems.isEmpty(), "VVR should not have any items due to the earliest cutoff");
		self.deleteVVR(vvr);
		
		// Try load EDI, should get error as well
		ifPreNote.id := TI2ID;
		ifPreNote.myTerminal := self.getTerminal;
		ifPreNote.cargoType := TI_CargoType_Container;
		ifPreNote.isoType := "2200";
		ifPreNote.commodity := "MT";
		ifPreNote.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
		ifPreNote.operatorCode := operator.code;
		ifPreNote.weightTotal := 2000;
		ifPreNote.voyageCode := voyage.code;
		ifPreNote.dischargePort := "NZAKL";
		ifPreNote.transportMode := TI_TRANSMODE_ROAD_STR;
		ifPreNote.bookingReference := null;
		ifPreNote.myBookingRefItem := null;
		ifPreNote.action := "A";
		ifArray.add(ifPreNote);
		
		self.ignoreTrxWarnings(true);
		app.myTrxUA.trxProcessEDIPreNotes(ifArray, false, ediData, app.myPassport);
		self.assertTrxErrorMsg(Receival_Outside_EarliestPN, "Should get error due to earliest cutoff");
	/* =====================
	Scenario 2 - Should fail due to item created after cutoff time
	=========================*/
		// Delete and Create Term Cutoff
		self.deleteVoyageCutoff(TERMCUTOFF);
		delete pxyTermCutoff;
		create pxyTermCutoff transient;
		pxyTermCutoff.setValues(TERMCUTOFF, TERMCUTOFF, 34228, DefaultRelativeTo_Departure, 4, 5, true, CM_ReceivalCutoffTermDef.CriteriaType_CARGO, self.getTerminal(), 4, 5);
		app.myTrxCA.trxCreateRecRestrictionDef(pxyTermCutoff, cmif, termCutoff, app.myPassport);
		self.assertNotNullMsg(termCutoff, "Failed to create term cutoff"); 
		
		//// Test scenario - Should fail due to the cutoff time
		process.sleep(5000);
		self.clearExpectedTrxErrors();
		self.expectTrxError(Receival_Outside_CutoffPN);
		self.expectTrxError(ERR_CONTAINER_NO);
		self.expectTrxError(ERR_No_Items_Entered);
		self.deleteVehicle(TRUCKID);
		vvr := self.gateInPrenote(TRUCKID, "", "", ti1, self.getProfileSetting(UT_Profile.P_DGATE).asString());
		self.assertNotNullMsg(vvr, "VVR should not be null");
		self.assertTrueMsg(vvr.allReceivedTrackedItems.isEmpty(), "VVR should not have any items due to the cutoff time");
		self.deleteVVR(vvr);
		
		delete ifArray;
		delete ifPreNote;
		delete ediData;
		create ifArray transient;
		create ifPreNote transient;
		create ediData transient;
		// Try load EDI, should get error as well
		ifPreNote.id := TI2ID;
		ifPreNote.myTerminal := self.getTerminal;
		ifPreNote.cargoType := TI_CargoType_Container;
		ifPreNote.isoType := "2200";
		ifPreNote.commodity := "MT";
		ifPreNote.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
		ifPreNote.operatorCode := operator.code;
		ifPreNote.weightTotal := 2000;
		ifPreNote.voyageCode := voyage.code;
		ifPreNote.dischargePort := "NZAKL";
		ifPreNote.transportMode := TI_TRANSMODE_ROAD_STR;
		ifPreNote.bookingReference := null;
		ifPreNote.myBookingRefItem := null;
		ifPreNote.action := "A";
		ifArray.add(ifPreNote);
		
		self.ignoreTrxWarnings(true);
		app.myTrxUA.trxProcessEDIPreNotes(ifArray, false, ediData, app.myPassport);
		self.assertTrxErrorMsg(Receival_Outside_CutoffPN, "Should get error due to cutoff");
	/* =====================
	Scenario 3 - Should receive the cargo OK
	=========================*/
		// Delete and Create Term Cutoff
		self.deleteVoyageCutoff(TERMCUTOFF);
		delete pxyTermCutoff;
		create pxyTermCutoff transient;
		pxyTermCutoff.setValues(TERMCUTOFF, TERMCUTOFF, 34228, DefaultRelativeTo_Departure, 1, 5, true, CM_ReceivalCutoffTermDef.CriteriaType_CARGO, self.getTerminal(), 1, 5);
		app.myTrxCA.trxCreateRecRestrictionDef(pxyTermCutoff, cmif, termCutoff, app.myPassport);
		self.assertNotNullMsg(termCutoff, "Failed to create term cutoff"); 
		
		//// Test scenario - Should fail due to the cutoff time
		process.sleep(5000);
		self.clearExpectedTrxErrors();
		self.deleteVehicle(TRUCKID);
		vvr := self.gateInPrenote(TRUCKID, "", "", ti1, self.getProfileSetting(UT_Profile.P_DGATE).asString());
		self.assertNotNullMsg(vvr, "VVR should not be null");
		self.assertTrueMsg(vvr.allReceivedTrackedItems.first() = ti1, "VVR should have cargo 1 in the list");
		self.deleteVVR(vvr);
		
		delete ifArray;
		delete ifPreNote;
		delete ediData;
		create ifArray transient;
		create ifPreNote transient;
		create ediData transient;
		// Try load EDI, should not get any errors
		ifPreNote.id := TI2ID;
		ifPreNote.myTerminal := self.getTerminal;
		ifPreNote.cargoType := TI_CargoType_Container;
		ifPreNote.isoType := "2200";
		ifPreNote.commodity := "MT";
		ifPreNote.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
		ifPreNote.operatorCode := operator.code;
		ifPreNote.weightTotal := 2000;
		ifPreNote.voyageCode := voyage.code;
		ifPreNote.dischargePort := "NZAKL";
		ifPreNote.transportMode := TI_TRANSMODE_ROAD_STR;
		ifPreNote.bookingReference := null;
		ifPreNote.myBookingRefItem := null;
		ifPreNote.action := "A";
		ifArray.add(ifPreNote);
		
		self.ignoreTrxWarnings(true);
		app.myTrxUA.trxProcessEDIPreNotes(ifArray, false, ediData, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
epilog
	self.deleteTrackedItem(ti1, false);
	self.deleteTrackedItem(ti2, false);
	self.deleteVoyageCutoff(TERMCUTOFF);
	delete pxyTermCutoff;
	delete cmif; 
	delete ifPreNote; 
	delete ifArray;
	delete ediData;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVoyageAutoMovements" id="24f2bef4-4da1-48cb-8115-019d0ad7dd17">
        <source>tVoyageAutoMovements();
/*
Purpose:			

Date		Who		Reason
08 July 2024	navab1	CR 64615 TASK 64647
*/

vars
	pxyAM, realAM : CM_EDIAutoMovements;
	term : CM_Terminal;
	bs : CM_BlockStack;
	voyStatus : CM_VoyageStatus;
	voyProcess : CM_VoyageProcess;
begin
	term := self.getTerminal();
	
	if term.myEDIAutoMove &lt;&gt; null then
		app.myTrxDA.trxDeleteEDIAutoMove(term.myEDIAutoMove, app.myPassport);
		self.assertTrueTrxOKShowPassport("Delete Auto Movement Config");
	endif;
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Auto_movem_confi_requr_disch_y); 
	/* not raised anymore NAVAB1 23OCT2024
	self.expectedTrxErrors.add(Requir_voyage_status_auto_clos); 
	self.expectedTrxErrors.add(Auto_closu_statu_must_statu_au); 
	*/
	self.expectedTrxErrors.add(Minut_offse_only_withi_minut_h); 

	self.opts.addAssoc("ExpectErrors",true);
	
	create pxyAM transient;
	pxyAM.setProxy(term, 800, 0, null,null);
	app.myTrxCA.trxCreateEDIAutoMove(pxyAM, realAM, app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected CREATE error");
	self.assertTrueMsg(realAM = null, "Create realAM shoudl be null");
	delete pxyAM;
	self.clearExpectedTrxErrors();

	self.opts.addAssoc("ExpectErrors",false);
	
	bs := self.addBlockStack("voyAM", 99999, null);
	self.assertTrueMsg(bs &lt;&gt; null, "BS is null");
	
	voyProcess := app.myRoot.allVoyageProcesses["AUTO"];
	self.assertTrueMsg(voyProcess &lt;&gt; null, "voyProcess is null");
	
	voyStatus := voyProcess.allStatuses.last;
	self.assertTrueMsg(voyStatus &lt;&gt; null, "voyStatus is null");
	
	
	create pxyAM transient;
	pxyAM.setProxy(term, 30, Voyage_Arrival, bs.myLocationsController, voyStatus);
	
	app.myTrxCA.trxCreateEDIAutoMove(pxyAM, realAM, app.myPassport);
	self.assertTrueTrxOKShowPassport("Delete Auto Movement Config");
	self.assertTrueMsg(realAM &lt;&gt; null, "Create realAM is null");
	self.assertTrueMsg(realAM.myTerminal = term, "Create terminal is wrong");
	self.assertTrueMsg(realAM.minutesOffset = 30, "Create minutesOffset should be 30");
	self.assertTrueMsg(realAM.voyageDateType = Voyage_Arrival, "Create voyageDateType should be Voyage_Arrival");
	self.assertTrueMsg(realAM.myTranshipDischargeLC = bs.myLocationsController, "Create myTranshipDischargeLC is wrong");
	self.assertTrueMsg(realAM.myVoyageStatusForClosure = voyStatus, "Create voyStatus is wrong");
	
	delete pxyAM;
		
	pxyAM := app.createUpdateProxy(realAM).CM_EDIAutoMovements;
	self.assertTrueMsg(pxyAM &lt;&gt; null, "pxyAM is null");

	voyStatus := voyProcess.allStatuses.first;
	self.assertTrueMsg(voyStatus &lt;&gt; null, "voyStatus is null");
	
	pxyAM.setProxy(term, 40, Voyage_Departed, bs.myLocationsController, voyStatus);
	
	
	app.myTrxUA.trxUpdateEDIAutoMove(pxyAM, app.myPassport);
	self.assertTrueMsg(realAM &lt;&gt; null, "Update realAM is null");
	self.assertTrueMsg(realAM.myTerminal = term, "Update terminal is wrong");
	self.assertTrueMsg(realAM.minutesOffset = 40, "Update minutesOffset should be 40");
	self.assertTrueMsg(realAM.voyageDateType = Voyage_Departed, "Update voyageDateType should be Voyage_Departed");
	self.assertTrueMsg(realAM.myTranshipDischargeLC = bs.myLocationsController, "Update myTranshipDischargeLC is wrong");
	self.assertTrueMsg(realAM.myVoyageStatusForClosure = voyStatus, "Update voyStatus is wrong");
	
	delete pxyAM;

	app.myTrxDA.trxDeleteEDIAutoMove(realAM, app.myPassport);
	self.assertTrueTrxOKShowPassport("Delete Auto Movement Config");
	
epilog
	delete pxyAM;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVoyageEDIAutoComparison" id="81994f0a-0b5f-46b7-a0b6-8d41acce1038">
        <source>tVoyageEDIAutoComparison();
/*
Purpose - 	
Who - NAVAB1
Date - 16JUL2024
ADO - CR 64614 TASK 64644
*/

constants
	IssueCode = "UT_HELP";
	IssueDesc = "Unit Test EDI Auto Comparison";
	EmailAddress1 = "andrew.bishop@kaleris.com";
vars
	pxyAutoComp, realAutoComp : CM_EDIComparisonConfig;
	term : CM_Terminal;

	sa, compfields, ignoreFields : StringArray;
	emailTempl : CM_EmailTemplate;
	
begin
	create sa transient;
	create compfields transient;
	create ignoreFields transient;
	
	sa.add(ETRow_FileType);
													
	compfields.add(ETRow_ContainerLength);
	compfields.add(ETRow_ContentsStatus);
	compfields.add(ETRow_IsoType);
	ignoreFields.add(ETRow_DischPort);
	ignoreFields.add(ETRow_LoadPort);

	term := self.getTerminal();
	
	realAutoComp := term.myEDIComparisonConfig;
	if realAutoComp&lt;&gt; null then
		app.myTrxDA.trxDeleteEDICompCon(realAutoComp, app.myPassport);
		self.assertTrueTrxOKShowPassport("Delete  EDI Auto Comparison HELP");
	endif;
	
	
	// ### TEST EXPECTED ERRORS
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Auto_compar_must_have_termin); 

	self.opts.addAssoc("ExpectErrors",true);
	
	create pxyAutoComp transient;
	app.myTrxCA.trxCreateEDICompCon(pxyAutoComp, realAutoComp, app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected CREATE error");
	self.assertTrueMsg(realAutoComp = null, "Create realAM should be null");
	
	delete pxyAutoComp;
	self.clearExpectedTrxErrors();
	self.opts.addAssoc("ExpectErrors",false);
	
	// ### TRY CREATE AGAIN
	create emailTempl transient;
	emailTempl.setProxyForEDIIssue(EmailAddress1,EmailAddress1,EmailAddress1,
												"EDI EMAIL Auto Comparison",
												"This is the body of the email",
												"Email Auto Comparison",
												true,
												sa
												);


	
	create pxyAutoComp transient;
	pxyAutoComp.setProxy(term, emailTempl, true, compfields, ignoreFields);
		
	app.myTrxCA.trxCreateEDICompCon(pxyAutoComp, realAutoComp, app.myPassport);
	self.assertTrueTrxOKShowPassport("Create EDI Auto Comparison");
	self.assertTrueMsg(realAutoComp &lt;&gt; null, "Create realAM is null");
	self.assertTrueMsg(realAutoComp.myTerminal = term, "Create terminal is wrong");
	self.assertTrueMsg(realAutoComp.doAutoComparison = true, "Create doAutoComparison is wrong");
	self.assertTrueMsg(realAutoComp.comparisonFields.size = compfields.size, "Create comparisonFields is wrong");
	self.assertTrueMsg(realAutoComp.comparisonFields.membersSame(compfields), "Create comparisonFields is wrong");

	self.assertTrueMsg(realAutoComp.myEmailTemplate &lt;&gt;  null, "Create EMail Template is wrong");
	self.assertTrueMsg(realAutoComp.myEmailTemplate.bccAddresses = EmailAddress1, "Create Email BCC  is wrong");
	self.assertTrueMsg(realAutoComp.myEmailTemplate.toAddresses = EmailAddress1, "Create Email BCC  is wrong");
	self.assertTrueMsg(realAutoComp.myEmailTemplate.bccAddresses = EmailAddress1, "Create Email BCC  is wrong");
	self.assertTrueMsg(realAutoComp.myEmailTemplate.allIncludedFields.membersSame(sa), "Create Email selected fields  is wrong");
	self.assertTrueMsg(realAutoComp.myEmailTemplate.sendtoOperatorVoyage = true, "Create Email Include 5  is wrong");
	
	delete pxyAutoComp;
		
	pxyAutoComp := app.createUpdateProxy(realAutoComp).CM_EDIComparisonConfig;
	emailTempl :=  app.createUpdateProxy(realAutoComp.myEmailTemplate).CM_EmailTemplate;
	
	self.assertTrueMsg(pxyAutoComp &lt;&gt; null, "pxyAM is null");

	compfields.clear();
	compfields.add(ETRow_CargoType);
	
	pxyAutoComp.setProxy(term, emailTempl, false, compfields, ignoreFields);
	
	app.myTrxUA.trxUpdateEDICompCon(pxyAutoComp, app.myPassport);
	self.assertTrueMsg(realAutoComp &lt;&gt; null, "Update realAM is null");
	self.assertTrueMsg(realAutoComp.myTerminal = term, "Update terminal is wrong");
	self.assertTrueMsg(realAutoComp.doAutoComparison = false, "Update doAutoComparison is wrong");
//	self.assertTrueMsg(realAutoComp.comparisonFields.size = compFields.size = true, "Update comparisonFields is wrong");
//	self.assertTrueMsg(realAutoComp.comparisonFields.membersSame(compFields), "Create comparisonFields is wrong");
	self.assertTrueMsg(realAutoComp.myEmailTemplate &lt;&gt;  null, "Update EMail Template is wrong");
	
	delete pxyAutoComp;

	app.myTrxDA.trxDeleteEDICompCon(realAutoComp, app.myPassport);
	self.assertTrueTrxOKShowPassport("Delete EDI Auto Comparison");
	
epilog
	delete pxyAutoComp;
	delete sa;
	delete compfields;
	delete ignoreFields;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVoyageEDIIssues" id="b72aa80a-5cfa-40cb-a06e-83165978960d">
        <source>tVoyageEDIIssues();
/*
Purpose:	
Date		Who		Reason
08 July 2024	navab1	CR 64617 TASK 65065 NAVAB1 09JUL2024
*/
constants
	IssueCode = "UT_HELP";
	IssueDesc = "Unit Test EDI Issue";
	EmailAddress1 = "andrew.bishop@kaleris.com";
vars
	pxyIssue, realIssue : CM_EDIIssue;
	term : CM_Terminal;

	sa : StringArray;
	emailTempl : CM_EmailTemplate;
	
begin
	create sa transient;
	sa.add(ETRow_FileType);
	
	term := self.getTerminal();
	
	realIssue := term.allEDIIssues[IssueCode] ;
	if realIssue&lt;&gt; null then
		app.myTrxDA.trxDeleteEDIIssue(realIssue, app.myPassport);
		self.assertTrueTrxOKShowPassport("Delete  EDI Issue HELP");
	endif;
	
	// ### TEST EXPECTED ERRORS
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Issue_must_have_descrip); 
	self.expectedTrxErrors.add(Issue_must_have_code); 
	self.expectedTrxErrors.add(Issue_must_have_termina); 

	self.opts.addAssoc("ExpectErrors",true);
	
	create pxyIssue transient;
	app.myTrxCA.trxCreateEDIIssue(pxyIssue, realIssue, app.myPassport);
	
	self.assertEqualMsg(self.checkErrorWarnAllHaveOccurred(), true, "Unexpected CREATE error");
	self.assertTrueMsg(realIssue = null, "Create realAM should be null");
	
	delete pxyIssue;
	self.clearExpectedTrxErrors();
	self.opts.addAssoc("ExpectErrors",false);
	
	// ### TRY CREATE AGAIN
	create emailTempl transient;
	emailTempl.setProxyForEDIIssue(EmailAddress1,EmailAddress1,EmailAddress1,
												"EDI EMAIL ISSUES",
												"This is the body of the email",
												"Email Issue",
												true,
												sa
												);


	
	create pxyIssue transient;
	pxyIssue.setProxy(term, IssueCode, IssueDesc, true,true, emailTempl);
		
	app.myTrxCA.trxCreateEDIIssue(pxyIssue, realIssue, app.myPassport);
	self.assertTrueTrxOKShowPassport("Create EDI Issue");
	self.assertTrueMsg(realIssue &lt;&gt; null, "Create realAM is null");
	self.assertTrueMsg(realIssue.myTerminal = term, "Create terminal is wrong");
	self.assertTrueMsg(realIssue.code = IssueCode, "Create code  should be IssueCode");
	self.assertTrueMsg(realIssue.description = IssueDesc, "Create description should be IssueDesc");
	self.assertTrueMsg(realIssue.includeLoadIssue = true, "Create includeLoadIssue is wrong");
	self.assertTrueMsg(realIssue.includeVerifyIssue = true, "Create includeVerifyIssue is wrong");
	self.assertTrueMsg(realIssue.myEmailTemplate &lt;&gt;  null, "Create EMail Template is wrong");
	self.assertTrueMsg(realIssue.myEmailTemplate.bccAddresses = EmailAddress1, "Create Email BCC  is wrong");
	self.assertTrueMsg(realIssue.myEmailTemplate.toAddresses = EmailAddress1, "Create Email BCC  is wrong");
	self.assertTrueMsg(realIssue.myEmailTemplate.bccAddresses = EmailAddress1, "Create Email BCC  is wrong");
	self.assertTrueMsg(realIssue.myEmailTemplate.allIncludedFields.membersSame(sa), "Create Email selected fields  is wrong");
	self.assertTrueMsg(realIssue.myEmailTemplate.sendtoOperatorVoyage = true, "Create Email Include 5  is wrong");
	
	delete pxyIssue;
		
	pxyIssue := app.createUpdateProxy(realIssue).CM_EDIIssue;
	emailTempl :=  app.createUpdateProxy(realIssue.myEmailTemplate).CM_EmailTemplate;
	
	self.assertTrueMsg(pxyIssue &lt;&gt; null, "pxyAM is null");

	pxyIssue.setProxy(term, IssueCode &amp; "X", IssueDesc &amp; "X", false,false, emailTempl);
	
	app.myTrxUA.trxUpdateEDIIssue(pxyIssue, app.myPassport);
	self.assertTrueMsg(realIssue &lt;&gt; null, "Update realAM is null");
	self.assertTrueMsg(realIssue.myTerminal = term, "Update terminal is wrong");
	self.assertTrueMsg(realIssue.code = IssueCode &amp; "X", "Update code  should be IssueCode");
	self.assertTrueMsg(realIssue.description = IssueDesc &amp; "X", "Update description should be IssueDesc");
	self.assertTrueMsg(realIssue.includeLoadIssue = false, "Update includeLoadIssue is wrong");
	self.assertTrueMsg(realIssue.includeVerifyIssue = false, "Update includeVerifyIssue is wrong");
	self.assertTrueMsg(realIssue.myEmailTemplate &lt;&gt;  null, "Update EMail Template is wrong");
	
	delete pxyIssue;

	app.myTrxDA.trxDeleteEDIIssue(realIssue, app.myPassport);
	self.assertTrueTrxOKShowPassport("Delete EDI Issue");
	
epilog
	delete pxyIssue;
	delete sa;

end;</source>
    </JadeMethod>
    <JadeMethod name="tVoyageProcessAutoProgress" id="9d72e9a9-841a-4c64-ab14-01780b834bd5">
        <source>tVoyageProcessAutoProgress();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2024	navra1	Initial creation for //navra1 - TFS 65380 - 7th Aug 2024
02 Feb 2025 navlc30 JIRA 33860 Unit test UT_Voyage::tVoyageProcessAutoProgress needs to be fixed
19 Sep 2025 navlc30 JIRA 33860 Unit test UT_Voyage::tVoyageProcessAutoProgress needs to be fixed

*/
constants	
	INV_TYPE : String = 'INV_TYPE';
	VOYAGE_ID : String = 'UT_AUTOVOY';
	VESSEL_ID : String = 'VESSEL';
	UT_OPERATOR : String = 'MSC';
	SHIP_LINE : String = "CMA";
	INVOICE_SERV_ID : String = 'INVOICE_SERV_ID';
	GL_CODE : String = 'GL_CODE';
	GL_CODE_REM : String = 'GL_CODE_REM';
	INV_LINE_TYP_ID : String = 'INV_LINE_TYP_ID';
	UT_ILTFSD2 : String = "RECEIVESHIP";
	UT_ILTFSD3 : String = "RELEASESHIP";
	CALC_TYPE : String = 'CALC_TYPE';
	MEASURE_TYPE : String = 'MEA_TYPE';
	VESSL_CODE : String = 'VESSL_CODE';
	LLOYDS_ID : String = '123444';
	CARGO_TR_MAP : String = 'LoadMap2';
	USER_DEF_NAME : String = "JMTInternalShipManifest";
	LLFILENAME : String = "File";					
	UserDefinedLoadList : String = 'DPW Terminal';	
vars
	oldDeferredConfig : Any;
	services	: CM_ServiceByNameDict;	
	invType : CM_InvoiceDesc;
	ti : CM_TrackedItem;
	voyage : CM_Voyage;
	operator : CM_Operator;
	calcType : CM_CalculationType;
	mesType : CM_MeasurementType;
	glCode : CM_GLCode;
	service : CM_Service;
	invLineType : CM_InvoiceLineDesc;
	vessel : CM_Vessel;
	
	fileContent : String;
	fileName	: String;
	mapName		: String;
	cargoMap	: CM_TranMap;
	tiMap : CM_TIServiceMap;
	pgm : CM_ProductGroupMap;
	mapProduct : CM_ProductMap;
	imexsm : CM_ImexServiceMap;
	csn : CM_ContentsMap;
	commodityMap:      CM_CommodityMap;
	tsb : CM_TransServiceBroker;
	qm	: CM_QuantityMap;
	qrm	: CM_QuantityRangeMap;

	recFound,
	relFound	: Boolean;
	
	bank	: CM_Bank;
	terminal : CM_Terminal;
	originalVoyageProcess : String;
	
	ediFileManifest : CM_EDIFile;
	ediFileDischList : CM_EDIFile;
	ediText : String;
	ediData : CM_EDIData;
	errorMsg : String;
	
	pxyFileTypeUser : CM_EDIFileTypeUser;
	xmlformatString : String;
	
	fileTypeUser : CM_EDIFileTypeUser;	
	
	voyStage : CM_VoyageStage;
	
	stage : Integer;
	operatorCode : String;
	//allInvoices : CM_InvoiceBySeqNumDict;
	debtorCode : String; 
	ediDataDesc : String;
	description : String;
	failureMessage : String;
	stageDescription :String;
	type : Integer;
	status : Integer;
	statusStr : String;
	manLoad, dischlistLoad, manMove, invoiceGen, invPost, voyClosed : Boolean;
	now : TimeStamp;
	realAM : CM_EDIAutoMovements;
	moveTS : TimeStamp;
	pxyAM, realAMConfig : CM_EDIComparisonConfig;
	ignoreFields,compFields : StringArray;
	emailTemplate : CM_EmailTemplate;
	currPortDestCode : String;
	oa : ObjectArray;
	ediDatas : CM_EDIDataArray;
	stops : CM_StopsByIdDict;
	stop : CM_Stops;
begin
	///////////////////////////////////////////////////////////////////////////
	//SETUP
	///////////////////////////////////////////////////////////////////////////	
	create oa transient;
	oldDeferredConfig := self.setTerminalConfig(DeferredCharging, false);	
	terminal := self.getMyTerminal();
	currPortDestCode := terminal.getConfig(PortDestCode).String.trimBlanks();
	self.assertNotNullMsg(terminal, "Terminal not available");
	self.assertEqualMsg(terminal.code , "UT", "The default terminal is not UT");
	if terminal.getConfig(DefaultVoyageProcess) &lt;&gt; null then
		originalVoyageProcess := terminal.getConfig(DefaultVoyageProcess).String;
	endif;
	
	self.setTerminalConfig(DefaultVoyageProcess, VoyageProcessAutomatic);
	
	beginTransaction;	
		if terminal.myEDIComparisonConfig &lt;&gt;null then			
			create ignoreFields transient;
			create compFields transient;
			
			ignoreFields.add(ETRow_Bol);
			ignoreFields.add(ETRow_BookingRef);
			ignoreFields.add(ETRow_Commodity);
			ignoreFields.add(ETRow_DestinationPort);
			ignoreFields.add(ETRow_DischargePort);
			ignoreFields.add(ETRow_TotalWeight);			
			
			pxyAM := app.createUpdateProxy(terminal.myEDIComparisonConfig).CM_EDIComparisonConfig;
			pxyAM.setProxy(terminal, null, true, compFields, ignoreFields);
			
			app.myUtilityUA.utlUpdateEDICompCon(pxyAM, app.myPassport);
		else
			create pxyAM transient;		
			create ignoreFields transient;
			create compFields transient;
			
			ignoreFields.add(ETRow_Bol);
			ignoreFields.add(ETRow_BookingRef);
			ignoreFields.add(ETRow_Commodity);
			ignoreFields.add(ETRow_DestinationPort);
			ignoreFields.add(ETRow_DischargePort);
			ignoreFields.add(ETRow_TotalWeight);			
			
			pxyAM.setProxy(terminal, null, true, compFields, ignoreFields);
			
			app.myUtilityCA.utlCreateEDICompCon(pxyAM, realAMConfig, app.myPassport);
			
		endif;	
	commitTransaction;
	
	realAM := self.autoVoyageMoveConfig(-30, Voyage_DepartedUnique);// ### TFS BUG 65730 22AUG2024 NAVAB1
	self.assertTrueMsg(realAM &lt;&gt; null, "Auto movement Config is null");
	self.assertTrueMsg(terminal.myEDIAutoMove &lt;&gt; null, "Term Auto movement Config is null");
	
	self.deleteInvoiceLineType(INV_LINE_TYP_ID, FORCED_ERASE);	
	self.deleteInvoiceLineType(UT_ILTFSD2, FORCED_ERASE);	
	self.deleteInvoiceLineType(UT_ILTFSD3, FORCED_ERASE);	
	self.deleteInvoiceType(INV_TYPE);
	self.deleteInvoiceService(INVOICE_SERV_ID, FORCED_ERASE);
	self.deleteCalculationType(CALC_TYPE, FORCED_ERASE);
	self.deleteMeasurementType(MEASURE_TYPE);	
	self.deleteInvoiceGLCode(GL_CODE);
	self.deleteVessel(VESSEL_ID);
	self.deleteInvoiceTransactionMap(1, CARGO_TR_MAP);	
	
	create services transient;
	
	self.opts.addAssoc(CM_InvoiceDesc::invoiceKey.name ,CM_InvoiceDesc.Key_Voyage);
	invType := self.createInvoiceType(INV_TYPE, InvoiceTypeGeneral);
	
	//
	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, MEASURE_TYPE, Type_Weight, MEASURE_TYPE);
	
	self.assertNotNull(mesType);
	
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_CARGOWEIGHTCONVT, CALC_TYPE, CALC_TYPE, 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
		null, null, null, "SUPERUSER", true, false, false, null, null, null, mesType);
	
	self.assertNotNullMsg(calcType, "Calculation type UT_MDHCONVW not created");

	glCode := self.createInvoiceGLCode(GL_CODE, GL_CODE_REM);
	service := self.createInvoiceService(INVOICE_SERV_ID, "MDH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();	
	
	services.add(service);
	invLineType := self.createInvoiceLineType(INV_LINE_TYP_ID, calcType, invType, services, "SDT1");
	invLineType := self.createInvoiceLineType(UT_ILTFSD2, calcType, invType, services, "SDT1");
	invLineType := self.createInvoiceLineType(UT_ILTFSD3, calcType, invType, services, "SDT1");
	//
	
	self.assertNotNullMsg(invType, "Invoice type " &amp; INV_LINE_TYP_ID &amp; " not created");
	
	self.assertTrueMsg(invLineType &lt;&gt; null, "NULL INVOICE LINE TYPE");
	self.assertTrueMsg(invLineType.invoiceType &lt;&gt; null, "NULL INVOICE  TYPE on Line TYPE");
	
	operator := app.myRoot.allOperators[UT_OPERATOR];
	self.assertNotNullMsg(operator, "Operator MSC not found");
		
	//load transaction map for relese ship and receive ship	
	fileName := "ResourceLoad";
	mapName := CARGO_TR_MAP;	
	
	fileContent := self.getLargeStringValue('MAPFILE', null, currPortDestCode);
	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := self.getTerminal().getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);


	///
	
	cargoMap := bank.currentTransactionMap;
	self.assertNotNullMsg(cargoMap,"cargo map should not be null - 2");	
	self.assertEqualMsg(cargoMap.name,"LoadMap2", "the test is not using the map just created(LoadMap2)");	

	// check the map
	foreach tiMap in cargoMap.tiServiceMap do
		foreach pgm in tiMap.allProductGroupMaps do
			foreach mapProduct in pgm.allProductMaps do
				foreach imexsm in mapProduct.allImExMaps do
					foreach csn in imexsm.contentsMaps do
						foreach commodityMap in csn.commoditiesMap do
							foreach tsb in commodityMap.allTransServiceBrokersByType do
								if tsb.className = "CM_ReceiveShip" then
									recFound := true;
									qm := tsb.myChildQuantityMap;
									foreach qrm in qm.allQuantityRanges do 
										// TFS 40620 self.assertEqualMsg(qrm.allInvoiceLineMaps.size, 8, "receive allInvoiceLineMaps size");
										self.assertEqualMsg(qrm.allTMInvoiceLineMappings.size, 1, "receive allTMInvoiceLineMappings size");
										// TFS 40620 self.assertEqualMsg(qrm.allInvoiceLinesUsed.size, 2, "receive allInvoiceLinesUsed size");
									endforeach;
								elseif tsb.className = "CM_ReleaseShip" then
									relFound := true;
									qm := tsb.myChildQuantityMap;
									foreach qrm in qm.allQuantityRanges do
										// TFS 40620 self.assertEqualMsg(qrm.allInvoiceLineMaps.size, 3, "release allInvoiceLineMaps size");
										self.assertEqualMsg(qrm.allTMInvoiceLineMappings.size, 1, "release allTMInvoiceLineMappings size");
										// TFS 40620 self.assertEqualMsg(qrm.allInvoiceLinesUsed.size, 1, "release allInvoiceLinesUsed size");
									endforeach;
								endif;
							endforeach;
						endforeach;
					endforeach;
				endforeach;
			endforeach;
		endforeach;
	endforeach;
	//
	
	vessel := self.addVesselCellularWithCode( VESSEL_ID, "UT - Do not Touch", operator );
	beginTransaction;
		vessel.setPropertyValue("lloydsNumber",LLOYDS_ID);
	commitTransaction;
	
	///////////////////////////////////////////////////////////////////////////
	//UC-1 - 1 Operator, loading of manifest, and then loadlist
	///////////////////////////////////////////////////////////////////////////
	self.opts.addAssoc("tsArrival" ,now);

	voyage := self.addVoyageWithContainerStructur(VOYAGE_ID, VESSEL_ID, operator.code, SHIP_LINE);
	beginTransaction;
		voyage.setPropertyValue(CM_Voyage::inwardCodeAuto.name,'INWARD001');
		//terminal.allVoyagesByInwardCodeAuto.add(voyage);
		voyage.setPropertyValue(CM_Voyage::myTerminalForInwardCodeAuto.name,terminal);
	//	voyage.myTerminalForInwardCodeAuto := terminal;
	commitTransaction;
	self.assertNotNull(voyage);
	
	//CHECK - check if the voyage process is AUTOMATIC
	self.assertTrueMsg(voyage.myVoyageProcess.isKindOf(CM_VoyageProcessAutomatic), "The voyage process is not AUTOMATIC");
	
	//CHECK - check if the voyage progress is initialized
	self.assertNotNullMsg(voyage.myVoyageProgress, "The voyage progress is not initialized");
	
	//CHECK - check if allstages is not null
	self.assertNotNullMsg(voyage.myVoyageProgress.allStages, "The voyage progress stages is null");
	
	//CHECK - check if no stages exist on the progress
	self.assertTrueMsg(voyage.myVoyageProgress.allStages.size() = 0, "The voyage has stages in the start, which is wrong");
	
	//
	// setup the add ship manifest here
	ediText := self.getLargeStringValue('SHIPMANIFESTNAME_UC1_MSC',VOYAGE_ID,currPortDestCode);
	
	ediFileManifest := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);
	//
	self.assertNotNull(ediFileManifest);
	self.assertEqualMsg(true, app.myPassport.allErrors.isEmpty(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertNotNull(ediFileManifest.ediData);
	self.ediVerify(ediFileManifest);
	errorMsg := "Verify Failed" &amp; CrLf &amp; app.myPassport.getErrorsAsString();	
	self.assertEqualMsg(ediFileManifest.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediData := ediFileManifest.ediData;
	self.assertNotNullMsg(ediData, "EDIData was null");
	self.ediDBLoad(ediFileManifest);
	oa.add(ediData);
	oa.add(ediFileManifest);

	errorMsg := "DB Load Failed" &amp; CrLf &amp; app.myPassport.getErrorsAsString();
	self.assertEqualMsg(ediFileManifest.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	//verify if the cargo was created on the ship
	//self.assertTrueMsg(voyage.allOnshipTIsByCargoTypeId.size() = 3, "The cargo created on ship on loading the manifest was not 3 as expected");

	//create allInvoices transient;
	
	//verify if the stage for manifest load was created and it was successful
	self.assertTrueMsg(voyage.myVoyageProgress.allStages.size() = 2, "The voyage has stages unexpected number of stages, we only expect edimanifestload and comparison stage to be there");
	
	voyStage := voyage.myVoyageProgress.allStages.first();
	voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
	self.assertEqualMsg(stage, CM_VoyageStage.VoyStage_DischManLoad, "The stage found was not CM_VoyageStage.VoyStage_DischManLoad");
	self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischManLoad stage was not successful");
	self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischManLoad stage was classfied as discharge");
	
	//clear stops
	foreach ti in voyage.allOnshipTIsByCargoTypeId do
		stops := ti.getAllStops;
		now := now.addDays(30);
		foreach stop in stops do
			self.clearStopWithExpiry(ti, stop.myStopsTable, "1234", now.date);
		endforeach;
	endforeach;
	
	create pxyFileTypeUser transient;	
	xmlformatString := self.getLargeStringValue('DPWTERMINALFORMAT', null,currPortDestCode);	
	pxyFileTypeUser.importMeXML(xmlformatString);
	fileTypeUser := self.uCreateEDIFileTypeUser(pxyFileTypeUser);
	self.assertTrueMsg( fileTypeUser &lt;&gt; null, "User Defined Type not created during setup.");
	delete pxyFileTypeUser;
	
	ediText := self.getLargeStringValue('DISCHLIST_UC1_MSC',null,currPortDestCode);
	
	ediFileDischList := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedLoadList, LLFILENAME&amp;method.name);
	
	self.assertNotNull(ediFileDischList);
	self.assertEqualMsg(true, app.myPassport.allErrors.isEmpty(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertNotNull(ediFileDischList.ediData);
	self.ediVerify(ediFileDischList);
	self.assertTrueMsg(ediFileDischList.fileStatus = CM_EDIFile.EDI_STATUS_VERIFIED, "Discharge list file was not verified");	
	
	oa.add(ediFileDischList.ediData);//asdfasdfasdf//
	oa.add(ediFileDischList);	
	
	
	//self.clearStopWithExpiry(
	
	// now everything should have happened - check everything
	foreach voyStage in voyage.myVoyageProgress.allStages do
		if voyStage.stage = CM_VoyageStage.VoyStage_DischManLoad then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischManLoad stage was not successful");
			self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischManLoad stage was classfied as discharge");
			self.assertEqualMsg(operatorCode, 'MSC', "CM_VoyageStage.VoyStage_DischManLoad stage does not have MSC as the operator");
			
			manLoad := true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_DischListLoad	then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischListLoad stage was not successful");
			self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischListLoad stage was classfied as discharge");
			
			dischlistLoad:=true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_DischManMoved then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischManMoved stage was not successful");
			self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischManMoved stage was classfied as discharge");			
			self.assertTrueMsg(voyage.allOffsiteTIsByIdCargoType.size() = 3, "CM_VoyageStage.VoyStage_DischManMoved stage not all the cargo have been discharged and sent offsite");
			
			ti := voyage.allOffsiteTIsByIdCargoType.first;
			
			
			moveTS:= terminal.myEDIAutoMove.getDateForMove(voyage);
			moveTS:= realAM.getDateForMove(voyage);
			assertTrueMsg(moveTS = ti.receivedDT, "Move Date is wrong");
			
			manMove := true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_InvoiceGenerated then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertTrueMsg(voyStage.allInvoices.size() = 1, "CM_VoyageStage.VoyStage_InvoiceGenerated stage does not have invoices");						
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_InvoiceGenerated stage was not successful");			
			
			invoiceGen :=true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_InvoicePosted	then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_InvoicePosted stage was not successful");
			
			
			invPost := true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_VoyageClosed	then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_VoyageClosed stage was not successful");		
			
			self.assertEqualMsg(voyage.status, Voyage_Status_Closed_Auto, "The voyage was not closed");					
			
			voyClosed :=true;
		endif;
		
	endforeach;	
	
	self.assertTrueMsg(manLoad, "CM_VoyageStage.VoyStage_DischManLoad stage was done");
	self.assertTrueMsg(dischlistLoad, "CM_VoyageStage.VoyStage_DischListLoad stage was done");
	self.assertTrueMsg(manMove, "CM_VoyageStage.VoyStage_DischManMoved stage was done");
	self.assertTrueMsg(invoiceGen, "CM_VoyageStage.VoyStage_InvoiceGenerated stage was done");
	self.assertTrueMsg(invPost, "CM_VoyageStage.VoyStage_InvoicePosted stage was done");
	self.assertTrueMsg(voyClosed, "CM_VoyageStage.VoyStage_VoyageClosed stage was done");
	
	/* Set voyage status to Departed */
	updateVoyageStatus(Voyage_Status_Departed,voyage);
	
	if ediDatas = null then
		create ediDatas transient;
	endif;
	voyage.getAllEDILoadLists(ediDatas);
	if ediDatas &lt;&gt; null and ediDatas.size() &gt; 0 then
		beginTransaction;
			ediDatas.purge();
		commitTransaction;
	endif;
	delete ediDatas;
	
	self.deleteVoyage(VOYAGE_ID);
	
	
	
	///////////////////////////////////////////////////////////////////////////
	//UC-2 - 2 Operators, load of load list and 1 by 1 loading of manifests
	///////////////////////////////////////////////////////////////////////////
	
	
	voyage := self.addVoyageWithContainerStructur(VOYAGE_ID, VESSEL_ID, operator.code, SHIP_LINE);
	operator := app.myRoot.allOperators['ONEY'];
	if operator &lt;&gt; null then
		beginTransaction;
			voyage.allOperators.add(operator);
		commitTransaction;
	endif;
	
	beginTransaction;
		voyage.setPropertyValue(CM_Voyage::inwardCodeAuto.name,'INWARD001');
		//terminal.allVoyagesByInwardCodeAuto.add(voyage);
		voyage.setPropertyValue(CM_Voyage::myTerminalForInwardCodeAuto.name,terminal);
	//	voyage.myTerminalForInwardCodeAuto := terminal;
	commitTransaction;
	self.assertNotNull(voyage);
	
	//CHECK - check if the voyage process is AUTOMATIC
	self.assertTrueMsg(voyage.myVoyageProcess.isKindOf(CM_VoyageProcessAutomatic), "The voyage process is not AUTOMATIC");
	
	//CHECK - check if the voyage progress is initialized
	self.assertNotNullMsg(voyage.myVoyageProgress, "The voyage progress is not initialized");
	
	//CHECK - check if allstages is not null
	self.assertNotNullMsg(voyage.myVoyageProgress.allStages, "The voyage progress stages is null");
	
	//CHECK - check if no stages exist on the progress
	self.assertTrueMsg(voyage.myVoyageProgress.allStages.size() = 0, "The voyage has stages in the start, which is wrong");
	
	
	ediText := self.getLargeStringValue('SHIPMANIFESTNAME_UC2_MSC',VOYAGE_ID,currPortDestCode);	
	
	ediFileManifest := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);	
	
	//
	self.assertNotNull(ediFileManifest);
	self.assertEqualMsg(true, app.myPassport.allErrors.isEmpty(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertNotNull(ediFileManifest.ediData);
	self.ediVerify(ediFileManifest);
	errorMsg := "Verify Failed" &amp; CrLf &amp; app.myPassport.getErrorsAsString();	
	self.assertEqualMsg(ediFileManifest.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediData := ediFileManifest.ediData;
	self.assertNotNullMsg(ediData, "EDIData was null");
	self.ediDBLoad(ediFileManifest);

	oa.add(ediData);
	oa.add(ediFileManifest);
	
	//clear stops
	foreach ti in voyage.allOnshipTIsByCargoTypeId do
		stops := ti.getAllStops;
		now := now.addDays(30);
		foreach stop in stops do
			self.clearStopWithExpiry(ti, stop.myStopsTable, "1234", now.date);
		endforeach;
	endforeach;
	
	errorMsg := "DB Load Failed" &amp; CrLf &amp; app.myPassport.getErrorsAsString();
	self.assertEqualMsg(ediFileManifest.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	//verify if the cargo was created on the ship
	self.assertTrueMsg(voyage.allOnshipTIsByCargoTypeId.size() = 2, "The cargo created on ship on loading the manifest was not 2 as expected, UC-2");

	//create allInvoices transient;
	
	//verify if the stage for manifest load was created and it was successful
	self.assertTrueMsg(voyage.myVoyageProgress.allStages.size() = 2, "The voyage has stages unexpected number of stages, we only expect edimanifestload of MSC to be there, UC-2");
	
	voyStage := voyage.myVoyageProgress.allStages.first();
	voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
	self.assertEqualMsg(stage, CM_VoyageStage.VoyStage_DischManLoad, "The stage found was not CM_VoyageStage.VoyStage_DischManLoad, UC2");
	self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischManLoad stage was not successful, UC2");
	self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischManLoad stage was classfied as discharge, UC2");
	
	ediText := self.getLargeStringValue('DISCHLIST_UC2_MSC_ONEY',null,currPortDestCode);
	
	ediFileDischList := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedLoadList, LLFILENAME&amp;method.name);
	
	oa.add(ediFileDischList);
	
	self.assertNotNull(ediFileDischList);
	self.assertEqualMsg(true, app.myPassport.allErrors.isEmpty(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertNotNull(ediFileDischList.ediData);
	self.ediVerify(ediFileDischList);
	self.assertTrueMsg(ediFileDischList.fileStatus = CM_EDIFile.EDI_STATUS_VERIFIED, "Discharge list file was not verified, UC2");	
	
	// now everything should have happened wrt MSC - check everything
	foreach voyStage in voyage.myVoyageProgress.allStages do
		if voyStage.stage = CM_VoyageStage.VoyStage_DischManLoad then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischManLoad stage was not successful, UC2 MSC");
			self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischManLoad stage was classfied as discharge, UC2 MSC");
			self.assertEqualMsg(operatorCode, 'MSC', "CM_VoyageStage.VoyStage_DischManLoad stage does not have MSC as the operator, UC2 MSC");
			
			manLoad := true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_DischListLoad	then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischListLoad stage was not successful, UC-2 MSC");
			self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischListLoad stage was classfied as discharge, UC-2 MSC");
			
			dischlistLoad:=true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_DischManMoved then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			if operatorCode = 'MSC' then
				self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischManMoved stage was not successful, UC-2 MSC");
				self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischManMoved stage was classfied as discharge, UC-2 MSC");						
				self.assertTrueMsg(voyage.allOffsiteTIsByIdCargoType.size() = 2, "CM_VoyageStage.VoyStage_DischManMoved stage not all the cargo have been discharged and sent offsite, UC-2 MSC");
			endif;
			
			manMove := true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_InvoiceGenerated then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(voyStage.allInvoices.size(), 1, "CM_VoyageStage.VoyStage_InvoiceGenerated stage does not have invoices, UC-2 MSC");									
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_InvoiceGenerated stage was not successful, UC-2 MSC");			
			
			invoiceGen :=true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_InvoicePosted	then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_InvoicePosted stage was not successful, UC-2 MSC");
			
			
			invPost := true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_VoyageClosed	then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_WAITING, "CM_VoyageStage.VoyStage_VoyageClosed stage is not in waiting state, UC-2 MSC");		
			
			self.assertNotEqualMsg(voyage.status, Voyage_Status_Closed_Auto, "The voyage was closed, which is wrong , UC-2");					
			
			voyClosed :=true;
		endif;
		
	endforeach;	
	
	self.assertTrueMsg(manLoad, "CM_VoyageStage.VoyStage_DischManLoad stage was done");
	self.assertTrueMsg(dischlistLoad, "CM_VoyageStage.VoyStage_DischListLoad stage was done");
	self.assertTrueMsg(manMove, "CM_VoyageStage.VoyStage_DischManMoved stage was done");
	self.assertTrueMsg(invoiceGen, "CM_VoyageStage.VoyStage_InvoiceGenerated stage was done");
	self.assertTrueMsg(invPost, "CM_VoyageStage.VoyStage_InvoicePosted stage was done");
	self.assertTrueMsg(voyClosed, "CM_VoyageStage.VoyStage_VoyageClosed stage was done");
	
	//Now load ONEY's manifest
	ediText := self.getLargeStringValue('SHIPMANIFESTNAME_UC2_ONEY',VOYAGE_ID,currPortDestCode);	
	
	ediFileManifest := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);
	//
	self.assertNotNull(ediFileManifest);
	self.assertEqualMsg(true, app.myPassport.allErrors.isEmpty(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertNotNull(ediFileManifest.ediData);
	self.ediVerify(ediFileManifest);
	errorMsg := "Verify Failed" &amp; CrLf &amp; app.myPassport.getErrorsAsString();	
	self.assertEqualMsg(ediFileManifest.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediData := ediFileManifest.ediData;
	self.assertNotNullMsg(ediData, "EDIData was null");
	self.ediDBLoad(ediFileManifest);
	
	//really?
	//clear stops
	foreach ti in voyage.allOnshipTIsByCargoTypeId do
		stops := ti.getAllStops;
		now := now.addDays(30);
		foreach stop in stops do
			self.clearStopWithExpiry(ti, stop.myStopsTable, "1234", now.date);
		endforeach;
	endforeach;

	oa.add(ediData);
	oa.add(ediFileManifest);
	
	errorMsg := "DB Load Failed" &amp; CrLf &amp; app.myPassport.getErrorsAsString();
	self.assertEqualMsg(ediFileManifest.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	//verify if the cargo was created on the ship
	self.assertTrueMsg(voyage.allOnshipTIsByCargoTypeId.size() = 0, "The cargo created on ship on loading the manifest was not 0 as expected, the cargo would have already been discharged since we have the manifest and the load list have been loaded, UC-2 ONEY");
	
	// now everything should have happened wrt MSC - check everything
	foreach voyStage in voyage.myVoyageProgress.allStages do
		if voyStage.stage = CM_VoyageStage.VoyStage_DischManLoad then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);			
			
			if operatorCode = 'MSC' then
				self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischManLoad stage was not successful, UC2 MSC(ONEY)");
				self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischManLoad stage was classfied as discharge, UC2 MSC(ONEY)");
				self.assertEqualMsg(operatorCode, 'MSC', "CM_VoyageStage.VoyStage_DischManLoad stage does not have MSC as the operator, UC2 MSC(ONEY)");
			elseif operatorCode = 'ONEY' then
				self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischManLoad stage was not successful, UC2 ONEY");
				self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischManLoad stage was classfied as discharge, UC2 ONEY");
				self.assertEqualMsg(operatorCode, 'ONEY', "CM_VoyageStage.VoyStage_DischManLoad stage does not have MSC as the operator, UC2 ONEY");
			endif;
			
			manLoad := true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_DischListLoad	then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischListLoad stage was not successful, UC-2 ONEY");
			self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischListLoad stage was classfied as discharge, UC-2 ONEY");
			
			dischlistLoad:=true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_DischManMoved then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			if operatorCode = 'ONEY' then
				self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischManMoved stage was not successful, UC-2 ONEY");
				self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischManMoved stage was classfied as discharge, UC-2 ONEY");						
				self.assertTrueMsg(voyage.allOffsiteTIsByIdCargoType.size() = 3, "CM_VoyageStage.VoyStage_DischManMoved stage not all the cargo have been discharged and sent offsite, UC-2 2(MSC) 1ONEY");
			endif;
			
			manMove := true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_InvoiceGenerated then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			if operatorCode = 'ONEY' then
				self.assertEqualMsg(voyStage.allInvoices.size(), 1 , "CM_VoyageStage.VoyStage_InvoiceGenerated stage does not have invoices, UC-2 ONEY");									
				self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_InvoiceGenerated stage was not successful, UC-2 ONEY");			
			elseif operatorCode = 'MSC' then
				self.assertEqualMsg(voyStage.allInvoices.size(), 1 , "CM_VoyageStage.VoyStage_InvoiceGenerated stage does not have invoices, UC-2 ONEY(MSC)");									
				self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_InvoiceGenerated stage was not successful, UC-2 ONEY(MSC)");			
			endif;
			
			invoiceGen :=true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_InvoicePosted	then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_InvoicePosted stage was not successful, UC-2 ONEY");
			
			
			invPost := true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_VoyageClosed	then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_VoyageClosed stage is not in waiting state, UC-2 ONEY");		
			
			self.assertEqualMsg(voyage.status, Voyage_Status_Closed_Auto, "The voyage was not closed, which is wrong , UC-2, ONEY");					
			
			voyClosed :=true;
		endif;
		
	endforeach;	
	
	
	/* Set voyage status to Departed */
	updateVoyageStatus(Voyage_Status_Departed,voyage);
	
	if ediDatas = null then
		create ediDatas transient;
	endif;
	voyage.getAllEDILoadLists(ediDatas);
	if ediDatas &lt;&gt; null and ediDatas.size() &gt; 0 then
		beginTransaction;
			ediDatas.purge();
		commitTransaction;
	endif;
	delete ediDatas;
	
	self.deleteVoyage(VOYAGE_ID);	
	
	///////////////////////////////////////////////////////////////////////////
	//UC-3 - 1 Operator, loading of manifest, and then loadlist, with errors in the stages
	///////////////////////////////////////////////////////////////////////////
	
	voyage := self.addVoyageWithContainerStructur(VOYAGE_ID, VESSEL_ID, operator.code, SHIP_LINE);
	operator := app.myRoot.allOperators[UT_OPERATOR];		//02.02.2025 navlc30 #33860
	if operator = null then									//22.09.2025 navlc30 #33860
		operator := self.addOperatorSimple (UT_OPERATOR, UT_OPERATOR);
	endif;
	if operator &lt;&gt; null then								//02.02.2025 navlc30 #33860
		if not voyage.allOperators.includes(operator) then
			beginTransaction;
				voyage.allOperators.add(operator);
			commitTransaction;				
		endif;
	endif;
	beginTransaction;
		voyage.setPropertyValue(CM_Voyage::inwardCodeAuto.name,'INWARD001');
		//terminal.allVoyagesByInwardCodeAuto.add(voyage);
		voyage.setPropertyValue(CM_Voyage::myTerminalForInwardCodeAuto.name,terminal);
	//	voyage.myTerminalForInwardCodeAuto := terminal;
	commitTransaction;
	self.assertNotNull(voyage);
	
	//CHECK - check if the voyage process is AUTOMATIC
	self.assertTrueMsg(voyage.myVoyageProcess.isKindOf(CM_VoyageProcessAutomatic), "The voyage process is not AUTOMATIC");
	
	//CHECK - check if the voyage progress is initialized
	self.assertNotNullMsg(voyage.myVoyageProgress, "The voyage progress is not initialized");
	
	//CHECK - check if allstages is not null
	self.assertNotNullMsg(voyage.myVoyageProgress.allStages, "The voyage progress stages is null");
	
	//CHECK - check if no stages exist on the progress
	self.assertTrueMsg(voyage.myVoyageProgress.allStages.size() = 0, "The voyage has stages in the start, which is wrong");
	
	//
	// setup the add ship manifest here
	ediText := self.getLargeStringValue('SHIPMANIFESTNAME_UC1_MSC',VOYAGE_ID,currPortDestCode);
	
	ediFileManifest := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);
	//
	self.assertNotNull(ediFileManifest);
	self.assertEqualMsg(true, app.myPassport.allErrors.isEmpty(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertNotNull(ediFileManifest.ediData);
	self.ediVerify(ediFileManifest);
	errorMsg := "Verify Failed" &amp; CrLf &amp; app.myPassport.getErrorsAsString();	
	self.assertEqualMsg(ediFileManifest.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediData := ediFileManifest.ediData;
	self.assertNotNullMsg(ediData, "EDIData was null");
	self.ediDBLoad(ediFileManifest);
	
	oa.add(ediData);
	oa.add(ediFileManifest);
	
	//clear stops
	foreach ti in voyage.allOnshipTIsByCargoTypeId do
		stops := ti.getAllStops;
		now := now.addDays(30);
		foreach stop in stops do
			self.clearStopWithExpiry(ti, stop.myStopsTable, "1234", now.date);
		endforeach;
	endforeach;
	
	errorMsg := "DB Load Failed" &amp; CrLf &amp; app.myPassport.getErrorsAsString();
	self.assertEqualMsg(ediFileManifest.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	//verify if the cargo was created on the ship
	self.assertTrueMsg(voyage.allOnshipTIsByCargoTypeId.size() = 3, "The cargo created on ship on loading the manifest was not 3 as expected");

	//create allInvoices transient;
	
	//verify if the stage for manifest load was created and it was successful
	self.assertTrueMsg(voyage.myVoyageProgress.allStages.size() = 2, "The voyage has stages unexpected number of stages, we only expecte edimanifestload to be there");
	
	voyStage := voyage.myVoyageProgress.allStages.first();
	voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
	self.assertEqualMsg(stage, CM_VoyageStage.VoyStage_DischManLoad, "The stage found was not CM_VoyageStage.VoyStage_DischManLoad");
	self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischManLoad stage was not successful");
	self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischManLoad stage was classfied as discharge");
	
	create pxyFileTypeUser transient;	
	xmlformatString := self.getLargeStringValue('DPWTERMINALFORMAT', null,currPortDestCode);	
	pxyFileTypeUser.importMeXML(xmlformatString);
	fileTypeUser := self.uCreateEDIFileTypeUser(pxyFileTypeUser);
	self.assertTrueMsg( fileTypeUser &lt;&gt; null, "User Defined Type not created during setup.");
	delete pxyFileTypeUser;
	
	ediText := self.getLargeStringValue('DISCHLIST_UC1_MSC_WRONG',null,currPortDestCode);
	
	ediFileDischList := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedLoadList, LLFILENAME&amp;method.name);
	
	self.assertNotNull(ediFileDischList);
	self.assertEqualMsg(true, app.myPassport.allErrors.isEmpty(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertNotNull(ediFileDischList.ediData);
	self.ediVerify(ediFileDischList);
	self.assertTrueMsg(ediFileDischList.fileStatus = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, "Discharge list does not have verified warnings as expected");	
	
	oa.add(ediFileDischList);
	
	//check if the stage was created but didnt pass
	foreach voyStage in voyage.myVoyageProgress.allStages do
		if voyStage.stage = CM_VoyageStage.VoyStage_DischManLoad then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischManLoad stage was not successful, UC-3");
			self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischManLoad stage was classfied as discharge, UC-3");
			self.assertEqualMsg(operatorCode, 'MSC', "CM_VoyageStage.VoyStage_DischManLoad stage does not have MSC as the operator, UC-3");
			
			manLoad := true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_DischListLoad	then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			//self.assertEqualMsg(status, CM_VoyageStage.STATUS_FAILED, "CM_VoyageStage.VoyStage_DischListLoad stage did not fail, UC-3");   &lt;&lt;-- we allow load list with warnings to proceed, so the stage will not fail anymore	//18.09.2025 navlc30 #33860
			self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischListLoad stage was classfied as discharge, UC-3");
			
		endif;		
	endforeach;
	
	//fix the file and load it again and verify
	ediText := self.getLargeStringValue('DISCHLIST_UC1_MSC',null,currPortDestCode);
	
	ediFileDischList := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedLoadList, LLFILENAME&amp;method.name);
	
	self.assertNotNull(ediFileDischList);
	self.assertEqualMsg(true, app.myPassport.allErrors.isEmpty(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertNotNull(ediFileDischList.ediData);
	self.ediVerify(ediFileDischList);
	self.assertTrueMsg(ediFileDischList.fileStatus = CM_EDIFile.EDI_STATUS_VERIFIED, "Discharge list is not verified, UC-3");
	
	oa.add(ediFileDischList);
	
	// now everything should have happened - check everything
	foreach voyStage in voyage.myVoyageProgress.allStages do
		if voyStage.stage = CM_VoyageStage.VoyStage_DischManLoad then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischManLoad stage was not successful");
			self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischManLoad stage was classfied as discharge");
			self.assertEqualMsg(operatorCode, 'MSC', "CM_VoyageStage.VoyStage_DischManLoad stage does not have MSC as the operator");
			
			manLoad := true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_DischListLoad	then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischListLoad stage was not successful");
			self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischListLoad stage was classfied as discharge");
			
			dischlistLoad:=true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_DischManMoved then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_DischManMoved stage was not successful");
			self.assertEqualMsg(type, CM_VoyageStage.Type_Discharge, "CM_VoyageStage.VoyStage_DischManMoved stage was classfied as discharge");			
			self.assertTrueMsg(voyage.allOffsiteTIsByIdCargoType.size() = 3, "CM_VoyageStage.VoyStage_DischManMoved stage not all the cargo have been discharged and sent offsite");
			
			manMove := true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_InvoiceGenerated then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertTrueMsg(voyStage.allInvoices.size() = 1, "CM_VoyageStage.VoyStage_InvoiceGenerated stage does not have invoices");						
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_InvoiceGenerated stage was not successful");			
			
			invoiceGen :=true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_InvoicePosted	then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_InvoicePosted stage was not successful");
			
			
			invPost := true;
		elseif voyStage.stage  = CM_VoyageStage.VoyStage_VoyageClosed	then
			voyStage.retrieveVoyageStageDetails(stage ,operatorCode , debtorCode , ediDataDesc, description ,failureMessage ,stageDescription ,type ,status ,statusStr);
			
			self.assertEqualMsg(status, CM_VoyageStage.STATUS_SUCCESS, "CM_VoyageStage.VoyStage_VoyageClosed stage was not successful");		
			
			self.assertEqualMsg(voyage.status, Voyage_Status_Closed_Auto, "The voyage was not closed");					
			
			voyClosed :=true;
		endif;
		
	endforeach;	
	
	self.assertTrueMsg(manLoad, "CM_VoyageStage.VoyStage_DischManLoad stage was done");
	self.assertTrueMsg(dischlistLoad, "CM_VoyageStage.VoyStage_DischListLoad stage was done");
	self.assertTrueMsg(manMove, "CM_VoyageStage.VoyStage_DischManMoved stage was done");
	self.assertTrueMsg(invoiceGen, "CM_VoyageStage.VoyStage_InvoiceGenerated stage was done");
	self.assertTrueMsg(invPost, "CM_VoyageStage.VoyStage_InvoicePosted stage was done");
	self.assertTrueMsg(voyClosed, "CM_VoyageStage.VoyStage_VoyageClosed stage was done");
	
	/* Set voyage status to Departed */
	updateVoyageStatus(Voyage_Status_Departed,voyage);

epilog	
	
	self.resetDefaultTranMap();
	
	if ediDatas = null then
		create ediDatas transient;
	endif;
	if voyage &lt;&gt; null then
		voyage.getAllEDILoadLists(ediDatas);
	endif;
	if ediDatas &lt;&gt; null and ediDatas.size() &gt; 0 then
		beginTransaction;
			ediDatas.purge();
		commitTransaction;
	endif;
	delete ediDatas;
	
	self.deleteVoyage(VOYAGE_ID);	
	self.deleteInvoiceLineType(INV_LINE_TYP_ID, FORCED_ERASE);	
	self.deleteInvoiceLineType(UT_ILTFSD2, FORCED_ERASE);	
	self.deleteInvoiceLineType(UT_ILTFSD3, FORCED_ERASE);	
	self.deleteInvoiceType(INV_TYPE);
	self.deleteInvoiceService(INVOICE_SERV_ID, FORCED_ERASE);
	self.deleteCalculationType(CALC_TYPE, FORCED_ERASE);
	self.deleteMeasurementType(MEASURE_TYPE);	
	self.deleteInvoiceGLCode(GL_CODE);
	self.deleteVessel(VESSEL_ID);
	
	delete services;
	delete pxyAM;
	delete ignoreFields;
	delete compFields;
	beginTransaction;
		if oa &lt;&gt; null then
			oa.purge();
		endif;
	commitTransaction;
	delete oa;
	
	//delete pxyAM;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uAutoVoyageProgress" id="12f7b5f7-6dc7-4282-9663-41d6f384d232">
        <updating/>
        <source>uAutoVoyageProgress() updating;
/*
Purpose:	

Date		Who		Reason
19 July 2024	navab1	CR 64612 TASK 64659
*/

vars
	progress : CM_VoyageProgress;
	realStage : CM_VoyageStage;
	voyage : CM_Voyage;
	term : CM_Terminal;
	op1, op2 : CM_Operator;
	ts : TimeStamp;
	yyyymmddhh : String;
begin
	term := self.getTerminal();

	voyage := term.allVoyagesByCode.getAtKeyGeq("NOHMS240719",null);
	progress := voyage.myVoyageProgress;
	if progress = null then
		app.myTrxCA.trxCreateVoyageProgress(voyage, app.myPassport);
	endif;
	progress := voyage.myVoyageProgress;
	
	self.assertTrueMsg(progress &lt;&gt; null, "Progress Object is null");
	
	op1 := voyage.myOperator;
	op2 := self.getOperator("ABOS");
	
	self.deleteAllVoyageStages(progress);
	
	yyyymmddhh := voyage.arrivedDT.formatAsYYYYMMDDHHmmSS()[1:10];
	
	
	
	ts.setFromYYYYMMDDHHmm(yyyymmddhh &amp; "00");
	self.voyageStageCreate(ts, CM_VoyageStage.VoyStage_LoadListLoad, progress, op1.code, CM_VoyageStage.STATUS_SUCCESS,CM_VoyageStage.Type_Load,"AB Ship Load List");		
	ts.setFromYYYYMMDDHHmm(yyyymmddhh &amp; "01");
	self.voyageStageCreate(ts, CM_VoyageStage.VoyStage_DischListLoad, progress, op1.code, CM_VoyageStage.STATUS_SUCCESS,CM_VoyageStage.Type_Discharge,"AB Ship Discharge List");		
	ts.setFromYYYYMMDDHHmm(yyyymmddhh &amp; "02");
	self.voyageStageCreate(ts, CM_VoyageStage.VoyStage_LoadManLoad, progress, op1.code, CM_VoyageStage.STATUS_SUCCESS, CM_VoyageStage.Type_Load,"AB OnSite Manifest");		
	ts.setFromYYYYMMDDHHmm(yyyymmddhh &amp; "03");
	realStage := self.voyageStageCreate(ts, CM_VoyageStage.VoyStage_DischManLoad, progress, op1.code, CM_VoyageStage.STATUS_WAITING, CM_VoyageStage.Type_Discharge,"AB OnShip Manifest");		
	ts.setFromYYYYMMDDHHmm(yyyymmddhh &amp; "04");
	self.voyageStageCreate(ts, CM_VoyageStage.VoyStage_LoadManMoved, progress, op1.code, CM_VoyageStage.STATUS_SUCCESS,CM_VoyageStage.Type_Load,"");		
	ts.setFromYYYYMMDDHHmm(yyyymmddhh &amp; "06");
	self.voyageStageCreate(ts, CM_VoyageStage.VoyStage_InvoiceGenerated, progress, op1.code, CM_VoyageStage.STATUS_SUCCESS,CM_VoyageStage.Type_Load,"");		
	ts.setFromYYYYMMDDHHmm(yyyymmddhh &amp; "08");
	self.voyageStageCreate(ts, CM_VoyageStage.VoyStage_InvoicePosted, progress, op1.code, CM_VoyageStage.STATUS_WAITING, CM_VoyageStage.Type_Load,"");		
	ts.setFromYYYYMMDDHHmm(yyyymmddhh &amp; "10");
	
	ts.setFromYYYYMMDDHHmm(yyyymmddhh &amp; "05");
	self.voyageStageCreate(ts, CM_VoyageStage.VoyStage_LoadListLoad, progress, op2.code, CM_VoyageStage.STATUS_SUCCESS,CM_VoyageStage.Type_Load,"AB Ship Load List");		
	ts.setFromYYYYMMDDHHmm(yyyymmddhh &amp; "07");
	self.voyageStageCreate(ts, CM_VoyageStage.VoyStage_LoadManLoad, progress, op2.code, CM_VoyageStage.STATUS_SUCCESS, CM_VoyageStage.Type_Load,"AB OnSite Manifest");		
	ts.setFromYYYYMMDDHHmm(yyyymmddhh &amp; "09");
	self.voyageStageCreate(ts, CM_VoyageStage.VoyStage_LoadManMoved, progress, op2.code, CM_VoyageStage.STATUS_SUCCESS,CM_VoyageStage.Type_Load,"");		
	ts.setFromYYYYMMDDHHmm(yyyymmddhh &amp; "11");
	self.voyageStageCreate(ts, CM_VoyageStage.VoyStage_InvoiceGenerated, progress, op2.code, CM_VoyageStage.STATUS_SUCCESS, CM_VoyageStage.Type_Load,"");		
	ts.setFromYYYYMMDDHHmm(yyyymmddhh &amp; "13");
	self.voyageStageCreate(ts, CM_VoyageStage.VoyStage_InvoicePosted, progress, op2.code, CM_VoyageStage.STATUS_FAILED, CM_VoyageStage.Type_Load,"");		
	
	
//	process.sleep(3000);
	
	ts.setFromYYYYMMDDHHmm(yyyymmddhh &amp; "03");
	self.voyageStageUpdate(ts, realStage,CM_VoyageStage.VoyStage_DischManLoad, progress, op1.code, CM_VoyageStage.STATUS_SUCCESS, CM_VoyageStage.Type_Discharge, null, null, "AB OnShip Manifest");		
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uCheckVoyageAllocationSetting" id="1a5139f5-c4a2-425f-a67e-77ce4849b9c3">
        <source>uCheckVoyageAllocationSetting();

/*

Purpose:		Check the default setting of Voyage Allocations
				- For new vessel should be true
				- For vessel with existing voyage should default to the previous voyage
				
Date			Who		Reason
26/05/014		cnwmh5	Initial creation

*/

constants

	VesselId					: String = "MDHVESSELVA";
	VoyageIdFirst				: String = "UTMDHVVA1";
	VoyageIdSecond				: String = "UTMDHVVA2";
	VoyageIdThird				: String = "UTMDHVVA3";

vars

	vessel						: CM_Vessel;
	voyage						: CM_Voyage;

begin

	self.deleteVoyage(VoyageIdFirst);
	self.deleteVoyage(VoyageIdSecond);
	self.deleteVoyage(VoyageIdThird);
	self.deleteVessel(VesselId);

	vessel := self.addVesselCellular(VesselId, app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString()]);
	self.assertNotNull(vessel);
	
	voyage := self.addVoyageWithConRORO(VoyageIdFirst, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), self.getProfileSetting(UT_Profile.P_TRADE).asString(), 
		0, true, false);
	self.assertNotNull(voyage);
	self.assertEqual(voyage.useVoyageAllocations, true);
	
	// set use voyage allocation to false
	beginTransaction;
	voyage.useVoyageAllocations := false;
	commitTransaction;
	self.assertEqual(voyage.useVoyageAllocations, false);
	
	voyage := self.addVoyageWithConRORO(VoyageIdSecond, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), self.getProfileSetting(UT_Profile.P_TRADE).asString(), 
		0, true, false);
	self.assertNotNull(voyage);
	self.assertEqual(voyage.useVoyageAllocations, false);
	
	// set use voyage allocation to false
	beginTransaction;
	voyage.useVoyageAllocations := true;
	commitTransaction;
	self.assertEqual(voyage.useVoyageAllocations, true);
	
	voyage := self.addVoyageWithConRORO(VoyageIdThird, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), self.getProfileSetting(UT_Profile.P_TRADE).asString(), 
		0, true, false);
	self.assertNotNull(voyage);
	self.assertEqual(voyage.useVoyageAllocations, true);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateVoyage" id="c9ccac4c-4deb-4504-9da5-4aed1e303489">
        <updating/>
        <source>uCreateVoyage() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/01/2014	cnwma1	Initial creation

*/

constants

	VesselId			: String = "AOR";
	VoyageId			: String = "UT_URORA123";
	ShipLine			: String = "CMA";
	CargoCntr			: String = "APZU1234567";
	BlockStackId		: String = "UT_RDBS1";
	YardIC				= "UT_RD_IC";
	YardAlloc			= 'RDALLOC';
	CraneTransferAreaId	= "CTMADWY";
	CraneId				= "CRR1";

vars
	dischargeTi,
	ti					: CM_TrackedItem;
	vessel				: CM_Vessel;
	voyage 				: CM_Voyage;
	operator			: CM_Operator;
	shipline			: CM_ShippingLine;
	cntr				: CM_Container;
	theSlot				: CM_LocationsController;
	bs 					: CM_BlockStack;
	tmpLoadCC			: CMIF_LoadColorCode;
	
	strs 				: StringArray;
	idx 				: Integer;
	aPort 				: CM_Port;
	voyageDeck 			: CM_DeckVoyage;
	lcs 				: CM_LCArray;
	
	bayName				: String;
	yardIC				: CM_InterchangeArea;
	locations 			: CM_LCArray;
	yaName				: String;
	ya					: CM_YardAllocation;
	cta					: CM_CraneTransferArea;
	tas					: StringArray;
	crane				: CM_Machine;
	dischargePort,
	loadPort			: CM_Port;
	slots 				: CM_SlotControllerArray;
	voyageJob			: CM_VoyageJob;
	job					: CM_Job;
	jobs				: CM_JobArray;
	wle					: CM_WorkListEntry;
	wles 				: CM_WLEArray;
	voyageQueue			: CM_VoyageQueue;
	craneQueue			: CM_VoyageCraneQueue;
	request				: CM_Request;
	straddle			: CM_Machine;
	agent				: CM_MobileAgent;
	looper				: Integer;
begin	
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNull(operator);

		/*
	bs := self.getTerminal().allTerminalAreasByTypeId.getAtKey(app.myRoot.allTerminalAreaTypes.getAtKey(1).type, BlockStackId).CM_BlockStack;
	if bs = null then
		bs := self.addBlockStack(BlockStackId, 99, null).CM_BlockStack;
		self.assertNotNull(bs);
	endif;

	location := bs.allLocationsControllers.first;
	self.assertNotNull(location);
	*/
	//Delete Voyage  &amp; Voyage if exist
	self.deleteVoyage(VoyageId);
    self.assertNoTrxErrorsOrWarnings();
	//self.deleteVessel(VesselId);
	//self.assertNoTrxErrorsOrWarnings();
		
	// Create Vessel
	//vessel := self.addVesselCellular(VesselId,operator);
	//self.assertNotNull(vessel);
	
	// Create Voyage
	voyage := self.addVoyageWithContainerStructur(VoyageId,VesselId,operator.code,ShipLine);
	self.assertNotNull(voyage);
	
	// Delete CNTR from YARD
	self.deleteContainer(CargoCntr);
	self.assertNoTrxErrorsOrWarnings();
	
	// Create Container
	//cntr :=self.addContainerAtLocation(CargoCntr,operator,"2200","GENL",1,BlockStackId);
	//self.assertNotNull(cntr);
	
		aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		///create strs transient;
/*	
	// ### FORWARD 20 GENERALS
	strs.clear;
	strs.add("010784");
	voyage.findLocation(strs, false, theSlot, idx);
	self.opts.addAssoc(UTTI_TotalWeight, 18000);
	cntr := self.addContainerAtLocnDisch(CargoCntr, "2200", "GENL", 1, theSlot, aPort, voyage);
	self.assertTrueMsg((cntr.getImExStatus() =1), "ImEx Import is wrong" );
	*/
	
	
		///////////////////////////////////////////////////////////////// Discharge Process ////////////////////////////////////////////////////////
		// create the terminal areas - gridded block stack, block stack and interchange
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	yardIC := self.addInterchangeArea(YardIC, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	bs := self.addBlockStack(BlockStackId, 20, null);		
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	create locations transient;
	
	locations.add(bs.allLocationsControllers.first);
	yaName := YardAlloc;
	self.deleteYA(YardAlloc);
	ya := self.addYA1WithFill(YardAlloc, YACriteriaType_OperatorItem, operator.code, locations, YAFillOption_InOrder, YAFillOption_FIFO,false);
	
	
	// create the crane transfer area
	self.deleteMachine(CraneId);
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	self.deleteMachine(CraneId);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	delete tas;
	
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	loadPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	//create discharge job
	bayName := '07';
	create slots transient;
	self.getJobSlotControllers(VoyageId, bayName, DeckOnDeck, 1, 1, 1, slots);
	assertEqual(slots.size, 1);
	dischargeTi := self.addContainerAtLocnDisch(CargoCntr , "2200", "GENL", 1, slots[1], dischargePort, voyage);
	
	// Color code and Create Discharge Jobs
	//self.voyageDischargeColourCode(voyage);
	create tmpLoadCC transient;
	//self.markSlotsAsLoadJob(slots, tmpLoadCC);
	self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, true);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job 1 not created");
	//jobs.add(voyageJob);
	
	foreach wle in voyageJob.workListEntries do
		self.movePlannedWLE(wle.myTrackedItem, 	bs.myLocationsController, wle);
	endforeach;
	delete slots;
	

	self.opts.purge();
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc("ISOType", '2200');

	//load to ops
	self.loadAllJobsToOps(voyage, true);				
	
	self.addMachineRule( bs, crane.CM_Crane.transferArea, RTMoveMethod_23); //simple single straddle moves
	self.addMachineRule( crane.CM_Crane.transferArea, bs, RTMoveMethod_23); 
		
	voyageQueue := self.addVoyageQueue(voyage);
	craneQueue := self.addVoyageCraneQueue(voyage, voyageQueue, crane);
	
	// Create Queues
	//create wles transient;
	//foreach job in jobs do
		foreach request in voyageJob.allRequests do
			foreach wle in request.allWorkListEntries do
				if wle.CM_VoyageWLE.myRequest.CM_SlotRequest.isLoad then
					//wles.add(wle);
					self.autoplanWLE(wle);
				else
					//wles.add(wle);
					self.queueWLE(wle);
				endif;

			endforeach;
		endforeach;
	//endforeach;
	


	// workJob using straddle
	
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add(bs.id); 
	tas.add(yardIC.id); 
	tas.add(crane.CM_Crane.transferArea.id); 
	self.addStraddle("UTS1", 91, tas, null);
	straddle := self.getMachine("UTS1");
	assertNotNull(straddle);
	if craneQueue &lt;&gt; null then
		beginTransaction;
		straddle.addToQueue(craneQueue, true, 0); //add straddle to crane queue
		commitTransaction;
	endif;
	delete tas;
	
	app.isRTApp:=true;  
	self.machineLogon(straddle);
	// Use Lander to move to ship
	create agent transient;

	looper := 1;
	//foreach wle in wles do
		if wle.isReceipt and wle.job.isVoyageJob then 
			//crane := wle.job.CM_VoyageJob.getJobCrane();
			self.machineAcceptTask(straddle, wle.allRTQueueEntries.first.allTasks.first);
			self.machineCraneActionPickup(straddle, dischargeTi, ti);
			self.machinePickup(straddle);			
			self.machineSetdownTask(straddle, wle.allRTQueueEntries.first.allTasks.last, bs.id);	
	
		endif;
		
	//endforeach;	
	
	self.assertTrue( dischargeTi.myPrimaryActualLocation.isYardLocation);

	
	// check txns created correctly for the following
	self.checkTIForTxnOfType(dischargeTi, TRANS_TYPE_REC_SHIP);			// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(dischargeTi, TRANS_TYPE_WHARFAGE);			// 15/08/2012 cnwmh5
	
	
	

	
epilog
	app.isRTApp:=false;  
	delete jobs;
	delete slots;
	delete wles;
	delete tas;	
	delete agent;
	delete tmpLoadCC;

	delete locations;
	self.disableAllYA(false);

end;</source>
    </JadeMethod>
    <JadeMethod name="uDeleteAllVoyages" id="0f618348-03a3-487b-9dc9-e2d28f58a79f">
        <source>uDeleteAllVoyages();
//29 March 2010	cnwdw1	
//
vars
	voyage:CM_Voyage;
	voyageCode: String;
begin
	voyageCode := "Enter Yes to delete all voyages";
	read voyageCode;
	if voyageCode = "Yes" then
		foreach voyage in self.getTerminal.allVoyagesByCode do
			if voyage.isNullVoyage then
				continue;
			endif;
			write "Delete: " &amp; voyage.code;
			self.deleteVoyage(voyage.code);
		endforeach;
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="uDeleteVoyage" id="4fca8b0f-5a45-424f-8668-38ec56508fd5">
        <source>uDeleteVoyage();
//29 March 2010	cnwdw1	
//
vars
	voyageCode: String;
begin

	read voyageCode;
	
	self.deleteVoyage(voyageCode);
end;</source>
    </JadeMethod>
    <JadeMethod name="uDeleteVoyageTrackedItems" id="6e4ac1da-cbe4-47a7-b402-08629ecfe36f">
        <source>uDeleteVoyageTrackedItems();

/*

Purpose:		Delete tracked items for a voyage excluding any that are in the dontDeleteTrackedItem array	
				in a specific terminal

Parameters:			

Return Value:		


Date			Who		Reason
24 September 2012	cnwmh5	Initial creation

*/
constants
	TerminalId				: String = "MH1";
	VoyageId				: String = "ITL0000A";
vars

	ti						: CM_TrackedItem;
	voyage					: CM_Voyage;
	terminal				: CM_Terminal;

	dontDeleteTIArray		: CM_StringArray;
	
begin

	create dontDeleteTIArray transient;
	dontDeleteTIArray.add("AMFU4150260");
	
	self.opts.purge();
	self.opts.addAssoc("terminal", TerminalId);
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	self.assertEqual(terminal.code, TerminalId);
	
	
	foreach voyage in terminal.allVoyagesByCode do
		if voyage.code = VoyageId then
			break;
		endif;
	endforeach;
	
	
	foreach ti in voyage.allOnshipTIsByCargoTypeId discreteLock do
		if dontDeleteTIArray.includes(ti.id) then
			continue;
		endif;
		
		self.deleteTrackedItem(ti, false);
	endforeach;

	
	

epilog

	delete dontDeleteTIArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="updateVoyageCodes" id="7c2e20c7-e71f-4384-a6c9-abe89db6052e">
        <source>updateVoyageCodes(voyage 			  : CM_Voyage; 
				  newVoyageCode 	  : String; 
				  newVoyageInwardCode : String);
/****Changes

Date		Name	TFS#			Description
============================================================================
23/10/2010	cnwas3				
08/04/2011	cnwmh5	PAR #27347  	Add cmsEndLoad or endLoad to epilog so that 
									if error occurs it will not leave it in beginLoad state
05/03/2015	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
============================================================================*/
vars
	proxyVoyage 	: CM_Voyage;
	conflictManager : CMIF_HMS_ConflictsManager;
	yearOfBuild		: Integer;
begin
	if voyage = null then
		return;
	endif;
	//proxyVoyage := app.createUpdateProxy(_voyage).CM_Voyage;	
	beginLoad;
	proxyVoyage := voyage.pxyCreateUpdateProxy();
	endLoad;
	
	if self.opts.includesKey("YearOfBuild") then				// 23/01/2014 cnwmh5
		yearOfBuild := self.opts.int("YearOfBuild");
	endif;
		
	proxyVoyage.setProxyVoyage(	voyage.bitmap,
							voyage.callSign,
							newVoyageCode,	//the new codes
							newVoyageInwardCode,	//the new codes
							voyage.remarks,
							voyage.vesselCode,
							voyage.vesselName,
							voyage.lloydsNumber,
							voyage.archived,
/*PAR 33644							_voyage.isNonPlannedVoyage,
							_voyage.isNonWorkedVoyage, */
							voyage.isTransferable,
							voyage.starboardBerthed,
							voyage.craneClearance,
							voyage.displayOption,
							voyage.colour,
							voyage.status,
							voyage.vesselType,
							voyage.archivedDT,
							voyage.arrivedDT,
							voyage.departedDT,
							voyage.loadStartDT,
							voyage.loadEndDT,
							voyage.nonPlannedEffectiveDT,
							voyage.cutOffDT,
							null,
							null,
							voyage.myOperator,
							voyage.myTrade,
							voyage.myShippingLine,
							voyage.myTerminal,
							voyage.myVoyageGlobalArrival,
							null,
							null,
							null,
							null,
							null,
							voyage.voyageNumber,
							voyage.overrideDefaults,
							voyage.allOperators,
							null,
							voyage.useVoyageAllocations,
							voyage.externalRef,
							yearOfBuild,
							null,
							null,
							null,
							null,
							null,
							null,null,null,
							null,null,
							null,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407
							null,			// TFS 4050
							voyage.paymentType,
							voyage.isBarge,			 //jlgka1 TFS 37102
							voyage.voyageGroupCode,   //03/06/2020 cnwma1 Tfs #49400
							false	// 31.Aug.2023 navsp1 TFS 57809
							);										
	//proxyVoyage.addPortToAllPorts(app.myRoot.allPorts["NZAKA"]);
	//proxyVoyage.addPortToAllPorts(app.myRoot.allPorts["NZGMN"]);
	//proxyVoyage.addPortToAllPorts(app.myRoot.allPorts["NZGOB"]);
	//proxyVoyage.addPortToAllPorts(app.myRoot.allPorts["NZDUG"]);
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateVoyage(true,false,proxyVoyage,conflictManager,null,false,app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete proxyVoyage;
	delete conflictManager;
end;</source>
        <Parameter name="voyage" type="CM_Voyage"/>
        <Parameter name="newVoyageCode" type="String"/>
        <Parameter name="newVoyageInwardCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="voyageStageCreate" id="d8881e3f-68ac-4e8a-a80e-501cef1e189a">
        <source>voyageStageCreate(_dateTime : TimeStamp; _stage : Integer; _voyageProgress : CM_VoyageProgress; _operatorCode : String; _status : Integer; _type : Integer; _ediDesc :String) : CM_VoyageStage;
/*
Purpose:	

Date		Who		Reason
19 July 2024	navab1	CR 64612 TASK 64659
*/

vars
	progress : CM_VoyageProgress;
	pxyStage, realStage : CM_VoyageStage;
	voyage : CM_Voyage;
	term : CM_Terminal;
	op1, op2 : CM_Operator;
begin
	
	create pxyStage transient;
	pxyStage.setProxy(_stage,_voyageProgress,_operatorCode, _status, _type, null, null, null, null , null);			//navra1 - MTN-34348 - 13th March 2025
	app.myTrxCA.trxCreateVoyStageForOpAndVoy(pxyStage, realStage, app.myPassport);	
	
	self.assertTrueTrxOKShowPassport(method.qualifiedName);
	delete pxyStage;
	beginTransaction;
	realStage.setPropertyValue("ediDataDesc",_ediDesc);
	realStage.setPropertyValue("dateTime",_dateTime);
	commitTransaction;
	
	return realStage;
epilog	
	delete pxyStage;
end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_stage" type="Integer"/>
        <Parameter name="_voyageProgress" type="CM_VoyageProgress"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_ediDesc" type="String"/>
        <ReturnType type="CM_VoyageStage"/>
    </JadeMethod>
    <JadeMethod name="voyageStageUpdate" id="43e23bef-89b3-4dea-8ca1-9a8d2a243b6e">
        <updating/>
        <source>voyageStageUpdate(_dateTime : TimeStamp; _realStage : CM_VoyageStage input; _stage : Integer; _voyageProgress : CM_VoyageProgress; _operatorCode : String; _status : Integer; _type : Integer; _invoiceList: CM_InvoiceBySeqNumDict; _debtorCode : String;  _ediDesc :String) updating;
/*
Purpose:	

Date		Who		Reason
19 July 2024	navab1	CR 64612 TASK 64659
*/

vars
	progress : CM_VoyageProgress;
	pxyStage, realStage : CM_VoyageStage;
	voyage : CM_Voyage;
	term : CM_Terminal;
	op1, op2 : CM_Operator;
begin
	
	pxyStage := app.createUpdateProxy(_realStage).CM_VoyageStage;
	pxyStage.setProxy(_stage,_voyageProgress,_operatorCode, _status, _type, _invoiceList, _debtorCode, null, null , null);			//navra1 - MTN-34348 - 13th March 2025
	app.myTrxUA.trxUpdateVoyStageForOpAndVoy(pxyStage, app.myPassport);	
	
	self.assertTrueTrxOKShowPassport(method.qualifiedName);
	delete pxyStage;
	beginTransaction;
	_realStage.setPropertyValue("ediDataDesc",_ediDesc);
	_realStage.setPropertyValue("dateTime",_dateTime);
	commitTransaction;
	
epilog	
	delete pxyStage;
end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_realStage" type="CM_VoyageStage" usage="input"/>
        <Parameter name="_stage" type="Integer"/>
        <Parameter name="_voyageProgress" type="CM_VoyageProgress"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_invoiceList" type="CM_InvoiceBySeqNumDict"/>
        <Parameter name="_debtorCode" type="String"/>
        <Parameter name="_ediDesc" type="String"/>
    </JadeMethod>
</Class>
