//	btnPrintTV.translateBubbleHelp(Xlat_0018022, locale);
//	btnPrintTV.translateCaption(Xlat_0018023, locale);
//	btnRemFilter.translateCaption(Xlat_0018024, locale);
	btnResetJMT.translateBubbleHelp(Xlat_0000283, locale);
	btnResetJMT.translateCaption(Xlat_0000285, locale);
	btnResetSys.translateBubbleHelp(Xlat_0015987, locale);
	btnResetSys.translateCaption(Xlat_0000286, locale);
//	btnSelectAll.translateCaption(Xlat_0000287, locale);
	btnShow.translateCaption(Xlat_0018014, locale);
//	btnUnselectAll.translateCaption(Xlat_0000288, locale);
//	btnUpdFilter.translateCaption(Xlat_0000289, locale);
//	cbxSystem.translateBubbleHelp(Xlat_0017243, locale);
//	cbxSystem.translateCaption(Xlat_0017244, locale);
//	lblFilters.translateCaption(Xlat_0017245, locale);
	lblShowFilter.translateCaption(Xlat_0018015, locale);
//	optTableData.translateCaption(Xlat_0000290, locale);
//	optUserData.translateCaption(Xlat_0017246, locale);
//	shtColumnFilter.translateCaption(Xlat_0018021, locale);
