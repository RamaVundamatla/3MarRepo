    <JadeMethod name="getExtraInfo" id="07e10385-52c5-4b31-95ab-5d84ef843d59">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;
	yalDict : 	CM_YardAllocationsByCodeDict;
	aGridController : CM_GridController;
	yal : CM_YardAllocation;
begin
	create yalDict transient;

	block := _dataContainer.addNewBlock;
	block.addNewItem("Column", DC_Label, 1, self);
	block.addNewItem(self.myGridArea.id &amp; " Column " &amp; self.label , DC_Data, 1, self);

	
	foreach aGridController in self.allControllersByRow do
		// CCMS 1013
		//foreach yal in aGridController.allYardAllocations do
		foreach yal in aGridController.allYardAllocations where yal.includeInYardDisplays() do
			yalDict.addNoDuplicates(yal,false);
		endforeach;
	endforeach;
	
	foreach yal in yalDict do
		block := _dataContainer.addNewBlock;
		block.addNewItem("Yard Allocation", DC_MoreInfo, 1, self);
		yal.getExtraInfo(_dataContainer);
	endforeach;
epilog 
	delete yalDict;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
