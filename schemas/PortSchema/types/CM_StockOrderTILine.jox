    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="stkOrd"/>
    <ExplicitInverseRef name="myTrackedItem" id="074dd163-02ba-44e7-bd03-22400bfa1dff">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_TrackedItem"/>
