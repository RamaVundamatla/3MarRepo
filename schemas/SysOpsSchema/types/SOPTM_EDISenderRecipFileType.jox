    <JadeMethod name="setControlsForAddEdit" id="a3c811b7-6cff-4d96-87ae-7c0dab963e5e">
        <updating/>
        <source>setControlsForAddEdit() updating;
//
//08 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
vars
	theForm : SOP_TableMaintForm;
begin
 	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	if theForm.mode = theForm.Mode_Add then
		//not an option
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_EDISenderRecipFileType);
		// cannot update some rows
		theForm.tblInput1.disableRowByName(ETRow_Sender);		
		theForm.tblInput1.disableRowByName(ETRow_Recipient);		
		theForm.tblInput1.disableRowByName(ETRow_FileType);		
		theForm.tblInput1.disableRowByName(ETRow_FileVersion);		
		theForm.tblInput1.disableRowByName(ETRow_FileDateTime);		
		theForm.tblInput1.disableRowByName(ETRow_LastFileName);		
//		theForm.tblInput1.disableRowByName(ETRow_SeqNumber);		
		theForm.shtViewTable1.enabled := false;
	endif;
end;</source>
    </JadeMethod>
