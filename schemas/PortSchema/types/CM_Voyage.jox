        <source>excludeReport(set: Boolean; _value: Boolean io) mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwrd1	Initial creation

*/

vars

begin
	if set then
		// set code here
	else
		// get code here
		_value := false;		
		if self.myHMSVoyageData &lt;&gt; null then		// 10/06/2008 cnwar2 #16751
			_value := self.myHMSVoyageData.excludeReport;
		endif;

	endif;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
