    <JadeMethod name="actionOnTargetNode" id="21b0131f-da9a-4a01-9e50-65bc23aee71d">
        <updating/>
        <source>actionOnTargetNode() updating;
// ---------------------------------------------------------------------------
// Created:     27 May 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpAppType	: Character;
	tmpForm		: Form;
	tmpControl	: Control;
	nextProcess	: Process;
begin

	self.logEntry('Action on ' &amp; process.String);

	tmpAppType := app.applicationType;

	beginTransaction;

	self.appName := app.niceName;
	self.appType := tmpAppType;
	self.currentDateTime := app.actualTimeServer;
	self.userName := process.userCode;
	self.allFormDetails.clear;

	if self.allProcesses.includes(process) then
		self.allProcesses.remove(process);
	endif;

	if tmpAppType &lt;&gt; Application.ApplicationType_GUI then
		self.logEntry('Non GUI app for ' &amp; process.String);
		commitTransaction;
		return;
	endif;
	
	self.countForms();

	self.isBeingActioned	:= false;
	self.isRequestComplete 	:= true;
	
	commitTransaction;

epilog
	if process.isInTransactionState then
		// something went wrong so commit and return to initiator asap
		commitTransaction;
	endif;
	self.logEntry('Processing complete for process ' &amp; process.String);
	self.causeEvent(NR_NodeRequestCompleteEvent, true, self);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="countForms" id="c3123f3d-6308-4212-89bf-6d375f661ebb">
        <source>countForms() protected;
// ---------------------------------------------------------------------------
// Created:     27 May 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpForm	: Form;
	totForms,
	idx		: Integer;
	str		: String;
begin

	totForms := app.formsCount;

			
	foreach idx in 1 to totForms do
		tmpForm := app.forms(idx);
		str := '"' &amp; tmpForm.class.name &amp; '","' &amp;
			tmpForm.caption &amp; '", "' &amp;
			self.getWindowStateDescription(tmpForm.windowState) &amp; '"';
			
		self.allFormDetails.add(str);
	endforeach;
	
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getWindowStateDescription" id="d5bb1575-605b-4f29-a0b9-bc0272b69b9e">
        <source>getWindowStateDescription(_windowState : Integer) : String;
/*
----------   ----------  --------------------------------------------------
Created:	29 May 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _windowState = Form.WindowState_Normal then
		return 'Normal';
	elseif _windowState = Form.WindowState_Maximized then
		return 'Maximised';
	elseif _windowState = Form.WindowState_Minimized then
		return 'Minimised';
	endif;
	
end;</source>
        <Parameter name="_windowState" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="reset" id="4a5860c9-008f-46dc-90b1-2c500c5b6818">
        <updating/>
        <source>reset() updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	beginTransaction;
	self.isBeingActioned	:= false;
	self.isRequestComplete	:= false;
	self.allFormDetails.clear;
	commitTransaction;
	
end;</source>
    </JadeMethod>
