<Class name="ExplicitInverseRef">
    <JadeMethod name="jssGetInverses" id="0cca94a1-9f61-479d-8ccf-1d6cd52186b0">
        <source>jssGetInverses():InverseSet;
// --------------------------------------------------------------------------------
// Created:		05 May 2002 by cnwdad1
//
// Purpose:		Returns a set of the receiver's inverse (by reference) objects.
//
// Parameters:	None
//
// Returns:		A set of inverse objects, within a InverseSet.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.inverses);
end;</source>
        <ReturnType type="InverseSet"/>
    </JadeMethod>
</Class>
