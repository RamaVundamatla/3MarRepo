    <JadeMethod name="doDelete" id="15e66bb9-2ae4-4547-a29d-95401f779381">
        <updating/>
        <source>doDelete(_obj : CM_Object io) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 04/11/2016	cnwdap1		Initial creation TFS 2841 Hazardous Details Enhancement
//
vars

begin
