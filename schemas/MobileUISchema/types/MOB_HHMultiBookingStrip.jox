    <JadeMethod name="handleNotifications" id="f6c5e573-c73e-4a27-a9eb-e4f6ebd869e7">
        <updating/>
        <source>handleNotifications(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2016	cnwndl1	Initial creation

*/

vars

	doRefresh : Boolean;
	ti : CM_TrackedItem;
	selectedTi : CM_TrackedItem;

begin

	if theObject &lt;&gt; null and theObject.isKindOf( CM_TrackedItem ) then
		ti := theObject.CM_TrackedItem;
	else
		return;
	endif;

	if self.allSelectedConts.includes( ti ) then
		doRefresh := true;
	elseif self.allNotableObjects.includes( ti ) then
		doRefresh := true;
	endif;
	
	if doRefresh then
		self.myMobileGenericAgent.allConfirmedTis.clear();
		foreach selectedTi in self.allSelectedConts do
			self.myMobileGenericAgent.allConfirmedTis.add( selectedTi);
		endforeach;
		
		self.myMobileGenericAgent.setInward( self.chkByCont.value );
		self.myMobileGenericAgent.setDecimalField1( self.cmbSortBy.listIndex );
		self.myMobileGenericAgent.setStringField1( self.fldChildren.topSheet.caption );
		
		self.setupControls();
		
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="populateCmbSortBy" id="25bb750f-14a7-4f2d-882c-0aa776bc5fb4">
        <source>populateCmbSortBy()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation		TFS 2811 / 2549

*/

vars

begin

	self.cmbSortBy.clear();
	self.cmbSortBy.itemData[self.cmbSortBy.addItem( app.getErrorString(Sort_cargo_id) )] := 1;
	self.cmbSortBy.itemData[self.cmbSortBy.addItem( app.getErrorString(Sort_cargo_type_type) )] := 2;
	self.cmbSortBy.itemData[self.cmbSortBy.addItem( app.getErrorString(Sort_cargo_group_cargo) )] := 3;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateContainers" id="f18fa52a-f666-4a01-9dfd-3109801960e6">
        <updating/>
        <source>populateContainers() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation

*/

constants
	TAB_INDEX_START = 1000;
vars

	bookingRef : CM_BookingRef;
	ti : CM_TrackedItem;
	availableConts : CM_TISet;
	selectedConts : CM_TISet;
	
	buttonNumber : Integer;
	menuButton : MOB_Button;
	buttonWidth : Real;
	size : Integer;
	buttonHeight : Integer;
	buttonOffset : Integer;
	
	docActions : CM_DocumentActions;
	taskAndStopStr : String;
	
	dummyIndex : Integer;
	extraDisplay : String;
	reason : String;

begin

	self.docActsToDisplay1.clear();	//03 Mar 2017	NDL	TFS 3299

	size := self.availButtonCount + self.selectedButtonCount;  // to allow for nulti moving done in setupControls
	if size &gt; 0 then
		foreach buttonNumber in 1 to size do
			menuButton := self.btnAvailTemp.getControl( buttonNumber ).MOB_Button;
			if menuButton &lt;&gt; null then
				delete menuButton;
			endif;
		endforeach;
		self.availButtonCount := 0;
		buttonNumber := 0;
	endif;


	create availableConts transient;
	create selectedConts transient;
	
	foreach bookingRef in self.myMobileGenericAgent.allSelectedBookings discreteLock do
		foreach ti in bookingRef.allTIs discreteLock do
			if ti.isContainer then
				if not ti.isOnSite then
					continue;
				endif;
				if ti.allChildren.isEmpty and ti.myPrimaryQueuedLocation &lt;&gt; null then	//10 Feb 2017	NDL	TFS 3297
					if self.allSelectedConts.includes( ti ) then
						self.allSelectedConts.remove(ti);
					endif;
					continue;
				endif;
				if self.allSelectedConts.includes( ti ) then
					selectedConts.addNoDuplicates( ti, false );
				else
					availableConts.addNoDuplicates( ti, false );
				endif;
			endif;
		endforeach;
	endforeach;
	
	//available
	size := availableConts.size;
	buttonHeight := self.getScrollingButtonHeight();
	self.btnAvailTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmContAvail, self.btnAvailTemp.height, self.scrContAvail );
	
	foreach ti in availableConts do
	
		if  ti.myBookingRefItem &lt;&gt; null then
			docActions := ti.myBookingRefItem.myBookingRefItemActions;
		else
			docActions := null;
		endif;
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnAvailTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" 
										&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		elseif ( ti.isBulkByWeight or ti.isBulkByVolume ) then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")" 
										&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		endif;
		
		extraDisplay := null;
		if docActions &lt;&gt; null then
			taskAndStopStr := docActions.getTaskAndStopStrForTi(ti,true);
			if taskAndStopStr &lt;&gt; null then
				extraDisplay := " " &amp; taskAndStopStr;
			endif;
		endif;
		if ti.allChildren.isEmpty then
			extraDisplay := extraDisplay &amp; " " &amp; app.getErrorString(Empty);
			if ti.myPrimaryQueuedLocation &lt;&gt; null then
				extraDisplay := extraDisplay &amp; " " &amp; app.getErrorString(RTQMachineTableAnnotateMove);
			endif;
		endif;
		menuButton.caption := menuButton.caption &amp; extraDisplay;
		
		self.addHazDetailsToButton( menuButton, ti, " " ); //30 May 2017	NDL	TFS 4587
		
		menuButton.enabled := true;
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	self.availButtonCount := buttonNumber;
	
	self.btnAvailTemp.visible := false;
	self.frmContAvail.caption := null;
	
	lblNoContAvail.visible := (buttonNumber = 0);
	
	//Selected
	
	if self.selectedButtonCount &gt; 0 then
		foreach buttonNumber in 1 to self.selectedButtonCount do
			menuButton := self.btnSelectedTemp.getControl( buttonNumber ).MOB_Button;
			if menuButton &lt;&gt; null then
				delete menuButton;
			endif;
		endforeach;
		self.selectedButtonCount := 0;
		buttonNumber := 0;
	endif;
	
	buttonNumber := 0;
	buttonOffset := 0;
	size := selectedConts.size;
	buttonHeight := self.getScrollingButtonHeight();
	self.btnSelectedTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmContSel, self.btnSelectedTemp.height, self.scrContSel );
	
	foreach ti in selectedConts do
	
		if  ti.myBookingRefItem &lt;&gt; null then
			docActions := ti.myBookingRefItem.myBookingRefItemActions;
		else
			docActions := null;
		endif;
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnSelectedTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" 
										&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		elseif ( ti.isBulkByWeight or ti.isBulkByVolume ) then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")" 
										&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		endif;
		
		extraDisplay := null;
		if docActions &lt;&gt; null then
			taskAndStopStr := docActions.getTaskAndStopStrForTi(ti,true);
			if taskAndStopStr &lt;&gt; null then
				extraDisplay := " " &amp; taskAndStopStr;
				self.docActsToDisplay1.addExclusive( docActions );
			endif;
		endif;
		if ti.allChildren.isEmpty then
			extraDisplay := extraDisplay &amp; " " &amp; app.getErrorString(Empty);
		elseif ti.myPrimaryQueuedLocation &lt;&gt; null then	//10 Feb 2017	NDL	TFS 3297 Can no longer be both...
			extraDisplay := extraDisplay &amp; " " &amp; app.getErrorString(RTQMachineTableAnnotateMove);
		endif;
		menuButton.caption := menuButton.caption &amp; extraDisplay;
		
		self.addHazDetailsToButton( menuButton, ti, " " ); //30 May 2017	NDL	TFS 4587
		
		menuButton.enabled := true;
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	self.selectedButtonCount := buttonNumber;	
	
	self.btnSelectedTemp.visible := false;
	self.frmContSel.caption := null;
	
	lblNoContSel.visible := (buttonNumber = 0);
	
	self.setupFldContainers(false, dummyIndex);
	
	//01 Dec 2016	NDL	TFS 3034 / 2549 
	if self.showAvailableSheet then
		if self.availButtonCount = 0 and self.selectedButtonCount &gt; 0 then
			self.fldContainers.topSheet := self.shtContSel;
		elseif self.selectedButtonCount = 0 and self.availButtonCount &gt; 0 then
			self.fldContainers.topSheet := self.shtContAvail;
		endif; 
	endif;
	
	self.btnOne.enabled := self.selectedButtonCount = 1;
	
	self.setupFldChildren( false );
	
epilog

	delete availableConts;
	delete selectedConts;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateLblBookings" id="d11f00be-f84e-4f5a-8c42-4131cea8dc4a">
        <source>populateLblBookings()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation			TFS 2811 / 2549

*/

vars

	bookingRef : CM_BookingRef;
	str : String;

begin

	self.lblBookings.caption := null;
	self.lblBookings.wordWrap := true;

	foreach bookingRef in self.myMobileGenericAgent.allSelectedBookings do
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		str := str &amp; bookingRef.bookingReference;
	endforeach;
	
	if str = null then
		str := app.getErrorString(Bookings_selected_process);
	endif;
	
	self.lblBookings.caption := str;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
