This class should be subclassed (as many times as required) within all Package
schemas, upon which all transactions should be implemented.</text>
    <PrimAttribute name="isDoTransactionState" id="9e7ef658-c461-4e6b-85aa-726e08ad2676">
        <embedded/>
        <type name="Boolean"/>
        <access>protected</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myServiceManager" id="5a7662d1-182b-4bc3-b505-9fe20c147568">
        <kind>child</kind>
        <embedded/>
        <type name="JSSServiceManagerObject"/>
        <access>protected</access>
        <Inverse name="JSSServiceManagerObject::myTA"/>
    </ExplicitInverseRef>
    <JadeMethod name="checkTransactionState" id="21998e79-adff-436c-9798-0247b34e3d5e">
        <source>checkTransactionState() protected;
// --------------------------------------------------------------------------------
// Created:		23 April 2003 by cnwdad1
//
// Purpose:		Checks the database transaction state according to whether the
//				peer schema is flagged to control the state or not.  If the state
//				is not correct, and exception will be raised.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isDoTransactionState then
		// The peer schema is controlling the transaction state, therefore we should
		// not already be in transaction state.
		if process.isInTransactionState() then
			self.myServiceManager.raiseJSSException(JSS_EX_00083);
		endif;
	else
		// The application schema is controlling the transaction state, therefore
		// we should already be in transaction state.
		if not process.isInTransactionState() then
			self.myServiceManager.raiseJSSException(JSS_EX_00084);
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="create" id="0c14fdaa-f6f1-49a6-899a-45a35b08a715">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		13 February 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if not self.isTransient then
		JSSException.raise_(JSS_EX_00004, "Persistent instances of the Transaction Agent are not allowed.");
	endif;
	
	self.isDoTransactionState	:=	true;
end;</source>
    </JadeMethod>
    <JadeMethod name="setDoTransactionState" id="23cc1150-fa16-48c0-9568-8279fd0bacc4">
        <updating/>
        <source>setDoTransactionState(pIsDoTransactionState:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		13 December 2002 by cnwdad1
//
// Purpose:		Sets a flag to tell the peer schema whether to handle the database
//				transaction state.  If false, it will be assumed that the application
//				schema will handle the transaction state.
//
// Parameters:	pIsDoTransactionState - True if the peer schema will handle the
//					transaction state, or false if the application schema will
//					handle the transaction state.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isDoTransactionState &lt;&gt; pIsDoTransactionState then
		self.isDoTransactionState	:=	pIsDoTransactionState;
	endif;
end;</source>
        <Parameter name="pIsDoTransactionState" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setServiceManager" id="e1f94037-6c18-4104-aade-bf5f21cf09d5">
        <updating/>
        <source>setServiceManager(pServiceManagerObj:JSSServiceManagerObject) updating;
// --------------------------------------------------------------------------------
// Created:		02 June 2003 by cnwdad1
//
// Purpose:		Sets a reference to the peer schema's Service Manager object.
//
// Parameters:	pTheServiceManager - A reference to the peer schema's service manager
//					object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myServiceManager	:=	pServiceManagerObj;
end;</source>
        <Parameter name="pServiceManagerObj" type="JSSServiceManagerObject"/>
    </JadeMethod>
    <JadeMethod name="trxRemoveProcessObjectForApp" id="6f1a081c-7121-43f1-8b07-8969be2fcaca">
        <updating/>
        <source>trxRemoveProcessObjectForApp(pApp : JSSServiceManagerObject input)  updating;

vars
	processDict				: JSSProcessObjectDict;
	processObject			: JSSProcessObject;
begin
	self.checkTransactionState();
	
	if self.isDoTransactionState then
		on Exception do self.xHandlerCommon(exception);
	endif;
	
	//	get the process dictionary off the service manager
	processDict := pApp.myProcessObjectDict;
	
	//	get the process object off the service manager
	processObject := pApp.myProcessObject;
	
	if not global.isValidObject(processObject) then		// cnwdad1 31/03/2003.
		return;											// cnwdad1 31/03/2003.
	endif;												// cnwdad1 31/03/2003.
	
	exclusiveLock(processDict);
	//	remove and delete the process object
	beginTransaction;
	
	if processDict.includes(processObject) then			// cnwdad1 31/03/2003.
		processDict.remove(processObject);
	endif;												// cnwdad1 31/03/2003.
	
	delete processObject;
	commitTransaction;
	
	pApp.setMyProcessObject(null);
end;</source>
        <Parameter name="pApp" type="JSSServiceManagerObject" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSetProcessObjectForApp" id="ee9caed2-21bf-401e-a517-b58fb8abe6a9">
        <updating/>
        <source>trxSetProcessObjectForApp(pApp : JSSServiceManagerObject input)  updating;

vars
	processDict				: JSSProcessObjectDict;
	processObject			: JSSProcessObject;
	
begin
	self.checkTransactionState();
	
	if self.isDoTransactionState then
		on Exception do self.xHandlerCommon(exception);
	endif;
	
	//	see if we already have a process dictionary
	processDict := JSSProcessObjectDict.firstInstance;
	
	beginTransaction;
	
	if processDict = null then
		create processDict;
	else
		exclusiveLock(processDict);
	endif;
	
	//	see if we already have a process object left around for the current process
	processObject := processDict[process.getOidString()];
	
	if processObject = null then
		create processObject;
		processDict.add(processObject);
	endif;
	
	//	point the process object at this service manager object
	processObject.setApplicationOidAsString(pApp.getOidString());
	
	commitTransaction;
	
	pApp.setMyProcessObjectDict(processDict);
	pApp.setMyProcessObject(processObject);
end;</source>
        <Parameter name="pApp" type="JSSServiceManagerObject" usage="input"/>
    </JadeMethod>
    <JadeMethod name="xHandlerCommon" id="90b80a99-b09d-4bde-aca0-7d9cc8672562">
        <source>xHandlerCommon(pExceptionObj:Exception):Integer protected;
// --------------------------------------------------------------------------------
// Created:		23 April 2003 by cnwdad1
//
// Purpose:		Common exception handler to abort the transaction state, and then
//				pass control back to the next handler in the stack.
//
// Parameters:	pTheException - A reference to the current exception object.
//
// Returns:		The pass-back code.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	abortTransaction;
	
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
