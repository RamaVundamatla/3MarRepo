    <JadeMethod name="translateForm" id="fc13bd57-8fdb-4056-b984-71de6528c275">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017450, locale);
	lblBooking.translateCaption(Xlat_0012139, locale);
	lblReconDetail.translateCaption(Xlat_0012140, locale);
	lblVoyage.translateCaption(Xlat_0012141, locale);
	mnuBookingDiscrep.translateCaption(Xlat_0014156, locale);
	optAllBookings.translateCaption(Xlat_0012142, locale);
	optBooking.translateCaption(Xlat_0012143, locale);
	optUnbookedCargo.translateCaption(Xlat_0015066, locale);
	optVoyage.translateCaption(Xlat_0012144, locale);
end;</source>
    </JadeMethod>
