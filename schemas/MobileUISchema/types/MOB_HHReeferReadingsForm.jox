    <JadeMethod name="displayLocation" id="858bef19-428e-4ee8-8b02-42d231c22dc8">
        <source>displayLocation() protected;
/*
Date		Who		Reason
27/01/2009	cnwcp2	Initial creation
14/12/2009	cnwdap1	CCMS MES 1007 Any tracked item can now be a reefer, not just containers
*/
vars
	
begin
	
	if self.myTrackedItem &lt;&gt; null then
		self.txtLocation.text := self.myTrackedItem.locationId;
	else
		self.txtLocation.text := "";
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayTemperature" id="e3731be9-0bf0-4fc4-b46f-cbce762ed5d7">
        <source>displayTemperature() protected;
/*
Date		Who		Reason
23/01/2009	cnwcp2	Initial creation
14/12/2009	cnwdap1	CCMS MES 1007 Any tracked item can now be a reefer, not just containers
20/03/2015	cnwdap1	PAR #65874 TFS 265 Include last humidity and ventilation readings as well
*/

vars
	
	temp : CM_TempReading;
	humidity : CM_HumidReading;														// PAR #35874
	vent : CM_VentReading;															// PAR #35874
	measure : CM_MeasurementType;													// PAR #35874
	val : Real;
	str : String;
begin
	// default readings fields to null												// PAR #35874
	txtTemperature.text := null;													// PAR #35874
	txtHumidity.text := null;														// PAR #35874
	txtVentilation.text := null;													// PAR #35874

	if self.myTrackedItem &lt;&gt; null then
		//Display last read temperature if it exists
		temp := self.myTrackedItem.getLastTempReading;
		if temp &lt;&gt; null and temp.getTemperatureValue &lt;&gt; NULL_TEMPERATURE then
			str := app.temperatureDisplayString(temp.getTemperatureValue);
			str := str.removeString("+");
			txtTemperature.text := str;
			//return;																// PAR #35874
		else
			// Otherwise display set temperature
			if self.myTrackedItem.getTemperature &lt;&gt; NULL_TEMPERATURE then
				str := app.temperatureDisplayString(self.myTrackedItem.getTemperature);
				str := str.removeString("+"); //PAR 19532 cnwgb1 27.4.09
				txtTemperature.text :=  str;
				//return;															// PAR #35874
			endif;
		endif;
		// Display last humidity reading if it exists								// PAR #35874
		humidity := self.myTrackedItem.getLastHumidityReading;						// PAR #35874
		if humidity &lt;&gt; null and humidity.getHumidity &lt;&gt; NULL_HUMIDITY then				// PAR #35874
			str := humidity.getHumidity.String;										// PAR #35874
			txtHumidity.text := str;												// PAR #35874
		else																		// PAR #35874
			if self.myTrackedItem.getHumidity &lt;&gt; NULL_HUMIDITY then					// PAR #35874
				txtHumidity.text := self.myTrackedItem.getHumidity.String;			// PAR #35874
			endif;																	// PAR #35874
		endif;																		// PAR #35874
		// Display last ventilation reading if it exists							// PAR #35874
		measure := app.getDefaultMeasurementForType(Type_Displacement);				// PAR #35874
		vent := self.myTrackedItem.getLastVentilationReading;						// PAR #35874
		if vent &lt;&gt; null and vent.ventilation &lt;&gt; NULL_VENTILATION then				// PAR #35874
			str := app.convertMeasurementForDisplay(measure.shortName, vent.ventilation);	// PAR #35874
			txtVentilation.text := str;												// PAR #35874
		else																		// PAR #35874
			if self.myTrackedItem.getVentilation &lt;&gt; NULL_VENTILATION then			// PAR #35874
				str := app.convertMeasurementForDisplay(measure.shortName, self.myTrackedItem.getVentilation);	// PAR #35874
				txtVentilation.text := str;											// PAR #35874
			endif;																	// PAR #35874
		endif;																		// PAR #35874
	endif;
	// if not set earlier then it will be null										// PAR #35874
	//txtTemperature.text := null;													// PAR #35874
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doChkTraverseColChange" id="8ea2a87e-d0db-42c7-b3e3-e3070acb1b77">
        <source>doChkTraverseColChange() protected;

vars
	agent	: CM_MobileAgent;
begin
	agent := self.getSessionAgent;
	agent.setTraverseColumns(chkTraverseCol.value);
	btnThree.enabled := agent.getNextTI(self.myTrackedItem, self.isReeferOnlyForm) &lt;&gt; null;
	btnFour.enabled := agent.getPreviousTI(self.myTrackedItem, self.isReeferOnlyForm) &lt;&gt; null;
end;
</source>
        <access>protected</access>
    </JadeMethod>
