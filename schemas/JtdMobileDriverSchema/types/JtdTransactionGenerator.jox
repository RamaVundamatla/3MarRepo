    <JadeMethod name="create" id="8bdcb50d-9fd5-48e7-a2bb-20429a826a44">
        <updating/>
        <source>create() updating;

begin
	if not self.isTransient then
		app.jtdMyContext.jtdRaiseJtdException(JtdExCannotCreatePersistent);
	endif;
	shortPause:=200;
	longPause:=2000;
end;</source>
    </JadeMethod>
