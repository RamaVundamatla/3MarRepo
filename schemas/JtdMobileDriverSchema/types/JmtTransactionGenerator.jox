    <JadeMethod name="doLogon" id="6f458b87-43ce-439e-aab4-6bb708e64733">
        <updating/>
        <source>doLogon() updating;

vars
	aa:ApplicationArray;
	ap:Application;
begin
	create aa transient;
	process.getAllApps(aa);
	foreach ap in aa where ap.getName = "MobileServerSchema" do
		ap.setPropertyValue("testLevel", 911);  // skips password check
	endforeach;

	create myHandHeldLogonForm;
	myHandHeldLogonForm.show;
	myHandHeldLogonForm.txtUsername.text:="CNWTH2";
	myHandHeldLogonForm.txtPassword.text:=null;
	myHandHeldLogonForm.btnLogon.click(myHandHeldLogonForm.btnLogon);
epilog
	delete aa;
end;
</source>
    </JadeMethod>
    <JadeMethod name="handleAllExceptions" id="a01694ca-7b7e-4764-a194-bc000ff1a4b2">
        <updating/>
        <source>handleAllExceptions(pException:Exception):Integer updating;

begin
	self.errorCode := pException.errorCode;
	return(Ex_Pass_Back);
end;</source>
        <Parameter name="pException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pauseAndStop" id="e7bf4bfc-d27a-409b-bcc6-5276db0c2f3a">
        <source>pauseAndStop(overrideTime:Integer):Boolean;
//	For when you need a pause within a method, use this
//
//		if pauseAndStop then return; endif;
//	
//	Pauses within code can cause issues, because a stop notification can arrive and be processed.
//	Then your code resumes, but all forms etc have been deleted by the stop method.
constants
	TimeGranule:Integer = 2000;
vars
	timeRemaining:Integer;
begin
	app.controlLockRelease;
	if overrideTime &lt;&gt; 0 then
		timeRemaining:=overrideTime;
	else
		timeRemaining:=pauseTime;
	endif;
	
	//app.jtdLogMessage(method.qualifiedName&amp;" timeRemaining="&amp;timeRemaining.String);
	while timeRemaining &gt; TimeGranule do
		app.doWindowEvents(TimeGranule);
		timeRemaining:=timeRemaining-TimeGranule;
		//app.jtdLogMessage(method.qualifiedName&amp;" timeRemaining="&amp;timeRemaining.String);
	endwhile;
	//app.jtdLogMessage(method.qualifiedName&amp;" timeRemaining="&amp;timeRemaining.String);
	app.doWindowEvents(timeRemaining);
	
	if not stopped then
		app.controlLockAcquire;
	endif;

	return stopped;
end;
</source>
        <Parameter name="overrideTime" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="startup" id="f0e4066d-5751-481d-b831-7be72e7a5b39">
        <updating/>
        <source>startup() updating;
//	This method will start EVERY profile.
//	It creates an instance of myGH, creates the mainParentForm and calls the relevant selectStartupForm.
//	See method text for typical profile assignments.
//	See ShipLander::startup2 for crane assignments. IMVs and RTGs are pre-assigned in the persistent database.
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	i,signonStagger,startupStagger,signonElapsed,signonPeriod:Integer;
	signOnSequence,startUpSequence,userNumInThisAppServer,appServerNum,signonDelayAfterFirstUser:Integer;
	delay,maxDelay,mthCount,appServers,usersPerAppServer,totalUsers:Integer;
	signonStart:Decimal[19];
	doingDelays:Boolean;
begin
	app.controlLockAcquire;
	app.setSequenceId;
	app.controlLockRelease;
	/*if app.profileName = null or app.computerName.toLower = "cnwjhp1a" then
		if app.atcgRunningAtcgReplay then
			app.profileName:=self.class.name;
		else
			app.profileName:="ShipLander"; app.profileSequenceId:=0;
			app.profileName:="RTG"; app.profileSequenceId:=12;
			app.profileName:="IMV"; app.profileSequenceId:=0;
		endif;
		//app.profileSequenceId:=0;
	endif;/**/
	//app.profileSequenceId:=app.profileSequenceId*8+4;  // special RTG test
	// jimmy the id's for working just JBL500N C9
	if      app.profileName = "IMV" then				app.profileSequenceId:=app.profileSequenceId+15;
	elseif app.profileName = "ShipLander" then	app.profileSequenceId:=app.profileSequenceId+4;
	endif;
	//app.profileName:="RTG"; app.profileSequenceId:=12;
	//app.profileName:="IMV"; app.profileSequenceId:=31;
	//app.profileName:="ShipLander"; app.profileSequenceId:=0;
	//app.profileSequenceId:=12;
	
	if app.runningBenchmark and app.computerName.toLower &lt;&gt; "cnwjhp1a" then
		doingDelays:=true;  // set to false for quicker testing, true for benchmark runs
	endif;
	signonStart:=app.relativeMachineTime;
	usersPerAppServer:=2;
	appServers:=12;
	if false then app.jtdMyContext.jtdAllProfileText; endif;  // IDE hyperlink to profile data! (Methods&gt;Text)
	totalUsers:=usersPerAppServer*appServers;
	//totalUsers:=totalUsers - 1;  // one appserver only has 4 users
	signonStagger:=3700;  //8700;  // it takes a long time for first user to start up
	signonDelayAfterFirstUser:=14000;  // wait for first user per appserver to sign on
	startupStagger:=1670;  //167000;  // this is set large to stagger heavy part of Gate profile
	pauseTime:=4811;  // used by pauseAndStop, used mainly by VoyagePlanner
//	pauseTime:=100;  // used by pauseAndStop, used mainly by VoyagePlanner
	if app.jtdMyContext &lt;&gt; null then
		app.jtdMyContext.jtdGetProfileNameAndMthCount(app.profileName, mthCount);
	endif;
	app.setProcessUserInfo;  // in case profile was changed by JtdControllerApp
	if stopped then
		app.logMessage(method.qualifiedName&amp;" rerun not permitted!");
		//assert(false, self);  // log call stack
		terminate;
	endif;
	app.jtdMyTransactionGenerator:=self;
	if true and app.profileName &lt;&gt; "SkipMe" then
		process.profiler.fileName:="profiler_"&amp;app.profileName&amp;"_"&amp;getInstanceIdForObject(process).String
				&amp;"_"&amp;app.actualTimeServer.date.format("yyyyMMdd")			// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				&amp;"_"&amp;app.actualTimeServer.time.format("HHmmss")&amp;".log";		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		process.profiler.methodCount:=10000;
		process.profiler.start;
	endif;

	self.errorCode := 0;
	on Exception do handleAllExceptions(exception) global;

	create myGH;
	app.jtdMyGenerationHelper:=myGH;
	myGH.repeatable:=true;
	stopped:=false;
	app.stopped:=false;
	
//	delay:=((app.sequenceId div usersPerAppServer)+(app.sequenceId mod usersPerAppServer)*appServers)*signonStagger;
	appServerNum:=app.sequenceId div usersPerAppServer;
	userNumInThisAppServer:=(app.sequenceId mod usersPerAppServer);
	signOnSequence:=appServerNum+userNumInThisAppServer*appServers;
//	startUpSequence:=app.sequenceId;
	startUpSequence:=signOnSequence;
	delay:=signOnSequence*signonStagger+15000;  // let ShipOperations reset machine logons first
	if userNumInThisAppServer &gt; 0 then
		delay:=delay+signonDelayAfterFirstUser;
	endif;

	process.sleep(signOnSequence*100);
	if doingDelays and delay &gt; 0 then
		app.logMessage("Delaying signon for " &amp; delay.String &amp; " ms");
		process.sleep(delay);
	endif;

	myGH.userListFile.kind := File.Kind_Unknown_Text;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	startupSkipFile(myGH.userListFile);
	
	//if app.runningBenchmark then
	//	app.myUser:=myGH.selectRandomUser;
	//else
		//app.myUser:=app.myRoot.allUsers['CNWTH2'];
		if app.profileName = "IMV" and app.profileSequenceId &gt;= 9 then
			app.jmtComputerName:=app.profileName[1:2]&amp;(app.profileSequenceId+1).String;
		elseif app.profileName = "RTG" and app.profileSequenceId &gt;= 8 then
			app.jmtComputerName:=app.profileName[1:2]&amp;"B"&amp;(app.profileSequenceId-8+1).String;
		else
			app.jmtComputerName:=app.profileName&amp;(app.profileSequenceId+1).String;
		endif;
		if app.profileName = "RTG" or app.profileName = "IMV" then
			app.initializeVehicleMountedLogon;
			//app.getProfileString(app.getIniFileName, "VehicleMounted", "VehicleMountedDevice", "&lt;not set&gt;");
		else
			app.initializeHandHeldLogon;
		endif;
	//endif;

	app.logMessage("=================================================");
	//app.logMessage("Starting profile, user="&amp;app.jmtComputerName&amp;", version="&amp;rootSchema.getSchema("PortSchema").getClass("CM_Root").firstInstance.getPropertyValue("versionString").String);
	app.logMessage("Starting profile, user="&amp;app.computerName&amp;", version="&amp;rootSchema.getSchema("PortSchema").getClass("CM_Root").firstInstance.getPropertyValue("versionString").String);
	app.logMessage("=================================================");

	//app.initTerminalApp;
	//app.setIsVoyageCommodityPlanning(false);
	//app.myPassport.setMyTerminal(app.myRoot.allTerminals['JBL']);
	doLogon;

	app.doWindowEvents(200);  // let startup timers expire first
	//app.mainForm.activate;  // ensure navigator form gets loaded
	//app.mainForm.windowState := Form.WindowState_Normal;
	//app.mainForm.addControl(null);
	//app.mainForm.move(0,30,1024,685);  // standard form size so tables etc have same number of rows
	if app.runningBenchmark then
		//app.mainForm.windowState := Form.WindowState_Minimized;
	endif;
	//myNavigator := app.getForm(CMUI_Navigator.name).CMUI_Navigator;
	//pp.myPassport.setMyTerminal(app.myRoot.allTerminals['JBL']);
	//create myUtlRT as rootSchema.getSchema('MobileServerSchema').getClass('CM_UtilityRTAgent');
	if app.atcgCleanStartMode then
		app.unloadAllForms;
	endif;

	app.controlLockAcquire;
	startup2;
	app.controlLockRelease;

	// wait till everyone has done startup, then stagger trans start
	signonElapsed:=(app.relativeMachineTime - signonStart).Integer;
	assert(signonElapsed &gt; 0, self);  // detect wraparound of app.relativeMachineTime
	app.logMessage("Signon took "&amp;(signonElapsed-delay).String&amp;" ms");
	signonPeriod:=(totalUsers-1)*signonStagger + 15000 + 5000;
	delay:=(signonPeriod - signonElapsed + startUpSequence*startupStagger);
	if doingDelays and delay &gt; 0 then
		app.logMessage("Delaying startup for " &amp; delay.String &amp; " ms");
		process.sleep(delay);
	endif;
	app.logMessage(method.qualifiedName&amp;" finished");
	app.logMessage(method.qualifiedName&amp;" pausing for several minutes");
	if pauseAndStop(900000) then return; endif;  // "safe" way to add a delay
	app.logMessage(method.qualifiedName&amp;" proceeding");
	
//	app.myCnCntrl.setClientTranStats(true);
end;</source>
        <text>Typical profile assignments

Creator08/4797:         1      RoadOpsInquiry            0       51700   cnwjhp1_1674@cnwchcs122
Creator08/4798:         1      GateInOut                 1       51700   cnwjhp1_f7c@cnwchcs122
Creator08/4799:         1      GateInOut                 2       51700   cnwjhp1_16bc@cnwchcs122
Creator08/4800:         1      GateInOut                 3       51700   cnwjhp1_170c@cnwchcs122
Creator08/4801:         1      GateInOut                 4       51700   cnwjhp1_1150@cnwchcs122
Creator08/4802:         1      RoadOpsInquiry            5       51701   cnwjhp1_11c0@cnwchcs122
Creator08/4803:         1      VoyagePlanner             6       51701   cnwjhp1_c18@cnwchcs122
Creator08/4804:         1      VoyageWorker              7       51701   cnwjhp1_15a8@cnwchcs122
Creator08/4805:         1      VoyageWorker              8       51701   cnwjhp1_c48@cnwchcs122


To add more VoyagePlanners and VoyageWorkers, add more appservers. And maybe take the RoadOpsInquiry
user out of the first appserver so there are 4 users per appserver.

Creator08/4802:         1      RoadOpsInquiry            9       51702   cnwjhp1_11c0@cnwchcs122
Creator08/4803:         1      VoyagePlanner            10       51702   cnwjhp1_c18@cnwchcs122
Creator08/4804:         1      VoyageWorker             11       51702   cnwjhp1_15a8@cnwchcs122
Creator08/4805:         1      VoyageWorker             12       51702   cnwjhp1_c48@cnwchcs122

</text>
    </JadeMethod>
