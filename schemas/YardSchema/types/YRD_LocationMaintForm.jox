	btnPenHeight3.translateBubbleHelp(Xlat_0004530, locale);
	btnPenHeight3.translateCaption(Xlat_0004541, locale);
	btnPenHeight4.translateBubbleHelp(Xlat_0004525, locale);
	btnPenHeight4.translateCaption(Xlat_0004535, locale);
	btnPenHeight5.translateBubbleHelp(Xlat_0004531, locale);
	btnPenHeight5.translateCaption(Xlat_0004536, locale);
	btnPenHeight6.translateBubbleHelp(Xlat_0004532, locale);
	btnPenHeight6.translateCaption(Xlat_0004538, locale);
	btnPenHeight7.translateBubbleHelp(Xlat_0004527, locale);
	btnPenHeight7.translateCaption(Xlat_0004540, locale);
	btnPenHeight8.translateBubbleHelp(Xlat_0004529, locale);
	btnPenHeight8.translateCaption(Xlat_0004542, locale);
	btnPenLight.translateBubbleHelp(Xlat_0004507, locale);
	btnPenLight.translateCaption(Xlat_0004511, locale);
	btnPenPower.translateBubbleHelp(Xlat_0004508, locale);
	btnPenPower.translateCaption(Xlat_0004512, locale);
	btnPenPowerDam.translateBubbleHelp(Xlat_0004502, locale);
	btnPenPowerDam.translateCaption(Xlat_0004504, locale);
	btnPenUnavail.translateBubbleHelp(Xlat_0004533, locale);
