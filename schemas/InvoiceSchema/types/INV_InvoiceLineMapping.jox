    <JadeMethod name="doTblDataDBClick" id="fa9a79ee-9510-4a52-9fc0-60fced3e89da">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	if table.column &lt;= table.fixedColumns then
		return;
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	self.showPropertyFrame();

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataRowColChange" id="8e14935d-bcb5-4d6b-9e2f-5c8de8a67e9a">
        <updating/>
        <source>doTblDataRowColChange(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
// Purpose:		
// 09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up
// ---------------------------------------------------------------------------

vars
	theRow, theCol : Integer;
	aMapping : CM_InvoiceLineDescMapping; // 09/01/2017 cnwma1 TFS #2712
begin
	self.myCurrentDebtor := null;
	self.myCurrentInvLineType := null;
	self.myCurrentInvType := null;
	self.myCurrentMapping := null; // 09/01/2017 cnwma1 TFS #2712
	inheritMethod(table);
	theRow := table.row;
	theCol := table.column;
	
	if theRow &gt; table.fixedRows then
		self.myCurrentInvLineType := table.accessRow(theRow).itemObject.CM_InvoiceLineDesc;
		if theCol &gt; table.fixedColumns then
			self.myCurrentDebtor := table.accessColumn(theCol).itemObject.CM_Debtor;
			self.myCurrentInvType := table.accessCell(theRow,theCol).itemObject.CM_InvoiceDesc;
			if self.myCurrentDebtor &lt;&gt; null and self.myCurrentInvType &lt;&gt; null then   // 09/01/2017 cnwma1 TFS #2712
				foreach aMapping in self.myCurrentInvLineType.allInvoiceTypeMappingsByDebtor do
					if aMapping.myDebtor = self.myCurrentDebtor then
						self.myCurrentMapping :=aMapping;
						break;
					endif;
				endforeach;
			endif;
			
		endif;
	endif;
	
	self.cmbDebtors.listObject := self.myCurrentDebtor;
	self.cmbInvoiceLines.listObject := self.myCurrentInvLineType;
	self.cmbInvoiceTypes.listObject := self.myCurrentInvType;
	
	self.setEnableObjects();
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditItem.enabled := false;
	endif;
	
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="fileSilentExceptionHandler" id="7ac507d9-523d-4475-9ab9-d4dd95454b47">
        <source>fileSilentExceptionHandler(_exObj: Exception; _hadFileException : Boolean io): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2023	navmk20	Bug 56954: FR | 53978 - EUP - Invoicing - Configuration Enhancements - User Story 050 issues

*/

vars
	returnVal		: Integer;
begin
	returnVal := Ex_Pass_Back;
	if _exObj.errorCode &gt; 5000 and _exObj.errorCode &lt;= 5099 then
		_hadFileException:=true;
		if _exObj.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

	return returnVal;
epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_hadFileException" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDebtorName" id="731d2d20-3875-4aec-8b0b-09876cec892d">
        <source>getDebtorName(_debtor : CM_Debtor) : String;
/*

Purpose:			Gets the debtor name for the debtor passed in

Parameters:			_debtor	CM_Debtor	The debtor to get the name for

Return Value:		String	The debtors name

Date			Who		Reason
06 October 2022	navpw1	Initial creation TFS: 54566

*/

begin
	return _debtor.name;
	
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExportFileName" id="5febd0f9-1757-4770-94c3-b9c733ac537b">
        <source>getExportFileName(_startDT :TimeStamp; _extension : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2023	navmk20	Bug 56954: FR | 53978 - EUP - Invoicing - Configuration Enhancements - User Story 050 issues

*/

vars
	
begin
	return "InvLineMapping_" &amp; _startDT.date.userFormat($CM_YearFormat) &amp;_startDT.time.formatAsHHMMSS() &amp; _extension ;
epilog

end;</source>
        <Parameter name="_startDT" type="TimeStamp"/>
        <Parameter name="_extension" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExportFileNameBase" id="8c756626-260e-45d1-a2fb-388beda36d92">
        <source>getExportFileNameBase(_exportPath : String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2023	navmk20	Bug 56954: FR | 53978 - EUP - Invoicing - Configuration Enhancements - User Story 050 issues

*/

vars
	fdir:         FileFolder;
	target:       String;
	pos:          Integer;
	hadFileException : Boolean;
begin
	if _exportPath = null then
		target := app.getJadeInstallDir;
		pos := target.reversePos("\");
		if pos &gt; 0 then
			target := target[1:pos - 1];
		endif;
		target := target &amp; "\" &amp; app.getErrorString(INV_InvLineMappingDesc) &amp; "\";
	else
		target := _exportPath.normaliseDirectory().substituteDirectory();
	endif;
		
	create fdir transient;
	fdir.fileName := target;
	
	on FileException do self.fileSilentExceptionHandler(exception,hadFileException);
	
	if not fdir.isAvailable then
		fdir.make;
	endif;
	
	if hadFileException then
		target := app.getJadeInstallDir;
		pos := target.reversePos("\");
		if pos &gt; 0 then
			target := target[1:pos - 1];
		endif;
		target := target &amp; "\" &amp; app.getErrorString(INV_InvLineMappingDesc) &amp; "\";
		fdir.fileName := target;
		if not fdir.isAvailable then
			fdir.make;
		endif;
	endif;
	return target;
epilog
	delete fdir;
end;</source>
        <Parameter name="_exportPath" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvLineTypeDescription" id="d6599c11-de84-472f-b80d-59c8f83d3033">
