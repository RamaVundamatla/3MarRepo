    <JadeMethod name="dropDown" id="2a34b456-e35f-4978-bf32-08f55766ce16">
        <updating/>
        <source>dropDown(combobox: ComboBox input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     23 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.useManualDropDown then
		if (not self.canDropDown) then
			return false;
		endif;
		self.canDropDown := false;
	endif;

	return inheritMethod(combobox);

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterCombo" id="ab2c5f89-b267-4aee-829e-96efcd441a58">
        <updating/>
        <source>filterCombo() updating;
 // ### TFS 55105 07NOV2022 NAVAB1
vars
	filterText, itemText : String;
	index, count, firstVisibleIndex : Integer;
	
	switchText : String;
	switchObject : Object;
	switchData : Integer;
begin
	// repopulate
	self.filterReshowAllItems();
	
	// Get filter text
	filterText := self.text.toUpper;
	if filterText = null or filterText.length &lt; 1 then
		return;
	endif;

	// filter contents
	self.sorted := false; // if this is removed the filtering does not work.
	
	index := self.listCount(); // going backwards
	
	while true do
		if index &lt; 1 then
			break;
		endif;
		
		// ### TFS BUG 60630 25SEP2023 NAVAB1
		if index &gt; 1 // ### TFS BUG 61016 30OCT2023 NAVAB1
		and self.itemEnabled[index] = false then
			self.itemLevel[index] := 2;
			index := index - 1;
			continue;
		endif;

		itemText := self.itemText[index].toUpper;
		
		
		if filterText &lt;&gt; null then
			// 'hide' those that do not match
			if itemText.pos(filterText,1) &lt; 1 then
				if index &gt; 1 then
					self.itemLevel[index] := 2;
				endif;
			else
				firstVisibleIndex := index;
				count := count + 1;
			endif;
		endif;
		index := index - 1;
	endwhile;

	// ### The first row MUST be level 1, if the first row does not equal the filter text then switch it with the first visible row. In the reshowAllItems() we will switch back
	if filterText &lt;&gt; null 
	and firstVisibleIndex &gt; 0 then
		itemText := self.itemText[1].toUpper;
		if itemText &lt;&gt; null
		and itemText.pos(filterText,1) &lt; 1 then
			self.filterFirstVisibleIndex := firstVisibleIndex;
			self.filterSwitch(1,firstVisibleIndex);
		endif;	
	endif;
/*// ### TFS DEFECT 56733 24FEB2023 NAVAB1
	if self.listIndex &gt; 0 then
		if count = 1 then
			self.click(self);
		endif;
	else
	*/
	 // ### TFS DEFECT 56495 10FEB2023 NAVAB1
	/*	if the filter text happens to match the first word of the full text Jade returns that as a true full match e.g. 'WLM' matches 'WLM - Wilmerton', so removing to show filtering 
		index := self.findString(1,filterText);
		if index &gt; 0 then
			self.listIndex := index;
			if count = 1 then
				self.click(self);
			endif;
		endif;
		*/
//	endif;

	self.showDropDown();
	// ### TFS BUG 64069 10MAY2024 NAVAB1 self.selectAllText();
end;
</source>
    </JadeMethod>
    <JadeMethod name="filterHandleException" id="4b3bca90-4b55-4a21-9ebf-61d0e8c9d31b">
        <source>filterHandleException(_exObj : Exception; _invalidObject : Boolean io) : Integer;
 // ### TFS 55105 07NOV2022 NAVAB1
// If combobox was populated by ListCollection() then cannot do 'switching' that is done to handle index 1 having to be level 1.
vars
	returnVal : Integer;
begin

	returnVal := Ex_Pass_Back;
	if _exObj.errorCode = 14072  // 14072 - 'This action is not valid when a collection is attached to a Control'
	or _exObj.errorCode = 14011 then // 14011 - 'Invalid index'
		if _exObj.resumable then
			returnVal :=  Ex_Resume_Next; // Ex_Abort_Action
			_invalidObject := true;
			
		endif;
	endif;

	return returnVal;
end;
</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_invalidObject" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="filterReshowAllItems" id="29af37ac-263b-4e35-b0cf-5b43f9212ae5">
        <updating/>
        <source>filterReshowAllItems() updating;
 // ### TFS 55105 07NOV2022 NAVAB1

// Reshow all the items in the combo box. If an item has been clicked the listIndex still stands and Jade will show the correct item in a now full list.
vars

	index, firstVisibleIndex, itemLevelCount, listCount : Integer;
	switchText : String;
	switchObject : Object;
	switchData : Integer;
	exceptionOccured : Boolean;
begin
	if self.helpContextId = ArrowKeys then // ### TFS DEFECT 56520 13FEB2023 NAVAB1 - Do not show all if pressing up or down arrows
		return; // ### TFS DEFECT 56520 13FEB2023 NAVAB1
	endif;

	on Exception do self.filterHandleException( exception,exceptionOccured); // Odd behaviour where itemLevel index was invalid -  Auto Schedule Task, Add - Check Wash Expired, choose to do task, press cancel get 14011

	// ### The first row MUST be level 1. If the selected index was the first visible one (after filtering)
	//		and the full list's first row did not equal the filter text then that first item will have been switched with the first visible row. Now we will switch them back
	
	firstVisibleIndex := self.filterFirstVisibleIndex;
	
	if firstVisibleIndex &gt; 0 then
		if self.filterSwitch(firstVisibleIndex, 1) then
			if self.listIndex = 1
			and firstVisibleIndex &gt; 1 then // has been switched out
				self.listIndex := firstVisibleIndex;
			endif;
		
		endif;
	endif;

	self.filterFirstVisibleIndex := 0;
	// they have selected an item, put everything back in the list. Thi sis incase the UI has a reset option and is setting th elist index to -1 or 1 etc.
	index := self.listCount();
	
	while true do
		if index &lt; 1 then
			break;
		endif;

		self.itemLevel[index] := 1;

		index := index - 1;
	endwhile;


end;
</source>
    </JadeMethod>
    <JadeMethod name="filterSwitch" id="eda5246c-945d-4208-a1c9-cc3bcb94c18a">
        <source>filterSwitch(_index1, _index2 : Integer) : Boolean;
 // ### TFS 55105 07NOV2022 NAVAB1
vars
	switchText : String;
	switchObject : Object;
	switchData : Integer;
	retVal, exceptionOccured : Boolean;
begin
	on Exception do self.filterHandleException( exception,exceptionOccured); // If combobox was populated by ListCollection() then cannot do the following

	switchText := self.itemText[_index1];
	switchObject := self.itemObject[_index1];
	switchData := self.itemData[_index1];

	
	self.itemObject[_index1] := self.itemObject[_index2];
	
	if exceptionOccured then
		return false;
	endif;
	
	self.itemText[_index1] := self.itemText[_index2];
	self.itemData[_index1] := self.itemData[_index2];
	
	self.itemText[_index2] := switchText;
	self.itemObject[_index2] := switchObject;
	self.itemData[_index2] := switchData;
	
	if _index1 = 1 then // Switching index 1 for the first visible
		self.itemLevel[_index2] := 2; // hide the switched one
		self.itemLevel[_index1] := 1; // show the other switched one

	endif;
	
	retVal := true;
	
epilog
	return retVal;
end;
</source>
        <Parameter name="_index1" type="Integer"/>
        <Parameter name="_index2" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findItemData" id="2339e7c1-01a9-4f35-8c29-16292cc0b816">
        <source>findItemData(_itemData : Integer) : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	08 January 2007 By cnwth2

Purpose:	Returns the listIndex of _itemData

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	idx,
	theListCount	: Integer;
begin
	
	theListCount := self.listCount;
	foreach idx in 1 to theListCount do
		if self.itemData[idx] = _itemData then
			return idx;
		endif;
	endforeach;

	return -1;
end;


</source>
        <Parameter name="_itemData" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findObjectFromListCollection" id="ee992863-a50d-4e5f-aff7-ab5538a4965d">
        <updating/>
        <source>findObjectFromListCollection(_object : CM_Object) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 11 February 2009
//
// Implemented version: 7.7.1
// 
//----------------------------------------------------------------------
vars
	idx	: Integer;
begin
	if self.listCount = 0 
	or _object = null then
		return;
	endif;
		
	foreach idx in 1 to self.listCount do
		if self.itemObject[idx] = _object then
			self.setIndex(idx);
			break;
		endif;
	endforeach;
epilog
end;</source>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="itemDataIndex" id="a1ed8a3d-0664-494f-a204-1e41927a15a2">
        <source>itemDataIndex(_itemData : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     22 August 2003	cnwth2
//
// Purpose:     Returns the listIndex of the _itemData - should be on ComboBox!!
//			 
// ----------   ----------  --------------------------------------------------
vars
	idx,
	theListCount		: Integer;
begin
	theListCount := self.listCount;
	foreach idx in 1 to theListCount do
		if self.itemData[idx] = _itemData then
			return idx;
		endif;
	endforeach;
	
	return -1;

end;</source>
        <Parameter name="_itemData" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="c9888748-826f-4003-9ffc-185f0837d7e5">
        <updating/>
        <source>keyDown(combobox: ComboBox input; keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     23 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 April 2024 navrv30 Bug 63181: FR - 53548 - Drop down search marks search parameter
// ---------------------------------------------------------------------------
vars

	type,
	remaining		: Integer;
begin

	if not self.filterIgnore then // ### TFS 55105 07NOV2022 NAVAB1
		if keyCode = J_key_DownArrow // ### TFS DEFECT 56520 13FEB2023 NAVAB1
		or keyCode = J_key_UpArrow then // ### TFS DEFECT 56520 13FEB2023 NAVAB1
			self.helpContextId := ArrowKeys; // ### TFS DEFECT 56520 13FEB2023 NAVAB1 - set context and do not set timer
		else
			self.helpContextId := AllKeys; // ### TFS DEFECT 56520 13FEB2023 NAVAB1
			if self.getTimerStatus(self.Timer_TableData_Filter, type, remaining) then  // ### TFS 55105 07NOV2022 NAVAB1
				self.endTimer(self.Timer_TableData_Filter);  // ### TFS 55105 07NOV2022 NAVAB1
			endif;
			//04 April 2024 navrv30 Bug 63181
			self.beginTimer(700, Timer_OneShot, self.Timer_TableData_Filter);  // ### TFS 55105 07NOV2022 NAVAB1
		endif;
	endif;
	

	if self.useManualDropDown and keyCode = J_key_Return then
		self.canDropDown := (not self.isDroppedDown);
	endif;

	inheritMethod(combobox, keyCode, shift);

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listCollectionWithAny" id="b1742451-e15a-4fa9-a5f7-c97f04940681">
        <updating/>
        <source>listCollectionWithAny(_coll : Collection; 
				_propertyName : String) updating;
// ---------------------------------------------------------------------------
// Created:     20 September 2002 by cnwth2
//
// Purpose:     Use this method to populate a combobox with an **Any** string
//				at the top - with no object associated - to allow for null selection.
//				Passing in a null collection is fine - just puts an **Any** string 
//				at the top
//			
//
//
// ----------   ----------  --------------------------------------------------
vars
	obj			: Object;
	iter		: Iterator;
	i,
	idx			: Integer;
	str			: String;
	firstTime	: Boolean;
begin
	if self.sorted = true then
		app.msgBox(app.getErrorString(AddAnyToSortedComboBox), app.getErrorString(Error), 0);
		return;
	endif;	
	
	self.addItem(Any_String);
	
	if _coll &lt;&gt; null then
		iter := _coll.createIterator;
		while iter.next(obj) do
			str := obj.getPropertyValue(_propertyName).String;
			idx := self.addItem(str);
			self.itemObject[idx] := obj;
		endwhile;
	endif;
	
	self.listIndex := 1;
epilog
	delete iter;	
end;</source>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_propertyName" type="String"/>
    </JadeMethod>
    <JadeMethod name="listData" id="12837bc3-b9de-45e1-a132-0367d4953ad4">
        <source>listData() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	11 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.listIndex &lt; 1 then
		return null;
	endif;
	
	return self.itemData[self.listIndex];

end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="74dd990e-a7aa-4f22-813c-c94196a13aec">
        <updating/>
        <source>lostFocus(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     06 October 2003 by cnwrs2
//
// Purpose:  
// 
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//09 May 2024   navbs1      Bug 64079: SAL- Error code : 91008 Your locale setting is different from the application server locale setting.  
// ---------------------------------------------------------------------------
vars
	dataTable : CM_DataTable;
begin
	if self.filterIgnore then  // ### TFS BUG 64462 04JUNE024 NAVAB1  - NOT FILTERING
			inheritMethod(combobox);
	else
		// ### TFS 55105 14NOV2022 NAVAB1
	// ### TFS 55105 16NOV2022 NAVAB1 - some combo boxes are used for data input of new codes, so do not blank out
	// ### TFS 55105 16NOV2022 NAVAB1	if combobox.listIndex &lt; 1 then
	// ### TFS 55105 16NOV2022 NAVAB1		combobox.text := "";
	// ### TFS 55105 16NOV2022 NAVAB1	endif;
		self.helpContextId := AllKeys; // ### TFS DEFECT 56520 13FEB2023 NAVAB1 - RESET

		// ### TFS 55105 14NOV2022 NAVAB1
		if self.parent.isKindOf(CM_DataTable) and not self.filterIgnore then		//09.05.2024 navbs1 #64079
			dataTable := self.parent.CM_DataTable;
			dataTable.setCellText(dataTable.row, dataTable.column, combobox.text);
		endif;

		inheritMethod(combobox);
		//process.dumpStackMDH();
		
		self.filterReshowAllItems();  // ### TFS 55105 07NOV2022 NAVAB1
	endif;
	
	if self.parent.isKindOf(CMUI_RowFrame) then
		self.parent.CMUI_RowFrame.handleComboLostFocus(combobox.CMUI_ComboBox);
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="a80d8c57-067e-4df7-bd27-e7506fb42194">
        <updating/>
        <source>mouseDown(comboBox: ComboBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     23 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.useManualDropDown and x &gt; self.width - 20 then
		self.canDropDown := (not self.isDroppedDown);
	endif;

	inheritMethod(comboBox, button, shift, x, y);

end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="refreshList" id="ad364d56-309f-4f22-892d-231d839c3a51">
        <updating/>
        <source>refreshList(pCol : Collection; pSelectedObject : Object; pIsNew : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     27 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------


	// this method refreshes thecombo box, based on the collection passed, and sets the index
	// to either the given (previously selected) object if it exists, otherwise the first in the list
vars

begin

	// populate the combo box
	if pCol.isTransient then
		self.listCollection(pCol, false, 0);
	else
		self.listCollection(pCol, true, 0);
	endif;
	
	// set the index to invalid (e.g. upon add)
	if pIsNew or pSelectedObject = null then
		self.listIndex := -1;
		return;
	endif;
	
	// or set to previously selected organisation
	self.setIndex(self.findObject(pSelectedObject));

end;</source>
        <Parameter name="pCol" type="Collection"/>
        <Parameter name="pSelectedObject" type="Object"/>
        <Parameter name="pIsNew" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeObject" id="056af6bd-8854-4b3a-b563-792a0d9b55b2">
        <source>removeObject(_obj : Object) : Boolean;
// ---------------------------------------------------------------------------
// Created:     04 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	idx			: Integer;
	loopObj		: Object;
begin
	foreach idx in 1 to self.listCount do
		loopObj := self.itemObject[idx];
		if loopObj &lt;&gt; null 
		and loopObj.String = _obj.String then
			self.removeItem(idx);
			return true;
		endif;
	endforeach;

	return false;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="688364e5-cc53-4d85-b513-87d5ae1e17a0">
        <updating/>
        <source>repositionAfterResize() updating;
// ---------------------------------------------------------------------------
// Created:     01 August 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
   	newLeft, newTop, newWidth, newHeight,
   	parentWidth,
   	parentHeight	: Real;

begin
	if self.parent.isKindOf(Form) then
		parentWidth  := self.parent.Form.clientWidth;
		parentHeight := self.parent.Form.clientHeight;
	elseif self.parent.isKindOf(Control) then
		parentWidth  := self.parent.Control.clientWidth;
		parentHeight := self.parent.Control.clientHeight;
	else
		parentWidth  := self.parent.width;
		parentHeight := self.parent.height;
	endif;
	
	newLeft 	:= self.left;
	newTop 		:= self.top;
	newWidth 	:= self.width;
	newHeight 	:= self.height;
	
	if self.lockRight then
		newLeft := (parentWidth - newWidth - self.distanceFromRight).max(0);
	endif;
	if self.lockBottom then
		newTop := (parentHeight - newHeight - self.distanceFromBottom).max(0);
	endif;
	if self.stretchWidth then
		newWidth := (parentWidth - newLeft - self.distanceFromRight).max(0);
	endif;
	if self.stretchHeight then
		newHeight := (parentHeight - newTop - self.distanceFromBottom).max(0);
	endif;
		
	if newLeft &lt;&gt; self.left or newTop &lt;&gt; self.top or newWidth &lt;&gt; self.width or newHeight &lt;&gt; self.height then
		self.move(newLeft, newTop, newWidth, newHeight);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="selectAllText" id="d297e306-16ab-4c19-a547-3c97eea7eb25">
        <updating/>
        <source>selectAllText() updating;
// ---------------------------------------------------------------------------
// Created:     15 August 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.style = ComboBox.Style_DropDown or
	   self.style = ComboBox.Style_Simple or
	   self.style = ComboBox.Style_DropDownComboList then
		self.selStart := 0;
		self.selLength := 1000;	// set to something big, Jade will set to actual length of text
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setIndex" id="4d1a4000-5054-42f4-a3c2-e75c96309430">
        <updating/>
        <source>setIndex(newIndex:Integer) updating;
// ---------------------------------------------------------------------------
// Created:     27 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if newIndex &gt; 0 and newIndex &lt;= self.listCount then
		self.listIndex := newIndex;
	endif;
	
end;</source>
        <Parameter name="newIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setIndexForItemData" id="cea9a59c-c159-453a-b492-a941b743ffc3">
        <updating/>
        <source>setIndexForItemData(_itemData: Integer) updating;
//----------------------------------------------------------------
//	Created:	01 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx	: Integer;

begin
	if self.listCount = 0 then
		return;
	endif;
		
	foreach idx in 1 to self.listCount do
		if self.itemData[idx] = _itemData then
			self.setIndex(idx);
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_itemData" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setIndexFromObject" id="e6fd78db-c2ec-4d89-a764-e478fff874a1">
        <updating/>
        <source>setIndexFromObject(_theObject : Object) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lstIndx : Integer;
begin
	lstIndx := self.findObject(_theObject);
	self.listIndex := lstIndx;
	if lstIndx &gt; 0 then
		//don't set text explicitly.  itemText can be longer than maxLength!
		//and will barf.  JC -  to fix bug in voy planning with long job ids
		///self.text := self.itemText[lstIndx];
		self.backColor := self.itemBackColor[lstIndx];
		self.foreColor := self.itemForeColor[lstIndx];
	endif;

end;</source>
        <Parameter name="_theObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="265c2dfd-38e5-40f4-8467-bb5a91541960">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
 // ### TFS 55105 07NOV2022 NAVAB1
vars

begin

	if eventTag = self.Timer_TableData_Filter then
		self.filterCombo();
	endif;

end;
</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="c1ee7c67-d9da-43ff-bd55-7b02bc80d613">
        <controlMethod name="ComboBox::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2013	cnwmc5	Initial creation

*/

vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	
	if not self.isInPainter then
		self.filterIgnore := app.doNotFIlterCombos; // ### TFS CR 55105 28DEC2022 NAVAB1
		if not app.doNotFIlterCombos then // ARE FILTERING
			self.style := ComboBox.Style_DropDown; // ### TFS 55105 07NOV2022 NAVAB1
		endif;
	endif;
epilog

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
