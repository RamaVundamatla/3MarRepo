    <JadeMethod name="rsFindBaplieRORO" id="779deffc-6cf3-43f2-84a2-b4c886cddac2">
        <source>rsFindBaplieRORO();

constants
	UserDefinedROROBaplie = 'Unit Test RORO Baplie Par29388';
vars
	roroLocnDefnVoyage : CM_ROROLocnDefnVoyage;
	allRequests : CM_VoyageRequestArray;
	roroRequest : CM_RORORequest;
	ediAgent : CM_EDIControllerAgent;
	voyage : CM_Voyage;
	operator : CM_Operator;
	fileName : String;
	fileType : CM_EDIFileTypeUser;
	planType : Integer;
	terminal : CM_Terminal;
	voyageCode : String;
	terminalCode : String;
begin
	app.initialize;
	create allRequests transient;
	foreach	roroLocnDefnVoyage in CM_ROROLocnDefnVoyage.instances do
		if roroLocnDefnVoyage.isOOTLLocn then
			allRequests.clear();
			roroLocnDefnVoyage.getAllVoyageRequests(allRequests);
			foreach roroRequest in allRequests do
				if roroRequest.myROROControllerLoad &lt;&gt; null then
					///////////////////////////
					planType := PROPOSED_BAYPLANS;	//ACTUAL_BAYPLANS
					terminal := roroLocnDefnVoyage.getFirstLC.myVoyage.getMyTerminal;
					voyage := roroLocnDefnVoyage.getFirstLC.myVoyage;
					if terminal.code &lt;&gt; "T01" then
						break;
					endif;
					if terminalCode = terminal.code and
					   voyageCode = voyage.code then
						break;
					endif;
					terminalCode := terminal.code;
					voyageCode := voyage.code;
					operator := roroLocnDefnVoyage.getFirstLC.myVoyage.myOperator;
					fileType := app.myRoot.allEDIFileTypeUsersByName[UserDefinedROROBaplie];
					fileName := "d:\cnwdmast\EDI2\"&amp;voyage.code&amp;"_Proposed.csv";
					create ediAgent transient;
					ediAgent.setTerminal(terminal);
					ediAgent.loadDeckPlanTIs(voyage, planType, fileName, operator, fileType); 
					///////////////////////////
//					write roroLocnDefnVoyage.String&amp;' code='&amp;roroLocnDefnVoyage.code&amp;' voyage='&amp;voyage.code&amp;' terminal='&amp;terminal.code;
					break;
				endif;
			endforeach;
		endif;
	endforeach;
epilog
	delete allRequests;
end;
</source>
    </JadeMethod>
