    <JadeMethod name="displayAreas" id="f6684208-fe83-4931-b38a-fccc3c88c942">
        <source>displayAreas(_obj : CM_Object) : String;

// Created by cnwdvb1 on 31 July 2007
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/03/2010	consw1		PAR #22868
// ---------------------------------------------------------------------------

vars

begin
	if _obj = null then
		return null;
	elseif _obj.isKindOf(CM_TerminalAreaMaster) then
		return _obj.CM_TerminalAreaMaster.getDisplayName(true);
	elseif _obj.isKindOf(CM_CraneLaneController) then
		return _obj.CM_CraneLaneController.getLaneId();
	endif;
	
	return _obj.getName;

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayCriteriaDesc" id="5d741cb1-fb68-4505-becb-a5692559f003">
        <source>displayCriteriaDesc();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 October 2025		jlizm1	Initial creation MTN 35861 RTQueue configuration - cargo attribute criteria

*/

vars
	criteria: CM_YACriteria;
	text: String;
	cmifCriteria: CMIF_Object;
	
begin

	if self.tblMain.getRow(ETRow_CriteriaDblClick) = null then
		return;
	endif;
	
	foreach cmifCriteria in self.allCriteria do
		criteria := cmifCriteria.CMIF_YACriteriaPriority.myProxy.CM_YACriteria;
		text := text &amp; criteria.getListDisplay &amp; " ";
	endforeach;
	
	if text &lt;&gt; null then
		self.tblMain.setValueByName(ETRow_CriteriaDblClick,text);
	else
		self.tblMain.setValueByName(ETRow_CriteriaDblClick,"-- Dbl Click to Add --");
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayLocations" id="c0f6c627-f75a-4f0c-a394-f13bb8aa5c5b">
        <source>displayLocations(_theLocationsController : CM_LocationsController) : String;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	if _theLocationsController = null then
		return "";
	endif;
	
	return _theLocationsController.getFullId();

end;</source>
        <Parameter name="_theLocationsController" type="CM_LocationsController"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayMachineTypeGrps" id="97fc288d-f856-45a5-99a5-cfe00b5524b7">
        <source>displayMachineTypeGrps(_machineTypeGroup : CM_MachineTypeGroup) : String;

// Created by cnwdvb1 on 15 September 2006

vars

begin

	if _machineTypeGroup.type = MACHINETYPEGRP_SOURCEIC or
		_machineTypeGroup.type = MACHINETYPEGRP_TARGETIC or
		_machineTypeGroup.type = MACHINETYPEGRP_MAFI then //jlier1 TFS 54701 19/9/22
		return null;
		
	endif;

	return _machineTypeGroup.description;
end;</source>
        <Parameter name="_machineTypeGroup" type="CM_MachineTypeGroup"/>
        <ReturnType type="String"/>
    </JadeMethod>
