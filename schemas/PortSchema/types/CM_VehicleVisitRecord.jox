    <JadeMethod name="setProxyBookingSlots" id="7aa22f70-4990-4b62-a802-9b980875cafc">
        <updating/>
        <source>setProxyBookingSlots(_bookingSlots : CMIF_1StopBookingDataArray) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/01/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS Integration
//
vars
	detail : CMIF_1StopBookingData;
	bookingSlot : CM_1StopExtVehicleBookingSlot;

begin
	
	if _bookingSlots = null then	//TFS 53107, AjitM, navam1
		return;
	endif;
	
	self.all1StopExtVehicleBookings.purge;
	foreach detail in _bookingSlots do
		create bookingSlot transient;
		bookingSlot.setFromCMIFDetail(self.carrierCode, self.myTerminal, self, detail);
	endforeach;
epilog

end;</source>
