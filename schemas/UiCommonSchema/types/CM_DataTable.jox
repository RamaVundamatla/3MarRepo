    <JadeMethod name="addColumns" id="52cad253-6291-4871-b784-3a0ad8c03bb0">
        <updating/>
        <source>addColumns() updating, protected;
//--------------------------------------------------------------
//Created: January 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 22/02/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	entRow		: EntTableRow;
	tmpStr		: String;
	inputType2 	: Integer;
	tmpLocale	: CM_Locale;	
	alteredHeaderName : String;

begin

	tmpLocale := app.myCurrentLocale;

	self.doHandleMeasurementColumns();				// PAR #31155

	foreach entRow in self.allTblDataEntRows do
		//The row/col input types are overridden here to be either checkbox or text.
		//When sort type is required (later) we go back to the entRow object to get 
		//what was actually set for the inputType and convert this to a sort type.
		//We don't convert the input type as set in self.allTblDataColInputTypes.
		if entRow.inputType &lt;&gt; Table.InputType_CheckBox then
			//so if its not a checkBox (1) we want to see the text so inputType_None
			inputType2 := Table.InputType_None;
		else 
			//else it's a checkBox so we need to see that tick rather than a 1 or 0 
			inputType2 := entRow.inputType; 
			
		endif;
		
		tmpStr := entRow.getShortHeading(self.myTerminologyCargoBOLType, self.myTerminologyTerminal, tmpLocale);
		// 35440 use the cargo type attribute heading
		alteredHeaderName := self.getCargoTypeAttrHeading(entRow.name);
		if alteredHeaderName &lt;&gt; null then
			tmpStr := alteredHeaderName;
		endif;
	
		self.zAddColumn(tmpStr, entRow.name, inputType2);

		if entRow.sortFieldName &lt;&gt; null then
			self.zAddColumn(entRow.sortFieldName, entRow.sortFieldName, self.SortColInputType);
		endif;
	endforeach;

epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addHiddenSortColumn" id="1e952b38-e32b-47e1-ab7d-9aee4ffd501d">
        <updating/>
        <source>addHiddenSortColumn(_sortColumn : Integer output) updating, protected;
//-----------------------------------------
// Created: 20 September 2005 By: cnwgd1
//-----------------------------------------
vars
	col	: JadeTableColumn;
begin

	_sortColumn := self.columns;
	
	if _sortColumn &gt; 0 and self.rows &gt; 0 then
		if self.accessCell(1, _sortColumn).text = self.SortColumnHeading then
			// sort column already exists
			return;
		endif;
	endif;
	
	_sortColumn := _sortColumn + 1;
	self.columns := _sortColumn;

	col := self.accessColumn(_sortColumn);
	col.inputType := InputType_None;
	col.visible := false;
	col.width := 0;

	if self.rows &lt; 1 then
		self.rows := 1;
		self.fixedRows := 1;
	endif;

	self.accessCell(1, _sortColumn).text := self.SortColumnHeading;
	
end;</source>
        <access>protected</access>
        <Parameter name="_sortColumn" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="addItemObject" id="358ebe59-edaf-4ae9-b1e6-bde5f9faa294">
        <updating/>
        <source>addItemObject(_obj : Object; _str : String) : Integer updating;
/* ---------------------------------------------------------------------------
// Created:     15 September 2002 by cnwrs2
//
// Purpose:     
// 13 Mar 2025	navnk30	JIRA 34245: Develop a generic solution to show data in a CM_DataTable using "Pagination"
// 11 Jun 2025	jlier1		JIRA 34771
// 29 Aug 2025  navhl20 Bug MTN-35804: Notifications are not handled on the Work Order Operations form and Work Order Enquiry form
// 04 Sep 2025	navhl20 Bug MTN-35916: MTN - Error 1309 in WO Enquiry
--------------------------------------------------------------------------- */
vars
	coll 		: Collection;
	idx 		: Integer;
	baseform	: CM_BaseForm;
	tbl			: CM_DataTable;
begin	
	//return inheritMethod(_obj, _str);		//13.03.2025 navnk30 JIRA 34245
	if self.isPaginated() then				//13.03.2025 navnk30 JIRA 34245
		coll:=self.getCollection;
		if coll = null then
			return NULLINDEX;
		endif;
		idx:=NULLINDEX;
		if not  coll.includes(_obj) then
			if coll.isKindOf(DynaDictionary) then
				self.addKeyValForPagination(coll.DynaDictionary,_obj);
			else
				coll.tryAddIfNotNull(_obj);
			endif;
			
			
			//23/06/2025	navkc1 JIRA MTN 34973
		
			if self.isPaginatedNotification() then
				self.doPaginatedNoteAdd(_obj.CM_Object);
			endif;
			
			self.refreshEntries(null);
			self.findObjectInRow(_obj,idx);  //jlier1 35762 19/8/25
		endif;
	
		return idx;
	else
		//Start 11.09.2025 navhl20 #35804
		idx := inheritMethod(_obj, _str);
		if self.form.isKindOf(CM_BaseForm) then
			baseform := self.form.CM_BaseForm;
		endif;
		
		if baseform &lt;&gt; null then
			tbl := self;
			baseform.rowPostprocess(tbl, idx, _obj);
		endif;
		
		return idx;
		//End 11.09.2025 navhl20 #35804
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addKeyValForPagination" id="53b10a31-bde8-4378-aaa0-13639c155a84">
        <source>addKeyValForPagination(_dynaDict : DynaDictionary io; _obj : Object) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2025	navnk30	JIRA 34245: Develop a generic solution to show data in a CM_DataTable using "Pagination"
03 Apr 2025 navnk30 JIRA 34552: Pagination - Issue sorting Columns with Date/Time fields
10 Jun 2025 jlier1 JIRA 35394 : Error 1322 - even though max key length is 512 if we have 3 keys it adds a terminating char so would be max of 169.66 
*/
constants
	MAX_KEY_LEN_LIMIT	: Integer = 169;
vars
	keyStr1,
	keyStr2,
	keyStr3		: String;
	keyType1,
	keyType2,
	keyType3	: Type;
	colId,
	idx			: Integer;
	sortEtRows	: EntTableRowArray;
begin
	create sortEtRows transient;
	foreach idx in 1 to self.allTblDataSortColumns.size() do
		sortEtRows.tryAdd(self.getEntRowColumnByRowName(self.allTblDataSortColumns[idx], colId));
	endforeach;
	if sortEtRows.isEmpty() then
		return;
	endif;
	
	keyStr1 := _obj.getDisplayStringForAttribute(sortEtRows[1].name, false);
	keyType1 := self.convertInputTypeToPrimType(sortEtRows[1].inputType);
	if sortEtRows.size() = 1 then
		_dynaDict.tryPutAtKey(keyStr1[1:MAX_KEY_LEN_LIMIT].asAnyOfType(keyType1), _obj);
		return;
	endif;
	
	keyStr2 := _obj.getDisplayStringForAttribute(sortEtRows[2].name, false);
	keyType2 := self.convertInputTypeToPrimType(sortEtRows[2].inputType);
	if sortEtRows.size() = 2 then
		_dynaDict.tryPutAtKey(keyStr1[1:MAX_KEY_LEN_LIMIT].asAnyOfType(keyType1), keyStr2[1:MAX_KEY_LEN_LIMIT].asAnyOfType(keyType2), _obj);
		return;
	endif;
	
	keyStr3 := _obj.getDisplayStringForAttribute(sortEtRows[3].name, false);
	keyType3 := self.convertInputTypeToPrimType(sortEtRows[3].inputType);
	_dynaDict.tryPutAtKey(keyStr1[1:MAX_KEY_LEN_LIMIT].asAnyOfType(keyType1), keyStr2[1:MAX_KEY_LEN_LIMIT].asAnyOfType(keyType2), keyStr3[1:MAX_KEY_LEN_LIMIT].asAnyOfType(keyType3), _obj);
epilog
	delete sortEtRows;
end;</source>
        <access>protected</access>
        <Parameter name="_dynaDict" type="DynaDictionary" usage="io"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="addObject" id="f369e30e-e228-4bf2-aa87-f31af4c993ce">
        <updating/>
        <source>addObject(_obj : Object) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/08/2011	cnwer1	Initial creation CCMS MES 1033
*/

vars
	tmpStr,rtnStr : String;
	firstTime : Boolean;
	entRow : EntTableRow;
	colorColumn	, 
	theColumn,
	theRow 	: Integer;
	theColor 	: Integer;
	cell : JadeTableCell;
begin
	
	firstTime:=true;
	theColumn:=1;
	foreach entRow in self.allTblDataEntRows do			
		//epr TFS 830 now handles display for CMIFs
		tmpStr := _obj.getDisplayStringForAttribute(entRow.name, true);
		
		if   entRow.inputType = Table.InputType_CheckBox then						
			if tmpStr.Boolean = true or tmpStr.toLower='yes' or tmpStr = '1' then  //cnwjo3 par 24661
				tmpStr := '1';
			else
				tmpStr := '0';
			endif;	
		elseif entRow.inputType = CM_EntryTable.InputType_ColourSelection then
			colorColumn:=theColumn;
			theColor:=tmpStr.Integer;
		endif;
		if firstTime then
			firstTime := false;
			rtnStr := tmpStr;
		else
			rtnStr := rtnStr &amp; Tab &amp; tmpStr;
		endif;
		
		if entRow.sortFieldName &lt;&gt; null then			
			tmpStr := _obj.getDisplayStringForAttribute(entRow.sortFieldName, false);
					
			rtnStr := rtnStr &amp; Tab &amp; tmpStr;
		endif;
		
		theColumn:=theColumn + 1;
	endforeach;

	

	theRow:=self.addItemObject(_obj,rtnStr);
	
	if colorColumn &lt;&gt; 0 then
		cell := self.accessCell(theRow, colorColumn);
		cell.text := null;
		cell.backColor := theColor;	
	endif;
	
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="addObjectAt" id="a98a310c-8a7f-4d3c-8977-17e0d6cd36c4">
        <updating/>
        <source>addObjectAt(_obj : Object; idx : Integer) updating;
/*

Date		Who		Reason
21 March 2017	cnwer1	Initial creation TFS 830

*/

vars
	rowIdx		: Integer;
	invalid : Boolean;
	str 	: String;
begin
	if _obj = null or 
		(self.myDataClass &lt;&gt; null and	// par 24292 cnwcs5 25/05/2010
		not self.myDataClass.hasInstance(_obj)) then
		return ;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _obj, invalid);

	str := _obj.getAttributeStringForDefArray(self.allTblDataEntRows);
	
	if invalid then
		return ;
	endif;
	
	 self.addItemObjectAt(_obj, str,idx);
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addTableObjectsMemberKeys" id="0044d60e-06ef-4f68-b12e-9073af6c7469">
        <updating/>
        <source>addTableObjectsMemberKeys() : Boolean updating;
//--------------------------------------------------
// Created:	09 September 2005 By: cnwgd1
//--------------------------------------------------
constants
	// dynaDict key limit = 512, max sort columns = 15
	// max sort columns X lenght = 450
	Length = 30;
vars
	rowsInError,
	rowName : String;
	primType : PrimType;
	rowIdx,
	numCols,
	idx	: Integer;
	tmpDynaDict : CM_ExtKeyDynaDictionary;
	entRow	 : EntTableRow;
	descending,
	caseInsensitive : Boolean;
	doEndKeys		: Boolean;
begin

	tmpDynaDict := self.allTableObjects;
	
	if tmpDynaDict.noKeys() then
		// defintion incomplete
	else
		tmpDynaDict.clear();
		tmpDynaDict.clearKeys();
	endif;
	
	// set the member keys form the selected sort columns
	// caseInsensitive := true; not used - only ever set to true
	
	numCols := self.getNumberOfSortColumns;	// moved code into method so we can re-implement
	
	if numCols &gt; self.maxSortColumns then
		numCols := self.maxSortColumns;
	elseif numCols = 0 then
		return false;
	endif;
	
	// 12/08/2009 - moved code below to its own method
	self.zAddTableObjectsMemberKeys (numCols, tmpDynaDict);
/*	idx := 1;
	
	while idx &lt;= numCols do
		rowIdx := 0;
		rowName := self.allTblDataSortColumns[idx];
		descending := self.allTblDataSortDescending[idx];
		entRow := self.getEntRowColumnByRowName(rowName, rowIdx);

		if rowIdx &gt; 0 then
			self.accessCell(self.fixedRows, rowIdx).fontBold := false;
		endif;
				
		primType := self.convertInputTypeToPrimType(entRow.inputType);
		tmpDynaDict.addExternalKeyForEntRow(rowName, primType, Length, descending, caseInsensitive);
		doEndKeys := true;	
		idx := idx + 1;
	endwhile;
*/
	tmpDynaDict.endKeys(true);
	
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
