    <JadeMethod name="setMachineStatusPicSecondaryQs" id="ce6b000d-ad78-48a0-a52b-710af3a46dfc">
        <source>setMachineStatusPicSecondaryQs(_machine : CM_Machine; _row : Integer; _isInPrimary : Boolean; _queue : CM_RadioTelemetryQueue);
// --------------------------------------------------------------------------------
// Created:		05 November 2010 by cnwjo3
//
// Purpose:		alot of duplication in showMachinesForQueue.  Have moved code out of there into this method.
//				this method deals with the displaying of the machine in secondary queues.  The ~XX machines!
//				par 25669
//
vars
	cell : JadeTableCell;
	offLine : Binary;
	inactive : Binary;
	active : Binary;
begin
/*
	cell := self.tblMachines.accessCell(_row, 1);
	
	if _machine.machineType = MACHINETYPE_STRADDLE then
		offLine		:= picStraddleOff.picture;
		inactive	:= picStraddleIdle.picture;
		active		:= picStraddleActiv.picture;
	elseif _machine.machineType = MACHINETYPE_PORTAINER_CRANE then
		offLine		:= picCraneOff.picture;
		inactive	:= picCrane.picture;
		active		:= picCrane.picture;
	elseif _machine.machineType = MACHINETYPE_FORK_LIFT then
		offLine		:= picForkliftOff.picture;
		inactive	:= picForkliftIdle.picture;
		active		:= picForkliftActiv.picture;
	elseif _machine.machineType = MACHINETYPE_RTG or _machine.machineType = MACHINETYPE_RMG then
		offLine		:= picRTGOff.picture;
		inactive	:= picRTGIdle.picture;
		active		:= picRTGActive.picture;
	elseif _machine.machineType = MACHINETYPE_IMV then
		offLine		:= picIMVOff.picture;
		inactive	:= picIMVIdle.picture;
		active		:= picIMVActive.picture;
	else
		offLine		:= picForkliftOff.picture;
		inactive	:= picForkliftIdle.picture;
		active		:= picForkliftActiv.picture;
	endif;
	
	
	if _machine.machineStatus = STATUS_OFFLINE then
		cell.picture := offLine;
	else
		if _machine.currentQueueTask = null then
			cell.picture := inactive;
		else
		//	if _machine.workingInQueue = _queue then
			if ( _machine.workingInQueue = _queue ) or ( _machine.currentQueueTask.queue = _queue ) then //06 Dec 2010	NDL	Par 25669/26450
				cell.picture := active;
			else
				cell.picture := inactive;
			endif;
		endif;
	endif;
	*/
end;</source>
