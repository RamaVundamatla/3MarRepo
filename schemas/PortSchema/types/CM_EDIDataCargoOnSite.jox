    <JadeMethod name="getParentTI" id="846cebf1-c730-4fa4-91b6-b522ddd09253">
        <source>getParentTI(_childTI : CM_EDICargoTI) : CM_TrackedItem;
/*
Purpose:			
Date		Who		Reason
09 July 2014	cnwab1	Initial creation
*/

vars
	terminal				:CM_Terminal;
	parentTI : CM_TrackedItem;
	matches					: Integer;

begin
	terminal	:= self.getMyTerminal;
	
	if terminal = null then
		return null;
	endif;
	
	parentTI := terminal.searchForOnsiteTI(_childTI.parentCargoID, matches, app.myRoot.getCargoTypeFromAbbrevOrDescr(_childTI.parentCargoType).type());
	
	return parentTI;
epilog

end;</source>
        <Parameter name="_childTI" type="CM_EDICargoTI"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getRealBreakBulkItem" id="b60479ba-5b76-4bfc-8d19-909fbd105980">
        <source>getRealBreakBulkItem(_ediTI: CM_EDICargoTI; _cargoType: CM_CargoType; _dict: CM_TIByCargoTypeIdDict): CM_TrackedItem;
/*
Purpose:			

Date		Who		Reason
// ### TFS BUG 58101 22MAY2023 NAVAB1
*/

vars

	terminal	: CM_Terminal;
	locn : CM_LocationsController;
	otherTI : CM_TrackedItem;
	matches,height : Integer;
begin

	terminal	:= self.getMyTerminal();

	terminal.findLocationFromString(_ediTI.locationId,false,locn, height);
	if locn &lt;&gt; null then
		otherTI := locn.searchForOnsiteTI(_ediTI.id,matches,_ediTI.cargoType,_ediTI.cargoGroupId,_ediTI.product, _ediTI.operatorCode); //03.Nov.2023 navsp TFS 61067
		return otherTI;
	endif;
	
	return inheritMethod(_ediTI, _cargoType, _dict);
epilog

end;</source>
        <Parameter name="_ediTI" type="CM_EDICargoTI"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_dict" type="CM_TIByCargoTypeIdDict"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getRealCargoItem" id="076bdddf-be97-4cb0-9490-24e9313b6416">
        <source>getRealCargoItem(_ediTI : CM_EDICargoTI): CM_TrackedItem;
/* ---------------------------------------------------------------------------
Created:     25 February 2010 by cnwrs2

Change Date	Who		Reason
20/06/2012	cnwcs5	par 29747 - no longer protected
------------------------------------------------------------------------------*/
vars
	terminal	: CM_Terminal;
	cargoType: CM_CargoType;
	existingCG : CM_CargoGroup;
begin

	terminal := self.getMyTerminal();
		
	cargoType := terminal.myRoot.allCargoTypesById[_ediTI.cargoType];
	if cargoType &lt;&gt; null and cargoType.isAllowDuplicates then
		return self.getRealBreakBulkItem(_ediTI, cargoType, terminal.allOnsiteTIsByCargoTypeId);
	endif;	

	//04.Oct.2023 navsp1 TFS 58058
	if cargoType &lt;&gt; null and cargoType.isCargoGroup then
		//existingCG := terminal.getCargoGroupItemForOperator( _ediTI.id, self.operatorCode, _ediTI.cargoType);  //14.Nov.2023 navsp1 TFS 61127
		existingCG := terminal.getCargoGroupItem( _ediTI.id );  												 //14.Nov.2023 navsp1 TFS 61127
		if existingCG &lt;&gt; null then
			return existingCG;
		endif;
	endif;
	
	return terminal.allOnsiteTIsByCargoTypeId[_ediTI.cargoType, _ediTI.id];

epilog

end;</source>
        <Parameter name="_ediTI" type="CM_EDICargoTI"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
