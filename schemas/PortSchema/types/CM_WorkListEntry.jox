    <JadeMethod name="getLoadPortForDisplay" id="0b1572d9-4f01-443b-bbd9-27e56b998f76">
        <source>getLoadPortForDisplay() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/03/2011	cnwdap1	Initial creation PAR #27153 CCMS POL 2000
*/
vars
	loadPort	: CM_Port;

begin
	if self.myRequest &lt;&gt; null and self.myRequest.myOriginatingBulkRelease &lt;&gt; null then
		loadPort := self.myRequest.myOriginatingBulkRelease.myLoadPort;
	elseif self.myRequest &lt;&gt; null and self.myRequest.myReserveDetail &lt;&gt; null and self.myRequest.myReserveDetail.myReserveHeader &lt;&gt; null then
		loadPort := self.myRequest.myReserveDetail.myReserveHeader.myLoadPort;
	endif;
	
	if loadPort &lt;&gt; null then
		return loadPort.code;
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLoadSequence" id="5e53503f-0ca9-43b5-b550-599fb2719009">
        <source>getLoadSequence():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navhl20	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
03 Jul 2023 navma1  ChangeRequest 58849: EUP | Delivery Dispatch Screen - Unpack Operation
*/

vars
	job : CM_Job;
begin
	job := self.job;
	
	if job &lt;&gt; null then
		if job.workListEntries.isNotEmpty() then
			return job.workListEntries.indexOf(self).asStringJMT;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
