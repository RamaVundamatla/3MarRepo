    <JadeMethod name="showHideFrmSP" id="73ffaeb4-6793-4737-a3b4-b45b874d0e5a">
        <updating/>
        <source>showHideFrmSP(_hide : Boolean; _pilot : CM_InvTypePilotSurcharge) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/06/2018	jlgdap1		Initial creation TFS 39355 PEL1 Pilot Surcharges
//
vars
	invalidObj, load : Boolean;

begin
	on Exception do app.handleDeletedObject( exception, self.myProxySPCharges, invalidObj );
	if self.myProxySPCharges &lt;&gt; null then
		delete self.myProxySPCharges;
	endif;
	
	if not _hide then
		self.resize();
	endif;
	
	self.frmSP.visible := not _hide;
	self.frmMain.enabled := _hide;
	
	self.cmbSPNotReady.listIndex := -1;
	self.cmbSPTooSoon.listIndex := -1;
	
	if not _hide then
		self.frmSP.ignoreSkin := true;
		if _pilot &lt;&gt; null then
			if  _pilot.myPilotSurchargeInvLineTypeVNR &lt;&gt; null then
				self.cmbSPNotReady.listIndex := self.cmbSPNotReady.findObject( _pilot.myPilotSurchargeInvLineTypeVNR);
			endif;
			if  _pilot.myPilotSurchargeInvLineTypeRTS &lt;&gt; null then
				self.cmbSPTooSoon.listIndex := self.cmbSPTooSoon.findObject( _pilot.myPilotSurchargeInvLineTypeRTS );
			endif;
			app.cmsBeginLoad( load );
			self.myProxySPCharges := _pilot.pxyCreateUpdateProxy();
			app.cmsEndLoad( load );
		else
			create self.myProxySPCharges transient;
		endif;
		self.frmMain.zOrder(0);
	endif;
epilog

end;</source>
        <Parameter name="_hide" type="Boolean"/>
        <Parameter name="_pilot" type="CM_InvTypePilotSurcharge"/>
    </JadeMethod>
    <JadeMethod name="showHideFrmVMC" id="c625b2a5-cea5-4b8f-a69e-c859dd639d4f">
        <updating/>
        <source>showHideFrmVMC( _hide : Boolean; _minChg : CM_InvTypeVesselMinCharge ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2018	jlgndl1	Initial creation	TFS 38914

*/

vars

	invalidObj : Boolean;
	load : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, self.myProxyVMCharges, invalidObj );
	if self.myProxyVMCharges &lt;&gt; null then
		delete self.myProxyVMCharges;
	endif;
	
	if not _hide then
		self.resize();
	endif;
	
	self.frmVMC.visible := not _hide;
	self.frmMain.enabled := _hide;
	
	self.cmbVMCInvLineType.listIndex := -1;
	self.cmbVMCVessel.listIndex := -1;
	self.txtVMCMinCharge.text := null;
	
	if not _hide then
		self.frmVMC.ignoreSkin := true;
		if _minChg &lt;&gt; null then
			if  _minChg.getMinimumChargeInvLineType &lt;&gt; null then
				self.cmbVMCInvLineType.listIndex := self.cmbVMCInvLineType.findObject( _minChg.getMinimumChargeInvLineType );
			endif;
			if  _minChg.myVessel &lt;&gt; null then
				self.cmbVMCVessel.listIndex := self.cmbVMCVessel.findObject( _minChg.myVessel );
			endif;
			self.txtVMCMinCharge.text := _minChg.minimumChargeAmount.asStringJMT();
			app.cmsBeginLoad( load );
			self.myProxyVMCharges := _minChg.pxyCreateUpdateProxy();
			app.cmsEndLoad( load );
		else
			create self.myProxyVMCharges transient;
		endif;
		self.frmMain.zOrder(0);
	endif;

epilog

end;</source>
        <Parameter name="_hide" type="Boolean"/>
        <Parameter name="_minChg" type="CM_InvTypeVesselMinCharge"/>
    </JadeMethod>
    <JadeMethod name="tblACS_dblClick" id="9f749ca8-ee49-4187-9d70-f43b8832672b">
