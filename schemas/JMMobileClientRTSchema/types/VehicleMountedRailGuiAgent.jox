    <JadeMethod name="create" id="b2067f6d-03ef-455c-8a4f-121f7026446f">
        <updating/>
        <source>create() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	create self.myVehicleMountedRAILAgent transient;
	create self.myNotesObj transient;
	self.beginNotification(self.myVehicleMountedRAILAgent, MobileHandHeldThin::VehicleMountedAgent.Event_Server_Note, Response_Continuous , null);

epilog

end;</source>
