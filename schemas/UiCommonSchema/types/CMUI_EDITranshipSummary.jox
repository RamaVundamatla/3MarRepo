    <JadeMethod name="doUnload" id="2c515e69-16ac-4b7f-9a29-a859e003cf3d">
        <source>doUnload();
// ---------------------------------------------------------------------------
// Created:     September 2007 cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars

begin
