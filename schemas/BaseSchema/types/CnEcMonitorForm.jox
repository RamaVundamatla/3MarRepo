    <JadeMethod name="tblInclude_rowColumnChg" id="547e5c8a-28d9-4a15-915d-db8eba4fefdf">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInclude_rowColumnChg(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		07 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	saveRow		: Integer;
	rowPointer	: Integer;

begin
	saveRow	:=	table.row;

	// compress any blank rows

	rowPointer	:=	table.rows - 1;
	
	while rowPointer &gt;= 2 do
		table.row	:=	rowPointer;
		
		if table.text = null then
			table.deleteRow(rowPointer);
		endif;
		
		rowPointer	:=	rowPointer - 1;
	endwhile;

	table.row := saveRow;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblNode_click" id="92f68d24-3502-4167-9bf3-77dad7b03b35">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblNode_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		27 May 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	nodeObj		: Node;
	rowIndex	: Integer;
	rowCount	: Integer;

begin
	app.mousePointer	:=	Busy;
	rowCount			:=	table.rows;
	rowIndex			:=	table.row;

	if rowIndex &gt; 1 and rowIndex &lt;= rowCount then
		nodeObj	:=	table.cnEcGetCellObject(rowIndex, 1).Node;

		if nodeObj = null then
			btnKillNode.enabled		:=	false;
			btnKillProcess.enabled	:=	false;
		else
			self.doLoadNodeProcesses(nodeObj);
			btnKillNode.enabled		:=	true;
			btnKillProcess.enabled	:=	false;
		endif;
	else
		btnKillNode.enabled		:=	false;
		btnKillProcess.enabled	:=	false;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblNode_mouseDown" id="4206bfa2-773f-44d9-a410-43b1b5e66e87">
        <controlMethod name="Table::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblNode_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		27 May 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if table.row &gt; 1 and table.row &lt;= table.rows then
		table.cnEcSelectRow();
	else
		table.clearAllSelected();
		tblProcess.rows	:=	1;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblProcess_click" id="63154534-c72e-4c52-9b6d-2cd21da48ca0">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblProcess_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		29 May 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex	: Integer;
	rowCount	: Integer;

begin
	app.mousePointer	:=	Busy;
	rowCount			:=	table.rows;
	rowIndex			:=	table.row;

	if rowIndex &gt; 1 and rowIndex &lt;= rowCount then
		btnKillProcess.enabled	:=	true;
	else
		btnKillProcess.enabled	:=	false;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblProcess_mouseDown" id="d29aa8c3-2c7e-4cf2-84d0-5cf3837b40d0">
        <controlMethod name="Table::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblProcess_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		27 May 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if table.row &gt; 1 and table.row &lt;= table.rows then
		table.cnEcSelectRow();
	else
		table.clearAllSelected();
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="b6fb253a-3ec0-468c-8181-b1f873cad7ea">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2000 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if eventTag = self.BLINK_TIMER then
		lblPaused.visible	:=	(not lblPaused.visible);
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="unload" id="4e4d381a-f659-429f-a4f5-b068a49b4eae">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

begin
	if self.aMyLogFile &lt;&gt; null then
		delete self.aMyLogFile;		// If the file is open, it'll be closed automatically.
	endif;

	if self.aIsPaused then
		endTimer(self.BLINK_TIMER);
	endif;

	// Cancel all my notifications.
	endNotificationForSubscriber(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="5c92a5b8-35fb-43f2-aa99-9d060a57d58d">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType:Integer; theObject:Object; eventTag:Integer; userInfo:Any) updating;

vars
	monitorMessage		: String;

begin
	if eventType = CNEC_MONITOR then
		monitorMessage	:=	userInfo.String;
		return;
	endif;

	monitorMessage	:=	"Unknown event: " &amp; eventType.String &amp; " (" &amp; userInfo.String &amp; ")";
	cnEcLog("Monitor - UNKNOWN MESSAGE TYPE: " &amp;  monitorMessage);
epilog
	if monitorMessage &lt;&gt; null then
		self.doShowMonitorMessage(monitorMessage);
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="zExceptionHandler" id="8b5802f9-f4d8-4dc2-8b86-8ea109c8f4ba">
        <source>zExceptionHandler(pExceptionObj:Exception):Integer protected;
// --------------------------------------------------------------------------------
// Created:		25 May 2000 by cnwdad1
//
// Purpose:		Handler to log any exceptions encountered by the Monitor.
//
// Parameters:	pExceptionObj - The JADE Exception object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.cnEcLog("*** BaseSchema Monitor: " &amp; pExceptionObj.cnEcGetDetails() &amp; CrLf);
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
