*/

begin
	self.raiseExceptionIfNull(_pxyVDR, 'Volume Discrepancy Reason Proxy');
	self.raiseExceptionIfNull(_existingVDR, "Volume Discrepancy Reason Existing");
	_pxyVDR.raiseExceptionIfNotProxy(method);
	
	if _existingVDR.code = _pxyVDR.code then
		_pxyVDR.validateForUpdate();
	else
		_pxyVDR.validateForCreate();
	endif;
end;</source>
