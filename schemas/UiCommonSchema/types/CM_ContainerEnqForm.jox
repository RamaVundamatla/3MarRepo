    <JadeMethod name="cmbFiltTermArea_lostFocus" id="381e5882-1934-4d35-b042-32bab636987c">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbFiltTermArea_lostFocus(combobox: ComboBox input) updating;
//--------------------------------------------------------------
//Created: 31 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpTA 	: CM_TerminalArea;
begin
	
	self.tblSearch.setValueByControlName(combobox.name, combobox.text);
	if self.origValueStr &lt;&gt; combobox.text then	
		tmpTA := combobox.listObject.CM_TerminalArea;
		self.setFilterTerminalArea(tmpTA);
		self.resetNavigatorHeading(null);
		if tmpTA &lt;&gt; null then
				self.setYardLocations(tmpTA);
//				self.myAssistant.comboBoxLocationControllers(self.cmbFiltYardLocn, tmpTA.getLCsCollectionForDisplay, false);
		else
			self.cmbFiltYardLocn.clear();
			self.cmbFiltYardLocn.lostFocus(self.cmbFiltYardLocn);
		endif;
		//Used by YRD_LocationEnquiryForm
		//No change for CM_ContainerEnqForm, should be the selected terminal and TI id
		self.setFormHeading();
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbFiltTiType_click" id="9bc20110-64e1-4e24-a684-780ff0781042">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbFiltTiType_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     20 June 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	entTableRowProxy : EntTableRow;
begin
	if self.origValueStr &lt;&gt; combobox.text then
		if combobox.listObject &lt;&gt; null then
			self.myCurrentCargoBOLType := combobox.listObject.CM_CargoBOLType;
			self.filterCargoTypeId := self.myCurrentCargoBOLType.id;
			// cnwrl1 29/10/2010 CCMS 1111 - PAR 26162 - start of coding
			if self.filterCargoTypeId = TI_CargoType_Log then
				// C3 in particular want CargoType of "Log" to default "Site/State" to "**Anywhere**"
				
				self.cmbFiltSite.listIndex	:= 1;
			elseif self.non_Log_Index &gt; null then
				self.cmbFiltSite.listIndex	:= self.non_Log_Index;
			endif;
			self.cmbFiltSite_click( self.cmbFiltSite );
			self.cmbFiltSite.lostFocus( self.cmbFiltSite );
			// cnwrl1 29/10/2010 PAR 26162 - end of coding
		else
			self.myCurrentCargoBOLType := null;
			self.filterCargoTypeId := null;
		endif;			
		self.setCargoTypeFields(self.myCurrentCargoBOLType);

		
		// height of searcher to change when table changes from diff TI types selected.
		if not self.isSearcherFloating then 
			self.searcherDockUndock(true);
		else
			self.adjustSearcherHeight();
		endif;
		
		self.loadProductCombo();
		if self.tblSearch.isRowVisible(ETRow_FilterTrailerType) then
			self.loadTrailerCombo();
		endif;
		
		self.origValueStr := combobox.text;

	
		
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
