    <JadeMethod name="copyToRealWSObject" id="698c7032-f4fd-442c-83e3-f32529c56905">
        <source>copyToRealWSObject(_realRequest: IPN1_SendRealisasiTunda input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

