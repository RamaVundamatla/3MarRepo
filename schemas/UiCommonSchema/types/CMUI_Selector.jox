    </JadeMethod>
    <JadeMethod name="getModeDescription" id="21fa4033-39c1-4fc2-9cd5-15d0ec8feaae">
        <source>getModeDescription(_cargoBOLType : Integer) : String protected;
// ---------------------------------------------------------------------------
// Created:     23 June 2003		cnwth2	
//
// Purpose:     		 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 27/05/2013	cnwdap1		PAR #31486 New User-Defined Cargo mode
// 22 Dec 2022  navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 18 Feb 2023  navmv20     TFS 55649 Task 55689: UI - Selector Query Contracts
// 10 May 2023 	navlw1   	ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
vars
	theCargoType				: CM_CargoType;
	theCargoBOLType				: CM_CargoBOLType;
	str							: String;
begin

	if _cargoBOLType &gt; BOLType_Min and _cargoBOLType &lt; BOLType_Max then
		str := app.getErrorString(Docket);
	//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
	elseif _cargoBOLType = CM_QueryDefinition.CargoTransaction_Query_Mode then
		str := app.getErrorString(Cargo_Transaction);
	elseif _cargoBOLType = CM_QueryDefinition.EventTransaction_Query_Mode then
		str := app.getErrorString(Event_Transaction);
	elseif _cargoBOLType = CM_QueryDefinition.HMSTransaction_Query_Mode then
		str := app.getErrorString(HMS_Transactions);
	elseif _cargoBOLType = CM_QueryDefinition.BOLTransaction_Query_Mode then	//04 Nov 2019	NDL	TFS 47100
		str := app.getErrorString(BOL_Transactions);
	elseif _cargoBOLType = CM_QueryDefinition.Location_Activity_Query_Mode then	//13 Apr 2021	NDL	TFS 50906
		str := app.getErrorString(Location_activity);
	elseif _cargoBOLType = CM_QueryDefinition.WorkOrderTrans_Query_Mode then	//22.12.2022 navhl20 #54350[54269]
		str := app.getErrorString(Workorder_transaction);	//22.12.2022 navhl20 #54350[54269]
	//15 May 2014	NDL	Par 34142
	elseif _cargoBOLType = CM_QueryDefinition.Invoice_Query_Mode then
		str := app.getErrorString(CM_Invoice_GC);
	//15 May 2014	NDL	Par 34142
	elseif _cargoBOLType = CM_QueryDefinition.InvoiceLine_Query_Mode then
		str := app.getErrorString(Invoice_line);
	elseif _cargoBOLType = CM_QueryDefinition.Contract_Query_Mode then //18/02/2023 navmv20 TFS 55649 TASK 55689
		str := app.getErrorString(Contract); //18/02/2023 navmv20 TFS 55649 TASK 55689
	//15 May 2014	NDL	Par 34142
	elseif _cargoBOLType = CM_QueryDefinition.CashPayment_Query_Mode then
		str := app.getErrorString(Cash_payment);
	//15 May 2014	NDL	Par 34142
	elseif _cargoBOLType = CM_QueryDefinition.CashReceipt_Query_Mode then
		str := app.getErrorString(Cash_receipt);
	elseif _cargoBOLType = CM_QueryDefinition.Audit_Query_Mode then // TFS 8390
		str := app.getErrorString(Audit_object);
	elseif _cargoBOLType = CM_QueryDefinition.VehicleBookingSlot_Query_Mode then // 10/05/2023 navlw1 tfs 53902
		str := app.getErrorString(Vehicle_bookings);
	else
		theCargoType := app.myRoot.allCargoTypesById[_cargoBOLType];
		if theCargoType &lt;&gt; null then
			str := theCargoType.description;
		endif;
	endif;
	
	if str = null then
		if self.myQDef &lt;&gt; null and self.myQDef.mode = CM_QueryDefinition.UserDefined_Query_Mode then	// PAR #31486
			str := app.getErrorString(User_Defined_Cargo);												// PAR #31486
		elseif self.myQDef &lt;&gt; null and  (self.myQDef.isKindOf(CM_QDefTILC) or self.myQDef.isKindOf(CM_QDefCar)) then
			str:=  self.myQDef.modeDescription;  //jlier1 TFS 64054 1/7/24
		else																							// PAR #31486
			str := app.getErrorString(TrackedItem);
		endif;																							// PAR #31486
	endif;
	
	return str &amp; ' ' &amp; app.getErrorString(Mode);

end;</source>
        <access>protected</access>
        <Parameter name="_cargoBOLType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveMode" id="06e0d5d0-9c32-41c7-90a6-2c755a44c589">
        <source>getMoveMode(): Integer;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/01/2011	cnwdap1	Initial creation PAR #26830 CCMS 2013
*/
vars

begin
	if self.moveModeForm = self.frmStatusLine.MENU_MOVE_INSTANT then
		return REAL_MODE;
	elseif self.moveModeForm = self.frmStatusLine.MENU_MOVE_QUEUED then
		return QUEUE_MODE;
	elseif self.moveModeForm = self.frmStatusLine.MENU_MOVE_PLAN then
		return PLANNING_MODE;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="9f276485-f99b-4b71-86bc-0751bbc1d23c">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:     12 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// Changed On	By			Reason
// ----------	----------	--------------------------------------------------
// 13/12/2019	jlgdap1		TFS 48011 PNL Selector reports missing
// 19/02/2025 	navlw1		JIRA-33939: MTN | Selector Save Option to XML
vars
	theXML,
	mode		: String;
begin

	theXML := inheritMethod();

	if self.myQDef &lt;&gt; null then
		mode := self.myQDef.mode.String;
	endif;

	theXML := theXML &amp; global.formatAsXML(self.XML_DefaultCargoBOLType, mode);
	
	theXML := theXML &amp; global.formatAsXML(self.XML_ShowAll, self.chkShowAll.value.asStringJMT);		// TFS 48011	
	
	theXML := theXML &amp; global.formatAsXML(self.XML_SupressedMessage, self.chkSupressMessage.value.asStringJMT); // navlw1 #JIRA-33939 19/02/2025 
	
	return theXML;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleNotification" id="4e6c7b46-5992-4144-9b31-ddaf7a42b4f7">
        <updating/>
        <source>handleNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//----------------------------------------------------------------
//	Created:	08 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx			: Integer;
	propName	: String;
	foundIdx	: Integer;
	qProp		: CM_QueryProperty;
	combo		: ComboBox;
begin
	combo := self.cmbAttr;

	if eventType = SelectorProperty_Delete_Event then
		//a stop or task has been deleted and it's associated query property
		//for delete event userInfo is the niceName
		foundIdx := 0;
		foreach idx in 1 to combo.listCount do
			propName := combo.itemText[idx];
			if propName = userInfo.String then
				foundIdx := idx;
				break;
			endif;
		endforeach;
		
		if foundIdx &gt; 0 then
			self.cmbAttr.removeItem(foundIdx);
		endif;
	elseif eventType = SelectorProperty_Update_Event then
		qProp := self.myQDef.allQueryProperties[userInfo.String];
		
		if qProp = null then
			return;
		endif;
		
		foreach idx in 1 to combo.listCount do
			if combo.itemObject[idx] = qProp then
				foundIdx := idx;
				break;
			endif;
		endforeach;
		
		if foundIdx &gt; 0 then
			combo.itemText [foundIdx] := qProp.niceName;
		endif;	
	
	elseif eventType = SelectorProperty_Create_Event then
		if self.myQDef &lt;&gt; null then
			//there is new stop or task query property
			//for create event userInfo is the propertyName
			qProp := self.myQDef.allQueryProperties[userInfo.String];
		endif;
		
		if qProp = null then
			return;
		endif;
		
		idx := combo.addItem(qProp.niceName);
		combo.itemObject[idx] := qProp;
				
	endif;
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="15e80827-45b8-4a76-967a-dd912b4998bf">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:     12 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// Changed On	By			Reason
// ----------	----------	--------------------------------------------------
// 13/12/2019	jlgdap1		TFS 48011 PNL Selector reports missing
// 22 Dec 2022  navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
// 10 May 2023 	navlw1   	ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
// 19/02/2025 	navlw1		JIRA-33939: MTN | Selector Save Option to XML
vars
	userWindow				: CM_UserWindow;
	defaultCargoBOLType		: Integer;
	theXML					: String;
	queryType				: Integer;
	showAll					: Boolean;			// TFS 48011
	showAllStr				: String;			// TFS 4801
	supressMsg				: String;
begin
	inheritMethod(_userWindow);
	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;

 	defaultCargoBOLType := theXML.cnEcGetTagValueOfName(self.XML_DefaultCargoBOLType).Integer;
	
	//23 Nov 2009	NDL	CCMS 1028
	//15 May 2014	NDL	Par 34142
	if defaultCargoBOLType = CM_QueryDefinition.Invoice_Query_Mode then
		queryType := CM_QueryDefinition.Invoicing_Query_Type;
	elseif defaultCargoBOLType = CM_QueryDefinition.InvoiceLine_Query_Mode then
		queryType := CM_QueryDefinition.Invoicing_Query_Type;
	elseif defaultCargoBOLType = CM_QueryDefinition.Contract_Query_Mode then 	//17/02/2023 navmv20 TFS 55626 TASK 55688
		queryType := CM_QueryDefinition.Invoicing_Query_Type;					//17/02/2023 navmv20 TFS 55626 TASK 55688
	elseif (defaultCargoBOLType = CM_QueryDefinition.EventTransaction_Query_Mode // TFS 47297 noticed during testing 47297
			or defaultCargoBOLType = CM_QueryDefinition.CargoTransaction_Query_Mode // TFS 47297
			or defaultCargoBOLType = CM_QueryDefinition.WorkOrderTrans_Query_Mode	//22.12.2022 navhl20 #54350[54269]
			or defaultCargoBOLType = CM_QueryDefinition.BOLTransaction_Query_Mode	//04 Nov 2019	NDL	TFS 47100
			or defaultCargoBOLType = CM_QueryDefinition.Location_Activity_Query_Mode	//13 Apr 2021	NDL	TFS 50906
			or defaultCargoBOLType = CM_QueryDefinition.HMSTransaction_Query_Mode) then // TFS 47297
		queryType := CM_QueryDefinition.Transaction_Query_Type; // TFS 47297
		
	elseif defaultCargoBOLType = CM_QueryDefinition.CashPayment_Query_Mode then
		queryType := CM_QueryDefinition.Cash_Query_Type;
		
	elseif defaultCargoBOLType = CM_QueryDefinition.CashReceipt_Query_Mode then
		queryType := CM_QueryDefinition.Cash_Query_Type;
		
	elseif defaultCargoBOLType = CM_QueryDefinition.Audit_Query_Mode then // TFS 8390
		queryType := CM_QueryDefinition.Audit_Query_Type;
		
	elseif defaultCargoBOLType = CM_QueryDefinition.VehicleBookingSlot_Query_Mode then // 10/05/2023 navlw1 tfs 53902
		queryType := CM_QueryDefinition.VehicleBookingSlot_Query_Type;

	elseif defaultCargoBOLType &gt;= BOLType_Min and defaultCargoBOLType &lt;= BOLType_Max then
		queryType := CM_QueryDefinition.BOL_Query_Type;	
	else
		queryType := CM_QueryDefinition.TrackedItem_Query_Type;
		
	endif;
	
	self.myQDef := app.myRoot.allQueryDefinitionObjects[queryType, defaultCargoBOLType];
	
	// TFS 48011 start
	showAllStr := theXML.cnEcGetTagValueOfName(self.XML_ShowAll);
	if showAllStr = null or showAllStr.toUpper = "TRUE" then
		self.chkShowAll.value := true;
	else
		self.chkShowAll.value := false;
	endif;
	// TFS 48011 end
	
	// START navlw1 #JIRA-33939 19/02/2025
	supressMsg := theXML.cnEcGetTagValueOfName(self.XML_SupressedMessage);
	if supressMsg.toUpper = "TRUE" then
		self.chkSupressMessage.value := true;
	else
		self.chkSupressMessage.value := false;
	endif;
	// END navlw1 #JIRA-33939 19/02/2025 
end;

</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTblQueryEnt" id="a3e14ace-cd41-4e94-8f59-5eae65b364b5">
        <source>initTblQueryEnt();
// ---------------------------------------------------------------------------
// Created:     16 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	idx			: Integer;
	numRows		: Integer;
	totHeight	: Real;
begin
	
	theTable := self.tblQueryEnt;
	theTable.warningMethod := 'entTableWarning';

	theTable.optimiseRowHeight := true;
	entTableDef := app.myController.getEntTableDef(ETDef_SelectorEnt);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	
	//theTable.height := 32;  //06/04/2006 cnwsh3 Not set on table properties in painter.
	
	//06/04/2006 cnwsh3 Changed to allow for new font in 7.4.1
	//theTable.accessColumn(CM_EntryTable.ColumnHeading).width := 100;
	theTable.accessColumn(CM_EntryTable.ColumnHeading).width := 110;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="isCriteriaUpdate" id="ede39321-bdf0-40f6-bfb3-ba617ea02829">
        <source>isCriteriaUpdate() : Integer;
/*
Purpose:			

Date		Who		Reason
26 February 2024	navab1	BUG 61210
*/
vars
	criteriaLine 		: CM_SelectorCriteriaLine;
	criteriaHolder			: CM_QueryCriteriaLineHolder;
	tblSheet				: JadeTableSheet;
	persistentProp			: CM_QueryProperty;
	row : Integer;
	controlSearchDescription, criteriaSearchDescription, argumentStr : String;
begin
	persistentProp		:= self.cmbAttr.listObject.CM_QueryProperty;
	if persistentProp = null then
		return CMUI_Selector.Mode_Unchanged;
	endif;

	tblSheet := self.tblCriteria.accessSheet(self.tblCriteria.topSheet);
	criteriaHolder := tblSheet.itemObject.CM_QueryCriteriaLineHolder;
	criteriaLine := criteriaHolder.allCriteriaByPropertyName[persistentProp.propertyName, persistentProp.propertyClassName];
	
	tblSheet.findRowObject(criteriaLine, row);
	if row &gt; 0 and row &lt;= tblSheet.rows then
		tblSheet.row := row;
	else
		tblSheet.row := tblSheet.rows;
	endif;
	
	if criteriaLine &lt;&gt; null then
		criteriaSearchDescription := criteriaLine.getDescriptionString();
	else
		return CMUI_Selector.Mode_Add;
	endif;
	
	if self.cmbArgument.visible then
		argumentStr := self.cmbArgument.text;
	elseif self.lblargList.visible then
		argumentStr := self.lblargList.caption;
	elseif self.txtFromDate.visible then
		argumentStr:= self.txtFromDate.text &amp; " and " &amp; self.txtToDate.text;
	elseif self.txtArgument.visible then
		argumentStr := self.txtArgument.text;
	endif;
	
	controlSearchDescription := self.cmbAttr.text &amp; " " &amp; self.cmbOperator.text &amp; " " &amp; argumentStr;
	
	if  controlSearchDescription &lt;&gt; criteriaSearchDescription then
		return CMUI_Selector.Mode_Update;
	endif;
	
	return CMUI_Selector.Mode_Unchanged;

	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="29b8bc5d-9506-4c93-b67b-78a6ab95914b">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		25 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
//----------------------------------------------------------------------
vars

begin
	if keyCode = CMUI_Key_F11 and
	   (app.isAllowedToInspect() or app.isDevelopmentSystem())then
		if self.lstQuery.listObject &lt;&gt; null then
			self.lstQuery.listObject.inspect();
		endif;
	 endif;
	 
	 inheritMethod(keyCode, shift);
epilog
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadAttrCombo" id="998e5874-3ffa-4743-8256-3fcc0b57694e">
        <source>loadAttrCombo();
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 
// ---------------------------------------------------------------------------
vars
	qProp	: CM_QueryProperty;
	terminology : String;	
	theCargoBOLType : CM_CargoBOLType;
	index : Integer;	//02 Sep 2019	NDL	TFS 45891
begin
	self.cmbAttr.clear();
	self.frmArgument.visible := false;
	self.cmbAttr.sorted := true; // ### TFS BUG 61210 23FEB2024 NAVAB1
	
	theCargoBOLType := app.myRoot.getCargoBOLTypeForId(self.myQDef.mode);

	foreach qProp in self.myQDef.allQueryProperties do			//RocH
		if not qProp.canBeViewed(app.myPassport) then
			continue;
		endif;
		
		//cnwjo3 par 23349
		if not qProp.propertyAvailableInCombo() then
			continue;
		endif;
		
		//19/06/2009 cnwdz2  par20027
		if qProp.propertyName = CM_TrackedItem::mySubTerminal.name then
			if not app.isSubTerminalsLicensed then
				continue;
			endif;
		endif;

		terminology := app.getTerminologyAlternate(theCargoBOLType, null, qProp.niceName , CM_TermExpressionSingular, qProp.niceName) ;	//Roch
		index := self.cmbAttr.addItem(terminology);
		self.cmbAttr.itemObject[index] := qProp;
		self.cmbAttr.itemBackColor[index] := qProp.getPerformanceColour;	//02 Sep 2019	NDL	TFS 45891

	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="9d254df1-edfe-4e5c-876e-324159d3872c">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      29 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	defaultCargoType			: Integer;
	ls							: Boolean;
	criteriaHolder				: CM_QueryCriteriaLineHolder;
	tblSheet					: JadeTableSheet;
begin
	inheritMethod();
	
	self.useEntDefColumns := self.myTerminal.getConfig(UseDefColsInSelectorForm).Boolean; // ### JIRA 14794 01NOV2024 NAVAB1
	
	if self.isBaseFormModal then
		self.clipControls := false;
	endif;
	
	if self.myAssistant = null then
		create self.myAssistant transient;
	endif;
	if self.myAssistant.myTerminal = null then
		self.myAssistant.myTerminal := self.myTerminal;
	endif;
	
	if self.myJRWRepresentationAgent = null then
		create self.myJRWRepresentationAgent transient;
	endif;
	
	self.lstQuery.allMenuRoots.add(app.myRoot.myQueryMenuRoot);
	self.lstQuery.displayTree(true, null);
	
	self.loadSelectorModes();	
	
	
	if self.useForNonPlannedLoad then // AKB2005SEP - CCMS 1370
		self.createQueryForUnplannedLoads(self.myDefaultVoyage);
	else
		if self.myCurrentQuery = null then
			self.resetForMode(null);
		endif;
	endif;
	// if query set before showing this form, select it now
	if self.myCurrentQuery &lt;&gt; null then
		self.lstQuery.selectObject(self.myCurrentQuery);
	endif;
	self.setDefaultDates();	
// cnwdad1 20/12/2005 - PAR #11151.
//	self.lblItemsFound.caption := null;
	self.updateStatus();

	self.doLoadTerminals();
	self.initTblQueryEnt();
	
	//epr TFS 47132 30/12/19
	if self.myCurrentQuery &lt;&gt; null and global.isValidObject(self.myCurrentQuery) then
		self.tblQueryEnt.setValueByName(ETRow_QueryName, self.myCurrentQuery .heading);
		self.tblQueryEnt.setValueByName(ETRow_QueryDescr, self.myCurrentQuery .description);
	endif;
	
	//cnwth2 - because the incorrect order in which events happen when 
	//opening a form I still have to this:
	self.doResize;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadMeasureCombo" id="4ac21d8b-2e8c-45b3-b7ce-281bf4420504">
        <updating/>
        <source>loadMeasureCombo(_property : CM_QueryProperty) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 03/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
//
vars
	measure : CM_MeasurementType;
	default : CM_MeasurementType;

begin
	//self.cmbMeasure.clear;
	if _property = null then
		self.lblMeasure.visible := false;
		self.cmbMeasure.visible := false;
		self.cmbArgument.width := self.grpQryDetails.width - self.cmbArgument.left - 10;
		self.txtArgument.width := self.cmbArgument.width;
		//self.tblArgument.width := self.cmbArgument.width;	//05 Sep 2019	NDL	TFS 45891
		self.frmArgument.width := self.cmbArgument.width;
		self.cmbMeasure.clear;
		return;
	endif;
	if self.queryLineChanged then
		self.cmbMeasure.clear;
	endif;
	
	if CM_QDecimalProperty.hasInstance(_property) or CM_QDecimalMethod.hasInstance(_property) then
		if CM_QDecimalProperty.hasInstance(_property)and _property.CM_QDecimalProperty.myMeasurementType &lt;&gt; null then
			default := _property.CM_QDecimalProperty.myMeasurementType;
		elseif CM_QDecimalMethod.hasInstance(_property) and _property.CM_QDecimalMethod.myMeasurementType &lt;&gt; null then
			default := _property.CM_QDecimalMethod.myMeasurementType;
		elseif self.cmbMeasure.listObject &lt;&gt; null then
			default := self.cmbMeasure.listObject.CM_MeasurementType;
		endif;
	endif;
	if default = null then
		if _property.propertyName.isOneOf(ETRow_Volume, CM_TrackedItem::getMyTotalVolume.name) then
			default := app.getDefaultMeasurementForType(Type_Volume);
		elseif _property.propertyName.isOneOf(ETRow_WeightCargo, ETRow_WeightDeclared, ETRow_WeightTare, ETRow_TotalWeight) then
			default := app.getDefaultMeasurementForType(Type_Weight);
	//	elseif _property.propertyName.isOneOf(ETRow_Length, ETRow_OverLengthFront, "overLengthRear", ETRow_OverWidthLeft, ETRow_OverWidthRight, ETRow_Width) then
	//		default := app.getDefaultMeasurementForType(Type_Linear);
		elseif _property.propertyName.isOneOf(ETRow_Height, ETRow_OverHeight) then
			default := app.getDefaultMeasurementForType(Type_Height);
		elseif _property.propertyName.isOneOf(ETRow_Length, ETRow_OverLengthFront, "overLengthRear") then
			default := app.getDefaultMeasurementForType(Type_Length);
		elseif _property.propertyName.isOneOf(ETRow_OverWidthLeft, ETRow_OverWidthRight, ETRow_Width) then
			default := app.getDefaultMeasurementForType(Type_Width);
		elseif _property.propertyName = CM_TrackedItem::getVentilation.name then
			default := app.getDefaultMeasurementForType(Type_Displacement);
		endif;
	endif;
	
	if default &lt;&gt; null then
		self.lblMeasure.visible := true;
		self.cmbMeasure.visible := true;
		self.cmbArgument.width := self.grpQryDetails.width - self.cmbArgument.left - self.cmbMeasure.width - 10;
		self.txtArgument.width := self.cmbArgument.width;
		//self.tblArgument.width := self.cmbArgument.width;		//05 Sep 2019	NDL	TFS 45891
	
		self.lblMeasure.move(self.cmbArgument.left + self.cmbArgument.width + 5, self.lblArgument.top, self.lblMeasure.width, self.lblMeasure.height);
		self.cmbMeasure.move(self.lblMeasure.left, self.cmbArgument.top, self.cmbMeasure.width, self.cmbMeasure.height);
		if self.cmbMeasure.listCount &gt; null then
			measure := self.cmbMeasure.itemObject[1].CM_MeasurementType;
			if measure.measurementType &lt;&gt; default.measurementType then
				self.cmbMeasure.clear;
			endif;
		endif;
		if self.cmbMeasure.listCount = null then
			foreach measure in app.myRoot.allMeasurementTypesByShortName discreteLock where measure.measurementType = default.measurementType do
				self.cmbMeasure.addItemObject(measure.name, measure);
			endforeach;
		endif;
		self.cmbMeasure.setIndexFromObject(default);
	else
		self.lblMeasure.visible := false;
		self.cmbMeasure.visible := false;
		self.cmbArgument.width := self.grpQryDetails.width - self.cmbArgument.left - 10;
		self.txtArgument.width := self.cmbArgument.width;
		//self.tblArgument.width := self.cmbArgument.width;		//05 Sep 2019	NDL	TFS 45891
		
		self.cmbMeasure.clear;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="CM_QueryProperty"/>
    </JadeMethod>
    <JadeMethod name="loadOperationCombo" id="cd3ab119-34f0-4f18-9220-f22ad0528f7f">
        <updating/>
        <source>loadOperationCombo(_qProp : CM_QueryProperty) updating;
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	qOperator	: CM_QueryOperator;
	idx			: Integer;
begin

	cmbOperator.clear;
	foreach qOperator in _qProp.allAllowedOperators do
		idx := cmbOperator.addItem(qOperator.description);
		cmbOperator.itemObject[idx] := qOperator;
	endforeach;
	
	qOperator := _qProp.getDefaultOperator;
	cmbOperator.listObject := qOperator;
	cmbOperator.text := qOperator.description;

end;</source>
        <Parameter name="_qProp" type="CM_QueryProperty"/>
    </JadeMethod>
    <JadeMethod name="loadReports" id="1c882a5a-1e5d-487c-aa02-dfea2d1ae816">
        <source>loadReports() protected;
// ---------------------------------------------------------------------------
// Created:     03 September 2003	cnwth2
//
// Purpose:     Load up the reports that use the view determined by the particular selector type
//			 
//	35069 
// 22 Dec 2022 navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
// 18/05/2023   navlw1  CR 53902 EUP - VBS MTN - [6] - Selector Query and JRW
// ----------   ----------  --------------------------------------------------
vars
	path		: String;
	reportPaths	: StringArray;
	cmb			: CMUI_ComboBox;
	jrwReport,
	jrwView		: CMUI_JRWEntityRepresentation;
begin
	cmb := self.cmbJRWReport;
	cmb.clear();
	if self.myJRWRepresentationAgent.allJRWViews.isEmpty then
		self.myJRWRepresentationAgent.loadJRWRepresentationObjects();
	endif;
	
	create reportPaths transient;
	//15 May 2014	NDL	Par 34142
	if self.myQDef.mode = CM_QueryDefinition.CashPayment_Query_Mode then
		jrwView := self.myJRWRepresentationAgent.allJRWViews['CM_InvoiceView'];
		reportPaths.add("allCashPayments");
		self.cmbJRWReport.bubbleHelp := 'Send to a JRW report that uses the "CM_InvoiceView"';
	elseif self.myQDef.mode = CM_QueryDefinition.CashReceipt_Query_Mode then
		jrwView := self.myJRWRepresentationAgent.allJRWViews['CM_InvoiceView'];
		reportPaths.add("allCashReceipts");
		self.cmbJRWReport.bubbleHelp := 'Send to a JRW report that uses the "CM_InvoiceView"';
	elseif self.myQDef.mode = CM_QueryDefinition.Invoice_Query_Mode then
		jrwView := self.myJRWRepresentationAgent.allJRWViews['CM_InvoiceView'];
		reportPaths.add("allInvoices");
		reportPaths.add("allReportInvoiceSummaries");	// 35069
		self.cmbJRWReport.bubbleHelp := 'Send to a JRW report that uses the "CM_InvoiceView"';
	elseif self.myQDef.mode = CM_QueryDefinition.InvoiceLine_Query_Mode then
		jrwView := self.myJRWRepresentationAgent.allJRWViews['CM_InvoiceView'];
		reportPaths.add("allInvoiceLines");
		self.cmbJRWReport.bubbleHelp := 'Send to a JRW report that uses the "CM_InvoiceView"';
	//17/02/2023 navmv20 TFS 55626 TASK 55688 - START
	elseif self.myQDef.mode = CM_QueryDefinition.Contract_Query_Mode then
		jrwView := self.myJRWRepresentationAgent.allJRWViews['CM_InvoiceContractView'];	// 20/04/2023	navkc1	CR 55654 Task 55670
		reportPaths.add("allContracts");												// 20/04/2023	navkc1	CR 55654 Task 55670
		self.cmbJRWReport.bubbleHelp := 'Send to a JRW report that uses the "CM_InvoiceView"';	
	//17/02/2023 navmv20 TFS 55626 TASK 55688 - END	
	// Feb 2012 CCMS 1262 transaction enquiry
	elseif self.myQDef.mode &gt;= CM_QueryDefinition.CargoTransaction_Query_Mode and
	   self.myQDef.mode &lt;= CM_QueryDefinition.HMSTransaction_Query_Mode then
		jrwView := self.myJRWRepresentationAgent.allJRWViews['CM_TransactionView'];
		self.cmbJRWReport.bubbleHelp := 'Send to a JRW report that uses the "CM_TransactionView"';
	//Start 22.12.2022 navhl20 #54350[54269]
	elseif self.myQDef.mode = CM_QueryDefinition.WorkOrderTrans_Query_Mode then
		jrwView := self.myJRWRepresentationAgent.allJRWViews['CM_TransactionView'];
		self.cmbJRWReport.bubbleHelp := 'Send to a JRW report that uses the "CM_TransactionView"';
	//End 22.12.2022 navhl20 #54350[54269]
	elseif self.myQDef.mode = CM_QueryDefinition.BOLTransaction_Query_Mode then	//04 Nov 2019	NDL	TFS 47100
		jrwView := self.myJRWRepresentationAgent.allJRWViews['CM_TransactionView'];
		self.cmbJRWReport.bubbleHelp := 'Send to a JRW report that uses the "CM_TransactionView"';
	elseif self.myQDef.mode = CM_QueryDefinition.Location_Activity_Query_Mode then	//13 Apr 2021	NDL	TFS 50906
		self.cmbJRWReport.bubbleHelp :=  app.getErrorString1( NotYetImplemented, "Send to a JRW report  for Location Activities" );
	//	jrwView := self.myJRWRepresentationAgent.allJRWViews['CM_TransactionView'];
	//	self.cmbJRWReport.bubbleHelp := 'Send to a JRW report that uses the "CM_TransactionView"';
	elseif self.myQDef.mode = CM_QueryDefinition.Audit_Query_Mode then		// 6/6/18 MAP TFS37718
		jrwView := self.myJRWRepresentationAgent.allJRWViews['CM_AuditObjectView'];
		reportPaths.add("allAudits");
		self.cmbJRWReport.bubbleHelp := 'Send to a JRW report that uses the "CM_AuditObjectView"';
	elseif self.myQDef.mode = CM_QueryDefinition.VehicleBookingSlot_Query_Mode then	//18 May 2023 navlw1 tfs 53902
		jrwView := self.myJRWRepresentationAgent.allJRWViews['CM_VehicleVisitView'];
		self.cmbJRWReport.bubbleHelp := 'Send to a JRW report that uses the "CM_VehicleVisitView"';
	else
		jrwView := self.myJRWRepresentationAgent.allJRWViews['CM_TrackedItemView'];
		self.cmbJRWReport.bubbleHelp := 'Send to a JRW report that uses the "CM_TrackedItemView"';
	endif;
	if jrwView = null then
		return;
	endif;

	foreach jrwReport in jrwView.allJRWRepresentationEntities do
		// 22/05/2014 cnwjre1	CCMS 2348 Financial Reporting add reportPath to show the appropriate reports
		if reportPaths .isEmpty() then
			cmb.itemObject[cmb.addItem(jrwReport.name)] := jrwReport;
		else
			foreach path in reportPaths do
				if jrwReport.reportsOn(path) then
					cmb.itemObject[cmb.addItem(jrwReport.name)] := jrwReport;
					break;
				endif;
			endforeach;
		endif;
	endforeach;
epilog	
	delete reportPaths;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadSelectorModes" id="0edeb6c7-efbc-4d52-bc8a-91f8b7a12f72">
        <source>loadSelectorModes() protected;
// ---------------------------------------------------------------------------
// Created:     23 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 12/02/2010	cnwcs5	par 22140 - New functions
// 10/05/2023   navlw1  ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
vars
	cmb						: CMUI_ComboBox;
	qDefDict				: CM_QueryDefinitionByModeDict;
	qDef					: CM_QueryDefinition;
	idx,
	keepIdx					: Integer;
begin
	cmb := self.cmbSelectorMode;
	cmb.sorted	:= true;				// cnwrl1 22/01/2009
	cmb.clear();
	
	qDefDict := app.myRoot.allQueryDefinitionObjects;
	
	foreach qDef in qDefDict do
		if qDef.type &lt;&gt; qDef.TrackedItem_Query_Type and	// 12/02/2010 cnwcs5 par 22140
			qDef.type &lt;&gt; qDef.BOL_Query_Type and		// 12/02/2010 cnwcs5 par 22140
			qDef.type &lt;&gt; qDef.Invoicing_Query_Type and	//14 May 2014	NDL	Par 34142
			qDef.type &lt;&gt; qDef.Cash_Query_Type and	//14 May 2014	NDL	Par 34142
			qDef.type &lt;&gt; qDef.Transaction_Query_Type and	//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
			qDef.type &lt;&gt; qDef.Audit_Query_Type and	// TFS 8390
			qDef.type &lt;&gt; qDef.VehicleBookingSlot_Query_Type then // 10/05/2023 navlw1 tfs 53902
			continue;									// 12/02/2010 cnwcs5 par 22140
		endif;											// 12/02/2010 cnwcs5 par 22140		
		idx := cmb.addItem(qDef.modeDescription);
		cmb.itemObject[idx] := qDef;
	endforeach;
	
	cmb.listObject := self.myQDef;	
	
	//epr TFS 47132 30/12/19
	if self.myCurrentQuery = null then
		cmb.click(cmb); // TFS 47297
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
