    <JadeMethod name="getAftLocnDefn" id="22f4dcd6-79b7-4ef3-bf49-30a6c6dbbc9f">
        <source>getAftLocnDefn(): CM_ROROLocnDefn;
/*
Purpose:			
Date		Who		Reason
08 September 2011	cnwab1	Initial creation
*/

vars
	myLocnDefn : CM_ROROLocnDefn;
begin
	myLocnDefn := self.myROROController.getDefn().CM_ROROLocnDefn;
	
	if myLocnDefn &lt;&gt; null then
