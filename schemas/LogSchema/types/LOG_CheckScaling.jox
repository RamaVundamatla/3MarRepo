    <JadeMethod name="setFilterDefaults" id="903a1ae7-c041-4b2a-8ea9-43a3918ce602">
        <lockReceiver/>
        <updating/>
        <source>setFilterDefaults() updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	fromDate,
	toDate				: Date;
begin
	self.filtBatchNo := null;
	self.filtUserCode := Any_String;
	//first day of current month up until today
	app.getDatesThisMonth(fromDate, toDate);
	self.filtFromDate := fromDate;
	self.filtToDate := self.systemToLocalTime(app.actualTimeServer()).date;	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
//	self.txtFiltFrom.setDate(fromDate);
//	self.txtFiltTo.setDate(toDate);
	
	//PAR12047 cnwsh3 07/07/2006 UHE14202 for Jade Edit Mask Literals cnwsh3  
	//Need to pass date values to Date based JadeEditMasks, not strings.
	
	//self.tblSearch.setValueByName(ETRow_FiltFromDate, fromDate.String);
	//self.tblSearch.setValueByName(ETRow_FiltToDate, toDate.String);
	
	self.tblSearch.setValueByName(ETRow_FiltToDate, self.filtToDate);
	self.tblSearch.setValueByName(ETRow_FiltFromDate, self.filtFromDate);

end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterValues" id="0918992a-f201-461f-b93c-af58e7cb21ab">
        <lockReceiver/>
        <updating/>
        <source>setFilterValues() updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	userCode		: String;
	toDate,
	fromDate			: Date;
	time			: Time;
begin
//	fromDate := self.tblSearch.getValueByName(ETRow_FiltFromDate).Date;
	fromDate := self.tblSearch.getValueAsDate(ETRow_FiltFromDate);
	
	if fromDate.isValid then
		self.filtFromDate := fromDate;
	else
		self.filtFromDate := null;
	endif;
	
//	toDate := self.tblSearch.getValueByName(ETRow_FiltToDate).Date;
	toDate := self.tblSearch.getValueAsDate(ETRow_FiltToDate);
	
	if toDate.isValid then
		self.filtToDate:= toDate;
	else
		self.filtToDate:= null;
	endif;
	
	userCode := self.tblSearch.getValueByName(ETRow_UserCode).String;
	
	if userCode &lt;&gt; Any_String then
		self.filtUserCode := userCode;
	else
		self.filtUserCode := null;
	endif;
	
	self.filtBatchNo 	:= self.tblSearch.getValueByName(ETRow_BatchNo).Integer;


end;</source>
    </JadeMethod>
