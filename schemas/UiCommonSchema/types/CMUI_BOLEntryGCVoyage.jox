    <JadeMethod name="changeNumberOfItems" id="75d3bfa4-46de-43f3-882d-7b4f994669d9">
        <source>changeNumberOfItems();
//-----------------------------------------------------------------------
//	Created:	21 April 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	newNumberOfItems : Integer;
begin

	if self.txtNoOfEntries.text &lt;&gt; null then
		newNumberOfItems := self.txtNoOfEntries.text.Integer;
	endif;
	
	if newNumberOfItems &gt; self.frmRowScroll.getRowCount then
		while newNumberOfItems &lt;&gt; self.frmRowScroll.getRowCount do
			self.addScrollRow(null);
		endwhile;
	elseif  newNumberOfItems &lt; self.frmRowScroll.getRowCount then
		if app.msgBox ("You have selected fewer items than already exist. Click 'Yes' to delete items " &amp; (newNumberOfItems+1).String &amp;
						" to " &amp; self.frmRowScroll.getRowCount.String &amp;". Click 'No' to cancel", "Warning", MsgBox_Yes_No) = MsgBox_Return_Yes then
			while newNumberOfItems &lt;&gt; self.frmRowScroll.getRowCount do
				self.frmRowScroll.unuseCurrentRow(self.frmRowScroll.getRowCount);
			endwhile;
		endif;
	endif;
	
	self.txtNoOfEntries.text := self.frmRowScroll.getRowCount().String;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clearControls" id="f8504fbf-ac56-42d9-ba00-cf4626295bd9">
