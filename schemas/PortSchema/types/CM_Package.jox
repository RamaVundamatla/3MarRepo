    <JadeMethod name="createPackageHistory" id="a5cee85c-865d-4517-ac23-9e346f878090">
        <source>createPackageHistory(_allHdrs : CM_FileDataStorageHdrSet; _allEventData : CM_EventDataByTypeDict);

// Created by cnwdvb1 on 27 June 2006

vars

	history : CM_PackageHistoryHdr;

begin

	// Nothing to do.
	if _allHdrs.isEmpty() then
		return;
	endif;
	
	create history persistent;
	self.allHistory.add(history);
	history.addHistoryFromHdrs(_allHdrs, _allEventData);
	history.addEmailHistory(self);

end;</source>
        <Parameter name="_allHdrs" type="CM_FileDataStorageHdrSet"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="4f983fde-2e5f-4516-96e7-504ae69e51ac">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

// Created by cnwdvb1 on 26 June 2006

vars

begin

	if _attrName = ETRow_Type then
		return self.getTypeDescription();
	else
		return inheritMethod(_attrName, _short);
	endif;
	

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="90a6ff6c-f256-4877-a076-9d7590100c8e">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);

// Created by cnwdvb1 on 26 June 2006

vars

	block 	: CM_DataContainerBlock;
	str		: String;
begin
	inheritMethod(_dataContainer);
		

	block := _dataContainer.addNewBlock;
	block.addNewItem("Code", DC_Label, 1, self);
	block.addNewItem(self.code, DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Description", DC_Label, 1, self);
	block.addNewItem(self.description, DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Type", DC_Label, 1, self);
	block.addNewItem(self.getTypeDescription(), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Reports", DC_Label, 1, self);
	block.addNewItem(self.allReportTemplates.size.String, DC_Data, 1, self);
	
	str := self.myEmailTemplate.getAllToAddressesOrNames(false);
	if str &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Email To", DC_Label, 1, self);
		block.addNewItem(str, DC_Data, 1, self);
	endif;	
		
	str := self.myEmailTemplate.getAllBCCAddressesOrNames(false);
	if str &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Email BCC", DC_Label, 1, self);
		block.addNewItem(str, DC_Data, 1, self);
	endif;
	
	str := self.myEmailTemplate.getAllCCAddressesOrNames(false);
	if str &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Email CC", DC_Label, 1, self);
		block.addNewItem(str, DC_Data, 1, self);
	endif;

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getTypeDescription" id="f2a2c343-1784-4c39-ba51-4437df2cf0ac">
        <source>getTypeDescription() : String;

// Created by cnwdvb1 on 26 June 2006
// 09 Mar 2020 cnwma1 ChangeRequest 48524: CPL - Credit Invoice Details for Print
vars

begin

	if self.type = PackageSailing then
		return app.getErrorString(Sailing_package); // 'Sailing Package';
	elseif self.type = PackageReports then
		return app.getErrorString(Report_package); // 'Report Package';
	elseif self.type = PackageInvoicePost then
		//return app.getErrorString(Invoice_posted); // ''Invoice Posted';  //09/03/2020 cnwma1 TFS #48524
		return app.getErrorString(Invoice_package);                         //09/03/2020 cnwma1 TFS #48524
	elseif self.type = PackageVVR then
		return app.getErrorString(Vehicle_visit_report_package);	        // 1/3/18 MAP TFS37340
	else
		return app.getErrorString(Unknown); // 'Unknown';
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
