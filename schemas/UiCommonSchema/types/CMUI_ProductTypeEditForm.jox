    <JadeMethod name="showEditCodesForm" id="0c37f99b-e646-4d5f-af99-fffd6c9c495e">
        <updating/>
        <source>showEditCodesForm() updating, protected;
/* ---------------------------------------------------------------------------
Created:	29 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	theForm		: CMUI_CodeMaintForm;

begin

	theForm := app.loadForm(CMUI_CodeMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_CodeMaintForm;
	
	if theForm = null then
		return;
	endif;

//	this is set so after codes are edited and the user trys to cancel out of this 
//	screen without saving then message can be raised to user to warn them. 
	//self.isCodesEdited := true;
		
	theForm.myCargoType := self.myCargoType;
	//theForm.productCode := self.myProxyObject.CM_Product.code;
	theForm.myProductAttr := self.myCurrentProdAttr;
	//theForm.myParentForm	:= self;
	theForm.setFormParent( self );
	theForm.myForm			:= self;
	theForm.myFormIsCloning := self.myFormIsCloning;
	theForm.myProduct := self.myProductType;
	theForm.productCode := self.myProductType.code;
	
	self.isCodesPressedSave := false;
	
	theForm.showModal();
	
	if self.isCodesPressedSave then
		self.setCmbCode();
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9c04be48-f6ca-4cb3-8ba5-aae4f5d39b04">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012010, locale);
	lblCode.translateCaption(Xlat_0012011, locale);
	lblDisplayName.translateCaption(Xlat_0012012, locale);
	lblDisplayValue.translateCaption(Xlat_0012013, locale);
	lblIsViewable.translateCaption(Xlat_0012014, locale);
	lblMeasureType.translateCaption(Xlat_0018803, locale);
	lblMultipplier.translateCaption(Xlat_0012015, locale);
	lblRange.translateCaption(Xlat_0012016, locale);
	lblSystemName.translateCaption(Xlat_0012017, locale);
	lblValidation.translateCaption(Xlat_0012018, locale);
	lblValue.translateCaption(Xlat_0012019, locale);
end;</source>
    </JadeMethod>
