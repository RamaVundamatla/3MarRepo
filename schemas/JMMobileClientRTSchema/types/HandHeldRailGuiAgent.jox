    <JadeMethod name="getNextRakePosition" id="dfe42ec4-ab4d-430d-bdb4-d65a2b738a75">
        <source>getNextRakePosition(_rake : CM_RailLine) : Integer;
// ---------------------------------------------------------------------------
// Created:     13 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _rake = null then
		return 0;
	endif;
	
	return _rake.getNextFreePosition();
epilog

end;</source>
        <Parameter name="_rake" type="MobileHandHeldThin::CM_RailLine"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
