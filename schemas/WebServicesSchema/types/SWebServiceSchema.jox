    <JadeMethod name="setMyCurrentMachine" id="501e50ea-7707-4c16-83e6-fe9ac4cc8cd9">
        <updating/>
        <source>setMyCurrentMachine(_machine : CM_Machine input ) updating;
/*

Date		Who		Reason
19 May 2017	cnwer1	Initial creation TFS 995

*/

vars

begin
	self.myCurrentMachine:=_machine;
	self.myCurrentTerminal:=_machine.getMyTerminal();
	self.myUser:=_machine.user;
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentTerminal" id="2f9d67c2-6cf6-4029-8a0d-11026cb97fc2">
        <updating/>
        <source>setMyCurrentTerminal(value: CM_Terminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	if myCurrentTerminal &lt;&gt; value then 
		myCurrentTerminal := value;
	endif;


epilog

end;</source>
        <Parameter name="value" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setMyUser" id="8ced2d87-9eb3-4f65-b74c-07a6a914df08">
