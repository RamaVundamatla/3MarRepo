    <JadeMethod name="setupThumbnailDetails" id="caa9f72f-9d3a-4657-bc3d-f416301c2dc0">
        <source>setupThumbnailDetails();

vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_ContRangeTbl);
	//theForm.zAddColumn('ContRange Lower', 'lower', Table.InputType_None, 30);
	//theForm.zAddColumn('Upper', 'upper', Table.InputType_None, 70);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Lower, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_ContRangeMaint);
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;

	theForm.myAssistant.comboBoxISOType(theForm.cmbISOType, null);//self.myIntFaceConfig.defISOType);
	theForm.myAssistant.comboBoxCoolingType(theForm.tblInput1, ETRow_CoolingType, null);
	theForm.myAssistant.comboBoxVoltageType(theForm.tblInput1, ETRow_VoltageType, null);
		
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="6ac73526-6230-4c7c-9119-b2427204dee5">
        <updating/>
        <source>showThumbnail(pContRange : CM_ContRange) updating;

vars

	theForm : SOP_TableMaintForm;
	port:CM_Port;
	first:Boolean;
	list:String;
	isoType	:	CM_ISOType;	
begin
  
  theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Lower, pContRange.lower);
	theForm.tblInput1.setValueByName(ETRow_Upper, pContRange.upper);
	theForm.tblInput1.setValueByName(ETRow_CoolingType, app.coolingTypeENumToString(pContRange.coolingType, false));
	theForm.tblInput1.setValueByName(ETRow_VoltageType, app.voltageTypeENumToString(pContRange.voltageType, false));		
	theForm.tblInput1.setValueByName(ETRow_HeavyLift, pContRange.heavyLift);
	theForm.tblInput1.setValueByName(ETRow_IsoType, pContRange.isoType);

	//18 Mar 2014	NDL	Par 33268
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_CubicMetres,  pContRange.cubicMetres, self.volumeType );
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_ExtHeight,  pContRange.extHeight, self.linearType );
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_ExtLength,  pContRange.extLength, self.linearType );
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_ExtWidth,  pContRange.extWidth, self.linearType );
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_IntHeight,  pContRange.intHeight, self.linearType );
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_IntLength,  pContRange.intLength, self.linearType );
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_IntWidth,  pContRange.intWidth, self.linearType );
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxKilos,  pContRange.maxKilos, self.weightType );
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_TareKilos,  pContRange.tareKilos, self.weightType );
	
	isoType := app.myRoot.allISOTypes[pContRange.isoType];
	if isoType &lt;&gt; null then
		theForm.myAssistant.comboBoxISOType(theForm.cmbISOType, isoType);
	endif;
end;</source>
        <Parameter name="pContRange" type="CM_ContRange"/>
    </JadeMethod>
</Class>
