    <JadeMethod name="utlDeleteDataAccessController" id="3eeb48fc-1562-4b65-b3c3-70b95532d464">
        <source>utlDeleteDataAccessController(_dac : CM_DataAccessController io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();

	if not self.exclusiveLockObjectToDelete(_dac) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_dac);
	endif;

	if _passport.noErrors then
		_dac.erase(NORMAL_ERASE);	//A superclass delete is ok here, all we are doing is erasing.
	endif;

epilog
	return;
	
end;</source>
        <Parameter name="_dac" type="CM_DataAccessController" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
