<Class name="CM_RemoteDisassemblyDtl">
    <JadeMethod name="loadRemoteTable" id="04713a16-48db-4b44-84ea-4004525e7f9e">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

// cnwdvb1 25 November 2002 

begin

	//PAR 23972 10/05/2010
	inheritMethod(_table);
	_table.setColumnHeadings('Attribute', 'Value');
	self.addRemoteRow(_table, 'New Area', self.newArea, null);
	self.addRemoteRow(_table, 'New Location', self.newLcn, null);
	self.addRemoteRow(_table, 'New ID', self.newId, null);
	self.addRemoteRow(_table, 'New Grade', self.newGrade, null);
	self.addRemoteRow(_table, 'New Type', self.newType, null);
	self.addRemoteRow(_table, 'New Treatment', self.newTreatment, null);
	self.addRemoteRow(_table, 'New Length', self.newLength, null);
	self.addRemoteRow(_table, 'New SED Max', self.newSedMax.String, null);
	self.addRemoteRow(_table, 'New SED Min', self.newSedMin.String, null);
	self.addRemoteRow(_table, 'New Weight', self.weight.String, null);

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
