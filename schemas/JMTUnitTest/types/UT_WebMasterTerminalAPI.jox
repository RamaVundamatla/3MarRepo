	self.assertTrueMsg(booking.consigneeCode = UTConsigneeCode2, "Field: " &amp; CM_BookingRef::consigneeCode.name &amp; " | Expected: '" &amp; UTConsigneeCode2 &amp; "' | Actual: '" &amp; booking.consigneeCode &amp; "'");
	self.assertTrueMsg(booking.myConsignee &lt;&gt; null, "Field: " &amp; CM_BookingRef::myConsignee.name &amp; " | Expected: 'not null' | Actual: 'null'");
	self.assertTrueMsg(booking.myConsignee.code = UTConsigneeCode2, "Field: " &amp; CM_BookingRef::myConsignee.name &amp; " | Expected: '" &amp; UTConsigneeCode2 &amp; "' | Actual: '" &amp; booking.myConsignee.code &amp; "'");
	self.assertTrueMsg(booking.operatorCode = UTOperatorIdOrig2, "Field: " &amp; CM_BookingRef::operatorCode.name &amp; " | Expected: '" &amp; UTOperatorIdOrig2 &amp; "' | Actual: '" &amp; booking.operatorCode &amp; "'");
	self.assertTrueMsg(booking.myOperator &lt;&gt; null, "Field: " &amp; CM_BookingRef::myOperator.name &amp; " | Expected: 'not null' | Actual: 'null'");
	self.assertTrueMsg(booking.myOperator.code = UTOperatorIdOrig2, "Field: " &amp; CM_BookingRef::myOperator.name &amp; " | Expected: '" &amp; UTOperatorIdOrig2 &amp; "' | Actual: '" &amp; booking.myOperator.code &amp; "'");
	self.assertTrueMsg(booking.voyageCode = UTVoyageCodeOrig2, "Field: " &amp; CM_BookingRef::voyageCode.name &amp; " | Expected: '" &amp; UTVoyageCodeOrig2 &amp; "' | Actual: '" &amp; booking.voyageCode &amp; "'");
	self.assertTrueMsg(booking.myVoyage &lt;&gt; null, "Field: " &amp; CM_BookingRef::myVoyage.name &amp; " | Expected: 'not null' | Actual: 'null'");
	self.assertTrueMsg(booking.myVoyage.code = UTVoyageCodeOrig2, "Field: " &amp; CM_BookingRef::myVoyage.name &amp; " | Expected: '" &amp; UTVoyageCodeOrig2 &amp; "' | Actual: '" &amp; booking.myVoyage.code &amp; "'");
	self.assertTrueMsg(booking.bookingRefRemarks = UTRemarks2, "Field: " &amp; CM_BookingRef::remarks.name &amp; " | Expected: '" &amp; UTRemarks2 &amp; "' | Actual: '" &amp; booking.bookingRefRemarks &amp; "'");
	self.assertTrueMsg(booking.shippingReference = UTShippingReference2, "Field: " &amp; CM_BookingRef::shippingReference.name &amp; " | Expected: '" &amp; UTShippingReference2 &amp; "' | Actual: '" &amp; booking.shippingReference &amp; "'");
	self.assertTrueMsg(booking.noEmptiesOut = false, "Field: " &amp; CM_BookingRef::noEmptiesOut.name &amp; " | Expected: '" &amp; false.String &amp; "' | Actual: '" &amp; booking.noEmptiesOut.asStringJMT &amp; "'");
	self.assertTrueMsg(booking.status = UTStatus2, "Field: " &amp; CM_BookingRef::status.name &amp; " | Expected: '" &amp; UTStatus2.asStringJMT &amp; "' | Actual: '" &amp; booking.status.asStringJMT &amp; "'");
	self.assertTrueMsg(booking.receiveAsTranship = UTReceiveAsTranship2, "Field: " &amp; CM_BookingRef::receiveAsTranship.name &amp; " | Expected: '" &amp; UTReceiveAsTranship2.asStringJMT &amp; "' | Actual: '" &amp; booking.receiveAsTranship.asStringJMT &amp; "'");
	self.assertTrueMsg(booking.myTranshipVoyage &lt;&gt; null, "Field: " &amp; CM_BookingRef::myTranshipVoyage.name &amp; " | Expected: 'not null' | Actual: 'null'");
	self.assertTrueMsg(booking.myTranshipVoyage.code = UTTransVoyageCode2, "Field: " &amp; CM_BookingRef::myTranshipVoyage.name &amp; " | Expected: '" &amp; UTTransVoyageCode2 &amp; "' | Actual: '" &amp; booking.myTranshipVoyage.code &amp; "'");
	self.assertTrueMsg(booking.packAs = app.bookingPackAsStringToEnumb(PackAs), "Field: " &amp; CM_BookingRef::packAs.name &amp; " | Expected: '" &amp; app.bookingPackAsStringToEnumb(PackAs).asStringJMT &amp; "' | Actual: '" &amp; booking.packAs.asStringJMT &amp; "'");
	self.assertTrueMsg(booking.customsAgent = UTCustomsAgent2, "Field: " &amp; CM_BookingRef::customsAgent.name &amp; " | Expected: '" &amp; UTCustomsAgent2 &amp; "' | Actual: '" &amp; booking.customsAgent &amp; "'");
	self.assertTrueMsg(booking.directDelivery = UTDirectDelivery2, "Field: " &amp; CM_BookingRef::directDelivery.name &amp; " | Expected: '" &amp; UTDirectDelivery2.asStringJMT &amp; "' | Actual: '" &amp; booking.directDelivery.asStringJMT &amp; "'");
	self.assertTrueMsg(booking.myFreightForwarder &lt;&gt; null, "Field: " &amp; CM_BookingRef::myFreightForwarder.name &amp; " | Expected: 'not null' | Actual: 'null'");
	self.assertTrueMsg(booking.myFreightForwarder.code = UTFreightForwarderCode2, "Field: " &amp; CM_BookingRef::myFreightForwarder.name &amp; " | Expected: '" &amp; UTFreightForwarderCode2 &amp; "' | Actual: '" &amp; booking.myFreightForwarder.code &amp; "'");
	self.assertTrueMsg(booking.myCarrier &lt;&gt; null, "Field: " &amp; CM_BookingRef::myCarrier.name &amp; " | Expected: 'not null' | Actual: 'null'");
	self.assertTrueMsg(booking.myCarrier.code = UTCarrierCode2, "Field: " &amp; CM_BookingRef::myCarrier.name &amp; " | Expected: '" &amp; UTCarrierCode2 &amp; "' | Actual: '" &amp; booking.myCarrier.code &amp; "'");
	self.assertTrueMsg(booking.myStevedore &lt;&gt; null, "Field: " &amp; CM_BookingRef::myStevedore.name &amp; " | Expected: 'not null' | Actual: 'null'");
	self.assertTrueMsg(booking.myStevedore.code = UTStevedoreCode2, "Field: " &amp; CM_BookingRef::myStevedore.name &amp; " | Expected: '" &amp; UTStevedoreCode2 &amp; "' | Actual: '" &amp; booking.myStevedore.code &amp; "'");
	
	contCargoType := app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation(UTCargoType21);
	
	if contCargoType &lt;&gt; null then
		contCargoTypeId := contCargoType.id;
	endif;
	
	//Assert Booking Items
	foreach bookingItem in booking.allBookingRefItems do
		if bookingItem.id = UTCargoId21 then
			self.assertTrueMsg(bookingItem.cargoType = contCargoTypeId, "Field: " &amp; CM_BookingRefItem::id.name &amp; " | Expected: '" &amp; contCargoTypeId.String &amp; "' | Actual: '" &amp; booking.cargoType.String &amp; "'");
			self.assertTrueMsg(booking.myCargoType &lt;&gt; null, "Field: " &amp; CM_BookingRefItem::myCargoType.name &amp; " | Expected: 'not null' | Actual: 'null'");
			self.assertTrueMsg(bookingItem.myCargoType.id = contCargoTypeId, "Field: " &amp; CM_BookingRefItem::myCargoType.name &amp; " | Expected: '" &amp; contCargoTypeId.String &amp; "' | Actual: '" &amp; booking.myCargoType.id.String &amp; "'");
			
			self.assertTrueMsg(bookingItem.commodity = UTCommodityCode21, "Field: " &amp; CM_BookingRefItem::commodity.name &amp; " | Expected: '" &amp; UTCommodityCode21 &amp; "' | Actual: '" &amp; bookingItem.commodity &amp; "'");
			self.assertTrueMsg(bookingItem.isoType = UTIsoType21, "Field: " &amp; CM_BookingRefItem::isoType.name &amp; " | Expected: '" &amp; UTIsoType21 &amp; "' | Actual: '" &amp; bookingItem.isoType &amp; "'");
			
			self.assertTrueMsg(bookingItem.myISOType &lt;&gt; null, "Field: " &amp; CM_BookingRefItem::myISOType.name &amp; " | Expected: 'not null' | Actual: 'null'");
			self.assertTrueMsg(bookingItem.myISOType.code = UTIsoType21, "Field: " &amp; CM_BookingRefItem::myISOType.name &amp; " | Expected: '" &amp; UTIsoType21 &amp; "' | Actual: '" &amp; bookingItem.myISOType.code &amp; "'");
			
			self.assertTrueMsg(bookingItem.weight = UTWeight21, "Field: " &amp; CM_BookingRefItem::weight.name &amp; " | Expected: '" &amp; UTWeight21.String &amp; "' | Actual: '" &amp; bookingItem.weight.String &amp; "'");
			self.assertTrueMsg(bookingItem.description = UTDescription21, "Field: " &amp; CM_BookingRefItem::description.name &amp; " | Expected: '" &amp; UTDescription21 &amp; "' | Actual: '" &amp; bookingItem.description &amp; "'");
			self.assertTrueMsg(bookingItem.purchaseOrder = UTPurchaseOrder21, "Field: " &amp; CM_BookingRefItem::purchaseOrder.name &amp; " | Expected: '" &amp; UTPurchaseOrder21 &amp; "' | Actual: '" &amp; bookingItem.purchaseOrder &amp; "'");
			self.assertTrueMsg(bookingItem.remarks = UTRemarks21, "Field: " &amp; CM_BookingRefItem::remarks.name &amp; " | Expected: '" &amp; UTRemarks21 &amp; "' | Actual: '" &amp; bookingItem.remarks &amp; "'");
			self.assertTrueMsg(bookingItem.serviceOrder = UTServiceOrder21, "Field: " &amp; CM_BookingRefItem::serviceOrder.name &amp; " | Expected: '" &amp; UTServiceOrder21 &amp; "' | Actual: '" &amp; bookingItem.serviceOrder &amp; "'");
			
			self.assertTrueMsg(bookingItem.mySpecialStow &lt;&gt; null, "Field: " &amp; CM_BookingRefItem::mySpecialStow.name &amp; " | Expected: 'not null' | Actual: 'null'");
			self.assertTrueMsg(bookingItem.mySpecialStow.code = UTSpecialStow21, "Field: " &amp; CM_BookingRefItem::mySpecialStow.name &amp; " | Expected: '" &amp; UTSpecialStow21 &amp; "' | Actual: '" &amp; bookingItem.mySpecialStow.code &amp; "'");
			
			self.assertTrueMsg(bookingItem.allTIHazards.isNotEmpty, "Field: " &amp; CM_BookingRefItem::allTIHazards.name &amp; " | Expected: 'not empty' | Actual: 'empty'");
			self.assertTrueMsg(booking.quantity = UTCargoQuantity21, "Field: " &amp; CM_BookingRef::quantity.name &amp; " | Expected: '" &amp; UTCargoQuantity21.String &amp; "' | Actual: '" &amp; booking.quantity.asStringJMT &amp; "'"); //TFS 63028
			//Extend the above to check all ti hazards on booking item
			
		elseif bookingItem.id = UTCargoId22 then
		
		endif;
	endforeach;
	
	//Assert Release Request
	
	//Assert Reserve Selection
	
	//Test for errors:
	expectFailure := true;
	
	// Unauthorized - Username / Password not OK
	loginJson := BadLogin;
	params := null;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "401 Unauthorized - Username / Password not OK");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBooking.name, loginJson, incomingJsonString, params, expectFailure);
	
epilog
	delete pxyBooking;
	delete utHelperTerminal;
	app.writeLog("Changing MaxLiftWeightWarnOnly Terminal Config to false", LogINFO);
	app.writeLog("Changing IsSubTerminalsOn Terminal Config to true", LogINFO);
	self.setTerminalConfig(MaxLiftWeightWarnOnly, false);
	self.setTerminalConfig(IsSubTerminalsOn, true);
	
end;</source>
