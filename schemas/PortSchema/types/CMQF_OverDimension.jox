<Class name="CMQF_OverDimension" id="eb45612d-5c31-4519-9df5-924ba3f38502">
    <superclass name="CMQF_TrackedItem"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="0d9e9221-e3ca-4899-a65c-2c2fe16343df">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		29 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	ti				: CM_TrackedItem;
	terminal		: CM_Terminal;
	breakOut		: Boolean;
begin
		//need a voyage
		//search all onsite (normal)  colls
	foreach terminal in self.allTerminals do
		foreach ti in terminal.allOnsiteTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
//			if breakOut then
//				return;
//			endif;
		endforeach;
		
		//search onship ti's for selected voyage
		//TI_STATE_ONSHIP
		if self.getMyVoyage &lt;&gt; null then
			foreach ti in self.getMyVoyage.allOnshipTIsByIdCargoType discreteLock do
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//				if self.includesObject(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
					endif;
				endif;
				
//				if breakOut then
//					return;
//				endif;
			endforeach;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="85408c6d-303b-4645-b79b-988834e985dc">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		29 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars
	tmpState	: Integer;

begin
	if	(not _ti.isKindOf(CM_Log)) 
		and (not _ti.isKindOf(CM_Machinery)) 
		and _ti.isOverDimensions then
			//exclude logs, machines for this report

			tmpState := _ti.state;
			if tmpState = TI_STATE_ONSHIP or tmpState = TI_STATE_OFFLOADED then

				return inheritMethod(_ti, _passport, _breakOut);
			//elseif	tmpState = TI_STATE_NORMAL and _ti.isExport then							// PAR #25021
			elseif	tmpState = TI_STATE_NORMAL and (_ti.isExport or _ti.isTranshipOutbound) then	// PAR #25021

				return inheritMethod(_ti, _passport, _breakOut);
			endif; 

	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
