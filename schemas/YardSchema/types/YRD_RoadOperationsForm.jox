		endif;
		int := lstICAreas_Sel.addItem(area.getDisplayName(true));			//11-06-2025 MTN-35032
		lstICAreas_Sel.itemObject[int] := area;								//11-06-2025 MTN-35032						
		count += 1;
    endwhile;
	lstICAreas_Avail.clear;
epilog

