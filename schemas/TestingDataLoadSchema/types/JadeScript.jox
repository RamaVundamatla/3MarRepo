    <JadeMethod name="setColourForColourField" id="9a9751af-3066-4fec-b119-6a05a37e45f7">
        <source>setColourForColourField();


/*

	classes:
	CM_Carriers
	CM_ISOType
	CM_ISOTypeGroup
	CM_EventTypes
	CM_IMEXStatus
	CM_JobType
	CM_Port
	CM_Operator
	CM_WeightRange




*/

vars

	carrier					: CM_Carrier;
	commodity				: CM_Commodity;
	isoType					: CM_ISOType;
	isoTypeGroup			: CM_ISOTypeGroup;
	eventType				: CM_EventType;
	imexStatus				: CM_IMEXStatus;
	jobType					: CM_JobType;
	operator				: CM_Operator;
	port					: CM_Port;
	weightRange				: CM_WeightRange;
	
	colourInt				: Integer;

begin
	
	beginTransaction;
	foreach carrier in CM_Carrier.instances discreteLock do
	
		if carrier.colour = 0 then
		
			colourInt := app.randomRange(0, 16777215);
			carrier.setPropertyValue("colour", colourInt);
		
		endif;
	
	endforeach;
	commitTransaction;
	
	beginTransaction;
	foreach commodity in CM_Commodity.instances discreteLock do
	
		if commodity.colour = 0 then
		
