    <JadeMethod name="doRefresh" id="98dcd0b2-957c-447a-9d3c-d3a9e7455888">
        <updating/>
        <source>doRefresh() updating, protected;
/*

Date		    	Who			Reason
09 November 2010	cnwas3	  	Initial creation
8 February 2022 	navcs2		TFS 52784 Added Boolean flags to method signature to be able to select certain rows in a table

*/

vars

begin
	inheritMethod();
	self.statusLine.caption := null;
	self.doShowCountResults(self.monthsSpan,self.referenceTimeStamp,self.cargoTypes, self.isContainerCount, self.isContainerTeu, self.isGenTeu, self.isGenWeight, self.isGenCount, self.isGenVolume);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowCountResults" id="67598e45-6d28-4722-ba8c-f3ac57f67577">
        <updating/>
        <source>doShowCountResults( _months : Integer; _initMonth : Date; _cargoTypes : CM_CargoTypesByIdDict; _containterCount ,_containterTeu, _teu, _weight, _count,_volume: Boolean) updating;
/*

Date		    	Who			Reason
14 September 2010	cnwas3	  	Initial creation
8 February 2022 	navcs2		TFS 52784 Added Boolean flags to method signature to be able to select certain rows in a table

*/

vars

begin
	self.monthsSpan := _months;
	if self.monthsSpan = 0 or _cargoTypes.size() = 0 then
		self.doShowParametersForm();
		return;
	endif;
	
	self.referenceTimeStamp := _initMonth;
	
	if self.monthsSpan = 1 and self.isChildForm then
		self.caption := app.getErrorString(Cargo_counter) &amp; " " &amp; self.myTerminal.code &amp; " - " &amp; self.referenceTimeStamp.monthName() &amp; " " &amp; self.referenceTimeStamp.year().asStringJMT &amp; " " &amp; app.getErrorString(Daily_breakdown);
	else
		self.caption := app.getErrorString(Cargo_counter) &amp; " " &amp; self.myTerminal.code;
	endif;	
		
	self.setCargoTypes(_cargoTypes);	
	//epr par 36624 16/4/15
	self.getKPICounter();	
	self.setColumnHeadings(self.monthsSpan,self.referenceTimeStamp.cnEcGetFirstDayOfMonth());
	self.isContainerCount := _containterCount;
	self.isContainerTeu := _containterTeu;
	self.isGenTeu := _teu;
	self.isGenWeight := _weight;
	self.isGenCount := _count;
	self.isGenVolume := _volume;
	
	self.setRowHeadings(_containterCount ,_containterTeu, _teu, _weight, _count,_volume);
	self.populateTable();		
	self.statusLine.caption := "";
	
epilog

end;</source>
        <Parameter name="_months" type="Integer"/>
        <Parameter name="_initMonth" type="Date"/>
        <Parameter name="_cargoTypes" type="CM_CargoTypesByIdDict"/>
        <Parameter name="_containterCount" type="Boolean"/>
        <Parameter name="_containterTeu" type="Boolean"/>
        <Parameter name="_teu" type="Boolean"/>
        <Parameter name="_weight" type="Boolean"/>
        <Parameter name="_count" type="Boolean"/>
        <Parameter name="_volume" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowMonthDetailsForm" id="9e49b260-fa2d-4104-9b0b-47cf5d6c3509">
        <updating/>
        <source>doShowMonthDetailsForm(table : Table input) updating;
/*

Date		    Who			Reason
14 September 2010	cnwas3	  Initial creation

*/

vars
	theTI : CM_TrackedItem;
	theRow : Integer;
	monthCount : Integer;
begin
	self.statusLine.caption := null;
	if self.monthsSpan &lt; 1 then
		return;
	elseif self.monthsSpan = 1 and self.isChildForm then
		self.doCargoEnquiry(false);
		return;
	endif;
	
	if table.column &lt;= table.fixedColumns or table.column = table.columns then
		return;
	endif;
			
	self.myAssistant.SHP_Assistant.showKPICargoCountForm(1,self.referenceTimeStamp.addMonths(table.column - 2),self.cargoTypes,self.xmlColourAltRow,self.xmlColourCargoType,self.xmlColourRowColour,self.xmlColourTotals);	
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
