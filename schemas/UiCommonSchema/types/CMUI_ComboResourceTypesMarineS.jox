<GUIClass name="CMUI_ComboResourceTypesMarineS" id="b919f957-c73c-414f-ab29-334723cde226">
    <superclass name="CMUI_ComboResourceTypes"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>*** this control does not display Resourse types that have the IsAMarineService flag set.</text>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="displayEntry" id="5a67290a-a31c-4dce-8f2f-f4762f9736c5">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _resourceType : HMS_ResourceType; lstIndex: Integer): String updating, clientExecution;
//--------------------------------------------------
// Created:	26 November 2004 By: cnwgd1
// Changed On	By			Reason
// ----------	--------	------------------------
// 17/07/2018	jlgdap1		TFS 39685 PEL1 Pilots vs Harbours
//--------------------------------------------------
vars
	harbour : HMS_Harbour;					// TFS 39685
	resource : HMS_Resource;				// TFS 39685
	found : Boolean;						// TFS 39685

begin
	if _resourceType = null then
		return null;
	endif;

	if _resourceType.HMS_ResourceType.isMarineService then // CCMS 1350
		return null;
	endif;
	
	if _resourceType.isNotAvailableForEntry then // CCMS 1350
		if self.myObject &lt;&gt; _resourceType then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;
	
	// TFS 39685 Check for resources for the harbour 
	if combobox.form.isKindOf(CM_BaseForm) and combobox.form.CM_BaseForm.myTerminal &lt;&gt; null then
		harbour := combobox.form.CM_BaseForm.myTerminal.myHarbour;
		if harbour &lt;&gt; null then
			foreach resource in _resourceType.allResources discreteLock do
				if resource.myHarbour = harbour then
					found := true;
				endif;
			endforeach;
		endif;
	endif;
	if not found then
		return null;
	endif;
	// TFS 39685 end

	//PAR3818
	return _resourceType.description &amp; ' ('&amp; _resourceType.code &amp; ')';				
	//return _resourceType.code &amp; Tab &amp; _resourceType.description;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_resourceType" type="HMS_ResourceType"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
