    <JadeMethod name="setOverstowedQueueEntries" id="af3c133f-1cff-468f-a6fd-c930f0f5d8cc">
        <source>setOverstowedQueueEntries(_ti : CM_TrackedItem input);
/*
	ti is the cargo which has the overstowed entries

Date		Who		Reason
06 July 2017	cnwer1	Initial creation TFS 5254

*/

vars
	tiQEntry,
	qEntry : CM_RTQueueEntry;
	allRestrictingLCs 	: CM_LCSet;
begin
	tiQEntry:= _ti.getQueueEntry;
	if tiQEntry = null then
		return;
	endif;
	qEntry := self.getRTQueueEntry();						// 28/07/2011 cnwmh5 #27774
	if qEntry &lt;&gt; null   and not tiQEntry.myQueue.isKindOf(CM_VoyageCraneQueue) then
		qEntry.shiftEntry(tiQEntry.myQueue);
	endif;
	create allRestrictingLCs transient;
	_ti.getSideAccessRestrictingLCs(allRestrictingLCs);
	self.moveQueueEntryAbove(tiQEntry,allRestrictingLCs);
	foreach qEntry in self.allRTQueueEntries discreteLock do
		if not tiQEntry.allOverstowQueueEntries.includes(qEntry) then
			tiQEntry.allOverstowQueueEntries.add(qEntry);
		endif;
	endforeach;
epilog
	delete allRestrictingLCs;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setRTQueueEntry" id="7eb5e9f7-a552-4379-8b8b-ab2efbb536bf">
        <updating/>
        <source>setRTQueueEntry(_rtQueueEntry : CM_RTQueueEntry; _isMultiQueueEntry : Boolean) updating;
// -------------------------------------------
// Created 23 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	
	//if self.allRTQueueEntries &lt;&gt; _rtQueueEntry then
		//self.allRTQueueEntries := _rtQueueEntry;
	//endif;
	
	// DVB changed 10/08/06
	if not self.allRTQueueEntries.includes(_rtQueueEntry) then
		self.allRTQueueEntries.add(_rtQueueEntry);
	endif;
	
	
	self.isMultiQueueMove := _isMultiQueueEntry;


end;</source>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <Parameter name="_isMultiQueueEntry" type="Boolean"/>
    </JadeMethod>
</Class>
