<PrimType name="Time">
    <JadeMethod name="displayWithMilliseconds" id="6373f63e-a69e-49eb-9991-807f907454fa">
        <source>displayWithMilliseconds() : String;

/*

Purpose:			


Return Value:		


Date		Who		Reason
02 November 2004	cnwkpd1	PAR #4801 - Web Service application

*/

vars

begin
	return self.String &amp; "." &amp; self.milliSecond.String.padLeadingZeros(3);


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
