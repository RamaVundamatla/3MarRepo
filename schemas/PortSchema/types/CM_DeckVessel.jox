		else
			app.myEventManager.createSingleObjInfoNoteEvt(self.myROROStructure, EVENT_VESSEL_DECK_UPDATE, self);	
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_proxyDeck" type="CM_Deck" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyROROStructure" id="16c2769d-83d3-4b9e-947f-f5b66e1443b3">
        <updating/>
        <source>setMyROROStructure(_roroStructure: CM_ROROVesselStructure ) updating;
/*

