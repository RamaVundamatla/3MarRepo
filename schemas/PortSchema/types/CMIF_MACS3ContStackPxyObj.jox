    <PrimAttribute name="orientation" id="4c54dc2f-252a-427a-a1de-6909164b4bc9">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="weightLimit" id="76299700-2e30-47dd-a8f0-1228072fe93a">
        <precision>23</precision>
        <scaleFactor>3</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <text>While the JSON supports a decimal value, we only store this as in Integer (currently?)

Matches Integer CM_CellDefn::maxPileWeight20 or CM_CellDefn::maxPileWeight40</text>
    </PrimAttribute>
    <JadeMethod name="cloneSelf" id="1a245ffd-0072-46ad-9fb5-bf99223bdfba">
        <source>cloneSelf(bTransient: Boolean): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 February 2021	navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars
	clonedObj 		: SelfType;
	existingStackLen,
	clonedStackLen 	: CMIF_MACS3ContStackLenPxyObj;
begin
	clonedObj := inheritMethod(bTransient);
	
	clonedObj.common := self.common.cloneSelf(true);
	
	foreach existingStackLen in self.containerStackLengths do
		clonedStackLen := existingStackLen.cloneSelf(bTransient);
		clonedObj.containerStackLengths.add(clonedStackLen);
	endforeach;
	
	return clonedObj;
epilog

end;</source>
        <Parameter name="bTransient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="delete" id="33745137-2aa9-4995-b877-c5fd6944eff4">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 February 2021	navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars

begin
	self.containerStackLengths.purge();

	delete common;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="is20" id="18867ec0-de89-433c-bb9f-50c875a36905">
        <source>is20(): Boolean;
/*

Purpose:			If any slot in a Bay is marked for 20ft then return true

Parameters:			

Return Value:		

Date				Who		Reason
17 March 2021		navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars
	stackLen	: CMIF_MACS3ContStackLenPxyObj;
	
	isTwenty	: Boolean;
begin
	foreach stackLen in self.containerStackLengths do
		isTwenty := stackLen.is20;
		break;
	endforeach;
	
	return isTwenty;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
