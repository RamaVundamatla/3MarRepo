epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="39e504a9-ae00-49f4-93b2-64cb47edb4cf">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*
Date		    Who			Reason
11 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_VesselRampPositionType);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_VesselRampPositionType);
	theForm.shtTblInput1.visible := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="b79ec4b5-578a-431c-bd10-5680c599c952">
        <updating/>
        <source>showThumbnail(_vesselRampPositionType: CM_VesselRampPositionType) updating;
/*
Date		    Who			Reason
11 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	theForm : SOP_TableMaintForm;
	tmpTbl	: CM_EntryTable;
begin
	theForm := self.myForm;
	tmpTbl := theForm.tblInput1;
	
	tmpTbl.clearValues();

	tmpTbl.setValueByName(ETRow_Code, _vesselRampPositionType.code);
    tmpTbl.setValueByName(ETRow_Description,	_vesselRampPositionType.description);
    tmpTbl.setValueByName(ETRow_IsAvailableForEntry, _vesselRampPositionType.isAvailableForEntry);
	tmpTbl.setValueByName(ETRow_Remarks, _vesselRampPositionType.remarks);
epilog

end;</source>
        <Parameter name="_vesselRampPositionType" type="CM_VesselRampPositionType"/>
    </JadeMethod>
</Class>
