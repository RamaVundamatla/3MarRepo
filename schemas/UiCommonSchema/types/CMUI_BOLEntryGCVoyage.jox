    <JadeMethod name="addScrollRow" id="d96c6b85-3c51-46f1-b7cd-97c34b2c9c43">
        <source>addScrollRow(_obj: Object);
//-----------------------------------------------------------------------
//	Created:	04 April 2006	by Jason Chapman  (cnwjc2)
//-----------------------------------------------------------------------
vars
	tmpCtrl : CMUI_RowFrame;
begin

	tmpCtrl := self.frmRowScroll.addRow(_obj);
	//Make my new row frame the current.  cnwsh3 20/03/2007
	self.frmRowScroll.setCurrentRowFrame(tmpCtrl);
	self.txtNoOfEntries.text := self.frmRowScroll.getRowCount().String;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="c1ec253a-41c4-4627-8b36-c86458f53a73">
