    <JadeMethod name="getActionFormRemaining" id="a6c3be60-6fb9-4c71-9751-ed040d7c77f2">
        <source>getActionFormRemaining(	_treatment	: CM_LogTreatment output;
						_type		: CM_LogType output;
						_length		: CM_LogLength output) protected;

begin

	// Get specs based on the type of search.
	if self.selection = LOGID and
	   self.myLog &lt;&gt; null then
		_treatment 	:= self.myLog.myLogTreatment;
		_type 		:= self.myLog.myLogType;	
		_length 	:= self.myLog.myLogLength;	

	elseif (self.selection = LOGDOCKET  or 
	   self.selection = LOGLOCATION or
	   self.selection = LOGSPECS) and
	   self.mySelectedDocketDef &lt;&gt; null then
		_treatment 	:= self.mySelectedDocketDef.getTreatmentReference;
		_type 		:= self.mySelectedDocketDef.getTypeReference;	
		_length 	:= self.mySelectedDocketDef.getLengthReference;	
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_treatment" type="CM_LogTreatment" usage="output"/>
        <Parameter name="_type" type="CM_LogType" usage="output"/>
        <Parameter name="_length" type="CM_LogLength" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDocket" id="1e3e50c7-6021-453e-b415-151436670fb2">
        <updating/>
        <source>getDocket() protected, updating;

vars

	display		: String;
	supplier	: CM_Operator;
	opTerm		: CM_OperatorTerminal;
	location	: CM_TerminalArea;
	log			: CM_Log;
	ti			: CM_TrackedItem;
	id			: String;
	row			: Integer;
	iter		: Iterator;
	bol			: CM_BOL;
	ls,
	isFound		: Boolean;
	bolTerminal	: CM_BOLTerminal;

begin

	self.allDocketLogDef.clear;

	// Get selected supplier.
	supplier := cmbSupplier.listObject.CM_Operator;
	if supplier = null then
		return;
	endif;
	opTerm := supplier.getOperatorTerminal(self.myTerminal, false);
	if opTerm = null then
		return;
	endif;
	// Get docket id from form.
	id := self.tblSelection.getValueByName(ETRow_DocketNumber).String;
	if id &lt;&gt; null then
		// Try and get the docket.
		self.allDocketLogDef.purge;

		app.cmsBeginLoad(ls);
		iter := self.myTerminal.allBOLTermsByTypeOpNum.createIterator;
		self.myTerminal.allBOLTermsByTypeOpNum.startKeyGeq(BOLType_Log, supplier, id, iter);
		while iter.next(bolTerminal) do
			bol := bolTerminal.myBOL;
			if bol &lt;&gt; null then
				if bol.number = id then
					// Process tracked items to determine various log specs.
					bol.myExtension.CM_BOLExtLog.getLogLocations(self.allDocketLogDef, CM_LogController, self.myTerminal);
					isFound := true;
				endif;
				if bol.number &lt;&gt; id then
					break;
				endif;
			endif;
		endwhile;
		
		
		/*
		iter := opTerm.allBOLByTypeNumber.createIterator;
		opTerm.allBOLByTypeNumber.startKeyGeq(BOLType_Log, id, null, iter);
		while iter.next(bol) do
			if bol &lt;&gt; null and bol.number = id then
				// Process tracked items to determine various log specs.
				bol.myExtension.CM_BOLExtLog.getLogLocations(self.allDocketLogDef, CM_LogController, self.myTerminal);
				isFound := true;
			endif;
		endwhile;
		*/
		
		if isFound then
			// Setup display table.
			self.setSelectionData();
		else
			// Try again.
			if id &lt;&gt; self.prevDocketSearch then
				self.tblSelection.goToRowByName(ETRow_DocketNumber);
				self.tblSelection.setFocus;
				self.prevDocketSearch := id;
				app.raiseCMException1(DocketNotFound, id, null, null);
			endif;
		endif;
	endif;
epilog
	app.cmsEndLoad(ls);
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getId" id="c166cf8a-476a-447b-a47a-14bf14430677">
        <updating/>
        <source>getId() protected, updating;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars

	logId 					: String;
	ti						: CM_TrackedItem;
	log						: CM_Log;
	display,
	operatorTerminology		: String;
	row						: Integer;
	location				: CM_LocationsController;
	failedDAC  :CM_DataAccessController;

begin

	// Turn off split container.
	splitContainer.hideLeftControl(true);
	self.txtDetails.text := null;
	// Get log id from form.
	logId := self.tblSelection.getValueByName(ETRow_LogId).String;
	if logId &lt;&gt; null then
		// Try and find appropriate log.
		log := self.myTerminal.lookupTrackedItem(logId, TI_CargoType_Log, TI_STATE_NORMAL, null, false).CM_Log;
		
		if log &lt;&gt; null and log.myOperator.canUserAccessSelf(null, failedDAC, app.myPassport) then
			operatorTerminology := self.terminologyForOperatorLog;
			txtDetails.text := log.displayLogDetail(operatorTerminology, self.getTextExtent(operatorTerminology));
			self.myLog := log;
			self.tblSelectData.tabStop := false;
			return;
		endif;
		// Try again.
		if logId &lt;&gt; self.prevLogSearch then
			self.tblSelection.goToRowByName(ETRow_LogId);
			self.tblSelection.setFocus;
			app.raiseCMException1(LogNotFound, logId, null, null);
		endif;
	endif;
epilog
	self.prevLogSearch := logId;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getLogGrade" id="301873cc-6bf1-4b05-bb36-4412794c0a8e">
        <source>getLogGrade(): CM_LogGrade protected;

vars

	grade : CM_LogGrade;

begin

	// Get grade based on search type.
	// par#12536 2/10/2006 Mohammad 
	if self.selection = LOGID and self.myLog &lt;&gt; null then
		grade := self.myLog.myLogGrade;
	elseif self.selection = LOGDOCKET  or 
	       self.selection = LOGLOCATION or 
	       self.selection = LOGSPECS then
		grade :=  self.mySelectedDocketDef.getGradeReference;
	endif;
	return grade;

end;</source>
