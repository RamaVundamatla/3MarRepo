        <source>createCashCargo(_voyage : CM_Voyage; _daysBack : Integer; _containers : CM_TISet input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     1/5/2014	create on-site cargo directly
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

constants
	BlockStack = "BS2";
vars
