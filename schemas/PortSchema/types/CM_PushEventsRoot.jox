        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="replayEndTS" id="244a79b9-bbab-431b-9327-225f2c001945">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
