epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="formatCargoTypeTollQual" id="fb125a56-354e-4b23-b9cc-2bbfc9629d80">
        <source>formatCargoTypeTollQual(): Integer;
//----------------------------------------------------------------
//	Created:	11 August 2005	by Jason Chapman  (cnwjc2)
//
//	Require further codes for this to be useful
//
//----------------------------------------------------------------
vars

begin

	if self.ediString = null then
		return TI_CargoType_Container;
	endif;

	if self.ediString = "CN" then
		return TI_CargoType_Container;
	//elseif self.ediString = "BB" then
	//	return TI_CargoType_BreakBulk;
	else
		return TI_CargoType_Null;
	endif;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="formatFullOrEmptyBoolean" id="dcbd3301-5bee-4f42-8ef8-90ac7f78db65">
        <source>formatFullOrEmptyBoolean() : String;
//-----------------------------------------------------------------------
//	Created:	11 August 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	if self.ediString.trimBlanks = "" then
		return "E";
	endif;
	
	return "F";	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="formatIntegerWithCommas" id="dbe2b949-ea25-43ba-ad15-d99f85cd7d6a">
        <source>formatIntegerWithCommas(): Integer;
//-----------------------------------------------------------------------
//	Created:	11 August 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	s, s1	  	 : String;
begin
	s := self.ediString.trimBlanks;
	s1 := s.stripAlpha();
	// see if it had a decimal point
	if s &lt;&gt; null and s.pos (".", 1) &gt; 0 then
		return (s1.Integer / 100).Integer;
	endif;
	return s.Integer;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="formatInteger_Inputx10" id="f8b64344-4d10-4b4e-b0a5-bc17d992fee8">
        <source>formatInteger_Inputx10(): Integer;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.ediString.isReal then	//includes integers
		return self.multiplyReal(self.ediString.Real, 10);
	endif;		

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
