    <JadeMethod name="getCriteriaTypeDesc" id="7683bc17-de9e-4afe-ad4d-16e5b4efaf9e">
        <source>getCriteriaTypeDesc():String;
/*
Date		Who		Reason
23/02/2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars

begin
	if self.isEDIType then
		return self.CriteriaType_EDI_Desc;
	else
		return self.CriteriaType_CARGO_Desc;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
