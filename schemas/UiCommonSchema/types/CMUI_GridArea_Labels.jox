    <JadeMethod name="doOK" id="e42daca9-a6ce-4f7a-8a84-a45cb66968b5">
        <updating/>
        <source>doOK() updating;

vars

begin
	labelCheckArray.clear;

	if isRow then
		self.updateRowLabels();
	else
		self.updateColumnLabels();
	endif;
	
	inheritMethod();	
end;</source>
