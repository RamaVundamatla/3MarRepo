    <JadeMethod name="getDisplayStringForAttribute" id="99b4225f-363b-4223-9915-3c08e90b1c4e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2014	cnwndl1	Initial creation	Par 35295

*/

vars

	def : CM_SubTerminalAreaDef;
	bank : CM_Bank;

begin

	if _attrName = ETRow_AreasDefined  then
		if not self.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
			return app.getErrorString(NotApplicable);
		endif;
		def := self.mySubTerminalAreaDef;
		if def &lt;&gt; null then
			return def.getDisplayStringForAttribute( _attrName, _short );
		endif;
		return app.getErrorString(None);
		
	elseif _attrName = ETRow_DefineAreas then
		if self.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
			return "&lt;double click to edit&gt;";
		endif;
		return null;
		
	elseif _attrName = ETRow_Bank then	//03 Dec 2014	NDL	Par 35337
		bank := self.getMyBank;
		if bank &lt;&gt; null then
			return bank.code;
		endif;
		return null;
		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyBank" id="0e0110f8-3dfb-4bca-947a-37d81fe0607c">
        <source>getMyBank():CM_Bank;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2014	cnwndl1	Initial creation	Par 35295

*/

vars

	bank : CM_Bank;
	edition : Integer;
	invalidObject : Boolean;

begin

	on Exception do app.handleDeletedObject(exception, bank, invalidObject);

	bank := self.myBank;
	if bank &lt;&gt; null then
		edition := bank.edition;
		if not invalidObject then
			return bank;
		endif;
	endif;
	
	invalidObject := false;
	
	if self.myTerminal &lt;&gt; null then
		bank := self.myTerminal.getDefaultCompanyBank;
		if bank &lt;&gt; null then
			edition := bank.edition;
			if not invalidObject then
				return bank;
			endif;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
