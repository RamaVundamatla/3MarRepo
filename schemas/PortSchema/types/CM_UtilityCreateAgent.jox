    <JadeMethod name="utlCreateShipBOL" id="fb00798d-aba6-49b3-a237-42787831926b">
        <updating/>
        <source>utlCreateShipBOL(pIntFaceArray : CMIF_TIObjectArray; _validateOnly: Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     04 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	item		: CMIF_TIObject;
	nullObject	: CM_Object;
	tmpEvent	: Integer;
	todo, done	: Integer;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	// do the validation here
	foreach item in pIntFaceArray do
		if item.isKindOf(CMIF_BOLIn) then
			item.validateForCreate(_passport);		//Also does the sub items
			app.setContinueCMExceptions(true);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Item is not a preNote (' &amp; item.String &amp; ')');
		endif;
	endforeach;
	
	if (not self.checkValidationWithPassport(_passport))
	and (not _validateOnly)then
		return;
	endif;

	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;

	todo := pIntFaceArray.size;
	foreach item in pIntFaceArray do
		done := done + 1;
		if (_passport.myCMIFMonitor &lt;&gt; null) then
			_passport.myCMIFMonitor.updateProgress("Creating prenote", todo, done);
		endif;
				
		//want to keep going to get all errors at once while _validateOnly = true
		if (not item.actionForCreate(nullObject, _passport))
		and (not _validateOnly) then 	//Also does sub items
			break;
		endif;
		
		if (not _passport.noErrors())
		and (not _validateOnly) then
			break;
		endif;
		
	endforeach;

	if _passport.noErrors 
	and (not _validateOnly) then
		// issue notifications on created objcets
		tmpEvent := _passport.myTerminal.getTerminalEvent(TIEvent_PreNote_Add);
		foreach item in pIntFaceArray do
			if item.isKindOf(CMIF_PreNote) then
				item.CMIF_PreNote.myPersistentTrackedItem.causeEvent(tmpEvent, false, item.CMIF_PreNote.myPersistentTrackedItem);
			endif;
		endforeach;
	endif;	

end;</source>
        <Parameter name="pIntFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
