        <source>isAnExclusiveObject(): Boolean;

vars
	dotPos:       Integer;
	oidString:    String;
begin
	oidString := self.getOidString;
	dotPos := oidString.pos('.', 1);
	if oidString.pos('.', dotPos + 1) &gt; 0 then
		return true;
	else
		return false;
	endif;
end;</source>
