    <JadeMethod name="cnEcGetDuplicate" id="bb997737-e2b5-4cb3-9246-afcd600b76d2">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	code : String;
	port : CM_Port;

begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).String; 
	
	if code &lt;&gt; null then
		port := app.myRoot.allPorts.getAtKey( code );
	endif;

epilog

	return port;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="countryCode" id="2b9093cb-6a29-40d8-9de4-294e1db3cce4">
        <source>countryCode() : String;
//
// need a method without paramters for DSS Par19916 cnwrs1 June 2009
//
vars
	tmpCountry	: CM_Country;
begin
	tmpCountry := self.myCountry;
	if tmpCountry &lt;&gt; null then
		return tmpCountry.code;
	else
		return null;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
