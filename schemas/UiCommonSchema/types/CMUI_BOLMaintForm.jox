    <JadeMethod name="cmbDischargePort_displayEntry" id="1f97aa13-7d67-4442-8fc1-73f27a076a71">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDischargePort_displayEntry(combobox: ComboBox input; _port : CM_Port; lstIndex: Integer):String updating;

/*

Date		Who		Reason
27 May 2010	cnwas3	par 23827
01/03/2011	cnwmh5	PAR #27142 - Change where handler armed
*/
vars
	invalidPort : Boolean;
	port : String;
	portCmbOrderDescrFirst : Boolean;
begin
		
	if _port = null then 
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _port, invalidPort);
	
	if _port.isNotAvailableForEntry or not _port.isPort then
	  	if combobox.listObject &lt;&gt; _port then
			return null;		
		endif;
	endif;
		
	port := _port.getDisplayFormatted(self.portCmbOrderDescrFirst);
	
	if invalidPort then 
		port := null;
	endif;

	return port;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
