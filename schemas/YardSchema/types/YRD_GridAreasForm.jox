    <JadeMethod name="doNotesForLegend" id="882b7bef-0ff4-4060-b3ac-c2de5fbfb268">
        <source>doNotesForLegend(_startNote : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
	idx, numRows : Integer;
	theTable : Table;
begin
	theTable := self.frmColLegendTIs.myLegendTable;
	numRows := theTable.rows;
	foreach idx in 2 to numRows do
		anObject := theTable.accessRow(idx).itemObject;
		if anObject &lt;&gt; null then
			if _startNote then
				self.beginNotification(anObject, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			else
				self.endNotification(anObject, EVENT_CODE_COLOUR_CHANGE);
			endif;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_startNote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNotesForLegendStartStop" id="425f81cf-1f40-4e0b-bcae-657550b238f3">
        <updating/>
        <source>doNotesForLegendStartStop(_theIndex : Integer; _ydc : YRD_ContainerDrawingController) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.doNotesForLegend(false);
	if (not self.frmColLegendTIs.displayCodesForMode(_ydc.viewMode, _ydc.myDrawingAttrController)) then
		// could not find any codes/colours in controller so display them all
		self.frmColLegendTIs.doChangeViewMode(_theIndex);
	endif;
	self.doNotesForLegend(true);

end;</source>
        <Parameter name="_theIndex" type="Integer"/>
        <Parameter name="_ydc" type="YRD_ContainerDrawingController"/>
    </JadeMethod>
    <JadeMethod name="doProcessMoveLog" id="53337405-5c1a-4def-aa00-6ee246ba9719">
        <source>doProcessMoveLog() protected;
// --------------------------------------------------------------------------------
// Created:		04 November 2008 by cnwdad1
//
// Purpose:		Processes queued Movement Logs and their corresponding statistics.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	movementLogObj	: CMIF_MovementLogController;
	
begin
	create movementLogObj transient;
	
	// Keep processing Movement Logs until there are none left to do.
	
	while movementLogObj.processMovementLog() do
	endwhile;
epilog
	delete movementLogObj;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRebuildStats" id="8af560e0-9e68-41d4-ba78-6b75cf725d63">
        <source>doRebuildStats(_yaEntityObj:CM_YAEntity) protected;
// --------------------------------------------------------------------------------
// Created:		04 November 2008 by cnwdad1
//
// Purpose:		Rebuilds the statistics for the specified yard Allocation entity.
//
// Parameters:	_yaEntityObj - A reference to the Yard Allocation entity who's
//				statistics we want to rebuild.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	blockSetObj	: CM_YABlockSet;
	blockObj	: CM_YABlock;
	arrayObj	: ObjectArray;
	termAreaSet : CM_TerminalAreaSet;
begin
	if _yaEntityObj = null then
		return;
	endif;
	
	create termAreaSet transient;
	create blockSetObj transient;
	
	if _yaEntityObj.isKindOf(CM_YABlock) then
		blockSetObj.add(_yaEntityObj.CM_YABlock);
	else
		foreach blockObj in _yaEntityObj.CM_YardAllocation.allYABlocksIn do
			blockSetObj.add(blockObj);
		endforeach;
	endif;
	
	app.myTrxUA.trxCalcLocationStats(termAreaSet, blockSetObj, arrayObj, app.myPassport);
epilog
	delete blockSetObj;
	delete termAreaSet;
end;</source>
        <access>protected</access>
        <Parameter name="_yaEntityObj" type="CM_YAEntity"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="ec51147c-3645-4aa7-baed-7a6c24edc6a4">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpController	: YRD_ContainerDrawingController;
	anObj : Object;
	tmpVM ,topRow: Integer;
	wasYALOC : Boolean;
	arrSelected, arrExpanded : ObjectArray;
	filter	: CM_YardAllocationSet;
begin
	create filter transient; //cnwrd1 par 26697 6.1.2011
	self.tblYAM.getSelectedYardAllocations(filter); //cnwrd1 par 26697 6.1.2011
	
	foreach anObj in self.allDrawingControllers do
		tmpController := anObj.YRD_ContainerDrawingController;
		
		if tmpController.viewMode = VIEW_YARD_ALLOC then
			wasYALOC := true;
			tmpVM := self.viewModePrev4YardAlloc;
		else
			tmpVM := tmpController.viewMode;
		endif;
		
		if tmpVM &lt;&gt; 0 then
			tmpController.setViewMode(tmpVM);
		else
			tmpController.setViewMode(VIEW_VOYAGE);
		endif;
		tmpController.drawSelf(true);
		if wasYALOC then
			tmpController.setViewMode(VIEW_YARD_ALLOC);
		endif;
		tmpController.getYardAllocationPoints(false); // draw on viewing frame	
		tmpController.filterYardAllocationLines(filter);  //cnwrd1 par 26697 6.1.2011
	
	endforeach;

/*	//epr 16/12/10 -  refresh the yam table too
	create arrSelected transient;
	create arrExpanded transient;
	
	// Record the top row currently being displayed
	topRow := self.tblYAM.topRow;

	// Make a copy of selected items in YAM table
	self.tblYAM.allSelectedObjects.copy(arrSelected);
	
	// Make a copy of expanded items in YAM table
	self.tblYAM.getExpandedObjectsYA(arrExpanded);
	
	if self.tblYAM.visible then
		self.tblYAM.initialise(false, self.fraPictures, self.pic1, self.pic2, self.pic3);
	endif;
	// cnwjk3 SFW1030
	// Re-select all that were already selected
	foreach anObj in arrSelected do
		self.tblYAM.selectObject(anObj, false);
	endforeach;
	
	// Re-expand rows that were previously expanded
	foreach anObj in arrExpanded do
		self.tblYAM.expandYALocations(anObj.CM_YardAllocation, true );
	endforeach;
	
	// Restore the top row
	self.tblYAM.topRow := topRow;

	// cnwjk3 SFW1030
	self.doYAMTableSelection();
epilog
	delete arrSelected;
	delete arrExpanded;*/
epilog
	delete filter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="d5b0b794-659f-48cf-b5b3-2c61c24c9172">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	anObj : Object;
	cdb : YRD_ContainerGridAreaDockBar;
begin

	inheritMethod();
	
	self.frmSelectorPane.cnEcResizeContents;	//28 July 2011	NDL	Par 27890
	self.frmSelectorPane.enabled := not self.allTerminalAreas.isEmpty;	//28 July 2011	NDL	Par 27890
	
	foreach anObj in self.allDockBars do
		cdb := anObj.YRD_ContainerGridAreaDockBar;
		cdb.cnEcResizeContents();
		if cdb.myDrawingFrame &lt;&gt; null then
//			cdb.myDrawingFrame.parent.top := YRD_ContainerDrawingController.LABEL_WIDTH + 1;
//			cdb.myDrawingFrame.parent.left := YRD_ContainerDrawingController.LABEL_WIDTH + 1;
		endif;
	endforeach;

	self.frmStatusLine.doResize();
	self.setLastColumnMaxWidth(self.tblGridAreaInfo);
	self.doResizeColumnWidths(self.tblGridAreaInfo, true);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doRestrictionOpenLabour" id="afa2aa0e-ec26-4010-a3b0-a3dd12fcd2cf">
        <source>doRestrictionOpenLabour(_ta : CM_TerminalArea)protected;
// ---------------------------------------------------------------------------
// Created:     07 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
// 07/11/2012	cnwcs5	par 30475 - replace YRD_LocationMaintForm constants with YRDPadArea Constants
vars
	rowNum				: Integer;
	theTA				: CM_TerminalArea;
	restrictionLabour	: CM_LabourRestriction;
begin

	theTA := _ta;
	
	if theTA = null then
		return;
	endif;
	
	restrictionLabour := theTA.allRestrictionsLabour.first;
	
	self.myAssistant.showRestrictionsForm(theTA,YRD_PadArea.AreaMode_Labour,restrictionLabour,
												false,false, self.myMasterMenuAction);

end;</source>
        <access>protected</access>
