    <JadeMethod name="moveOutwardJobToRail" id="e51d983f-04f2-430b-aad0-b4328846a5ad">
        <source>moveOutwardJobToRail(_job : CM_RailJob input);
// ---------------------------------------------------------------------------
// Created:     09 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	io : CM_RailJSInOutRake;
	jobWagon : CM_Wagon;
	
begin

	if self.myJobSheet = null then // PAR 19987
		return;
	endif;

	

	// only move jobs for the selected wagons.
	jobWagon := _job.getMyWagon();
	if jobWagon &lt;&gt; null and jobWagon.myRailLine &lt;&gt; null then // and only move them to the ACTUAL RAIL jobsheet if the wagon has been confirmed as on the rake.
		io := self.myTerminal.myRailJobSheet.getJSForRailArea(jobWagon.myRailLine.myRailArea, Rail_JSIO_Type_Out);
		if io = null then
			return;
		endif;
		_job.removeFromJobSheet();
		self.myTerminal.myRailJobSheet.addJob(_job, 0);	
		_job.setInOutRakeSheet(io);

		_job.causeEvent(self.myTerminal.getTerminalEvent(RailJob_Update_Event),true,_job);// 28 Jul 2009	NDL to update forms..
	endif;
		
end;</source>
        <Parameter name="_job" type="CM_RailJob" usage="input"/>
    </JadeMethod>
    <JadeMethod name="moveOutwardJobsToRail" id="b1f6b2ad-9a0e-4031-9762-afa70ba5390d">
        <source>moveOutwardJobsToRail(control : CMIF_WagonMoveController input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     09 June 2009 by cnwab1
//
// Changed On   Changed By  	Reason
// ----------   ----------  	--------------------------------------------------
// 24/11/2010	cnwdap1			PAR #23794 CCMS MES 1102 Rail release requests on load list	
// 02 May 2024  navma1 			ChangeRequest 63936: MTN - Use Deferred Updates When Confirm Wagons
// ---------------------------------------------------------------------------

vars
	io 				: CM_RailJSInOutRake;
	job 			: CM_Job;
	jobs 			: CM_JobArray;
	jobWagon 		: CM_Wagon;
	term			: CM_Terminal;
	termJobSheet	: CM_RailJobSheet;
begin

	if self.myJobSheet = null then // PAR 19987
		return;
	endif;
	
	term 			:= self.myTerminal;
	
	//30 Apr 2015	NDL	Par 36133
	if term = null then  
		return;
	endif;

	termJobSheet	:= term.myRailJobSheet;
	
	if termJobSheet = null then
		return;
	endif;
	
	io := termJobSheet.getJSForRailArea(control.myTargetRailLine.myRailArea, Rail_JSIO_Type_Out);
	
	if io = null then
		return;
	endif;
	
	create jobs transient;
	self.myJobSheet.allJobsByOrder.copy(jobs);

	foreach job in jobs discreteLock do

		// only move jobs for the selected wagons.
		jobWagon := job.CM_RailJob.getMyWagon();
		if jobWagon &lt;&gt; null then
			if control.allWagons.includes(jobWagon) then
				job.CM_RailJob.removeFromJobSheet();
				termJobSheet.addJob(job, 0);	
				job.CM_RailJob.setInOutRakeSheet(io);
				app.myEventManager.createSingleObjInfoNoteEvt(job, term.getTerminalEvent(RailJob_Update_Event), job);	
				
			endif;
		// Move the release requests jobs with the first wagon job
		endif;
		
		if job.CM_RailJob.requestNum &lt;&gt; null then
			job.CM_RailJob.removeFromJobSheet();
			termJobSheet.addJob(job, 0);	
			job.CM_RailJob.setInOutRakeSheet(io);
			app.myEventManager.createSingleObjInfoNoteEvt(job, term.getTerminalEvent(RailJob_Update_Event), job);					 // PAR 21740
		endif;
	endforeach;
	
	// PAR #23794 create note for Rail Load List form to rebuild release request details
	app.myEventManager.createSingleObjInfoNoteEvt(self, term.getTerminalEvent(Train_OutwardJobMove_Event), self);
	
epilog
	delete jobs;
end;</source>
        <Parameter name="control" type="CMIF_WagonMoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="myRailArea" id="5cfdf7b6-cf2a-4f9d-b883-32555537371f">
        <methodInvocation>mapping</methodInvocation>
        <source>myRailArea(set: Boolean; _value: CM_Rail io) mapping;
// --------------------------------------------------------------------------------
// Created:		8 December 2009 by cnwjo3
//
// Purpose:		NFS 21884
//
vars
	wagon : CM_Wagon;
	railArea : CM_Rail;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.allWagonsByIdInward.isNotEmpty() then
		foreach wagon in self.allWagonsByIdInward do
			if wagon.myRailLine &lt;&gt; null then
				railArea := wagon.myRailLine.myRailArea;
				break;
			endif;
		endforeach;		
	elseif self.allWagonsByIdInward.isNotEmpty() then
		foreach wagon in self.allWagonsByIdInward do
			if wagon.myRailLine &lt;&gt; null then
				railArea := wagon.myRailLine.myRailArea;
				break;
			endif;
		endforeach;
	endif;
	
	_value := railArea;
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Rail" usage="io"/>
    </JadeMethod>
    <JadeMethod name="onSiteAt" id="9372ef6d-5dcb-46ed-bd12-dedfaa468252">
        <source>onSiteAt( _ts : TimeStamp ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if not _ts.isValid then
		return false;
	endif;

	if self.arrivalDT.isValid then
		if _ts &lt; self.arrivalDT then
			return false;
		endif;
	elseif self.scheduledArrivalDT.isValid then
		if _ts &lt; self.scheduledArrivalDT then
			return false;
		endif;
	endif;
	
	if self.departureDT.isValid then
		if _ts &gt; self.departureDT then
			return false;
		endif;
	elseif self.scheduledDepartureDT.isValid then
		if _ts &gt; self.scheduledDepartureDT then
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processCustomsEDIOnTrain" id="6f0b7be5-6ede-4ade-adbe-b28ac5093483">
        <updating/>
        <source>processCustomsEDIOnTrain(_passport: CM_Passport) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 November 2009	cnwndl1	Initial creation	Par 21519
// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars
	ediConfig			: CM_EDIConfig;
	terminal			: CM_Terminal;
	ediRequest			: BGP_EdiRequest;
	added				: Boolean;
begin
	terminal := self.myTerminal;
	ediConfig := terminal.myEdiConfig;
	
	if ediConfig = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'cannot continue with ediConfig not set');
		return;
	endif;
	
	//all we need to do here is add this train to the ediConfigs train list...
	added := ediConfig.addTrainToProcessing(self);
	
	//...and create a bgp request to process edi
	create ediRequest persistent;
	//11 Jul 2016	NDL	TFS 2296
	if app.myPassport.myTerminal &lt;&gt; terminal then
		app.myPassport.setMyTerminal(terminal);
	endif;
	ediRequest.initEDIFromTrainArrival();

	
	//if you are going to change this bit update getRemarks also
	if added then
		self.setRemarks(self.remarks &amp; CrLf &amp; "Train added to EDI Customs processing " &amp; app.serverTimestampAtTrxStart.shortCurrentLocaleSystemUTC);// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	else
		self.setRemarks(self.remarks &amp; CrLf &amp; "Train already added to EDI Customs processing.");
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="73ac9f99-42b7-4fff-9a07-b86aa15ba4ff">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     31 July 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 20/04/2011		cnwmh5			PAR #27401 - Add code to handle prossible exceptions occurring when
//									trying to create the proxy
// 04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
// 22 Jun 2023 navra1	TFS 57808 - EUP - Manifest Processing - Train - Create
// ---------------------------------------------------------------------------
vars
	me : SelfType;
	completedOK		: Boolean;
	
begin

	me :=  inheritMethod();
	
	me.myTerminal 			:= self.myTerminal;
	me.myTerminalDeparted 	:= self.myTerminalDeparted;
	me.myCarrier			:= self.myCarrier;
	me.myTrackClearance 	:= self.myTrackClearance;	
	me.myOriginPort			:= self.myOriginPort;
	me.myDestinationPort	:= self.myDestinationPort;
	me.myStevedoreReceive   := self.myStevedoreReceive;  //04.11.2020 cnwma1 TFS #50112
	me.myStevedoreRelease   := self.myStevedoreRelease;  //04.11.2020 cnwma1 TFS #50112
	me.myCarrier			:= self.myCarrier;			 //navra1 - TFS 57808 - 22nd June 2023 
	completedOK := true;								 // 20/04/2011 cnwmh5 #27401
	return me;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete me;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeWagon" id="4dcaff79-d056-4a16-bae6-757056b2d1e3">
        <updating/>
        <source>removeWagon(_inward : Boolean; _wagon : CM_Wagon input) updating;

/*

Purpose:			Remove a wagon from the train

Parameters:			

Return Value:		


Date		Who		Reason
29 May 2009	consw1	Initial creation

*/

vars

begin
	if _inward then
		if _wagon.myTrainInwards &lt;&gt; self then
			app.setContinueCMExceptions(false);
			//app.raiseCMException2(MethodWithNullParam, method.name, "Train Reference", null, null); //- cnwmd1, CCMS 1067, Par 19710
			app.raiseCMException2(MethodWithNullParam, method.name, app.getErrorString(Train_reference), null, null); //+ cnwmd1, CCMS 1067, Par 19710
		endif;
	else
		if _wagon.myTrainOutwards &lt;&gt; self then
			app.setContinueCMExceptions(false);
			//app.raiseCMException2(MethodWithNullParam, method.name, "Train Reference", null, null); //- cnwmd1, CCMS 1067, Par 19710
			app.raiseCMException2(MethodWithNullParam, method.name, app.getErrorString(Train_reference), null, null);
		endif;
	endif;
	
	_wagon.setMyTrain(_inward,null);
		
epilog

end;</source>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_wagon" type="CM_Wagon" usage="input"/>
    </JadeMethod>
