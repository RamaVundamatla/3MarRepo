    <JadeMethod name="getImportReleasePIN" id="d7d20e9c-0e84-41c4-84db-2f7c18207d83">
        <source>getImportReleasePIN() : String;

/*
Purpose:	This method will return a string of the entered RequiredInfo if it is for the ImportReleasePIN.
			This method is available for use in JRW so do not delete.

Date				Who		Reason
23 September 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.

*/
	
vars
	
begin
	if self.requiresInfoType = ImportReleasePIN then
	
		//09 Feb 2011	NDL	Par 26936
		if ( not app.getMyUser.canDo(self.myTerminal, PmAdmOpImpReleasePinEdit) )
		and ( not app.getMyUser.canDo(self.myTerminal, PmAdmOpImpReleasePinView) ) then
			return "*****";
		else
			return self.requiredInfo;
		endif;
		
	endif;
	
	return null;
	
epilog
	
end;
	
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="20acad53-48a2-4407-88a6-5d9e8ff38cf3">
        <source>getName() : String;

vars
	returnStr	: String;
	
begin
	returnStr	:= 	inheritMethod() &amp; Tab &amp;
					self.stopID.display &amp; Tab &amp;
					self.stopDescription;
	
	if self.myTrackedItem &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; self.myTrackedItem.id;
	endif;
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
