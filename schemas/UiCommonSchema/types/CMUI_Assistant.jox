    <JadeMethod name="comboBoxRelReqConsigneeVal" id="bdb27430-3045-4b19-ba84-9af540bd5395">
        <source>comboBoxRelReqConsigneeVal(_cmb : ComboBox input; _value : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 June 2025		jlizm1	Initial creation MTN 34950 Add config to set if consignee must match release

*/

vars
	idx : Integer;
	
begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear;
	_cmb.sorted := false;
	
	idx := _cmb.addItem(app.getErrorString(Cargo_consignee_no_match_rel));
	_cmb.itemData[idx] := ConsigneeNoMatch;
	
	idx := _cmb.addItem(app.getErrorString(Cargo_consignee_can_empty));
	_cmb.itemData[idx] := ConsigneeEmptyOk;
	
	idx := _cmb.addItem(app.getErrorString(Cargo_consignee_must_match_rel));
	_cmb.itemData[idx] := ConsigneeStrictMatch;
	
	_cmb.text := app.relReqConsigneeValEnumToStr(_value);
	
epilog

end;</source>
