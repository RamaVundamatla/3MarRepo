    <JadeMethod name="jrwGetGrossProductivity" id="fa0a7f13-6b6a-48e0-aa30-25785579439f">
        <source>jrwGetGrossProductivity():Decimal;
// ---------------------------------------------------------------------------
// Created:     15 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Gross productivity as a percentage
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	percent		:Decimal [12,2];
	workingTime, 
	runningTime	:Integer;
begin
	workingTime := self.grossWorkingTime;
	runningTime	:= self.grossRunningTime;
	
	if runningTime &lt;&gt; 0 then
		percent := (workingTime/runningTime).roundedTo (2);
	endif;
	
	return percent;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
