    <JadeMethod name="setFiltAvailGardes" id="1ca3e8a1-82c2-432e-abdc-aa8f96792122">
        <updating/>
        <source>setFiltAvailGardes( _allFilterAvailCodes : CM_MTGradeByCodeDict )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2013	cnwndl1	Initial creation

*/

vars

begin

	self.allFilterAvailCodes.clear();
	if _allFilterAvailCodes &lt;&gt; null and not _allFilterAvailCodes.isEmpty then
		_allFilterAvailCodes.copy( self.allFilterAvailCodes );
	endif;

epilog

end;</source>
