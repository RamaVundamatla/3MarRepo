    <JadeMethod name="setupContextMenu" id="01928e59-277a-4f76-8dd8-e982b462d7b7">
        <source>setupContextMenu(	_bay : CM_BayVoyage; _crane : CM_Crane; _objs : ObjectArray input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	obj : Object;
	str : String;
begin

	mnuTimeZoom.visible:=self.myVoyage &lt;&gt; null;
	mnuJobZoom.visible:=mnuTimeZoom.visible;
	
	mnuBayView.visible:=_bay &lt;&gt; null;
	mnuBayView.userObject:=_bay;
	mnuCraneDefinition.visible:=_crane &lt;&gt; null;
	mnuCraneDefinition.userObject :=_crane;
	
	//02 Apr 2012	NDL	Par 29369
	mnuWPOpHrs.visible := self.myVoyage &lt;&gt; null;
	mnuWPOpHrs.userObject :=_crane;
	
	mnuDelayAdd.visible:=not _bay &lt;&gt; null;
	obj:=_bay;
	str := null;
	if _crane &lt;&gt; null then
		mnuDelayAdd.userObject:=_crane;
		mnuShowCraneInJobOps.userObject := _crane;
		str :=app.getErrorString1(Show_crane_operations,_crane.CM_Crane.id);
		mnuShowCraneInJobOps.caption := str;
		obj:=_crane;
	endif;
	
	if _bay &lt;&gt; null or _crane &lt;&gt; null then
		self.resetJobMenuItems;
	endif;
	mnuShowCraneInJobOps.visible := _crane &lt;&gt; null;
	if _crane &lt;&gt; null then
		mnuShowCraneInJobOps.userObject := _crane;
	endif;
	self.mnuDelay.visible:=self.mnuDelayEdit.visible or self.mnuDelayAdd.visible or self.mnuEndDelay.visible;
	
	mnuTimeSep.visible:=	mnuDelay.visible or
								self.allJobContMenuItems.size &gt; 0  or
								mnuCraneDefinition.visible or
								mnuBayView.visible;
	
	if app.isAllowedToInspect then
		mnuInspect.visible:=true;
		mnuInspect.userObject:=obj;
	else
		mnuInspect.visible:=false;
		mnuInspect.userObject:=null;
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuDelay.visible:= false;
	endif;

 
epilog

end;</source>
        <Parameter name="_bay" type="CM_BayVoyage"/>
        <Parameter name="_crane" type="CM_Crane"/>
        <Parameter name="_objs" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupCraneStatsTable" id="cdbaf510-3b04-4267-9dbd-452f2b1288d9">
        <source>setupCraneStatsTable();
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	frmLeft : Integer;
begin
	frmLeft:=self.picBridgeTop.pictureWidth + 20;
	self.frmCranesNew.top:=1;
	self.frmCranesNew.left:=frmLeft;
	self.frmCranesNew.width :=self.clientWidth - frmLeft -  app.getVerticalScrollbarWidth ;
	self.tblCranes.visible:=true;
	self.tblCranes.left:=0;
	self.tblCranes.top:=0;
	self.tblCranes.width:=self.frmCranesNew.width;

	self.myAssistant.tblVoyageStats(self.tblCranes,self.myJobController.myVoyageStats);
	self.frmCranesNew.height:=self.tblCranes.height;
	self.frmCranesNew.visible:=true;
	self.frmCranesNew.zOrder(1);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupDelayContextMenu" id="c617c55a-49c4-43c8-927e-e7a03f7bd382">
        <source>setupDelayContextMenu(_delay : CM_Delay);
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 June 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if _delay = null then
		return;
	endif;
	self.mnuDelayEdit.visible:=true;
	self.mnuDelayEdit.userObject:=_delay;
	self.mnuEndDelay.visible :=true;
	self.mnuEndDelay.userObject := _delay;

epilog

end;</source>
        <Parameter name="_delay" type="CM_Delay"/>
