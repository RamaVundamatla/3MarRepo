    <JadeMethod name="doAddMovementToGraphicalView" id="6b631cea-83f8-41c5-96ec-d21feec1ac2f">
        <updating/>
        <source>doAddMovementToGraphicalView(_movement : CMIF_HMS_WorkingMovement input) : Boolean updating;
//--------------------------------------------------
// Created:	22 July 2004 By: cnwgd1
//--------------------------------------------------
// 10/12/2014  cnwdb2	PAR 35364

vars
	tmpBerth : HMS_Berth;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	tmpBerth := self.cmbMyBerth.listObject.HMS_Berth;
	if tmpBerth = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Berth', null, null);
		app.raiseCMException(Input_required_field_berth, null, null); // cnwdb2	PAR 35364

		return false;
	endif;
	// Don't need a drag picture as it will be created when the movement is added to the wharf control
	//if self.myGraphicalViewForm.updateMovementToController(null, _movement, true, false, tmpBerth, self.txtBowMarkTo.text.Decimal, self.txtSternMarkTo.text.Decimal) then
	if self.myGraphicalViewForm.updateMovementToController(null, _movement, true, false, tmpBerth, self.txtBowMarkTo.text.asDecimalJMT(), self.txtSternMarkTo.text.asDecimalJMT()) then	// 01 APR 2010	NDL	Par 23556
		return true;
	endif;
	
	return false;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_movement" type="CMIF_HMS_WorkingMovement" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
