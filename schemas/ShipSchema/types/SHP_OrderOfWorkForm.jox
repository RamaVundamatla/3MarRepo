    <JadeMethod name="doSelectAll" id="10472ca0-a001-4de2-8a3c-c5d57106f394">
        <source>doSelectAll();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	numRows,
	numFooterRows,
	rowIdx		: Integer;
	jRow		: JadeTableRow;
	allSel 	: Boolean;
	
begin
	numRows 		:= self.tblData.rows;
	
	// PAR 31756 find first non job row
	foreach rowIdx in self.tblData.fixedRows + 1 to numRows do
		if self.tblData.accessRow(rowIdx).itemObject = null then
			numFooterRows := numRows - rowIdx + 1;
			break;
		endif;
	endforeach;	

	/* PAR 31756
	// 03/02/2012 cnwar2 #28897
	numFooterRows	:= 7;	// = blank row + "Crane Totals" + "20' Totals" + "40' Totals" + "Timber Totals" + "BreakBulk Totals" + "Reefer Totals"
	if self.showLength30 then
		numFooterRows := numFooterRows + 1;
	endif;
	if self.showLength45 then
		numFooterRows := numFooterRows + 1;
	endif;
	if self.showLength53 then
		numFooterRows := numFooterRows + 1;
	endif;
	*/
	
	allSel := ((numRows - self.tblData.fixedRows - numFooterRows) &lt;&gt; self.tblData.allSelectedObjects.size);
	
	self.tblData.allSelectedObjects.clear();

	if allSel then
		foreach rowIdx in self.tblData.fixedRows to numRows - numFooterRows do
			jRow := self.tblData.accessRow(rowIdx);
			jRow.selected := true;
			if jRow.itemObject &lt;&gt; null then
				self.tblData.allSelectedObjects.add(jRow.itemObject);
			endif;
		endforeach;
		self.btnSelectAll.caption := app.getErrorString(SelectAll);		// 25/01/2012 cnwar2 #28897
		
	else
		foreach rowIdx in self.tblData.fixedRows to numRows do
			jRow := self.tblData.accessRow(rowIdx);
			jRow.selected := false;
		endforeach;
		self.btnSelectAll.caption := app.getErrorString(Deselect_All);	// 25/01/2012 cnwar2 #28897
		
	endif;	
	inheritMethod();

end;</source>
    </JadeMethod>
