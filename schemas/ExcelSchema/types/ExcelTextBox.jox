<GUIClass name="ExcelTextBox" id="4c5a9628-c41c-4d45-adac-c2e457a7a543">
    <superclass name="TextBox"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="readOnly" id="8616322b-0f3f-4272-9dd3-44821393e344">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>readOnly(set: Boolean; value: Boolean io) updating, mapping, clientExecution;

/*****************************************************
	Written by	:	cnwpra1		06 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

constants

vars

begin
	if isTransient = true then												// ... to avoid schema/ddb load failure
		if set then
			backColor := Window.Color_Window + SYSTEM_COLOUR;
			inheritMethod(set, value);
			if app.getName = "Jade"  then	// app.getName = "Jade" means we are in painter
				if value then
					if form &lt;&gt; null then
						backColor := form.backColor;						// back color may not always be gray!
					else
						backColor := Window.Color_3DFace + SYSTEM_COLOUR;
					endif;
					if not app.getName = "Jade" then
						tabStop := false and visible ;
					else
						tabStop := false ;
					endif ;
				else
					backColor := Window.Color_Window + SYSTEM_COLOUR;
					tabStop := true;
				endif;
			else
				if value then
					if form &lt;&gt; null then
						backColor := form.backColor;						// back color may not always be gray!
					else
						backColor := Gray;
					endif;
					tabStop := false and visible ;
				else
					backColor := White;
					tabStop := true;
				endif;
			endif;
			self.refresh;													// make sure that a repaint is done
		else
			inheritMethod(set, value);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
