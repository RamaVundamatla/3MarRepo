begin
	if self.aMySpellCheck &lt;&gt; null then
		self.aMySpellCheck.setReplaceAll(txtReplace.text.trimBlanks());
	endif;
	
	self.nextWord();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resize" id="b0bcd9e7-138c-4723-be76-7cc3c19e62fc">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		21 June 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.width &lt; 318 then
		self.move(self.left, self.top, 318, self.height);
	endif;

	if self.height &lt; 273 then
		self.move(self.left, self.top, self.width, 273);
	endif;
	
	fraText.move(fraText.left, fraText.top, (self.width - fraText.left - 18), fraText.height);
	hscTextScroll.move(hscTextScroll.left, hscTextScroll.top, fraText.width, hscTextScroll.height);
	txtReplace.move(txtReplace.left, txtReplace.top, fraText.width, txtReplace.height);
	ruler.move(ruler.left, ruler.top, fraText.width, ruler.height);
	
	btnIgnoreAll.move((self.width - btnIgnoreAll.width - 17), btnIgnoreAll.top, btnIgnoreAll.width, btnIgnoreAll.height);
	btnIgnore.move((btnIgnoreAll.left - btnIgnore.width - 9), btnIgnore.top, btnIgnore.width, btnIgnore.height);
	btnReplaceAll.move((self.width - btnReplaceAll.width - 17), btnReplaceAll.top, btnReplaceAll.width, btnReplaceAll.height);
	btnReplace.move(btnIgnore.left, btnReplace.top, btnReplace.width, btnReplace.height);
	btnDictMaint.move((self.width - btnDictMaint.width - 17), btnDictMaint.top, btnDictMaint.width, btnDictMaint.height);
	btnAdd.move(btnIgnore.left, btnAdd.top, btnAdd.width, btnAdd.height);
	btnCancel.move((self.width - btnCancel.width - 17), (self.height - btnCancel.height - 38), btnCancel.width, btnCancel.height);

	optMetaphone.move(optMetaphone.left, (self.height - optMetaphone.height - 38), optMetaphone.width, optMetaphone.height);
	optSoundex.move(optSoundex.left, (self.height - optSoundex.height - 38), optSoundex.width, optSoundex.height);
	lstProspectWords.move(lstProspectWords.left, lstProspectWords.top, (btnAdd.left - lstProspectWords.left - 7), (self.height - lstProspectWords.top - 59));
end;</source>
    </JadeMethod>
    <JadeMethod name="setSpellFeatures" id="501fb13a-9316-41db-b771-3927b84a9c5a">
        <updating/>
        <source>setSpellFeatures(	pSpellCheckObj:CnEcSpellCheck;
					pIsMetaphoneSearch:Boolean;
					pCheckedProse:String;
					pWordToCheck:String;
					pRemainingProse:String;
					pAllSoundexWords:StringArray;
					pAllMetaphoneWords:StringArray) updating;
// --------------------------------------------------------------------------------
// Created:		17 February 2003 by cnwdad1
//
// Purpose:		Sets up references, text, options and word arrays for the Spell
//				Checker.
//
// Parameters:	pTheSpellCheck - A reference to the spell checker object.
//				pIsMetaphoneSearch - True is the word search defaults to using
//					metaphone words, otherwise soundex words will be used.
//				pCheckedProse - The text that has already been checked.
//				pWordToCheck - The word to check/replace.
//				pRemainingProse - The rest of he text that has not yet been checkd.
//				pAllSoundexWords - An array of alternative words to the word being
//					checked.  The words are all equivalent soundex words.
//				pAllMetaphoneWords - An array of alternative words to the word being
//					checked.  The words are all equivalent metaphone words.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMySpellCheck		:=	pSpellCheckObj;
	self.optMetaphone.value	:=	pIsMetaphoneSearch;
	self.aPreText			:=	pCheckedProse;
	self.aErrorText			:=	pWordToCheck;
	self.aPostText			:=	pRemainingProse;
	
	self.stripNonTextCharacters(self.aErrorText);
	self.stripNonTextCharacters(self.aPostText);
	self.stripNonTextCharacters(self.aPreText);
	self.aPreText			:=	self.aPreText &amp; " ";
	
	pAllSoundexWords.copy(self.aAllSuggestedSoundexWords);
	pAllMetaphoneWords.copy(self.aAllSuggestedMetaphoneWords);
end;</source>
        <Parameter name="pSpellCheckObj" type="CnEcSpellCheck"/>
        <Parameter name="pIsMetaphoneSearch" type="Boolean"/>
        <Parameter name="pCheckedProse" type="String"/>
        <Parameter name="pWordToCheck" type="String"/>
        <Parameter name="pRemainingProse" type="String"/>
        <Parameter name="pAllSoundexWords" type="StringArray"/>
        <Parameter name="pAllMetaphoneWords" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setupScroll" id="f12bc78d-2e91-41f8-88ee-89249add637a">
        <updating/>
        <source>setupScroll() updating, protected;

vars
	preTextSize				: Integer;
	errorTextSize			: Integer;
	postTextSize			: Integer;
	displayCharacterWidth	: Integer;
	testWidth				: String;
	
begin
	// determine the width in caharcters of the control
	//  in which we are writing the text
	
	testWidth := "H";
	while fraText.drawTextWidth(testWidth) &lt; fraText.width do	
		testWidth := testWidth &amp; "H";
	endwhile;	
	displayCharacterWidth := testWidth.length - 1;				
	
	// determine the sizes of the peices of text we are writing there	
	preTextSize		:= self.aPreText.length;
	errorTextSize	:= self.aErrorText.length;
	postTextSize	:= self.aPostText.length;
	
	// set the relative values for use of the scroll bar
	// given the capacity of the area we are writing in and
	// the sizes of the data we are attempting to write there.
	hscTextScroll.min := 0;
	hscTextScroll.max := preTextSize + errorTextSize + postTextSize;
	if hscTextScroll.max &gt; displayCharacterWidth then
		hscTextScroll.max := hscTextScroll.max - displayCharacterWidth;
	endif;
	  
	hscTextScroll.smallChange := 1;
	hscTextScroll.largeChange := displayCharacterWidth;
	
	// set the relative position of the scroll tab so that
	// the word in error is displayed in the control.
	if displayCharacterWidth &lt; preTextSize then
		hscTextScroll.value := preTextSize - (displayCharacterWidth / 2).Integer; 
	else
		hscTextScroll.value := 0;
	endif;		
	
	// display the text in the control.
	self.doDisplayText();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="stripNonTextCharacters" id="f215ca46-3795-4b52-97a4-cad14d0653c3">
        <source>stripNonTextCharacters(pValue:String io) protected;
// --------------------------------------------------------------------------------
// Created:		17 February 2003 by cnwdad1
//
// Purpose:		Strip non-text characters from the specified parameter value.
//
// Parameters:	pValue - The string to be stripped.
//
// Returns:		The stripped string parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pValue.cnEcReplaceCrLf(CrLf, " ");
	pValue.cnEcReplaceCrLf(Cr, " ");
	pValue.cnEcReplaceCrLf(Lf, " ");
	pValue.cnEcReplaceCrLf(Tab, "    ");
end;</source>
        <access>protected</access>
        <Parameter name="pValue" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="textReplaceChange" id="b95cef12-b624-474c-9c69-cda4ab2aa0ca">
        <source>textReplaceChange() protected;

begin
	if txtReplace.text.trimBlanks() = "" then
		btnReplace.enabled		:=	false;
		btnReplaceAll.enabled	:=	false;
	else
		btnReplace.enabled		:=	true;
		btnReplaceAll.enabled	:=	true;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="txtReplace_change" id="ce9b7567-bc09-41f1-b0f8-657d557f0c41">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtReplace_change(textbox: TextBox input) updating;

begin
	app.mousePointer	:=	Busy;
	self.textReplaceChange();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unload" id="e3fb2780-31d3-4ab4-ab52-bff261551f5c">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

begin
	self.nextWord();
end;</source>
    </JadeMethod>
    <JadeMethod name="updateFromDictionary" id="2e09b222-bd33-460f-a9fb-0748ada9731f">
        <updating/>
        <source>updateFromDictionary() updating, protected;

begin
	if self.aWordFromDictionary &lt;&gt; "" then
		txtReplace.text	:=	self.aWordFromDictionary;
		self.textReplaceChange();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
