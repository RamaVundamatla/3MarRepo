    <JadeMethod name="populateCmbReleaseNumber" id="3f581db4-50d0-482f-8684-a393a2c4fe5d">
        <source>populateCmbReleaseNumber();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2009	cnwrd1	Initial creation

*/

vars
	dict				: CM_BulkReleaseByTypeStCodeDict;
	iter 				: Iterator;	
	bulkRelease			: CM_BulkRelease;
	releaseNoKey		: String;
	typeKey,
	statusKey			: Integer;
	tsKey				: TimeStamp;
	
begin
	dict := self.myTerminal.allBulkReleaseByTypeByStByCd;
	iter := dict.createIterator();
	
	dict.startKeyGeq(BR_TYPE_ROAD, BR_ACTIVE, null , null, iter);
	
	while iter.next(bulkRelease) do
		dict.getIteratorKeys(typeKey, statusKey, releaseNoKey, tsKey, iter);
		
		if typeKey &lt;&gt; BR_TYPE_ROAD or statusKey &lt;&gt; BR_ACTIVE then
			break;
		endif;
		
		self.cmbReleaseNumber.addItemObject(bulkRelease.code, bulkRelease);
	endwhile;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateVoyageDetails" id="4f91ff00-1fca-432f-9d84-1413e45fe4b5">
        <source>populateVoyageDetails();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2009	cnwrd1	Initial creation
18/02/2010	cnwmh5	PAR22417 - Handle deleted bookingRef
10/03/2011	cnwmh5	PAR #27142 - Change where handleDeletedObject is armed
*/

vars
	bookingRef			: CM_BookingRef;
	voyage				: CM_Voyage;
	invalidObject		: Boolean;			// 18/02/2010 cnwmh5 #22417
begin

	bookingRef := self.cmbBookingRef.listObject.CM_BookingRef;
	
	if bookingRef = null then 
		self.txtVoyage.text := null;	
		self.txtDestination.text := null;
		self.txtDischarge.text	:= null;
		self.chkUpdateVoyDet.value := false;
		return;
	else	
		on Exception do app.handleDeletedObject(exception, bookingRef, invalidObject);	// 18/02/2010 cnwmh5 #22417Y
		voyage := bookingRef.myVoyage;
	endif;
	
	if voyage &lt;&gt; null then
		self.txtVoyage.text := voyage.code;
	else
		self.txtVoyage.text := null;
	endif;
	self.txtDestination.text := bookingRef.destinationPort;
	self.txtDischarge.text	:= bookingRef.dischargePort;
epilog

end;</source>
    </JadeMethod>
