    <JadeMethod name="getAnswerFromMethod" id="3413ed4b-5531-45f6-8476-92ed1d661fd8">
        <source>getAnswerFromMethod(_theMethod : String;_theTI : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpMethod	: Method;

begin
	if _theTI = null then
		return false;
	endif;
	
	// check to see if the method exists on the class
	// we are looking at.  Need to look up everytime as
	// we need to get the correct method for this sub-class,
	// and not one for another sub-class
	tmpMethod := _theTI.class.getMethodInHTree(_theMethod);
	if (tmpMethod = null) then

		return false;
	endif;
	
	if tmpMethod.isMappingMethod() then
		return _theTI.getPropertyValue(_theMethod).Boolean;
	endif;
	
	return _theTI.sendMsg(_theMethod).Boolean;
end;</source>
        <Parameter name="_theMethod" type="String"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="cae95a8a-c6f2-43bd-9c0d-00e9adaaa131">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/

vars
	txt,
	tmpStr	: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	if self.getMyTerminal &lt;&gt; null then
		tmpStr := self.getMyTerminal.name;
		txt := txt &amp; app.getErrorString(Terminal) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.getBank &lt;&gt; null then
		tmpStr := self.getBank.mailingName;
		txt := txt &amp; app.getErrorString(CM_Business_Unit) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
