    <JadeMethod name="isOutward" id="817039a9-b177-4c0f-894e-1709a807489a">
        <source>isOutward() : Boolean;
/*
Purpose:			

Date		Who		Reason
19 September 2023	navab1	CR 60424 TASK 60549 
*/

vars
	custDocType : CM_CustomDocumentType;
begin
	
	custDocType := self.myCustomDocumentType;
	
	if custDocType &lt;&gt; null then
		return custDocType.isOutward(); // ### TFS CR 60424 TASK 60549 17OCT2023 NAVAB1
	endif;
	
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="7287c3f7-ba73-4e2d-8fc8-db25039f1a00">
        <source>pxyCreateUpdateProxy(): SelfType;
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
vars
	pxySelf : SelfType;
begin
	pxySelf :=  inheritMethod();
	
	pxySelf.myCustomDocumentType := self.myCustomDocumentType;
	pxySelf.myCustomLicense := self.myCustomLicense;
	pxySelf.myCustomsAgent := pxySelf.myCustomsAgent;
	pxySelf.myTerminal := self.myTerminal;
	pxySelf.myHSCode := self.myHSCode;
	
	return pxySelf;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
