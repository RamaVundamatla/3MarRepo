    <JadeMethod name="initialise" id="a3ae4665-097a-4086-9fab-619473d8114d">
        <source>initialise(_bank : CM_Bank);

vars
	theCommodityMap:    CM_CommodityMap;
begin

	//initalise the commodity Map
	theCommodityMap := commoditiesMap[CM_CommodityMap.Default_Commodity_Map_Key];
	if theCommodityMap = null then
		create theCommodityMap;
		theCommodityMap.commodityCode := CM_CommodityMap.Default_Commodity_Map_Key;
		theCommodityMap.contentsMap := self;
	endif;

	theCommodityMap.initialise(_bank);
end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
