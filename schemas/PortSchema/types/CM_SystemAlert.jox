    <JadeMethod name="setMyRemoteDataHdr" id="4bd6fce5-d29d-4c17-a06c-f75e5d294cc0">
        <updating/>
        <source>setMyRemoteDataHdr(_remoteDataHdr : CM_RemoteDataHdr) updating;
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	invalid 		: Boolean;
	
begin
	if _remoteDataHdr &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, _remoteDataHdr, invalid);
		if not _remoteDataHdr.isTransient then
			self.myRemoteDataHdr := _remoteDataHdr;
		endif;
	endif;

end;</source>
        <Parameter name="_remoteDataHdr" type="CM_RemoteDataHdr"/>
    </JadeMethod>
    <JadeMethod name="setMySystemAlertType" id="f06de080-109d-4a01-8843-320caa7e25ef">
