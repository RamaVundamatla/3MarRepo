    <JadeMethod name="tCreateRR" id="291671a9-4be1-485a-b5c1-ad61dcd00e4e">
        <source>tCreateRR();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2025	navnk30	Initial creation

*/

constants
	//XML_File_Name = "C:\Users\navnk30\yara\xml_files\OrderCreate-3.xml";
	//XML_File_Name= "C:\Users\navnk30\yara\xml_files\RR-1006-01-OrderCreate.txt";
	//XML_File_Name= "C:\Users\navnk30\yara\xml_files\OrderCreate-RR-1014-07.txt";
	XML_File_Name = "C:\Users\navnk30\yara\xml_files\OrderCreate_ML_2.txt";
	//XML_File_Name = "C:\Users\navnk30\yara\xml_files\OrderCreate_ML_UnknownProduct.txt";
vars
	file		: File;
	bgpReq		: BGP_AgGatewayWSRequest;
	incomingXML	: String;
	ramTerminal	: CM_Terminal;
begin
	app.initialize();
	app.myPassport.setMyUserFromCode("NAVNK30");
	ramTerminal := "2351.1561".asOid().CM_Terminal;
	app.myPassport.setMyTerminal(ramTerminal);
	create file transient;
	file.fileName := XML_File_Name;
	while not file.endOfFile do
		incomingXML &amp;= file.readLine();
	endwhile;
	
	create bgpReq transient;
	bgpReq.setDetails(incomingXML, ramTerminal, "navnk30", "Nithish");
	bgpReq.action();
	
	
epilog
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateXMLForRR" id="bb90d0b4-5dff-42b0-ab94-36f3e722a20e">
        <source>tCreateXMLForRR();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2025	navnk30	Initial creation

*/

constants
	Tag_Root			= "OrderResponse";
	Tag_Header			= "Header";
	Tag_Body			= "OrderResponseBody";
	To_Do				= "TO_DO";
	Resp_Code_Success	= "000";
	Resp_Desc_Success	= "Order Accepted";
	Resp_Code_Failure	= "999";
vars
    doc  				: JadeXMLDocument;
    rootEle,								//OrderResponse
	headerEle,
	bodyEle,
	orderPropEle,
	orderPartnerEle,
	orderDtlLineNumEle,
	attrEle				: JadeXMLElement;
    dateTimeStr,
	carrierCode,
	consigneeCode,
	carrierDesc,
	consigneeDesc,
	prodDesc,
	prodCode,
	xml  				: String;
	_releaseReq			: CM_BulkRelease;
	dateReq				: Date;
	timeReq				: Time;
	foundMatch			: Boolean;
	product				: CM_Product;
	consignee			: CM_ConsigneeConsignor;
	carrier				: CM_Carrier;
begin
    create doc transient;
    doc.indentString := "  ";
	app.closeWriteWindow();
	
    rootEle		:= doc.addElement(Tag_Root);
	headerEle	:= rootEle.addElement(Tag_Header);
	
	rootEle.addAttribute("Version", "5.0");
	rootEle.addAttributeNS(null, "xmlns", "urn:cidx:names:specification:ces:schema:all:5:0");
	
	_releaseReq := "2161.2054779".asOid().CM_BulkRelease;
	
	consignee := _releaseReq.myConsignee;
	carrier := app.myRoot.allCarriers[_releaseReq.carrierId];
	consigneeDesc := consignee.description;
	carrierDesc := carrier.description;
	consigneeCode	:= _releaseReq.myOperator.getXlationForeignCode(consignee.code, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);
	carrierCode		:= _releaseReq.myOperator.getXlationForeignCode(_releaseReq.carrierId, XLATION_TYPE_CARRIER_BYOP, foundMatch);
	product			:= _releaseReq.getMyProduct();
	prodCode 		:= product.code;																									//configure EDI xlation and use here
	prodCode		:= "NPK-" &amp; prodCode[1:7];
	prodDesc		:= product.description;																								
	dateReq := _releaseReq.dateEstimatedRequired.date;
	timeReq := _releaseReq.dateEstimatedRequired.time;
	dateTimeStr := dateReq.year.String &amp; "-" &amp; dateReq.month.String &amp; "-" &amp; dateReq.day.String &amp; "T" &amp; timeReq.String;
	
	// Header part
	attrEle := headerEle.addElement("ThisDocumentIdentifier");
	attrEle := attrEle.addElement("DocumentIdentifier");
	attrEle.setText("0000000000004220");																						//Hardcoded val, unable to find this in OrderCreate msg
	
	attrEle := headerEle.addElement("ThisDocumentDateTime");
	attrEle := attrEle.addElement("DateTime");
	attrEle.addAttribute("DateTimeQualifier", "On");
	attrEle.setText(dateTimeStr);
	
	attrEle := headerEle.addElement("RequestingDocumentIdentifier");
	attrEle := attrEle.addElement("DocumentIdentifier");
	attrEle.setText(To_Do);																									//addl docId, add to rmrk and get it back
	
	attrEle := headerEle.addElement("RequestingDocumentDateTime");
	attrEle := attrEle.addElement("DateTime");
	attrEle.addAttribute("DateTimeQualifier", "On");
	attrEle.setText(dateTimeStr);
	
	attrEle := headerEle.addElement("From");
	attrEle := attrEle.addElement("PartnerInformation");
	attrEle := attrEle.addElement("PartnerName");
	attrEle.setText("JACKSONVILLE");
	attrEle := headerEle.getElementByTagName("From").getElementByTagName("PartnerInformation").addElement("PartnerIdentifier");
	attrEle.addAttribute("Agency", "AssignedBySeller");
	attrEle.setText("JACK");
	
	attrEle := headerEle.addElement("To");
	attrEle := attrEle.addElement("PartnerInformation");
	attrEle := attrEle.addElement("PartnerName");
	attrEle.setText(_releaseReq.myOperator.description); 																			// should be Yara operator, desc = "YARA NORTH AMERICA, INC" configured
	attrEle := headerEle.getElementByTagName("To").getElementByTagName("PartnerInformation").addElement("PartnerIdentifier");
	attrEle.addAttribute("Agency", "AssignedByBuyer");
	attrEle.setText(To_Do);																										//todo : store assigned by buyer in remarks with | , then retrieve it
	
	
	// OrderResponse Body
	
	bodyEle := rootEle.addElement(Tag_Body);
	
	orderPropEle := bodyEle.addElement("OrderResponseProperties");
	attrEle := orderPropEle.addElement("PurchaseOrderNumber").addElement("DocumentIdentifier");
	attrEle.setText(To_Do);																										//what was originally in releaseReq.remarksAdditional1, need to append with other doc IDs and retrieve
	attrEle := orderPropEle.addElement("PurchaseOrderIssuedDate").addElement("DateTime");
	attrEle.addAttribute("DateTimeQualifier", "On");
	attrEle.setText(dateTimeStr);
	attrEle := orderPropEle.addElement("LanguageCode");
	attrEle.addAttribute("Domain", "ISO-639-2T");																					//hardcoded as of now, must be modified as per reply from Enstructure
	attrEle.setText("eng");
	attrEle := orderPropEle.addElement("CurrencyCode");
	attrEle.addAttribute("Domain", "ISO-4217");
	attrEle.setText("USD");																											//hardcoded as of now, must be modified as per reply from Enstructure
	orderPropEle.addElement("BuyerSequenceNumber").setText("0");																	//always 0?
	orderPropEle.addElement("SellerSequenceNumber").setText("0");																	//always 0?
	attrEle := orderPropEle.addElement("ReferenceInformation");
	attrEle.addAttribute("ReferenceType", "DeliveryNoteNumber");
	attrEle := attrEle.addElement("DocumentReference").addElement("DocumentIdentifier");
	attrEle.setText(_releaseReq.code);
	attrEle := orderPropEle.addElement("TransportMethodCode");																		//hardcoded as of now, must be modified as per reply from Enstructure
	attrEle.addAttribute("Domain", "UN-Rec-19");
	attrEle.setText("3");																											//always releaseReq's type (road)?
	attrEle := orderPropEle.addElement("DeliveryTerms").addElement("DeliveryTermsCode");
	attrEle.addAttribute("Domain", "Incoterms-2000");																				//hardcoded as of now, must be modified as per reply from Enstructure for all elements of DeliveryTerms
	orderPropEle.getElementByTagName("DeliveryTerms")
			.addElement("DeliveryTermsLocation").setText(_releaseReq.myConsignee.getAddress1());									//Eg : SYLACAUGA
	
	
	orderPartnerEle	:= bodyEle.addElement("OrderResponsePartners");
	attrEle := orderPartnerEle.addElement("Buyer").addElement("PartnerInformation").addElement("PartnerName");
	attrEle.setText(consigneeDesc);
	attrEle := orderPartnerEle.findElement("PartnerInformation", "PartnerInformation").addElement("PartnerIdentifier");
	attrEle.addAttribute("Agency", "AssignedBySeller");
	attrEle.setText(consigneeCode);
	
	orderPartnerEle.addElement("Seller").addElement("PartnerInformation").addElement("PartnerName").setText(_releaseReq.myOperator.description);
	attrEle := orderPartnerEle.getElementByTagName("Seller").findElement("PartnerInformation", "PartnerInformation").addElement("PartnerIdentifier");
	attrEle.addAttribute("Agency", "AssignedByBuyer");
	attrEle.setText(To_Do);																										//todo : store assigned by buyer in remarks with | , then retrieve it
	
	
	orderPartnerEle.addElement("Payer").addElement("PartnerInformation").addElement("PartnerName").setText(_releaseReq.myOperator.description);
	attrEle := orderPartnerEle.getElementByTagName("Payer").getElementByTagName("PartnerInformation").addElement("PartnerIdentifier");
	attrEle.addAttribute("Agency", "AssignedByBuyer");
	attrEle.setText(To_Do);																										//todo : store assigned by buyer in remarks with | , then retrieve it
	
	//OrderResponseDetails -&gt; OrderResponseProductLineItem
	orderDtlLineNumEle := bodyEle.addElement("OrderResponseDetails").addElement("OrderResponseProductLineItem");
	orderDtlLineNumEle.addElement("LineNumber").setText("10");																		//hardcoded for now, always 10?
	orderDtlLineNumEle.addElement("PurchaseOrderLineItemNumber").setText("10");														//hardcoded for now, always 10?
	attrEle := orderDtlLineNumEle.addElement("ProductIdentification").addElement("ProductIdentifier");
	attrEle.addAttribute("Agency", "AssignedBySeller");
	attrEle.setText(To_Do);																										//todo: try to get EDI xlation for product
	orderDtlLineNumEle.getElementByTagName("ProductIdentification").addElement("ProductName").setText(prodDesc);
	
	orderDtlLineNumEle.addElement("ReferenceInformation").addElement("DocumentReference").addElement("DocumentIdentifier").setText(_releaseReq.code);
	orderDtlLineNumEle.findElement("ReferenceInformation", "ReferenceInformation").addAttribute("ReferenceType", "DeliveryNoteNumber");
	
	attrEle := orderDtlLineNumEle.addElement("ProductQuantity").addElement("Measurement");
	attrEle.addElement("MeasurementValue").setText(_releaseReq.getTotalWeightRequested());									//todo: set weight val from incoming xml to first reserve dtl and fetch it
	attrEle := attrEle.addElement("UnitOfMeasureCode");
	attrEle.setText("STN");																											//Short ton hardcoded. Always STN?
	attrEle.addAttribute("Domain", "UN-Rec-20");
	
	attrEle := orderDtlLineNumEle.addElement("PackagingQuantity").addElement("Measurement");
	attrEle.addElement("MeasurementValue").setText(_releaseReq.totalRequested.String);
	attrEle := attrEle.addElement("UnitOfMeasureCode");
	attrEle.addAttribute("Domain", "UN-Rec-20");
	attrEle.setText("BBU");
	
	attrEle := orderDtlLineNumEle.addElement("ScheduleDateTimeInformation");
	attrEle.addAttribute("ScheduleType", "RequestedShip");
	attrEle := attrEle.addElement("DateTimeInformation").addElement("DateTime");
	attrEle.addAttribute("DateTimeQualifier", "OnOrAfter");
	attrEle.setText(dateReq.String);
	
	attrEle := orderDtlLineNumEle.addElement("OtherPartner");
	attrEle.addAttribute("PartnerRole", "ShipFrom");
	attrEle := attrEle.addElement("PartnerInformation");
	attrEle.addElement("PartnerName").setText(" JACKSONVILLE ");
	attrEle := attrEle.addElement("PartnerIdentifier");
	attrEle.addAttribute("Agency", "AssignedBySeller");
	attrEle.setText("JAX1");
	
	attrEle := orderDtlLineNumEle.addElement("OtherPartner");
	attrEle.addAttribute("PartnerRole", "ShipTo");
	attrEle := attrEle.addElement("PartnerInformation");
	attrEle.addElement("PartnerName").setText(_releaseReq.myConsignee.description);
	attrEle := attrEle.addElement("PartnerIdentifier");
	attrEle.addAttribute("Agency", "AssignedBySeller");
	attrEle.setText(consigneeCode);
	
	attrEle := orderDtlLineNumEle.addElement("ResponseStatus").addElement("ResponseStatusReasonIdentifier");
	attrEle.addAttribute("Agency", "RAPIDResponseRejectionTable");
	attrEle.setText(Resp_Code_Success);																				//need to make changes for failure as well.
	attrEle := orderDtlLineNumEle.getElementByTagName("ResponseStatus");
	attrEle.addElement("ResponseStatusReasonDescription").setText(Resp_Desc_Success);
	attrEle.addElement("ResponseStatusComments");
	
    xml := doc.writeToString;
    write xml;

    delete doc;
end;
</source>
    </JadeMethod>
