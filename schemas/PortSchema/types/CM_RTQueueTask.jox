    <JadeMethod name="isShipLoadTask" id="d12d1503-6120-4eb0-acde-a78e4ecf5fb8">
        <source>isShipLoadTask() : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 April 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpReq	: CM_Request;
	
begin

	tmpReq := self.getTaskRequest();
	if tmpReq = null then
		return false;
	endif;
	
	if (not tmpReq.isKindOf(CM_SlotRequest)) then
		return false;
	endif;

	return tmpReq.CM_SlotRequest.isLoad;

end;</source>
