        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5e7d69b6-2793-4450-86e0-c0a117eeac1c">
        <updating/>
        <source>setForUpdate(_proxyRORORamp: SelfType;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	
begin
	inheritMethod(_proxyRORORamp,_passport);
	
	self.isMovable:=_proxyRORORamp.isMovable;
	self.length:=_proxyRORORamp.length;
	self.maxClearHeight:=_proxyRORORamp.maxClearHeight;
	self.maxLoadAxel:=_proxyRORORamp.maxLoadAxel;
	self.maxLoadM2:=_proxyRORORamp.maxLoadM2;
	self.maxLoadTotal:=_proxyRORORamp.maxLoadTotal;
	self.width:=_proxyRORORamp.width;
	
	
	if self.myDeck &lt;&gt; null then
		if _proxyRORORamp.pxyGetRealObject =null then
			self.myDeck.causeEvent(EVENT_DECK_ITEM_CREATE,false,self);
		else
			self.myDeck.causeEvent(EVENT_DECK_ITEM_UPDATE,false,self);
		endif;
	endif;
		
epilog

end;</source>
        <Parameter name="_proxyRORORamp" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyRamp" id="228223b5-ae8b-45a6-a302-78c7a7ff47f7">
        <updating/>
        <source>setProxyRamp(	_isMovable : Boolean;
				_length : Decimal;
				_maxClearHeight : Decimal;
				_maxLoadAxel : Decimal;
				_maxLoadM2 : Decimal;
				_maxLoadTotal : Decimal;
				_width : Decimal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin	
	self.isMovable:=_isMovable;
	self.length:=_length;
	self.maxClearHeight:=_maxClearHeight;
	self.maxLoadAxel:=_maxLoadAxel;
	self.maxLoadM2:=_maxLoadM2;
	self.maxLoadTotal:=_maxLoadTotal;
	self.width:=_width;
epilog

end;</source>
        <Parameter name="_isMovable" type="Boolean"/>
        <Parameter name="_length" type="Decimal"/>
        <Parameter name="_maxClearHeight" type="Decimal"/>
        <Parameter name="_maxLoadAxel" type="Decimal"/>
        <Parameter name="_maxLoadM2" type="Decimal"/>
        <Parameter name="_maxLoadTotal" type="Decimal"/>
        <Parameter name="_width" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="testPileHeight" id="3b7c8dc1-2ce3-41d4-a94e-7a18c7c5b038">
        <source>testPileHeight(_ti : CM_TrackedItem);
/*
Purpose:			
Date		Who		Reason
23 September 2011	cnwab1	Initial creation
*/

vars
	heightCM, widthM : Decimal[12,2];
begin

	heightCM := _ti.getActualHeightRaw() / 100;

	if self.maxClearHeight &gt; 0 and heightCM  &gt; self.maxClearHeight then
		app.raiseCMWarning5(Height_exceeds_clear_height, _ti.id, heightCM.asStringJMTWithPrecision(2,false), self.description, self.code, self.maxClearHeight.asStringJMTWithPrecision(2,false), null, null, self);	
	endif;
	
	widthM := _ti.getActualWidthRaw() / 100;
	

	if self.width &gt; 0 and widthM &gt; self.width then
		app.raiseCMWarning5(Widthof_exceeds_maximum_width, _ti.id, widthM.asStringJMTWithPrecision(2,false), self.description, self.code, self.width.asStringJMTWithPrecision(2,false), null, null, self);	
		
	
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="testPileWeight" id="efb9101d-fa23-44db-abd1-4dc40a2b8fa5">
        <source>testPileWeight(_ti : CM_TrackedItem);
/*
Purpose:			
Date		Who		Reason
23 September 2011	cnwab1	Initial creation
*/

vars

begin
	if self.maxLoadTotal &gt; 0  and _ti.totalWeight  &gt; self.maxLoadTotal then
		app.raiseCMWarning5(Weight_exceeds_maximum_load, _ti.id, _ti.totalWeight.asStringWeightJMT(), self.description, self.code, self.maxLoadTotal.asStringWeightJMT(), null, null, self);	
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
