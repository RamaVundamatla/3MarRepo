    <JadeMethod name="addToSpecialStows" id="e789e6ea-6b54-4c85-a33d-f6ef69dc3c43">
        <source>addToSpecialStows(_ti: CM_TrackedItem);
//----------------------------------------------------------------
//	Created:	12 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 28/10/2010	cnwdap1		PAR #26140 Don't show special stow for items where commodity group is not marked as special stow
vars
	ti				: CM_TrackedItem;
	cmif			: CMIF_SpecialStowSummary;
	ssCode,
	odimHazDetail	: String;
begin

	ti := _ti;

	if ti = null
	or (not ti.isSpecialStow()) then
		return;
	endif;
	ssCode := ti.getSpecialStowString();
	// PAR #26140 if ti.getSpecialStowString returns null, this means that
	//     the item's commodity group is not marked as special stow
	// AND the item is not hazardous
	// AND the item is not overdimensions
	// In this circumstance, do not include this item in the special stows (it's probably a reefer, which do not count as special stow)
	if ssCode = null then
		return;
	endif;
	// PAR #26140 end
	
	// 22/09/2008 cnwar2 #17980/CCMS1619
	if ti.height &lt;&gt; 0 or ti.length &lt;&gt; 0 or ti.width &lt;&gt; 0 then
		odimHazDetail := "HEIGHT " &amp; ti.height.asStringJMT &amp; "; LENGTH " &amp; ti.length.asStringJMT &amp; "; WIDTH " &amp; ti.width.asStringJMT &amp; ";    ";
	endif;
	if not ti.allTIHazards.isEmpty then
		odimHazDetail := odimHazDetail &amp; ti.getHazardsAsString;
	endif;
	odimHazDetail := odimHazDetail.truncatedAt(60);
	
	cmif := self.allSpecialStowSumObjects[ti.dischargePort, ssCode, odimHazDetail];
	
	if cmif = null then
		create cmif transient;
		cmif.ssCode 		:= ssCode;
		cmif.dischPort 		:= ti.dischargePort;
		cmif.odimHazDetail	:= odimHazDetail;		// 22/09/2008 cnwar2 #17980/CCMS1619
		self.allSpecialStowSumObjects.add(cmif);
	endif;
	
	cmif.setFromTI(_ti);
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="d83fc5b2-8ac4-46cc-91dc-cb70c84753fb">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	22 December 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ti			: CM_TrackedItem;
	breakOut	: Boolean;
begin
	if self.getMyVoyage = null then
		
		return;
	endif;

	//notified exp cargo
	foreach ti in self.getMyVoyage.allNotifiedTIsByCargoTypeId discreteLock where ti.cargoType = TI_CargoType_Container do
		if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//		if self.includesObject(ti, _passport, breakOut) then
			if not _collection.includes(ti) then
				_collection.add(ti);
				self.addToSpecialStows(ti);
			endif;
		endif;
//		if breakOut then
//			return;
//		endif;
	endforeach;

	//onsite exp cargo
	foreach ti in self.getMyVoyage.allOnsiteTIsByCargoTypeId discreteLock where ti.cargoType = TI_CargoType_Container do
		if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//		if self.includesObject(ti, _passport, breakOut) then
			if not _collection.includes(ti) then
				_collection.add(ti);
				self.addToSpecialStows(ti);
			endif;
		endif;
//		if breakOut then
//			return;
//		endif;
	endforeach;

	//onship exp cargo
	foreach ti in self.getMyVoyage.allOnshipTIsByCargoTypeId discreteLock where ti.cargoType = TI_CargoType_Container do
		if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//		if self.includesObject(ti, _passport, breakOut) then
			if not _collection.includes(ti) then
				_collection.add(ti);
				self.addToSpecialStows(ti);
			endif;
		endif;
//		if breakOut then
//			return;
//		endif;
	endforeach;


	//onship exp tranship cargo added 19/7/06 epr CCMS 1011
	foreach ti in self.getMyVoyage.allTranshipTIsExport discreteLock where ti.cargoType = TI_CargoType_Container do
		if self.checkStatusIncludesObject(ti, _passport, breakOut) then
			if not _collection.includes(ti) then
				_collection.add(ti);
				self.addToSpecialStows(ti);
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="47147a08-924c-4084-83c9-e1a13ad0b22f">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------
//	Created:	22 December 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
// 14/10/2010	cnwdap1		PAR #26001 Correct tranship handling
vars

begin
	//if _ti.isExport 									// PAR #25021
	//if (_ti.isExport or _ti.isTranshipOutbound) 		// PAR #25021					// PAR #26001
	if (_ti.isExport or (_ti.isTranshipItem and _ti.myExportVoyage = self.getMyVoyage)) 	// PAR #26001
	and ((not _ti.isRehandle) or (_ti.isARework))
	and inheritMethod(_ti, _passport, _breakOut) then
		return true;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setJRWXML" id="a0d8af7b-d5d5-4eff-a6dc-c197c30713f9">
        <updating/>
        <source>setJRWXML(_jrwTransient: CM_JRWTrackedItems input) updating;
//----------------------------------------------------------------
//	Created:	12 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	cmif		: CMIF_SpecialStowSummary;
	lastDisch	: String;
	firstTime	: Boolean;
	xml			: String;
	edition : Integer;	//18 July 2016	NDL	TFS 2329
	invalid : Boolean;	//18 July 2016	NDL	TFS 2329
begin

	lastDisch := "###";
	firstTime := true;
	
	
	on Exception do app.handleDeletedObject( exception, cmif, invalid );
	
	foreach cmif in self.allSpecialStowSumObjects do
		
		//18 July 2016	NDL	TFS 2329
		invalid := false;
		edition := cmif.edition;
		if invalid then
			continue;
		endif;
		
		//change of dischargePort?
		if cmif.dischPort &lt;&gt; lastDisch then
			if not firstTime then
				//end the previous group
				xml := xml &amp; "&lt;/ss&gt;" &amp; CrLf &amp; "&lt;/" &amp; lastDisch &amp; "&gt;" &amp; CrLf;
			endif;
		//	dischCode := cmif.dischPort;
			lastDisch := cmif.dischPort;
			xml := xml &amp; "&lt;" &amp; cmif.dischPort &amp; "&gt;" &amp; CrLf
										&amp; "&lt;ss&gt;" &amp; CrLf;
		endif;
		xml := xml &amp; cmif.displayString;
		firstTime := false;
	endforeach;
	
	//end the last group
	xml := xml &amp; "&lt;/ss&gt;" &amp; CrLf &amp; "&lt;/" &amp; lastDisch &amp; "&gt;" &amp; CrLf;
				
	_jrwTransient.strCodedXML := xml;

end;</source>
        <Parameter name="_jrwTransient" type="CM_JRWTrackedItems" usage="input"/>
    </JadeMethod>
</Class>
