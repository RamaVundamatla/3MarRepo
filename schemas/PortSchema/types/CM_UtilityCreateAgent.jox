        <source>utlCreateFileCategory(_pxyFileDataCategory : CM_FileDataCategory input;
					  _realFileDataCategory : CM_FileDataCategory output;
					  _passport : CM_Passport input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
29/11/2022 navmv20 TFS CR 55299 TASK 55516: Jade - Write TRX for new file category

*/
vars

begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyFileDataCategory, 'File Data Category Proxy');
	_pxyFileDataCategory.validateForCreate();
	
	create _realFileDataCategory persistent;
	_realFileDataCategory.setForCreate(_pxyFileDataCategory);
	
