<Class name="CM_EnqControllerTI">
    <JadeMethod name="isInContext" id="84bb46aa-28a0-4435-ae7a-013558d43027">
        <source>isInContext(_value: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2014	cnwndl1	Initial creation	Par 34625

*/

vars

begin

	if _value = self.CargoEnquiryForm then
		if self.myContext &lt;&gt; null and self.myContext.isKindOf(CM_ContainerEnqForm) then
			return true;
		else
			return false;
		endif;
	endif;
	
	return inheritMethod(_value);

epilog

end;</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
