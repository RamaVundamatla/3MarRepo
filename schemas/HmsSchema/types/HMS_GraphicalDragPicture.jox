    <JadeMethod name="mouseMove" id="6b2da687-7236-4fea-96aa-c73c202ff824">
        <controlMethod name="Picture::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseMove(dragPic: HMS_GraphicalDragPicture input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     04 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	timeNow			: TimeStamp;	
	viewForm		: HMS_GraphicalViewX;
begin

	viewForm := self.myGraphicalViewForm;

	if button = 0 then
		// no button is down
		// need to check if near the edge and change cursor accordingly to
		// indicate if the user can resize or not.
		if self.getEdge(x, y) &lt;&gt; HMS_Edge_None then
			app.mousePointer := MousePointer_NS;	// the resize cursor
		else
			app.mousePointer := MousePointer_Default;
		endif;
		
		self.getBubbleHelpCaption();
		return;
	endif;

	dragPic.zOrder(1);
	
	if viewForm.isReadOnly then
		// user does not have permission to move sprite
		return;			
	elseif self.myWorkingVoyage.voyageStatus = HMS_VoyageIsLocked then
		// voyage is locked and cannot be moved	
		return;	
	elseif viewForm.myCurrentWorkingMovement &lt;&gt; null then
		if viewForm.myCurrentWorkingMovement.myWorkingVoyage.voyageStatus = HMS_VoyageIsLocked then
			// voyage is locked and cannot be moved
			return;
		endif;
	endif;
		
	// want to move the sprite - only if mouse has moved past the debounce threshold
	if (not dragPic.isDragging) then
		// check if the mouse pointer has escaped the 'mouse debounce' zone - if it has, allow movement of sprite
		if ((dragPic.origXOffset-x).abs &gt; HMS_GraphicalViewX.Drag_Start_Threshold
		or (dragPic.origYOffset-y).abs &gt; HMS_GraphicalViewX.Drag_Start_Threshold)
		and viewForm.controlMoveStyle &lt;&gt; HMS_GraphicalViewX.Move_None then
			
			dragPic.isDragging := true;

			if dragPic.origEdge &lt;&gt; HMS_Edge_None then
				app.mousePointer := MousePointer_NS;
			else
				app.mousePointer := MousePointer_Size;
			endif;

			// Notify controller that a movement is being added or edited
			// - delay any database updates until user finishes this action
			viewForm.myViewController.set_AddEditMovementActiveState(true);
		endif;
		
		return; 
		  
	endif;

	// move the sprite
	if dragPic.isDragging then

		if viewForm.isReadOnly then
			// no access rights to move sprite
			app.msgBox(app.getErrorString1(VB_SECMOVE,"Harbour Management Graphical View"), "Security",MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			return;										
		endif;
		
		if app.mousePointer &lt;&gt; MousePointer_NS then
			app.mousePointer := MousePointer_Size;
		endif;

		dragPic.moveControl(x,y, self.vesselLengthOverall, viewForm.controlMoveStyle);

		// Restrict speed of updates for position so that 
		// sprite does not start shadowing
		if (timeNow - viewForm.timeIncrementSensitivity) &gt; viewForm.lastSpritePosnUpdateTime then
			// Update posn indication;
			viewForm.lastSpritePosnUpdateTime := timeNow;
 			viewForm.showSpritePositionDetails(dragPic);
 		endif;

	endif;
	
end;</source>
        <Parameter name="dragPic" type="HMS_GraphicalDragPicture" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="22f04855-d7eb-4e94-9d01-aa107eba66d3">
