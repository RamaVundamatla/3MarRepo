/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation

*/

vars

begin

	self.doPrintOutTable(	self.tblCalendar,	//_dataTable: Table input;
							app.getErrorString(Calendar),	//_headerStr: String;
							true,	//_preview: Boolean;
							true,	//_whiteBG: Boolean;
							false,	//_useOrigTableColumnWidths: Boolean;
							( self.cmbPeriod.text = ByDay ).Boolean	//_portrait: Boolean
							);


epilog

end;</source>
