    <JadeMethod name="includeVoyage" id="45371098-5167-452b-ab80-385cd880c701">
        <source>includeVoyage(_camProtocol: CM_CamProtocol; _voyage: CM_Voyage; _trx :CM_Transaction; _camAgent : CM_CamControllerAgent; _logExcluded: Boolean): Boolean protected;
/*
Date		Who		Reason
27/06/2012	cnwcs5	Initial creation - par 29601
*/
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
vars
	result	:Boolean;
begin
	result := _voyage.isCellularVoyage or _voyage.isNullVoyage;
	
	if not result and _logExcluded then
		_camAgent.logReasonForExclusion (_trx, 'Voyage is not cellular or null voyage');
	endif;
	
	return result;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_trx" type="CM_Transaction"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_logExcluded" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="outputFile" id="62ec2951-8d1f-4fe4-9fbd-cad7d75b25fd">
        <updating/>
        <source>outputFile(_protocol : CM_CamProtocol input; _camAgent : CM_CamControllerAgent; _camFile : CM_CamFile input; _runDateTime : TimeStamp; _camTaskHistory : CM_CamTaskHistory input;
		   _unhSeqNumber : Integer io; _seqNumber : Integer; _terminal : CM_Terminal; _contextObj : CM_Object; _transactions : CM_TITransactionSet) updating;
// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camFile/_camTaskHistory parameter usage from io to input
// 18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 30 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 19/12/2012	cnwcs5 CCMS SFW 1294 /par 30855
// 25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
// 09 Jan 2020 	jlgdap1	TFS 48016 SNO Deletion CODECO - new _transactions parameter
vars
	camVoyage	: CM_CamVoyage;
	camMessage	: CM_CamMessage;
	str			: String;
	i			: Integer;
	strLine : String;
begin
	app.writeLog("===================================", LogWARN);

	if _camFile.camVoyages.size &gt; 0 then
		foreach camVoyage in _camFile.camVoyages do
			foreach camMessage in camVoyage.camMessages do
				i := 1;
				while i &lt; camMessage.group3.size+1 do
					str := null;
					
					str := camMessage.group3[i].String;
					strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, str, null);
					
					str := camMessage.group4[i].String;
					strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, str, null);
					
					str := camMessage.group5[i].String;
					strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, str, null);
					
					i := i + 1;
					
					_camFile.incrementMessageCount();
				endwhile;

			endforeach;
		endforeach;
	endif;
	
	app.writeLog("===================================", LogWARN);
	_camTaskHistory.setRawDataString(strLine);
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="outputFileMessage" id="28ced838-c2ae-40c0-a5b4-e30f36ef55a1">
        <updating/>
        <source>outputFileMessage(_camTaskHistory: CM_CamTaskHistory input; _message: String; _coll :HugeStringArray input) : String updating;
//
// cnwrs1 Apr 2007 this is for non UN/EDIFACT lines PAR 13832
// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camTaskHistory parameter usage from io to input
// 19/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//29 Sep 2015	cnwrs1	Par 35544 - Change Cams task hisoty to use JadeBytes  
vars
	str	:String;
begin
//	_camTaskHistory.addFileDataLineRAW(_message);
	
	str := _message;
	
	if _coll &lt;&gt; null then
//		if str.length &gt; 60 then
//			str := str [1:60];
//		endif;
		
		_coll.add (str);
	endif;
	
	return str;
end;
</source>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setStatus" id="dcea2ade-8162-43f1-b0f9-ea1eb53f3cc1">
        <source>setStatus(_trans:CM_TITransaction):Integer;

vars
	status:Integer;
	theTI:CM_TrackedItem;
begin
	theTI := _trans.myTrackedItem;
	if theTI.isRehandle or theTI.isSOB then
		return null;
	endif;
	if _trans.isCamsRoadReceiveType() or
	   _trans.isCamsRailReceiveType() then
		if theTI.isExport then
			status := RCVF;	//export recived at gate
		else
			status := RCVD; //anything else received at gate
		endif;
	elseif _trans.type = TRANS_TYPE_DAMAGED then
		status := SNTR;
	elseif _trans.type = TRANS_TYPE_DAIRY then
		status := RCDB;
	elseif _trans.isCamsRoadReleaseType() or
	   _trans.isCamsRailReleaseType()then
		if _trans.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
			if theTI.deliveryReleaseReason = DEL_SNT then
				status := SNTS;
			elseif theTI.deliveryReleaseReason = DEL_NIB or
				   theTI.deliveryReleaseReason = DEL_TSC or
				   theTI.deliveryReleaseReason = DEL_IST then
				status := TRFE;
			endif;
		else
			if theTI.deliveryReleaseReason = DEL_NULL then
				status := SNTC;
			else
				status := TRFF;
			endif;
		endif;
	elseif _trans.isCamsShipReceiveType() then
		if _trans.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
			status := DCHE;
		else
			status := DCHF;
		endif;
	elseif _trans.isCamsShipReleaseType() then
		if _trans.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
			status := LODE;
		else
			status := LODF;
		endif;
	//elseif _trans.class = CM_Edit then
	elseif _trans.isCamsEditType() then		// PAR 13509
		status := self.checkEditTransaction(_trans);
	elseif _trans.affectsTIAvailability() then
	//elseif _trans.class = CM_ToDoTask then  -  not going to happen, not sending RCVA!  PAR 9050
		if theTI.isAvailable and
		   not theTI.CM_Container.dairyBoardAvailable then
	   		status := RCVA;
		endif;
	endif;
	return status;
end;</source>
        <Parameter name="_trans" type="CM_TITransaction"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="statusString" id="a232a451-d187-4025-9a2d-d500b8552e8a">
        <source>statusString(_status:Integer):String;

vars
	statusCode:String;
begin
	if _status = DCHE then
		statusCode := "DCHE";
	elseif _status = DCHF then
		statusCode := "DCHF";
	elseif _status = DIIN then
		statusCode := "DIIN";
	elseif _status = DIOU then
		statusCode := "DIOU";
	elseif _status = DVAN then
		statusCode := "DVAN";
	elseif _status = LODE then
		statusCode := "LODE";
	elseif _status = LODF then
		statusCode := "LODF";
	elseif _status = LVAN then
		statusCode := "LVAN";
	elseif _status = OFH1 then
		statusCode := "OFH1";
	elseif _status = OFHR then
		statusCode := "OFHR";
	elseif _status = ON002 then
		statusCode := "ON002";
	elseif _status = ONHI then
		statusCode := "ONHI";
	elseif _status = ONHR then
		statusCode := "ONHR";
	elseif _status = RATE then
		statusCode := "RATE";
	elseif _status = RATF then
		statusCode := "RATF";
	elseif _status = RCDB then
		statusCode := "RCDB";
	elseif _status = RCVA then
		statusCode := "RCVA";
	elseif _status = RCVD then
		statusCode := "RCVD";
	elseif _status = RCVF then
		statusCode := "RCVF";
	elseif _status = SBRO then
		statusCode := "SBRO";
	elseif _status = SNTC then
		statusCode := "SNTC";
	elseif _status = SNTE then
		statusCode := "SNTE";
	elseif _status = SNTR then
		statusCode := "SNTR";
	elseif _status = SNTS then
		statusCode := "SNTS";
	elseif _status = SUBI then
		statusCode := "SUBI";
	elseif _status = SUBO then
		statusCode := "SUBO";
	elseif _status = SUBR then
		statusCode := "SUBR";
	elseif _status = TRFE then
		statusCode := "TRFE";
	elseif _status = TRFF then
		statusCode := "TRFF";
	endif;
	return statusCode;
end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
