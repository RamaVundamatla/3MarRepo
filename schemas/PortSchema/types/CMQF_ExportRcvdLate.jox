<Class name="CMQF_ExportRcvdLate" id="604405c8-b7c0-48e3-9ce0-01ef0bfb581a">
    <superclass name="CMQF_Export"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="4ab1f54a-5909-4e30-b95d-a9d8d4bfd5f4">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	20 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	ti			: CM_TrackedItem;
	breakOut	: Boolean;
begin
	//need a voyage
	if self.getMyVoyage &lt;&gt; null then
	
		foreach ti in self.getMyVoyage.allOnshipTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
			
//			if breakOut then
//				return;
//			endif;
		endforeach;
		
		foreach ti in self.getMyVoyage.allOnsiteTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
			
//			if breakOut then
//				return;
//			endif;
		endforeach;
		
		foreach ti in self.getMyVoyage.allOffloadedTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
			
//			if breakOut then
//				return;
//			endif;
		endforeach;		
	endif;
		

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="fde68eed-1170-491c-a962-44903b1d825a">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------
//	Created:	20 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.tiIsLate(_ti) and 
	inheritMethod(_ti, _passport, _breakOut) then
		return true;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="997439d1-1935-4360-8848-9ebe928bb177">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData: CM_EventDataByTypeDict) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 03 August 2007
//
//----------------------------------------------------------------------

vars

	eventData : CM_EventDataVoyage;

begin
	inheritMethod(_obj, _runDate, _allEventData);
	
	// Get the event data again. If we have one then just make sure it is the same 
	// one that was set above. If it is then we are allowed to grap the data and time off
	// the voyage.
	
	// We double check because if there is no event data then this method must have been called as
	// a standard bgp report and the dates could be being passed in via the background gui settings.
	/*eventData := _allEventData[EventDataVoyage].CM_EventDataVoyage;
	if eventData &lt;&gt; null and eventData.myVoyage &lt;&gt; null then
		if self.myVoyage = eventData.myVoyage then
			self.onDate := self.myVoyage.cutOffDT.date;
			self.onTime := self.myVoyage.cutOffDT.time;
		endif;
	endif;*/
	// 12/11/2009 cnwar2 #21574 - commented.  cutoff date now calculated in tiIsLate
end;</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
    <JadeMethod name="tiIsLate" id="23557029-3b41-46b6-a5b4-158b683aff48">
        <source>tiIsLate(_ti: CM_TrackedItem): Boolean;
//----------------------------------------------------------------
//	Created:	20 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ts : TimeStamp;
begin
	/*if self.getOnTimeStamp.cnEcIsLessThanOrEqual(_ti.receivedDT) then	//late
		return true;
	endif;
	
	if CM_Container.hasInstance(_ti) and 
	self.getOnTimeStamp.cnEcIsLessThanOrEqual(_ti.CM_Container.packedDT) then	//also late
		return true;
	endif;*/
		
							// 12/11/2009 cnwar2 #21574
	ts := _ti.cutoffTS;		// Get cutoff date/time corresponding to ti and voyage
	if ts.isValid() then
		if ts.cnEcIsLessThanOrEqual(_ti.receivedDT) then	//late
			return true;
		endif;
		
		if CM_Container.hasInstance(_ti) and 
		ts.cnEcIsLessThanOrEqual(_ti.CM_Container.packedDT) then	//also late
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
