    <JadeMethod name="reProcessSapResponse" id="9b5c1ac9-ed05-4394-bcd9-7a0e0c528685">
        <source>reProcessSapResponse( _extInterface : CM_ActivityHistoryExtInterface input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2019	jlgndl1	Initial creation	TFS 46758

*/

vars

	cmifSapHelper : CMIF_SAPWSHelper;
	msg : String;
	errorString : String;

begin

	if not app.myCurrentUserCan( self.myTerminal, PmInvSAPReprocess ) then
		msg := app.getErrorString(ERR_dontHaveAccessToThisItem);
		return;
	endif;
	if _extInterface = null then
		msg := app.getErrorString(Activity_history_selected);
		return;
	endif;
	if not _extInterface.canReprocessSapResponse then
		msg := app.getErrorString(Repro_not_valid_selec_activ_hi);
		return;
	endif;
	
	//good enough to try
	create cmifSapHelper transient;
	cmifSapHelper.setFromActivityHistory( _extInterface );
	
	if not cmifSapHelper.handleSAPResponseReprocess( _extInterface, errorString ) then
		if errorString &lt;&gt; null then
			msg := errorString;
		else
			msg := app.getErrorString(Reprocessing_failed) &amp; CrLf &amp; app.getErrorString(Check_activity_history);
		endif;
	endif;
	
epilog

	if msg &lt;&gt; null then
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
	endif;

	delete cmifSapHelper;

end;</source>
        <Parameter name="_extInterface" type="CM_ActivityHistoryExtInterface" usage="input"/>
    </JadeMethod>
    <JadeMethod name="searcherShowHideControls" id="9493741d-4f4a-43ab-9a93-fb14af3843a6">
        <source>searcherShowHideControls(_hide : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 November 2008	cnwjk3	PAR 18356 

*/

vars

begin
	self.btnPrint.enabled := _hide;
	self.btnShowSearcher.enabled := _hide;
	self.btnTerminal.enabled := _hide;
	self.btnSystem.enabled := _hide;
	self.btnAll.enabled := _hide;
	self.btnGeneral.enabled := _hide;
	self.btnEmail.enabled := _hide;
	self.btnCams.enabled := _hide;
	self.btnEDI.enabled := _hide;
	self.btnGarbage.enabled := _hide;
	self.btnExtInterface.enabled := _hide;		//17 Apr 2018	NDL	TFS 38135
	/*		LoadRite button no longer being used 
	if app.getMyUser.canDo(self.myTerminal, PmInMachineWeighing) then
		self.btnLoadrite.enabled := _hide;
	endif;
	*/
	self.btnDelete.enabled := _hide;
	self.btnRefresh.enabled := _hide;
	self.btnCancelBase.enabled := _hide;


	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled := false;
	endif;

end;</source>
        <Parameter name="_hide" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDisplaySystem" id="aeeceb78-4d09-402b-a954-c83cad9e959f">
        <updating/>
        <source>setDisplaySystem() updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTerminal	: CM_Terminal;
	isBoth		: Boolean;

begin
	self.haveToldUserTableActivityFull := false;	// 16 July 2010	NDL	Par 17868
	self.displayType := 0;
	self.endNotificationForSubscriber(self);
	if self.btnTerminal.value then
		tmpTerminal := self.myTerminal;
		self.beginNotification(tmpTerminal, tmpTerminal.getTerminalEvent(EventTerminalActivityAdd), Response_Continuous, null);
		self.beginNotification(tmpTerminal, tmpTerminal.getTerminalEvent(EventTerminalActivityDelete), Response_Continuous, null);
		self.displayType := DISPLAY_TERMINAL;
		isBoth := true;
	endif;
	
	if self.btnSystem.value then
		self.beginNotification(app.myRoot, EventSystemActivityAdd, Response_Continuous, null);
		self.beginNotification(app.myRoot, EventSystemActivityDelete, Response_Continuous, null);
		if isBoth then
			self.displayType := DISPLAY_BOTH;
		else
			self.displayType := DISPLAY_SYSTEM;
		endif;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFormCaption" id="6d0b3f7b-549e-4ab8-b551-131f7d0a58f5">
        <updating/>
        <source>setFormCaption(_count : Integer) updating;
// Feb 2012 from 28754 factor out updating the form caption from both query and notifications

vars
	dateStr,
	str	: String;
	systemFrom,
	systemTo,
	localFrom,
	localTo: TimeStamp;
begin

    if self.queryDateFrom.isValid and
       self.queryDateTo.isValid then
		systemFrom.setDate(self.queryDateFrom);	//	cnwmp6	TFS 488 - Multi timezone changes 13/4/2016
		systemFrom.setTime(self.queryTimeFrom);
		systemTo.setDate(self.queryDateTo);
		systemTo.setTime(self.queryTimeTo);
		localFrom := self.systemToLocalTime(systemFrom);
		localTo := self.systemToLocalTime(systemTo);
		dateStr := localFrom.Date.shortFormatJMT &amp; " " &amp; localFrom.Time.shortFormatJMT
					&amp; '-' &amp; localTo.Date.shortFormatJMT &amp; " " &amp; localTo.Time.shortFormatJMT;
    endif;
	
	if self.displayType = DISPLAY_SYSTEM then
        self.setCaption(app.getErrorString2(Global_System_Activity_Date, _count.String, dateStr));
	elseif self.displayType = DISPLAY_TERMINAL then
        self.setCaption(app.getErrorString2(Terminal_Activity_History_Date, _count.String, dateStr));
	elseif self.displayType = DISPLAY_BOTH then
        self.setCaption(app.getErrorString2(Terminal_And_Global_Date, _count.String, dateStr));
	else
		str := app.getErrorString(Select_Activity_View);
		self.setCaption(str);
	endif;

end;</source>
        <Parameter name="_count" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setPreSelected" id="0e554b95-7b86-4736-bc0d-ba8d440027fb">
        <updating/>
        <source>setPreSelected( _coll : CM_ActivityByCreatedTsTypeDict ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2018	jlgndl1	Initial creation	TFS 42116

*/

vars

begin

	self.allPreSelected.clear();

	if _coll &lt;&gt; null and not _coll.isEmpty then
		_coll.copy( self.allPreSelected );
	endif;
	
	self.isPreSelected := true;

epilog

end;</source>
        <Parameter name="_coll" type="CM_ActivityByCreatedTsTypeDict"/>
    </JadeMethod>
    <JadeMethod name="setQueryDefaults" id="7ad6e3b1-04ba-4b1f-a85f-72821c380cac">
        <updating/>
        <source>setQueryDefaults() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 November 2008	cnwjk3	Initial creation
13/4/2016	cnwmp6	TFS 488 - Multi timezone changes
*/

vars
	systemFrom,
	systemTo,
	localFrom,
	localTo:	TimeStamp;
begin
	systemTo := app.actualTimeServer();
	localTo := self.systemToLocalTime(systemTo);
	localFrom := localTo;
	localFrom.setTime("0:00:00".Time);
	systemFrom := self.localToSystemTime(localFrom);

	self.queryDateFrom := systemFrom.Date;
	self.queryTimeFrom := systemFrom.Time;
	self.queryDateTo := systemTo.Date;
	self.queryTimeTo := systemTo.Time;

	self.tblQuery.setValueByName(ETRow_DateFrom, localFrom.Date);
	self.tblQuery.setValueByName(ETRow_TimeFrom, localFrom.Time);//27 Oct 2011	NDL	Par 28449
	
	//20 Sep 2019	NDL TFS 46655
	self.tblQuery.setValueByName(ETRow_SearchString, null);
	if app.getMyUser.isSuperUser or app.isSpecial then
		self.tblQuery.showRowByName( ETRow_SearchString, false );
	else
		self.tblQuery.hideRowByName( ETRow_SearchString, false );
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setQueryValues" id="00b6a18d-822b-4df0-b4fb-094cdd4d9c8a">
        <updating/>
        <source>setQueryValues() : Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 November 2008	cnwjk3	Initial creation
13/4/2016	cnwmp6	TFS 488 - Multi timezone changes
*/

vars
	localFrom,
	localTo,
	systemFrom,
	systemTo:	TimeStamp;
	rowIndex : Integer;
begin

	localFrom.setDate(self.tblQuery.getValueByName(ETRow_DateFrom).Date);
	localFrom.setTime(self.tblQuery.getValueByName(ETRow_TimeFrom).Time);
	localTo.setDate(self.tblQuery.getValueByName(ETRow_DateTo).Date);
	localTo.setTime(self.tblQuery.getValueByName(ETRow_TimeTo).Time);
	// TFS 3294 add date range validation
	if (localTo &lt;&gt; null and localTo.isValid) and localFrom &gt; localTo then
		app.raiseCMException(Date_from_before_to, null, null);
		return false;
	endif;
	
	systemFrom := self.localToSystemTime(localFrom);
	if localTo = null or not localTo.isValid then
		systemTo := app.actualTimeAppServer;
	else
		systemTo := self.localToSystemTime(localTo);
	endif;

	
	self.queryDateFrom := systemFrom.Date;
	self.queryTimeFrom := systemFrom.Time;
	self.queryDateTo := systemTo.Date;
	self.queryTimeTo := systemTo.Time;
	
	//20 Sep 2019	NDL TFS 46655
	rowIndex := self.tblQuery.getRowByName(ETRow_SearchString);
	if rowIndex &gt; 1 and self.tblQuery.accessRow( rowIndex ).visible then
		self.queryString := self.tblQuery.getValueByName(ETRow_SearchString).String.trimBlanks;
	else
		self.queryString := null;
	endif;
	
	self.queryInitiated := app.actualTimeServer;
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
