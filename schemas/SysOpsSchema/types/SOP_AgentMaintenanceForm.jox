        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="2b7a4073-e4c6-46d1-b3e8-3c687f88642a">
        <updating/>
        <source>doDelete() updating, protected;
// delete both agent and debtor
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 10/06/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
vars
	theReturn	: Integer;
	index		: Integer;
	label	: String;
	object		: CM_Object;
	consigneeor	: CM_ConsigneeConsignor;
	customsAgent	: CM_CustomsAgent;
	stevedore	: CM_Stevedore;					// TFS 44554
	debtor	: CM_DebtorNode;
begin

	object := self.cmbAgent.listObject.CM_Object;
	if object = null then
		return;
	endif;
	index := self.cmbAgent.listIndex;
	
	if object.isKindOf(CM_ConsigneeConsignor) then
		consigneeor := object.CM_ConsigneeConsignor;
		debtor := consigneeor.debtor;
		label := self.myAgentType.description &amp; " '" &amp; consigneeor.description &amp; "'";
		if debtor &lt;&gt; null then
			if debtor.CM_Debtor.hasNoOtherRelatedEntities(consigneeor) then
				label := label &amp; " and debtor '" &amp; debtor.name &amp; "'";
			else
				debtor := null;			// to stop deleting it below
			endif;
		endif;
		label := label &amp; " ?";
	elseif object.isKindOf(CM_CustomsAgent) then
		customsAgent := object.CM_CustomsAgent;
		debtor := customsAgent.myDebtor;
		label := self.myAgentType.description &amp; " '" &amp; customsAgent.name &amp; "'";
		if debtor &lt;&gt; null then
			if debtor.CM_Debtor.hasNoOtherRelatedEntities(customsAgent) then
				label := label &amp; " and debtor '" &amp; debtor.name &amp; "'";
			else
				debtor := null;			// to stop deleting it below
			endif;
		endif;
		label := label &amp; " ?";
		
	// TFS 44554
	elseif object.isKindOf(CM_Stevedore) then
		stevedore := object.CM_Stevedore;
		debtor := stevedore.myDebtor;
		label := self.myAgentType.description &amp; " '" &amp; stevedore.description &amp; "'";
		if debtor &lt;&gt; null then
			if debtor.CM_Debtor.hasNoOtherRelatedEntities(stevedore) then
				label := label &amp; " and debtor '" &amp; debtor.name &amp; "'";
			else
				debtor := null;			// to stop deleting it below
			endif;
		endif;
		label := label &amp; " ?";
	// TFS 44554
	
	endif;

	if app.msgBox(app.getErrorString1(Lit_Confirm_Delete,  label), app.getErrorString(Confirm_Delete), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;

	while true do
		while true do
			// check status after this trx so errors here are not lost
			if debtor &lt;&gt; null then
				app.myTrxDA.trxDeleteDebtorNode(debtor, app.myPassport);
				if not app.myPassport.trxCompletedOK then
					break;
				endif;
			endif;
			if consigneeor &lt;&gt; null then
				app.myTrxDA.trxDeleteConsigneeConsignor(consigneeor, app.myPassport);
			endif;
			if customsAgent &lt;&gt; null then
				app.myTrxDA.trxDeleteCustomsAgent(customsAgent, app.myPassport);
			endif;
			break;
		endwhile;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			// remove agent from combo and table
			self.cmbAgent.removeItem(index);
			if index &lt;= self.cmbAgent.listCount then
				self.cmbAgent.listIndex := index;
				self.cmbAgent_click(self.cmbAgent);		// refresh with the next agent
			else
				self.tblAgents.clearValues();
			endif;
			self.enableToolbarButtons();
			return ;
		else
			theReturn := app.showErrorWarningDialog(self.myAgentType.description &amp; "/Debtor Delete", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			return ;
		endif;
		break;
	endwhile;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEdit" id="7e1d5dca-c80d-4e77-be6f-f75bcf9031e9">
        <updating/>
        <source>doEdit() updating, protected;
// enable the table to be edited, set the toolbar buttons
vars

begin
	self.mode := self.Mode_Update;
	self.btnSaveBase.enabled := true;
	self.btnEdit.enabled := false;
	self.btnDelete.enabled := false;
	self.btnNew.enabled := false;
	self.btnChangeDebtor.enabled := true;

	self.tblAgents.userInputEnabled := true;
	self.tblAgents.row := 1;
	self.tblAgents.setFocus();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNew" id="d7de81fa-b9e8-4494-bafe-87ea1bb5ec46">
        <updating/>
        <source>doNew() updating, protected;
// clear the table and set Add mode.  Default the 'is consignee' etc options based on selected type.
vars
	addressRow	: Integer;
	table		: CM_EntryTable;
begin
	self.mode := self.Mode_Add;
	table := self.tblAgents;
	table.clearValues();
	if self.myAgentType.code = "SDT2" or			// consignee
	   self.myAgentType.code = "SDT3" then		// consignor
		table.setValueByName(ETRow_IsConsignor, true);
		table.setValueByName(ETRow_IsConsignee, true);
	endif;
	if self.myAgentType.code = "SDT7" then		// freight forwarder
		table.setValueByName(ETRow_IsFreightFwdr, true);
	endif;
	
	// set the address row height for easier multi-line entry
	addressRow := table.getRow(ETRow_Address);
	if table.rowHeight[addressRow] &lt; 70 then
		table.rowHeight[addressRow] := 70;
	endif;
	table.userInputEnabled := true;
	table.row := 1;
	table.setFocus();

	self.btnNew.enabled := false;
	self.btnSaveBase.enabled := true;
	self.btnEdit.enabled := false;
	self.btnDelete.enabled := false;
	self.btnChangeDebtor.enabled := true;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="21402250-64f3-4ad9-a099-092f3d7f9749">
        <updating/>
        <source>doResetSearch() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2014	cnwjre1	Initial creation

*/

vars

begin
	self.txtAgent.text := "";
	self.populateAgentCombo();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="enableToolbarButtons" id="0c79a70b-4843-46ba-b291-5d4109911394">
        <updating/>
        <source>enableToolbarButtons() updating, protected;
// set the toolbar buttons to their default enabled status
vars

begin
	self.btnNew.enabled := true;
	self.btnEdit.enabled := true;
	self.btnSaveBase.enabled := false;
	self.btnDelete.enabled := true;
	self.btnChangeDebtor.enabled := false;
	self.mode := self.Mode_View;
	self.tblAgents.showRowByName(ETRow_Debtor, false);			// restore to default textbox for debtor name
	self.tblAgents.hideRowByName(ETRow_MyDebtor, false);		// combo of existing debtors
	self.tblAgents.enableRowByName(ETRow_Address);

	// #### TFS 2734
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNew.enabled:= false;
		self.btnEdit.enabled:= false;
		self.btnDelete.enabled:= false;
		
		
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getAgentDescription" id="49838535-323f-48e0-a073-598e1d8f3c26">
        <source>getAgentDescription(_agent : CM_Object) : String protected;
/*
Purpose:			Format agent description/name for combo in one place

Parameters:			Consignee/customs agent

Return Value:		Combo description

Date		Who		Reason
05/03/2014	cnwjre1	Initial creation
10/06/2019	jlgdap1	TFS 44554 AAT Stevedore Data Access
*/
vars
	result	: String;
	
begin
	if _agent.isKindOf(CM_ConsigneeConsignor) then
		result := _agent.CM_ConsigneeConsignor.description &amp; "  " &amp; _agent.CM_ConsigneeConsignor.code;
	elseif _agent.isKindOf(CM_CustomsAgent) then
		result := _agent.CM_CustomsAgent.name;
	elseif _agent.isKindOf(CM_Stevedore) then												// TFS 44554
		result := _agent.CM_Stevedore.description &amp; "  " &amp; _agent.CM_Stevedore.code;		// TFS 44554
	endif;
	return result;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_agent" type="CM_Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="68fab078-6370-4a9e-888f-d0fe5dad962f">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//	save the agent type
vars

	str : String;

begin

	str	:=	inheritMethod();
	
	str := str &amp; global.formatAsXML( self.cmbAgentType.name, self.cmbAgentType.text);
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initAgentTable" id="eb27a13c-1fe6-44a3-a5e2-45ae0cf5f6d3">
        <source>initAgentTable() protected;

vars
	entTableDef		: EntTableDef;
	theTable		: CM_EntryTable;
	
begin

	theTable := self.tblAgents;
	theTable.warningMethod := 'entTableWarning';

	theTable.optimiseRowHeight := true;
	entTableDef := app.myController.getEntTableDef(ETDef_ConsignDebtor);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	
	theTable.adjustHeight(300);	
	theTable.optimiseHeadingColumn();
	theTable.changeMode := theTable.ChangeMode_FirstOnly;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="5952163a-a2e5-4e20-be4d-e85731831c11">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// set agent type to the last-selected value
vars

begin

	inheritMethod(_userWindow);
	// save off and use when the agent type combo is built later
	self.savedAgentDesc := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.cmbAgentType.name);

end;
</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
