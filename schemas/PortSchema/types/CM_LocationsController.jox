    <JadeMethod name="getTotalsByMode" id="5fd6f87c-3638-434f-8425-78bf889805da">
        <source>getTotalsByMode(_mode: Integer; _vol: Decimal io; _weight: Decimal io; _qty: Integer io);

/*

Purpose:		TFS 49959	

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2020	jlgab1	Initial creation

*/

vars
	array : CM_TIArray;
	ti : CM_TrackedItem;
begin
	create array transient;
	self.getTIs(array, _mode, true);
	
	foreach ti in array discreteLock do
		_vol := _vol + ti.totalVolume;
		_weight := _weight + ti.totalWeight;
		_qty := _qty + ti.totalQuantity;
	endforeach;
epilog
	delete array;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_vol" type="Decimal" usage="io"/>
        <Parameter name="_weight" type="Decimal" usage="io"/>
        <Parameter name="_qty" type="Integer" usage="io"/>
    </JadeMethod>
