    <JadeMethod name="create" id="1a95b1d8-9ddd-4c32-8ace-3cf5e0603e25">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwndl1	Initial creation	CCMS 1028

*/

vars

	oper : CM_QueryOperator;
	
begin

	if self.isTransient then 
		return;
	endif;

	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="70745f16-d77a-4880-b987-e7d8527b9a4a">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwndl1	Initial creation	CCMS 1028

*/

vars

begin
	
	if CM_QReferenceLookup.hasInstance(_operator) then
		return 'cmbPort';
	endif;

epilog

end;</source>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPortCodeFromDescription" id="b75084ad-852c-4886-8166-efdf3e51a13e">
        <source>getPortCodeFromDescription(description : String; _portCmbOrderDescrFirst : Boolean) : String;
/****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 17 September 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	port : CM_Port;
	countryCode	: String;
	code		: String;
begin
	if _portCmbOrderDescrFirst = true then
		return description[1:5];
	else
		return description[6:2] &amp; description[1:3];
	endif;		
	return null;
end;</source>
        <Parameter name="description" type="String"/>
        <Parameter name="_portCmbOrderDescrFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWebDataRowName" id="3dc2e83f-e01d-44ce-92d2-eea592fc899d">
