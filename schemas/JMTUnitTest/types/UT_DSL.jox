    <JadeMethod name="deleteSecurityRole" id="f717e011-1127-4fd1-b0a3-b4ff66d0eb9e">
        <source>deleteSecurityRole(_name : String);

/*

Purpose:		Delete Security Role

Date			Who		Reason
10/02/2014		cnwmh5	Initial creation

*/

vars

	securityRole					: CM_SecurityRole;
	user							: CM_User;
	
	userSet							: CM_UserSet;
	
begin

	securityRole := app.myRoot.allRoles[_name].CM_SecurityRole;
	if securityRole = null then
		return;
	endif;
	
	create userSet transient;
	securityRole.getAllUsers(userSet);
	beginTransaction;
	foreach user in  userSet do	
		delete user;
	endforeach;
	commitTransaction;
	
	app.myTrxDA.trxDeleteSecurityRole(securityRole, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

	delete userSet;

end;</source>
