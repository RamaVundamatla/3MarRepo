<ExceptionClass name="JSSException" id="8b878f08-3f96-4c51-adaa-664934af3b48">
    <superclass name="NormalException"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
