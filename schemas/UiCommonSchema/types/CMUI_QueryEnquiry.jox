    <JadeMethod name="doTblDataMouseMove" id="3ead9e64-0b1d-413d-b37e-dc3a64424e9c">
        <updating/>
        <source>doTblDataMouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if button = Window.MouseButton_Left 
	and app.dragDetected(x, y, self.origXPos, self.origYPos) 
	and y &gt; 15 then
//	and table.row &gt; table.fixedRows then // resizing columns
		if self.useCtrlScroll then
			if app.isControlKeyDown()
			and not app.isAltKeyDown()
			and not app.isShiftKeyDown()
			then
				self.dragMode := DragMode_Drag;
				self.dragCursor := self.picCtrlScroll.dragCursor;
			endif;
		endif;

	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTblDataMouseUp" id="92aa2e2c-9080-4368-9002-2f2672a6ecdd">
        <updating/>
        <source>doTblDataMouseUp(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
	theObject : Object;
	thePIC : CMIF_PopupInfoController;
	theRow	: Integer;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if self.mnuContextHide.caption = self.MNU_MACRO_HIDE then // this means that the macro info is hidden
		return;
	endif;

	if table.row &lt;= table.fixedRows then
		return;
	endif;
	if useTableInfo then

		theObject := table.accessRow(table.row).itemObject;
		if theObject = null then
			self.tblInfo.rows := 0;
			return;
		endif;
		if theObject.isKindOf(CM_WorkListEntry) then
			theObject := theObject.CM_WorkListEntry.myTrackedItem;
		endif;
		
		if not app.isDragging 
		and self.tblData.longLeftClick then
		// 28/9/2006 - par #12208 
			theRow := self.tblData.getRowFromY(self.tblData.origYPos);
			if theRow &lt;&gt; self.tblData.fixedRows then
				create thePIC transient;
				thePIC.setForCreate(theObject.CM_Object, 0, self.frmPopupInfo,self.tblPopupInfo,self.frmToolBarPopup,
									self.frmPopupInfoPic1,self.picExtraInfoTI1,self.btnPopupEnq);
				self.showPopupInfoFrame(thePIC);
			endif;
		endif;
	endif;
epilog
	app.isDragging := false;
	
	delete thePIC;

	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataPrint" id="ba2e53cb-2ea5-4369-af5d-186f01745174">
        <source>doTblDataPrint(_message : String; _header : String; _title : String);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	gtptmpTable:        CM_GenericTablePrint;
	rowString:           String;
	pd:                  CMS_Progress;
	doPrint:             Boolean;
	bShift:              Boolean;
	state:               Integer;
	now:                 TimeStamp;
	hdrStr, dateStr				: String;
	tmpTable : Table;
	tmpJadeReport  : JadeReport;
begin
	tmpTable := self.tblData;
	
	app.mousePointer := MP_HOURGLASS;
	app.printer.suppressDialog := true;
	now := self.systemToLocalTime(app.actualTimeServer());	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support

	create gtptmpTable;
	create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.raiseExceptionOnAbort := false;
	
	pd.setAction(_message);
	hdrStr := _header; 
	app.printer.setMargins(Print_Landscape,0,0,10,10);

	pd.progress.partsInJob := tmpTable.rows - 1;

	// setup header information
	gtptmpTable.frHeader.width := app.printer.pageWidth;
	gtptmpTable.setHeaders(hdrStr, null);
	create tmpJadeReport transient;
	tmpJadeReport.description := _title;
	app.printer.setReport(tmpJadeReport);

	app.printer.setHeader(gtptmpTable.frHeader);

	// set footer
	gtptmpTable.frFooter.width := app.printer.pageWidth;
	gtptmpTable.lblTheUser.caption := app.getMyUserCode;
	gtptmpTable.lblTheDatePrinted.caption := now.String;
	app.printer.setFooter(gtptmpTable.frFooter);

	gtptmpTable.printTable(tmpTable, true, pd);

	//app.printer.print(gtptmpTable.frTable);

	if pd.aborted then
		app.printer.abort;
		return;
	endif;
	pd.unloadForm;

epilog
	app.printer.close;
	app.printPreview(tmpJadeReport, true);
	delete pd;
	delete gtptmpTable;
	app.mousePointer := MP_DEFAULT;


end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_header" type="String"/>
        <Parameter name="_title" type="String"/>
    </JadeMethod>
    <JadeMethod name="doTblDataRowColChange" id="6fb75829-049c-4d21-9e62-3afafae44eef">
        <updating/>
        <source>doTblDataRowColChange(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
	theObject : Object;
	dataContainer : CM_DataContainer;
	theAttribs :	CMUI_GridAttributesArray;
	theAttrib : CMUI_GridAttributes;
	ct			: TimeStamp;
	invalid		: Boolean;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	self.myCurrentTrackedItem := null;
	self.tblInfo.rows := 0;

	if table.row &lt;= table.fixedRows then
		return;
	endif;

	theObject := table.accessRow(table.row).itemObject;

	//if (not global.isValidObject(theObject)) then
	//	return;
	//endif;
	//cnwjo3 par 23520
	if theObject &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,theObject,invalid);
		ct := theObject.creationTime;
	endif;
	
	if invalid then
		return;
	endif;
	
	
	if CM_TrackedItem.hasInstance(theObject) then
		self.myCurrentTrackedItem := theObject.CM_TrackedItem;	
	elseif CM_WorkListEntry.hasInstance(theObject) then
		if theObject.CM_WorkListEntry.myTrackedItem &lt;&gt; null or not theObject.isKindOf(CM_VoyageWLE) then  // 09/06/2010 cnwmh5 #20661
			theObject := theObject.CM_WorkListEntry.myTrackedItem;
			self.myCurrentTrackedItem := theObject.CM_TrackedItem;
		endif;
		//theObject := theObject.CM_WorkListEntry.myTrackedItem;
		//self.myCurrentTrackedItem := theObject.CM_TrackedItem;
	endif;
			
	if self.useTableInfo then

		
		if self.mnuContextHide.caption = self.MNU_MACRO_SHOW // this means that the macro info is hidden
		and not app.isDragging then
		else
			create dataContainer transient;
			dataContainer.headerColour := self.colorHeadingColumn;
			dataContainer.valueColour := self.colorValueColumn;
			
			if theObject &lt;&gt; null and theObject.isKindOf(CM_Object) then
				
				self.getExtraExtraInfo(dataContainer, theObject.CM_Object);
				theObject.CM_Object.getExtraInfo(dataContainer);
				self.tblInfo.userObject := theObject;
			endif;
			self.showExtraInformation(dataContainer, self.tblInfo, true, false, 4, 1, 1, 1, 1);
		endif;
	endif;
epilog
	delete dataContainer;
	delete theAttrib;
	delete theAttribs;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
