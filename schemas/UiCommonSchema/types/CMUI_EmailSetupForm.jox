    <JadeMethod name="doSaveAddresses" id="5af5607c-74dc-4b05-bcc2-45b73f1927b1">
        <updating/>
        <source>doSaveAddresses() protected, updating;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
vars

	str,
	str2,
	names,
	freeText,
	selectedAddresses,
	rowName 	: String;
	email		: Object;
	newAddresses,
	addresses	: CM_EmailEntityByTypeNameDict;
	strArray	: StringArray;
	pos			: Integer;

	
begin

	addresses := self.getRowName(self.doubleClickedRow, rowName);
	addresses.clear();
	newAddresses := self.getEmailInfo(self.doubleClickedRow);
	newAddresses.copy(addresses);
	names := addresses.getNames();	
	if  rowName &lt;&gt; null then
		create strArray transient;
		freeText := self.tblEmail.getValueByName(rowName).String;
		self.getAddresses(freeText, strArray);
		foreach str in strArray do
			if self.findEmail(str, true) = null then
				str2 := str2 &amp; ';' &amp; str;
			endif;
		endforeach;
		if str2.length &gt; 0 then
			str2 := str2[2:end];
			self.setFreeText(self.doubleClickedRow, str2);
			str2 := str2 &amp; ';' &amp; names;
		else
			str2 := names;
		endif;
		self.tblEmail.setValueByName(rowName, str2);
	endif;
	//self.openCloseSelector(false);

epilog
	delete strArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="findEmail" id="4e18b1de-3523-4934-b5df-0e8b011f57d0">
        <source>findEmail(_name : String; _findExact : Boolean) : CM_EmailEntity protected;
// -------------------------------------------
// Created 06 November 2003 by cnwdvb1
// -------------------------------------------
vars

	entity,
	entity2,
	entity3	: CM_EmailEntity;
	name	: String;

begin

	
	name := _name.trimBlanks();
	// Find the exact name
	if _findExact then
		// Check groups and then addresses
		entity := app.myRoot.allEmailEntities[Email_Group, name];
		if entity = null then
			entity := app.myRoot.allEmailEntities[Email_Address, name];
		endif;
	else
		// Get closest approximation to string as possible for both.
		entity2 := app.myRoot.allEmailEntities.getAtKeyGeq(Email_Group, name);
		entity3 := app.myRoot.allEmailEntities.getAtKeyGeq(Email_Address, name);
		// We have both so compare and see which one is lower case or smallest.
		if entity2 &lt;&gt; null and entity3 &lt;&gt; null then
			if entity2.name &lt; entity3.name then
				entity := entity2;
			else
				entity := entity3;
			endif;
		elseif entity2 &lt;&gt; null then
			entity := entity2;
		else
			entity := entity3;
		endif;
	endif;
	return entity;
end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <Parameter name="_findExact" type="Boolean"/>
        <ReturnType type="CM_EmailEntity"/>
    </JadeMethod>
    <JadeMethod name="getAddresses" id="a1de6ee9-afe5-4f44-b591-25e2eec58cd8">
        <source>getAddresses(_str : String; _strArray : StringArray io) protected;
// -------------------------------------------
// Created 06 November 2003 by cnwdvb1
// -------------------------------------------
vars

	pos	: Integer;
	str	: String;
	
begin
	_strArray.clear();
	if  _str &lt;&gt; null then
		//_strArray := _str.cnGetTokensUsingTruthSet(";,|");
		_strArray := _str.cnGetTokensUsingTruthSet(CM_EmailEntity.EmailSeperatorChars);
	endif;
	
	/*if  _str &lt;&gt; null then		//cnwas3 par 27332
		while true do
			pos := pos + 1;
			str := _str.scanUntil(Delimiter, pos);
			_strArray.add(str);
			if pos = 0 or (pos + 1) &gt; _str.length then
				break;
			endif;
		endwhile;
	endif;*/
	
end;</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
        <Parameter name="_strArray" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getEmailInfo" id="3e40a591-5abd-412e-bdd3-74e963fe146d">
        <source>getEmailInfo(_row : Integer) : CM_EmailEntityByTypeNameDict protected;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	if _row = 1 then
		return self.myEmailController.allToAddresses;
	elseif _row = 2 then
		return self.myEmailController.allCcAddresses;
	elseif _row = 3 then
		return self.myEmailController.allBccAddresses;
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="CM_EmailEntityByTypeNameDict"/>
    </JadeMethod>
    <JadeMethod name="getModeFromRow" id="829e6839-a51f-4989-bb4f-1e617cf2711e">
        <source>getModeFromRow() : Integer protected;

// Created by cnwdvb1 on 19 October 2006

vars

begin

	if self.doubleClickedRow = 1 then
		return CMUI_RecipientSelector.Mode_To;
	elseif self.doubleClickedRow = 2 then
		return CMUI_RecipientSelector.Mode_CC;
	else
		return CMUI_RecipientSelector.Mode_BCC;
	endif;

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowName" id="7ac17251-1749-448c-aadf-e471704c15d2">
        <source>getRowName(_row : Integer; _rowName : String output) : CM_EmailEntityByTypeNameDict protected;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	if _row = 1 then
		_rowName :=  ETRow_EmailToAddresses;
		return self.allToAddresses;
	elseif _row = 2 then
		_rowName :=  ETRow_EmailCarbonCopy;
		return self.allCCAddresses;
	elseif _row = 3 then
		_rowName := ETRow_EmailBlindCarbonCopy;
		return self.allBCCAddresses;
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_rowName" type="String" usage="output"/>
        <ReturnType type="CM_EmailEntityByTypeNameDict"/>
    </JadeMethod>
    <JadeMethod name="gotoFirstOfChar" id="bab87788-b6b7-4ce9-b8d4-885bf65caee7">
        <source>gotoFirstOfChar(_char : Character) protected;
// -------------------------------------------
// Created 31 August 2004 by cnwdvb1
// -------------------------------------------
vars

	entity		: CM_EmailEntity;
	rtnValue	: Boolean;
	char		: Character;
	idx			: Integer;

begin

	// Search for lower case first cos that's how it is sorted.
	// If we can't find one then try upper.
	char := _char.toUpper();
	entity := self.findEmail(char, false);
	if entity &lt;&gt; null and entity.name[1:1] = char then
		rtnValue := true;
	else
		char := char.toLower();
		entity := self.findEmail(char, false);
		if entity &lt;&gt; null and entity.name[1:1] = char then
			rtnValue := true;
		endif;
	endif;

	if rtnValue then
		self.gotoRow(entity);
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="_char" type="Character"/>
    </JadeMethod>
    <JadeMethod name="gotoRow" id="9690372d-be25-43fc-8212-b71f15e95df0">
        <source>gotoRow(_entity	: CM_EmailEntity) protected;

vars

	idx : Integer;

begin
	
	self.lstAddresses.findObjectInRow(_entity, idx);
	if idx &gt; 0 and idx &lt;= self.lstAddresses.rows then
		self.lstAddresses.topRow := idx;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_entity" type="CM_EmailEntity"/>
    </JadeMethod>
