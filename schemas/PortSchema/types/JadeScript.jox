    <JadeMethod name="updateTrensMode" id="b3a77213-7b83-4666-a898-e7db6af913b4">
        <source>updateTrensMode();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2022	navhl20	Initial creation

*/

vars
	wodRel : CM_WodRelease;
	wodRec : CM_WodReceive;
begin
	beginTransaction;
		foreach wodRel in CM_WodRelease.instances  do
			wodRel.setTransportMode(TI_TRANSMODE_ROAD);
		endforeach;
		
		foreach wodRec in CM_WodReceive.instances  do
			wodRec.setTransportMode(TI_TRANSMODE_ROAD);
		endforeach;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateWO" id="601cce45-4f6b-4443-9369-b36a988de55f">
