    <JadeMethod name="addTrackingObject" id="65e59d89-2cf5-4895-83a2-cb992a94c7a8">
        <lockReceiver/>
        <updating/>
        <source>addTrackingObject(_trackingObject: JSSCTChangeTrackingObject) lockReceiver, updating;
/*
		Add the object to this collection AND the collection by oid
*/
begin
//	on Exception do handleException(exception, _trackingObject);

	if not self.allChangesByOid.includes(_trackingObject) then
		self.allChangesByOid.add(_trackingObject);
	endif;
	if not self.allChangesByTime.includes(_trackingObject) then
		self.allChangesByTime.add(_trackingObject);
	endif;
end;</source>
        <Parameter name="_trackingObject" type="JSSCTChangeTrackingObject"/>
    </JadeMethod>
    <JadeMethod name="handleException" id="5eb75211-1263-4d57-8f76-cb8d78dc8d04">
        <source>handleException(_exception: Exception; _trackingObject: JSSCTChangeTrackingObject): Integer;

vars
	trackingObject: JSSCTChangeTrackingObject;
begin
//	if self.isDelete then
//		write "Delete Dict [" &amp; self.String &amp; "]";
//	else
//		write "Change Dict [" &amp; self.String &amp; "]";
//	endif;
	write "Class " &amp; self.className &amp; " [" &amp; _trackingObject.String &amp; "]";
	write "Oid " &amp; _trackingObject.changeObjectID;
	write "Action " &amp; _trackingObject.changeAction.String;
	write "TimeStamp " &amp; _trackingObject.changeTimestamp.String;
	write "TransID " &amp; _trackingObject.changeTransactionID.String;
	write "Sequence " &amp; _trackingObject.changeSequence.String;

	trackingObject := self.allChangesByOid[_trackingObject.changeObjectID];
	if trackingObject &lt;&gt; null then
		write " Oid " &amp; trackingObject.changeObjectID;
		write " Action " &amp; trackingObject.changeAction.String;
		write " TimeStamp " &amp; trackingObject.changeTimestamp.String;
		write " TransID " &amp; trackingObject.changeTransactionID.String;
		write " Sequence " &amp; trackingObject.changeSequence.String;
	endif;

	return (Ex_Pass_Back);
end;</source>
        <Parameter name="_exception" type="Exception"/>
        <Parameter name="_trackingObject" type="JSSCTChangeTrackingObject"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeTrackingObject" id="b4bc2caa-9c96-458e-b371-795bd0a687ed">
        <lockReceiver/>
        <updating/>
        <source>removeTrackingObject(_trackingObject: JSSCTChangeTrackingObject) lockReceiver, updating;
/*
		Remove the object from this collection AND the collection by oid
*/
begin

	if self.allChangesByOid.includes(_trackingObject) then
		self.allChangesByOid.remove(_trackingObject);
	endif;
	if self.allChangesByTime.includes(_trackingObject) then
		self.allChangesByTime.remove(_trackingObject);
	endif;
end;</source>
        <Parameter name="_trackingObject" type="JSSCTChangeTrackingObject"/>
    </JadeMethod>
