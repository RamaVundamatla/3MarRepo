    </PrimAttribute>
    <JadeMethod name="delete" id="ea810432-f371-4be2-af42-87a3a6193858">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 July 2023	navcs2	ChangeRequest 57650: MTN - Refactor getCustomer(s) REST Webservice

*/

vars

begin
	self.addresses.purge();
	self.terminalSpecificConfiguration.purge();
	delete self.tax;
	delete self.relatedEntities;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="65b74b5b-9842-4765-8d51-cffe45a8572c">
        <updating/>
        <source>setProxy(_debtor : CM_Debtor; _includeRelatedInfo : Boolean; _includeSpecificConfig: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2023	navra1	Initial creation for TFS 56641
18/07/2023	navcs2	ChangeRequest 57650: MTN - Refactor getCustomer(s) REST Webservice
26 Feb 2024	navhn30	ChangeRequest 59198: MTN - REST GET /Customers and /Customer/Id TerminalConfiguration optional
*/

vars
	carrier 				: CM_Carrier;
	customerCarrier 		: WS_RestCarrierObject;
	consignor 				: CM_ConsigneeConsignor;
	customerConsignor 		: WS_RestConsignee_orObject;
	operator 				: CM_Operator;
	customerOperator 		: WS_RestOperatorObject;
	shippingLine 			: CM_ShippingLine;
	customerShippingLine 	: WS_RestShippingLineObject;
	stevedore 				: CM_Stevedore;
	customsAgent			: CM_CustomsAgent;
	customerStevedore 		: WS_RestStevedoreObject;
	customerCustomsAgent	: WS_RestCustomsAgentObject;
	address					: CM_Address;
	customerAddress 		: WS_RestAddressObject;
	customerTaxObejct		: WS_RestCustTaxObject;
	termSpecConfig			: WS_RestTermSpecConfObject;
	debtorTerminal			: CM_DebtorTerminal;
	debtorType				: CM_DebtorType;
	customerDebtorType		: WS_RestDebtorTypeObject;
begin
	//self.debtorName := _debtor.name;	//JIRA-20787
	//self.debtorCode := _debtor.code;	//JIRA-20787
	self.id := _debtor.code;
	self.name := _debtor.name;
	self.description := _debtor.longName;
	self.accountCode := _debtor.decfinName;
	self.additionalInfo1 :=_debtor.additionalInformation1;
	self.additionalInfo2 :=_debtor.additionalInformation2;
	self.badCredit := _debtor.hasBadCredit();
	self.suspended := _debtor.isSuspended;
	//self.billingAddress := _debtor.getBillingAddressString();	//JIRA-20787
	if _debtor.myTermsOfTrade &lt;&gt; null then
		self.termsOfTradeId := _debtor.myTermsOfTrade.code;
	endif;
	
	// 18/07/2023 navcs2 ChangeRequest 57650 Start
	foreach address in _debtor.allAddressesByCode do
		create customerAddress transient;
		customerAddress.setProxy(address);
		self.addresses.add(customerAddress);
	endforeach;
	
	create customerTaxObejct transient;
	customerTaxObejct.number := _debtor.taxNumber;
	if _debtor.myTaxCountry &lt;&gt; null then
		customerTaxObejct.countryId := _debtor.myTaxCountry.code;
	endif;
	
	self.tax := customerTaxObejct;
	
	if _includeSpecificConfig then				// 26.02.24		navhn30		TFS #59198	
		foreach debtorTerminal in _debtor.allDebtorTerminals do
			create termSpecConfig transient;
			termSpecConfig.cashOnly := debtorTerminal.isCashOnly;
			if debtorTerminal.myCurrencyType &lt;&gt; null then
				termSpecConfig.currencyId := debtorTerminal.myCurrencyType.code;
			endif;
			termSpecConfig.id := debtorTerminal.myTerminal.code;
			termSpecConfig.intercompanyCode := debtorTerminal.interTerminalCode;
			termSpecConfig.invoiceReportName := debtorTerminal.defaultInvoiceJRW;
			if debtorTerminal.myLocale &lt;&gt; null then
				termSpecConfig.localeId := debtorTerminal.myLocale.localeId;
			endif;
			termSpecConfig.organisationCode := debtorTerminal.orgCode;
			termSpecConfig.paymentType := app.paymentTypeEnumToString(debtorTerminal.paymentType);
			self.terminalSpecificConfiguration.add(termSpecConfig);
		endforeach;
	endif;
	// 18/07/2023 navcs2 ChangeRequest 57650 End
	
	if _includeRelatedInfo then
		create self.relatedEntities transient;

		foreach carrier in _debtor.allCarriers do
			create customerCarrier transient;
			customerCarrier.id := carrier.code;
			customerCarrier.description := carrier.description;
			customerCarrier.rail := carrier.isRail;
			customerCarrier.road := carrier.isRoad;
			customerCarrier.subCarrier := carrier.isSubCarrier;
			self.relatedEntities.carriers.add(customerCarrier);
		endforeach;
		
		foreach consignor in _debtor.consignors do
			create customerConsignor transient;
			customerConsignor.id := consignor.code;
			customerConsignor.description := consignor.description;
			customerConsignor.consignee := consignor.isConsignee;
			customerConsignor.consignor := consignor.isConsignor;			
			self.relatedEntities.consignors.add(customerConsignor);
		endforeach;
		
		foreach operator in _debtor.operators do
			create customerOperator transient;
			customerOperator.id := operator.code;
			customerOperator.description := operator.description;
			self.relatedEntities.operators.add(customerOperator);
		endforeach;
		
		foreach shippingLine in _debtor.allShippingLines do
			create customerShippingLine transient;
			customerShippingLine.id := shippingLine.code;
			customerShippingLine.description := shippingLine.description;
			self.relatedEntities.shippingLines.add(customerShippingLine);
		endforeach;
		
		foreach stevedore in _debtor.allStevedores do
			create customerStevedore transient;
			customerStevedore.id := stevedore.code;
			customerStevedore.description := stevedore.description;
			self.relatedEntities.stevedores.add(customerStevedore);
		endforeach;
		
		foreach customsAgent in _debtor.allCustomsAgents do
			create customerCustomsAgent transient;
			customerCustomsAgent.id := customsAgent.code;
			customerCustomsAgent.description := customsAgent.name;
			self.relatedEntities.customsAgents.add(customerCustomsAgent);
		endforeach;
		
		// 02/08/2023 navcs2 Bug 59605
		foreach debtorType in _debtor.allDebtorTypes do
			create customerDebtorType transient;
			customerDebtorType.id := debtorType.code;
			customerDebtorType.description := debtorType.description;
			self.relatedEntities.debtorTypes.add(customerDebtorType);
		endforeach;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_includeRelatedInfo" type="Boolean"/>
        <Parameter name="_includeSpecificConfig" type="Boolean"/>
    </JadeMethod>
</Class>
