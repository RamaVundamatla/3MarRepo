    <JadeMethod name="setSearchValue" id="7461c404-4db0-454e-bf6e-4b8db6024270">
        <updating/>
        <source>setSearchValue(_value: Any) updating;
// ---------------------------------------------------------------------------
// Created:     07 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _value &lt;&gt; null and _value.isKindOf(String) then // par 18123
		self.selectionValue := _value.String.trimBlanks;
	endif;

end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateForRT" id="e0fdca39-bd81-44a4-951b-5400c9f8eb1a">
        <source>validateForRT( _queryName, _propName : String );
// -------------------------------------------------------------------------------------
// Created:	28 April 2008 by cnwvu1
//
// Purpose:	Queries for RT must only use the operations having only one searching value.
//			A set of selected values is not valid for the RT Drivers screen. 
// -------------------------------------------------------------------------------------

vars

begin

	return;
	
end;
</source>
        <Parameter name="_queryName" type="String"/>
        <Parameter name="_propName" type="String"/>
    </JadeMethod>
