    <ImplicitInverseRef name="imexStatusString" id="29b03f2c-7171-4848-89dc-f0da0464eab1">
        <embedded/>
        <type name="WS_IMEXStatus"/>
        <access>readonly</access>
        <text>The import/ export status of the cargo - IMport, Export, Storage, Remain on Board, In transit, Tranship.
TI_IMEX_STATUS_IMPORT = 1
TI_IMEX_STATUS_EXPORT = 2
TI_IMEX_STATUS_STORAGE = 3
TI_IMEX_STATUS_TRANSIT = 6
TI_IMEX_STATUS_TRANSHIP = 7</text>
    </ImplicitInverseRef>
    <PrimAttribute name="isControlledAtmosphere" id="48601d75-bdbe-457a-b0ec-8ab3b6dd705b">
