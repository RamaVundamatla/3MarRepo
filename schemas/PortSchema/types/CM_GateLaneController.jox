    <JadeMethod name="delete" id="dd766f4f-f2b6-42c6-adaa-2662e26ba92a">
        <updating/>
        <source>delete() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.isTransient then
		if self.myRFIDTagReader &lt;&gt; null and  self.myRFIDTagReader.isTransient then
			self.myRFIDTagReader.erase(NORMAL_ERASE);
		endif;	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="14327d04-ebb5-4a31-969d-3c835a83c6a0">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	
	if self.isTransient then
		if self.myRFIDTagReader &lt;&gt; null and  self.myRFIDTagReader.isTransient then
			self.myRFIDTagReader.erase(_eraseLevel);
		endif;	
	endif;


	inheritMethod(_eraseLevel);


epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="511d45dc-c1b0-4700-943b-ab5f589ec4d6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if _attrName = ETRow_BoomPortNo then
		return self.boomPortNo.String;
	elseif _attrName = ETRow_BoomMachineName then
		return self.boomMachineName.String;
	elseif _attrName = ETRow_GateLaneId then
		return self.ident;
	elseif _attrName = ETRow_Printer then
		if self.myPrinter &lt;&gt; null then
			return self.myPrinter.description;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_RFIDTagReader then
		if self.myRFIDTagReader &lt;&gt;  null then
			return self.myRFIDTagReader.code;
		endif;
		
	elseif _attrName = ETRow_IsInwards then //PAR16483  cnwgb1...
		return (laneDirection = self.InLane and not isUnavailable).String;
	elseif _attrName = ETRow_IsOutwards then
		return (laneDirection = self.OutLane and not isUnavailable).String;
	elseif _attrName = ETRow_IsClosed then 
	    return isUnavailable.String;		//...PAR16483 cnwgb1
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
