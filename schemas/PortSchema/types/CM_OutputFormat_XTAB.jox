    <JadeMethod name="getQueryBOLType" id="5f1394c9-b5f8-4486-b88a-1554da6fe4b8">
        <source>getQueryBOLType(): CM_CargoBOLType;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myOutputFormat_SS &lt;&gt; null then
		return self.myOutputFormat_SS.getQueryBOLType;
