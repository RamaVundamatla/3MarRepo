    <JadeMethod name="updateCargoToTable" id="a436b35b-1d2b-436e-b05a-62d42f3f7999">
        <updating/>
        <source>updateCargoToTable(_ti : CM_TrackedItem; _table : CM_DataTable input; _sheet : CMUI_Sheet input) updating;
/*
Purpose:			

Date				Who		Reason
01 March 2023		navab1	TFS CR 56806 TASK 56807
19 March 2024		jlizm1	TFS 62763 Table auto updates
*/

vars
	str : String;
	rowIdx : Integer;
begin
	str := _ti.getAttributeStringForDefArray(_table.allTblDataEntRows);

	_table.findObjectInRow(_ti,rowIdx);
	
	if rowIdx &gt; _table.fixedRows then // ### TFS BUG 57053 27MAR2023 NAVAB1
		_table.accessCell(rowIdx,1).text := str;

		self.doQueryColourUp(_table, _ti, rowIdx);
		//jlier1 TFS 65906 30/8/24 - re-select the child cargo if parent changes
		if self.myCurrentTrackedItem = _ti then
			self.showChildCargo(self.myCurrentTrackedItem,  self.getBottomTable(_table));
		endif;
	else
		// no in table, so add it
		self.addCargoToTable(_ti, _table, _sheet);
		self.doSheetCaption(_sheet, _table);
	endif;
	_table.resort(); //jlier1 TFS 65252 16/7/24
	self.colourTableRows(_table); 	//jlier1 TFS 65275 19/7/24
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_sheet" type="CMUI_Sheet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="ca607165-37b6-4809-9e94-c679b92a63fc">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Purpose:			

Date		Who		Reason
13 March 2023	navab1	TFS CR 56806 TASK 56807
*/

vars

begin
	self.handleUserNotifications(eventType,theObject.CM_Object,userInfo.CM_Object);
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
