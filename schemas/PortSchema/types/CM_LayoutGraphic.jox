    <JadeMethod name="setDefaultOutline4" id="0b0629bc-363a-458c-a843-82b8d995aefd">
        <source>setDefaultOutline4(_left, _top, pWidth, pLength : Integer; _pointsPolygon : PointArray input);
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lPoint	: Point;
begin

	_pointsPolygon.clear;

	lPoint.set(_left,_top);
	_pointsPolygon.add(lPoint);
	lPoint.set(pWidth,_top);
	_pointsPolygon.add(lPoint);
	lPoint.set(pWidth,pLength);
	_pointsPolygon.add(lPoint);
	lPoint.set(_left,pLength);
	_pointsPolygon.add(lPoint);
	lPoint.set(_left,_top);
	_pointsPolygon.add(lPoint);
end;</source>
        <Parameter name="_left" type="Integer"/>
        <Parameter name="_top" type="Integer"/>
        <Parameter name="pWidth" type="Integer"/>
        <Parameter name="pLength" type="Integer"/>
        <Parameter name="_pointsPolygon" type="PointArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDefaultOutline6" id="25b9623d-90c3-47c5-bbb7-a7eb8ba556f0">
        <source>setDefaultOutline6(_left, _top, _width : Integer; _pointsPolygon : PointArray input);
/*
Purpose:			
Date		Who		Reason
29 July 2011	cnwab1	Initial creation
*/
constants
	Length1 = 25;
	Length2 = 75;
	Length3 = 100;
	Length4 = 44;
	Length5 = 86;
vars
	scale : Real;
	lPoint	: Point;
begin
	scale := (_width / Length3);
	
	
	_pointsPolygon.clear;
	//Point 1
	lPoint.set(_left + (Length1 * scale).Integer,_top);
	_pointsPolygon.add(lPoint);
	//Point 2
	lPoint.set(_left + (Length2 * scale).Integer,_top);
	_pointsPolygon.add(lPoint);
	//Point 3
	lPoint.set(_left + (Length3 * scale).Integer,_top + (Length4 * scale).Integer);
	_pointsPolygon.add(lPoint);
	//Point 4
	lPoint.set(_left + (Length2 * scale).Integer,_top + (Length5 * scale).Integer);
	_pointsPolygon.add(lPoint);
	//Point 5
	lPoint.set(_left + (Length1 * scale).Integer,_top + (Length5 * scale).Integer);
	_pointsPolygon.add(lPoint);
	//Point 6
	lPoint.set(_left,_top + (Length4 * scale).Integer);
	_pointsPolygon.add(lPoint);
	//Point 1
	lPoint.set(_left + (Length1 * scale).Integer,_top);
	_pointsPolygon.add(lPoint);


epilog

end;</source>
        <Parameter name="_left" type="Integer"/>
        <Parameter name="_top" type="Integer"/>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_pointsPolygon" type="PointArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDefaultOutline8" id="3f3f3526-45e8-4236-8703-bd7526f6de22">
        <source>setDefaultOutline8(_left, _top, _width : Integer; _pointsPolygon : PointArray input);
/*
Purpose:			
Date		Who		Reason
29 July 2011	cnwab1	Initial creation
*/
constants
	Length1 = 28;
	Length2 = 70;
	Length3 = 100;
vars
	scale : Real;
	lPoint	: Point;
begin
	scale := (_width / Length3);
	
	
	_pointsPolygon.clear;
	//Point 1
	lPoint.set(_left + (Length1 * scale).Integer,_top);
	_pointsPolygon.add(lPoint);
	//Point 2
	lPoint.set(_left + (Length2 * scale).Integer,_top);
	_pointsPolygon.add(lPoint);
	//Point 3
	lPoint.set(_left + (Length3 * scale).Integer,_top + (Length1 * scale).Integer);
	_pointsPolygon.add(lPoint);
	//Point 4
	lPoint.set(_left + (Length3 * scale).Integer,_top + (Length2 * scale).Integer);
	_pointsPolygon.add(lPoint);
	//Point 5
	lPoint.set(_left + (Length2 * scale).Integer,_top + (Length3 * scale).Integer);
	_pointsPolygon.add(lPoint);
	//Point 6
	lPoint.set(_left + (Length1 * scale).Integer,_top + (Length3 * scale).Integer);
	_pointsPolygon.add(lPoint);
	//Point 7
	lPoint.set(_left,_top + (Length2 * scale).Integer);
	_pointsPolygon.add(lPoint);
	//Point 8
	lPoint.set(_left,_top + (Length1 * scale).Integer);
	_pointsPolygon.add(lPoint);
	//Point 1
	lPoint.set(_left + (Length1 * scale).Integer,_top);
	_pointsPolygon.add(lPoint);


epilog

end;</source>
        <Parameter name="_left" type="Integer"/>
        <Parameter name="_top" type="Integer"/>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_pointsPolygon" type="PointArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="af5e3c46-3a02-4bc7-bc0b-b897be099cda">
        <updating/>
        <source>setForCreate(pProxyLayoutGraphic : CM_LayoutGraphic) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		Create the basic Points (x,y) structure for drawing a terminal area
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	
//	self.setForUpdate(pProxyLayoutGraphic);
	// Only for terminal AREAS
	if pProxyLayoutGraphic.myTerminalArea &lt;&gt; null and pProxyLayoutGraphic.myTerminal = null then
		if pProxyLayoutGraphic.myTerminalArea.isKindOf(CM_GridArea) then
			self.height := pProxyLayoutGraphic.myTerminalArea.CM_GridArea.numberOfRows * 3;// * self.PAD_SIZE_Y;
			self.width  := pProxyLayoutGraphic.myTerminalArea.CM_GridArea.numberOfColumns * 3;// * self.PAD_SIZE_X;
		else
			self.height := 10;
			self.width  := 10;
		endif;
	else
		self.height := 10;
		self.width  := 10;
	endif;
	
	self.top := pProxyLayoutGraphic.top;
	self.left := pProxyLayoutGraphic.left;
	self.orientation := pProxyLayoutGraphic.orientation;
	self.drawLineColour  := pProxyLayoutGraphic.drawLineColour;
	self.label := pProxyLayoutGraphic.label;
	
	self.pointsPolygon.clear;
	pProxyLayoutGraphic.pointsPolygon.copy(self.pointsPolygon);

	if pProxyLayoutGraphic.myTerminalArea &lt;&gt; null and pProxyLayoutGraphic.myTerminal = null then
		self.setForCreateLocations(pProxyLayoutGraphic.myTerminalArea); // this creates a mini polygon for each location controller
	endif;
end;</source>
        <Parameter name="pProxyLayoutGraphic" type="CM_LayoutGraphic"/>
    </JadeMethod>
    <JadeMethod name="setForCreateLocations" id="317d3598-a776-403f-9584-b8dacb0b8623">
        <source>setForCreateLocations(_pxyTerminalArea : CM_TerminalArea);
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
23 Jan 2014	cnwkpd1	PAR #33353 - tidy up creation of RootSchema classes
	
*/

vars

	theSegmentor : CMIF_RectangleSegments;
	anObject, aPointObject : Object;
	thePoints, ourPoints : PointArray;
	aController : CM_LocationsController;
	aGridController : CM_GridController;
	idx,tmp, aRow, aCol, controllerIndex, numCargo, theColour, numRows, numCols: Integer;
	theGraphic : CM_LayoutGraphic;
begin
	create theSegmentor transient;
	
	if self.myTerminalArea = null or _pxyTerminalArea = null then
		return;
	endif;
	
	if CM_StraddleStack.hasInstance(self.myTerminalArea) or CM_ForkLiftStack.hasInstance(self.myTerminalArea) then
		numRows := _pxyTerminalArea.CM_GridArea.numberOfRows;
		numCols := _pxyTerminalArea.CM_GridArea.numberOfColumns;

		if numRows = 0 or numCols = 0 then
			app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Cannot_create_segment_size));
			return;
		endif;
		ourPoints := self.pointsPolygon;
		
		theSegmentor.setupSegmentor(numRows, numCols,ourPoints,true);		
		theSegmentor.generatePolygons();
		self.allLocationPointPolygons.purge();			// PAR #33107
		theSegmentor.allPolygons.copy(self.allLocationPointPolygons);
	endif;
epilog

	delete theSegmentor;
end;</source>
        <Parameter name="_pxyTerminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="eca075a3-f4c5-4da3-8171-f235cea04292">
        <updating/>
        <source>setForUpdate(pProxyLayoutGraphic : CM_LayoutGraphic) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.height := pProxyLayoutGraphic.height;// * self.PAD_SIZE_Y;
	self.width  := pProxyLayoutGraphic.width;// * self.PAD_SIZE_X;
	self.top := pProxyLayoutGraphic.top;
	self.left := pProxyLayoutGraphic.left;
	self.orientation := pProxyLayoutGraphic.orientation;
	self.drawLineColour  := pProxyLayoutGraphic.drawLineColour;
	self.label := pProxyLayoutGraphic.label;
	
	self.pointsPolygon.clear;
	pProxyLayoutGraphic.pointsPolygon.copy(self.pointsPolygon);

	// Only for terminal AREAS
	if self.myTerminalArea &lt;&gt; null then
		self.setForCreateLocations(pProxyLayoutGraphic.myTerminalArea); // this creates a mini polygon for each location controller
	endif;
end;</source>
        <Parameter name="pProxyLayoutGraphic" type="CM_LayoutGraphic"/>
    </JadeMethod>
    <JadeMethod name="setPoint" id="0ed99c6c-31e8-4e85-a742-c92c919d826d">
