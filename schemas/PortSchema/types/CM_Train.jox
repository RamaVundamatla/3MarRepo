    <JadeMethod name="getDischargeMoveCount" id="83f25afe-53d7-4d83-9b90-4c6c6e5c33bd">
        <source>getDischargeMoveCount() : Integer;

vars
	wles: CM_WLEArray;	
	wle: CM_WorkListEntry;
	count: Integer;
begin
	if self.isDeparted then
		return self.allTIsReceived.size;
	endif;

	create wles transient;
	self.getAllWLEs(wles);
	foreach wle in wles do
		if wle.isReceipt then
			count := count + 1;
		endif;
	endforeach;
	return count;
epilog
	delete wles;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="8a2a5460-f5a1-4535-8ce3-cde4c1f1d2d5">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//04 May 2016		cnwns1			TFS 488 - Multi Timezone Support
//02 Oct 2020 		cnwma1 			ChangeRequest 50112: ASPA - GCI Stevedores
//09 Aug 2022 		navsj20			ChangeRequest 54281: EUP - Wagon Track Planning
//28 Apr 2023 		navmk20			Bug 57743: EUP -FR 53740 | Wagon Track Planning - Elapsed Time
//27/09/2023		navkc1			CR 60428 Task 60701: UI - Customs Status on Transport UI
// ---------------------------------------------------------------------------

vars
	dwell : Integer;
	tmpString : String;
begin
	//process.debugAdi();
	if _attrName = ETRow_OriginPort  then
		if self.myOriginPort &lt;&gt; null then
			return  self.myOriginPort.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_MyRailArea then // PAR 23878
		return self.getRailLocation(); // PAR 23878
		
	elseif _attrName = ETRow_ConfirmedStatus  then
		// PAR 26564
		tmpString := self.getConfirmedStatus(true);
		if tmpString = app.getErrorString(WagonsNone) then // At MES outward trains are created with no inward wagons, but have outward wagons so switch to outward status.
			return self.getConfirmedStatus(false);
		else
			return tmpString;
		endif;
	elseif _attrName = ETRow_DestinationPort  then
		if self.myDestinationPort &lt;&gt; null then
			return  self.myDestinationPort.code;
		else
			return null;
		endif;
	elseif (_attrName = ETRow_ActualArrival  or _attrName = ETRow_TrainTSArriveActual) then
			if self.arrivalDT.isValid() then
			return self.systemToLocalTime(self.arrivalDT).asStringJMT();//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			return null;
		endif;
	elseif (_attrName = ETRow_ScheduledArrival or _attrName = ETRow_TrainTSArriveSchedule)  then
		if self.scheduledArrivalDT.isValid() then
			return self.systemToLocalTime(self.scheduledArrivalDT).asStringJMT();//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			return null;
		endif;
	elseif (_attrName = ETRow_ScheduledDepartureDT or _attrName = ETRow_TrainTSDepartureSchedule)  then
		if self.scheduledDepartureDT.isValid() then
			return self.systemToLocalTime(self.scheduledDepartureDT).asStringJMT();//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			return null;
		endif;
	elseif _attrName = ETRow_HasDeparted  then
		if (self.myTerminalDeparted &lt;&gt; null) then
			return $CNEC_LIT_YES;
		else
			return null;
		endif;
	elseif _attrName = ETRow_DwellTime  then
		dwell := self.dwellTime();
		return dwell.String; // &amp; " (" &amp; dwell.asDHMString() &amp; ")";
	elseif _attrName = ETRow_NumCargoRec  then
		return self.allTIsReceived.size.String;
	elseif _attrName = ETRow_NumCargoRel  then
		return self.allTIsReleased.size.String;
	elseif _attrName = ETRow_NumWagons  then
		return self.allWagonsByOrderInward.size.String;
	elseif _attrName = ETRow_NumWagonsOut  then
		return self.allWagonsByOrderOutward.size.String;

	elseif _attrName = ETRow_ShunterInDT  then
		if self.shunterInDT.isValid() then
			return self.systemToLocalTime(self.shunterInDT).asStringJMT();//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			return null;
		endif;
	elseif _attrName = ETRow_ShunterOutDT  then
		if self.shunterOutDT.isValid() then
			return self.systemToLocalTime(self.shunterOutDT).asStringJMT();//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			return null;
		endif;
	elseif _attrName = ETRow_MaxWeight  then
		return self.maxWeight.asStringJMT();
	elseif _attrName = ETRow_MaxHeight  then
		return self.maxHeight.asStringMeasurementJMT();
	elseif _attrName = ETRow_MaxWidth  then
		return self.maxWidth.asStringMeasurementJMT();
	elseif (_attrName = ETRow_DepartureDT or _attrName = ETRow_TrainTSDepartureActual  ) then
		if self.departureDT.isValid() then
			return self.systemToLocalTime(self.departureDT).asStringJMT();//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			return null;
		endif;
	elseif _attrName = ETRow_MyCarrier  then
		if self.myCarrier &lt;&gt; null then
			return  self.myCarrier.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_MyGaugeClearance  then	// 26 Jun 2009	NDL	CCMS 1067
		if self.myTrackClearance &lt;&gt; null then
			return  self.myTrackClearance.code;
		else
			return null;
		endif; 
	elseif _attrName = ETRow_TeuReceived then
		return self.getNumTEU(true).asStringJMT(); //+ cnwmd1, CCMS 1067, Par 19913
	elseif _attrName = ETRow_TeuReleased then
		return self.getNumTEU(false).asStringJMT();	//+ cnwmd1, CCMS 1067, Par 19913
	elseif _attrName = ETRow_WagonWeightInward then
		return self.getWagonTareWeight(true).asStringMeasurementJMT(); //+ cnwmd1, CCMS 1067, Par 19913
	elseif _attrName = ETRow_WagonWeightOutward then
		return self.getWagonTareWeight(false).asStringMeasurementJMT(); //+ cnwmd1, CCMS 1067, Par 19913
	elseif _attrName = ETRow_CargoWeightReceived then
		return self.getCargoWeight(true).asStringMeasurementJMT; //+ cnwmd1, CCMS 1067, Par 19913
	elseif _attrName = ETRow_CargoWeightReleased then
		return self.getCargoWeight(false).asStringMeasurementJMT; //+ cnwmd1, CCMS 1067, Par 19913
	elseif _attrName = ETRow_TrainWeightIn then
		return self.getTrainWeight(true).asStringMeasurementJMT; //+ cnwmd1, CCMS 1067, Par 19913
	elseif _attrName = ETRow_TrainWeightOut then
		return self.getTrainWeight(false).asStringMeasurementJMT; //+ cnwmd1, CCMS 1067, Par 19913
		
	elseif _attrName = ETRow_Total20InMT then													//cnwas3 CCMS MSL 1013 begin
		return self.getContainersByLength(true,Container20,true,false).asStringJMT; 
	elseif _attrName = ETRow_Total30InMT then
		return self.getContainersByLength(true,Container30,true,false).asStringJMT; 
	elseif _attrName = ETRow_Total40InMT then
		return self.getContainersByLength(true,Container40,true,false).asStringJMT; 
	elseif _attrName = ETRow_Total45InMT then
		return self.getContainersByLength(true,Container45,true,false).asStringJMT; 
	elseif _attrName = ETRow_Total53InMT then
		return self.getContainersByLength(true,Container53,true,false).asStringJMT; 
	elseif _attrName = ETRow_Total20OutMT then
		return self.getContainersByLength(false,Container20,true,false).asStringJMT; 
	elseif _attrName = ETRow_Total30OutMT then
		return self.getContainersByLength(false,Container30,true,false).asStringJMT; 
	elseif _attrName = ETRow_Total40OutMT then
		return self.getContainersByLength(false,Container40,true,false).asStringJMT; 
	elseif _attrName = ETRow_Total45OutMT then
		return self.getContainersByLength(false,Container45,true,false).asStringJMT; 
	elseif _attrName = ETRow_Total53OutMT then
		return self.getContainersByLength(false,Container53,true,false).asStringJMT; 
	elseif _attrName = ETRow_Total20InFull then
		return self.getContainersByLength(true,Container20,false,false).asStringJMT; 
	elseif _attrName = ETRow_Total30InFull then
		return self.getContainersByLength(true,Container30,false,false).asStringJMT; 
	elseif _attrName = ETRow_Total40InFull then
		return self.getContainersByLength(true,Container40,false,false).asStringJMT; 
	elseif _attrName = ETRow_Total45InFull then
		return self.getContainersByLength(true,Container45,false,false).asStringJMT; 
	elseif _attrName = ETRow_Total53InFull then
		return self.getContainersByLength(true,Container53,false,false).asStringJMT; 
	elseif _attrName = ETRow_Total20OutFull then
		return self.getContainersByLength(false,Container20,false,false).asStringJMT; 
	elseif _attrName = ETRow_Total30OutFull then
		return self.getContainersByLength(false,Container30,false,false).asStringJMT; 
	elseif _attrName = ETRow_Total40OutFull then
		return self.getContainersByLength(false,Container40,false,false).asStringJMT; 
	elseif _attrName = ETRow_Total45OutFull then
		return self.getContainersByLength(false,Container45,false,false).asStringJMT; 
	elseif _attrName = ETRow_Total53OutFull then
		return self.getContainersByLength(false,Container53,false,false).asStringJMT; 
	elseif _attrName = ETRow_Total20In then
		return self.getContainersByLength(true,Container20,true,true).asStringJMT; 
	elseif _attrName = ETRow_Total30In then
		return self.getContainersByLength(true,Container30,true,true).asStringJMT; 
	elseif _attrName = ETRow_Total40In then
		return self.getContainersByLength(true,Container40,true,true).asStringJMT; 
	elseif _attrName = ETRow_Total45In then
		return self.getContainersByLength(true,Container45,true,true).asStringJMT; 
	elseif _attrName = ETRow_Total53In then
		return self.getContainersByLength(true,Container53,true,true).asStringJMT; 
	elseif _attrName = ETRow_Total20Out then
		return self.getContainersByLength(false,Container20,true,true).asStringJMT;
	elseif _attrName = ETRow_Total30Out then
		return self.getContainersByLength(false,Container30,true,true).asStringJMT; 
	elseif _attrName = ETRow_Total40Out then
		return self.getContainersByLength(false,Container40,true,true).asStringJMT;
	elseif _attrName = ETRow_Total45Out then
		return self.getContainersByLength(false,Container45,true,true).asStringJMT; 
	elseif _attrName = ETRow_Total53Out then
		return self.getContainersByLength(false,Container53,true,true).asStringJMT; 		//cnwas3 CCMS MSL 1013 end;
	elseif _attrName = ETRow_ReceiveStevedore then  //02.10.2020 cnwma1 TFS #50112   ***Pending
		return self.getStevedoreCodeReceive();
	elseif _attrName = ETRow_ReleaseStevedore then  //02.10.2020 cnwma1 TFS #50112   ***Pending
		return self.getStevedoreCodeRelease();
	elseif _attrName = ETRow_CargoForecast then		//Apr 19, 2022 TFS #53142 
		return self.getCargoForecastStr();			//Cargo Forecast Form
	// START 09 Aug 2022	navsj20	TFS 54281
	elseif _attrName = ETRow_WagonElapsedTime then	
		if self.departureDT.isValid() and self.arrivalDT.isValid() then 
			return (self.departureDT - self.arrivalDT).asStringJMT();
		elseif self.arrivalDT.isValid() then 							// 28.4.2023 navmk20 TFS 57743
			return (app.actualTime - self.arrivalDT).asStringJMT(); 	// 28.4.2023 navmk20 TFS 57743
		else
			return null;
		endif;
	// END 09 Aug 2022	navsj20	TFS 54281
	elseif _attrName = ETRow_CustomStatus then //27/09/2023	navkc1	CR 60428 Task 60701
		return self.getCustomStatus();
	elseif _attrName=ETRow_Status then										//navsp1 17MAY2022 TFS#53619
		return app.trainStatusEnumToString(self.status.Integer);			//navsp1 17MAY2022 TFS#53619
	endif;																	//navsp1 17MAY2022 TFS#53619
	//if _attrName = Total20InFull then process.debugAdi();endif;
	return inheritMethod(_attrName, _short);



epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="ce6c8b4d-e83e-4953-bdd6-301515af58e0">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;

// 06 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	block : CM_DataContainerBlock;

	lString : String;
begin

	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_ID), DC_Label, 1, self);
	block.addNewItem(self.code, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Description), DC_Label, 1, self);
	block.addNewItem(self.description, DC_Data, 1, self);


	if self.remarks &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Remarks_GC), DC_Label, 1, self);
		block.addNewItem(self.remarks, DC_Data, 1, self);
	
	endif;
	if self.arrivalDT.isValid() then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Arrival_date), DC_Label, 1, self);
		block.addNewItem(self.systemToLocalTime(self.arrivalDT).asStringJMT(), DC_Data, 1, self);// 06 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	endif;
	if self.scheduledArrivalDT.isValid() then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Scheduled_arrival_date), DC_Label, 1, self);
		block.addNewItem(self.systemToLocalTime(self.scheduledArrivalDT).asStringJMT(), DC_Data, 1, self);// 06 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	//Scheduled_departure_date
	endif;
	if self.departureDT.isValid() then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Departure_date), DC_Label, 1, self);
		block.addNewItem(self.systemToLocalTime(self.departureDT).asStringJMT(), DC_Data, 1, self);// 06 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	endif;
	
	if self.shunterInDT.isValid() then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Shunter_In_date), DC_Label, 1, self);
		block.addNewItem(self.systemToLocalTime(self.shunterInDT).asStringJMT(), DC_Data, 1, self);// 06 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	endif;
	if self.shunterOutDT.isValid() then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Shunter_Out_date), DC_Label, 1, self);
		block.addNewItem(self.systemToLocalTime(self.shunterOutDT).asStringJMT(), DC_Data, 1, self);// 06 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	endif;
	
	if self.myOriginPort &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Origin_port), DC_Label, 1, self);
		block.addNewItem(self.myOriginPort.getDisplayDetails(false), DC_Data, 1, self);
	
	endif;
		
	if self.myDestinationPort &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Departure_port), DC_Label, 1, self);
		block.addNewItem(self.myDestinationPort.getDisplayDetails(false), DC_Data, 1, self);
	
	endif;
	
	
	block := _dataContainer.addNewBlock;		//13.05.2022 navsrk	53142
	block.addNewItem(app.getErrorString(Cargo_Forecast), DC_Label, 1, self);	//13.05.2022 navsrk	53142
	block.addNewItem(self.getCargoForecastStr, DC_Data, 1, self);	//13.05.2022 navsrk	53142
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getInwardCargoByTIAndType" id="892c9280-8882-473d-84b5-e403dddf3eab">
        <source>getInwardCargoByTIAndType( _id : String; _ediCargoType : Integer ) : CM_TrackedItem;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2009	cnwndl1	Initial creation	CCMS 1013 Par 21519

*/

vars

	allTrainTrackedItems : CM_TIArray;
	allTrainCargo : CM_TIByIdCargoTypeDict;
	ti : CM_TrackedItem;
	trackedItem : CM_TrackedItem;
	
begin

	create allTrainTrackedItems transient;
	create allTrainCargo transient;
	
	self.getAllTrackedItems(true, allTrainTrackedItems);
	foreach ti in allTrainTrackedItems do
		allTrainCargo.add(ti);
	endforeach;
	
	trackedItem := allTrainCargo[_id, _ediCargoType];
	
	return trackedItem;
	
epilog

	delete allTrainTrackedItems;
	delete allTrainCargo;
	
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_ediCargoType" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getLoadMoveCount" id="ceacee1f-cc5c-47aa-9ab5-94846029c703">
        <source>getLoadMoveCount() : Integer;

vars
	wles: CM_WLEArray;	
	wle: CM_WorkListEntry;
	count: Integer;
begin
	if self.isDeparted then
		return self.allTIsReleased.size;
	endif;
	
	create wles transient;
	self.getAllWLEs(wles);
	foreach wle in wles do
		if not wle.isReceipt then
			count := count + 1;
		endif;
	endforeach;
	return count;
epilog
	delete wles;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMostEmptyBoxcarControlleFor" id="f84a2c53-304e-425b-ae83-3447deb83e29">
        <source>getMostEmptyBoxcarControlleFor( _obj : CM_Object ):CM_BoxcarWagonController;
/*

Purpose:			

Parameters:			Simple view of box cars based purely on cargo count.

Return Value:		

Date		Who		Reason
28 July 2014	cnwndl1	Initial creation	Par 34656
04/03/2015 		cnwmh5	Tranisent Leak

*/

vars

	iter : Iterator;
	outWagon : CM_Wagon;
	outBoxcar : CM_BoxcarVisit;
	cont : CM_BoxcarWagonController;
	least : Integer;
	leastCont : CM_BoxcarWagonController;
	numAllTIs : Integer;

begin

	iter := self.allWagonsByOrderOutward.createIterator;
	
	least := 999999;
	while iter.next(outWagon) do
		if not outWagon.isBoxcarVisit then
			continue;
		endif;
		outBoxcar := outWagon.CM_BoxcarVisit;
		//cont := outBoxcar.allLocationsControllers.first.CM_BoxcarWagonController;
		cont := outBoxcar.allLocationsControllersArray[1].CM_BoxcarWagonController;	//04 Dec 2014	NDL	Par 35345
		numAllTIs := cont.numAllTIs + cont.allRailWLELoad.size;
		if numAllTIs &lt; least then
			leastCont := cont;
			least := numAllTIs;
		endif;
	endwhile;
	
	return leastCont;

epilog
	delete iter;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="CM_BoxcarWagonController"/>
    </JadeMethod>
