    <JadeMethod name="handleSOAPException" id="29221496-a913-4929-9ef0-5e348fee0c20">
        <source>handleSOAPException(_exc : JadeSOAPException;
					_consumer : JadeWebServiceConsumer;
					_soapExcOccurred : Boolean io) : Integer;
/*

Purpose:			Handle SOAP exceptions during the calling of any web service method

Parameters:			Exception object

Return Value:		Exception return code
					_soapExcOccurred set to true if this handler caught the exception

Date		Who		Reason
11 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	
begin
	_soapExcOccurred := true;

	app.writeLog(method.qualifiedName &amp; _exc.cnEcGetDetails, LogERROR);	//25 Nov 2019	NDL	TFS 47053
	
	if _exc.resumable then
		app.writeLog(method.qualifiedName &amp; ", returning Ex_Resume_Next", LogERROR);	//25 Nov 2019	NDL	TFS 47053
		return Ex_Resume_Next;
	else
		app.writeLog(method.qualifiedName &amp; ", returning Ex_Pass_Back", LogERROR);	//25 Nov 2019	NDL	TFS 47053
		return Ex_Pass_Back;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_exc" type="JadeSOAPException"/>
