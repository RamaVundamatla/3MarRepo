    <JadeMethod name="valRestAuthToken" id="c99a85fa-42fb-4f3d-abaf-53c2241179d4">
        <source>valRestAuthToken(_pxyToken : CM_RestAuthToken);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/09/2020	jlgdap1		Initial creation TFS 49227 MTN Navis API - nReefer API
//
vars

begin
	if _pxyToken.myUser = null then
		app.raiseCMException(UnknownUser, null, null);
	endif;
	
	if _pxyToken.myTerminal = null then
		app.raiseCMException(Select_Terminal, null, null);
	endif;
	
	if _pxyToken.guid = null then
		app.raiseCMException1(REQUIRED_FIELD, "GUID", null, null);
	endif;
	
	if _pxyToken.refreshGuid = null then
		app.raiseCMException1(REQUIRED_FIELD, "Refresh GUID", null, null);
	endif;
	
	if _pxyToken.tokenExpiryDateTime = null or not _pxyToken.tokenExpiryDateTime.isValid then
		app.raiseCMException(Expiry_date_invalid, null, null);
	endif;
	
	if _pxyToken.scope = null then
		app.raiseCMException1(REQUIRED_FIELD, "Scope", null, null);
	endif;
epilog

end;</source>
        <Parameter name="_pxyToken" type="CM_RestAuthToken"/>
    </JadeMethod>
    <JadeMethod name="valRestartCamsRequest" id="576f1311-7d8f-45dc-90e5-87a3fcd52bcd">
        <source>valRestartCamsRequest(_camTaskHistory: CM_CamTaskHistory);
// ---------------------------------------------------------------------------
// Created:		27 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
vars

begin
	if _camTaskHistory = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'History was null for Cams Request.');
		return;
	endif;
	
	if not _camTaskHistory.isRestartable then
		app.raiseCMException1(ERR_CAM_RESTART_STATUS,_camTaskHistory.statusString, 'status', null);	
	endif;
	
end;</source>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory"/>
    </JadeMethod>
