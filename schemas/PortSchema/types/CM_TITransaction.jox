    <JadeMethod name="getSpecialListBoxString" id="56050bfd-0f73-4e2e-9e1f-81c1beea21ea">
        <source>getSpecialListBoxString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	deleteStr : String;
	str : String;

begin

	deleteStr := "";
	if self.deleted then
		deleteStr:= "("&amp;app.getErrorString(LOB_Delete_Action)&amp;")";
	endif;
	str := self.getDisplayStringForAttribute(ETRow_Date, false) &amp; Space &amp;
			self.getDisplayStringForAttribute(ETRow_TransactionType, false) &amp; Space &amp; deleteStr  &amp; Space &amp;
			self.getDisplayStringForAttribute(ETRow_UserID, false) &amp; Space &amp;
			self.getDisplayStringForAttribute(ETRow_Details, false);
	
	return str;

epilog

end;</source>
