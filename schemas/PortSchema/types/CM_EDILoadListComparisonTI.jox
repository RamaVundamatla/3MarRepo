    <JadeMethod name="isTranshipInbound" id="e3e0b7a3-78ed-46b3-8fe4-f20179676fad">
        <source>isTranshipInbound() : Boolean;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 27 August 2010
//
// Implemented version: JMT 7.8.3
// Date  		User  		Change
// 27/08/2010	cnwsh3		PAR25362
//----------------------------------------------------------------------
vars
	inValid : Boolean;
	cargo : CM_TrackedItem;
	edition : Integer;

begin
	//Is myTrackedItem currently onboard the import voyage (incoming voyage)?
	on Exception do app.handleDeletedObject( exception, cargo, inValid );	
	
	//Deleted object check
	cargo := self.myTrackedItem;
	edition := cargo.edition();
	
	if not inValid then
		if cargo.isTranshipInbound then
			return true;
		endif;
	endif;
	
	return false;
	
epilog
end;
	</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
