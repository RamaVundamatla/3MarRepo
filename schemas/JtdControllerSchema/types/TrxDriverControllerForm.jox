    <JadeMethod name="tblTrans_mouseDown" id="293359cb-691d-4a3f-8630-14bf20028fba">
        <controlMethod name="Table::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTrans_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	r, c : Integer;
	
begin
	if button &lt;&gt; Window.MouseButton_Right then
		return;
	endif;
	
	if not table.getCellFromPosition(x, y, r, c) then
		return;
	endif;

	if r &lt; 1 or r &lt;= table.fixedRows or r &gt; table.rows then
		return;
	endif;

	self.popupMenu(self.mnuTrxPop, (table.left + x).Integer, (table.top + y).Integer);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="371464e4-7fe4-41c9-aed5-75a646bad645">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

begin
	if eventTag = self.GraphTimerEventNumber then
		self.myRateGraphTotalTPS.update(app.mySession.lastTotalTPS);
		self.myRateGraphUpdTPS.update(app.mySession.lastUpdTPS);
		self.myRateGraphReadTPS.update(app.mySession.lastReadTPS);
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="unload" id="304eed58-18af-4a75-b4a4-cc15a1c20f66">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

vars
	errTxt : String; // not used
	errNo : Integer;
	
begin
	app.myControllerForm := null;
	
	self.stopGraphTimer;
	
	endNotificationForSubscriber(self);

	// don't save any session state if we're minimized
	if self.windowState &lt;&gt; Form.WindowState_Minimized then
		beginTransaction;	

		errNo := 0;

		// catch any exceptions that might occur saving our session state
		// so we can resume back to this method and unload the form anyway
		on Exception do app.resumeNextExHandler(exception, errNo, errTxt);

		self.saveSessionState;

		// if an exception occurs, our handler will resume to here
		if errNo = 0 then
			commitTransaction;
		else
			abortTransaction;
		endif;
	
		on Exception do null; // disarm our handler
	endif;

	if self.myRateGraphUpdTPS &lt;&gt; null and global.isValidObject(self.myRateGraphUpdTPS) then
		delete self.myRateGraphUpdTPS;
	endif;
	
	if self.myRateGraphReadTPS &lt;&gt; null and global.isValidObject(self.myRateGraphReadTPS) then
		delete self.myRateGraphReadTPS;
	endif;

	if self.myRateGraphTotalTPS &lt;&gt; null and global.isValidObject(self.myRateGraphTotalTPS) then
		delete self.myRateGraphTotalTPS;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="c8ba9b8f-0e74-43b4-87c6-64ca1b48c79a">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars
	pd, nd, obj : Object;
	secs, n : Integer;
	s : String;
	
begin
	if theObject &lt;&gt; process then
		return;
	endif;

	// If we get any exceptions processing a notification, we just abort the operation
	// which will cut the stack back to an idle point. The notification is effectively
	// ignored. Most exceptions in here occur because a node or process has gone away,
	// and the controller is still receiving a backlog of notifications. In such cases,
	// processing the notifications can raise exceptions because the node or process
	// reference supplied in the userInfo is no longer valid. Such notifications should
	// be ignored anyway.
	on Exception do app.abortActionExHandler(exception);
	
	if eventType = InitialFormLoadPing then
//		write "InitialFormLoadPing";
		// Our form load method has asked us to do our initial ping to see what drivers
		// are out there. For a discussion of why we do this, refer to the comments in
		// the form load method. Force an immediate repaint of the whole form before we
		// send out out initial ping so that we know the form is shown and painted. If
		// we don't do this and there are lots of driver processes out there, the form
		// sometimes doesn't have a chance to finish painting before it gets bombarded
		// with notifications.
		self.refreshNowTheLot;
		self.doWindowEvents(0);
		app.mySession.doCmdPing(system);
		return;
	endif;

	app.mousePointer := Busy;
	
	if eventType = ProcessDescriptorUpdated then
//		write "ProcessDescriptorUpdated";
		self.refreshDriverRowForDescriptor(userInfo.ProcessDescriptor);
		self.refreshStatsTable;
		self.displayDbServerFreeDisk;

	elseif eventType = ProcessDescriptorCreated then
//		write "ProcessDescriptorCreated";
		self.addDriverRowForNewDescriptor(userInfo.ProcessDescriptor);
		self.positionDriverTableRowForObj(self.mySelectedCmdTarget);
		self.refreshStatsTable;
		self.displayDbServerFreeDisk;

	elseif eventType = ProcessDescriptorDeleted then
//		write "ProcessDescriptorDeleted";
		s := userInfo.String;
		n := s.pos(';', 1);
		if n &gt; 1  and n &lt; s.length then
			pd := s[1 : n - 1].asOid;
			nd := s[n + 1 : end].asOid;
			self.removeDriverRowForDescriptor(pd, nd);
			self.positionDriverTableRowForObj(self.mySelectedCmdTarget);
		else
			// belts and braces
			self.refreshDriversTable;
		endif;
		self.refreshStatsTable;
		self.displayDbServerFreeDisk;

	elseif eventType = NodeAndProcessDescCreated then
//		write "NodeAndProcessDescCreated";
		obj := self.mySelectedCmdTarget;
		self.refreshDriversTable;
		self.positionDriverTableRowForObj(obj);
		self.refreshStatsTable;
		self.displayDbServerFreeDisk;
			
	elseif eventType = TransactionDescriptorUpdated then
//		write "TransactionDescriptorUpdated";
		self.refreshTransRowForDescriptor(userInfo.SessionTransactionDescriptor);

	elseif eventType = TransactionDescriptorCreated then
//		write "TransactionDescriptorCreated";
		self.refreshTransTable;
		
	elseif eventType = SessionDescriptorInitialized then
//		write "SessionDescriptorInitialized";
		self.refreshDriversTable;
		self.refreshTransTable;

	elseif eventType = StartBenchmark then
		doCmdStart(null);

	elseif eventType = StopBenchmark then
		doCmdStop(null);

	elseif eventType = TerminateBenchmark then
		doSaveToLogs;
		app.mySession.doCmdTerminate(null);
	endif;

	// Make sure that when a benchmark is running, (roughly) at least every 30 seconds
	// we give the form a chance to process events. This is to try and make sure that
	// if the controller is being bombarded with notifications from driver processes,
	// every 30 seconds or so there is a chance for events (eg: menu item clicks) to
	// get in so that the user can stop the run.
	secs := app.clock div 1000;
	if (secs - self.lastUserNotifyPauseAtSecs &gt;= 30) and app.mySession.isRunning then
		self.lastUserNotifyPauseAtSecs := secs;
		self.doWindowEvents(0);
	endif;
	
	// auto-stop at a particular point
	if targetTranCount &gt; 0 and app.mySession.mySummary.jtdGetTotalTransactions &gt;= targetTranCount then
		mnuStop_click(null);
	endif;
epilog
	app.mousePointer := Idle;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
