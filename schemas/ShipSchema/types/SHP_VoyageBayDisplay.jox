<Class name="SHP_VoyageBayDisplay" id="cb1e6a0c-7529-4e1c-b569-e7c8dffc87b8">
    <superclass name="SHP_BayDisplay"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ImplicitInverseRef name="myBayVoyage" id="f2c7c144-5fac-4a8c-b6ce-ba622a2d1b57">
        <embedded/>
        <virtual/>
        <type name="CM_BayVoyage"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myCellularVoyageStructure" id="830ed578-677a-43fe-9e49-0703d9810bfb">
        <embedded/>
        <type name="CM_CellularVoyageStructure"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myProxyBayVoyage" id="43f9b6ad-8641-499b-849b-1c956722e185">
        <embedded/>
        <virtual/>
        <type name="CM_BayVoyage"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="createProxyBay" id="92d0c11e-c155-4d5b-bbc1-59567623c952">
        <updating/>
        <source>createProxyBay() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars

	pxyHold : CM_VoyageHold;
begin
	inheritMethod;
	if self.myProxyBay = null then
		return;
	endif;

	beginLoad;
	pxyHold:=self.myBay.myHold.CM_VoyageHold.pxyCreateUpdateProxy;
	pxyHold.setProxy(null,self.myBay.myHold.ordinalHold);
	self.myProxyBay.setMyHold(pxyHold);
	
epilog
	endLoad;
end;</source>
    </JadeMethod>
    <JadeMethod name="getBaysCollection" id="992d6756-88a0-4749-a492-6a90a4f4615f">
        <source>getBaysCollection(): Collection;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars

begin
	if self.myCellularVoyageStructure &lt;&gt; null then
		return  self.myCellularVoyageStructure.allBayVoyagesById;
	
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getTerminal" id="587cc858-ef3f-4a61-8810-c5673b52b2a0">
        <source>getTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars

begin
	if self.myCellularVoyageStructure &lt;&gt; null then
		if  self.myCellularVoyageStructure.myVoyage &lt;&gt; null then
			return self.myCellularVoyageStructure.myVoyage.myTerminal;
		endif;
	endif;
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="myBayVoyage" id="163724c9-a75f-4d06-9e26-0100219162d9">
        <methodInvocation>mapping</methodInvocation>
        <source>myBayVoyage(set: Boolean; _value: CM_BayVoyage io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars

begin
	_value:=self.myBay.CM_BayVoyage;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_BayVoyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myProxyBayVoyage" id="d536c568-4a49-489a-a8da-519177432d80">
        <methodInvocation>mapping</methodInvocation>
        <source>myProxyBayVoyage(set: Boolean; _value: CM_BayVoyage io) mapping;
/*

Purpose:			

Parameters:			

