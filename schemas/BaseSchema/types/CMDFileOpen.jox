<Class name="CMDFileOpen">
    <JadeMethod name="cnEcSetFilters" id="e558486b-ce67-43f7-a0fe-38581117ebb4">
        <updating/>
        <source>cnEcSetFilters(pIsIncludeAll:Boolean; pDefaultIndex:Integer; pFilterList:ParamListType) updating;
// --------------------------------------------------------------------------------
// Created:		29 December 2005 by cnwdad1
//
// Purpose:		Sets one or more filters for the receiver.
//
// Parameters:	pIsIncludeAll - True if an "All" filter is to be included.
//				pDefaultIndex - The index of the default Filter.
//				pFilterList - A list of filter strings.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	filterCount			: Integer;
	filterPointer		: Integer;
	filterString		: String;
	concatenatedFilters	: String;
	
begin
	filterCount	:=	app.getParamListTypeLength(pFilterList);
	
	if filterCount = 0 then
		return;
	endif;
	
	foreach filterPointer in 1 to filterCount do
		filterString	:=	app.getParamListTypeEntry(filterPointer, pFilterList).String;
		
		if concatenatedFilters = null then
			concatenatedFilters	:=	filterString;
		else
			concatenatedFilters	:=	concatenatedFilters &amp; "|" &amp; filterString;
		endif;
	endforeach;
	
	if pIsIncludeAll then
		if concatenatedFilters = null then
			concatenatedFilters	:=	CNEC_FILE_FILTER_ALL;
		else
			concatenatedFilters	:=	concatenatedFilters &amp; "|" &amp; CNEC_FILE_FILTER_ALL;
		endif;
	endif;
	
	self.filter	:=	concatenatedFilters;
	
	if pDefaultIndex &gt; 0 then
		self.filterIndex	:=	pDefaultIndex;
	endif;
end;</source>
        <Parameter name="pIsIncludeAll" type="Boolean"/>
        <Parameter name="pDefaultIndex" type="Integer"/>
        <Parameter name="pFilterList" type="ParamListType"/>
    </JadeMethod>
</Class>
