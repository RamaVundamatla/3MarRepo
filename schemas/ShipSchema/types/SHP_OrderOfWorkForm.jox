    <JadeMethod name="displayLoadPlanDetails" id="10690e4f-7d54-4f96-9a6b-58e8e1bccf06">
        <source>displayLoadPlanDetails(_startDateTime : TimeStamp; _shipController : CMIF_ShipPlanningController; _allJobs : CM_JobArray);
// --------------------------------------------------------------------------------
// Created:		19 November 2010 by cnwjo3
//
// Purpose:		open LoadPlanInfo and set essential properties
//
vars
	loadPlanInfoForm : CMUI_LoadPlanInfo;
begin
	create loadPlanInfoForm;

	loadPlanInfoForm.startDateTime := _startDateTime;
	loadPlanInfoForm.myCurrentVoyage := self.myCurrentVoyage;
	loadPlanInfoForm.shipController := _shipController;
	_allJobs.copy(loadPlanInfoForm.allJobs);
	
	loadPlanInfoForm.setMyTerminal(self.myTerminal);
	
	loadPlanInfoForm.show();
end;</source>
        <Parameter name="_startDateTime" type="TimeStamp"/>
        <Parameter name="_shipController" type="CMIF_ShipPlanningController"/>
        <Parameter name="_allJobs" type="CM_JobArray"/>
    </JadeMethod>
    <JadeMethod name="doBtnHideHatchJobClick" id="ddcc8178-910e-4a16-a250-5be5a9a100a7">
        <updating/>
        <source>doBtnHideHatchJobClick(btn: CMUI_ButtonForToolbar input) updating;
// ---------------------------------------------------------------------------
// Created:		19/11/2007 By cnwyl1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aSheet : Sheet;
	idx : Integer;
begin
	if btn.value then
		self.mnuContextHideHatchJob.caption := MNU_HATCH_SHOW;
	else
		self.mnuContextHideHatchJob.caption := MNU_HATCH_HIDE;
	endif;

	aSheet := self.fldMain.topSheet;
	// ### PAR 13827 and PAR 16228
	if aSheet.userObject.isKindOf(CM_Crane) then
		idx := aSheet.index;
	endif;
	
	self.initTable();
	self.doRefresh();
	
	// ### PAR 13827 and PAR 16228
	if not global.isValidObject(aSheet) then
		aSheet := self.shtCrane.getControl(idx);
		if aSheet = null then
			aSheet := self.shtMain;
		endif;
		
	endif;
	
	self.fldMain.topSheet := aSheet; // PAR 11646
	self.selectNewSheet();	 // PAR 11646	
end;
</source>
        <Parameter name="btn" type="CMUI_ButtonForToolbar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBtnLoadClick" id="559eaf02-2f23-4a9b-8444-557cb7ff33b8">
        <updating/>
        <source>doBtnLoadClick() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 1/11/2012	PJS			PAR #30631 - translation
// 25/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
// ---------------------------------------------------------------------------

vars
	theObject 	: Object;
	theJob,
	theProxyJob : CM_VoyageJob;
	loadState,
	load2Ops 	: Boolean;
	result		: Integer;
	jobs 		: CM_VoyageJobArray;
begin
	if self.tblData.allSelectedObjects.size = 0 then
		app.msgBox(app.getErrorString(Please_Select_Job_Operations),app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;
	self.mousePointer := Window.MousePointer_HourGlass;
	
	create jobs transient;// AKB2007JULY - DCT EXCEPTION
	
	// AKB2007JULY - DCT EXCEPTION
	foreach theObject in self.tblData.allSelectedObjects do
		if (not CM_VoyageJob.hasInstance(theObject)) then
			continue;
		endif;	
		jobs.add(theObject.CM_VoyageJob);
	endforeach;
	
	while true do : outerLoop // AKB2007JULY - DCT EXCEPTION
	
		if jobs.isEmpty() then
			break outerLoop;
		endif;
		
		theJob := jobs.first;
		jobs.remove(theJob);
		
		load2Ops := not theJob.isLoadedToOperations;

		if (theJob.jobType &lt;&gt; JOB_TYPE_LOAD) and (theJob.jobType &lt;&gt; JOB_TYPE_DISCHARGE)
			and (theJob.jobType &lt;&gt; JOB_TYPE_SOB) then
			continue;
		endif;

		delete theProxyJob;
		
		app.cmsBeginLoad(loadState);
		theProxyJob := theJob.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);

		while true do : innerLoop
			app.myTrxUA.trxUpdateVoyageJobLoadUnload(theProxyJob, load2Ops, app.myPassport);
			if app.myPassport.trxCompletedOK then
				break innerLoop;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Order_Of_Work), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue innerLoop;
				endif;
			endif;
			return;
		endwhile;
		
		if jobs.isEmpty() then
			break outerLoop;
		endif;

	endwhile;

	global.beep;
epilog	
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
	delete theProxyJob;
	delete jobs;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnMoveUpDown" id="fbfb7c5e-6f15-47ed-9405-c19efaf77120">
        <updating/>
        <source>doBtnMoveUpDown(_moveIndex : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//01 Nov 2012	PJS			PAR #30631 - Voyage Rationalisation
// ---------------------------------------------------------------------------

vars
	obj					: Object;
	theVoyage			: CM_Voyage;
	theJob				: CM_VoyageJob;
	theVoyageJS			: CM_VoyageJobSheet;
	index, makeTopRow	: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	
	theVoyage := self.myCurrentVoyage;
	if theVoyage = null then
		return;
	endif;
	makeTopRow := self.tblData.row;
	obj := self.tblData.accessRow(makeTopRow).itemObject;
	
	if JadeTableRow.hasInstance(obj) then
		makeTopRow := self.tblData.row-1;
		obj := self.tblData.accessRow(makeTopRow).itemObject;
	endif;
	
	if obj = null
	or not CM_VoyageJob.hasInstance(obj) then
		app.msgBox(app.getErrorString(Please_Select_Job_Move),app.getErrorString(Job_Move_Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	theJob := obj.CM_VoyageJob;	
	
	theVoyageJS := theJob.myJobSheet.CM_VoyageJobSheet;
	
	if theVoyageJS = null then
		app.msgBox(app.getErrorString(Job_Sheet_Could_Not_Found) &amp; " " &amp; theVoyage.code &amp; "/" &amp; theJob.jobId ,app.getErrorString(Job_Move_Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if self.tblData.allSelectedObjects.size &gt; 1 then
		app.msgBox(app.getErrorString(Only_1_Moved_Time) ,app.getErrorString(Job_Move_Error),	MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	index := theVoyageJS.allJobsByOrder.indexOf(theJob);
	if index &gt; 0 then
		if index =1 and _moveIndex = -1 then
			return;
		endif;
		if index = theVoyageJS.allJobsByOrder.size and _moveIndex = 1 then
			return;
		endif;
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxShiftJobInJobSheet(theJob, app.myPassport, (_moveIndex));
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(Order_Of_Work), app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return;
			
		endwhile;
		
		//epr TFS 830 job move handled by notes 21/3/17		
	endif;

epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_moveIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBtnRenumberClick" id="142cbd97-6316-4982-b981-7f67d17e2543">
        <updating/>
        <source>doBtnRenumberClick() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
begin
	if self.tblData.allSelectedObjects.size = 0 then
		app.msgBox(app.getErrorString(Please_Select_Job_Renumber),app.getErrorString(Job_Renumber_Error), MsgBox_OK_Only);
		return;
	endif;
	
	//epr TFS 830 13/4/17 refactored for reuse
