    <JadeMethod name="translateForm" id="3a28dfa0-5cc2-4457-b11c-22f4bc873384">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 November 2019 08:12:37.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007242, locale);
	btnAll.translateBubbleHelp(Xlat_0000021, locale);
	btnAll.translateCaption(Xlat_0000023, locale);
	btnCams.translateBubbleHelp(Xlat_0000019, locale);
	btnCams.translateCaption(Xlat_0000020, locale);
	btnDelete.translateBubbleHelp(Xlat_0000009, locale);
	btnDelete.translateCaption(Xlat_0000011, locale);
	btnEDI.translateBubbleHelp(Xlat_0000022, locale);
	btnEDI.translateCaption(Xlat_0000024, locale);
	btnEmail.translateBubbleHelp(Xlat_0000015, locale);
	btnEmail.translateCaption(Xlat_0000017, locale);
	btnExtInterface.translateBubbleHelp(Xlat_0022418, locale);
	btnExtInterface.translateCaption(Xlat_0022419, locale);
	btnGarbage.translateBubbleHelp(Xlat_0000028, locale);
	btnGarbage.translateCaption(Xlat_0000031, locale);
	btnGeneral.translateBubbleHelp(Xlat_0000029, locale);
	btnGeneral.translateCaption(Xlat_0000032, locale);
	btnHideSearcher.translateCaption(Xlat_0009747, locale);
	btnPrint.translateBubbleHelp(Xlat_0000016, locale);
	btnPrint.translateCaption(Xlat_0000018, locale);
	btnQuery.translateCaption(Xlat_0009748, locale);
	btnRefresh.translateBubbleHelp(Xlat_0000030, locale);
	btnRefresh.translateCaption(Xlat_0000033, locale);
	btnResetSearch.translateCaption(Xlat_0009749, locale);
	btnShowSearcher.translateCaption(Xlat_0009750, locale);
	btnSystem.translateBubbleHelp(Xlat_0000010, locale);
	btnSystem.translateCaption(Xlat_0000012, locale);
	btnTerminal.translateBubbleHelp(Xlat_0000007, locale);
	btnTerminal.translateCaption(Xlat_0000008, locale);
	clrOne.translateCaption(Xlat_0000025, locale);
	clrTwo.translateCaption(Xlat_0000026, locale);
	frame4.translateCaption(Xlat_0000027, locale);
	frmReport.translateCaption(Xlat_0000013, locale);
