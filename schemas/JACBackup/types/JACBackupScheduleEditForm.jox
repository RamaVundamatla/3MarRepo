    <JadeMethod name="enablePaths" id="afdc1e27-58de-433b-805d-7d0b1a18e4a3">
        <source>enablePaths();
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	i: Integer;
	c: Control;
begin
	foreach i in 1 to self.controlCount do
		c := controls(i);
		if c.parent.name = "frmSplitPaths" then
			if c.name[c.name.length:1].Integer &lt;= self.tbxSplits.text.Integer then
				c.enabled := true;
			else
				c.enabled := false;
			endif;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="0fa92942-6b3d-4548-93cf-615188845c2e">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04/08/2006	cnwdad1		Changed the receiver's caption to show whether the
//							Primary or Secondary is being backed up.
//
//							Also changed so that if this is not running on the
//							server machine, then DO NOT allow updates.
// ---------------------------------------------------------------------------
// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	pathCount	: Integer;
	backupPath	: String;
	formCaption	: String;
	
begin
	self.centreWindow();
	formCaption	:=	self.caption;

	self.cbxRecur.addItem("None");
	self.cbxRecur.addItem("Daily");
	self.cbxRecur.addItem("Weekly");
	self.cbxRecur.addItem("Fortnightly");
	self.cbxRecur.addItem("4-Weekly");
	self.cbxRecur.addItem("12-Hourly");
	self.cbxRecur.addItem("8-Hourly");
	self.cbxRecur.addItem("4-Hourly");
	self.cbxRecur.addItem("2-Hourly");
	self.cbxRecur.addItem("Hourly");
	self.cbxRecur.addItem("Half-Hourly");
	self.cbxRecur.addItem("Quarter-Hourly");
	self.cbxRecur.addItem("Ten-Minutes");
	self.cbxRecur.addItem("Five-Minutes");
	self.cbxRecur.addItem("Two-Minutes");
	self.cbxRecur.addItem("One-Minutes");

	// Load if editing exising.
	if self.mySchedule &lt;&gt; null then
		self.tbxDate.text	:=	self.mySchedule.startTS.Date.format("dd/MM/yyyy");
		self.tbxTime.text	:=	self.mySchedule.startTS.Time.format("HH:mm");
		self.tbxSplits.text	:=	self.mySchedule.numSplits.String;
		self.enablePaths();

		// Show the split paths
		
		if app.isSDSSecondaryBackup() then
			formCaption	:=	formCaption &amp; ": Secondary";
		else
			formCaption	:=	formCaption &amp; ": Primary";
		endif;
		
		self.caption	:=	formCaption;
		
		foreach pathCount in 1 to 9 do
			if pathCount &gt; self.mySchedule.numSplits then
				break;
			endif;
			if app.isSDSSecondaryBackup() then
				if self.mySchedule.splitSecPaths.size &lt; pathCount then
					break;
				endif;
				backupPath	:=	self.mySchedule.splitSecPaths[pathCount];
			else
				if self.mySchedule.splitPaths.size &lt; pathCount then
					break;
				endif;
				backupPath	:=	self.mySchedule.splitPaths[pathCount];
			endif;
				if backupPath &lt;&gt; null then
					self.getControlWithName("tbxPath" &amp; pathCount.String).TextBox.text	:=	backupPath;
				endif;
		endforeach;

		self.cbxRecur.listIndex	:=	cbxRecur.findString(1, self.mySchedule.recur);
		self.chkCompress.value	:=	self.mySchedule.compress;
		self.chkExclude.value	:=	self.mySchedule.exclude;
		self.chkOverwrite.value	:=	self.mySchedule.overwrite;
		self.chkQuiesce.value	:=	self.mySchedule.quiesce;
		self.chkVerify.value	:=	self.mySchedule.verify;
	else
		self.tbxDate.text		:=	app.actualTimeServer.Date.format("dd/MM/yyyy");	// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.tbxTime.text		:=	app.actualTimeServer.Time.format("HH:mm");		// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.enablePaths();
	endif;
	

	if not app.computerName = app.getServerCompName() or app.isSDSSecondaryDB() then
		tbxDate.readOnly		:=	true;
		tbxTime.readOnly		:=	true;
		tbxSplits.readOnly		:=	true;
		cbxRecur.enabled		:=	false;
		chkExclude.readOnly		:=	true;
		chkQuiesce.readOnly		:=	true;
		chkVerify.readOnly		:=	true;
		chkOverwrite.readOnly	:=	true;
