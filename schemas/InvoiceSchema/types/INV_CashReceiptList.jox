    <JadeMethod name="performSearches" id="cec069bb-b235-4c0d-b6b1-1827a3a750d7">
        <updating/>
        <source>performSearches() protected, updating;
/*
Purpose:			Find the cargo to pay for.

Parameters:			

Return Value:		

Date		Who		Reason
01/06/2010	cnwer1	Initial creation
29/07/2015	cnwjre1	36102 add offsite cargo to invoice pro forma only
06/04/2016	cnwdap1	PAR #37730 Convert Customs Entry Number comparison toUpper
21/04/2016 	cnwma1  PAR #37681  QNS - locking issue
25/05/2016	cnwns1	TFS 488 - Multi Timezone Support
15/02/2018	JLGNS1	Bug 36956: PKT - Cash Collection Window
*/

vars
	now			: Date;
	id, 
	cargoId,
	str			: String;
	sa			: StringArray;
	obj			: Object;
	oa,
	objArray 	: ObjectArray;
	ti			: CM_TrackedItem;
	voyage		: CM_Voyage;
	config 		: CM_ProformaTransactionCriteria;
begin
    self.deleteProxyCashReceipt();

	self.setDefaultCargoDebtorDetails();

	self.billOfLading 		 := null;
	self.cmbAgent.listObject := null;
	now	   := self.systemToLocalTime(app.actualTimeServer).date();
	voyage := self.cmbVoyage.listObject.CM_Voyage;
	
	self.txtEffDate.setDate( now );
	create objArray transient;
	create oa transient;
	
	// customs entry number
	id := self.txtItemId1.text.trimBlanks;
	if id &lt;&gt; null then
		foreach ti in self.myTerminal.allOnsiteTIsByCargoTypeId discreteLock do
			if ti.isExport then
				foreach str in ti.allCustomsDetails do
					if str.toUpper = id.toUpper then				
						if ti.isChild then
							continue;
						endif;
						objArray.add(ti);
						break;
					endif;
				endforeach;
			else
				foreach str in ti.allCustomsEntryNumbers do
					if str.toUpper = id.toUpper then			
						if ti.isChild then	
							continue;
						endif;
						objArray.add(ti);
						break;
					endif;
				endforeach;
			endif;
		endforeach;
		
		// 36102 offsite for invoice pro forma
		if self.isInvoiceProforma then
			
			foreach ti in self.myTerminal.allOffsiteTIsByCargoTypeId discreteLock do
				if ti.isExport then
					foreach str in ti.allCustomsDetails do
						if str.toUpper = id.toUpper then			
							if ti.isChild then
								continue;
							endif;
							objArray.add(ti);
							break;
						endif;
					endforeach;
				else
					foreach str in ti.allCustomsEntryNumbers do
						if str.toUpper = id.toUpper then
							if ti.isChild then
								continue;
							endif;
							objArray.add(ti);
							break;
						endif;
					endforeach;
				endif;
			endforeach;
		endif;
	else
	// BOL
		id := self.cmbBOL.text.trimBlanks;
		cargoId := self.txtCargoId.text.trimBlanks; 
		self.billOfLading := id;
		if voyage &lt;&gt; null or id &lt;&gt; null then
			if voyage &lt;&gt; null and cargoId &lt;&gt; null then 
				ti := voyage.lookupTrackedItemAnyWhere(cargoId, objArray); 
				if ti &lt;&gt; null and ti.id = cargoId then	
					objArray.add(ti); 
				endif;
			else
				self.doBOLSearch(voyage, id, objArray);
			endif;
		
		// cargo ids 31177, allow for multiple ids comma-delimited
		else
			id := self.txtCargoId.text.trimBlanks;
			if id &lt;&gt; null then
				create sa transient;
				id.convertToDelimitedArray(",", sa);
			
				foreach id in sa do
					//epr TFS 1856 20/4/16, look onsite/notified/offsite for each set of tis for the id
					oa.clear;
					self.myTerminal.findAllCargoWithId(id,CM_QueryOperator.Operator_Equal,null,TI_STATE_NORMAL,null,null,null,false,oa);
					if oa.isEmpty then
						self.myTerminal.findAllCargoWithId(id,CM_QueryOperator.Operator_Equal,null,TI_STATE_NOTIFIED,null,null,null,false,oa);
					endif;
					if oa.isEmpty then
						if self.isInvoiceProforma then
							self.myTerminal.findAllCargoWithId(id,CM_QueryOperator.Operator_Equal,null,TI_STATE_OFFSITE,null,null,null,false,oa);
						endif;
					endif;
					foreach obj in oa do
						objArray.add(obj);
					endforeach;
				endforeach;
			
			endif;
		endif;
	endif;

	oa.clear;
	foreach obj in objArray do
		if not oa.includes(obj) then
			oa.add(obj);
		endif;
	endforeach;
	
	self.loadCargo( oa );

	if voyage &lt;&gt; null and voyage.myDischargeCompany &lt;&gt; null then
		config := voyage.myDischargeCompany.getVesselProforma(voyage.getMyVessel());
		if config = null then
			config := voyage.myDischargeCompany.getVesselProformaDefault();
		endif;
		if config &lt;&gt; null then
			self.loadVoyage(voyage);
		endif;
	endif;
	
	
	
epilog
	delete objArray;
	delete sa;
	delete oa;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateAgentCombo" id="557f6247-cee0-4978-8901-a0605cde3102">
        <updating/>
        <source>populateAgentCombo(_voyage : CM_Voyage) updating, protected;

/*

Purpose:			Show the cash-only consignee/customs agents etc for the type, if any, in the cash module config screen.

Parameters:			

Return Value:		


Date		Who		Reason
13 September 2013	cnwjre1	Initial creation
15/02/2018	JLGNS1	Bug 36956: PKT - Cash Collection Window
*/

vars
	combo		: ComboBox;
	debtorType	: CM_DebtorType;
begin
	debtorType := self.cashDebtorType;
	if debtorType = null then
		return;
	endif;
	self.txtCustomsAg.visible:=false;
	self.btnCheck.visible:=false;
	combo := self.cmbAgent;
	// add an empty element.  If this is selected, the code makes no change to cargo customs agent/consignee etc
	combo.itemObject[combo.addItem("")] := null;
	
	if debtorType.code = "SDT2" then		// consignee
		self.myAssistant.comboBoxConsignorCashOnlyDr(combo, null, CONSIGNEE, self.myTerminal);
	elseif debtorType.code = "SDT3" then	// consignor
		self.myAssistant.comboBoxConsignorCashOnlyDr(combo, null, CONSIGNOR, self.myTerminal);
	elseif debtorType.code = "SDT4" then	// ship operator // TFS 37454
		self.myAssistant.comboBoxOperatorCashOnlyDr(combo, _voyage, null, self.myTerminal); // TFS 37454
		
	// ### TFS CR 65835 TASK 65891 27AUG2024 NAVAB1
	elseif debtorType.code = "SDT1" then	// cargo operator
		self.myAssistant.comboBoxOperatorCashOnlyDr(combo, null, null, self.myTerminal); // TFS 37454
	elseif debtorType.code = "SDT6" then	// customs agent
		self.myAssistant.comboBoxCustomsAgentCashOnlyDr(combo, null, self.myTerminal);
		//CCMS GHA 2369 &amp; 2373 - eGate Integration
		if  self.myTerminal.getConfig(CashFullCustomsAgentID).Boolean then
			self.cmbAgent.visible:=false;
			self.txtCustomsAg.visible:=true;
			self.btnCheck.visible:=true;
		else	
			self.cmbAgent.visible:=true;		
		endif;
	elseif debtorType.code = "SDT7" then			// freight forwarder
		self.myAssistant.comboBoxConsignorCashOnlyDr(combo, null, FREIGHT_FORWARDER, self.myTerminal);
	endif;
	
//	Bug 36956
//	// select the first?
//	if combo.listCount &gt; 0 then
//		combo.listIndex := 1;
//	endif;	
//	Bug 36956

	self.lblAgent.caption := debtorType.description;
	self.lblAgent.visible := true;
	//self.cmbAgent.visible := true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="populateBolCombo" id="20611df9-62b5-4413-b6de-14e7e624c5cd">
        <source>populateBolCombo(_voyage : CM_Voyage) protected;

/*

Purpose:			33497 BOL search via combo box
					revised 33881 to include all bill of lading from BOL and cargo text
Parameters:			

Return Value:		


Date		Who		Reason
27 February 2014	cnwjre1	Initial creation

*/

vars
	voyageBolNumbers	: StringArray;
	bolNumber			: String;
begin
	self.cmbBOL.clear();
	if _voyage &lt;&gt; null then
		create voyageBolNumbers transient;
		_voyage.getImportBOLNumbers(voyageBolNumbers);
		// 34917 add export BOLs
		_voyage.getExportBOLNumbers(voyageBolNumbers);
		foreach bolNumber in voyageBolNumbers do
			self.cmbBOL.addItem(bolNumber);
		endforeach;
	endif;
epilog
	delete voyageBolNumbers;
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="populateFromQuery" id="0ebc1594-3d9b-4af7-a709-e713c1cfd934">
        <updating/>
        <source>populateFromQuery() updating, protected;
/*
Purpose:			33256 Show the contents of myQueryCashReceipt

Parameters:			

Return Value:		

Date		Who		Reason
07/01/2014	cnwjre1	Initial creation
06/01/2015	cnwdap1	PAR #37337 Display any minimum charge details from the cash receipt
13/10/2017	MAP		Added 2 x tax columns	TFS7357
28/05/2018 	JLGNS1	Bug 38730: Cash Collection - Extra charge lines
10/01/2020  cnwma1	Bug 48211: JMT - 4 x Issues relating to cash credit totals.
25/03/2020  cnwma1  Bug 48966: MTN - Cash Transaction Enquiry - Error 4 when trying to Display CASH Receipt
02/06/2020  cnwma1	Bug 49504: MTN - 1090 Error when loading WorkOrders Cash Receipts
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
*/
vars
	agentName		: String;
	cashReceipt		: CM_CashReceipt;
	agent			: CM_Object;
	edition         : Integer;
	invalidObject   : Boolean;
begin
	
	on Exception do app.handleDeletedObject(exception, agent, invalidObject); 
	if self.myQueryCashReceipt = null then
		return;
	endif;

	cashReceipt := self.myQueryCashReceipt;
	
	if cashReceipt.myCashInvoice &lt;&gt; null then
		self.cashComments := cashReceipt.myCashInvoice.narration;
	endif;
	
	self.proformaDisplayCashReceipt(cashReceipt);
	
	self.caption				 := self.caption &amp; " Query";
	self.frmPayment.borderStyle  := 0;
	self.frmTables.borderStyle   := 0;
	self.frmCargo.borderStyle    := 0;
	self.frmMain.borderStyle     := 0;
	self.frmMain.top             := 0;
	self.frmMain.parentAspect    := 3;
	
	self.setQueryBalances();
	
	//  use text boxes not combos in enquiry, hide unwanted controls
	self.txtItemId2.visible    := true;
	self.txtItemId3.visible    := true;
	self.cmbBOL.visible        := false;
	self.btnEvenWeight.visible := false;
	self.cmbVoyage.visible     := false;
	self.txtItemId2.text 	   := cashReceipt.cashId1;
	self.txtItemId2.readOnly   := true;
	self.txtItemId3.text       := cashReceipt.cashId2;
	self.txtItemId3.readOnly   := true;
	self.txtItemId1.text       := cashReceipt.cashId3;
	self.txtItemId1.readOnly   := true;
	self.txtEffDate.setDate(cashReceipt.effectiveDate);
	self.txtEffDate.readOnly   := true;
	self.txtRelDate.setDate(cashReceipt.shipReleaseDate);		// 36457
	self.txtRelDate.readOnly   := true;
	self.lblDrName.caption     := cashReceipt.getDebtor().getListName();
	self.txtCargoId.visible    := false;
	self.lblAgent.visible      := false;
	self.cmbAgent.visible      := false;
	self.lblBOLWeight.visible  := false;
	self.lblCredit.visible     := false;
	self.txtCashPayment2nd.enabled :=false;     //10.01.2020 cnwma1 #48211
	
	//  show the agent as well, use lblAgent
	
	agent 	:= cashReceipt.myAgent;
	
	if agent &lt;&gt; null then                      //02.06.2020 cnwma1 #49504
		edition := agent.edition;
	endif;
	
	if not invalidObject then                   //25.03.2020 cnwma1 #48966
		if agent &lt;&gt; null then
			self.lblAgent.left  := self.lblEffDate.left + 10;
			self.lblAgent.width := self.lblAgent.width + self.cmbAgent.width;
			if agent.isKindOf(CM_ConsigneeConsignor) then
				agentName := agent.CM_ConsigneeConsignor.description &amp; " " &amp; agent.CM_ConsigneeConsignor.code;
			elseif agent.isKindOf(CM_CustomsAgent) then
				agentName := agent.CM_CustomsAgent.name;
			endif;
			self.lblAgent.alignment    := 1;		// left-justify this
			self.lblAgent.caption      := agentName;
			self.lblAgent.visible      := true;
		endif;
	endif;
	
	self.chkPrintRec.visible       := false;
	self.btnCalculate.visible      := false;
	self.btnSave.visible           := false;
	self.btnSave.enabled 		   := app.myCurrentUserCan( self.myTerminal, PmGteCashCollectionMaint );	//10 Dec 2019	NDL	TFS 47963
	self.btnRun.visible            := false;
	self.mnuExtraItems.visible     := false;
	self.mnuExtraItemsView.visible := false;	//Bug 38730
	self.btnExtraItems.visible 	   := false;
	// still show the cargo enquiry menu
	self.mnuCargoEnquiry.visible   := true;
	self.btnEdit.visible           := true; 
	self.btnEdit.enabled           := self.doEnableEdit();    	    //10 Dec 2019	NDL	TFS 47963 //10.09.2021 navma1 #51002
	self.btnComments.enabled       := false; 
	self.chkForRelease.visible     := false;
	
epilog


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTaxDetails" id="38601b69-8046-4468-a23e-a88681cb1aae">
        <source>populateTaxDetails() protected;
/*

Date		Who		Reason
14 April 2016	cnwer1	Initial creation PAR

*/

vars

begin
	self.lblTax1.visible		:= false;
	self.lblTaxValue1.visible	:= false;
	self.lblTax2.visible		:= false;
	self.lblTaxValue2.visible	:= false;
	self.lblTax3.visible		:= false;
	self.lblTaxValue3.visible	:= false;
	self.lblTaxValue1.caption 	:= null;
	self.lblTaxValue2.caption 	:= null;
	self.lblTaxValue3.caption 	:= null;
	self.lblZeroTax.visible		:= false;
	
	// do tax unless debtor is zero-rated
	if self.myDebtor &lt;&gt; null 
	and not self.myDebtor.isZeroRatedTax 
	and not self.isVoyageExempt() then // TFS 37562 exempt by voyage
	   
	   if self.taxValue1 &lt;&gt; null then
		    self.lblTax1.visible	  := true;
			self.lblTaxValue1.visible := true;
			self.lblTaxValue1.caption := self.taxValue1.asCurrencyJMT;
			if self.allowSecondCurrency then
				self.lblTaxValue12nd.caption := self.getSecondaryAmount( self.taxValue1);
			endif;
		endif;
	   
	    if self.taxValue2 &lt;&gt; null then
		    self.lblTax2.visible	  := true;
			self.lblTaxValue2.visible := true;
			self.lblTaxValue2.caption := self.taxValue2.asCurrencyJMT;
			if self.allowSecondCurrency then
				self.lblTaxValue22nd.caption := self.getSecondaryAmount( self.taxValue2);
			endif;
		endif;
		
		 if self.taxValue3 &lt;&gt; null then
		    self.lblTax3.visible	  := true;
			self.lblTaxValue3.visible := true;
			self.lblTaxValue3.caption := self.taxValue3.asCurrencyJMT;
			if self.allowSecondCurrency then
				self.lblTaxValue32nd.caption := self.getSecondaryAmount( self.taxValue3);
			endif;
		endif; 
	else		
		self.lblZeroTax.visible:=true;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateVoyageCombo" id="ea9b5863-5dc0-41e4-94a2-837fca7f41d0">
        <source>populateVoyageCombo() protected;

/*

Purpose:			33497 voyage search via combo box

Parameters:			

Return Value:		


Date		Who		Reason
27 February 2014	cnwjre1	Initial creation

*/

vars
	voyage	: CM_Voyage;
	voyages	: CM_VoyageSet;
begin
	create voyages transient;
	self.cmbVoyage.clear();
	self.myTerminal.getAllCurrentVoyagesCashColl(voyages);		// 13/9/19 MAP TFS46519
	foreach voyage in voyages do
		self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code)] := voyage;
	endforeach;

epilog
	delete voyages;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="proformaAddMinChargesForWhole" id="3ef6383c-7358-4155-b3db-cdfbac696668">
        <source>proformaAddMinChargesForWhole(_allPxyCashPays : ObjectArray input);

// TFS 45953 Refactor UI, WO and UT to use 1 cash receipt TRX
// TFS 45953 THIS CODE HAS BEEN MOVED TO CMIF_ProformaInvLinesForDebtor::proformaAddMinChargesForWhole


















/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jun 2019	jlgab1	Initial creation
23 Sep 2019 cnwma	Bug 46673: New form - Minimum charge narration missing when minimum charge by Invoice  
*/
/*
vars
	pxyCashPayment 		: CM_CashPayment;
	proformaDetail, 
	minAmount 			: CM_ProformaDetails;
	allMinimumAmounts   : CM_ProformaDetailsByInvType;
	newLine 			: CM_InvoiceLine;
	seqNum			    : Integer;
	now 			    : TimeStamp;
	charge 				: CM_Charge;
	bank 				: CM_Bank;
	debtor 				: CM_Debtor;
	drterm 				: CM_DebtorTerminal;
	tempAgent 			: CM_CashInvoiceProformaAgent;
	invCashPayment, 
	taxCashPayment, 
	totalAllocated 		: Real;
	*/		
begin
/*
	now := app.actualTimeServer();	

	if self.myProxyCashReceipt = null then
		return;
	endif;
	
	if self.myProxyCashReceipt.allCashPayments.isEmpty() then
		return;
	endif;
	totalAllocated := self.myProxyCashReceipt.cashValue;
	
	create tempAgent transient;
	
	foreach pxyCashPayment in self.myProxyCashReceipt.allCashPayments do
		proformaDetail := pxyCashPayment.myProformaDetail;
		
		if proformaDetail = null then
			continue;
		endif;
*/		
		/*First Type of Minimum Charge By Invoice */
/*		if proformaDetail.myInvoiceLineType.minimumChargeGroupBy = CM_InvoiceLineDesc.GROUP_BY_INVOICE then
			if allMinimumAmounts = null then
				create allMinimumAmounts transient;
			endif;
			
			minAmount := allMinimumAmounts[proformaDetail.myInvoiceLineType];
			if minAmount= null then
				create minAmount transient;
				minAmount.setPropertyValue(CM_ProformaDetails::myInvoiceLineType.name, proformaDetail.myInvoiceLineType);
				allMinimumAmounts.add(minAmount);
			endif;
			
			minAmount.setValue(minAmount.lineTotal + pxyCashPayment.cashValue);
			
			if bank= null then
				bank := pxyCashPayment.getBank();
			endif;
			if drterm = null then
				drterm := pxyCashPayment.myDebtorTerminal;
				debtor := drterm.myDebtor;
			endif;		
		endif;
	endforeach;
	
	if allMinimumAmounts = null then
		return;
	endif;
	
	foreach minAmount in allMinimumAmounts discreteLock do
		if minAmount.myInvoiceLineType.minimumChargeAmount &gt; minAmount.lineTotal then
			invCashPayment := minAmount.myInvoiceLineType.minimumChargeAmount - minAmount.lineTotal;
			
			
			
			
			create newLine transient;
			seqNum := seqNum + 1;
			newLine.setForCreate(seqNum, false, null, minAmount.myInvoiceLineType.minimumChargeInvoiceLineType, null, debtor, bank, 1, now);
			newLine.createChargesProforma(seqNum);
			foreach charge in newLine.charges do
				charge.total := invCashPayment;
				charge.setOverriden();
				charge.setRateForMinMax(invCashPayment);
			endforeach;
			
			
			taxCashPayment := newLine.getTaxAmountForLine();                                       //23.09.2019 cnwma1 #46673
			pxyCashPayment := tempAgent.createProxyPaymentForList(true,                            //23.09.2019 cnwma1 #46673  
																self.myProxyCashReceipt,
																newLine, 
																invCashPayment, 
																taxCashPayment, 
																totalAllocated,
																now,
																drterm,
																null);
			
			pxyCashPayment.setCashReceipt(self.myProxyCashReceipt);
			_allPxyCashPays.add(pxyCashPayment);
			pxyCashPayment.setIsMinimumCharge(true);
			
			delete newLine;
		endif;
	endforeach;
	*/
	
epilog
/*
	delete tempAgent;
	delete newLine;
	if allMinimumAmounts&lt;&gt; null then
		allMinimumAmounts.purge();
		delete allMinimumAmounts;
	endif;
	*/
end;</source>
        <Parameter name="_allPxyCashPays" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="proformaDisplayCashReceipt" id="a5f9f66a-227f-4ba8-8030-a5d43318aa27">
        <updating/>
        <source>proformaDisplayCashReceipt(_pxyCashReceipt : CM_CashReceipt) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2019	jlgab1	Initial creation
25 Sep 2019 cnwma1	Bug 46582: Cash Credit are not being accounted for correctly
30 Oct 2019	jlgma1	Bug 46674: JMT - Form - Minimum charges does not calculate minimum charges when grouping invoice lines
26 Nov 2019 cnwma1	Bug 47681: PIBT - Unable to save receipts
11 Feb 2020 cnwma1  Bug 48511: JMT - Duplicate Narration for Manual Cash Payment on Cash Collection Screen
*/

vars
	realCashReceipt			: CM_CashReceipt; //20/01/2025	navkc1 JIRA Bug MTN-33463
	pxyCashPayment, 
	realCashPayment 		: CM_CashPayment;
	typeStr, 
	narrStr, 
	childStr, 
	parentStr, 
	sortStr 				: String;
	taxValue, 
	totalValue,
	totalCashValue, 
	totalTaxValue, 
	grandTotalValue, 
	totPayment,
	creditOnPayment,
	creditOnPaymentTax		: Decimal [23,6];
	dynaDict 				: DynaDictionary;
	iter 					: Iterator;
	lastTI, 
	currentTI 				: CM_TrackedItem;
	newRow 					: Integer;
	checkboxvalue, 
	paidStr, 
	debtorStr 				: String;
	showPaidDebtor, 
	showProformaDebtor, 
	isProformaPrintPayment	: Boolean;
	currentTopRow 			: Integer;
	currentVoyage, 
	firstVoyage 			: CM_Voyage;
begin
	
	if _pxyCashReceipt = null then
		return;
	endif;
	
	currentTopRow		:= self.tblCharges.topRow;
	showPaidDebtor 		:= self.myTerminal.getConfig(ShowDebtorForPayment).Boolean;
	showProformaDebtor  := self.myTerminal.getConfig(ShowDebtorForProforma).Boolean;
	

	_pxyCashReceipt.applyCreditOnProxy();   						        //26.09.2019 cnwma1 #46582
	_pxyCashReceipt.applyMinChargeByGroupOnProxy(self.isInvoiceProforma);   //31.10.2019 cnwma1	#46674
	self.initChargesTable();
	
	
	create dynaDict transient;	
	dynaDict.setMembership(CM_CashPayment);
	dynaDict.addExternalKey(String, 100, false, true	); // TI ID
	dynaDict.addExternalKey(String, 100, false, true	); // NARRATION
	dynaDict.addExternalKey(String, 100, false, true	); // SORT
	dynaDict.endKeys(true);
	
	
	
	foreach pxyCashPayment in _pxyCashReceipt.allCashPayments	discreteLock do
		sortStr := "Z"; // Put any exisitng payment at the bottom
		if pxyCashPayment.myTrackedItem &lt;&gt; null then
				if pxyCashPayment.myTrackedItem.isChild then
					parentStr := pxyCashPayment.myTrackedItem.myParent.id;
					childStr := pxyCashPayment.myTrackedItem.id;
					if not pxyCashPayment.pxyIsProxy() then
						sortStr := "A"; // Put any new payment at the top
					endif;
				else
					parentStr := pxyCashPayment.myTrackedItem.id;
					childStr := "";
					if not pxyCashPayment.pxyIsProxy() then
						sortStr := "A"; // Put any new payment at the top
					endif;
				endif;
		else
				parentStr := "ZZZZZZZZZZ";
				childStr := "ZZZZZZZZZ";
		
		endif;
		dynaDict.putAtKey(parentStr, childStr,sortStr,pxyCashPayment);
	endforeach;
	
	totalCashValue 		:= 0;
	totalTaxValue 		:= 0;
	grandTotalValue 	:= 0;
	totPayment 			:= 0;
	creditOnPayment     := 0;
	creditOnPaymentTax  := 0;
	
	// ### TFS 46857 - Handle cargo with No cash payments, show just the cargo line so extra payments can be added
	if dynaDict.isEmpty() then
		foreach currentTI in _pxyCashReceipt.allTrackedItems	discreteLock do
			// ### NEXT CARGO ITEM
			parentStr := currentTI.id;
			newRow := self.tblCharges.addItemObject(currentTI, Tab &amp; parentStr &amp; Tab &amp; currentTI.cargoBOLTypeDescr &amp; " " &amp; currentTI.billOfLading);
			self.tblCharges.accessRow(newRow).backColor := LightYellow;
	
		endforeach;
		self.setBalances(); // TFS 46857 jlgzm1 16/10/2019
	
		return;
	endif;
	
	iter := dynaDict.createIterator();

	while(iter.next(pxyCashPayment))  do
		taxValue               := 0;
		typeStr 			   := "";
		narrStr                := "";
		totalValue             := 0;
		childStr               := "";
		parentStr              := "";
		debtorStr              := "";
		creditOnPayment        := 0;
		creditOnPaymentTax     := 0;
		isProformaPrintPayment := false;
		
		if pxyCashPayment.myCashPaymentForTax &lt;&gt; null then
			taxValue := pxyCashPayment.myCashPaymentForTax.cashValue;
		endif;
		
		currentTI := pxyCashPayment.myTrackedItem;
		
		if currentTI&lt;&gt; null then
			if lastTI = null or lastTI &lt;&gt; currentTI then
				if lastTI &lt;&gt; null  and lastTI &lt;&gt; currentTI then
					// ### CARGO TOTAL
					newRow := self.tblCharges.addItemObject(_pxyCashReceipt, Tab &amp; "" &amp; Tab &amp; Tab &amp; Tab &amp;
																			totalCashValue.asStringJMTWithPrecision(2,true) &amp; Tab &amp; 
																			totalTaxValue.asStringJMTWithPrecision(2,true) &amp; Tab &amp; 
																			grandTotalValue.asStringJMTWithPrecision(2,true) &amp; Tab &amp; 
																			totPayment.asStringJMTWithPrecision(2,true));
					self.tblCharges.accessRow(newRow).backColor := LightOrange;
					
					
					totalCashValue  := 0;
					totalTaxValue   := 0;
					grandTotalValue := 0;
					totPayment      := 0;
				endif;
			
			
				if currentTI.isChild then
					parentStr := "(" &amp; currentTI.myParent.id &amp; ") " &amp; currentTI.id;
				else
					parentStr := currentTI.id &amp; " " &amp; currentTI.totalWeight.Integer.String &amp; " kg";
				endif;
				// ### NEXT CARGO ITEM
				newRow := self.tblCharges.addItemObject(currentTI, Tab &amp; parentStr &amp; Tab &amp; currentTI.cargoBOLTypeDescr &amp; " " &amp; currentTI.billOfLading);
				self.tblCharges.accessRow(newRow).backColor := LightYellow;
			endif;
		elseif pxyCashPayment.myVoyage &lt;&gt; null then
				if lastTI &lt;&gt; null  then
					// ### LAST CARGO TOTAL
					newRow := self.tblCharges.addItemObject(_pxyCashReceipt, Tab &amp; "" &amp; Tab &amp; Tab &amp; Tab &amp;
																			totalCashValue.asStringJMTWithPrecision(2,true) &amp; Tab &amp; 
																			totalTaxValue.asStringJMTWithPrecision(2,true) &amp; Tab &amp; 
																			grandTotalValue.asStringJMTWithPrecision(2,true) &amp; Tab &amp; 
																			totPayment.asStringJMTWithPrecision(2,true));
					self.tblCharges.accessRow(newRow).backColor := LightOrange;
					
					
					totalCashValue  := 0;
					totalTaxValue   := 0;
					grandTotalValue := 0;
					totPayment      := 0;
				endif;
			parentStr :=pxyCashPayment.myVoyage.code;
			currentVoyage := pxyCashPayment.myVoyage;
			
			if firstVoyage = null then
				firstVoyage := currentVoyage;
				newRow := self.tblCharges.addItemObject(currentVoyage, Tab &amp; parentStr &amp; Tab &amp; " ETA: " &amp; currentVoyage.getArrivedDTLocalTZ().asStringJMT()
														&amp; " ETD: " &amp; currentVoyage.getEstimatedArrivalDTLocalTZ().asStringJMT());
				self.tblCharges.accessRow(newRow).backColor := LightYellow;
			endif;

		endif;
		
		totalCashValue  := totalCashValue + pxyCashPayment.cashValue;
		totalTaxValue   := totalTaxValue  + taxValue;
		grandTotalValue := totalCashValue + totalTaxValue;
		
		
		typeStr 	  := pxyCashPayment.getPaymentType(self.isInvoiceProforma); 								//11.02.2020 cnwma1 #48511
		narrStr 	  := pxyCashPayment.getPaymentNarration(true,true); 		 							    //11.02.2020 cnwma1 #48511
		checkboxvalue := pxyCashPayment.getPaymentCheckBox(self.myQueryCashReceipt,self.isInvoiceProforma);      //11.02.2020 cnwma1 #48511
		
		// ### EXTRA EXTRA
		if pxyCashPayment.manual then	
		// ### INVOICED INVOICED
		elseif pxyCashPayment.myInvoiceLine &lt;&gt; null then	
		// ### ESTIMATE
		else
			if showProformaDebtor then
				isProformaPrintPayment := self.getProformaPrintDebtor(pxyCashPayment, debtorStr);
			endif;
		endif;
		
		totalValue := pxyCashPayment.cashValue + taxValue;
		
		if pxyCashPayment.pxyIsProxy  // update proxy = existing cash payment
		or self.myQueryCashReceipt &lt;&gt; null then
			
			realCashPayment := pxyCashPayment.pxyGetRealObject().CM_CashPayment;
			
			//20/01/2025	navkc1 JIRA Bug MTN-33463
			if self.myQueryCashReceipt &lt;&gt; null then
				realCashReceipt := self.myQueryCashReceipt;
			else
				realCashReceipt := realCashPayment.myCashReceipt;
			endif;
			
			//20/01/2025	navkc1 JIRA Bug MTN-33463 - Return the status for receipt generated from the API
			if realCashReceipt.paymentStatus &gt;= CM_CashReceipt.API_RECEIPT_DRAFT and realCashReceipt.paymentStatus &lt;= CM_CashReceipt.API_RECEIPT_FINAL then
				paidStr := app.paymentStatusCashEnumToString(realCashReceipt.paymentStatus);
			else
				paidStr 	    := app.getErrorString(Paid);
			endif;
			checkboxvalue   := "";

			 // ### JIRA 35213 01JUL2025 NAVAB1
			if realCashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_CANCELLED then
				totalCashValue  := totalCashValue - pxyCashPayment.cashValue;
				totalTaxValue   := totalTaxValue  - taxValue;
				grandTotalValue := totalCashValue - totalTaxValue;
			endif;
			
			
			
			
			if showPaidDebtor 
			and realCashPayment &lt;&gt; null then	
					debtorStr :=  realCashPayment.getDebtorName(); 
			endif;

		else
			if self.isInvoiceProforma then
				paidStr := app.getErrorString(Proforma);
			else
				paidStr := app.getErrorString(Outstanding);
			endif;
			
			if pxyCashPayment.status = self.StatusSelected then
				totPayment := totPayment + pxyCashPayment.cashValue;
				if pxyCashPayment.hasTax  then
					totPayment := totPayment + pxyCashPayment.myCashPaymentForTax.cashValue;
				endif;
			endif;
		endif;
		
		// ### CASH PAYMENT
		newRow := self.tblCharges.addItemObject(pxyCashPayment,
																checkboxvalue	 &amp; Tab &amp; 
																typeStr 		 &amp; Tab &amp;
																narrStr 		 &amp; Tab &amp;
																paidStr 		 &amp; Tab &amp; 
																pxyCashPayment.cashValue.asStringJMTWithPrecision(2,true) &amp; Tab &amp; 
																taxValue.asStringJMTWithPrecision(2,true)                 &amp; Tab &amp; 
																totalValue.asStringJMTWithPrecision(2,true)               &amp; Tab &amp;
																debtorStr);
		
		if not pxyCashPayment.pxyIsProxy    // not an update
		and self.myQueryCashReceipt = null  // show cash receipt
		and not self.isInvoiceProforma then // proforma non cash module mode
			self.tblCharges.accessCell(newRow, 1).inputType := Table.InputType_CheckBox;
		endif;
		
		if showProformaDebtor 
		and isProformaPrintPayment 
		and debtorStr&lt;&gt; "" then
			self.tblCharges.accessCell(newRow, 8).backColor := LightYellow;
		endif;
				
		if pxyCashPayment.isMinimumCharge then  //11.02.2020 cnwma1  #48531
			self.tblCharges.accessCell(newRow, 1).enabled := false;
		endif;
		
		lastTI := currentTI;
	endwhile;
	
	if not dynaDict.isEmpty() then
		newRow := self.tblCharges.addItemObject(_pxyCashReceipt,Tab &amp; Tab &amp; Tab &amp; Tab &amp;
																totalCashValue.asStringJMTWithPrecision(2,true)  &amp; Tab &amp; 
																totalTaxValue.asStringJMTWithPrecision(2,true)   &amp; Tab &amp; 
																grandTotalValue.asStringJMTWithPrecision(2,true) &amp; Tab &amp; 
																totPayment.asStringJMTWithPrecision(2,true));
		self.tblCharges.accessRow(newRow).backColor := LightOrange;
	endif;
	
	
	self.setBalances();
	self.tblCharges.topRow := currentTopRow;

epilog
	delete dynaDict;
end;</source>
        <Parameter name="_pxyCashReceipt" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="proformaGetAndDisplay" id="f39f02be-b1a4-4965-b739-0a1e0af3a1dc">
        <updating/>
        <source>proformaGetAndDisplay( _allTIs : ObjectArray input) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
*/

vars
	allAgents : CM_CashProformaAgentSet;
	pxyCashReceipt : CM_CashReceipt;
	tmpController : CMIF_ProformaInvLinesForDebtor; // DMAST ONLY
	allCashReceiptFound : CM_CashReceiptSet; //06/05/2025	navkc1 JIRA Bug MTN-34734
begin
		self.deleteProxyCashReceipt();
		
		create allCashReceiptFound transient; //06/05/2025	navkc1 JIRA Bug MTN-34734
		
		//06/05/2025	navkc1 JIRA Bug MTN-34734
		if _allTIs.isEmpty() then
			self.getAllSelectedCargo(_allTIs);
		endif;
		
		self.getTIsPendingOrPaidCashReceipt(_allTIs, allCashReceiptFound); //06/05/2025	navkc1 JIRA Bug MTN-34734
		
		// ############################################################
		// ### CREATE PROFORMA PAYMENTS
		// ############################################################
		allAgents := self.proformaGetProformas(_allTIs);
		// ############################################################
		// ### CREATE CASH RECEIPT
		// ############################################################
		
		pxyCashReceipt := self.proformaProxyCashReceipt(allAgents);
		self.myProxyCashReceipt := pxyCashReceipt;
		// ############################################################
		// ### CREATE CASH PAYMENTS
		// ############################################################
		 // TFS 45953 self.proformaProxyCashPayments(pxyCashReceipt,allAgents);
		  // DMAST ONLY
		create tmpController transient; // TFS 45953 Refactoring so UI, WorkOrders and Units Tests all call the same create cash receipt code
		tmpController.proformaProxyCashPayments(pxyCashReceipt,allAgents, true); // TFS 45953 added true // TFS 45953
		
		// ############################################################
		// ### Remove unecessary cash payments //06/05/2025	navkc1 JIRA Bug MTN-34734
		// ############################################################
		self.doCompareProformaAndExisting(pxyCashReceipt, allCashReceiptFound); //06/05/2025	navkc1 JIRA Bug MTN-34734
		
		// ############################################################
		// ### DISPLAY CASH RECEIPT
		// ############################################################
		self.proformaDisplayCashReceipt(pxyCashReceipt);
		
epilog
	//06/05/2025	navkc1 JIRA Bug MTN-34734/34800
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents; // TFS 45953
	delete tmpController; // DMAST ONLY
	delete allCashReceiptFound; //06/05/2025	navkc1 JIRA Bug MTN-34734
end;</source>
        <access>protected</access>
        <Parameter name="_allTIs" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="proformaGetProformas" id="b380ee66-2b3e-4f23-8fa0-d543ab8607eb">
        <updating/>
        <source>proformaGetProformas( _allTIs : ObjectArray input) : CM_CashProformaAgentSet protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Sep 2019	jlgma1	Bug 46660: UX issue in new cash form when changing effective date
*/

vars
	parentAgent,
	proformaAgent		: CM_CashInvoiceProformaAgent;
	agent				: CM_Object;
	fullProforma		: Boolean;
	releaseDate			: Date;
	effectiveTSLocal	: TimeStamp;
	releaseTSLocal		: TimeStamp;
	drTerm				: CM_DebtorTerminal;
	obj					: Object;
	ti 					: CM_TrackedItem;
	bank 				: CM_Bank;
	terminal			:  CM_Terminal;
	proformaPayment 	: CM_CashPayment;
	voyage 				: CM_Voyage;
	proformaAgentVessel : CM_CashProformaVoyageAgent;
	allAgents 			: CM_CashProformaAgentSet;
begin
	
	terminal 			:=  self.getMyTerminal;
	voyage 				:= self.cmbVoyage.listObject.CM_Voyage;
	fullProforma 		:= not self.chkForRelease.value;
	
	if self.myDebtor &lt;&gt; null then													
		drTerm := self.myDebtor.allDebtorTerminals[self.myTerminal];				
	endif;		
	
	if _allTIs.isEmpty then					//30.09.2019 cnwma1 #4660			
		self.getAllSelectedCargo(_allTIs);
	endif;
	
	// purge transient proforma agents
	self.tblCharges.clear;
	if self.isInvoiceProforma then
		self.initChargesTable();
		agent := self.cmbAgent.listObject.CM_Object;
	else
		self.initChargesTable();
	endif;
	
	// if 'for cargo release' is checked, the pro forma is to do just the road release, to match the release validation
	effectiveTSLocal.cnEcSetDateAndTime(self.txtEffDate.getDate(),TimeStartOfDay);	// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	releaseTSLocal.cnEcSetDateAndTime(self.txtRelDate.getDate(),TimeStartOfDay);	// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	effectiveDate := self.localToSystemTime(effectiveTSLocal).date();
	releaseDate   := self.localToSystemTime(releaseTSLocal).date(); 
	
	create allAgents transient;
	// create a proforma agent and charge table lines for each item, both parent and child, but only show the parents initially
	foreach obj in _allTIs discreteLock do	
		ti 		:= obj.CM_TrackedItem;
		bank    := ti.companyOid;
		
		if bank = null then
			bank := self.myTerminal.getDefaultCompanyBank();
		endif;

		/*		TFS 47985 myCashReceiptProformaPrint is not used
		foreach proformaPayment in ti.allCashPaymentProformaPrints do											// TFS 5740
			if proformaPayment.myDebtorTerminal = drTerm then													// TFS 5740
				self.myCashReceiptProformaPrint := proformaPayment.myCashReceipt.CM_CashReceiptProformaPrint;	// TFS 5740
			endif;																								// TFS 5740
		endforeach;																								// TFS 5740
		*/	
		create proformaAgent transient;
		proformaAgent.init( bank, ti, effectiveDate, fullProforma );
		proformaAgent.setDebtorFromAgent(self.myDebtor);
		proformaAgent.setReleaseDate(releaseDate);
		proformaAgent.createProformaInvLines(null, false, false );
		proformaAgent.getCurrentInvLines();
		
		/* TFS 45953 NO LONGER USE CHANLD STUFF
		// keep a collection of the child agents on the parent agent for consolidation
		if ti.isParent then
			parentAgent := proformaAgent;
		//else									// TFS 5740 30/08/2017
		elseif ti.isChild then					// TFS 5740 30/08/2017
			if parentAgent &lt;&gt; null then
				parentAgent.allChildAgents.add(proformaAgent);
			// TFS 45953 never used	proformaAgent.isChildAgent := true;
			endif;
		endif;
		*/
		allAgents.add(proformaAgent);
	endforeach;
	
	// TFS 37454
	if voyage &lt;&gt; null and self.includeVoyageProforma then
	
		create proformaAgentVessel transient;
		proformaAgentVessel.initialise(voyage, null, false, false );
		proformaAgentVessel.createProformaInvLines(null, false, false );
		proformaAgentVessel.getCurrentInvLines();
		allAgents.add(proformaAgentVessel);

	endif;
	
	/* TFS 45953 NO LONGER NEEDED
	// populate the table after creating the agents
	foreach proformaAgent in allAgents do
		ti := proformaAgent.myTrackedItem;
		if ti &lt;&gt; null and ti.isParent then
			proformaAgent.consolidateChildCharges();
		endif;
	endforeach;
	*/
	// ########################################################################
	// ########################################################################
	
	
	return allAgents;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allTIs" type="ObjectArray" usage="input"/>
        <ReturnType type="CM_CashProformaAgentSet"/>
    </JadeMethod>
    <JadeMethod name="proformaProxyCashReceipt" id="e152e566-74af-475b-9f13-d4e452c65d71">
        <source>proformaProxyCashReceipt(_allAgents : CM_CashProformaAgentSet) : CM_CashReceipt;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2019	jlgab1	Initial creation
23 September 2019	jlgma1	Bug 46645: New cash form - subsequent payments going to default business unit
26 Nov 2019 cnwma1  Bug 47681: PIBT - Unable to save receipts
*/

vars
	pxyCashRec 		   : CM_CashReceipt;
	cashPaymentAmount  : Decimal [23,6];
	proformaAgent	   : CM_CashInvoiceProformaAgent;
	now, 
	releaseTSLocal     : TimeStamp;
	releaseDate        : Date;
	user               : CM_User;
	drTerm 			   : CM_DebtorTerminal;
	payMeth 		   : CM_PaymentMethod;
	voyage 			   : CM_Voyage;
	voyCode, 
	bolNumber 		   : String;
	newSeq			   : Integer;
	invoiceLine		   : CM_InvoiceLine;
	showProformaDebtor : Boolean;
	bank               : CM_Bank;
begin
	
	if _allAgents.isEmpty then
		return null ;
	endif;
	now     := app.actualTimeServer;
	user    := app.getMyUser;
	drTerm  := self.myTerminal.allDebtorTerminals.getAtKey( self.myDebtor );
	payMeth := self.cmbMOP.listObject.CM_PaymentMethod;
	bank    := _allAgents.first.CM_CashInvoiceProformaAgent.myBank;

	foreach proformaAgent in _allAgents	discreteLock do
		cashPaymentAmount := cashPaymentAmount + proformaAgent.getProformaCashValue();
	
	endforeach;
	

	showProformaDebtor := self.myTerminal.getConfig(ShowDebtorForProforma).Boolean;
	
	if showProformaDebtor then
		create pxyCashRec as CM_CashReceiptProformaPrint transient; 
	else
		create pxyCashRec transient; 	
	endif;
	pxyCashRec.setProxy(cashPaymentAmount,				//_cashValue : Decimal;
						now,							//_dateTime : TimeStamp;
						user,					   		//_myUser : CM_User;
						0,//drTerm.getNextRecSeqNum,	//_sequenceNum : Integer;    //26.11.2019 cnwma1 #47681
						self.txtChqBank.text,			//_chequeBank : String;
						self.txtChqBranch.text,			//_chequeBranch : String;
						self.txtChqNumber.text,			//_chequeNumber : String;
						self.txtChqDate.getDate(),		//_chequeDate : Date;
						payMeth,						//_myPaymentMethod : CM_PaymentMethod;
						drTerm,							//_myDebtorTerminal : CM_DebtorTerminal;
						0								//_paymentType : Integer
						);

	voyage    := self.cmbVoyage.listObject.CM_Voyage;
	voyCode   := self.cmbVoyage.text;
	bolNumber := self.cmbBOL.text.trimBlanks();
	
	
	pxyCashRec.setPxyForBank(bank); //23.09.2019 cnwma1 #46645
	
	pxyCashRec.setProxy2(voyCode,								// _cashId1
					 bolNumber,									// _cashId2
					 self.txtItemId1.text.trimBlanks(),			// _cashId3
					 null, 										// _cashId4 : String
					 self.txtCashPayment.text.asDecimalJMT,		// _payment1 : Decimal
					 self.txtCashPayment2nd.text.asDecimalJMT,	// _payment2 : Decimal
					 self.effectiveDate,						// _effectiveDate : Date
					 null,
					 self.txtPosReceipt.text.trimBlanks(),		//  _externalInvoiceNumber, _externalReferenceNumber : String
					 0,
					 0,
					 0,
					 0,
					 voyage,									// _myVoyage : CM_Voyage
					 self.cmbAgent.listObject.CM_Object,		// _agent
					 null,
					 self.myTerminal);
			
			
 			
	pxyCashRec.setTaxValues(self.taxValue1, self.taxValue2, self.taxValue3, self.taxCode1, self.taxCode2, self.taxCode3);

	if self.txtRelDate.enabled then
		releaseTSLocal.cnEcSetDateAndTime(self.txtRelDate.getDate(),TimeStartOfDay);
		releaseDate := self.systemToLocalTime(releaseTSLocal).date();// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		pxyCashRec.setShipReleaseDate(releaseDate);		// 36457
	endif;

	newSeq := 1;
	foreach proformaAgent in _allAgents do
		foreach invoiceLine in proformaAgent.allProformaInvLines do
			if not invoiceLine.manual then		// Bug 37608 - skip manual paid lines		
				if invoiceLine.sequenceNum = Max_Integer then
					invoiceLine.invoice := null;		// to prevent the sequence number change being applied to an invalid .invoice property
					invoiceLine.sequenceNum := newSeq;	// to get unique ids for the CM_CashReceipt allProformaInvoiceLines dictionary
					newSeq := newSeq + 1;
					pxyCashRec.allProformaInvoiceLines.add(invoiceLine);
				endif;
			endif;	
		endforeach;
		
		/* TFS 45953 nothing was adding to allExtraProfInvLines, it is always empty
		// and the extra charges
		foreach invoiceLine in proformaAgent.allExtraProfInvLines do
			invoiceLine.invoice := null;		// to prevent the sequence number change being applied to an invalid .invoice property
			invoiceLine.sequenceNum := newSeq;	// to get unique ids for the CM_CashReceipt allProformaInvoiceLines dictionary
			newSeq := newSeq + 1;
			pxyCashRec.allProformaInvoiceLines.add(invoiceLine);
		endforeach;
*/
	

		if proformaAgent.myTrackedItem &lt;&gt; null then								// PAR #36909
			pxyCashRec.allTrackedItems.add(proformaAgent.myTrackedItem);
		endif;																	// PAR #36909
	endforeach;
	
	return pxyCashRec;
epilog

end;</source>
        <Parameter name="_allAgents" type="CM_CashProformaAgentSet"/>
        <ReturnType type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="runSelectorQuery" id="e5dfa1c5-02a4-4cfe-8fd9-a7f062cf38e4">
        <updating/>
        <source>runSelectorQuery(objArray: ObjectArray io): Boolean protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 January 2013	cnwndl1	Initial creation
19 November 2019	jlgmp6	Copied to new cash collection	TFS47595

*/

vars
	
	enqController : CM_EnquiryController;
	realCriteriaLineHolder,
	criteriaLineHolder		: CM_QueryCriteriaLineHolder;
	realCriteriaLine,
	criteriaLine			: CM_SelectorCriteriaLine;
	searchValueA		: String;
	valueTranslated		: Any;
	allCriteriaHolders		: ObjectArray;
	obj						: Object;
	queryType					: Integer;
	
begin

	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	
	self.mySelectorQuery := self.myTerminal.getProformaItemQuery();
	
	if self.mySelectorQuery &lt;&gt; null then
	
		app.myQAFilter.createEnqControllerForMode(self.mySelectorQuery.queryMode, self.mySelectorQuery.getType, enqController);
	
		enqController.numItemsFoundLimit	:= null;
	
		create enqController.allObjects as CM_ObjectSet transient;
		create allCriteriaHolders transient;
		
		searchValueA:=self.txtItemId1.text;
		
		if searchValueA = null then
			return true;
		endif;
		
		foreach criteriaLineHolder in self.mySelectorQuery.allCriteriaLineHolders do
					
			realCriteriaLineHolder:=criteriaLineHolder;
			criteriaLineHolder := realCriteriaLineHolder.cloneSelf(true);
			criteriaLineHolder.setForUpdate( realCriteriaLineHolder );	
			allCriteriaHolders.add(criteriaLineHolder);
			
			foreach realCriteriaLine in realCriteriaLineHolder.allCriteriaLines do
				
					create criteriaLine transient; 
					criteriaLine.setMyCriteriaLineHolder( criteriaLineHolder );
					criteriaLine.setForUpdateForRT( realCriteriaLine );	
					
					if realCriteriaLine.isUnavailableAtRunTime then
						continue;
					endif;
					
					valueTranslated := criteriaLine.myQueryProperty.translateStringToSearchValue( searchValueA, criteriaLine );
					criteriaLine.myQueryOperator.setSearchValue( valueTranslated );
			endforeach;
			
		endforeach;
		
		
		queryType := self.mySelectorQuery.getType;
		foreach obj in allCriteriaHolders do
			criteriaLineHolder:=obj.CM_QueryCriteriaLineHolder;
			enqController.myCriteriaLineHolder := criteriaLineHolder;
			enqController.doQuery( app.myRoot.allQueryDefinitionObjects[queryType, self.mySelectorQuery.queryMode] );
			
			if app.myPassport.hasErrors then
				app.msgBox(app.myPassport.allErrors.first.text,app.myPassport.allErrors.first.errorCode.asStringJMT,MsgBox_OK_Only);
				return false;
			endif;
		endforeach;
		
		
		if app.myPassport.hasErrors then
			app.msgBox(app.myPassport.allErrors.first.text,app.myPassport.allErrors.first.errorCode.asStringJMT,MsgBox_OK_Only);
			return false;
		endif;
	
	endif;
	
	self.loadSearchResults( enqController, objArray );
	
	return true;
	
epilog
	delete enqController;
	if allCriteriaHolders &lt;&gt; null then
		allCriteriaHolders.purge;
	endif;
	
	delete allCriteriaHolders;
end;</source>
        <access>protected</access>
        <Parameter name="objArray" type="ObjectArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAgentCombo" id="f64d6744-e639-4fdf-8984-23fc3d4bde63">
        <updating/>
        <source>setAgentCombo(_ti : CM_TrackedItem) updating, protected;

/*

Purpose:			Populate the agent combo from the (first) selected items

Parameters:			

Return Value:		


Date		Who		Reason
13 September 2013	cnwjre1	Initial creation

*/

vars
	combo		: ComboBox;
	debtorType	: CM_DebtorType;
	ca			: CM_CustomsAgent;
	cc			: CM_ConsigneeConsignor;
	op : CM_Operator;
begin
	self.myDebtor := null;
	debtorType := self.cashDebtorType;
	if debtorType = null or
	   _ti = null then
		return;
	endif;
	combo := self.cmbAgent;
	if combo.listIndex &gt; 1 then
		return;
	endif;
	if debtorType.code = "SDT2" then		// consignee
		cc := _ti.getConsigneeObject();
		if cc &lt;&gt; null then
			combo.listIndex := combo.findObject(cc);
			self.myDebtor := cc.debtor; // TFS 44275

		endif;
	elseif debtorType.code = "SDT3" then	// consignor
		cc := _ti.getConsignorObject();
		if cc &lt;&gt; null then
			combo.listIndex := combo.findObject(cc);
			self.myDebtor := cc.debtor; // TFS 44275
		endif;
	elseif debtorType.code = "SDT6" then	// customs agent
		ca := _ti.myCustomsAgent;
		if ca &lt;&gt; null then
			combo.listIndex := combo.findObject(ca);
			self.myDebtor := ca.myDebtor; // TFS 44275
		endif;
	elseif debtorType.code = "SDT7" then			// freight forwarder
		cc := _ti.myFreightForwarder;
		if cc &lt;&gt; null then
			combo.listIndex := combo.findObject(cc);
			self.myDebtor := cc.debtor; // TFS 44275
		endif;
	// ### TFS CR 65835 TASK 65891 27AUG2024 NAVAB1
	elseif debtorType.code = "SDT1" then			// cargo operator
		op := _ti.myOperator;
		if op &lt;&gt; null then
			combo.listIndex := combo.findObject(op);
			self.setMyDebtor(op.debtor);
		endif;
		
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setAgentComboVessel" id="76d0f430-af25-4274-9bc6-b86d33fe8039">
        <updating/>
        <source>setAgentComboVessel(_voyage : CM_Voyage) updating, protected;

/*
Purpose:		TFS 37454	
Date				Who			Reason
MARCH 2018		CNWAB1		Initial creation
*/


vars
	combo		: ComboBox;
	debtorType	: CM_DebtorType;
	op : CM_Operator;
begin
	debtorType := self.cashDebtorType;
	if debtorType = null or
	   _voyage = null then
		return;
	endif;
	combo := self.cmbAgent;
	if combo.listIndex &gt; 1 then
		return;
	endif;
	if debtorType.code = "SDT4" then		
		op := _voyage.myOperator;
		if op&lt;&gt; null then
			combo.listIndex := combo.findObject(op);
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setBalances" id="7f60ffa7-3850-4911-8750-4dca9eaa9977">
        <updating/>
        <source>setBalances() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
18 Jul 2012	cnwndl1				Initial creation
25 May 2016	cnwns1	TFS 488 	Multi Timezone Support
04 Oct 2017	jlgdap1	TFS 7204 	Correct real handling for non-standard locales
19 Apr 2018 jlgmd1	TFS 38165 	JMT - Invoice Proforma Calculate Button causing 14050
18 Oct 2017	jlgrh7 	TFS 40904  	GUQ - Read only Label currency Translation not Available on JMT#851.220
21 Mar 2019	jlgka1  TFS 43618	PKT - Error While Calculating Invoice. 
20 Sep 2019 cnwma1	Bug 46581:  Cash Credit balance field not being shown on the new cash collection form
18 Sep 2019	cnwma1	Bug 46582:  Cash Credit are not being accounted for correctly
07 Nov 2019 cnwma1  Bug 47351:  JMT - Cash Collection - Secondary currency Total with Credit
10 Jan 2020 cnwma1  Bug 48211:  JMT - 4 x Issues relating to cash credit totals.
03 Feb 2020 cnwma1  Bug 48450:  ADP - FW: 200420000856 - ##341337##
03 Mar 2020 cnwma1  Bug 49055: MTN - Cash Collection - Unknown amount turning up in Totals area
============================================================================*/

vars
	effectiveDate		: TimeStamp;
	taxValue,
	taxTotal,
	creditAvailable,
	creditUsed,
	cashTotal ,
	totalCargoCharges,
	chargeTax			: Decimal[23,6];
	taxCode 			: CM_TaxCode;
	count  				: Integer;
	drTerm				: CM_DebtorTerminal;
	taxRate				: CM_TaxRate;
	oa					: ObjectArray;
	obj					: Object;
	cashPayment 		: CM_CashPayment;
	taxCodeStr, 
	taxDescStr 			: String;
begin
	cashTotal 						 := 0;
	taxTotal  						 := 0;
	self.creditTotal 				 := 0;
	self.cashAlreadyPaid 			 := 0;
	self.cashRequiredToClearCharges  := 0;
	self.cashPaymentSecondary  	  	 := 0;
	self.taxValue1					 := null; 
	self.taxValue2					 := null; 
	self.taxValue3					 := null; 
	self.txtCashPayment2nd.text 	 := "0.00";
	self.txtCashPayment.text 		 := "0.00";
	lblCredit.caption          	     := null;
	self.txtCashPayment.enabled      := false;     //10.01.2020 cnwma1 #48211
	
	if self.showServiceTax then // Only blank these is using proper tax. If using GHANA tax these are ponly set once, when the screen is opened.
	
		self.taxCode1 := null;
		self.taxCode2 := null;
		self.taxCode3 := null;
	endif;
	
	self.populateTaxDetails();
	
	self.lblSubTotal2.caption := cashTotal.asCurrencyJMT;
	if self.allowSecondCurrency then
		self.lblSubTotal2nd.caption := self.getSecondaryAmount(0);
		self.lblCashPayReqd2.caption :=self.getSecondaryAmount(0);
	endif;
	
	self.lblCashPayReqd2.caption := cashTotal.asCurrencyJMT;
	
	if self.myProxyCashReceipt = null then
		return;
	endif;
	
	foreach cashPayment in self.myProxyCashReceipt.allCashPayments	discreteLock do
		if cashPayment.pxyIsProxy then // a real cash payment
			continue;
		endif;
		
		if cashPayment.status = self.StatusNotSelected then
			continue;
		endif;

		cashTotal := cashTotal + cashPayment.cashValue;
		
		totalCargoCharges := totalCargoCharges + cashPayment.cashValue; 
		
		
		
		if self.showServiceTax then
			taxDescStr := cashPayment.getTaxCode(true);
			taxCodeStr := cashPayment.getTaxCode(false);
			
			chargeTax := 0; 												   // 03.04.2020 cnwma1 #49055
			if cashPayment.hasTax() then
				//chargeTax  := cashPayment.getTaxAmountForPayment();          // 03.02.2020 cnwma1 #48450
				chargeTax    :=  cashPayment.myCashPaymentForTax.cashValue;    // 03.02.2020 cnwma1 #48450
			endif;
			if self.taxValue1 = 0 then
				self.lblTax1.caption := taxDescStr;
				self.taxCode1 		 := taxCodeStr;
				self.taxValue1 	     := chargeTax;
			
			elseif self.lblTax1.caption = taxDescStr then
				self.taxValue1	     := self.taxValue1 + chargeTax;
			
			elseif self.taxValue2 = 0 then
				self.lblTax2.caption := taxDescStr;
				self.taxCode2 		 := taxCodeStr;
				self.taxValue2 		 := chargeTax;
			
			elseif self.lblTax2.caption = taxDescStr then
				self.taxValue2 		 := self.taxValue2 + chargeTax;
			
			elseif self.taxValue3 = 0 then
				self.lblTax3.caption := taxDescStr;
				self.taxCode3 		 := taxCodeStr;
				self.taxValue3 		 := chargeTax;
			
			elseif self.lblTax3.caption = taxDescStr then
				self.taxValue3 		 := self.taxValue3 + chargeTax;
			endif;
		endif;
		
	endforeach;
	
	
	
	if self.myDebtor &lt;&gt; null then
		drTerm := self.myDebtor.allDebtorTerminals[self.myTerminal];
		if drTerm &lt;&gt; null then
			creditAvailable  := drTerm.getCreditAmount();
			self.creditTotal := creditAvailable;										   	   				 // TFS 1953
			if creditAvailable &gt; 0 then                                        			 	  				 //20.09.2018 cnwma1 # 46581
				self.lblCredit.caption    := "Credit Value " &amp; creditAvailable.roundedTo(2).asCurrencyJMT; 	 //20.09.2018 cnwma1 # 46581
				self.lblCredit.visible    := true;                                 			   				 //20.09.2018 cnwma1 # 46581
			else
				self.lblCredit.caption    := null;                                 			    			//18.09.2019 cnwma1 TFS #46582
				self.lblCredit.visible    := false;                               			 				//18.09.2019 cnwma1 TFS #46582
			endif;
		endif;
	endif;
	// do tax unless debtor is zero-rated
	if self.myDebtor &lt;&gt; null 
	and not self.myDebtor.isZeroRatedTax 
	and not self.isVoyageExempt() then 				// TFS 37562 exempt by voyage
		effectiveDate := app.actualTimeServer;		// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
		if self.showServiceTax then
			taxTotal := self.taxValue1 + self.taxValue2 + self.taxValue3;
		else
			foreach obj in self.allTaxCodes do
				count := count + 1;
				taxCode := obj.CM_TaxCode;
				taxRate := taxCode.getTimeRate(effectiveDate);
				if taxRate &lt;&gt; null then
					taxValue := ((totalCargoCharges * taxRate.rate) / 100);
					taxTotal := taxTotal + taxValue;
					if count = 1 then
						self.taxValue1 := taxValue;
					elseif count = 2 then
						self.taxValue2 := taxValue;				
					elseif count = 3 then
						self.taxValue3 := taxValue;		
					endif;
				endif;
			endforeach;
		endif;
	endif;
	
	self.populateTaxDetails();
	
	// CHECK THE ROUNDING HERE!!!
	self.cashRequiredToClearCharges := totalCargoCharges + taxTotal;                               //09.01.2020 cnwma1 #48211
	self.lblCashPayReqd2.caption 	:= self.cashRequiredToClearCharges.roundedTo(2).asCurrencyJMT;

	
	// save off values to persist in CM_CashReceipt
	
	self.lblCreditUsed.visible  := creditAvailable &gt; 0;
	self.lblCreditValue.visible := creditAvailable &gt; 0;
	
	if creditAvailable &gt; 0 then
		if self.cashRequiredToClearCharges &gt;= creditAvailable then
			creditUsed := creditAvailable;
			self.cashRequiredToClearCharges := self.cashRequiredToClearCharges - creditAvailable;
		else
			creditUsed                      := self.cashRequiredToClearCharges;
			self.cashRequiredToClearCharges := 0;
		endif;
		self.lblCreditValue.caption := creditUsed.asCurrencyJMT();
		self.cashAlreadyPaid 		:= creditUsed;
		if self.allowSecondCurrency then
			self.lblCredit2nd.caption := self.getSecondaryAmount(self.cashAlreadyPaid);
		endif;
	endif;
	
	self.lblSubTotal2.caption := totalCargoCharges.asCurrencyJMT;
	if self.allowSecondCurrency then
		self.lblSubTotal2nd.caption :=self.getSecondaryAmount(totalCargoCharges);
	endif;
	
	self.cargoTotalCharges := totalCargoCharges;                 //21.10.2019 cnwma1 TFS #47081
	//cnwmc5 - 14 Sep 2015 - PAR 36895
	self.calculateRounding();
	
	/*
	07.11.2019 cnwma1 #47351
	Cash Payment Required
	Should be here after adding rounding and subtracting credit
	*/
	if self.allowSecondCurrency then             
		self.lblCashPayReqd2nd.caption := self.getSecondaryAmount(self.cashRequiredToClearCharges);
	endif;
	
	// the text value has to be numeric to be re-entered so don't format it using asCurrencyJMT, a String cast is correct
	if self.cashRequiredToClearCharges &gt; 0 then
		self.txtCashPayment.text 	 := self.cashRequiredToClearCharges.asStringJMT;			// TFS 7204
		self.lblCashPayReqd2.caption := self.cashRequiredToClearCharges.asCurrencyJMT();
	else
		self.txtCashPayment.text 	 := "0.00";
		self.lblCashPayReqd2.caption := "0.00";
	endif;
	self.txtCashPayment2nd.text := null;
	self.lblPayC2.caption 		:= '';									
	self.stackValueControls(false);

epilog
	delete oa;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDefaultCargoDebtorDetails" id="8d29d4bf-4b5f-4fdc-b103-70fb4a22bd9b">
        <updating/>
        <source>setDefaultCargoDebtorDetails() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.setMyDebtor(null);
	self.tblCharges.rows:=self.tblCharges.fixedRows;
	self.cmbAgent.listIndex := -1;

	if self.myQueryCashReceipt = null then
		self.setBalances();
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFormConfigSetting" id="597b5883-a89c-428e-a3b2-3880990250ce">
        <updating/>
        <source>setFormConfigSetting()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Feb 2020	cnwma1  Bug 48450: ADP 

*/

vars
	taxCodeList    : String;
	term 		   : CM_Terminal;
begin
	term    	 := self.myTerminal;
	taxCodeList  := term.getConfig(CashAllCashTax).String ;
	
	self.showServiceTax     := taxCodeList = null and term.getConfig(InvoiceMultiTaxRates).Boolean;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setInitialControlValues" id="52153a5e-fba5-4218-8fe5-fa90ccc89865">
        <updating/>
        <source>setInitialControlValues() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 Jul 2012	cnwndl1	Initial creation	Par 29968
25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
28 May 2018	JLGNS1	Bug 38730: Cash Collection - Extra charge lines
15 Aug 2018	jlgrh7  TFS #40269 GUQ - Currency rate converter/currency type maintenance
18 Oct 2017	jlgrh7 TFS40904  GUQ - Read only Label currency Translation not Available on JMT#851.220
25 Sep 2019 cnwma1  Bug 46707: JMT - Payment Method combo box being cropped
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
*/

vars

	now 		: Date;
	taxCode		: CM_TaxCode;
	sa		    : StringArray;
	defaultBank	: CM_Bank;
	codeList	: String;
	code		: String;
	count		: Integer;

begin

	now := self.systemToLocalTime(app.actualTimeServer).date();// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.setNavigatorHeading( self.caption );

	if self.myQueryCashReceipt = null then
		// TFS 1802 8/4/16
		self.allowSecondCurrency := self.myTerminal.getConfig(CashAllowSecondCurrency).Boolean;
	
		if self.allowSecondCurrency then
			self.secondCurrencySymbol := self.myTerminal.getCashSecondPayCurrency;
			self.convertMultiplyRate  := self.getMultiplyRate(self.secondCurrencySymbol );						//+TFS40269
		else
			self.lblPayC2.visible := false;																																//+TFS40904
		endif;
	else
		self.allowSecondCurrency:=(self.myQueryCashReceipt.cashPayment2 &gt; 0);
	endif;
	
	self.cashDebtorType := self.myTerminal.getConfig(CashDebtorType).CM_DebtorType;
	if self.cashDebtorType &lt;&gt; null then
		self.populateAgentCombo(null); // TFS 37454
	endif;
	self.showToolbar := false;

	self.minimumHeight := 600;
	self.minimumWidth := 1000;
	
	self.frmPayment.borderStyle       := 0;
	self.frmTables.borderStyle        := 0;
	self.frmCargo.borderStyle         := 0;
	self.frmMain.borderStyle          := 0;
	self.frmMain.top 				  := 0;
	self.frmMain.parentAspect 		  := 3;
	self.frmPaymentValues.borderStyle := 0;
	self.frmPay2nd.borderStyle 		  := 0;
	self.lblSubTotal1.top 			  := 1;
	self.lblSubTotal2.top 			  := 1;
	self.lblSubTotal2nd.top 		  := 1;        // 25.09.2019 cnwma1 #46707
	
	if self.myAssistant = null then
		create self.myAssistant transient;
		self.myAssistant.setMyTerminal(self.myTerminal);		// from 34227
	endif;
	self.myAssistant.comboBoxMethodOfPayment( self.cmbMOP, false );
	// 33497 use combos for input
	self.txtItemId2.visible := false;
	self.txtItemId3.visible := false;
	self.cmbBOL.left 	    := self.txtItemId3.left;
	self.lblBOLWeight.left  := self.cmbBOL.left + self.cmbBOL.width + 10;
	self.cmbBOL.top			:= 5;
	self.cmbBOL.tabIndex 	:= self.txtItemId3.tabIndex;
	self.cmbBOL.visible 	:= true;
	
	self.btnEvenWeight.left := self.cmbBOL.left + self.cmbBOL.width + 10;
	self.cmbVoyage.left 	:= self.txtItemId2.left;
	self.cmbVoyage.tabIndex := self.txtItemId2.tabIndex;
	self.cmbVoyage.visible  := true;
	self.populateVoyageCombo();

	self.btnEvenWeight.left   := self.btnRun.left;
	self.lblBOLWeight.caption := "";
	self.lblCredit.visible 	  := false;

	self.txtEffDate.setDate( now );
	// enable Even Weight by permission
	self.btnEvenWeight.enabled := false;
	
	
	self.setDefaultCargoDebtorDetails();

	self.taxValue1 := null;
	self.taxValue2 := null;
	self.taxValue3 := null;
	self.taxCode1  := null;
	self.taxCode2  := null;
	self.taxCode3  := null;

	// TFS 44275 if using proper tax but also had tax codes on the config it only showed the proper tax for the codes in the config
	if not showServiceTax then 

		// show configured taxes 
		codeList := self.myTerminal.getConfig(CashAllCashTax).String;
		create sa transient;
		codeList.asStringArrayByDelimiter(sa, ",");
		defaultBank := self.myTerminal.getDefaultCompanyBank();
		if defaultBank &lt;&gt; null then
			// get the actual current tax code from the saved code string
			foreach code in sa do
				taxCode := defaultBank.allTaxCodes[code];
				if taxCode &lt;&gt; null then
					self.allTaxCodes.add(taxCode);
					count := count + 1;
					if count = 1 then
						self.lblTax1.visible 	  := true;
						self.lblTax1.caption 	  := taxCode.description;
						self.lblTaxValue1.visible := true;
						self.lblTaxValue1.caption := "";
						self.taxCode1 			  := code; 
					elseif count = 2 then
						self.lblTax2.visible 	  := true;
						self.lblTax2.caption 	  := taxCode.description;
						self.lblTaxValue2.visible := true;
						self.lblTaxValue2.caption := "";
						self.taxCode2 			  := code; 
					elseif count = 3 then
						self.lblTax3.visible 	  := true;
						self.lblTax3.caption 	  := taxCode.description;
						self.lblTaxValue3.visible := true;
						self.lblTaxValue3.caption := "";
						self.taxCode3 			  := code; 
						break;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	
	self.lblZeroTax.visible:= not lblTax1.visible;
	self.lblZeroTax.caption := "(" &amp; app.getErrorString(INV_Zero_Rated_Tax) &amp; ")";	
	
	///self.setDefaultCargoDebtorDetails();
	self.lblStatus.caption := "";
	// 34917 make the trace option visible to users
	self.mnuTrace.visible := true;
	
	// if invoice proforma, hide the unwanted controls and rename some
	if self.isInvoiceProforma then
		self.btnEvenWeight.visible     := false;
		self.btnSave.caption 		   := "Print";
		self.btnSave.enabled 			:= true;	//10 Dec 2019	NDL	TFS 47963
		self.btnExtraItems.visible     := false;
		self.chkForRelease.visible     := false;
		self.chkPrintRec.visible 	   := false;
		self.cmbMOP.visible 		   := false;
		self.lblMoP.visible 		   := false;
		self.frmChqDetails.visible     := false;
		self.frmPOSDetails.visible     := false;
		self.mnuExtraItems.visible     := false;
		self.mnuExtraItemsView.visible := false;	
		self.lblDebtor.caption         := "Debtor";
		self.lblCashPayReqd.caption    := "Payment Required";
		self.lblCashPayment.caption    := "Payment";
	endif;
	
	self.lblCashPayment2nd.visible     := self.allowSecondCurrency;
	self.txtCashPayment2nd.visible     := self.allowSecondCurrency;
	if self.allowSecondCurrency then
		self.lblCashPayment2nd.caption :=  self.secondCurrencySymbol;	
	endif;	
	
	if self.shouldRound then
		self.lblRoundUp.visible      := true;
		self.lblRoundUpValue.visible := true;
		self.lblRoundUpValue.caption := "";
	endif;
	
	self.btnEdit.enabled := self.doEnableEdit() ;	//10 Dec 2019	NDL	TFS 47963  //10.09.2021 navma1 #51002
	
	self.stackValueControls(true);
	
epilog
	delete sa;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyDebtor" id="3d8c8b39-6e82-4059-b028-fec12e15ef94">
        <updating/>
        <source>setMyDebtor( _debtor : CM_Debtor ) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.myDebtor := _debtor;
	if self.myDebtor = null then
		if self.isInvoiceProforma then
			self.lblDrName.caption := "";
		else
			self.lblDrName.caption := "No Cash Debtor";
		endif;
	else
		self.lblDrName.caption := self.myDebtor.getListName;
	endif;
	
	self.cargoTotalCharges := 0;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="setProxyCashReceiptAmounts" id="27c153ca-81a7-46ae-956a-17d8b265f75b">
        <source>setProxyCashReceiptAmounts(now : TimeStamp);
/*
Purpose:	TFS 44275		
Date			Who	   Reason
JUNE 2019		JLGAB1 initial creation
09/01/2019      cnwma1 Bug 48211: JMT - 4 x Issues relating to cash credit totals.
*/


vars

begin
	
	self.myProxyCashReceipt.setPxyForPaymentDetails(self.txtChqBank.text,
													self.txtChqBranch.text,
													self.txtChqNumber.text,
													self.txtChqDate.getDate(),
													self.txtPosReceipt.text.trimBlanks());

	self.myProxyCashReceipt.setTaxValues(self.taxValue1, 
										self.taxValue2, 
										self.taxValue3, 
										self.taxCode1, 
										self.taxCode2, 
										self.taxCode3);

	self.myProxyCashReceipt.setRoundingDifference(self.roundingDifference);

	self.myProxyCashReceipt.setProxy2(self.myProxyCashReceipt.cashId1,
										self.myProxyCashReceipt.cashId2,
										self.txtItemId1.text.trimBlanks(),
										null, 
										self.cashRequiredToClearCharges,	//self.txtCashPayment.text.asDecimalJMT, 	//21.10.2019 cnwma1 TFS #47081
										self.cashPaymentSecondary,		    //self.txtCashPayment2nd.text.asDecimalJMT, //21.10.2019 cnwma1 TFS #47081	
										self.myProxyCashReceipt.effectiveDate,
										null,
										self.myProxyCashReceipt.externalReceiptNumber,
										self.cargoTotalCharges,
										self.cashAlreadyPaid,
										self.cargoTotalCharges,
										self.cashRequiredToClearCharges,
										self.myProxyCashReceipt.myVoyage,
										self.myProxyCashReceipt.myAgent,
										null, 
										self.myTerminal);
	
	self.myProxyCashReceipt.setDateTime(now); // TFS 45894 set to NOW

	//self.myProxyCashReceipt.setPxyCashValue();//	TFS 47990  //- 09.01.2020 cnwma1 #48211
epilog

end;</source>
        <Parameter name="now" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setQueryBalances" id="1067c997-e6c9-4d3d-890a-39291343ca02">
        <updating/>
        <source>setQueryBalances() protected, updating;

/*

Purpose:			33256 Show the contents of myQueryCashReceipt

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	cnwndl1	Initial creation
18 Oct 2017	jlgrh7 TFS40904  GUQ - Read only Label currency Translation not Available on JMT#851.220
*/

vars
	invalidMethod	: Boolean;
	ed				: Integer;
	mop				: CM_PaymentMethod;
	cashReceipt		: CM_CashReceipt;
	taxCodeObj		: CM_TaxCode;
begin
	
	
	on Exception do app.handleDeletedObject(exception, mop, invalidMethod);
	
	cashReceipt := self.myQueryCashReceipt;

	self.lblCashPayReqd2.caption := cashReceipt.cashPaymentRequired.asCurrencyJMT;
	
	self.lblSubTotal2.caption := cashReceipt.totalCargoCharges.asCurrencyJMT;
	
	self.lblPayC2.visible := false;																			//+TFS40969
	// 37141 show any credit
	if cashReceipt.cashAlreadyAllocated &gt; 0 then
		self.lblCreditValue.caption := cashReceipt.cashAlreadyAllocated.asCurrencyJMT();
		self.lblCreditUsed.visible := true;
		
	else
		self.lblCreditValue.visible := false;
		self.lblCreditUsed.visible := false;
	endif;
	// TFS 1802 show 2nd cash value
	self.txtCashPayment.text := cashReceipt.cashPayment1.String;
	self.txtCashPayment.readOnly := true;
	self.txtCashPayment2nd.text := cashReceipt.cashPayment2.String;
	self.txtCashPayment2nd.enabled := false;
	
	self.lblStatus.caption := cashReceipt.getExternalInvoiceNumber &amp; "   " &amp; cashReceipt.dateTime.asStringJMT();	// 36476 fix external number

	self.frmChqDetails.visible := false;
	self.frmPOSDetails.visible := false;
	mop := cashReceipt.myPaymentMethod;
	// no inverse, guard against deleted payment method
	ed := mop.edition;
	if invalidMethod then
		mop := null;
	endif;
	if mop &lt;&gt; null then
		if mop.isCheque then
			self.frmChqDetails.visible := true;
			self.txtChqBank.text := cashReceipt.chequeBank;
			self.txtChqBank.readOnly := true;
			self.txtChqBranch.text := cashReceipt.chequeBranch;
			self.txtChqBranch.readOnly := true;
			self.txtChqDate.text := cashReceipt.chequeDate.asStringJMT();
			self.txtChqDate.readOnly := true;
			self.txtChqNumber.text := cashReceipt.chequeNumber;
			self.txtChqNumber.readOnly := true;
		elseif mop.isPOS then
			self.frmPOSDetails.visible := true;
			self.txtPosReceipt.text := cashReceipt.externalReceiptNumber;
			self.txtPosReceipt.readOnly := true;
		endif;
	endif;
	
	self.myDebtor := cashReceipt.getDebtor();
	
	//epr par 37737 tfs 1802 14/4/16
   if cashReceipt.taxValue1 &lt;&gt; null then
		self.lblTax1.visible:=true;
		self.lblTaxValue1.visible:=true;
		self.lblTaxValue1.caption := cashReceipt.taxValue1.asCurrencyJMT;
		if cashReceipt.taxCode1 &lt;&gt; null and cashReceipt.myBank &lt;&gt; null then
			taxCodeObj := cashReceipt.myBank.allTaxCodes.getAtKey(cashReceipt.taxCode1);
			if taxCodeObj &lt;&gt; null then
				self.lblTax1.caption := taxCodeObj.description;
			endif;
		endif;
	endif;
	if cashReceipt.taxValue2 &lt;&gt; null then
		self.lblTax2.visible:=true;
		self.lblTaxValue2.visible:=true;
		self.lblTaxValue2.caption := cashReceipt.taxValue2.asCurrencyJMT;
		if cashReceipt.taxCode2 &lt;&gt; null and cashReceipt.myBank &lt;&gt; null then
			taxCodeObj := cashReceipt.myBank.allTaxCodes.getAtKey(cashReceipt.taxCode2);
			if taxCodeObj &lt;&gt; null then
				self.lblTax2.caption := taxCodeObj.description;
			endif;
		endif;
	endif;
	if cashReceipt.taxValue3 &lt;&gt; null then
		self.lblTax3.visible:=true;
		self.lblTaxValue3.visible:=true;
		self.lblTaxValue3.caption := cashReceipt.taxValue3.asCurrencyJMT;
		if cashReceipt.taxCode3 &lt;&gt; null and cashReceipt.myBank &lt;&gt; null then
			taxCodeObj := cashReceipt.myBank.allTaxCodes.getAtKey(cashReceipt.taxCode3);
			if taxCodeObj &lt;&gt; null then
				self.lblTax3.caption := taxCodeObj.description;
			endif;
		endif;
	endif;
	self.lblZeroTax.visible := cashReceipt.taxValue1 = 0;

	//cnwmc5 - 15 Sep 2015 - PAR 36985
	if self.shouldRound then
		self.lblRoundUp.visible := true;
		self.lblRoundUpValue.visible := true;
		self.lblRoundUpValue.caption := cashReceipt.roundingDifference.asCurrencyJMT;
	endif;
	
	//epr par 37737 tfs 1802 14/4/16
	self.stackValueControls(false);
	
	// re-use lblCargoId for the method of payment, overlay cmbMOP with it
	self.lblCargoId.parent := self.cmbMOP.parent;
	self.lblCargoId.top := self.cmbMOP.top;
	self.lblCargoId.left := self.cmbMOP.left;
	self.lblCargoId.width := self.cmbMOP.width;
	self.lblCargoId.parentAspect := self.cmbMOP.parentAspect;
	
	if mop &lt;&gt; null then
		self.lblCargoId.caption := mop.description;
	endif;
	self.cmbMOP.visible := false;
	self.lblCargoId.visible := true;
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="73adcc35-6816-4fa9-9f8b-b98a28235c70">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/07/2012	cnwndl1	Initial creation	Par 29968
15/08/2017	jlgdap1	TFS 5740 AAT Changes to Pro Forma Invoices
28/05/2018 	JLGNS1	Bug 38730: Cash Collection - Extra charge lines
17/03/2020  cnwma1  Bug 48915: AAT - RE: FW: Ticket 48826 Re: Cash Collection Testing Issue
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
*/

vars
	term 				: CM_Terminal;
	isWorkOrderCashRec  : Boolean;
begin

	term                         := self.myTerminal;				 	//10.09.2021 navma1 #51002
	self.btnPrintNow.visible     := myQueryCashReceipt &lt;&gt; null;
	self.mnuTableContext.visible := false; 
	self.lblDrName.visible       := true;  							 	//17.03.2020 cnwma1 #48915
	self.setFormConfigSetting();
	
	
	if myQueryCashReceipt &lt;&gt; null then								   //10.09.2021 navma1 #51002	
		isWorkOrderCashRec := myQueryCashReceipt.isWorkOrderCashRec();
	endif;
	
	
	if not self.isInvoiceProforma then
		if not isWorkOrderCashRec then                                //10.09.2021 navma1 #51002
			if not app.isCashOnlyEnabled then
				self.unloadForm;
				return;
			
			elseif self.myTerminal = null or not self.myTerminal.isCashOnlyEnabled then
				app.msgBox(app.getErrorString(Term_not_cash_enabled), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
				self.unloadForm;
				return;
			endif;

			if self.myTerminal.getCashInvoiceType( null ) = null then
				app.msgBox("Cash Module Config option 'Cash Invoice Type' must be set.", "Error", 0);
				self.unloadForm;
				return;
			endif;
		endif;
	else
		self.caption := app.getErrorString(Invoice_Proforma);
	endif;
	
	self.setNavigatorHeading(self.caption);
	self.selectedString := true.cnEcGetTableCheckBoxValue;

	inheritMethod();
	// from 33885, set current bank for receipt report
	if self.myAssistant = null then
		create self.myAssistant as INV_Assistant transient;
		self.myAssistant.setMyTerminal(self.myTerminal);		
	endif;
	
	self.mnuExtraItemsView.visible := false;
	

	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnExtraItems.enabled 		 := false;
		self.btnSave.enabled             := false;
		self.tblCharges.userInputEnabled := false;
		self.btnComments.enabled		 := false;
		self.mnuExtraItems.enabled		 := false;
		self.mnuExtraItemsView.enabled 	 := false;	
		self.cmbAgent.enabled			 := false;
		self.txtCustomsAg.enabled		 := false;
		self.btnCheck.enabled			 := false;
	endif;
	
	self.setInitialControlValues();
	
	if self.myQueryCashReceipt &lt;&gt; null then
		self.populateFromQuery();
		self.btnPrintProforma.visible := false; 
		return;
	endif;

	self.isSelectorCapable := true;
	
	
	self.openWithSavedSettings();

	if not self.isInvoiceProforma then
		self.doChangeMOP();
	endif;
	
	self.tblCharges.visible := true;
	self.initCargoTable();
	
	self.chkPrintRec.caption := app.getErrorString(Print_receipt);
	
	//epr TFS 2334 18/7/16
	if self.isInvoiceProforma or not app.getMyUser().canDo(self.myTerminal, PmCashAllowEvenWeight) then
		self.btnEvenWeight.visible:=false;
		self.lblBOLWeight.visible :=false;
	endif;
	
	if self.isInvoiceProforma then														    // TFS 5740
		self.btnPrintProforma.visible := false;											    // TFS 5740
	else																			   	    // TFS 5740
		self.btnPrintProforma.visible := true;											    // TFS 5740
		self.btnPrintProforma.left    := self.btnSave.left-7-self.btnPrintProforma.width;	// TFS 5740
		if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then			    // TFS 5740
			self.btnPrintProforma.enabled := false;										    // TFS 5740
		endif;																			    // TFS 5740
		if self.myTerminal.getConfig(CashProformaReport).String = "" then			        // TFS 7557 if no report is configured then do not show the button
			self.btnPrintProforma.visible := false; 									    // TFS 7557
		endif;
	endif;																				    // TFS 5740
	
	//"Record Proforma Invoice Print Debtor" from Cash Module Config
	self.btnSave.visible 	:= not self.myTerminal.getConfig(ShowDebtorForProforma).Boolean;   // TFS 47985
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="shouldApplyAgent" id="246a3944-842e-49b4-807d-66671be56f17">
        <source>shouldApplyAgent(_ti : CM_TrackedItem; _agent : CM_Object) : Boolean;
/*
Purpose:	TFS 45953 added for performance
Date				Who			Reason
OCTOBER 2019		JLGAB1 initial creation
*/


vars
	consignee		: CM_ConsigneeConsignor;
	customsAgent	: CM_CustomsAgent;
	operator : CM_Operator;
	child : CM_TrackedItem;
begin
	if _agent	&lt;&gt; null then	
	
		foreach child in _ti.allChildren do
			if not self.shouldApplyAgent(child, _agent) then
				return false;
			endif;
		endforeach;
	
		if self.cashDebtorType.code = "SDT2" then
			consignee := _agent.CM_ConsigneeConsignor;
			return _ti.getConsigneeObject() &lt;&gt; consignee;
		elseif self.cashDebtorType.code = "SDT3" then
			consignee := _agent.CM_ConsigneeConsignor;
			return _ti.getConsignorObject() &lt;&gt; consignee;
		elseif self.cashDebtorType.code = "SDT4" then
			operator := _agent.CM_Operator;
			return _ti.myOperator &lt;&gt; operator;
		// ### TFS CR 65835 TASK 65891 27AUG2024 NAVAB1
		elseif self.cashDebtorType.code = "SDT1" then
			operator := _agent.CM_Operator;
			return _ti.myOperator &lt;&gt; operator;
		elseif self.cashDebtorType.code = "SDT6" then
			customsAgent := _agent.CM_CustomsAgent;
			return _ti.myCustomsAgent &lt;&gt; customsAgent;
		elseif self.cashDebtorType.code = "SDT7" then
			consignee := _agent.CM_ConsigneeConsignor;
			return _ti.myFreightForwarder &lt;&gt; consignee;
		endif;
	endif;

	return false;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_agent" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shouldRound" id="427cc26c-1bf9-4fd7-a322-e2080f15964e">
        <source>shouldRound() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2015	cnwmc5	Initial creation		PAR 36895

*/

vars
	bank : CM_Bank;
	roundingType : Integer;
begin
	if self.myProxyCashReceipt &lt;&gt; null then
		bank := self.myProxyCashReceipt.getBank();
	elseif self.myQueryCashReceipt &lt;&gt; null then
		bank := self.myQueryCashReceipt.getBank();
	
	endif;

	roundingType := self.myTerminal.getCashRoundingType( bank );	//08 Jan 2019	NDL	TFS 40010
	return roundingType &gt; 0;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showCashCredit" id="e1cd3983-90dd-43df-9a4f-c180aed2c15a">
        <source>showCashCredit(_receipt : CM_CashReceipt);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2019	jlgab1	Initial creation

*/

vars

	receiptForm		: INV_CashCredit;
begin
	create receiptForm transient;
	receiptForm.myTerminal    := self.myTerminal;
