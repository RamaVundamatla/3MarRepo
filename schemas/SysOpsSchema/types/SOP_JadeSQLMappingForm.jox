    <JadeMethod name="tblExtFeatures_keyUp" id="13590757-23d9-4285-8126-1b44d71cc495">
        <controlMethod name="CM_DataTable::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblExtFeatures_keyUp(table: Table input; keyCode: Integer io; shift: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	#cnwdz2	 

*/

vars
	sqlDataType : String;
	dataDumpFeature : CM_DataDumpFeature;
	sqlTypeLength : String;
	isMaxLength : Boolean;
	maxColDes   : String;
	scaleFactor : String;
begin
	if table.column = self.TableColumn_SQLTypeLength then
		maxColDes := table.getCellText(table.row, self.TableColumn_SQLTypeLength);
		if maxColDes.asIntegerJMT &gt; CM_DataDumpExtractDef.SQLMaxValueForString then
			table.setCellText(table.row, self.TableColumn_SQLIsMaxtLength, true.cnEcGetTableCheckBoxValue());
		else
			table.setCellText(table.row, self.TableColumn_SQLIsMaxtLength, false.cnEcGetTableCheckBoxValue());
		endif;
	endif;
	
	if table.column = self.TableColumn_SQLType then
		sqlDataType := table.getCellText(table.row, self.TableColumn_SQLType);
		if sqlDataType &lt;&gt; null then
			dataDumpFeature	:=	self.tblExtFeatures.accessRow(table.row).itemObject.CM_DataDumpFeature;	
			sqlTypeLength := dataDumpFeature.getSQLTypeLengthDesc(sqlDataType,isMaxLength,scaleFactor);
			table.setCellText(table.row, self.TableColumn_SQLTypeLength, sqlTypeLength);
			if isMaxLength then
				table.setCellText(table.row, self.TableColumn_SQLIsMaxtLength, isMaxLength.cnEcGetTableCheckBoxValue());
			endif;
			if scaleFactor &lt;&gt; null then
				table.setCellText(table.row, self.TableColumn_SQLDecimalDigits, scaleFactor);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblExtFeatures_mouseUp" id="d3dbd7d7-90c9-4a85-af95-bae6757e2058">
        <controlMethod name="CM_DataTable::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblExtFeatures_mouseUp(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	#cnwdz2	 

*/

vars
	sqlDataType : String;
	dataDumpFeature : CM_DataDumpFeature;
	sqlTypeLength : String;
	isMaxLength : Boolean;
	maxColDes   : String;
	scaleFactor : String;
begin
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	if table.column = self.TableColumn_SQLType then
		sqlDataType := table.getCellText(table.row, self.TableColumn_SQLType);
		if sqlDataType &lt;&gt; null then
			dataDumpFeature	:=	self.tblExtFeatures.accessRow(table.row).itemObject.CM_DataDumpFeature;	
			sqlTypeLength := dataDumpFeature.getSQLTypeLengthDesc(sqlDataType,isMaxLength,scaleFactor);
			table.setCellText(table.row, self.TableColumn_SQLTypeLength, sqlTypeLength);
			if isMaxLength then
				table.setCellText(table.row, self.TableColumn_SQLIsMaxtLength, isMaxLength.cnEcGetTableCheckBoxValue());
			endif;
			if scaleFactor &lt;&gt; null then
				table.setCellText(table.row, self.TableColumn_SQLDecimalDigits, scaleFactor);
			endif;
		endif;
	endif;
	
	if table.column = self.TableColumn_SQLIsMaxtLength then
		dataDumpFeature	:=	self.tblExtFeatures.accessRow(table.row).itemObject.CM_DataDumpFeature;
		maxColDes := table.getCellText(table.row, self.TableColumn_SQLIsMaxtLength);
		if dataDumpFeature.canChangeLength(table.getCellText(table.row, self.TableColumn_SQLType)) then
			if maxColDes = '1' then
				table.setCellText(table.row, self.TableColumn_SQLTypeLength, CM_DataDumpExtractDef.SQLMaxValueForString.String);
			else
				sqlDataType := table.getCellText(table.row, self.TableColumn_SQLType);
				sqlTypeLength := dataDumpFeature.getSQLTypeLengthDesc(sqlDataType,isMaxLength,scaleFactor);
				table.setCellText(table.row, self.TableColumn_SQLTypeLength, sqlTypeLength);
				if scaleFactor &lt;&gt; null then
					table.setCellText(table.row, self.TableColumn_SQLDecimalDigits, scaleFactor);
				endif;
			endif;
		else
			if maxColDes = '1' then
				table.setCellText(table.row, self.TableColumn_SQLIsMaxtLength, false.cnEcGetTableCheckBoxValue());
			else
				table.setCellText(table.row, self.TableColumn_SQLIsMaxtLength, true.cnEcGetTableCheckBoxValue());
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblExtFeatures_rowColumnChg" id="587747af-92d0-4e37-9780-bb2ace68af83">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblExtFeatures_rowColumnChg(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	#cnwdz2	 

*/

vars
	dataDumpFeature : CM_DataDumpFeature;
begin
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	if lastSelRow = table.row then
		return;
	endif;
	
	lastSelRow := table.row;
	
	dataDumpFeature := self.tblExtFeatures.accessRow(table.row).itemObject.CM_DataDumpFeature;
	if dataDumpFeature.myFeature &lt;&gt; null then
		self.txtFeatureDesc.text := self.getItemDescription(dataDumpFeature.myFeature.text);
	elseif dataDumpFeature.mySubClassFeatureType &lt;&gt; null then
		self.txtFeatureDesc.text := self.getItemDescription(dataDumpFeature.mySubClassFeatureType.text);
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f13c234d-b027-4b3e-8264-4528ddc6c9ec">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014925, locale);
	btnSelFeature.translateCaption(Xlat_0014926, locale);
	grpClassDesc.translateCaption(Xlat_0014927, locale);
	grpFeatureDesc.translateCaption(Xlat_0014928, locale);
	lblColNameHead.translateCaption(Xlat_0014929, locale);
	lblColPosHeading.translateCaption(Xlat_0014930, locale);
	lblDeleteColName.translateCaption(Xlat_0014931, locale);
	lblExpDateTimie.translateCaption(Xlat_0014932, locale);
	lblIsDeleted.translateCaption(Xlat_0014933, locale);
	lblJadeClass.translateCaption(Xlat_0014934, locale);
	lblOIDClumnName.translateCaption(Xlat_0014935, locale);
	lblOptnColName.translateCaption(Xlat_0014936, locale);
	lblSQLTable.translateCaption(Xlat_0014937, locale);
	lblSelectFeature.translateCaption(Xlat_0014938, locale);
end;</source>
    </JadeMethod>
</GUIClass>
