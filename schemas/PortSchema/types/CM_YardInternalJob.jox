    <JadeMethod name="jobId" id="5f858f77-f432-42ed-a4e8-fd664cc78352">
        <methodInvocation>mapping</methodInvocation>
        <source>jobId(set: Boolean; value: String io) mapping;
//11/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
vars
	aStr : String;
	//maxLen : Integer;
	reqst : CM_Request;
	delReq : CM_YardDeliveryRequest;
	req	:	CM_YardMoveRequest;
	invalidSourceLocation,
	invalidTargetLocation	: Boolean;
	sourceLocation, 
	targetLocation			: CM_LocationsController;
begin
	value := null;
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.id.trimBlanks &lt;&gt; null then
		value := self.id;
		return;
	endif;
	reqst := self.allRequests.first;
	if reqst = null then
		value := "Unknown";
		return;
	endif;
	
	if reqst.isKindOf(CM_YardMoveRequest) then	
		req := reqst.CM_YardMoveRequest;
		//26/02/2010 cnwdz2 par21933
		sourceLocation := req.mySourceLocation;
		on Exception do app.handleDeletedObject(exception, sourceLocation, invalidSourceLocation);
		if sourceLocation = null then
			value := "Unknown -&gt;";			
		else
			value := sourceLocation.getFullId &amp; "-&gt;";
		endif;
		
		//26/02/2010 cnwdz2 par21933
		targetLocation := req.myTargetLocation;
		on Exception do app.handleDeletedObject(exception, targetLocation, invalidTargetLocation);
		if targetLocation = null or invalidTargetLocation then
			value := value &amp; 'Unknown ' &amp; req.totalRequested.String;			
		else
			value := value &amp; targetLocation.getFullId &amp; " " &amp; req.totalRequested.String;
		endif;
		return;
	elseif reqst.isKindOf(CM_YardDeliveryRequest) then
		delReq := reqst.CM_YardDeliveryRequest;
		//26/02/2010 cnwdz2 par21933
		on Exception do app.handleDeletedObject(exception, delReq.sourceLocation, invalidSourceLocation);
		
		if delReq.sourceLocation = null or invalidSourceLocation then
			value := "Unknown";			
		else
			value := delReq.sourceLocation.getFullId;
		endif;
		if delReq.targetLocation &lt;&gt; null then
			value := value &amp; " =&gt; "&amp; delReq.targetLocation &amp; " " &amp; delReq.totalRequested.String;
		else
			value := value &amp; " =&gt; "&amp; 'Unknown '  &amp; delReq.totalRequested.String;
		endif;
		return;	
	endif;

	if workListEntries.size &gt; 0 then
		if workListEntries.first.myTrackedItem &lt;&gt; null then
			if self.isSwapJob then
				aStr :=  "Swap move " &amp; workListEntries.size.String;
			else
				aStr :=  workListEntries.first.myTrackedItem.id.trimBlanks &amp; "- Internal" ;
			endif;
		endif;
	endif;

	if aStr = null then
		aStr := "Internal " &amp; getOidString();	
	endif;

	//maxLen := CM_Job.getProperty("jobId").getLength;
	if aStr.length &gt; JOBID_LEN -1 then
		aStr := aStr[1:JOBID_LEN -1];
	endif;
	value := aStr;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="linkToTI" id="357bcb90-3321-4f0d-9088-f842d34e8a9b">
        <updating/>
        <source>linkToTI(ti: CM_TrackedItem input) protected, updating;
//Link the passed in TI to the job, link is from to to job, NOT reversed.
//Reverse is handled by the WLE
vars
begin
	//-----------------
	//Test to be sure we are not already doing an internal OR a swap job
	//-----------------
	if ti = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, "LinkToTI method, TrackedItem reference", null, null);
		return;
	endif;
	ti.setJobInternal(self);
end;</source>
        <access>protected</access>
        <Parameter name="ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeTI" id="093a16c7-26cb-4aff-9d67-aa050d64e8e9">
        <updating/>
        <source>removeTI(_ti : CM_TrackedItem input; req : CM_Request) updating;
//Remove the Links to the TI's job reference
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars

begin
//	if not global.isValidObject(_ti) then
	if _ti = null then
		return;
	endif;
	//Remove reference to the job from TI.
	//_ti.doRemoveJob(_ti.jobYardInternal, req);
	
	if self.isSwapJob then
		if self.allTrackedItemsSwap.includes(_ti) then
			self.allTrackedItemsSwap.remove(_ti);
		endif;
	elseif self.isDoorJob then
		if self.allTrackedItemsDoor.includes(_ti) then
			self.allTrackedItemsDoor.remove(_ti);
		endif;
	else
		if self.allTrackedItems.includes(_ti) then
			self.allTrackedItems.remove(_ti);
		endif;
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="req" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="setEntryOverrideFlag" id="eff1e63a-5559-451f-bb10-a666084d5e53">
        <source>setEntryOverrideFlag();
//See CM_Job description...
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	wle	:	CM_WorkListEntry;
	flags	:	Integer;
	rtqe : CM_RTQueueEntry;
begin
	flags := 0;
	flags := flags.bitOr(MP_RT_AUTOPLAN );
	flags := flags.bitOr(MP_RT_IGNORE_WARNINGS );

	foreach wle in self.workListEntries do
		foreach rtqe in wle.allRTQueueEntries do
			rtqe.overRideFlags := flags;
		endforeach;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreateDelivery" id="6d58c617-42af-45a9-8d45-32378177c3fa">
        <updating/>
        <source>setForCreateDelivery(_proxyJob:CM_YardInternalJob input) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.type := _proxyJob.type;
	self.id := _proxyJob.id;
	self.myTerminal := _proxyJob.myTerminal;
	self.priority := _proxyJob.priority; // cnwrd1 24.8.09
	self.myWODtl := _proxyJob.myWODtl;
	self.addToJobSheet();

end;</source>
        <Parameter name="_proxyJob" type="CM_YardInternalJob" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateInternal" id="51ac8e8c-0695-4ea1-b9a1-a6e91ad93535">
        <updating/>
        <source>setForCreateInternal(_yardInternalJobParam : CMIF_YardWorkJobParams;_terminal : CM_Terminal) updating;
/*
 ------------------------------------------------------------------------
Created:			22 August 2002 by cnwdwq1
Purpose:			This method creates a job that is used to "strip" a number of unknown objects 
							from one area to another (typically for containers, a block stack). 
							(ie, fill the wash from a dirty stack) 
							A yard move is not an ops move, but is one between 2 YARD areas.
							A VARIANT of this job is an auto-repeating type where we DONT know the 
							tracked items involved (logs for example). We are told its complete when its deleted.
							The behavious is to create new rtqentries when one is selected by a machine.
							That way multiple machines can work on the same job in the queue.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	req : CM_YardMoveRequest;
	wle	: CM_WorkListEntry;
begin

	self.myTerminal := _terminal;
	self.id := _yardInternalJobParam.jobId;
	self.type := _yardInternalJobParam.typeToCreate;
	self.priority := _yardInternalJobParam.priority; // cnwrd1 24.8.09
	
	self.selectedTIs.clear();
	_yardInternalJobParam.allSelectedTIs.copy(self.selectedTIs);
	//---------------
	//Build a Request
	//---------------
	create req;
	req.setForCreateInternal(self, _yardInternalJobParam);
	//---------------
	//Build the WLEs' from the request.
	//---------------
	self.createReleaseWLEs();
	// 23098 set the bestPick option on these WLEs
	foreach wle in self.workListEntries do
		wle.setBestPick(_yardInternalJobParam.isBestPick);
	endforeach;

	self.addToJobSheet();
	
	self.enqueueJobInternal(_yardInternalJobParam);
end;</source>
        <Parameter name="_yardInternalJobParam" type="CMIF_YardWorkJobParams"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f0bd0c5a-184d-4d2a-888f-b0db391d8c4b">
