    <JadeMethod name="checkAllowTargetChange" id="10045b6e-68b4-460d-8622-970d29a71ab4">
        <source>checkAllowTargetChange();
//26 May 2014	cnwdw1	
//
vars

begin
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipLoadCargo and 
	   not app.getMyUser.canDo(self.myTerminal,PmHHAllowTargetChange) then
		self.txtLocation.enabled := false;
	endif;
end;</source>
