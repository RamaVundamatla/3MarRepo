<Class name="WS_ReeferMonitoringData" id="8e70416b-7ccd-4a5b-8237-dd33a3f6d79a">
    <superclass name="WS_RestProxyObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
