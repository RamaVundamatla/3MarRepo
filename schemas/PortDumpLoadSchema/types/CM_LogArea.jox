<Class name="CM_LogArea">
    <JadeMethod name="exportPDXMLMyCollections" id="7f99ef22-6a0c-4e8c-b0bc-44d0e6626913">
        <source>exportPDXMLMyCollections(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars
	obj: Object;
begin
	if _property.name = CM_LogArea::allRows.name then
		_file.writeLine('&lt;'&amp;CM_LogArea::allRows.name&amp;'&gt;');
		foreach obj in self.allRows do
			_file.writeLine('&lt;class&gt;'&amp;obj.class.name&amp;'&lt;/class&gt;');
			obj.CM_RowAreaRow.exportPDXML(_file, _objArray, false, false);
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_LogArea::allRows.name&amp;'&gt;');
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="60acdcd7-0804-4c4b-a81e-14b8f583c03f">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_TerminalArea::myTerminal.name then
		return app.myRoot.allTerminals[_theCode];
	elseif _name = CM_TerminalArea::myType.name then
		return app.myRoot.allTerminalAreaTypes[_theCode.Integer];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
