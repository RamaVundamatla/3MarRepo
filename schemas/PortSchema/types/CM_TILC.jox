    <JadeMethod name="includesCargoTypeOnboard" id="373e33f9-c315-4c17-9a31-6ce61fe2d455">
        <source>includesCargoTypeOnboard(_cargoType : CM_CargoType; _subType : CM_Product) : Boolean;
/*
Purpose:			

Date		Who		Reason
01 March 2023	navab1	TFS CR 56806 TASK 56807
*/

vars
	lc : CM_LocationsController;
	ti : CM_TrackedItem;
begin
	foreach lc in self.allLCs do
		foreach ti in lc.allTrackedItems do
			
			if _subType &lt;&gt;  null then
				if _subType = ti.myProduct then
					return true;
				endif;
				
			elseif _cargoType &lt;&gt; null then
				if _cargoType = ti.myCargoType then
					return true;
				endif;
			endif;
		endforeach;
	endforeach;

	return false;

epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_subType" type="CM_Product"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAvGradeSuitableForRelease" id="55fe6971-d7dd-4026-b3e0-f954a37a920f">
        <source>isAvGradeSuitableForRelease(): Boolean;
/*

Date		Who		Reason
21 August 2013	cnwer1	Initial creation PAR

*/

vars
	grade : CM_MTGrade;

begin
	
	grade := app.myRoot.allAvailabilityGrades[self.availabilityGrade];
	if grade = null then
		return false;
	endif;
	
	return grade.isSuitableForRelease;

epilog

end;</source>
