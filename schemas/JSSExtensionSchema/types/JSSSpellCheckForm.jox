    <JadeMethod name="lstProspectWords_click" id="06510a44-a50e-4d6b-ae66-39ac795c5901">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstProspectWords_click(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	txtReplace.text := lstProspectWords.text;
	
	if txtReplace.text.trimBlanks &lt;&gt; "" then
		btnReplace.enabled		:=	true;
		btnReplaceAll.enabled	:=	true;
	else
		btnReplace.enabled		:=	false;
		btnReplaceAll.enabled	:=	false;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
