    <JadeMethod name="isSnapShotDataMatch" id="43abe2a4-619b-4c0e-b28e-3dbbed4055fe">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/10/2025	navkc1 JIRA 36148 AAT | RotaBox ISO Type and New Attributes - Yard Allocation

*/

vars
	match	: Boolean;
	obj		: Object;
begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	foreach obj in _criteria.myYAData.CM_YADataObjects.allObjects do
		if obj.CM_CargoType.description = _propertyValue then
			return true;
		endif;
	endforeach;
	
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="9212ae0b-aee2-4e44-822b-cafbf4737e94">
        <source>isStorageDetailMatch(_criteria: CM_YACriteria; _ti: CM_TrackedItem; _tiTrx: CM_TITransaction): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/10/2025	navkc1 JIRA 36148 AAT | RotaBox ISO Type and New Attributes - Yard Allocation

*/

vars
	cargoType : CM_CargoType;
	
begin

	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then
		cargoType := _tiTrx.myTrackedItem.getCargoTypeForContents();
	else
		cargoType := _ti.getCargoTypeForContents();
	endif;
	
	// specific value - 31221 handle wild cards as well
	if _criteria.myYAData.CM_YADataObjects.matchesStorage( cargoType ) then
		return true;
	endif;
	
	// default value
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
