    <JadeMethod name="doTblCodeRowColChange" id="6229f971-4a20-4950-a997-ea25d51ce539">
        <source>doTblCodeRowColChange();
// ---------------------------------------------------------------------------
// Created:     04 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	prodCode		: CM_ProductAttributeCode;
begin
	prodCode := self.tblCodeData.accessRow(self.tblCodeData.row).itemObject.CM_ProductAttributeCode;
	if prodCode = null then
		return;
	endif;
	
	self.tblEntCode.setValueByName(ETRow_EntCode, prodCode.code);
	self.tblEntCode.setValueByName(ETRow_EntDescription, prodCode.description);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateCode" id="4653cf60-ef73-409b-9804-cb2171491c35">
        <source>doUpdateCode();
// ---------------------------------------------------------------------------
// Created:     04 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	prodCode		: CM_ProductAttributeCode;
	code,
	descr			: String;
	row				: Integer;		
begin
	row := self.tblCodeData.row;
	prodCode := self.tblCodeData.accessRow(row).itemObject.CM_ProductAttributeCode;
	if prodCode = null then
		app.msgBox(app.getErrorString(SelectCargoSubAttrCodeToUpdate),'Nothing selected', 0);
		return;
	endif;
	
	code := self.tblEntCode.getValueByName(ETRow_EntCode).String;
	if self.isDuplicateCode(code) then
		return;
	endif;
	
	code := self.tblEntCode.getValueByName(ETRow_EntCode).String;
	descr := self.tblEntCode.getValueByName(ETRow_EntDescription).String;
	
	prodCode.setProxy(code, descr, true, null);
	self.tblCodeData.setCellText(row, self.tblCodeData.getColumnByRowName(ETRow_EntCode), code);
	self.tblCodeData.setCellText(row, self.tblCodeData.getColumnByRowName(ETRow_EntDescription), descr);

end;</source>
    </JadeMethod>
