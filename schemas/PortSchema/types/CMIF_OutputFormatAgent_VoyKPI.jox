    <JadeMethod name="resizeColumn" id="ad4a7cd0-e5d8-4eb8-9d05-97fdf09b2701">
        <source>resizeColumn(_table :Table input; _column, _previousWidth :Integer);
/*
Date		Who		Reason
29 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars

begin
	if self.isSplitterColumn (_table, _column) then
		_table.accessColumn (_column).width	:= _previousWidth;
	endif;
