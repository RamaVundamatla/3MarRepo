    </JadeMethod>
    <JadeMethod name="setProxy" id="42853f17-ea07-4e02-b60d-dcfd326f5030">
        <updating/>
        <source>setProxy(pValue:Real; pColour:Integer;pUpper,pLower :Real) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.value := pValue;
	self.colour := pColour;
	self.lower := pLower;
	self.upper := pUpper;
	
end;</source>
        <Parameter name="pValue" type="Real"/>
        <Parameter name="pColour" type="Integer"/>
        <Parameter name="pUpper" type="Real"/>
        <Parameter name="pLower" type="Real"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="a87efed8-8f3c-43a2-96d5-90c90ae75b96">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.allTempRanges[value] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.value.String, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
