    <JadeMethod name="setFrom" id="ec6ad785-7f11-46a5-958b-ee359c299221">
        <updating/>
        <source>setFrom(_snapshot: CM_KPITrainSnapshotDtl) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2012	cnwdw1	Initial creation
*/
vars

begin
	self.dateTime := _snapshot.dateTime.asStringForWebInterface;
	self.actualMoveCounts.setFrom(_snapshot.actualMoveCounts);
	self.plannedMoveCounts.setFrom(_snapshot.plannedMoveCounts);
	self.targetFinishTime := _snapshot.targetFinishTime.asStringForWebInterface;
	self.startTime := _snapshot.startTime.asStringForWebInterface;
	self.id := _snapshot.id;
	self.type := _snapshot.type;

epilog
end;</source>
        <Parameter name="_snapshot" type="CM_KPITrainSnapshotDtl"/>
    </JadeMethod>
