<Class name="HandHeldLogonAgent">
    <JadeMethod name="findFormsForUser" id="cff189bf-e606-4b1f-ae5b-e018cccd9561">
        <source>findFormsForUser(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2010	cnwer1	Initial creation

*/

vars

begin

	app.myPassport.setMyUser(self.user);
	
	//epr TFS 36402 refactored so could call this code not from a app class
	app.myMobileGUIAgent.findFormsForUser(app.myMobileAgent.allAvailableForms,app.myPassport);
	
	return app.myMobileAgent.allAvailableForms.size &gt; 0;

epilog
	app.myPassport.setMyUser(null);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
