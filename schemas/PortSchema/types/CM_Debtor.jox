    <JadeMethod name="getDefaultPaymentType" id="3af117fe-20c9-4fd2-99fa-8fc45447bd64">
        <source>getDefaultPaymentType( _term : CM_Terminal ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	drTerm : CM_DebtorTerminal;
	paymentType : Integer;

begin

	if _term &lt;&gt; null then
		drTerm := _term.allDebtorTerminals.getAtKey( self );	
		if drTerm &lt;&gt; null then
			paymentType := drTerm.paymentType;
