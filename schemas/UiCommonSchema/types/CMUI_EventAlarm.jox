    <JadeMethod name="getXMLSettingsForSave" id="d14b8ff8-617e-4dc0-9602-194be07b098b">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*
----------   ----------  --------------------------------------------------
Created:	18 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	block			: String;

begin
	block := inheritMethod();
	block := block &amp; global.formatAsXML(self.XML_SAVETOP, self.top.String) &amp; 
					global.formatAsXML(self.XML_SAVELEFT, self.left.String);
	
	return block;

end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
