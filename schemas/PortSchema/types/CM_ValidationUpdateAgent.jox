    <JadeMethod name="valVentFlow" id="611085ce-8932-4e17-8033-66de8b198818">
        <source>valVentFlow(_ventilation : Decimal; _id : String); //par19252 cnwrs1 may 2009
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 November 2008	cnwer1	Initial creation

*/

constants
	Min	: Integer = 0;
	Max	: Integer = 999;
vars

	strRange	: String;
begin
	if _ventilation &lt;&gt; NULL_VENTILATION and
		   (_ventilation &lt; Min or
		   _ventilation &gt; Max) then
		   
		   	strRange := Min.asStringJMT &amp; '-' &amp; Max.asStringJMT;
			app.raiseCMException2(ERR_VENT_CBM_OUT_OF_RANGE, _id ,strRange , app.getErrorString(CM_Ventilation), null);
		endif;

epilog

end;</source>
        <Parameter name="_ventilation" type="Decimal"/>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
