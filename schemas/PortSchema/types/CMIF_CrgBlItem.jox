Attribute piece_length_cm  (Real)
Attribute piece_width_cm  (Real)
Attribute piece_height_cm  (Real)
Attribute brand   (String 60)
Attribute model   (String 60)
Attribute temp_reqd_C  (Real)
Attribute temp_max_C  (Real)
Attribute temp_min_C  (Real)
Attribute temp_show_fahrenheit (Boolean)
Attribute created (Integer64)
Attribute creator   (String 30)
Attribute changed (Integer64)
Attribute changer   (String 30)
Attribute sequence (Integer64)
Attribute weight_total_kg (Real)
Attribute package_volume_cu_cm (Real)
Attribute handling_code_gkey  (Integer64)
Attribute equipment_handling_code_gkey  (Integer64)
Attribute is_direct (boolean)
</text>
