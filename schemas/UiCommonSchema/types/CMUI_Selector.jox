    <JadeMethod name="tblResults_keyDown" id="4b2f13b1-88e9-48bd-8110-6db9545901b1">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResults_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;

/*
Date				Who		Reason
10 September 2010	cnwar2	#25718
31 January 2011		cnwdap1	PAR #26830 CCMS 2013 allow move from selector
*/
vars
	selectedCount, row 	: Integer;
	statusMsg			: String;
	
begin
	// Can't just call updateStatus as the table selected count isn't updated until after the keyDown event
	self.updateStatus();
	
	if shift.bitAnd(2) &lt;&gt; 0 then	// ctrl
		statusMsg		:=	(table.rows - table.fixedRows).cnEcNumberFormat() &amp; " Items displayed";
		selectedCount 	:= table.getSelectedRowCount();
		
		if keyCode = J_key_UpArrow then
			row := table.row - 1;
			if row &gt; table.fixedRows then
				if table.getCellSelected(row,1) then
					selectedCount := selectedCount - 1;
				else
					selectedCount := selectedCount + 1;
				endif;
			endif;
			
		elseif keyCode = J_key_DownArrow then
			row := table.row + 1;
			if row &lt;= table.rows then
				if table.getCellSelected(row,1) then
					selectedCount := selectedCount - 1;
				else
					selectedCount := selectedCount + 1;
				endif;
			endif;
		endif;			
	
		statusMsg	:=	statusMsg &amp; " (" &amp; selectedCount.asStringJMT() &amp; " Items selected)";
		staLine.cnEcSet(" " &amp; statusMsg);
		self.frmStatusLine.myFrameCaption.caption := (" " &amp; statusMsg);		// PAR #26830
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblResults_mouseDown" id="a141b03c-6cd7-4d96-bc12-5edb6baac024">
        <controlMethod name="CM_DataTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResults_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
----------   ----------  --------------------------------------------------
Created:	21 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if button = 1 then
		self.origXPos := x;
		self.origYPos := y;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblResults_mouseHover" id="75faf63f-48d1-4102-b101-529858c50638">
        <controlMethod name="Table::mouseHover"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResults_mouseHover(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2019	jlgndl1	Initial creation	TFS 45891

*/

vars

	columnIndex : Integer;
	rowIndex : Integer;
	headerText : String;
	backColour : Integer;

begin

	self.bubbleHelp := null;

	if table.rows = 0 then // TFS 47297 noticed during testing 47297
		return;
	endif;
	
	if y &lt;= table.accessRow(1).height then
		//we are in the header row
		
		//find our column
		table.getCellFromPosition( x, y, rowIndex, columnIndex );
		
		if columnIndex &lt; 1 or columnIndex &gt; table.columns then // 29 Oct 2019	NDL	- Found in general testing of TFS 47198.
			return;
		endif;
		
		//what colour is it
		backColour := table.accessCell( 1, columnIndex ).backColor;
		if backColour = CM_QueryProperty.ComplexColour then
			headerText := "'" &amp; table.accessCell( 1, columnIndex ).text &amp; "'";
			table.bubbleHelp := app.getErrorString1( Consi_remov_from_resul_table_i, headerText );
		endif;
			
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblResults_mouseMove" id="170fde99-fca7-4a1b-940f-55b4f4e8483c">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResults_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
----------   ----------  --------------------------------------------------
Created:	21 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tmpHeight : Real;	
begin
	if table.fixedRows &gt; 0 then
		tmpHeight := table.accessRow(table.fixedRows).height;
		if self.origYPos &lt;= tmpHeight then
			return;
		endif;
	endif;
	if button = 1 then
	
		// TFS 2198 CNWAB1
		if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			return;
		endif;

		if app.dragDetected(x, y, self.origXPos, self.origYPos) then
			self.doTblResultsDragTI();
			self.origXPos := 0;
			self.origYPos := 0;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
