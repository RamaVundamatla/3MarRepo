<Class name="CM_EDIFileTypeCoparn" id="b15314e0-93de-43f9-80cd-aa764b67c8c2">
    <superclass name="CM_EDIFileTypeUNEDIFACT"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="changeToPreNoteProcessing" id="2b85b441-4305-4e05-8966-21b85a4a030c">
        <source>changeToPreNoteProcessing(	_reload : Boolean; 
							_ediData : CM_EDIData io; 
							_ediFile : CM_EDIFile input; 
							_params : CMIF_EDIFACTParams io;
							_msgHelper : CMIF_EDIFACTHelper io	) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/07/2017	jlgdap1		Initial creation TFS 5294 SNO Create prenotes in COPARN
//
vars
	ediType : Integer;
	ediData : CM_EDIData;
	ediFileType : CM_EDIFileType;

begin
	if not _reload then	
		ediType := EDIDataType_Prenote;
		_ediData := null;
		// (This will only happen if there are multiple Release Request BGMs in the file.
		if _ediFile.allEDIData.size &gt; 0 then
			foreach ediData in _ediFile.allEDIData do
				if ediData.isKindOf(CM_EDIDataPrenote) then
					_ediData := ediData;
					break;
				endif;
			endforeach;
		endif;
		// If we don't have a prexisting Release Request EDI Data, create one.
		if _ediData = null then
			app.myUtilityCA.utlCreateEDIData(_ediData, CM_EDIDataPrenote, ediType, EDIFileType_Coparn, _ediFile.ediConfig, _ediFile, ediFileType, app.myPassport);
			_ediData.setStatus(CM_EDIFile.EDI_STATUS_LOADED);
		endif;
		_msgHelper.myCurrentParams.ediDataType := _ediData.ediDataType;
	else
		if _ediData.isKindOf(CM_EDIDataPrenote) then
			_params.skipTillNextBGM := false;
		else
			_params.skipTillNextBGM := true;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_reload" type="Boolean"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="io"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_params" type="CMIF_EDIFACTParams" usage="io"/>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cleanupEDIData" id="626387e1-b6e2-4c18-9787-a1ee17398e72">
        <updating/>
        <source>cleanupEDIData(_ediFile : CM_EDIFile input) updating;
//
// cnwrs1 ccms 2122 01 dec 2011 
// this should cleanup the self.ediData and self.alediData so no edidatas are left with no ediTrackedItems and alediDatas only contains the overflow of edidata
/*
Date		Who		Reason
05/12/2011  cnwrs1  CCMS POL 2122 / PAR 28696 - add support for EDI Release Request processing
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	coll		: CM_EDIDataSet;
	ediData 	: CM_EDIData;
	iter 		: Iterator;
begin
	coll := _ediFile.allEDIData;
	
	if coll.size &gt; 0 then
		iter := _ediFile.allEDIData.createIterator;
		
		while iter.next(ediData) do
			// no edi tracked items so get rid of it
			if ediData.allEDITrackedItems.size = 0 then 
				_ediFile.allEDIData.remove(ediData);
				ediData.erase(NORMAL_ERASE);
			endif;
		endwhile;
	endif;
	
	if coll.size &gt; 0 then
		ediData := _ediFile.ediData;

		if ediData.allEDITrackedItems.size = 0 then	
			// no edi tracked items so used ediData from collection
			_ediFile.ediData := null;	// disconnect this as edidata is the parent
			
			ediData.erase(NORMAL_ERASE);
			
			ediData := coll.first();
			
			coll.remove(ediData);
			
			_ediFile.ediData := ediData; 
		endif;
	endif;
epilog
	delete iter;
end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="143a2c01-b177-4d87-82da-fdcc55847a04">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     Mar 2006 cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
// 30/12/2011	cnwrs1	CCMS POL 2122 / PAR 28696 - 
vars

begin
	self.name	:= "COPARN - Container Announcement Message";	 // CCMS POL 2122 / par 28696 cnwrs1 07 Dec 2011
	self.type	:= EDIFileType_Coparn;

//	we need to create transients with no reference to root so do this elsewhere	
//	self.myRoot := app.myRoot;
end;</source>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="d9479499-7056-4f9b-bdf8-eaabf15fd908">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
// cnwrs1 mar 2006 ccms 
// 14 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
vars

begin
	if app.myPassport.myTerminal.getConfig(EdiUseOldCoparn).Boolean then
		_ediDataClass := CM_EDIDataBooking; //cnwrs1 CCMS 1882 25 May 2010
		_dataType := EDIDataType_BookingMultiLine; //cnwrs1 CCMS 1882 25 May 2010
	else
		_ediDataClass := CM_EDIDataGateDoc;
		_dataType := EDIDataType_GateDocument;
	endif;
	_fileTypeCode := self.type;
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllEDIDataTypes" id="33d7ff35-1a0d-4add-b91c-93c2deb3dbd5">
        <source>getAllEDIDataTypes(_coll: IntegerArray input);
/*
Date		Who		Reason
06 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
//06 May 2016	cnwrs1	TFS 1600 COPARN VGM
// 18 Aug 2016	cnwrs1	TFS 2553 remove COPARN VGM processing
*/
vars

begin
	if not _coll.includes(EDIDataType_BookingMultiLine) then
		_coll.add (EDIDataType_BookingMultiLine);
	endif;
	if not _coll.includes(EDIDataType_ReleaseRequest) then
		_coll.add (EDIDataType_ReleaseRequest);
	endif;
epilog

end;</source>
        <Parameter name="_coll" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDGSData" id="15d431ba-7f6d-44c2-b7ac-0325f1dc1462">
        <source>getDGSData(_msgHelper : CMIF_EDIFACTHelper io;
			_imCodes : StringArray input )  protected;
/*

Date		Who		Reason
17 February 2017	cnwer1	Initial creation TFS 2744

*/

vars
	hazardCode,
	undgCode   : String;
begin
	if _msgHelper.currentTag &lt;&gt; "DGS" then
		return ;
	endif;
	
	_msgHelper.setNextField();
    
    if _msgHelper.currentField = "IMD" then
          _msgHelper.setNextField();
			
          hazardCode := _msgHelper.currentSubItem;
            
          _msgHelper.setNextField();
			
          undgCode := _msgHelper.currentSubItem;
		  _imCodes.add(hazardCode &amp; ":+" &amp; undgCode);
		  if _msgHelper.currentGroup = 6 then 
                _msgHelper.myCurrentParams.hazundg 	:= hazardCode &amp; ":+" &amp; undgCode;
           endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_imCodes" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDIMData" id="3974bf02-f0ad-49ce-b638-120a740ddb9c">
        <source>getDIMData(_msgHelper : CMIF_EDIFACTHelper io; _length, _width, _height : Decimal io) protected;
/*

Date		Who		Reason
17 February 2017	cnwer1	Initial creation TFS 2744

*/

vars

begin
	if _msgHelper = null then
		return;
	endif;
	
	if _msgHelper.currentTag &lt;&gt; "DIM" then    
		return;
	endif;
	
	_msgHelper.setNextField();
	_msgHelper.setNextField();
	
	
	if _msgHelper.currentSubItem = "CMT" then
		_msgHelper.setNextSubItem();
		_length := _msgHelper.currentSubItem.Integer;
		
		_msgHelper.setNextSubItem();
		_width := _msgHelper.currentSubItem.Integer;
		
		_msgHelper.setNextSubItem();
		_height := _msgHelper.currentSubItem.Integer;
	endif; 
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_length" type="Decimal" usage="io"/>
        <Parameter name="_width" type="Decimal" usage="io"/>
        <Parameter name="_height" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getEDIFileIssueDateTime" id="ba506f7a-687f-441b-a360-cc8276f559c8">
        <source>getEDIFileIssueDateTime(_msgHelper: CMIF_EDIFACTHelper io) protected;
/*

Date		Who		Reason
16/02/2017	cnwer1	Initial creation TFS 2744
26/06/2017	cnwdap1	TFS 4492 SNO VERMAS Changes

*/

vars
	 params 		: CMIF_EDIFACTParams; 
	 dtString 				: String; // DTM local variable
	 vgmDT			: TimeStamp;				// TFS 4492
begin
	if _msgHelper = null then
		return;
	endif;
	if _msgHelper.currentTag &lt;&gt; "DTM" then
		return;
	endif;
	 params := _msgHelper.myCurrentParams;
	if _msgHelper.currentGroup &gt; 1 then								//Par 18495 FEb 2009
		 return;
	endif;
	_msgHelper.setNextField();
	
	if _msgHelper.currentSubItem = "137" then		// date of EDI file issue
		_msgHelper.setNextSubItem();
		dtString := _msgHelper.currentSubItem.trimBlanks();
		
		_msgHelper.setNextSubItem();
		params.ediFileIssueDateTime := dtString.getUNEDIFACTTimeStamp(_msgHelper.currentSubItem.Integer);
		
	elseif _msgHelper.currentField = "798" then											// TFS 4492
		// VGM determination date/time													// TFS 4492
		_msgHelper.setNextSubItem();													// TFS 4492
		dtString := _msgHelper.currentSubItem.trimBlanks();								// TFS 4492
		vgmDT := dtString.getUNEDIFACTTimeStamp(_msgHelper.currentSubItem.Integer);		// TFS 4492
		params.vgmDeterminationDT := vgmDT;												// TFS 4492
	elseif _msgHelper.currentField = "137" then											// TFS 4492
		// VGM documentation issue date/time											// TFS 4492
		_msgHelper.setNextSubItem();													// TFS 4492
		dtString := _msgHelper.currentSubItem.trimBlanks();								// TFS 4492
		vgmDT := dtString.getUNEDIFACTTimeStamp(_msgHelper.currentSubItem.Integer);		// TFS 4492
		params.vgmDocsIssuedDT := vgmDT;												// TFS 4492
		
	endif;
        
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getEDIPartyRules" id="84ff8dc2-53c6-4b70-a175-da479e9dfac6">
        <source>getEDIPartyRules(_ediParty: CM_EDIParty): CM_EDIPartyRules protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2014	cnwrd1	Initial creation
// 21 Aug 2017	jlgrs1	TFS 6564 add Coparn and Coreor RFF and NAD translation

*/

vars

begin
	if _ediParty = null then
		return null;
	endif;
	
	return _ediParty.getRulesForFileType (EDIFileType_Coparn);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediParty" type="CM_EDIParty"/>
        <ReturnType type="CM_EDIPartyRules"/>
    </JadeMethod>
    <JadeMethod name="getFTXCommodity" id="a33c4c5a-97e4-458a-bda7-4268f9e5238a">
        <source>getFTXCommodity(_msgHelper: CMIF_EDIFACTHelper io; _ediPartyRules : CM_EDIPartyCoparnRules) protected;
/*

Date		Who		Reason
16 February 2017	cnwer1	Initial creation TFS 2744

*/

vars
	params 	: CMIF_EDIFACTParams; 
	port 		: String;
	foundMatch : Boolean;
	dtCode : String;
	ruleFunction : Integer;
	segmentValue : String;
	ftxArray : StringArray512;
	rule : CM_EDIEDIFactRule;
	specialStow : String;

begin	
	if _msgHelper = null then
		return;
	endif;
	
	if _msgHelper.currentTag &lt;&gt; "FTX" then
		return;
	endif;
			
	 params := _msgHelper.myCurrentParams;
	 
	 //20 Jun 2017	NDL	TFS 4454
	 if _ediPartyRules &lt;&gt; null and not _ediPartyRules.allEDIPartyRules.isEmpty then	
		rule := _ediPartyRules.allEDIPartyRules.getEDIEDIFactRule( CM_EDIEDIFactRule.Item_FTX_3_1 );
		if rule &lt;&gt; null then
			dtCode := _msgHelper.currentMessage;
			if  dtCode[1:4].cnContains("FTX+") then                                                                		
				dtCode := dtCode[5 : end];
				create ftxArray transient;
				dtCode.getTokensForDelimiter ("+'", ftxArray);
				if ftxArray[1] = rule.value then
					ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_FTX_3_1, rule.value, segmentValue);
					if ruleFunction = CM_EDIEDIFactRule.Function_FTX_3_1_Stowage then
						specialStow := rule.getFTXSpecialStowage(ftxArray);
						if specialStow &lt;&gt; null then
							params.specialStowage := specialStow;
						endif;
					endif;
				endif;
				delete ftxArray;
			endif;
		endif;
		
	endif;
	
	
	_msgHelper.setNextField();				// 010 Text subject qualifier
	
	if _msgHelper.currentField  = "AAA" then

		_msgHelper.setNextField();				// 020 Text function coded
		_msgHelper.setNextField();				// 030 Text reference
		_msgHelper.setNextField();				// 040 Text literal
				
		params.commodityDescHeader:=_msgHelper.currentSubItem[1:30];
		
	endif;
	
epilog

	delete ftxArray;

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules"/>
    </JadeMethod>
    <JadeMethod name="getLOCData" id="0ff2e2da-00f1-47d4-90fa-ca11eaa13ba0">
        <source>getLOCData(_msgHelper: CMIF_EDIFACTHelper io;
			_dischargePort : String io;
			_destinationPort : String io)  protected;
/*

Date		Who		Reason
16 February 2017	cnwer1	Initial creation TFS 2744

*/

vars
	params 	: CMIF_EDIFACTParams; // BGM local variable
	port 		: String;
	foundMatch : Boolean;
begin	
	if _msgHelper = null then
		return;
	endif;
	
	if _msgHelper.currentTag &lt;&gt; "LOC" then
		return;
	endif;
	params:= _msgHelper.myCurrentParams;
	
	if _msgHelper.currentGroup = 0 then
		_msgHelper.setCurrentGroup(1);	
	endif;
	
	_msgHelper.setNextField();
	
	if _msgHelper.currentGroup &lt;&gt; 1 and _msgHelper.currentGroup &lt;&gt; 7 then
		return;
	endif;	

	if _msgHelper.currentField = "9" then //place of loading
		_msgHelper.setNextField();
		port := _msgHelper.currentSubItem[1:5].trimBlanks();

	elseif _msgHelper.currentField = "11" then
		_msgHelper.setNextField();
		port := _msgHelper.currentSubItem[1:5].trimBlanks();
		params.dischargePort := port;
		if params.mySenderOperator &lt;&gt; null then
			params.dischargePort := params.mySenderOperator.getXlationSystemCode(params.dischargePort, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
		endif;	
		_dischargePort:=params.dischargePort;
	elseif _msgHelper.currentField = "88" then 
	elseif _msgHelper.currentField = "7" or //delivery
	   _msgHelper.currentField = "8" then //destination
		_msgHelper.setNextField();
		port := _msgHelper.currentSubItem[1:5].trimBlanks();
		params.destination := port;	
		if params.mySenderOperator &lt;&gt; null then
			params.destination := params.mySenderOperator.getXlationSystemCode(params.destination, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];			
		endif;
		_destinationPort:=params.destination;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_dischargePort" type="String" usage="io"/>
        <Parameter name="_destinationPort" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMEAData" id="6b31e775-b1da-469c-9108-1298189b6679">
        <source>getMEAData(_msgHelper: CMIF_EDIFACTHelper io;
			_weight : Decimal io; 
			_isVerifiedWeight : Boolean io;
			_humidity : Decimal io;
			_vent : Decimal io;
			_carbonDioxide : Decimal io;
			_oxygen : Decimal io
			) protected;
/*

Date		Who		Reason
17 February 2017	cnwer1	Initial creation TFS 2744

*/

vars

begin
	if _msgHelper = null then
		return;
	endif;
	
	if _msgHelper.currentTag &lt;&gt; "MEA" then
		return;
	endif;
	
	_msgHelper.setNextField();
	if _msgHelper.currentField = "WT" or		// weight
	   _msgHelper.currentField = "AAE" then	// measurement
		_msgHelper.setNextField();
		if _msgHelper.currentField = "AAO" then //Humidity
			_msgHelper.setNextField();
			_msgHelper.setNextSubItem();
			_humidity := _msgHelper.currentSubItem.Integer;
		elseif _msgHelper.currentField = "AAS" then //Air flow
			_msgHelper.setNextField();
			_msgHelper.setNextSubItem();
			_vent := _msgHelper.currentSubItem.Real;
		elseif _msgHelper.currentField = "CD" then //Carbondioxide (temporary code)
			_msgHelper.setNextField();
			_msgHelper.setNextSubItem();
			_carbonDioxide := _msgHelper.currentSubItem.Integer;
		elseif _msgHelper.currentField = "EGW" then //Equipment gross weight
			_msgHelper.setNextField();
			if _msgHelper.currentSubItem = "KGM" then
				_msgHelper.setNextSubItem();
				_weight := _msgHelper.currentSubItem.Integer;
			endif;
		elseif _msgHelper.currentField = "G" then //Gross weight
			_msgHelper.setNextField();
			if _msgHelper.currentSubItem = "KGM" then
				_msgHelper.setNextSubItem();
				_weight := _msgHelper.currentSubItem.Integer;
			endif;
		elseif _msgHelper.currentField = "T" then //Tare weight
			_msgHelper.setNextField();
			if _msgHelper.currentSubItem = "KGM" then
				_msgHelper.setNextSubItem();
				// cnwrs1 Par 12539 dont use Tare wight
				//bookingRef.weight := _msgHelper.currentSubItem.Integer;
			endif;
		elseif _msgHelper.currentField = "ZO" then //Oxygen
			_msgHelper.setNextField();
			_msgHelper.setNextSubItem();
			_oxygen := _msgHelper.currentSubItem.Integer;
		elseif _msgHelper.currentField = "VGM" then //Transport equipment verified gross weight //TFS 1429 par 37551 17/2/16
			//should only do this if licensed check 
			if app.myRoot.canDo(Mod_EDIVGM) then
				_msgHelper.setNextField();
				//measure unit qualifier 		
				if _msgHelper.currentSubItem = "KGM" then
					_msgHelper.setNextSubItem();
					_weight := _msgHelper.currentSubItem.Integer;
					_isVerifiedWeight:=true;
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_weight" type="Decimal" usage="io"/>
        <Parameter name="_isVerifiedWeight" type="Boolean" usage="io"/>
        <Parameter name="_humidity" type="Decimal" usage="io"/>
        <Parameter name="_vent" type="Decimal" usage="io"/>
        <Parameter name="_carbonDioxide" type="Decimal" usage="io"/>
        <Parameter name="_oxygen" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getNADData" id="6ccf3b86-525c-49ae-bd1f-836baad81864">
        <source>getNADData(_msgHelper: CMIF_EDIFACTHelper io; _ediPartyRules :CM_EDIPartyCoparnRules; _consignor, _freightForwarder : String io) protected;
/*

Date		Who		Reason
17 February 2017	cnwer1	Initial creation TFS 2744
// 21 Aug 2017	jlgrs1	TFS 6564 add Coparn and Coreor RFF and NAD translation
// 30 May 2018	jlgrs1	TFS 38357 SNO Fix Xlations from TFS 6797
*/

vars
	params 	: CMIF_EDIFACTParams; // BGM local variable
    ruleFunction : Integer; 				// DTM local variable
	foundMatch : Boolean;
	nad1_1Code : String;
	segmentValue : String;
	nad1_1Function : String;
	nad2_1Function : String;
	nad3_1Function : String;
	cargoOperatorCode : String;
begin
	if _msgHelper = null then
		return;
	endif;
	
	params := _msgHelper.myCurrentParams;
	
	if _msgHelper.currentGroup &lt; 2 then
		_msgHelper.setCurrentGroup(2);
	endif;
		_msgHelper.setNextField();
		nad1_1Code := _msgHelper.currentField;
		if _ediPartyRules &lt;&gt; null then
			ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_NAD_1_1, nad1_1Code, segmentValue);
/*			if ruleFunction = CM_EDIEDIFactRule.Function_NAD_1_1_CA then
				nad1_1Code := "CA";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_1_1_CC then
				nad1_1Code := "CC";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_1_1_CN then
				nad1_1Code := "CN";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_1_1_CU then
				nad1_1Code := "CU";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_1_1_CZ then
				nad1_1Code := "CZ";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_1_1_FW then
				nad1_1Code := "FW";
			elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_1_1_SH then
				nad1_1Code := "SH";
			endif;*/
			if ruleFunction &lt;&gt; CM_EDIRule.Function_Undefined then
				if ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee then
					nad1_1Function := CM_EDIPrenoteTI::consignee.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor then
					nad1_1Function := CM_EDIPrenoteTI::consignor.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd then
					nad1_1Function := CM_EDIPrenoteTI::freightForwarder.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper then
					nad1_1Function := CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_CustomAgent then
					nad1_1Function := CM_EDIPrenoteTI::customsAgent.name;
//				elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_n_1_WeightCertNam then
//					nad1_1Function := CM_EDIPrenoteTI::weightCertifiedName.name;
//				elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_n_1_WeightCertRef then
//					nad1_1Function := CM_EDIPrenoteTI::weightCertifiedReference.name;
				endif;
				if nad1_1Function &lt;&gt; null then
					_msgHelper.setNextField();
					if params.mySenderOperator &lt;&gt; null then
						params.setPropertyValue(nad1_1Function, params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30]);
					else
						params.setPropertyValue(nad1_1Function, _msgHelper.currentSubItem.trimBlanks()[1:30]);
					endif;
					if nad1_1Function = CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc then
						if params.mySenderOperator &lt;&gt; null then
							cargoOperatorCode := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_OPERATOR_BYOP, foundMatch)[1:30];
							params.myCargoOperator := app.myRoot.allOperators[cargoOperatorCode];
						endif;
					endif;
				endif;	
			endif;
			ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_NAD_2_1, nad1_1Code, segmentValue);
			if ruleFunction &lt;&gt; CM_EDIRule.Function_Undefined then
				if ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee then
					nad2_1Function := CM_EDIPrenoteTI::consignee.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor then
					nad2_1Function := CM_EDIPrenoteTI::consignor.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd then
					nad2_1Function := CM_EDIPrenoteTI::freightForwarder.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper then
					nad1_1Function := CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc;
//				elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_n_1_WeightCertNam then
//					nad2_1Function := CM_EDIPrenoteTI::weightCertifiedName.name;
//				elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_n_1_WeightCertRef then
//					nad2_1Function := CM_EDIPrenoteTI::weightCertifiedReference.name;
				endif;
				if nad2_1Function &lt;&gt; null then
					_msgHelper.setNextField();
					_msgHelper.setNextField();
					if params.mySenderOperator &lt;&gt; null then
						params.setPropertyValue(nad2_1Function, params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30]);
					else
						params.setPropertyValue(nad2_1Function, _msgHelper.currentSubItem.trimBlanks()[1:30]);
					endif;
					if nad1_1Function = CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc then
						if params.mySenderOperator &lt;&gt; null then
							cargoOperatorCode := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_OPERATOR_BYOP, foundMatch)[1:30];
							params.myCargoOperator := app.myRoot.allOperators[cargoOperatorCode];
						endif;
					endif;
				endif;	
			endif;
			ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_NAD_3_1, nad1_1Code, segmentValue);
			if ruleFunction &lt;&gt; CM_EDIRule.Function_Undefined then
				if ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignee then
					nad3_1Function := CM_EDIPrenoteTI::consignee.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_Consignor then
					nad3_1Function := CM_EDIPrenoteTI::consignor.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_FreightForwd then
					nad3_1Function := CM_EDIPrenoteTI::freightForwarder.name;
				elseif ruleFunction = CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper then
					nad1_1Function := CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc;
//				elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_n_1_WeightCertNam then
//					nad3_1Function := CM_EDIPrenoteTI::weightCertifiedName.name;
//				elseif ruleFunction = CM_EDIEDIFactRule.Function_NAD_n_1_WeightCertRef then
//					nad3_1Function := CM_EDIPrenoteTI::weightCertifiedReference.name;
				endif;
				if nad3_1Function &lt;&gt; null then
					_msgHelper.setNextField();
					_msgHelper.setNextField();
					_msgHelper.setNextField();
					if params.mySenderOperator &lt;&gt; null then
						params.setPropertyValue(nad3_1Function, params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30]);
					else
						params.setPropertyValue(nad3_1Function, _msgHelper.currentSubItem.trimBlanks()[1:30]);
					endif;
					if nad1_1Function = CM_EDIEDIFactRule.Fnct_NAD_n_1_CargoOper_Desc then
						if params.mySenderOperator &lt;&gt; null then
							cargoOperatorCode := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_OPERATOR_BYOP, foundMatch)[1:30];
							params.myCargoOperator := app.myRoot.allOperators[cargoOperatorCode];
						endif;
					endif;
				endif;	
			endif;
		endif;
		if nad1_1Function = null and
		   nad2_1Function = null and
		   nad3_1Function = null then
			if _msgHelper.currentGroup = 2 then
				if nad1_1Code = "CA" then // carrier (sea)
					_msgHelper.setNextField();
				elseif nad1_1Code = "CZ" then //consignor
					_msgHelper.setNextField();
					if params.mySenderOperator &lt;&gt; null then
						params.consignor := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
					else
						params.consignor := _msgHelper.currentSubItem.trimBlanks()[1:30];
					endif;
					
					// 27/02/2014 cnwar2 #33519 - if nothing in first field, check third
					if params.consignor = null then
						_msgHelper.setNextField();
						_msgHelper.setNextField();
						if params.mySenderOperator &lt;&gt; null then
							params.consignor := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
						else
							params.consignor := _msgHelper.currentSubItem.trimBlanks()[1:30];
						endif;
					endif;
					_consignor :=params.consignor;
				elseif nad1_1Code = "FW" then  //freight forward
					_msgHelper.setNextField();
					_msgHelper.setNextField();
					if params.mySenderOperator &lt;&gt; null then
						//bookingHdr.consignor := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
						params.freightForwarder := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];	// 17/07/2013 cnwar2 #31784
					else
						//bookingHdr.consignor := _msgHelper.currentSubItem.trimBlanks()[1:30];
						params.freightForwarder := _msgHelper.currentSubItem.trimBlanks()[1:30];	// 17/07/2013 cnwar2 #31784
					endif;
					
					_freightForwarder:=params.freightForwarder;
				elseif nad1_1Code = "SH" then  //shipper (non standard! COSCO) PAR 18716 cnwgb1 26.5.09
					_msgHelper.setNextField();
					_msgHelper.setNextField();
					if params.mySenderOperator &lt;&gt; null then
						params.consignor := params.mySenderOperator.getXlationSystemCode(_msgHelper.currentSubItem, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
					else
						params.consignor := _msgHelper.currentSubItem.trimBlanks()[1:30];
					endif;
					_consignor := params.consignor;
				endif;
			endif;
		endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules"/>
        <Parameter name="_consignor" type="String" usage="io"/>
        <Parameter name="_freightForwarder" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getSELData" id="8fdbbe23-40f3-4aab-bfbb-9b069dcf0a7f">
        <source>getSELData(_msgHelper: CMIF_EDIFACTHelper io; _sealNum, _sealShipper, _sealCustoms, _sealTerminalOperator, _sealUnknown : String io) protected;
//
// 26 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars
	 params 	: CMIF_EDIFACTParams; // BGM local variable
	 foundMatch : Boolean;
	sealNumber : String;
	sealType : String;
begin
	if _msgHelper = null then
		return;
	endif;
	params := _msgHelper.myCurrentParams;
	if _msgHelper.currentTag &lt;&gt; "SEL" then
		return;
	endif;
	 _msgHelper.setNextField();
	sealNumber := _msgHelper.currentField;
	_msgHelper.setNextField();
	sealType := _msgHelper.currentSubItem;
	if sealType = "CA" then
		_sealNum := sealNumber;
	elseif sealType = "SH" then
		_sealShipper := sealNumber;
	elseif sealType = "CU" then
		_sealCustoms := sealNumber;
	elseif sealType = "TO" then
		_sealTerminalOperator := sealNumber;
	else
		_sealUnknown := sealNumber; //cnwgb1 PAR 34171 20.5.2014
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_sealNum" type="String" usage="io"/>
        <Parameter name="_sealShipper" type="String" usage="io"/>
        <Parameter name="_sealCustoms" type="String" usage="io"/>
        <Parameter name="_sealTerminalOperator" type="String" usage="io"/>
        <Parameter name="_sealUnknown" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTDTData" id="5034da3a-0cb8-4be5-b7af-b7c841bd3020">
        <source>getTDTData(_msgHelper: CMIF_EDIFACTHelper io; _ediData : CM_EDIData input) protected;
/*

Date		Who		Reason
16 February 2017	cnwer1	Initial creation TFS 2744

*/

vars
	params 	: CMIF_EDIFACTParams;
	vesselCode 				: String; // TDT local variable
    vessel 					: CM_Vessel; // TDT local variable
	foundMatch				: Boolean;
begin
	if _msgHelper = null then
		return;
	endif;
	
	if _msgHelper.currentTag &lt;&gt; "TDT" then
		return;
	endif;
	if _msgHelper.currentGroup = 0 then
		_msgHelper.setCurrentGroup(1);
	endif;
	
	if _msgHelper.currentGroup &lt;&gt; 1 then
		return;
	endif;
	 params := _msgHelper.myCurrentParams;
	_msgHelper.setNextField();
	if _msgHelper.currentField &lt;&gt; "20" then
		return;
	endif;
	self.getVoyageDetailsFromTDT(	_msgHelper, params.voyageCode, params.voyageOperatorCode, params.myVoyageOperator, params.vesselName, params.lloydsNumber, params.callsign );
	
	// Because some port clients (ANL and COS in particular) do not send
	// through the mandatory UNB record the operator is not getting set up.
	// To cater for this we will use the first valid TDT+20 operator
	// if and only if the operator is not already set up.
	if params.mySenderOperator = null then
		params.mySenderOperator	:= params.myVoyageOperator;
		params.senderOperatorCode := params.voyageOperatorCode;
	endif;
	
	
	_ediData.operatorCode	:= params.senderOperatorCode;
				
	if params.mySenderOperator &lt;&gt; null then
	//cnwrs1 par 26022 19 Oct 2010 now we have the vessel and the xlation operator try the vesselname xlation
		vesselCode := params.mySenderOperator.getXlationSystemCode(params.vesselName, XLATION_TYPE_VESSEL_BYOP, foundMatch);
		if not foundMatch then	//14 Mar 2014	cnwrs1	Par 33619 if not match the vesselName is returned
			vessel := app.myRoot.allVesselsByName[vesselCode];
		else
			vessel := app.myRoot.allVessels[vesselCode];
		endif;
		if vessel &lt;&gt; null then
			params.vesselName := vessel.name;
		endif;
		params.voyageCode	:= self.getXlationOperatorVoyageCode(	params.mySenderOperator, params.myVoyageOperator, params.voyageCode, params.vesselName, params.lloydsNumber, params.callsign );				
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTMPData" id="e6c116d2-6651-4e12-a720-6b4fb3c162b2">
        <source>getTMPData(_msgHelper: CMIF_EDIFACTHelper io; _temperature : Real io );
/*

Date		Who		Reason
17 February 2017	cnwer1	Initial creation TFS 2744

*/

vars
	temperature 			: Real; // TMP l;ocal variable
begin
	if _msgHelper = null then
		return;
	endif;
	
	if _msgHelper.currentTag &lt;&gt; "TMP" then
		return;
	endif;
	
	 _msgHelper.setNextField();
	if _msgHelper.currentField = "1" or //par 16128 cnwrs1 Mar 2008
	   _msgHelper.currentField = "2" or
	   _msgHelper.currentField = "3" or
	   _msgHelper.currentField = "5" or
	   _msgHelper.currentField = "7" then
		_msgHelper.setNextField();
		temperature := _msgHelper.currentSubItem.asEDIReal();
		
		_msgHelper.setNextSubItem();
		if _msgHelper.currentSubItem = "CEL" then
			_temperature := temperature;
		elseif _msgHelper.currentSubItem = "FAH" then
			_temperature := app.temperatureConversion(false,temperature);
		endif;
	endif;
		
epilog

end;</source>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_temperature" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processBookingRefID" id="7dbe8988-e489-4db4-bbf9-468c51fc8cb1">
        <source>processBookingRefID(_currentSubItem : String; _currentBrID : String io; _ediPartyRules :CM_EDIPartyCoparnRules) protected;
//
// 14 Dec 2017	jlgrs1	TFS 8399 - SNO - EDI Booking Ref ID in group 7 not able to strip off version
//
//22 Jan 2018	jlgrs1	TFS 36627 - PENN - Request request code length too short
vars
	idx : Integer;
	pos : Integer;
	ruleFunction : Integer; 	
	charFounded : String;
	segmentValue : String;
	bookingRefId : String;
begin
	foreach idx in 1 to _currentBrID.length do								
		charFounded := _currentBrID[idx:1];
		if not charFounded.isInteger and not charFounded.toUpper.isUppercaseAlpha then
			charFounded := charFounded;
			break;
		endif;
	endforeach;
	pos := _currentBrID.pos(charFounded,1);
	if _ediPartyRules &lt;&gt; null then				
		ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_RFF_1_1, charFounded, segmentValue);
		if ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_RelNo then // Ignore Release No After Charchter
			if pos &gt; 0 then
				_currentBrID :=_currentSubItem[1:30].truncatedAt(pos-1);
			else
				_currentBrID := _currentSubItem[1:30];
			endif;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_currentSubItem" type="String"/>
        <Parameter name="_currentBrID" type="String" usage="io"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules"/>
    </JadeMethod>
    <JadeMethod name="processEDIFACTBooking" id="5bbd9bba-aa7c-45f5-a4a5-9f02e1fbb8e5">
        <source>processEDIFACTBooking(_msgHelper: CMIF_EDIFACTHelper io; _ediFile : CM_EDIFile input; _ediData : CM_EDIData input; _ediOperator : CM_Operator; _ediPartyRules :CM_EDIPartyCoparnRules) protected;
/*
Date		Who		Reason
05/12/2011  cnwrs1  CCMS POL 2122 / PAR 28696 - add support for EDI Release Request processing
06/03/2012	cnwcs5	par 29197 - LOC+11 after TDT+30 overwriting destination incorrectly
07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
08/04/2012	cnwcs5	par 31228 - do NOT use 1st 4 characters of commodity description if there is no xlation
04/07/2013	cnwcs5	par 31942
16 Aug 2013	cnwrs1	Par32278 try and makesure we have a voyageCode
16 Sep 2013 cnwah9 removed error messages and unnecessary code
14 Mar 2014	cnwrs1	Par 33619 if not match the vesselName is returned
21 Mar 2014 cnwgb1  PAR 33707 ICL Bookings
11 Sep 2014	cnwma1	PAR#34855 CCMS 2351: Hapag-Lloyd Release Request Enhancements
//31 Oct 2016	cnwrs1	TFS 2896 - HSD Sequence are no booking item numbers.
// 21 Aug 2017	jlgrs1	TFS 6564 add Coparn and Coreor RFF and NAD translation
// 01 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 30 Nov 2017	jlgrs1	TFS 5705B - SNO - EDIDataBooking Prenote release Req
// 14 Dec 2017	jlgrs1	TFS 8399 - SNO - EDI Booking Ref ID in group 7 not able to strip off version
//22 Jan 2018	jlgrs1	TFS 36627 - PENN - Request request code length too short
// 13 Feb 2018	jlgrs1	TFS 36945 CTA+RP not working in COPARN
// 10 Apr 2018	jjnlrs1	TFS 37746 - SNO dont create prenote if the container is on site
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 30 May 2018	jlgrs1	TFS 38357 SNO Fix Xlations from TFS 6797
// 12 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
//14/06/2018 	JLGNS1	Bug 38885: SNO - VGM Issue
03/09/2018		jlgka1  TFS 40214 Not set the Destination port if the LOC+8 is null.
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 07 Apr 2019  jlgsl4	TFS 44030 - SNO - enforce callsign check for multiple translations
// 02 May 2019	jlgzm1	TFS 43425 SNO Append new bookings rather than replace
// 30 Jul 2019	jlgsl4	TFS 45766 - SNO - Inconsistent weight information
*/
vars
	bookingHdr 				: CM_EDIBookingHeaderTI; 
	bookingItem 			: CM_EDIBookingItemTI;
    params 					: CMIF_EDIFACTParams; // BGM local variable
    isotype 				: String; // EQD local variable
    port 					: String; // LOC local variable
    vesselCode 				: String; // TDT local variable
    vessel 					: CM_Vessel; // TDT local variable
    thisPortCode 			: String; // TDT local variable
	foundMatch				: Boolean;
	segmentValue	: String;
	ruleFunction 	: Integer; 	
	pos				: Integer;
	charFounded		:String;
	idx				: Integer;
	nad1_1Code : String;
	rff1_1Code : String;
	prenoteEDITI : CM_EDIPrenoteTI;
	createPrenote : Boolean;
	bookingRefId : String;
	nad1_1Function : String;
	nad2_1Function : String;
	nad3_1Function : String;
	nad1_Booking : Boolean;
	nad1_Prenote : Boolean;
	rff1_1Function : String;
	cargoOperatorCode : String;

begin
	if _ediPartyRules &lt;&gt; null then
		createPrenote := _ediPartyRules.CM_EDIPartyCoparnRules.createPrenotesForEQDWithID;
	endif;
    params := _msgHelper.myCurrentParams;
	
    if params.myEDIBookingHeaderTI &lt;&gt; null then
        bookingHdr := params.myEDIBookingHeaderTI;
    endif;
	
    if params.myEDIBookingItemTI &lt;&gt; null  then
        bookingItem := params.myEDIBookingItemTI;
    endif;
	if createPrenote and
	   params.myEDIPrenoteTI &lt;&gt; null then
		prenoteEDITI := params.myEDIPrenoteTI;
	endif;
//CTA
	if _msgHelper.currentTag = "CTA" then										// TFS 4492
		_msgHelper.setNextField();												// TFS 4492
		if createPrenote and prenoteEDITI &lt;&gt; null then
			if _msgHelper.currentField = "RP" then									// TFS 4492
				// signature of VGM authorised person								// TFS 4492
				_msgHelper.setNextField;															// TFS 4492
				_msgHelper.setNextSubItem;														// TFS 4492
				prenoteEDITI.vgmAuthSignature := _msgHelper.currentSubItem;			// TFS 4492
			endif;																	// TFS 4492
		endif;
//DGS
    elseif _msgHelper.currentTag = "DGS" then
        if _msgHelper.currentGroup &lt; 6 then
            _msgHelper.setCurrentGroup( 6 );
        endif;		
		//epr TFS 2744 17/2/17
		self.getDGSData(_msgHelper, bookingItem.imCodes);	
		if createPrenote and prenoteEDITI &lt;&gt; null then
			bookingItem.imCodes.copy(prenoteEDITI.imCodes);
		endif;
//DIM
    elseif _msgHelper.currentTag = "DIM" then
        if _msgHelper.currentGroup = 7 then
			//epr TFS 2744 17/2/17
			self.getDIMData(_msgHelper,bookingItem.length, bookingItem.width, bookingItem.height);		         
			if createPrenote and prenoteEDITI &lt;&gt; null then
				prenoteEDITI.length := bookingItem.length;
				prenoteEDITI.width := bookingItem.width;
				prenoteEDITI.height := bookingItem.height;
			endif;
		endif; 
//DTM
    elseif _msgHelper.currentTag = "DTM" then
        self.getEDIFileIssueDateTime(_msgHelper); //epr TFS 2744		
//EQA
 
//EQD
	elseif _msgHelper.currentTag = "EQD" then
		_msgHelper.setCurrentGroup(7);
		
		if bookingItem.number &gt; 0 then // (And everything in the if) Added for PAR 18471 cnwgb1 11.11.08 //cnwrs1 CCMS 1882 24 May 2010
			// We've previously seen an EQD. Need to make another one for multi item cnwgb1 11.11.08
			// The first bookingRef has been created in RFF section. Before creating others multi items, need to flag the first one as multi item.  Par 18495, Jan 2009
		
            create bookingItem persistent;
			params.myEDIBookingItemTI := bookingItem;
			
			bookingItem.setForCreateNew(_ediData);

			bookingHdr.setId(params.currentBrID);
			bookingItem.setId(params.currentBrID);
			bookingItem.myParent 		:= bookingHdr;
			bookingHdr.messageMode 		:= _msgHelper.currentMessageMode;
			bookingHdr.destinationPort 	:= params.destination;
			bookingHdr.dischargePort 	:= params.dischargePort;
			bookingHdr.operatorCode 	:= params.cargoOperatorCode;

			if params.hazundg &lt;&gt; null then 
				bookingItem.imCodes.add(params.hazundg);
			endif;
			// if commodity was set by FTX in group 3 then use that commodity for the booking item
			if params.commodityDescHeader &lt;&gt; null then
				self.setRawCommodityValue (3, bookingItem, params.commodityDescHeader);
			endif;
			
			if params.vesselName &lt;&gt; null then
				bookingHdr.vesselName := params.vesselName;
			endif;
			
			bookingHdr.setRawVoyageCode( params.voyageCode.trimBlanks()[1:30] );
			
			if params.mySenderOperator &lt;&gt; null then
				params.voyageCode	:= self.getXlationOperatorVoyageCode(params.mySenderOperator, params.myVoyageOperator, params.voyageCode, params.vesselName, params.lloydsNumber, params.callsign );
				bookingHdr.setVoyageCode( params.voyageCode[1:30] );
			else
				// make sure the manual collection on CM_EDIConfig gets maintained
				if bookingHdr.getVoyageCode() = null then	//14 Mar 2014	cnwrs1	Par 33619 dont overwrite any newly setup voyageCode
					bookingHdr.setVoyageCode( bookingHdr.getRawVoyageCode );
				endif;
			endif;
			
			bookingHdr.ediFileIssueDateTime	:= params.ediFileIssueDateTime;
		else	//16 Aug 2013	cnwrs1	Par32278 try and makesure we have a voyageCode
			if bookingHdr.getVoyageCode() = null then	//14 Mar 2014	cnwrs1	Par 33619 dont overwrite any newly setup voyageCode
				bookingHdr.setVoyageCode(bookingHdr.getRawVoyageCode);
			endif;
		endif;
        bookingItem.number := 1; //cnwgb1 33707 21.3.2013
        params.foundEQD := true; //cnwgb1 33707 21.3.2013 		
		_msgHelper.setNextField();
		
		if _msgHelper.currentField = "CN" or
		   _msgHelper.currentField[1:2] = "T7" then
			bookingHdr.setCargoType(TI_CargoType_Container);
			_msgHelper.setNextField();
			//epr TFS 1480 EDI Vefified weight changes 5/2/16
			bookingItem.cargoId:=_msgHelper.currentSubItem;
			
			_msgHelper.setNextField();
			isotype := _msgHelper.currentField[1:4];
			//now use xlation CCMS 1157
			if params.mySenderOperator &lt;&gt; null then
				bookingItem.isoType := params.mySenderOperator.getXlationSystemCode(isotype, XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:4];
			else
				bookingItem.isoType := isotype.trimBlanks()[1:4];
			endif;
			
			_msgHelper.setNextField();
			_msgHelper.setNextField();
			_msgHelper.setNextField();
			
			if _msgHelper.currentField = "4" then
				bookingItem.fullOrMT := "E"; //cnwrs1 CCMS 1882 24 May 2010
			elseif _msgHelper.currentField = "5" then
				bookingItem.fullOrMT := "F";
			endif;
		endif;
		if createPrenote then 
			params.myCargoOperator := null;
			if bookingItem.cargoId = null then
				prenoteEDITI := null;
				params.myEDIPrenoteTI := null;
			else
				if prenoteEDITI = null or
				   prenoteEDITI.id &lt;&gt; bookingItem.cargoId then
					create prenoteEDITI persistent; 
					params.myEDIPrenoteTI := prenoteEDITI;
					prenoteEDITI.messageMode := bookingHdr.messageMode;
					prenoteEDITI.setForCreateNew(_ediData);
					prenoteEDITI.setId(bookingItem.cargoId);
					prenoteEDITI.setCargoType(bookingItem.cargoType);
					prenoteEDITI.destinationPort := bookingHdr.destinationPort;
					prenoteEDITI.dischargePort := bookingHdr.dischargePort;
					prenoteEDITI.operatorCode := bookingHdr.operatorCode;
					prenoteEDITI.ediFileIssueDateTime := params.ediFileIssueDateTime;
					prenoteEDITI.bookingRef := params.currentBrID;
					prenoteEDITI.consignee := bookingHdr.consignee;
					prenoteEDITI.consignor := bookingHdr.consignor;
					prenoteEDITI.customsAgent := bookingHdr.customsAgent;
					prenoteEDITI.clientRef := params.clientRef;
					prenoteEDITI.bol := params.bolNumber;
					prenoteEDITI.freightForwarder := bookingHdr.freightForwarder;
					if params.hazundg &lt;&gt; null then 
					//	bookingItem.imCodes.add(params.hazundg);
						prenoteEDITI.imCodes.add(params.hazundg);	//17 Sep 2019	NDL	TFS 46556
					endif;
					prenoteEDITI.carrierCode := bookingHdr.carrierCode;
					prenoteEDITI.releaseCarrierCode := params.releaseCarrier;
					prenoteEDITI.setVoyageCode(bookingHdr.getVoyageCode);
					prenoteEDITI.vesselName := bookingHdr.vesselName;
					prenoteEDITI.commodityDescription := params.commodityDescHeader;
					prenoteEDITI.isoType := bookingItem.isoType;
					prenoteEDITI.fullOrMT := bookingItem.fullOrMT;
					if params.weightCertifiedName &lt;&gt; null then
						prenoteEDITI.weightCertifiedName := params.weightCertifiedName;
					endif;
					if params.weightCertifiedReference &lt;&gt; null then
						prenoteEDITI.weightCertifiedReference := params.weightCertifiedReference;
					endif;
				endif;	
			endif;
		endif;		
//EQN
    elseif _msgHelper.currentTag = "EQN" then
        if _msgHelper.currentGroup = 7 then
            _msgHelper.setNextField();
            if params.foundEQD = true then                              //cnwgb1 33707 21.3.2013
                bookingItem.number := _msgHelper.currentField.Integer;  //cnwgb1 33707 21.3.2013
                params.foundEQD := false;                               //cnwgb1 33707 21.3.2013
            else
                bookingItem.number := bookingItem.number + _msgHelper.currentField.Integer;
            endif;
        endif; 
//FTX
	elseif _msgHelper.currentTag = "FTX" then
		self.processEDIFACTBooking_FTX (_msgHelper, params, bookingItem, _ediPartyRules);	// par 31942
		if createPrenote and prenoteEDITI &lt;&gt; null then
			prenoteEDITI.remarks := bookingHdr.remarks;
			prenoteEDITI.specialStowage := bookingItem.specialStowage;
		endif;
//GID
    elseif _msgHelper.currentTag = "GID" then
        if _msgHelper.currentGroup &lt; 3 then
            _msgHelper.setCurrentGroup(3);
        endif;
//LOC
	elseif _msgHelper.currentTag = "LOC" then
		if _msgHelper.currentGroup = 0 then
			_msgHelper.setCurrentGroup(1);	
		endif;
		_msgHelper.setNextField();
		if _msgHelper.currentGroup = 1 or
		   _msgHelper.currentGroup = 7 then //par 16128 cnwrs1 Mar 2008
			if _msgHelper.currentField = "9" then //place of loading
				_msgHelper.setNextField();
				port := _msgHelper.currentSubItem[1:5].trimBlanks();
			elseif _msgHelper.currentField = "11" then
				_msgHelper.setNextField();
				port := _msgHelper.currentSubItem[1:5].trimBlanks();
				params.dischargePort := port;
				if params.mySenderOperator &lt;&gt; null then
					bookingHdr.dischargePort := params.mySenderOperator.getXlationSystemCode(params.dischargePort, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
				else
					bookingHdr.dischargePort := params.dischargePort.trimBlanks()[1:5];
				endif;
			elseif _msgHelper.currentField = "88" then 
			elseif _msgHelper.currentField = "7" or //delivery
			   _msgHelper.currentField = "163" or	//destination for stowage purposes			29/6/18 MAP TFS36654
			   _msgHelper.currentField = "171" or	//destination prior to stowage
			   _msgHelper.currentField = "8" then //destination
				_msgHelper.setNextField();
				port := _msgHelper.currentSubItem[1:5].trimBlanks();
				if port &lt;&gt; null then	// jlgka1 40214 3.9.2018
					params.destination := port;
					if params.mySenderOperator &lt;&gt; null then
						bookingHdr.destinationPort := params.mySenderOperator.getXlationSystemCode(params.destination, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					else
						bookingHdr.destinationPort := params.destination.trimBlanks()[1:5];
					endif;
				endif;
			elseif _msgHelper.currentField = "13" then //place of tranship
			elseif _msgHelper.currentField = "64" then //first optional discharge
			elseif _msgHelper.currentField = "98" then //Place of empty equipment despatch
			else
				//Do Nothing
			endif;
			if createPrenote and prenoteEDITI &lt;&gt; null then
				prenoteEDITI.destinationPort := bookingHdr.destinationPort;
				prenoteEDITI.dischargePort := bookingHdr.dischargePort;
			endif;
		elseif _msgHelper.currentGroup = 9 then
			if _msgHelper.currentField = "98" then
			endif;//add end
		endif; 
//MEA
	elseif _msgHelper.currentTag = "MEA" then
		if _msgHelper.currentGroup = 7 then
			_msgHelper.setNextField();
			if _msgHelper.currentField = "WT" or		// weight
			   _msgHelper.currentField = "AAE" then	// measurement
				_msgHelper.setNextField();
				if _msgHelper.currentField = "AAO" then //Humidity
					_msgHelper.setNextField();
					_msgHelper.setNextSubItem();
					bookingItem.setHumidity( _msgHelper.currentSubItem.asDecimalJMT );
				elseif _msgHelper.currentField = "AAS" then //Air flow
					_msgHelper.setNextField();
					_msgHelper.setNextSubItem();
					bookingItem.vent := _msgHelper.currentSubItem.Real;
				elseif _msgHelper.currentField = "CD" then //Carbondioxide (temporary code)
					_msgHelper.setNextField();
					_msgHelper.setNextSubItem();
					bookingItem.setCarbonDioxide( _msgHelper.currentSubItem.asDecimalJMT );
				elseif _msgHelper.currentField = "EGW" then //Equipment gross weight
					_msgHelper.setNextField();
					if _msgHelper.currentSubItem = "KGM" then
						_msgHelper.setNextSubItem();
						bookingItem.weight := _msgHelper.currentSubItem.Integer;
					endif;
				elseif _msgHelper.currentField = "G" then //Gross weight
					_msgHelper.setNextField();
					if _msgHelper.currentSubItem = "KGM" then
						_msgHelper.setNextSubItem();
						bookingItem.weight := _msgHelper.currentSubItem.Integer;
					endif;
				elseif _msgHelper.currentField = "T" then //Tare weight
					_msgHelper.setNextField();
					if _msgHelper.currentSubItem = "KGM" then
						_msgHelper.setNextSubItem();
						bookingItem.tareWeight := _msgHelper.currentSubItem.Integer; // TFS 45766
						// cnwrs1 Par 12539 dont use Tare wight
						//bookingRef.weight := _msgHelper.currentSubItem.Integer;
					endif;
				elseif _msgHelper.currentField = "ZO" then //Oxygen
					_msgHelper.setNextField();
					_msgHelper.setNextSubItem();
					bookingItem.setOxygen( _msgHelper.currentSubItem.asDecimalJMT );
				elseif _msgHelper.currentField = "VGM" then //Transport equipment verified gross weight //TFS 1429 par 37551 17/2/16
					//should only do this if licensed check 
					if app.myRoot.canDo(Mod_EDIVGM) then
						_msgHelper.setNextField();
						//measure unit qualifier 		
						if _msgHelper.currentSubItem = "KGM" then
							_msgHelper.setNextSubItem();
							bookingItem.weight := _msgHelper.currentSubItem.Integer;
							bookingItem.isVerifiedWeight:=true;
						endif;
					endif;
				endif;
			endif;
			if createPrenote and prenoteEDITI &lt;&gt; null then
				prenoteEDITI.weight := bookingItem.weight;
				prenoteEDITI.setHumidity( bookingItem.getHumidity );
				prenoteEDITI.vent := bookingItem.vent;
				prenoteEDITI.setCarbonDioxide( bookingItem.getCarbonDioxide );
				prenoteEDITI.setOxygen( bookingItem.getOxygen );
				prenoteEDITI.isWeightCertified := bookingItem.isVerifiedWeight;
				prenoteEDITI.tareWeight := bookingItem.tareWeight; // TFS 45766
			endif;
		endif; 
//NAD
	elseif _msgHelper.currentTag = "NAD" then
		if _msgHelper.currentGroup &lt; 2 then
			_msgHelper.setCurrentGroup(2);
		endif;
		_msgHelper.setNextField();
		nad1_1Code := _msgHelper.currentField;
		if _ediPartyRules &lt;&gt; null then
			ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_NAD_1_1, nad1_1Code, segmentValue);
