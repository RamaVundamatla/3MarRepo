    <JadeMethod name="isCargoAvailCheckEnabled" id="e83410fe-f147-4d0c-8867-c51db5efa089">
        <source>isCargoAvailCheckEnabled() : Boolean;
/*
Purpose: Determines if the Road Gate Cargo Availability Check feature is turned on.
		 The conditions to perform Cargo Availability Check are:
		 - the user opted to release the cargo by CARGO TYPE
		 - the Road Gate Cargo Availability Check option is SET
		 - the cargo availability criteria has been configured and the configured criteria are satisfied
		 
Parameters:			

Return Value:		

Date		Who		TFS		Reason
29 Nov 2019	jlgdi1	47771	Code reusability
*/

begin
	return self.isReleaseCargoByType() and 
		   self.isRoadGateCargoCheckSet() and 
		   self.isCargoCheckCriteriaMatch();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCargoCheckCriteriaMatch" id="d86f2b90-acb2-48d7-9461-b5a5fcbc0f3d">
        <source>isCargoCheckCriteriaMatch() : Boolean;
/*
Purpose: Returns true if 
		 - criteria for the cargo to be checked has been configured or setup
		 - and the corresponding combos {Operator, Cargo Type, Cargo Subtype} in the Road Release screen matched with the configured criteria values

Parameters:	

Return Value: 

Date		Who		TFS		Reason
29 Nov 2019	jlgdi1	47771	The entire code was taken out from the method isReleaseCargoByType() to observe single responsibility principle
*/

vars
	criteria : CM_RoadGateCargoCheckCriteria;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	product : CM_Product;
	yaRequest : CMIF_YARequest;
	
begin
	criteria := self.myTerminal.myRoadGateCargoCheckCriteria;
	if criteria &lt;&gt; null then
		cargoType := self.cmbTiType.getObject().CM_CargoType;
		operator := self.cmbOperatorCode.myObject.CM_Operator;
		product := self.cmbSubCargo.getObject().CM_Product;
		create yaRequest transient;
		yaRequest.initializeForRoadGateCargoChk(self.myTerminal,
												cargoType,
												operator,
												product);
		return criteria.matchesCriteria(yaRequest);
	endif;

	return false;
	
epilog
	delete yaRequest;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMoreThanTheAvailable" id="46589388-3c47-4b7b-8eba-1c0dd5ab7bac">
        <source>isMoreThanTheAvailable(_releaseByType : Boolean; 
					   _byQuantity : Boolean;
					   _totalQuantity : Integer;
					   _totalWeight : Decimal;
					   _controller : CMIF_FlexiGateController) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2019	jlgdi1	TFS# 41721 Initial creation

*/

begin
	if _releaseByType then 
		if _byQuantity then
			return _controller.numItems &gt; _totalQuantity;
		else
			return _controller.weight &gt; _totalWeight;
		endif;
	else
		return false;
	endif;
end;</source>
        <Parameter name="_releaseByType" type="Boolean"/>
        <Parameter name="_byQuantity" type="Boolean"/>
        <Parameter name="_totalQuantity" type="Integer"/>
        <Parameter name="_totalWeight" type="Decimal"/>
        <Parameter name="_controller" type="CMIF_FlexiGateController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReleaseCargoByType" id="b2591748-bee8-40f3-a0b4-77b8f6d11ab8">
        <source>isReleaseCargoByType() : Boolean;
/*
Purpose: Determines if the operation in the Release Cargo screen is in 'Release by Type' mode.
		 To be considered as 'Release by Type'
		 1 - must be GENERAL CARGO
		 AND the user must have atleast entered values on
		 1 - Operator combobox
		 2 - Cargo Type	combobox
		 AND specific TrackedItem has not been identified
		 
Parameters:	

Return Value:		

Date		Who		TFS		Reason
18 Mar 2019	jlgdi1	41721	Initial creation
29 Nov 2019	jlgdi1	47771	Removed the code that determines if the criteria matched with the cargo that requires 
							availability check. The code that was removed is transfered to the new method isCargoCheckCriteriaMatch() to 
							observed single responsiblity principle. Added a condition check if myTI has been identified.
*/

begin
	return (self.myTI = null) and 
		   (self.isGeneralCargo()) and 
		   (self.cmbOperatorCode.listObject &lt;&gt; null) and 
	       (self.cmbTiType.getObject() &lt;&gt; null);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRoadGateCargoCheckSet" id="f1f4313d-7497-48ca-9b28-d748392e79c9">
        <source>isRoadGateCargoCheckSet() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2019	jlgdi1	TFS# 41721 Initial creation

*/

begin
	return self.myTerminal.getConfig(RoadGateCargoCheckOption).Integer &gt; 0;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
