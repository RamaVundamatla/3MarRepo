    <JadeMethod name="setProxy" id="1fc473cf-2e85-4b37-ac36-438906236e79">
        <updating/>
        <source>setProxy(pBookingRef : String;
		 pCargoType : Integer;
		 pClean : Boolean;
		 pCommodity, pConsignorRef, pDescription, pDestinationPort, pDischargePort : String;
		 pMyTranshipToPort : CM_Port;
		 pDischargePorts : StringArray;
		 pHazards : ObjectArray;
		 pHumidity : Decimal;
		 pInspected : Boolean;
		 pIsoType : String;
		 pConsignor : CM_ConsigneeConsignor; 
		 pConsignee : CM_ConsigneeConsignor; 
		 pOperator : CM_Operator; 
		 pVoyage : CM_Voyage; 
		 pQuantity : Integer;
		 pBookingRemarks : String;
		 pRemarks : String;
		 pTemperature : Real;
		 pVentilation : Decimal;
		 pHeight,
		 pLength,
		 pWidth 	: Decimal;
		 pHeightStr,
		 pLengthStr,
		 pWidthStr,
		 pTypeStr 	: String;
		 pDensity : Decimal;						// PAR #33606
		 pVolume : Real;
		 pProductQuantity : Integer;
		 pWeight : Decimal;
		 pCubicMetres : Real;
		 pTerminal : CM_Terminal;
		 pProduct : CM_Product;
		 pIsMultiItem : Boolean;
		 pIsStockBookingRef : Boolean;
		 pEDIBookingRefTI : CM_EDIBookingRefTI;
		 _rawEDIData,
		 pShippingRef,
		 _carrierReference, 	// par 27460 cnwcs5
		_consignorDesc,
		_consigneeDesc : String;
		_custPriority : CM_CustomerPriority;
		_specialStow : CM_SpecialStow;  
		_holdPartials,
		_noFullIsAllowedIn,
		_noEmptiesOut, 
		_isMilitary : Boolean; 
		_vNumber : String;
		_overrideCutoff, 
		_overDimension,
		_fumigationNeeded, 
		_isStopped : Boolean;
		_status : Integer;
		_ediFileIssueDateTime : TimeStamp;
		_specialLift : ObjectArray; 												//+cnwml2 PAR20173 SFW CCMS 1091
		_allLinkedStockBookingItems : CM_BookingRefItemSet;							//+cnwml2 MSL CCMS 1012
		_receiveAsTranship : Boolean;												//+cnwml2 MSL CCMS 1012
		_transhipVoyage : CM_Voyage;												//+cnwml2 MSL CCMS 1012
		_packAs 		: Integer;															//+cnwml2 MSL CCMS 1012
		_customsAgent   : String; // cnwrl1 18/02/2010 PAR 22393
		_ediVoyageCode  : String; //cnwrs1 CCMS 1882 03 June 2010
		_ediVesselName  : String;
		pDirectDelivery : Boolean;
		_freightFwdr    : CM_ConsigneeConsignor;
		_carrier        : CM_Carrier;
		_stevedore      : CM_Stevedore ) updating;								// PAR #31596
// ---------------------------------------------------------------------------
// Created:     30 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// adm 160310 Par 22937 remove bolType
// 21 May 2011	cnwcs5		CCMS SCT 2058/par 27460 - add carrier reference
// 27 May 2103	cnwdap1		PAR #31596 Added freight forwarder
// 24 Mar 2014 	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk - change density parameter to decimal
// 05 Jun 2018	jlgrs1		TFS 39018 SNO Cargo Operator in COPRAR
// 02 Oct 2020  cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
vars
	haz			: CM_Hazard;
	tmpHazards	: CM_HazardByCodeDict;
	tmpSpecialLift : CM_SpecialLiftByCodeDict;
	
begin
	self.raiseExceptionIfNotTransient(method);
	
//	self.bookingReference	:= pBookingRef;
//	self.bookingReference	:= pBookingRef.trimBlanks;	//22 Oct 2013	NDL	Par 32553
	self.setBookingReference( pBookingRef.trimBlanks );	//06 Dec 2017	NDL	TFS 8013
//	self.bolType			:= pBOLType;
	self.cargoType			:= pCargoType;
	self.clean				:= pClean;
	self.commodity 			:= pCommodity;
	self.consignorReference	:= pConsignorRef;
	self.cubicMetres		:= pCubicMetres;
	self.description 		:= pDescription;
	self.destinationPort	:= pDestinationPort;
	self.setDirectDelivery( pDirectDelivery );	//29 Jan 2013	NDL	Par 31102
	self.dischargePort		:= pDischargePort;
	//self.myTranshipToPort	:= pMyTranshipToPort;
	self.setTranshipToPort( pMyTranshipToPort, false );	//07 Sep 2012	NDL	Par 29684
	self.consignorDesc		:= _consignorDesc; // dh 3/9/2008 added for APM
	self.consigneeDesc		:= _consigneeDesc; // dh 3/9/2008 added for APM
	self.myCustomerPriority	:= _custPriority;  // dh 3/9/2008 added for APM
	self.mySpecialStow		:= _specialStow;  // dh 3/9/2008 added for APM
	self.holdPartials		:= _holdPartials; // dh 3/9/2008 added for APM
	self.noFullIsAllowedIn	:= _noFullIsAllowedIn; // dh 3/9/2008 added for APM
	self.noEmptiesOut		:= _noEmptiesOut; // dh 3/9/2008 added for APM
	self.isMilitary			:= _isMilitary; // dh 3/9/2008 added for APM
	self.vNumber			:= _vNumber; // dh 3/9/2008 added for APM
	self.overrideCutoff		:= _overrideCutoff; // dh 3/9/2008 added for APM
	self.overDimension		:= _overDimension; // dh 3/9/2008 added for APM
	self.fumigationNeeded	:= _fumigationNeeded; // dh 3/9/2008 added for APM
	self.isStopped			:= _isStopped; // dh 3/9/2008 added for APM
	
	allDischargePorts.clear;
	pDischargePorts.copy(self.allDischargePorts);

	create tmpHazards transient;
	pHazards.copy(tmpHazards);
	self.setPxyHazards(tmpHazards);		//CCMS 1203
	foreach haz in tmpHazards do
		//self.allHazards has already been populated with the original values
		//need to check that we aren't piling on the same ones
		if not self.allHazards.includes(haz.code) then  //cnwjo3 par 20606
			self.allHazards.add(haz.code);
		endif;
	endforeach;
	
	if _specialLift &lt;&gt; null then
		create tmpSpecialLift transient;					//+cnwml2 PAR20173 SFW CCMS 1091
		_specialLift.copy(tmpSpecialLift);					//+cnwml2 PAR20173 SFW CCMS 1091
		self.setSpecialLift(tmpSpecialLift);				//+cnwml2 PAR20173 SFW CCMS 1091
	endif;

	self.setHumidity( pHumidity ); //02 Apr 2020	NDL	TFS 47958 
	self.inspected			:= pInspected;
	self.isoType			:= pIsoType;
	self.myConsignor		:= pConsignor;
	self.myConsignee		:= pConsignee;
	self.myFreightForwarder	:= _freightFwdr;				// PAR #31596
	// self.myOperator is done below in references
	
	self.myVoyage			:= pVoyage;
	self.quantity			:= pQuantity;
	self.bookingRefRemarks	:= pBookingRemarks.trimBlanks;
	self.remarks			:= pRemarks.trimBlanks;
	self.temperature		:= pTemperature;
	self.ventilation		:= pVentilation;
	self.weight				:= pWeight;
	self.height				:= pHeight;
	self.length				:= pLength;
	self.width				:= pWidth;
	self.heightString		:= pHeightStr;
	self.lengthString		:= pLengthStr;
	self.widthString		:= pWidthStr;
	self.typeString			:= pTypeStr;
	self.density			:= pDensity;
	self.volume				:= pVolume;
	self.productQuantity	:= pProductQuantity;
	self.isMultiItemBookingRef := pIsMultiItem;
	self.isStockBookingRef 	:= pIsStockBookingRef; 
	self.shippingReference  := pShippingRef; //AER 30/06/2008 par 17421
	self.operatorReferenceNumber	:= _carrierReference;	// par 27460 cnwcs
	self.ediFileIssueDateTime	:= _ediFileIssueDateTime; //Par 18495 Feb 2009
	self.myCarrier := _carrier;
	// set the references with inverses that will add to the appropriate collections
	self.myOperator			:= pOperator;
	self.myTerminal			:= pTerminal;
	self.myProduct			:= pProduct;
	self.myEDIBookingRefTI  := pEDIBookingRefTI;
	self.rawEDIData			:= _rawEDIData;
	self.status 			:= _status; 								//AER SFW 1037 
	self.receiveAsTranship	:= _receiveAsTranship;						//+cnwml2 MSL CCMS 1012
	self.myTranshipVoyage	:= _transhipVoyage;							//+cnwml2 MSL CCMS 1012
	self.packAs				:= _packAs;									//+cnwml2 MSL CCMS 1012
	self.customsAgent		:= _customsAgent;							// cnwrl1 17/02/2010 PAR 22393
	self.ediVesselName 		:= _ediVesselName;							//cnwrs1 CCMS 1882 03 June 2010
	self.ediVoyageCode 		:= _ediVoyageCode;							//cnwrs1 CCMS 1882 03 June 2010
	self.myStevedore        := _stevedore;                              //02.10.2020 cnwma1 TFS #50112
epilog
	delete tmpHazards;
	delete tmpSpecialLift;
end;</source>
        <Parameter name="pBookingRef" type="String"/>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="pClean" type="Boolean"/>
        <Parameter name="pCommodity" type="String"/>
        <Parameter name="pConsignorRef" type="String"/>
