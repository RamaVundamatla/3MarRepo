        <source>wsRESTFindCargo(_operator: String; _queryParams: String; _body: String; _expectFailure: Boolean; _response: String io): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
05 July 2024		navmd1	Initial creation TFS 65034 Partial test to cover CUX specific /Find/Cargo functionality

*/

vars
	requestBody			: WS_FindCargoRequestObject;
	requestLogin		: WS_RESTLoginAuthRequest;
	webService			: MasterTerminalAPIService;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	response 			: WS_Response;
	ref 				: String;
	jsonHelper 			: JMTJadeJson;
begin
	create webService transient;
	create transientJSONObjs transient;
	create parser transient;
	
	// Login Request
	self.loginRestWithOperator(webService, _operator);
	webService.qsData.parseNameValuePair(_queryParams);

	// set up the WS_Request object
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/find/cargo");
	requestBody := parser.parse(_body, WS_FindCargoRequestObject, transientJSONObjs).WS_FindCargoRequestObject;
	if requestBody = null then
		return "Unable to parse /Find www-form-urlencoded body";
	endif;

	response := webService.postFind("cargo", requestBody);
	create jsonHelper transient;
	_response := jsonHelper.generateJson(response, JadeJson.Format_Json_Microsoft);	
	
	// If we're expecting to fail, then return early
	if _expectFailure then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		return response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		if response.allErrors.size &gt; 0 then
			app.writeLog(response.allErrors.first.text, LogERROR);
		endif;
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details" &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTFindCargo.name;

epilog
	if webService.objectsToBeDeleted.isNotEmpty then
		webService.objectsToBeDeleted.purge;
	endif;
	webService.qsData.purge();
	delete webService;
	delete parser;
	delete requestLogin;
	delete requestBody;
	transientJSONObjs.purge();
	delete transientJSONObjs;
	delete jsonHelper;
end;</source>
