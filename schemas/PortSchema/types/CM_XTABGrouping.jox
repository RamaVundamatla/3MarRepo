    <JadeMethod name="validateForCreate" id="104a11fd-e40e-45ca-a0e7-b56f5c06a881">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	
	if self.myXTABMapping &lt;&gt; null then
		self.myXTABMapping.validateForCreate;
	endif;

epilog

end;</source>
