    <JadeMethod name="getGrossTerminalArea" id="a86ede4c-cdad-4bf0-b638-c013c64098b8">
        <source>getGrossTerminalArea(strLocation: String): String protected;

// 25/02/2010 cnwcs5 remove VTA references
vars
	bank		: CM_Bank;
	terminal	: CM_Terminal;
	terminalArea:   CM_TerminalArea;
	voyage:         CM_Voyage;
	wagon:          CM_Wagon;
	areaID:         String;
	pos:            Integer;
begin
	pos := 1;

	areaID := strLocation.getNextToken(pos);

	if areaID = null then
		return GROSSAREA_YARD;
	endif;
	// 36348 handle Road target; 36460 and rail, ship, nowhere
	if areaID = GROSSAREA_ROAD or
	   areaID = GROSSAREA_RAIL or
	   areaID = GROSSAREA_SHIP or
	   areaID = GROSSAREA_NOWHERE then
		return areaID;
	endif;
		
	bank := self.getBank();
	if bank &lt;&gt; null then
		terminal := bank.terminal;
	endif;
	if terminal = null then
		terminal := app.getMyTerminalDO_NOT_USE();
	endif;
	terminalArea := terminal.allTerminalAreas[areaID];

	if terminalArea &lt;&gt; null then
		if terminalArea.type = TA_TYPE_RAILWAY_TRACK then
			return GROSSAREA_RAIL;
		elseif //terminalArea.type = TA_TYPE_ROAD_TRANS or			25/02/2010 cnwcs5 remove VTA references
				terminalArea.type = TA_TYPE_GATE_ROAD or			// CNWCS5 11/09/2009
				terminalArea.type = TA_TYPE_YARD_INTERCHANGE then	// cnwcs5 11/09/2009
			return GROSSAREA_ROAD;
		else
			return GROSSAREA_YARD;
		endif;
	endif;

	// check voyages (don't need to worry about archived voyages I presume)
	voyage := app.getMyTerminalDO_NOT_USE().lookupVoyage(areaID, null, false);
	if voyage &lt;&gt; null then
		return GROSSAREA_SHIP;
	endif;

// PAR 19710	wagon := app.getMyTerminal().allWagons[areaID, null];
	wagon := app.getMyTerminalDO_NOT_USE().getLatestWagonByCode(areaID);
	

	if wagon &lt;&gt; null then
		return GROSSAREA_RAIL;
	endif;

	// Yard is the default
	return GROSSAREA_YARD;
end;</source>
        <access>protected</access>
        <Parameter name="strLocation" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
