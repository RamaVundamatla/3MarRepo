    <JadeMethod name="btnAdd_click" id="02ea0450-a7be-440e-bb82-0dc2023288e2">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdd_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		30 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.statusMsg('Updating object selection criteria...');

	if self.validateCriteria() then
		if btn.caption = 'Upd&amp;ate' then
			self.formAdd(false);
		else
			self.formAdd(true);
		endif;

		btnOk.enabled	:=	true;
	endif;
epilog
	self.statusMsg('');
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
