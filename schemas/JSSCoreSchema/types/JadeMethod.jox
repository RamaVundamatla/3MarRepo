<Class name="JadeMethod">
    <JadeMethod name="jssGetLocalVars" id="06e48555-1ce0-40b0-9d54-35ed94ccbd0a">
        <source>jssGetLocalVars():JadeLocalVarColl;
// --------------------------------------------------------------------------------
// Created:		24 April 2003 by cnwdad1
//
// Purpose:		Returns a reference to the receiver's collection of variables.
//
// Parameters:	None
//
// Returns:		A reference to the variables collection.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.localVars;
end;</source>
        <ReturnType type="JadeLocalVarColl"/>
    </JadeMethod>
