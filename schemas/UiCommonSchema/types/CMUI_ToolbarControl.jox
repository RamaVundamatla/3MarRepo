    <JadeMethod name="visible" id="cfbe9d6f-7f2b-4883-895a-c6c022ddd3e3">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>visible(set: Boolean; value: Boolean io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     07 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if set then
		if (not value) then
			self.isHiddenForMoreToShow := false;
		endif;
	endif;
	
	inheritMethod(set, value);

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
