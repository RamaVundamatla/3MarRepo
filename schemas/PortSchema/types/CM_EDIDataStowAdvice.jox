    <JadeMethod name="canUserSet" id="eec9fda1-28f6-4be0-8807-9b36eb96645c">
        <source>canUserSet(_propName: String): Boolean;
//
// 05 Nov 2014	cnwrs1	Par 34702 - Add support for JMT XML with implied header
//
vars

begin
	if _propName = CM_EDIDataStowAdvice::loadRecordsForPort.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createProxyItem" id="2ff9c008-c338-4579-b81e-97527aff31bd">
        <source>createProxyItem(_ediTI:CM_EDIStowAdviceTI;_mode:String;_moveType:Integer;_stowageId:String;_proxySlotRequest,_realSlotRequest:CM_SlotRequest io);
// ---------------------------------------------------------------------------
// Created:     18 July 2002 by cnwrs1
//
// Purpose:  	Find and create/update proxy slot request  
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	
// ---------------------------------------------------------------------------

vars
	voyage						: CM_Voyage;
	bayVoyage					: CM_BayVoyage;
	slotRequest					: CM_SlotRequest;
	slotCont					: CM_SlotController;
	isoType						: CM_ISOType;
	found,empty,fortyFront,
	fortyBack,halfHeight,
	hazardous,overDimension,
	power,reefer,waterCooled,
	unavailable					: Boolean;
	bayId,cellId,tierId			: String;
	terminal					: CM_Terminal;

begin
	terminal := self.getMyTerminal();
	voyage := terminal.lookupVoyage(self.voyageCode, null, false);
	if voyage = null then
		app.raiseCMException2(ERR_VOYAGE_CODE, self.voyageCode, "Voyage Code", null, _ediTI);
		return;
	endif;
	
	if voyage.myCellularVoyageStructure = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'method called for unsupported voyage type');
		return;
	endif;
	
	bayId := _stowageId[2:2];
	cellId := _stowageId[4:2];
	tierId := _stowageId[6:2];

//	if _mode = CM_EDIStowAdviceTI.MODE_DIS then
//		colourCode := voyage.dischargeColourCode;
//	elseif _mode = CM_EDIStowAdviceTI.MODE_LOA then
//		colourCode := voyage.loadColourCode;
//	endif;

	isoType := app.myRoot.allISOTypes[_ediTI.isoType];
	
	if isoType = null then
		app.raiseCMException2(ERR_ISOTYPE_FIELD, _ediTI.isoType, "ISOType", null, _ediTI);
		return;
	endif;
	
	if isoType.is40ftLong or isoType.is45ftLong then
		bayVoyage := voyage.myCellularVoyageStructure.allBayVoyagesById40[bayId];
	else
		bayVoyage := voyage.myCellularVoyageStructure.allBayVoyagesById[bayId];
	endif;
	
	if bayVoyage = null then
		app.raiseCMException2(ERR_BAYID_FIELD, bayId, "Bay Id", null, _ediTI);
		return;
	endif;
		
	found := false;

	foreach slotCont in bayVoyage.allSlotControllersByOrdinal do
		if slotCont.cellId = cellId and
		   slotCont.tierId = tierId then
			found := true;
			break;
		endif;
	endforeach;

	if found = false then
		app.raiseCMException2(ERR_STOWAGE_FIELD, _stowageId, "Stowage Id", null, _ediTI);
		return;
	endif;

	_proxySlotRequest := slotRequest.pxyCreateUpdateProxy;
	_realSlotRequest := slotRequest;

	if isoType.isHalfHeight then
		halfHeight := true;
		if isoType.is4ft3High then
			overDimension := true;
		endif;
	else
		if isoType.is8ft6High then
			overDimension := true;
		endif;
	endif;

//	_proxySlotRequest.moveType := LOAD_MOVETYPE;

	if isoType.isReefer then
		reefer := true;
	endif;

	if isoType.isPowered then
		power := true;
	endif;

	if isoType.is40ftLong or isoType.is45ftLong then
		fortyFront := true;
		fortyBack := false;
	endif;

	if _ediTI.imCodes.size &gt; 0 then
		hazardous := true;
	endif;

//	_proxySlotRequest.setProxy(_ediTI.commodity,_ediTI.dischargePort,_moveType,
//		empty,fortyBack,fortyFront,halfHeight,hazardous,overDimension,power,reefer,waterCooled,unavailable);

	if isoType.is40ftLong then
		fortyFront := true;
		fortyBack := false;
//		_proxySlotRequest.setProxy(_ediTI.commodity,_ediTI.dischargePort,_moveType,
//			empty,fortyBack,fortyFront,halfHeight,hazardous,overDimension,power,reefer,waterCooled,unavailable);
	endif;

	return;
end;</source>
        <Parameter name="_ediTI" type="CM_EDIStowAdviceTI"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_stowageId" type="String"/>
        <Parameter name="_proxySlotRequest" type="CM_SlotRequest" usage="io"/>
        <Parameter name="_realSlotRequest" type="CM_SlotRequest" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createVOIProxyItem" id="311907ea-da3c-4cd4-8255-0b096450c301">
        <source>createVOIProxyItem(_ediTI:CM_EDIStowAdviceTI;_mode:String;_moveType:Integer;_stowageId:String; _pxySR,_realSlotRequest:CM_SlotRequest io);
// ---------------------------------------------------------------------------
// Created:     18 July 2002 by cnwrs1
//
// Purpose:  	Find and create/update proxy slot request  
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	
// ---------------------------------------------------------------------------

vars
	voyage					: CM_Voyage;
	bayVoyage				: CM_BayVoyage;
//	colourCode				: CM_ColourCode;
	slotRequest				: CM_SlotRequest;
	slotCont				: CM_SlotController;
	found,empty,fortyFront,
	fortyBack,halfHeight,
	hazardous,overDimension,
	power,waterCooled,
	reefer,unavailable		: Boolean;
	bayId,cellId,tierId		: String;
	terminal				: CM_Terminal;


begin
	terminal := self.getMyTerminal();
	voyage := terminal.lookupVoyage(self.voyageCode, null, false);
	if voyage = null then
		app.raiseCMException2(ERR_VOYAGE_CODE, self.voyageCode, "Voyage Code", null, _ediTI);
		return;
	endif;
	
	if voyage.myCellularVoyageStructure = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'method called for unsupported voyage type');
		return;
	endif;
	
	bayId := _stowageId[2:2];
	cellId := _stowageId[4:2];
	tierId := _stowageId[6:2];
	
	unavailable := true;
	
	bayVoyage := voyage.myCellularVoyageStructure.allBayVoyagesById[bayId];
	
	if bayVoyage = null then
		bayVoyage := voyage.myCellularVoyageStructure.allBayVoyagesById40[bayId];
	endif;
	
	if bayVoyage = null then
		app.raiseCMException2(ERR_BAYID_FIELD, bayId, "Bay Id", null, _ediTI);
		return;
	endif;
		
	found := false;
	
	foreach slotCont in bayVoyage.allSlotControllersByOrdinal do
		if slotCont.cellId = cellId and slotCont.tierId = tierId then
			found := true;
			break;
		endif;
	endforeach;

	if found = false then
		//create it 
		
		return;
	else
	//	create _pxySR transient;
	//	_pxySR.setProxyForCreate(aBayPoint.mySlotDefn,theMoveType,theCargoType);
	//	app.myTrxCA.trxCreateSlotRequest(_pxySR,realSlotRequest,theSlotController,app.myPassport);
	//	delete _pxySR;
	endif;

//	_pxySR := slotRequest.pxyCreateUpdateProxy;
//	_realSlotRequest := slotRequest;
//	_pxySR.setProxy(null,null,_moveType,null,null,null,null,null,null,null,null,null,unavailable);
	return;


end;</source>
        <Parameter name="_ediTI" type="CM_EDIStowAdviceTI"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_stowageId" type="String"/>
        <Parameter name="_pxySR" type="CM_SlotRequest" usage="io"/>
        <Parameter name="_realSlotRequest" type="CM_SlotRequest" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findHeadings" id="beeff381-2463-44c0-bd7d-edfd476c6a16">
        <source>findHeadings(tiName: String; shortDesc: String io; longDesc: String io; width: Integer io; num: Integer io);
// note: num does not have to be order but the largest num must be
//	   greater than the total number of properties.
//	   ie what is return by getNumColumns.
vars

begin
	if tiName = "commodity" then
		num := 11;
		shortDesc := "Cmdty";
		longDesc := "Commodity";
		width := 50;
	elseif tiName = "fullOrMT" then
		num := 9;
		shortDesc := "MT";
		longDesc := "MT or Full (E/F)";
		width := 30;
	elseif tiName = "id" then
		num := 1;
		shortDesc := "Container";
		longDesc := "Container";
		width := 140;
	elseif tiName = "stowageId" then
		num := 1;
		shortDesc := "StowageId";
		longDesc := "Stowage Id";
		width := 50;
	elseif tiName = "newStowageId" then
		num := 2;
		shortDesc := "New StowageId";
		longDesc := "New Stowage Id";
		width := 50;
	elseif tiName = "imCodes" then
		num := 15;
		shortDesc := "IMCodes";
		longDesc := "IM Codes";
		width := 50;
	elseif tiName = "isoType" then
		num := 8;
		shortDesc := "ISO";
		longDesc := "ISO Type";
		width := 50;
	elseif tiName = "operatorCode" then
		num := 4;
		shortDesc := "Oper";
		longDesc := "Operator";
		width := 50;
	elseif tiName = "remarks" then
		num := 14;
		shortDesc := "Remarks";
		longDesc := "Remarks";
		width := 100;

	elseif tiName = "commodityDescription" then
		num := 12;
		shortDesc := "Description";
		longDesc := "Commodity Description";
		width := 120;
	elseif tiName = "destinationPort" then
		num := 6;
		shortDesc := "Dest";
		longDesc := "Destination";
		width := 50;
	elseif tiName = "dischargePort" then
		num := 5;
		shortDesc := "Disch";
		longDesc := "Discharge Port";
		width := 50;
	elseif tiName = "height" then
		num := 16;
		shortDesc := "Hght";
		longDesc := "Height";
		width := 30;
	elseif tiName = "length" then
		num := 17;
		shortDesc := "Lght";
		longDesc := "Length";
		width := 30;
	elseif tiName = "loadPort" then
		num := 7;
		shortDesc := "Load";
		longDesc := "Load Port";
		width := 50;
	elseif tiName = "locationId" then
		num := 2;
		shortDesc := "Location";
		longDesc := "Location";
		width := 50;
	elseif tiName = "optDischargePorts" then
		num := 19;
		shortDesc := "OptDisch";
		longDesc := "Optional Discharge Ports";
		width := 100;
	elseif tiName = "mode" then
		num := 20;
		shortDesc := "Mode";
		longDesc := "Load Mode";
		width := 30;
	elseif tiName = "temperature" then
		num := 13;
		shortDesc := "Temp";
		longDesc := "Temperature";
		width := 50;
	elseif tiName = "weight" then
		num := 10;
		shortDesc := "Weight";
		longDesc := "Weight";
		width := 50;
	elseif tiName = "width" then
		num := 18;
		shortDesc := "Wdth";
		longDesc := "Width";
		width := 30;
	else
		num := 0;
		shortDesc := "";
		longDesc := "";
		width := 0;
	endif;
end;</source>
        <Parameter name="tiName" type="String"/>
        <Parameter name="shortDesc" type="String" usage="io"/>
        <Parameter name="longDesc" type="String" usage="io"/>
        <Parameter name="width" type="Integer" usage="io"/>
        <Parameter name="num" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="7dda4994-852d-4a15-8dcc-873a69c5f44f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	if _attrName = ETRow_VoyageCode then
		return self.voyageCode;
	elseif _attrName = ETRow_VesselName then
		return self.vesselName;
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
