    <JadeMethod name="isOnboardStops_Match" id="91453ad4-734b-41f1-8abe-755d21c56888">
        <source>isOnboardStops_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2025	navhn30	Initial creation

*/

vars
	tiSet	 : CM_TISet;
	stops	 : CM_StopsByIdDict;
	ti 		 : CM_TrackedItem;
	stop 	 : CM_Stops;
begin
	if _yaData.isEmpty() then
		return true;
	endif;
	
	if self.myTrackedItem = null or not self.myTrackedItem.isTILC() then
		return false;
	endif;
	
	create tiSet transient;
	self.myTrackedItem.CM_TILC.getAllOnboardTIs(tiSet);
	
	create stops transient;
	
	foreach ti in tiSet discreteLock do
		ti.getAllActiveStops(stops);	
	endforeach;
	
	if stops.isEmpty() then
		return false;
	endif;
	
	foreach stop in stops discreteLock do
		if _yaData.matches(stop.myStopsTable) then
			return true;
		endif;
	endforeach;
	
	return false;
	

epilog
	delete tiSet;
	delete stops;

end;</source>
