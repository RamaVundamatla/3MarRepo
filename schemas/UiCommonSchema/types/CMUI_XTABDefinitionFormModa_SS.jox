<GUIClass name="CMUI_XTABDefinitionFormModa_SS" id="bbcd7fb4-9ec7-4940-adce-ea37168acb3d">
    <superclass name="CMUI_XTABDefinitionForm_SS"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>COPIED from CMUI_XTABDefinitionFormModal

need to rework GUI for XTABs so we don't need modal forms</text>
    <JadeMethod name="displayOnSetupForm" id="3ba5b2e5-ecfd-49f7-897c-f42db4d795d8">
        <updating/>
        <source>displayOnSetupForm() updating, protected;

/*

Purpose:		This method will display the form and details in the appropriate state for inital start up.
				This will usually be with a the selected definition and with full details showing.
Parameters:		
Return Value:	

Date				Who		Reason
16/12/2009			cnwcs5	COPIED FROM CMUI_XTABDefinitionFormModal

*/
	
vars
	index		: Integer;
	
begin
	// show the proxy details supplied (in a modal form)
	self.myQueryDefinition	:= null;			// force the property table to be refreshed.
	self.displayXTABDefinition( self.myProxyXTAB );
	
	// add proxy into tree (alphabetically) unless already there.
	lstSavedDisplays.listIndex	:= lstSavedDisplays.findStringExact( 1, self.myProxyXTAB.name );
	if lstSavedDisplays.listIndex &gt; null then
		// just ing case reset myCurrentXTAB
		self.myCurrentXTAB							:= lstSavedDisplays.listObject.CM_OutputFormat_XTAB;
	else
		index										:= self.lstSavedDisplays.addItem( self.myProxyXTAB.name );
		self.lstSavedDisplays.itemObject[ index ]	:= self.myProxyXTAB;
		self.lstSavedDisplays.listIndex				:= index;
	endif;
	
	if self.myCurrentXTAB = null then
		self.formMode := Mode_Add;
	else
		self.formMode := Mode_Update;
	endif;
	
	self.doBtnShowDetails;
	self.zSetControls;
	self.modalResult	:= MsgBox_Return_Cancel;
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnRunDefn" id="59f15eaf-0ee0-4f36-97ec-04eb9cf10e0c">
        <updating/>
        <source>doBtnRunDefn() updating, protected;
/* ---------------------------------------------------------------------------
Created:     29 January 2009 by cnwrs2

Purpose:     
        
Change Date			Who		Reason
16/12/2009			cnwcs5	COPIED FROM CMUI_XTABDefinitionFormModal
------------------------------------------------------------------------------*/
vars
	form		: CMUI_XTABDisplayForm;
	
begin
	// need to refresh the display form realFormatExpectedEdition in case the user has saved the query since last run.
	form	:= app.getForm( CMUI_XTABDisplayForm.name ).CMUI_XTABDisplayForm;
	
	if form &lt;&gt; null then

		form.setRealFormatExpectedEdition( self.currentXTABEdition );
		form.isVoyageCCMode := self.isVoyageCCMode; // PAR 21746
	endif;
	
	self.modalResult	:= MsgBox_Return_OK;
	self.unloadForm;
	
	// Do not do an inheritMethod.  As this is called from the CMUI_XTABDisplayForm via showModal it then
	// reruns the query in itself, and does not open a new form
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d0adc9fe-38dc-4ea2-93c6-d5e5a6fcdf1e">
        <updating/>
        <source>setupForm() updating;
/* ---------------------------------------------------------------------------
Created:     16/12/2009	cnwcs5	COPIED FROM CMUI_XTABDefinitionFormModal

Purpose:     
        
Change Date	Who		Reason
16/12/2009			cnwcs5	COPIED FROM CMUI_XTABDefinitionFormModal
------------------------------------------------------------------------------*/
vars

begin
	inheritMethod();
	
	self.centreOverParent( 250 );			// keeps the modal form on the same monitor as the display form.
	self.doBtnShowDetails;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c4878e85-c8ef-4ce0-8cd1-91058080b741">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013551, locale);
end;</source>
    </JadeMethod>
</GUIClass>
