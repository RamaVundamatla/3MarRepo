    <JadeMethod name="translateForm" id="0c2aef4c-f22b-4e16-ae7a-2534b5c81dc1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016907, locale);
	btnExtract.translateBubbleHelp(Xlat_0016908, locale);
	btnExtract.translateCaption(Xlat_0016909, locale);
	btnFind.translateBubbleHelp(Xlat_0016910, locale);
	btnFind.translateCaption(Xlat_0016911, locale);
	btnPrint.translateBubbleHelp(Xlat_0016912, locale);
	btnPrint.translateCaption(Xlat_0016913, locale);
	lblEvenRowColour.translateCaption(Xlat_0016914, locale);
	lblOddRowColour.translateCaption(Xlat_0016915, locale);
end;</source>
    </JadeMethod>
</GUIClass>
