    <JadeMethod name="tblOnBoard_contextMenu" id="2a69d2a0-9e4d-4134-9c96-72bcda687dba">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblOnBoard_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     12 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

	x1 : Real;
	y1 : Real;
begin

	x1 := x;
	y1 := y;
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if table.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := table.positionTop();
	    endif;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	self.popupMenu(self.mnuColumnOrganiser, x1.Integer, y1.Integer);                 // cancel further processing
	return false;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
