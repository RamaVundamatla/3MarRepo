    <JadeMethod name="delete" id="10dd9402-129b-4464-9d02-ea42230a15e8">
        <updating/>
        <source>delete() updating, protected;
// --------------------------------------------------------------------------------
// Created:		23 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if global.isValidObject(self.myProxy) then
		delete self.myProxy;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getListDisplay" id="9a9a525a-3baf-4def-bea2-59b3f8657c58">
        <source>getListDisplay():String;
// --------------------------------------------------------------------------------
// Created:		23 March 2005 by cnwdad1
//
// Purpose:		Returns a display string for the receiver, to show in a listbox.
//
// Parameters:	None
//
// Returns:		The receiver's description.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myProxy.getListDisplay();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplay" id="02e20cc1-5788-46d1-90b0-377be0f633d3">
        <source>getTableDisplay():String;
// --------------------------------------------------------------------------------
// Created:		22 March 2005 by cnwdad1
//
// Purpose:		Returns a display string for the receiver's (proxy) Yard Allocation
//				Criteria/Priority.
//
// Parameters:	None
//
// Returns:		A tab-delimited display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myProxy.getTableDisplay();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValueUsed" id="745682a1-bbf1-4d2d-af06-95043be9595e">
        <source>isValueUsed(pAllValues:Any):Boolean;
// --------------------------------------------------------------------------------
// Created:		13 June 2005 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether specific data values
//				have already been used.
//
// Parameters:	pAllValues - This will be an array of values, the Type of which will
//					depend upon the Type of the data value.
//
// Returns:		True if one of the values is used, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myProxy.isValueUsed(pAllValues);
end;</source>
        <Parameter name="pAllValues" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFlag" id="dc27fb44-044a-4e47-8e0f-17701c50db5c">
        <updating/>
        <source>setFlag(pIsNew:Boolean; pIsChanged:Boolean; pIsDeleted:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		23 March 2005 by cnwdad1
//
// Purpose:		Sets boolean flags to indicate whether the receiver has been changed
//				or deleted.
//
// Parameters:	pIsNew - True if the receiver's Criteria/Priority is new.
//				pIsChanged - True if the receiver's Criteria/Priority has changed.
//				pIsDeleted - True if the receivetr's Criteria/Priority is deleted.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isNew		:=	pIsNew;
	self.isChanged	:=	pIsChanged;
	self.isDeleted	:=	pIsDeleted;
end;</source>
        <Parameter name="pIsNew" type="Boolean"/>
        <Parameter name="pIsChanged" type="Boolean"/>
        <Parameter name="pIsDeleted" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setReferences" id="0cfdfd14-2389-43fd-a26c-f431b20faa3e">
        <updating/>
        <source>setReferences(pCriteriaPriorityObj:CM_YACriteriaPriority) updating;
// --------------------------------------------------------------------------------
// Created:		22 March 2005 by cnwdad1
//
// Purpose:		Sets the references to the original Yard Allocation Criteria/Priority
//				object, and its transient proxy object.
//
// Parameters:	pCriteriaPriorityObj - A reference to the Criteria/Priority which
//					the receiver is representing.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave in begin load state
// --------------------------------------------------------------------------------
vars
	proxyObj	: CM_YACriteriaPriority;
	ls : Boolean;
begin
	if pCriteriaPriorityObj.isTransient() then
		self.myProxy	:=	pCriteriaPriorityObj;
	else
		app.cmsBeginLoad(ls);
		proxyObj		:=	pCriteriaPriorityObj.pxyCreateUpdateProxy();
		app.cmsEndLoad(ls);
		
		self.myCriteriaPriority	:=	pCriteriaPriorityObj;
		self.myProxy			:=	proxyObj;
	endif;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
end;</source>
        <Parameter name="pCriteriaPriorityObj" type="CM_YACriteriaPriority"/>
    </JadeMethod>
</Class>
