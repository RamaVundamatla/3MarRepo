	//toolbar.addButton(self.btnEditTV, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnDeleteTV, CMUI_Toolbar.Control_Alignment_Left);
	showCaptions := toolbar.showCaptions;
	
	//=======================================
	// now setup searchToolbar
	//=======================================
	toolbar := self.frmSearchToolbar;

	toolbar.showCaptions := showCaptions;
 // PAR 15966
//	toolbar.addButton(self.btnSearchTV, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnResetSearchTV, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnCloseSearchTV, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;


epilog

end;</source>
