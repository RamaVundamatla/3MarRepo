    <JadeMethod name="mnuRebuildStats_click" id="79b2cda9-b9bc-4d3d-a270-e45f5a3262b2">
        <updating/>
        <source>mnuRebuildStats_click( menuItem : MenuItem input ) updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
20 April 2009		cnwrl1	PAR 19463/19330

*/
	
vars
	object		: Object;
	
begin
	app.mousePointer	:=	Busy;
	
	// Since the 2 tables are on built top of each other, we need to establish
	// which table (active control) we are trying to rebuild the statistics on.
	if app.activeControl = self.tblYAM then
		self.doRebuildStats( self.getSelectedYAM, null );
	elseif app.activeControl = self.tblLocnStats then
		object	:= self.tblLocnStats.getSelectedObject;
		if object.isKindOf( CM_GridArea ) then
			self.doRebuildStats( null, object.CM_GridArea );
		elseif object.isKindOf( CM_GridRow ) then
			self.doRebuildStats( null, object.CM_GridRow.myGridArea );
		elseif object.isKindOf( CM_TerminalArea ) then
			self.doRebuildStats( null, object.CM_TerminalArea );
		endif;
	endif;
	//
	// Now check for errors
	//
	if not app.myPassport.trxCompletedOK then
		app.showErrorWarningDialog(app.getErrorString(Rebuild_stats), app.myPassport, ErrWarnMode_Update);
	endif;	
epilog
	app.mousePointer	:=	Idle;
	
end;
</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
