    <JadeMethod name="create" id="fd8e2253-ff79-4708-832e-01162640dbef">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2010	cnwndl1	Initial creation

*/

vars

begin
	
	self.fixedColumns := ColumnHeading;
	self.fixedRows	 := 1;
	
	self.rows	:= 1;
	self.columns := ColumnValue;
	
	self.tabKey := J_key_Tab;
	self.fixed3D := false;
	self.allowResize := Table.AllowResize_Column; // No resize allowed

epilog

end;</source>
    </JadeMethod>
