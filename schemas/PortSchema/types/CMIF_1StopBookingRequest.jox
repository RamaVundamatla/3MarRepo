<Class name="CMIF_1StopBookingRequest" id="f7e6fb57-6f87-45ad-9486-2382067e9a4b">
    <superclass name="CMIF_Object"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="carrierCode" id="d845c833-1cde-4bb9-a5db-2361152d6801">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="containerId" id="7df48f64-bff7-4a5d-978c-e40d9f85eaab">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="pinNumber" id="3c41780a-c2d5-48ef-92d9-b7b807c2d391">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="truckReg" id="0579ec1d-ef8b-4b0f-96d4-29cc9b4f7b51">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="getActivityDescription" id="186a0e19-afc9-4718-910c-95f5540c1930">
        <source>getActivityDescription() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/01/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS Integration
//
vars

begin
	return "Carrier: " &amp; self.carrierCode &amp; ", " &amp; 
			"Container: " &amp; self.containerId &amp; ", " &amp;
			"PIN: " &amp; self.pinNumber &amp; ", " &amp; 
			"Truck Reg: " &amp; self.truckReg;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
