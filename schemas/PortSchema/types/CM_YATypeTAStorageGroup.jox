    <JadeMethod name="getObjects" id="e2dc0ebd-64c0-4217-8eb3-d98d39c9ac52">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria

*/
vars
	tasGrp   : CM_TerminalAreaStorageGroup;
	terminal : CM_Terminal;
begin
	terminal := app.getMyTerminalDO_NOT_USE();
	foreach tasGrp in terminal.allTerminalAreaStorageGroups do
		objects[tasGrp.getYAIdentifier] := tasGrp;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
