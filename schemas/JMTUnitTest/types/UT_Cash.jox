    <JadeMethod name="createTargetVesselVoyage" id="279c3b7e-f80d-4d12-bdd9-06cad0273a4c">
        <updating/>
        <source>createTargetVesselVoyage(_terminal : CM_Terminal; _vesselName : String; _voyageName : String; _operator : CM_Operator) : CM_Voyage updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	voyage1: CM_Voyage;
	vessel: CM_Vessel; 
	
begin
	voyage1 := self.getVoyage(_voyageName);
	if voyage1 &lt;&gt; null then
		self.loadAllJobsToOps(voyage1, false);
	endif;
	self.deleteVoyage(_voyageName);
	self.deleteVessel(_vesselName);
	vessel := self.addVesselCellular(_vesselName, _operator);
	self.addVesselDefnReefer40(vessel);
	voyage1 := self.addVoyageWithContainerStructur(_voyageName, _vesselName, _operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);

	return voyage1;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_voyageName" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVVR" id="df130f3b-cdf6-4636-98cb-9d91ce76d26f">
        <source>createVVR(	truck : CM_Vehicle;
			ti : CM_TrackedItem
			) : CM_VehicleVisitRecord protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2012	cnwndl1	Initial creation	Par 29968
13/05/2022 		navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
*/

vars

	gate : CM_Gate;
	pxyVVR, vVR : CM_VehicleVisitRecord; 
	gateArea: CM_GateArea;
	now: TimeStamp;
	yic: String;
	_driver : String;
	gateEntity : CMGTE_Entity;
	allProformaLines : CM_InvoiceLineBySeqNumDict;

begin

	//create vehicle visit
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	gateArea := gate.getFirstAGate_IN();
	
	create pxyVVR transient;
	pxyVVR.setProxyFlexiGate(	_driver,	//_driverCode : String;
								_driver,	//_driverName : String;
								truck.carrier.code,	//_carrier : String;
								null,											//13/05/2022 navhl20 TFS 53430
								truck.regNumber,	//_regNumber : String;
								truck.state,	//_state : String;
								yic,	//_yic : String;
								self.myTerminal,	//_term : CM_Terminal;
								gate,	//_gate: CM_Gate;
								self.getGateLane(gateArea, 1),	//_gateLane : CM_YardController;
								""	//_ownerTrailerID : String
								);
	pxyVVR.setAutoComplete( false );
	pxyVVR.setTimeIn(now.date, now.time);
	
	app.myTrxCA.trxCreateVehicleVisitFlexi(pxyVVR, vVR, app.myPassport);
	self.assertTrueMsg(vVR &lt;&gt; null, "Vehicle Visit not created...");
	delete pxyVVR;
	
	//create gate entity
	if ti.isPreNote then
		gateEntity := self.createGateEntity(	vVR,	//_vvr: CM_VehicleVisitRecord input;
												"CONT",
												ti.id,	//_containerID: String;
												ti.getISOType,	//_isoCode: String;
												ti.myOperator.code,	//_operatorCode: String;
												ti.commodity,	//_commodity: String;
												1
												); 
	else
		gateEntity := self.createGTEOut( ti.CM_Container, vVR );
	endif;
	self.assertTrueMsg(gateEntity &lt;&gt; null, "Gate Entity not created...");
	
	return vVR;
	
epilog

	if allProformaLines &lt;&gt; null and not allProformaLines.isEmpty then
		allProformaLines.purge();
	endif;
	delete allProformaLines;
	delete pxyVVR;

end;</source>
        <access>protected</access>
        <Parameter name="truck" type="CM_Vehicle"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="createVVRBBlk" id="f92316c6-0956-4b52-961c-6d7cac6d8c2f">
        <source>createVVRBBlk(	truck : CM_Vehicle;
			ti : CM_TrackedItem;
			_ct : CM_CargoType
			) : CM_VehicleVisitRecord protected;

/*
Purpose - 	
Who - NAVAB1
Date - 02MAY2025
ADO - JIRA 34760
*/

vars

	gate : CM_Gate;
	pxyVVR, vVR : CM_VehicleVisitRecord; 
	gateArea: CM_GateArea;
	now: TimeStamp;
	yic: String;
	_driver : String;
	gateEntity : CMGTE_Entity;
	allProformaLines : CM_InvoiceLineBySeqNumDict;

begin

	//create vehicle visit
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	gateArea := gate.getFirstAGate_IN();
	
	create pxyVVR transient;
	pxyVVR.setProxyFlexiGate(	_driver,	//_driverCode : String;
								_driver,	//_driverName : String;
								truck.carrier.code,	//_carrier : String;
								null,											//13/05/2022 navhl20 TFS 53430
								truck.regNumber,	//_regNumber : String;
								truck.state,	//_state : String;
								yic,	//_yic : String;
								self.myTerminal,	//_term : CM_Terminal;
								gate,	//_gate: CM_Gate;
								self.getGateLane(gateArea, 1),	//_gateLane : CM_YardController;
								""	//_ownerTrailerID : String
								);
	pxyVVR.setAutoComplete( false );
	pxyVVR.setTimeIn(now.date, now.time);
	
	app.myTrxCA.trxCreateVehicleVisitFlexi(pxyVVR, vVR, app.myPassport);
	self.assertTrueMsg(vVR &lt;&gt; null, "Vehicle Visit not created...");
	delete pxyVVR;
	
	//create gate entity
	if ti.isPreNote then
		gateEntity := self.createGateEntity(	vVR,	//_vvr: CM_VehicleVisitRecord input;
												_ct.abbreviation,
												ti.id,	//_containerID: String;
												ti.getISOType,	//_isoCode: String;
												ti.myOperator.code,	//_operatorCode: String;
												ti.commodity,	//_commodity: String;
												ti.totalQuantity  // ### JIRA 34760 02MAY2025 NAVAB1
												); 
	else
		gateEntity := self.createGTEOutBBlk( ti.CM_Cargo, vVR, ti.totalQuantity );  // ### JIRA 34760 02MAY2025 NAVAB1
	endif;
	self.assertTrueMsg(gateEntity &lt;&gt; null, "Gate Entity not created...");
	
	return vVR;
	
epilog

	if allProformaLines &lt;&gt; null and not allProformaLines.isEmpty then
		allProformaLines.purge();
	endif;
	delete allProformaLines;
	delete pxyVVR;

end;</source>
        <access>protected</access>
        <Parameter name="truck" type="CM_Vehicle"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="_ct" type="CM_CargoType"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="createVesselVoyageCash" id="676f618b-080d-4baf-b6a0-60c9872d3478">
        <updating/>
        <source>createVesselVoyageCash( _vesselName : String; _voyageCode : String; _operatorCode : String) : CM_Voyage updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars
	voyageCode	: String;
	vesselName	: String;
	operatorCode	: String;
	voyage1: CM_Voyage;
	vessel: CM_Vessel; 
	
begin
	if _voyageCode &lt;&gt; null then
		voyageCode := _voyageCode;
	else
		voyageCode := CashVoyageCode;
	endif;
	if _vesselName &lt;&gt; null then
		vesselName := _vesselName;
	else
		vesselName := CashVesselName;
	endif;
	if _operatorCode &lt;&gt; null then
		operatorCode := _operatorCode;
	else
		operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	endif;
		
	deleteVoyage(voyageCode);
	deleteVessel(vesselName);
	vessel := addVesselCellular(vesselName, self.getOperator(operatorCode));
	self.addVesselDefnReefer40(vessel);
	voyage1 := addVoyageWithContainerStructur(voyageCode, vesselName, operatorCode, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);

	return voyage1;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="creditTest1" id="fc304f53-b107-4000-bfcf-540a653b8498">
        <updating/>
        <source>creditTest1(_id : String; _drTerm1 : CM_DebtorTerminal) updating, protected;

/*

Purpose:		Cash module testing, create a cash receipt then a credit from it

Parameters:			

Return Value:		


Date		Who		Reason
Feb 2016	cnwjre1	37141 cash credits etc
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	count		: Integer;
	
	cashCredit	: CM_CashCredit;
	creditDetail	: CM_CashCreditDetail;
	cashReceipt : CM_CashReceipt;
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	paymentMeth : CM_PaymentMethod;

	onsiteTi : CM_TrackedItem;
	trans	: CM_TITransaction;
	payment1 ,
	payment2 ,
	cashToPay,
	cashTotal	 : Decimal[23,6];// [16,4]; // TFS 47529

	debtorType	: CM_DebtorType;
	customsAgent	: CM_CustomsAgent;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	allAgents		: ObjectArray;
	agent : CM_CashInvoiceProformaAgent;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;

	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
begin
	msg := method.name;

	//Now create onsite cargo for the receipt
	cargoId  := _id;
	onsiteTi := self.addOnsiteCargoForId(cargoId, true, 0);
	// has CM_Create, CM_Receive, CM_SubTermxxx, CM_Wash
	// is Storage, FCL, operator UTC1, null voyage, no stops, no agent assigned, 
	beginTransaction;
	onsiteTi.setMyVoyage(self.myVoyage, app.myPassport);
	foreach trans in onsiteTi.allTransactions do
		trans.setPropertyValue("voyage", self.myVoyage);
		trans.setPropertyValue("voyageCode", self.myVoyage.code);
		trans.setPropertyValue("myVoyageRelivant", self.myVoyage);
	endforeach;
	commitTransaction;

	self.assertTrueMsg(onsiteTi &lt;&gt; null, msg &amp; " On Site Cargo '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(onsiteTi);
	debtorType   := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor       := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	agent := self.createProformaAgent(now, onsiteTi);
	allAgents.add(agent);
	self.myAgent := agent;
	
	cashTotal := agent.cashPayments;
	cashToPay := agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;

	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;

	cashReceipt := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					payment1,			// _payment1 : Decimal;
					payment2,			// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	
	// $20 current (Move), $20 proforma (Road Release), 2 x $20 cash payments
	
	self.assertTrueMsg(cashReceipt &lt;&gt; null, msg &amp; " Cash Receipt for on site cargo not created...");

	foreach cashPayment in cashReceipt.allCashPayments do
		if cashPayment.isProformaPayment then
			cashPaymentProForma := cashPayment;
		endif;
	endforeach;
	self.assertTrueMsg(cashPaymentProForma &lt;&gt; null, msg &amp; " Cash Payment Pro Forma for on site cargo not created...");
	self.assertTrueMsg(not onsiteTi.allCashPayments.isEmpty, msg &amp; " Pro Forma not on On Site Cargo...");
	
	cashCredit := self.createCashCredit(cashReceipt, 40, "credit comments",20,20);
	self.assertEqualMsg(cashCredit.cashValue, 40.Decimal, "Credit value");
	self.assertEqualMsg(cashCredit.myBank, self.getTerminal().getDefaultCompanyBank(), "credit bank");
	self.assertEqualMsg(cashCredit.myDebtorTerminal, cashReceipt.myDebtorTerminal, "Debtor terminal");
	self.assertEqualMsg(cashCredit.myDerivedFromCashReceipt, cashReceipt, "credit receipt");
	count := 0;
	foreach creditDetail in cashCredit.allDerivedFromCreditDetails do
		count := count + 1;
		self.assertEqualMsg(creditDetail.cashValue, 20.Decimal, "Detail value");
	endforeach;
	self.assertEqualMsg(count, 2, "Credit details");
	
epilog
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	// delete the credit to keep it out of the next test
	if cashCredit &lt;&gt; null then
		beginTransaction;
		delete cashCredit;
		commitTransaction;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
    </JadeMethod>
    <JadeMethod name="creditTest2" id="de193475-c8cd-474a-b13e-67f02d38d7f2">
        <updating/>
        <source>creditTest2(_id : String; _drTerm1 : CM_DebtorTerminal) updating, protected;

/*

Purpose:		Cash module testing, create a cash receipt, two credits from it and use these credits in a subsequent receipt.
				Release the cargo of the second receipt and check the internal objects.

Parameters:			

Return Value:		


Date		Who		Reason
Feb 2016	cnwjre1	37141 cash credits etc

*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	count		: Integer;
	cashCredit1,
	cashCredit2	: CM_CashCredit;
	creditDetail	: CM_CashCreditDetail;
	cashReceipt : CM_CashReceipt;
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	paymentMeth : CM_PaymentMethod;

	onsiteTi : CM_TrackedItem;
	trans	: CM_TITransaction;
	payment1 ,
	payment2,
	cashToPay,
	cashTotal	 : Decimal [23,6];

	debtorType	: CM_DebtorType;
	customsAgent	: CM_CustomsAgent;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	allAgents		: ObjectArray;
	agent : CM_CashInvoiceProformaAgent;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;
	
	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
	carrier : CM_Carrier;
	
	truckOut : CM_Vehicle;
	vvrOut : CM_VehicleVisitRecord;
begin
	msg := method.name;

	//Now create onsite cargo for the receipt
	cargoId  := _id;
	onsiteTi := self.addOnsiteCargoForId(cargoId, true, 0);
	// has CM_Create, CM_Receive, CM_SubTermxxx, CM_Wash
	// is Storage, FCL, operator UTC1, null voyage, no stops, no agent assigned, 
	beginTransaction;
	onsiteTi.setMyVoyage(self.myVoyage, app.myPassport);
	foreach trans in onsiteTi.allTransactions do
		trans.setPropertyValue("voyage", self.myVoyage);
		trans.setPropertyValue("voyageCode", self.myVoyage.code);
		trans.setPropertyValue("myVoyageRelivant", self.myVoyage);
	endforeach;
	commitTransaction;

	self.assertTrueMsg(onsiteTi &lt;&gt; null, msg &amp; " On Site Cargo '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(onsiteTi);
	debtorType   := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor       := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	agent := self.createProformaAgent(now, onsiteTi);
	allAgents.add(agent);
	self.myAgent := agent;
	
	cashTotal := agent.cashPayments;
	cashToPay := agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;

	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;

	cashReceipt := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					payment1,			// _payment1 : Decimal;
					payment2,			// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	
	// $20 current (Move), $20 proforma (Road Release), 2 x $20 cash payments
	
	self.assertTrueMsg(cashReceipt &lt;&gt; null, msg &amp; " Cash Receipt for on site cargo not created...");

	foreach cashPayment in cashReceipt.allCashPayments do
		if cashPayment.isProformaPayment then
			cashPaymentProForma := cashPayment;
		endif;
	endforeach;
	self.assertTrueMsg(cashPaymentProForma &lt;&gt; null, msg &amp; " Cash Payment Pro Forma for on site cargo not created...");
	self.assertTrueMsg(not onsiteTi.allCashPayments.isEmpty, msg &amp; " Pro Forma not on On Site Cargo...");
	
	cashCredit1 := self.createCashCredit(cashReceipt,30, "credit 1 comments",20,10);
	self.assertEqualMsg(cashCredit1.cashValue, 30.Decimal, "credit 1 value");
	self.assertEqualMsg(cashCredit1.myBank, self.getTerminal().getDefaultCompanyBank(), "credit 1 bank");
	self.assertEqualMsg(cashCredit1.myDebtorTerminal, cashReceipt.myDebtorTerminal, "credit 1 debtor terminal");
	self.assertEqualMsg(cashCredit1.myDerivedFromCashReceipt, cashReceipt, "credit 1 receipt");
	self.assertEqualMsg(cashCredit1.comments, "credit 1 comments", "credit 1 comments");
	count := 0;
	foreach creditDetail in cashCredit1.allDerivedFromCreditDetails do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(creditDetail.cashValue, 20.Decimal, "Detail 1 value 1");
		elseif count = 2 then
			self.assertEqualMsg(creditDetail.cashValue, 10.Decimal, "Detail 1 value 2");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Credit 1 details");

	cashCredit2 := self.createCashCredit(cashReceipt, 10, "",10,0);
	self.assertEqualMsg(cashCredit2.cashValue, 10.Decimal, "credit 2 value");
	self.assertEqualMsg(cashCredit2.myBank, self.getTerminal().getDefaultCompanyBank(), "credit 2 bank");
	self.assertEqualMsg(cashCredit2.myDebtorTerminal, cashReceipt.myDebtorTerminal, "credit 2 debtor terminal");
	self.assertEqualMsg(cashCredit2.myDerivedFromCashReceipt, cashReceipt, "credit 2 receipt");
	count := 0;
	foreach creditDetail in cashCredit2.allDerivedFromCreditDetails do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(creditDetail.cashValue, 10.Decimal, "Detail 2 value 1");
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, "Credit 2 details");
	
	// create carrier and truck
	self.deleteVehicle(VehicleNumOut);
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, self.myDebtor1);
	self.assertNotNull(carrier);
	truckOut := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truckOut &lt;&gt; null, "Truck not created...");

	// Clear all the stops
	self.deleteStops(onsiteTi);

	vvrOut := createVVR( truckOut, onsiteTi );
	self.assertTrueMsg(vvrOut &lt;&gt; null, msg &amp; " Vehicle Visit Record not created...");
	
	self.gateInTruck( vvrOut, false );
	
	self.workTruck( vvrOut, 2 );

	self.gateOutTruck( vvrOut, false ); 

epilog
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
    </JadeMethod>
    <JadeMethod name="creditTest3" id="329e15f0-ed3b-4f1e-a7e5-dc5c3d415cba">
        <updating/>
        <source>creditTest3(_ids : StringArray; _drTerm1 : CM_DebtorTerminal) updating, protected;

/*

Purpose:		Cash module testing, create a cash receipt for 2 TIs, one credit from it and use the credit in a subsequent receipt of 2 tis.
				Release the cargo of the second receipt and check the internal objects.
				Done to check changes for TFS 1808 where the credit was being over-applied.

Parameters:			

Return Value:		


Date		Who		Reason
Apr 2016	cnwjre1	more cash credits

*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	count		: Integer;
	
	cashCredit1,
	cashCredit2		: CM_CashCredit;
	creditDetail	: CM_CashCreditDetail;
	cashReceipt : CM_CashReceipt;
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	paymentMeth : CM_PaymentMethod;
	drTerm1		: CM_DebtorTerminal;

	ti1,
	ti2,
	ti3,
	ti4	: CM_TrackedItem;
	trans	: CM_TITransaction;
	payment1,
	payment2,
	cashToPay,
	cashTotal	 : Decimal[23,6];//[16, 6]; // TFS 47529

	debtorType	: CM_DebtorType;
	customsAgent	: CM_CustomsAgent;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	allAgents		: ObjectArray;
	agent : CM_CashInvoiceProformaAgent;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;

	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
	carrier : CM_Carrier;
	
	truckOut : CM_Vehicle;
	vvrOut : CM_VehicleVisitRecord;
begin
	msg := method.name;
	// purge prior credits so they don't get used here
	drTerm1 := _drTerm1;
	self.zPurgeCashDebtor(drTerm1);

	//Now create onsite cargo for the receipts
	cargoId := _ids[1];
	ti1 := self.addOnsiteCargoForId(cargoId, true, 0);
	cargoId := _ids[2];
	ti2 := self.addOnsiteCargoForId(cargoId, true, 0);
	cargoId := _ids[3];
	ti3 := self.addOnsiteCargoForId(cargoId, true, 0);
	cargoId := _ids[4];
	ti4 := self.addOnsiteCargoForId(cargoId, true, 0);
	// has CM_Create, CM_Receive, CM_SubTermxxx, CM_Wash
	// is Storage, FCL, operator UTC1, null voyage, no stops, no agent assigned, 
	beginTransaction;
	ti1.setMyVoyage(self.myVoyage, app.myPassport);
	ti2.setMyVoyage(self.myVoyage, app.myPassport);
	ti3.setMyVoyage(self.myVoyage, app.myPassport);
	ti4.setMyVoyage(self.myVoyage, app.myPassport);
	foreach trans in ti1.allTransactions do
		trans.setPropertyValue("voyage", self.myVoyage);
		trans.setPropertyValue("voyageCode", self.myVoyage.code);
		trans.setPropertyValue("myVoyageRelivant", self.myVoyage);
	endforeach;
	foreach trans in ti2.allTransactions do
		trans.setPropertyValue("voyage", self.myVoyage);
		trans.setPropertyValue("voyageCode", self.myVoyage.code);
		trans.setPropertyValue("myVoyageRelivant", self.myVoyage);
	endforeach;
	foreach trans in ti3.allTransactions do
		trans.setPropertyValue("voyage", self.myVoyage);
		trans.setPropertyValue("voyageCode", self.myVoyage.code);
		trans.setPropertyValue("myVoyageRelivant", self.myVoyage);
	endforeach;
	foreach trans in ti4.allTransactions do
		trans.setPropertyValue("voyage", self.myVoyage);
		trans.setPropertyValue("voyageCode", self.myVoyage.code);
		trans.setPropertyValue("myVoyageRelivant", self.myVoyage);
	endforeach;
	commitTransaction;

	self.assertTrueMsg(ti1 &lt;&gt; null, msg &amp; " On Site Cargo 1 '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(ti1);
	allTIs.add(ti2);
	allTIs.add(ti3);
	allTIs.add(ti4);
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	agent := self.createProformaAgent(now, ti1);
	allAgents.add(agent);
	cashTotal := agent.cashPayments;
	cashToPay := agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;

	agent := self.createProformaAgent(now, ti2);
	allAgents.add(agent);
	cashTotal := cashTotal + agent.cashPayments;
	cashToPay := cashToPay + agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;

	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;

	cashReceipt := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					payment1,			// _payment1 : Decimal;
					payment2,			// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	
	self.assertTrueMsg(cashReceipt &lt;&gt; null, msg &amp; " Cash Receipt for on site cargo not created...");

	foreach cashPayment in cashReceipt.allCashPayments do
		if cashPayment.isProformaPayment then
			cashPaymentProForma := cashPayment;
		endif;
	endforeach;
	self.assertTrueMsg(cashPaymentProForma &lt;&gt; null, msg &amp; " Cash Payment Pro Forma for on site cargo not created...");

	self.assertTrueMsg(not ti1.allCashPayments.isEmpty, msg &amp; " Pro Forma not on On Site Cargo...");


	
	cashCredit1 := self.createCashCredit(cashReceipt, 30, "credit 1 comments",20,10);
	self.assertEqualMsg(cashCredit1.cashValue, 30.Decimal, "credit 1 value");
	self.assertEqualMsg(cashCredit1.myBank, self.getTerminal().getDefaultCompanyBank(), "credit 1 bank");
	self.assertEqualMsg(cashCredit1.myDebtorTerminal, cashReceipt.myDebtorTerminal, "credit 1 debtor terminal");
	self.assertEqualMsg(cashCredit1.myDerivedFromCashReceipt, cashReceipt, "credit 1 receipt");
	self.assertEqualMsg(cashCredit1.comments, "credit 1 comments", "credit 1 comments");
	count := 0;
	foreach creditDetail in cashCredit1.allDerivedFromCreditDetails do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(creditDetail.cashValue, 20.Decimal, "Derived detail 1 value 1");
		elseif count = 2 then
			self.assertEqualMsg(creditDetail.cashValue, 10.Decimal, "Derived detail 1 value 2");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Credit derived details");
	
	// second receipt using this credit
	allAgents.purge;
	agent := self.createProformaAgent(now, ti3);
	allAgents.add(agent);
	cashTotal := agent.cashPayments;
	cashToPay := agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;

	agent := self.createProformaAgent(now, ti4);
	allAgents.add(agent);
	cashTotal := cashTotal + agent.cashPayments;
	cashToPay := cashToPay + agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;

	cashReceipt := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					payment1,			// _payment1 : Decimal;
					payment2,			// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	
	self.assertTrueMsg(cashReceipt &lt;&gt; null, msg &amp; " Cash Receipt 2 for on site cargo not created...");
	count := 0;
	foreach creditDetail in cashCredit1.allAppliedToCreditDetails do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(creditDetail.cashValue, 20.Decimal, "Applied detail 1 value 1");
		elseif count = 2 then
			self.assertEqualMsg(creditDetail.cashValue, 10.Decimal, "Applied detail 1 value 2");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Credit applied details");
	
	count := 0;
	foreach cashPayment in cashReceipt.allCashPayments do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, "Receipt 2 payment 1 value");
			self.assertTrueMsg(cashPayment.allCashCreditDetails.size=1, "Receipt 2 payment 1 credit");
		elseif count = 2 then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, "Receipt 2 payment 2 value");
			self.assertTrueMsg(cashPayment.allCashCreditDetails.size=1, "Receipt 2 payment 2 credit");
		elseif count = 3 then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, "Receipt 2 payment 3 value");
			self.assertTrueMsg(cashPayment.allCashCreditDetails.size=0, "Receipt 2 payment 3 credit");
		elseif count = 4 then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, "Receipt 2 payment 4 value");
			self.assertTrueMsg(cashPayment.allCashCreditDetails.size=0, "Receipt 2 payment 4 credit");
			/*
		elseif count = 5 then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, "Receipt 2 payment 5 value");
			self.assertTrueMsg(cashPayment.allCashCreditDetails.size=0, "Receipt 2 payment 5 credit");
			*/
		endif;
	endforeach;
	self.assertEqualMsg(count, 4, "Second receipt payments");

epilog
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ids" type="StringArray"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
    </JadeMethod>
    <JadeMethod name="deleteCashReceipts" id="aab8d9e2-7b83-4133-9189-4e2771467d48">
        <source>deleteCashReceipts(_debtor : CM_DebtorTerminal);
// compensate for no inverses, delete old cash receipts with now-invalid invoice lines or cargo
vars
	receipt		: CM_CashReceipt;
	invLine		: CM_InvoiceLine;
begin
	beginTransaction;
	foreach receipt in _debtor.allCashReceipts do
		foreach invLine in receipt.allInvoiceLines do
			if not global.isValidObject(invLine) then
				delete receipt;
				break;
			endif;
		endforeach;
	endforeach;
	commitTransaction;
end;
</source>
        <Parameter name="_debtor" type="CM_DebtorTerminal"/>
    </JadeMethod>
    <JadeMethod name="doCashReceipt" id="57ec520f-6740-4bf4-bd72-a24336529756">
        <source>doCashReceipt(_allCargo : CM_TISet; _customsAgent : CM_CustomsAgent; _itemCount : Integer; _cashId1, _cashId2 : String) : CM_CashReceipt protected;
// create a cash receipt for the given number of cargo items, fully paying each, skipping those already paid for
//28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent

vars
	allTIs		: CM_TISet;
	ti			: CM_TrackedItem;

	allAgents		: ObjectArray;
	debtorType		: CM_DebtorType;
	debtor			: CM_Debtor;
	cashReceipt	: CM_CashReceipt;
	paymentMeth : CM_PaymentMethod;
	agent : CM_CashInvoiceProformaAgent;
	
	now		: TimeStamp;
	count	: Integer;
	payment1,
	payment2,
	amount : Decimal[23,6];//[16, 6]; // TFS 47529
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;

	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	drTerm : CM_DebtorTerminal;

begin
	
	create allTIs transient;
	// each 'n' items are picked up and paid for by the next customs agent
	foreach ti in _allCargo do
		if ti.isPaidFor() then
			continue;
		endif;
		count := count + 1;
		if count &gt; _itemCount then
			break;
		endif;
		allTIs.add(ti);
	endforeach;
	
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	debtor := _customsAgent.myDebtor;
	drTerm := debtor.CM_Debtor.allDebtorTerminals.getAtKey( self.myTerminal );
	self.applyAgentToCargo(allTIs, debtorType, _customsAgent);
	cashId1 := _cashId1;
	cashId2 := _cashId2;
	
	create allAgents transient;
	foreach ti in allTIs do
		agent := self.createProformaAgent(now, ti);
		amount := amount + agent.estimatedCashCharges + agent.invoicedCashCharges;
		allAgents.add(agent);
	endforeach;
	
	paymentMeth := CM_PaymentMethod.firstInstance;
	payment1 := amount;
	cashReceipt := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					amount,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					payment1,			// _payment1 : Decimal;
					payment2,			// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					amount,
					0,
					null,
					drTerm,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	return cashReceipt;
epilog
	delete allTIs;
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
end;</source>
        <access>protected</access>
        <Parameter name="_allCargo" type="CM_TISet"/>
        <Parameter name="_customsAgent" type="CM_CustomsAgent"/>
        <Parameter name="_itemCount" type="Integer"/>
        <Parameter name="_cashId1" type="String"/>
        <Parameter name="_cashId2" type="String"/>
        <ReturnType type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="epilogCleanup" id="d852068e-2402-46c9-9f1e-6fc1af5507e2">
        <updating/>
        <source>epilogCleanup() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	realProCrit : CM_ProformaTransactionCriteria;
	cash : CM_Cash;
	tsb : CM_ServiceBroker;

begin

	delete self.myAgent;
	
	self.deleteReleaseRequest(OnSiteId);
	
	self.setTaxOnBank( false );
	
	if not self.allProFormaInvLines.isEmpty then
		self.allProFormaInvLines.purge();
	endif;
	
	foreach realProCrit in self.allProCriteria do
		app.myTrxDA.trxDeleteProformaCriteria( realProCrit, app.myPassport );
	endforeach;
		
	foreach cash in self.allCashObjectsToCleanup do
		if cash &lt;&gt; null and global.isValidObject(cash) then
			beginTransaction;
			delete cash;
			commitTransaction;
		endif;
	endforeach;

	if self.myPaymentMethod &lt;&gt; null then
		self.deletePaymentMethod(null,self.myPaymentMethod);
	endif;
	
	if not allTsbs.isEmpty then
		foreach tsb in allTsbs do
			app.myTrxDA.trxDeleteInvoiceTMService(tsb, app.myPassport);
			allTsbs.remove(tsb);
		endforeach;
	endif;
		
	if self.myDebtor1 &lt;&gt; null then
		self.deleteDebtor( self.myDebtor1 );
	endif;
	if self.myDebtor2 &lt;&gt; null then
		self.deleteDebtor( self.myDebtor2 );
	endif;
	
	self.deleteContainer(PreNoteId);
	self.deleteContainer(OnSiteId);
	self.deleteOperator(OperatorName);
	self.deleteVehicle(VehicleNumIn);
	self.deleteVehicle(VehicleNumOut);
	self.deleteCarrier(CarrierName);
	
	self.deleteVoyage(CashVoyageCode);
	self.deleteVessel(CashVesselName);

	self.enableCashOnlyTerminal( self.myTerminal, false );
	
epilog
	self.resetDefaultTranMap();										// 17/04/2013 cnwmh5
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="gateInTruck" id="de5da372-9037-401d-a115-b6b43d5fa73a">
        <source>gateInTruck( _vvr : CM_VehicleVisitRecord io; _expectError : Boolean ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06/05/2014	cnwjre1	Gate in truck for cargo release, parameter for expected error

*/

vars

	pxyVVR : CM_VehicleVisitRecord; 
	allProformaLines : ObjectSet;

begin

	create allProformaLines transient;
	self.ignoreTrxWarnings( false ); 
	app.myValUA.valCashCollectionForVVR( _vvr, true, true , allProformaLines, app.myPassport );
	if _expectError then
		self.assertTrueMsg( app.myPassport.allWarnings.includesErrorCode(Cash_cargo_not_paid),"Errors should include " &amp; Cash_cargo_not_paid.String );
	else
		self.assertTrueMsg( not app.myPassport.allWarnings.includesErrorCode(Cash_cargo_not_paid),"Errors should NOT include " &amp; Cash_cargo_not_paid.String );
	endif;
		
	if _expectError then
		return;
	endif;
	pxyVVR := app.createUpdateProxy(_vvr).CM_VehicleVisitRecord;
	self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, _vvr, allProformaLines, app.myPassport);
	self.assertTrueMsg(not app.myPassport.hasErrors, "Create gate in failed...");
	
epilog

	if allProformaLines &lt;&gt; null and not allProformaLines.isEmpty then
		allProformaLines.purge();
	endif;
	delete allProformaLines;
	delete pxyVVR;

end;</source>
        <access>protected</access>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="io"/>
        <Parameter name="_expectError" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="gateInTruckOK" id="e8aa48b6-1d03-4d8a-99dc-96ff32c844cd">
        <source>gateInTruckOK( _vvr : CM_VehicleVisitRecord io ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2012	cnwndl1	Initial creation	29968

*/

vars

	pxyVVR : CM_VehicleVisitRecord; 
	allProformaLines : ObjectSet;

begin

	create allProformaLines transient;
	self.ignoreTrxWarnings( false ); 
	app.myValUA.valCashCollectionForVVR( _vvr, true, true , allProformaLines, app.myPassport );
	self.assertTrueMsg( not app.myPassport.allWarnings.includesErrorCode(Cash_only_debtor_insufficient),"Errors should NOT include " &amp; Cash_only_debtor_insufficient.String );
	
	pxyVVR := app.createUpdateProxy(_vvr).CM_VehicleVisitRecord;
	self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, _vvr, allProformaLines, app.myPassport);
	self.assertTrueMsg(not app.myPassport.hasErrors, "Create gate in failed...");
	
epilog

	if allProformaLines &lt;&gt; null and not allProformaLines.isEmpty then
		allProformaLines.purge();
	endif;
	delete allProformaLines;
	delete pxyVVR;

end;</source>
        <access>protected</access>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="io"/>
    </JadeMethod>
    <JadeMethod name="gateOutCargo" id="9677c805-825b-4478-9316-9ab1048e0ec4">
        <source>gateOutCargo(_ti : CM_TrackedItem; _truck  : CM_Vehicle; _occurence : Integer) protected;
// gate a truck in, load cargo, gate it out, to get the final transactions for charging
vars
	vvr : CM_VehicleVisitRecord;

begin
	self.deleteStops(_ti);

	vvr := self.createVVR( _truck, _ti );
	self.assertTrueMsg(vvr &lt;&gt; null, "Vehicle Visit Record " &amp; _occurence.String &amp; " not created...");
	
	//gate in for a release
	self.gateInTruckOK( vvr );
	
	// work the truck and get it to an outward Lane
	self.workTruck( vvr, 2 );
	
	self.gateOutTruck( vvr, false );

end;
</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_truck" type="CM_Vehicle"/>
        <Parameter name="_occurence" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="gateOutTruck" id="59d5c33a-708b-4f9b-8221-a4cc3cdc7707">
        <source>gateOutTruck( _vvr : CM_VehicleVisitRecord input; expectInsufficientFunds : Boolean ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars


begin
	
	app.myTrxDA.trxVehicleRoadExit( _vvr.vehicle, app.myPassport );
	if expectInsufficientFunds then
		self.assertTrueMsg( not app.myPassport.allWarnings.isEmpty, "Should be an insuffient funds warning/error..."); //error 87607
		self.assertTrueMsg( app.myPassport.allWarnings.includesErrorCode(Cash_only_debtor_insufficient),"Errors should include " &amp; Cash_only_debtor_insufficient.String );
	else
		self.assertTrueMsg( not app.myPassport.allWarnings.includesErrorCode(Cash_only_debtor_insufficient),"Errors should NOT include " &amp; Cash_only_debtor_insufficient.String );
		self.assertTrueMsg( not _vvr.vehicle.isOnsite, "Truck should be gone. [" &amp; app.myPassport.getErrorsAndWarningsAsString &amp; "]");
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="expectInsufficientFunds" type="Boolean"/>
    </JadeMethod>
