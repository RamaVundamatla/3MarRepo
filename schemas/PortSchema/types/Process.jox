/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason


*/
vars

	user : CM_User;
	
begin

	executeWhen JMTDevelopmentEnvironment;
	
	// JMT
	if app.myPassport &lt;&gt; null then
		user := app.myPassport.myUser;
		
		if user &lt;&gt; null 
		and (user.code.toUpper = "NAVMA1" or user.code = "CNWMA1" or user.code = "CNWMA2")
		and user.userName = "Mohamed Adwy" then
			return true;
		endif;
	endif;
		
	// PatchCreatorApp
	if process.getComputerName().toUpper = "NAVMA1B" and
		(currentSchema.name = "DevSchema" or
			currentSchema.superschema.name = "DevSchema") then
		return true;
	endif;
	
	endExecuteWhen;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
