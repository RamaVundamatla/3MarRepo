	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_ST, false, null);
	self.allAvailableStorageTriggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_IM_TO_TR, false, null);
	self.allAvailableStorageTriggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_ST_TO_EX, false, null);
	self.allAvailableStorageTriggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_ST_TO_IM, false, null);
	self.allAvailableStorageTriggers.add(pxyStorageTrigger);

	//08 May 2015	NDL	Par 36006
//	create pxyStorageTrigger transient;
//	pxyStorageTrigger.setProxy( IMEX_ST_TO_TR, false, null);
//	self.allAvailableStorageTriggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_TR_TO_EX, false, null);
	self.allAvailableStorageTriggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_TR_TO_IM, false, null);
	self.allAvailableStorageTriggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( IMEX_TR_TO_ST, false, null);
	self.allAvailableStorageTriggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( PackAsChild, false, null);
	self.allAvailableStorageTriggers.add(pxyStorageTrigger);
	 
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( PackAsParent, false, null);
