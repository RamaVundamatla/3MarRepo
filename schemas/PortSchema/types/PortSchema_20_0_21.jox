    <JadeMethod name="populateRootCompanyCode" id="cd26c796-7115-48b5-a5fb-6d18cdbd3a03">
        <source>populateRootCompanyCode(_updController : CnEcReleaseController);
/*
Purpose: For OpsView, MTN generates unique keys for all the objects sent to OpsView, this is called the GKEY. 
		In the OpsView database  there is also a PKEY value, which is the real unique key and is the COMPLEX ID and the GKEY concatinated.
		The COMPLEX ID sent to OpsView is the CM_Root.companyCode value.	
		
		In theory there could be multiple clients in one instance of OpsView so we need the company code (COMPLEX ID) to be set correctly (uniquely) in each customer environment.

Date		Who		Reason
01FEB2022	NAVAB1	TFS 51855
*/

vars
	mess : String;
	root : CM_Root;
	compCode : String;
begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	mess := " Updating Root Company Code";
	app.writeLog(method.qualifiedName &amp; mess, LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(mess) ;	
	endif;
	
	root := CM_Root.firstInstance();
	
	if root &lt;&gt; null then
		if not root.isClientC3() // not including C3 as some log screens use root company code and company name.
		and not root.isClientJadeMaster() then // one of our systems, so ignore
			if root.companyCode = ""
			or root.companyCode = "JMT" then
				compCode := root.deriveCompanyCode();
				
				if compCode &lt;&gt; null then
					beginTransaction;
						root.setPropertyValue("companyCode", compCode);

					commitTransaction;
				
				endif;
					
			endif;
		endif;
		
		app.writeLog(method.qualifiedName &amp; mess &amp; " complete", LogINFO);
		if _updController &lt;&gt; null then
			_updController.logEntry(mess &amp; " complete") ;	
		endif;
		
		self.addScriptRun(method.name);
	else
		app.writeLog(method.qualifiedName &amp; " Root is not set!", LogINFO);

	endif;
epilog

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="populateRootDebtorTerminals" id="b8632bce-d0bc-451a-b0e8-2580503de441">
        <source>populateRootDebtorTerminals(_updController : CnEcReleaseController);
/*

Purpose:	Add debtor terminals to the root debtor of the bank if required		

Parameters:			None

Return Value:		None

Date				Who		Reason
09 November 2022	navcs2	Bug 55380: SNO -- Exception 1090 thrown when selecting an invoice and clicking Re-evaluate when debtor is RDT

*/

vars
	paymentType			 	: Integer;					
	usesCash 				: Boolean;
	currencyType 			: CM_CurrencyType; 
	locale 					: CM_Locale; 		
	defaultInvoiceJRW 		: String;
	terminal				: CM_Terminal;
	theBank					: CM_Bank;
	rootDebtor						: CM_Debtor;
	allTerminals			: CM_TerminalByCodeDict;
begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	
	app.writeLog(method.qualifiedName &amp; " Started adding debtor terminals to root debtor", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Started adding debtor terminals to root debtor") ;	
	endif;
	
	theBank := app.myRoot.myRootCompany;
	rootDebtor := theBank.rootDebtor;
	allTerminals := app.myRoot.allTerminals;
		
	foreach terminal in allTerminals do
		if not rootDebtor.allDebtorTerminals.includesKey( terminal ) then
			paymentType			:= PaymentType_None; 
			usesCash 			:= false;
			currencyType 		:= null; 	
			locale 				:= null; 
			defaultInvoiceJRW 	:= null; 

			beginTransaction;
			//rootDebtor.createDebtorTerminal( terminal, usesCash, paymentType, currencyType, locale, defaultInvoiceJRW); 
			rootDebtor.createDebtorTerminal( terminal, usesCash, paymentType, currencyType, locale, defaultInvoiceJRW, "", ""); //navra1 - TFS 57086 - 1st May 2023
			commitTransaction;
			
			app.writeLog(method.qualifiedName &amp; " Adding debtor terminals " &amp; terminal.code &amp; " to debtors", LogINFO);
		endif;
	endforeach;

	app.writeLog(method.qualifiedName &amp; " Finished adding debtor terminals to root debtor", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Finished adding debtor terminals to all debtors") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="populateTerminalMarkExtDict" id="705dd764-09d5-4ab2-bb02-81dbb8f9f246">
        <source>populateTerminalMarkExtDict(_updController : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/03/2021	navdap1		Initial creation TFS 50889 Yard Allocation Performance Improvement
//
vars
	term : CM_Terminal;
	ya : CM_YardAllocation;
	crit : CM_YACriteria;
	data : CM_YADataString;
	mark, markData : String;
	marks : StringArray512;

begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Populating CM_Terminal::allYAsByMark external key dict", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry("Populating CM_Terminal::allYAsByMark external key dict") ;	
	endif;
	
	create marks transient;
	beginTransaction;
	foreach term in CM_Terminal.instances do
		term.allYAsByMark.clear;
		foreach ya in term.allYardAllocatonsByCode do
			foreach crit in ya.allCriteria do
				if crit.code = ya.CRITERIA_MARK then
					marks.clear;
					data := crit.myYAData.CM_YADataString;
					markData := data.value;
					markData.getTokensForDelimiter(Comma, marks);
					foreach mark in marks do
						mark := mark.trimBlanks[1:100];
						if term.allYAsByMark[mark, ya.code] = null then
							term.allYAsByMark.putAtKey(mark, ya.code, ya);
						endif;
					endforeach;
				endif;
			endforeach;
		endforeach;
	endforeach;	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Completed populating CM_Terminal::allYAsByMark external key dict", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry("Completed populating CM_Terminal::allYAsByMark external key dict") ;
	endif;
	self.addScriptRun(method.name);
	
epilog
	delete marks;
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="populateWorkOrderTIDtl" id="581af77e-1154-41dd-83b2-f307b81c3e59">
        <source>populateWorkOrderTIDtl(_updController : CnEcReleaseController);
/*

Purpose:			
	This script will be used to populate CM_WorkOrderTIDtl::allSelectedTIs from  CM_WorkOrderTI::allTIs or CM_WorkOrderTI::mySource
Parameters:			

Return Value:		

Date		Who		Reason
15 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task

*/

vars
	wod 		: CM_WorkOrderDtl ;
	workOrderTI	: CM_WorkOrderTI;
	objArray 	: ObjectArray;
	obj 		: Object;
	wodToDo		: CM_WodToDo;
	tiSet		: CM_TISet;
begin
	
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Populating CM_WorkOrderTIDtl::allSelectedTIs", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Populating CM_WorkOrderTIDtl::allSelectedTIs") ;	
	endif;
	
	create objArray transient;
	CM_WorkOrderTI.allInstances( objArray, 0, true );
	
	beginTransaction;
	foreach obj in objArray do 
		workOrderTI 	:= obj.CM_WorkOrderTI;
		
		delete tiSet;
		create tiSet transient;
		
		if not workOrderTI.allTIs.isEmpty then
			workOrderTI.allTIs.copyNoDuplicates(tiSet,false);
		else
			if workOrderTI.mySource &lt;&gt; null then
				workOrderTI.mySource.getAllTIs(tiSet);
			endif;
		endif;
		
		if tiSet.isEmpty then
			continue;
		endif;
		
		foreach wod in  workOrderTI.allWoDtls do
			if wod.CM_WorkOrderTIDtl.allSelectedTIs.isNotEmpty then
				continue;
			endif;
			
			tiSet.copyNoDuplicates(wod.CM_WorkOrderTIDtl.allSelectedTIs,false);
			
			if wod.CM_WorkOrderTIDtl.allToDoRequests.isNotEmpty then
				foreach wodToDo in wod.CM_WorkOrderTIDtl.allToDoRequests do
					tiSet.copyNoDuplicates(wodToDo.allSelectedTIs,false);
				endforeach;
			endif;
		endforeach;
			
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Completed Populating CM_WorkOrderTIDtl::allSelectedTIs", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Completed Populating CM_WorkOrderTIDtl::allSelectedTIs") ;
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	delete objArray;
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="renameDebtorTypeStevedore" id="29eda956-ee66-45d5-8351-6664b1f2051a">
        <source>renameDebtorTypeStevedore(_updController : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	debtorType : CM_DebtorType;
begin
	
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; "Renaming Stevedore Debtor Type to Stevedore for Voyage ", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry("Renaming Stevedore Debtor Type to Stevedore for Voyage") ;	
	endif;
	if app.myRoot.allDebtorTypes["SDT10"] = null then
		return;
	endif;
	
	debtorType := app.myRoot.allDebtorTypes["SDT10"];
	
	if debtorType.description &lt;&gt;  CM_DebtorType.DT_STEVEDORE_VOYAGE_DESC then
		beginTransaction;
			debtorType.setDescription(CM_DebtorType.DT_STEVEDORE_VOYAGE_DESC);
		commitTransaction;
	endif;
	app.writeLog(method.qualifiedName &amp; "Renaming Stevedore Debtor Type to Stevedore for Voyage complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry("Renaming Stevedore Debtor Type to Stevedore for Voyage complete") ;	
	endif;
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="resetIconsOnHMSResTypes" id="f939c132-0e2a-4d1e-b93f-f18e406231e1">
        <source>resetIconsOnHMSResTypes(_controller : CnEcReleaseController);
/*
Purpose:	this must be run after the standard release that includes loading the new icons into root config		

Date		Who		Reason
20OCT2021	NAVAB1	TFS 50421
*/


vars

	iter01 : Iterator;
	men : HMS_ResourceType;
	oArray : ObjectArray; 
	idx : Integer;
	
begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Reset Icons on ALL HMS Resource Types", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Reset Icons on ALL HMS Resource Types") ;	
	endif;
	
	create oArray transient;
	HMS_ResourceType.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;
	idx := 1;
	
	while iter01.next(men) do
		
		beginTransaction;
		men.resetIcons();
		commitTransaction;
		
	endwhile;

	
	app.writeLog(method.qualifiedName &amp; " all HMS Resource Types Reset", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all HMS Resource Types Reset") ;
	endif;
	
	self.addScriptRun(method.name);

epilog
	delete oArray;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="resetIconsOnMenuEntities" id="d35d8483-8a0e-4a07-a9fe-1561ad1084fa">
        <source>resetIconsOnMenuEntities(_controller : CnEcReleaseController);
/*
Purpose:	this must be run after the standard release that includes loading the new icons into root config		

Date		Who		Reason
20OCT2021	NAVAB1	TFS 50421
*/


vars

	iter01 : Iterator;
	men : CM_MenuEntity;
	oArray : ObjectArray; 
	idx : Integer;
	
begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Reset Icons on ALL Menu Entities", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Reset Icons on ALL Menu Entities") ;	
	endif;
	
	create oArray transient;
	CM_MenuEntity.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;
	idx := 1;
	
	while iter01.next(men) do
		if men.isKindOf(CM_QryReportSystem) // NO ICON
		or  men.isKindOf(CM_QryReportUser) // NO ICON
		or  men.isKindOf(CM_MenuRootQuery) // NO ICONS only 1 instance
		or  men.isKindOf(CM_MenuRootReportForRoot) // NO ICON
		or  men.isKindOf(CM_MenuRootReportUserTerminal) // NO ICON
		or  men.isKindOf(CM_MenuRootToolbar) // NO ICON
		or  men.isKindOf(CM_MenuRootUserBackgroundReps) // NO ICON
		or  men.isKindOf(CM_MenuRootUserTemplates) // NO ICON
		or  men.isKindOf(CM_MenuRootUserTerminal) // NO ICON
		or  men.isKindOf(CM_MenuUserToolbarRoot) // NO ICON
		or  men.isKindOf(CM_MenuUserReport) // NO ICON
		then
			continue;
		endif;
		
		if men.pictureStringButton = PicToolBarSpaceSmall then // seperator
			continue;
		endif;
		
		if men.getHeading() = "EDI Data Translations" then
			beginTransaction;
			men.setPictures("p16Translations",men.pictureStringButtonDown,men.pictureStringIcon);
			commitTransaction;
			continue;
		endif;
	
		if men.getHeading() = "Snapshot Summary" then
			beginTransaction;
			men.setPictures("picSnapshotSumm","picSnapshotSumm","picSnapshotSumm");
			commitTransaction;
			continue;
		endif;
		
		if men.getHeading() = "Harbour" then
			beginTransaction;
			men.setPictures("picHarbourSys","picHarbourSys","picHarbourSys");
			commitTransaction;
			continue;
		endif;
		
		if men.getHeading() = "Currency Type Maintenance" then
			beginTransaction;
			men.setPictures("picCurrencyType","picCurrencyType","picCurrencyType");
			commitTransaction;
			continue;
		endif;
		
		if men.getHeading() = "Activity History" then
			beginTransaction;
			men.setPictures("picActivityHistory","picActivityHistory","picActivityHistory");
			commitTransaction;
			continue;
		endif;
		if men.getHeading() = "Load List" then
			beginTransaction;
			men.setPictures(men.pictureStringButton,men.pictureStringButtonDown,"picLoadListUp");
			commitTransaction;
			continue;
		endif;
		if men.getHeading() = "Cash Consolidation" then
			beginTransaction;
			men.setPictures("picTermTrade16","picTermTrade16","picTermTrade16");
			commitTransaction;
			continue;
		endif;
		if men.getHeading() = "Location Inventory Enquiry" then
			beginTransaction;
			men.setPictures("picLocnInventoryEnq","picLocnInventoryEnq","picLocnInventoryEnq");
			commitTransaction;
			continue;
		endif;
		if men.getHeading() = "Text Translation" then
			beginTransaction;
			men.setPictures("picTranslationsUp","picTranslationsUp","picTranslationsUp");
			commitTransaction;
			continue;
		endif;		
		
		
		
		
	
		beginTransaction;
		men.resetPictures();
		commitTransaction;
		
	endwhile;


	
	app.writeLog(method.qualifiedName &amp; " all Menu Entities Reset", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all Menu Entities Reset") ;
	endif;
	
	self.addScriptRun(method.name);

epilog
	delete oArray;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="resetZombieLocations" id="7d1bc56d-9de4-4e02-ae5b-f433bf0a6916">
        <source>resetZombieLocations(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2021	navndl1	Initial creation	TFS 50796

*/

vars

	lc : CM_LocationsController;
	objArray : ObjectArray;
	lcIter : Iterator;
	lcObj : Object;
	tiIter : Iterator;
	ti : CM_TrackedItem;
	zombies : CM_TISet;
	size : Integer;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Reset Zombie Locations", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Reset Zombie Locations") ;	
	endif;
	
	//Start
	
	create zombies transient;
	create objArray transient;
	
	CM_YardController.allInstances( objArray, 0, true );
	
	lcIter := objArray.createIterator;
	while lcIter.next( lcObj ) do
		lc := lcObj.CM_LocationsController;
		tiIter := lc.allTrackedItems.createIterator;
		while tiIter.next( ti ) do
			if ti.hasBeenMerged then
				zombies.add( ti );
			endif;
		endwhile;
		delete tiIter;
	endwhile;
	
	size := zombies.size;

	beginTransaction;
	foreach ti in zombies do	
		ti.clearMyActualLocation();	
	endforeach;
	commitTransaction;
	
	//End
	
	app.writeLog(method.qualifiedName &amp; " Reset " &amp; size.String &amp; " Zombie Locations, Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Reset " &amp; size.String &amp; " Zombie Locations, Completed") ;
	endif;
	
	self.addScriptRun(method.name);

epilog

	delete lcIter;
	delete tiIter;
	delete objArray;
	delete zombies;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setAuditConfigsEnabled" id="3580fccf-c329-4e6f-be0c-3ebe237b47df">
        <source>setAuditConfigsEnabled(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

	auditConfig : CM_AuditConfig;
	root : CM_Root;
	iterAuditConfig : Iterator;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Initial enabling of original Audit Configs", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Initial enabling of original Audit Configs") ;	
	endif;
	
	root := CM_Root.firstInstance;
	
	iterAuditConfig := root.allAuditConfigs.createIterator;
	while iterAuditConfig.next( auditConfig ) do
	
		if auditConfig.className = CM_DocketError.name
		or auditConfig.className = CM_EventRequest.name
		or auditConfig.className = CM_FileFormatEDI.name
		or auditConfig.className = "CM_TIMasterGroup"
			//these ones aren't used or are invalid classes.
		then
			continue;
		endif;
		
		if not auditConfig.isEnabled and not auditConfig.canBeUserDisabled then
			//This should always be set
			app.myTrxUA.trxAuditConfigSetIsEnable( true, auditConfig, app.myPassport );
			continue;
		endif;
		
		//we want to turn the new 'isEnable' flag for existing audit configs, but not for the
		//ones just added that should be left for the users to decide to turn on or not.
		
		if not auditConfig.isEnabled // So only those that are not currently set
		and auditConfig.allAuditObjectsForClass.isEmpty	// (the collection of changes to this audit config) - No audits here means it has never been set
		and not auditConfig.allAuditObjects.isEmpty// (the collection of objects of the related class that this config controls) - Audits here means is or has been in use so must be pre existing
		then
			// so its not set and never been set and was active before this release (so not just created) then enable it
			app.myTrxUA.trxAuditConfigSetIsEnable( true, auditConfig, app.myPassport );
		endif;
		
	endwhile;
	
	
	app.writeLog(method.qualifiedName &amp; " Initial enabling of original Audit Configs, Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Initial enabling of original Audit Configs, Completed") ;
	endif;
	
	self.addScriptRun(method.name);

epilog

	delete iterAuditConfig;
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
