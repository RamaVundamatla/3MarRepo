    <JadeMethod name="rsabc" id="b86b02df-4b53-44cb-a229-2dbc081d6020">
        <source>rsabc();
vars
	ti1:CM_TrackedItem;
	ti2:CM_TrackedItem;
	ti3:CM_TrackedItem;
	ti4:CM_TrackedItem;
	lc1:CM_WellcarWagonController;
	lc2:CM_WellcarWagonController;
	lc3:CM_WellcarWagonController;
	lc4:CM_WellcarWagonController;
	str:String;
	terminal : CM_Terminal;
begin
	app.initialize();
	app.myPassport.setMyUserFromCode('SUPERUSER');
	terminal := app.myRoot.allTerminals["UT"];
	beginTransaction;
	terminal.setConfig(RailDefaultWCIdFormat, Rail_UPSP_Int); //Rail_UPSP_Int);
	commitTransaction;
	ti1 := terminal.lookupTrackedItem("UTWLAA22002", 1, TI_STATE_NORMAL, "", false); //UTWLAA22002
	ti2 := terminal.lookupTrackedItem("UTWLAA22003", 1, TI_STATE_NORMAL, "", false); //UTWLAA22003
	ti3 := terminal.lookupTrackedItem("UTWLAA22004", 1, TI_STATE_NORMAL, "", false); //UTWLAA22002
	ti4 := terminal.lookupTrackedItem("UTWLAA22005", 1, TI_STATE_NORMAL, "", false); //UTWLAA22003
	lc1 := ti1.allQueuedFutureMoves.first.CM_FutureMoveQueued.allLocationsControllers.first.CM_WellcarWagonController;
	lc2 := ti2.allQueuedFutureMoves.first.CM_FutureMoveQueued.allLocationsControllers.first.CM_WellcarWagonController;
	lc3 := ti3.allQueuedFutureMoves.first.CM_FutureMoveQueued.allLocationsControllers.first.CM_WellcarWagonController;
	lc4 := ti4.allQueuedFutureMoves.first.CM_FutureMoveQueued.allLocationsControllers.first.CM_WellcarWagonController;
//	lc1 := '8253.11568'.asOid.CM_WellcarWagonController;
//	lc2 := '8253.11572'.asOid.CM_WellcarWagonController;
	
	str := lc1.CM_WellcarWagonController.getIdUPSPformat(null) &amp; CrLf;
	str := str &amp; lc2.CM_WellcarWagonController.getIdUPSPformat(null) &amp;CrLf;
	str := str &amp; lc3.CM_WellcarWagonController.getIdUPSPformat(null) &amp;CrLf;
	str := str &amp; lc4.CM_WellcarWagonController.getIdUPSPformat(null) &amp;CrLf;
	str := str &amp; lc1.CM_WellcarWagonController.getIdUPSPformat(ti1) &amp;CrLf;
	str := str &amp; lc2.CM_WellcarWagonController.getIdUPSPformat(ti2) &amp;CrLf;
	str := str &amp; lc3.CM_WellcarWagonController.getIdUPSPformat(ti3) &amp;CrLf;
	str := str &amp; lc4.CM_WellcarWagonController.getIdUPSPformat(ti4) &amp;CrLf;
	write str;
	write null;
	str := lc1.getFullId&amp;CrLf;
	str := str&amp;lc2.getFullId&amp;CrLf;
	str := str&amp;lc3.getFullId&amp;CrLf;
	str := str&amp;lc4.getFullId&amp;CrLf;
	str := str&amp;lc1.getFullIdTI(ti1)&amp;CrLf;
	str := str&amp;lc2.getFullIdTI(ti2)&amp;CrLf;
	str := str&amp;lc3.getFullIdTI(ti3)&amp;CrLf;
	str := str&amp;lc4.getFullIdTI(ti4)&amp;CrLf;
	write str;
	write null;
	str := lc1.ident&amp;CrLf;
	str := str&amp;lc2.ident&amp;CrLf;
	str := str&amp;lc3.ident&amp;CrLf;
	str := str&amp;lc4.ident&amp;CrLf;
	write str;
end;</source>
    </JadeMethod>
