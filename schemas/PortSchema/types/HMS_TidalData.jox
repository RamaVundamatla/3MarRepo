    <JadeMethod name="pxyCreateUpdateProxy" id="b7c2dcd0-6cfe-4f1d-9d4c-1ebc4bb236fb">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
20/04/2011	 cnwmh5		 PAR #27401 - Add code to handle prossible exceptions occurring when
						 trying to create the proxy	
----------   ----------  --------------------------------------------------
*/
vars
	newTidalData	: SelfType;
	completedOK		: Boolean;
begin
	newTidalData := inheritMethod();
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return newTidalData;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete newTidalData;
	endif;	
end;


</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="72f963f1-747d-4c27-9cf7-ed123b01d3da">
        <updating/>
        <source>setForUpdate(_pxyTidalData : HMS_TidalData; _passport: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.raiseExceptionIfTransient(method);
	self.ts := _pxyTidalData.ts;
	//self.myTidalModelDefinition := _pxyTidalData.myTidalModelDefinition;
	

end;


</source>
        <Parameter name="_pxyTidalData" type="HMS_TidalData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyTidalModelDefinition" id="df359cf0-217c-4795-8daa-b0d515950f4f">
        <updating/>
        <source>setMyTidalModelDefinition(_tidalModelDef : HMS_TidalModelDefinition) updating;
/*
----------   ----------  --------------------------------------------------
Created:	11 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.myTidalModelDefinition &lt;&gt; _tidalModelDef then
		self.myTidalModelDefinition := _tidalModelDef;
	endif;
	
end;


</source>
        <Parameter name="_tidalModelDef" type="HMS_TidalModelDefinition"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="617cbac6-e955-4c4c-838f-e5b8da0271ea">
        <source>validateForUpdate(_passport: CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.getDataType &lt;&gt; self.myTidalModelDefinition.dataType then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid tidal data type for definition data type(' &amp; self.getDataType.String &amp; ')');
	endif;
	
	if self.ts = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Tidal Data: Timestamp', null,  null);
		app.raiseCMException(Input_required_field_tidTmeStp, null,  null); // cnwdb2	PAR 35364
	endif;

end;


</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
