    <DbClassMap file="_usergui"/>
    <PrimAttribute name="timeDisplay" id="77c58d7d-9125-4d77-b27d-b3490288814a">
        <embedded/>
        <type name="Time"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="buildSelf" id="8a4b71f1-8565-4c84-9591-ec7c417e93c1">
        <updating/>
        <source>buildSelf() updating;

vars
	time : Time;
	
begin
	inheritMethod();
	
	self.setClockSize();	
	self.setTime(time);
	self.setTimeDisplay();
	self.displayTime();
end;</source>
    </JadeMethod>
    <JadeMethod name="displayTime" id="55919c0b-184e-406d-856e-e8615a6059b4">
        <updating/>
        <source>displayTime() updating;

vars
	startX	: Real;
	startY	: Real;
	endX	: Real;
	endY	: Real;
	
begin
	if self.drawSize = 0 then
		self.drawClockFace();
	else
		self.drawUndo(14);		
	endif; 
	
//	self.clearGraphics;
//	self.autoRedraw	:=	true;
	
	//draw Hour hand
	
//	write self.drawSize;
	startX := self.clockWidth / 2;
	startY := self.clockHieght / 2;	
	self.setHourHandEndPoint(startX, startY, endX, endY);
	self.drawWidth := 5;
	self.drawLine(startX, startY, endX, endY, Black);
	
	//draw Minute hand
	
	self.setMinuteHandEndPoint(startX, startY, endX, endY);
	self.drawWidth := 3;
	self.drawLine(startX, startY, endX, endY, Black);
	
	//draw Second hand
	
	if self.isShowSeconds then
		self.setSecondHandEndPoint(startX, startY, endX, endY);
		self.drawWidth := 1;
		self.drawLine(startX, startY, endX, endY, Red);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawClockFace" id="e6087d33-9964-4173-8b36-bafad354cd79">
        <updating/>
        <source>drawClockFace() updating;

vars
	x1			: Integer;
	y1			: Integer;
	x2			: Integer;
	y2			: Integer;
	color		: Integer;
	textHeight	: Real;
	degrees		: Real;
	radius		: Real;
	x			: Real;
	y			: Real;
	pos 		: Integer;
	centre		: Real;
	
begin
	x1 := 0;
	x2 := self.clockWidth;
	y1 := 0;
	y2 := self.clockHieght;
	color := Black;
	self.drawFontSize := self.fontSize;
	self.drawFontBold := self.fontBold;
	textHeight := self.drawTextHeight("0");

	self.clearGraphics();
	self.autoRedraw	:=	true;
	
	//draw Clock Face
	
	self.drawFillStyle := 0;
	self.drawFillColor := self.backColor;
	self.drawWidth := 1;
	self.drawEllipse(x1, y1, x2, y2, self.backColor);
	
	//draw Clock Text
	
	self.drawTextAlign := 2;
//	self.drawTextAt("12", x2 / 2, y1 + 1, clockNumberColour);
//	self.drawTextAt("6", x2 / 2, ( y2 - ( textHeight + 1 ) ) , clockNumberColour);
//	self.drawTextAt("3", ( x2 - ( (textHeight / 2)) ), (y2 / 2) - (textHeight / 2), clockNumberColour);
//	self.drawTextAt("9", ( x1 + textHeight / 2) , (y2 / 2) - (textHeight / 2), clockNumberColour);
	
	radius := self.clockWidth * .43;
	centre := self.clockWidth * .5;
	
	foreach pos in 1 to 12 do
		degrees := pos * 30;
		self.returnXYfromDegreesAndLength(degrees, radius, x, y );
		self.drawTextAt(pos.String, centre + x , centre + y - ( textHeight / 2 ), self.foreColor);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="returnXYfromDegreesAndLength" id="bb9b5a37-cf57-4094-885c-40079c927cbb">
        <source>returnXYfromDegreesAndLength(degreesPastTwelve:Real; length : Real; x:Real io; y : Real io);

begin
	x := 0;
	y := 0;

	if length &gt; 0 then
		if degreesPastTwelve = 360 or degreesPastTwelve = 0 then
			x := 0;
			y := -1 * length; 
		elseif degreesPastTwelve &gt; 270 then
			x := -1 * (length * (degreesPastTwelve - 270).cos());
			y := -1 * (length * (degreesPastTwelve - 270).sin());
		elseif degreesPastTwelve &gt; 180 then
			x := -1 * (length * (degreesPastTwelve - 180).sin());
			y := (length * (degreesPastTwelve - 180).cos());
		elseif degreesPastTwelve &gt; 90 then
			x := length * (degreesPastTwelve - 90).cos();
			y := length * (degreesPastTwelve - 90).sin();
		elseif degreesPastTwelve &gt; 0 then
			x := length * degreesPastTwelve.sin();
			y := -1 * (length * degreesPastTwelve.cos());
		endif;
	endif;
end;</source>
        <Parameter name="degreesPastTwelve" type="Real"/>
        <Parameter name="length" type="Real"/>
        <Parameter name="x" type="Real" usage="io"/>
        <Parameter name="y" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setClockSize" id="b7223fd5-7712-4cca-86ae-bf5aa5a78813">
        <updating/>
        <source>setClockSize() updating;

begin
	if self.width &lt; 90 then
		self.width := 90;
	endif;
	
	if self.height &lt; 90 then
		self.height := 90;
	endif;
	
	if self.width &gt; self.height then
		self.height := self.width;
	else
		self.width := self.height;
	endif;				
	
	self.clockWidth		:=	self.width.Integer;
	self.clockHieght	:=	self.height.Integer;
end;</source>
    </JadeMethod>
    <JadeMethod name="setHourHandEndPoint" id="885cbc48-97b3-4c3d-b298-1665d84fbfc6">
        <source>setHourHandEndPoint(startX, startY : Real; endX, endY : Real io);

vars
	vHour		: Integer;
	degrees		: Integer;
	faceWidth	: Integer;
	faceHeight	: Integer;
	handLength	: Real;
	x			: Real;
	y			: Real;
	
begin
	handLength	:=	self.clockWidth * 0.35; 

	vHour	:=	self.timeDisplay.format("HH").Integer;
	degrees	:=	vHour * 30; 
	degrees	:=	degrees + (self.min.Integer div 2);
	
	self.returnXYfromDegreesAndLength(degrees, handLength, x, y );
	endX	:=	startX + x;
	endY	:=	startY + y;
end;</source>
        <Parameter name="startX" type="Real"/>
        <Parameter name="startY" type="Real"/>
        <Parameter name="endX" type="Real" usage="io"/>
        <Parameter name="endY" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMinuteHandEndPoint" id="8f1202ca-82ea-4592-80c3-b52a23ce593c">
        <source>setMinuteHandEndPoint(startX, startY : Real; endX, endY : Real io);

vars
	vMin		: Integer;
	degrees		: Integer;
	faceWidth	: Integer;
	faceHeight	: Integer;
	handLength	: Real;
	x			: Real;
	y			: Real;
	
begin
	handLength := self.clockWidth * 0.45; 

	vMin := self.timeDisplay.format("mm").Integer;
	degrees := vMin * 6;
	degrees := degrees + (self.sec.Integer div 10);
	
	self.returnXYfromDegreesAndLength(degrees, handLength, x, y );
	endX := startX + x;
	endY := startY + y;
end;</source>
        <Parameter name="startX" type="Real"/>
        <Parameter name="startY" type="Real"/>
        <Parameter name="endX" type="Real" usage="io"/>
        <Parameter name="endY" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setSecondHandEndPoint" id="431f158c-ffa0-4dfd-82a6-1fe3d4b70678">
        <source>setSecondHandEndPoint(startX, startY : Real; endX, endY : Real io);

vars
	second		: Integer;
	degrees		: Integer;
	faceWidth	: Integer;
	faceHeight	: Integer;
	handLength	: Real;
	x			: Real;
	y			: Real;
	
begin
	handLength := self.clockWidth * 0.49; 

	second	:=	self.timeDisplay.format("ss").Integer;
	degrees	:=	second * 6; 
	
	self.returnXYfromDegreesAndLength(degrees, handLength, x, y );
	endX	:=	startX + x;
	endY	:=	startY + y;
end;</source>
        <Parameter name="startX" type="Real"/>
        <Parameter name="startY" type="Real"/>
        <Parameter name="endX" type="Real" usage="io"/>
        <Parameter name="endY" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setTimeDisplay" id="0e83d64f-5903-430a-a939-c39d88225445">
        <updating/>
        <source>setTimeDisplay() updating;

vars
	clockHour	: Integer;
	
begin
	if self.hour.Integer &gt; 12 then
		clockHour	:=	self.hour.Integer - 12;
	else
		clockHour	:=	self.hour.Integer;		
	endif;
	
	self.timeDisplay.setTime(clockHour, self.min.Integer, self.sec.Integer, 00);
		
	if not isInPainter() then	
		self.setTimer();	
	endif;
end;</source>
    </JadeMethod>
