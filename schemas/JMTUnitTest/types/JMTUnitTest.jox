    <JadeMethod name="getInputDate" id="cad80cf4-c623-4d50-bd9f-600960cc55d4">
        <source>getInputDate(_date : Date io; _text : String) : Boolean;

/*

Purpose:		Gets an input date	


Date			Who		Reason
27/02/2013		cnwmh5	Initial creation

*/

vars

	inputStr						: String;
	captionTxt						: String;

begin

	captionTxt := "Date Error";
	if _text.trimBlanks() &lt;&gt; null then
		captionTxt := _text.trimBlanks() &amp; " " &amp; captionTxt;
	endif;

	inputStr := _date.format("dd/MM/yyyy");
	read  inputStr;
	
	if inputStr = null then
		app.msgBox("Cancelling", captionTxt, MsgBox_OK_Only + MsgBox_Information_Icon);
		return true;
	endif;

	// return the date
	if inputStr.trimBlanks().length = 10 then
		_date := inputStr.trimBlanks().Date;
	elseif inputStr.trimBlanks().length = 8 then
		_date := (inputStr[1:2] &amp; "/" &amp;  inputStr[3:2] &amp; "/" &amp; inputStr[5:4]).Date;
	endif;
	
	if not _date.isValid() then
		app.msgBox("Cancelling", captionTxt, MsgBox_OK_Only + MsgBox_Information_Icon);
		return true;
	endif;

	return false;
	
epilog

end;</source>
        <Parameter name="_date" type="Date" usage="io"/>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getListOfClassesToCheck" id="3f28d5d3-f217-42f6-b707-4b82e0f99d22">
        <source>getListOfClassesToCheck(_klass : Class input; _classesToCheck : ClassColl io);

/*

Purpose:		Get the list of Classes 

Date			Who		Reason
02/11/2012		cnwmh5	Initial creation

*/

vars

	klass						: Class;
	
	classes						: ClassColl;

begin

	create classes transient;
	_klass.allLocalSubclasses(classes);
			
	foreach klass in classes do
		self.getListOfClassesToCheck(klass, _classesToCheck);
	endforeach;
	
	if _klass.name &lt;&gt; "UT_DSL" and not _classesToCheck.includes(_klass) then
		_classesToCheck.add(_klass);
	endif;

epilog

	delete classes;

end;</source>
        <Parameter name="_klass" type="Class" usage="input"/>
        <Parameter name="_classesToCheck" type="ClassColl" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMasterAddress" id="100b2abe-d32e-458c-8f5f-797df55c40b3">
        <updating/>
        <source>getMasterAddress() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2012	cnwmc5	Initial creation

*/

vars

	xmlDoc					: JadeXMLDocument;
	element					: JadeXMLElement;
	attribute				: JadeXMLAttribute;
	
	emailAddress 			: String;
	
begin

	on JadeXMLException do app.handleXMLExceptions(exception);

	create xmlDoc transient;
	xmlDoc.parseString(UM_UserEmailAddress.getPropertyValue("text").String);
	
	element := xmlDoc.getElementByTagName("EmailAddress");
	if element &lt;&gt; null then
		attribute := element.getAttributeByName("address");
	endif;
	
	if attribute &lt;&gt; null then
		emailAddress := attribute.value;
	endif;
	
	self.masterAddress := emailAddress;	

epilog

	delete xmlDoc;

end;</source>
    </JadeMethod>
    <JadeMethod name="getNextRunDate" id="c7f53f94-ffe1-4af0-ab4a-826fa335817a">
        <source>getNextRunDate(_currentTimeStamp : TimeStamp io; _runDaysOfWeekArray, _runTimesArray : StringArray) : Integer;

/*

Purpose:		Get the date and dayOfWeekIndex for the next run date	

Date		Who		Reason
01 April 2011	cnwmh5	Initial creation

*/

vars

	dayOfWeek		: Integer;
	dayOfWeekIndex	: Integer;
	
begin
	
	// check the run day of week.  If empty then use today, if in array use this else workout when next one will be
	if not _runDaysOfWeekArray.isEmpty() then
		while true do
			dayOfWeek := _currentTimeStamp.date.dayOfWeek();
			dayOfWeekIndex := _runDaysOfWeekArray.indexOf(dayOfWeek.String);
			if dayOfWeekIndex &gt; 0 then
				break;
			endif;
			_currentTimeStamp := _currentTimeStamp.addDays(1);
		endwhile;
	else
		dayOfWeekIndex := _currentTimeStamp.date.dayOfWeek();
	endif;
	
	return dayOfWeekIndex;
	
epilog

end;</source>
        <Parameter name="_currentTimeStamp" type="TimeStamp" usage="io"/>
        <Parameter name="_runDaysOfWeekArray" type="StringArray"/>
        <Parameter name="_runTimesArray" type="StringArray"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
