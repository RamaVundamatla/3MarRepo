    <JadeMethod name="showThumbnailData" id="689f5a09-f26b-4e22-81cc-4dd2ae6ca36d">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theInvoiceType 	: CM_InvoiceDesc;
	theTable		: CM_ThumbnailTable;
	narrText : String;
	numLines : Integer;
	narrationRow : Integer;
	idx		: Integer;
begin
	self.fldEntDetail.visible := false;
	theInvoiceType 	:= obj.CM_InvoiceDesc;
	theTable		:= self.tblThumb;
	theTable.rows := 0;
	theTable.columns := 2;
	theTable.scrollBars := 3;
	self.showThumbnailForDef(ETDef_InvMainInvTypeThumb, theInvoiceType);
	
	// the last row should be Narration. There is special text to be populated
	self.populateEntNarrTable();
	narrText := self.getNarrationEx();
	numLines := narrText.getDelimiterCount(CrLf);
	if numLines &lt; 1 then 
		numLines := 1;
	else
		numLines := numLines + 2;
	endif;
	
	//cnwjo3 par 25387 ccms 1970.  note ETRow_Narration is 'narration' but in table its 'Narration'.  can't use the below method
	//narrationRow := theTable.getRowFromHeading(ETRow_Narration.toUpper());
	foreach idx in 1 to theTable.rows do
		if theTable.accessCell(idx,1).text.toUpper() = ETRow_Narration.toUpper() then
			narrationRow := idx;
			break;
		endif;
	endforeach;
	
	if narrationRow &gt; 0 then  //if narration is in table then populate;
		theTable.accessCell(narrationRow,2).text := narrText;
		theTable.accessRow(narrationRow);
		theTable.accessedRow.height := numLines * 18;
	endif;
	
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
