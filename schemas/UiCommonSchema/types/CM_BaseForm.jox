    <JadeMethod name="progressStart" id="2681af44-d57f-4be0-a378-2402c51f0baa">
        <updating/>
        <source>progressStart(totalParts : Integer; btnDefaultCaption, btnOpt1Caption, btnOpt2Caption, _msg1 : String) updating;
// ---------------------------------------------------------------------------
// Created:		30 May 2003 by cnwsgp1
//
// Purpose:		Sets up the progress bar
// ---------------------------------------------------------------------------

begin
	progressPartsDone := 0;
	progressTotalParts := totalParts;

	// will increment every 5%
	progressUpdateAfter := (totalParts / 20).roundedUp;

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;
	self.modalDialogShow(null, btnDefaultCaption, btnOpt1Caption, btnOpt2Caption,
						_msg1, null);
	self.modalDialogProgressBar(totalParts);
end;</source>
        <Parameter name="totalParts" type="Integer"/>
        <Parameter name="btnDefaultCaption" type="String"/>
        <Parameter name="btnOpt1Caption" type="String"/>
        <Parameter name="btnOpt2Caption" type="String"/>
        <Parameter name="_msg1" type="String"/>
    </JadeMethod>
    <JadeMethod name="progressUpdate" id="224e7cf3-5429-4cd8-9105-4ac1586d723a">
        <updating/>
        <source>progressUpdate() updating;
// ---------------------------------------------------------------------------
// Created:      30 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	count : Integer;

begin
	progressPartsDone := progressPartsDone + 1;
	count := progressPartsDone;
	
	if progressUpdateAfter &gt; 0 and count mod progressUpdateAfter = 0 then
		self.modalDialogUpdateInfo("Loaded " &amp; count.String &amp;
						' of ' &amp; progressTotalParts.String &amp; " Items");
		self.pbProgressBar.partsDone := count;
		self.pbProgressBar.doWindowEvents(0);
		if self.btnModalDefault.visible then
			self.btnModalDefault.doWindowEvents(0);
		endif;
	endif;
	
end;</source>
    </JadeMethod>
