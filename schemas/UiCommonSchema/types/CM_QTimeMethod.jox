<Class name="CM_QTimeMethod">
    <JadeMethod name="setTimeRangeValues" id="227429ae-e2c2-4cca-b373-93ab7bd34891">
        <source>setTimeRangeValues(_textboxArray : ObjectArray input; 
					_params: CM_QueryCriteriaLineHolder; 
					_operator: CM_QueryOperator; 
					_passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2012	cnwndl1	Initial creation	Par 29532

*/

vars
	timeRangeOp		: CM_QTimeRange;
	fromDay,
	toDay			: Integer;
	today			: Date;
begin
	
	if _textboxArray = null or 
	   (_textboxArray.size &lt; 2) or
	   (not CM_QTimeRange.hasInstance(_operator)) then
		return;
	endif;
	
	timeRangeOp := _operator.CM_QTimeRange;
	
	_textboxArray[1].CMUI_TimeMask.setTime(timeRangeOp.getSearchValueFromTime);
	_textboxArray[2].CMUI_TimeMask.setTime(timeRangeOp.getSearchValueToTime);

epilog

end;</source>
        <Parameter name="_textboxArray" type="ObjectArray" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setTimeValues" id="b80d7285-255c-47fc-af85-afcbf06ab5a7">
        <source>setTimeValues(_txt: CMUI_TimeMask input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2012	cnwndl1	Initial creation	Par 29532

*/

vars
	theTime		: Time;
begin
	if _txt = null or (not  CM_QueryTimeOperators.hasInstance(_operator)) then
		return;
	endif;
	
	theTime := _operator.CM_QueryTimeOperators.searchValue;
	if (not theTime.isValid) then
		theTime := "00:00".Time;
	endif;
	
	_txt.setTime(theTime);

end;</source>
        <Parameter name="_txt" type="CMUI_TimeMask" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
