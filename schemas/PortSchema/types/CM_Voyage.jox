    <JadeMethod name="displayTerminalDetails" id="021fd000-f738-4b68-957a-75ae9c2625ee">
        <source>displayTerminalDetails() : String;
//-----------------------------------------------------------------------
//	Created:	03 November 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	if self.myTerminal &lt;&gt; null then
		return self.myTerminal.name &amp; " Arr: " &amp; self.systemToLocalTime(self.arrivedDT).shortCurrentLocaleFormat();	// 25/5/16	cnwmp6	TFS 488 - Multi timezone support
