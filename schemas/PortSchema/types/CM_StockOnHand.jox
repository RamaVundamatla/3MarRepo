        <source>isNotScenarioStockOnHandCond() : Boolean condition;
// ---------------------------------------------------------------------------
// Created:     26 March 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
begin
	return (not self.isScenarioStockOnHand);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myExtension" id="77e10fe4-cc51-4cb6-ba91-50a057aeda20">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myExtension(set: Boolean; _value: CM_StockOnHandExtension io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	extClass	: Class;

begin

	if self.isTransient then
		return;
	endif;

	if (not process.isInTransactionState) then
		return;
	endif;
	
	if set and _value = null then
		delete self.myExtension;
		return;
	endif;

	if self.myExtension = null then
		extClass := self.getExtensionClass();
		if extClass &lt;&gt; null then
			create self.myExtension as extClass persistent;
			_value := self.myExtension;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_StockOnHandExtension" usage="io"/>
    </JadeMethod>
    <JadeMethod name="recalcSummaryData" id="81497601-3895-4bb0-a4c4-63df5b16b75f">
