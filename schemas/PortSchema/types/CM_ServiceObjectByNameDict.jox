<CollClass name="CM_ServiceObjectByNameDict" id="0cb0b25f-bf58-43d5-b07e-8788ec5b27e8">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_ServiceObject"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <MemberKey>
        <property name="CM_ServiceObject::name"/>
    </MemberKey>
    <JadeMethod name="getServiceList" id="05f628d8-1306-49a3-bcf5-c1171424bd3d">
        <source>getServiceList() : String;
/*
Purpose:			
Date		Who		Reason
27 May 2013	cnwab1	Initial creation
*/

vars
	calc : CM_ServiceObject;
	tmpStr : String;
begin
	foreach calc in self  discreteLock do
		if tmpStr = null then
			tmpStr := "'" &amp; calc.name &amp; "'";
		else
			tmpStr := tmpStr &amp; ", '" &amp; calc.name &amp; "'";
			endif;
	endforeach;
 
 
	return tmpStr &amp; ".";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
