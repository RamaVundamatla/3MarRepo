    <JadeMethod name="deleteDamagePosition" id="a4ffab7e-9754-49e0-a202-e1093047d758">
        <source>deleteDamagePosition(_damagePositionCode : String);
//  Created by cnwsh3
//	Date 23 July 2009
//
// Implemented version: 7.7.3

//----------------------------------------------------------------------
// 20/06/2012	cnwmh5	Change so that removes all active cargo types
vars
	damagePos : CM_DamagePosition;
	root : CM_Root;
	cargoType : CM_CargoType;
	damageInstance  : CM_DamageInstance;
begin
	root := CM_Root.firstInstance();
	damagePos := root.allDamagePositionsByCode[_damagePositionCode];
	//app.myPassport.setWarningsIgnored(true);
	if damagePos &lt;&gt; null then
		
		beginTransaction;
		foreach cargoType in app.myRoot.allCargoTypesById do
			if cargoType.allDamagePositions.includes(damagePos) then
				cargoType.allDamagePositions.remove(damagePos);
			endif;
		endforeach;
		
		// 16/03/2016 cnwmh5 - Remove damaage from ti's then delete damange instance
		foreach damageInstance in damagePos.allDamageInstances do
			delete damageInstance;
		endforeach;

		commitTransaction;
		
		app.myTrxDA.trxDeleteDamagePosition(damagePos, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
epilog
end;</source>
        <Parameter name="_damagePositionCode" type="String"/>
    </JadeMethod>
