    <JadeMethod name="setDataEntryFields" id="68064a2f-b71f-4f23-9e70-8da59643db8b">
        <updating/>
        <source>setDataEntryFields(_enabled : Boolean) updating;

/*

Purpose:			Enable/Disable all the data entry fields, to allow form to exectute without
					going non-responsive in Windows

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services

*/

vars

begin
	self.btnCancel.enabled := _enabled;
	self.btnClear.enabled := _enabled;
	self.btnExtract.enabled := _enabled;
	self.btnFind.enabled := _enabled;
	self.cmbTerminal.enabled := _enabled;
	self.tblExtractClass.enabled := _enabled;
	self.txtDirectory.enabled := _enabled;
	
	self.controlBox := _enabled;

	
epilog

end;</source>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a1a7f473-c978-42a1-bffe-678dd829862a">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2011	#cnwdz2	 

*/

vars

begin
	inheritMethod();
	
	self.handleMenusForModalDisplay();
	
	self.initCmbTerminal();
	self.initTblExtractClasses();
	self.cmbTerminal.setFocus();
	
	self.populateDataExtractClass();
epilog

end;</source>
