/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2023	navhl20	Defect 58906: MTN - The Allocated and Unallocated list is not refreshing correctly using the filter criteria

*/

vars

begin
	if self.myWODtl &lt;&gt; null then
		return self.myWODtl.getDtlType() = _jobType;
	elseif self.myWorkOrderDtlToDo &lt;&gt; null	 then
		return self.myWorkOrderDtlToDo.getDtlType = _jobType;
	endif;
epilog

end;</source>
        <Parameter name="_jobType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
