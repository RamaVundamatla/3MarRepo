    <JadeMethod name="updateStatusWoWLE" id="9085c294-1c47-4576-b393-0ac45a1abc42">
        <source>updateStatusWoWLE(_status : Integer;
				  _wagon     : CM_Wagon);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/11/2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars
	woJob	:	CM_Job;
	wle		:	CM_WorkListEntry;
begin
	foreach woJob in self.allJobs do
		if woJob &lt;&gt; null then
			foreach wle in woJob.workListEntries do
					if wle.CM_WOWagonToDoWLE.myWagon &lt;&gt; _wagon then
						continue;
					endif;
					if wle.status = JOB_COMPLETE then
						continue;
					endif;
					wle.setStatus(_status);
				endforeach;
			endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="validate" id="05497bd0-f5d0-4cb8-bc92-f8904803cc73">
        <source>validate()protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
04 October 2022	navcs2  ChangeRequest 54344: EUP - VAS Work Orders - Jobs
28 Dec 2022		navhl20	Task 56057(54344): WodToDoDetail validation
*/

vars

begin
	//Start 28.12.2022 navhl20 TFS 56057(54344)
	inheritMethod();
	if self.allWagons.isEmpty() then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Wagon), null, null); 
	endif;
	//End 28.12.2022 navhl20 TFS 56057(54344)
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
