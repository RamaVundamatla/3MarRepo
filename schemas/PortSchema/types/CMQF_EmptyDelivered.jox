<Class name="CMQF_EmptyDelivered" id="f6891ca9-37dd-4e28-a648-cb1e5c8bedbc">
    <superclass name="CMQF_Container"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="bedf7ea6-6676-4ce4-8bd1-57e18cb1cf3a">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		20 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 12/09/2012	cnwcs5	par 29780	Include sub-terminal intrnal releases

vars
	ti				: CM_TrackedItem;
	tran			: CM_TITransaction;
	col				: CM_TITransactionByDateTypeDict;
	terminal		: CM_Terminal;
	start, 
	endDateTime		: TimeStamp;
	breakOut		: Boolean;
begin
	endDateTime.setTime("23:59:59".Time);
	endDateTime.setDate(self.endDate);

	start 	:= self.startDate.TimeStamp;
	
	create col transient;
	//search for releases
	foreach terminal in self.allTerminals do
		terminal.getTITxnsForTypeAll(TRANS_TYPE_RELEASE, start, endDateTime, null, self, col );
		// par 29780 - include sub-terminal releases as well
		terminal.getTITxnsForTypeAll(TRANS_TYPE_REL_ST_DEPOT_INT, start, endDateTime, null, self, col );
		terminal.getTITxnsForTypeAll(TRANS_TYPE_REL_ST_MARINE_INT, start, endDateTime, null, self, col );
		terminal.getTITxnsForTypeAll(TRANS_TYPE_REL_ST_WHOUSE_INT, start, endDateTime, null, self, col );
	endforeach;
	

	foreach tran in col do
		// par 29780 - don't include transaction if TI was not MT at time of transaction
		if not tran.isEmpty then
			// TI was not empty at time of transaction
			continue;
		endif;
		
		ti := tran.myTrackedItem;
		
		if ti &lt;&gt; null then		
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					
					self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
				endif;
			endif;
		endif;
	endforeach;

epilog
	delete col;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="8ab0c058-0a97-4b32-bdea-072fc2fd18c6">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		20 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 12/09/2012	cnwcs5	par 29780 - check transaction MT status not TI MT status as TI may have been packed by time report run.
vars

begin
	// Note: contentsStatus (MT) is checked in calling method
	if _ti.releasedTransportMode &lt;&gt; TI_TRANSMODE_SHIP and
		inheritMethod(_ti, _passport, _breakOut) then
	 	
		return true;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
