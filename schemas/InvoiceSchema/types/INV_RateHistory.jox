vars

	sl : CM_ShippingLine;
	spg : CM_ShipPortGroup;

begin

	sl := self.cmbTrade.itemObject[self.cmbTrade.listIndex].CM_ShippingLine;
	self.myCurrentTrade := sl;
	self.cmbTradeGroup.clear;
	self.cmbTradeDebtor.clear;
	foreach spg in sl.shipPortGroups do
		self.cmbTradeGroup.addItem(spg.code);
		self.cmbTradeGroup.itemObject[self.cmbTradeGroup.newIndex] := spg;
	endforeach;
	self.setEnableObjects();


end;</source>
