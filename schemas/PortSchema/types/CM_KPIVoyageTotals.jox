    <JadeMethod name="resetExtraMoveDtls" id="7a612b1f-9487-4078-b96c-d5e38286997b">
        <updating/>
        <source>resetExtraMoveDtls() updating;
/*

Date		    Who			Reason
18 June 2010	cnwas3	  ccms 1134

*/

vars

begin	
	self.numCageMoves := 0;
	self.numExtraMoves := 0;
	self.numLashingBinMoves := 0;
	self.numLashings := 0;
	self.numUnlashings := 0;	
epilog

