//----------------------------------------------------------------
//	Created:	17 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	return;
	
	//YOU CANNOT PATCH 722B WITH THIS
	//PATCH FROM TMAST or
	//RUN convertForCCMS1205
	// 20/05/2004  JC
/*
