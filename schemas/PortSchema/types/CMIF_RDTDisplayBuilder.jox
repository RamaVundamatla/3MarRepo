    <JadeMethod name="getSupportedMode" id="5f4facfb-3ccc-4889-9f6f-59d9d64d1c7f">
        <source>getSupportedMode(_mode : Integer) : Integer;

/*

Purpose:			
		returns the supplied _mode if supported, otherwise one that is
Parameters:			

Return Value:		


Date		Who		Reason
01 June 2010	cnwjk3	Initial creation

*/

vars
	actualMode : Integer;
begin
	if _mode = CMIF_RDTDrawElement.MODE_TOPDOWN then
		if self.canDisplayTopDown() then 
			actualMode :=  _mode;
		else
			actualMode := self.getDefaultDisplayMode();
		endif;
	elseif _mode = CMIF_RDTDrawElement.MODE_FACE then
		if self.canDisplayFace() then 
			actualMode :=  _mode;
		else
			actualMode := self.getDefaultDisplayMode();
		endif;	
	else
		if self.canDisplayEnd() then 
			actualMode :=  _mode;
		else
			actualMode := self.getDefaultDisplayMode();
		endif;		
	endif;
	
	return actualMode;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
