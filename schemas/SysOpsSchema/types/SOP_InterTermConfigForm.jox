Return Value:		

Date				Who		Reason
02 February 2010	conkc1	Initial creation

*/
vars

	reason : CM_DeliveryReleaseReason;
	index  : Integer;
begin

	self.cmbDeliveryReasn.clear;

	foreach reason in app.myRoot.allDeliveryReasonselReasons do
		index := self.cmbDeliveryReasn.addItem(reason.description);
