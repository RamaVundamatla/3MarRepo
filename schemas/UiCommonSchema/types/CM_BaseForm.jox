    <JadeMethod name="centreOverParent" id="33484131-9478-4c61-ab7a-808338a57068">
        <updating/>
        <source>centreOverParent(_yAdjustment : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     15 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	cLeft, cTop : Real;
	x, y: Real;
	parent: Form;
begin

	if self.myParentForm &lt;&gt; null then
		parent := self.myParentForm;
		x := parent.left;
		y := parent.top;
		
		// 20.08.2018 TFS 38467 jlggb1 Remove special "Jade not working Code" from, here
		
		cLeft := ((parent.width - self.width) / 2).Integer;
		cLeft := cLeft + x.Integer;

		if parent.clientHeight &gt;= self.clientHeight then
			cTop := y + _yAdjustment;
		else
			cTop := y;
		endif;
		self.top := cTop ;
		self.left := cLeft;
		
	else
		// if no parent then just centre on the screen
		self.centreWindow();
	endif;

epilog

end;</source>
        <Parameter name="_yAdjustment" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="checkPermissions" id="06a24a15-8630-4345-ba02-f11a7b03886d">
        <source>checkPermissions(_terminal : CM_Terminal) : Boolean;
//--------------------------------------------------
// Created:	27 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin 
	// need to add pTerminal to user permission check
	if (not app.myCurrentUserCan(_terminal, self.permissionView)) then 
		// user does not have access to view form
		app.msgBox(app.getErrorString1(VB_SECSHOW, self.caption), "Security Warning", MsgBox_Stop_Icon);
		return false;
	endif;
		
	return true;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkSecurity" id="327a2145-20e2-4b67-9272-4a1bb821a85e">
        <source>checkSecurity(permissionCode: Integer; permLabel: String): Boolean;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	// AKB PAR 3736 - 24Jan2001 added. Has the user got  access?
	if (not app.getMyUser().canDo(self.myTerminal, permissionCode)) then
		app.msgBox(app.getErrorString1(VB_SECMOVE, permLabel), "Application Security", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	else
		return true;
	endif;

end;</source>
        <Parameter name="permissionCode" type="Integer"/>
        <Parameter name="permLabel" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkSuperUserPassword" id="3b3d5fc8-ec6c-45e3-ad57-22d77a05e07b">
        <source>checkSuperUserPassword(_enteredPW : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:     23 July 2008 by cnwab1
//
// Purpose:      IsSpecial extra check is used outside JMT Plant - PAR 17588
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	superUser : CM_User;
	passwordBin : Binary;
	pwSTR : String;
begin
	pwSTR := _enteredPW;
	
	superUser := app.myRoot.allUsers['SUPERUSER'];
	passwordBin := app.encryptPassword('SUPERUSER', pwSTR, true);
	
	if superUser.currentPassword = passwordBin then
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="_enteredPW" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
