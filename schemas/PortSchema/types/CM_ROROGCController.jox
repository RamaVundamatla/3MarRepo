    <JadeMethod name="setForUpdateTI" id="54124018-511d-4be0-9a43-33a8deac79ae">
        <updating/>
        <source>setForUpdateTI(_ti: CM_TrackedItem) updating;
/*
Purpose:		27749	To allow location specific updates based on the TI update			
Date		Who		Reason
23 June 2011	cnwab1	Initial creation
*/

vars
	newColour : Integer;
begin
	inheritMethod(_ti);

	if self.myGCDefn = null then
		return;
	endif;
	if _ti = null then
		return;
	endif;
	app.myEventManager.createSingleObjInfoNoteEvt(self.myVoyage,self.myVoyage.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),	self);
	
	newColour := _ti.getDrawingColour(TI_ColourMode_DischargePort);
	if newColour &lt;&gt; self.myGCDefn.myLayout.drawFillColour then
		self.myGCDefn.myLayout.setRealDrawFillColour(newColour);
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setFromROROGCDefn" id="9a909d97-8d25-4996-b689-1054151118d2">
        <updating/>
        <source>setFromROROGCDefn() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.code := self.myGCDefn.code;
	self.ident:= self.code ;
	self.myDeck:= self.myGCDefn.myDeck.CM_DeckVoyage;
	self.myVoyage:= self.myDeck.CM_DeckVoyage.getVoyage();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="testIsControllerAvailable" id="683d6c17-a8b7-45e5-9791-81a0bf18478b">
        <source>testIsControllerAvailable(_autoMovePlan: CMIF_AutoMovePlan input);
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars

begin
	_autoMovePlan.updateController(null);
	if not self.myGCDefn.myLayout.isVisible then
		_autoMovePlan.addLogEntry(app.getErrorString1(Unavailable, self.getFullId) &amp; " " &amp; app.getErrorString(Discharge_roro_area_not_visibl), IsError, Unavailable);
		return;
	endif;
	
	//We are happy, so set ref to us.
	_autoMovePlan.updateController(self);
end;</source>
        <Parameter name="_autoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
</Class>
