    <JadeMethod name="rh_fixVehicleTabTFS3032" id="4e101c16-e963-42cd-9ed6-b0b901e59c6c">
        <source>rh_fixVehicleTabTFS3032 ();

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2016	cnwrh7	Initial creation

*/

vars
    vecicleVisitRecord     : CM_VehicleVisitRecord;
    vecicle                              :    CM_Vehicle;
    obj                                 : Object;
    tab                                 : String;
    newReg                         : String;
    numberRecd                 : Integer;
begin
    tab := Tab;
    numberRecd := 0;
    foreach obj in CM_VehicleVisitRecord.instances discreteLock do
        if obj.CM_VehicleVisitRecord.regNumber.cnContains(tab) then
            numberRecd := numberRecd +1;
            newReg :=obj.CM_VehicleVisitRecord.regNumber.removeTabCrLfs();
       beginTransaction;
                 obj.CM_VehicleVisitRecord.setPropertyValue(CM_VehicleVisitRecord::regNumber.name,newReg);
            commitTransaction;
        endif;
    endforeach;
    app.msgBox ( "Fixed objects in CM_VehicleVisitRecord is " &amp; numberRecd.String , "Finished Searching CM_VehicleVisitRecord Class", MsgBox_OK_Only);

    numberRecd := 0;
    foreach obj in CM_Vehicle.instances discreteLock do
        if obj.CM_Vehicle.regNumber.cnContains(tab) then
            numberRecd := numberRecd +1;
            newReg :=obj.CM_Vehicle.regNumber.removeTabCrLfs();
	beginTransaction;
					 obj.CM_Vehicle.setPropertyValue(CM_Vehicle::regNumber.name,newReg);           
			commitTransaction;
		endif;
    endforeach;

    app.msgBox ("Fixed objects in CM_Vehicle is: "&amp; numberRecd.String,  "Finished Searching CM_Vehicle Class ", MsgBox_OK_Only);
epilog
end;

</source>
    </JadeMethod>
