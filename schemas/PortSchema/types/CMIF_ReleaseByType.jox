    <JadeMethod name="actionForCreate" id="74edee43-64a5-4e6b-9f54-e1bdcb13d17f">
        <updating/>
        <source>actionForCreate(pProxy : CM_Object io; _passport : CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08 Feb 2019	jlgrs1	TFS 43312 - More Deadlocking in Multiuser EDI
// 30 Jun 2025 navma1 MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
// ---------------------------------------------------------------------------
vars
	bulkRelease : CM_BulkRelease;
	request     : CM_Request;	
	job			: CM_RoadJob;
	array 		: StringArray;
begin

	job := self.getInOutJob();
	if job = null then
		return false;
	endif;
	
	if idMask &lt;&gt; "" then
		create array transient;
		idMask.convertToDelimitedArray(",", array);
		if array &lt;&gt; null then
			array.copy(ids);
			self.myProxyYardRequest.CM_DeliveryRequest.setIds(ids);
		endif;
	endif;

	request := job.addRequest(self.myProxyYardRequest, _passport);
	
	if request = null or _passport.hasErrors() then
		return false;
	endif;

	if (not self.myTerminal.getConfig(DoNotCreateBulkRelease).Boolean) then
		//th2 added 22/01/07 - deadlocks in CM_BulkRelease::setFromTIRequest(2167)
		//setting CM_BulkRelease::myTerminal reference
		/*
		Collections Should be locked in the right Oid Order
		30.06.2025 navma1 #MTN-34090
		*/
		self.exclusiveLock(self.myTerminal.allBulkReleasesByCodeDate);    //004 - CM_BulkReleaseByCodeDict
		self.exclusiveLock(self.myTerminal.allBulkReleasesByDelRelNo);    //021 - CM_BulkReleaseByDelRelNoDict
		self.exclusiveLock(self.myTerminal.allBulkReleaseByTypeByStByCd); //159 - CM_BulkReleaseByTypeStCodeDict
		
		// Par8380 - add bulk release if needed
		bulkRelease := request.myOriginatingBulkRelease;
		if bulkRelease = null then
			if self.releaseNo = null then
				//See if one has been created for system code
				bulkRelease := self.myTerminal.getBulkReleaseFromCode(self.systemBulkReleaseCode);
				
			endif;
			if bulkRelease &lt;&gt; null then
				//Set bulk release and adjust total requested
				request.setMyOriginatingBulkRelease(bulkRelease);
				//epr 11/9/17 TFS 6723 deleted reference to method that did nothing
			else
				//create bulk release for gate out request
				request.createBulkReleaseFromSelf(_passport);
				self.systemBulkReleaseCode := request.myOriginatingBulkRelease.code;
			endif;
		else
			//determine whether the bulk release totals need adjusting
			if bulkRelease.isSystemGenerated then
				self.systemBulkReleaseCode := bulkRelease.code;			
			endif;
		endif;
	endif;
epilog
	delete array;
	return inheritMethod(pProxy, _passport);
end;</source>
        <Parameter name="pProxy" type="CM_Object" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionForCreatePost" id="13538493-f361-4668-96f3-5d5b138b6592">
        <updating/>
        <source>actionForCreatePost(_obj : Object; _passport : CM_Passport input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	
	if self.myRequest &lt;&gt; null then
		self.myRequest.setItemDetails(self);
	endif;
	
	return true;
epilog
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="3c36f877-9436-4ba1-b253-25984be5aa52">
        <updating/>
        <source>delete() updating;

vars
	isInvalid	: Boolean;
	proxyObj	: Object;
	
begin
	// cnwjk3 16/10/09 PAR 21332 - NOTE this exception handler had been put in previously to fix the 
	// same issue, but had been subsequently commented out.
	on Exception do app.handleDeletedObject(exception, proxyObj, isInvalid);

	// A case was found in the Kiosk application where a user entered a pin for a release
	// that was already being processed - in this case an error was correctly reported,
	// but when the user hit the restart button, the system clears all of these CMIF objects,
	// however the proxy object has already been deleted.
	
	proxyObj	:=	self.myProxyYardRequest;
	delete proxyObj;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="isContainer" id="5bb5b7d5-d4d6-4557-ad39-f886a6a43c2b">
        <source>isContainer(): Boolean protected;
// --------------------------------------------------------------------------------
// Created:		05 May 2009 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myCargoType = null then
		return false;
	else
		return (self.myCargoType.id = TI_CargoType_Container);
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForty" id="23586139-8fac-4aa0-a36a-dd6e5c288b4d">
        <source>isForty() : Boolean;
// --------------------------------------------------------------------------------
// Created:		7 May 2009 by cnwjo3
//
// Purpose:		Replace CM_BulkRelease::isForty when multiple items on Release
vars
	isoTypeObj		: CM_ISOType;
begin
	if self.isoType &lt;&gt; null then
		isoTypeObj	:=	app.myRoot.allISOTypes[self.isoType];
		
		if isoTypeObj &lt;&gt; null then
			return isoTypeObj.is40ftLong();
		endif;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromBookingRef" id="6ea416dc-7ebc-48db-ad02-378f4d8baf86">
        <updating/>
        <source>setFromBookingRef(_bookingRef : CM_BookingRef) updating;
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	bri : CM_BookingRefItem;
begin
	if _bookingRef = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_bookingRef', null, null);
		return;
	endif;
	
	self.myTerminal				:=	app.getMyTerminalDO_NOT_USE();
	self.consigneeCode			:=	_bookingRef.consigneeCode;
	self.myCargoType			:=	_bookingRef.myCargoType;
	self.releaseNo				:=	_bookingRef.bookingReference;
	self.removeStops			:=	false;
	self.ignoreWarnings			:=	true;
	if _bookingRef.myOperator &lt;&gt; null then
		self.myOperatorGroup		:=	_bookingRef.myOperator.getOperatorGroupIfOnlyOne();
	endif;
	self.quantity				:=	1;
	
		
	self.clean					:=	_bookingRef.clean;
	self.doISOGroupCheck		:=	false;
	self.heavyRated				:=	false;
	self.idMask					:=	null;
	self.isoType				:=	_bookingRef.isoType;
	if self.isoType = null then
		bri := _bookingRef.allBookingRefItems.first;
	endif;
	
	
	if self.myOperatorGroup &lt;&gt; null then
		self.operatorGroupCode		:=	self.myOperatorGroup.code;
	endif;
	if _bookingRef.myOperator &lt;&gt; null then
		self.operatorCode	:=	_bookingRef.myOperator.code;
	endif;
end;</source>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setFromBulkRelease" id="6babfbc8-beac-477d-bcb6-af384dc98060">
        <updating/>
        <source>setFromBulkRelease(_bulkReleaseObj : CM_BulkRelease; _reserveDetail : CM_ReserveSelection) updating;
// ---------------------------------------------------------------------------
// Created:     22 August 2006 by cnwrs2
//
// Purpose:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/09/2009	consw1		SFW1035 - get info from ReserveDetail rather than Yard Request
// ---------------------------------------------------------------------------
vars
//	requestObj		: CM_Request;
//	yardRequestObj	: CM_YardRequest;
//	deliveryObj		: CM_DeliveryRequest;
//	operatorObj		: CM_Operator;
	allStringsObj	: HugeStringArray;
	
//	reserveSelection : CM_ReserveSelection;
//	reserveDetail : CM_ReserveDetail;
//	i : Integer;
//	thisIsoType : String;
begin
	if _bulkReleaseObj = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_bulkReleaseObj', null, null);
		return;
	elseif _reserveDetail = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_reserveDetail', null, null);
		return;
	endif;
	
//	requestObj	:=	_bulkReleaseObj.requests.first();
	
//	if requestObj = null then
//		app.raiseUnexpectedProgramError(class.name, method.name, 'Release object null for (' &amp; _bulkReleaseObj.String &amp; ')');
//		return;
//	endif;
	//th2 PAR 14869 - availability grades not copying over
//	_bulkReleaseObj.getAllAvailabilityGrades().copy(self.allAvailabilityGrades);
	_reserveDetail.allAvailabilityGrades.copy(self.allAvailabilityGrades);
	
	self.myTerminal				:=	_bulkReleaseObj.myTerminal;			// app.getMyTerminal();
	self.consigneeCode			:=	_bulkReleaseObj.consigneeCode;
//	self.myBulkRelease			:=	requestObj.bulkRelease;
	self.myBulkRelease			:=	_bulkReleaseObj;
	//par 18563
	//self.myCargoType			:=	_bulkReleaseObj.getMyCargoType();
//	reserveDetail 				:=  _rd;
//	if reserveDetail &lt;&gt; null then
		self.myCargoType := _reserveDetail.getCargoType();
//	endif;
//	self.freightForwarderCode	:=	requestObj.freightForwarderCode;
	self.freightForwarderCode	:=	null;
	if _bulkReleaseObj.myFreightForwarder &lt;&gt; null then
		self.freightForwarderCode := _bulkReleaseObj.myFreightForwarder.code;
	endif;
//	self.freightPayerCode		:=	requestObj.freightPayerCode;
	self.freightPayerCode		:=	_bulkReleaseObj.freightPayerCode;
	
	self.releaseNo				:=	_bulkReleaseObj.code;	// ????????
	self.removeStops			:=	false;	// ???
	self.ignoreWarnings			:=	true;
	self.myOperatorGroup		:=	_bulkReleaseObj.myOperatorGroup;
	self.quantity				:=	1;
	
/*	if requestObj.isKindOf(CM_YardRequest) then
		yardRequestObj				:=	requestObj.CM_YardRequest;
		self.consignorVoyageCode	:=	yardRequestObj.consignorVoyageCode;
		self.deliveryReason			:=	yardRequestObj.reasonCodeDescr;
		self.doorsDirection			:=	yardRequestObj.doorsDirection;
		self.eirNumber				:=	yardRequestObj.eirNumber;
		self.needCOU				:=	yardRequestObj.needCOU;
		self.needGenerator			:=	yardRequestObj.needGenerator;
		self.remarks				:=	yardRequestObj.remarks;
	endif;
*/
	self.consignorVoyageCode	:= _bulkReleaseObj.consignorVoyageCode;
	self.deliveryReason			:= _bulkReleaseObj.deliveryReasonDescr;
	self.doorsDirection			:= _bulkReleaseObj.doorsDirection;
	self.eirNumber				:= null;								// looks like this was not set up in CM_YardRequest
	self.needCOU				:= false;								// looks like this was not set up in CM_YardRequest
	self.needGenerator			:= false;								// looks like this was not set up in CM_YardRequest
	self.remarks				:= _reserveDetail.remarks;
		
/*	if requestObj.isKindOf(CM_DeliveryRequest) then
		deliveryObj					:=	requestObj.CM_DeliveryRequest;
		self.clean					:=	deliveryObj.clean;
		self.doISOGroupCheck		:=	deliveryObj.doISOGroupCheck;
		self.heavyRated				:=	deliveryObj.heavyRated;
		self.idMask					:=	deliveryObj.getIdsAsString();
		//self.isoType				:=	deliveryObj.isoType;
		//par 18530
		if reserveDetail &lt;&gt; null then
			self.isoType := reserveDetail.getISOTypeCode;
		else
			self.isoType :=	deliveryObj.isoType;
		endif;
	
		if self.myOperatorGroup = null then
			self.myOperatorGroup		:=	deliveryObj.myOperatorGroup;
		endif;
		
		if deliveryObj.myOperatorGroup &lt;&gt; null then
			self.operatorGroupCode		:=	deliveryObj.myOperatorGroup.code;
		endif;
		
		create allStringsObj transient;
		deliveryObj.ids.getStrings(allStringsObj);
		allStringsObj.copy(self.ids);
		
	elseif requestObj.isKindOf(CM_TIRequest) then
		// There are two properties on CM_TI_Request, neither of which appear relevant ?
		// CM_TIRequest.myTrackedItemIfRelease (type=CM_TrackedItem)
		// CM_TIRequest.trackedItem (type=CM_TrackedItem)
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled release type (' &amp; requestObj.String &amp; ')');
		return;
	endif;
*/
	self.clean					:= _reserveDetail.clean;
	self.heavyRated				:= _reserveDetail.heavyRated;
	self.idMask					:= _reserveDetail.getIdsAsString();
	self.isoType 				:= _reserveDetail.getISOTypeCode();
	//cnwmc5 - PAR 32207 - 11 Sep 2013
	self.isoTypeGroup			:= _reserveDetail.getISOGroupCode();
		
	self.myTransferToTerminal := _bulkReleaseObj.myTransferToTerminal; //cnwrd1 par 25216 if the bulk release has a transfer to terminal need to set it here. 5.8.2010
		
	create allStringsObj transient;
	if _reserveDetail.maskIds &lt;&gt; null then
		_reserveDetail.maskIds.getStrings(allStringsObj);
		allStringsObj.copy(self.ids);
	endif;
/*	
	operatorObj	:=	_bulkReleaseObj.myOperator;
	
	if operatorObj = null then
		if deliveryObj &lt;&gt; null then
			self.operatorCode	:=	deliveryObj.operatorCode;
		endif;
	else
		self.operatorCode	:=	operatorObj.code;
	endif;
*/
	self.myOperatorGroup		:= _bulkReleaseObj.myOperatorGroup;
	self.operatorGroupCode		:= null;
	if self.myOperatorGroup &lt;&gt; null then
		self.operatorGroupCode	:= self.myOperatorGroup.code;
	endif;
	self.operatorCode			:= null;
	if _bulkReleaseObj.myOperator &lt;&gt; null then
		self.operatorCode		:= _bulkReleaseObj.myOperator.code;
	endif;

epilog
	delete allStringsObj;
end;</source>
        <Parameter name="_bulkReleaseObj" type="CM_BulkRelease"/>
        <Parameter name="_reserveDetail" type="CM_ReserveSelection"/>
    </JadeMethod>
    <JadeMethod name="setGateItemDetail" id="cf460401-31df-48af-95f3-057ebcd8f265">
