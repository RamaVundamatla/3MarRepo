//
//04 November 2019	jlgrs1	Initial creation
//
vars

begin
	return null;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="initApp" id="c69cd3c4-d90b-4c7b-9daf-01b5729875cd">
        <updating/>
        <source>initApp() updating;
// -------------------------------------------
// Created 07 September 2004 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
23 Sep 2008	cnwkpd1	PAR #18009 - Allow ini file control of transient check

*/

vars

begin
	inheritMethod();

	if process.userInfo &lt;&gt; null then							
		app.setCnAppAlias(self.class.name &amp; "#" &amp; process.userInfo);	//epr TFS 36655 29/4/19
	endif;		

end;</source>
    </JadeMethod>
    <JadeMethod name="numQueuedRequests" id="c6f6446a-186b-4e7d-b701-be4d762f409a">
        <methodInvocation>mapping</methodInvocation>
        <source>numQueuedRequests(set: Boolean; _value: Integer io) mapping;
// -------------------------------------------
// Created 01 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin


	inheritMethod(set, _value);
/*	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	_value := BGP_ReportRequest.instances.size + BGP_ReportPDFEmailerRequest.instances.size;*/
	

end;</source>
        <Parameter name="set" type="Boolean"/>
