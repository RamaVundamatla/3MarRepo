    <JadeMethod name="getAllSlotAbove" id="e11cdf9a-c5ee-4f63-a76c-3496a5a21f68">
        <source>getAllSlotAbove() : CM_SlotDefnByDeckCellTier;
// ---------------------------------------------------------------------------
// Created:     20 January 2017 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ordDeck, ordCell, ordTier, ordinal, ordinalDeckInt : Integer;
	bay : CM_Bay;
	slot : CM_SlotDefn;
	slotArray : CM_SlotDefnByDeckCellTier;
begin

	create slotArray transient;
	ordDeck := self.ordinalDeck;
	ordCell := self.ordinalCell;
	ordTier := self.ordinalTier;
	
	bay := self.myBay;
	foreach ordinalDeckInt in ordDeck to DeckOnDeck do
		foreach ordinal in ordinalTier + 1 to 99 do
			slot := bay.allSlotsByOrdinal[ordinalDeckInt, ordCell, ordinal];
			if slot = null then
				break;
			endif;
			
			slotArray.addNoDuplicates(slot,false);
		endforeach;
	endforeach;
	
	return slotArray;
epilog

end;</source>
        <ReturnType type="CM_SlotDefnByDeckCellTier"/>
    </JadeMethod>
    <JadeMethod name="getDefaultDirections" id="38361159-a15f-47fd-87f9-785cceb37ca5">
        <source>getDefaultDirections(_dirController : CMIF_DirectionController; _door20 : Boolean output; _door40 : Boolean output; _motor20 : Boolean output ; _motor40 : Boolean output);
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		CCMS 1045 
//
// ---------------------------------------------------------------------------

vars
	dirController :  CMIF_DirectionController;
begin

	dirController := _dirController;
	
	if self.ordinalDeck = DeckOnDeck then
		_door20 := dirController.dirODDoors20AFT; //On Deck Doors20 AFT
		_door40 := dirController.dirODDoors40AFT; //On Deck Doors40 AFT
		_motor20 := dirController.dirODMotor20AFT; //On Deck Motor20 AFT
		_motor40 :=  dirController.dirODMotor40AFT; //On Deck Motors40 AFT
	else
		if self.myBay.isAftBay then
			_door20 := dirController.dirUDDoors20AFTFWD; //Under Deck Doors20 In AftBay FWD
			_door40 := dirController.dirUDDoors40AFT; //Under Deck Doors40 AFT
			_motor20 := dirController.dirUDMotor20AFTAFT; //Under Deck Motor20 In AftBay AFT
			_motor40 :=  dirController.dirUDMotor40AFT; //Under Deck Motor40 AFT
		else
			_door20 := dirController.dirUDDoors20FWDAFT; //Under Deck Doors20 In FwdBay AFT
			_door40 := dirController.dirUDDoors40AFT; //Under Deck Doors40 AFT
			_motor20 := dirController.dirUDMotor20FWDFWD; //Under Deck Motor20 In FwdBay FWD
			_motor40 :=  dirController.dirUDMotor40AFT; //Under Deck Motor40 AFT
		
		endif;
	endif;
	

end;</source>
        <Parameter name="_dirController" type="CMIF_DirectionController"/>
        <Parameter name="_door20" type="Boolean" usage="output"/>
        <Parameter name="_door40" type="Boolean" usage="output"/>
        <Parameter name="_motor20" type="Boolean" usage="output"/>
        <Parameter name="_motor40" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDefinitionXML" id="45c9051a-b751-4dfe-960b-34416c949487">
        <source>getDefinitionXML() : String;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		NOTE FROM VESSEL
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	s7 : String;
begin
	if self.myBay.isAftBay then
		s7 := self.fortyBack.Integer.String;
	else
		s7 := self.fortyFront.Integer.String;
	endif;
	return "&lt;oc&gt;" &amp; self.ordinalCell.String &amp; "&lt;/oc&gt;&lt;ot&gt;" &amp;  self.ordinalTier.String &amp; "&lt;/ot&gt;&lt;na&gt;" &amp; self.unavailable.Integer.String &amp; "&lt;/na&gt;" &amp; 
			 "&lt;wc&gt;" &amp; self.watercooled.Integer.String &amp; "&lt;/wc&gt;&lt;d20&gt;" &amp; self.doors20Aft.Integer.String &amp; "&lt;/d20&gt;" &amp; 
			 "&lt;d40&gt;" &amp; self.doors40Aft.Integer.String &amp; "&lt;/d40&gt;" &amp; 
			 "&lt;f40&gt;" &amp; s7 &amp; "&lt;/f40&gt;&lt;m20&gt;" &amp; self.motor20Aft.Integer.String &amp; "&lt;/m20&gt;" &amp; 
			 "&lt;m40&gt;" &amp; self.motor40Aft.Integer.String &amp; "&lt;/m40&gt;&lt;mt&gt;" &amp; self.mtOnly.Integer.String &amp; "&lt;/mt&gt;&lt;vt&gt;" &amp; self.voltageType.String &amp; "&lt;/vt&gt;&lt;hv&gt;" &amp; self.heavy.Integer.String &amp; "&lt;/hv&gt;" &amp; 
			 "&lt;pw&gt;" &amp; self.power.Integer.String &amp; "&lt;/pw&gt;&lt;rf&gt;" &amp; self.reefer.Integer.String &amp; "&lt;/rf&gt;" &amp; 
			 "&lt;is30&gt;" &amp; self.is30.Integer.String &amp; "&lt;/is30&gt;" &amp; // PAR 19692
			 "&lt;is45&gt;" &amp; self.is45.Integer.String &amp; "&lt;/is45&gt;" &amp; // PAR 19692 
			 "&lt;is53&gt;" &amp; self.is53.Integer.String &amp; "&lt;/is53&gt;" ;  // PAR 19692

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
