    <JadeMethod name="c3_clearLogControlerBol" id="1eebb4dc-03d2-4666-841e-0c9383839155">
        <source>c3_clearLogControlerBol();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2017	jlgns1	Initial creation

*/
vars
	log: CM_Log;
	logCont: CM_LogController;
	logArray: CM_TIArray;
	i: Integer;
	changes: String;
begin
	logCont := "4353.XXXXX".asOid().CM_LogController;  // get from inspecting Log Row Maintenance
	logArray := logCont.allTrackedItems;
	foreach i in 1 to logArray.size do
		log := logArray[i].CM_Log;
		if log.myReleaseBOL &lt;&gt; null then
			changes := changes &amp; log.id &amp; " was " &amp; log.myReleaseBOL.number &amp; CrLf;
			beginTransaction;
			log.setPropertyValue("myReleaseBOL", null);
			commitTransaction;
		endif;
	endforeach;
	app.msgBox(changes, null, 0);
 
end; </source>
    </JadeMethod>
