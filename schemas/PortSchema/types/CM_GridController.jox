    <JadeMethod name="testIsDiffOperator" id="9f26fead-ac1a-4b23-92e2-a4e5a7f0a406">
        <source>testIsDiffOperator(obj: CMIF_AutoMovePlan io);
//In this case, we are testing 40' next LC as well as this LC.
//ASSUMPTIONS:
//That testIsControllerFull method has been called (it checks for differing heights)
//	Changed On	By			Reason
// 	----------	--------	--------------------------------------
//	12/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	topTI : CM_TrackedItem;
	tmpMoveMode : Integer;
	numControllers : Real;
begin

//	if parent.autoPlanTest.testOperator = false then
//		obj.addLogEntry("Operator Test not selected, Skipping.");
//		return;
//	endif;
	obj.updateController(null);
 	//----------------
 	//Call method to retrieve the topmost TI
 	//----------------
	topTI := getTopTI(obj.moveMode);	

	if topTI = null and obj.moveMode &lt;&gt; REAL_MODE then
	 	//----------------
		//Test for a real mode TI
	 	//----------------
	 	tmpMoveMode := REAL_MODE;
		topTI := getTopTI(tmpMoveMode);	

	endif;

	if topTI = null then
	 	//----------------
		//None Here. (if 40, than the same MUST be true, see Assumption above).
	 	//----------------
		obj.updateController(self);
		return;
	endif;
	//--------------
	//At least 1 TI here, check its discharge port
	//--------------
	if not obj.myTrackedItem.hasSameUnderStowAttribute(topTI, TI_Test_Operator) then
		//obj.addLogEntry("Operator of item underneath is different", IsWarning); //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString(Operato_item_underne_differe), IsWarning, Operato_item_underne_differe);
		return;
	endif;
	numControllers := self.calculateMoveLCs(obj.myTrackedItem);
	//-----------------
	//If the TI needs more than 1 controller, then check next location.
	//-----------------
	if numControllers &gt; 1 and not obj.checkingSecondary then
		if  self.myNextController = null then // AKBJULY2002 removed not
			obj.addVerboseLogEntry(app.getErrorString(Next_positi_contai_longer_than), IsError, Next_positi_contai_longer_than);// PAR 17386 
			return;	//No next position. 40' cannot go here.
		endif;
		if self.myNextController.isSuitableForTI(obj) = false then
			//epr par 31492 14/8/13 if not auto planned this error has already been raised and reported
			if obj.isAutoPlanMove then
				obj.addVerboseLogEntry(app.getErrorString1(Suitab_contai_longer_than_foot,self.getFullId), obj.getLogType, Suitab_contai_longer_than_foot); // PAR 5723 PAR 17386		
			endif;
			return;
		endif;
		obj.checkingSecondary := true;
		self.myNextController.testIsDiffOperator(obj);		
		obj.checkingSecondary := false;
		if obj.getController = null then
			//----------------
			//Next operator is different
			//----------------
			return;
		endif;
	endif;
	//----------------
	//Operator is same.
	//----------------
	obj.updateController(self);
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="io"/>
    </JadeMethod>
    <JadeMethod name="testIsDiffOperatorYA" id="da3205a3-0cca-4b72-9265-d69b927eae08">
        <source>testIsDiffOperatorYA(_yaAgent: CM_YAAutoplanAgent input): Boolean;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
//	Changed On	By			Reason
// 	----------	--------	--------------------------------------
//	12/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars

	topTI 			: CM_TrackedItem;
	tmpMoveMode		: Integer;
	numControllers	: Real;
	rtnValue		: Boolean;
begin

	// NOT USED
	
	return false;
	
	topTI := self.getTopTI(QUEUE_MODE);	

	if topTI = null then
		topTI := self.getTopTI(PLANNING_MODE);	
	endif;

	if topTI = null then
	 	//----------------
		//Test for a real mode TI
	 	//----------------
	 	tmpMoveMode := REAL_MODE;
		topTI := self.getTopTI(tmpMoveMode);	
	else
		// Par 12313
		//if topTI.myTranshipExport &lt;&gt; null then	// PAR #23645 CCMS 1116
			//topTI := topTI.myTranshipExport;		// PAR #23645 CCMS 1116
		//endif;									// PAR #23645 CCMS 1116
	endif;

	if topTI = null then
	 	return false;
	endif;
	
	//--------------
	//At least 1 TI here, check its discharge port
	//--------------
	if not _yaAgent.myCurrentCMIFYAAutoPlan.hasSameUnderStowAttribute(topTI, TI_Test_Operator) then
		_yaAgent.addLogEntry(AP_Log_YA_Default,"Operator of item underneath is different", true);
		return true;
	endif;
	
	numControllers := _yaAgent.numControllers;
	//-----------------
	//If the TI needs more than 1 controller, then check next location.
	//-----------------
	if numControllers &gt; 1 and not _yaAgent.checkingSecondary then
		if  self.myNextController = null then // AKBJULY2002 removed not
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Not suitable for 40 foot container", true);
			return true;	//No next position. 40' cannot go here.
		endif;
		if not self.myNextController.isSuitableForTI(null) then
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Not suitable for 40 foot container", true);
			return true;
		endif;
		_yaAgent.checkingSecondary := true;
		rtnValue :=  self.myNextController.testIsDiffOperatorYA(_yaAgent);
		_yaAgent.checkingSecondary := false;
		if rtnValue then
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIsDiffVoyage" id="22be6ba6-9eab-4b73-b11d-ffba21f5f15e">
        <source>testIsDiffVoyage(obj: CMIF_AutoMovePlan input);
//In this case, we are testing 40' next LC as well as this LC.
//ASSUMPTIONS:
//That testIsControllerFull method has been called (it checks for differing heights)
//	Changed On	By			Reason
// 	----------	--------	--------------------------------------
//	12/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	topTI : CM_TrackedItem;
	tmpMoveMode : Integer;
	numControllers : Real;
begin

	if obj.isTestToBeDone(TI_Test_Voyage, self) = false then
		return;
	endif;
	//----------------
	//PAR5395. DQ. ONLY complain about Voyage if we are NOT a stored MT
	//----------------
	if obj.myTrackedItem.isStorage then
		if obj.myTrackedItem.isAttributeTrue(TI_Attrib_IsEmpty) then
			return;
		endif;
	endif;
	obj.updateController(null);
 	//----------------
 	//Call method to retrieve the topmost TI
 	//----------------
	topTI := getTopTI(obj.moveMode);	

	if topTI = null and obj.moveMode &lt;&gt; REAL_MODE then
	 	//----------------
		//Test for a real mode TI
	 	//----------------
	 	tmpMoveMode := REAL_MODE;
		topTI := getTopTI(tmpMoveMode);	
	endif;

	if topTI = null then
	 	//----------------
		//None Here. (if 40, than the same MUST be true, see Assumption above).
	 	//----------------
		obj.updateController(self);
		return;
	endif;
	if not obj.myTrackedItem.hasSameUnderStowAttribute(topTI, TI_Test_Voyage) then
		//obj.addLogEntry("Voyage of item underneath is different", IsWarning); //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString(Voyage_item_underne_differe), IsWarning, Voyage_item_underne_differe);
		return;
	endif;
	numControllers := self.calculateMoveLCs(obj.myTrackedItem);
	if numControllers &gt; 1 and not obj.checkingSecondary then
		if  self.myNextController = null then // AKBJULY2002 removed not
			
			obj.addVerboseLogEntry(app.getErrorString(Next_positi_contai_longer_than), IsError, Next_positi_contai_longer_than);// PAR 17386 
			return;
		endif;
		if self.myNextController.isSuitableForTI(obj) = false then
			//epr par 31492 14/8/13 if not auto planned this error has already been raised and reported
			if obj.isAutoPlanMove then	
				obj.addVerboseLogEntry(app.getErrorString1(Suitab_contai_longer_than_foot,self.getFullId), obj.getLogType, Suitab_contai_longer_than_foot); // PAR 5723 PAR 17386	
			endif;
			return;
		endif;
		obj.checkingSecondary := true;
		self.myNextController.testIsDiffVoyage(obj);		
		obj.checkingSecondary := false;
		if obj.getController = null then
			//----------------
			//Next voyage port is different
			//----------------
			return;
		endif;
	endif;
	//----------------
	//Voyage is same.
	//----------------
	obj.updateController(self);
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testIsDiffVoyageYA" id="23b587a7-7b0e-4887-9a6f-21e32bcb6a03">
        <source>testIsDiffVoyageYA(_yaAgent: CM_YAAutoplanAgent input): Boolean;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
//	Changed On	By			Reason
// 	----------	--------	--------------------------------------
//	12/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars

	topTI			: CM_TrackedItem;
	tmpMoveMode		: Integer;
	numControllers	: Real;
	rtnValue		: Boolean;
begin

	//if not self.myTerminalArea.autoPlanTest.testVoyage then  PAR 25972
		//return false;
	//endif;
	
	//----------------
 	//Call method to retrieve the topmost TI
 	//----------------
	topTI := self.getTopTI(QUEUE_MODE);	
	
	// Changed 09/05/06 DVB
	if topTI = null then
		topTI := self.getTopTI(PLANNING_MODE);	
	endif;

	if topTI = null then
	 	//----------------
		//Test for a real mode TI
	 	//----------------
	 	tmpMoveMode := REAL_MODE;
		topTI := self.getTopTI(tmpMoveMode);
	else
		// Par 12313
		//if topTI.myTranshipExport &lt;&gt; null then	// PAR #23645 CCMS 1116
			//topTI := topTI.myTranshipExport;		// PAR #23645 CCMS 1116
		//endif;									// PAR #23645 CCMS 1116
	endif;

	if topTI = null then
	 	//----------------
		//None Here. (if 40, than the same MUST be true, see Assumption above).
	 	//----------------
		return false;
	endif;

	//----------------
	//PAR5395. DQ. ONLY complain about Voyage if we are NOT a stored MT
	//----------------
	
	// DVB Changed 10/05/2005. Checking top box to see if it is in an empty.
	if topTI.isStorage and topTI.isAttributeTrue(TI_Attrib_IsEmpty) then
		return false;
	endif;	
	if not _yaAgent.myCurrentCMIFYAAutoPlan.hasSameUnderStowAttribute(topTI, TI_Test_Voyage) then
		_yaAgent.addLogEntry(AP_Log_YA_Default,"Voyage of item underneath is different", true);
		return true;
	endif;
	
	numControllers := _yaAgent.numControllers;
	


	return false;


end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIsHazardSegRulesMet" id="712d1b0d-2cfc-40e2-8e22-3f5a7f6c012c">
        <source>testIsHazardSegRulesMet(obj:CMIF_AutoMovePlan input);
// --------------------------------------------------------------------------------
// Created:		10 July 2009 by cnwjo3
//
// Purpose:		check that this location does not break any hazard segragation rules
//
// Returns:		null if rules aren't meet, controller if no problems
vars
	locnId : String;
	
	ti								: CM_TrackedItem;	
	allHazardousTIs					: CM_TISet;
	allErrorWarnings				: CM_ErrorSet;
	error							: CM_Error;
begin
	locnId	:= self.getFullId;
	
	create allHazardousTIs transient;
	create allErrorWarnings transient;
	
	if obj.myTrackedItem.isHazardous then
		allHazardousTIs.add(obj.myTrackedItem);
	endif;	
	
	foreach ti in obj.allOtherTrackedItems where ti.isHazardous do
		if (not allHazardousTIs.includes(ti)) then
			allHazardousTIs.add(ti);
		endif;
	endforeach;

	if allHazardousTIs.isEmpty then
		obj.updateController(self);
		return;//nothing to do
	endif;	

	foreach ti in allHazardousTIs do
		self.validateMoveToForHazTI(ti, true, allErrorWarnings);
	endforeach;
	
	foreach error in allErrorWarnings do
		if error.warningOnly then
			//app.raiseCMWarning1(error.errorCode, error.text, error.fieldName, error.myUserObject, self);		
			//obj.addVerboseLogEntry("Position " &amp; obj.iteration.String &amp; " of " &amp; locnId &amp; ", Warning: " &amp; error.text, IsForLogging); //- cnwmd1, Par 20524
			obj.addVerboseLogEntry(app.getErrorString3(Position_warning_isforloggi,obj.iteration.String, locnId, error.text),IsForLogging, Position_warning_isforloggi);
		else
			//app.raiseCMException1(error.errorCode, error.text, error.fieldName, error.myUserObject);
			//obj.addVerboseLogEntry("Position " &amp; obj.iteration.String &amp; " of " &amp; locnId &amp; ", Error: " &amp; error.text, IsForLogging); //- cnwmd1, Par 20524
			obj.addVerboseLogEntry(app.getErrorString3(Position_error, obj.iteration.String, locnId, error.text), IsForLogging, Position_error);
			obj.updateController(null);
		endif;
	endforeach;	
	
	return;

epilog
	delete allHazardousTIs;
	delete allErrorWarnings;
end;
</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testIsInSpecificGrid" id="9ce0ee81-ebd0-479e-a115-15763f7e5321">
        <source>testIsInSpecificGrid(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2010	cnwer1	Initial creation

*/

vars

begin
	if _yaAgent.myCurrentSpecificRow &lt;&gt; null then
		if self.myGridRow &lt;&gt; _yaAgent.myCurrentSpecificRow then
			_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " is not in the specified grid row of " &amp; _yaAgent.myCurrentSpecificRow.label, true);
			return false;
		endif;
	endif;
			
	if _yaAgent.myCurrentSpecificColumn &lt;&gt; null then
		if self.myGridColumn &lt;&gt; _yaAgent.myCurrentSpecificColumn then
			_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " is not in the specified grid column of " &amp; _yaAgent.myCurrentSpecificColumn.label, true);
			return false;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIsRequirePower" id="5bc2cd93-ae98-4af6-bef1-c42ff1f0f5de">
        <source>testIsRequirePower(obj: CMIF_AutoMovePlan input);
//Test to see if this TI requires Power.
vars

begin

	if obj.isTestToBeDone(TI_Test_Power, self) = false then
		
		return;
	endif;

	

	if (not obj.myTrackedItem.isAttributeTrue(TI_Attrib_RequiresPower)) then
		//----------------
		//TI does NOT require power...
		//----------------
		obj.updateController(self);
		return;
	endif;
	//----------------
	//TI does require power
	//----------------
	
	self.myTerminalArea.testIfRequirePower(obj, self);
	// AKB September 2001. Fork Lift Stack Enhancements from here
	// Fork Lift Stacks have power points and a container can be connected to any power point in the yard area, not just the power next to it as with straddles
	if not self.myTerminalArea.testPowerPointsAvail(obj,self) then
		obj.updateController(null);
		return;
	endif;

	obj.updateController(self);

epilog	

end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testIsRequirePowerYA" id="705322ed-1d81-4876-b39e-4a2e76f70263">
        <source>testIsRequirePowerYA(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
//Test to see if this TI requires Power.
vars
	locnId	:	String;
	lPowerPoints	: ObjectArray;
	lGap	: Object;
	lPowerDamaged	: Integer;
begin

	//cnwrd1 par 28295 18.10.2011
	/*if not self.myTerminalArea.autoPlanTest.testPower then
		return false;
	endif;*/
	
	locnId := self.getFullId;

	if (not _yaAgent.myCurrentCMIFYAAutoPlan.isAttributeTrue(TI_Attrib_RequiresPower)) then
		//----------------
		//TI does NOT require power...
		//----------------
		return false;
	endif;
	//----------------
	//TI does require power
	//----------------
	if self.myTerminalArea.testIfRequirePowerYA(_yaAgent, self) then
		return true;
	endif;
	// Fork Lift Stacks have power points and a container can be connected to any power point in the yard area, not just the power next to it as with straddles

	return self.myTerminalArea.testPowerPointsAvailYA(_yaAgent,self);




epilog	
	delete lPowerPoints;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIsRequireTower" id="b3120087-6774-4c01-aba3-61a91dc31b7a">
        <source>testIsRequireTower(obj:CMIF_AutoMovePlan  input);
//Test to see if this TI requires Reefer Tower services. Is so, this method determines
//that the tower exists, is not already used, is not sick, and if it has another ti
//hooked to the other side, that its temperature is compatible with this ti.
vars
begin

	if obj.isTestToBeDone(TI_Test_Tower, self) = false then
		return; 
	endif;
	obj.updateController(null);
	
	if not self.myTerminalArea.testTowerRequired(obj , self) then
		return;
	endif;

	//------------------
	//If we have got this far, then OK
	//------------------
	obj.updateController(self);
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testLocationYA" id="8d92b8e3-3252-4cd2-9246-2d59564d751a">
        <source>testLocationYA(_yaAgent : CM_YAAutoplanAgent input; _isIn : Boolean) : Boolean;
// -------------------------------------------
// Created 30 March 2005 by cnwdvb1
// -------------------------------------------
vars

	rtnValue		: Boolean;
	ti 				: CM_TrackedItem;
	maxHeightGridAreaYAInFeet  : Real;
	firstTi : CM_TrackedItem;
	griddedStackHeight1 : CM_GriddedTAStackHeight;
	griddedStackHeight2 : CM_GriddedTAStackHeight;
	restrictionName1 : String;
	restrictionName2 : String;
begin

	if not inheritMethod(_yaAgent, _isIn) then
		return false;
	endif;
	
	if self.mySubBlockStack &lt;&gt; null then
		_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " is Sub-block stacked.", true);
		return false;
	endif;
	
	//cnwjo3, par 21975
	ti := _yaAgent.getMyCurrentTrackedItem();
	if ti &lt;&gt; null  and not _yaAgent.checkingSecondary and self.testStrictGrids(_yaAgent, ti, self) then			// 31/03/2014 cnwmh5 #33758 Added not _yaCheckingSecondary  
		return false;
	endif;
	
	// 25/10/2011 cnwmh5 #28509 - Add checking for not going over height
	if ti &lt;&gt; null then
		maxHeightGridAreaYAInFeet := self.getMyGridArea().getMaxHeightGridAreaYAInFeet();
		if maxHeightGridAreaYAInFeet &gt; 0 and not self.canAccessHeight(maxHeightGridAreaYAInFeet - ti.getActualHeight(), PLANNING_MODE) then
			_yaAgent.addLogEntry(AP_Log_YA_Default,ti.id &amp; ". Location " &amp; self.getFullId() &amp; " height access restricted, maximum height " &amp; 
				self.getMyGridArea().getMaxHeightGridAreaYAInFeet().String &amp; " ft.", true);
			return false;
		endif;
	endif;
	
	//28 Sep 2020	NDL	TFS 49984
	if ti &lt;&gt; null and not self.getMyTerminalArea.allGriddedTAStackHeights.isEmpty then
		griddedStackHeight1 := self.getGriddedStackHeightObj( firstTi );
		if firstTi &lt;&gt; null then
			griddedStackHeight2 := self.getMyTerminalArea.allGriddedTAStackHeights.getFirstMatching( ti );
			if griddedStackHeight1 &lt;&gt; griddedStackHeight2 then	
				if ( griddedStackHeight1 &lt;&gt; null and griddedStackHeight1.neverMix ) or ( griddedStackHeight2 &lt;&gt; null and griddedStackHeight2.neverMix ) then
					if griddedStackHeight1 &lt;&gt; null then
						restrictionName1 := griddedStackHeight1.name;
					else
						restrictionName1 := app.getErrorString(NoMatch);
					endif;
					if griddedStackHeight2 &lt;&gt; null then
						restrictionName2 := griddedStackHeight2.name;
					else
						restrictionName2 := app.getErrorString(NoMatch);
					endif;
					_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " " &amp; app.getErrorString2( Restr_does_not_permi_mixin_car, restrictionName1, restrictionName2), true);
					return false;
				endif;
			endif;
		endif;
	endif;
	
	if self.hasRestrictions(LABOUR_RESTRICTION) then  //cnwrd1 par 28295 13.10.2011
		_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " has labour restriction(s) in place", true);
		//return false;
		_yaAgent.addToPassedWithRestrictionLoc(self);//cnwrd1 par 29269 14.3.2012
	endif;	
	
	/* tem autoplantest settings deimplimented
	if 	self.myTerminalArea.autoPlanTest.testLabourRestriction and self.hasRestrictions(LABOUR_RESTRICTION) then
		_yaAgent.addLogEntry(self.getFullId &amp; " has labour restriction(s) in place", true);
		return false;
	endif;	
	*/

	if _isIn then
		if self.testIsRequirePowerYA(_yaAgent) then
			return false;
		endif;
		
		
		if not _yaAgent.checkingSecondary then
		
			//epr 22/2/10 ccms 1025
			if not self.testIsInSpecificGrid(_yaAgent) then
				return false;
			endif;
			
			if self.isStackFullYA(_yaAgent) then
				return false;
			endif;
			//epr par 19331 9/4/09 moved to only test when primary location
			if self.testIs45YA(_yaAgent) then
				return false;
			endif;
			if self.testIs30YA(_yaAgent) then // PAR 16415
				return false;
			endif;
			if self.testIs53YA(_yaAgent) then // PAR 16415
				return false;
			endif;
			
			if not _yaAgent.useOverstowRules then
				//-cnwml2 PAR25712
				//This is now redundant, as there is criteria which can be used to autoplan based on weight
				// Test whether we can stick a tracked item on top of another one.
				//if not self.testOverstowWeightInRangeYA(_yaAgent) then
				//	_yaAgent.addLogEntry('Unable to overstow due to weight restriction ', true);
				//	return false;
				//endif;
				
				/*  PAR 26373 this is redundant. Only do oberstow checking using the overstow rules
				if self.testIsDiffVoyageYA(_yaAgent) then
					return false;
				endif;
					
				if self.testIsDiffIMEXYA(_yaAgent) then
					return false;
				endif;
					
				if self.testIsDiffCmdtyGroupYA(_yaAgent) then
					return false;
				endif;
			
				if self.testIsDiffDischPortYA(_yaAgent) then
					return false;
				endif;
				*/
			else
				
				//epr ccms 1025 26/1/09
				//if the front end can overstow does not mean the backend can
				if not _yaAgent.canOverstow(self) then
					// This is the new overstow stuff
					return false;
				endif;
				
			endif;
		else
			//testing secondary i.e 40, 30, 53ft backend 
			//if there are lcs to ignore i.e. we can't go there and this is here return false
			
			if _yaAgent.allLCsToIgnore.includes(self) then
				_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " is in the collection of locations that will restrict moves", true);
				return false;
			endif;
		endif;
	endif;
	
	//--------------------
	//No restriction, check next controller....
	//--------------------
		
	if _yaAgent.numControllers &gt; 1 and not _yaAgent.checkingSecondary then
		if self.myNextController = null then 
			_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " has no next location", true);
			_yaAgent.checkingSecondary := false;
			return false;	//No next position. 40' cannot go here.
		endif;
		//-------------
		//Recursive call, on next controller
		//-------------
		_yaAgent.checkingSecondary := true;
		rtnValue :=  self.myNextController.testLocationYA(_yaAgent, _isIn);

		//cnwjo3 par 25084.  It appears _yaAgent.myCurrentAllocation can be null.  see par 19645
		if _yaAgent.myCurrentAllocation &lt;&gt; null then		
			// Only need to do back end as front should be covered cause we are currently processing.
			if not self.myNextController.allYardAllocations.includes(_yaAgent.myCurrentAllocation) then
				_yaAgent.addLogEntry(AP_Log_YA_Default,"Back end not covered by allocation " &amp; _yaAgent.myCurrentAllocation.code, true); // PAR 17386
				_yaAgent.checkingSecondary := false;
				return false;
			endif;
		endif;
		
		_yaAgent.checkingSecondary := false;
		if not rtnValue then
			return false;
		endif;
	endif;
	
	return true;

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_isIn" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testMyNextController" id="30cbe35b-5bf6-406b-bcd0-265b68582d56">
        <source>testMyNextController(pController : Class) : Boolean;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		Ask the question do I have a certain controller next to me?
//				By passing in the class of the controller - Stack, Gap Tower etc this will check the next controller in the 
//				chain. If it is of the passed in type  then pass true else false
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myNextController &lt;&gt; null 
	and self.myNextController.isKindOf(pController) then
		return true;	
	endif;
	return false;


end;</source>
        <Parameter name="pController" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testMyPreviousController" id="92baf9a3-823e-40d0-8f1e-e51950e2b711">
        <source>testMyPreviousController(pController : Class) : Boolean;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		Ask the question do I have a certain controller previous to me?
//				By passing in the class of the controller - Stack, Gap Tower etc this will check the previous controller in the 
//				chain. If it is of the passed in type  then pass true else false
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myPreviousController &lt;&gt; null 
	and self.myPreviousController.isKindOf(pController) then
		return true;	
	endif;
	return false;


end;</source>
        <Parameter name="pController" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testOverstowLCAvailability" id="71504c76-53c1-4ab5-966c-cd940b0f72a2">
        <source>testOverstowLCAvailability() : Integer;
// ---------------------------------------------------------------------------
// Created:		15 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="testOverstowPlannedOrQueued" id="6785921d-8ebf-48b4-9a40-5f4651c1d1f1">
        <source>testOverstowPlannedOrQueued(obj: CMIF_AutoMovePlan input);
//Test that the box under us is NOT Queued or Planned
//	Changed On	By			Reason
// 	----------	--------	--------------------------------------
//	12/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	topTI		:	CM_TrackedItem;
	tmpMoveMode :	Integer;
	aLocation 	: CM_LocationsController;
	futureMove	: CM_FutureMove;
begin
	if obj.isTestToBeDone(TI_Test_OverstowPlnQue, self) = false then
		return;
	endif;

	obj.updateController(null);
	//----------------
	//The call checks that the height in the 1st stack, is available in the 2nd 
	//stack if we are dealing with a 40' ti.
	//----------------
	if obj.iteration = 1 then
		if self.numTIs = 0 and self.numPlannedTIs = 0 and self.numQueuedTIs = 0 then
			//------------------
			//If we are at ground level, then no weight to test! All OK
			//------------------
			obj.updateController(self);
			return;
		endif;
	endif;

	topTI := getTopTI(obj.moveMode);

	if topTI = null and obj.moveMode &lt;&gt; REAL_MODE then
	 	//----------------
		//Test for a real mode TI
	 	//----------------
	 	tmpMoveMode := REAL_MODE;
		topTI := getTopTI(tmpMoveMode);	
	endif;

	if topTI = null then
	 	//----------------
		//None Here. (if 40, than the same MUST be true, see Assumption above).
	 	//----------------
		obj.updateController(self);
		return;
	endif;
	//--------------
	//At least 1 TI here, check its planned or queued
	//--------------
	aLocation := topTI.getPrimaryLocation(PLANNING_MODE);
	if ( aLocation &lt;&gt; null and obj.moveMode &lt;&gt; PLANNING_MODE) then
		if aLocation &lt;&gt; self and (not obj.myTrackedItem.isRehandle) then 
			//obj.addVerboseLogEntry("You are trying to place cargo on top of " &amp; topTI.id.trimRight &amp; " which is Planned to " &amp; aLocation.getFullId, IsWarning, 0); //- cnwmd1, Par 20524
			obj.addVerboseLogEntry(app.getErrorString2(Trying_place_cargo_which_plann,topTI.id.trimRight, aLocation.getFullId), IsWarning, Trying_place_cargo_which_plann);
			return;
		endif;
	endif;

	foreach futureMove in topTI.allQueuedFutureMoves do
		aLocation := futureMove.CM_FutureMoveQueued.allLocationsControllers.first;
		if (aLocation &lt;&gt; null) then //and obj.moveMode &lt;&gt; QUEUE_MODE) then
			if aLocation &lt;&gt; self then
				//obj.addVerboseLogEntry("You are trying to place cargo on top of " &amp; topTI.id.trimRight &amp; " which is Queued to " &amp; aLocation.getFullId, IsWarning, 0); //- cnwmd1, Par 20524
				obj.addVerboseLogEntry(app.getErrorString2(Trying_place_cargo_which_queue,topTI.id.trimRight, aLocation.getFullId), IsWarning, Trying_place_cargo_which_queue);
				return;
			endif;
		endif;
	endforeach;

	//-------------
	//Yep, not planned/queued
	//-------------
	obj.updateController(self);
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testOverstowPlannedQueuedYA" id="bad30824-c3d0-4802-aad5-51f268570b91">
        <source>testOverstowPlannedQueuedYA(_yaAgent: CM_YAAutoplanAgent input): Boolean;
// -------------------------------------------
// Created 31 March 2005 by cnwdvb1
// -------------------------------------------
//	Changed On	By			Reason
// 	----------	--------	--------------------------------------
//	12/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	topTI		:	CM_TrackedItem;
	tmpMoveMode :	Integer;
	aLocation 	: CM_LocationsController;
	futureMove	: CM_FutureMove;
begin
	//-cnwml2 PAR25715
	//if not self.myTerminalArea.autoPlanTest.testPlannedOrQueuedOverstow and not _yaAgent.myCurrentAllocation.isTestOverstowWeight then
	//	return false;
	//endif;

	//----------------
	//The call checks that the height in the 1st stack, is available in the 2nd 
	//stack if we are dealing with a 40' ti.
	//----------------
	if _yaAgent.iteration = 1 then
		if self.numTIs = 0 and self.numPlannedTIs = 0 and self.numQueuedTIs = 0 then
			return false;
		endif;
	endif;

	// Auto planning so use queued mode.
	topTI := getTopTI(QUEUE_MODE);

	if topTI = null then
	 	//----------------
		//Test for a real mode TI
	 	//----------------
	 	tmpMoveMode := REAL_MODE;
		topTI := getTopTI(tmpMoveMode);	
	else
		// Par 12313
		//if topTI.myTranshipExport &lt;&gt; null then	// PAR #23645 CCMS 1116
			//topTI := topTI.myTranshipExport;		// PAR #23645 CCMS 1116
		//endif;									// PAR #23645 CCMS 1116
	endif;

	if topTI = null then
	 	//----------------
		//None Here. (if 40, than the same MUST be true, see Assumption above).
	 	//----------------
		return false;
	endif;
	//--------------
	//At least 1 TI here, check its planned or queued
	//--------------
	aLocation := topTI.getPrimaryLocation(PLANNING_MODE);
	if ( aLocation &lt;&gt; null) then
		if aLocation &lt;&gt; self and (not _yaAgent.myCurrentCMIFYAAutoPlan.isRehandle) then 
			_yaAgent.addLogEntry(AP_Log_YA_Default,"You are trying to place cargo on top of " &amp; topTI.id.trimRight &amp; " which is Planned to " &amp; aLocation.getFullId, true);
			return true;
		endif;
	endif;

	foreach futureMove in topTI.allQueuedFutureMoves do
		aLocation := futureMove.CM_FutureMoveQueued.allLocationsControllers.first;
		if (aLocation &lt;&gt; null) then //and obj.moveMode &lt;&gt; QUEUE_MODE) then
			if aLocation &lt;&gt; self then
				_yaAgent.addLogEntry(AP_Log_YA_Default,"You are trying to place cargo on top of " &amp; topTI.id.trimRight &amp; " which is Queued to " &amp; aLocation.getFullId, true);
				return true;
			endif;
		endif;
	endforeach;

	//+cnwml2 PAR25712
	if topTI.isOverDimensions then
		_yaAgent.addLogEntry(AP_Log_YA_Default,"You are trying to place cargo on top of " &amp; topTI.id.trimRight &amp; " which is Overdimensional", true);
		return true;
	endif;
	
	//-------------
	//Yep, not planned/queued
	//-------------
	return false;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testOverstowWeight" id="350b4440-05ce-46ac-b7d2-ba4d8c2dfe2d">
        <source>testOverstowWeight(obj : CMIF_AutoMovePlan input);
//Test that the box under us is LIGHTER or == our weight.
//	Changed On	By			Reason
// 	----------	--------	--------------------------------------
//	12/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	topTI	:	CM_TrackedItem;
	tmpMoveMode :	Integer;
begin
	if obj.isTestToBeDone(TI_Test_OverstowWeight, self) = false then
		return;
	endif;
	//----------------
	//The call checks that the height in the 1st stack, is available in the 2nd 
	//stack if we are dealing with a 40' ti.
	//----------------
	if obj.iteration = 1 then
		if self.numTIs = 0 and self.numPlannedTIs = 0 and self.numQueuedTIs = 0 then
			//------------------
			//If we are at ground level, then no weight to test! All OK
			//------------------
			obj.updateController(self);
			return;
		endif;
	endif;

	topTI := self.getTopTI(obj.moveMode);	

	if topTI = null and obj.moveMode &lt;&gt; REAL_MODE then
	 	//----------------
		//Test for a real mode TI
	 	//----------------
	 	tmpMoveMode := REAL_MODE;
		topTI := self.getTopTI(tmpMoveMode);	
	else
		// Par 12313
		//if topTI &lt;&gt; null and topTI.myTranshipExport &lt;&gt; null then	// PAR #23645 CCMS 1116
			//topTI := topTI.myTranshipExport;						// PAR #23645 CCMS 1116
		//endif;													// PAR #23645 CCMS 1116
	endif;

	if topTI = null then
	 	//----------------
		//None Here. (if 40, than the same MUST be true, see Assumption above).
	 	//----------------
		obj.updateController(self);
		return;
	endif;
	//--------------
	//At least 1 TI here, check its weight is LESS than OR EQUAL to this ti
	//weight
	//--------------
	if topTI.totalWeight &gt; obj.myTrackedItem.totalWeight then
		/*obj.addVerboseLogEntry("Weight of " &amp; topTI.id.trimRight &amp; 
				" already in position is greater than " &amp; obj.myTrackedItem.id.trimRight &amp; 
				". Must be less of equal to.", IsWarning, 0); */ //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString2(Weigh_alrea_posit_great_than_m,topTI.id.trimRight, obj.myTrackedItem.id.trimRight), IsWarning, Weigh_alrea_posit_great_than_m);
		obj.updateController(null);
		return;
	endif;
	//-------------
	//Yep, weight is fine.
	//-------------
	obj.updateController(self);

end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testOverstowWeightInRangeYA" id="05116b3f-236a-458e-af10-d4dd0a67afbb">
        <source>testOverstowWeightInRangeYA(_yaAgent: CM_YAAutoplanAgent input): Boolean;
// -------------------------------------------
// Created 19 May 2005 by cnwdvb1
// -------------------------------------------
//	Changed On	By			Reason
// 	----------	--------	--------------------------------------
//	12/05/2010	cnwdap1		CCMS 1116 Tranship changes
//	30/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars

	topTI			: CM_TrackedItem;
	underStowWeight	: Integer;
	currentItemWeight : Decimal[14,4];
	tmpMoveMode		: Integer;
	minimumWeight	: Decimal[12,2];
	weightRange		: CM_WeightRange;
	measure			: CM_MeasurementType;				// PAR #31155

begin
	
	if not _yaAgent.myCurrentAllocation.isTestOverstowWeight then
		return true;
	endif;
	
	_yaAgent.addLogEntry(AP_Log_YA_Default,'Checking overstow weight restrictions', true);
	
	// Auto planning so use queued mode.
	topTI := getTopTI(QUEUE_MODE);

	// Changed 09/05/06 DVB
	if topTI = null then
		topTI := self.getTopTI(PLANNING_MODE);	
	endif;
	
	if topTI = null then
	 	//----------------
		//Test for a real mode TI
	 	//----------------
	 	tmpMoveMode := REAL_MODE;
		topTI := self.getTopTI(tmpMoveMode);
	else
		// Par 12313
		//if topTI.myTranshipExport &lt;&gt; null then	// PAR #23645 CCMS 1116
			//topTI := topTI.myTranshipExport;		// PAR #23645 CCMS 1116
		//endif;									// PAR #23645 CCMS 1116
	endif;

	if topTI = null then
	 	//----------------
		//None Here. (if 40, than the same MUST be true, see Assumption above).
	 	//----------------
		return true;
	endif;
	
	currentItemWeight	:= _yaAgent.myCurrentCMIFYAAutoPlan.totalWeight();
	underStowWeight		:= topTI.totalWeight.Integer;
	
	//weightRange := app.myRoot.allWeightRanges.getAtKeyGeq(underStowWeight);		// PAR #31155
	measure := app.getDefaultMeasurementForType(Type_Weight);						// PAR #31155
	weightRange := measure.allWeightRanges.getAtKeyGeq(measure, underStowWeight);	// PAR #31155
	
	if weightRange = null then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'No weight range defined for ' &amp; underStowWeight.String, false);
		return false;
	endif;
	
	minimumWeight := (underStowWeight - (underStowWeight * (weightRange.percentage / 100)));
	
	if not (currentItemWeight &gt;= minimumWeight) then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Minimum overstow weight for understow tracked item is ' &amp; minimumWeight.String, true);
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Current item weight is ' &amp; currentItemWeight.String, true);
		return false;
	endif;
	
	 return true;
	
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testStrictGrids" id="2ae068b4-ba43-479d-ac0b-3a420f42ef6d">
        <source>testStrictGrids(_yaAgent: CM_YAAutoplanAgent input; _ti : CM_TrackedItem; _controller : CM_LocationsController): Boolean;
// --------------------------------------------------------------------------------
// Created:		19 February 2010 by cnwjo3
//
// Purpose:		par 21975.  Currently if you attempt to place container into a slot that is defined as strict an
//				error message is displayed.  Previously if you auto-plan a container to a strict slot it was not rejecting the autoplan.
//				This method not verifies that the TI that you are attempting to place into a slot fits the strict rules
//
//				NOTE: If method returns 'true' then autoplan has failed in this place/slot.  If return false then it is successful.
vars

begin
	if _ti.isOverSizedContainer() then // is a 45 etc
		if  self.myTerminalArea &lt;&gt; null 
		and self.myTerminalArea.hasOverhangingBackends() 
		and self.offsetFlexi = self.myTerminalArea.locationLength then
			if not self.allTrackedItems.includes(_ti)  and not self.allTrackedItemOSBackEnds.includes(_ti) then
				_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString2(ERR_TI_CANNOT_PLACE_OVERHANG, _ti.id, self.getFullId()),true);
				return true;
			endif;
		endif;
		
		
		if self.isOKForOverSizedCargo() then // Strictly defined for 30, 45, 53
			if not self.allTrackedItemOSBackEnds.isEmpty() then // something over hanging
				if self.is30ft and _ti.isAttributeTrue(TI_Attrib_IsThirty) then // Strict for 30s and moving a 30 footer
					if self.offsetFlexi &gt; self.offset30 then // over hanging offset is crossing over my 30 foot strict offset
						_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString5(ERR_OVERHANG_STRICT_GRID, _ti.id, "30", "30", "30",self.getFullId()),true);
						return true;
					endif;
				elseif self.is45ft and _ti.isAttributeTrue(TI_Attrib_IsFortyFive) then // Strict for 45s and moving a 45 footer
					if self.offsetFlexi &gt; self.offset45 then // over hanging offset is crossing over my 45 foot strict offset
						_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString5(ERR_OVERHANG_STRICT_GRID, _ti.id, "45", "45", "45",self.getFullId()),true);
						return true;
					endif;
				elseif self.is53ft and _ti.isAttributeTrue(TI_Attrib_IsFiftyThree) then // Strict for 53s and moving a 53 footer
					if self.offsetFlexi &gt; self.offset53 then // over hanging offset is crossing over my 53 foot strict offset
						_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString5(ERR_OVERHANG_STRICT_GRID, _ti.id, "53", "53", "53",self.getFullId()),true);
						return true;
					endif;
				endif;
			endif;
		endif;
	endif;


	if self = _controller
	and self.is40ft and _ti.isForty() then
		if self.offset40 = CM_LocationsController.Offset40_Unavailable then
			_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString5(ERR_STRICT_GRID, _ti.id, "40", "40", "40",self.getFullId()),true);
			return true;
		elseif self.offsetFlexi &gt; self.offset40 then // over hanging offset is crossing over my 40 foot strict offset
			_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString5(ERR_OVERHANG_STRICT_GRID, _ti.id, "40", "40", "40",self.getFullId()),true);
			return true;
		endif;
	endif;

	if self = _controller
	and self.is20ft and _ti.isTwenty() then
		if self.offsetFlexi &gt; 0 then // over hanging offset is crossing over my 20 foot strict offset
			_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString5(ERR_OVERHANG_STRICT_GRID, _ti.id, "20", "20", "20",self.getFullId()),true);
			return true;
		endif;
	endif;

	return false;  //everything is OK
end;
</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_controller" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testTAAccess" id="d2471274-7808-4a61-a39d-19cbbd29049e">
        <source>testTAAccess(obj: CMIF_AutoMovePlan input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2008	cnwrd1	Initial creation
par #16861

*/

vars

begin

	if (not self.myTerminalArea.CM_GridArea.hasAccessLeft) and (not self.myTerminalArea.CM_GridArea.hasAccessRight) then
		//obj.addLogEntry("Terminal Area has no access from either side.", IsWarning);	 //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString(Termi_area_acces_from_eithe_si), IsWarning, Termi_area_acces_from_eithe_si);	
	endif;
	
epilog

end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
