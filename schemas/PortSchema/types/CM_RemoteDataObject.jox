    <JadeMethod name="addError" id="0b05d578-3c6d-4c43-8dc5-010f861988a6">
        <source>addError(pErrorCode : Integer; pText : String; _errorSet : CM_ErrorSet input) protected;

vars
	err	: CM_Error;

begin

	create err transient;
	err.set(pErrorCode, pText, false, null, null, null);
	_errorSet.add(err);
end;</source>
        <access>protected</access>
        <Parameter name="pErrorCode" type="Integer"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="convertDate" id="e529f332-5407-42f3-b69c-928147110db5">
        <source>convertDate(_date : String) : Date;

vars

	day, month, year,
	hour, minute, sec	: Integer;
	timeStamp			: TimeStamp;
	date				: Date;
	time				: Time;
	
begin

	if _date.length = 8 then	
		year 	:= _date[1:4].Integer;
		month	:= _date[5:2].Integer;
		day		:= _date[7:2].Integer;
				
		date.setDate(day, month, year);
		return date;
	endif;
	return null;
end;</source>
        <Parameter name="_date" type="String"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="convertTime" id="a6bd4596-af55-48ba-8387-5ed803f27edc">
        <source>convertTime(_time : String) : TimeStamp;

vars

	day, month, year,
	hour, minute, sec	: Integer;
	timeStamp			: TimeStamp;
	date				: Date;
	time				: Time;
	
begin

	if _time.length = 14 then	
		year 	:= _time[1:4].Integer;
		month	:= _time[5:2].Integer;
		day		:= _time[7:2].Integer;
		hour	:= _time[9:2].Integer;
		minute	:= _time[11:2].Integer;
		sec		:= _time[13:2].Integer;
		
		date.setDate(day, month, year);
		time.setTime(hour, minute, sec, 0);
		timeStamp.setDate(date);
		timeStamp.setTime(time);
		return timeStamp;
	endif;
	return null;
end;</source>
        <Parameter name="_time" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getAttributes" id="60179462-1f2c-46f2-8314-d8d49339ec42">
        <source>getAttributes(_typeString : String; _class, _type : String output);

constants

	Equals = '=';
	Space = ' ';
	
vars

	pos 		: Integer;
	value,	
	attribute,
	first,
	second,
	str1,
	str2,
	attribute1,
	attribute2	: String;

begin

	if _typeString = null then
		return;
	endif;
	_class	:= null;
	_type 	:= null;
	pos := 1;
	_typeString.scanUntil(Space,pos);
	if pos &lt;&gt; 0 then
		_typeString.scanWhile(Space, pos);
	endif;
	if pos &lt;&gt; 0 and _typeString.length &gt; pos + 1 then
		first := _typeString[1: pos - 1];
		second := _typeString[pos: end];
	else
		first := _typeString;
	endif;

	if first &lt;&gt; null then
		str1 := getValue(first, attribute1);
	endif;
	if second &lt;&gt; null then
		str2 := getValue(second, attribute2);
	endif;
	
	if attribute1.trimBlanks = 'class' then
		_class := str1.trimBlanks;		
	elseif attribute1.trimBlanks = 'type' then
		_type := str1.trimBlanks;
	endif;
	
	if attribute2.trimBlanks = 'class' then
		_class := str2.trimBlanks;
	elseif attribute2.trimBlanks = 'type' then
		_type := str2.trimBlanks;
	endif;
	
end;</source>
        <Parameter name="_typeString" type="String"/>
        <Parameter name="_class" type="String" usage="output"/>
        <Parameter name="_type" type="String" usage="output"/>
    </JadeMethod>
