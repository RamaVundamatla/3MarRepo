    <JadeMethod name="btnDamage_click" id="6d5456a6-2c3b-4e74-ac30-0cef4977c554">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDamage_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     28 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	term : CM_Terminal;
	user : CM_User;

begin

	//27 Nov 2017	NDL	TFS 7590 - Kludge to get a valid terminal to validate security against.
	term := self.myTerminal;
	if term = null then
		// This is a system based form, so couuld expect no terminal to be set, if has come directly from the main menyu.
		user := app.myPassport.myUser;
		if user &lt;&gt; null and not user.allUserTerminals.isEmpty then
			term := user.allUserTerminals.first.myTerminal;
		endif;
	endif;
	
	self.myAssistant.showDamageEntryForm(self, CMUI_DamageCodesForm.Mode_Update, term, null, self.myWagonMaster, null, self.myMasterMenuAction, false); // ### TFS 54887 21SEP2022 NAVAB1 reversing out CMUI_DamageCodesAdvanceForm

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
