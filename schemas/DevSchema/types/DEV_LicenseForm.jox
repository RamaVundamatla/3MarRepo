    <JadeMethod name="outputLicenses" id="6752e094-df96-4b8d-b6bc-ded0b460ca00">
        <source>outputLicenses(_licSet : DEV_LicenseDtlSet) protected;
// ---------------------------------------------------------------------------
// Created:     06 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// ### JIRA 33543 12DEC2024 NAVAB1 change to use constants
vars
	theRemoteObject	: Object;
	licDtl			: DEV_LicenseDtl;
	prodCode,
	prodDescr,
	key,
	licStr			: String;
	expiryDate		: Date;
	tmpArray		: BooleanArray;
	dateArray : DateArray;

begin

	if _licSet = null or
	   (_licSet &lt;&gt; null and _licSet.isEmpty) then
	   	app.msgBox('No licenses to output', 'Error', 0);
		return;
	endif;
	
	theRemoteObject := self.getRemoteObject();
	
	if theRemoteObject = null then
		return;
	endif;
	
	self.txtLicense.text := null;
	
	create tmpArray transient;
	create dateArray transient;	//17 Jun 2020	NDL	TFS 49569
	
	foreach licDtl in _licSet do
		tmpArray.clear;
		expiryDate := licDtl.expiryDate;
		licDtl.allDetails.copy(tmpArray);
		
		if licDtl.type = DEV_LicenseEntity.LicenseType_System then
			if licDtl.myClient.hasSiteLicense then
				tmpArray.atPut(PmSite - Mod_BaseView, true);
			endif;
			self.setNumTerminals(licDtl.myClient.numTerminals, tmpArray);
		endif;
		
		if licDtl.type = DEV_LicenseEntity.LicenseType_Subscription then
			dateArray.clear();
			licDtl.allExpiries.copy(dateArray);
			prodCode := ProductCode_Subs;
			prodDescr := ProductStr_SUBS ;	//24 Nov 2020	NDL	TFS 49356
			theRemoteObject.sendMsgWithParams('generateSubsKey', licDtl.name, ProductCode_Subs, expiryDate, tmpArray, dateArray );
		// ### JIRA 33543 12DEC2024 NAVAB1i
		elseif licDtl.type = DEV_LicenseEntity.LicenseType_EWS then
			dateArray.clear();
			licDtl.allExpiries.copy(dateArray);
			prodCode := ProductCode_EWS;
			prodDescr := ProductStr_EWS;
			theRemoteObject.sendMsgWithParams('generateSubsKey', licDtl.name, ProductCode_EWS, expiryDate, tmpArray, dateArray );
		elseif licDtl.type = DEV_LicenseEntity.LicenseType_EDI then
			prodCode := ProductCode_JMT_EDI;
			prodDescr := ProductStr_JMT_EDI ;	//24 Nov 2020	NDL	TFS 49356
			theRemoteObject.sendMsgWithParams('generateKey', licDtl.name, ProductCode_JMT_EDI, expiryDate, tmpArray );
		else
			prodCode := ProductCode_JMT;
			prodDescr := ProductStr_JMT ;	//24 Nov 2020	NDL	TFS 49356
			theRemoteObject.sendMsgWithParams('generateKey', licDtl.name, ProductCode_JMT, expiryDate, tmpArray );
		endif;
		key := theRemoteObject.getPropertyValue('data1').String;
		licStr := licStr &amp;
				  'License For  : ' &amp; prodDescr &amp; CrLf &amp;
				  'License Name : ' &amp; licDtl.name &amp; CrLf &amp;
		          'License Key  : ' &amp; key &amp; CrLf &amp; CrLf;

	endforeach;

	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  License Details &gt;&gt;' &amp; CrLf &amp; licStr);

	self.txtLicense.text := licStr;

epilog
	delete theRemoteObject;
	delete tmpArray;
	delete dateArray;

end;</source>
        <access>protected</access>
        <Parameter name="_licSet" type="DEV_LicenseDtlSet"/>
    </JadeMethod>
    <JadeMethod name="printClient" id="3fc6862a-33c3-40bb-8e58-7b1005603b38">
        <source>printClient(_client : DEV_LicenseClient; _printTable : CM_GenericTablePrint) protected;
// ---------------------------------------------------------------------------
// Created:     14 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// ### JIRA 33543 12DEC2024 NAVAB1 change to use constants
vars
	tmpPrintTable	: CM_GenericTablePrint;
	tmpDtl			: DEV_LicenseDtl;

begin

	tmpPrintTable := _printTable;

	// setup the report header
	tmpPrintTable.frHeader.width := app.printer.pageWidth;
	tmpPrintTable.lblHeader1.caption := "JMT License Details for " &amp; _client.name;
	tmpPrintTable.lblHeader1.visible := true;
	tmpPrintTable.lblHeader1.centreHorizontallyInParent();

	app.printer.setHeader(tmpPrintTable.frHeader);

	// setup the report footer
	tmpPrintTable.frFooter.width := app.printer.pageWidth;
	tmpPrintTable.lblTheDatePrinted.caption := app.actualTimeServer.String;
	app.printer.setFooter(tmpPrintTable.frFooter);
	
	// setup the table for printing
	tmpPrintTable.table.columns := 2;
	tmpPrintTable.table.rows := 0;

	tmpPrintTable.addRowToTable('Number of Terminals' &amp; Tab &amp; _client.numTerminals.String);
	tmpPrintTable.addRowToTable('Site License' &amp; Tab &amp; _client.hasSiteLicense.String);
	
	foreach tmpDtl in _client.allLicenseDtls do
		tmpPrintTable.addRowToTable(null);
		if tmpDtl.type = DEV_LicenseEntity.LicenseType_System then
			tmpPrintTable.addRowToTable(ProductStr_JMT);
			self.printDtlForSysOrTerminal(tmpPrintTable, tmpDtl);
		elseif tmpDtl.type = DEV_LicenseEntity.LicenseType_EDI then
			tmpPrintTable.addRowToTable(ProductStr_JMT_EDI);
			self.printDtlForEDI(tmpPrintTable, tmpDtl);
		// ### JIRA 33543 12DEC2024 NAVAB1
		elseif tmpDtl.type = DEV_LicenseEntity.LicenseType_EWS then
			tmpPrintTable.addRowToTable(ProductStr_EWS);
			self.printDtlForEWS(tmpPrintTable, tmpDtl);
		elseif tmpDtl.type = DEV_LicenseEntity.LicenseType_Subscription then	//17 Jun 2020	NDL	TFS 49569
			tmpPrintTable.addRowToTable(ProductStr_SUBS);
			self.printDtlForSubs(tmpPrintTable, tmpDtl);
		else
			tmpPrintTable.addRowToTable('Terminal ' &amp; tmpDtl.name);
			self.printDtlForSysOrTerminal(tmpPrintTable, tmpDtl);
		endif;
	endforeach;

	tmpPrintTable.printTable(null, false, null);

end;</source>
        <access>protected</access>
        <Parameter name="_client" type="DEV_LicenseClient"/>
        <Parameter name="_printTable" type="CM_GenericTablePrint"/>
    </JadeMethod>
    <JadeMethod name="printDtlForEDI" id="f2da044a-3a54-4d22-8e5d-29c5919c7379">
        <source>printDtlForEDI(_printTable : CM_GenericTablePrint input; _licenseDtl : DEV_LicenseDtl) protected;
// ---------------------------------------------------------------------------
// Created:     05 November 2003 by cnwrs2
//
// Purpose:     Should only be called from setCurrentLicenseDtls(..)
// ---------------------------------------------------------------------------
vars
	ediAgent	: CM_EDIFileTypeAgent;
	ediFileType	: CM_EDIFileType;
	camDescType	: CM_CamProtocolDesc;
	canDoStr	: String;
	idx,
	color1,
	color2,
	theColor,
	tmpValue	: Integer;

begin

	if _licenseDtl &lt;&gt; null and
	   _licenseDtl.type &lt;&gt; DEV_LicenseEntity.LicenseType_EDI then
		app.msgBox('Incorrect license type (' &amp; _licenseDtl.type.String &amp; ') for ' &amp; method.name, 'Error', 0);
		return;
	endif;
	
	ediAgent := self.myEDIFileTypeAgent;

	_printTable.addRowToTable('License' &amp; Tab &amp; 'Value');
	

	foreach ediFileType in ediAgent.allEDIFileTypes do
		tmpValue := ediFileType.type;
		
		canDoStr := null;	//'No';	// so as unchecked
		if _licenseDtl &lt;&gt; null then
			if _licenseDtl.canDo(tmpValue) then
				canDoStr := 'Yes';	// so as checked
			endif;
		endif;
		
		_printTable.addRowToTable(ediFileType.name &amp; Tab &amp; canDoStr);

		
	endforeach;
	

	foreach camDescType in ediAgent.allCAMProtocolDescs do
		tmpValue := camDescType.type;
		
		canDoStr := null;	//'No';	// so as unchecked
		if _licenseDtl &lt;&gt; null then
			if _licenseDtl.canDo(tmpValue) then
				canDoStr := 'Yes';	// so as checked
			endif;
		endif;
		
		_printTable.addRowToTable(camDescType.name &amp; Tab &amp; canDoStr);

		
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_printTable" type="CM_GenericTablePrint" usage="input"/>
        <Parameter name="_licenseDtl" type="DEV_LicenseDtl"/>
    </JadeMethod>
    <JadeMethod name="printDtlForEWS" id="99346446-0eec-41fb-88c9-8c92587902ca">
        <source>printDtlForEWS(_printTable : CM_GenericTablePrint input; _licenseDtl : DEV_LicenseDtl) protected;
/*
Purpose - 	
Who - NAVAB1
Date - 12DEC2024
ADO - JIRA 33543
*/

vars
	ewsAgent	: CM_EWSTypeAgent;
	ewsType	: CM_ExternalWebServiceType;
	endpointType	: CM_EWSEndpointType;
	canDoStr	: String;
	idx,
	color1,
	color2,
	theColor,
	tmpValue	: Integer;
expDateDate : Date;
begin

	if _licenseDtl &lt;&gt; null and
	   _licenseDtl.type &lt;&gt; DEV_LicenseEntity.LicenseType_EWS then
		app.msgBox('Incorrect license type (' &amp; _licenseDtl.type.String &amp; ') for ' &amp; method.name, 'Error', 0);
		return;
	endif;
	
	ewsAgent := self.myEWSTypeAgent;

	_printTable.addRowToTable('License' &amp; Tab &amp; 'Value');
	

	foreach ewsType in ewsAgent.allEWSTypesByType do
		tmpValue := ewsType.type;
		
		canDoStr := null;	//'No';	// so as unchecked
		if _licenseDtl &lt;&gt; null then
			if _licenseDtl.canDo(tmpValue) then
				expDateDate := _licenseDtl.allExpiries[tmpValue];
				canDoStr :=  'Yes - ' &amp; expDateDate.format("dd MMM yyyy");	// so as checked // ### JIRA 33843 23JAN2025 NAVAB1 added date
			endif;
		endif;
		
		_printTable.addRowToTable(ewsType.name &amp; Tab &amp; canDoStr);

		
	endforeach;
	

	foreach endpointType in ewsAgent.allEWSEndpointTypeByType do
		tmpValue := endpointType.type;
		
		canDoStr := null;	//'No';	// so as unchecked
		if _licenseDtl &lt;&gt; null then
			if _licenseDtl.canDo(tmpValue) then
				expDateDate := _licenseDtl.allExpiries[tmpValue];
				canDoStr :=  'Yes - ' &amp; expDateDate.format("dd MMM yyyy");	// so as checked // ### JIRA 33843 23JAN2025 NAVAB1 added date
			endif;
		endif;
		
		_printTable.addRowToTable(endpointType.name &amp; Tab &amp; canDoStr);

		
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_printTable" type="CM_GenericTablePrint" usage="input"/>
        <Parameter name="_licenseDtl" type="DEV_LicenseDtl"/>
    </JadeMethod>
    <JadeMethod name="printDtlForSubs" id="b7d2d7cd-8f0b-4fa8-b987-330d4fdcfa70">
        <source>printDtlForSubs(_printTable : CM_GenericTablePrint input; _licenseDtl : DEV_LicenseDtl) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2020	jlgndl1	Initial creation	TFS 49569

*/

vars
	permAgent	: CM_PermissionAgent;
	permObj		: CM_PermissionObject;
	canDoStr	: String;
	tmpIgnore	: Boolean;
	idx,
	color1,
	color2,
	theColor,
	tmpValue	: Integer;
	subsExpDateDate : Date;

begin

	if _licenseDtl &lt;&gt; null and _licenseDtl.type &lt;&gt; DEV_LicenseEntity.LicenseType_Subscription then
		app.msgBox('Incorrect license type (' &amp; _licenseDtl.type.String &amp; ') for ' &amp; method.name, 'Error', 0);
		return;
	endif;

	permAgent := self.mySubscriptionPermAgent;
	
	_printTable.addRowToTable('License' &amp; Tab &amp; 'Value - Expires');

	foreach permObj in permAgent.allPermissionsByName do
		tmpValue := permObj.constValue;
		
		canDoStr := null;	//'No';	// so as unchecked
		if self.getValueForSysTermPermission(_licenseDtl, tmpValue, tmpIgnore, subsExpDateDate) then
			canDoStr := 'Yes - ' &amp; subsExpDateDate.format("dd MMM yyyy");	// so as checked
		endif;
		
		if tmpIgnore then
			continue;
		endif;
	
		_printTable.addRowToTable(permObj.description &amp; Tab &amp; canDoStr);
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_printTable" type="CM_GenericTablePrint" usage="input"/>
        <Parameter name="_licenseDtl" type="DEV_LicenseDtl"/>
    </JadeMethod>
    <JadeMethod name="printDtlForSysOrTerminal" id="5594b052-ca0b-4777-af10-4ba4dd1ce096">
        <source>printDtlForSysOrTerminal(_printTable : CM_GenericTablePrint input; _licenseDtl : DEV_LicenseDtl) protected;
// ---------------------------------------------------------------------------
// Created:     05 November 2003 by cnwrs2
//
// Purpose:     Should only be called from setCurrentLicenseDtls(..)
// ---------------------------------------------------------------------------
vars
	permAgent	: CM_PermissionAgent;
	permObj		: CM_PermissionObject;
	canDoStr	: String;
	tmpIgnore	: Boolean;
	idx,
	color1,
	color2,
	theColor,
	tmpValue	: Integer;
	dummyDate : Date;

begin

	if _licenseDtl &lt;&gt; null and
	   _licenseDtl.type &lt;&gt; DEV_LicenseEntity.LicenseType_System and
	   _licenseDtl.type &lt;&gt; DEV_LicenseEntity.LicenseType_Terminal then
		app.msgBox('Incorrect license type (' &amp; _licenseDtl.type.String &amp; ') for ' &amp; method.name, 'Error', 0);
		return;
	endif;

	permAgent := self.myPermissionAgent;
	
	_printTable.addRowToTable('License' &amp; Tab &amp; 'Value');

	foreach permObj in permAgent.allPermissionsByName do
		tmpValue := permObj.constValue;
		
		canDoStr := null;	//'No';	// so as unchecked
		if self.getValueForSysTermPermission(_licenseDtl, tmpValue, tmpIgnore, dummyDate) then
			canDoStr := 'Yes';	// so as checked
		endif;
		
		if tmpIgnore then
			continue;
		endif;
	
		_printTable.addRowToTable(permObj.description &amp; Tab &amp; canDoStr);
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_printTable" type="CM_GenericTablePrint" usage="input"/>
        <Parameter name="_licenseDtl" type="DEV_LicenseDtl"/>
    </JadeMethod>
