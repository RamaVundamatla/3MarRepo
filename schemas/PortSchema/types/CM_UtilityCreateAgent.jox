    <JadeMethod name="utlCreateLocationStatistics" id="dd3e4052-5922-4263-8293-6980bfcb7122">
        <source>utlCreateLocationStatistics(_proxyLocationStatistics : CM_LocationStatistics; _newLocationStatistics : CM_LocationStatistics output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August  2008 By conkc1
//
// Purpose:		Initial create of Location Statistic objects for all relevant
//				Terminal and Terminal areas. 
//
// Parameters:	proxy CM_LocationStatistics object
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);
	
	app.myValCA.valLocationStatistics(_proxyLocationStatistics);

	if self.checkValidationWithPassport(_passport) = false then
		return;
	endif;
		
	app.setContinueCMExceptions(false);

	create _newLocationStatistics persistent;
