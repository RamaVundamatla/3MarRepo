    <JadeMethod name="valBreakBulkAggregate" id="9e1401ed-c505-48b4-a167-6a93ef81efdc">
        <source>valBreakBulkAggregate(	_targetTi : CM_Bulk;
						_id : String;
						_cargoType : CM_CargoType;
						_product : CM_Product;
						_operator : CM_Operator;
						_location : CM_LocationsController;
						_allItemsToBeAggregated : CM_TISet;
						_passport : CM_Passport input
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2014	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	testDensity : Decimal [16,4];
	descr : String;
	
begin

	if _targetTi &lt;&gt; null then
		if _targetTi.isOffSite then	//14 Jun 2013	NDL	Par 31826
			app.raiseCMException1(ERR_TI_NOT_ONSITE,_targetTi.id,null,null);
			return;
		endif;
		if _allItemsToBeAggregated = null or _allItemsToBeAggregated.isEmpty then
			app.raiseCMException(Break_bulk_items_select_aggreg,null,null);
			return;
		endif;
	else
		if _id = null then
			app.raiseCMException(Must_enter_choos_exist_item_ag,null,null);
			return;
		endif;
		if _operator = null then
			app.raiseCMException(Please_select_operator,null,null);
			return;
		endif;
		if _cargoType = null then
			app.raiseCMException(Select_cargo_type_continu,null,null);
			return;
		elseif _cargoType.hasProductTypes then
			if _product = null then
				app.raiseCMException(Please_select_cargo_type_conti,null,null);
			return;
			endif;
		endif;
		if _location = null then
			app.raiseCMException(Location_NotFound,null,null);
			return;
		endif;
	endif;
	
	foreach ti in _allItemsToBeAggregated do
		if ti.isOffSite then	//14 Jun 2013	NDL	Par 31826
			app.raiseCMException1(ERR_TI_NOT_ONSITE,ti.id,null,null);
			return;
		endif;
	endforeach;
	
	ti := _allItemsToBeAggregated.first;
	if _targetTi &lt;&gt; null then
		if _targetTi.isBulkByVolume and _targetTi.getDensity &lt;&gt; ti.getDensity then
			app.raiseCMException2(Densi_value_cargo_items_must_m, ti.id &amp; " (" &amp; ti.getDensity.asStringJMT &amp; ")", _targetTi.id &amp; " (" &amp; _targetTi.getDensity.asStringJMT &amp; ")",null,null);
			return;
		endif;
	elseif _cargoType &lt;&gt; null then
		if _cargoType.mySystemProductType &lt;&gt; null and _cargoType.mySystemProductType.myDensityDec &lt;&gt; null then		// ### TFS 52193 22Nov2021 NAVPW1
			testDensity := _cargoType.mySystemProductType.myDensityDec.getRawValue.Decimal;							// ### TFS 52193 22Nov2021 NAVPW1
			descr := _cargoType.description;
		endif;
		if _product &lt;&gt; null then
			if _product.myDensityDec &lt;&gt; null then							// ### TFS 52193 22Nov2021 NAVPW1
				testDensity := _product.myDensityDec.getRawValue.Decimal;	// ### TFS 52193 22Nov2021 NAVPW1
				descr := _cargoType.description &amp;  "/" &amp; _product.description;
			endif;
		endif;
		if _cargoType.isBulkByVolume then
			if testDensity &lt;&gt; ti.getDensity then
				app.raiseCMException2(Densi_value_cargo_type_cargo_i, descr &amp; " (" &amp; testDensity.asStringJMT &amp; ")", ti.id &amp; " (" &amp; ti.getDensity.asStringJMT &amp; ")",null,null);
				return;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_targetTi" type="CM_Bulk"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_allItemsToBeAggregated" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valBreakBulkMergeManual" id="6331b863-ffad-4bdd-8c43-ec883ef1e19c">
        <source>valBreakBulkMergeManual(	_targetTi : CM_Cargo io;
							_allItemsToBeMerged : CM_TISet;
							_passport : CM_Passport input	);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk
01 May 2023	jlizm1	TFS 55453 Cargo uniqueness by subtype

*/

vars

	ti : CM_TrackedItem;
	cargoType : Integer;
	operator : CM_Operator;
	location : CM_LocationsController;
	uniqueBySubtype : Boolean;
	subtype : String;

begin

	if _targetTi = null then
		app.raiseCMException(No_Target_item_for_merge,null,null);
		return;
	endif;
	if _targetTi.isOffSite then	//14 Jun 2013	NDL	Par 31826
		app.raiseCMException1(ERR_TI_NOT_ONSITE,_targetTi.id,null,null);
		return;
	endif;
	if _allItemsToBeMerged = null or _allItemsToBeMerged.isEmpty then
		app.raiseCMException1(No_cargo_to_merge,_targetTi.id,null,null);
		return;
	endif;
	
	cargoType := _targetTi.cargoType;
	operator := _targetTi.myOperator;
	location := _targetTi.myPrimaryActualLocation;
	subtype := _targetTi.getCargoSubTypeCode;
	uniqueBySubtype := _targetTi.myCargoType &lt;&gt; null and _targetTi.myCargoType.useCargoSubtypeForUniqueness;
	
	foreach ti in _allItemsToBeMerged do
		if ti.isOffSite then	//14 Jun 2013	NDL	Par 31826
			app.raiseCMException1(ERR_TI_NOT_ONSITE,ti.id,null,null);
			return;
		endif;
		if ti = _targetTi then
			app.raiseCMException(Not_merge_cargo_item_into_itse,null,null);
			return;
		endif;
		if ti.cargoType &lt;&gt; cargoType then
			app.raiseCMException3(Not_merge_into_differe,ti.id,_targetTi.id,app.getErrorString(CargoType),null,null);
			return;
		endif;
		if ti.myOperator &lt;&gt; operator then
			app.raiseCMException3(Not_merge_into_differe,ti.id,_targetTi.id,app.getErrorString(Operator),null,null);
			return;
		endif;
		if ti.myPrimaryActualLocation &lt;&gt; location then
			app.raiseCMException3(Not_merge_into_differe,ti.id,_targetTi.id,app.getErrorString(Location),null,null);
			return;
		endif;
		if uniqueBySubtype and ti.getCargoSubTypeCode &lt;&gt; subtype then
			app.raiseCMException3(Not_merge_into_differe,ti.id,_targetTi.id,app.getErrorString(Cargo_subtype),null,null);
			return;
		endif;
		if ( ti.isBulkByQuantity and ti.totalQuantity &lt; 1 ) then
			app.raiseCMException(Not_merge_cargo_that_zero_tota,null,null);
			return;
		endif;
		if ( ( ti.isBulkByWeight or ti.isBulkByVolume ) and ti.totalWeight &lt; 1 ) then
			app.raiseCMException(Not_merge_cargo_zero_weight,null,null);
			return;
		endif;
		//11 Apr 2018	NDL	TFS 37989 - This is only relevant for cargo being completely merged via the manual merge form
		if not ti.allQueuedFutureMoves.isEmpty or not ti.allPlannedFutureMoves.isEmpty then
			app.raiseCMException1(Unact_plann_queue_moves_merge,ti.id,null,null);
			return;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_targetTi" type="CM_Cargo" usage="io"/>
        <Parameter name="_allItemsToBeMerged" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valBreakBulkOverage" id="1245f126-dfc2-4cc6-853a-28d325d5bd1c">
        <source>valBreakBulkOverage(_ti : CM_TrackedItem;
					_quantity : Integer; 
					_weight : Decimal; 
					_validateInput : Boolean;
					_passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2013	cnwrd1	Initial creation
07 Apr 2014 cnwer1	CCMS 1366
14 Jun 2016 cnwer1	TFS 1502
05 Apr 2023	navkc1	CR 56430 TASK 56439
19 Mar 2025	navhl20 Bug MTN-34322: EUP FR | 54014 - Unable to zero out weight and quantity for cargo attached to a job (Error 88606)
*/

vars
	allJobs : CM_JobSet;
	job : CM_Job;
	wle : CM_WorkListEntry;
	amountType : String;
	checkJobs : Boolean;
	quantityAdded : Integer;
	weightAdded : Decimal[14,4];
	terminal : CM_Terminal;
	disallowZero : Boolean;
	
begin

	if _ti = null then
		app.raiseCMException(No_Cargo_selected,null,null);
		return;
	endif;
	
	terminal := _ti.getMyTerminal();
	// 05 Apr 2023	navkc1	CR 56430 TASK 56439
	if terminal &lt;&gt; null then
		disallowZero := terminal.getConfig(DisallowDiscrepZero).Boolean;
	endif;
	
	if _validateInput then
		if  _ti.totalWeight = _weight and _ti.totalQuantity = _quantity then
			app.raiseCMException(NothingHasBeenChanged,null,null);
		endif;
		if ( _quantity = 0 or _weight = 0 ) and _quantity &lt;&gt; _weight then
			if _quantity = 0 then
				app.raiseCMException2(No_set_A_zero_while_B_not_zero, app.getErrorString(CM_Quantity), app.getErrorString(CM_Weight),null,null);
			elseif _weight = 0 then
				app.raiseCMException2(No_set_A_zero_while_B_not_zero, app.getErrorString(CM_Weight), app.getErrorString(CM_Quantity),null,null);
			endif;
		endif;
	endif;
	
	//epr par 34935 29/9/14
	if _ti.myCargoType.isBulkMulti then
		if _weight = 0 then
			if _ti.isBulkByWeight then
				amountType:=app.getErrorString(CM_Total_Weight);
			else
				amountType:=app.getErrorString(CM_Total_Volume);
			endif;
			// 05 Apr 2023	navkc1	CR 56430 TASK 56439
			if disallowZero then
				app.raiseCMException1(Not_Allowed_Zero,amountType,null,null);
			else
				app.raiseCMWarning1(Confirm_Amount_Zero,amountType,null,null,null);
			endif;
			checkJobs:=true;
		endif;
		//epr par 34935 26/9/14 validate that we are not now over subscribing to the booking
		if not _ti.isChild then
			if _ti.myBookingRefItem &lt;&gt; null then
				weightAdded:= _weight - _ti.totalWeight;
				if weightAdded &gt; 0 and _ti.myBookingRefItem.getReceivedWeight() + weightAdded &gt; _ti.myBookingRefItem.getWeight() then
					if not _ti.myTerminal.getConfig(BookingOversubscribe).Boolean then					
						app.raiseCMException2(Book_item_already_has, _ti.myBookingRefItem.getAmountDisplay(), _ti.myBookingRefItem.getReceivedDisplay(), null, null);
					else
						app.raiseCMWarning2(Book_item_already_has, _ti.myBookingRefItem.getAmountDisplay(),_ti.myBookingRefItem.getReceivedDisplay(), null, self, null);		
					endif;
				endif;	
			endif;	
		endif;
		
	else
		if _quantity = 0 then
			// 05 Apr 2023	navkc1	CR 56430 TASK 56439
			if disallowZero then
				app.raiseCMException(Not_Allowed_Quantity_Zero,null,null);
			else
				app.raiseCMWarning(Confirm_total_quantity,null,null,null);
			endif;
			checkJobs:=true;
				
		endif;
		//epr par 34935 26/9/14 validate that we are not now over subscribing to the booking
		if not _ti.isChild then
			if _ti.myBookingRefItem &lt;&gt; null then
				quantityAdded:= _quantity - _ti.totalQuantity;
				if quantityAdded &gt; 0 and _ti.myBookingRefItem.getRecievedCount() + quantityAdded &gt; _ti.myBookingRefItem.getQuantity() then
					if not _ti.myTerminal.getConfig(BookingOversubscribe).Boolean then					
						app.raiseCMException2(Book_item_already_has, _ti.myBookingRefItem.getAmountDisplay(), _ti.myBookingRefItem.getReceivedDisplay(), null, null);
					else
						app.raiseCMWarning2(Book_item_already_has, _ti.myBookingRefItem.getAmountDisplay(),_ti.myBookingRefItem.getReceivedDisplay(), null, self, null);		
					endif;
				endif;	
			endif;	
		endif;
	endif;
	
	if checkJobs then
		create allJobs transient;
		_ti.getAllJobs(allJobs);
		if _ti.isBulkByWeight then
			amountType:=app.getErrorString(CM_Total_Weight);
		elseif _ti.isBulkByVolume then
			amountType:=app.getErrorString(CM_Total_Volume);
		else 
			amountType:=app.getErrorString(CM_Total_Quantity);
		endif;
		
		foreach job in allJobs discreteLock do
			if not job.isJobComplete and disallowZero then			//19.03.2025 navhl20 #34322
				app.raiseCMException2(Total_amount_zero_jobs,amountType,_ti.id,null,null);
				return;
			endif;
		endforeach;
		
		foreach wle in _ti.allWorklistEntries discreteLock do
			if wle.status &lt;&gt; WLE_COMPLETED and disallowZero then		//19.03.2025 navhl20 #34322
				app.raiseCMException2(Tota_quanity_zero_wles,amountType,_ti.id,null,null);
				return;
			endif;
		endforeach;
	endif;

epilog
	delete allJobs;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_validateInput" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valBreakBulkSplitManual" id="c536b6e8-413e-4b83-a5a6-8d7004ba1900">
        <source>valBreakBulkSplitManual(	_sourceTi : CM_Cargo io;
							_newTiIds : StringArray;
							_quantity : Integer;
							_weight : Decimal;
							_passport : CM_Passport input
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk
01 Apr 2014	NDl	CCMS 1366
19 Apr 2016	cnwdap1	TFS #1843 Change zero weight check to minimum measurement allowance 
01 May 2023	jlizm1	TFS 55453 Cargo uniqueness by subtype
*/

vars

	totalSplitQuantity : Integer;
	allJobs : CM_JobSet;
	job : CM_Job;
	wle : CM_WorkListEntry;
	proposedId : String;
	iter : Iterator;
	cargoTypeId : Integer;
	location : CM_LocationsController;
	startObject : Object;
	existingTi : CM_TrackedItem;
	totalSplitWeight : Decimal [16,4];
	totalSplitVolume : Decimal [16,4];
	weightStr : String;
	volumeStr : String;
	measureType : CM_MeasurementType;
	prod : CM_Product;
	splittingAll : Boolean;
	terminal : CM_Terminal;
	preventDupIdSubType : Boolean;
	
begin

	if _sourceTi = null then
		app.raiseCMException(No_Target_item_for_merge,null,null);
		return;
	endif;
	if _sourceTi.isOffSite then	//14 Jun 2013	NDL	Par 31826
		app.raiseCMException1(ERR_TI_NOT_ONSITE,_sourceTi.id,null,null);
		return;
	endif;
	if not _sourceTi.canSplitTotalQuantity then
		app.raiseCMException(No_split_cargo_not_BB,null,null);
		return;
	endif;
	if _newTiIds = null or _newTiIds.isEmpty then
		app.raiseCMException1(NoTIsForSplit,_sourceTi.id,null,null);
		return;
	endif;
	terminal:=_sourceTi.getMyTerminal();
	
	
	if _sourceTi.isBulkByQuantity then
		if _quantity &lt; 1 then
			app.raiseCMException1(Not_split_zero_quanti_from,_sourceTi.id,null,null);
			return;
		endif;
	
		totalSplitQuantity := ( _newTiIds.size * _quantity );
		if totalSplitQuantity &gt; _sourceTi.totalQuantity then
			app.raiseCMException1(Not_decla_quant_great_than_tot, _sourceTi.id &amp; " (" &amp; _sourceTi.totalQuantity.String &amp; ")",null,null);
			return;
		endif;
		
	elseif _sourceTi.isBulkByWeight then
		//if _weight &lt; 1 then										// TFS #1843
		if _weight &lt; Measure_AllowableDifference then				// TFS #1843
			app.raiseCMException2(Not_split_zero_from, app.getErrorString(CM_Weight),_sourceTi.id,null,null);
			return;
		endif;
	
		totalSplitWeight := ( _newTiIds.size * _weight );
		if totalSplitWeight &gt; _sourceTi.totalWeight then
			measureType := _sourceTi.myCargoType.getMeasurementTypeFor(Type_Weight, true);
			weightStr := app.convertMeasurementForDisplay(measureType.shortName, _sourceTi.totalWeight) &amp; " " &amp; measureType.shortName;
			app.raiseCMException3(Not_declar_greate_than_total, app.getErrorString(CM_Weight), app.getErrorString(CM_Weight), _sourceTi.id &amp; " (" &amp; weightStr &amp; ")",null,null);
		endif;
		
	elseif _sourceTi.isBulkByVolume then
		if _weight &lt; 1 then
			app.raiseCMException2(Not_split_zero_from, app.getErrorString(CM_Volume),_sourceTi.id,null,null);
			return;
		endif;
		
		totalSplitVolume := (( _newTiIds.size * _weight ) / _sourceTi.getDensity );
		if totalSplitVolume &gt; _sourceTi.totalVolume then
			measureType := _sourceTi.myCargoType.getMeasurementTypeFor(Type_Volume, true);
			volumeStr := app.convertMeasurementForDisplay(measureType.shortName, _sourceTi.totalVolume) &amp; " " &amp; measureType.shortName;
			app.raiseCMException3(Not_declar_greate_than_total, app.getErrorString(CM_Volume), app.getErrorString(CM_Volume), _sourceTi.id &amp; " (" &amp; weightStr &amp; ")",null,null);
		endif;
		
	endif;
	
	if _sourceTi.isBulkByQuantity then
		if _quantity = _sourceTi.totalQuantity then
			splittingAll := true;
		endif;
	elseif _sourceTi.isBulkByWeight then
		if totalSplitWeight = _sourceTi.totalWeight then
			splittingAll := true;
		endif;
	elseif _sourceTi.isBulkByVolume then
		if totalSplitVolume = _sourceTi.totalVolume then
			splittingAll := true;
		endif;
	endif;
	
	if splittingAll then
		create allJobs transient;
		_sourceTi.getAllJobs(allJobs);
		foreach job in allJobs discreteLock do
			if not job.isJobComplete then
				app.raiseCMException1(Not_split_items_while_incom_jo,_sourceTi.id,null,null);
				return;
			endif;
		endforeach;
		foreach wle in _sourceTi.allWorklistEntries discreteLock do
			if wle.status &lt;&gt; WLE_COMPLETED then
				app.raiseCMException1(Not_split_items_while_incom_wo,_sourceTi.id,null,null);
				return;
			endif;
		endforeach;
	endif;
	
	preventDupIdSubType := terminal.getConfig(DisallowDupIDForSubtype).Boolean;
	
	cargoTypeId := _sourceTi.cargoType;
	location := _sourceTi.myPrimaryActualLocation;
	iter := terminal.allOnsiteTIsByCargoTypeId.createIterator;
	foreach proposedId in _newTiIds do
		if proposedId.length &gt; 20 then
			app.raiseCMException3(Data_Too_Long,"Id",proposedId,'20',null,null);
		endif;
		startObject := terminal.allOnsiteTIsByCargoTypeId.getAtKey(cargoTypeId,proposedId);
		if startObject = null then
			continue;
		endif;
		iter.reset;
		iter.startAtObject(startObject);
		while iter.next( existingTi ) do
			if existingTi.cargoType &lt;&gt; cargoTypeId then
				break;
			endif;
			if existingTi.id &lt;&gt; proposedId then
				break;
			endif;
			if preventDupIdSubType then
				if existingTi.getCargoSubTypeCode &lt;&gt; _sourceTi.getCargoSubTypeCode then
					app.raiseCMException3(ERR_TI_ONSITE, _sourceTi.cargoTypeDescr, proposedId, terminal.code, null, null);
				endif;
			endif;
			if  existingTi.myPrimaryActualLocation &lt;&gt; location then
				continue;
			endif;
			//we already have one with this id in this location
			app.raiseCMException1(Propos_alread_used_this_locati,proposedId,null,null);
			return;
		endwhile;
	endforeach;
	
	
	

epilog

	delete allJobs;
	delete iter;

end;</source>
        <Parameter name="_sourceTi" type="CM_Cargo" usage="io"/>
        <Parameter name="_newTiIds" type="StringArray"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valBulkRelease" id="55513f58-62aa-49dd-94f5-9a0059e43950">
        <source>valBulkRelease(_pxyBulkRelease : CM_BulkRelease; _allTIPins : CM_StringDict; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
