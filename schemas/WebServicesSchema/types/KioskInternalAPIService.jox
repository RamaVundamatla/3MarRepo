<Class name="KioskInternalAPIService" id="de342d91-caa1-4fbf-be9b-e754382e11b3">
    <superclass name="MTNInternalAPIService"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>For any web service methods used by our .NET Kiosk application - NOT by customers apps</text>
    <Constant name="QueryParam_LanguageId" id="72e51a47-5b2d-4c53-8efc-0d4fbb4a7764">
        <source>"languageId"</source>
        <type name="String"/>
    </Constant>
    <Constant name="QueryParam_ReferenceId" id="3d7cd115-1f6d-43ba-852e-01f72220f4d5">
        <source>"referenceId"</source>
        <type name="String"/>
    </Constant>
    <Constant name="QueryParam_References" id="f31f5a75-c719-49a3-9ea1-b005da8a4031">
        <source>"references"</source>
        <type name="String"/>
    </Constant>
    <JadeMethod name="createJWT" id="dcf43177-5087-4c98-b573-180f2207851b">
        <options>4</options>
        <source>createJWT(	_user: CM_User; 
			_terminal: CM_Terminal;
			_kioskID : String;
			_userContext: String;
			_expiryInSeconds: Integer io; 
			_isRefreshToken: Boolean;
			_sessionID : String output) :String typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2023	jlier1	Initial creation 59732
10 October 203 	navmj1	Added user context to the kiosk JWT token

*/
constants
	DEFAULT_EXPIRY			: Integer = 60 * 24;			// 15 minutes
	DEFAULT_REFRESH_EXPIRY	: Integer = 60 * 24 * 365;	// 24 hours
vars
	expiry			: Integer;
	appName			: String;
	issuer			: String;
	jwt				: JadeJsonWebToken;
	nonceKeyName	: String;
	nonce			: String;
	factory			: JadeMessagingFactory;
	userIdClaim,
	terminalIdClaim,
	userContextClaim,
	kioskIdClaim,
	sessionClaim	: JadeJWTClaim;
	tokenString		: String;
	encKey			: String;
	jwtError		: String;
begin
	// Every JWT should have a 'userId' and 'TerminalId' claim
	if _user = null or _terminal = null then
		app.raiseUnexpectedProgramError(WS_WebServiceAgent.name, method.name, "CM_User or CM_Terminal invalid/not specified");
		return null;
	endif;
	
	expiry := _expiryInSeconds;
	if expiry = null then
		if not _isRefreshToken then
			expiry := DEFAULT_EXPIRY * 60;
		else
			expiry := DEFAULT_REFRESH_EXPIRY * 60;
		endif;
		_expiryInSeconds := expiry;
	endif;
	appName := app.getNiceName;
	
	create jwt transient;
	jwt.addAudience("KioskApp");
	jwt.addExpiry(app.actualTimeServer.addSeconds(expiry));
	jwt.addSubject(appName);
	
	issuer := app.getEnvName.toUpper;
	if issuer = null then
		issuer := "JADE";	// Work around 1090 when validating Subject if there is no issuer. Par 68876
		// NB: getEnvName returns the DB folder name in the web services
		// But returns the "System Title" name in the Unit Tests
		// This can be safely removed when the 1090 is resolved
	endif;
	jwt.addIssuer(issuer);
	
	nonceKeyName := (WS_WebServiceAgent.JWT_NONCE_KEY &amp; "_" &amp; appName &amp; "_" &amp; _terminal.code &amp;"-" &amp; _kioskID)[1:CM_StateData::key.length];
	
	if not _isRefreshToken then
		// New login = new nonce
		create factory transient;
		nonce := factory.generateAccessPassword()[1:30];
		app.myTrxUA.trxUpdateUserStateData(_user, ConfigGrp_Web, nonceKeyName, nonce, app.myPassport);
		delete factory;
	else
		nonce := _user.getStateData(ConfigGrp_Web, nonceKeyName).String;
		if nonce = null then
			app.raiseUnexpectedProgramError(WS_WebServiceAgent.name, method.name, "User State Data not found for JWT " &amp; appName);
			return null;
		endif;
	endif;
	jwt.addId(nonce);	// Limited to 30 characters
	
	userIdClaim := create JadeJWTClaim(CMIF_WSClaimsObj.JWT_CLAIM_USERID, _user.code) transient; // 27 July 2022 navlw1 tfs 53854
	jwt.addCustomClaim(userIdClaim);
	
	terminalIdClaim := create JadeJWTClaim(CMIF_WSClaimsObj.JWT_CLAIM_TERMINALID, _terminal.code) transient; // 27 July 2022 navlw1 tfs 53854
	jwt.addCustomClaim(terminalIdClaim);
	
	kioskIdClaim := create JadeJWTClaim(CMIF_WSClaimsObj.JWT_CLAIM_KIOSKID, _kioskID) transient; // 27 July 2022 navlw1 tfs 53854
	jwt.addCustomClaim(kioskIdClaim);

	userContextClaim := create JadeJWTClaim(CMIF_WSClaimsObj.JWT_CLAIM_USERCONTEXT, _userContext) transient; // 17 October July 2023 navmj1 tfs 60902
	jwt.addCustomClaim(userContextClaim);
	
	_sessionID:=app.generateUuid(VariantMicrosoft).uuidAsString();
	sessionClaim:=	create JadeJWTClaim(CMIF_WSClaimsObj.JWT_CLAIM_SESSION,_sessionID);
	jwt.addCustomClaim(sessionClaim);
	
	// Generate/Sign our JWT using a randomly generated key
	if _isRefreshToken then
		encKey := _terminal.getConfig(JWTRefreshKey).String;
	else
		encKey := _terminal.getConfig(JWTAccessKey).String;
	endif;
	
	// Time to generate a new key (this probably shouldn't be in this method
	// TODO: Move somewhere else ?
	// How/When do we rotate these ?
	if encKey = null then
		create factory transient;
		encKey := factory.generateAccessPassword();
		beginTransaction;
		if _isRefreshToken then
			_terminal.setConfig(JWTRefreshKey, encKey.String);
		else
			_terminal.setConfig(JWTAccessKey, encKey.String);
		endif;
		commitTransaction;
		delete factory;
	endif;
	
	tokenString := jwt.encodeHS256(encKey, jwtError);
	if jwtError &lt;&gt; null then
		app.raiseUnexpectedProgramError(WS_WebServiceAgent.name, method.name, "Unable to generate JWT Access Token: " &amp; jwtError);
		return null;
	endif;
	
	return tokenString;	
	
epilog
	delete jwt;
	delete userIdClaim;
	delete terminalIdClaim;
	delete kioskIdClaim;
	delete sessionClaim;
	delete userContextClaim;
	delete factory;
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_kioskID" type="String"/>
        <Parameter name="_userContext" type="String"/>
        <Parameter name="_expiryInSeconds" type="Integer" usage="io"/>
        <Parameter name="_isRefreshToken" type="Boolean"/>
        <Parameter name="_sessionID" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAdditionalQuestions" id="6b22e9ae-625b-43e3-8250-c2feed37be88">
        <updating/>
        <source>getAdditionalQuestions() : WS_KioskAdditionalResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2023	jlier1	Initial creation 59732
07 Feb 2023 	navhl20 ChangeRequest 61960: FR | 57937 - [TKT: 61898] - Kiosk - US.080 'c' - Coded Instructions Missing from Additional question Criteria 
*/

vars
	gateLane : CM_GateAreaLaneController;
	response : WS_KioskAdditionalResponse;
	kiosk : CM_Kiosk;
	additionalQuestion : CM_KioskAdditionalQuestion;
	wsAdditionalQuestion : WS_KioskAdditionalQuestion;
	references 	: StringArray;
	languageId : String;
	question : CM_KioskTranslation;
	reference : String;
	terminal : CM_Terminal;
	vbts  		:  CM_VehicleBookingTimeSlot;
	vbtItem  : CM_VehicleBookingTimeSlotItem;
	ti : CM_TrackedItem;
	hasAdditional : Boolean;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.httpStatusCode := HttpResponseUnauthorized;	
	create response transient;
	
	self.initialisePassportKiosk(gateLane);
		
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
		
	create references transient;
	self.qsData.getValue(QueryParam_References).csvToStringArray(references,",");
	
	kiosk:=gateLane.getKiosk;
	terminal:=app.myPassport.myTerminal;
	
	foreach additionalQuestion in kiosk.allAdditionalQuestions  discreteLock do
		question:=additionalQuestion.allQuestions[app.myCurrentLocale.localeId];
		if question = null and kiosk.myPrimaryLocale &lt;&gt; null then
			question:=additionalQuestion.allQuestions[kiosk.myPrimaryLocale.localeId];
		endif;
		hasAdditional:=false;
		if not additionalQuestion.allCriteria.isEmpty then
			foreach reference in references do : referenceOuter
				vbts:=terminal.myVehicleBookingTerminal.allVBTimeslotsById[reference];
				if vbts = null then
					vbts:= terminal.myVehicleBookingTerminal.allVBTimeslotsByExtRef[reference];
				endif;
				if vbts = null then
					continue;
				endif;
				foreach vbtItem in vbts.allVehicleBookingItems do
					ti:=vbtItem.myTrackedItem;
					if ti &lt;&gt; null then
							if additionalQuestion.doesTIMatch(ti) then
								hasAdditional:=true;
								break referenceOuter;
							endif;
					elseif vbtItem.myBookingItem &lt;&gt; null then														//07.02.2023 navhl20 #61960
						if additionalQuestion.doesBookingRefItemMatch(vbtItem.myBookingItem) then
							hasAdditional:=true;
							break referenceOuter;
						endif;
					else
						if vbtItem.myReserveDetails &lt;&gt; null and vbtItem.myReserveDetails.isKindOf(CM_ReserveSelection) then
							if additionalQuestion.doesReserveSelectionMatch(vbtItem.myReserveDetails.CM_ReserveSelection) then
								hasAdditional:=true;
								break referenceOuter;
							endif;
						endif;
					
					endif;
				endforeach;
				
			endforeach;
		else
			hasAdditional:=true; //no criteria 
		endif;
		
		if hasAdditional then
			create wsAdditionalQuestion transient;
			wsAdditionalQuestion.id:=additionalQuestion.code;
			if question &lt;&gt; null then
				wsAdditionalQuestion.description:=question.text;
			endif;	
			response.additionalQuestions.add(wsAdditionalQuestion);
		endif;
	endforeach;

	
	response.result:=HttpResponseOK;
	
	return response;
	
epilog
	delete references;
	self.finaliseResponse(response);

end;</source>
        <ReturnType type="WS_KioskAdditionalResponse"/>
    </JadeMethod>
    <JadeMethod name="getAwake" id="65952235-0b53-48d7-8d9b-0a0ad87be6a7">
        <updating/>
        <source>getAwake(queryId: String) : String updating;
/*

Purpose:			

Parameters:			

