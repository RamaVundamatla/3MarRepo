    <JadeMethod name="doBtnNotiSaveClick" id="9f495b3d-493e-4a28-8bb5-904e429f23c1">
        <updating/>
        <source>doBtnNotiSaveClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/03/2025	navkc1 JIRA Story MTN-34156: MTN | Road Operations - Handle Notifications

*/

vars

begin
	// Do notification
	if self.optDoNotes.value then
		self.notificationLevel := self.NoteLevelDoNotes;
		// End the current timer and start a new one
		self.endTimer(self.BaseForm_TimerRefresh);
		self.endTimer(self.BaseForm_TimerNotes);
		//27/03/2025	navkc1 JIRA Story MTN-34156
		if self.doRefreshOnNotiChange() then
			self.doNoteRefresh();
		endif;
		
		self.beginTimer(500 + app.random(100), Timer_OneShot, self.BaseForm_TimerNotes);
	// No notification, but Refresh every x minutes
	elseif self.optNoNotesRefresh.value then
		self.notificationLevel := self.NoteLevelNoNotesRefresh;
		if self.cmbNotiMinutes.listIndex &lt; 1 then
			self.autoRefreshValue := 15;
		else
			self.autoRefreshValue := cmbNotiMinutes.listData();
		endif;
		// End the current timer and start a new one
		self.endTimer(self.BaseForm_TimerRefresh);
		self.endTimer(self.BaseForm_TimerNotes);
		self.beginTimer((self.autoRefreshValue * 60000) + app.random(100), Timer_Continuous, self.BaseForm_TimerRefresh);
		// Purge all notification object
		//self.allNoteRecords.purge();
		//self.doClearNoteRecords(true); //27/03/2025	navkc1 JIRA Story MTN-34156
		self.doClearNoteRecords(true, true); //23/06/2025	navkc1 JIRA MTN 34973
	// No notification at all
	elseif self.optNoNotes.value then
		self.notificationLevel := self.NoteLevelNoNotes;
		// End the current timer and start a new one
		self.endTimer(self.BaseForm_TimerRefresh);
		self.endTimer(self.BaseForm_TimerNotes);
		//self.allNoteRecords.purge();
		//self.doClearNoteRecords(true); //27/03/2025	navkc1 JIRA Story MTN-34156
		self.doClearNoteRecords(true, true); //23/06/2025	navkc1 JIRA MTN 34973
	endif;
	
	self.hideShowFrameNoteConfig();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildCmbNotiMinutes" id="7b3758fa-01b3-419e-b681-3db547a352a4">
        <source>doBuildCmbNotiMinutes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/03/2025	navkc1 JIRA Story MTN-34219: MTN | Notification Framework

*/

vars
	combo	: CMUI_ComboBox;
	index	: Integer;
begin
	combo := self.cmbNotiMinutes;
	combo.clear();
	combo.addItemWithData(app.getErrorString1(Minutes, "1"), 1);
	combo.addItemWithData(app.getErrorString1(Minutes, "2"), 2);
	combo.addItemWithData(app.getErrorString1(Minutes, "5"), 5);
	combo.addItemWithData(app.getErrorString1(Minutes, "10"), 10);
	combo.addItemWithData(app.getErrorString1(Minutes, "15"), 15);
	
	if self.autoRefreshValue &gt; null then
		index := combo.findItemData(self.autoRefreshValue);
		if index &gt; null then
			combo.listIndex := index;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildConnectCaption" id="3cc1f7bc-a31e-4424-b15e-48a056e2a7cc">
        <updating/>
        <source>doBuildConnectCaption(_theTI : CM_TrackedItem;_theAction : Integer io) : String updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theContainer : CM_Container;
	theTower, theCaption : String;
	otherTI : CM_TrackedItem;
	
begin
	if _theTI &lt;&gt; null then
		if _theTI.isKindOf(CM_Container) then
			theContainer := _theTI.CM_Container;
			if theContainer.isConnected then
				_theAction := ACTION_DISCONNECT;
			else
				_theAction := ACTION_CONNECT;
			endif;
			
			if theContainer.isPortHole then
				theTower := theContainer.towerId.trimBlanks;
				if theTower.trimBlanks = null then
					otherTI := theContainer.getOtherTrackedItem(_theAction);
					if otherTI &lt;&gt; null then
						theTower := otherTI.id;
					else
						theTower := "Tower";
						theCaption := null;
						return theCaption;
					endif;
				endif;
				if _theAction = ACTION_DISCONNECT then
					theCaption := theContainer.id &amp; " Disconnect From " &amp; theTower ;
				else
					theCaption := theContainer.id &amp; " Connect To " &amp; theTower;
				endif;
			else
				if theContainer.isConnected then
					_theAction := ACTION_DISCONNECT;
					theCaption := theContainer.id &amp; " Disconnect From Power";
				else
					_theAction := ACTION_CONNECT;
					theCaption := theContainer.id &amp; " Connect To Power";
				endif;
			
			endif;
		endif;				
	endif;

	return theCaption;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theAction" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBuildUnplanMenu" id="62084bb8-9e3d-4abc-ba96-40a0098069b3">
        <updating/>
        <source>doBuildUnplanMenu(_unPlanMenu : MenuItem input;_unPlanSingleMenu : MenuItem input; _theTI : CM_TrackedItem input) updating;
/* ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

28/5/14 	cnwer1		PAR 33948 - need to be able to  unplan many planned future moves - also did some tiding up
*/
vars
	idx : Integer;
	mnuChild : MenuItem;
	qfm, aDFM, aLFM : CM_FutureMove;
begin
	if _unPlanSingleMenu &lt;&gt; null then
		_unPlanSingleMenu.visible := false;
	endif;
	_unPlanMenu.visible := false;
	_unPlanMenu.helpKeyword := self.UnplanMenu_TypeMain;
	_unPlanMenu.helpContextId := null;
	_unPlanMenu.userObject := null;
	
	// PAR 18596 Hide all possible child menu items
	foreach idx in 1 to 10 do
		mnuChild := _unPlanMenu.getMenuItem(idx);
		if mnuChild &lt;&gt; null then
			mnuChild.visible := false;
		endif;
	endforeach;

	//jlier1 14/1/26 JIRA-36877
	if _theTI.isRRPforVoyage then
		return;
	endif;
	
	if _theTI.allQueuedFutureMoves.size &gt; 0 then 
		// ### ONLY 1 MENU ITEM
		if _theTI.allQueuedFutureMoves.size = 1 and _unPlanSingleMenu &lt;&gt; null then // PAR 18596
			qfm:=_theTI.allQueuedFutureMoves.first;
			_unPlanSingleMenu.caption := app.getErrorString(CMUI_Unqueue) &amp; _theTI.id; //self.MENU_UNQUEUE_DESC;
			if  qfm.moveType = TI_FutureMoveOverstow then
				_unPlanSingleMenu.caption :=_unPlanSingleMenu.caption  &amp; " (Overstow)";		
			endif;
			_unPlanSingleMenu.helpKeyword := "QUEUE";
			_unPlanSingleMenu.helpContextId := qfm.moveType;
			_unPlanSingleMenu.userObject := qfm;
			_unPlanSingleMenu.visible := true;
			_unPlanMenu.visible := false;
		 // PAR 18596 from here
		else // Multiple Qs
			if  _unPlanSingleMenu &lt;&gt; null then
				_unPlanSingleMenu.visible := false;
			endif;
			_unPlanMenu.visible := true;
			_unPlanMenu.caption := app.getErrorString(CMUI_Unqueue) &amp; _theTI.id; 
			idx := 0;
			foreach qfm in _theTI.allQueuedFutureMoves discreteLock do
				idx := idx + 1;
				mnuChild := _unPlanMenu.getMenuItem(idx);
				if mnuChild = null then
					mnuChild := _unPlanMenu.loadSubMenu(idx);
				endif;
				mnuChild.helpKeyword := "QUEUE";
				mnuChild.helpContextId := qfm.moveType;
				mnuChild.caption := app.getErrorString(CMUI_Unqueue) &amp; _theTI.id &amp; " to " &amp; qfm.getPrimaryLocationId();
				if  qfm.moveType = TI_FutureMoveOverstow then
					mnuChild.caption :=mnuChild.caption  &amp; " (Overstow)";		
				endif;
				mnuChild.userObject := qfm; // NOTE HERE WE ARE USING THE FM 
				mnuChild.visible := true;
			
			endforeach;
		endif;
	elseif _theTI.allPlannedFutureMoves.size &gt; 0 then
		// ### ONLY 1 MENU ITEM
		if _theTI.allPlannedFutureMoves.size = 1 and _unPlanSingleMenu &lt;&gt; null then // PAR 18596
			qfm:=_theTI.allPlannedFutureMoves.first;
			_unPlanSingleMenu.caption := app.getErrorString(Unplan_GC) &amp; _theTI.id; //self.MENU_UNQUEUE_DESC;
			_unPlanSingleMenu.helpKeyword := self.UnplanMenu_TypeLoad;
			if  qfm.moveType = TI_FutureMoveDLRDischarge then
				_unPlanSingleMenu.caption :=app.getErrorString(CMUI_Unplan_DLR_Discharge) &amp; _theTI.id;	
				_unPlanSingleMenu.helpKeyword := self.UnplanMenu_TypeDischarge;
			elseif  qfm.moveType = TI_FutureMoveDLRLoad then
				_unPlanSingleMenu.caption :=app.getErrorString(CMUI_Unplan_DLR_Load) &amp; _theTI.id;
			endif;
			
			_unPlanSingleMenu.helpContextId := qfm.moveType;
			_unPlanSingleMenu.userObject := qfm;
			_unPlanSingleMenu.visible := true;
			_unPlanMenu.visible := false;
		 // PAR 18596 from here
		else // Multiple Qs
			if  _unPlanSingleMenu &lt;&gt; null then
				_unPlanSingleMenu.visible := false;
			endif;
			_unPlanMenu.visible := true;
			_unPlanMenu.caption := app.getErrorString(Unplan_GC) &amp; _theTI.id; 
			idx := 0;
			foreach qfm in _theTI.allPlannedFutureMoves discreteLock do
				idx := idx + 1;
				mnuChild := _unPlanMenu.getMenuItem(idx);
				if mnuChild = null then
					mnuChild := _unPlanMenu.loadSubMenu(idx);
				endif;
				mnuChild.helpKeyword := self.UnplanMenu_TypeLoad;
				if  qfm.moveType = TI_FutureMoveDLRDischarge then
					mnuChild.caption :=app.getErrorString(CMUI_Unplan_DLR_Discharge) &amp; _theTI.id;	
					mnuChild.helpKeyword := self.UnplanMenu_TypeDischarge;
				elseif  qfm.moveType = TI_FutureMoveDLRLoad then
					mnuChild.caption :=app.getErrorString(CMUI_Unplan_DLR_Load) &amp; _theTI.id;
				endif;
				mnuChild.helpContextId := qfm.moveType;
				mnuChild.caption := app.getErrorString(Unplan_GC) &amp; _theTI.id &amp; " to " &amp; qfm.getPrimaryLocationId();
				
				mnuChild.userObject := qfm; // NOTE HERE WE ARE USING THE FM 
				mnuChild.visible := true;
			
			endforeach;
		endif;
	endif;
end;</source>
        <Parameter name="_unPlanMenu" type="MenuItem" usage="input"/>
        <Parameter name="_unPlanSingleMenu" type="MenuItem" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
