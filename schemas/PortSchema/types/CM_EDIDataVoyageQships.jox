    <JadeMethod name="isVoyageDataCanBePartLoaded" id="3b83d766-1777-41b0-a72d-40bf3ea8f2fe">
        <source>isVoyageDataCanBePartLoaded(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/08/2025	navdap1		Initial creation MTN-35604 NSW | OnePort API - file error stops whole file processing
//
vars

begin
	// If terminal config isn't turned on, we can't be partially loaded
	if not self.ediConfig.myTerminal.getConfig(EdiVoyageAllowPartial).Boolean then
		return false;
	endif;
	if not self.status = CM_EDIFile.EDI_STATUS_VERIFIED 
	and not self.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS
	and not self.status = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		return false;
	endif; 
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="f2e418e5-c83b-4a1c-a502-76ead4d66a57">
        <updating/>
        <source>loadDB(mergeCargo: Boolean; _passport: CM_Passport input) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 25 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description
12/08/2025		navdap1		MTN-35604	NSW - Load Partial Voyage EDI
****************************************************/
vars
	cmifVoyageConsist : CMIF_VoyageConsist;
	errorSet : CM_ErrorSet;					// MTN-35604
	allowPartialLoad : Boolean;				// MTN-35604
	
begin
	on Exception do validationExceptionHandler( exception, _passport );
	app.setContinueCMExceptions( false );
	
	create cmifVoyageConsist transient;
	cmifVoyageConsist.myEDIData := self;
	
	self.setupProxies(Loading_EDI_Data_Total, cmifVoyageConsist, _passport);
	
	allowPartialLoad := self.getMyTerminal.getConfig(EdiVoyageAllowPartial).Boolean;	// MTN-35604
	if _passport.hasErrors() and not allowPartialLoad then								// MTN-35604
		return;
	endif;
	
	// MTN-35604 Allow partial loading
	if allowPartialLoad then
		create errorSet transient;
		_passport.moveErrorsToSet(errorSet);
		app.myTrxUA.trxProcessEDIVoyageConsistPart(cmifVoyageConsist, false, errorSet, _passport);
	else
		app.myTrxUA.trxProcessEDIVoyageConsist(cmifVoyageConsist, false, _passport);
	endif;
	
epilog
	if cmifVoyageConsist &lt;&gt; null then	// MTN-35604
		cmifVoyageConsist.purge();
	endif;
	delete cmifVoyageConsist;
	delete errorSet;					// MTN-35604
end;</source>
        <Parameter name="mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="02b1619b-e9d0-4bd8-8b89-cae71e469b2c">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 26 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description
12/08/2025		navdap1		MTN-35604	NSW - Load Partial Voyage EDI
****************************************************/
vars
	cmifVoyageConsist : CMIF_VoyageConsist;
	allowPartialLoad : Boolean;				// MTN-35604
	errorSet : CM_ErrorSet;					// MTN-35604
	
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(false);
	
	create cmifVoyageConsist transient;
	cmifVoyageConsist.myEDIData := self;
	
	self.setupProxies(Verifying_Loaded_Details, cmifVoyageConsist, _passport);
	
	allowPartialLoad := self.getMyTerminal.getConfig(EdiVoyageAllowPartial).Boolean;	// MTN-35604
	if _passport.hasErrors() and not allowPartialLoad then								// MTN-35604
		return _passport.allErrors.size();
	endif;
	
	// MTN-35604 Allow partiaal loading
	if allowPartialLoad then
		create errorSet transient;
		_passport.moveErrorsToSet(errorSet);
		app.myTrxUA.trxProcessEDIVoyageConsistPart(cmifVoyageConsist, true, errorSet, _passport);
	else
		app.myTrxUA.trxProcessEDIVoyageConsist(cmifVoyageConsist, true, _passport);
	endif;
	
	return _passport.allErrors.size();
epilog
	cmifVoyageConsist.purge();
	delete cmifVoyageConsist;
	delete errorSet;				// MTN-35604
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="warnOnDBLoad" id="8a7a6647-1e4f-423f-9bc2-b13abf9efe11">
        <source>warnOnDBLoad(_message: String output; _flags: Integer output; _intCancel: Integer output);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/08/2025	navdap1		Initial creation MTN-35604 NSW - Voyage Partial Load EDI
//
vars
	daysToCheck : Integer;
	config : CM_EDIConfig;
	iter : Iterator;
	ediTI, checkEdiTI : CM_EDITrackedItem;
	voyageCode : String;
	processedDaysAgo : Integer;

begin
	if self.getMyTerminal &lt;&gt; null and self.getMyTerminal.getConfig(EdiVoyagePartialWarning).Boolean then
		daysToCheck := self.getMyTerminal.getConfig(EdiVoyagePartialWarnDays).Integer;
		if daysToCheck = null then
			return;
		endif;
		
		// Check each EDI voyage tracked item attached to me to see if there's another EDI voyage tracked item
		// for the same voyage within the specified number of days
		config := self.ediConfig;
		iter := config.allEDITrackedItemsByVoyageCode.createIterator;
		foreach ediTI in self.allEDITrackedItems where ediTI.isVoyageTI() do
			iter.reset();
			voyageCode := ediTI.getVoyageCode();
			config.allEDITrackedItemsByVoyageCode.startKeyGeq(voyageCode, null, iter);
			while iter.next(checkEdiTI) do
				if checkEdiTI.getVoyageCode &lt;&gt; voyageCode then
					break;
				endif;
				if checkEdiTI.myEDIData = self then
					continue;
				endif;
				
				if checkEdiTI.myEDIData.status.isOneOf(CM_EDIFile.EDI_STATUS_DBLOADED, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL) then
					processedDaysAgo := checkEdiTI.createdTime.date - self.createdTime.date;
					if processedDaysAgo.abs &lt; daysToCheck then
						_message := app.getErrorString2(DBLoaded_file_already_exists, voyageCode, checkEdiTI.getCreatedTimeLocalTZ.asStringJMT);
						_flags := MsgBox_OK_Cancel + MsgBox_Information_Icon;
						_intCancel := MsgBox_Return_Cancel;
						return;
					endif;
				endif;
			endwhile;
		endforeach;
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="_message" type="String" usage="output"/>
        <Parameter name="_flags" type="Integer" usage="output"/>
        <Parameter name="_intCancel" type="Integer" usage="output"/>
    </JadeMethod>
</Class>
