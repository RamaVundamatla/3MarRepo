    <JadeMethod name="getOpForUCForDamRep" id="f5a89307-e8e2-4cfa-96a1-da48e4a40aaf">
        <source>getOpForUCForDamRep(_uc : Integer) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who			Reason
11 April 	 2023	navra1		Initial creation
18 September 2023 	navra1 		TFS 60208 - EUP | FR 54536 - D&amp;R - File Generation

*/

vars

