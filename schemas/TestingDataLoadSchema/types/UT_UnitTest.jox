    <JadeMethod name="getAssertMethodCall" id="e92c90a8-b460-4b3c-bcb7-d984eda45122">
        <source>getAssertMethodCall(_methodName: String output; _methodPosition: Integer output): Boolean protected;
//17 December 2008	cnwdw1	
// Return the position of the assert in the test method
vars
	callStack : ProcessStackArray;
	methodCall : MethodCallDesc;
	i: Integer;
begin
	_methodName := "";
	_methodPosition := 0;
	create callStack transient;
	self.cnEcGetPreviousMethods(callStack);
	methodCall := callStack.removeAt(1);
	delete methodCall;
	foreach methodCall in callStack do
		i := i + 1;
		if not methodCall.method.name.startsWith("assert") and
		   not methodCall.method.name.startsWith("raise") 
		then
			_methodName := methodCall.method.name;
			_methodPosition := methodCall.position;
			return true;
		endif;
	endforeach;
	return false;
epilog
	callStack.purge();
	delete callStack;
end;</source>
        <access>protected</access>
        <Parameter name="_methodName" type="String" usage="output"/>
        <Parameter name="_methodPosition" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
