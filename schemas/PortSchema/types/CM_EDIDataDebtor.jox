    <DbClassMap file="edi"/>
    <JadeMethod name="createAddressProxy" id="a78fd4f8-d61c-4033-a8e1-373e2552dfbf">
        <source>createAddressProxy(ediAddress: CM_EDIAddressTI; 
				   realAddress: CM_Address; 
				   debtor: CM_Debtor ): CM_Address;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Dec 2025 navlc30 JIRA 36749 - LINX - Audits not getting created for the Debtor with Addressed created through EDI
*/

vars
    proxyAddress: CM_Address;
begin
    proxyAddress := null;
    
    //create proxy from existing address - Update scenario
    if realAddress &lt;&gt; null then
		proxyAddress := app.createUpdateProxy(realAddress).CM_Address;
    endif;
    
    //If proxyAddress is null Create new transient proxy - Add scenario
    if proxyAddress = null then
        create proxyAddress transient;
    endif;
    
    // Set proxy properties from EDI
    proxyAddress.setProxy(
        ediAddress.id,
        ediAddress.description,
        ediAddress.address1,
        ediAddress.address2,
        ediAddress.address3,
        ediAddress.region,
        ediAddress.postCode,
        ediAddress.countryCode,
        ediAddress.city,
        ediAddress.emailAddress,
        null,
        ediAddress.isDefault,
        ediAddress.isAlternate,
        debtor
    );
    
    return proxyAddress;
end;</source>
        <Parameter name="ediAddress" type="CM_EDIAddressTI"/>
        <Parameter name="realAddress" type="CM_Address"/>
        <Parameter name="debtor" type="CM_Debtor"/>
        <ReturnType type="CM_Address"/>
    </JadeMethod>
    <JadeMethod name="getDataTypeFromDefName" id="bb404362-86e5-4acd-9130-cc1de3a4f70f">
        <source>getDataTypeFromDefName(_name: String): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Nov 2025 navlc30 JIRA 36357 - LINX - Enable importing debtor addresses via EDI
*/

vars

begin

	if _name = ETDef_EDITIDebtor then
		return EDIDataType_Debtor;
	elseif _name = ETDef_EDITIDebtorAddress then
		return EDIDataType_Address;
	endif;

	return inheritMethod(_name);

epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStrForDefName" id="a8cf72d2-e263-44d4-ae02-599cfcd4fb04">
        <source>getDisplayStrForDefName(_name: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Nov 2025 navlc30 JIRA 36357 - LINX - Enable importing debtor addresses via EDI
*/

vars

begin

	if _name = ETDef_EDITIDebtorAddress then
		return app.getErrorString(Address);
	elseif _name = ETDef_EDITIDebtor then
		return app.getErrorString(INV_Debtor);
	endif;

	return inheritMethod(_name);

epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
