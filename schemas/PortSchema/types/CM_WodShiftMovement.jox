    <JadeMethod name="pxyCreateUpdateProxy" id="5c612fc5-38e4-458b-96bf-1f135d98ddb0">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

	pxy : SelfType;
	completedOK : Boolean;
	wodMarineServiceDtl : CM_WodMarineServiceDetail;
	pxyWodMarineServiceDtl : CM_WodMarineServiceDetail;

begin

	pxy := inheritMethod();
	
	pxy.myFromBerth := self.myFromBerth;
	pxy.myToBerth := self.myToBerth;
	
	self.allWodCargoRequests.copy( pxy.allWodCargoRequests );
	
	//22 Jun 2018	NDL	TFS 39248
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		pxyWodMarineServiceDtl := wodMarineServiceDtl.pxyCreateUpdateProxy();
		if pxyWodMarineServiceDtl &lt;&gt; null then
			pxy.allMarineServiceDetails.add( pxyWodMarineServiceDtl );
		endif;
	endforeach;
	pxy.myTowingVoyage := self.myTowingVoyage;	//22 Jun 2018	NDL	TFS 39248
	
	completedOK := true;
	return pxy;

epilog

	if not completedOK then
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="requiresLengthOfTime" id="986c49c9-a018-48be-876b-5f8fdcf8a20e">
        <source>requiresLengthOfTime(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2018	jlger1	Initial creation 42396

*/

vars

begin
	if self.myToBerth = null then
		return true;
	endif;
	
	if self.myToBerth &lt;&gt; null and self.myToBerth.isLogicalBerth or not self.myToBerth.requiresLengthOfTime then  
		return false;
	endif;
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="bf0f2efc-e8c1-4039-82f6-4d6cd434eb00">
        <updating/>
        <source>setForCreate(_pxyWoDDtl: CM_WorkOrderDtl io; _realWorkOrder: CM_WorkOrder) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/07/2018	jlgdap1		Initial creation TFS 39741 PEL1 Marine Service Timings Changes
// 03/04/2019	jlgdap1		TFS 43694 PEL1 Charging for Vessels that use a Ramp
//
vars
	detail : CM_WodMarineServiceDetail;
	occursDateTime : TimeStamp;

begin
	inheritMethod(_pxyWoDDtl, _realWorkOrder);
	
	//16 Oct 2018	NDL	TFS 41412  and out again 19 Oct 2018
//	if self.myHMSVoyageMovement &lt;&gt; null then
//		occursDateTime := self.getOccursDT;
//		if occursDateTime.date.isValid and self.myHMSVoyageMovement.myMarineServiceTimings &lt;&gt; null then
//			self.myHMSVoyageMovement.myMarineServiceTimings.setMovementDateTimes( occursDateTime, true, false, false );
//		endif;
//	endif;

	//23 Oct 2018	NDL	TFS 41412
	self.enteredOccursDT := self.getOccursDT;
	self.originalHasRamp := _pxyWoDDtl.CM_WodShiftMovement.hasRamp;											// TFS 43694
	self.hasRamp := _pxyWoDDtl.CM_WodShiftMovement.hasRamp;													// TFS 43694
	if self.myHMSVoyageMovement &lt;&gt; null and self.myHMSVoyageMovement.myMarineServiceTimings &lt;&gt; null then	// TFS 43694
				/* Ian says 'don't tick any box automatically and leave it up to the user to confirm on the movement 
									when the vessel moves away from the berth if the ramp was actually used there.'
		self.myHMSVoyageMovement.myMarineServiceTimings.setHasRamp(self.hasRamp);							// TFS 43694
		*/
	endif;																									// TFS 43694
	
	// Update "original" date/times on any pilot and tug details
	foreach detail in self.allMarineServiceDetails do
		if detail.myHMSResource &lt;&gt; null then 
			if detail.myHMSResource.isResourceForClass(HMS_ResourceForPilot)
			or detail.myHMSResource.isResourceForClass(HMS_ResourceForTug) then
				detail.setOriginalDateTime();
			endif;
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WorkOrderDtl" usage="io"/>
        <Parameter name="_realWorkOrder" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d7f25343-f273-4a52-9777-613ef2f3c1dd">
        <updating/>
        <source>setForUpdate( _pxyWoDDtl: CM_WodShiftMovement ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/05/2018	jlgndl1	Initial creation	TFS 38560
03/04/2019	jlgdap1	TFS 43694 PEL1 Charging for Vessels that use a Ramp
*/

vars

	wodMarineServiceDtl : CM_WodMarineServiceDetail;
	pxyWodMarineServiceDtl : CM_WodMarineServiceDetail;
	purgeSet : CM_WodMarineServiceDetailSet;
	voyage : CM_Voyage;
	permitRequest : CM_WodPermitRequest;	
begin

	inheritMethod(_pxyWoDDtl);
	
	self.hasRamp := _pxyWoDDtl.hasRamp; // TFS 40236
	self.starboardBerthed := _pxyWoDDtl.starboardBerthed; // TFS 40236
	if self.myHMSVoyageMovement &lt;&gt; null and self.myHMSVoyageMovement.myMarineServiceTimings &lt;&gt; null then	// TFS 43694
				/* Ian says 'don't tick any box automatically and leave it up to the user to confirm on the movement 
									when the vessel moves away from the berth if the ramp was actually used there.'
		self.myHMSVoyageMovement.myMarineServiceTimings.setHasRamp(self.hasRamp);							// TFS 43694
		*/
	endif;																									// TFS 43694
	
	
	self.bowMarkTo := _pxyWoDDtl.bowMarkTo;
	self.draftAft := _pxyWoDDtl.draftAft;
	self.draftFwd := _pxyWoDDtl.draftFwd;
	self.occursOnDT := _pxyWoDDtl.occursOnDT;
	self.relativeOrderTimeLines := _pxyWoDDtl.relativeOrderTimeLines;
	self.relativeOrderTimePlaunch := _pxyWoDDtl.relativeOrderTimePlaunch;
	self.relativeOrderTimeTugs := _pxyWoDDtl.relativeOrderTimeTugs;
	self.sternMarkTo := _pxyWoDDtl.sternMarkTo;
	
	self.approvedOccursDT := _pxyWoDDtl.approvedOccursDT;	//24 Oct 2018	NDL	TFS 41412
	self.enteredOccursDT := _pxyWoDDtl.enteredOccursDT;	//24 Oct 2018	NDL	TFS 41412
	self.berthArrival := _pxyWoDDtl.berthArrival;	//26 Oct 2018	NDL	TFS 41413
	
	self.myToBerth := _pxyWoDDtl.myToBerth;
	self.myFromBerth := _pxyWoDDtl.myFromBerth;
	
	self.hasRamp := _pxyWoDDtl.hasRamp;				// TFS 43694
	
	self.allWodCargoRequests.clear();
	_pxyWoDDtl.allWodCargoRequests.copy(self.allWodCargoRequests);
	
	//22 Jun 2018	NDL	TFS 39248
	self.myTowingVoyage := _pxyWoDDtl.myTowingVoyage;	
	//epr TFS 41946 10/11/18
	voyage := getMyVoyageObject();
	if voyage &lt;&gt; null and voyage.myHMSVoyageData &lt;&gt; null then
		voyage.myHMSVoyageData.setMyTowingVoyage( _pxyWoDDtl.myTowingVoyage );
	endif;
	
	
	//22 Jun 2018	NDL	TFS 39248 - Find any we need to delete
	create purgeSet transient;
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if _pxyWoDDtl.allMarineServiceDetails.findWodMarineServiceDet( wodMarineServiceDtl.myHMSResource ) = null then
			purgeSet.add( wodMarineServiceDtl );
		endif;
	endforeach;
	if not purgeSet.isEmpty then
		foreach wodMarineServiceDtl in purgeSet do
			self.allMarineServiceDetails.remove( wodMarineServiceDtl );
		endforeach;
		purgeSet.purge();
	endif;
	
	//update or add the rest
	foreach pxyWodMarineServiceDtl in _pxyWoDDtl.allMarineServiceDetails do
		wodMarineServiceDtl := pxyWodMarineServiceDtl.pxyGetRealObject();
		if wodMarineServiceDtl = null then
			// must be an addiional one
			create wodMarineServiceDtl persistent;
			self.allMarineServiceDetails.add( wodMarineServiceDtl );
		endif;
		wodMarineServiceDtl.setForUpdate( pxyWodMarineServiceDtl );
	endforeach;
	
	//21 Sep 2018	NDL	TFS 39741
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if wodMarineServiceDtl.myHMSResource &lt;&gt; null then 
			if wodMarineServiceDtl.myHMSResource.isResourceForClass(HMS_ResourceForPilot)
			or wodMarineServiceDtl.myHMSResource.isResourceForClass(HMS_ResourceForTug) then
				wodMarineServiceDtl.setOriginalDateTime();
			endif;
		endif;
	endforeach;

	//epr 12/10/18 TFS 41310
	if self.myRelatedPermitRequest = null and voyage &lt;&gt; null then
		//find the ETMAL permit
		permitRequest:=voyage.allWorkOrders.getWODPermitForDetailType(self.detailType,WO_STATUS_COMPLETE).CM_WodPermitRequest;
		if permitRequest &lt;&gt; null then
			self.myRelatedPermitRequest:=permitRequest;
		endif;			
	endif;
	
epilog

	delete purgeSet;

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodShiftMovement"/>
    </JadeMethod>
    <JadeMethod name="setMarineDetsFromResourceUsed" id="d2ee5583-653e-4888-8294-6969c4a9f45f">
        <updating/>
        <source>setMarineDetsFromResourceUsed( _resourceUsedSet : HMS_ResourceUsedSet ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2018	jlgndl1	Initial creation	TFS 39248

*/

vars

	wodMarineServiceDtl : CM_WodMarineServiceDetail;
	resourceUsed : HMS_ResourceUsed;
	purgeSet : CM_WodMarineServiceDetailSet;
	

begin
	
	create purgeSet transient;
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if _resourceUsedSet.findResourceUsedFor( wodMarineServiceDtl.myHMSResource ) = null then
			purgeSet.add( wodMarineServiceDtl );
		endif;
	endforeach;
	if not purgeSet.isEmpty then
		foreach wodMarineServiceDtl in purgeSet do
			self.allMarineServiceDetails.remove( wodMarineServiceDtl );
		endforeach;
		purgeSet.purge();
	endif;
	
	if _resourceUsedSet= null or _resourceUsedSet.isEmpty then
		return;
	endif;
	
	foreach resourceUsed in _resourceUsedSet do
		wodMarineServiceDtl := self.allMarineServiceDetails.findWodMarineServiceDet( resourceUsed.myResource );
		if wodMarineServiceDtl = null then
			if self.isTransient then
				create wodMarineServiceDtl transient;
			else
				create wodMarineServiceDtl persistent;
			endif;
			self.allMarineServiceDetails.add( wodMarineServiceDtl );
		endif;
		wodMarineServiceDtl.setProxyFromResourceUsed( resourceUsed );		
	endforeach;

epilog

	delete purgeSet;

end;</source>
        <Parameter name="_resourceUsedSet" type="HMS_ResourceUsedSet"/>
    </JadeMethod>
    <JadeMethod name="setMyHMSVoyageMovement" id="599be573-17b8-455a-9913-d8a288d0bdcd">
        <updating/>
        <source>setMyHMSVoyageMovement(_value : HMS_VoyageMovement) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/09/2018	jlgdap1		Initial creation TFS 40543 WP Time Change does not display all relevant work orders for the Voyage
//
vars

begin
	if self.myHMSVoyageMovement &lt;&gt; _value then
		self.myHMSVoyageMovement := _value;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="setProxyWodShiftMovement" id="6b73d9cc-e582-4bba-ad29-638cfaf3a5c0">
        <updating/>
        <source>setProxyWodShiftMovement(	_bowMarkTo : Decimal;
							_draftAft : Decimal;
							_draftFwd : Decimal;
							_occursOnDT : TimeStamp;
							_relativeOrderTimeLines : Integer;
							_relativeOrderTimePlaunch : Integer;
							_relativeOrderTimeTugs : Integer;
							_sternMarkTo : Decimal;
							_myFromBerth : HMS_Berth;
							_myToBerth : HMS_Berth;
							_allWodCargoRequests : CM_WodCargoRequestSet;
							_towingVoyage : CM_Voyage;
							_hasRamp : Boolean;
							_starboard : Boolean;
							_berthArrivalDT : TimeStamp
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars
	berthForMarks : HMS_Berth;
	voyage : CM_Voyage;
	prevMovement : HMS_VoyageMovement;
	bridgeToBow,   bridgeMark : Decimal [12,2];
	sideTo : Integer;
begin

	self.bowMarkTo := _bowMarkTo;
	self.draftAft := _draftAft;
	self.draftFwd := _draftFwd;
	self.occursOnDT := _occursOnDT;
	self.relativeOrderTimeLines := _relativeOrderTimeLines;
	self.relativeOrderTimePlaunch := _relativeOrderTimePlaunch;
	self.relativeOrderTimeTugs := _relativeOrderTimeTugs;
	self.sternMarkTo := _sternMarkTo;
	
	self.berthArrival := _berthArrivalDT;	//26 Oct 2018	NDL	TFS 41413
	
	// TFS 40236
	self.hasRamp := _hasRamp;
	self.starboardBerthed := _starboard;
	
	self.myFromBerth := _myFromBerth;
	self.myToBerth := _myToBerth;
	voyage:=self.getMyVoyageObject;
	if self.myFromBerth = null then
		
		if voyage &lt;&gt; null then
			prevMovement := voyage.myHMSVoyageData.allVoyageMovements.getAtKeyLeq(self.occursOnDT);
			if prevMovement &lt;&gt; null then
				self.myFromBerth:= prevMovement.getMyBerth;
			endif;
		endif;
	endif;
	
	if self.sternMarkTo = null and self.myToBerth &lt;&gt; null and voyage &lt;&gt; null then
		if self.starboardBerthed then
			sideTo := OrientStarboardSideTo;
		else
			sideTo := OrientPortSideTo;		
		endif;
	
		self.myToBerth.getBowSternBridgeMarksFromLOA(voyage.myHMSVoyageData.dim_LengthOverall, voyage.myHMSVoyageData.dist_BridgeToBow, sideTo, self.bowMarkTo, self.sternMarkTo, bridgeMark, null, berthForMarks,false);
	endif;
	
	self.allWodCargoRequests.clear();
	if _allWodCargoRequests &lt;&gt; null then
		_allWodCargoRequests.copy(self.allWodCargoRequests);
	endif;
	
	self.myTowingVoyage := _towingVoyage;	//22 Jun 2018	NDl	TFS 39248
	
epilog

end;</source>
        <Parameter name="_bowMarkTo" type="Decimal"/>
        <Parameter name="_draftAft" type="Decimal"/>
        <Parameter name="_draftFwd" type="Decimal"/>
        <Parameter name="_occursOnDT" type="TimeStamp"/>
        <Parameter name="_relativeOrderTimeLines" type="Integer"/>
        <Parameter name="_relativeOrderTimePlaunch" type="Integer"/>
        <Parameter name="_relativeOrderTimeTugs" type="Integer"/>
        <Parameter name="_sternMarkTo" type="Decimal"/>
        <Parameter name="_myFromBerth" type="HMS_Berth"/>
        <Parameter name="_myToBerth" type="HMS_Berth"/>
        <Parameter name="_allWodCargoRequests" type="CM_WodCargoRequestSet"/>
        <Parameter name="_towingVoyage" type="CM_Voyage"/>
        <Parameter name="_hasRamp" type="Boolean"/>
        <Parameter name="_starboard" type="Boolean"/>
        <Parameter name="_berthArrivalDT" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setRequiredByDT" id="cb81ad14-a4f4-45c9-8b43-577cf314742b">
        <updating/>
        <source>setRequiredByDT(_dateTime: TimeStamp) updating;

/*

Purpose:		TFS 41084 SAT29SEP18 PEL1 ON CALL	

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2018	jlgab1	Initial creation

*/

vars
	span : TimeStampInterval;
begin
	inheritMethod(_dateTime);

	self.occursOnDT := _dateTime;
	
	//23 Oct 2018	NDL	TFS 41084
	if self.myHMSVoyageMovement &lt;&gt; null then
		self.myHMSVoyageMovement.setOccursOnDT( self.occursOnDT );
	endif;
	
epilog

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="e7a927eb-1b6a-4baf-aa86-d6387090135f">
