    <JadeMethod name="getTerminalAuditText" id="a5476401-171b-41e4-b9d3-91c3a94203d7">
        <source>getTerminalAuditText():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2020	jlgndl1	Initial creation	TFS 48407

*/

vars

	txt : String;
	tmpStr : String;

begin

	txt[10000] := '*';
	txt := null;
	
	if self.bank &lt;&gt; null then
		tmpStr := self.bank.code;
		txt := txt &amp; "Fin IO - Bank " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	if self.exportPath &lt;&gt; null then
		tmpStr := self.exportPath.trimBlanks;
		txt := txt &amp; "Fin IO - Export path " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	if self.firstMonthOfFinYear &lt;&gt; null then
		tmpStr := self.firstMonthOfFinYear.String;
		txt := txt &amp; "Fin IO - 1st Month of year " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	if self.glPeriod &lt;&gt; null then
		tmpStr := self.glPeriod.trimBlanks;
		txt := txt &amp; "Fin IO - GL Period " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	if self.glYear &lt;&gt; null then
		tmpStr := self.glYear.trimBlanks;
		txt := txt &amp; "Fin IO - GL year " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	if self.name &lt;&gt; null then
		tmpStr := self.name.trimBlanks;
		txt := txt &amp; "Fin IO " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	if self.remarks &lt;&gt; null then
		tmpStr := self.remarks.trimBlanks;
		txt := txt &amp; "Fin IO - Remarks " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
