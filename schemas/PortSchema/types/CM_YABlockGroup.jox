    <JadeMethod name="getNextGroup" id="0492edd0-1188-4414-b994-3d25e9099d50">
        <source>getNextGroup(_groupArray : CM_YABlockGroupArray input) : CM_YABlockGroup protected;

// Created by cnwdvb1 on 04 May 2006

vars

	group	: CM_YABlockGroup;
	found	: Boolean;

begin

	// Only need to look through once as groups are always
	// called in group order. So if the last group was looking
	// for the next group then there wouldn't be one because the first
	// group should already have been processed by this stage.
	foreach group in _groupArray discreteLock do
		if found then
			return group;
		endif;
		if group = self then
			found := true;
		endif;
	endforeach;
	
	return null;

end;</source>
        <access>protected</access>
        <Parameter name="_groupArray" type="CM_YABlockGroupArray" usage="input"/>
        <ReturnType type="CM_YABlockGroup"/>
    </JadeMethod>
