    <JadeMethod name="create" id="8131f344-443c-41a7-986d-1f9b74ca692c">
        <updating/>
        <source>create() updating;
/*

Purpose:			Force all error responses to be JSON

Parameters:			

Return Value:		

Date			Who		Reason
07 April 2022	navmd1	Initial creation - 52829 REST API Refactor

*/

vars

begin
	self.exceptionFormat := JadeRestService.OutputFormat_Json;
epilog

end;</source>
