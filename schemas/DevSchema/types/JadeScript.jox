    <JadeMethod name="rsPar38502" id="653e4488-189a-4f28-8d38-f6c2d4c7ce92">
        <source>rsPar38502();
constants
	Term : String = "UT";
	StartTime = "01/01/2016 00:00".TimeStamp;
	EndTime	= "31/12/2016 23:59:59.999".TimeStamp;
//	AClass  : String = "CM_ReceiveRail";
vars
	camProtocolList : CM_ObjectArray;
	trxList : IntegerArray;
	camProtocol : CM_CamProtocol;
	transaction : CM_TITransaction;
	transaction2 : CM_TITransaction;
	transList : CM_TITransactionByDateOrdDict;
	camFile : CM_CamFile;
	obj : Object;
	objArray : CM_ObjectArray;
	terminal : CM_Terminal;
	iter : Iterator;
	file : File;
	msg : String;
	now : TimeStamp;
	found : Boolean;
	trxType : Integer;
	str : String;
//	aClass : Class;
	camAgent : CM_CamControllerAgent;
	messageTypeArray : IntegerArray;
begin
//	aClass := currentSchema.getClass(AClass);
	app.initialize();
	terminal := app.myRoot.allTerminals[Term];
	if terminal = null then
		app.writeLog("Terminal "&amp;Term&amp;" does not exist.", LogINFO);
		return;
	endif;
	app.setMyTerminal(terminal);
//	trnxType := global.getTiTxnTypeForClass(aClass);
	app.writeLog("Looking for transactions  from "&amp;StartTime.dataDumpFormat&amp;' to '&amp;EndTime.dataDumpFormat, LogINFO);
	create camProtocolList transient;
	create file transient;
	create trxList transient;
	create camAgent transient;
	create camFile transient;
	create messageTypeArray transient;
	file.fileName := "C:\cnwdmast\logs\CamsCheck_"&amp;now.formatAsYYYYMMDDHHmmSS&amp;".txt";
	app.writeLog("file "&amp;file.fileName, 0);
	file.mode := File.Mode_Output;
	file.open;
	file.writeLine("Looking for transactions  from "&amp;StartTime.dataDumpFormat&amp;' to '&amp;EndTime.dataDumpFormat);
	foreach camProtocol in terminal.camProtocols do
		if camProtocol.isUserDefinedReport or 
		   camProtocol.isUserDefinedEventReport then
			continue;
		endif;
		if camProtocol.protocolDesc.isKindOf(CM_CamVERMASDesc) then
			continue;
		endif;
		if camProtocol.status = CAM_HOLDSTATUS then
			continue;
		endif;
		if not camProtocol.getLogExcludedTransactions then
			continue;
		endif;
		camProtocolList.add(camProtocol);
		app.writeLog("cam protocol added "&amp;camProtocol.code, LogINFO);
		foreach str in camProtocol.registeredTransactions do
			trxType := str.Integer;
			if not trxList.includes(trxType) then
				trxList.add(trxType);
//		if camProtocol.registeredTransactions.includes(trxType.String) then 
				app.writeLog("trxType "&amp;trxType.String, LogINFO);
			endif;
		endforeach;
	endforeach;
	
	camAgent.setPropertyValue("protocolLog", file);
	iter := terminal.allTITransactionsByCamsTS.createIterator();
	foreach trxType in trxList do
		terminal.allTITransactionsByCamsTS.startKeyGeq(trxType, StartTime, iter);
		while iter.next(transaction) do
			if not transaction.myTrackedItem.isContainer then
				continue;
			endif;
	//		app.writeLog("transaction "&amp;transaction.String&amp;' '&amp;transaction.camsTimeStamp.String, LogAlways);
			if transaction.type &lt;&gt; trxType or
				transaction.camsTimeStamp &gt; EndTime then 
				app.writeLog("end of transactions "&amp;transaction.String&amp;' '&amp;transaction.camsTimeStamp.String, LogINFO);
				break;
			endif;
			foreach obj in camProtocolList do
				camProtocol := obj.CM_CamProtocol;
				if not camProtocol.registeredTransactions.includes(trxType.String) then
					continue;
				endif;
				if camProtocol.isCAMGroupMatch(transaction, null, false) then
					transList := transaction.myTrackedItem.getAllTransactions();
					found := false;
					foreach transaction2 in transList do
						if not transaction2.isKindOf(CM_InfoEDISent) then
							continue;
						endif;
						if transaction2.CM_InfoEDISent.myCamProtocol &lt;&gt; camProtocol then
							continue;
						endif;
						if transaction2.CM_InfoEDISent.myOtherTransaction &lt;&gt; transaction then
							continue;
						endif;
						found := true;
						break;
					endforeach;
					if not found then
						msg := "Found transaction  "&amp;transaction.String&amp;' '&amp;transaction.myTrackedItem.String&amp;' '&amp;transaction.myTrackedItem.id&amp;' '&amp;transaction.myTrackedItem.isEmptyFullString&amp;' '&amp;transaction.createdTime.String&amp;' '&amp;transaction.camsTimeStamp.String&amp;' not in '&amp;camProtocol.code;
						file.writeLine(msg);
						app.writeLog(msg, LogINFO);
						camAgent.setPropertyValue("logExcludedTransactions", true);
						if camProtocol.protocolDesc.includeTransaction (transaction, transaction.camsTimeStamp, StartTime, EndTime, 
									camProtocol, camProtocol.camGroup, camAgent, true, null) then			// TFS 48785
						endif;
						if camProtocol.protocolDesc.isTransactionToBeProcessed(camProtocol, transaction, camAgent) then 
						endif;
						camProtocol.protocolDesc.getMessageType(transaction, messageTypeArray, camProtocol, camAgent);
						camProtocol.protocolDesc.processTransaction(transaction, camProtocol, camAgent, camFile);
						camFile.camMessageByActivityVoyage.purge();
						messageTypeArray.clear;
	//					write msg;
					endif;
				endif;
			endforeach;
		endwhile;
	endforeach;
epilog
	file.close();
	delete file;
	delete camProtocolList;
	delete trxList;
	delete iter;
	camAgent.setPropertyValue("protocolLog", null);
	delete camAgent;
	delete messageTypeArray;
	camFile.camMessageByActivityVoyage.purge();
	delete camFile;
end;
</source>
    </JadeMethod>
    <JadeMethod name="rsReceiveDT" id="5d9666d1-9bfd-4c1b-b4f9-fa287eeed08d">
        <source>rsReceiveDT();

vars
	container : CM_Container;
	ti : CM_TrackedItem;
	receive : CM_Receive;
begin
	app.initialize;
	app.setMyTerminal(app.myRoot.allTerminals["UT"]);
	foreach ti in app.myPassport.myTerminal.allOnsiteTIsByCargoTypeId do
		receive := ti.getTransReceiveFirst;
		if receive &lt;&gt; null and receive.dateTime.String &lt;&gt; ti.receivedDT.String then
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;ti.id&amp;' '&amp;ti.cargoTypeDescr&amp;' createdTime='&amp;ti.createdTime.String&amp;' receivedDT='&amp;ti.receivedDT.String&amp;' receive.dateTime='&amp;receive.dateTime.String&amp;' '&amp;receive.String;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="rsScanTranLog" id="bdd261e0-116e-430e-a2c8-e6b96bcaf74c">
        <source>rsScanTranLog();
//
//22 February 2018	jlgrs1	Initial creation
//
constants
	FileDir			= 'D:\Portdata\QNS\TFS36963\QNSPJMT_LogArchive_20180217235904\qnspjmt\logs\archive\cnwhousekeeper';
//	PeriodFrom		= 'Period from';
