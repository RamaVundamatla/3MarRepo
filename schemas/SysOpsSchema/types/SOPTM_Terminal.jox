    <JadeMethod name="getRowDifference" id="71a91156-5b26-444e-99b3-f5f91a226024">
        <updating/>
        <source>getRowDifference(rowNumber : Integer) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2021	navlw1	Initial creation

*/

vars
	theForm         	: SOP_TableMaintForm;
	rowDifference		: Integer;
	row 				: Integer;
	entRow 				: EntTableRowTransient;
	lastMeasurementRow 	: Integer;
	lastMeasurementName : String;
	theTable			: CM_EntryTable;	// ### TFS 55144 17Oct2022 NAVPW1
	fixedRows,
	startIndex,
	tableRows			: Integer;			// ### TFS 55144 17Oct2022 NAVPW1
	
begin
	theForm := self.myForm;
	
	// ### TFS 55144 17Oct2022 NAVPW1
	theTable := theForm.tblInput2;
	
	fixedRows := theTable.fixedRows;
	
	if fixedRows = 0 then
		startIndex := 1;
	else
		startIndex := fixedRows + 1;
	endif;
	
	tableRows := theTable.rows;
	
	// ### TFS 55144 17Oct2022 NAVPW1
	
	//foreach row in theForm.tblInput2.fixedRows + 1 to theForm.tblInput2.rows do
	foreach row in startIndex to tableRows do	// ### TFS 55144 17Oct2022 NAVPW1
		if row &gt; rowNumber then
			break;
		endif;
		entRow := theTable.accessRow(row).itemObject.EntTableRowTransient;
		if entRow.name.isMeasurementType then
			lastMeasurementName := entRow.getHeadingUnaltered;
		else
			if entRow.getHeadingUnaltered = lastMeasurementName then
				rowDifference := rowDifference + 1;
				lastMeasurementRow := row;
			else
				lastMeasurementName := null;
			endif;
		endif;
	endforeach;
	
	//if rowNumber = lastMeasurementRow + 1 then
	if lastMeasurementRow &gt; 0 and rowNumber = lastMeasurementRow + 1 then	// ### TFS 55144 17Oct2022 NAVPW1
		rowDifference := rowDifference + 1;
	endif;
	
	return rowDifference;
epilog

end;</source>
        <Parameter name="rowNumber" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
