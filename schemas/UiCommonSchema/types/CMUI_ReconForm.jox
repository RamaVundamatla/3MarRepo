    <JadeMethod name="doTblExtraInfo" id="4251fc08-11f5-4265-9657-d1e0b27c37fe">
        <updating/>
        <source>doTblExtraInfo(_obj : Object; _tbl : CM_DataTable io) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 09 August 2007
//
//----------------------------------------------------------------------

vars
	dataContainer	: CM_DataContainer;
	
begin
	// DISPLAY INFO
	_tbl.rows := 0;
	_tbl.userObject := null;
	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
	dataContainer.displayMode := DISPLAY_MODE_ACTUAL;
	
	if _obj.isKindOf(CM_BookingRefItem) then
		_obj.CM_BookingRefItem.getExtraInfo(dataContainer);
	elseif _obj.isKindOf(CM_TrackedItem) then
		_obj.CM_TrackedItem.getExtraInfo(dataContainer);
	elseif _obj.isKindOf(CM_BOLDtl) then
		_obj.CM_BOLDtl.getExtraInfo(dataContainer);
	else
		return;
	endif;
	
	_tbl.userObject := _obj; // this is used to redraw this info
	
	self.showExtraInformation(dataContainer, _tbl, false,false, 4, 1, 4, 1, 1);
	self.doResizeColumnWidths(_tbl, true);
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_tbl" type="CM_DataTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="d13cccb2-df6b-4e71-bbef-26079ae893f7">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//06 August 2009	cnwdw1	
//
vars
	xml: String;
begin
	xml := inheritMethod() &amp; 
		   self.tblExpected.getXmlStrForColumns(true) &amp; 
		   self.tblActual.getXmlStrForColumns(true) &amp;
		   self.tblUnreconciled.getXmlStrForColumns(true);
	
	// Splitter positions
	xml := xml &amp;
		   global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' name="sptLeft"') &amp;
		   global.formatAsXML(XMLTag_Ratio, self.sptLeft.leftToRightRatio.String) &amp;
		   global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' name="sptLeft"');
		   
	xml := xml &amp;
		   global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' name="sptRight"') &amp;
		   global.formatAsXML(XMLTag_Ratio, self.sptRight.leftToRightRatio.String) &amp;
		   global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' name="sptRight"');
	
	return xml;	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
