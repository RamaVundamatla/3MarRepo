    <JadeMethod name="getJobTypeForWLE" id="c17ab95a-137b-4c43-8ba7-963222e27a88">
        <source>getJobTypeForWLE(_wle: CM_WorkListEntry input): String;
/*
Purpose:			

Return Value:		

Date		Who		Reason
06/11/2006	cnwer1	Initial creation - PAR#xxxx
26/05/2010	cnwdap1	CCMS 1116 Tranship changes
*/
vars

begin

	if _wle.myTrackedItem &lt;&gt; null then
		if _wle.myTrackedItem.isTranshipItem then	// PAR #23645 CCMS 1116
			// PAR 25687 return "TRANSHIP";	 // PAR #23645 CCMS 1116
			return app.getErrorString(RailJob_TS);
		elseif _wle.myTrackedItem.isExport then
			// PAR 25687 return "EXPORT"; 
			return app.getErrorString(RailJob_IN);
		elseif _wle.myTrackedItem.isStorage then
			//cnwrd1 par 28500 5.3.2012
			return app.getErrorString(RailJob_Storage);			
		else
			// PAR 25687 return "IMPORT"; 
			return app.getErrorString(RailJob_OUT);
		endif;
	endif;
	
	//10 Dec 2010	NDL	Par 26568
	if self.isRelease() then
		return app.getErrorString(RailJob_OUT);
	else
		return app.getErrorString(RailJob_IN);
	endif;
	
	return null;


epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="3f018122-f816-4afe-9ded-7df5313c4bfe">
        <source>getMyTerminal(): CM_Terminal ;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
