DmastPrenoteCustomsStatus2 = '{"allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"customsReferences":[{"alternateId":"PRETEST02","id":"PRETEST02","packages":{"remaining":0,"total":0},"position":2,"remarks":"PRETEST02","retentionPeriod":"2024-01-15","status":"HELD","typeId":"PRETEST02"}],"stops":[{"action":"HOLD","description":"CustomsExport(CEDO)","id":2,"requiredInfo":""}]}';	// 30.07.24	navhn30	TFS #65415
WmastPrenoteCustomsStatus1 = ' {"allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"customsReferences":[{"alternateId":"PRETEST01","id":"PRETEST01","packages":{"remaining":20,"total":15},"position":1,"remarks":"PRETEST01","retentionPeriod":"2024-01-15","status":"HELD","typeId":"PRETEST01"}],"stops":[{"action":"HOLD","description":"CustomsExport(CEDO)","id":2,"requiredInfo":""}]}';
WmastPrenoteCustomsStatus2 = '{"allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"customsReferences":[{"alternateId":"PRETEST02","id":"PRETEST02","packages":{"remaining":0,"total":0},"position":2,"remarks":"PRETEST02","retentionPeriod":"2024-01-15","status":"HELD","typeId":"PRETEST02"}],"stops":[{"action":"HOLD","description":"CustomsExport(CEDO)","id":2,"requiredInfo":""}]}';	// 30.07.24	navhn30	TFS #65415
vars

	realTrackedItem,
	trackedItem 		: CM_TrackedItem;
	operator 			: CM_Operator;
	voyage				: CM_Voyage;
	root				: CM_Root;
	cargoId 			: String;
	terminal 			: CM_Terminal;
	bs					: CM_BlockStack;
	customsReference	: CM_CustomsReference;
 	loginJson,
	incomingJsonString,
	terminalCode 		: String;
	expectFailure 		: Boolean;
	stops				: CM_StopsByIdDict;
	stop				: CM_Stops;
	isStopPresent		: Boolean;
	operatorCode	: String;
	passport		: CM_Passport;
	cargoType		: CM_CargoType;
	cargoSubType	: CM_Product;
	vessel			: CM_Vessel;
	prenote1, 
	prenote2		: CM_TrackedItem;
	bookingRef1,
	bookingRef2		:CM_BookingRef;
	prenoteUniqBooking, noPINs : Any;
	query, response	    : String;
	sent_1,exp_1		: String;
	isSubTerminalsOn	: Any;
	params, output		: String;
	
begin
	self.deleteContainer(CONTAINERID);
	self.assertNoTrxErrorsOrWarnings();
	
	self.deleteTerminalArea(BSName);
	
	bs := self.addBlockStack( BSName, 32, null);	
	self.assertTrueMsg( bs &lt;&gt; null, BSName &amp; " block stack not created");

	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	terminal := self.getTerminal();
	
	trackedItem := self.addContainerAtLocation(CONTAINERID, operator, "2200", "FCL", TI_IMEX_STATUS_EXPORT, bs);

	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	incomingJsonString := JsonString1;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCustomsStatus.name, loginJson, incomingJsonString, expectFailure);
	
		self.assertNoTrxErrorsOrWarnings();
	
	realTrackedItem := app.myRoot.lookupTrackedItem(CONTAINERID, null, TI_STATE_NORMAL, null, false, terminal, true);
	
	//Check all customs references is not null/set	
	self.assertTrueMsg(realTrackedItem.allCustomsReferences.isNotEmpty, "Customs References is empty");
	
	//Check custom references objects to make sure they are correctly set
	customsReference := realTrackedItem.allCustomsReferences[ReferenceType1, ReferenceNumber1, PositionNumber1];
	self.assertNotNullMsg(customsReference, "Customs Reference 1");
	
	self.assertNotNullMsg(customsReference.myTrackedItem, "Tracked Item");
	self.assertTrueMsg(customsReference.referenceType = ReferenceType1, "Expected: " &amp; ReferenceType1 &amp; " | Actual: " &amp; customsReference.referenceType);
	self.assertTrueMsg(customsReference.referenceNumber = ReferenceNumber1, "Expected: " &amp; ReferenceNumber1 &amp; " | Actual: " &amp; customsReference.referenceNumber);
	self.assertTrueMsg(customsReference.positionNumber = PositionNumber1, "Expected: " &amp; PositionNumber1.asStringJMT() &amp; " | Actual: " &amp; customsReference.positionNumber.asStringJMT());
	self.assertTrueMsg(customsReference.status = Status1, "Expected: " &amp; Status1 &amp; " | Actual: " &amp; customsReference.status);
	self.assertTrueMsg(customsReference.customsContol = CustomsControl1, "Expected: " &amp; CustomsControl1 &amp; " | Actual: " &amp; customsReference.customsContol);
	self.assertTrueMsg(customsReference.objectName = ObjectName1, "Expected: " &amp; ObjectName1 &amp; " | Actual: " &amp; customsReference.objectName);
	self.assertTrueMsg(customsReference.packagesTotal = TotalPackages1, "Expected: " &amp; TotalPackages1.asStringJMT() &amp; " | Actual: " &amp; customsReference.packagesTotal.asStringJMT());
	self.assertTrueMsg(customsReference.packagesRemaining = PackagesRemaining1, "Expected: " &amp; PackagesRemaining1.asStringJMT() &amp; " | Actual: " &amp; customsReference.packagesRemaining.asStringJMT());
	self.assertTrueMsg(customsReference.retentionPeriod = UpdRetentionPeriod1.asDateJMT, "Expected: " &amp; UpdRetentionPeriod1 &amp; " | Actual: " &amp; customsReference.retentionPeriod.asStringJMT);

	//Checking created Stops
	stops := realTrackedItem.getAllStops();
	foreach stop in stops do
		if stop.id = 1 then
			isStopPresent	:= true;
		endif;
	endforeach;	
	self.assertTrue(isStopPresent);
	
	incomingJsonString := JsonString2;
	expectFailure := false;
	isStopPresent := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCustomsStatus.name, loginJson, incomingJsonString, expectFailure);
	
		self.assertNoTrxErrorsOrWarnings();
	
	realTrackedItem := app.myRoot.lookupTrackedItem(CONTAINERID2, null, TI_STATE_NORMAL, null, false, terminal, true);
	
	//Check all customs references is not null/set	
	self.assertTrueMsg(realTrackedItem.allCustomsReferences.isNotEmpty, "Customs References is empty");
	
	//Check custom references objects to make sure they are correctly set
	customsReference := realTrackedItem.allCustomsReferences[ReferenceType2, ReferenceNumber2, PositionNumber2];
	self.assertNotNullMsg(customsReference, "Customs Reference 2");	
	self.assertNotNullMsg(customsReference.myTrackedItem, "Tracked Item");	
	self.assertTrueMsg(customsReference.referenceType = ReferenceType2, "Expected: " &amp; ReferenceType2 &amp; " | Actual: " &amp; customsReference.referenceType);
	self.assertTrueMsg(customsReference.referenceNumber = ReferenceNumber2, "Expected: " &amp; ReferenceNumber2 &amp; " | Actual: " &amp; customsReference.referenceNumber);
	self.assertTrueMsg(customsReference.positionNumber = PositionNumber2, "Expected: " &amp; PositionNumber2.asStringJMT() &amp; " | Actual: " &amp; customsReference.positionNumber.asStringJMT());
	self.assertTrueMsg(customsReference.status = Status2, "Expected: " &amp; Status2 &amp; " | Actual: " &amp; customsReference.status);
	self.assertTrueMsg(customsReference.customsContol = CustomsControl2, "Expected: " &amp; CustomsControl2 &amp; " | Actual: " &amp; customsReference.customsContol);
	self.assertTrueMsg(customsReference.objectName = ObjectName2, "Expected: " &amp; ObjectName2 &amp; " | Actual: " &amp; customsReference.objectName);
	self.assertTrueMsg(customsReference.packagesTotal = TotalPackages2, "Expected: " &amp; TotalPackages2.asStringJMT() &amp; " | Actual: " &amp; customsReference.packagesTotal.asStringJMT());
	self.assertTrueMsg(customsReference.packagesRemaining = PackagesRemaining2, "Expected: " &amp; PackagesRemaining2.asStringJMT() &amp; " | Actual: " &amp; customsReference.packagesRemaining.asStringJMT());
	self.assertTrueMsg(customsReference.retentionPeriod = UpdRetentionPeriod2.asDateJMT, "Expected: " &amp; UpdRetentionPeriod2 &amp; " | Actual: " &amp; customsReference.retentionPeriod.asStringJMT);
	
	customsReference := realTrackedItem.allCustomsReferences[ReferenceType3, ReferenceNumber3, PositionNumber3];
	self.assertNotNullMsg(customsReference, "Customs Reference 3");
	self.assertNotNullMsg(customsReference.myTrackedItem, "Tracked Item");	
	self.assertTrueMsg(customsReference.referenceType = ReferenceType3, "Expected: " &amp; ReferenceType3 &amp; " | Actual: " &amp; customsReference.referenceType);
	self.assertTrueMsg(customsReference.referenceNumber = ReferenceNumber3, "Expected: " &amp; ReferenceNumber3 &amp; " | Actual: " &amp; customsReference.referenceNumber);
	self.assertTrueMsg(customsReference.positionNumber = PositionNumber3, "Expected: " &amp; PositionNumber3.asStringJMT() &amp; " | Actual: " &amp; customsReference.positionNumber.asStringJMT());
	self.assertTrueMsg(customsReference.status = Status3, "Expected: " &amp; Status3 &amp; " | Actual: " &amp; customsReference.status);
	self.assertTrueMsg(customsReference.customsContol = CustomsControl3, "Expected: " &amp; CustomsControl3 &amp; " | Actual: " &amp; customsReference.customsContol);
	self.assertTrueMsg(customsReference.objectName = ObjectName3, "Expected: " &amp; ObjectName3 &amp; " | Actual: " &amp; customsReference.objectName);
	self.assertTrueMsg(customsReference.packagesTotal = TotalPackages3, "Expected: " &amp; TotalPackages3.asStringJMT() &amp; " | Actual: " &amp; customsReference.packagesTotal.asStringJMT());
	self.assertTrueMsg(customsReference.packagesRemaining = PackagesRemaining3, "Expected: " &amp; PackagesRemaining3.asStringJMT() &amp; " | Actual: " &amp; customsReference.packagesRemaining.asStringJMT());
	self.assertTrueMsg(customsReference.retentionPeriod = UpdRetentionPeriod3.asDateJMT, "Expected: " &amp; UpdRetentionPeriod3 &amp; " | Actual: " &amp; customsReference.retentionPeriod.asStringJMT);

	self.assertNotNullMsg(realTrackedItem.allTransactions.getLastTransOfType(TRANS_TYPE_EDIT, null), "An Edit transaction has not been created"); // 27/02/2024	navcs2	Defect 62587
	
	//Checking Cleared Stops
	stops := realTrackedItem.getAllStops();
	foreach stop in stops do
		if stop.id = 1 then
			isStopPresent	:= true;
		endif;
	endforeach;	
	self.assertTrue(not isStopPresent);
	
// 23.07.24		navhn30		TFS 65091	Start

	isSubTerminalsOn := self.setTerminalConfig(IsSubTerminalsOn, false);
	prenoteUniqBooking := self.setTerminalConfig(PrenoteUniqBooking, true);
	noPINs := self.setTerminalConfig(NoPINs, true).Boolean;
	
	self.deleteCargo(TestCargoId,TestCargoType);
	self.deleteCargo(TestCargoId1,TestCargoTypeCont);
	self.deleteTrackedItem(cargoId, true);

	root := app.myRoot;
	passport := app.myPassport;
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	terminal := root.allTerminals[terminalCode];
	operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	operator := root.allOperators[operatorCode];
	self.assertNotNullMsg(operator, "Operator for '" &amp; operatorCode &amp; "' not found");
	
	cargoType := root.getCargoTypeFromAbbrevOrDescr(TestCargoType);
	self.assertNotNullMsg(cargoType, "Cargo Type PAPER not found");
	cargoSubType := cargoType.allProducts[null, TestCargoSubType];
	self.assertNotNullMsg(cargoSubType, "Cargo Subtype ROLLS not found");
	
	// Set up - delete vessel, voyage, terminal area, prenotes, onsite cargo, onship cargo
	self.deleteVoyage(ThisVoyage);
	voyage := self.getVoyage(ThisVoyage);
	self.assertTrueMsg(voyage = null, "Voyage " &amp; ThisVoyage &amp; " not deleted");
	self.deleteVessel(ThisVessel);
	vessel := self.getVessel(ThisVessel);
	self.assertTrueMsg(vessel = null, "Vessel " &amp; ThisVessel &amp; " not deleted");
	self.deleteTerminalArea(ThisBlockStack);
	
	// Create Vessel / Voyage
	self.createVesselVoyage(ThisVoyage, ThisVessel, operator);
	voyage := self.getVoyage(ThisVoyage);
	self.assertNotNullMsg(voyage, "Voyage " &amp; ThisVoyage &amp; " not found");
	
	bookingRef1 := self.addBookingForContainer(UTBookingRef1,operator,voyage,"DEHAM","2200","GENL");
	bookingRef2 := self.addBookingForContainer(UTBookingRef2,operator,voyage,"DEHAM","2200","GENL");
	
	loginJson := null;	// Use default (REST) operator
	
	//Creation of new tracked item
	// Create Prenote
	self.opts.purge;
	self.opts.addAssociation("CargoType", cargoType.id);
	self.opts.addAssociation("cargoSubType", cargoSubType);
	self.opts.addAssociation("BookingItem", bookingRef1.allBookingRefItems.first);
	prenote1 := self.addPrenoted(TestCargoId);
	self.opts.addAssociation("BookingItem", bookingRef2.allBookingRefItems.first);
	prenote2 := self.addPrenoted(TestCargoId);
	
	beginTransaction;
	prenote1.setMyVoyage(voyage, passport);
	prenote1.setPropertyValue(CM_TrackedItem::consignee.name, "UTCC1");
	prenote1.setPropertyValue(CM_TrackedItem::consignor.name, "UTCC2");
	prenote1.setPropertyValue(CM_TrackedItem::remarks.name, "Prenote Remarks");
	prenote1.setAlternativeId("UT63113-01");
	prenote1.setDestinationPort("NZAKA");
	prenote1.setWeightCargo(2000.0000);
	prenote1.setWeightTare(200.0000);
	prenote1.setTotalWeightWithoutTrans(2200.0000);
	prenote1.CM_BreakBulkGeneric.setGrammage(360.0000);
	prenote1.CM_BreakBulkGeneric.setGrade("FIRST");
	prenote1.CM_BreakBulkGeneric.setDiameter(1000.000);
	prenote1.CM_BreakBulkGeneric.setRollingLength(12345.0000);
	prenote1.setHeight(200.000);
	prenote1.setWidth(150.000);
	prenote1.setLength(5000.000);

	prenote2.setMyVoyage(voyage, passport);
	prenote2.setPropertyValue(CM_TrackedItem::consignee.name, "UTCC1");
	prenote2.setPropertyValue(CM_TrackedItem::consignor.name, "UTCC2");
	prenote2.setPropertyValue(CM_TrackedItem::remarks.name, "Prenote Remarks");
	prenote2.setAlternativeId("UT63113-02");
	prenote2.setDestinationPort("NZAKA");
	prenote2.setWeightCargo(2000.0000);
	prenote2.setWeightTare(200.0000);
	prenote2.setTotalWeightWithoutTrans(2200.0000);
	prenote2.CM_BreakBulkGeneric.setGrammage(360.0000);
	prenote2.CM_BreakBulkGeneric.setGrade("FIRST");
	prenote2.CM_BreakBulkGeneric.setDiameter(1000.000);
	prenote2.CM_BreakBulkGeneric.setRollingLength(12345.0000);
	prenote2.setHeight(200.000);
	prenote2.setWidth(150.000);
	prenote2.setLength(5000.000);
	commitTransaction;
	
	incomingJsonString := PrenoteJsonString1;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCustomsStatus.name, loginJson, incomingJsonString, expectFailure);
	
	self.logMessage("Scenario 1 - Passing Prenote with same Id");
	params := "/Cargo/" &amp; TestCargoId &amp; "/" &amp; "PAPER" &amp; "/" &amp; '3' &amp; "?MasterTerminalAPI=true";
	query := "&amp;BookingId=BK63082-01";	
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetCustomsStatus.name, loginJson,query,params,expectFailure,response);
	if app.isRunningInDMAST() then
		output := DmastPrenoteCustomsStatus1;
	elseif app.isRunningInWMAST() then
		output := WmastPrenoteCustomsStatus1;
	endif;
	sent_1 := response.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	sent_1  := JadeRegex@replaceAll(sent_1 , "", DateTimeRegex, true);
	exp_1 := output.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	exp_1 := JadeRegex@replaceAll(exp_1, "", DateTimeRegex, true);
	self.assertEqualMsg(sent_1,exp_1,"1: CustomsStatus not matched");
	
	incomingJsonString := PrenoteJsonString2;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCustomsStatus.name, loginJson, incomingJsonString, expectFailure);
	
	self.logMessage("Scenario 2 - Passing Prenote with same Id");
	params := "/Cargo/" &amp; TestCargoId &amp; "/" &amp; "PAPER" &amp; "/" &amp; '3' &amp; "?MasterTerminalAPI=true";
	query := "&amp;BookingId=BK63082-02";	
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetCustomsStatus.name, loginJson,query,params,expectFailure,response);
	if app.isRunningInDMAST() then
		output := DmastPrenoteCustomsStatus2;
	elseif app.isRunningInWMAST() then
		output := WmastPrenoteCustomsStatus2;
	endif;
	sent_1 := response.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	sent_1  := JadeRegex@replaceAll(sent_1 , "", DateTimeRegex, true);
	exp_1 := output.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	exp_1 := JadeRegex@replaceAll(exp_1, "", DateTimeRegex, true);
	self.assertEqualMsg(sent_1,exp_1,"2: CustomsStatus not matched");
	
// 23.07.24		navhn30		TFS 65091	end
epilog
	self.setTerminalConfig(IsSubTerminalsOn, isSubTerminalsOn);
	self.setTerminalConfig(PrenoteUniqBooking, prenoteUniqBooking);
	self.setTerminalConfig(NoPINs, noPINs);

end;</source>
