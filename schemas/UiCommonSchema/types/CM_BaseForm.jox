    <JadeMethod name="setColorsFromController" id="0e6f315c-f45d-4206-992a-ed6b3cb5bf44">
        <updating/>
        <source>setColorsFromController(_colorControl : CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     25 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpColorControl	: CM_ColorController;
	infoColor		: Integer;

begin

	if _colorControl = null then
		create tmpColorControl transient;	// the create method of this sets the default colors
	else
		tmpColorControl := _colorControl;
	endif;
	
	//cnwmc5 - PAR #31051 - 30/01/2013
	if not app.isUsingSkin() then
		self.backColor 		:= tmpColorControl.getColorValue(self, tmpColorControl.formBackColor);
	endif;
	
	self.colorControlBack 	:= tmpColorControl.getColorValue(self, tmpColorControl.controlBackColor);
	self.colorHeadingColumn	:= tmpColorControl.getColorValue(self, tmpColorControl.headingColumnColor);
	self.colorRow1			:= tmpColorControl.getColorValue(self, tmpColorControl.rowColor1);
	self.colorRow2			:= tmpColorControl.getColorValue(self, tmpColorControl.rowColor2);
	self.colorValueColumn	:= tmpColorControl.getColorValue(self, tmpColorControl.valueColumnColor);

	// setup modal display window
	infoColor := self.backColor;	//self.getSystemColor(Window.Color_InfoBk);
	
	self.lblModalInfo.backColor		:= infoColor;
	self.lblModalMessage.backColor	:= infoColor;
	self.frmModalDialog.backColor	:= infoColor;
	self.frmProgressCtr.backColor	:= infoColor;
	// ==========================

epilog
	if _colorControl = null then
		delete tmpColorControl;
	endif;

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
