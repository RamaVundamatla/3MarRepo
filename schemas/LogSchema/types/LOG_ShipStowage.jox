    <JadeMethod name="clearTotals" id="e451124a-2245-4323-ad26-eae5a5547441">
        <source>clearTotals(_type : Integer) protected;

/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars

	total	: CMIF_ShipStowageTotals;
	iter	: Iterator;

begin

	iter := self.allTotals.createIterator;
	while iter.next(total) do
		total.clear(_type); 
	endwhile;

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createTotalObjects" id="2f2e301d-a18d-4d8f-b2dd-d710061ec516">
        <source>createTotalObjects() protected;

vars

	totals	: CMIF_ShipStowageTotals;

begin

	create totals transient;
	totals.heading := 'HATCH 1 TOTALS:';
	self.allTotals.add(totals);
	create totals transient;
	totals.heading := 'HATCH 2 TOTALS:';
	self.allTotals.add(totals);
	create totals transient;
	totals.heading := 'HATCH 3 TOTALS:';
	self.allTotals.add(totals);
	create totals transient;
	totals.heading := 'HATCH 4 TOTALS:';
	self.allTotals.add(totals);
	create totals transient;
	totals.heading := 'HATCH 5 TOTALS:';
	self.allTotals.add(totals);
	create totals transient;
	totals.heading := 'VESSEL TOTALS : ' &amp; self.myVoyage.code;
	self.allTotals.add(totals);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPrint" id="4824862b-976e-4679-a594-4b528335e901">
        <source>doPrint(_fr : Frame input) protected;

// cnwdvb1 20 December 2002 

vars

begin

	app.printer.print(_fr);
//	self.myRTFOutputGenerator.printFrame(_fr);

end;</source>
        <access>protected</access>
        <Parameter name="_fr" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPrinterVoyageReport" id="0f0794a4-ba9b-481c-bcbc-39a510ee41d8">
        <updating/>
        <source>doPrinterVoyageReport(_array : ObjectArray; _isFirstTime : Boolean) protected, updating;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars

	
	soh			: CM_SOHLocation;
	
begin

	if not _isFirstTime then
		app.printer.newPage();
	endif;
	soh := _array.first.CMIF_SOHReporter.mySOHLocation;
//	self.myVoyage := soh.myLocationsController.CM_LogVoyageController.myLogVoyage;
	self.myVoyage := soh.myLocationsController.CM_LogVoyageController.myVoyage;
	
	self.createTotalObjects();
	self.setHeaderAndFooter(soh.myOperator);
	self.processReport(_array);
epilog

	self.allTotals.purge;

end;</source>
        <access>protected</access>
        <Parameter name="_array" type="ObjectArray"/>
        <Parameter name="_isFirstTime" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCMIFTotal" id="f52cdcc7-4912-48b2-b076-d1bffdcc9b39">
        <source>getCMIFTotal(_hatch : Integer) : CMIF_ShipStowageTotals protected;

vars

begin

	if _hatch &gt; 0 and _hatch &lt;= self.allTotals.size then
		return self.allTotals[_hatch].CMIF_ShipStowageTotals;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_hatch" type="Integer"/>
        <ReturnType type="CMIF_ShipStowageTotals"/>
    </JadeMethod>
    <JadeMethod name="printDetail" id="efeaba47-2261-42c0-b13a-7b544a52ae7b">
        <source>printDetail(_array : ObjectArray; _place : Integer) protected;

vars
	
	obj			: Object;
	soh			: CM_SOHLocation;
	place		: String;
	code		: CM_ProductLog;
	isFirst		: Boolean;
	hatch,	
	pcs,	
	totalPcs	: Integer;
	currentVol,
	totalVolume	: Decimal[12,3];
	total		: CMIF_ShipStowageTotals;

begin

	isFirst := true;
	place := self.getPlaceString(_place);
	self.lblPlaceDtl.caption := place;
	self.lblPcs1.caption	:= null;
	self.lblVol1.caption	:= null;
	self.lblPcs2.caption	:= null;
	self.lblVol2.caption	:= null;
	self.lblPcs3.caption	:= null;
	self.lblVol3.caption	:= null;
	self.lblPcs4.caption	:= null;
	self.lblVol4.caption	:= null;
	self.lblPcs5.caption	:= null;
	self.lblVol5.caption	:= null;
	foreach obj in _array do
		soh := obj.CM_SOHLocation;
		if isFirst then
			code := soh.myProduct.CM_ProductLog;
			self.lblSupplierDtl.caption		:= code.getDisplayStringForAttribute(ETRow_OperatorCode, true);
			self.lblSpeciesDtl.caption		:= code.speciesCode;
			self.lblGradeDtl.caption		:= code.gradeCode;
			self.lblTypeDtl.caption			:= code.typeCode;
			self.lblTreatmentDtl.caption	:= code.treatmentCode;
			self.lblLengthDtl.caption		:= code.lengthCode;
			isFirst := false;
		endif;
		hatch := soh.myLocationsController.CM_LogVoyageController.hatch;
		pcs 		:= soh.currentQuantity;
		currentVol	:= soh.currentVolume;
		if		hatch = 1 then
			self.lblPcs1.caption	:= pcs.String;
			self.lblVol1.caption	:= currentVol.String;	
		elseif	hatch = 2 then
			self.lblPcs2.caption	:= pcs.String;
			self.lblVol2.caption	:= currentVol.String;	
		elseif	hatch = 3 then
			self.lblPcs3.caption	:= pcs.String;
			self.lblVol3.caption	:= currentVol.String;	
		elseif 	hatch = 4 then
			self.lblPcs4.caption	:= pcs.String;
			self.lblVol4.caption	:= currentVol.String;	
		elseif 	hatch = 5 then
			self.lblPcs5.caption	:= pcs.String;
			self.lblVol5.caption	:= currentVol.String;	
		endif;
		if hatch &lt; 6 then
			total := self.getCMIFTotal(hatch);
			if  total &lt;&gt; null then
				total.addPcs(pcs, _place);
				total.addVolume(soh.currentVolume, _place);
			endif;
			totalPcs					:= totalPcs + pcs;
			totalVolume					:= totalVolume + currentVol;	
		endif;
	endforeach;		
	self.lblPcs6.caption			:= totalPcs.String;
	self.lblVol6.caption			:= totalVolume.String;
	total := self.getCMIFTotal(6);
	if total &lt;&gt; null then
		total.addPcs(totalPcs, _place);
		total.addVolume(totalVolume, _place);
	endif;
	self.doPrint(self.frmDetail);
//	app.printer.print(self.frmDetail);
end;</source>
        <access>protected</access>
        <Parameter name="_array" type="ObjectArray"/>
        <Parameter name="_place" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="printHeading" id="f24bf037-6ba9-4a87-880e-b99d911dad84">
        <source>printHeading(_lot : CM_LogLot) protected;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars

begin
	self.lblLotNoDtl.caption		:= _lot.lotNo;
	
	if _lot.myConsignee &lt;&gt; null then
		self.lblBuyerDtl.caption		:= _lot.myConsignee.description;
	else
		self.lblBuyerDtl.caption		:= null;
	endif;
	
	if _lot.myDischargePort &lt;&gt; null then
		self.lblDischargeDtl.caption	:= _lot.myDischargePort.description;
	else
		self.lblDischargeDtl.caption	:= null;
	endif;

	self.doPrint(self.frmLotHeading);

end;</source>
        <access>protected</access>
        <Parameter name="_lot" type="CM_LogLot"/>
    </JadeMethod>
