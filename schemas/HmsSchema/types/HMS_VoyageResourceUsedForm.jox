    <JadeMethod name="translateForm" id="db77abd4-b98d-4b56-94dd-391659ab6e54">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 September 2022 10:14:46.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005981, locale);
	btnVoyInvStatus.translateBubbleHelp(Xlat_0001840, locale);
	btnVoyInvStatus.translateCaption(Xlat_0001841, locale);
	lblQueryDateFrom.translateCaption(Xlat_0001839, locale);
	lblQueryDateTo.translateCaption(Xlat_0001842, locale);
	lblQueryVoyage.translateCaption(Xlat_0001843, locale);
end;</source>
    </JadeMethod>
