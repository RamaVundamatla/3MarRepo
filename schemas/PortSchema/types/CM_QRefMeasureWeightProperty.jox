    <JadeMethod name="getValueForObject" id="056a2483-b3ea-49cf-b518-63fbf85a80c8">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2014	cnwma1	Initial creation

*/

vars
	pos 		: Integer;
	propName 	: String;
	measure 	: String;
	prop		: Property;
	value 		: Decimal [22,10];

begin
	pos := self.propertyName.pos(CN_UNDERSCORE, 1);
	if pos = null then
		return inheritMethod(_obj, _op);
	endif;
	
	measure := self.propertyName[1:pos-1];		// get measurement type from prefix
	propName := self.propertyName[pos+1:end]; 	// remove measurement type prefix to get property name
	prop := _obj.class.getPropertyInHTree(propName);
	if prop &lt;&gt; null then
		value := _obj.getPropertyValue(propName).Decimal;
	else
		value := _obj.sendMsgWithParams(propName).Decimal;
	endif;
	return app.convertMeasurementForDisplay(measure, value);// &amp; Space &amp; measure;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="b3350611-fbb7-4ecc-bd4a-dd271be47313">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2014	cnwma1	Initial creation

*/


vars
	weight		: CM_WeightRange;
	weightDict	: CM_WeightRangeByValueDict;
	measure		: CM_MeasurementType;
	measureShort : String;
	pos :  Integer;
begin
	_combo.clear();
	//jlier1 TFS 53515 25/5/22
	pos := self.propertyName.pos(CN_UNDERSCORE, 1);
	if pos &gt; 0 then
		measureShort := self.propertyName[1:pos-1];
		if measureShort &lt;&gt; null then
			measure:=app.myRoot.allMeasurementTypesByShortName[measureShort];
		endif;
	endif;
	if measure =  null then
		measure := app.getDefaultMeasurementForType(Type_Weight);	
	endif;
	weightDict := measure.allWeightRanges;							
	_combo.sorted := false;
	foreach weight in weightDict do
		_combo.itemObject[_combo.addItem(weight.lower.String &amp; "-" &amp; weight.value.String)] := weight;
	endforeach;

	if CM_QDecimalInRange.hasInstance(_queryOperator) then	
		_combo.listObject := weightDict[measure, _queryOperator.CM_QDecimalInRange.searchValue.Integer];	
	elseif CM_QDecimalNotInRange.hasInstance(_queryOperator) then  
		_combo.listObject := weightDict[measure, _queryOperator.CM_QDecimalNotInRange.searchValue.Integer];
	endif;
	
	_combo.sorted := true;
end;
</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
