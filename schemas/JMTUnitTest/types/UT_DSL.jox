&lt;/CM_EDIFieldMappingType&gt;
&lt;/allEDIFieldMappingTypes&gt;
&lt;/CM_EDIFileTypeUserCollections&gt;
&lt;/CM_EDIFileTypeUser&gt;';
	
	return xmlBlock;
	
epilog
	
end;
</source>
