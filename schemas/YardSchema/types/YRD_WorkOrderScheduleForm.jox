    <JadeMethod name="mnuActionThese_click" id="29aec785-4143-4739-8b92-b23e6059a25b">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuActionThese_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2009	cnwrd1	Initial creation

*/

vars

	allValue,
	theseValue : Integer;
	caption : Integer;
	parent : CM_WorkOrderTIDtl;
	schedule : CM_WorkOrderSchedule;
begin
			
	schedule := menuItem.userObject.CM_WorkOrderSchedule;
	parent := schedule.myParent;
		
	allValue := parent.totalUnactioned;
		
	theseValue := schedule.numberScheduled - schedule.getNumberActioned();
	
	if theseValue &gt; allValue then							
		theseValue := allValue;
	endif;

	self.doActionWorkSchedule( schedule, theseValue );
	

epilog

end;</source>
