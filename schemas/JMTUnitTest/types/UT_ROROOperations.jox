			//	self.deleteTrackedItem(tempTI, false);
			//endforeach;	
					
			// setup OOTL 40'
			///voyageDeck.myVoyageStructure.createQuickCargoOOTL(null, true, 12, 3, voyageDeck, 1); // 1 X 40
			///self.assertNoTrxErrorsOrWarnings();
			//locnDefnVoyage := voyageDeck.allROROLocnDefnByCode["D4341O"].CM_ROROLocnDefnVoyage;
			//tiArray.clear();
			//locnDefnVoyage.getAllTIs(REAL_MODE, tiArray, true);
			//foreach tempTI in tiArray do
			//	self.deleteTrackedItem(tempTI, false);
			//endforeach;	
			
			// setup the cargo
			///self.uSetupCargoForGCDC(voyage, voyageDeck, slots, tiArray);
					
		endif;
		
		if voyageDeck &lt;&gt; null then
			// create the discharge jobs
			///self.createGCDCDischJobs(voyage, voyageDeck);
			///self.planGCDCDischageItems(voyage);
			
			// create the load jobs
			///self.createGCDCLoadJobsPlan(voyage, voyageDeck);

			// loading jobs to job ops
			///self.loadAllJobsToOps(voyage, true);
			
			///self.opts.purge;
			///self.opts.addAssoc("Sleep", 5000);
			///self.opts.addAssoc("WPOpHrs", 2);	//10 Apr 2012	NDL	Par 29369.
			///self.moveAllCargoOnVoyage(voyage, REAL_MODE);
		
			// check that the details are correct
			//self.checkGCDCorrect(ShpDisplayMode_Actual, 0, voyageDeck);
