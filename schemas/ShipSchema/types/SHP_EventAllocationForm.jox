    <JadeMethod name="doCmbVesselChanged" id="9386ea2d-7758-4064-9835-8d9864f124b1">
        <updating/>
        <source>doCmbVesselChanged() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2017	cnwns1	Initial creation

*/

vars

begin
	if self.cmbVessel.myObject &lt;&gt; null and self.cmbVessel.myObject &lt;&gt; self.myVessel  then
		self.myVessel := self.cmbVessel.myObject.CM_Vessel;
		self.populateForm();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageChanged" id="f82c0222-7452-41ad-8697-bb28fbf2c816">
        <updating/>
        <source>doCmbVoyageChanged() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2017	cnwns1	Initial creation

*/

vars

begin
	if self.cmbVoyage.myObject &lt;&gt; null and self.cmbVoyage.myObject &lt;&gt; self.myVoyage then
