    <JadeMethod name="processEmailData" id="401a4886-8afc-42ce-a7e7-25e1f5251487">
        <source>processEmailData(_fileName, _saveToDirectory : String);

/*

Purpose:		Process the data from the email, and load straight to the database


Date			Who		Reason
25/07/2013		cnwmh5	Initial creation
17 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/
constants

	DateRun							: String = "Date:";
	TotalRunnable					: String = "Total Tests Runable: ";
	
vars

	inputFile						: File;
	outputFile						: File;
	unitTestRun						: UM_UnitTestRun;
	unitTestResults					: UM_UnitTestResult;
	obj								: Object;
	classMethod						: UM_UnitTestClassMethod;
	
	
	checkFor						: StringArray;
	detailsArray					: StringArray;
	totalRunnableDetails			: StringArray;
	failedDetailsArray				: ObjectArray;

	line 							: String;
	runTS							: TimeStamp;
	taskStartTimeTS					: TimeStamp;
	actualStartTimeTS				: TimeStamp;
	tsStr							: String;
	pos								: Integer;
	tmpStr							: String;
	totalRunnable					: Boolean;
	pos2							: Integer;
	failedFound						: Boolean;
	failedDetailsFound				: Boolean;
	testSummary						: Boolean;
	ownerSummary					: Boolean;
	pos3							: Integer;
	
	detailsStr						: String;
	
	elapsedIdx						: Integer;
	index							: Integer;
	emailedTo						: String;
	tempTS							: TimeStamp;
	tempSeconds						: Decimal[9,3];
	tempElapsed						: Decimal[9,3];
		
begin
	
	// initialisations
	runTS := null;
	
	create detailsArray transient;
	create totalRunnableDetails transient;
	create failedDetailsArray transient;

	// create the input file
	create inputFile transient;
	inputFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	inputFile.fileName := _fileName;
	
	while not inputFile.endOfFile do
	
		line := inputFile.readLine();
	
		// get the run date
		if runTS = null then
			if line[1:DateRun.length] = DateRun then
				pos := line.pos(",", 1) + 1;
				tsStr := line.scanUntil("+", pos).trimBlanks();
				pos := tsStr.length-7;
				runTS.setTime(tsStr[pos:end].trimBlanks().Time);
				runTS.setDate(tsStr[1:pos-1].trimBlanks().Date);				
			endif;
			continue;
		endif;
	
		
		// now get the runnable details
		if totalRunnable = null then
			
			if line.pos(TotalRunnable, 1) &gt; 0 then
			
				totalRunnableDetails.clear();
				
				create checkFor transient;
				checkFor.add(TotalRunnable);
				checkFor.add("Tests Run: ");
				checkFor.add("Passed: ");
				checkFor.add("Failed: ");
				checkFor.add("Ignored: ");
				checkFor.add("Elapsed: ");
				checkFor.add("Schedule Name: ");
				
				foreach tmpStr in checkFor do
					pos := line.pos(tmpStr, 1);
					if pos &gt; 0 then
						pos := pos + tmpStr.length;
						pos2 := line.pos(" ", pos);
						tmpStr := tmpStr.replaceString(": ", "");
						tmpStr := tmpStr.replaceString(" ", "");
						tmpStr[1:1] := tmpStr[1:1].toLower();
						
						if pos2 = 0 then
							tmpStr := line[pos:end];
						else
							tmpStr := line[pos:pos2-pos];
						endif;
					else	
						tmpStr := null;
					endif;
					totalRunnableDetails.add(tmpStr);
				endforeach;
				
			
				// leakChecking / logResult
				totalRunnableDetails.add((line.pos("Leak Checking:", 1) &gt; 0).String);
				totalRunnableDetails.add((line.pos("Log Result:", 1) &gt; 0).String);
				
				taskStartTimeTS := runTS;
				taskStartTimeTS := taskStartTimeTS.addMinutes(-totalRunnableDetails[6].Real.roundedTo(0).Integer);
				actualStartTimeTS := taskStartTimeTS;
				taskStartTimeTS := taskStartTimeTS.addSeconds(-taskStartTimeTS.time.second);
				taskStartTimeTS := taskStartTimeTS.addMinutes(-taskStartTimeTS.time.minute);
				
				///*
				write inputFile.fileName &amp; Tab &amp; runTS.date.dayName &amp; Tab &amp; runTS.date.String &amp; Tab &amp; runTS.time.String &amp; Tab &amp; 
					'task: ' &amp; taskStartTimeTS.String &amp; Tab &amp; 'actual: ' &amp; actualStartTimeTS.String &amp; Tab &amp; 
					'tot runnable: ' &amp; totalRunnableDetails[1] &amp; Tab &amp; 'tests run: ' &amp; totalRunnableDetails[2] &amp; Tab &amp; 
					'passed: ' &amp; totalRunnableDetails[3] &amp; Tab &amp; 'failed: ' &amp; totalRunnableDetails[4] &amp; Tab &amp; 
					'ignored: ' &amp; totalRunnableDetails[5] &amp; Tab &amp; 'elpased: ' &amp; totalRunnableDetails[6] &amp; Tab &amp; 
					'schedule: ' &amp; totalRunnableDetails[7] &amp; Tab &amp; 'leak: ' &amp; totalRunnableDetails[8] &amp; Tab &amp; 
					'logResult: ' &amp; totalRunnableDetails[9];
				//*/
				
				// create unit test run
				beginTransaction;
				create unitTestRun persistent;
				unitTestRun.updateDetails(taskStartTimeTS, runTS, totalRunnableDetails[6], totalRunnableDetails[7], totalRunnableDetails[9].Boolean,
					totalRunnableDetails[8].Boolean, totalRunnableDetails[1].Integer);
				commitTransaction;
				
				tempTS.setDate("31/12/2998".Date);
				tempTS.setTime("23:59:59".Time);

				totalRunnable := true;
			endif;
			continue;
		endif;
		
		//return;
		
		// get the failed items
		if failedFound = null then
			if line.pos("Test Runner Failures", 1) &gt; 0 then
				line := inputFile.readLine();			//  get rid of the "========" line
				failedFound := true;
			endif;
			if line.cnContains("Test Runner Summary") then
				line := inputFile.readLine();
				testSummary := true;
				failedFound := true;
				failedDetailsFound := true;
				continue;
			endif;	
			continue;
		endif;
	
		// read through till get to the failure details
		if not failedDetailsFound then
			if line.cnContains("====================") then
				failedDetailsFound := true;
				///elementTestRun := elementMaster.addElement("TestRunDetails");
			endif;		
			continue;
		endif;
	
		// read through the failure details
		if not testSummary then
					
			if line.cnContains("====================") then
				continue;
			endif;
			
			if line.cnContains("Test Runner Summary") then
				line := inputFile.readLine();
				testSummary := true;
				continue;
			endif;	
			
			emailedTo := null;
			
			// header line
			if line[1:5] = "FAIL " then
		
			// save the previous details if there are any
				if detailsStr &lt;&gt; null then
				
					// update the result details
					beginTransaction;
					create unitTestResults persistent;
					unitTestResults.updateDetails(detailsArray[2][1:detailsArray[2].pos("::", 1)-1], detailsArray[2][detailsArray[2].pos("::", 1)+2:end], 
						 detailsArray[elapsedIdx], emailedTo, detailsArray[3], detailsArray[1], detailsStr, tempTS, unitTestRun, null);						//17.10.2025 navbs1  #34979
					unitTestResults.myClassMethod.updateRunnableUTClassMethod(true);
					commitTransaction;
					failedDetailsArray.add(unitTestResults);
					
					detailsStr := detailsStr.replaceString(Cr, "@");
					detailsStr := detailsStr.replaceString(Lf, "^");
					/*
					write Tab &amp; Tab &amp; 'result: ' &amp; detailsArray[1] &amp; Tab &amp; 'class: ' &amp; detailsArray[2][1:detailsArray[2].pos("::", 1)-1] &amp; Tab &amp; 
						'method: ' &amp; detailsArray[2][detailsArray[2].pos("::", 1)+2:end] &amp; Tab &amp; 'owner: ' &amp; detailsArray[3] &amp; Tab &amp; 
						'emailedTo: ' &amp; emailedTo &amp; Tab &amp; 'elapsed: ' &amp; detailsArray[elapsedIdx] &amp; Tab &amp; 'runTime: ' &amp; tempTS.String &amp; Tab &amp; 
						detailsStr;
					*/
					detailsStr := null;
					emailedTo := null;
				endif;
		
				// substring the line
				detailsArray.clear();
				line.getTokensForDelimiter(" ", detailsArray);
				
				// workout emailed to and elapsed
				if detailsArray[4].cnContains("(Emailed") then
					index := 6;
					tmpStr := null;
					while true do	
						tmpStr := tmpStr &amp; " " &amp; detailsArray[index];
						if detailsArray[index].cnContains(")") then
							break;
						endif;
						index := index + 1;
					endwhile;
					emailedTo := tmpStr[1:tmpStr.length - 1].trimBlanks();
					elapsedIdx := index + 1;
				else
					elapsedIdx := 5;
				endif;
				
				// workout a temporary time stamp in the future until we read through the main run and then update with correct details
				//pos3 := detailsArray[elapsedIdx].pos(".", 1);
				//runTS := runTS.addMinutes(detailsArray[elapsedIdx][1:pos3-1].Integer);
				//tempSeconds := 60.00;
				//tempSeconds := tempSeconds / detailsArray[elapsedIdx][pos3+1:end].Decimal;
				//runTS := runTS.addSeconds(tempSeconds.rounded);
				tempTS := tempTS.addMinutes(1);
				tempTS := tempTS.addSeconds(5);

			else
			
				// just update the string
				detailsStr := detailsStr.trimBlanks() &amp; line &amp; CrLf;
			
			endif;
			
			continue;
			
		endif;
		
		// save the last one if anything exists
		if detailsStr &lt;&gt; null then
		// update the result details
			beginTransaction;
			///write "BBBBBBB" &amp; Tab &amp; Tab &amp; line &amp; Tab &amp; detailsArray[2][1:detailsArray[2].pos("::", 1)-1] &amp; Tab &amp; detailsArray[2][detailsArray[2].pos("::", 1)+2:end];
			create unitTestResults persistent;
			unitTestResults.updateDetails(detailsArray[2][1:detailsArray[2].pos("::", 1)-1], detailsArray[2][detailsArray[2].pos("::", 1)+2:end], 
				 detailsArray[elapsedIdx], emailedTo, detailsArray[3], detailsArray[1], detailsStr, tempTS, unitTestRun, null);					//17.10.2025 navbs1  #34979
			unitTestResults.myClassMethod.updateRunnableUTClassMethod(true);
			commitTransaction;
			failedDetailsArray.add(unitTestResults);
			
			detailsStr := detailsStr.replaceString(Cr, "@");
			detailsStr := detailsStr.replaceString(Lf, "^");
			
			/*
			write Tab &amp; Tab &amp; 'result: ' &amp; detailsArray[1] &amp; Tab &amp; 'class: ' &amp; detailsArray[2][1:detailsArray[2].pos("::", 1)-1] &amp; Tab &amp; 
				'method: ' &amp; detailsArray[2][detailsArray[2].pos("::", 1)+2:end] &amp; Tab &amp; 'owner: ' &amp; detailsArray[3] &amp; Tab &amp; 
				'emailedTo: ' &amp; emailedTo &amp; Tab &amp; 'elapsed: ' &amp; detailsArray[elapsedIdx] &amp; Tab &amp; 'runTime: ' &amp; tempTS.String &amp; Tab &amp; detailsStr;
			*/
			detailsStr := null;
			emailedTo := null;
			
		endif;
		
		if not ownerSummary then
		
			if line.cnContains("===================") then
				continue;
			endif;
		
			if line.cnContains("Test Owner Summary") then
				ownerSummary := true;
				continue;
			endif;
		
		
			/*// already processed the failed so don't need to do it again
			if line[1:5] = "FAIL " then
				
				pos3 := detailsArray[elapsedIdx].pos(".", 1);
				actualStartTimeTS := actualStartTimeTS.addMinutes(detailsArray[elapsedIdx][1:pos3-1].Integer);
				tempSeconds := 60.00;
				tempSeconds := tempSeconds / detailsArray[elapsedIdx][pos3+1:end].Decimal;
				actualStartTimeTS := actualStartTimeTS.addSeconds(tempSeconds.rounded);
			
				continue;
			endif;
			*/
			
			// substring the line
			detailsArray.clear();
			line.getTokensForDelimiter(" ", detailsArray);
						
			// workout emailed to and elapsed
			if detailsArray[4].cnContains("(Emailed") then
				index := 6;
				tmpStr := null;
				while true do	
					tmpStr := tmpStr &amp; " " &amp; detailsArray[index];
					if detailsArray[index].cnContains(")") then
						break;
					endif;
					index := index + 1;
				endwhile;
				emailedTo := tmpStr[1:tmpStr.length - 1].trimBlanks();
				elapsedIdx := index + 1;
			else
				elapsedIdx := 5;
			endif;
			
			// Need to update the results run date
			if line[1:5] = "FAIL " then
				
				//pos3 := detailsArray[elapsedIdx].pos(".", 1);
				//actualStartTimeTS := actualStartTimeTS.addSeconds(detailsArray[elapsedIdx][1:pos3-1].Integer);
				//tempSeconds := 60.00;
				//tempSeconds := tempSeconds / detailsArray[elapsedIdx][pos3+1:end].Decimal;
				//actualStartTimeTS := actualStartTimeTS.addSeconds(tempSeconds.rounded);
				
				tempElapsed := detailsArray[elapsedIdx].Decimal;
				tempTS := null;
				if tempElapsed &lt;&gt; 0.00 then
					actualStartTimeTS := actualStartTimeTS.addSeconds(tempElapsed.rounded);
					//tempElapsed := tempElapsed - tempElapsed.truncated;
					//if tempElapsed &lt;&gt; 0.00 then
					//	tempSeconds := 60.00;
					//	tempSeconds := tempSeconds * tempElapsed;
					//	actualStartTimeTS := actualStartTimeTS.addSeconds(tempSeconds.rounded);
					//endif;
				endif;
			
				foreach obj in failedDetailsArray do
					unitTestResults := obj.UM_UnitTestResult;
					//classMethod := unitTestResults.getClassMethodDetails(detailsArray[2][1:detailsArray[2].pos("::", 1)-1], 
					//	detailsArray[2][detailsArray[2].pos("::", 1)+2:end]);
					//if classMethod &lt;&gt; null then
					
					if unitTestResults.myClassMethod.className = detailsArray[2][1:detailsArray[2].pos("::", 1)-1] and 
							unitTestResults.myClassMethod.methodName = detailsArray[2][detailsArray[2].pos("::", 1)+2:end] then
						beginTransaction;
						unitTestResults.updateMethodRunStartTS(actualStartTimeTS);
						commitTransaction;
						break;
						//endif;
					endif;
				endforeach;
				
				write Tab &amp; Tab &amp; 'result: ' &amp; detailsArray[1] &amp; Tab &amp; 'class: ' &amp; detailsArray[2][1:detailsArray[2].pos("::", 1)-1] &amp; Tab &amp; 
					'method: ' &amp; detailsArray[2][detailsArray[2].pos("::", 1)+2:end] &amp; Tab &amp; 'owner: ' &amp; detailsArray[3] &amp; Tab &amp; 
					'emailedTo: ' &amp; emailedTo &amp; Tab &amp; 'elapsed: ' &amp; detailsArray[elapsedIdx] &amp; Tab &amp; 'runTime: ' &amp; actualStartTimeTS.String;
							
				continue;
			endif;
			
			//write 'detailsArray.size: ' &amp; detailsArray.size.String;
			//write Tab &amp; Tab &amp; 'result: ' &amp; detailsArray[1] &amp; Tab &amp; 'class: ' &amp; detailsArray[2][1:detailsArray[2].pos("::", 1)-1] &amp; Tab &amp; 
			//		'method: ' &amp; detailsArray[2][detailsArray[2].pos("::", 1)+2:end] &amp; Tab &amp; 'owner: ' &amp; detailsArray[3] &amp; Tab &amp; 
			//		'emailedTo: ' &amp; emailedTo &amp; Tab &amp; 'elapsed: ' &amp; detailsArray[elapsedIdx] &amp; Tab &amp; 'runTime: ' &amp; actualStartTimeTS.String;
			
			
			// Work out what the methods run time is
			//if detailsArray[elapsedIdx].Decimal &lt;&gt; 0.00 then
				//pos3 := detailsArray[elapsedIdx].pos(".", 1);
				//if pos3 = 0 then
				//	detailsArray[elapsedIdx] := detailsArray[elapsedIdx] &amp; ".00";
				//endif;
				//pos3 := detailsArray[elapsedIdx].pos(".", 1);
				//actualStartTimeTS := actualStartTimeTS.addSeconds(detailsArray[elapsedIdx][1:pos3-1].Integer);
				//tempSeconds := 60.00;
				//if detailsArray[elapsedIdx][pos3+1:end].Decimal &lt;&gt; 0 then
				//	tempSeconds := tempSeconds / detailsArray[elapsedIdx][pos3+1:end].Decimal;
				//endif;
				//actualStartTimeTS := actualStartTimeTS.addSeconds(tempSeconds.rounded);
				//tempTS := actualStartTimeTS;
			//endif;
			
			tempElapsed := detailsArray[elapsedIdx].Decimal;
			tempTS := null;
			if tempElapsed &lt;&gt; 0.00 then
				actualStartTimeTS := actualStartTimeTS.addSeconds(tempElapsed.rounded);
				//tempElapsed := tempElapsed - tempElapsed.truncated;
				//if tempElapsed &lt;&gt; 0.00 then
				//	tempSeconds := 60.00;
				//	tempSeconds := tempSeconds * tempElapsed;
				//	actualStartTimeTS := actualStartTimeTS.addSeconds(tempSeconds.rounded);
				//endif;
			else
				actualStartTimeTS := actualStartTimeTS.addSeconds(1);
			endif;
			
			// update the result details
			beginTransaction;
			///write "CCCCCCC" &amp; Tab &amp; Tab &amp; detailsArray[2][1:detailsArray[2].pos("::", 1)-1] &amp; Tab &amp; detailsArray[2][detailsArray[2].pos("::", 1)+2:end];
			create unitTestResults persistent;
			unitTestResults.updateDetails(detailsArray[2][1:detailsArray[2].pos("::", 1)-1], detailsArray[2][detailsArray[2].pos("::", 1)+2:end], 
				 detailsArray[elapsedIdx], emailedTo, detailsArray[3], detailsArray[1], null, actualStartTimeTS, unitTestRun, null);				//17.10.2025 navbs1  #34979
			unitTestResults.myClassMethod.updateRunnableUTClassMethod(true);
			commitTransaction;
			
			
			write Tab &amp; Tab &amp; 'result: ' &amp; detailsArray[1] &amp; Tab &amp; 'class: ' &amp; detailsArray[2][1:detailsArray[2].pos("::", 1)-1] &amp; Tab &amp; 
					'method: ' &amp; detailsArray[2][detailsArray[2].pos("::", 1)+2:end] &amp; Tab &amp; 'owner: ' &amp; detailsArray[3] &amp; Tab &amp; 
					'emailedTo: ' &amp; emailedTo &amp; Tab &amp; 'elapsed: ' &amp; detailsArray[elapsedIdx] &amp; Tab &amp; 'runTime: ' &amp; actualStartTimeTS.String;
			
			emailedTo := null;
			tempTS := null;
			
			continue;
		endif;
	
		// don't need to process anything more
		if ownerSummary then
			break;
		endif;	
		
		
	endwhile;
	
	inputFile.close();

epilog

	delete inputFile;
	delete outputFile;
	
	delete checkFor;
	delete detailsArray;
	delete failedDetailsArray;
	
	delete totalRunnableDetails;

end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_saveToDirectory" type="String"/>
    </JadeMethod>
    <JadeMethod name="processEmailData_original" id="9a69f807-144c-4f9a-8581-02784686fb2f">
        <source>processEmailData_original(_fileName, _saveToDirectory : String; _regenerateFiles : Boolean);

/*

Purpose:		Process the data from the email, convert and save as XML	

Date			Who		Reason
08 March 2013	cnwmh5	Initial creation

*/
constants

	DateRun							: String = "Date:";
	TotalRunnable					: String = "Total Tests Runable: ";
	
vars

	inputFile						: File;
	outputFile						: File;
	
	xmlDocument						: JadeXMLDocument;
	elementMaster					: JadeXMLElement;
	elementTestRun					: JadeXMLElement;
	elementRunDetails				: JadeXMLElement;
	element							: JadeXMLElement;
	
	checkFor						: StringArray;
	detailsArray					: StringArray;

	line 							: String;
	runTS							: TimeStamp;
	startTS							: TimeStamp;
	tsStr							: String;
	pos								: Integer;
	tmpStr							: String;
	totalRunnable					: Boolean;
	pos2							: Integer;
	failedFound						: Boolean;
	failedDetailsFound				: Boolean;
	testSummary						: Boolean;
	ownerSummary					: Boolean;
	
	elapsed							: Real;
	detailsStr						: String;
	
begin

	// initialisations
	runTS := null;
	
	create detailsArray transient;

	// create the input file
	create inputFile transient;
	inputFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version	
	inputFile.fileName := _fileName;
	
	create xmlDocument transient;
	
	while not inputFile.endOfFile do
	
		line := inputFile.readLine();
	
		// get the run date
		if runTS = null then
			if line[1:DateRun.length] = DateRun then
				pos := line.pos(",", 1) + 1;
				tsStr := line.scanUntil("+", pos).trimBlanks();
				pos := tsStr.length-7;
				runTS.setTime(tsStr[pos:end].trimBlanks().Time);
				runTS.setDate(tsStr[1:pos-1].trimBlanks().Date);
				
				// create the output file if required
				create outputFile transient;
				outputFile.fileName := _saveToDirectory &amp; "\" &amp; runTS.date.year.String &amp; "-" &amp; runTS.date.month.padLeadingWith("0", 2).String &amp; "-" &amp;
					runTS.date.day.padLeadingWith("0", 2).String &amp; " " &amp; runTS.time.hour.padLeadingWith("0", 2).String &amp;
					runTS.time.minute.padLeadingWith("0", 2).String &amp; runTS.time.second.padLeadingWith("0", 2).String &amp; ".xml";
				if outputFile.isAvailable() then
					if _regenerateFiles then
						outputFile.purge;
					else
						inputFile.close();
						return;
					endif;
				endif;
				
			endif;
			continue;
		endif;
	
		// now get the runnable details
		if totalRunnable = null then
			//pos := line.pos(TotalRunnable, 1);
			//if pos &gt; 0 then
			if line.pos(TotalRunnable, 1) &gt; 0 then
				elementMaster := xmlDocument.addElement("UnitTestRunDetails");
				elementTestRun := elementMaster.addElement("TestRun");
				
				create checkFor transient;
				checkFor.add(TotalRunnable);
				checkFor.add("Tests Run: ");
				checkFor.add("Passed: ");
				checkFor.add("Failed: ");
				checkFor.add("Ignored: ");
				checkFor.add("Elapsed: ");
				checkFor.add("Schedule Name: ");
				
				foreach tmpStr in checkFor do
					pos := line.pos(tmpStr, 1);
					if pos &gt; 0 then
						pos := pos + tmpStr.length;
						pos2 := line.pos(" ", pos);
						tmpStr := tmpStr.replaceString(": ", "");
						tmpStr := tmpStr.replaceString(" ", "");
						tmpStr[1:1] := tmpStr[1:1].toLower();
						element := elementTestRun.addElement(tmpStr);
						
						if pos2 = 0 then
							tmpStr := line[pos:end];
						else
							tmpStr := line[pos:pos2-pos];
						endif;
						element.setText(tmpStr);
					endif;
					
				endforeach;
				
				// set the startTimeStamp
				
				element := elementTestRun.addElement("startTimestamp");
				element.setText(runTS.addMinutes(-elapsed.roundedTo(0).Integer).String);
				
				if line.pos("Leak Checking:", 1) &gt; 0 then
					elementTestRun.addElement("checkLeaks");
				endif;
				if line.pos("Log Result:", 1) &gt; 0 then
					elementTestRun.addElement("logResult");
				endif;
								
				totalRunnable := true;
			endif;
			continue;
		endif;
		
		// get the failed items
		if failedFound = null then
			if line.pos("Test Runner Failures", 1) &gt; 0 then
				line := inputFile.readLine();			//  get rid of the "========" line
				failedFound := true;
			endif;
			if line.cnContains("Test Runner Summary") then
				line := inputFile.readLine();
				testSummary := true;
				failedFound := true;
				failedDetailsFound := true;
				continue;
			endif;	
			continue;
		endif;
	
		// read through till get to the failure details
		if not failedDetailsFound then
			if line.cnContains("====================") then
				failedDetailsFound := true;
				elementTestRun := elementMaster.addElement("TestRunDetails");
			endif;		
			continue;
		endif;
	
		// read through the failure details
		if not testSummary then
					
			if line.cnContains("====================") then
				continue;
			endif;
			
			if line.cnContains("Test Runner Summary") then
				line := inputFile.readLine();
				testSummary := true;
				continue;
			endif;	
				
			// header line
			if line[1:5] = "FAIL " then
		
			// save the previous details if there are any
				if detailsStr &lt;&gt; null then
					element := elementRunDetails.addElement("details");
					element.setText(detailsStr);
					detailsStr := null;
				endif;
		
				// substring the line
				detailsArray.clear();
				line.getTokensForDelimiter(" ", detailsArray);
				
				elementRunDetails := elementTestRun.addElement("RunDetails");
				
				element := elementRunDetails.addElement("result");
				element.setText(detailsArray[1]);
				
				element := elementRunDetails.addElement("class");
				element.setText(detailsArray[2][1:detailsArray[2].pos("::", 1)-1]);
				
				element := elementRunDetails.addElement("method");
				element.setText(detailsArray[2][detailsArray[2].pos("::", 1)+2:end]); 
				
				element := elementRunDetails.addElement("owner");
				element.setText(detailsArray[3]);
				
				if detailsArray[4] &lt;&gt; null then
					element := elementRunDetails.addElement("owner");
					element.setText(detailsArray[4]);
				endif;
				
				element := elementRunDetails.addElement("elapsed");
				element.setText(detailsArray[5]);
				
			else
			
				// just update the string
				detailsStr := detailsStr.trimBlanks() &amp; line &amp; CrLf;
			
			endif;
			
			continue;
			
		endif;
		
		// save the last one if anything exists
		if detailsStr &lt;&gt; null then
			element := elementRunDetails.addElement("details");
			element.setText(detailsStr);
			detailsStr := null;
		endif;
		
		if not ownerSummary then
		
			if line.cnContains("===================") then
				continue;
			endif;
		
			if line.cnContains("Test Owner Summary") then
				ownerSummary := true;
				continue;
			endif;
		
			// already processed the failed so don't need to do it again
			if line[1:5] = "FAIL " then
				continue;
			endif;
			
			// substring the line
			detailsArray.clear();
			line.getTokensForDelimiter(" ", detailsArray);
			elementTestRun := elementMaster.addElement("TestRunDetails");
			
			element := elementTestRun.addElement("result");
			element.setText(detailsArray[1]);
			
			element := elementTestRun.addElement("class");
			element.setText(detailsArray[2][1:detailsArray[2].pos("::", 1)-1]);
			
			element := elementTestRun.addElement("method");
			element.setText(detailsArray[2][detailsArray[2].pos("::", 1)+2:end]); 
			
			element := elementTestRun.addElement("owner");
			element.setText(detailsArray[3]);
			
			if detailsArray[4] &lt;&gt; null then
				element := elementTestRun.addElement("owner");
				element.setText(detailsArray[4]);
			endif;
			
			element := elementTestRun.addElement("elapsed");
			element.setText(detailsArray[5]);
			
			continue;
		endif;
	
		// don't need to process anything more
		if ownerSummary then
			break;
		endif;	
	
	endwhile;
	
	inputFile.close();
	
	// write to the file
	xmlDocument.writeToFile(outputFile.fileName);	

epilog

	delete inputFile;
	delete outputFile;
	delete xmlDocument;
	
	delete checkFor;
	delete detailsArray;

end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_saveToDirectory" type="String"/>
        <Parameter name="_regenerateFiles" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processSuperClassRefs_New" id="6b024f32-8188-40f4-b8ec-84774848e6d8">
        <source>processSuperClassRefs_New(_trxClassName, _trxMethodName : String input; _type : Type; _methodName : String; _index: Integer; _refsByLevel, _uniqueMethsByLevel : IntegerArray io; _allRefs : ObjectSet io);

vars
	meth:Method;
	methodRefSet:MethodSet;
	cls:Class;
begin
//	if pType.inheritsFrom(JASEntity) then
		cls := _type.Class.getSuperclass;
		if cls = null then
			return;
		endif;
		if cls.schema = rootSchema then
			return;
		endif;
		meth := cls.getMethod(_methodName);
		if meth &lt;&gt; null then
			if not _allRefs.includes(meth) then
				addMethodToList_New(_trxClassName, _trxMethodName, meth, _index, _refsByLevel, _uniqueMethsByLevel, _allRefs);
			endif;
		endif;
		processSuperClassRefs_New(_trxClassName, _trxMethodName, cls, _methodName, _index, _refsByLevel, _uniqueMethsByLevel, _allRefs);
//	endif;
epilog

end;</source>
        <Parameter name="_trxClassName" type="String" usage="input"/>
        <Parameter name="_trxMethodName" type="String" usage="input"/>
        <Parameter name="_type" type="Type"/>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_refsByLevel" type="IntegerArray" usage="io"/>
        <Parameter name="_uniqueMethsByLevel" type="IntegerArray" usage="io"/>
        <Parameter name="_allRefs" type="ObjectSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pwCheckMethodText" id="48a0d583-c8aa-44d5-bf0b-a628269707ee">
        <source>pwCheckMethodText();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2025	navpw1	Initial creation

*/

vars

begin

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pwExtractUserEmailAddress" id="c7230b64-d6ef-420b-8d5b-6524d3e2324d">
        <source>pwExtractUserEmailAddress();
/*

Purpose:			Extracts all instances of UM_UserEmailAddress to CSV

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2025	navpw1	Initial creation

*/

constants
	RemoveUserEmailAddresses : Boolean = true;
	
vars
	defaultFileName		: String;
	filePath			: String;
	file				: File;
	longStr				: String;
	userEmailAddress	: UM_UserEmailAddress;
	headerLine			: String;
	
begin
	defaultFileName := "userEmailAddresses.csv";
	// pass null path so opens where last open at
	filePath := app.getFilePath(null, '*.csv', defaultFileName, false);
	
	if filePath = null then
		return;
	endif;	
	
	if filePath.toLower.pos('.csv', 1) &lt;= 0 then
		filePath := filePath &amp; '.csv';
	endif;
	
	create file transient;
	file.fileName := filePath;
	file.mode := File.Mode_Output;

	if (not file.tryOpen) then
		app.raiseCMException1(FileUnavailable, file.fileName, null, null);	
		return;
	endif;
	
	if file = null then
		app.raiseCMException(Input_required_field_file, null, null); // cnwdb2	PAR 35364
		return;
	endif;	
	
	if (not file.isAvailable()) then
		app.raiseCMException1(FileUnavailable, file.fileName, null, null);	
		return;
	endif;
	
	file.purge();	
	
	headerLine := UM_UserEmailAddress::user.name &amp; Comma &amp; 
					UM_UserEmailAddress::altUser.name &amp; Comma &amp;
					UM_UserEmailAddress::getsSummary.name &amp; Comma &amp;
					UM_UserEmailAddress::getsUserIgnore.name &amp; Comma &amp;
					UM_UserEmailAddress::getsUserSummary.name &amp; Comma &amp;
					UM_UserEmailAddress::isAdmin.name &amp; Comma &amp;
					UM_UserEmailAddress::isDisabled.name &amp; Comma &amp;
					UM_UserEmailAddress::isTester.name;
	
	file.writeLine(headerLine);
	
	foreach userEmailAddress in UM_UserEmailAddress.instances do
		longStr := "";
		longStr &amp;= userEmailAddress.user.csvFormat &amp; Comma;
		longStr &amp;= userEmailAddress.altUser.csvFormat &amp; Comma;
		longStr &amp;= userEmailAddress.getsSummary.String.csvFormat &amp; Comma;
		longStr &amp;= userEmailAddress.getsUserIgnore.String.csvFormat &amp; Comma;
		longStr &amp;= userEmailAddress.getsUserSummary.String.csvFormat &amp; Comma;
		longStr &amp;= userEmailAddress.isAdmin.String.csvFormat &amp; Comma;
		longStr &amp;= userEmailAddress.isDisabled.String.csvFormat &amp; Comma;
		longStr &amp;= userEmailAddress.isTester.String.csvFormat;
		file.writeLine(longStr);
		
	endforeach;
	
	if RemoveUserEmailAddresses then
		beginTransaction;
		UM_UserEmailAddress.instances.purge;
		commitTransaction;
		
	endif;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwImportUserEmailAddress" id="0306e1dd-f3bb-40a2-ac6d-070866e92ce3">
        <source>pwImportUserEmailAddress();
/*

Purpose:			Imports all instances of UM_UserEmailAddress from CSV

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2025	navpw1	Initial creation

*/

vars
	userEmailAddress,
	realUserEmail		: UM_UserEmailAddress;
	root				: UM_Root;
	
	
	
	fileObj			: File;
	fileName		: String;
	fileLine		: String;
	rowCount		: Integer;
	allRowFields	: HugeStringArray;
	allFileRows		: ObjectArray;
	fieldCount		: Integer;
	pointer			: Integer;
//	returnValue		: Integer;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
	object : Object;
	stringArray : HugeStringArray;
	
	userString,
	altUser		: String;
	getsSummary,
	getsUserIgnore,
	getsUserSummary,
	isAdmin,
	isDisabled,
	isTester	: Boolean;
	
begin
	root := UM_Root.firstInstance;
	
	/*headerLine := UM_UserEmailAddress::user.name &amp; Comma &amp; 
					UM_UserEmailAddress::altUser.name &amp; Comma &amp;
					UM_UserEmailAddress::getsSummary.name &amp; Comma &amp;
					UM_UserEmailAddress::getsUserIgnore.name &amp; Comma &amp;
					UM_UserEmailAddress::getsUserSummary.name &amp; Comma &amp;
					UM_UserEmailAddress::isAdmin.name &amp; Comma &amp;
					UM_UserEmailAddress::isDisabled.name &amp; Comma &amp;
					UM_UserEmailAddress::isTester.name;
	*/
    //on FileException do global.fileExceptionHandler(exception, "Import");     
	on FileException do global.fileExceptionHandler(exception,ERR_FILEIMPORT);
	
	create fileObj transient;
	
	if fileObj.cnEcSetOpenName(false, false, "CSV Files (*.csv)|*.csv") then
		fileName := fileObj.fileName;
	endif;
	
	if fileName = null then
		return;
	endif;
	
	create fileObj transient;
	fileObj.kind		:=	File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	fileObj.fileName	:=	fileName;
	fileObj.close();
	fileObj.mode		:=	File.Mode_Input;
	fileObj.shareMode	:=	File.Share_Read;
	fileObj.endOfLine	:=	Lf;
	fileObj.open();
	
	create allFileRows transient;
	rowCount	:=	0;
	
	//Build an array to pass to the trx from the file.
	while not fileObj.endOfFile() do
		fileLine	:=	fileObj.readLine().trimBlanks();
		
		rowCount	:=	rowCount + 1;
		
		if rowCount = 1 or fileLine.isBlankRecordCSV() then
			// Ignore the first line, this only contains headers.
			// Also ignore blank lines.
			continue;
		endif;
		
		create allRowFields transient;
		fileLine.csvConvert(allRowFields, ",");		// cnwdad1 25/11/2009 - PAR #21720 Added delimiter parameter.
		
		fieldCount	:=	allRowFields.size();
		
		allFileRows.add(allRowFields);
	endwhile;
	fileObj.close();
	
	
	foreach stringArray in allFileRows as HugeStringArray do
		realUserEmail := null;
		
		//actionType := null;
		//actionHeading := null;
		//actionObject := null;
		//keyword := null;
		//descrip := null;
		//keyFileSegment := null;
		//name := null;
		//found := false;
		
		//The file needs to have at least 3 fields. Identified during PAR19517
		if stringArray.size &lt; 8 then
			app.raiseCMException(ERR_CSVLoadError, null, null);
			return;
		endif;
		
		userString := stringArray[1];
		altUser := stringArray[2];
		getsSummary := stringArray[3].Boolean;
		getsUserIgnore := stringArray[4].Boolean;
		getsUserSummary := stringArray[5].Boolean;
		isAdmin := stringArray[6].Boolean;
		isDisabled := stringArray[7].Boolean;
		isTester := stringArray[8].Boolean;
		
		if userString = null then
			continue;
		endif;
		
		//Check a user email does not already exist.
		realUserEmail := root.allUserEmailAddresses[app.returnCorrectUserName(userString, true)];
		//realUserEmail := root.allUserEmailAddresses[userString];
		
		if realUserEmail &lt;&gt; null then
			//run an update
			if process.isInTransactionState then
				app.cmsAbortTransaction();
				//raiseException("Script is in transaction state which is not expected. Aborting Transaction");
				return;
			endif;
			beginTransaction;
			realUserEmail.setNewUserDetails(realUserEmail.user, altUser, isAdmin, getsSummary, getsUserSummary, getsUserIgnore, isDisabled, isTester, null);
			realUserEmail.setPropertyValue(UM_UserEmailAddress::user.name, userString);
			commitTransaction;
		else
			//Add new
			//readline
			beginTransaction;
			create userEmailAddress persistent;
			userEmailAddress.setNewUserDetails(userString, altUser, isAdmin, getsSummary, getsUserSummary, getsUserIgnore, isDisabled, isTester, null);
			userEmailAddress.setPropertyValue(UM_UserEmailAddress::user.name, userString);
			commitTransaction;
		endif;
		
	endforeach;
	
	
	
epilog
	if process.isInTransactionState then
		app.cmsAbortTransaction();
		//raiseException("Script is still in transaction state when running the epilog. This is not expected. The transaction has been aborted");
	endif;
	
	
	delete fileObj;
	//Can be null if a file exception occurs.
	if allFileRows &lt;&gt; null then
		allFileRows.purge();
	endif;
	delete allFileRows;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwResendEmailSummaryByTeam" id="7cd21381-df05-4b39-944c-dd59238b6428">
        <source>pwResendEmailSummaryByTeam();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2025	navpw1	Initial creation
08/05/2025		navhn30 MTN: 34403: MTN - Sending Unit Tests Failing Summary Report by Team to Users that are Interested in it - Part 4 - Phase1

*/

vars
	testRoot					: UM_Root;
	previousRun					: UM_UnitTestRun;
	testRunner 					: JMTTestController;
	previousTestResults			: UT_TestResultsByName;
	allPreviousUMResults		: UM_UnitTestResultByMRunTS;
	umResult					: UM_UnitTestResult;
	utResult					: UT_TestResult;
	userSummaryDict				: CM_AssociationDict;
	userIgnoreDict				: CM_AssociationDict;
	association					: CM_Association;
	summary						: String;
	user						: String;
	
	iter						: Iterator;
	retVal						: Integer;
	isOk						: Boolean;
	byTeam						: Boolean;
	teamName					: String;
	isHtml						: Boolean;
	
begin
	app.initialize();
	testRoot := UM_Root.firstInstance;
	iter := testRoot.allUnitTestRuns.createIterator();
	iter.back(previousRun);
	
	byTeam := true;
	isHtml := true;
	
	if previousRun &lt;&gt; null and not previousRun.endTS.isValid() then
		retVal := app.msgBox("Are you sure you want to continue ?" &amp; CrLf &amp; "Script will likely break." &amp; CrLf &amp; CrLf &amp; "Retry to get the run before this one", "Previous run did not finish", MsgBox_Abort_Retry_Ignore);
		if retVal = MsgBox_Return_Abort then
			return;
		elseif retVal = MsgBox_Return_Retry then
			iter.back(previousRun);
		endif;
	endif;
	
	if previousRun = null then
		app.msgBox("No Unit Test run found", "Error", MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	
	create testRunner transient;
	testRunner.setTotalRunableTests(previousRun.totalRunnable);
	testRunner.setPropertyValue(JMTTestController::startTime.name, previousRun.startTS);
	testRunner.setPropertyValue(JMTTestController::finishTime.name, previousRun.endTS);
	testRunner.checkLeaks := previousRun.checkLeaks;
	testRunner.logResult := previousRun.logResult;
	testRunner.setScheduleName(previousRun.scheduleName);
	
	previousTestResults := testRunner.getTestResults();
	
	create allPreviousUMResults transient;
	previousRun.allFailed.copy(allPreviousUMResults);
	previousRun.allIgnored.copy(allPreviousUMResults);
	previousRun.allPassed.copy(allPreviousUMResults);
	
	// ... the hard way it is then (surely there is a better way to get the previous results)
	foreach umResult in allPreviousUMResults do
		create utResult transient;
		utResult.setFromUmResult(umResult);
		previousTestResults.add(utResult);
	endforeach;
	
	create userSummaryDict transient;
	create userIgnoreDict transient;
	
	testRunner.setSendEmail(true);
	
	userSummaryDict.clear();
	userIgnoreDict.clear();
	delete iter;
	
	summary := "";
	
	if isHtml and byTeam then //09.09.2025 navah1 #34969
		summary := testRunner.getResSumFailOnlyHTML(userSummaryDict, userIgnoreDict);
	else
		summary := testRunner.getResultsSumFailOnly(userSummaryDict, userIgnoreDict, false, byTeam);
	endif;
	
	// 28/04/2025  navhn30 	MTN-34403	 start
	if not byTeam then
		if not summary.cnContains("Failed: 0 ") then
			summary &amp;= CrLf &amp; "Note: This is tabbed delimited. If the spacing looks in-correct that will be because you are not viewing it with a monospace font. Please copy and paste the message into notepad, which uses a monospace font";
			app.emailReports(summary, "Failure Summary", 1, testRunner, byTeam,false);
		endif;
	else
		if not userSummaryDict.isEmpty then
			iter := userSummaryDict.createIterator;
			while iter.next(association) do
				iter.getCurrentKeys(teamName);
				if isHtml then //09.09.2025 navah1 #34969
					summary := "&lt;h3&gt;&lt;hr/&gt;Team " &amp; teamName &amp; "&lt;hr/&gt;&lt;/h3&gt;&lt;table border='1'&gt;&lt;tr&gt;&lt;th&gt;Pass/Fail&lt;/th&gt;&lt;th&gt;Time(Sec)&lt;/th&gt;&lt;th&gt;Start Date&lt;/th&gt;&lt;th&gt;Test Class/Name&lt;/th&gt;&lt;/tr&gt;" &amp; association.asString &amp; "&lt;/table&gt;";				
				else
					summary := "====================" &amp; CrLf &amp;
								"Team " &amp; teamName &amp; CrLf &amp;
								"====================" &amp; CrLf &amp;
								"P/F" &amp; Tab &amp; "Time (Sec)" &amp; Tab &amp; "Start Date" &amp; Tab &amp; Tab &amp; "Test Class/Name" &amp;
								association.asString;
					summary &amp;= CrLf &amp; "Note: This is tabbed delimited. If the spacing looks in-correct that will be because you are not viewing it with a monospace font. Please copy and paste the message into notepad, which uses a monospace font";
				endif;
				app.emailReports(summary, teamName, 1, testRunner, byTeam, isHtml);
				//write summary;
			endwhile;
		endif;
	endif;
	
	isOk := true;
	
epilog
	if not isOk then
		delete utResult;
	endif;
	
	delete testRunner;
	delete allPreviousUMResults;
	delete userSummaryDict;
	delete userIgnoreDict;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwTestEmailSummary" id="c2565334-39cc-4be8-acca-5efdffda40ae">
        <source>pwTestEmailSummary();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2025	navpw1	Initial creation
08/05/2025		navhn30 MTN: 34403: MTN - Sending Unit Tests Failing Summary Report by Team to Users that are Interested in it - Part 4 - Phase1

*/

vars
	testRoot					: UM_Root;
	previousRun					: UM_UnitTestRun;
	testRunner 					: JMTTestController;
	previousTestResults			: UT_TestResultsByName;
	allPreviousUMResults		: UM_UnitTestResultByMRunTS;
	umResult					: UM_UnitTestResult;
	utResult					: UT_TestResult;
	userSummaryDict				: CM_AssociationDict;
	userIgnoreDict				: CM_AssociationDict;
	association					: CM_Association;
	summary						: String;
	user						: String;
	
	iter						: Iterator;
	retVal						: Integer;
	isOk						: Boolean;
	byTeam						: Boolean;
	teamName					: String;
	globalSummaryByTeam			: Boolean;
	
begin
	app.initialize();
	testRoot := UM_Root.firstInstance;
	iter := testRoot.allUnitTestRuns.createIterator();
	iter.back(previousRun);
	
	byTeam := false;
	globalSummaryByTeam := true;
	
	if previousRun &lt;&gt; null and not previousRun.endTS.isValid() then
		retVal := app.msgBox("Are you sure you want to continue ?" &amp; CrLf &amp; "Script will likely break." &amp; CrLf &amp; CrLf &amp; "Retry to get the run before this one", "Previous run did not finish", MsgBox_Abort_Retry_Ignore);
		if retVal = MsgBox_Return_Abort then
			return;
		elseif retVal = MsgBox_Return_Retry then
			iter.back(previousRun);
		endif;
	endif;
	
	if previousRun = null then
		app.msgBox("No Unit Test run found", "Error", MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	
	create testRunner transient;
	testRunner.setTotalRunableTests(previousRun.totalRunnable);
	testRunner.setPropertyValue(JMTTestController::startTime.name, previousRun.startTS);
	testRunner.setPropertyValue(JMTTestController::finishTime.name, previousRun.endTS);
	testRunner.checkLeaks := previousRun.checkLeaks;
	testRunner.logResult := previousRun.logResult;
	testRunner.setScheduleName(previousRun.scheduleName);
	
	previousTestResults := testRunner.getTestResults();
	
	create allPreviousUMResults transient;
	previousRun.allFailed.copy(allPreviousUMResults);
	previousRun.allIgnored.copy(allPreviousUMResults);
	previousRun.allPassed.copy(allPreviousUMResults);
	
	// ... the hard way it is then (surely there is a better way to get the previous results)
	foreach umResult in allPreviousUMResults do
		create utResult transient;
		utResult.setFromUmResult(umResult);
		previousTestResults.add(utResult);
	endforeach;
	
	create userSummaryDict transient;
	create userIgnoreDict transient;
	
	testRunner.setSendEmail(true);
	
	userSummaryDict.clear();
	userIgnoreDict.clear();
	delete iter;
	
	summary := "";
	summary := testRunner.getResultsSumFailOnly(userSummaryDict, userIgnoreDict, false, globalSummaryByTeam);
	
	if not byTeam then
		if not summary.cnContains("Failed: 0 ") then
			summary &amp;= CrLf &amp; "Note: This is tabbed delimited. If the spacing looks in-correct that will be because you are not viewing it with a monospace font. Please copy and paste the message into notepad, which uses a monospace font";
			app.emailReports(summary, "Failure Summary", 1, testRunner, null,false);
		endif;
	else
			if not userSummaryDict.isEmpty then
			iter := userSummaryDict.createIterator;
			while iter.next(association) do
				iter.getCurrentKeys(teamName);
				summary := "====================" &amp; CrLf &amp;
							"Team " &amp; teamName &amp; CrLf &amp;
							"====================" &amp; CrLf &amp;
							"P/F" &amp; Tab &amp; "Time (Sec)" &amp; Tab &amp; "Start Date" &amp; Tab &amp; Tab &amp; "Test Class/Name" &amp;
							association.asString;
				summary &amp;= CrLf &amp; "Note: This is tabbed delimited. If the spacing looks in-correct that will be because you are not viewing it with a monospace font. Please copy and paste the message into notepad, which uses a monospace font";
				app.emailReports(summary, teamName, 1, testRunner, byTeam,false);
				write summary;
			endwhile;
		endif;
	endif;
	
	isOk := true;
	
epilog
	if not isOk then
		delete utResult;
	endif;
	
	delete testRunner;
	delete allPreviousUMResults;
	delete userSummaryDict;
	delete userIgnoreDict;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwTestEmailSummaryByTeam" id="c705b9d1-cd76-48d7-9fd6-860376d6d276">
