    <JadeMethod name="deleteDiskFile" id="c5c22017-b38d-45a4-8846-4a6f7d14e9cc">
        <updating/>
        <source>deleteDiskFile(pFileName:String; pIsPresentationFileSystem:Boolean):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		30 June 2002 by cnwdad1
//
// Purpose:		Deletes the specified disk file.
//
// Parameters:	pFileName - The path name of the file to delete.
//				pIsPresentationFileSystem - For thin client nodes, this flag indicates
//					whether to use the thin client's own file system rather than the
//					Application Server node's file system.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theDiskFile	: File;
	returnValue	: Boolean;
	
begin
	returnValue	:=	false;
	create theDiskFile transient;
	
	theDiskFile.usePresentationFileSystem	:=	pIsPresentationFileSystem;
	theDiskFile.fileName					:=	pFileName;
	theDiskFile.purge();
	
	if theDiskFile.errorCode() &lt;&gt; 0 then
		self.doFileErrorSet(theDiskFile.errorCode(), pFileName);
	endif;
	
	returnValue	:=	true;
epilog
	delete theDiskFile;
	
	return returnValue;
end;</source>
        <access>protected</access>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pIsPresentationFileSystem" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
