    <JadeMethod name="isImport" id="a27bc89d-e4dc-4637-b3b2-0556a69f3542">
        <source>isImport() : Boolean;
vars
	ti: CM_TrackedItem;
begin
	if self.allDutyDocItems.isEmpty then
		return null;
	endif;
	
	ti := self.allDutyDocItems.first.getMyTrackedItem();
	if ti &lt;&gt; null then
		return ti.isImport;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCargoDetails" id="bdf0ee2b-d27a-43f0-9417-8d949668f33c">
        <updating/>
        <source>setCargoDetails(_cargo : CM_TrackedItem) updating;
/*

Purpose:		Some fields get set from the first CM_DutyDocItem cargo 	

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	if _cargo = null then
		
		return;
	endif;
	self.voyage:=_cargo.voyageCode;
//its the receival bol
	if _cargo.myReceivalBOL &lt;&gt; null then
		self.bol:=_cargo.myReceivalBOL.number;
	endif;
	
	if _cargo.myBOLDtl &lt;&gt; null then
		self.bolItem:=_cargo.myBOLDtl.getShortDisplay;
	endif;
	
	self.dischargePort:=_cargo.dischargePort;
	// self.destination:=_cargo.destinationPort;  PAR 32002
	self.loadPort:=_cargo.loadPort;
	
	if _cargo.myConsignee &lt;&gt; null then
		self.consignee:=_cargo.myConsignee.code;
		self.consigneeExpiryDate:=_cargo.myConsignee.licenseExpiryDate;
		self.consigneeLicenseNo :=_cargo.myConsignee.license;
	endif;
epilog

end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
    </JadeMethod>
