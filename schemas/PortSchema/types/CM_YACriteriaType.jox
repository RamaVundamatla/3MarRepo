	create tokens transient;
	pattern.getTokens(pattern.pattern, tokens);
	foreach name in tokens do
		mode := app.transitStatusString2Enum(name);
		if mode = null then
			//app.raiseCMException2(ErrYACriteriaNotFound, name, self.getTypeName, null, null);
			app.raiseCMException2(ErrYACriteriaNotFound, name, self.description, null, null);	//09 Oct 2013	NDL	Par 32456
		else
			if not _valueArray.includes(mode) then
				_valueArray.add(mode);
			endif;
		endif;
	endforeach;
epilog
	delete tokens;
