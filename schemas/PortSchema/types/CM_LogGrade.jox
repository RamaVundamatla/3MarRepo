    <JadeMethod name="getAllLocationRestrictions" id="dc51a9b3-452f-4faf-a8d7-7f188592eb79">
        <source>getAllLocationRestrictions():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

	lrl : CM_Restriction;
	str : String;

begin

	foreach lrl in self.allLocationRestrictions do
		if not lrl.isKindOf( CM_LocationRestriction ) then
			continue;
		endif;
		if str &lt;&gt; null then
			str := str &amp; ",";
		endif;
		str := str &amp; lrl.CM_LocationRestriction.id;
	endforeach;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="ef56e52c-cbe1-4f75-841b-f281ce6ee6ab">
        <source>getAuditText(): String;

vars
	txt,
	tmpStr	: String;
	len		: CM_LogLength;
	typ     : CM_LogType;
	treat   : CM_LogTreatment;
begin
	txt[10000] := '*';
	txt := null;

	txt := inheritMethod();

	foreach len in self.allLogLengths do
		if tmpStr = null then
			tmpStr := len.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; len.code;
		endif;
	endforeach;
	txt := txt &amp; 'Lengths' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	tmpStr:=null;
	foreach typ in self.allLogTypes do
		if tmpStr = null then
			tmpStr := typ.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; typ.code;
		endif;
	endforeach;
	txt := txt &amp; 'Types' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	tmpStr:=null;
	foreach treat in self.allLogTreatments do
		if tmpStr = null then
			tmpStr := treat.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; treat.code;
		endif;
	endforeach;
	txt := txt &amp; 'Treatments' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;


	return txt;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAvailableLocationsForSpec" id="63678b2e-148d-4e00-bb66-fab024f92794">
        <source>getAvailableLocationsForSpec(_type : CM_LogType; _treatment : CM_LogTreatment; _length : CM_LogLength; _locations : CM_LCSet input);
// -----------------------------------------------------------------------------
// Created:		15 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	iter, iter2 : Iterator;
	locationRestriction : CM_LocationRestrictLog;
	typeSet,
	treatmentSet,
	lengthSet			: CM_CodeSet;
begin
	iter := self.allLocationRestrictions.createIterator();
	create typeSet transient;
	create treatmentSet transient;
	create lengthSet transient;
	
	if _type &lt;&gt; null then
		typeSet.add(_type);
	endif;
	if _treatment &lt;&gt; null then
		treatmentSet.add(_treatment);
	endif;
	lengthSet.add(_length);
	
	while iter.next(locationRestriction) do
		//if locationRestriction.doesAllowTypeTreatmentLength(typeSet, treatmentSet, lengthSet) then
		if locationRestriction.doesAllowLogType(typeSet) and
	       locationRestriction.doesAllowTreatment(treatmentSet) and
	       locationRestriction.doesAllowLength(lengthSet) then
			locationRestriction.allLocationControllers.copy(_locations);
		endif;
	endwhile;
	
	if _locations.isEmpty then
		iter2 := self.allLocationRestrictions.createIterator();	
		while iter2.next(locationRestriction) do
			locationRestriction.allLocationControllers.copy(_locations);
		endwhile;	
	endif;

epilog
	delete typeSet;
	delete treatmentSet;
	delete lengthSet;
	delete iter;
	delete iter2;
end;</source>
        <Parameter name="_type" type="CM_LogType"/>
        <Parameter name="_treatment" type="CM_LogTreatment"/>
        <Parameter name="_length" type="CM_LogLength"/>
        <Parameter name="_locations" type="CM_LCSet" usage="input"/>
    </JadeMethod>
