    <JadeMethod name="initFilterTable" id="5f2f88d6-b8a3-4467-8be4-e64c3a5e0d7e">
        <updating/>
        <source>initFilterTable() updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	controller		: CMUI_Controller;
	
begin

	theTable := tblSearch;
	theTable.setTerminologyRelevant(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal);
	controller := app.myController;
	entTableDef := controller.getEntTableDef(ETDef_SupplierReleaseFilter);
	
	if entTableDef &lt;&gt; null then
		theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		theTable.adjustHeight(200);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef TAFind not found');
	endif;

end;</source>
