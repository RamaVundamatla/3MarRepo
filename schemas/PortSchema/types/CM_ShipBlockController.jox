    <JadeMethod name="validateMoveFrom" id="550c9406-ee9e-40c4-8f9a-a3d372914c1d">
        <source>validateMoveFrom(control: CMIF_MoveController);
//--------------------------------------------------
// Created:	12 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
	term : CM_Terminal;
begin

	if control.isPostMoveCleanup or control.isUndoMove then
		//---------------------
		//We are doing a cleanup or an unplan. No "from" validation is required
		//---------------------
		return;
	endif;

	// To be re engineered in 7.3.4 validate outside transaction.
/*	if CM_YardController.hasInstance(control.myToPrimaryLocation) then
		tmpTI := control.myTrackedItem;
		if tmpTI &lt;&gt; null then
			term := control.myToPrimaryLocation.myTerminal;
			if term &lt;&gt; null then
				if term.allOnsiteTIsByCargoTypeId[tmpTI.cargoType, tmpTI.id.trimBlanks] &lt;&gt; null then
					app.raiseCMException1(ERR_TI_ONSITE, tmpTI.cargoTypeDescr &amp; ' ' &amp; tmpTI.id, null, null);
				endif;
			endif;
		endif;
	endif;*/
		
	if control.isForcedMove then
		return;
	endif;
	
	// Can plan cargo now.	
/*	if self.myVoyage.isNonWorkedVoyage then
		//move mode can only be real mode
		if control.moveMode &lt;&gt; REAL_MODE then
			 	app.raiseCMException(ERR_INVALID_MODE, null, null);
		 endif;
	endif;*/
		
		
	inheritMethod(control);

end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="2c2a9c8e-ae55-472b-b186-63a6876dce9a">
        <source>validateMoveTo(_control: CMIF_MoveController input);
//--------------------------------------------------
// Created:	09 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	checkVoy : Boolean;
	theTI : CM_TrackedItem;
begin

	inheritMethod(_control);
	
	//19 Nov 2009	NDL	CCMS 1031 - commented out, can now plan and queue...
/*	if self.myVoyage.isNonWorkedVoyage or self.myVoyage.isNonPlannedVoyage then
		//move mode can only be real mode
// PAR 19450		if _control.moveMode &lt;&gt; REAL_MODE then
		if _control.moveMode = QUEUE_MODE then
		 	app.raiseCMException(ERR_INVALID_MODE, null, null);
		 endif;
	endif;	*/
	
   	//ti check for different voyage
	theTI := _control.myTrackedItem;
	checkVoy := true;
	
	if theTI.myVoyage = null then
		// no voyage to validate 
		checkVoy := false;
	elseif theTI.isStorage then
		//Validate same voyage if not an empty
		checkVoy := (not theTI.isAttributeTrue(TI_Attrib_IsEmpty));
	elseif theTI.allPlannedFutureMoves.containsLC(self) then   // PAR 35347
		checkVoy := false;
	endif;

	if checkVoy then
		//if theTI.myVoyage &lt;&gt; self.myVoyage then
		if theTI.myVoyage &lt;&gt; self.myVoyage and _control.moveMode = REAL_MODE then //05 Nov 2014	NDL	Par 35015
			app.raiseCMWarning3(WARN_DIFF_SHIP_VOYAGE, theTI.id, theTI.myVoyage.code, self.myVoyage.code, null, null, self);
		endif;		
	endif;

end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
