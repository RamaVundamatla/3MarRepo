    <JadeMethod name="updateLogDocket" id="b48489dc-e319-4889-9b82-7e8714176952">
        <source>updateLogDocket(_bolIn: CM_BOLIn);
//27 January 2011	cnwvu1
vars
	pxyBOLIn	: CM_BOLIn;
	loadStateSet: Boolean;
	
begin

	app.cmsBeginLoad(loadStateSet);
	pxyBOLIn:= _bolIn.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadStateSet);
	
	if self.opts.includesKey("Consignor") then
		pxyBOLIn.setConsignor( self.opts.str("Consignor").String );
	endif;

	
	self.updateBOL(pxyBOLIn);

epilog
	app.cmsEndLoad(loadStateSet);
	delete pxyBOLIn;
	
end;</source>
        <Parameter name="_bolIn" type="CM_BOLIn"/>
    </JadeMethod>
</Class>
