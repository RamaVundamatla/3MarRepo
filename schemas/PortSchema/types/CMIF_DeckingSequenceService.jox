    <JadeMethod name="getStackingSequence" id="a5a13f52-e3b4-4134-b366-16513930a3af">
        <source>getStackingSequence(_stack, _row, _tier: Integer): Integer;

/*

Purpose:			Get the sequence for the passed in stack, row and tier

Parameters:			Stack, Row and Tier

Return Value:		Sequence number calculated from Decking Options


Date		Who		Reason
17 Dec 2008	cnwdw1	Initial creation
18 Mar 2009	cnwkpd1	PAR #19164 - Rewrite to correct sequence calculation to allow
					"carpet stow" sequence, and correct the topup option
22 Dec 2009	cnwer1	CCMS 1025 when using out decking rules these are often reverse of in so needed to be able to 
					do that calc
*/

vars
	effectiveTierRule,
	effectiveTiers,
	tierOffset,
	actualStack,
	actualRow,
	sequenceStack,
	sequenceRow,
	middlePosition,
	gridSequence,
	middleOffset,
	sequence			: Integer;
	
begin
	
	// Firstly, just switch input row and stack if the Area Rule is by Row
	if self.areaRule = DeckingRule_ByStack or self.areaRule = DeckingRule_ByStackFill then
		actualStack			:= _stack;
		actualRow			:= _row;
	else
		actualStack			:= _row;
		actualRow			:= _stack;
	endif;
	
	// Set up effective Tier rule from Pattern Rule as either Columnwise
	// or Tierwise.  SideToSide is effectively Tierwise, and TopUp is effectively
	// Columnwise to the TopUp value, then Tierwise above that.
	effectiveTiers := self.tiers;
	tierOffset := null;
	
	if self.patternRule = DeckingRule_SideToSide then
		effectiveTierRule := DeckingRule_Tierwise;
	elseif self.patternRule = DeckingRule_Topup then
		if _tier &lt;= self.topupTier then
			effectiveTierRule := DeckingRule_Columnwise;
			// Effective number of tiers is the topup number in this case
			effectiveTiers := self.topupTier;
		else
			effectiveTierRule := DeckingRule_Tierwise;
			// We are now carpeting on top of the topup tiers, so we need an offset calculated
			// from the total number of slots in the topup area
			tierOffset := self.stacks * self.rows * self.topupTier;
		endif;
	else
		effectiveTierRule := self.patternRule;
	endif;
	
	// Calculate sequence Stack and Row (zero-relative orders) based on effective Rules
	if self.stackRule = DeckingRule_Increasing then
		sequenceStack := actualStack - 1;
	elseif self.stackRule = DeckingRule_Decreasing then
		sequenceStack := self.stacks - actualStack;
	elseif self.stackRule = DeckingRule_MiddleOut then
		if self.startStack = null then
			middlePosition := (self.stacks + 1) div 2;
		else
			middlePosition := (self.stacks + 1) div 2;
			if self.startStack &gt;= middlePosition then
				middleOffset:= self.stacks -self.startStack;
			else
				middleOffset:= self.startStack -1 ;
			endif;
			middlePosition:=self.startStack;
		endif;
		sequenceStack := (actualStack - middlePosition).abs * 2;
		if self.stacks.isEven then
			if actualStack &gt; middlePosition then
				sequenceStack := sequenceStack - 1;
			endif;
		else
			if actualStack &gt; middlePosition then
				sequenceStack := sequenceStack - 1;
			endif;
		endif;
		
		if self.startStack &gt; 0 then
			if actualStack &lt; (self.startStack - middleOffset) then
				sequenceStack:=self.stacks -actualStack;
			elseif actualStack &gt; (self.startStack + middleOffset) then
				sequenceStack:=actualStack -1;
			endif;
		endif;
	elseif self.stackRule = DeckingRule_Random then
		sequenceStack := null;
	endif;
	
	if self.rowRule = DeckingRule_Increasing then
		sequenceRow := actualRow - 1;
	elseif self.rowRule = DeckingRule_Decreasing then
		sequenceRow := self.rows - actualRow;
	elseif self.rowRule = DeckingRule_MiddleOut then
		if self.startRow = null then
			middlePosition := (self.rows + 1) div 2;
		else
			middlePosition := (self.rows + 1) div 2;
			if self.startRow &gt;= middlePosition then
				middleOffset:= self.rows -self.startRow;
			else
				middleOffset:= self.startRow -1 ;
			endif;

			middlePosition:=self.startRow;
		endif;	
		sequenceRow := (actualRow - middlePosition).abs * 2;		
		if self.rows.isEven then
			if actualRow &gt; middlePosition then
				sequenceRow := sequenceRow - 1;
			endif;
		else
			if actualRow &lt; middlePosition then
				sequenceRow := sequenceRow - 1;
			endif;
		endif;
		
		if self.startRow &gt; 0 then
			if actualRow &lt; (self.startRow - middleOffset) then
				sequenceRow:=self.rows -actualRow;
			elseif actualRow &gt; (self.startRow + middleOffset) then
				sequenceRow:=actualRow -1;
			endif;
		endif;
	elseif self.rowRule = DeckingRule_Random then
		sequenceRow := null;
	endif;
	
	// For Side To Side pattern, need to flip the relative order for every second
	// Stack and Tier combination
	if self.patternRule = DeckingRule_SideToSide then
		if (sequenceStack + _tier).isEven then
			sequenceRow := self.rows - sequenceRow - 1;
		endif;
	endif;
	
	// First we calculate the (zero-relative) grid position
	gridSequence := sequenceStack * self.rows + sequenceRow;

	// Then we can calculate the final sequence based on the effective Tier rule
	if effectiveTierRule = DeckingRule_Tierwise then
		if self.areaRule = DeckingRule_ByStack or self.areaRule = DeckingRule_ByRow then
			// Allow for (tier - 1) layers underneath our current slot
			sequence := (_tier - 1) * self.stacks * self.rows + gridSequence + 1;
		else
			// Allow for (tier - 1) layers underneath our current slot (stack first)
			sequence := (sequenceStack * self.rows * self.tiers) + ((_tier - 1) * self.rows) - (sequenceStack * self.rows) + gridSequence + 1;
		endif;
	else
		// Allow for previous full columns (up to effectiveTiers)
		sequence := gridSequence * effectiveTiers + _tier + tierOffset;
	endif;
	
	
	return sequence;
	
	
epilog

end;</source>
        <Parameter name="_stack" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_tier" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStackingSequenceByStack" id="bca39a39-3e06-4b35-a7d6-4c4c94b0752c">
        <source>getStackingSequenceByStack(_stack, _row, _tier: Integer): Integer;
//17 December 2008	cnwdw1	
// row is row, stack is stack (column) and _tier is tier (height)
vars
	seq: Integer;
	d: Integer;
	stack, row: Integer;
begin

	if self.areaRule  = DeckingRule_ByStackFill then
		stack := _stack;
		row := _row;
	else
		stack := _row;
		row := _stack;
	endif;
	
	if self.stackRule = DeckingRule_Increasing then
		seq := ((stack-1)*rows*tiers);
	elseif self.stackRule = DeckingRule_Decreasing then
		seq := ((stacks-stack)*rows*tiers);
	elseif self.stackRule = DeckingRule_MiddleOut then
		d := stack - ((stacks+1) / 2).Integer;  // distance from middle
		if d &gt;= 0 then
			seq := 1 + (d * 2);
		else
			seq := d * -1 * 2;
		endif;
		seq := ((seq-1)*rows*tiers);
	elseif self.stackRule = DeckingRule_Random then
	
	endif;
	
	if self.rowRule = DeckingRule_Increasing then
		if self.patternRule = DeckingRule_Columnwise then
			seq := seq + ((row-1)*tiers) + _tier;
		elseif self.patternRule = DeckingRule_Tierwise then
			seq := seq + ((_tier-1)*rows) + row;
		elseif self.patternRule = DeckingRule_Topup then
			if _tier &lt;= self.topupTier then
				seq := seq + ((row-1)*self.topupTier) + _tier;
			else
				seq := seq + ((_tier-1)*self.rows) + row;
			endif;
		elseif self.patternRule = DeckingRule_SideToSide then
			seq := seq + ((_tier-1)*rows);
			if _tier.isOdd then
				seq := seq + row;
			else
				seq := seq + (rows-row+1);
			endif;
		endif;
	elseif self.rowRule = DeckingRule_Decreasing then	
		if self.patternRule = DeckingRule_Columnwise then
			seq := seq + ((rows-row)*tiers) + _tier;
		elseif self.patternRule = DeckingRule_Tierwise then
			seq := seq + ((_tier-1)*rows) + (rows-row+1);
		elseif self.patternRule = DeckingRule_Topup then
			if _tier &lt;= self.topupTier then
				seq := seq + ((rows-row)*self.topupTier) + _tier;
			else
				seq := seq + ((_tier-1)*rows) + (rows-row+1);
			endif;
		elseif self.patternRule = DeckingRule_SideToSide then
			seq := seq + ((_tier-1)*rows);
			if _tier.isOdd then
				seq := seq + (rows-row+1);
			else
				seq := seq + row;
			endif;
		endif;
	elseif self.rowRule = DeckingRule_MiddleOut then	
		if self.patternRule = DeckingRule_Columnwise then
			d := row - ((rows+2) / 2).Integer;  // distance from middle
			if d &gt;= 0 then
				seq := seq + (d*2*tiers);
			else
				seq := seq + (((d*-1*2)-1)*tiers);
			endif;
			seq := seq + _tier;
		endif;
	endif;
//write "Stack:"&amp;_stack.String&amp;" Row:"&amp;_row.String&amp;" Tier:"&amp;_tier.String&amp;" Seq:"&amp;seq.String;
	return seq;
end;</source>
        <Parameter name="_stack" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_tier" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="onCreate" id="37bb90b4-a020-4291-9e66-78f6a1626db6">
        <updating/>
        <source>onCreate(_areaRule: Integer) updating;
//06 January 2009	cnwdw1	
// This must be set first
vars

begin
	self.areaRule := _areaRule;
end;</source>
        <Parameter name="_areaRule" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setExtent" id="bd17a8c3-6ab1-459f-a640-ada65495e791">
        <updating/>
        <source>setExtent(_stacks, _rows, _tiers: Integer) updating;
//17 December 2008	cnwdw1	
// Set the extend of the area
vars

begin
	if self.areaRule = DeckingRule_ByStack or self.areaRule = DeckingRule_ByStackFill then
		self.rows := _rows;
		self.stacks := _stacks;
	else
		self.rows := _stacks;
		self.stacks := _rows;
	endif;
	self.tiers := _tiers;
end;</source>
        <Parameter name="_stacks" type="Integer"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_tiers" type="Integer"/>
    </JadeMethod>
