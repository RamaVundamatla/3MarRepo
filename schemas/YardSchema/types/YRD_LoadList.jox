    <JadeMethod name="doSummaryContextMenu" id="5a9e3996-9e80-4144-bc24-dc78e6f63044">
        <updating/>
        <source>doSummaryContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//----------------------------------------------------------------
//	Created:	27 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	
begin
		
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return false;
	endif;

	return self.showContextMenu(self.mnuSummary,cntrl,conwin,mouse,x, y);

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
