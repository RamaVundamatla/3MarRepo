    <JadeMethod name="setIsWeightCertified" id="e4fa030f-cf27-4cd8-9139-893244f95700">
        <source>setIsWeightCertified(_value : Boolean);
/*

Date		Who		Reason
02 June 2016	cnwer1	Initial creation TFS 2011

*/

vars

begin
	if self.chkIsWeightCertified.visible then
		self.chkIsWeightCertified.setValue(_value);
	else
		self.chkWeightCert.value := _value;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setNumItemsCaptionAndEnabled" id="a532c4df-5a4b-4535-8eb7-836c1434eb12">
        <source>setNumItemsCaptionAndEnabled( _cargoType : CM_CargoType ) protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/03/2014	cnwndl1	Initial creation	Par 22596
21/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - hide Num Items field for Bulk with allowDuplicateIds
*/

vars

	cargoId : String;

begin

	/*
	txtNumItems should only ever be used for the "Total Quantity" value of a real break bulk cargo item OR the "total Quantity" of a receive by type
	where the cargo type is real Break Bulk. (In this situation we are still talking about "Total Quantity" but it may come from
	one or more cargo ids.)
	
	When the Cargo Type is NOT real break bulk, the the name should always be "Number of Cargo Ids." 
	So when the Cargo Id is declared, AND the Cargo Type is NOT real Break Bulk, then txtNumItems should be set to 'one' and it should be non-eneterabnle.
	But if NO cargo id(s) are entered, then "Number of Cargo Ids." should be available for ebtry and represent the number of individual cargo items
	that are being received (by type).
	*/

	cargoId := self.txtCargoID.getString();
	
	//Set the name on the label to something meaningful
	if self.isFlexiGateForm and _cargoType &lt;&gt; null and not _cargoType.allowDuplicates and cargoId = null then
		//receive by type of NON break bulk with no identified cargo id(s)
		self.txtNumItems.setMyCaption(app.getErrorString(NumberOfCargoIds));
	else
		self.txtNumItems.setMyCaption(app.getErrorString(CM_Total_Quantity));
	endif;
	
	
	//  Enable/Disable the text box and label based on whether it is allowed to be something other than a value of '1'. 
	if self.isFlexiGateForm then
		//In the Road Gate you can have Receive by types, this changes teh rules slightly
		if cargoId = null and _cargoType &lt;&gt; null and not _cargoType.allowDuplicates then
			//receive by type of NON break bulk cargo with NO identified cargo id(s)
			// allow "Number of cargo ids" to be set
			self.txtNumItems.setIsEnabled(true);
			self.txtNumItems.enabled := true;
		elseif _cargoType &lt;&gt; null and _cargoType.allowDuplicates then
			if _cargoType.isBulkMulti then											// PAR #33606
				self.txtNumItems.isHidden := true;									// PAR #33606
			else																	// PAR #33606
				//Real break bulk cargo always allow "total quantity" to be entered
				self.txtNumItems.setIsEnabled(true);
				self.txtNumItems.enabled := true;
			endif;																	// PAR #33606
		else
			//Not break bulk and not NON Break Bulk 'receive by type'
			self.txtNumItems.setIsEnabled(false);
			self.txtNumItems.enabled := false;
			self.txtNumItems.setValue(1);
		endif;
		
	else
		// All other forms, there is no Receive by Type
		if _cargoType &lt;&gt; null and _cargoType.allowDuplicates then
			if _cargoType.isBulkMulti then											// PAR #33606
				self.txtNumItems.isHidden := true;									// PAR #33606
			else																	// PAR #33606
				//Real break bulk cargo always allow
				self.txtNumItems.setIsEnabled(true);
				self.txtNumItems.enabled := true;
			endif;																	// PAR #33606
		else
			//Everything else
			self.txtNumItems.setIsEnabled(false);
			self.txtNumItems.enabled := false;
			self.txtNumItems.setValue(1);
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setNumItemsValueFormObject" id="a4eba912-3f98-48be-85f8-ba029963881a">
        <source>setNumItemsValueFormObject( _obj : Object ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2014	cnwndl1	Initial creation	Par 33596

*/

vars

begin

	
	if _obj.isKindOf(CMIF_PreNote) then	//08 July 2014	NDL	Par 34526
		self.txtNumItems.setValue(_obj.CMIF_PreNote.numberOfItems.asStringJMT);	//08 July 2014	NDL	Par 34526
	elseif _obj.isKindOf(CM_TrackedItem) then
		self.txtNumItems.setValue(_obj.CM_TrackedItem.totalQuantity);
	elseif _obj.isKindOf(CMGTE_Receival) then
		self.txtNumItems.setValue(_obj.CMGTE_Receival.totalQuantity);
	elseif _obj.isKindOf(CM_ReceivalInfo) then
		self.txtNumItems.setValue(_obj.CM_ReceivalInfo.quantity);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setObjectFromNumItemsValue" id="51adf36e-f68f-4d0c-9552-9ad889942f23">
        <source>setObjectFromNumItemsValue( _obj : Object ) protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/03/2014	cnwndl1	Initial creation	Par 33596
25/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - if we are receiving a Bulk item, set pieces to 1

*/

vars

	int : Integer;
	controller : CMIF_FlexiGateController;
	intFaceObj : CMIF_PreNote;
	proxyTI : CM_TrackedItem;
	cargoType : CM_CargoType;							// PAR #33606

begin

	int := self.txtNumItems.getInteger();
	cargoType := self.cmbType.getObject().CM_CargoType;						// PAR #33606
	if cargoType &lt;&gt; null and cargoType.isBulkProduct and int = null then	// PAR #33606
		int := 1;															// PAR #33606
	endif;																	// PAR #33606

	if _obj.isKindOf( CMIF_FlexiGateController ) then
		controller := _obj.CMIF_FlexiGateController;
		controller.numItems := self.txtNumItems.getInteger();	
		if controller.jobType &lt;&gt; CMGTE_Entity.JobType_ReceivalByType then		// PAR 35270
			controller.numItems := controller.numItems.max(1);					// PAR #33606
		endif;
		
		//this looks dubious.....  Think it is specifically for Port Nelson.
		if controller.cargoType = TI_CargoType_Timber then
			if self.txtCargoID.getString &lt;&gt; null then
				if int &gt; 0 then
					controller.quantity := int;
				endif;
			endif;
		endif;
		
	elseif _obj.isKindOf( CMIF_PreNote ) then
		intFaceObj := _obj.CMIF_PreNote;
		intFaceObj.numberOfItems := int;
	
	
	elseif _obj.isKindOf( CM_TrackedItem ) then
		proxyTI := _obj.CM_TrackedItem;
		if proxyTI.myCargoType &lt;&gt; null and proxyTI.myCargoType.allowDuplicates then
			proxyTI.setTotalQuantity( int );
		endif;
		
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setObjectFromQuantityValue" id="0e271d73-4ef8-4552-9b07-020d3a50b3fe">
        <source>setObjectFromQuantityValue( _obj : Object ) protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/03/2014	cnwndl1	Initial creation	Par 33596
25/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - if we are receiving a Bulk item, set pieces to 1
15 May 2025 navah1	Story 34459: MTN - Unnecessary Edit Transaction Created for Quantity
*/

vars

	pieces : Integer;
	controller : CMIF_FlexiGateController;
	intFaceObj : CMIF_PreNote;
	proxyTrackedItem : CM_TrackedItem;
	cargoType : CM_CargoType;							// PAR #33606

begin

	// this value always represents teh 'pieces' style of quantity.  I.e. The 12 beers in a box of beer
	// where the box of beer is the cargo in JMT with the cargo id. ( Not the bottles.) 
	
	pieces := self.txtQuantity.getInteger();
	cargoType := self.cmbType.getObject().CM_CargoType;							// PAR #33606
	
	/* //15.05.2025 navah1 #34459
	if cargoType &lt;&gt; null and cargoType.isBulkProduct and pieces = null then		// PAR #33606
		pieces := 1;															// PAR #33606
	endif;																		// PAR #33606
	*/
	if cargoType &lt;&gt; null and pieces = null then									//15.05.2025 navah1 #34459
		if cargoType.isBulkProduct or cargoType.isBreakBulk then	 
			pieces := 1;
		endif;
	endif;

	if _obj.isKindOf( CMIF_FlexiGateController ) then
		controller := _obj.CMIF_FlexiGateController;
		controller.quantity := pieces;
		
	elseif _obj.isKindOf( CM_TrackedItem ) then
		proxyTrackedItem := _obj.CM_TrackedItem;
		proxyTrackedItem.setAttributeFromDisplayName(ETRow_Quantity, pieces);
	
	elseif _obj.isKindOf( CMIF_PreNote ) then
		intFaceObj := _obj.CMIF_PreNote;
		intFaceObj.quantity := pieces;
		
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setOptionalDischargePortsList" id="269fc79c-a961-4766-9367-bdb2367e6596">
        <updating/>
        <source>setOptionalDischargePortsList(_voyage : CM_Voyage; _ports : StringArray) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwdap1	Initial creation

*/

vars
	str 	: String;

begin
	self.myAssistant.listTableDischarge(self.lstOptionalPorts, _voyage, null);
	self.myAssistant.setListTablePorts(self.lstOptionalPorts, _ports);
	str := self.lstOptionalPorts.getSelectedString('code');
	if str.length &gt; 30 then
		self.txtOptDischarge.text := str[1:29]&amp; '...';
	else
		self.txtOptDischarge.text := str;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_ports" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setOverDimensionDetails" id="8651bb1c-f5f5-4f3a-a224-637d8f720b71">
        <updating/>
        <source>setOverDimensionDetails(_front, _rear, _left, _right, _height : Decimal) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/07/2009	cnwdap1	Initial creation
19/02/2010	cnwdap1	PAR #21624 Dimensions are displayed with no decimals
27/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements - we now have to keep decimals for measurements
25/03/2014	cnwdap1	PAR #33810 Can't just cast as String as that buggers up locales where '.' is not the decimal separator
*/
vars
	str 	: String;

begin
	//txtDimLenFront.text	:= _front.String;						// PAR #31155	// PAR #33810
	//txtDimLenRear.text	:= _rear.String;						// PAR #31155	// PAR #33810
	//txtDimWidthLeft.text	:= _left.String;						// PAR #31155	// PAR #33810
	//txtDimWidthRight.text	:= _right.String;						// PAR #31155	// PAR #33810
	//txtDimOverHeight.text	:= _height.String;						// PAR #31155	// PAR #33810
	txtDimLenFront.text		:= _front.asStringJMT;					// PAR #31155	// PAR #33810
	txtDimLenRear.text		:= _rear.asStringJMT;					// PAR #31155	// PAR #33810
	txtDimWidthLeft.text	:= _left.asStringJMT;					// PAR #31155	// PAR #33810
	txtDimWidthRight.text	:= _right.asStringJMT;					// PAR #31155	// PAR #33810
	txtDimOverHeight.text	:= _height.asStringJMT;					// PAR #31155	// PAR #33810
	
	// set label text
	if _front &lt;&gt; null or _rear &lt;&gt; null or _left &lt;&gt; null or _right &lt;&gt; null or _height &lt;&gt; null then
		lblIsOverDim.caption := "Click for Details";
	endif;
epilog

end;</source>
        <Parameter name="_front" type="Decimal"/>
        <Parameter name="_rear" type="Decimal"/>
        <Parameter name="_left" type="Decimal"/>
        <Parameter name="_right" type="Decimal"/>
        <Parameter name="_height" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setPhotosText" id="af7e09c0-15ef-42d3-b686-192ca0d0433e">
        <source>setPhotosText();
/*

Date		Who		Reason
24 October 2013	cnwer1	Initial creation PAR

*/

vars

begin
	
	if self.allPhotos.size &gt; 0 then
	
		self.lblPhotos.caption:=self.allPhotos.size.asStringJMT;
	else
		self.lblPhotos.caption:=null;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setPreNote" id="a77f4253-3e4b-4f45-a3d3-c7440221f66c">
        <updating/>
        <source>setPreNote() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/07/2009	cnwdap1	Initial creation
09/10/2009	cnwdap1	PAR #21138 clear hazards and special lift arrays on transient intFaceObj to avoid duplicates if we get an error then try to save again
12/10/209	cnwdap1	PAR #21125 Weight (at the subcargo level) was not being set
12/10/2009	cnwdap1	PAR #21139 Colour was not being saved to CMIF_Receival or tracked item
20/11/2009	cnwdap1	CCMS MES 1017 Save Tare and Cargo (net) weight
15/12/2009	cnwdap1	PAR #21969 Fix 1086 error when editing an existing prenote (tracked item)
17/12/2009	cnwdap1	PAR #21586 Save entered booking reference even if we don't have a booking ref object
17/12/2009	cnwdap1	PAR #21827 Clear Iso type if iso type combo is not visible
22/01/2010	cnwjre1	CCMS 1071 add on-ship general cargo code
15/03/2010	cnwdap1	PAR #23190 Dimensions type could ceom from combo box or text box
16/03/2010	cnwmh5	PAR #22546 Change txtTotalWeight to use getString.asDecimalJMT() rather than getInteger
15/01/2013	cnwdap1	PAR #31018 CCMS POL 2223 Added new On Power During Transit fields
27/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
10/04/2013	cnwdap1	PAR #31411 If packed date/time in the future, don't relcalculate remaining time off power
17/06/2013	cnwdap1	PAR #31688 Changes for PAR #31574 meant allowable time off power field was no longer a decimal field
								but this method still did a getDecimal on it, which returned zero.
12/08/2013	cnwdap1	PAR #32123 Colour changes
12/09/2013	cnwdap1	PAR #32215 New Car attributes
21/01/2014	cnwdap1	PAR #33278 Correct handling of Available Time Off Power not being entered 
05/03/2014	cnwdap1	PAR #33193 CCMS DPH 2285 Added Purchase Order and Service order fields
01/07/2014	cnwdap1	PAR #34483 Allow child cargo to be entered on ship
21/04/2015	cnwdap1	PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
30/10/2015	cnwma1	PAR #36740 Creating Prenote and Cargo Onship does not save damage details
25/11/2015	cnwma1  PAR #36943 Shipping Reference error during extract
16/11/2016	cnwdap1	TFS 2842 STWR Hazardous Details Enhancements
31/08/17    jlgns1	6735 POL - [Fwd: ##5431## : 8.5.1.090 Not saving VGM authorised details]
4.1.2018 	cnwma1  Bug 36720: LNX - FW: Ticket 8126 Ticket Number 6223214 - GLG - JMT - fault. THIS IS A PRIORATY A
20/02/2018 	cnwer1	tfs 7756 tiding up dimensions to align with web portal
3/05/2018 	JLGNS1	Bug 38457: DQM - Dry Bulk - ( Gate in and Merge )
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
15 Oct 2021	navdap1	TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
06 Dec 2021	navdap1	TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
20 May 2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
20 may 2022	navgm20 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
16 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
19/12/2022	jlika1	TFS 55584 HS Code Combobox Usage
06/04/2023	navkc1	CR# 56431 Task 56440: UI - Receive Cargo Form
10 Aug 2023	jlika1	TFS 59741 59148 POB | Port of Origin on Add New Cargo
27 Sep 2024 navhl20 Bug 23125 CUX - Wrong Child Cargo Load Port
03 Aug 2025	navnk30	JIRA 35571: SPT - Default value of No Info Voyage does not get transmitted while creating Pre-note
05 Jan 2026 navhl20 Bug MTN-36905: MTN - Transient leaks in receive cargo forms.
*/
vars
	assistant		: CMUI_Assistant;
	intFaceObj		: CMIF_PreNote;
	tmpAttach		: CMIF_TIObject;
	obj				: Object;
	operator		: CM_Operator;
	carriageTempC,
	carriageTempF,
	packTempC,
	packTempF		: Real;
	contentsCargoType,
	cargoType		: CM_CargoType;
	dimType			: CM_ProductAttributeCode;
	control 		: Control;
	newSeal			: CM_SealTI;
	sealValue 		: String;
	sealTypeName 	: String;
	sealType 		: CM_SealType;
	invalidHazard	: Boolean;
	hazard			: Object;
	
	tILCType 		: CM_TILCType;
	packed 			: TimeStamp;			// PAR #31018
	transit 		: TimeStamp;			// PAR #31018
	totalMinutes 	: Integer;				// PAR #31018
	hours 			: Integer;				// PAR #31018
	minutes 		: Decimal [12,2];		// PAR #31018
	stop : CM_Stops;
	rowIndex : Integer;
	allowable		: Decimal [12,2];		// PAR #31688
	tmpVoy : CM_Voyage;	//Par 32102
	haz, newHaz : CM_TIHazard;			// PAR #36421
	expArrivalTSLocal 	: TimeStamp;
	expArrivalTSSystem 	: TimeStamp;
	packTSLocal			: TimeStamp;
	packTSSystem		: TimeStamp;
	transitOnTSLocal 	: TimeStamp;
	transitOnTSSystem 	: TimeStamp;
	expiryTSLocal		: TimeStamp;
	weighAuthority : CM_WeighAuthority;
	weight		   : Decimal [16,8];
	product        : CM_Product;
	cmb				: CMUI_ComboBox;
	parentForm		: CM_BaseForm;
	isoType 	: CM_ISOType;
	invalid  	: Boolean;
	edition  	: Integer;
begin
	on Exception do app.handleDeletedObject( exception, self.myIntFacePreNote, invalid );		//05.01.2026 navhl20 #36905
	assistant := self.myAssistant;
	
	if self.myIntFacePreNote &lt;&gt; null then														//05.01.2026 navhl20 #36905
		invalid := false;
		edition := self.myIntFacePreNote.edition;
		
		if invalid then
			self.myIntFacePreNote := null;
		endif;
	endif;
	
	if self.myIntFacePreNote = null then
		if self.isOnshipForm  then // PAR 28400
			create self.myIntFacePreNote as CMIF_OnshipCargo transient;	
		elseif self.isOnsiteForm  then // TFS 2318
			create self.myIntFacePreNote as CMIF_OnsiteCargo transient;	 // TFS 2318
		else
			create self.myIntFacePreNote transient;	
		endif;
	endif;

	intFaceObj := self.myIntFacePreNote;	
	
	intFaceObj.myTerminal		:= self.myTerminal;
	intFaceObj.setUserDetails(self);
	intFaceObj.setMyInOutCommon(null);

	if self.myBookingRefItem &lt;&gt; null then
		intFaceObj.myBookingRefItem 	:= self.myBookingRefItem;
		intFaceObj.bookingReference		:= self.myBookingRefItem.myBookingReference.bookingReference;
	else
		intFaceObj.myBookingRefItem 	:= null;
		if self.txtBookingRef.getString &lt;&gt; null then										// PAR #21586
			intFaceObj.bookingReference	:= self.txtBookingRef.getString;	// PAR #21586
		endif;																				// PAR #21586
	endif;
	// BOL for onship
	if self.isOnshipForm then
		intFaceObj.CMIF_OnshipCargo.myBOL 				:= null;	//05 May 2014	NDL	Par 34034
		intFaceObj.CMIF_OnshipCargo.myBOLDtl			:= null;	//05 May 2014	NDL	Par 34034
		if self.myBOLDtl &lt;&gt; null then
			intFaceObj.billOfLading					:= self.myBOLDtl.myBOL.number;
			intFaceObj.CMIF_OnshipCargo.myBOL 		:= self.myBOLDtl.myBOL.CM_BOLIn;
			intFaceObj.CMIF_OnshipCargo.myBOLDtl	:= self.myBOLDtl;
		else
			//05 May 2014	NDL	Par 34034
			intFaceObj.billOfLading					:= self.txtBOLNumber.getString;
		endif;
		intFaceObj.houseBOL:= self.txtHouseBOL.getString; //epr par 35955 29/4/15
	else
		intFaceObj.billOfLading						:= self.txtHouseBOL.getString;
	endif;
	
	//15 Feb 2016	NDL	Par 37544
	intFaceObj.cargoGroupId := self.txtCargoGroupID.getString; //jlier1 TFS 53515 26/5/22

	// Main Details
	if self.cmbType.getObject &lt;&gt; null then
		cargoType 					:= self.cmbType.getObject.CM_CargoType;
		intFaceObj.cargoType		:= cargoType.id;
	endif;
	if self.cmbSubCargo.getObject &lt;&gt; null then
		intFaceObj.myProduct		:= self.cmbSubCargo.getObject.CM_Product;
	endif;
	
	intFaceObj.allDamageInstancesByPos.clear;									// 30/10/2015 cnwma1 PAR#36740
	self.allDamageInstancesByPos.copy(intFaceObj.allDamageInstancesByPos);		// 30/10/2015 cnwma1 PAR#36740
	//epr 20/2/18 tfs 7756 found while testing if pervious cargo type shows commodity  and changed to one that didn't causes weird validation error
	if not self.cmbCommodity.isHidden and self.cmbCommodity.getObject &lt;&gt; null then
		intFaceObj.commodity 		:= self.cmbCommodity.getObject.CM_Commodity.code;
	else	
		intFaceObj.commodity :=null;
	endif;
	intFaceObj.id 					:= self.txtCargoID.getString;
	
	if self.cmbISOType.visible then
		isoType := self.cmbISOType.getObject().CM_ISOType; //08/10/2025	navkc1 JIRA 36151
		if isoType &lt;&gt; null then
			intFaceObj.isoType			:= isoType.code;
			
			if isoType.isRotatable() then
				//07/10/2025	navkc1 JIRA 36151 - Create cargo on ship
				if not self.cmbContentsCargoType.isHidden then
					contentsCargoType := self.cmbContentsCargoType.getObject().CM_CargoType;
					if contentsCargoType &lt;&gt; null then
						intFaceObj.cargoTypeContents := contentsCargoType.id;
					endif;
					
					if not self.cmbProdType.isHidden then
						intFaceObj.myProduct := self.cmbProdType.getObject().CM_Product;
					endif;
				endif;
			endif;
		endif;
	else
		intFaceObj.isoType			:= null;
	endif;
	
	 // intFaceObj.weightTotal			:= self.tblTotalWeight.getConvertedValue;  			// PAR #31155  //24.1.2018 cnwma1 BUG #36720
	//24.1.2018 cnwma1 BUG #36720
	if cargoType &lt;&gt; null and cargoType.isBulkByVolume then
		if not self.cmbSubCargo.isHidden then
			product := self.cmbSubCargo.getObject.CM_Product;
		else
			product := cargoType.mySystemProductType;
		endif;
		if product &lt;&gt; null and product.myDensityDec.value &lt;&gt; null then							// ### TFS 52193 22Nov2021 NAVPW1
				weight := self.tblTotalVolume.getConvertedValue * product.myDensityDec.value;	// ### TFS 52193 22Nov2021 NAVPW1
		endif;
		intFaceObj.weightTotal 		:= weight;
	else
		intFaceObj.weightTotal			:= self.tblTotalWeight.getConvertedValue; 
	endif;
	
	if self.tblNettWeight.visible then														//Bug 38457
		intFaceObj.weightCargo			:= self.tblNettWeight.getConvertedValue; 	  		// PAR #31155  
		intFaceObj.weightTare			:= self.tblTareWeight.getConvertedValue;     		// PAR #31155
	endif;																					//Bug 38457
	
	if self.myTI &lt;&gt; null then		// PAR 23836
		intFaceObj.weightDeclared 	:= self.myTI.weightDeclared;
	else
		intFaceObj.weightDeclared 	:= intFaceObj.weightTotal;
	endif;
	
	if self.isPreNoteForm then
		if self.chkIsWeightCertified.visible then
			intFaceObj.isWeightCertified:=self.chkIsWeightCertified.getBoolean();
		//	intFaceObj.weightCertifiedReference:= self.txtWeightCertifiedBy.getString();
		//	intFaceObj.weightCertifiedName:= self.txtWeightAuthorised.getString();
			
		//TFS 6735 jlgns1 31/08/2017 
		//		//23 Aug 2017	NDL	TFS 5803
		//		weighAuthority := self.cmbWeightPerson.getObject.CM_WeighAuthority;
		//		if weighAuthority &lt;&gt; null then
		//			intFaceObj.weightCertifiedName := weighAuthority.certifiedName;  // company
		//			intFaceObj.weightCertifiedReference := weighAuthority.authorisedName;	// person
		//		endif;
			intFaceObj.weightCertifiedName :=	self.txtWeightAuthorised.getString();  		// company	//TFS 6735 jlgns1 31/08/2017 
			intFaceObj.weightCertifiedReference := self.txtWeightCertifiedBy.getString();	// person	//TFS 6735 jlgns1 31/08/2017 
				
		endif;
	endif;
	
	
	//17 Apr 2013	NDl	Par 31393
	if self.myProxyTrackedItem &lt;&gt; null then
		intFaceObj.myVehicleBookingTimeslot := self.myProxyTrackedItem.myVehicleBookingTimeslot;
	endif;
	
	if self.isAttachmentForm then
		//intFaceObj.weightTotal	:= self.txtTotalWeight.getInteger;
		//intFaceObj.weightTotal	:= self.txtTotalWeight.getInteger;  				// PAR #31155
		//intFaceObj.weightTotal		:= self.tblTotalWeight.getConvertedValue;		// PAR #31155 //24.1.2018 cnwma1 BUG #36720
		if cargoType &lt;&gt; null and cargoType.isBulkByVolume then
			if not self.cmbSubCargo.isHidden then
				product := self.cmbSubCargo.getObject.CM_Product;
			else
				product := cargoType.mySystemProductType;
			endif;
			if product &lt;&gt; null and product.myDensityDec.value &lt;&gt; null then							// ### TFS 52193 22Nov2021 NAVPW1
					weight := self.tblTotalVolume.getConvertedValue * product.myDensityDec.value;	// ### TFS 52193 22Nov2021 NAVPW1
			endif;
			intFaceObj.weightTotal 		:= weight;
		else
			intFaceObj.weightTotal			:= self.tblTotalWeight.getConvertedValue; 
		endif;
	endif;
	intFaceObj.yardLocationTxt		:= self.txtLocation.getString;
	intFaceObj.stowageLocation 		:= intFaceObj.yardLocationTxt;

	if app.isSubTerminalsOn(self.myTerminal) then
		intFaceObj.mySubTerminal	:= self.cmbSubTerminal.getObject.CM_SubTerminal;
	endif;
	
	if cargoType &lt;&gt; null then
		if cargoType.isTrailer then
			tILCType := self.cmbTrailerType.getObject.CM_TILCType;
			if tILCType &lt;&gt; null then	// 06 Jul 2012	NDL	Par 29870
				intFaceObj.trailerType := tILCType.code;
			endif;
		elseif cargoType.id = TI_CargoType_Generator then
			intFaceObj.setMyGeneratorType(self.cmbGeneratorType.getObject.CM_GeneratorType);
		endif;
	endif;
	
	intFaceObj.hasAttachments		:= not self.allAttachments.isEmpty;
	
	//+cnwml2 MSL CCMS 1019
	expArrivalTSLocal.cnEcSetDateAndTime(self.dateExpArrival.getDate,self.timeExpArrival.getTime);
	expArrivalTSSystem := self.localToSystemTime(expArrivalTSLocal);
	intFaceObj.CMIF_PreNote.expectedArrivalDate := expArrivalTSSystem.date();
	intFaceObj.CMIF_PreNote.expectedArrivalTime := expArrivalTSSystem.time();

	// ensure that masterItem is set correctly for all attachments
	// PAR #21969 If editing an existing tracked item, don't need to do this, only necessary for CMIF_Prenote objects
	if intFaceObj.hasAttachments then
		foreach obj in self.allAttachments where CMIF_TIObject.hasInstance(obj) do
			tmpAttach := obj.CMIF_TIObject;
			tmpAttach.setMasterItem(intFaceObj);
			if CMIF_PreNote.hasInstance(tmpAttach) then												// PAR #34483
				tmpAttach.CMIF_PreNote.stowageLocation := intFaceObj.CMIF_PreNote.stowageLocation;	// PAR #34483
				tmpAttach.CMIF_PreNote.yardLocationTxt := intFaceObj.CMIF_PreNote.yardLocationTxt;	// PAR #34483
			endif;																					// PAR #34483
		endforeach;
	else
		//self.allAttachments.purge;
		self.purgeTransientAttachments();	//10 Oct 2012	NDL	Par 30503
	endif;
	// general cargo fields
	//intFaceObj.numberOfItems		:= self.txtNumItems.getInteger;
	self.setObjectFromNumItemsValue( intFaceObj );	//04 Mar 2014	NDL	Par 33596
	
	//intFaceObj.volumeTotal		:= self.txtTotalVolume.getDecimal;					// PAR #31155
	intFaceObj.volumeTotal			:= self.tblTotalVolume.getConvertedValue;			// PAR #31155
	
	// Voyage Details
	if self.cmbImexStatus.getObject &lt;&gt; null then
		intFaceObj.imExStatus 		:= self.cmbImexStatus.getObject.CM_IMEXStatus;
	endif;
	if self.cmbVoyageCode.listObject &lt;&gt; null then
		intFaceObj.voyageCode		:= self.cmbVoyageCode.listObject.CM_Voyage.code;
	else	//30 Jul 2013	NDL	Par 32102
		tmpVoy := self.myAssistant.getVoyageFromCombo(self.cmbVoyageCode.text);
		// PAR 33780 testing direct deliveries for PAR 33644 notice that could not create new cargo on NWNP
		if tmpVoy = null then
			tmpVoy := self.myAssistant.getVoyageFromCombo(self.txtLocation.getString());
		endif;
		if tmpVoy = null then		//03AUG2025 navnk30 JIRA-35571
			tmpVoy := app.myPassport.myTerminal.getConfig(DefVoyage).CM_Voyage;
		endif;
		if tmpVoy &lt;&gt; null then
			intFaceObj.voyageCode := tmpVoy.code;
		endif;
	endif;
	if self.cmbOperatorCode.listObject &lt;&gt; null then
		intFaceObj.operatorCode		:= self.cmbOperatorCode.listObject.CM_Operator.code;
	endif;
	if self.cmbDestPort.listObject &lt;&gt; null then
		intFaceObj.destinationPort	:= self.cmbDestPort.listObject.CM_Port.code;
	endif;
	if self.cmbDischargePort.listObject &lt;&gt; null then
		intFaceObj.dischargePort	:= self.cmbDischargePort.listObject.CM_Port.code;
	endif;
	if self.cmbTranshipPort.listObject &lt;&gt; null then
		intFaceObj.myTranshipToPort	:= self.cmbTranshipPort.listObject.CM_Port;
	endif;		
	assistant.saveListTablePorts(lstOptionalPorts, intFaceObj.allDischargePorts);
	if self.cmbConsignor.getObject &lt;&gt; null then
		intFaceObj.consignorCode	:= self.cmbConsignor.getObject.CM_ConsigneeConsignor.code;
	endif;
	if self.cmbConsignee.getObject &lt;&gt; null then
		intFaceObj.consigneeCode	:= self.cmbConsignee.getObject.CM_ConsigneeConsignor.code;
	endif;
	if self.cmbCarrier.getObject &lt;&gt; null then
		intFaceObj.carrier			:= self.cmbCarrier.getObject.CM_Carrier.code;
	endif;
	if self.cmbStevedore.getObject &lt;&gt; null then                                         //02.10.2020 cnwma1 TFS #50112
		intFaceObj.stevedoreCode	:= self.cmbStevedore.getObject.CM_Stevedore.code;
	endif;
	
	// General Cargo Dimension Details
	intFaceObj.length				:= self.tblLength.getConvertedValue;				// PAR #31155
	intFaceObj.width				:= self.tblWidth.getConvertedValue;					// PAR #31155
	intFaceObj.height				:= self.tblHeight.getConvertedValue;				// PAR #31155
	intFaceObj.lengthString			:= self.txtLengthText.getString;
	intFaceObj.widthString			:= self.txtWidthText.getString;
	intFaceObj.heightString			:= self.txtHeightText.getString;
	intFaceObj.diameter				:= self.tblDiameter.getConvertedValue;
	intFaceObj.grade				:= self.txtGrade.getString;
	intFaceObj.grammage				:= self.txtGrammage.getString.Decimal;
	intFaceObj.rollingLength		:= self.tblRollingLength.getConvertedValue;
	self.setObjectFromQuantityValue( intFaceObj );	//04 Mar 2014	NDL	Par 33596

	if not self.tblWeight.isHidden then														// PAR #31155	
		intFaceObj.weight			:= self.tblWeight.getConvertedValue;				// PAR #31155
	endif;

	if not self.tblVolume.isHidden then														// PAR #31155		
		intFaceObj.volume			:= self.tblVolume.getConvertedValue;				// PAR #31155
	endif;
	intFaceObj.density				:= self.tblDensity.getConvertedValue;		// PAR #31155 // ### TFS 52193 22Nov2021 NAVPW1
	// PAR #23190 start
	if not self.cmbDimType.isHidden then
		dimType						:= self.cmbDimType.getObject.CM_ProductAttributeCode;
		if dimType &lt;&gt; null then
			intFaceObj.type			:= dimType.code;
		endif;
	else
		intFaceObj.type				:= self.txtDimType.getString;
	endif;
	// PAR #23190 end
	
	// Cargo Details
	intFaceObj.hasRadio				:= self.chkRadio.getBoolean;
	intFaceObj.selfPropelled		:= self.chkSelfPropelled.getBoolean;
	intFaceObj.description			:= self.txtDescription.getString;
	
	// 20 Sep 2010	NDL Par 25608
	intFaceObj.allSeals.clear();
	if cargoType &lt;&gt; null then
		foreach obj in self.allClonedControls do
			control := obj.Control;
			if control.isKindOf(CMUI_FieldTextBox) then
				sealValue := control.CMUI_FieldTextBox.getString;
				sealTypeName := control.name;
				sealType := app.myRoot.getSealType( sealTypeName );
				if sealType &lt;&gt; null then
					if not sealType.notAvailableForEntry then
						if sealType.allCargoTypes.includes( cargoType ) then
							intFaceObj.setSealNumberValueDirect( sealType,  sealValue, null );
						endif;
					endif;
				endif;
			endif;
		endforeach;
	endif;
	
	intFaceObj.operatorExportReleaseNumber	:= self.txtOpExRelNbr.getString;
	intFaceObj.customExportEntryNumber		:= self.txtCustomsExDel.getString;
	if self.cmbMTGrade.getObject &lt;&gt; null then
		intFaceObj.availabilityGrade:= self.cmbMTGrade.getObject.CM_MTGrade.code;
	endif;
	intFaceObj.offsiteCleaned		:= self.chkCleaned.getBoolean;
	intFaceObj.offsitePreTrip		:= self.chkPreTrip.getBoolean;
	
	intFaceObj.allTIHazards.clear;									// PAR #21138 avoid 1309 duplicates errors
	// 17/02/2011 cnwar2 #27051 - handle invalid hazards
	//self.lstHazardList.allSelectedObjects.copy(intFaceObj.allTIHazards);
	on Exception do app.handleDeletedObject(exception, hazard, invalidHazard);
	foreach hazard in self.lstHazardList.allSelectedObjects do
		invalidHazard := false;
		hazard.edition();
		if invalidHazard then
			continue;
		endif;
		if hazard.cnEcIsPersistent then										// PAR #36421
			haz := hazard.CM_TIHazard;										// PAR #36421
			create newHaz transient;										// PAR #36421
			//newHaz.setProxy(haz.code, haz.description, haz.allUNDGCodes.asCSV(false), null, haz.limitedQuantity, haz.packingGroup);	// TFS 2842
			newHaz.setProxy(	haz.code, 							// TFS 2842
								haz.description, 					// TFS 2842
								haz.allUNDGCodes.asCSV(false), 		// TFS 2842
								null, 								// TFS 2842
								haz.limitedQuantity, 				// TFS 2842
								haz.packingGroup,					// TFS 2842
								haz.flashpointTemperature,			// TFS 2842
								haz.isMarinePollutant,				// TFS 2842
								haz.acidsBases	);					// TFS 2842
		else																// PAR #36421
			newHaz := hazard.CM_TIHazard;									// PAR #36421
		endif;																// PAR #36421
		//intFaceObj.allTIHazards.add(hazard.CM_Hazard);					// PAR #36421
		intFaceObj.allTIHazards.addNoDuplicates(newHaz, false);				// PAR #36421
	endforeach;
	
	if self.cmbSpecialStow.getObject &lt;&gt; null then
		intFaceObj.specialStow		:= self.cmbSpecialStow.getObject.CM_SpecialStow.code;
	endif;
	
	// Start 20 may 2022 navgm20 TFS 53204
	if self.cmbShippingLine.getObject &lt;&gt; null then
		intFaceObj.shippingLineCode := self.cmbShippingLine.getObject.CM_ShippingLine.code;
	endif;
	// End 20 may 2022 navgm20 TFS 53204
	
	//Start 16.08.2022 navak20 TFS 54441
	if self.cmbCtryOfOrigin.getObject &lt;&gt; null then
		intFaceObj.countryOfOriginCode := self.cmbCtryOfOrigin.getObject.CM_Country.code;
	endif;
	//End 16.08.2022 navak20 TFS 54441
	
	//Start//21.02.2023 navtnr20 TFS CR 55648 Task 55663
	obj := self.cmbInvContractID.getObject();
	if obj &lt;&gt; null then
		intFaceObj.setContractId(obj.CM_InvoiceContract.contractId); 
	endif;
	//end //21.02.2023 navtnr20 TFS CR 55648 Task 55663
	intFaceObj.allSpecialLifts.clear;									// PAR #21138 avoid 1309 duplicates errors
	self.lstSpecialLift.allSelectedObjects.copy(intFaceObj.allSpecialLifts);
	intFaceObj.remarks				:= self.txtRemarks.getString;

	intFaceObj.isOverDimension		:= self.chkIsOverDim.value;					//+cnwml2 PAR25277
	intFaceObj.overLengthFront		:= self.txtDimLenFront.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
	intFaceObj.overLengthRear		:= self.txtDimLenRear.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
	intFaceObj.overWidthLeft		:= self.txtDimWidthLeft.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
	intFaceObj.overWidthRight		:= self.txtDimWidthRight.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
	intFaceObj.overHeight			:= self.txtDimOverHeight.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
	intFaceObj.coolingType			:= app.coolingTypeStringToENum(self.cmbCoolingType.getString);
	intFaceObj.voltageType			:= app.voltageTypeStringToENum(self.cmbVoltageType.getString);
	// General Cargo stuff
	intFaceObj.alternativeId		:= self.txtAlternativeId.getString;
	intFaceObj.mark					:= self.txtMark.getString;
	intFaceObj.markNumber			:= self.txtMarkNumber.getString;
	intFaceObj.colour				:= self.myAssistant.getColourString(self.lstColourList, self.txtColourList);// PAR #32123
	
	intFaceObj.clientRef			:= self.txtClientRef.getString; // cnwrd1 par 23337 20.5.2010
	
	intFaceObj.purchaseOrder		:= self.txtPurchaseOrder.getString();		// PAR #33193 
	intFaceObj.serviceOrder			:= self.txtServiceOrder.getString();		// PAR #33193 
	intFaceObj.shippingReference	:= self.txtShippingRef.getString();       //25/11/2015 cnwma1 PAR #36943
	// PAR #23442 Timber details
	intFaceObj.preSlung				:= self.chkPreSlung.getBoolean;
	intFaceObj.wet					:= self.chkWet.getBoolean;
	// Reefer Details
	//if self.txtTimeOffPower &lt;&gt; null then							//cnwas3 par 26199	// PAR #33278
	if self.txtTimeOffPower.getString &lt;&gt; null then										// PAR #33278
		intFaceObj.allowableTimeOffPower:= self.txtTimeOffPower.getString.Decimal;		//PAR #31688
	else
		intFaceObj.allowableTimeOffPower := NULL_ALLOWABLE_TIME_OFF_POWER;
	endif;
	operator := self.cmbOperatorCode.listObject.CM_Operator;
	self.doDeriveTemperatures(operator, carriageTempC, carriageTempF, packTempC, packTempF);
	intFaceObj.carriageTempF 		:= carriageTempF;
	intFaceObj.carriageTempC 		:= carriageTempC;
	intFaceObj.packTempF 			:= packTempF;
	intFaceObj.packTempC 			:= packTempC;
	if self.txtCO2Percent.getString.Integer = 0 then
		intFaceObj.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	else
		intFaceObj.setCarbonDioxide( self.txtCO2Percent.getString.asDecimalJMT );
	endif;
	if self.txtOxygenPercent.getString.Integer = 0 then
		intFaceObj.setOxygen( NULL_OXYGEN );
	else
		intFaceObj.setOxygen( self.txtOxygenPercent.getString.asDecimalJMT );
	endif;
	intFaceObj.curtainsIn 			:= self.chkCurtainsIn.getBoolean;
	if self.txtHumidity.getString.Decimal = 0 then
		intFaceObj.setHumidity( NULL_HUMIDITY );
	else
		intFaceObj.setHumidity( self.txtHumidity.getString.asDecimalJMT );
	endif;
	//if self.txtVentilation.getString.asCastDecimalJMT() = 0 then						// PAR #31155
	if self.tblVentilation.getConvertedValue = 0 then									// PAR #31155
		intFaceObj.ventilation 		:= NULL_VENTILATION;
	else
		intFaceObj.ventilation 		:= self.tblVentilation.getConvertedValue;			// PAR #31155
	endif;
	
	if self.chkExternallyMonitor.visible then
		intFaceObj.isExternallyMonitored := self.chkExternallyMonitor.getBoolean; //epr TFS 3581 2/3/17
	endif;
	
	packTSLocal.cnEcSetDateAndTime(self.txtPackDate.getDate,self.txtPackTime.getTime);	//TFS 2755
	packTSSystem := self.localToSystemTime(packTSLocal);								//TFS 2755	
	intFaceObj.packDate				:= packTSSystem.date();								//TFS 2755
	
	//15 Aug 2011	NDL	Par 27898
	if intFaceObj.commodity &lt;&gt; null and self.cmbCommodity.getObject.CM_Commodity.hasTemp then
		// has a commodity that requires pack temperature
		if intFaceObj.packDate.isValid and self.txtPackTime.CMUI_FieldTimeBox.invalidOrNoTimeEntered then
			// a date had been entered, but no valid time yet.
			app.raiseCMException2(ERR_COMMODITY_REQ_PACKINFO, intFaceObj.commodity, "'" &amp; self.txtPackTime.CMUI_FieldTimeBox.myLabel.caption &amp; "'", ETRow_PackTime, null);
		endif;
	endif;
	
	intFaceObj.packTime 			:= packTSSystem.time();								//TFS 2755
	expiryTSLocal.cnEcSetDateAndTime(self.txtExpiryDate.getDate,TimeEndOfDay);			//TFS 2755
	intFaceObj.expiryDate			:= expiryTSLocal.date();	// PAR #36094			//TFS 2755
	
	// Additional Details
	intFaceObj.doSetStops 			:= true;
	intFaceObj.allStops.clear();
	foreach obj in self.lstAllStops.allSelectedObjects do
		intFaceObj.allStops.add(obj.CM_StopsTable.id);
	endforeach;
	
	//14 Mar 2013	NDL	Par 31284 - Also need to include any stops already applied that are not shown
	//                              on the form because we are not allowed to maintain them.
	if self.myProxyTrackedItem &lt;&gt; null then
		foreach stop in self.myProxyTrackedItem.getAllStops() do
			rowIndex := 1;
			if not self.lstAllStops.findObject(stop.myStopsTable,rowIndex) then
				intFaceObj.allStops.add(stop.myStopsTable.id);
			endif;
		endforeach;
	endif;
	
	intFaceObj.doSetToDoTasks 		:= true;
	intFaceObj.allToDoTasks.clear();
	foreach obj in self.lstToDoTasks.allSelectedObjects do
		intFaceObj.allToDoTasks.add(obj.CM_ToDoTaskDesc);
	endforeach;
	if self.cmbFreightFwdr.getObject &lt;&gt; null then
		intFaceObj.freightForwarderCode	:= self.cmbFreightFwdr.getObject.CM_ConsigneeConsignor.code;
	endif;
	if self.cmbCustomsAgent.getObject &lt;&gt; null then
		intFaceObj.customsAgentCode	:= self.cmbCustomsAgent.getObject.CM_CustomsAgent.code;
	endif;
//	intFaceObj.billOfLading			:= self.txtHouseBOL.getString;	//05 May 2014	NDL	Par 34034
	intFaceObj.consignorVoyageCode	:= self.txtConsignVoy.getString;
	intFaceObj.eirNumber			:= self.txtEquipXchg.getString;
	intFaceObj.purchaseOrder		:= self.txtPurchaseOrder.getString;
	
	//epr par 34945 17/10/14 moved up from SHP_CreateNewCargoForm
	if intFaceObj.isKindOf(CMIF_OnshipCargo) then
		intFaceObj.transportMode := BR_TYPE_SHIP_STR;
		intFaceObj.receiptTransportMode := app.transModeToCode(intFaceObj.transportMode);
	
		if self.cmbLoadPortCombo.listObject &lt;&gt; null then
			intFaceObj.loadPort	:= self.cmbLoadPortCombo.listObject.CM_Port.code;
		elseif self.isAttachmentForm then												//27.09.2024 navhl20 #23125
			parentForm := self.myParentForm;
			if parentForm &lt;&gt; null then
				cmb := parentForm.CMUI_ReceiveCargoForm.cmbLoadPortCombo;
			endif;
			if cmb &lt;&gt; null and cmb.listObject &lt;&gt; null then
				intFaceObj.loadPort	:= cmb.listObject.CM_Port.code;
			endif;
		endif;
		if self.frmCoordinates.visible then 
			if self.txtX.text = null and self.txtY.text = null then
				intFaceObj.CMIF_OnshipCargo.roroX := -999;
				intFaceObj.CMIF_OnshipCargo.roroY := -999;
			else
				intFaceObj.CMIF_OnshipCargo.roroX := self.txtX.text.Decimal;
				intFaceObj.CMIF_OnshipCargo.roroY := self.txtY.text.Decimal;
			endif;
		endif;
	else
		intFaceObj.receiptTransportMode := app.transModeToCode(cmbTransportMode.getString);
		intFaceObj.transportMode 		:= self.cmbTransportMode.getString;
	endif;

	if self.cmbBusUnit.getObject &lt;&gt; null then
		intFaceObj.companyCode		:= self.cmbBusUnit.getObject.CM_Bank.code;
	endif;
	intFaceObj.wagon				:= self.txtWagon.getString.toUpper;	// 15 Feb 2010	NDL Par 22343
	intFaceObj.myWagonClass			:= self.cmbWagonClass.getObject.CM_WagonClass;	//12 May 2014	NDL	Par 33615
	
	if cmbTransportMode.getString = TI_TRANSMODE_SHIP_STR and cmbTransportMode.enabled and  self.txtLocation.getString &lt;&gt; null then
		//set stowage location.
		intFaceObj.stowageLocation := self.txtLocation.getString;
	endif;

	//+cnwml2 PAR23715 SFW CCMS1131
	intFaceObj.allSeals.clear();
	foreach obj in self.allClonedControls do
		control := obj.Control;
		if control.isKindOf(CMUI_FieldTextBox) then
			if control.CMUI_FieldTextBox.getString &lt;&gt; null then
				create newSeal transient;
				newSeal.setPreviousSeal(null);
				newSeal.setSealType(control.name);
				newSeal.allSealNums.add(control.CMUI_FieldTextBox.getString);
				newSeal.setMyTrackedItem(self.myTI);
				intFaceObj.allSeals.add(newSeal);
			endif;
		endif;
	endforeach;
	
	intFaceObj.directDelivery		:= self.chkDirDel.getBoolean;//28 Jan 2013	NDL	CCMS 1299			Par 31102		// TFS 52293 reinstated
	//intFaceObj.directDelivery		:= self.chkDirDel.getBoolean or self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean;	// TFS 51935
	
	// PAR #31018 CCMS POL 2223 On Power During Transit fields
	intFaceObj.onPowerDuringTransit		:= self.chkTransitPower.getBoolean;				// PAR #31018
	transitOnTSLocal.cnEcSetDateAndTime(self.txtTransitOnDate.getDate,self.txtTransitOnTime.getTime);//TFS 2755
	transitOnTSSystem := self.localToSystemTime(transitOnTSLocal);									//TFS 2755
	intFaceObj.transitOnPowerDate		:= transitOnTSSystem.date();				// PAR #31018	//TFS 2755
	intFaceObj.transitOnPowerTime		:= transitOnTSSystem.time();				// PAR #31018	//TFS 2755
	intFaceObj.transitOnPowerRemarks	:= self.txtTransitRemark.getString;				// PAR #31018
	intFaceObj.remainingTimeOffPower	:= NULL_ALLOWABLE_TIME_OFF_POWER;				// PAR #31018
	// calculate remaining time off power												// PAR #31018
	// if I was on power during transit, remaining time off power is 					// PAR #31018
	// 		transit on power date/time - pack date/time									// PAR #31018
	// If I wasn't on power during transit, remaining time off power is					// PAR #31018
	// 		now date/time - pack date/time												// PAR #31018
	if intFaceObj.packDate &lt;&gt; null then													// PAR #31018
		packed.setDate(intFaceObj.packDate);											// PAR #31018
		packed.setTime(intFaceObj.packTime);											// PAR #31018
		if packed &gt; app.actualTimeServer then											// PAR #31411
			intFaceObj.remainingTimeOffPower := intFaceObj.allowableTimeOffPower;		// PAR #31411
		else																			// PAR #31411
			if intFaceObj.onPowerDuringTransit then										// PAR #31018
				transit.setDate(intFaceObj.transitOnPowerDate);							// PAR #31018
				transit.setTime(intFaceObj.transitOnPowerTime);							// PAR #31018
				totalMinutes := packed.minutesDiff(transit).Integer;					// PAR #31018
			else																		// PAR #31018
				totalMinutes := packed.minutesDiff(app.actualTimeServer).Integer;		// PAR #31018
			endif;																		// PAR #31018
			//totalMinutes := ((intFaceObj.allowableTimeOffPower * 60) - totalMinutes).Integer;// PAR #31018				// PAR #31688
			allowable := intFaceObj.allowableTimeOffPower.Integer * 60;														// PAR #31688
			allowable := allowable + ((intFaceObj.allowableTimeOffPower - intFaceObj.allowableTimeOffPower.Integer)*100);	// PAR #31688
			totalMinutes := (allowable - totalMinutes).Integer;																// PAR #31688
			hours := (totalMinutes / 60).Integer;										// PAR #31018
			minutes := (totalMinutes mod 60) / 100;										// PAR #31018
			if (hours + minutes) &gt; 0 then												// PAR #31018
				intFaceObj.remainingTimeOffPower := hours + minutes;					// PAR #31018
			else																		// PAR #31018
				intFaceObj.remainingTimeOffPower := null;								// PAR #31018
			endif;																		// PAR #31018
		endif;																			// PAR #31411
	endif;																				// PAR #31018
	
	// PAR #32215 New Car attributes													// PAR #32215
	if self.cmbVehicleMake.getObject &lt;&gt; null then										// PAR #32215
		intFaceObj.make			:= self.cmbVehicleMake.getObject.CM_VehicleMake.make;	// PAR #32215
	endif;																				// PAR #32215
	if self.cmbVehicleModel.getObject &lt;&gt; null then										// PAR #32215
		intFaceObj.model		:= self.cmbVehicleModel.getObject.CM_VehicleModel.model;// PAR #32215
	endif;																				// PAR #32215
	if self.cmbVehicleType.getObject &lt;&gt; null then										// PAR #32215
		intFaceObj.carType 		:= self.cmbVehicleType.getObject.CM_VehicleType.type;	// PAR #32215
	endif;																				// PAR #32215
	intFaceObj.year 			:= self.txtYear.getInteger;								// PAR #32215
	intFaceObj.trackingNumber1 	:= self.txtTracking1.getString;							// PAR #32215
	intFaceObj.trackingNumber2 	:= self.txtTracking2.getString;							// PAR #32215
	intFaceObj.docsReceived.setDate(self.txtDocsReceived.getDate);						// PAR #32215
	intFaceObj.docsSent.setDate(self.txtDocsSent.getDate);								// PAR #32215
	intFaceObj.docsCleared.setDate(self.txtDocsCleared.getDate);						// PAR #32215
	intFaceObj.docsReturned.setDate(self.txtDocsReturned.getDate);						// PAR #32215
	intFaceObj.nbrDoors 		:= self.txtDoors.getInteger;							// PAR #32215
	intFaceObj.isNewVehicle		:= self.chkNew.getBoolean;								// PAR #32215

	//03 May 2018	NDL	TFS 37795
	if self.myProxyTrackedItem &lt;&gt; null then
		intFaceObj.remarksAdditional1 := self.myProxyTrackedItem.remarksAdditional1;
		intFaceObj.remarksAdditional2 := self.myProxyTrackedItem.remarksAdditional2;
	endif;
	if self.cmbHSCode.getObject &lt;&gt; null then
		intFaceObj.hsCode		:= self.cmbHSCode.getObject.CM_HarmonizedSystem.id; //jlier1 TFS 55584 20/12/22
	endif;
	
	intFaceObj.attributeisOverlanded := self.chkOverlanded.getBoolean();  //06/04/2023	navkc1	CR# 56431 Task 56440
	
	// ### TFS 57812 (58439) 15Jun2023 NAVPW1
	intFaceObj.itemised := self.chkItemised.getBoolean();
	intFaceObj.secondaryBarcodeId := self.txtSecondaryBarcodeId.getString();
	intFaceObj.mySortingMethod := self.cmbSortingMethod.getObject.CM_SortingMethod;
	if self.cmbSortingMethod.getObject &lt;&gt; null then
		intFaceObj.mySortingMethod := self.cmbSortingMethod.getObject.CM_SortingMethod;
	endif;
	// ### TFS 57812 (58439) 15Jun2023 NAVPW1
	
	if self.cmbPortOfOriginCombo.listObject &lt;&gt; null then
		intFaceObj.portOfOrigin := self.cmbPortOfOriginCombo.listObject.CM_Port.code;
	endif;	
	
	if self.cmbCustPriority.getObject &lt;&gt; null then
		intFaceObj.myCustomerPriority := self.cmbCustPriority.getObject().CM_CustomerPriority;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setQuantityCaptionAndVisible" id="2761485b-dbd8-4c50-8da0-903049f7e386">
        <source>setQuantityCaptionAndVisible( _methName : String; _obj : Object );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2014	cnwndl1	Initial creation	Par 33596

*/

vars

	cargoBOLType : CM_CargoBOLType;
	product : CM_Product;
	cargoType : CM_CargoType;
	default : Boolean;

begin

	
	////////////updating screen fields
	if _methName = CMUI_ReceiveCargoForm::onCargoTypeChange.name then
		cargoBOLType := _obj.CM_CargoBOLType;
		self.txtQuantity.isHidden := true;
		if cargoBOLType.isCargoType() and 																					
		   ((cargoBOLType.CM_CargoType.isBreakBulk() and cargoBOLType.id &lt;&gt; TI_CargoType_Container) or 					
		   cargoBOLType.CM_CargoType.productType = ProductType_Vehicle) then 
		   if cargoBOLType.isSystemCargoBOLType then
				self.txtQuantity.isHidden := false;
		   else
			   product := cargoBOLType.CM_CargoType.mySystemProductType;
			   if product &lt;&gt; null then
					if product.getProdAttrFromName(ETRow_MyQuantity).isViewable then
						self.txtQuantity.isHidden := false;
					endif;	   
				endif;
			endif;		
		endif;
		
	elseif _methName = CMUI_ReceiveCargoForm::doFilterProductAttributes.name then
		default := self.updateMode = self.Mode_Add and self.myBookingRefItem = null and self.myTI = null;
		product := _obj.CM_Product;
		cargoType := product.myCargoType;
		if cargoType = null then
			cargoType := self.cmbType.getObject().CM_CargoType;
		endif;
		if product.myQuantity.getIsViewable() and cargoType.allAttributesOnProduct.includes(product.myQuantity.name) then	// PAR #23190
			self.txtQuantity.isHidden := false;
			self.txtQuantity.setMyCaption (product.myQuantity.displayName);	// par 22775		
			if default then 
				self.txtQuantity.setValue(product.myQuantity.getDisplayValueString);
			endif;
		else
			self.txtQuantity.isHidden := true;
		endif;
		
	elseif _methName = CMUI_ReceiveCargoForm::hideSelectedControls.name then
		cargoType := _obj.CM_CargoType;
		if cargoType.productType.isOneOf(ProductType_Trailer, ProductType_Vehicle) or
		   cargoType.id = TI_CargoType_Generator or (cargoType.isSystemCargoBOLType and not cargoType.id = TI_CargoType_BreakBulk) then //epr par 36625 17/7/15
			self.txtQuantity.isHidden := true;
		else
			self.txtQuantity.isHidden := false;
		endif;
	
		
	endif;

epilog

end;</source>
        <Parameter name="_methName" type="String"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setQuantityValueFormObject" id="b90925a4-aa3f-49e7-b5b4-dcfb0a26d97c">
        <source>setQuantityValueFormObject( _obj : Object ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2014	cnwndl1	Initial creation	Par 33596

*/

vars

begin

	if _obj.isKindOf(CMIF_PreNote) then
		self.txtQuantity.setValue(_obj.CMIF_PreNote.quantity.asStringJMT);
	elseif _obj.isKindOf(CMGTE_ReceivalByType) then
		self.txtQuantity.setValue(_obj.CMGTE_ReceivalByType.quantity.asStringJMT);
	elseif _obj.isKindOf(CM_BookingRefItem) then
		self.txtQuantity.setValue(_obj.CM_BookingRefItem.productQuantity.asStringJMT);
	elseif _obj.isKindOf(CM_TrackedItem) then
		self.txtQuantity.setValue(_obj.CM_TrackedItem.quantity.asStringJMT);
	elseif _obj.isKindOf(CMGTE_Receival) then
		self.txtQuantity.setValue(_obj.CMGTE_Receival.quantity.asStringJMT);
	endif;
		

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setSealDetailControls" id="56b24d0e-3142-484c-a920-46077aec0564">
        <source>setSealDetailControls( _allSeals : CM_SealTIBySealTypeDict ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 September 2010	cnwndl1	Initial creation	Par 25608

*/

vars

	sealTI : CM_SealTI;
	obj : Object;
	control : Control;
	str : String;
	textStr : String;
	
begin

	self.doWindowEvents(0);// Without this crappy line, the text is not shown.
	
	foreach sealTI in _allSeals do
		textStr := null;
		foreach obj in self.allClonedControls do
			control := obj.Control;
			if control.name = sealTI.sealType then
				if control.isKindOf(CMUI_FieldTextBox) then
					foreach str in sealTI.allSealNums do
						if textStr = null then
							textStr := str;
						else
							textStr := textStr &amp; "," &amp; str;
						endif;
					endforeach;
					control.CMUI_FieldTextBox.setValue(textStr);
				endif;
			endif;
		endforeach;
	endforeach;
		
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_allSeals" type="CM_SealTIBySealTypeDict"/>
    </JadeMethod>
    <JadeMethod name="setSealDetails" id="5e651a5e-c153-423c-9a46-3aeac79b560a">
        <updating/>
        <source>setSealDetails(_item : Object) updating, protected;
//09 September 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131

//20 Sep 2010	NDL	Par 25608 - split off population to "setSealDetailControls" and added ability to deal with
//								CMIF_Receival and CMGTE_Entity objects
//30/01/2015  cnwma1 PAR #35599 System Error 4 in CMUI_ReceiveCargoForm::setSealDetailControls
vars
	invalidObj : Boolean;
	edition    : Integer;
begin
	
	on Exception do app.handleDeletedObject(exception,_item, invalidObj);    // 30/01/2015 cnwma1 PAR #35599 
	edition :=_item.edition;
	
	if invalidObj then 
		return; 
	endif;


	
	if _item.isKindOf(CM_TrackedItem) then
		
		self.setSealDetailControls( _item.CM_TrackedItem.allSeals );
		
	elseif _item.isKindOf(CM_BookingRefItem) then
	
		// no facility to capture seals against bookings.
	
	elseif _item.isKindOf(CMIF_Receival) then
	
		self.setSealDetailControls( _item.CMIF_Receival.allSeals );
	
	elseif _item.isKindOf(CMGTE_Entity) then
	
		if _item.isKindOf(CMGTE_Receival) then
			// only care about seals on receivals...
			self.setSealDetailControls( _item.CMGTE_Receival.allSeals );
			
		endif;
		
	elseif _item.isKindOf(CM_BOLDtl) then
	
		// can't list seals for this, its effectively a collection of TI's...
		
	endif;
		
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setSubCargoDetails" id="2a4479ed-9386-4065-88b7-6519f0b9042f">
        <updating/>
        <source>setSubCargoDetails(_item : Object) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/07/2009	cnwdap1	Initial creation
12/10/2009	cnwdap1	PAR #21098 correct handling of subcargo type
22/10/2009	cnwdap1	PAR #21408 ensure we have a product type code before setting it in the Type combo
16/11/2009	cnwmh5	PAR #21492 if myProduct is null then check to see if cargo types mySystemProductType
					isn't null and use this.  Change the loading of cmbDimType call a method.
17/02/2010	cnwdap1	PAR #22397 New parameter for setDimTypeDetails method
17/02/2010	cnwdap1	PAR #21624 Display dimensions with no decimals
13/04/2010	cnwdap1	PAR #23673 Remove use of cnEcStripDecimalZeros - this doesn't work with locales
04/08/2010	cnwdap1	PAR #25296 Set total volume text box for general cargo
20/02/2018	cnwer1	removed all the commented out code
19/05/2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
*/
vars
	brItem		: CM_BRefItemContainer;
	item 		: CM_TrackedItem;
	entity		: CMGTE_Receival;
	bulk		: CM_BreakBulkGeneric;
	product		: CM_Product;
begin
	if _item.isKindOf(CM_BRefItemContainer) then
		brItem := _item.CM_BRefItemContainer;
		self.tblWeight.setValueDefault(brItem.weight.asStringJMT);	//25 Oct 2013	NDL	Par 32720
		self.tblLength.setValueDefault(brItem.length.asStringJMT);	//25 Oct 2013	NDL	Par 32720
		self.tblWidth.setValueDefault(brItem.width.asStringJMT);	//25 Oct 2013	NDL	Par 32720
		self.tblHeight.setValueDefault(brItem.height.asStringJMT);	//25 Oct 2013	NDL	Par 32720	
		self.txtWidthText.setValue(brItem.widthString);
		self.txtLengthText.setValue(brItem.lengthString);
		self.txtHeightText.setValue(brItem.heightString);	
		self.setQuantityValueFormObject( brItem ); //04 Mar 2014	NDL	Par 33596
		self.tblVolume.setValueDefault(brItem.volume.asStringJMT);					// PAR #31155
		self.tblDensity.setValueDefault(brItem.density.asStringJMT);				// PAR #31155

		self.setDimTypeDetails(brItem.myCargoType, brItem.myProduct, brItem.typeString);			// 19/11/2009 cnwmh5 par21492	
	elseif _item.isKindOf(CM_TrackedItem) then	
		item := _item.CM_TrackedItem;		

		self.tblWeight.setValues(item.getDefaultTotalWeightDisplay());	//25 Oct 2013	NDL	Par 32720		
		self.tblLength.setValueDefault(item.length.asStringJMT);	//25 Oct 2013	NDL	Par 32720					
		self.tblWidth.setValueDefault(item.width.asStringJMT);	//25 Oct 2013	NDL	Par 32720
		self.tblHeight.setValueDefault(item.height.asStringJMT);	//25 Oct 2013	NDL	Par 32720			
		self.setQuantityValueFormObject( item ); //04 Mar 2014	NDL	Par 33596
		self.tblVolume.setValueDefault(item.volume.asStringJMT);			// PAR #31155
		self.tblDensity.setValueDefault(item.density.asStringJMT);					// PAR #31155
		
		if item.isKindOf(CM_BreakBulkGeneric) then
			bulk := item.CM_BreakBulkGeneric;
			self.txtWidthText.setValue(bulk.widthString);
			self.txtLengthText.setValue(bulk.lengthString);
			self.txtHeightText.setValue(bulk.heightString);
			// jlika1 TFS 53316 --&gt;
			//self.tblDiameter.setValueDefault(bulk.diameter.asStringJMT);
			self.tblDiameter.setValueDefault(bulk.getDiameter().asStringJMT()); 			// ### TFS 54021 29June2022 NAVPW1
			//self.txtGrade.setValue(bulk.grade);
			self.txtGrade.setValue(bulk.getGrade());										// ### TFS 54021 29June2022 NAVPW1
			//self.txtGrammage.setValue(bulk.grammage.asStringJMT);
			self.txtGrammage.setValue(bulk.getGrammage());									// ### TFS 54021 29June2022 NAVPW1
			//self.tblRollingLength.setValueDefault(bulk.rollingLength.asStringJMT);
			self.tblRollingLength.setValueDefault(bulk.getRollingLength().asStringJMT());	// ### TFS 54021 29June2022 NAVPW1
			// jlika1 TFS 53316 &lt;--
			// 19/11/2009 cnwmh5 par21492 - Start
			product := bulk.myProduct;
			if product = null then
				if bulk.myCargoType &lt;&gt; null and bulk.myCargoType.mySystemProductType &lt;&gt; null then
					product := bulk.myCargoType.mySystemProductType;
				endif;
			endif;
			self.setDimTypeDetails(bulk.myCargoType, product, bulk.type);
			// 19/11/2009 cnwmh5 par21492 - End		
		endif;
		
	elseif _item.isKindOf(CMGTE_Receival) then	
		entity := _item.CMGTE_Receival;
		self.tblWeight.setValueDefault(entity.weight.asStringJMT);					// PAR #31155
		self.tblLength.setValueDefault(entity.length.asStringJMT);	//25 Oct 2013	NDL	Par 32720
		self.tblWidth.setValueDefault(entity.width.asStringJMT);	//25 Oct 2013	NDL	Par 32720
		self.tblHeight.setValueDefault(entity.height.asStringJMT);	//25 Oct 2013	NDL	Par 32720	
		self.txtWidthText.setValue(entity.widthString);
		self.txtLengthText.setValue(entity.lengthString);
		self.txtHeightText.setValue(entity.heightString);
		self.setQuantityValueFormObject( entity ); //04 Mar 2014	NDL	Par 33596
		self.tblVolume.setValueDefault(entity.getMyVolume.asStringJMT);				// PAR #31155
		self.tblDensity.setValueDefault(entity.density.asStringJMT);				// PAR #31155		
		// jlika1 TFS 53316 --&gt;
		self.tblDiameter.setValueDefault(entity.diameter.asStringJMT);
		self.txtGrade.setValue(entity.grade);
		self.txtGrammage.setValue(entity.grammage.asStringJMT);
		self.tblRollingLength.setValueDefault(entity.rollingLength.asStringJMT);
		// jlika1 TFS 53316 &lt;--
		self.setDimTypeDetails(app.myRoot.allCargoTypesById[entity.cargoType], entity.myProduct, entity.type);	// 19/11/2009 cnwmh5 par21492
		
		// ### TFS 57812 (58439) 15Jun2023 NAVPW1
		self.chkItemised.setValue(entity.itemised.asStringJMT);
		self.txtSecondaryBarcodeId.setValue(entity.secondaryBarcodeId);
		self.cmbSortingMethod.getEmbeddedControl.ComboBox.listObject := entity.mySortingMethod;
		// ### TFS 57812 (58439) 15Jun2023 NAVPW1
		
	endif;
		
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_item" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setTotalVolumeFromProdAttrQty" id="810a8b9d-e7f0-42d2-b01d-48085d1ee132">
        <source>setTotalVolumeFromProdAttrQty();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2016	cnwndl1	Initial creation	TFS 2141

*/

vars

	subType : CM_Product;
	pieces : Integer;
	numIds : Integer;
	volumeM3 : Decimal [16,4];
	measureType : CM_MeasurementType;
	displayValue : String;

begin

	if self.tblTotalVolume.isHidden then
		return;
	endif;

	if self.updateMode &lt;&gt; self.Mode_Add then
		return;
	endif;
	
	subType := self.cmbSubCargo.getObject().CM_Product;
	if subType = null or not subType.autoVolumeCalculate then
		return;
	endif;
	
	measureType := subType.myVolume.myMeasurementType;
	if measureType = null then
		measureType := app.getDefaultMeasurementForType(Type_Volume);
	endif;
	
	if measureType = null then
		return;
	endif;
	
	if not self.txtNumItems.isHidden then
		numIds := self.txtNumItems.getInteger.max(1);
	endif;
	
	if not self.txtQuantity.isHidden then
		pieces := self.txtQuantity.getInteger.max(1);
	endif;

	volumeM3 := subType.calculateCargoVolume( null, numIds, pieces );

	displayValue := app.convertMeasurementForDisplay(measureType.shortName, volumeM3);
	
	self.tblTotalVolume.setValues(displayValue &amp; Space &amp; measureType.shortName );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setWagonClassOnWagonIdChg" id="b85de712-481a-48ea-b402-850e29135a84">
        <source>setWagonClassOnWagonIdChg( _fieldFrame: CMUI_FieldFrame input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2014	cnwndl1	Initial creation	Par 33615

*/

vars

	wagonId : String;
	wagonVisit : CM_Wagon;
	wagonClassId : String;
	wagonClass : CM_WagonClass;
	wagonMaster : CM_WagonMaster;

begin

	self.cmbWagonClass.enabled := self.txtWagon.enabled;

	wagonId := _fieldFrame.CMUI_FieldTextBox.getString.trimBlanks;
	if wagonId = null then
		//NO wagon entered, no need to allow entry of a wagon class
		self.cmbWagonClass.enabled := false;
		return;
	endif;
	
	wagonVisit := self.myTerminal.getCurrentWagonByID(wagonId);
	if wagonVisit &lt;&gt; null then
		//There is a current wagon on site with this id, unconditionally use its wagon class, and don't alow them to change it.
		self.cmbWagonClass.setForObject( wagonVisit.myWagonClass );
		self.cmbWagonClass.enabled := false;
		return;
	endif;
	
	wagonMaster := self.myTerminal.myRoot.allWagonMasters[wagonId];
	if wagonMaster &lt;&gt; null then
		wagonClass := wagonMaster.myWagonClass;
		if wagonClass &lt;&gt; null then
			//know about this one, it has visited previously... unconditionally use its wagon class, and don't alow them to change it.
			self.cmbWagonClass.setForObject( wagonClass );
			self.cmbWagonClass.enabled := false;
			return;
		endif;
	endif;
	
	wagonClassId := app.myRoot.getWagonClassViaHookCode( self.myTerminal, wagonId, null );
	if wagonClassId &lt;&gt; null then
		wagonClass := self.myTerminal.myRoot.allWagonClasses[wagonClassId];
		if wagonClass &lt;&gt; null then
			//Hook code says use this one... unconditionally use its wagon class, and don't alow them to change it.
			self.cmbWagonClass.setForObject( wagonClass );
			self.cmbWagonClass.enabled := false;
			return;
		endif;
	endif;
	
	wagonClassId := self.myTerminal.getConfig(DefWagonClass).String;
	if wagonClassId &lt;&gt; null then
		wagonClass := self.myTerminal.myRoot.allWagonClasses[wagonClassId];
		if wagonClass &lt;&gt; null and self.cmbWagonClass.getObject = null then
			//OK default it and let them change it if they want
			self.cmbWagonClass.setForObject( wagonClass );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setWeightByAuthPerson" id="c46c1b62-be19-4ba5-93ec-85188dd1eb49">
        <updating/>
        <source>setWeightByAuthPerson(_weightCertifiedBy : String; _authorisedPerson : String) updating;
//
