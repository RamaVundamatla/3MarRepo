    <JadeMethod name="startupSkipFile" id="67aac75a-2058-480d-80f5-f3db4931f9d8">
        <updating/>
        <source>startupSkipFile(f:File) updating;

vars
	i,j:Integer;
begin
	if f = myGH.userListFile then
		loopCount:=app.sequenceId;
	else
		loopCount:=app.profileSequenceId*4;
	endif;
	if myGH.repeatable then
		foreach i in 1 to loopCount do
			if f.endOfFile then
				f.seek(0);
			endif;
			f.readLine;
		endforeach;
	endif;
end;</source>
        <Parameter name="f" type="File"/>
    </JadeMethod>
    <JadeMethod name="startupSkipIter" id="bc0e017b-3bf3-45ec-8729-9e335f59fc24">
        <updating/>
        <source>startupSkipIter(iter:Iterator input) updating;

vars
	i,j:Integer;
	o:Object;
begin
	loopCount:=app.profileSequenceId*4;
	foreach i in 1 to loopCount do
		iter.next(o);
		if o = null then
			iter.reset;
			iter.next(o);
		endif;
	endforeach;
end;</source>
        <Parameter name="iter" type="Iterator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="stop" id="a54728fe-3621-448b-a36f-7ac4518c736f">
        <updating/>
        <source>stop() updating;

vars
	i:Integer;
	frm:Form;
begin
	if stopped then
		//assert(false, self);  // see who's calling this out of turn!
		return;
	endif;
	stopped:=true;
	app.stopped:=true;

	app.doWindowEvents(app.sequenceId*200);  // stagger stop messages
	app.logMessage("==================================");
	app.logMessage("Stopping profile, user="&amp;app.myUser.code);
	app.logMessage("==================================");
	app.myCnKarmaCntrl.handleTranStatsRequestEvent;

	if process.profiler.isProfiling then
		process.profiler.report;  // done here in case stop2 causes an exception
	endif;
	
	app.doWindowEvents(4000);  // avoid stomping on measured transactions that may be in progress
	if app.profileName &lt;&gt; "RoadOpsInquiry" then
		// demoapp.doWindowEvents(5000);  // let RoadOpsInquiry end notifications before deleting objects it is inquiring on
	endif;
	app.controlLockAcquire;
	stop2;  // profile specific stuff that needs to be done after the wait

	delete myUtlRT;
	app.doLogout(false, false);
	myEDIForm := null;
	myNavigator := null;
	foreach i in 1 to app.formsCount do
		frm:=app.forms(i);
		if frm &lt;&gt; app.mainForm and frm &lt;&gt; null and not frm.isKindOf(JtdDriverForm) then
			frm.unloadForm;
		endif;
	endforeach;

//	CMUI_SuperAppForm2

	if app.mainForm &lt;&gt; null then
		app.mainForm.unloadForm;
	endif;
	app.controlLockRelease;

	delete myGH;
	app.jtdMyGenerationHelper := null;
	app.logMessage("Stopped");

	//terminate;  // demo
end;</source>
    </JadeMethod>
    <JadeMethod name="stop2" id="26500bc2-4dd8-42e2-b0ae-383ee14647e5">
        <updating/>
        <source>stop2() updating;
//	reimplement in subclass to do other things that should be staggered
begin

end;
</source>
    </JadeMethod>
