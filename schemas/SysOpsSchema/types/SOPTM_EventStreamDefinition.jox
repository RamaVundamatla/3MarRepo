    <JadeMethod name="initAuditTypes" id="7c04bd00-241c-4052-8a76-40a25e2c86e9">
        <source>initAuditTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars
	typeStrings	: CM_StringArray;
	typeString	: String;
	auditConfig	: CM_AuditConfig;
	auditDesc	: CM_LongString; 
	
begin
	create typeStrings transient;
	
	if self.allAuditTypes.isNotEmpty then
		// audit types have already been initialised.
		return;
	endif;
	
	typeStrings.add('Created');
	typeStrings.add('Updated');
	typeStrings.add('Deleted');
	
	foreach auditConfig in app.myRoot.allAuditConfigs discreteLock do
		if auditConfig.hasDataDumpClass then
			foreach typeString in typeStrings do
				create auditDesc transient;
				auditDesc.string := auditConfig.getDescription &amp; ' ' &amp; typeString;
				self.allAuditTypes.add(auditDesc);
			endforeach;
		endif;
	endforeach;
	
epilog
	delete typeStrings;
end;</source>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="19f0b3df-6fbe-4c6c-98bc-ebcf43aedd89">
        <source>initShtMultiSelect();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
