    <JadeMethod name="setDefaults" id="c945cd84-64a2-4630-baf0-42d2a817ec07">
        <updating/>
        <source>setDefaults(_cargoType : Integer) updating;
/*
	Created on 11 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	cargoType := _cargoType;
	quantity := 1;
	
	if self.cargoType = TI_CargoType_Container then				// CCMS 1654 - slw 15/09/2008
		self.setOxygen( NULL_OXYGEN );
		self.setCarbonDioxide( NULL_CARBON_DIOXIDE );
		self.temperature := NULL_TEMPERATURE; //par19252 cnwrs1 may 2009
		self.setHumidity( NULL_HUMIDITY );
		self.ventilation := NULL_VENTILATION;
	endif;
end;</source>
        <Parameter name="_cargoType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFromBReqItem" id="b924f406-e6c1-46b7-9c25-ffdf74b1e15d">
        <updating/>
        <source>setFromBReqItem(
		 pCargoType : Integer;
		 pCommodity, pDescription : String;
		 pHazards : CM_HazardByCodeDict;
		 pHumidity : Decimal;
		 pIsoType : String;
		 pQuantity : Integer;
		 pTemperature : Real;
		 pVentilation : Decimal; //par19252 cnwrs1 may 2009
		 pWeight : Integer;
		 pMaxToRelease : Integer;
		 pVentilationUnits : Integer;
		 pCarbonDioxide : Decimal;
		 pOxygen : Decimal;
		 pCurtainsIn : Boolean;
		 pGrade  : String) updating;
//-----------------------------------------
//
// Created : by cnwaer1 28 August 2008
//-----------------------------------------
vars
	
begin
	self.cargoType			:= pCargoType;
	self.commodity 			:= pCommodity;
	self.description 		:= pDescription;
	

	self.setHazards(pHazards);

	self.setHumidity( pHumidity );
	self.isoType			:= pIsoType;
	
	self.quantity			:= pQuantity;
	self.temperature		:= pTemperature;
	self.ventilation		:= pVentilation;
	self.ventilationUnits	:= pVentilationUnits;
	
	self.req_MaxToRelease 	:= pMaxToRelease;
	self.weight				:= pWeight;
	self.setCarbonDioxide( pCarbonDioxide );
	self.setOxygen( pOxygen );
	self.curtainsIn			:= pCurtainsIn;
	self.req_Grade          := pGrade;
epilog
	
end;</source>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="pCommodity" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pHazards" type="CM_HazardByCodeDict"/>
        <Parameter name="pHumidity" type="Decimal"/>
        <Parameter name="pIsoType" type="String"/>
        <Parameter name="pQuantity" type="Integer"/>
        <Parameter name="pTemperature" type="Real"/>
        <Parameter name="pVentilation" type="Decimal"/>
        <Parameter name="pWeight" type="Integer"/>
        <Parameter name="pMaxToRelease" type="Integer"/>
        <Parameter name="pVentilationUnits" type="Integer"/>
        <Parameter name="pCarbonDioxide" type="Decimal"/>
        <Parameter name="pOxygen" type="Decimal"/>
        <Parameter name="pCurtainsIn" type="Boolean"/>
        <Parameter name="pGrade" type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromBookingRefItem" id="2d79d999-e9f1-4429-b4bd-c585e918066c">
        <updating/>
        <source>setFromBookingRefItem(pBRefItem : CM_BookingRefItem) updating;
/*
	Created on 07 February 2008
	
	by Debby Hutchison
	
	Purpose:
	
   Changed On	By			Reason
   ----------	--------	------------------------------------------------------------
   05/03/2014	cnwdap1		PAR #33193 CCMS DH 2285 Added purchase order and service order fields
*/
vars
	resDtl : CM_ReserveDetail;
	availGrade : CM_MTGrade;
	
begin
//	self.bolType			:= pBRefItem.bolType; // adm 160310 Par 22937 remove bolType
	self.cargoType			:= pBRefItem.cargoType;
	self.clean				:= pBRefItem.clean;
	self.commodity 			:= pBRefItem.commodity;
	self.cubicMetres		:= pBRefItem.cubicMetres;
	self.description 		:= pBRefItem.description;
	
	self.setHazards(pBRefItem.allTIHazards);

	self.inspected			:= pBRefItem.inspected;
	self.isoType			:= pBRefItem.isoType;
	
	self.quantity			:= pBRefItem.quantity;
	self.remarks			:= pBRefItem.remarks;
	self.weight				:= pBRefItem.weight;
	self.height				:= pBRefItem.height;
	self.length				:= pBRefItem.length;
	self.width				:= pBRefItem.width;
	self.heightString		:= pBRefItem.heightString;
	self.lengthString		:= pBRefItem.lengthString;
	self.widthString		:= pBRefItem.widthString;
	self.typeString			:= pBRefItem.typeString;
	self.density			:= pBRefItem.density;
	self.volume				:= pBRefItem.volume;
	self.productQuantity	:= pBRefItem.productQuantity;
	self.shippingMarks		:= pBRefItem.shippingMarks;
	
	self.markNumber 		:= pBRefItem.markNumber;		// MES1008 JMH 28/9/09
	self.isoTypeGroup 		:= pBRefItem.isoTypeGroup;		// MES1008 JMH 28/9/09
	self.productWeight		:= pBRefItem.productWeight;		// MES1008 JMH 28/9/09			
	self.productVolume		:= pBRefItem.productVolume;		// MES1008 JMH 28/9/09
	
	self.myGeneratorType :=  pBRefItem.myGeneratorType;//cnwrd1 par 18220 23.2.09
	
	if CM_BRefItemContainer.hasInstance(pBRefItem) then
		self.setHumidity( pBRefItem.CM_BRefItemContainer.getHumidity );
		self.temperature 	:= pBRefItem.CM_BRefItemContainer.getTemperature();
		self.ventilation 	:= pBRefItem.CM_BRefItemContainer.getVentilation();
		self.ventilationUnits:= pBRefItem.CM_BRefItemContainer.getVentilationUnits();
		self.setCarbonDioxide( pBRefItem.CM_BRefItemContainer.getCarbonDioxide );
		self.setOxygen( pBRefItem.CM_BRefItemContainer.getOxygen );
		self.curtainsIn 	:= pBRefItem.CM_BRefItemContainer.getCurtainsIn();
	endif;
	
	// set the references with inverses that will add to the appropriate collections
	self.myProduct				:=	pBRefItem.myProduct;
	self.rawEDIData 			:=	pBRefItem.rawEDIData;
	self.myRealBookingRefItem	:=	pBRefItem;
	
// cnwdad1 16102008 - PAR #18191.
	if pBRefItem.myBookingReference &lt;&gt; null then
		self.myEDIBookingRefTI	:=	pBRefItem.myBookingReference.myEDIBookingRefTI;
	endif;
	
	// set fields from Reserve Details
	resDtl := pBRefItem.myReserveDetail;
	
	if resDtl &lt;&gt; null then
		self.req_Released		:= resDtl.allTrackedItemsReleased.size();
		self.req_MaxToRelease	:= resDtl.maxToRelease;
		
		if resDtl.isKindOf(CM_ReserveSelection) then
			if resDtl.CM_ReserveSelection.allAvailabilityGrades.size() &gt; 0 then
					availGrade := app.myRoot.allAvailableAvailabilityGrades[resDtl.CM_ReserveSelection.allAvailabilityGrades.first];
					self.req_Grade := availGrade.description;
			endif;
			
			resDtl.allTrackedItems.copy(self.allReserveTIs);
		endif;
	endif;
	self.sequence := pBRefItem.sequence; //cnwrs1 CCMS 1882 25 May 2010
	
	self.purchaseOrder			:= pBRefItem.purchaseOrder;			// PAR #33193
	self.serviceOrder			:= pBRefItem.serviceOrder;			// PAR #33193
	
	self.mySpecialStow 			:= pBRefItem.mySpecialStow;	//08 Jun 2017	NDL	TFS 4454
	
end;</source>
        <Parameter name="pBRefItem" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="setFromEDI" id="15b0f472-1c4e-4d65-a112-7b3c453ebacc">
        <updating/>
        <source>setFromEDI(_ediBookingRefTI : CM_EDIBookingRefTI)updating;
/*
	Created on 04 March 2008
	
	by Debby Hutchison
	
	Purpose:
/* Changes

Date		Name	TFS#		Description
============================================================================
02 Feb 2012	cnwrs1	Par 29076 	Fix up Hazard Processing in EDI
30 May 2017	cnwdap1	TFS 4449 	STWR Mark and Mark Number field length adjustments
12 Jun 2019	jlgka1	TFS 44416 	PNL Loading Default Cargo Type Settings via EDI
08 Dec 2022 jlika1 	TFS 55586 - HS Code User Defined EDI
============================================================================*/
vars
	tmpHazards 		: ObjectArray;
	hazards 		: CM_HazardByCodeDict;
	ediBookingRefTI : CM_EDIBookingRefTI;
begin
	create tmpHazards transient;
	create hazards transient;
	ediBookingRefTI := _ediBookingRefTI;
	ediBookingRefTI.getProxyHazards(ediBookingRefTI.imCodes, tmpHazards, false);
	tmpHazards.copy(hazards);

//	self.bolType := ediBookingRefTI.bolType; // adm 160310 Par 22937 remove bolType
	self.myProduct := ediBookingRefTI.getProduct(ediBookingRefTI.operatorCode, ediBookingRefTI.product); // jlgka1 TFS 44416
	if ediBookingRefTI.cargoType = 0 and
	   ediBookingRefTI.isStockBookingRef and
	   self.myProduct &lt;&gt; null then
		self.cargoType := self.myProduct.cargoType;
	else
		self.cargoType := ediBookingRefTI.cargoType;
	endif;
	self.commodity := ediBookingRefTI.commodity;

	self.setHazards(hazards);		//CCMS 1203
	self.isoType 			:= ediBookingRefTI.isoType;
	self.quantity 			:= ediBookingRefTI.number;
	self.remarks 			:= ediBookingRefTI.remarks;
	self.temperature 		:= ediBookingRefTI.temperature;    //FD for 1749
	self.height 			:= ediBookingRefTI.height; //height
	self.length 			:= ediBookingRefTI.length; //length
	self.width 				:= ediBookingRefTI.width; //width
	self.volume 			:= ediBookingRefTI.volume; //volume
	self.weight 			:= ediBookingRefTI.weight;
	self.cubicMetres 		:= ediBookingRefTI.volume;//cubic metres
	self.myEDIBookingRefTI 	:= ediBookingRefTI;
	self.rawEDIData 		:= rawEDIData;
	//self.shippingMarks		:= ediBookingRefTI.marks; // Nelson 1637, Anca 09/05/08 	// TFS 4449
	self.shippingMarks		:= ediBookingRefTI.marks[1:150];								// TFS 4449
	self.setCarbonDioxide(  ediBookingRefTI.getCarbonDioxide ); //par18932 cnwrs1 feb 2009
	self.curtainsIn 		:= ediBookingRefTI.curtainsIn;
	self.setHumidity( ediBookingRefTI.getHumidity );
	self.setOxygen( ediBookingRefTI.getOxygen );
	self.ventilation 		:= ediBookingRefTI.vent;
	//self.quantity 			:= ediBookingRefTI.quantity;		// 03/03/2014 cnwar2 #33016
	self.productQuantity 	:= ediBookingRefTI.productQuantity;	// 03/03/2014 cnwar2 #33016
	
	// MES1008 JMH 28/9/09 Add all the book ref item fields needed
	self.density 					:= ediBookingRefTI.density;
	//self.markNumber 				:= ediBookingRefTI.markNumber;							// TFS 4449
	self.markNumber 				:= ediBookingRefTI.markNumber[1:150];					// TFS 4449
	self.isoTypeGroup 				:= ediBookingRefTI.isoTypeGroup;
	self.productVolume 				:= ediBookingRefTI.productVolume;
	self.productWeight 				:= ediBookingRefTI.productWeight;
	self.ventilationUnits			:= ediBookingRefTI.ventilationUnits;
	if ediBookingRefTI.generatorType &lt;&gt; null then
		self.myGeneratorType		:= app.myRoot.allGeneratorTypes[ediBookingRefTI.generatorType];
	endif;
	
	self.hsCode := ediBookingRefTI.hsCode;
epilog
	if tmpHazards &lt;&gt; null then
		tmpHazards.purge();
	endif;
	delete tmpHazards;
	delete hazards;
end;</source>
        <Parameter name="_ediBookingRefTI" type="CM_EDIBookingRefTI"/>
    </JadeMethod>
    <JadeMethod name="setFromEDIBooking" id="98775187-bad5-4314-8e93-afe51bfded14">
        <updating/>
        <source>setFromEDIBooking(_ediBookingItemTI : CM_EDIBookingItemTI)updating;
//
// cnwrs1 sept 2009 CCMS Messina 1008 par21718
/* Changes

Date		Name	TFS#		Description
============================================================================
02 Feb 2012	cnwrs1	Par 29076 	Fix up Hazard Processing in EDI
30 May 2017	cnwadp1	TFS 4449 	STWR Mark adn Mark Number field length adjustments
12 Jun 2019	jlgka1	TFS 44416 	PNL Loading Default Cargo Type Settings via EDI
============================================================================*/
vars
	tmpHazards 			: ObjectArray;
	hazards 			: CM_HazardByCodeDict;
	ediBookingItemTI 	: CM_EDIBookingItemTI;
	allEDITiTaskRemarks : ObjectSet;
	allEDITiHazards 	: ObjectSet;
begin
	create tmpHazards transient;
	create hazards transient;
	ediBookingItemTI := _ediBookingItemTI;
	ediBookingItemTI.getProxyHazards(ediBookingItemTI.imCodes, tmpHazards, false);
	tmpHazards.copy(hazards);

//	self.bolType := ediBookingItemTI.bolType; // adm 160310 Par 22937 remove bolType
	self.myProduct := ediBookingItemTI.getProduct(null, ediBookingItemTI.product); // jlgka1 TFS 44416
	if ediBookingItemTI.cargoType = 0 and
	   self.myProduct &lt;&gt; null then
		self.cargoType := self.myProduct.cargoType;
	else
		self.cargoType := ediBookingItemTI.cargoType;
	endif;
	self.commodity 					:= ediBookingItemTI.commodity;
	self.ediCommodityDescription 	:= ediBookingItemTI.commodityDescription; //cnwrs1 CCMS 1882 03 June 2010
	self.setHazards(hazards);
	self.isoType 					:= ediBookingItemTI.isoType;
	self.quantity 					:= ediBookingItemTI.number;
	//self.quantity 					:= ediBookingItemTI.quantity;			// 03/03/2014 cnwar2 #33016
	self.productQuantity 			:= ediBookingItemTI.productQuantity;	// 03/03/2014 cnwar2 #33016
	self.remarks 					:= ediBookingItemTI.remarks;
	self.temperature 				:= ediBookingItemTI.temperature;
	self.height 					:= ediBookingItemTI.height; //height
	self.length 					:= ediBookingItemTI.length; //length
	self.width 						:= ediBookingItemTI.width; //width
	self.volume 					:= ediBookingItemTI.volume; //volume
	self.weight 					:= ediBookingItemTI.weight;
	self.cubicMetres 				:= ediBookingItemTI.volume;//cubic metres
	self.rawEDIData 				:= rawEDIData;
	//self.shippingMarks				:= ediBookingItemTI.marks;					// TFS 4449
	self.shippingMarks				:= ediBookingItemTI.marks[1:150];				// TFS 4449
	self.setCarbonDioxide( ediBookingItemTI.getCarbonDioxide );
	self.curtainsIn 				:= ediBookingItemTI.curtainsIn;
	self.setHumidity( ediBookingItemTI.getHumidity );
	self.setOxygen( ediBookingItemTI.getOxygen );
	self.ventilation 				:= ediBookingItemTI.vent;
	self.density 					:= ediBookingItemTI.density;
	//self.markNumber 				:= ediBookingItemTI.markNumber;					// TFS 4449
	self.markNumber 				:= ediBookingItemTI.markNumber[1:150];			// TFS 4449
	self.isoTypeGroup 				:= ediBookingItemTI.isoTypeGroup;
	self.productVolume 				:= ediBookingItemTI.productVolume;
	self.productWeight 				:= ediBookingItemTI.productWeight;
	self.ventilationUnits 			:= ediBookingItemTI.ventilationUnits;
	if ediBookingItemTI.generatorType &lt;&gt; null then
		self.myGeneratorType 		:= app.myRoot.allGeneratorTypes[ediBookingItemTI.generatorType];
	endif;
	self.sequence 					:= ediBookingItemTI.sequence; //cnwrs1 CCMS 1882 25 May 2010
	
	self.setSpecialStow(null, ediBookingItemTI.specialStowage );	//08 Jun 2017	NDL	TFS 4454
	
	ediBookingItemTI.getAllStopsToApply(self.allStopTablesToAdd);	//19 Sep 2016	NDL	TFS 2650 / 2001
	create allEDITiTaskRemarks transient;	//06 Oct 2016	NDL	TFS 2001 / 2792
	ediBookingItemTI.getAllEDITaskRemarks(allEDITiTaskRemarks);	//06 Oct 2016	NDL	TFS 2001 / 2792
	self.setTaskDescsToAddFromEDI( self.cargoType, allEDITiTaskRemarks );	//06 Oct 2016	NDL	TFS 2001 / 2792
	
	create allEDITiHazards transient;	//21 Nov 2016	NDL	TFS 2843 / 2604
	ediBookingItemTI.getAllEDIItemHazards(allEDITiHazards);	//21 Nov 2016	NDL	TFS 2843 / 2604
	self.setTIHazardsFromEDI( allEDITiHazards );	//21 Nov 2016	NDL	TFS 2843 / 2604
	
	//epr TFS 1480 5/2/16 EDI Weight Verification
	self.myEDIBookingItemTI:=ediBookingItemTI;
epilog
	// cnwrl1 26/04/2010 PAR 23782 - start of coding
	// clear up possible transients.
	if tmpHazards &lt;&gt; null then
		tmpHazards.purge();
	endif;
	// cnwrl1 26/04/2010 PAR 23782 - end of coding
	
	delete tmpHazards;
	delete hazards;
	delete allEDITiTaskRemarks;
	delete allEDITiHazards;
end;
</source>
        <Parameter name="_ediBookingItemTI" type="CM_EDIBookingItemTI"/>
    </JadeMethod>
    <JadeMethod name="setHazards" id="5a46306e-8013-41f2-b3ca-eca3c08c3e16">
        <updating/>
        <source>setHazards(_hazards: CM_HazardByCodeDict) updating;
/*
	Created on 07 February 2008
	
	by Debby Hutchison
	
	Purpose:

Changed On	By			Reason
----------	--------	----------------------------------------------------
11/06/2015	cnwdap1		PAR #36421 Change of signature for CM_TIHazard::setProxy
09/11/2016	cmwdap1		TFS 2842 Hazardous Details Enhancements
*/

vars
	obj		: Object;
	tiHaz	: CM_TIHazard;
	newHaz	: CM_TIHazard;
begin
	
	self.allTIHazards.purge;	//just clear ??why they are transient they'll never get deleted if we don't purge

	if _hazards.isEmpty then
		return;
	endif;
	
	foreach obj in _hazards do
		if CM_TIHazard.hasInstance(obj) then
			tiHaz := obj.CM_TIHazard;
			create newHaz transient;
			//newHaz.setProxy(tiHaz.code, tiHaz.description, tiHaz.allUNDGCodes.asCSV(false),null,tiHaz.limitedQuantity						// PAR #36421
			//newHaz.setProxy(tiHaz.code, tiHaz.description, tiHaz.allUNDGCodes.asCSV(false),null,tiHaz.limitedQuantity,tiHaz.packingGroup);	// TFS 2842
			newHaz.setProxy(	tiHaz.code, 							// TFS 2842
								tiHaz.description, 						// TFS 2842
								tiHaz.allUNDGCodes.asCSV(false),		// TFS 2842
								null,									// TFS 2842
								tiHaz.limitedQuantity,					// TFS 2842
								tiHaz.packingGroup,						// TFS 2842
								tiHaz.flashpointTemperature,			// TFS 2842
								tiHaz.isMarinePollutant,				// TFS 2842
								tiHaz.acidsBases	);					// TFS 2842
			//newHaz.setForCreate(tiHaz, null, app.myPassport);
			self.allTIHazards.add(newHaz);
		endif;
	endforeach;
end;

</source>
        <Parameter name="_hazards" type="CM_HazardByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="setHumidity" id="159cd21c-e610-4cf3-8af3-8f3500e62006">
