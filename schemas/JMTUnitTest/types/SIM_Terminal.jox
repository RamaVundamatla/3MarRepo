    <JadeMethod name="workMachines" id="377a5370-d44e-42f0-8402-149669d5adb9">
        <updating/>
        <source>workMachines() updating;

vars
	machine: Object;
	startTime, finishTime: TimeStamp;
	elapsedTime: TimeStampInterval;
	machines: DynaDictionary;
begin
	startTime := app.actualTimeServer;
	finishTime := startTime.addMinutes(self.maxRunMinutes);

	create machines transient;
	machines.setMembership(SIM_Machine);
	machines.addExternalKey(Integer,3,false,false);
	machines.endKeys(true);
	
	foreach machine in allMachines do
		machine.SIM_Machine.logon();
		machines.putAtKey(machine.SIM_Machine.getMachinePrecidence, machine);
	endforeach;
	
	self.logMessage(LOG_BRIEF, "Work Machines");
	while self.notFinished() do
		self.currentTime := app.actualTimeServer;
		self.logMessage(LOG_BRIEF, "***** Work Count " &amp; self.getTaskCount.String &amp; " Current Time: " &amp; self.currentTime.time.String &amp;
							" Finish Time: " &amp; finishTime.time.String);
		
		if self.currentTime &gt; finishTime then
			self.logMessage(LOG_BRIEF, "Max Run Time exceeded");
			break;
		endif;
		
		foreach machine in machines do
			machine.SIM_Machine.work();
		endforeach;
		
		//if app.msgBox("Continue", "Simulation", MsgBox_Yes_No) = MsgBox_Return_No then
		//	break;
		//endif;
		
		process.sleep(5000);    // 5 seconds
	endwhile;

	foreach machine in allMachines do
		machine.SIM_Machine.logoff();
	endforeach;

	elapsedTime := app.actualTimeServer - startTime;
	
	self.logMessage(LOG_BRIEF, "Work Machines completed " &amp; elapsedTime.asMinutes.asStringJMTWithPrecision(1, false));
	
epilog
	delete machines;
end;</source>
    </JadeMethod>
</Class>
