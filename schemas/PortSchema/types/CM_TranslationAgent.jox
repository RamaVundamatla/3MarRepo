    <JadeMethod name="create" id="e46c324c-3e08-443e-8bbb-7da06bd45fb0">
        <updating/>
        <source>create() updating;

vars
	searchResults	: XLAT_SearchResults;
begin
	self.myRoot := app.myRoot;
	self.mySchema := rootSchema.getSchema(PortSchemaName);
	self.myCategory := mySchema.getConstantCategory("XLAT_GCCatetegories");

	create searchResults;
	searchResults.update(self, self.myRoot.allXLAT_Categories[XLAT_Exceptions], false);
	create searchResults;
	searchResults.update(self, self.myRoot.allXLAT_Categories[XLAT_FormCaptions], false);
	create searchResults;
	searchResults.update(self, self.myRoot.allXLAT_Categories[XLAT_Menus], false);
	create searchResults;
	searchResults.update(self, self.myRoot.allXLAT_Categories[XLAT_Permissions], false);
	create searchResults;
	searchResults.update(self, self.myRoot.allXLAT_Categories[XLAT_ReportNames], false);
	create searchResults;
	searchResults.update(self, self.myRoot.allXLAT_Categories[EntTableRows], false);

end;</source>
    </JadeMethod>
    <JadeMethod name="doConstantSearch" id="97cd0445-a438-4fc6-9237-4a093bd5f7f8">
        <updating/>
        <source>doConstantSearch(_searchName: String;
				_progressCallBackObject : Object;
				_progressStartCallback : String;
				_progressUpdateCallback : String) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 13NOV2023
ADO -  CR 60425 TASK 60828 
*/

vars
	category : XLAT_Category;
	iter	: Iterator;
	translatableText : XLAT_TranslatableText;
	translation : XLAT_Translation;
begin
	_progressCallBackObject.sendMsgWithParams(_progressStartCallback, 0, 1, "Searching for translatable text");
	
	category:=myRoot.allXLAT_Categories[XLAT_Exceptions];
	self.allSearchResults[XLAT_Exceptions].allTranslatableText.clear;
	
	foreach translatableText in category.allTranslatableText where translatableText.vConstantName = _searchName do
		self.allSearchResults[category.constantCategoryName].allTranslatableText.add(translatableText);
	
	endforeach;
	
epilog

end;</source>
        <Parameter name="_searchName" type="String"/>
        <Parameter name="_progressCallBackObject" type="Object"/>
        <Parameter name="_progressStartCallback" type="String"/>
        <Parameter name="_progressUpdateCallback" type="String"/>
    </JadeMethod>
    <JadeMethod name="doExportCSV" id="3613041d-2a39-4195-a6ec-aa4f8b07d25c">
        <source>doExportCSV(_file : File; _targetLocale : String; 
			_allTranslations : Boolean;
			_selectedCategories : XLAT_CategoryByConstantCategry;
			_createTestLoadFile : Boolean);

// Purpose: This method builds a csv file that can be given to an agency for translation
// 			The _createTestLoadFile parameter is set to true to create a dummy translation file
// 			which can be loaded back in with a ZZZ prefix to all translations
//
//          Column 1: Locale id (eg "1045")
//          Column 2: Text Category (eg "XLAT_Exceptions")
//          Column 3: Global Constant number (70141)
//          Column 4: Length version of the text ("text" or "shortText")
//          Column 5: Default translation provided by Master Terminal
//                    (eg "The password supplied has been used previously by this user.")
//          Column 6: Often empty - current translation for locale in Column 1
//                    (eg "Parol dostarczany byl uzywany zawczasu przez tego uzytkownika.")
//
//          After updating Column 6, the file can be imported
//          Geoff Davies, 8 September 2006

constants
/*	Comma = #'2C';
	Text = XLAT_Translation::text.name;
	ShortText = XLAT_Translation::shortText.name;*/
	//30 Nov 2017	NDL	TFS 7718
	Text = "text";
	ShortText = "shortText";

vars
	results : XLAT_SearchResults;
	category : String;
	doShortText : Boolean;
	translatableText : XLAT_TranslatableText;
	csvRecord : String;
	translation : XLAT_Translation;
	potentialTotal : Integer;
	count : Integer;
	tmpCategory	: XLAT_Category;

begin
	
	_file.writeLine("Locale,Category,Number,Short/Long,Standard Text,Translation");

	// Initialise the progress monitor
	if _allTranslations then
		foreach tmpCategory in app.myRoot.allXLAT_Categories discreteLock
			where _selectedCategories.includes(tmpCategory) do
			potentialTotal := potentialTotal + tmpCategory.allTranslatableText.size;
		endforeach;
	else
		foreach results in self.allSearchResults discreteLock
		  where _selectedCategories.includes(results.myCategory) do
			potentialTotal := potentialTotal + results.allTranslatableText.size;
		endforeach;
	endif;
	self.progressCallBackObject.sendMsgWithParams(self.progressStartCallback, 0, potentialTotal, self.progressMessage);

	// Iterate the search result objects.
	// There is one search result object per XLAT_Category.
	// The condition skips categories that are not selected.
	if _allTranslations then
		foreach tmpCategory in app.myRoot.allXLAT_Categories discreteLock
			where _selectedCategories.includes(tmpCategory) do
	
			doShortText := tmpCategory.usesShortText;
	
			// Iterate the translatable text objects.
			// Each object has a collection of translations by locale (one for locale 5129 at least).
			foreach translatableText in tmpCategory.allTranslatableText discreteLock do
			
				translatableText.outputAsCSV(_file, _targetLocale, tmpCategory.constantCategoryName, doShortText, _createTestLoadFile);
	
				// Update the progress monitor
				count := count + 1;
				self.progressCallBackObject.sendMsgWithParams(self.progressUpdateCallback, count);
			endforeach; // translatableText
		endforeach;  // results
	else
		foreach results in self.allSearchResults discreteLock
		  where _selectedCategories.includes(results.myCategory) do
	
			category := results.myCategory.constantCategoryName;
			doShortText := results.myCategory.usesShortText;
	
			// Iterate the translatable text objects.
			// Each object has a collection of translations by locale (one for locale 5129 at least).
			foreach translatableText in results.allTranslatableText discreteLock do
			
				translatableText.outputAsCSV(_file, _targetLocale, category, doShortText, _createTestLoadFile);
	
				// Update the progress monitor
				count := count + 1;
				progressCallBackObject.sendMsgWithParams(progressUpdateCallback, count);
			endforeach; // translatableText
		endforeach;  // results
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_targetLocale" type="String"/>
        <Parameter name="_allTranslations" type="Boolean"/>
        <Parameter name="_selectedCategories" type="XLAT_CategoryByConstantCategry"/>
        <Parameter name="_createTestLoadFile" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doGlobalSearch" id="88f0bee3-3af2-4971-b1c5-1d023282480b">
        <updating/>
        <source>doGlobalSearch(_categories : XLAT_CategoryByConstantCategry;
				_locale : CM_Locale;
				_refineExisting : Boolean;
				_toBeReviewed : Boolean;
				_progressCallBackObject : Object;
				_progressStartCallback : String;
				_progressUpdateCallback : String) updating;

vars
	boolean : Boolean;
	translatableText : XLAT_TranslatableText;
	category : XLAT_Category;
	potentialTotal : Integer;
	count : Integer;
	translatableTexts : XLAT_TranslatableTextByCatNmbr;
	locale : CM_Locale;
begin
	self.progressCount := 0;
	
	// count items in the source collection over which the search is performed
	foreach category in _categories do
		if _refineExisting then
			potentialTotal := potentialTotal + self.allSearchResults[category.constantCategoryName].allTranslatableText.size;
		else
			potentialTotal := potentialTotal + self.myRoot.allXLAT_Categories[category.constantCategoryName].allTranslatableText.size;
		endif;
	endforeach;
	_progressCallBackObject.sendMsgWithParams(_progressStartCallback, 0, potentialTotal, "Searching for translatable text");

	create translatableTexts transient;

	// now check translatableText items for each category
	foreach category in _categories do : category_loop

		if _refineExisting then
			allSearchResults[category.constantCategoryName].allTranslatableText.copy(translatableTexts);
		else
			myRoot.allXLAT_Categories[category.constantCategoryName].allTranslatableText.copy(translatableTexts);
		endif;
		allSearchResults[category.constantCategoryName].clear;

		foreach translatableText in translatableTexts discreteLock do

			count := count + 1;
//			_progressCallBackObject.sendMsgWithParams(_progressUpdateCallback, count);	// cnwrl1 03/11/2009 PAR 21295 - what it was
			// cnwrl1 03/11/2009 PAR 21295 - start of coding
			// if the cancel button has been clicked then break out of both loops now. 
			boolean	:= _progressCallBackObject.sendMsgWithParams(_progressUpdateCallback, count).Boolean;
			if not boolean then
				break category_loop;
			endif;
			// cnwrl1 03/11/2009 PAR 21295 - end of coding
			
			// restrict to 'to be reviewed'?
			if _toBeReviewed = false
			or _toBeReviewed = true and translatableText.toBeReviewedFlag = true then
				// add to the results collection
				if translatableText.allTextByLocale[_locale.localeId] &lt;&gt; null then
					allSearchResults[category.constantCategoryName].allTranslatableText.add(translatableText);
					self.progressCount := self.progressCount + 1;
				endif;
			endif;
			
		endforeach;	// translatableText

		translatableTexts.clear;
		
	endforeach category_loop; // category
	
epilog
	delete translatableTexts;
end;</source>
        <Parameter name="_categories" type="XLAT_CategoryByConstantCategry"/>
        <Parameter name="_locale" type="CM_Locale"/>
        <Parameter name="_refineExisting" type="Boolean"/>
        <Parameter name="_toBeReviewed" type="Boolean"/>
        <Parameter name="_progressCallBackObject" type="Object"/>
        <Parameter name="_progressStartCallback" type="String"/>
        <Parameter name="_progressUpdateCallback" type="String"/>
    </JadeMethod>
    <JadeMethod name="doImportCSV" id="f348cdd2-c5a9-4ddb-9a25-5b9560ccaaad">
        <source>doImportCSV(_file : File);

vars
	count : Integer;
	str : String;
	idx : Integer;

begin
	// Read the contents of the text translations file and ignore the first line.
	count := _file.fileLength;
	str := _file.readString(count);
	if count &gt; 0 then
		idx := 1;
		str.scanUntil(CrLf, idx);
		str.scanWhile(CrLf, idx);
		if idx = 0 then
			return;
		endif;

		// Initialise the progress monitor.
		count := count - idx;
		str := str[idx : end];
		self.progressCallBackObject.sendMsgWithParams(self.progressStartCallback, 0, count, self.progressMessage);
		str.csvDecode(self, CM_TranslationAgent::trxUpdateTranslation.name);
	endif;

end;</source>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="doKeywordSearch" id="cb820d62-ed30-4b1e-a42f-efca8c31293b">
        <updating/>
        <source>doKeywordSearch(_categories : XLAT_CategoryByConstantCategry;
				_locale : CM_Locale;
				_matchAll : Boolean;
				_refineExisting : Boolean;
				_searchWords : StringArray;
				_toBeReviewed : Boolean;
				_caseInsensitive : Boolean;
				_progressCallBackObject : Object;
				_progressStartCallback : String;
				_progressUpdateCallback : String) updating;
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 11/02/2015	cnwdap1		PAR #35670 Add case insensitive parameter option
vars
	locale	: CM_Locale;
	translatableText : XLAT_TranslatableText;
	translation : XLAT_Translation;
	category : XLAT_Category;
	translations : XLAT_TranslationByCatAndNumber;
	count : Integer;
	existingTransTexts : XLAT_TranslatableTextByCatNmbr;
	transWords : StringArray;
	word : String;
	caseInsensitive : Boolean;

begin
	//if process.isNDL or process.isCNWAB1 or process.isCNWGB1		// PAR #35670
	//or process.isSarge() then										// PAR #35670
	if _caseInsensitive then										// PAR #35670
		caseInsensitive := true;
	endif;
	
	// Translations for the user selected locale.
	create translations transient;
	// 26733 option to search all locales at once
	if _locale = null then
		foreach locale in app.myRoot.allLocales do
			locale.getTranslations(_searchWords, translations);
		endforeach;
	else
		_locale.getTranslations(_searchWords, translations);
	endif;

	create existingTransTexts transient;
	foreach category in _categories do
		self.allSearchResults[category.constantCategoryName].allTranslatableText.copy(existingTransTexts);
	endforeach;
	self.allSearchResults[XLAT_Exceptions].allTranslatableText.clear;
	self.allSearchResults[XLAT_FormCaptions].allTranslatableText.clear;
	self.allSearchResults[XLAT_Menus].allTranslatableText.clear;
	self.allSearchResults[XLAT_Permissions].allTranslatableText.clear;
	self.allSearchResults[XLAT_ReportNames].allTranslatableText.clear;
	self.allSearchResults[EntTableRows].allTranslatableText.clear;

	self.progressCount := 0;

	_progressCallBackObject.sendMsgWithParams(_progressStartCallback, 0, translations.size, "Searching for translatable text");

	create transWords transient;
	foreach translation in translations do : translationLabel
		translatableText := translation.myTranslatableText;
		category := translatableText.myCategory;
		count := count + 1;
		_progressCallBackObject.sendMsgWithParams(_progressUpdateCallback, count);

		// Restrict to selected categories.
		if not _categories.includes(category) then
			continue;
		endif;

		// Restrict to 'to be reviewed'?
		if _toBeReviewed = true and translatableText.toBeReviewedFlag = false then
			continue;
		endif;

		// With a refineExisting search the translatable text must exist in the results set.
		if _refineExisting then
			if existingTransTexts[translatableText.myConstantCategoryName, translatableText.number] = null then
				continue;
			endif;
		endif;

		
		if caseInsensitive then	// testing for Par 20524
			if _matchAll then
				transWords.clear;
				translation.text.getWordsAsUpperCase(transWords);
				foreach word in _searchWords do
					if not transWords.includes(word.toUpper) then
						continue translationLabel;
					endif;
				endforeach;
			endif;
		else
			// ALL option - check the translation contains ALL keywords.
			if _matchAll then
				transWords.clear;
				translation.text.getWords(transWords);
				foreach word in _searchWords do
					if not transWords.includes(word) then
						continue translationLabel;
					endif;
				endforeach;
			endif;
		endif;

		// Add to the results collection.
		// 26733 option to search all locales at once
		if not self.allSearchResults[category.constantCategoryName].allTranslatableText.includes(translatableText) then
			self.progressCount := self.progressCount + 1;
			self.allSearchResults[category.constantCategoryName].allTranslatableText.add(translatableText);
		endif;

	endforeach translationLabel;

epilog
	delete translations;
	delete transWords;
	delete existingTransTexts;
end;
</source>
        <Parameter name="_categories" type="XLAT_CategoryByConstantCategry"/>
        <Parameter name="_locale" type="CM_Locale"/>
        <Parameter name="_matchAll" type="Boolean"/>
        <Parameter name="_refineExisting" type="Boolean"/>
        <Parameter name="_searchWords" type="StringArray"/>
        <Parameter name="_toBeReviewed" type="Boolean"/>
        <Parameter name="_caseInsensitive" type="Boolean"/>
        <Parameter name="_progressCallBackObject" type="Object"/>
        <Parameter name="_progressStartCallback" type="String"/>
        <Parameter name="_progressUpdateCallback" type="String"/>
    </JadeMethod>
    <JadeMethod name="doNumberSearch" id="e99bd376-8176-47a1-856e-07dcb7929967">
        <updating/>
        <source>doNumberSearch(	_searchNumber: Integer;
				_progressCallBackObject : Object;
				_progressStartCallback : String;
				_progressUpdateCallback : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 February 2009	cnwer1	Initial creation

*/

vars
	category : XLAT_Category;
	iter	: Iterator;
	translatableText : XLAT_TranslatableText;
	translation : XLAT_Translation;
begin
	_progressCallBackObject.sendMsgWithParams(_progressStartCallback, 0, 1, "Searching for translatable text");
	
	category:=myRoot.allXLAT_Categories[XLAT_Exceptions];
	self.allSearchResults[XLAT_Exceptions].allTranslatableText.clear;
	
	translatableText:=category.allTranslatableText.getAtKey(_searchNumber);
	
	if translatableText &lt;&gt; null then
		self.allSearchResults[category.constantCategoryName].allTranslatableText.add(translatableText);
	endif;
epilog

end;</source>
        <Parameter name="_searchNumber" type="Integer"/>
        <Parameter name="_progressCallBackObject" type="Object"/>
        <Parameter name="_progressStartCallback" type="String"/>
        <Parameter name="_progressUpdateCallback" type="String"/>
    </JadeMethod>
    <JadeMethod name="doRemoveResult" id="58c67407-6f6c-4b21-99df-596825879989">
        <source>doRemoveResult(_translatableText : XLAT_TranslatableText; _category : XLAT_Category):Boolean;

// return value - false indicates not found

vars
	results : XLAT_SearchResults;
begin
	results := self.allSearchResults[_category.constantCategoryName];
	if results &lt;&gt; null then
		if results.allTranslatableText[_translatableText.number] &lt;&gt; null then
			results.allTranslatableText.removeKey(_translatableText.number);
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <Parameter name="_translatableText" type="XLAT_TranslatableText"/>
        <Parameter name="_category" type="XLAT_Category"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doReplaceText" id="33784ee9-e0e2-44f8-8eb7-dee1003fb4ad">
        <updating/>
        <source>doReplaceText(_categories : XLAT_CategoryByConstantCategry;
			   _locale : CM_Locale;
			   _refineExisting : Boolean;
			   _searchWords : StringArray;
			   _searchPhrase : String;
			   _replaceText : String;
			   _progressCallBackObject : Object;
			   _progressStartCallback : String;
			   _progressUpdateCallback : String) updating;

vars
	translatableText : XLAT_TranslatableText;
	translation : XLAT_Translation;
	category : XLAT_Category;
	translations : XLAT_TranslationByCatAndNumber;
	standardTranslations : XLAT_TranslationByCatAndNumber;
	count : Integer;
	existingTransTexts : XLAT_TranslatableTextByCatNmbr;
	standardTextLocale : CM_Locale;
	localeTranslation : XLAT_Translation;
	transWords : StringArray;
	word : String;
	hasAllWords : Boolean;

begin
	// Don't waste time if replacement text is the same.
	if _searchPhrase.toLower = _replaceText.toLower then
		return;
	endif;
	
	// Translations for the user selected a 'real' locale.
	create translations transient;
	_locale.getTranslations(_searchWords, translations);

	// Translations for the standard text locale "0000".
	create standardTranslations transient;
	standardTextLocale := self.myRoot.allLocales[StandardTextLocaleStr];
	if _locale &lt;&gt; standardTextLocale then
		standardTextLocale.getTranslations(_searchWords, standardTranslations);

		// Merge the two sets of translations.
		foreach translation in standardTranslations do
			translatableText := translation.myTranslatableText;
			localeTranslation := translatableText.allTextByLocale[_locale.localeId];
			if localeTranslation = null then
				translations.add(translation);
			endif;
		endforeach;
	endif;

	_progressCallBackObject.sendMsgWithParams(_progressStartCallback, 0, translations.size, "Reviewing translatable text for update");

	// Remove translations that do not contain all keywords.
	create transWords transient;
	foreach translation in translations do
		transWords.clear;
		translation.text.getWords(transWords);
		hasAllWords := true;
		foreach word in _searchWords do
			if not transWords.includes(word) then
				hasAllWords := false;
				break;
			endif;
		endforeach;
		if not hasAllWords then
			translations.remove(translation);
			count := count + 1;
			_progressCallBackObject.sendMsgWithParams(_progressUpdateCallback, count);
		endif;
	endforeach;

	// Remove translations that do not contain the phrase, as opposed to just the keywords.
	foreach translation in translations do
		if translation.text.toLower.pos(_searchPhrase.toLower, 1) = 0 then
			translations.remove(translation);
			count := count + 1;
			_progressCallBackObject.sendMsgWithParams(_progressUpdateCallback, count);
		endif;
	endforeach;

	create existingTransTexts transient;
	foreach category in _categories do
		self.allSearchResults[category.constantCategoryName].allTranslatableText.copy(existingTransTexts);
	endforeach;
	self.allSearchResults[XLAT_Exceptions].allTranslatableText.clear;
	self.allSearchResults[XLAT_FormCaptions].allTranslatableText.clear;
	self.allSearchResults[XLAT_Menus].allTranslatableText.clear;
	self.allSearchResults[XLAT_Permissions].allTranslatableText.clear;
	self.allSearchResults[XLAT_ReportNames].allTranslatableText.clear;
	self.allSearchResults[EntTableRows].allTranslatableText.clear;

	self.progressCount := 0;

	foreach translation in translations do
		translatableText := translation.myTranslatableText;
		category := translatableText.myCategory;
		localeTranslation := translatableText.allTextByLocale[_locale.localeId];
		count := count + 1;
		_progressCallBackObject.sendMsgWithParams(_progressUpdateCallback, count);

		// Restrict to selected categories.
		if not _categories.includes(category) then
			continue;
		endif;

		// With a refineExisting search the translatable text must exist in the results set.
		if _refineExisting then
			if existingTransTexts[translatableText.myConstantCategoryName, translatableText.number] = null then
				continue;
			endif;
		endif;

		// Translate and add to the results collection.
		beginTransaction;
		if translation.myLocale = standardTextLocale and _locale &lt;&gt; standardTextLocale then
			create localeTranslation;
			localeTranslation.update(myRoot, translatableText, _locale, replaceTranslationText(translation, _searchPhrase, _replaceText), null);
		else
			translation.update(myRoot, translatableText, _locale, replaceTranslationText(translation, _searchPhrase, _replaceText), null);
		endif;
		commitTransaction;
		self.progressCount := self.progressCount + 1;
		self.allSearchResults[category.constantCategoryName].allTranslatableText.add(translatableText);

	endforeach;

epilog
	delete translations;
	delete standardTranslations;
	delete existingTransTexts;
	delete transWords;
end;
</source>
        <Parameter name="_categories" type="XLAT_CategoryByConstantCategry"/>
        <Parameter name="_locale" type="CM_Locale"/>
        <Parameter name="_refineExisting" type="Boolean"/>
        <Parameter name="_searchWords" type="StringArray"/>
        <Parameter name="_searchPhrase" type="String"/>
        <Parameter name="_replaceText" type="String"/>
        <Parameter name="_progressCallBackObject" type="Object"/>
        <Parameter name="_progressStartCallback" type="String"/>
        <Parameter name="_progressUpdateCallback" type="String"/>
    </JadeMethod>
    <JadeMethod name="doShowNoTranslationEntry" id="1926056f-d52f-45e3-95f4-310080094540">
        <updating/>
        <source>doShowNoTranslationEntry(_categories : XLAT_CategoryByConstantCategry;
							_locale : CM_Locale;
							_progressCallBackObject : Object;
							_progressStartCallback : String;
							_progressUpdateCallback : String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2009	cnwmd1	Initial creation

*/

vars
	category : XLAT_Category;
	translatableTexts : XLAT_TranslatableTextByCatNmbr;
	translatableText : XLAT_TranslatableText;
	translation : XLAT_Translation;
	count : Integer;
begin
	create translatableTexts transient;
	
	foreach category in _categories do
		myRoot.allXLAT_Categories[category.constantCategoryName].allTranslatableText.copy(translatableTexts);
		allSearchResults[category.constantCategoryName].clear;
	endforeach;
	
	_progressCallBackObject.sendMsgWithParams(_progressStartCallback, 0, translatableTexts.size, "Searching for translations with no text for locale");
	
	foreach translatableText in translatableTexts discreteLock do
		translation := translatableText.allTextByLocale[_locale.localeId];
		
		count := count + 1;
		_progressCallBackObject.sendMsgWithParams(_progressUpdateCallback, count);
		
		if translation = null then
			self.progressCount := self.progressCount + 1;
			self.allSearchResults[translatableText.myCategory.constantCategoryName].allTranslatableText.add(translatableText);
		elseif translation.text = null or translation.text[1:3].toUpper = "ZZZ" then
			self.progressCount := self.progressCount + 1;
			self.allSearchResults[translatableText.myCategory.constantCategoryName].allTranslatableText.add(translatableText);
		endif;
		
	endforeach;
epilog
	delete translatableTexts;

end;</source>
        <Parameter name="_categories" type="XLAT_CategoryByConstantCategry"/>
        <Parameter name="_locale" type="CM_Locale"/>
        <Parameter name="_progressCallBackObject" type="Object"/>
        <Parameter name="_progressStartCallback" type="String"/>
        <Parameter name="_progressUpdateCallback" type="String"/>
    </JadeMethod>
    <JadeMethod name="doShowTranslationsForForm" id="ca55b5f3-7362-4cae-906e-131bd0689965">
        <updating/>
        <source>doShowTranslationsForForm(_categories : XLAT_CategoryByConstantCategry;
							//_locale : CM_Locale;
							_formClass : String;
							_progressCallBackObject : Object;
							_progressStartCallback : String;
							_progressUpdateCallback : String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2009	cnwmd1	Initial creation

*/

vars
	category : XLAT_Category;
	translatableTexts : XLAT_TranslatableTextByCatNmbr;
	translatableText : XLAT_TranslatableText;
	translation : XLAT_Translation;
	count : Integer;
begin
	create translatableTexts transient;
	
	self.progressCount := 0;
	
	foreach category in _categories do
		myRoot.allXLAT_Categories[category.constantCategoryName].allTranslatableText.copy(translatableTexts);
		allSearchResults[category.constantCategoryName].clear;
	endforeach;
	
	_progressCallBackObject.sendMsgWithParams(_progressStartCallback, 0, translatableTexts.size, "Searching for translations for a form");
	
	foreach translatableText in translatableTexts discreteLock do
		
		count := count + 1;
		_progressCallBackObject.sendMsgWithParams(_progressUpdateCallback, count);
		
		if translatableText.vFormClass &lt;&gt; null and translatableText.vFormClass.toUpper = _formClass.toUpper then
			self.progressCount := self.progressCount + 1;
			self.allSearchResults[translatableText.myCategory.constantCategoryName].allTranslatableText.add(translatableText);
		endif;
		
	endforeach;
epilog	
	delete translatableTexts;
end;</source>
        <Parameter name="_categories" type="XLAT_CategoryByConstantCategry"/>
        <Parameter name="_formClass" type="String"/>
        <Parameter name="_progressCallBackObject" type="Object"/>
        <Parameter name="_progressStartCallback" type="String"/>
        <Parameter name="_progressUpdateCallback" type="String"/>
    </JadeMethod>
