        <updating/>
        <source>cmbUnits_lostFocus(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	lst, idx : Integer;

begin
	self.tblEntDetail.setValueByControlName(combobox.name,combobox.text);
	idx := self.cmbCharges.listIndex; // PAR 15750
	
	self.doCmbChargesBuild(combobox.listObject.CM_CalculationType);
	
	 // PAR 15750
	lst := self.cmbCharges.listCount();
	if lst = 1 then
		self.cmbCharges.listIndex := 1;
	elseif lst &gt; 1 then
		self.cmbCharges.listIndex := idx;
	endif;
end;</source>
