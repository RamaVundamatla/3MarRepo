    <JadeMethod name="trxUpdateVoyageJobSheetJobs" id="e0a44dc2-b8ee-47b0-b23f-b0c823bfb33a">
        <updating/>
        <source>trxUpdateVoyageJobSheetJobs(	_voyage : CM_Voyage;
								_allJobSheetJobs : ObjectArray;
								_allJobSheets : CM_VoyageJobSheetArray;
								_passport : CM_Passport input) updating;
/*

Purpose:	_jobsInOrder will be a collection of transient and persistant voyage jobs		
			transient jobs need to have either there crane | order or both changed

Return Value:		


Date		Who		Reason
31 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	pxyJob,
	realJob 	: CM_VoyageJob;
	jobSheet	: CM_VoyageJobSheet;
	oldJobSheet : CM_JobSheet;
	newCrane    : String;
	errorSet : CM_ErrorSet;
	alertCreated : Boolean;
	changeCrane : Boolean;
	indx : Integer;
	jobsInOrder : CM_VoyageJobArray;
	obj : Object;
	term : CM_Terminal;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	if _allJobSheets = null or _allJobSheets.size = 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Voyage Job Sheet', null, null);
		app.raiseCMException(Input_required_field_voyJobSht, null, null); // cnwdb2	PAR 35364


	endif;
	if _allJobSheetJobs = null or _allJobSheetJobs.size = 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Voyage Job Sheet', null, null);
		app.raiseCMException(Input_required_field_voyJobSht, null, null); // cnwdb2	PAR 35364


	endif;
	
	foreach jobSheet in _allJobSheets do
		exclusiveLock(jobSheet);
	endforeach;
	// so only 1 note sent from the move controller
//	self.initialiseActivityWithPassport(_passport, method);
	app.myEventManager.setMultiTransactionTrx();

	create errorSet transient;			
	term:=_voyage.myTerminal;
	
	foreach obj in _allJobSheetJobs do
		if not obj.isKindOf(CM_VoyageJobArray) then
			continue;
		endif;	
		jobsInOrder:=obj.CM_VoyageJobArray;

		indx:=0;
		foreach pxyJob in jobsInOrder do
			indx:=indx + 1;
			if not pxyJob.isTransient then
				continue;
			else
				realJob :=app.myProxyManager.getRealObject(pxyJob).CM_VoyageJob;
			endif;
			jobSheet:=_voyage.allJobSheets[pxyJob.craneId];
			//newCrane :=pxyJob.craneId;
			exclusiveLock(realJob);
	
			if not process.isInTransactionState then
				beginTransaction;
			endif;
			
			if _passport.noErrors() then
			
				app.myUtilityUA.utlUpdateVoyageJobSheetJob(	jobSheet,
									pxyJob,
									realJob,
									indx,
									_passport);
			//	app.myUtilityUA.utlUpdateJobTransOnJobSheet(pxyJob, _newJobSheet, _passport);
			endif;
	
			if _passport.isOkToCommit(false) then
				app.cmsCommitTransaction(_passport);
			else
				app.cmsAbortTransaction;
				if _passport.hasErrors then
					app.convertErrorsWarningsToAlert('Voyage Job ' &amp; pxyJob.getTreeDescription() 
													&amp; ' could not be transfered to crane ' 
													&amp; jobSheet.crane, _passport.allErrorWarnings);				
					alertCreated := true;
				elseif _passport.hasWarnings then
					//add job so it gets re-processed in order
					//_jobsWithWarnings.add(tmpJob);
				endif;
				_passport.moveErrorsToSet(errorSet);
				_passport.initialiseTransaction();				
			endif;
			
		endforeach;
	endforeach;
	
	if _passport.noErrors() 
	and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	_passport.addErrorsFromSet(errorSet);

	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'Job Transfer To Crane', null, self);
	endif;	
	app.myEventManager.createSingleObjInfoNoteEvt(_voyage,term.getTerminalEvent(JobSheet_Update_Event),_voyage);
epilog
	self.finaliseActivityWithPassport(_passport);
	delete errorSet;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_allJobSheetJobs" type="ObjectArray"/>
        <Parameter name="_allJobSheets" type="CM_VoyageJobSheetArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateVoyageJobShift" id="1a134b2b-6ca2-4cc9-9db2-f1ea0db57b05">
        <updating/>
        <source>trxUpdateVoyageJobShift(_pxyJob : CM_VoyageJob input; _allOtherJobs : CM_VoyageJobSet input; _passport : CM_Passport input) updating;
/*
Purpose:			
Date		Who		Reason
17 February 2017	cnwab1	Initial creation
*/

vars

	realJob : CM_VoyageJob;	//17 Mar 2017	NDL	TFS 3785
	otherRealJob : CM_VoyageJob;	//17 Mar 2017	NDL	TFS 3785
	realShift : CM_Shift;	//17 Mar 2017	NDL	TFS 3785
	
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	app.myUtilityUA.utlUpdateVoyageJobShift(_pxyJob, realJob, _passport);
	
	//17 Mar 2017	NDL	TFS 3785
	if _passport.hasErrors then
		return;
	endif;
	//17 Mar 2017	NDL	TFS 3785
	realShift := realJob.myShift;
	if not _allOtherJobs.isEmpty then
		foreach otherRealJob in _allOtherJobs do
			otherRealJob.setMyShift(null);
			otherRealJob.setMyShift(realShift);
			if _passport.hasErrors then
				break;
			endif;
			otherRealJob.causeTerminalEvent(CM_VoyageJob.Event_Mode_Update);
		endforeach;
	endif;

epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_pxyJob" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_allOtherJobs" type="CM_VoyageJobSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateVoyageJobUnassignTI" id="c6112220-ffd6-40f2-a0b8-9b8aaaa414da">
        <updating/>
        <source>trxUpdateVoyageJobUnassignTI(_moveControl : CMIF_MoveController input;_proxyVoyageJob :CM_VoyageJob; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:	 
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Mar 2025	navah1		Story 34324: MSL - Un Plan Cargo items Doesn't use Deferred Updates [With Jobs]
// ---------------------------------------------------------------------------
vars
	theTI 			: CM_TrackedItem;
	slotRequest		: CM_SlotRequest;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	beginTransaction;
	
	theTI := _moveControl.myTrackedItem;
	
	_passport.useTIDictDeferUpdate 			:= true;			 //11.03.2025 navah1 #34324					 
	_passport.useTITransactionDeferUpdate   := true;			 //11.03.2025 navah1 #34324
	
	if theTI &lt;&gt; null then
		
		app.myUtilityUA.utlUpdateWLEUnassignTI(_moveControl, _passport); // this sorts out the job as well
		
		//cnwdz2 par 18188
		if _passport.noErrors() then
			
			_passport.doDeferredUpdates();					//11.03.2025 navah1 #34324
			
			slotRequest := _moveControl.mySlotRequest;
			
			if slotRequest &lt;&gt; null 	and slotRequest.myJob &lt;&gt; null then
				slotRequest.myJob.setRemarks(null);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
