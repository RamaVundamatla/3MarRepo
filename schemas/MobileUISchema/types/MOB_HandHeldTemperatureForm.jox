        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupControls" id="697f8cb8-0789-4a24-8b11-a3f524c2afb7">
        <updating/>
        <source>setupControls() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2015	cnwdap1		Initial creation PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
//
vars
	state		: Integer;
	context		: Integer;
	cargoCheck	: CM_CargoCheck;
	item 		: CM_CargoCheckItem;
	toDo		: CM_ToDoTask;
	
begin
	cargoCheck := self.myMobileGenericAgent.getEquipCheckContextFromState();
	if cargoCheck &lt;&gt; null then
		foreach item in cargoCheck.allCargoCheckItems discreteLock where item.requiredExtraInfo = EXTRA_INFO_TEMPERATURE do
			if item.myToDoTaskDesc &lt;&gt; null then
				self.myCargoCheckItem := item;
				self.chkToDo.visible := true;
				self.chkToDo.caption := item.myToDoTaskDesc.description;
				if self.myTrackedItem &lt;&gt; null then
					foreach toDo in self.myTrackedItem.allToDoTasksToDo where toDo.toDoTaskDescCode = item.myToDoTaskDesc.code do
						self.chkToDo.value := true;
					endforeach;
				endif;
			endif;
		endforeach;
	endif;
	
	self.doResizeControls(true);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2dd90086-f82c-493c-b34c-0b52b8982e46">
        <updating/>
        <source>setupForm() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2015	cnwdap1		Initial creation PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
//
vars

begin
	if self.baseCaption = null then
		self.baseCaption := self.caption;
	endif;

	self.myTrackedItem := self.myMobileGenericAgent.myNextTiToAction;
	app.myMobileAgent.setMyProxy( self.myTrackedItem );
	app.myMobileAgent.setMySelectedTI(self.myTrackedItem);
	
	self.caption := self.baseCaption &amp; "  " &amp; myTrackedItem.cargoTypeDescr;

	inheritMethod();
	
	if self.myTrackedItem.myOperator.displayTempFahrenheit then
		self.lblCelFahr.caption := Degrees_F;
	else
		self.lblCelFahr.caption := Degrees_C;
	endif;
	
	self.setupCmdButtons( 2, app.getErrorString(Save), BACK_BUTTON, null, null, null );
	self.setupControls();
	self.displayTemperature();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="cc4eacac-1a06-4b82-ad6e-2698a61ac9e6">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 April 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020671, locale);
	chkToDo.translateCaption(Xlat_0020672, locale);
	lblCelFahr.translateCaption(Xlat_0020673, locale);
	lblTemperature.translateCaption(Xlat_0020674, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
