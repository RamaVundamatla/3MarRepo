<GUIClass name="CMUI_PictureView" id="e3b501bb-64c1-4d21-b656-c9472db079e7">
    <superclass name="CM_BaseForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="picView" id="fa059bd8-0855-44c0-9cb3-c1173e8e3dde">
        <embedded/>
        <type name="Picture"/>
    </ImplicitInverseRef>
    <JadeMethod name="setPicture" id="f13fe7cc-e52c-4d80-a5df-d6a6a55f29ed">
        <source>setPicture(pPic : Binary);

vars

begin

	self.picView.picture := pPic;
	
end;</source>
        <Parameter name="pPic" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="825b9e9c-ce5c-4072-87c2-802efa694819">
        <updating/>
        <source>setupForm() updating;

vars

begin
	inheritMethod();
	
	self.picView.top := 0;
	self.picView.left := 0;
	
	if self.picView.picture &lt;&gt; null then
		self.width := self.picView.width + 20;
		self.height := self.picView.height + 40;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="51110950-dbdc-4824-8d1c-40431e844473">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017437, locale);
end;</source>
    </JadeMethod>
</GUIClass>
