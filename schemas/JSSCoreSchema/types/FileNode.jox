    <JadeMethod name="jssUnqualName" id="43565b86-7b58-454c-97e7-0179f5ea0bff">
        <source>jssUnqualName() :String;
// --------------------------------------------------------------------------------
// Created:		18 February 2001 by cnwdad1
//
// Purpose:		Return only the unqualified filename (after the FINAL "\").
//
// Parameters:	None
//
// Returns:		The unqualified file name.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	charIndex	: Integer;
	lastCharPos	: Integer;

begin
	charIndex	:=	1;

	while charIndex &lt;&gt; 0 do
		lastCharPos	:=	charIndex;
		charIndex	:=	fileName.pos(global.jssGetFileSeparator(), (lastCharPos + 1));
	endwhile;

	return fileName[(lastCharPos + 1):end];	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
