    <JadeMethod name="create" id="834d7383-2a16-4864-b831-9e43e3f12969">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
/* Changes

Date		Name	TFS#		Description
============================================================================
24/09/2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
// 18 Nov 2019	jlgrs1	TFS 47300 collections not in pxyCreateUpdateProxy method
//
vars

begin

	// Always instantiate mode to "Production" and reset to Test/Dev if required.
	if self.isTransient() then
		return;
	endif;
	
	app.setPropertyValue("myRoot", self);
	self.setSystemMode(SystemMode_Production);
	
	self.createAuditConfigs();
	
	self.initDefaults();
	
	self.createTALevelColours();
	
	self.setInitialVersion(CM_Version.VERSION);	//cnwmc5 - 18/12/2012 - SFW 1323
	
	// create the bank and associated info
	create self.myRootCompany persistent;
	self.myRootCompany.initialise("", "ROOT", null, null);
	
	self.createDutyDocumentRoot;

end;</source>
    </JadeMethod>
    <JadeMethod name="createAuditConfig" id="15ece953-69b9-4b09-bf2d-62cbf0bf8800">
        <source>createAuditConfig(pClass : Class) : CM_AuditConfig;
// ---------------------------------------------------------------------------
// Created:     25 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	anAuditConfig	: CM_AuditConfig;
	endTS	: Boolean;	
begin

	anAuditConfig := self.allAuditConfigs[pClass.name];
	if anAuditConfig &lt;&gt; null then
		return anAuditConfig;
	endif;

	if (not process.isInTransactionState) then
		// this should never occur if JMTRelease has been
		// run correctly but is done here for security
		endTS := true;
		beginTransaction;
	endif;
	create anAuditConfig persistent;
	anAuditConfig.updateForCreate(pClass, self);
	
	//29 Jan 2021	NDL	TFS 50152
	if pClass = CM_AuditConfig then
		app.myUtilityUA.updAuditConfigSetIsEnable( true, anAuditConfig, app.myPassport);
	endif;
	
	return anAuditConfig;
epilog
	if endTS then
		commitTransaction;
	endif;

end;</source>
        <Parameter name="pClass" type="Class"/>
        <ReturnType type="CM_AuditConfig"/>
    </JadeMethod>
