    <JadeMethod name="setProxy" id="afa780df-62a9-419b-9c05-e9b183100d3f">
        <updating/>
        <source>setProxy(_cutoffdefn : CM_ReceivalCutoffTermDef; _defaultCutoff, _defaultEarliestReceival, _defaultCutoffPN, _defaultEarliestReceivalPN : Decimal; _defaultRelativeTo : Integer) updating;
/*
Purpose:

Date		Who		Reason
07 March 2025	navab1	JIRA 34233
*/

vars

begin
	self.myReceivalCutoffTermDef := _cutoffdefn;
	self.defaultCutoff := _defaultCutoff;
	self.defaultEarliestReceival := _defaultEarliestReceival;
	self.defaultCutoffPN := _defaultCutoffPN;
	self.defaultEarliestReceivalPN := _defaultEarliestReceivalPN;
	self.defaultRelativeTo := _defaultRelativeTo;
epilog

end;</source>
        <Parameter name="_cutoffdefn" type="CM_ReceivalCutoffTermDef"/>
        <Parameter name="_defaultCutoff" type="Decimal"/>
        <Parameter name="_defaultEarliestReceival" type="Decimal"/>
        <Parameter name="_defaultCutoffPN" type="Decimal"/>
        <Parameter name="_defaultEarliestReceivalPN" type="Decimal"/>
        <Parameter name="_defaultRelativeTo" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromTermDef" id="b0a97f35-ce84-448c-8126-1a11edbb39a9">
        <updating/>
        <source>setPxyFromTermDef(_recCutOffTermDef : CM_ReceivalCutoffTermDef; _opTerm : CM_OperatorTerminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/03/2025	navkc1 JIRA Story MTN-34232: MTN | Prenote Voyage Cut Offs - System Admin

*/

vars

begin
	self.defaultCutoff := _recCutOffTermDef.defaultCutoff;
	self.defaultCutoffPN := _recCutOffTermDef.defaultCutoffPN;
	self.defaultEarliestReceival := _recCutOffTermDef.defaultEarliestReceival;
	self.defaultEarliestReceivalPN := _recCutOffTermDef.defaultEarliestReceivalPN;
	self.myReceivalCutoffTermDef := _recCutOffTermDef;
	self.defaultRelativeTo := _recCutOffTermDef.defaultRelativeTo;
	self.myOperatorTerminal := _opTerm;
epilog

end;</source>
        <Parameter name="_recCutOffTermDef" type="CM_ReceivalCutoffTermDef"/>
        <Parameter name="_opTerm" type="CM_OperatorTerminal"/>
    </JadeMethod>
