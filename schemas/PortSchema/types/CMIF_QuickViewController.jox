    <JadeMethod name="create" id="456b8451-a977-4035-bd67-778d04d267a3">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Nov 2017	jlger1	Initial creation tfs 7725
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars
	user : CM_User;
	term : CM_Terminal;	
begin
	
	user	:=	app.myPassport.myUser;			//08.01.2026 navma1 #MTN-36897
	if app.myPassport.myUser &lt;&gt; null then
		
		term := app.myPassport.myTerminal;	     //08.01.2026 navma1 #MTN-36897
		self.setTerminal(app.myPassport.myTerminal);
		self.canDoPartialMatch := user.canDo(term, PmCargoQuickViewPartial);		
		self.checkAccess 	   := not user.canDo(term, PmCargoQuickViewNoDAC);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSearch" id="5f150c63-f4b8-48f7-a12c-409fba99e708">
        <updating/>
        <source>doSearch() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     29 August 2007 by cnwrs2
//
// Purpose:     
// 16 May 2018 cnwma1	ChangeRequest 38580: Public page - search by BOL and Booking-
// 01 Jun 2018 cnwma1	Bug 38540: JMT - Cannot search pre-notes on non-logged in search in the new web portal
// 12 Nov 2018 jlgmd1	TFS 41068 - JMT - CardSchema monitoring for Web services
vars
	tmpTerminal	: CM_Terminal;
	ti			: CM_TrackedItem;
	tmpVoy		: CM_Voyage;
	checkDT 	: TimeStamp;
	foundTIs	: CM_TISet;
	foundBookings : CM_BookingRefSet;
	foundBols     : CM_BOLSet;
	tmpDAC	: CM_DataAccessController;
	iter : Iterator;
	bookingRef : CM_BookingRef;
	bolIn	: CM_BOLIn;
	realBol : CM_BOL;
begin

	if (not self.validateCriteria()) then
		return false;
	endif;
	
	//epr TFS 7725 7/11/17 changed so can be used in RIA/ webservices and does the same
	// partial search will now work with ends with starts with
	
	checkDT := app.actualTimeServer();
	checkDT := checkDT.cnEcAddDays(-LOOKBACKDAYS);	
	checkDT.setTime("00:00:00:00".Time);
	
	self.allTIs.clear();
	
	if self.id &lt;&gt; null then							//16.05.2018 cnwma1 ChangeRequest #38580
		create foundTIs transient;
		foreach tmpTerminal in self.allTerminals do
				
				if site = TI_SITE_ONSITE or site = TI_SITE_UNDEFINED then
					tmpTerminal.lookupAllOnsiteTrackedItems(self.cargoType,self.id,foundTIs,self.canDoPartialMatch,null);
					tmpTerminal.lookupAllNotifiedOnsiteTIs(self.cargoType,self.id,foundTIs,self.canDoPartialMatch,null); // 01 Jun 2018 cnwma1	Bug 38540
				endif;
					
				if site = TI_SITE_OFFSITE or site = TI_SITE_UNDEFINED then
					tmpTerminal.lookupAllOffSiteTrackedItems(self.cargoType,self.id, foundTIs,self.canDoPartialMatch,null);
				endif;
				
				if site = TI_SITE_TBA  then
					tmpTerminal.lookupAllTBATrackedItems(self.cargoType,self.id, foundTIs,self.canDoPartialMatch,null);
				endif;
				
				if site = TI_SITE_PLACEHOLDER  then	//13 Mar 2020	NDL	TFS 47004
					tmpTerminal.lookupAllRRPTrackedItems(self.cargoType,self.id, foundTIs,null);
				endif;
				
				if site = TI_SITE_ONSHIP or site = TI_SITE_UNDEFINED then
					tmpTerminal.lookupAllOnShipTIsInPortFrom(self.id, self.cargoType,checkDT,foundTIs,self.canDoPartialMatch,null);
				
					if self.searchArchived then
						foreach tmpVoy in tmpTerminal.allVoyagesArchived discreteLock do
							tmpVoy.lookupAllTrackedItems(self.id, self.cargoType,false,self.canDoPartialMatch,foundTIs,null);
						endforeach;
					endif;
				endif;		
		endforeach;
		
		foreach ti in foundTIs discreteLock do
			// Let JSA know we're still doing something
			app.sendHeartbeatIfRequired();
			
			if ti = null then
				continue;
			endif;
			
			if not self.canDoPartialMatch then
				if ti.id &lt;&gt; self.id then
					continue;
				endif;
			endif;	
			
			if self.imexStatus &lt;&gt; TI_IMEX_STATUS_NULL and ti.getImExStatus &lt;&gt; self.imexStatus then
				continue;
			endif;
			
			if self.checkAccess and not ti.canUserAccessSelf(null, tmpDAC,app.myPassport) then
				continue;
			endif;
			
			if not self.allTIs.includes(ti) then
				self.allTIs.add(ti);
			endif;
		endforeach;
	elseif self.booking &lt;&gt; null then
		
		create foundBookings transient;
		foreach tmpTerminal in self.allTerminals discreteLock do
			delete iter;
			iter := tmpTerminal.allBookingRefsByRef.createIterator();
			tmpTerminal.allBookingRefsByRef.startKeyGeq(self.booking, iter);
			while iter.next(bookingRef) do
				if  bookingRef.bookingReference &lt;&gt; self.booking  then
					continue;
				endif;
				
				if self.checkAccess and not bookingRef.canUserAccessSelf(null, tmpDAC,app.myPassport) then
					continue;
				endif;
				foundBookings.add(bookingRef);
			endwhile;
		endforeach;
		
		foreach bookingRef in foundBookings discreteLock do
			foreach  ti in bookingRef.allTIs discreteLock do
				// Let JSA know we're still doing something
				app.sendHeartbeatIfRequired();
				
				if ti = null then
					continue;
				endif;
				
				if self.checkAccess and not ti.canUserAccessSelf(null, tmpDAC,app.myPassport) then
					continue;
				endif;
				if not self.allTIs.includes(ti) then
					self.allTIs.add(ti);
				endif;
			endforeach;
		endforeach;
	
	elseif self.bol &lt;&gt; null then
		create foundBols transient;
		foreach tmpTerminal in self.allTerminals discreteLock do
			bolIn := tmpTerminal.getBOLInByNumber(self.bol, BOLType_GeneralBillOfLading);
			if bolIn &lt;&gt; null then
				if self.checkAccess and not bolIn.canUserAccessSelf(null, tmpDAC,app.myPassport) then
						continue;
				endif;
				foundBols.add(bolIn);
			endif;
		endforeach;
		
		foreach realBol in foundBols discreteLock do
			if realBol.isKindOf(CM_BOLIn) then
				foreach  ti in realBol.CM_BOLIn.allTrackedItems discreteLock do
					// Let JSA know we're still doing something
					app.sendHeartbeatIfRequired();
					
					if ti = null then
						continue;
					endif;
					
					if self.checkAccess and not ti.canUserAccessSelf(null, tmpDAC,app.myPassport) then
						continue;
					endif;
					if not self.allTIs.includes(ti) then
						self.allTIs.add(ti);
					endif;
				endforeach;
			endif;
		endforeach;
	endif;
	
	return true;
	
epilog
	delete foundTIs;
	delete foundBookings;
	delete foundBols;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTerminal" id="2b1bc417-0f16-4c7d-a253-4dd663142fa5">
        <updating/>
        <source>setTerminal(_terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     29 August 2007 by cnwrs2
//
// Purpose:     Intially this will only allow search at 1 terminal but
//				have allowed data structure to search for more than one.
// ---------------------------------------------------------------------------
vars

begin
	if _terminal = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_terminal', null, null);
		return;
	endif;
	
	self.allTerminals.clear();
	self.allTerminals.add(_terminal);

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateCriteria" id="2481faad-f8b0-4435-a129-eb8110d30caa">
        <source>validateCriteria() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     29 August 2007 by cnwrs2
//
// Purpose:     
//16 May 2018 cnwma1	ChangeRequest 38580: Public page - search by BOL and Booking
vars
	minCharForSearch 	: Integer;
	term				: CM_Terminal;
begin
	if self.booking = null and self.bol = null then  //16.05.2018 cnwma1 ChangeRequest #38580
		if self.id = null then
			// put this error into CMIF controller
			app.raiseCMException(Input_required_field_cargoId, ETRow_Id, null);
			return false;
		endif;
	endif;
	
	//17/09/2025	navkc1 JIRA 35860 - In case of multiple terminals, take the least amount.
	foreach term in self.allTerminals do
		if minCharForSearch &lt;&gt; null then
			minCharForSearch := minCharForSearch.min(term.getConfig(WpMinCharPartialSearch).Integer);
		else
			minCharForSearch := term.getConfig(WpMinCharPartialSearch).Integer;
		endif;
	endforeach;
	
	//17/09/2025	navkc1 JIRA 35860
	if minCharForSearch &lt;&gt; null then
		if self.id &lt;&gt; null then
			if self.id.length() &lt; minCharForSearch then
				app.raiseCMException1(MinCharToPerformSearch, minCharForSearch.String, null, null);
				return false;
			endif;
		elseif self.booking &lt;&gt; null then
			if self.booking.length() &lt; minCharForSearch then
				app.raiseCMException1(MinCharToPerformSearch, minCharForSearch.String, null, null);
				return false;
			endif;
		elseif self.bol &lt;&gt; null then
			if self.bol.length() &lt; minCharForSearch then
				app.raiseCMException1(MinCharToPerformSearch, minCharForSearch.String, null, null);
				return false;
			endif;
		endif;
	endif;
	
	return true;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
