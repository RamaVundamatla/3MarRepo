    <JadeMethod name="addRoleToMaintTable" id="ee36caf1-8c91-4ef1-87e2-1c2388bc133d">
        <source>addRoleToMaintTable( _row : Integer;  _role : CM_SecurityRole; _level : Integer; _selected, _subItemSelected, _visible : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 February 2018	jlgndl1	Initial creation	TFS 36947

*/

constants

	Indent : String = "   ";
vars

	baseColumn : Integer;
	plusMinus : String;
	selected : String;
	padding : String;
	index : Integer;

begin

	if _level &lt; 2 then
	else
		foreach index in 2 to _level do
			padding := Indent &amp; padding;
			padding := padding &amp; ".";
		endforeach;
		padding := padding &amp; " ";
	endif;

	if not _role.allChildRoles.isEmpty then
		plusMinus := "+";
	endif;
	
	if _selected then
		selected := 1.String;
	else
		selected := 0.String;
	endif;
	
	self.tblMaintRoles.accessCell( _row, self.SelectColumn ).inputType := Table.InputType_CheckBox;
	self.tblMaintRoles.accessCell( _row, self.SelectColumn ).text := selected;
	
	self.tblMaintRoles.accessCell( _row, self.ExpandColumn ).inputType := Table.InputType_None;
	self.tblMaintRoles.accessCell( _row, self.ExpandColumn ).text := plusMinus;
	
	self.tblMaintRoles.accessCell( _row, self.DescrColumn ).inputType := Table.InputType_None;
	self.tblMaintRoles.accessCell( _row, self.DescrColumn ).text := padding &amp; _role.name;
	
	self.tblMaintRoles.accessRow( _row ).itemObject := _role;
	self.tblMaintRoles.accessRow( _row ).visible := _visible;
	
	if _selected then
		self.tblMaintRoles.accessRow( _row ).backColor := Grey; //self.ColourYellowDark;
	elseif _subItemSelected then
		self.tblMaintRoles.accessRow( _row ).backColor := self.colorRow1;//self.ColourYellowLight;
	else
		self.tblMaintRoles.accessRow( _row ).backColor := self.tblMaintRoles.backColor;
	endif;

epilog

end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_role" type="CM_SecurityRole"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_selected" type="Boolean"/>
        <Parameter name="_subItemSelected" type="Boolean"/>
        <Parameter name="_visible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addRoleToTreeView" id="c391d3b7-4402-4321-bed3-7fc59bc0f2ae">
        <source>addRoleToTreeView(_role : CM_SecurityRole; _level : Integer);
// ---------------------------------------------------------------------------
// Created:     19 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	child	: CM_SecurityRole;
	sortbyname : CM_SecurityRoleDict;
begin
	create sortbyname transient;
	
	self.addTreeObject(self.lstDataDisplayRow(_role), _role, _level, (_level &lt;= 2));
	self.cmbParentRole.addItemObject(self.lstDataDisplayRow(_role), _role);
	
	
	_role.allChildRoles.copy(sortbyname); // TFS 2198
//	foreach child in _role.allChildRoles do // TFS 2198
	foreach child in sortbyname do // TFS 2198
		self.addRoleToTreeView(child, _level + 1);
	endforeach;
	
epilog
	delete sortbyname;
end;</source>
        <Parameter name="_role" type="CM_SecurityRole"/>
        <Parameter name="_level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="adfd7e86-8a61-40b1-aaf7-4a7cfb2648c6">
        <updating/>
        <source>addToolbarControls() updating, protected;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 26 September 2003
//
//-----------------------------------------------------------------------

vars
	toolbar	: CMUI_Toolbar;
	
begin

	inheritMethod();

	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnRootReset, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShowFilter, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnResetFilter, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnAllowAll, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnDisallowAll, CMUI_Toolbar.Control_Alignment_Left);	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="amendPermissions" id="5045e8c4-b928-4094-8fc6-e8b993fdbe00">
        <updating/>
        <source>amendPermissions(_permissions : BooleanArray input) updating;
// ---------------------------------------------------------------------------
// Created:		10 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	if self.viewMode = ViewSystem then
		//ammend system permissions	
	
	else
		//ammend terminal permissions	
		// CCMS 1350
		if _permissions[PmHMSResUsedFull] = true then
			_permissions[PmHMSResUsedPartial] := true;
			_permissions[PmHMSResUsedView] := true;
		elseif _permissions[PmHMSResUsedPartial] = true then
			_permissions[PmHMSResUsedView] := true;
		else
			_permissions[PmHMSResUsedView] := true;
		endif;
	endif;
	
end;</source>
        <Parameter name="_permissions" type="BooleanArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnAllowAll_click" id="53baac12-568d-49c1-90ab-8c1573771608">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAllowAll_click(btn: Button input) updating;

vars

	iter : Iterator;
	permObj : CM_PermissionObject;
	r : Integer;
begin
	iter := self.myPermissionAgent.allPermsByCategoryDescrName.createIterator;
	self.myPermissionAgent.allPermsByCategoryDescrName.startKeyGeq(null, null, null, iter);
	while iter.next(permObj) do		
	permObj.permValue := true;
	endwhile;
	
	foreach r in 2 to tblPermissions.rows do
		tblPermissions.row := r;
		permObj := tblPermissions.itemObject.CM_PermissionObject;
		tblPermissions.text := "1";
	endforeach;

epilog
	delete iter;
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDisallowAll_click" id="5e03a483-2a6e-4803-9e51-aebd5fb06008">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDisallowAll_click(btn: Button input) updating;

vars

	r : Integer;
	iter : Iterator;
	permObj : CM_PermissionObject;
begin
	iter := self.myPermissionAgent.allPermsByCategoryDescrName.createIterator;
	self.myPermissionAgent.allPermsByCategoryDescrName.startKeyGeq(null, null, null, iter);
	while iter.next(permObj) do		
	permObj.permValue := false;
	endwhile;
	
	foreach r in 2 to tblPermissions.rows do
		tblPermissions.row := r;
		permObj := tblPermissions.itemObject.CM_PermissionObject;
		tblPermissions.text := "0";
	endforeach;

epilog
	delete iter;
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnResetFilter_click" id="b10195ac-6e06-41e3-a86e-1de1c722ba69">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnResetFilter_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2018	jlger1	Initial creation

*/

vars

begin
	if self.isFiltering then
		self.setIsFiltering(false);
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
