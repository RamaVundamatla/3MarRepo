    <JadeMethod name="setExtras" id="0f2b8143-bd16-46f8-9144-75b918e6df1e">
        <updating/>
        <source>setExtras(_authKey, 
			_clientKey,
			_clientSecret,
			_exportDetails,
			_scope,
			_subKeyName,
			_subKeyValue,
			_tenantId : String;
			_isForCams : Boolean;
			_baseAuthEndPoint : String;
			_oAuth2Version  : Integer;
			_resource : String;
			_customer : String;
			_terminal : CM_Terminal) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/01/2023	navdap1		Initial creation TFS 55159 MTN Export CAMS to JSON API Endpoint
// 04/09/2024	jlier1		TFS 65949 
// 04 Feb 2025 naviv1  JIRA-12173 : MTN - JSON CAM Protocol and APIConsumerAgent hard codes EUP as the customer
// 05 Sep 2025	navnk30 	JIRA 35707: 4 - YARA | Create a new web service definition to use to send out AG Gateway messages
vars

begin
	self.authKey := _authKey;
	self.clientKey := _clientKey;
	self.clientSecret := _clientSecret;
	self.exportDetails := _exportDetails;
	self.scope := _scope;
	self.subscriptionKeyName := _subKeyName;
	self.subscriptionKeyValue := _subKeyValue;
	self.tenantId := _tenantId;
	
	self.isForCams := _isForCams;
	self.baseAuthEndpoint:=_baseAuthEndPoint;
	self.oAuth2Version:=_oAuth2Version;
	self.resource:=_resource;
	if app.isSpecial() then
		self.setCustomer(_customer);	//04-Feb-2025 naviv1 MTN-12173
	endif;
epilog

end;</source>
        <Parameter name="_authKey" type="String"/>
        <Parameter name="_clientKey" type="String"/>
        <Parameter name="_clientSecret" type="String"/>
        <Parameter name="_exportDetails" type="String"/>
        <Parameter name="_scope" type="String"/>
        <Parameter name="_subKeyName" type="String"/>
        <Parameter name="_subKeyValue" type="String"/>
        <Parameter name="_tenantId" type="String"/>
        <Parameter name="_isForCams" type="Boolean"/>
        <Parameter name="_baseAuthEndPoint" type="String"/>
        <Parameter name="_oAuth2Version" type="Integer"/>
        <Parameter name="_resource" type="String"/>
        <Parameter name="_customer" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7ee9a2ed-4daa-41c6-ac13-ca2c97116a79">
        <updating/>
        <source>setForUpdate(_extWebService: CM_APIEndpointServiceDef) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/01/2023	navdap1		Initial creation TFS 55159 MTN Export CAMS to JSON API Endpoint
// 09/09/2024	navdap1		TFS 66034 NSW OnePort Integration Post-Dev Demo Issues
// 11/09/2024	jlier1		TFS 65949 
// 22/10/2024	navdap1		MTN-14005 NSW | OnePort Integration - Requested Changes
// 04 Feb 2025 	naviv1  	JIRA-12173 : MTN - JSON CAM Protocol and APIConsumerAgent hard codes EUP as the customer
vars

begin
	self.authKey				:= _extWebService.authKey;
	self.clientKey 				:= _extWebService.clientKey;
	self.clientSecret 			:= _extWebService.clientSecret;
	self.exportDetails 			:= _extWebService.exportDetails;
	self.isForCams				:= _extWebService.isForCams;
	self.scope 					:= _extWebService.scope;
	self.subscriptionKeyName 	:= _extWebService.subscriptionKeyName;
	self.subscriptionKeyValue 	:= _extWebService.subscriptionKeyValue;
	self.tenantId 				:= _extWebService.tenantId;
	self.resource				:=_extWebService.resource;
	self.baseAuthEndpoint		:=_extWebService.baseAuthEndpoint;
	self.oAuth2Version			:=_extWebService.oAuth2Version;
	if app.isSpecial() then
		self.setCustomer(_extWebService.customer);  //04-Feb-2025 naviv1 #12173
	endif;
	if self.oAuth2Version = 0 or self.oAuth2Version &gt; 2 then //default to version 2
		self.oAuth2Version:=2;
	endif;
	// MTN-14005 For NSW's temporary connection, we need a way to not append any oauth string to the authorisation endpoint
	// Use a oAuth version of 0 here to do that
	if self.baseAuthEndpoint &lt;&gt; null and app.myRoot.canDoEDIFileType(EDIFileType_JSONOnePortVoyage) and not self.isInvoiceAPIDef then
		self.oAuth2Version := 0;
	endif;
	// MTN-14005 end
	
	//self.lastSuccessfullTS		:= _extWebService.lastSuccessfullTS;		// TFS 66034            //MTN-36366 - replaced with terminal level TS
	
	inheritMethod(_extWebService);
epilog

end;</source>
        <Parameter name="_extWebService" type="CM_APIEndpointServiceDef"/>
    </JadeMethod>
    <JadeMethod name="setLastSuccessfulTS" id="cfc06a80-db64-47c8-a31e-5fb33e7e2f40">
        <updating/>
        <source>setLastSuccessfulTS(_timeStamp: TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2024	navsp1	Initial creation TFS ChangeRequest 63842: NSW | OnePort Integration Dev

*/

begin
	self.lastSuccessfullTS := _timeStamp;
end;</source>
        <Parameter name="_timeStamp" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setLastSuccessfulTSByTerminal" id="1d3e5986-09d1-4f56-9a24-f3ae55fbd9ec">
        <updating/>
        <source>setLastSuccessfulTSByTerminal(_timeStamp: TimeStamp; _terminal: CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Dec 2025	navah1	Initial creation
09 Dec 2025	navah1	MTN-36364: NSW | OnePort API Last Run Date - Automatically add a new terminal to the list
*/
vars
	terminalLastSuccessDT : CM_EWSTerminalLastSuccessDT;
begin
	if _terminal = null then
		return;
	endif;
	
	terminalLastSuccessDT := self.allTerminalLastSuccessDT[_terminal.code];

    if terminalLastSuccessDT = null then
		create terminalLastSuccessDT persistent;
    endif;

	terminalLastSuccessDT.setProxy(_timeStamp, self, _terminal);
end;</source>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="626d6ae3-f443-4d1b-8cb4-edadf1a46998">
        <source>validateMe() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2024	navsp1	Initial creation TFS 66166

*/

vars

begin
	inheritMethod();
	if self.subscriptionKeyName &lt;&gt; null and self.subscriptionKeyValue = null then
		app.raiseCMException1(Input_required_field_Required, app.getString(Subscription_key_value), self.subscriptionKeyValue, null);
	endif;
	
	if self.subscriptionKeyName = null and self.subscriptionKeyValue &lt;&gt; null then
		app.raiseCMException1(Input_required_field_Required, app.getString(Subscription_key_name), self.subscriptionKeyName, null);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
