    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sysops"/>
    <JadeMethod name="create" id="efd691d7-1347-49ad-911c-c778212f8faa">
        <updating/>
        <source>create() updating;
/*

Date		Who		Reason
29 September 2015	cnwer1	Initial creation PAR 36958

*/

vars

begin
	self.name :=SOP_TableMaintForm.Table_InvoiceStatusReason;
	self.permissionView  := PmAdmInvoicelistView;
	self.permissionMaint := PmAdmInvoicelistMaint;
	self.myDataClass := CM_InvoiceStatusReason;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="66c92dab-db4a-4a57-830b-9d03500bd39c">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Date		Who		Reason
29 September 2015	cnwer1	Initial creation PAR 36958

*/

vars
	realReason,
	proxyReason : CM_InvoiceStatusReason;
	theForm 					: SOP_TableMaintForm;
	code,description			: String;
	isNotAvailableForEntry		: Boolean;
begin
	theForm := self.myForm; 
	
	proxyReason:=theForm.myProxyObject.CM_InvoiceStatusReason;
	if proxyReason = null then
		create proxyReason transient;
		theForm.myProxyObject:=proxyReason;
	endif;
	
	
	code := theForm.tblInput1.getValueByName(ETRow_Code).asStringJMT;
	description := theForm.tblInput1.getValueByName(ETRow_Description).asStringJMT;
	isNotAvailableForEntry := theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;
	
	proxyReason.setProxy(code,description,isNotAvailableForEntry,theForm.myTerminal);
	
	if theForm.mode = SOP_TableMaintForm.Mode_Add then
		app.myTrxCA.trxCreateInvoiceStatusReason(proxyReason,realReason,app.myPassport);
	else
		app.myTrxUA.trxUpdateInvoiceStatusReason(proxyReason,app.myPassport);
	endif;
	return app.myPassport.trxCompletedOK();
epilog
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="bed9e4db-8b73-438d-a8a9-f2109e2b442c">
        <source>getCollection(): Collection;
/*

Date		Who		Reason
29 September 2015	cnwer1	Initial creation PAR 36958

*/

vars

begin
	return self.myForm.myTerminal.allInvoiceStatusReasons;

epilog

end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="6da54366-8a15-4f5a-89e6-62b6d4e6756a">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Date		Who		Reason
29 September 2015	cnwer1	Initial creation PAR 36958

*/

vars

begin
	self.myForm.tblInput1.userInputEnabled := true;

	self.myForm.tblInput1.setFocus;
	self.myForm.tblInput1.moveFirst();
	
epilog

end;</source>
    </JadeMethod>
