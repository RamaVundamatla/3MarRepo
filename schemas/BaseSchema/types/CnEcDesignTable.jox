    <JadeMethod name="getThisObjectsRow" id="ae7aee10-1091-4839-9ad1-0086004d5745">
        <updating/>
        <source>getThisObjectsRow(obj : Object) : Integer updating;

vars
	loopIndex				: Integer;
	maxIndex				: Integer;
	saveCol					: Integer;
begin
	saveCol := self.column;
	self.column := 1;
	loopIndex := 2;
	maxIndex  := self.rows;
	while loopIndex &lt;= maxIndex do
		self.row := loopIndex;
		if self.itemObject = obj then
			return(loopIndex);
		endif;
		loopIndex := loopIndex + 1;
	endwhile;
	return(1);
epilog
	self.column := saveCol;
end;</source>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="c9d8a03b-8c31-4cdf-bc39-f23c30ebc61b">
