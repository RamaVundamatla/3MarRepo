    <JadeMethod name="addToolbarControls" id="38afad3c-97d7-42ea-b45a-bead00866930">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2018	jlgndl1	Initial creation	TFS 42116

*/

vars

	frm : CMUI_Toolbar;

begin

	frm := self.frmToolbar;
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExportCSVQE, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnActivity, CMUI_Toolbar.Control_Alignment_Left);
	
	inheritMethod();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
