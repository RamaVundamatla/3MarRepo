    <JadeMethod name="validateForUpdate" id="2bd7b247-0696-42ed-92c6-9496b3eb4d04">
        <source>validateForUpdate();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/12/2016	cnwdap1		Initial creation TFS 3039 MT Container Pool Management
