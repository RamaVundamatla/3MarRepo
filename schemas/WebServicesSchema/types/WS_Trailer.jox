    <JadeMethod name="setProxyFromObject" id="1eee3b14-f50d-455e-b80d-347802f70f14">
        <updating/>
        <source>setProxyFromObject(_object: CM_TILC) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 August 2021	jlier1	Initial creation TFS 51879
14 Mar 2023		jlika1	TFS 57042 Enter Highest Cargo Height from MAFI load/unload app
14 Nov 2023 	jlier1 	TFS 66160
12 Feb 2024		jlizm1	TFS 62219 Unit conversions happening at wrong stage
*/

vars
	measurement : CM_MeasurementType;
begin
	inheritMethod(_object);
	self.regNumber:=_object.id;
	self.cargoTypeDesc:=_object.cargoTypeDescr;
	if _object.jobRoadRelease &lt;&gt; null then
		if _object.jobRoadRelease.myVehicle &lt;&gt; null then
			self.releaseTruckOid:=_object.jobRoadRelease.myVehicle.getOidAsString;
		endif;
	endif;
	if _object.myTILCType &lt;&gt; null then
		self.maxWeight:= _object.myTILCType.getMaxWeightDisplay; // jlier1 TFS 54703 22/9/22
	endif;
	self.weightLoaded :=  app.getWeightForDefaultDisplay(_object.weightCargo); //jlier1 TFS 54703 23/9/22
	
	self.height 	:= _object.height.asStringJSON();
	self.overHeight	:= _object.overHeight.asStringJSON();
	self.overLength := _object.overLength.asStringJSON();
	self.overWidth	:= _object.overWidth.asStringJSON();
	
	self.contentsStatus:=_object.getContentsStatus;
	self.contentsStatusDesc:=_object.getContentsStatusDesc(true);
epilog

end;</source>
        <Parameter name="_object" type="CM_TILC"/>
    </JadeMethod>
</Class>
