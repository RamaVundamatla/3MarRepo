    <JadeMethod name="setCSTIDetails" id="630e1440-0f3f-4038-b5c3-d18fc9ae066f">
        <updating/>
        <source>setCSTIDetails(
	_voyageCode,
	_vesselName,
	_entryNumber,
	_entryNumberEdition,
	_responseStatus,
	_desc,
	_consignor,
	_consignee,
	_customsAgent,
	_clientRef			: String;
	_fileDate			: Date;
	_fileTime			: Time;
	_seqNumber,
	_msgRef				: String ) updating;
	
//----------------------------------------------------------------
//	Created:	06 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 07/03/2013	cnwcs5	CCMS POL 2097 / par 31259 - include _foundMatch in method signatures
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 31 Mar 2025	naviv1	MTN-33684 SNO | CUSRES EDI - UNH03 Segment field length Dev Changes
vars
	vesselObj				: CM_Vessel;
	voyageObj				: CM_Voyage;
	matchDate				: TimeStamp;
	vesselCode				: String;
	foundMatch, 
	cusresUNHIsCondition	:Boolean;
	terminal				: CM_Terminal;
begin
	terminal := self.getMyTerminal();
	cusresUNHIsCondition := terminal.getConfig(CusresUNHIsCondition).Boolean; //JIRA-33684
	
	if self.myEDIFile &lt;&gt; null then
		//we need to take the actual message generation date off the sent message and use this in next version
		matchDate	:=	self.myEDIFile.createdTime;
	else
		matchDate	:=	self.createdTime;
	endif;

	// make sure the manual collection on CM_EDIConfig gets maintained
	self.setVoyageCode( _voyageCode );
	self.vesselName	:=	_vesselName;
	
	if _responseStatus = Customs_Deliver_BreakBulk then
		//important for Cars which are matched by BOL number (BOL number is only unique within a voyage)
		// cnwrl1 11/11/2010 PAR 26099 - replacement coding
		vesselObj	:= app.myRoot.getVesselByName( _vesselName );
		if vesselObj &lt;&gt; null then
			vesselCode	:=	vesselObj.code;
		endif;

		
		if vesselCode = null then
			// CCMS 1038 can't find a vessel for that vessel name so see if there a translation for that vessel
			vesselCode := app.myRoot.getXlationSystemCode(_vesselName.trimBlanks(), XLATION_TYPE_VESSEL, foundMatch);	// par 31259 March 2013
		endif;
		
		if vesselCode &lt;&gt; null then
			voyageObj	:=	self.getMyTerminal.getVoyageFromVesselCusRes(vesselCode, matchDate);
			if voyageObj &lt;&gt; null then
				self.setVoyage(voyageObj); //par 12685 cnwrs1 oct 2006
			endif;
		endif;
	endif;
	
	// CCMS 1559
	self.entryNumber 	:=	_entryNumber[1:30];
	self.responseStatus	:=	_responseStatus;
	self.description	:=	_desc;
	self.consignor		:=	_consignor[1:30];
	self.customsAgent	:=	_customsAgent[1:30];
	self.consignee		:=	_consignee[1:30];
	if cusresUNHIsCondition then
		self.clientRef		:=	_clientRef[1:35];
	else
		self.clientRef		:=	_clientRef[1:30];
	endif;
	
	if _fileDate.isValid() then
		self.fileDateTime.setDate(_fileDate);
		self.fileDateTime.setTime(_fileTime);
	endif;
	
	self.sequenceNum	:=	_seqNumber[1:20];
	
	if _msgRef.isInteger() then
		self.messageNum	:=	_msgRef.Integer;
	endif;
end;
</source>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_entryNumber" type="String"/>
        <Parameter name="_entryNumberEdition" type="String"/>
