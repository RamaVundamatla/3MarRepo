    <JadeMethod name="setContractId" id="32ea3db2-bbdf-4597-b3fb-9b4d10f12e9e">
        <updating/>
        <source>setContractId(_contractId : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
21 January 2023	navvt20		TFS CR 55625 Task 55658: Contract ID TRX 
13-03-2023 navtnr20 		Task 56818: Jade - Set Contract Ids on Invoice
*/

vars
	invoice : CM_Invoice;
begin
	if _contractId= null then
		return;
	endif;
	
	/*
	if self.contractIds.pos(_contractId, 1) = 0 then
		if self.contractIds = null then
