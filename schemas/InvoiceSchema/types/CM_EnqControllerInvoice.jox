<Class name="CM_EnqControllerInvoice">
    <JadeMethod name="isInContext" id="438f48ff-cbdb-477a-b38d-455a4d461f27">
        <source>isInContext(_value: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/04/2024	navkc1 CR63383 Task 63384: Jade - Improved invoice queries

*/

vars

begin
	if _value = self.InvoiceListForm then
		if self.myContext &lt;&gt; null and self.myContext.isKindOf(INV_ListInvoices) then
			return true;
		endif;
	endif;
	
	return inheritMethod(_value);
	
epilog

end;</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
