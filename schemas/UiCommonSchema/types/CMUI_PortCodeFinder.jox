    <JadeMethod name="btnSearch_click" id="489cbe3b-a462-4948-a905-999d83ba2b9f">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSearch_click(btn: Button input) updating;

vars

begin

	app.mousePointer := MousePointer_HourGlass;
	self.doLocodeSearch();
epilog	
	
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
