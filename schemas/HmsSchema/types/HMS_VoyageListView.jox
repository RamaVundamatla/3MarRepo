    <JadeMethod name="setCurrentVoyage" id="5fbaf1c8-4bf9-4915-b361-ac0bc78cf98a">
        <updating/>
        <source>setCurrentVoyage(voyage : CMIF_HMS_WorkingVoyage) updating;

vars
  	currentPosn: 	Integer;
  	count:		  	Integer;
  	obj:			Object;
begin
	// Highlight newly selected voyage in this view

	if voyage&lt;&gt;null then
		count:=1;
		while count&lt;=lbxVoyageTree.listCount do
        	obj:=lbxVoyageTree.itemObject[count];
        	if obj.isKindOf(CMIF_HMS_WorkingVoyage) then
        		if obj.CMIF_HMS_WorkingVoyage=voyage then
        			// SET COLOURS TO SELECTED VOYAGE
        			lbxVoyageTree.itemBackColor[count]:=VoyageSelectedSaved;	
        		else
        			lbxVoyageTree.itemBackColor[count]:=White;	
        		endif;
        	elseif obj.isKindOf(CMIF_HMS_WorkingMovement) then
        		if obj.CMIF_HMS_WorkingMovement.myWorkingVoyage=voyage then
        			// SET COLOURS TO SELECTED VOYAGE	
        			lbxVoyageTree.itemBackColor[count]:=VoyageSelectedSaved;
        		else
        			lbxVoyageTree.itemBackColor[count]:=White;	
        		endif;
        	endif;
        	count:=count+1;
		endwhile;
		// Highlight selected voyage
		currentPosn:=lbxVoyageTree.findObject(voyage);
		if currentPosn&gt;0 then
			lbxVoyageTree.listIndex:=currentPosn;
		endif;

	endif;
end;</source>
        <Parameter name="voyage" type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="setSelectedMovement" id="f43f61a5-20d4-49db-a40a-b6ac43f0cbb3">
        <updating/>
        <source>setSelectedMovement(movement : CMIF_HMS_WorkingMovement) updating;

vars
  	currentPosn: Integer;
begin
	// Highlight newly selected movement in this view
	if movement&lt;&gt;null then
		currentPosn:=lbxVoyageTree.findObject(movement);
		if currentPosn&gt;0 then
			lbxVoyageTree.listIndex:=currentPosn;
			if lbxVoyageTree.itemExpanded[lbxVoyageTree.listIndex]=false then
				lbxVoyageTree.itemExpanded[lbxVoyageTree.listIndex]:=true;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="movement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="6c28e528-dad3-471b-8d66-3712eeb7224a">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	15 August 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	if (not app.myCurrentUserCan(self.myTerminal, PmHMSGraphicalMaint)) then
		self.btnDelete.enabled := false;
		self.btnNew.enabled := false;
		self.btnEdit.enabled := false;		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showVoyageMaintenance" id="714d49c0-641e-4db5-9db2-649aeb3d0427">
        <updating/>
        <source>showVoyageMaintenance(_workingVoyage : CMIF_HMS_WorkingVoyage)updating;
//-----------------------------------------
// Created: January 2004 By: cnwgd1
//-----------------------------------------
vars
	realVoyage : CM_Voyage;
begin
	if _workingVoyage &lt;&gt; null then
		realVoyage := _workingVoyage.ofPermanentVoyage;
	endif;
	if realVoyage &lt;&gt; null then
		self.myAssistant.showVoyageDefForm(realVoyage, self.myMasterMenuAction, true, false);
	else
		self.myAssistant.showVoyageDefForm(null, self.myMasterMenuAction, true, false);
	endif;					
end;</source>
        <Parameter name="_workingVoyage" type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
