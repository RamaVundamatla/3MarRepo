<GUIClass name="CMUI_RowInputDisplayFrame" id="090254dd-b989-48d4-a12e-2d4d4d33fc1c">
    <superclass name="Frame"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="myRowFrame" id="9d01a994-03df-4528-9c99-b11d1c36a377">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CMUI_RowFrame"/>
        <Inverse name="CMUI_RowFrame::frmInput"/>
    </ExplicitInverseRef>
    <JadeMethod name="click" id="b7797355-cdfc-4741-b267-89e19a5c6767">
        <controlMethod name="Frame::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(frame: CMUI_RowInputDisplayFrame input) updating, clientExecution;
//----------------------------------------------------------------
//	Created:	06 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(frame);

	if self.parent.isKindOf(CMUI_RowFrame) then
		self.parent.CMUI_RowFrame.handleInputDisplayFrmClick(frame);
	endif;

end;</source>
        <Parameter name="frame" type="CMUI_RowInputDisplayFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleComboLostFocus" id="1505507d-54a7-4c42-b1cd-81255d6afc10">
        <source>handleComboLostFocus(_cmb: CMUI_ComboBox);
//----------------------------------------------------------------
//	Created:	07 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.myRowFrame &lt;&gt; null then
		self.myRowFrame.handleComboLostFocus(_cmb);
	endif;

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox"/>
    </JadeMethod>
