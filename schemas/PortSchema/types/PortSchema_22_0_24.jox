    <JadeMethod name="updateWorkPointandType" id="188eed6d-4fb7-4aac-a1c8-0584ffbbee10">
        <source>updateWorkPointandType(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2023	navhl20	ChangeRequest 57712:[54558] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars
	terminal 			: CM_Terminal;
	workPointType,
 	pxyWorkPointType	: CM_WorkPointType;
	workPoint			: CM_WorkPoint;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Update Work Point ", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Update Work Point ") ;	
	endif;
	
	beginTransaction;
	
	foreach terminal in app.myRoot.allTerminals do
		workPointType := terminal.allWorkPointTypes[WORK_POINT_TYPE_SHIP,'SHIP'];
		if workPointType = null then
			workPointType := terminal.createWorkPointTypeShip();
		endif;
		
		if workPointType &lt;&gt; null then
			foreach workPoint in terminal.allWorkPointsByCode do
				workPoint.setMyWorkPointType(workPointType);
			endforeach;
		endif;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Update Work Point completed ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Update Work Point completed") ;	
	endif;	
	
	self.addScriptRun(method.name);
epilog

end;</source>
