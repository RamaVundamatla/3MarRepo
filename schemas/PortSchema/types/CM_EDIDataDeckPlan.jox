    <JadeMethod name="getTILocation" id="71191aef-a36c-4cee-9026-3946c03cf1f4">
        <source>getTILocation(_realTI : CM_TrackedItem; _mode : Integer) : String;
//
//07 Nov 2012	cnwrs1	Par 30688 OOTL layouts are missing for proposed
//
//10 Dec 2012	cnwrs1	Par 30873	EDI RORO Deck Plan extract in location order
//14 Dec 2012	cnwrs1	Par 30907	EDI RORO Proposed Deck Plan Location ID not position ID
vars
	locationId : String;
	lc : CM_LocationsController;
	sc : CM_ROROSlotController;
begin
	lc := _realTI.getPrimaryLocation(_mode);
	if lc.isKindOf(CM_ROROSlotController) then
		sc := lc.CM_ROROSlotController;
		if _mode = PLANNING_MODE then
			if sc.myRORORequestLoad &lt;&gt; null and
			   sc.myRORORequestLoad.myLayout &lt;&gt; null then
				if sc.mySlotDefn &lt;&gt; null and
				   sc.mySlotDefn.myROROLocnDen &lt;&gt; null then
					if sc.mySlotDefn.myROROLocnDen.isOOTLLocn then
						locationId := sc.myRORORequestLoad.myLayout.code;
					else
						locationId := sc.mySlotDefn.code;
					endif;
				endif;
			endif;
		elseif _mode = REAL_MODE then
			if sc.mySlotDefn &lt;&gt; null and
			   sc.mySlotDefn.myROROLocnDen &lt;&gt; null then
				if sc.mySlotDefn.myROROLocnDen.isOOTLLocn then
					locationId := sc.getDefn().code;
				else
					locationId := sc.mySlotDefn.code;
				endif;
			endif;
		endif;
	endif;
	if locationId = null then
		if _mode = PLANNING_MODE then
			locationId := _realTI.plannedLocnId; //but 2 unreliable
		elseif _mode = REAL_MODE then
			locationId := _realTI.locationId; //but 2 unreliable
		endif;
	endif;
	return locationId;
end;

</source>
        <Parameter name="_realTI" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIRealLocation" id="5f04d03f-6c40-4c41-9913-515dfeed098b">
        <source>getTIRealLocation(_realTI : CM_TrackedItem) : String;
//
// 02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
//
vars
	locationId : String;
	lc : CM_ROROSlotController;
	deckItem : CM_DeckItem;
begin
	if _realTI.myPrimaryActualLocation.isKindOf(CM_ROROSlotController) then				// 09/08/2012 cnwmh5 #30077
		lc := _realTI.getPrimaryLocation(REAL_MODE).CM_ROROSlotController;
		deckItem := lc.getDefn();
		if not deckItem.CM_ROROLocnDefnVoyage.isOOTLLocn then
			locationId := _realTI.locationId;
		else
			locationId := deckItem.code;
		endif;
	else
		locationId := _realTI.locationId; //but 2 unreliable
	endif;
	return locationId;
end;
</source>
        <Parameter name="_realTI" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVesselName" id="e0f3e019-b3c8-4c22-b66a-95cdf4508c8a">
        <source>getVesselName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	vCode: String;
	terminal: CM_Terminal;
	voyage: CM_Voyage;
begin
	vCode := self.getVoyageCode;
	terminal := self.getMyTerminal;
	if vCode &lt;&gt; null and terminal &lt;&gt; null then
		voyage := terminal.lookupVoyage(vCode, null, false);
		if voyage &lt;&gt; null then
			return voyage.vesselName;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="80fbf150-3175-4a65-b8d1-60c37fa1a546">
        <source>getVoyage():CM_Voyage;
/*
Date		Who		Reason
24 May 2012	cnwcs5	Initial creation - par 29583
*/
vars
	ediTI	:CM_EDITrackedItem;
	code	:String;
	voyage	:CM_Voyage;
begin
	foreach ediTI in self.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDIVoyageHeaderTI) do
		code 	:= ediTI.CM_EDIVoyageHeaderTI.getVoyageCode();
		break;
	endforeach;

	voyage 	:= self.getMyTerminal().allVoyagesByCode.getAtKeyGeq(code, null);

	if voyage.code &lt;&gt; code then
		return null;
	endif;
	
	return voyage;
epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="dc9ee567-f9cf-4c0c-be80-d739b2c2822e">
        <source>getVoyageCode(): String;
// ---------------------------------------------------------------------------
// Created:     13 seopt 2011 cnwrs1 
// Purpose:     CCMS 1150 RORO Ship manifest  
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//24 Apr 2012	cnwrs1	Par 29476 - When a Voyage is not defined "Will Be Planned" and "Will Be Planned" the RORO Deck Plan nor the RORO Stowage Advice will fail verification.
// ---------------------------------------------------------------------------
vars
	ediTI : CM_EDITrackedItem;
begin
	if self.allEDITrackedItems.size &gt; 0 then
		foreach ediTI in self.allEDITrackedItems where ediTI.isKindOf(CM_EDIVoyageHeaderTI) do
			return ediTI.getVoyageCode();
		endforeach;
	endif;
	
	return inheritMethod();
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageETA" id="3d7ce102-8612-4d46-85dd-a72efe3dc5bd">
        <source>getVoyageETA(): Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	vCode: String;
	terminal: CM_Terminal;
	voyage: CM_Voyage;
begin
	vCode := self.getVoyageCode;
	terminal := self.getMyTerminal;
	if vCode &lt;&gt; null and terminal &lt;&gt; null then
		voyage := terminal.lookupVoyage(vCode, null, false);
		if voyage &lt;&gt; null then
			return voyage.estimatedArrivalDT.date;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
