<CollClass name="CM_YardActivityDict" id="d4c858c3-eb79-4250-ab2a-5e7319b94ea7">
    <loadFactor>66</loadFactor>
    <memberType name="CM_YardActivity"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardActivity"/>
    <MemberKey>
        <property name="CM_YardActivity::type"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_YardActivity::actionTime"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_YardActivity::myTrackedItem"/>
    </MemberKey>
    <JadeMethod name="getLastActivityTypeOf" id="3163870d-f43c-4223-a440-3ba8d54e5dd2">
        <source>getLastActivityTypeOf( _type : Integer ):CM_YardActivity;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	iter : Iterator;
	yardAct : CM_YardActivity;

begin

	if self.isEmpty then
		return null;
	endif;

	iter := self.createIterator;
	while iter.back( yardAct ) do
		if yardAct.type &lt;&gt; _type then
			continue;
		endif;
		return yardAct;
	endwhile;

	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_YardActivity"/>
    </JadeMethod>
</CollClass>
