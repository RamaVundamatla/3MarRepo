//		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
//	endif;	
	// makes sure the operator can use ALL availability grades
	beginTransaction;
	self.clearOperatorCodeGroups(operator, CodeGroup_AvailabilityGrade);
	commitTransaction;
	// this voyage will be used in most files
	self.createVesselVoyage(VoyageName, ShipName, operator);
	self.deleteEDIParty(PARTY1);
	self.deleteEDIParty(PARTY2);
	ediParty := self.createEDIPartyAndRules('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY3, PARTY3, SENDER1, SENDER2, operator, false);
	rules := ediParty.getRulesForFileType(EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	// change voyafge arrival/departure dates so we don't get cutoff errors
	voyage := self.getVoyage(VoyageName);
	if voyage &lt;&gt; null then
		ts1.setDate (ts1.date+7);
		beginTransaction;
		voyage.setArrivalDT (ts1);
		voyage.setDepartureDT (null);
		commitTransaction;
	endif;
	ts1 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	ts2 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	ts1.setDate(ts1.date-2);
	ts1.setTime('09:00'.Time);
	ts2.setDate(ts1.date+1);
	ts2.setTime('15:00'.Time);
	self.setTerminalConfig(EdiReleaseAllowPartial, false);
	self.setTerminalConfig(EdiBookingAllowPartial, false);

