    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="myCriteriaLineBoolean" id="4c1c4afc-52d0-4abf-a1e8-9e08a5673651">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="RT_CriteriaLineBoolean"/>
        <access>readonly</access>
        <Inverse name="RT_CriteriaLineBoolean::myOptBtnTrue"/>
        <Inverse name="RT_CriteriaLineBoolean::myOptBtnFalse"/>
    </ExplicitInverseRef>
    <JadeMethod name="setForCreate" id="d78373eb-055a-4944-a3e4-0d26476f7eb5">
        <updating/>
        <source>setForCreate( 	_form : RadioTelemetryMainForm input; _name : String; _value : Boolean;
				_parent : Control; _top : Real ) updating;
// -------------------------------------------
// Created 02 may 2008 by cnwvu1
// -------------------------------------------

vars

begin

	self.name	:= _name;
	self.parent	:= _parent;
	self.top	:= _top;
	self.value	:= _value;
	
	_form.addControl( self );
	
end;
</source>
        <Parameter name="_form" type="RadioTelemetryMainForm" usage="input"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_value" type="Boolean"/>
        <Parameter name="_parent" type="Control"/>
        <Parameter name="_top" type="Real"/>
    </JadeMethod>
