    <JadeMethod name="verifyEDIDataTIs" id="67e3add6-037d-4b0b-ad37-0d5a8209ea9b">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
//
// ccms 1976 01 dec 2010 cnwrs1
//
vars

begin
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(true);
	_passport.clearErrorsWarnings();
	//self.processEDITIs(true, _passport); //cnwrs1 par 26223 10 nov 2010
	app.myTrxUA.trxUpdateEDITIPackComplete(self, true, _passport); //jlgzm1 tfs41747 11/12/2018
	return _passport.allErrors.size;
epilog
end;
</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
