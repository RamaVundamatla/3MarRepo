//6/6/2025      navsaa30 MTN-34919 PEN | Event Stream Voyage Information
vars
	xdbFeature  : CMIF_ExternalDBFeature;
begin
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Voyage::archived.name, "CM_Voyage", "archived", "", _features);

