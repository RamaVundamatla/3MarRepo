	/*on Exception do app.handleDeletedObject(exception, self.myCCScreen, isInvalidLAC);
	on Exception do app.handleDeletedObject(exception, self.myCCPalette, isInvalidCC);
	
	self.myTerminal.causeEvent(self.myTerminal.getTerminalEvent(Show_VoyageAllocationsCC),true,self);//cnwas3 par26840a

