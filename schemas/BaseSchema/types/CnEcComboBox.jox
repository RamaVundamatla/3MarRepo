    <JadeMethod name="controlNamePrefix" id="ddb04142-3063-411b-9a6c-89b5bbaad0a7">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		18 November 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "cmb";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="245ed226-eefc-4cb2-93b9-8de5223cd2ba">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.focusColor		:=	self.backColor;
	self.colorNoFocus	:=	self.backColor;
end;</source>
    </JadeMethod>
    <JadeMethod name="getItemValueBinary" id="121c1a49-e939-4da7-9da6-d2f9b6088c1a">
        <source>getItemValueBinary(pItemIndex:Integer):Binary;
// --------------------------------------------------------------------------------
// Created:		07 October 2001 by cnwdad1
//
// Purpose:		Returns the binary item value for the requested index.
//
// Parameters:	pItemIndex - The array index of the item whose value to return.
//
// Returns:		The binary item value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.allItemValues.getBinaryAt(pItemIndex);
end;</source>
        <Parameter name="pItemIndex" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getItemValueString" id="f223247f-8cf8-40cc-bc79-cba4629e97a5">
        <source>getItemValueString(pItemIndex:Integer):String;
// --------------------------------------------------------------------------------
// Created:		07 October 2001 by cnwdad1
//
// Purpose:		Returns the string item value for the requested index.
//
// Parameters:	pItemIndex - The array index of the item whose value to return.
//
// Returns:		The string item value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.allItemValues.getStringAt(pItemIndex);
end;</source>
        <Parameter name="pItemIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="7714816b-14f7-4e9f-b33d-e01d86aa8eb0">
        <updating/>
        <source>gotFocus(combobox: ComboBox input) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(combobox);
	
	if self.isFocusColorUsed and self.backColor &lt;&gt; self.focusColor then
		self.colorNoFocus	:=	self.backColor;
		self.backColor		:=	self.focusColor;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="885d46b9-cb6e-4eb9-b1ca-1216ba44af66">
        <updating/>
        <source>lostFocus(combobox: ComboBox input) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(combobox);
	
	if self.isFocusColorUsed and self.backColor &lt;&gt; self.colorNoFocus then
		self.backColor		:=	self.colorNoFocus;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setItemValueBinary" id="73fc139d-7cd1-4aef-ad46-be3c6555a11c">
        <source>setItemValueBinary(pItemIndex:Integer; pValue:Binary);
// --------------------------------------------------------------------------------
// Created:		07 October 2001 by cnwdad1
//
// Purpose:		Sets the binary item value for the requested index.
//
// Parameters:	pItemIndex - The array index of the item whose value to set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	arrayElementObj	: CnEcArrayObject;
	
begin
	if self.allItemValues.size() &lt;= pItemIndex then
		arrayElementObj	:=	self.allItemValues[pItemIndex];
		
		if arrayElementObj = null then
			self.allItemValues.addBinaryAt(pItemIndex, pValue);
		else
			arrayElementObj.setBinaryValue(pValue);
		endif;
	else
		self.allItemValues.addBinaryAt(pItemIndex, pValue);
	endif;
end;</source>
        <Parameter name="pItemIndex" type="Integer"/>
        <Parameter name="pValue" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setItemValueString" id="e963a153-8904-44d6-b57c-1239fbf2b177">
        <source>setItemValueString(pItemIndex:Integer; pValue:String);
// --------------------------------------------------------------------------------
// Created:		07 October 2001 by cnwdad1
//
// Purpose:		Sets the string item value for the requested index.
//
// Parameters:	pItemIndex - The array index of the item whose value to set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	arrayElementObj	: CnEcArrayObject;
	
begin
	if pItemIndex &gt; 0 and pItemIndex &lt;= self.allItemValues.size() then
		arrayElementObj	:=	self.allItemValues[pItemIndex];
		
		if arrayElementObj = null then
			self.allItemValues.addStringAt(pItemIndex, pValue);
		else
			arrayElementObj.setStringValue(pValue);
		endif;
	else
		self.allItemValues.addStringAt(pItemIndex, pValue);
	endif;
end;</source>
        <Parameter name="pItemIndex" type="Integer"/>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="d4dea847-2ae8-4b26-859f-889dfc403544">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// -----------------------------------------------------------------------------
// Created:		26 November 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	if self.isRequired then
		self.autoRedraw	:=	true;
		self.drawSolidRectangle(self.clientWidth()-4, 0, self.clientWidth(), 4, Red);
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
