<PrimType name="Any">
    <JadeMethod name="asStringJMT" id="3308bb38-de7f-4b50-a08d-78c6bf24fde0">
        <source>asStringJMT():String;
// ---------------------------------------------------------------------------
// Created:     11 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.isKindOf(Object) then
		return self.Object.asStringJMT();
	elseif self.isKindOf(Binary) then
		return self.Binary.asStringJMT();
	elseif self.isKindOf(Boolean) then
		return self.Boolean.asStringJMT();
	elseif self.isKindOf(Character) then
		return self.Character.asStringJMT();
	elseif self.isKindOf(Date) then
		return self.Date.asStringJMT();
	elseif self.isKindOf(Decimal) then
		return self.Decimal.asStringJMT();
	elseif self.isKindOf(Integer) then
		return self.Integer.asStringJMT();
	elseif self.isKindOf(Integer64) then
		return self.Integer64.asStringJMT();
	elseif self.isKindOf(MemoryAddress) then
		return self.MemoryAddress.asStringJMT();
	elseif self.isKindOf(Point) then
		return self.Point.asStringJMT();
	elseif self.isKindOf(Real) then
		return self.Real.asStringJMT();
	elseif self.isKindOf(String) then
		return self.String.asStringJMT();
	elseif self.isKindOf(StringUtf8) then
		return self.StringUtf8.asStringJMT();
	elseif self.isKindOf(Time) then
		return self.Time.asStringJMT();
	elseif self.isKindOf(TimeStamp) then
		return self.TimeStamp.asStringJMT();
	elseif self.isKindOf(TimeStampInterval) then
		return self.TimeStampInterval.asStringJMT;
	endif;
	
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asStringJSON" id="1d2bc76a-24db-428b-a35e-72dd2510343c">
        <source>asStringJSON() : String;
/*

Purpose:			Return the receiver formatted for JSON

Parameters:			None

Return Value:		JSON string representing the receiver

Date		Who		Reason
14 Feb 2017	cnwkpd1	TFS 3369 - Push Events application
04 Dec 2024	navmd1	Return *something* if our Primative type isn't found to avoid generating invalid JSON

*/

vars

begin
	if self.isKindOf(Binary) then
		return self.Binary.asStringJSON();
	elseif self.isKindOf(Boolean) then
		return self.Boolean.asStringJSON();
	elseif self.isKindOf(Character) then
		return self.Character.asStringJSON();
	elseif self.isKindOf(Date) then
		return self.Date.asStringJSON();
	elseif self.isKindOf(Decimal) then
		return self.Decimal.asStringJSON();
	elseif self.isKindOf(Integer) then
		return self.Integer.asStringJSON();
	elseif self.isKindOf(Integer64) then
		return self.Integer64.asStringJSON();
	elseif self.isKindOf(MemoryAddress) then
		return self.MemoryAddress.asStringJSON();
	elseif self.isKindOf(Point) then
		return self.Point.asStringJSON();
	elseif self.isKindOf(Real) then
		return self.Real.asStringJSON();
	elseif self.isKindOf(String) then
		return self.String.asStringJSON();
	elseif self.isKindOf(StringUtf8) then
		return self.StringUtf8.asStringJSON();
	elseif self.isKindOf(Time) then
		return self.Time.asStringJSON();
	elseif self.isKindOf(TimeStamp) then
		return self.TimeStamp.asStringJSON();
	elseif self.isKindOf(TimeStampInterval) then
		return self.TimeStampInterval.asStringJSON;
	
	elseif self.isKindOf(Object) then
		return self.Object.asStringJSON();
	
	endif;

	return "null";	// Catch-all for 'Any' being null
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="dataDumpFormat" id="f4b6fc20-9b29-485c-83fe-5de7c82c1220">
        <source>dataDumpFormat() : String;
// ---------------------------------------------------------------------------
// Created:     05 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	if self.isKindOf(Object) then
		if self = null then
			return DataDumpDefaultNullValue;
		else
			return global.dataDumpFormatHex(self.Object);
		endif;
	elseif self.isKindOf(String) then
		return self.String.dataDumpFormat;
	elseif self.isKindOf(Integer) then
		return self.Integer.dataDumpFormat;
	elseif self.isKindOf(Boolean) then
		return self.Boolean.dataDumpFormat;
	elseif self.isKindOf(TimeStamp) then
		return self.TimeStamp.dataDumpFormat;
	elseif self.isKindOf(Date) then
		return self.Date.dataDumpFormat;
	elseif self.isKindOf(Binary) then
		return self.Binary.dataDumpFormat;
	elseif self.isKindOf(Decimal) then
		return self.Decimal.dataDumpFormat;
	elseif self.isKindOf(Real) then
		return self.Real.dataDumpFormat;
	elseif self.isKindOf(Character) then
		return self.Character.dataDumpFormat;
	elseif self.isKindOf(Time) then
		return self.Time.dataDumpFormat;
	elseif self.isKindOf(Point) then
		return self.Point.dataDumpFormat;
	endif;

	return self.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTypeJMT" id="283326f8-4b7d-4666-9e3c-255c373c5df0">
        <source>getTypeJMT(): Type;

begin
	if self.isKindOf(Object) then
		if self = null then //cnwrs1 May 2008 DSS create database SQL
			return Object;
		endif;
		return self.Object.class;
	elseif self.isKindOf(String) then
		return currentSchema.getPrimitive(PrimTypeStringName);
	elseif self.isKindOf(Integer) then
		return currentSchema.getPrimitive(PrimTypeIntegerName);
	elseif self.isKindOf(Boolean) then
		return currentSchema.getPrimitive(PrimTypeBooleanName);
	elseif self.isKindOf(TimeStamp) then
		return currentSchema.getPrimitive(PrimTypeTimeStampName);
	elseif self.isKindOf(Date) then
		return currentSchema.getPrimitive(PrimTypeDateName);
	elseif self.isKindOf(Binary) then
		return currentSchema.getPrimitive(PrimTypeBinaryName);
	elseif self.isKindOf(Decimal) then
		return currentSchema.getPrimitive(PrimTypeDecimalName);
	elseif self.isKindOf(Real) then
		return currentSchema.getPrimitive(PrimTypeRealName);
	elseif self.isKindOf(Character) then
		return currentSchema.getPrimitive(PrimTypeCharacterName);
	elseif self.isKindOf(Time) then
		return currentSchema.getPrimitive(PrimTypeTimeName);
	elseif self.isKindOf(Point) then
		return currentSchema.getPrimitive(PrimTypePointName);
	endif;
end;</source>
        <ReturnType type="Type"/>
    </JadeMethod>
    <JadeMethod name="typeCastForSQLServer" id="e5b17eb3-2f0a-44e5-a9cb-321c578805d7">
        <source>typeCastForSQLServer(_newType: String) : Any;
// ---------------------------------------------------------------------------
// Created:     07 July 2003 by cnwsb1
//
// Purpose:		Type casts for external database connectivity to an
//				SQL Server (2000) database.  If we want to connect to another
//				type of RDMS in the future (it's not planned as this is written)
//				then some extra logic can be added to typeCast differently for that.
// ---------------------------------------------------------------------------
//PAR19114 DSS speed up cnwrs1 apr 2009
constants
	EarliestDateForSQLServer = "01/Jan/1900".Date;

vars
	currType : Type;
	ts : TimeStamp;

begin
	if _newType = 'String' then
		return self.String;
	elseif _newType = 'Integer' then
		return self.Integer;
	elseif _newType = 'Boolean' then
		return self.Boolean;
	elseif _newType = 'TimeStamp' then
		if self.isKindOf(Time) then
			ts.setDate(EarliestDateForSQLServer);
			ts.setTime(self.Time);
			return ts;
		endif;
		return self.TimeStamp;
	elseif _newType = 'Time' then
		return self.Time;
	elseif _newType = 'Date' then
		return self.Date;
	elseif _newType = 'Decimal' then
		return self.Decimal;
	elseif _newType = 'Real' then
		return self.Real;
	elseif _newType = 'Character' then
		return self.Character;
	elseif _newType = 'Point' then
		return self.Point;
	endif;

	return self;
end;</source>
        <Parameter name="_newType" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</PrimType>
