    <JadeMethod name="getAllFutureMovesOfType" id="283b40e8-9345-48e3-98a6-ea423a5b534b">
        <source>getAllFutureMovesOfType(moveMode : Integer; moveType : Integer; allMoves : CM_FutureMoveArray input );
/*
------------------------------------------------------------------------
Created:			04 December 2002 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		As above. Special comment:
Returns:			As above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	move : CM_FutureMove;
	coll : CM_FutureMoveArray;
begin
	if allMoves = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'FutureMove array', null, null);
		return;
	endif;
	allMoves.clear;
	if moveMode = PLANNING_MODE then
		coll := self.allPlannedFutureMoves;
	elseif moveMode = QUEUE_MODE then
		coll := self.allQueuedFutureMoves;
	endif;
	if coll = null then
		return;
	endif;
	foreach move in coll where move.moveType = moveType do
		allMoves.add(move);
	endforeach;
end;</source>
        <Parameter name="moveMode" type="Integer"/>
        <Parameter name="moveType" type="Integer"/>
        <Parameter name="allMoves" type="CM_FutureMoveArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllInterchangeLocations" id="75b8b1ba-fdfd-488c-b6e1-959d6dc2ecf0">
        <source>getAllInterchangeLocations(_allLocations : CM_LCArray input);
/*

Purpose:		populate a collection with all the valid interchange locations	

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwer1	Initial creation

*/

vars
	icArea : CM_InterchangeArea;
	lc 		: CM_LocationsController;
begin
	if self.myTerminalArea = null then
		return;
	endif;
	
	foreach icArea in self.myTerminalArea.allAssociatedInterchangeAreas do
		lc:=icArea.getDefaultLane;
		if lc &lt;&gt; null then
			_allLocations.add(lc);
		endif;
	endforeach;
	
	
epilog

end;</source>
        <Parameter name="_allLocations" type="CM_LCArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllPickedUpQueuedMoves" id="f1d3bb2a-fadb-4e19-94d7-7df72b1f3283">
        <source>getAllPickedUpQueuedMoves(_tiToIgnore : CM_TrackedItem): Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2008	cnwer1	Initial creation

*/

vars
	move : CM_FutureMove;
	ti : CM_TrackedItem;
	fma : CM_FutureMoveArray;
	rtQueueEntry : CM_RTQueueEntry;
	count 	: Integer;
begin

	fma := self.allQueuedFutureMoves;
	count := 0;
	foreach move in fma discreteLock do
		//20/06/03  Needed this check because overstows was breaking future move. 
		foreach rtQueueEntry in move.CM_FutureMoveQueued.allRTQueueEntries do
			ti := rtQueueEntry.getTrackedItem;
			if ti &lt;&gt; null  and ti = _tiToIgnore then
				continue;				
			endif;
			if rtQueueEntry.findTaskOfType(TASK_PICKUP,TASK_WORKING) &lt;&gt; null or rtQueueEntry.findTaskOfType(TASK_PICKUP,TASK_COMPLETE) &lt;&gt; null or rtQueueEntry.findTaskOfType(TASK_PICKUP,TASK_ACCEPTED) &lt;&gt; null then
				count:=count + 1;
			endif;
		endforeach;
	endforeach;
	
	return count;
epilog

end;</source>
        <Parameter name="_tiToIgnore" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllPlannedTrackedItems" id="da642e08-1b9d-4e1f-9d84-200146118367">
        <source>getAllPlannedTrackedItems(_tis: CM_TIArray input; _clear : Boolean; _switchTS : Boolean);
/*
 ------------------------------------------------------------------------
Created:			05 August 2002 by cnwdwq1
Purpose:			Returns all future planned tracked items.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
----------		--------------	-----------------------------------------
12/05/2010		cnwdap1			CCMS 1116 Tranship changes
---------------------------------------------------------------------------
*/
vars
	move : CM_FutureMove;
	fma : CM_FutureMoveArray;
	ti : CM_TrackedItem;
begin
	if _clear then
		_tis.clear;
	endif;
	fma := self.allPlannedFutureMoves;
	foreach move in fma discreteLock do
		// not EDI future moves - see self.getAllFutureMovesOfType or similar
		if move.moveType &lt;&gt; TI_FutureMoveEDI then
			ti := move.CM_FutureMovePlanned.myTrackedItem;
			// PAR 22614
			if ti &lt;&gt; null then								// PAR #23645 CCMS 1116
				_tis.add(ti);
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_switchTS" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllProducts" id="1c9b8db2-28c4-44f9-b2ec-6b88383cf259">
        <source>getAllProducts(_allProductsObj:CM_ProductByCodeCargoTypeDict input);
// --------------------------------------------------------------------------------
// Created:		02 December 2005 by cnwdad1
//
// Purpose:		Populates the specified collection with all Products that are in use
//				by the receiver's Grid Areas. Note that the collection will NOT be
//				cleared before being populated.
//
// Parameters:	_allProductsObj - A reference to the collection to populate.
//
// Returns:		The populated collection parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sohLocationObj		: CM_SOHLocation;
	
begin
	on Exception do self.xHandlerAddProduct(exception);
	
	foreach sohLocationObj in self.allProductLocations do
		if sohLocationObj.numTIs = 0 then
			continue;
		endif;
		
	//	if not _allProductsObj.includes(sohLocationObj.myProduct) then
	//		_allProductsObj.add(sohLocationObj.myProduct);
	//	endif;
		_allProductsObj.addNoDuplicates(sohLocationObj.myProduct,false);	//10 Jun 2015	NDL	Par 36392
	endforeach;
end;</source>
        <Parameter name="_allProductsObj" type="CM_ProductByCodeCargoTypeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllQueuedTrackedItems" id="48231a22-9f86-4715-925b-88512e1ed2d0">
        <source>getAllQueuedTrackedItems(_tis: CM_TIArray input; _clear : Boolean);
/*
 ------------------------------------------------------------------------
Created:			05 August 2002 by cnwdwq1
Purpose:			Returns all future queued tracked items.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
----------		--------------	-----------------------------------------
12/05/2010		cnwdap1			CCMS 1116 Tranship changes
---------------------------------------------------------------------------
*/
vars
	move : CM_FutureMove;
	ti : CM_TrackedItem;
	fma : CM_FutureMoveArray;
begin
	if _clear then // AKB2009AUG PAR 19468
		_tis.clear;
	endif;
	fma := self.allQueuedFutureMoves;
	foreach move in fma discreteLock do

		//20/06/03  Needed this check because overstows was breaking future move. 
		ti := move.CM_FutureMoveQueued.myTrackedItem;
		if ti &lt;&gt; null then
			_tis.add(ti);
		endif;
	endforeach;
end;



</source>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllTIByIMEX" id="d5274b89-2120-428b-b1d9-4736d99aa686">
        <source>getAllTIByIMEX(_imex : Integer; _tis : CM_TIArray input; _clear : Boolean);
/*
Purpose:			
Date		Who		Reason
19 September 2011	cnwab1	Initial creation
*/

vars
	ti : CM_TrackedItem;
begin
	if _clear then
