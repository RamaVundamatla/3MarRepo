    <JadeMethod name="attemptMatch" id="0b410565-ef9a-43cc-99a2-9a5fa3b222bc">
        <updating/>
        <source>attemptMatch(_passport : CM_Passport input): Boolean updating;
//--------------------------------------------------------------
//Created: 25 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	bolOutHdr 	: CM_BOLOutHeader;
	rtnValue	: Boolean;
begin

	bolOutHdr := self.myTerminal.allBOLOutHeadersUnmatched.getAtKeyGtr(self.myOperator.code, self.number, null);
	
	if bolOutHdr &lt;&gt; null and
	   bolOutHdr.bolNumber = self.number and
	   bolOutHdr.operatorCode = self.myOperator.code then
		rtnValue := self.updateFromCM_BOLOutHeader(bolOutHdr, _passport);
	endif;

	if rtnValue then
		delete bolOutHdr;
	endif;
	
	return rtnValue;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="breakTerminalRefForPurge" id="cae506f2-4719-4c15-86c2-d31a1303bc17">
        <updating/>
        <source>breakTerminalRefForPurge() updating;
// -------------------------------------------
// Created 24 August 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.exclusiveLock(self);
	self.myReleaseTerminal := null;


end;</source>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="b89ddd9e-d213-4d7c-9290-25534e8c5358">
        <updating/>
        <source>cloneReferences(_bol: CM_BOLOut; _doVoyage : Boolean) updating;

vars

begin

	inheritMethod(_bol, _doVoyage);
	self.myMasterTI				:= _bol.myMasterTI;
	self.myReleaseTerminal		:= _bol.myReleaseTerminal;
	self.myStevedore			:= _bol.myStevedore;
	
	if _doVoyage then
		self.myVoyage			:= _bol.myVoyage;
	endif;
end;</source>
        <Parameter name="_bol" type="CM_BOLOut"/>
        <Parameter name="_doVoyage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateLocation" id="19891fdd-485a-4489-a5e3-165ba1aef2a0">
        <updating/>
        <source>doUpdateLocation(_mode: Integer; 
				_newLocn: CM_LocationsController;
				_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 18 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	if _newLocn &lt;&gt; null or 
	   self.bolType = BOLType_GeneralDocket or
	   self.bolType = BOLType_GeneralBillOfLading then
		inheritMethod(_mode, _newLocn, _passport);
	endif;

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_newLocn" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="erase" id="a62216b3-b17f-4b1d-b2f8-27a18eb6dddf">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//--------------------------------------------------------------
// Created: 29 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars

begin
	if not self.isTransient then
		exclusiveLock(self);
		if self.myTerminal &lt;&gt; null then
			self.myTerminal.causeEvent(Event_BOLOut_Delete, false, self.number);
		endif;
		if self.myTerminalIfUnmatched &lt;&gt; null then
			self.myTerminal.causeEvent(self.myTerminal.getTerminalEvent(BOLRecon_Delete_Event), false, self);	
		endif;
	endif;

	inheritMethod(_eraseLevel);
	
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exportMyCollectionsXML" id="5ff412f8-f11d-465d-b1d4-e4c2d8881f40">
        <source>exportMyCollectionsXML(_file: File; _objArray: ObjectArray io);

vars
	stockOrderLine		: CM_BOLOutStockOrderLineTI;
	
begin
	inheritMethod(_file, _objArray);
	
	_file.writeLine('&lt;'&amp;CM_BOLOut::allBOLOutStockOrderTIs.name&amp;'&gt;');
	foreach stockOrderLine in self.allBOLOutStockOrderTIs do
		stockOrderLine.exportMeXML(_file, _objArray, false, false);
	endforeach;
	_file.writeLine('&lt;/'&amp;CM_BOLOut::allBOLOutStockOrderTIs.name&amp;'&gt;');
	
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllBolsForNumValidation" id="670e9c95-efa6-423b-b1b2-2703d1fd546d">
        <source>getAllBolsForNumValidation(): CM_BOLByTypeNumberDTDict;
// ---------------------------------------------------------------------------
// Created:     24 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.myTerminal.allBOLsReleasedByTypeNumberDT;

end;</source>
        <ReturnType type="CM_BOLByTypeNumberDTDict"/>
    </JadeMethod>
    <JadeMethod name="getContainerCharge" id="716257ba-9b90-4067-b4ea-e815ca3603ce">
        <source>getContainerCharge() : Decimal;
// ---------------------------------------------------------------------------
// Created:     18 August 2002 by cnwth2
//
// Purpose:     This is for warehousing only - and is temporary. The container packing charges
//				need to be soft eventually - and got to another way. 
//
// ----------   ----------  --------------------------------------------------
vars
	masterTI	: CM_TrackedItem;
	op			: CM_Operator;
begin
	op := self.myOperator;
	
	if op = null then 
		return null;
	endif;
	
	masterTI := self.myMasterTI;
	if CM_Container.hasInstance(masterTI) then	
		if (not masterTI.CM_Container.is40)then
			return op.getConfig(ContainerPackingCharge20ft).Decimal;
		else
			return op.getConfig(ContainerPackingCharge40ft).Decimal;
		endif;
	endif;
	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getContainerTareWeight" id="e94fbf2c-2cac-4126-8d0d-4a5a7c2b63ef">
        <source>getContainerTareWeight(): Real;
//--------------------------------------------------------------
// Created: 14 August 2002 By: cnwsb1
//--------------------------------------------------------------
vars

begin
	
	if self.myMasterTI &lt;&gt; null then
		//return self.myMasterTI.weight;				//-cnwml2 MSL CCMS 1017
		return self.myMasterTI.weightTare;				//+cnwml2 MSL CCMS 1017
	endif;
	
	return 0;
	
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="e8256a57-9de2-4021-9867-fd0e0db49083">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     14 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/02/2010	cnwcs5		par 22193 - iso gruop
// 10/06/2022	navdap1		TFS 53013 booking and cargo sub type in road operations column organiser
// ---------------------------------------------------------------------------
// 28 July 2022 navvt20 	Bug 54199: EUP - Tables with Operator/Stevedore not adhering to the configuration
vars
	str			: String;
	theBR 		: CM_BulkRelease;
	shipLine	: CM_ShippingLine;
begin

	
	if _attrName = ETRow_NoNumber then
		if self.myExtension &lt;&gt; null then
			self.myExtension.CM_BOLExtLogOut.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_BOLOutNumber then
		return self.number;
		
	elseif _attrName = ETRow_ItemTypeToPack then
		if self.myMasterTI &lt;&gt; null then
			return self.myMasterTI.myCargoType.description;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_DischargePort or
	   _attrName = ETRow_OperatorCont or
	   _attrName = ETRow_IsoType or
	   _attrName = ETRow_IsoGroup or	// 24/02/2010 par 22193
	   _attrName = ETRow_BulkRelease or // CCMS 1288 AKB2005APR
	   _attrName = ETRow_ContainerVolume or
	   _attrName = ETRow_TotalVolume or
	   _attrName = ETRow_ContainerWeight or
	   _attrName = ETRow_WeightTotal or
	   _attrName = ETRow_BookingRef or
	   _attrName = ETRow_ImexStatus or
	   _attrName = ETRow_Commodity or
	   _attrName = ETRow_ContentsStatus or
	   _attrName = ETRow_Seal or
	   _attrName = ETRow_PrevSealNum or
	   _attrName = ETRow_SealNumCustoms or
	   _attrName = ETRow_SealNumShippers or	
	   _attrName = ETRow_Booking or				// TFS 53013
	   _attrName = ETRow_CargoSubType or		// TFS 53013
	   _attrName = ETRow_CedoNum then
		if self.myMasterTI &lt;&gt; null then
			return 	self.myMasterTI.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;   

	elseif _attrName = ETRow_Charged then
		return self.isCharged.cnEcGetTableCheckBoxValue;
		
	elseif _attrName = ETRow_CarrierCode then
		if self.carrierCode &lt;&gt; null then
			return self.carrierCode;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_MyConsignee  then
		return self.consignee;
				
// cnwdad1 30/08/2006 - Constant is no longer used.
//	elseif _attrName = ETRow_MyContainer or
	elseif _attrName = ETRow_ParentToPack then
		if self.myMasterTI &lt;&gt; null then
			return self.myMasterTI.id;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_DateOfEntry then
		return self.systemToLocalTime(self.dateTime).String;	// 19/04/2016 cnwmp6 TFS 488 - Multi timezone support
			
	elseif _attrName = ETRow_IsoType  then
		if CM_Container.hasInstance(self.myMasterTI) then
			return self.myMasterTI.CM_Container.isoType;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_MyOperator then
		//if self.myOperator &lt;&gt; null then    //28.07.2022 navvt20 TFS 54199
		//	return self.myOperator.code;	 //28.07.2022 navvt20 TFS 54199
		//else								 //28.07.2022 navvt20 TFS 54199
		//	return null;					 //28.07.2022 navvt20 TFS 54199
		//endif;							 //28.07.2022 navvt20 TFS 54199
		
		//START 28.07.2022 navvt20 TFS 54199
		if app.myRoot.getConfig(ComboByNameOperator).Boolean and self.myOperator &lt;&gt; null then    
            return self.myOperator.description;                                                   
        endif;                                                                                    
        return self.myOperator.code;
		// END 28.07.2022 navvt20 TFS 54199
		
	elseif _attrName = ETRow_MyStockOrder then
		if self.myStockOrderHeader &lt;&gt; null then
			return self.myStockOrderHeader.orderNo;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_OutwardsDate then
		return self.systemToLocalTime(self.dateTime).date.String;	// 19/04/2016 cnwmp6 TFS 488 - Multi timezone support
	
	elseif _attrName = ETRow_Number or
		_attrName = ETRow_DocketNumber or
		_attrName = ETRow_DocketNo or
		_attrName = ETRow_BolNumber then
		return self.number;
	
	elseif _attrName = ETRow_PartialLoadoutText or
		_attrName = ETRow_PartiallyLoaded then
		return self.partialLoadout.getYesNo;
	
	elseif _attrName = ETRow_Pieces then
		return self.numTIs.String;
	
	elseif _attrName = ETRow_ProcessOpt then
		return app.processOptionEnumToString(self.processOption);
	
	elseif _attrName = ETRow_ReferenceDate then
		return self.referenceDate.String;
	
	elseif _attrName = ETRow_Supplier then
		return self.myOperator.code;
		
	elseif _attrName = ETRow_TransportMode then
		if (self.processOption = Process_Direct_Loadout) then
			return app.transModeToString(self.transportMode);
		/*
		elseif self.processOption = Process_Pack then
			str := app.processOptionEnumToString(Process_Pack);
			if self.myMasterTI &lt;&gt; null then
				if self.myMasterTI &lt;&gt; null then
					str := str &amp; ' -' &amp; app.transModeToString(self.myMasterTI.releasedTransportMode);
				else
					str := str &amp; '-parent not yet released';
				endif;
			endif;
			
			return str;
		*/
		else
			return null;
		endif;
		
	elseif	_attrName = ETRow_Voyage then
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.code;
		endif;
	
	elseif _attrName = ETRow_VehicleId then
			return self.vehicle;
		
	elseif	_attrName = ETRow_VesselName then
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.vesselName;
		endif;
		
	elseif _attrName = ETRow_MyVessel then
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.vesselName;
		else
			return null;
		endif;
		
	elseif	_attrName = ETRow_ShippingLine then
		if self.myVoyage &lt;&gt; null and
			self.myVoyage.myShippingLine &lt;&gt; null then
			//TFS#53362 navsp1 20Jun2022
			if self.myTerminal.getConfig(ComboByNameLine).Boolean then  
				return self.myVoyage.myShippingLine.description;
			endif;
			return self.myVoyage.myShippingLine.code;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_Seal then
		if self.myMasterTI &lt;&gt; null and self.myMasterTI.isKindOf(CM_TrackedItem) then
			//return self.myMasterTI.CM_Container.sealNum;
			return self.myMasterTI.getSealNum;	//15 Sep 2010	NDL	Par 25608
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_MyReleaseTerminal then
		if self.myReleaseTerminal &lt;&gt; null then
			return self.myReleaseTerminal.name;
		else
			return null;
		endif;
	elseif _attrName = ETRow_MyPlannedLocation then
		if self.transportMode = TI_TRANSMODE_ROAD then
			if self.myYardJob &lt;&gt; null then
				return self.myYardJob.jobId;
			else
				return 'Vehicle';
			endif;
		else
			return null;
		endif;						
	elseif _attrName = ETRow_MyLocation then //rs1 dec 2005 
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.displayEntry();
		else
			return null;
		endif;
	elseif _attrName = ETRow_MatchDate or //rs1 dec 2005 
	   _attrName = ETRow_LoggingOperation or
	   _attrName = ETRow_UnloadPoint or
	   _attrName = ETRow_Opid or
	   _attrName = ETRow_LoggingOrganisation then
		return null;
	else
	endif;
	
	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyage" id="a7132136-de4b-46ef-8f08-b51b980fc535">
        <source>getMyVoyage(): CM_Voyage;
//--------------------------------------------------
// Created:	02 September 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.myVoyage;

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getTotalGrossWeight" id="c5074cc8-ace3-43b7-b833-a3542fbff4c9">
        <source>getTotalGrossWeight() :Real;
// ---------------------------------------------------------------------------
// Created:     26 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return self.getContainerTareWeight() + self.getTotalTIWeight();

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="hasDamagedTIs" id="65bb178d-8088-434a-95ea-9087bca62b09">
        <source>hasDamagedTIs() : Boolean;
//--------------------------------------------------------------
// Created: 25 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars
	ti : CM_TrackedItem;
	
begin
	foreach ti in self.allTrackedItems where
			ti.damaged do
		return true;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="importMeXML" id="e44f931c-50e0-42d1-a843-2ff3c28c83c3">
        <updating/>
        <source>importMeXML(_classBlock: String) updating;
// ---------------------------------------------------------------------------
// Created:     11 October 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_classBlock);
	
	self.processOption := Process_Pack;
end;</source>
        <Parameter name="_classBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importMyCollectionsXML" id="59be3f48-7a79-4cdd-8f60-538414cba90e">
        <updating/>
        <source>importMyCollectionsXML(_collectionsBlock: String) updating;
// ---------------------------------------------------------------------------
// Created:     10 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	terminal			: CM_Terminal;
	masterTI,
	ti					: CM_TrackedItem;
	blockLength,
	pos					: Integer;
	allStockOrdersBlock,
	stockOrderBlock,
	tiId,
	tiBlock				: String;
	stockOrderLine		: CM_BOLOutStockOrderLineTI;
	cargoTypeDict		: CM_CargoTypesByIdDict;
	cargoType,
	foundCargoType		: CM_CargoType;
	ext					: CM_BOLExtWarehouse;
	voy					: CM_Voyage;
begin
	terminal := app.myRoot.allTerminals['POE'];
	if terminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Terminal POE could not be found');
		return;
	endif;
	
	tiBlock := _collectionsBlock.cnEcGetTagValueOfName('allTrackedItems');
	
	cargoTypeDict := app.myRoot.allCargoTypesById;
	foreach cargoType in cargoTypeDict do
		if cargoType.abbreviation = 'BMLT' then
			foundCargoType := cargoType;
			break;
		endif;
	endforeach;
	
	if foundCargoType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Cargo type "BMLT" not found');
		return;
	endif;
	
	ext := self.myExtension.CM_BOLExtWarehouse;
	if ext = null then
		return;
	endif;
	
	if self.transportMode = TI_TRANSMODE_SHIP then
		voy := terminal.lookupVoyage(ext.voyageCode, null, true);
//		if voy = null then
//			voy := terminal.allVoyagesArchived[ext.voyageCode];
//		endif;
		
		self.myVoyage := voy;
	endif;
	
	masterTI := terminal.allOffsiteTIsByIdCargoType.getAtKeyGeq(ext.containerId, TI_CargoType_Container, null);
	if (masterTI &lt;&gt; null) and (masterTI.id = ext.containerId) and
	   masterTI.cargoType = TI_CargoType_Container then
		self.myMasterTI := masterTI;
	endif;
	
	blockLength := tiBlock.length;
	
	pos := 1;
	while pos &lt; blockLength do
		tiId := tiBlock.cnEcGetNextTagValueOfName('id', pos);

		if pos &lt; 1 then
			break;
		endif;
		
		ti := terminal.allOffsiteTIsByIdCargoType.getAtKeyGeq(tiId, cargoType.id, null);
//not checking key		
		//if CM_BreakBulkGeneric.hasInstance(ti) then
			ti.setPropertyValue('myReleaseBOL', self);
		//endif;
	endwhile;
	
end;</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
