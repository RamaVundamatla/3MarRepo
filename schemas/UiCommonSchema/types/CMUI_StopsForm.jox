    <JadeMethod name="setRowForAdd" id="610191fa-c46b-4f15-aea9-62f526854f41">
        <source>setRowForAdd(_table: CM_DataTable input; _row: Integer) protected;
// ---------------------------------------------------------------------------
// Created:     15 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	value	:Boolean;
	col		:Integer;
begin
	// reimplemented on each sub form.
	value	:= _table.getCellValueByName (ETRow_Add, _row).Integer.Boolean;
		
	if value then
		// add and update are mutually exclusive
		col := _table.getColumnByRowName (ETRow_Update);
		
		if col &lt;&gt; null and
			_table.accessCell (_row, col).inputType = Table.InputType_CheckBox then
			_table.setCellValueByName (ETRow_Update, _row, null.String);
		endif;
		// can't change expiry date while adding
		col := _table.getColumnByRowName (ETRow_ClearanceExpiryDate);
		
		if col &lt;&gt; 0 then
			_table.accessCell (_row, col).inputType := Table.InputType_None;
		endif;
		// make sure expiry date is set to current value for stop
		self.setExpiryDateForRow (_table, _row);
	else
		// nothing to do
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRowForClear" id="5bc8924f-7940-4187-9320-09d52078ee7c">
        <source>setRowForClear(_table: CM_DataTable input; _row: Integer) protected;
// ---------------------------------------------------------------------------
// Created:     15 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	value		:Boolean;
	stopTable	:CM_StopsTable;
	col			:Integer;
begin
	value 		:= _table.getCellValueByName (ETRow_Clear, _row).Integer.Boolean;
	stopTable	:= _table.accessRow(_row).itemObject.CM_StopsTable;
	
	if value then
		// clear, cancel and override are mutually exclusive
		_table.setCellValueByName (ETRow_Cancel, _row, null.String);
		_table.setCellValueByName( ETRow_Override, _row, null.String );		// cnwrl1 23/08/2010 PAR 23697
		
		col := _table.getColumnByRowName (ETRow_Input);
		
		if col &lt;&gt; 0 then
			if stopTable.requiresInfo then		
				// let them enter it
				_table.accessCell (_row, col).cellControl	:= self.txtExtraInfo;
			else
				_table.accessCell (_row, col).cellControl	:= null;
			endif;
		endif;
			
		col := _table.getColumnByRowName (ETRow_ClearanceExpiryDate);
		
		if col &lt;&gt; null then
			if stopTable.allowClearanceExpiryDate then 
				// stop can have a future clearance expiry - so enable input for the cell
				_table.accessCell (_row, col).inputType		:= Table.InputType_EditMask;
				_table.accessedCell.editMask				:= app.getDateEditMaskForShortFormat; 
			else
				_table.accessCell (_row, col).inputType		:= Table.InputType_None;
			endif;
		endif;
	else
		// can't input any required info or expiry date
		col := _table.getColumnByRowName (ETRow_Input);
		
		if col &lt;&gt; null then
			_table.accessCell (_row, col).cellControl			:= null;
		endif;
		
		col := _table.getColumnByRowName (ETRow_ClearanceExpiryDate);
		
		if col &lt;&gt; null then
			_table.accessCell (_row, col).inputType	:= CM_BaseTable.InputType_None;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7c41130e-6da6-4543-b928-d969e8752ebf">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	inheritMethod();
	
	if self.left &lt; app.mainForm.left then
		self.left := app.mainForm.left + self.left;
	endif;
	if self.top &lt; app.mainForm.top then
		self.top := app.mainForm.top + self.top;
	endif; 
	
	
	if app.getApplicationSkin &lt;&gt; null then
		self.jdbTop.ignoreSkin	 	:= true;
		self.grpTop.transparent		:= true;
		self.jdbBottom.ignoreSkin	:= true;
		self.grpBottom.transparent	:= true;
	endif;
	
	self.initStopsToAddTable (self.tblStopsAdd);
	self.initStopsToClearTable (self.tblStopsClear);
	
	// cnwrl1 23/08/2010 PAR 23697 - start of coding
	self.cmbOverrideRsons.setObject( null );		// CMUI_ComboBoxOverrideReasons
	self.cmbOverrideRsons.automaticCellControl	:= true;
	self.canOverride							:= self.canUpdate and app.myCurrentUserCan( self.myTerminal, PmAdmAllowStopOverride );
	// cnwrl1 23/08/2010 PAR 23697 - end of coding
	
	self.txtExtraInfo.automaticCellControl	:= true;
	self.txtExpiryDate.automaticCellControl	:= true;
	
	self.txtExtraInfo.scrollHorizontal:= true;
	
	if not self.canUpdate then
		self.btnSave.enabled			:= false;
		self.btnSaveAndClose.enabled	:= false;	
	endif;
	
	self.modalResult := IDCANCEL;
epilog

end;</source>
    </JadeMethod>
