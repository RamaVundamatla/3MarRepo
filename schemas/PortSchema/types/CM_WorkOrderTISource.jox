    <JadeMethod name="addTrackedItemToParent" id="3e9262ed-800d-4a79-8cdb-02f7059016fc">
        <source>addTrackedItemToParent( _ti : CM_TrackedItem);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28/01/2010	cnwrd1	Initial creation
22/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
*/

vars
	
begin

	if _ti = null then
		return;
	endif;
	
	if self.myParent = null then
		return;
	endif;

	if  CM_WorkOrderTI.hasInstance(self.myParent) then
		// TFS 38501 don't add TI to a PEL work order, it's already attached to the correct work order								// TFS 38501
		if not self.myParent.CM_WorkOrderTI.isWorkOrderForReceival and not self.myParent.CM_WorkOrderTI.isWorkOrderForRelease then	// TFS 38501
			self.myParent.CM_WorkOrderTI.addTrackedItem(_ti,self.myParent.CM_WorkOrderTI.allWoDtls.first);							//08.02.2023 navma1 #56457 Task#56458
		endif;																														// TFS 38501
	elseif CM_WodPack.hasInstance(self.myParent) then
		//nothing here yet
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="delete" id="a024d7d1-4eaa-49ca-8fe3-8e6da670bacd">
        <updating/>
        <source>delete() updating;
// -----------------------------------------------------------------------------
// Created:		03 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	woRequest : CM_WorkOrderRequestByType;
begin
	if self.isTransient and app.myProxyManager &lt;&gt; null then
		app.myProxyManager.deleteProxyLink(self);
	endif;
	
	//want to purge these if real or transient.
	self.allWORequestByType.purge();
	/*
	if self.isTransient then
		foreach woRequest in self.allWORequestByType do
			woRequest.raiseExceptionIfNotTransient(method);
		endforeach;
		self.allWORequestByType.purge();
	endif;*/
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllRBTWithUnactioned" id="3ad4e236-9ed2-48bd-a088-588ab49e7405">
        <source>getAllRBTWithUnactioned( _rbtSet: CM_WorkOrderRequestByTypeSet io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwrd1	Initial creation

*/

vars
	rbt : CM_WorkOrderRequestByType;
begin


	foreach rbt in self.allWORequestByType do
		if rbt.hasCargoToAction() then
			_rbtSet.add ( rbt );
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_rbtSet" type="CM_WorkOrderRequestByTypeSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllTIs" id="03aa1dcd-6b3e-4ba9-80c6-dcf1e88aadb6">
        <source>getAllTIs( _tiset : CM_TISet input) ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21/08/2009	cnwrd1	Initial creation
11/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
05/09/2018	jlgdap1	TFS 40157 PEL1 Change Voyage Work Order
16/05/2022	navcs2	TFS 53038
*/

vars
	tiArray : HugeStringArray;
	aBooking : CM_BookingRef;
	aBulkRel : CM_BulkRelease;
	aWorkOrder 	: CM_WorkOrder;
	aRBT		: CM_WorkOrderRequestByType;
	terminal : CM_Terminal;
	ti : CM_TrackedItem;
	tiId : String;
	workOrder : CM_WorkOrder;
	workOrderTask : CM_WorkOrderDtl;
	wodRelExtension : CM_WodReleaseExtension;	//13 Mar 2019	NDL	TFS 43405
	wodRel : CM_WodRelease;	//13 Mar 2019	NDL	TFS 43405
	invalid: Boolean;
begin

	on Exception do app.handleDeletedObject(exception,ti,invalid);// TFS 52176


	workOrder := self.getWorkOrder();
	
	create tiArray transient;
	self.getTIsAsStringArray(tiArray);

	terminal := workOrder.myTerminal;
	
	if _tiset.isEmpty then	// TFS 53038 16/05/2022																
		foreach tiId in tiArray do
			if workOrder.isWorkOrderForReceival then												// TFS 38501
				ti := terminal.lookupTrackedItem(tiId.trimBlanks(), null, TI_STATE_NOTIFIED, null, false);	// TFS 38501
																						// TFS 38501
			elseif workOrder.isWorkOrderForRelease then												// TFS 38501
				ti := terminal.lookupTrackedItem(tiId.trimBlanks(), null, TI_STATE_NORMAL, null, false);	// TFS 38501																					// TFS 38501
			else																							// TFS 38501
				ti := terminal.lookupTrackedItem(tiId.trimBlanks(), self.cargoType, TI_STATE_NORMAL, null, false);
				if ti = null and workOrder.isWorkOrderForNullVoyage() then													// TFS 40157
					ti := terminal.lookupTrackedItem(tiId.trimBlanks(), self.cargoType, TI_STATE_NOTIFIED, null, false);	// TFS 40157
				endif;																										// TFS 40157
			endif;																							// TFS 38501
			//else																							// TFS 38501
			if ti &lt;&gt; null then																				// TFS 38501
				if not _tiset.includes(ti) then
					_tiset.add(ti);
				endif;
			endif;
		endforeach;
	endif;

	// now each booking:
	if not workOrder.isWorkOrderForReceival then												// TFS 38501
		foreach aBooking in self.allBookings do	
			foreach ti in aBooking.allTIs do
				if not _tiset.includes(ti) then //  and ti.isOnSite ?
					_tiset.add(ti);
				endif;
			endforeach;
		endforeach;
	endif;																								// TFS 38501
	
	// now bulk releases
	if not workOrder.isWorkOrderForRelease then													// TFS 38501
		foreach aBulkRel in self.allBulkReleases do
			foreach ti in aBulkRel.allTrackedItemsAssigned  do
				if not _tiset.includes(ti) then
					_tiset.add(ti);
				endif;
			endforeach;
			
			foreach ti in aBulkRel.allTrackedItemsReleased  do
				if not _tiset.includes(ti) then
					_tiset.add(ti);
				endif;
			endforeach;
		endforeach;
	endif;																								// TFS 38501
	
	foreach aWorkOrder in self.allSourceWorkOrders do
		
		// only want items that have completed the last task here
		workOrderTask := aWorkOrder.getLastTask();
		if workOrderTask &lt;&gt; null then
			foreach ti in workOrderTask.CM_WorkOrderTIDtl.allCompleteTIs do
				if not _tiset.includes(ti) then
					_tiset.add(ti);
				endif;
			endforeach;
		endif;
	endforeach;
	
	//13 Mar 2019	NDL	TFS 43405  Cargo Release Extensions don't have their own tis until approved/completed.
	if workOrder.isWorkOrderForReleaseExtension then
		wodRelExtension := workOrder.allWoDtls.first.CM_WodReleaseExtension;
		wodRel := wodRelExtension.myReleaseWorkOrder;
		if wodRel &lt;&gt; null then
			foreach ti in wodRel.allAvailableTIs do
				if not ti.isOnSite then
					continue;
				endif;

				if invalid then// TFS 52176
					invalid := false;// TFS 52176
					continue;
				endif;

				if not _tiset.includes(ti) then
					_tiset.add(ti);
				endif;
			endforeach;
		endif;
	endif;
	
	// dont want any from here because we dont have real ti's yet
	//self.allWORequestByType
		
	
epilog
	delete tiArray;
	
end;
</source>
        <Parameter name="_tiset" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="854f3bba-4de0-4ca9-9ab5-0367c17190ea">
        <source>getDisplayString() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2009	cnwmd1	Initial creation

*/

vars
	bookingRef : CM_BookingRef;
	bulkRelease : CM_BulkRelease;
	request : CM_WorkOrderRequestByType;
	workOrder : CM_WorkOrder;
	bookingRefStr, bulkReleaseStr, requestStr, workOrderStr, display : String;
	invalidWO : Boolean;
begin

	on Exception do app.handleDeletedObject(exception, workOrder, invalidWO); 


	if self.hasNonIDSource() then
		foreach bookingRef in self.allBookings do
			if bookingRefStr = null then
				bookingRefStr := bookingRef.bookingReference;
			else
				bookingRefStr := bookingRefStr &amp; ", " &amp; bookingRef.bookingReference;
			endif;
		endforeach;
		
		foreach bulkRelease in self.allBulkReleases do 
			if bulkReleaseStr = null then
				bulkReleaseStr := bulkRelease.code;
			else
				bulkReleaseStr := bulkReleaseStr &amp; ", " &amp; bulkRelease.code;
			endif;
		endforeach;
		
		foreach request in self.allWORequestByType do 
			if requestStr = null then
				requestStr := request.getListDisplay();
			else
				requestStr := requestStr &amp; ", " &amp; request.getListDisplay();
			endif;
		endforeach;
		
		foreach workOrder in self.allSourceWorkOrders do 
			if workOrderStr = null then
				workOrderStr := workOrder.id;
			else
				workOrderStr := workOrderStr &amp; ", " &amp; workOrder.id;
			endif;
		endforeach;
		
		
		display := "Cargo ID's : " &amp; self.tiTextList;	
		
		if bulkReleaseStr &lt;&gt; null then
			display := display &amp; CrLf &amp; "Bulk Release : " &amp; bulkReleaseStr;
		endif;
		if requestStr &lt;&gt; null then
			display := display &amp; CrLf &amp; "Request : " &amp; requestStr;
		endif;
		
		if workOrderStr &lt;&gt; null then
			display := display &amp; CrLf &amp; "Work Orders : " &amp; workOrderStr;
		endif;
		
		if bookingRefStr &lt;&gt; null then
			display := display &amp; CrLf &amp; "Booking Reference : " &amp; bookingRefStr;
		endif;
	else
		display := self.tiTextList;	
	endif;
epilog
	return display;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyCargoType" id="4e6db750-fab9-4c14-b06c-fb0857602df2">
