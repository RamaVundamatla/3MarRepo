    <JadeMethod name="getDisplayStringForAttribute" id="2d2d2ab0-644d-46f5-9a55-71bbf8c94e5b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 25 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _attrName = ETRow_MatchFound then
		return app.getYesNo(self.myBOL.matchTime.isValid);
		
	elseif _attrName = ETRow_DriversPieceCount then
		return self.getActualPieceCountError().String;	//23894	21/05/2010
		
	elseif _attrName = ETRow_PieceCountError then
		if self.hasPieceCountError() then	//#23894	21/05/2010
			return app.getErrorString(Yes);
		else
			return app.getErrorString(No);
		endif;

	else
	
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
