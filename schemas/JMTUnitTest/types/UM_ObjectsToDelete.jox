    <JadeMethod name="clearObjectToDelete" id="235d7b14-a877-4eb8-8ecf-fec2b65254b3">
        <updating/>
        <source>clearObjectToDelete() updating;

/*

Purpose:		

Date			Who		Reason
20 April 2015	cnwmh5	Initial creation

*/

vars

begin
	self.objectToDelete := null;
	self.objectToDeleteOid := null;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="6cc43eda-caa7-4be3-b213-07b4db254093">
        <updating/>
        <source>create() updating;

/*

Purpose:		

Date			Who		Reason
20/04/2015		cnwmh5	Initial creation

*/

vars

	root					: UM_Root;

begin

	root := UM_Root.firstInstance;
	if root = null then
		create root;
	endif;
	self.myRoot := root;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateDetails" id="20e0c656-ec1a-4c8f-950a-6b2f2e2b575e">
        <updating/>
        <source>updateDetails(_objectToDelete : Object; _whenToDelete : Integer) updating;

/*

Purpose:		

Date			Who		Reason
20/04/2015		cnwmh5	Initial creation

*/

vars

begin

	self.objectToDelete := _objectToDelete;
	self.objectToDeleteOid := _objectToDelete.getOidAsString();
	self.whenToDelete := _whenToDelete;

epilog

end;</source>
        <Parameter name="_objectToDelete" type="Object"/>
        <Parameter name="_whenToDelete" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateWhenToDelete" id="e509f9c6-342b-4796-a95c-6dec2eb90885">
        <updating/>
        <source>updateWhenToDelete(_whenToDelete : Integer) updating;

/*

Purpose:		

Date			Who		Reason
20/04/2015		cnwmh5	Initial creation

*/

vars

begin

	self.whenToDelete := _whenToDelete;

epilog

end;</source>
        <Parameter name="_whenToDelete" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="whenToDeleteStr" id="9d679751-d63c-44de-bbc1-5a067ed7d877">
        <methodInvocation>mapping</methodInvocation>
        <source>whenToDeleteStr(set: Boolean; _value: String io) mapping;

/*

Purpose:		

Date			Who		Reason
20/04/2015		cnwmh5	Initial creation

*/

vars

begin

	if set then
		return;
	else
		if self.whenToDelete = self.WhenToDeleteNext then
			_value := self.WhenToDeleteNextStr;
		elseif self.whenToDelete = self.WhenToDeleteNull then
			_value := self.WhenToDeleteNullStr;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
