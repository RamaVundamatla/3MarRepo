    </JadeMethod>
    <JadeMethod name="validateUpdate" id="83e9f0c7-0a58-4ae9-9951-c2cacd83a9c4">
        <source>validateUpdate(_passport: CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	tsArray : TimeStampArray;
	strArray : StringArray;
	ts : TimeStamp;
	index : Integer;
	str1 : String;
	str2 : String;
	opHrs : CM_WorkPointOperatingHours;

begin

	if self.myVoyage = null then
		app.raiseCMException( Voyage_been_entered, null, null);
	endif;

	if self.myCrane = null and self.myWorkPoint = null then
		app.raiseCMException( Timing_requir_valid_workpo_cra, null, null);
	elseif self.myCrane &lt;&gt; null and self.myWorkPoint &lt;&gt; null then
		app.raiseCMException( Crane_or_workpoint, null, null);
	endif;
	
	if not self.labourStart.Date.isValid then
	//	app.raiseCMException1( REQUIRED_FIELD, app.getErrorString(Labour_aboard), null, null);
		app.raiseCMException1( Input_required_field_Required, app.getErrorString(Labour_aboard), null, null); // cnwdb2	PAR 35364
	endif;
	
	//28 Aug 2012	NDL	Par 30279
//	if not self.exchangeStart.Date.isValid then
//		app.raiseCMException1( REQUIRED_FIELD, app.getErrorString(Exchange_start), null, null);
//	endif;
	
	if self.exchangeStart.Date.isValid then
		if self.myVoyage.shipExchangeDate.Date.isValid then
			if self.exchangeStart &lt; self.myVoyage.shipExchangeDate then
				str1 := self.craneWorkPointId &amp; " " &amp; app.getErrorString(Exchange_start);
				str2 := self.myVoyage.code &amp; " " &amp; app.getErrorString(Exchange_start);
				app.raiseCMException2(May_Not_be_before, str1, str2, null, null);
			endif;
		endif;
	endif;
	if self.exchangeEnd.Date.isValid then
		if self.myVoyage.shipExchangeCompleteDT.Date.isValid then
			if self.exchangeEnd &gt; self.myVoyage.shipExchangeCompleteDT then
				str2 := self.craneWorkPointId &amp; " " &amp; app.getErrorString(Exchange_end);
				str1 := self.myVoyage.code &amp; " " &amp; app.getErrorString(Exchange_end);
				app.raiseCMException2(May_Not_be_before, str1, str2, null, null);
			endif;
		endif;
	endif;
	if self.labourStart.Date.isValid then
		if self.myVoyage.labourOnBoard.Date.isValid then
			if self.labourStart &lt; self.myVoyage.labourOnBoard then
				str1 := self.craneWorkPointId &amp; " " &amp; app.getErrorString(Labour_aboard);
				str2 := self.myVoyage.code &amp; " " &amp; app.getErrorString(Labour_aboard);
				app.raiseCMException2(May_Not_be_before, str1, str2, null, null);
			endif;
		endif;
	endif;
	if self.labourEnd.Date.isValid then
		if self.myVoyage.labourOnShore.Date.isValid then
			if self.labourEnd &gt; self.myVoyage.labourOnShore then
				str2 := self.craneWorkPointId &amp; " " &amp; app.getErrorString(Labour_ashore);
				str1 := self.myVoyage.code &amp; " " &amp; app.getErrorString(Labour_ashore);
				app.raiseCMException2(May_Not_be_before, str1, str2, null, null);
			endif;
		endif;
	endif;
	
	if self.exchangeEnd.Date.isValid then
		if not self.exchangeStart.Date.isValid then
			app.raiseCMException1( Start_time_required, app.getErrorString(Exchange_date), null, null);
		elseif self.exchangeEnd &lt;= self.exchangeStart then
			app.raiseCMException1( EndBeforeStart, app.getErrorString(Exchange_date), null, null);
		endif;
	endif;
	
	if self.labourEnd.Date.isValid then
		if not self.labourStart.Date.isValid then
			app.raiseCMException1( Start_time_required, app.getErrorString(Labour_aboard), null, null);
		elseif self.labourEnd &lt;= self.labourStart then
			app.raiseCMException1( EndBeforeStart, app.getErrorString(Labour_aboard), null, null);
		endif;
	endif;
	
	// TimeStamps must be in this order.
	
	//Labour Aboard
	//Exchange Start
	//Exchange End
	//Labour Ashore
	
	create tsArray transient;
	create strArray transient;
	
	if self.labourStart.Date.isValid then
		tsArray.add(self.labourStart);
		strArray.add(app.getErrorString(Labour_aboard));
	endif;
	if self.exchangeStart.Date.isValid then
		tsArray.add(self.exchangeStart);
		strArray.add(app.getErrorString(Exchange_start));
	endif;
	if self.exchangeEnd.Date.isValid then
		tsArray.add(self.exchangeEnd);
		strArray.add(app.getErrorString(Exchange_end));
	endif;
	if self.labourEnd.Date.isValid then
		tsArray.add(self.labourEnd);
		strArray.add(app.getErrorString(Labour_ashore));
	endif;
	
	if tsArray.size &gt; 1 then
		foreach index in 2 to tsArray.size do
			if tsArray[index] &lt; tsArray[index -1] then
				app.raiseCMException2(May_Not_be_before, strArray[index], strArray[index -1], null, null);
			endif;
		endforeach;
	endif;
	
	if not self.isTransient then
		foreach opHrs in self.myVoyage.allWorkPointOperatingHours do
			if opHrs = self then
				continue;
			endif;
			if opHrs.overlapsMe(self) then
				app.raiseCMException(Labour_dates_overlap, null, null);
			endif;
		endforeach;
	endif;

epilog

	delete tsArray;
	delete strArray;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
