vars

begin
	app.initialize();
	
	app.msgBox("Textual content of the message for test purpses only!!! Via the JSSMsgBoxForm","Message Box heading", -5);
	
	app.msgBox("Textual content of the message for test purpses only!!! Via the normal method","Message Box heading", MsgBox_Retry_Cancel);
	
	app.finalize();
end;</source>
