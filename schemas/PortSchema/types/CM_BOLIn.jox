    <JadeMethod name="getDetailForRemoteQuery" id="c2c2e22c-4f97-4745-b6c5-8a8c6dba52c7">
        <source>getDetailForRemoteQuery(_version : Integer): String;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	response,
	id,
	supplier,
	location,
	area,
	versioning,
	extraV5,logCon,loadCon	: String;
	
			
begin

	if self.myExtension &lt;&gt; null then


		if _version &gt;= 5 then
			// CCMS 1082
			if self.myHandlingContractor1 &lt;&gt; null then
				logCon := self.myHandlingContractor1.code;
			else
				logCon := self.handlingContractor1Code;
			endif;
			if self.myHandlingContractor2 &lt;&gt; null then
				loadCon := self.myHandlingContractor2.code;
			else
				loadCon := self.handlingContractor2Code;
			endif;
			extraV5 := self.matchTime.date.formatAsYYYYMMDD() &amp;" " &amp; self.matchTime.time.formatAsHHMMSS() &amp; "," &amp; 
				self.consignor  &amp; "," &amp; 
				self.loggingOperation &amp; "," &amp; 
				logCon &amp; "," &amp; 
				loadCon &amp; ",";
		endif;
		id 	:= self.number;
		location	:= self.origLocationControllerId;
		area		:= self.origTerminalAreaId;
		if self.myOperator &lt;&gt; null then
			supplier := self.myOperator.code;
		endif;
		if _version &gt;= 4 then
			versioning := self.dateTime.date.formatAsYYYYMMDD() &amp; ',' &amp;
			self.truckNumber &amp; ',' &amp;
			self.trailerNumber &amp; ',';
		endif;
		response := id &amp; ',' &amp; area &amp; ',' &amp; location &amp; ',' &amp; supplier &amp; ',' &amp; 
		//self.loggingOrganisation &amp; ',' &amp;    //21/01/2010 #cnwdz2	 CCMS 1108 par22177 
		self.getLoggingOrganisation() &amp; ',' &amp;
		self.sourceLocation &amp; ',' &amp; 
		self.sourceSubLocation &amp; ',' &amp; 
		self.sourceSubSubLocation &amp; ',' &amp;
		versioning &amp; 
		
		extraV5 &amp; 
		self.myExtension.getDetailForBol(_version) &amp; ',' &amp; 
		self.weightNetTonnes.String &amp; ','  &amp; 
		self.numTIs.String;
	endif;

	return response;
end;</source>
        <Parameter name="_version" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="c01aba5d-9db8-476f-a16c-424233dea493">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 13 May 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 25/06/2014	cnwdap1		PAR #34313 Added moveAmount
// 16 Dec 2021  navma1		ChangeRequest 52580: SAL - Work Order and Invoicing link
// 23 Aug 2022	navpw1		Bug 54634: MTN - Invalid Property error for ShippingLineCode when opening the Road Operations screen
// 11 Aug 2025	naviv1		MTN-35544 : FR 35007.010 Display Release Request ID in Road Ops
vars
	count		   : Integer;
	logDocketError : CM_DocketError;
	ti			   : CM_TrackedItem;
begin
	if self.allDocketErrors &lt;&gt; null and not self.allDocketErrors.isEmpty() then
		logDocketError := self.allDocketErrors.first();  //ccms 1110
	endif;
	
	if _attrName = ETRow_Location or
	   _attrName = ETRow_MyLocation then
		if self.origTerminalAreaId &lt;&gt; null then
			return self.origTerminalAreaId &amp; ' ' &amp; self.origLocationControllerId;
		else
			if self.myPlannedLocation &lt;&gt; null then
				return self.myPlannedLocation.getID;
			else
				return null;
			endif;
		endif;
	elseif _attrName = ETRow_MyPlannedLocation then
		if self.myPlannedLocation &lt;&gt; null then
			return self.myPlannedLocation.getID;
		else
			return self.origTerminalAreaId &amp; ' ' &amp; self.origLocationControllerId;
		endif;
	elseif _attrName = ETRow_MyReceivalTerminal then
		if self.myReceivalTerminal &lt;&gt; null then
			return self.myReceivalTerminal.name;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Opt then
		return 'false';	
	elseif _attrName = ETRow_DocketError then		///ccms 1110 begins
		
		if logDocketError &lt;&gt; null then
			return logDocketError.docketErrorCode &amp; " " &amp;logDocketError.docketErrorDesc;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_DriversPieceCount then	// #23894 21/10/2009
		if self.myExtension.CM_BOLExtLogIn.hasPieceCountError() then
			return self.myExtension.CM_BOLExtLogIn.getActualPieceCountError().String;	
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_PieceCountError then	// #23894 21/10/2009
		if self.myExtension.CM_BOLExtLogIn.hasPieceCountError() then
			return app.getErrorString(Yes);
		else
			return app.getErrorString(No);
		endif;
		
	elseif _attrName = ETRow_AverageSED then
		return self.getAverageSED().jasVolumeString();
	elseif _attrName = ETRow_MatchDate then
		return self.systemToLocalTime(self.matchTime).date.shortFormatJMT();	// 19/04/2016 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_LoggingOperation then
		return self.loggingOperation;
	elseif _attrName = ETRow_UnloadPoint then
		return self.unloadPoint;
	elseif _attrName = ETRow_LoggingOrganisation then
		return self.getLoggingOrganisation();
	elseif _attrName = ETRow_Opid then
		return self.opid;
	elseif _attrName = ETRow_Vessel then
		if self.myVoyage &lt;&gt; null then
			if self.myVoyage.getMyVessel &lt;&gt; null then
				return self.myVoyage.getMyVessel().name;
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_Voyage or _attrName = ETRow_VoyageCode then			//+cnwml2 MSL CCMS 1071
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.getDisplayDetails(true);
		endif;
		return null;	
	elseif _attrName = ETRow_USCustomsNumEntries then
        return self.customsQuantityEntered.asStringJMT(); //cnwgb1 28/5/2014 CCMS 2353
	elseif _attrName =ETRow_USCustomsNumReleased then
        return self.customsQuantityReleased.asStringJMT(); //cnwgb1 28/5/2014 CCMS 2353
	elseif _attrName = ETRow_USCustomsPortDischarge then
			app.getErrorString(NoAMSInfo);
	elseif _attrName = ETRow_USCustomsPortOfLading then
		return app.getErrorString(NoAMSInfo);
	elseif _attrName = ETRow_USCustomsStatus then
		return app.getErrorString(NoAMSInfo);
	elseif _attrName = ETRow_IsFSC then	//ccms jml 1105, par 21535 Nov 2009
		return self.myExtension.CM_BOLExtLogIn.isCertified().getYesNo();				
	elseif _attrName.isOneOf(ETRow_NumOnsiteTIs, ETRow_NumberOfItems, ETRow_TotalQuantity, ETRow_MoveAmount) then		// PAR #34313
		foreach ti in self.allTrackedItems where ti.myBOLDtl = null do
			count := count + 1;
		endforeach;
		return count.asStringJMT();
	elseif _attrName = ETRow_Colour then
		return null;
	// ### TFS 54634 23Aug2022 NAVPW1
	elseif _attrName = ETRow_ShippingLineCode then
		return null;
	elseif _attrName = ETRow_ShippingLineDesc then
		return null;
	// ### TFS 54634 23Aug2022 NAVPW
	elseif _attrName = ETRow_TrailerID or //jlier1 TFS 54700 15/9/22
			_attrName = ETRow_TrailerLocation or 
			_attrName = ETRow_TrailerOperator then
			return  null;
	elseif _attrName = ETRow_ReleaseNumber then //MTN-35544
		return null;
	elseif _attrName = ETRow_CargoTypeCodeForCntnt then		// MTN-36554
		return null;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDriversPieceCount" id="dae0d21e-5e95-490e-a6b4-bd5f4f12d10b">
