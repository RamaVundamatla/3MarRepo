    <JadeMethod name="getVehicleNumber" id="5f10ee58-0f57-4e62-86e0-3a0d74c930cf">
        <source>getVehicleNumber() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2023	navra1	Initial creation for TFS 59666 - EUP - CallOff fields not available in the column organiser
04 Oct 2023	jlika1	TFS 60232 - EUP | FR 54871 - EDI Management for New EDI Types
*/

vars
	tisOfRequestMultiLine  		: CM_EDITIById;
	found						: Boolean;
	ediTi 						: CM_EDITrackedItem;
begin

	if self.myRequestMultiLine = null then
		return null;
	endif;
	
	tisOfRequestMultiLine := self.myRequestMultiLine.allEDITrackedItems;
	
	foreach ediTi in tisOfRequestMultiLine do
		if ediTi.isKindOf(CM_EDIRequestHeaderTI) then
			found := true;
			break;
		endif;
	endforeach;
	
	if found then
		return ediTi.CM_EDIRequestHeaderTI.regNumber;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVesselName" id="db1699fc-adc2-4e6e-a8d0-3ca1a885df66">
        <source>getVesselName(): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 02 October 2023
TFS#		: 60232
Function	:

*** Changes ***
Date			Name		TFS#		Description
12 Feb 2024		navhn30		Bug 62209: FR | 54871 - EDI Administration Usability

****************************************************/

vars
	voyageCode : String;
	voyage	   : CM_Voyage;
	vessel	   : CM_Vessel;
begin
	voyageCode := self.getVoyageCode();
	voyage :=  self.getMyTerminal().lookupVoyage(voyageCode, null, false);		// 12.02.24		navhn30		TFS #62209
	if voyage &lt;&gt; null then
		vessel := voyage.getMyVessel();
		if vessel &lt;&gt; null then
			return vessel.name;
		endif;
	else 
		return null;
	endif;
	
	return null;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
