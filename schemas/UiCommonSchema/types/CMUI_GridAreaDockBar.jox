    <JadeMethod name="cnEcResizeContents" id="e89cbc95-1aff-429b-8e2b-69973ac3d4ca">
        <updating/>
        <source>cnEcResizeContents() updating;
// ---------------------------------------------------------------------------
// Created:     06 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	if self.myScrollableFrame &lt;&gt; null then
		
		self.myScrollableFrame.repositionScrollBars();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="createScrollableFrame" id="b5ac5182-1c5e-40aa-8436-bb9df59aceb4">
        <updating/>
        <source>createScrollableFrame() updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpScrollableFrame	: CMUI_GridAreaScrollableFrame;
	
begin

	if (self.isInPainter) then
		return;
	endif;
	
	create tmpScrollableFrame transient;
	self.myScrollableFrame := tmpScrollableFrame;
	
	tmpScrollableFrame.bevelInner := Frame.Bevel_None;
	tmpScrollableFrame.bevelOuter := Frame.Bevel_None;
	tmpScrollableFrame.borderStyle := Frame.BorderStyle_None;
	tmpScrollableFrame.boundaryWidth := 0;
	tmpScrollableFrame.ignoreSkin := true;
	tmpScrollableFrame.parent := self;
	tmpScrollableFrame.alignContainer := Frame.AlignContainer_All;

	self.form.addControl(tmpScrollableFrame);

	self.setScrolledCallbackMethod('handleGridAreaScrolledEvent');

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doScrollToCorners" id="47f83eca-8956-48e7-91e7-c16393ec9088">
        <updating/>
        <source>doScrollToCorners(pCorner: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if pCorner = VIEW_LEFT_TOP then
		self.myScrollableFrame.scrollTopLeft();
	elseif pCorner = VIEW_RIGHT_TOP then
		self.myScrollableFrame.scrollTopRight();
	elseif pCorner = VIEW_LEFT_BOTTOM then
		self.myScrollableFrame.scrollBottomLeft();
	elseif pCorner = VIEW_RIGHT_BOTTOM then
		self.myScrollableFrame.scrollBottomRight();
	endif;

end;</source>
        <Parameter name="pCorner" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCurrentScrollableFrmValues" id="30a441c5-1ea3-4fef-9e3b-cec226fe1141">
        <source>getCurrentScrollableFrmValues(_hScrollValue, _vScrollValue : Integer output; _width, _height : Real output);
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpScrollFrame	: CMUI_ScrollableFrame;
begin
	tmpScrollFrame := self.myScrollableFrame;
	if tmpScrollFrame = null then
		return;
	endif;
	
	_hScrollValue := tmpScrollFrame.getHScrollValue();
	_vScrollValue := tmpScrollFrame.getVScrollValue();
	_width := tmpScrollFrame.width;
	_height := tmpScrollFrame.height;
end;</source>
        <Parameter name="_hScrollValue" type="Integer" usage="output"/>
        <Parameter name="_vScrollValue" type="Integer" usage="output"/>
        <Parameter name="_width" type="Real" usage="output"/>
        <Parameter name="_height" type="Real" usage="output"/>
    </JadeMethod>
