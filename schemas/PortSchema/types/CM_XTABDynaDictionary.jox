    <JadeMethod name="createTransientMethod" id="3ea32283-8aea-43f3-8faa-f022fa9cdd30">
        <source>createTransientMethod( _source : String; _param1, _param2, _methodName : String ) : JadeMethod protected;
// ---------------------------------------------------------------------------
// Created:     08 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	strSource	: String;
	meth		: JadeMethod;
	errorCode	: Integer;
	errorPos	: Integer;
	errorLength	: Integer;
	
begin
	strSource 	:= _source.replaceString( '%params1', _param1 );
	strSource 	:= strSource.replaceString( '%params2', _param2 );
	meth		:= process.createTransientMethod(	_methodName,
													self.class,
													currentSchema,
													strSource,
													false,
													CMIF_OutputGrouping,
													errorCode,
													errorPos,
													errorLength );
	if errorCode &lt;&gt; null then
		write strSource &amp; CrLf &amp; errorCode.display &amp; ' ' &amp; errorPos.display &amp; ' ' &amp; errorLength.display;
		app.raiseUnexpectedProgramError( self.class.name, method.name, 'Unable to compile methods for XTAB' );
	endif;
	
	return meth;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_source" type="String"/>
        <Parameter name="_param1" type="String"/>
        <Parameter name="_param2" type="String"/>
        <Parameter name="_methodName" type="String"/>
        <ReturnType type="JadeMethod"/>
    </JadeMethod>
