<GUIClass name="CMUI_EDIDataTypeSelectForm" id="2c9e4f47-2e7a-42c9-891d-344f108d08b0">
    <superclass name="CMUI_CriteriaSelectForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <CompAttribute name="allEDIFileTypes" id="865931ae-8e13-4157-8166-35536c5f08e4">
        <type name="IntegerArray"/>
        <access>readonly</access>
    </CompAttribute>
    <JadeMethod name="createTransients" id="1833e5a5-4f10-4e12-b725-3a0f78de2a15">
        <updating/>
        <source>createTransients()updating, protected;
/*
Date		Who		Reason
22 February 2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
15/03/2012			cnwcs5	Take out 'All'
*/
vars
	agent	:CM_EDIControllerAgent;
	array	:IntegerArray;
	int		:Integer;
	str		:String;
	obj		:CM_Association;
begin
	create agent transient;
	create array transient;
		
	// now add in the rest of the EDI data types
	//epr TFS 3642 9/3/17
	agent.getVoyageCutoffEDIDataTypes(array);
	
	foreach int in array do
		
		str := agent.getEDIDisplayStrForType (int);
		
		create obj transient;
		obj.set2Values (int, str);
		
		self.allTransients.add (obj);
	endforeach;
epilog
	delete agent;
	delete array;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="f31bc68c-d39b-4c31-a53f-170469d71fca">
        <updating/>
        <source>doOK() updating;
/*
Date		Who		Reason
22 February 2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars
	coll	:IntegerArray;
	obj		:Object;
begin
	coll := self.allEDIFileTypes;
	
	foreach obj in self.tblAvailable.allSelectedObjects do
		coll.add (obj.CM_Association.asInteger);
	endforeach;
	
	inheritMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCollectionToLoad" id="6a216f24-26d1-42e3-9f75-958fe3fbf876">
        <source>getCollectionToLoad(_coll, _selectedColl: ObjectSet input) protected;
/*
Date		Who		Reason
22 February 2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars
	obj		:Object;
	coll	:IntegerArray;
begin
	// save off what is selected
	coll := self.allEDIFileTypes;
	
	if not coll.isEmpty then
		foreach obj in self.allTransients do
			if coll.includes (obj.CM_Association.asInteger) then
				_selectedColl.add (obj);
			endif;
		endforeach;
	
		coll.clear;	// only use it once
	else
		self.tblAvailable.allSelectedObjects.copy (_selectedColl);
	endif;
	
	if self.optSelected.value then
		_selectedColl.copy (_coll);
	else
		// show all values
		self.allTransients.copy (_coll);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="ObjectSet" usage="input"/>
        <Parameter name="_selectedColl" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="a3cf8560-51e7-45da-abf3-2a94ce852de7">
        <source>getValue(_obj: CM_Association): String protected;
/*
Date		Who		Reason
28 February 2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars

begin
	return _obj.asString;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Association"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadTable" id="5d2f0d26-86bf-463b-8a55-bcf46e2cc144">
        <source>loadTable(_coll, _selectedColl: ObjectSet) protected;
/*
Date		Who		Reason
22/12/2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars
	table		:CMUI_ListTable;
	row			:Integer;
	obj			:Object;
	str			:String;
begin
	table := self.tblAvailable;
	
	foreach obj in _coll do		
		str := obj.CM_Association.asString;
		
		if str &lt;&gt; null then
			row := table.addItemObject( str, obj);
		endif;
	endforeach;

	table.setSelected( _selectedColl );

epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="ObjectSet"/>
        <Parameter name="_selectedColl" type="ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c7f349a4-0488-4a87-9f95-1faa0545b4a6">
        <updating/>
        <source>setupForm() updating;
/*
Date		Who		Reason
28 February 2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars

begin
	self.createTransients;

	inheritMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a1852bdd-c7f5-4074-a936-3d290e4e64b2">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018729, locale);
end;</source>
    </JadeMethod>
</GUIClass>
