    <JadeMethod name="trxDeleteRailAllocsForWagons" id="3ef1883a-1e8e-43e6-9c7c-d860861aa764">
        <updating/>
        <source>trxDeleteRailAllocsForWagons(_wagonColl	: ObjectSet input; _passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 July 2009	cnwmd1	Initial creation

*/
vars
	obj : Object;
	wagon : CM_Wagon;
	railAlloc : CM_RailAllocation;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	// Start the transaction
	beginTransaction;

	foreach obj in _wagonColl do
		wagon := obj.CM_Wagon;
		railAlloc := wagon.getRailAllocation();
		if railAlloc &lt;&gt; null then
			app.myUtilityDA.utlDeleteRailAllocation(railAlloc, _passport);
		endif;
		app.myEventManager.createSingleObjInfoNoteEvt(wagon, _passport.myTerminal.getTerminalEvent(Wagon_Update_Event), wagon); //notify all wagons affected
	endforeach;
epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_wagonColl" type="ObjectSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
