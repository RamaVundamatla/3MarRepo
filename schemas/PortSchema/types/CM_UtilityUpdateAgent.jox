        <source>utlUpdateTerminalAreaView(	_proxyAreaView: CM_TerminalAreaView;
							_areaView : CM_TerminalAreaView io;
							_passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
02 September 2008	consw1	Initial creation

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivity();

	_proxyAreaView.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	
	app.myValUA.valTerminalAreaView(_areaView, _proxyAreaView);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(_areaView);

	// ====================================================
	// now do the update
	app.setContinueCMExceptions(false);

	if _passport.noErrors then 
	// This is only required if the class is being auditted 
		self.myUpdateAuditAgent.audUpdateGeneric(_areaView, true); 
	endif; 


	if _passport.noErrors() then
		_areaView.setForUpdate(_proxyAreaView);
		updateObjectEdition(_areaView);
	endif;

	if _passport.noErrors then 
	// This is only required if the class is being auditted 
		self.myUpdateAuditAgent.audUpdateGeneric(_areaView, false); 
	endif; 

	app.myEventManager.createSingleObjInfoNoteEvt(_areaView,_passport.myTerminal.getTerminalEvent(Event_TAView_Update),_passport.myUser);
epilog

end;</source>
        <Parameter name="_proxyAreaView" type="CM_TerminalAreaView"/>
