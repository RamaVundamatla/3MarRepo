<Class name="UT_VehicleScheduling" id="a6328277-4f16-487d-831c-b2d65eb331e1">
    <superclass name="UT_Gate"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="addBookingAndCargo" id="bfbfd89b-4a59-4edd-8a35-6593d5d12a21">
        <updating/>
        <source>addBookingAndCargo( vssTimeSlot : CM_VehicleBookingTimeSlot input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Oct 2014	cnwndl1	Initial creation	Par 35008
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
*/

constants

	CargoId1 :String = "UTPN7686866";
	CargoId2 :String = "UTPN7696967";
	RoadBooking : String = "UTVBSBOOK";
	VoyCode : String = "UTVOY1UT";
	
vars

	cargo1 : CM_TrackedItem;
	cargo2 : CM_TrackedItem;
	operator : CM_Operator;
	cargoType : CM_CargoType;
	booking : CM_BookingRef;
	loadState : Boolean;
	strArray : StringArray;
	allDeliveryIds, allPickupIds : StringArray;			// TFS 51248
	vbtsProxy : CM_VehicleBookingTimeSlot;
	allBookings : CM_BookingRefSet;
	voyage : CM_Voyage;

begin

	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString].CM_Operator;
	voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq( VoyCode, null );

	//create on-site cargo to use
	
	self.deleteContainer( CargoId1 );
	self.deleteContainer( CargoId2 );
	
	self.opts.purge();
	if voyage &lt;&gt; null then
		self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
		self.opts.addAssoc(UTTI_DischargePort, app.myRoot.allPorts["NZAKL"].code);
	endif;
	self.opts.addAssoc("STATE", TI_STATE_NOTIFIED);		// TFS 51248
	cargo1 := self.addContainer(CargoId1, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT);
	cargo2 := self.addContainer(CargoId2, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT);
	self.assertTrueMsg(cargo1 &lt;&gt; null , "27A. Failed to create cargo1 to add.");
	self.assertTrueMsg(cargo2 &lt;&gt; null , "27B. Failed to create cargo2 to add.");
	
	//create a bulk release to associate
	self.deleteBooking(RoadBooking);
	
	booking := self.addBookingForContainer(RoadBooking, operator, voyage, "NZAKL", "4200", "MT");
	self.assertTrueMsg(booking &lt;&gt; null , "27C. Failed to create booking to add.");
	
	
	// create a proxy, populate changes and update
	app.cmsBeginLoad(loadState);
	vbtsProxy := vssTimeSlot.pxyCreateUpdateProxy().CM_VehicleBookingTimeSlot;
	app.cmsEndLoad(loadState);
	
	create strArray transient;
	create allDeliveryIds transient;					// TFS 51248
	create allPickupIds transient;						// TFS 51248
	strArray.add( CargoId1 );
	strArray.add( CargoId2 );
	allDeliveryIds.add( CargoId1 );						// TFS 51248
	allDeliveryIds.add( CargoId2 );						// TFS 51248
	
	create allBookings transient;
	allBookings.add( booking );
	
	vbtsProxy.setProxy(	vssTimeSlot.bookingTSstart,	//_scheduleTSstart : TimeStamp;
						vssTimeSlot.bookingTSend,	//_scheduleTSend : TimeStamp;
						vssTimeSlot.myVehicleBookingTerminal,	//_myVBTerminal : CM_VehicleBookingTerminal;
						vssTimeSlot.myCarrier,	//_myCarrier : CM_Carrier;
						null,					//_mySubCarrier : CM_Carrier;
						vssTimeSlot.myDriver,	//_myDriver : CM_DriverDetails;
						vssTimeSlot.myVehicle,	//_myVehicle : CM_Vehicle;
						vssTimeSlot.remarks,	//_remarks : String;
						true,	//_includesDelivery : Boolean;
						true,	//_includesPickUp : Boolean;
						strArray,	//_bookedTiIds : StringArray;
						vssTimeSlot.myVehicleVisitRecord,	//_myVehicleVisitRecord : CM_VehicleVisitRecord
						vssTimeSlot.myVBTimeSlotType,	//_myVBTimeslotType : CM_VehicleBookingTimeSlotType
						vssTimeSlot.id,	//_id : String;
						allBookings,	//_allBookingRefs : CM_BookingRefSet;
						vssTimeSlot.allBulkReleases,	//_allBulkReleases : CM_BulkReleaseSet
						null,	//_allVBSTimeSlots : CM_VehicleBookingTSItemSet;
						null,	//_preGateInCheck : Boolean;
						null,	//_preGateOutChck : Boolean;
						null,	//_kioskCheck : Boolean;
						null,	//_externalReference : String
						null	//_myTILCType : CM_TILCType	// 08 Aug 2024 navcs2	ChangeRequest 63928
						);
					
	//app.myTrxUA.trxUpdateVehicleBooking(vbtsProxy, app.myPassport);									// TFS 51248
	app.myTrxUA.trxUpdateVehicleBooking(vbtsProxy, allDeliveryIds, allPickupIds, app.myPassport);		// TFS 51248
	self.assertTrueMsg(app.myPassport.noErrors , "26C. Failed to update vehicle booking timeslot with bulk release and pre-note.");
	
epilog

	delete strArray;
	delete allDeliveryIds;			// TFS 51248
	delete allPickupIds; 			// TFS 51248
	delete vbtsProxy;
	delete allBookings;

end;</source>
        <Parameter name="vssTimeSlot" type="CM_VehicleBookingTimeSlot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addPreNoteAndRelease" id="c8ea5589-da73-47cc-b845-713aa89d9fb8">
        <source>addPreNoteAndRelease( vssTimeSlot : CM_VehicleBookingTimeSlot input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Oct 2014	cnwndl1	Initial creation	Par 35008
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
*/

constants

	Prenote1Id :String = "UTPN7676765"; 
	RoadRelRequest : String = "UTVBSREL";
	
vars

	preNote : CM_TrackedItem;
	operator : CM_Operator;
	cargoType : CM_CargoType;
	bulkRelease : CM_BulkRelease;
	loadState : Boolean;
	strArray : StringArray;
	allDeliveryIds, allPickupIds : StringArray;			// TFS 51248
	vbtsProxy : CM_VehicleBookingTimeSlot;
	allBulkReleases : CM_BulkReleaseSet;

begin

	//create pre-note to use
	self.deleteContainer( Prenote1Id );
	
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString].CM_Operator;
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	
	self.opts.purge();
	self.opts.addAssoc('transMode', TI_TRANSMODE_ROAD);
	preNote := self.uAddPrenote(Prenote1Id, "2200", operator, cargoType);
	self.assertTrueMsg(preNote &lt;&gt; null , "26A. Failed to create pre-note to add.");
	
	
	//create a bulk release to associate
	self.deleteReleaseRequest(RoadRelRequest);
	
	self.opts.purge();
	self.opts.addAssoc("Number", 1);
	self.opts.addAssoc("FullRelease", false);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	bulkRelease := self.addReleaseByTypeRequest(RoadRelRequest, BR_TYPE_ROAD, TI_CargoType_Container, "2200");
	self.assertTrueMsg(bulkRelease &lt;&gt; null , "26B. Failed to create bulk release to add.");
	
	
	// create a proxy, populate changes and update
	app.cmsBeginLoad(loadState);
	vbtsProxy := vssTimeSlot.pxyCreateUpdateProxy().CM_VehicleBookingTimeSlot;
	app.cmsEndLoad(loadState);
	
	create strArray transient;
	create allDeliveryIds transient;		// TFS 51248
	create allPickupIds transient;			// TFS 51248
	strArray.add( Prenote1Id );
	allDeliveryIds.add( Prenote1Id );		// TFS 51248
	
	create allBulkReleases transient;
	allBulkReleases.add( bulkRelease );
	
	vbtsProxy.setProxy(	vssTimeSlot.bookingTSstart,	//_scheduleTSstart : TimeStamp;
						vssTimeSlot.bookingTSend,	//_scheduleTSend : TimeStamp;
						vssTimeSlot.myVehicleBookingTerminal,	//_myVBTerminal : CM_VehicleBookingTerminal;
						vssTimeSlot.myCarrier,	//_myCarrier : CM_Carrier;
						null,					//_mySubCarrier : CM_Carrier;
						vssTimeSlot.myDriver,	//_myDriver : CM_DriverDetails;
						vssTimeSlot.myVehicle,	//_myVehicle : CM_Vehicle;
						vssTimeSlot.remarks,	//_remarks : String;
						true,	//_includesDelivery : Boolean;
						true,	//_includesPickUp : Boolean;
						strArray,	//_bookedTiIds : StringArray;
						vssTimeSlot.myVehicleVisitRecord,	//_myVehicleVisitRecord : CM_VehicleVisitRecord
						vssTimeSlot.myVBTimeSlotType,	//_myVBTimeslotType : CM_VehicleBookingTimeSlotType
						vssTimeSlot.id,	//_id : String;
						vssTimeSlot.allBookingRefs,	//_allBookingRefs : CM_BookingRefSet;
						allBulkReleases,	//_allBulkReleases : CM_BulkReleaseSet
						null,			//_allVBSTimeSlots : CM_VehicleBookingTSItemSet;
						null,			//_preGateInCheck : Boolean;
						null,			//_preGateOutChck : Boolean;
						null,			//_kioskCheck : Boolean;
						null,			//_externalReference : String
						null);			//_myTILCType : CM_TILCType	// 08 Aug 2024 navcs2	ChangeRequest 63928
					
	//app.myTrxUA.trxUpdateVehicleBooking(vbtsProxy, app.myPassport);									// TFS 51248
	app.myTrxUA.trxUpdateVehicleBooking(vbtsProxy, allDeliveryIds, allPickupIds, app.myPassport);		// TFS 51248
	self.assertTrueMsg(app.myPassport.noErrors , "26C. Failed to update vehicle booking timeslot with bulk release and pre-note.");
	
epilog

	delete strArray;
	delete allDeliveryIds;			// TFS 51248
	delete allPickupIds;			// TFS 51248
	delete vbtsProxy;
	delete allBulkReleases;

end;</source>
        <Parameter name="vssTimeSlot" type="CM_VehicleBookingTimeSlot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addSpecialCalendar" id="94b150b4-a760-409c-9ac5-829384f77697">
        <source>addSpecialCalendar( specialDate : Date ):CM_Calendar;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars
	calendar		: CM_Calendar;
	startDate		: Date;
	
	calendarDateProxy : CM_CalendarDate;
	calendarDate	: CM_CalendarDate;
	year : Integer;
	nullTime	: Time;
	calendarYear : CM_CalendarYear;
	calendarYearProxy : CM_CalendarYear;

begin
	self.deleteCalendar("UTZZ", "UTZZ");
	
	calendar := self.createCalendar("UTZZ", "Vehicle Schedule Special", false, false, "UTZZ");
	self.assertTrueMsg(calendar &lt;&gt; null, "UTZZ special calendar not created.");
	
	create calendarYearProxy transient;
	calendarYearProxy.setProxy( specialDate.year, calendar);
	app.myTrxCA.trxCreateCalendarYear(calendarYearProxy, calendarYear, app.myPassport, false);
	self.assertTrueMsg(calendar &lt;&gt; null, "UTZZ special calendar year not created.");
	
	create calendarDateProxy transient;
	calendarDateProxy.setProxy(	specialDate,	//_date : Date;
								"VS Special dates",	//_description : String;
								calendar,	//_myCalendar : CM_Calendar;
								calendarYear,	//_myCalendarYear : CM_CalendarYear
								0	//_dataSource : Integer
								);
	nullTime := "00:00:00".Time;
	calendarDateProxy.setStartEndTime( nullTime, nullTime );
	app.myTrxCA.trxCreateCalendarDate(calendarDateProxy, calendarDate, app.myPassport);
	self.assertTrueMsg(calendar &lt;&gt; null, "Calendar date not created " &amp; specialDate.asStringJMT &amp; ".");
	
	return calendar;
	
epilog

	delete calendarYearProxy;
	delete calendarDateProxy;

end;</source>
        <Parameter name="specialDate" type="Date"/>
        <ReturnType type="CM_Calendar"/>
    </JadeMethod>
    <JadeMethod name="createVbsTimeSlotItem" id="98ca904f-893d-419d-81f8-37b3233d403b">
        <source>createVbsTimeSlotItem(_vbsTimeSlotItem : CM_VehicleBookingTimeSlot; _cargoRef : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 September 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot

*/

constants
	SOURCE_CARGO : Integer = 2;
	REF = UT_DSL.TFS53899;
vars
	vbsTimeSlotItem : CM_VehicleBookingTimeSlotItem;
	direction,		
	quantity, 
	sequence,
	sourceType		: Integer;
	trackedItem		: CM_TrackedItem;
begin
	
	direction  := DIRECTION_DELIVERY;
	quantity   := 0;
	sequence   := 0;
	sourceType := SOURCE_CARGO;
	
	self.deleteContainer(_cargoRef &amp; REF);
	trackedItem := self.addPrenoted(_cargoRef &amp; REF);	
	
	create vbsTimeSlotItem transient;
	
	vbsTimeSlotItem.setProxy(direction,
							null,
							null,
							null,
							null,
							trackedItem,
							_vbsTimeSlotItem,
							quantity,
							sequence,
							sourceType,
							0,
							0,
							null);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
							
	
epilog

end;</source>
        <Parameter name="_vbsTimeSlotItem" type="CM_VehicleBookingTimeSlot"/>
        <Parameter name="_cargoRef" type="String"/>
    </JadeMethod>
