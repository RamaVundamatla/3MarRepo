    <JadeMethod name="pxyCreateUpdateProxy" id="6bdec5a4-77e5-4785-8853-4f6e25279832">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     07 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	pxyRail		: CM_Rail;
	pxyRailLine	: CM_RailLine;
	idx			: Integer;
	completedOK		: Boolean;
	
begin

	pxyRail := inheritMethod();

	pxyRail.myTransferArea	:= self.myTransferArea;
	foreach idx in 1 to self.numberOfRailLines do
		create pxyRailLine transient;
		pxyRailLine.setForCreate(idx.String.padLeadingZeros(2) &amp; "##" ,self.numberOfWagonPositions); // ## in the ID are to overcome duplicate ID (Proxy/Real)
		pxyRail.addRailLine(pxyRailLine,0);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyRail;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyRail;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="09c1bce7-823c-4cbe-a252-9b761820fec8">
        <updating/>
        <source>setForCreate(_proxy :CM_Rail input; _passport : CM_Passport input) updating;
//setForCreate(_proxy : CM_Rail; _passport : CM_Passport input) updating;
/*
 ------------------------------------------------------------------------
Created:			16 July 2001 by cnwdwq1
Purpose:			!     
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin	


	inheritMethod(_proxy, _passport);

	self.setForUpdate(_proxy);	
	self.createSwapStack();
	self.createTransferArea(_passport);

end;</source>
        <Parameter name="_proxy" type="CM_Rail" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9e5343e8-4fa0-413c-94b4-7a9a7af0627f">
        <updating/>
        <source>setForUpdate(_proxy : CM_Rail) updating;
//setForUpdate(_proxy : CM_Rail) updating;
vars
	line 				: String;
	lNewLine 			: CM_RailLine;
	lLines				: Integer;
	lProxyLine 			: CM_RailLine;
	idx					: Integer;
	lRailJobSheet		: CM_RailJobSheet;
	lRailJSIO			: CM_RailJSInOut;
	lRailJSIORake		: CM_RailJSInOutRake;
	graphic				: CM_LayoutGraphic;		
begin
	_proxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.type 					:= _proxy.type;
//	self.typeString 			:= _proxy.typeString;
//	self.myTransferArea 		:= _proxy.myTransferArea;
	self.confirmFromFarEnd 		:= _proxy.confirmFromFarEnd;
	self.defaultToOppositeView	:= _proxy.defaultToOppositeView;
	self.workFromFarEnd 		:= _proxy.workFromFarEnd;
	self.myType 				:= _proxy.myType;
	self.myTransferArea			:= _proxy.myTransferArea;	// 13/12/2010 cnwar2 #25956
	
	self.allRailJSInOut.purge;
	self.allRailLines.purge;
	
	lRailJobSheet := _proxy.myTerminal.myRailJobSheet;
	foreach lRailJSIO in lRailJobSheet.inouts do
		if lRailJSIO.isRakeJobSheet then
			create lRailJSIORake;
			lRailJSIORake.inOut := lRailJSIO;
			lRailJSIORake.rake := self.id.trimBlanks;
			self.allRailJSInOut.add(lRailJSIORake);
		endif;
	endforeach;
	//-------------------
	//Create each RailLine object
	//-------------------
	foreach lProxyLine in _proxy.allRailLines do
		create lNewLine persistent;
		idx := lProxyLine.id.pos("##",1);
		idx := idx - 1;
		if idx &lt; 1 then
			idx := 1;
		endif;
			
		//lNewLine.setForCreate(self.id.trimBlanks &amp; lProxyLine.id[1:idx] ,lProxyLine.maximumWagons);
		//Removed the full rail area id in the rail line id.
		lNewLine.setForCreate(lProxyLine.id[1:idx] ,lProxyLine.maximumWagons);
		self.addRailLine(lNewLine,0);
		delete lProxyLine;
	endforeach;
	
	inheritMethod(_proxy);

end;</source>
        <Parameter name="_proxy" type="CM_Rail"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="ed53b093-5b27-4bd9-9113-b153d74aff70">
        <updating/>
        <source>setProxy(pID, pComment 				: String; 
		 pType 						: Integer;
		 pRows 						: Integer;
		 pCols 						: Integer;
		 pTypeString 				: String;
		 tmpCon, tmpDef, tmpWork 	: Boolean;
		 pactAsReleasePoint	 		: Boolean;
		 pTerm 						: CM_Terminal;
		 _stockControlled 			: Boolean;
		 _hideFromOverView 			: Boolean;
		 _allInterchangeAreas		:CM_InterchangeAreaArray;	// par 24292
		 _defaultInterchangeArea	: CM_InterchangeArea;
		 _railTransferArea			: CM_YardTransferArea		// 13/12/2010 cnwar2 #25956
		 ) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/05/2010	cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array
vars
	idx : Integer;
	lRailLine : CM_RailLine;
begin
	self.raiseExceptionIfNotTransient(method);
	setProxyTerminalArea(pID, pComment, pType, pactAsReleasePoint, pTerm, false, _stockControlled,_hideFromOverView, _allInterchangeAreas,_defaultInterchangeArea );
	self.confirmFromFarEnd := tmpCon;
	self.defaultToOppositeView	:= tmpDef;
	self.workFromFarEnd := tmpWork;
//	self.actAsReleasePoint := pactAsReleasePoint.Integer;
	self.myTransferArea := _railTransferArea;	// 13/12/2010 cnwar2 #25956
		
	if allRailLines.size &gt; 0 then
		allRailLines.purge;
	endif;
	foreach idx in 1 to pRows do
		create lRailLine transient;
		lRailLine.setForCreate(idx.String.padLeadingZeros(2) &amp; "##" ,pCols); // ## in the ID are to overcome duplicate ID (Proxy/Real)
		self.addRailLine(lRailLine,0);
	endforeach;
end;</source>
        <Parameter name="pID" type="String"/>
        <Parameter name="pComment" type="String"/>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="pRows" type="Integer"/>
        <Parameter name="pCols" type="Integer"/>
        <Parameter name="pTypeString" type="String"/>
        <Parameter name="tmpCon" type="Boolean"/>
        <Parameter name="tmpDef" type="Boolean"/>
        <Parameter name="tmpWork" type="Boolean"/>
        <Parameter name="pactAsReleasePoint" type="Boolean"/>
        <Parameter name="pTerm" type="CM_Terminal"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
        <Parameter name="_railTransferArea" type="CM_YardTransferArea"/>
    </JadeMethod>
    <JadeMethod name="setRailTransferArea" id="70473f1b-f708-4b70-9d36-2afb796ea901">
        <updating/>
        <source>setRailTransferArea(taId	:	String) updating;
//Sets the transfer area reference...
vars
	ta : CM_TerminalArea;
begin
	if taId = "" then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_TA_ID,taId,  null, null);
		return;
	endif;
	ta := self.myTerminal.allTerminalAreas[taId];
	if ta = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_TA_ID,taId,  null, null);
		return;
	endif;
	if ta.type &lt;&gt; TA_TYPE_RAIL_TRANS then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_INVALID_TA_TYPE,  null, null);
		return;
	endif;
	self.myTransferArea := ta.CM_YardTransferArea;
end;</source>
        <Parameter name="taId" type="String"/>
    </JadeMethod>
