<Class name="WS_ReportOutputFormat" id="bb91b1c4-d0d3-424f-953d-0ad004e591c2">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Used to return reports output formats </text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="description" id="de49ce60-9e3e-4c41-a0d5-23c4bbe4575f">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Output format description. ex. 2 = On Screen ,3 = CSV , 4 = RTF ,5 = XML , 10 = PDF</text>
    </PrimAttribute>
    <PrimAttribute name="id" id="d635b887-39b0-43c0-b0c0-e55f931427e9">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Output Format ID</text>
    </PrimAttribute>
</Class>
