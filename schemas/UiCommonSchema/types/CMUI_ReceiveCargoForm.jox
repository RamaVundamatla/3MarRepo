    <JadeMethod name="lblCargoDetails_doTabOrder" id="e6b4702a-82a3-4442-b1d8-f145d37745d1">
        <controlMethod name="CMUI_FieldGeneric::doTabOrder"/>
        <methodInvocation>event</methodInvocation>
        <source>lblCargoDetails_doTabOrder(_startTab: Integer):Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwdap1	Initial creation

*/

vars
	tabOrder	: Integer;

begin
	tabOrder 				:= _startTab;
	tabOrder 				:= tabOrder + 1;
	self.btnCargo.tabIndex	:= tabOrder;
	return tabOrder;
epilog

end;</source>
