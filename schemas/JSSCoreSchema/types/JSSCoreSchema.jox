    <JadeMethod name="truncateString" id="5bd8649a-0c8c-40bf-8b8d-3682e7451df8">
        <source>truncateString(pString:String; pLength:Integer):String protected;
// --------------------------------------------------------------------------------
// Created:		25 March 2002 by cnwdad2
//
// Purpose:		Truncates a string to a specified length.
//
// Parameters:	pString - The string to truncate.
//				pLength - The desired length of the truncated sring.
//
// Returns:		The truncated string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue	: String;
	
begin
	returnValue	:=	pString.trimBlanks;
	
	if pLength &lt; 1 or returnValue.length &lt;= pLength then
		return returnValue;
	endif;
	
	return returnValue[1:pLength];
end;</source>
        <access>protected</access>
        <Parameter name="pString" type="String"/>
        <Parameter name="pLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="writeLog" id="9029636d-7a41-4322-8f15-b524c5beea93">
        <source>writeLog(pLogMessage:String; pIsServerNode:Boolean);
// --------------------------------------------------------------------------------
// Created:		20 April 2003 by cnwdad1
//
// Purpose:		Write a message to a generic log file.
//
// Parameters:	pLogMessage - The message to be logged.
//				pIsServerNode - If true, the log file will be written on the machine
//					where the database server node is running.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	logObj	: JSSLog;
	
begin
	create logObj transient;
	logObj.initialize(pIsServerNode);
	
	if pIsServerNode then
		logObj.logServer(pLogMessage);
	else
		logObj.logClient(pLogMessage);
	endif;
epilog
	delete logObj;		// The file will be closed automatically.
end;</source>
        <Parameter name="pLogMessage" type="String"/>
        <Parameter name="pIsServerNode" type="Boolean"/>
    </JadeMethod>
</Class>
