    <JadeMethod name="canDo" id="6cd09186-d521-48e9-8b6c-ed20242f0ed8">
        <source>canDo(_value : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     05 April 2004 by cnwrs2
//
// Purpose:     Checks to see if this item  is licensed.
//				We store a local varaible (extraData) which combines the license 
//				details for all the terminals as it is possible to have a site
//				license for most things, but just have an individual license for
//				some specific terminals.  These may require things that are on
//				the System Menu, but not in the site license.
// ---------------------------------------------------------------------------
vars
	tmpNum,
	byteIndex		: Integer;
	byteValue		: Integer;
	bitPointer		: Integer;
	binData			: Binary;
	subsExpDate		: Date;	//19 Jun 2020	NDL	TFS 49569
	expDateArray	: DateArray;
	obj : Any;
	
begin

	if _value &lt;= Mod_BaseView then
		return false;
	endif;
	
// all clients on v7 rs oct 2005
//	if app.isConverting then
		// no license check if converting
//		return true;
//	endif;
	
	tmpNum := _value - Mod_BaseView;

	// done this way to avoid references to this property
	binData := self.getPropertyValue('extraInfo').Binary;

	byteIndex	:=	((tmpNum - 1) div 8) + 1;
	if byteIndex &gt; binData.length then
		return false;
	endif;
	
	//19 Jun 2020	NDL	TFS 49569
	subsExpDate := null;	
	expDateArray := self.getConfig("SUBS").DateArray;
	if expDateArray &lt;&gt; null and expDateArray.size &gt;= tmpNum then
		subsExpDate := expDateArray[ tmpNum ];
		if subsExpDate.isValid and subsExpDate &lt; app.actualTimeAppServer.Date then
			return false;
		endif;
		//if tmpNum = 75 then
		//	return false;
		//endif;
	endif;
	
	byteValue	:=	binData[byteIndex];
	bitPointer	:=	(tmpNum mod 8);
	
	if bitPointer = 1 then			// Right-most bit.
		return byteValue.bitAnd(1) &lt;&gt; 0;
	elseif bitPointer = 2 then
		return byteValue.bitAnd(2) &lt;&gt; 0;
	elseif bitPointer = 3 then
		return byteValue.bitAnd(4) &lt;&gt; 0;
	elseif bitPointer = 4 then
		return byteValue.bitAnd(8) &lt;&gt; 0;
	elseif bitPointer = 5 then
		return byteValue.bitAnd(16) &lt;&gt; 0;
	elseif bitPointer = 6 then
		return byteValue.bitAnd(32) &lt;&gt; 0;
	elseif bitPointer = 7 then
		return byteValue.bitAnd(64) &lt;&gt; 0;
	elseif bitPointer = 0 then		// Left-most bit.
		return byteValue.bitAnd(128) &lt;&gt; 0;
	endif;
	
	return false;

end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDoEDIFileType" id="c1bef89b-cd64-422c-90bc-d44b792bc3f6">
        <source>canDoEDIFileType(_ediFileType : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     September 2004 by cnwgd1
//
// Purpose:     Checks to see if this edi file type is licensed.
// ---------------------------------------------------------------------------
vars
	obj	: Object;
begin

	if _ediFileType &lt;= EDIFileType_Unknown then
		return false;
	endif;
	
	if _ediFileType = EDIFileType_CSVTranship then
		return true;
	endif;

// all clients on v7 rs oct 2005
//	if app.isConverting then
		// no license check if converting
//		return true;
//	endif;
	
	// need to call into license key schema
	obj := app.myCheckerObject;
	if obj = null then
		return false;
	endif;

	if self.licenseNameEDI = null then
		return false;
	endif;

	return obj.sendMsgWithParams('isLicensed', self.licenseNameEDI, ProductCode_JMT_EDI, _ediFileType).Boolean;

end;</source>
        <Parameter name="_ediFileType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDoEWSType" id="f2e996d8-9550-4e3c-ab85-9b83176b185f">
        <updating/>
        <source>canDoEWSType(_ewsType : Integer; _ewsExpDate : Date output) : Boolean updating;
// ### JIRA 33541 12DEC2024 NAVAB1
vars
	obj	: Object;
	lclDate : Date;
	candoothis : Boolean;
	prodCode, licenseName : String;
	modNum : Integer;
begin

	if _ewsType &lt;= EWS_Type_Unknown then
		return null;
	endif;
	
	
	// need to call into license key schema
	obj := app.myCheckerObject;
	if obj = null then
		return null;
	endif;

	if self.licenseEWS = null then
		return null;
	endif;

	prodCode := ProductCode_EWS;
	modNum:= _ewsType;
	licenseName := self.licenseEWS;
	
	candoothis :=  obj.sendMsgWithIOParams('isLicensedEWS',licenseName,prodCode , modNum, lclDate).Boolean; 
	
	_ewsExpDate := lclDate;
	
	return candoothis;
end;</source>
        <Parameter name="_ewsType" type="Integer"/>
        <Parameter name="_ewsExpDate" type="Date" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDoOLD" id="e2635153-22c0-4d32-838b-243a4285ca85">
        <source>canDoOLD(_doWhat : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     02 April 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	obj		: Object;
	tmpNum	: Integer;
	tmpTerm	: CM_Terminal;
	ls		: Boolean;

begin

	if _doWhat &lt;= Mod_BaseView then
		return false;
	endif;

// all clients on v7 rs oct 2005
//	if app.isConverting then
		// no license check if converting
//		return true;
//	endif;
	
//	return canDoSysMenu(_doWhat);

	
	tmpNum := _doWhat - Mod_BaseView;
		
	// need to call into license key schema
	obj := app.myCheckerObject;
	
	if obj = null then
		return false;
	endif;

	if obj.sendMsgWithParams('isLicensed', self.licenseName, 'JMT', PmSite - Mod_BaseView).Boolean then
		// system has a site license so get permission off root
		return obj.sendMsgWithParams('isLicensed', self.licenseName, 'JMT', tmpNum).Boolean;
	endif;

	app.cmsBeginLoad(ls);
	
	// no site license so need to check all terminals
	foreach tmpTerm in self.allTerminals do
		if (not tmpTerm.isLicensed) then
			continue;
		endif;
		if obj.sendMsgWithParams('isLicensed', tmpTerm.licenseName, 'JMT', tmpNum).Boolean then
			// if we can do at least one terminal then return true
			return true;
		endif;
	endforeach;

	return false;

epilog
	app.cmsEndLoad(ls);	
end;</source>
        <Parameter name="_doWhat" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="carHasRadioDisplay" id="a0b5287f-2568-4173-aec4-7544321b243a">
        <source>carHasRadioDisplay(_idx: Integer): String;

vars

begin
	if _idx = CM_Car.UnknownRadio then
		return app.getErrorString(Unknown_radio);
	elseif _idx = CM_Car.NoRadio then
		return app.getErrorString(Radio_no);

	elseif _idx = CM_Car.HasRadio then
		return app.getErrorString(Radio_yes);
	else
		return null;
	endif;
end;</source>
        <Parameter name="_idx" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkVesselHasFutureVoyage" id="b54e0956-3071-4627-b27e-49c5ae5ab199">
        <source>checkVesselHasFutureVoyage(_vesselCode : String; _fromDT : TimeStamp) : Boolean;
//--------------------------------------------------
// Created:	06 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	terminal : CM_Terminal;
	tmpFromDT : TimeStamp;
	
begin
	if _fromDT.isValid() then
		tmpFromDT := _fromDT;
	else
		tmpFromDT := app.actualTimeServer();
	endif;
	
	foreach terminal in self.allTerminals discreteLock do
		if terminal.checkVesselHasFutureVoyage(_vesselCode, tmpFromDT) then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_fromDT" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkVesselHasHMSVoyage" id="ee231050-11f6-4ec0-8ff8-a0b621e0d9cb">
        <source>checkVesselHasHMSVoyage(_vesselCode : String; _startDT : TimeStamp) : Boolean;
//--------------------------------------------------
// Created:	28 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	harbour : HMS_Harbour;
	tmpStartDT : TimeStamp;
begin
	tmpStartDT := _startDT;
	
	if (not tmpStartDT.isValid) then
		tmpStartDT := app.actualTimeServer();
	endif;
	
	foreach harbour in self.allHarbours do
		if harbour.checkVesselHasHMSVoyage(_vesselCode, tmpStartDT) then
			return true;
		endif;
	endforeach;
	return false;
end;</source>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_startDT" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="concurrentAppSignonCheck" id="c510ed72-8582-4a58-960d-e6caa129b08b">
        <source>concurrentAppSignonCheck(	_user : CM_User;
							_errorCode : Integer output; 
							_machine, 
							_machineToIgnore  : CM_Machine;
							_passport : CM_Passport input) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 Sep 2010	cnwmd1	Initial creation
 8 Feb 2011 cnwer1  PAR 26908 - now passing in _machine when checking more than one machine signed on ignoring the passed in machine
16 Aug 2021 navmd1	TFS 51226 Allow users with permission to force off old sessions
05 Mar 2024 jlier1 TFS 62428
15 May 2025 navnk30	JIRA 34701: SSO Implementation for Vehicle App - Jade Portion
*/
constants
	JMT : String = JMTerminal;
	HandHeld : String = HandHeldAppIniFileSection;
	VehicleApp : String = VehicleMountedApp;
	TekLogix : String = 'JMTRTProcess';
	ITS : String = 'JMTITSWorker';
vars
	zProcess 		: Process;
	userCode, appName 	: String;
	machine 		: CM_Machine;
	processes 		: ProcessDict;
	iter 			: Iterator;
	machines 		: CM_MachineByIdDict;
	invalidProcess 	: Boolean;
	extraInfo 		: StringArray512;
	machineUser		: CM_User;
	errorCode		: Integer;
	raiseError		: Boolean;
	currentAppName 	: String;
	currentComputerName,
	processComputerName	: String;
	webSession		: WebSession;
	
begin
	if _user = null then 
		return true; //validation can't be done but in some cases no user is ok.  See calling method.
	endif;
	
	if not _user.getUserSingleSignOnOnly() then 
		return true;
	endif;
	
	currentAppName := process.persistentApp.name;
	if currentAppName = TekLogix or currentAppName = ITS then 
	//these apps can only receive small messages
		errorCode := One_Session_Login_Simple;
	else
		errorCode := One_Session_Login;
	endif;
	
	userCode := _user.code;
	currentComputerName := app.computerName(); //cnwrd1 par 28203 26.10.2011
	
	on Exception do app.handleDeletedObject(exception, zProcess, invalidProcess);
	
	//Check if user is logged onto either JMT or Handhelp App
	create processes transient;
	Process.instances.copy(processes);
	iter := processes.createIterator();
	
	create extraInfo transient;
	
	while iter.next(zProcess) do
		//write "Node : " &amp; zProcess.node.name &amp; Tab &amp; "Process number : " &amp; zProcess.number.String &amp; Tab &amp; "App : " &amp; zProcess.persistentApp.name &amp; Tab &amp; "User : " &amp; zProcess.userCode ;
		if zProcess = process then
			continue;
		endif;
		appName := zProcess.persistentApp.name;
		invalidProcess := false;
		//if zProcess.userCode = userCode then						//15.05.2025 navnk30 JIRA 34701
		if zProcess.userCode.toUpper() = userCode.toUpper() then	//15.05.2025 navnk30 JIRA 34701
			if appName = JMT or appName = HandHeld then
				app.writeLog("Single Session User (" &amp; userCode &amp; ") already logged on to " &amp; appName &amp; " (" &amp; zProcess.number.String &amp; ")", LogERROR);
				raiseError := true;
				extraInfo.add(app.getErrorString(Name_Application) &amp; ' : ' &amp; appName);
				_passport.copyToExtraInformation(extraInfo);
				return false;
			endif;
		endif;
		
		//cnwrd1 par 28203 26.10.2011 we need to check some other stuff - machine and pc names for vehicle app
		processComputerName := zProcess.persistentApp.computerName();
		
		if processComputerName = currentComputerName then
		// ok same computer
			if currentAppName = VehicleApp and appName = VehicleApp  then
			//both running vehicle app
				//if zProcess.userCode = _machine.id then					//15.05.2025 navnk30 JIRA 34701
				if zProcess.userCode.toUpper() = _machine.id.toUpper() then //15.05.2025 navnk30 JIRA 34701
					app.writeLog("Single Session User (" &amp; userCode &amp; ") already running " &amp; appName &amp; " for machine " &amp; _machine.id &amp; " on same comupter", LogERROR);
					raiseError := true;
					extraInfo.add(app.getErrorString(Name_Application) &amp; ' : ' &amp; appName);
					_passport.copyToExtraInformation(extraInfo);
					return false;
				endif;
			endif;
		endif;
		
		if invalidProcess then
			continue;
		endif;
	endwhile;
	
	delete iter;
	
	//User not found so now check if user is logged onto a machine
	if not self.concurrentAppSignonCheckMach(_user,_errorCode,	_machine,_machineToIgnore, _passport ) then
		return false;
	endif;

	//All good so far, now check if user is logged onto a web session of some sort
	if self.hasCurrentWebSession( _user, appName, webSession ) then
		app.writeLog("Single Session User (" &amp; userCode &amp; ") already has existing web session (" &amp; webSession.getPropertyValue("_encryptedSessionId").String &amp; ")", LogERROR);
		raiseError := true;
		extraInfo.add(app.getErrorString(Name_Application) &amp; ' : ' &amp; appName);
		_passport.copyToExtraInformation(extraInfo);
		return false;
	endif; 
	
	return true;
	
epilog

	if raiseError then
		_errorCode := errorCode;
		//write "Returning errorCode : " &amp; _errorCode.String;
	endif;
	delete processes;
	delete machines;
	delete iter;
	delete extraInfo;
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_errorCode" type="Integer" usage="output"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_machineToIgnore" type="CM_Machine"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="concurrentAppSignonCheckJade" id="09690cea-595b-43f4-b049-4a05a85cd1c7">
        <source>concurrentAppSignonCheckJade(userCode : String;
							_machine : CM_Machine; 
							_passport : CM_Passport input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2023	jlier1	Initial creation 56468

*/

vars
	zProcess : Process;
	invalidProcess : Boolean;
	processes : ProcessDict;
	iter : Iterator;
	appName,processComputerName,currentComputerName : String;
	extraInfo 		: StringArray512;
	currentAppName 	: String;
begin
	on Exception do app.handleDeletedObject(exception, zProcess, invalidProcess);
	currentAppName := process.persistentApp.name;
	//Check if user is logged onto either JMT or Handhelp App
	create processes transient;
	Process.instances.copy(processes);
	iter := processes.createIterator();
	currentComputerName := app.computerName();
	create extraInfo transient;

	while iter.next(zProcess) do
		//write "Node : " &amp; zProcess.node.name &amp; Tab &amp; "Process number : " &amp; zProcess.number.String &amp; Tab &amp; "App : " &amp; zProcess.persistentApp.name &amp; Tab &amp; "User : " &amp; zProcess.userCode ;
		if zProcess = process then
			continue;
		endif;
		appName := zProcess.persistentApp.name;
		invalidProcess := false;
		if zProcess.userCode = userCode then
			if appName = JMTerminal or appName = HandHeldAppIniFileSection then
				app.writeLog("Single Session User (" &amp; userCode &amp; ") already logged on to " &amp; appName &amp; " (" &amp; zProcess.number.String &amp; ")", LogERROR);
				if _passport &lt;&gt; null then
					extraInfo.add(app.getErrorString(Name_Application) &amp; ' : ' &amp; appName);
					_passport.copyToExtraInformation(extraInfo);
				endif;
				return false;
			endif;
		endif;
		
		//cnwrd1 par 28203 26.10.2011 we need to check some other stuff - machine and pc names for vehicle app
		processComputerName := zProcess.persistentApp.computerName();
		
		if processComputerName = currentComputerName and _machine &lt;&gt; null then
		// ok same computer
			if currentAppName = VehicleMountedApp and appName = VehicleMountedApp  then
			//both running vehicle app
				if zProcess.userCode = _machine.id then
					app.writeLog("Single Session User (" &amp; userCode &amp; ") already running " &amp; appName &amp; " for machine " &amp; _machine.id &amp; " on same comupter", LogERROR);
					if _passport &lt;&gt; null then
						extraInfo.add(app.getErrorString(Name_Application) &amp; ' : ' &amp; appName);
						_passport.copyToExtraInformation(extraInfo);
					endif;
					return false;
				endif;
			endif;
		endif;
		
		if invalidProcess then
			continue;
		endif;
	endwhile;
	
	delete iter;
	return true;
epilog

	delete iter;
	delete processes;
	delete extraInfo;
end;</source>
        <Parameter name="userCode" type="String"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="concurrentAppSignonCheckMach" id="d61427a0-5140-42bb-90ea-afef800873e2">
        <source>concurrentAppSignonCheckMach(_user : CM_User;
							_errorCode : Integer output; 
							_machine, 
							_machineToIgnore  : CM_Machine;
							_passport : CM_Passport input) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 February 2011	cnwer1	Initial creation
05 Mar		2024	jlier1 	62428
02 May 2025			navah1	Bug 33966: MTN - Unable to change password in Vehicle Apps if Single User Session is enabled
15 May 2025 navnk30	JIRA 34701: SSO Implementation for Vehicle App - Jade Portion
25 Jun 2025 		navah1	Bug 35193: MTN - Multiple Sessions Allowed for Users with Single User Session enabled
*/
constants
	TekLogix : String = 'JMTRTProcess';
	ITS : String = 'JMTITSWorker';
vars
	machines 		: CM_MachineByIdTerminalDict;	// 29099
	iter			: Iterator;
	machine 		: CM_Machine;
	machineUser 	: CM_User;
	userCode		: String;
	raiseError		: Boolean;	
	extraInfo 		: StringArray512;
	errorCode		: Integer;
	currentAppName 	: String;  
	//activeMachines	: Integer;			//02.05.2025 navah1 #33966   //25.06.2025 navah1 #35193
begin
	create machines transient;
	app.myRoot.allMachines.copy(machines);
	iter := machines.createIterator();
	
	currentAppName := process.persistentApp.name; 
	
	if currentAppName = TekLogix or currentAppName = ITS then 
	//these apps can only receive small messages
		errorCode := One_Session_Login_Simple;
	else
		errorCode := One_Session_Login;
	endif;
	
	create extraInfo transient;
	userCode := _user.code;
	if _machine &lt;&gt; null then
		app.writeLog(method.name &amp;  Tab &amp; "Checking machine  " &amp; _machine.id , LogINFO);
	endif;
	while iter.next(machine) do
		machineUser := machine.user;
		if machineUser = null then
			continue;
		endif;
		//8 Feb 2011 cnwer1  PAR 26908 can ignore this machine
	
		if machine = _machine then	
			//continue; 	//jlier1 TFS 56468 - this doesn't work with REST 
		endif;
		//jlier1 TFS 62428 6/3/24
		if machine = _machineToIgnore then
			continue;
		endif;
		//write 'Machine Code: ' &amp; machine.code &amp; ' Terminal ' &amp; machine.myTerminal.name &amp; ' Machine User ' &amp; machineUser.code;		
		//if machine.loggedOn and machineUser.code = userCode then						//15.05.2025 navnk30 JIRA 34701
		if machine.loggedOn and machineUser.code.toUpper() = userCode.toUpper() then	//15.05.2025 navnk30 JIRA 34701
			//activeMachines += 1;		  //02.05.2025 navah1 #33966 //25.06.2025 navah1 #35193
			//if activeMachines &gt; 1 then  //02.05.2025 navah1 #33966 //25.06.2025 navah1 #35193
				app.writeLog("Single Session User (" &amp; userCode &amp; ") already logged on to another machine (" &amp; machine.id &amp; ")", LogERROR);
				raiseError := true;
				extraInfo.add(app.getErrorString(Terminal) &amp; ' : ' &amp; machine.myTerminal.name);
				extraInfo.add(app.getErrorString(Machine) &amp; ' : ' &amp; machine.code);
				_passport.copyToExtraInformation(extraInfo);
				return false;
			//endif;                       
		endif;
		
	endwhile;
	
	return true;
epilog
	if raiseError then
		_errorCode := errorCode;
		//write "Returning errorCode : " &amp; _errorCode.String;
	endif;
	delete iter;
	delete machines;
	delete extraInfo;
end;</source>
        <access>protected</access>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_errorCode" type="Integer" usage="output"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_machineToIgnore" type="CM_Machine"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
