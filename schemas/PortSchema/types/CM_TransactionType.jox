    <JadeMethod name="hasToDoResourcesConfigured" id="fbe97caf-dfdf-4434-aa6c-860b33f3594c">
        <source>hasToDoResourcesConfigured() : Boolean;
/*
Purpose:			

Date		Who		Reason
15 June 2023	navab1	 CR 54345 TASK 58281 
*/

vars
	todo : CM_ToDoTaskDesc;
	resType : CM_ResourceType;
begin
	foreach todo in self.allToDoTaskDesc do
		if todo.allResourceTypes.isNotEmpty() then
			return true;
		endif;
	endforeach;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEnquiryForCargoRelRecTrans" id="740f6644-9e5e-44fd-bf2c-587d6664707c">
        <source>isEnquiryForCargoRelRecTrans() : Boolean;
/*

Purpose:			TFS 40336

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2018	jlgab1	Initial creation

*/

vars

begin
	if self.classNameToCreate = CM_ReceiveShip.name 
	or self.classNameToCreate = CM_ReleaseShip.name 
	or self.classNameToCreate = CM_ReceiveRoad.name 
	or self.classNameToCreate = CM_ReleaseRoad.name 
	or self.classNameToCreate = CM_ReceiveRail.name 
	or self.classNameToCreate = CM_ReleaseRail.name 
	or self.classNameToCreate = CM_Pack.name 
	or self.classNameToCreate = CM_Unpack.name 
	then
		return true;
		
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
