<GUIClass name="Picture">
    <JadeMethod name="controlNamePrefix" id="d4bd96d6-ab76-4377-a8d1-dfaf3559ad3c">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		05 May 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "pic";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssSet" id="fd2a99cd-135d-401e-83c3-cb8bafafa91b">
        <updating/>
        <source>jssSet(pValue:Binary) updating;
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		Updates the receiver's picture binary with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.picture &lt;&gt; pValue then
		self.picture	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Binary"/>
    </JadeMethod>
</GUIClass>
