    <JadeMethod name="setForCreate" id="578d1383-72cd-4b49-86d9-d01430498b59">
        <updating/>
        <source>setForCreate(_pxyMe: SelfType) updating;
/*

Date		    Who			Reason
16 June 2010	cnwas3	  ccms 1134

*/

vars

begin
	inheritMethod(_pxyMe);
	
	self.myVoyage 	:= _pxyMe.myVoyage;
	self.myVessel 	:= _pxyMe.myVoyage.getMyVessel;	
	
	self.setNumCageMoves(_pxyMe.numCageMoves);
	self.setNumExtraMoves(_pxyMe.numExtraMoves);
	self.setNumLashingBinMoves(_pxyMe.numLashingBinMoves);
	self.setNumLashings(_pxyMe.numLashings);
	self.setNumUnlashings(_pxyMe.numUnlashings);
epilog

end;</source>
        <Parameter name="_pxyMe" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_VoyageExtraMoveDtl" id="45f4c059-a7fa-4dfd-8a99-863421ed28dd">
        <updating/>
        <source>setFromCMIF_VoyageExtraMoveDtl(_controller : CMIF_VoyageExtraMoveDtl) updating;
// ---------------------------------------------------------------------------
// Created:     20 August 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.numCageMoves 		:= _controller.numCageMoves;
	self.numExtraMoves 		:= _controller.numExtraMoves;
	self.numLashingBinMoves := _controller.numLashingBinMoves;
	self.numLashings 		:= _controller.numLashings;
	self.numUnlashings 		:= _controller.numUnlashings;
epilog

end;</source>
        <Parameter name="_controller" type="CMIF_VoyageExtraMoveDtl"/>
    </JadeMethod>
    <JadeMethod name="setFromEventTransactions" id="07d515c8-f78f-4db2-8888-f261470fdb1d">
        <updating/>
        <source>setFromEventTransactions() updating;
// ---------------------------------------------------------------------------
// Created:     20 August 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voy : CM_Voyage;
begin
	voy := self.myVoyage;
	
	if voy = null then
		return;
	endif;
	
	self.numCageMoves 		:= voy.getNumCageMoves();
	self.numExtraMoves 		:= voy.getNumExtraMoves();
	self.numLashingBinMoves := voy.getNumLashingBinMoves();
	self.numLashings 		:= voy.getNumLashings();
	self.numUnlashings 		:= voy.getNumUnlashings();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setHours" id="90b27cdd-3269-4d01-8570-6390fb9af285">
        <updating/>
        <source>setHours() updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 23/08/2011		cnwcs5			CCMS MES 1033 RORO KPI
// ---------------------------------------------------------------------------

vars
	kpi : CM_KPI;
	delayHours, grossHours	:Decimal [8,2];
begin
	foreach kpi in self.myVoyage.allVoyageKPIEntities discreteLock where kpi.type = KPI_Type_VoyageCraneShift   do
		delayHours := delayHours + kpi.CM_KPIVoyageEntity.hoursDelay;
		grossHours := grossHours + kpi.CM_KPIVoyageEntity.hoursGross;
	endforeach;
		
	foreach kpi in self.myVoyage.allVoyageKPIEntities discreteLock where kpi.type = KPI_Type_VoyageWorkPointShift   do
		delayHours := delayHours + kpi.CM_KPIVoyageEntity.hoursDelay;
		grossHours := grossHours + kpi.CM_KPIVoyageEntity.hoursGross;
	endforeach;
	
	self.hoursGross	:= grossHours;
	self.hoursDelay	:= delayHours;
	self.hoursNet 	:= grossHours - delayHours;
	//04 Apr 2012	NDL	Par 29369
	self.setHoursDown();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setKPIForCreate" id="74169e9b-a2bc-4be9-bc14-7489a9e7fb66">
        <updating/>
        <source>setKPIForCreate( _voyage : CM_Voyage; _dateTime : TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:	05 June 2008 By Graeme Black cnwgb1
// Purpose:	 Par 16900
// ---------------------------------------------------------------------------
vars
begin
	self.myVoyage 	:= _voyage;
	self.myVessel 	:= _voyage.getMyVessel;
	self.myTerminal := _voyage.myTerminal;
	self.code 		:= _voyage.code;
	self.dateTime 	:= _dateTime;
	self.userCode 	:= app.myPassport.userCode;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
