    <JadeMethod name="populateRailLines" id="7b59bf51-1cfd-4c46-b471-cd2bbe4f1d87">
        <source>populateRailLines();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	taIter : Iterator;
	railLine : CM_RailLine;
	taDict : CM_TAByTypeIdDict;
	taIdKey : String;
	taTypeKey : Integer;
	ta : CM_TerminalArea;
	
begin

	taDict := self.myTerminal.allTerminalAreasByTypeId;
	taIter := taDict.createIterator;
	taDict.startKeyGeq(TA_TYPE_RAILWAY_TRACK, null, taIter);
	
	while taIter.next(ta) do
		taDict.getIteratorKeys(taTypeKey, taIdKey, taIter);
		if taTypeKey &lt;&gt; TA_TYPE_RAILWAY_TRACK then
			break;
		endif;
		
		foreach railLine in ta.CM_Rail.allRailLinesByIndex do
			lstRailRake.itemObject[lstRailRake.addItem(ta.id &amp; ' ' &amp; railLine.id)] := railLine;
		endforeach;
		
	endwhile;
	
	if self.myMobileGenericAgent.myCurrentRailLine &lt;&gt; null then
		self.lstRailRake.listIndex := self.lstRailRake.findObject(self.myMobileGenericAgent.myCurrentRailLine);
	endif;
	
epilog

	delete taIter;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="populateTrains" id="d6139e56-6281-4288-8971-bf99e3cc3718">
        <source>populateTrains();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	trainDict			: CM_TrainByCodeDateDict;
	train				: CM_Train;

begin

	cmbTrain.clear();

	trainDict := self.myTerminal.allTrainsOnTerminal;
	foreach train in trainDict do
		if train.isNullTrain() then
			continue;
		endif;
		cmbTrain.itemObject[cmbTrain.addItem( train.getCodeDateString )] := train;
	endforeach;

	self.cmbTrain.addItemAt( lblTrain.caption.toUpper, 1 );
	
	if self.myMobileGenericAgent.myCurrentTrain &lt;&gt; null then
		self.cmbTrain.listIndex := self.cmbTrain.findObject( self.myMobileGenericAgent.myCurrentTrain );
	endif;
	
	if self.cmbTrain.listIndex &lt; 1 then
		self.cmbTrain.listIndex := 1;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="2ab3e7e7-7ea3-4c86-8ac4-b482fb98cf5e">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

begin
							
	self.doResizeControls(true);
													
	self.optReversed.value := not self.myMobileGenericAgent.forward;
	self.chkAutoPlan.value := self.myMobileGenericAgent.autoPlanWagonCargo;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1aa06429-34f5-4f52-bc3c-600e019426b6">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

begin
	
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;

	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Next), app.getErrorString(Back), null, null, null );
	
	self.setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="74a95ef2-df0c-4ac0-8ea6-7fba1d43ff18">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015193, locale);
	chkAutoPlan.translateCaption(Xlat_0017602, locale);
	lblRailRake.translateCaption(Xlat_0015194, locale);
	lblTrain.translateCaption(Xlat_0015195, locale);
	optForward.translateCaption(Xlat_0015196, locale);
	optReversed.translateCaption(Xlat_0015197, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
