    <JadeMethod name="copyToRealWSObject" id="3fa4c265-cf56-4814-b7ca-50c0abc74087">
        <source>copyToRealWSObject(_realRequest: IPN1_SetSpkPandu input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.jamPandu := self.jamPandu;
	_realRequest.jenisPandu := self.jenisPandu;
	_realRequest.kegiatan := self.kegiatan;
