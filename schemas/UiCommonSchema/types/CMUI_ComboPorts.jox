    <JadeMethod name="addPorts" id="3434107c-23f3-4e07-80d9-1f228dc9d677">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_PortCodeSelector::addPorts"/>
        </interfaceImplements>
        <updating/>
        <source>addPorts(_objectArray : ObjectArray; _areTranshipPorts : Boolean)updating;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
// ---------------------------------------------------------------------------
// Created:     03 June 2009 by concms1
// Purpose:     Par 19013
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj	:Object;
begin 
	if _objectArray.isEmpty then
		return;
	endif;

	// let the form do its thing
	if self.form.class.implementsInterface (IF_CMUI_PortCodeSelector) then
		self.form.IF_CMUI_PortCodeSelector.addPorts (_objectArray, _areTranshipPorts);
	endif;
	
	// now set contents of combo
	foreach obj in _objectArray do
		self.setObject (obj);
	endforeach;

epilog

end;</source>
        <Parameter name="_objectArray" type="ObjectArray"/>
        <Parameter name="_areTranshipPorts" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="dblClick" id="2063311e-dbef-4045-98ae-cda007d55ccb">
        <controlMethod name="ComboBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dblClick(combobox: ComboBox input) updating, clientExecution;

// Created by cnwdvb1 on 12 April 2006

// 03 Jun 2009	concms1	Par 19013 - use new CMUI_PortCodeSelector form instead
// 22 Jun 2009	cnwrl1	PAR 19980 - current number of ports

vars
	form : CMUI_PortCodeSelector;	// par 19013
	
begin 
	inheritMethod(combobox);
	
	if self.isDisabledPortCodeSelector then				// cnwjk3 PAR 22690 12/03/2010
		return;											// cnwjk3 PAR 22690 12/03/2010
	endif;												// cnwjk3 PAR 22690 12/03/2010
	
	create form transient;
	
	form.isPort 			:= not self.showAllDestinations;
	form.isRail				:= self.isRail;	// par 19013
	form.multiSelect		:= false;		// par 19013
	form.myInterfaceObject	:= self;		// par 19013
	
	form.setCurrentTotalOfPorts( combobox.listCount );		// cnwrl1 22/06/2009 PAR 19880
	
	form.showModal();
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayEntry" id="36d77c24-f8ca-4d10-8353-0e029d5bf0d2">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _port : CM_Port; lstIndex: Integer): String updating, clientExecution;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 06 December 2004
//
//********************************************************************
// 10/03/2011	cnwmh5	PAR #27142 - Change where handleDeleteObject is armed
vars
	invalidPort : Boolean;
	port : String;
begin
			
	if _port = null then 
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _port, invalidPort);
	
	if _port.isNotAvailableForEntry or (not self.showAllDestinations and not _port.isPort) then
	  	if self.myObject &lt;&gt; _port then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;

	if self.excludeRow (self, _port, lstIndex) then	// par 19013
		return null;								// par 19013
	endif;											// par 19013

//	if self.isPortByName then
//		return _port.description &amp; ' - (' &amp; _port.code &amp; ')';
//	else
//		return _port.codeDisplay &amp; Tab &amp; _port.description;
//	endif;

	port := _port.getDisplayFormatted(self.portCmbOrderDescrFirst);
	//23 Oct 2008	cnwdz2	Par18354
	if invalidPort then 
		port := null;
	endif;

	return port;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="excludeRow" id="dd4b76ed-c60b-4973-833a-fdc39279bd91">
        <controlMethod name="CMUI_ComboBoxObject::excludeRow"/>
        <methodInvocation>event</methodInvocation>
        <source>excludeRow(_comboboxObj: ComboBox input; _object: Object; _lstIndex: Integer): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     24 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aPort : CM_Port;
begin

	aPort := _object.CM_Port;
	
	if self.isRail then
		if not aPort.bIsRail then
			return true; // EXCLUDE
		endif;
	endif;
	
	return false; // INCLUDE
		

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_comboboxObj" type="ComboBox" usage="input"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_lstIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCode" id="de088561-1e79-4259-ab28-7a17fc02d70b">
        <source>getCode() : String;

// Created by cnwdvb1 on 11 April 2006

vars

begin

	if self.myObject &lt;&gt; null then
		return self.myObject.CM_Port.code;
	endif;
	
	return null;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="33833efb-5f1e-4a11-860b-8a8196e0dc8d">
        <source>getCollectionJMT(): Collection protected;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 09 December 2004
//
//********************************************************************
// 10/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
//									 Change where handleDeletedObject armed
vars
	invalidVoyage : Boolean; 
	voyage			: CM_Voyage;
begin

	if self.myAssistant = null then
		return null;
	endif;
	
	voyage := self.myVoyage;
	//if self.myVoyage = null or  self.myVoyage.isNullVoyage then	// cnwjk3 PAR 22690 12/03/2010
	if voyage = null then								// cnwjk3 PAR 23225 12/03/2010
		if self.isLeaveEmptyIfNoVoyage then						// cnwjk3 PAR 22690 12/03/2010
			return null;										// cnwjk3 PAR 22690 12/03/2010
		endif;													// cnwjk3 PAR 22690 12/03/2010
	endif;														// cnwjk3 PAR 22690 12/03/2010
	
	on Exception do app.handleDeletedObject(exception, voyage, invalidVoyage);  //cnwrd1 par 23073 12.3.2010
	
	if voyage &lt;&gt; null and
	   (not voyage.isNullVoyage) then
	   if not invalidVoyage then //cnwrd1 par 23073 12.3.2010
			return self.myAssistant.allPortsVoyCodeDisplay;
		else
			return self.myAssistant.allPortCodeDisplay;
		endif;
	else
		return self.myAssistant.allPortCodeDisplay;
	endif;
	//return app.myRoot.allPorts;
	

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="init" id="02c574d6-8cd3-4c16-9426-77cf13b3eba2">
        <updating/>
        <source>init() updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
/*

24 Sep 2009  	CNWER1		Only init from voyages allPorts if voyage &lt;&gt; null and not null voyage
12/03/2010		cnwmh5		Par22235 - Add port that may have existed when obj created but has since
							been removed so still available on the screen
*/
vars

	coll		: Collection;
	idx			: Integer;
	saveText	: String;

begin
//	if myTerminal &lt;&gt; null then 
//		self.isPortByName := self.myTerminal.getConfig(PortComboByName).Boolean;
//	endif;

	self.portCmbOrderDescrFirst := app.myRoot.getConfig(PortCmbOrderDescrFirst).Boolean;
	self.sorted := true;

	if self.myAssistant = null and
	   self.form.isKindOf(CM_BaseForm) then
		self.myAssistant := self.form.CM_BaseForm.myAssistant;
	endif;

	//epr 24/9/09 par 20675
	if self.myVoyage &lt;&gt; null and not self.myVoyage.isNullVoyage then
		self.myAssistant.allPortsForVoyageInitialize(self.myVoyage);
	else
		self.myAssistant.allPortDisplayCodesInitialize();
	endif;
	
	
	coll := self.getCollectionJMT();
	if coll = null then
		return;
	endif;

	// 12/03/2010 cnwmh5 #22235 - Start
	if self.myObject &lt;&gt; null and not coll.includes(self.myObject) then
		coll.add(self.myObject);
	endif;
	// 12/03/2010 cnwmh5 #22235 - End
	
	// save the current text as calling listCollection
	// clears the current text
	saveText := self.text;
	self.listCollection(coll, false, 0);
	
	self.selLength := 1000;			
	idx := self.findString(1, saveText);

	if idx &gt; 0 then
		self.listIndex := idx;
		self.text := saveText;
	else
		self.text := null;
		self.listIndex := -1;
		self.setEntryTableCell();
	endif;

	self.amInitialised := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTranshipsVoyageDischPort" id="bcab4974-f427-4349-bd21-193308aefbcb">
        <updating/>
        <source>initTranshipsVoyageDischPort(_dischargePort : CM_Port) updating, protected;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2009	cnwas3	Initial creation
24 03 2010	cnwas3	par 21773
*/

vars

	coll		: Collection;
	idx			: Integer;
	saveText	: String;
begin

	self.portCmbOrderDescrFirst := app.myRoot.getConfig(PortCmbOrderDescrFirst).Boolean;
	self.sorted := true;
	
	coll := self.getCollectionJMT();
	
	if self.myAssistant = null and
	   self.form.isKindOf(CM_BaseForm) then
		self.myAssistant := self.form.CM_BaseForm.myAssistant;
	endif;

	
	if self.myVoyage &lt;&gt; null and not self.myVoyage.isNullVoyage then	
		if _dischargePort &lt;&gt; null then
			self.myAssistant.allTranshipPortsForDischPort(_dischargePort,self.myVoyage,coll);
		else
			self.myAssistant.allTranshipPortsForVoyage(self.myVoyage,coll);	
		endif;
	else
		//self.myAssistant.allTranshipPortsForVoyage(self.myVoyage,coll);	
		coll := self.myAssistant.allPortCodeDisplay;
	endif;	
	
	if coll = null then
		return;
	endif;

	if self.myObject &lt;&gt; null and not coll.includes(self.myObject.CM_Port) then	//par 21773 //par 23485
		coll.add(self.myObject.CM_Port);
	elseif self.listObject &lt;&gt; null and not coll.includes(self.listObject.CM_Port) then//par 23485
		coll.add(self.listObject.CM_Port);
	endif;
	
	
	
	saveText := self.text;
	
	self.listCollection(coll, false, 0);
	
	self.selLength := 1000;			
	idx := self.findString(1, saveText);

	if idx &gt; 0 then
		self.listIndex := idx;
		self.text := saveText;
	else
		self.text := null;
		self.listIndex := -1;
		self.setEntryTableCell();
	endif;

	self.amInitialised := true;
end;</source>
        <access>protected</access>
        <Parameter name="_dischargePort" type="CM_Port"/>
    </JadeMethod>
