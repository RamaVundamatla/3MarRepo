    <JadeMethod name="doShowAlertDetails" id="cbd04a1f-dad2-419e-a6bb-637c319cc985">
        <source>doShowAlertDetails();
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetails	: CMUI_SystemAlertsDetails;
	anAlert : CM_SystemAlert;
begin
	anAlert := self.tblAlerts.accessRow(self.tblAlerts.row).itemObject.CM_SystemAlert;
	if anAlert = null then
		return;
	endif;
	if anAlert.hasDetails = false then
		app.msgBox(app.getErrorString(Alert_NoDetails), "No Detail", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	//02 Mar 2012	NDL	Par 29195
	if anAlert.details.toUpper.pos("AUTO PLAN",1) &gt; 0 then
		self.myAssistant.showAutoPlanLog(null, anAlert, null, null);
		return;
		
	else
	
		// Update the navigator
		self.setNavigatorHeading("System Alerts Details"); 
		create lDetails;
		//lDetails.centreWindow;
		//lDetails.mySystemAlert := anAlert;
		lDetails.myObject := anAlert;
		lDetails.setMyTerminal(self.myTerminal);
		lDetails.openWithSavedSettings();
		lDetails.show;
	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowSearcherClick" id="d778639b-2eef-4430-a00f-e40fb648013e">
        <source>doShowSearcherClick();
// ---------------------------------------------------------------------------
// Created:     13 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if not self.frmQuery.visible then
		// cnwjk3 PAR 18356 - Date - 03/11/2008 - disable toolbar buttons
		self.searcherShowHideControls(false);
		self.frmQuery.centreWindow();
	else
		// cnwjk3 PAR 18356 - Date - 03/11/2008 - enable toolbar buttons
		self.searcherShowHideControls(true);
	endif;
	self.frmQuery.visible := (not self.frmQuery.visible);
	self.frmQuery.zOrder(1); // who knows why, works for some but not others. 16 may 2012	NDL	Par 29556
end;</source>
    </JadeMethod>
