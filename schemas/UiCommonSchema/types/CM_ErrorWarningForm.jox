    <JadeMethod name="goToError" id="5aa1eb82-45fb-46d3-99ee-840d4105997d">
        <updating/>
        <source>goToError(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     08 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	errObj		: CM_Error;
	
begin

	if table.row &lt;= 0 or table.row &gt; table.rows then
		return;
	endif;

	errObj := table.accessRow(table.row).itemObject.CM_Error;
 	if self.myCurrentForm &lt;&gt; null then
	  
		self.myCurrentForm.setFocus;
		if errObj &lt;&gt; null then
			self.myCurrentForm.goToErrorItem(errObj);
		endif;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleParentResize" id="a2cfddd7-adcf-4b67-8bb5-783845f7ee0a">
        <updating/>
        <source>handleParentResize(pClientHeight, pClientWidth : Real) updating;
// ---------------------------------------------------------------------------
// Created:     09 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.lockType &lt;&gt; LockType_Bottom then
		return;
	endif;

	self.left 	:= 0;
	self.top 	:= pClientHeight - self.height;
	self.width 	:= pClientWidth;

	self.doResize;
		
end;</source>
        <Parameter name="pClientHeight" type="Real"/>
        <Parameter name="pClientWidth" type="Real"/>
    </JadeMethod>
    <JadeMethod name="hide" id="ee3a9ef0-44ff-4220-b969-00cc2dd943e9">
        <updating/>
        <source>hide() updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin

	self.savedTop	:=	self.top;
	self.top		:=	-(self.height + 10);
	
	/*
	This does NOT work and a combination of events can lead to
	self.myCurrentForm having an invalid reference (so far unrepeatable) RJS 5/11/01
	self.caption := "";					//	so Gate window doesn't display "Error/Warning" when this form is hidden
	if self.myCurrentForm &lt;&gt; null then	//	set focus to calling window when hidden
		self.myCurrentForm.setFocus;	//	RDD 3 8 2001 Xpose 1221
	endif;
	*/
	self.caption := "";	//	RDD 3 8 2001 Xpose 1221	//	so Gate window doesn't display "Error/Warning" when this form is hidden
	
	if self.myCurrentForm &lt;&gt; null and 				//	check that self.myCurrentForm is non-null and valid 
		global.isValidObject( self.myCurrentForm ) then	//	added 22/11/01 RDD
		self.myCurrentForm.setFocus;				//	set focus to calling window when hidden
	endif;
end;</source>
    </JadeMethod>
