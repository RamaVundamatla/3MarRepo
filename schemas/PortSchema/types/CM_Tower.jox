    <JadeMethod name="validateMoveFrom" id="81ea91e2-682e-4be3-ab2f-06b1a53dc8f1">
        <source>validateMoveFrom(control: CMIF_MoveController) protected;
/*
 ------------------------------------------------------------------------
Created:			13 September 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	if control.isUndoMove or control.isPostMoveCleanup then
		return;
	endif;
	if control.isForcedMove then
		return;
	endif;
	inheritMethod(control);
	if control.moveMode &lt;&gt; REAL_MODE and control.moveMode &lt;&gt; QUEUE_MODE then
		return;
	endif;

	if self.prevPortHole &lt;&gt; null and self.prevPortHole.isConnected then 
		app.raiseCMWarning1(WARN_PORTHOLE_CONNECTED, self.id, null, null, self);
	else
		if self.nextPortHole &lt;&gt; null and self.nextPortHole.isConnected then
			app.raiseCMWarning1(WARN_PORTHOLE_CONNECTED, self.id, null, null, self);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="51f72d83-c05e-46df-90b4-99e876e71462">
        <source>validateMoveTo(control: CMIF_AutoMovePlan input);
/*
 ------------------------------------------------------------------------
Created:			17 January 2002 by cnwdwq1
Purpose:			Tests that the tower is ok for a move to it.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	towerId : String;
	isPrevious : Boolean;
	lc : CM_LocationsController;
	gc : CM_GridController;
begin
	sharedLock(self);
	lc := self.getPrimaryLocation(REAL_MODE);
	if not lc.isKindOf(CM_GridController) then
		return;
	endif;
	gc := lc.CM_GridController;
	
	isPrevious := gc.myNextController = lc;
	
	towerId := self.id.trimRight;
	if self.nonOperational then
		//Its dead!
		control.updateController(null);
		//control.addLogEntry("Intended Tower " &amp; towerId &amp; " is non-operational", IsError); //- cnwmd1, Par 20524
		control.addLogEntry(app.getErrorString1(Intended_tower_nonoperati, towerId), IsError, Intended_tower_nonoperati);
		return;
	endif;
	//--------------
	//Check slide on other side is NOT disabled.
	//If it IS, check portHole on other side is there to hold temp.
	//--------------
	if isPrevious then
		if self.prevSlideDisabled then
			//Other slide dead, if no porthole, problem!
			if self.nextPortHole = null then
				control.updateController(null);
				//control.addLogEntry("Tower " &amp; towerId &amp; " slide is disabled, no porthole on that side", IsWarning); //- cnwmd1, Par 20524
				control.addLogEntry(app.getErrorString1(Tower_slide_disab_porth_that_s, towerId), IsWarning, Tower_slide_disab_porth_that_s);
				return;
			endif;
		endif;
	else
		if self.nextSlideDisabled then
			//Other slide dead, if no porthole, problem!
			if self.prevPortHole = null then
				//control.addLogEntry("Tower " &amp; towerId &amp; " slide is disabled, no porthole on that side", IsWarning); //- cnwmd1, Par 20524
				control.addLogEntry(app.getErrorString1(Tower_slide_disab_porth_that_s, towerId), IsWarning, Tower_slide_disab_porth_that_s);
				control.updateController(null);
				return;
			endif;
		endif;
	endif;
	//--------------
	//Check slide on other side is NOT faulted.
	//--------------
	if isPrevious then
		if self.prevSlideFault.trimRight &lt;&gt; "" then
			//slide is crook
			control.updateController(null);
			//control.addLogEntry("Tower " &amp; towerId &amp; " has previous slide problem", IsWarning); //- cnwmd1, Par 20524
			control.addLogEntry(app.getErrorString1(Tower_previou_slide_problem, towerId), IsWarning,Tower_previou_slide_problem);
			return;
		endif;
	else
		if self.nextSlideFault.trimRight &lt;&gt; null then
			//slide is crook
			control.updateController(null);
			//control.addLogEntry("Tower " &amp; towerId &amp; " has next slide problem", IsWarning); //- cnwmd1, Par 20524
			control.addLogEntry(app.getErrorString1(Tower_next_slide_problem, towerId), IsWarning, Tower_next_slide_problem);
			return;
		endif;
  endif;
epilog
	unlock(self);
end;</source>
        <Parameter name="control" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
