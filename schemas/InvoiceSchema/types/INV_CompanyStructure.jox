    <JadeMethod name="populateController" id="a78f2c3c-1d65-4bdf-915b-d08922460694">
        <updating/>
        <source>populateController(_controller : CMIF_BankDetails input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	_controller.isBU := (self.modePropertyUpdate = self.MODEPROPERTY_BU or self.modePropertyNew = self.MODEPROPERTY_BU);
	
	if self.myCurrentBU &lt;&gt; null then
		_controller.myParentCompany := self.myCurrentCompany;
	else
		if self.modePropertyNew = self.MODEPROPERTY_BU
		and self.myCurrentCompany &lt;&gt; null then
			_controller.myParentCompany := self.myCurrentCompany;
		else
			_controller.myParentCompany := app.myRoot.myRootCompany;
		endif;
	endif;
	
	_controller.setBankDetails(self.tblProperties.getValueByName(ETRow_BankDetails).String);
	_controller.setMailingAddress(self.tblProperties.getValueByName(ETRow_Address).String);
	_controller.setRemittanceAddress(self.tblProperties.getValueByName(ETRow_RemAddress).String); // CCMS 1587
	
	_controller.code := self.tblProperties.getValueByName(ETRow_Code).String;
	_controller.emailAddress := self.tblProperties.getValueByName(ETRow_Email).String;
	_controller.faxNumber := self.tblProperties.getValueByName(ETRow_Fax).String;
	_controller.isSuspended := self.tblProperties.getValueByName(ETRow_IsSuspended).Boolean;
	_controller.mailingName := self.tblProperties.getValueByName(ETRow_Name).String;
	_controller.onsiteStorageChargeTime := self.tblProperties.getValueByName(ETRow_CutOffTime).Time;
	_controller.phoneNumber := self.tblProperties.getValueByName(ETRow_Phone).String;
	_controller.retrospectiveRates := self.tblProperties.getValueByName(ETRow_RateLookup).Boolean;
	_controller.taxNarration := self.tblProperties.getValueByName(ETRow_TaxNarration).String;
	_controller.taxNumber := self.tblProperties.getValueByName(ETRow_TaxCode).String;
// cnwdad1 20/05/2009 - PAR 17633.
//	_controller.taxPercentageRate := self.tblProperties.getValueByName(ETRow_TaxPC).Real;
	_controller.taxPercentageRate := self.tblProperties.getValueByName(ETRow_TaxPC).String.asRealJMT();
	_controller.myBusinessUnitDebtor := self.cmbDebtorInvProp.listObject.CM_Debtor;
end;</source>
        <Parameter name="_controller" type="CMIF_BankDetails" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCorrectComboStyle" id="e392ebd1-3384-4318-9740-6e503b75bcb2">
