C,A,4493,,,,General Cargo,,,COIL,Coils,,,DFBU,,,,JPABA,JPADO,D1006G,,0.0000,,D1006G_COIL1,Remain On Board,,0.0000,MZMPM,,,,,,'&amp;TestOperator&amp;',,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,13438,,,,0.000,'&amp;VoyageName&amp;',,,0.0000,,,
C,A,4494,,,,General Cargo,,,COIL,Coils,,,DFBU,,,,JPABA,JPADO,D1006G,,0.0000,,D1006G_COIL2,Remain On Board,,0.0000,MZMPM,,,,,,'&amp;TestOperator&amp;',,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,13438,,,,0.000,'&amp;VoyageName&amp;',,,0.0000,,,
C,A,4495,,,,General Cargo,,,COIL,Coils,,,DFBU,,,,JPABA,JPADO,D1006G,,0.0000,,D1006G_COIL3,Remain On Board,,0.0000,MZMPM,,,,,,'&amp;TestOperator&amp;',,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,13438,,,,0.000,'&amp;VoyageName&amp;',,,0.0000,,,
C,A,4496,,,,General Cargo,,,COIL,Coils,,,DFBU,,,,JPABA,JPADO,D1008G,,0.0000,,D1008G_COIL1,Remain On Board,,0.0000,MZMPM,,,,,,'&amp;TestOperator&amp;',,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,13438,,,,0.000,'&amp;VoyageName&amp;',,,0.0000,,,
C,A,4497,,,,General Cargo,,,COIL,Coils,,,DFBU,,,,JPABA,JPADO,D1008G,,0.0000,,D1008G_COIL2,Remain On Board,,0.0000,MZMPM,,,,,,'&amp;TestOperator&amp;',,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,13438,,,,0.000,'&amp;VoyageName&amp;',,,0.0000,,,
C,A,4498,,,,General Cargo,,,COIL,Coils,,,DFBU,,,,JPABA,JPADO,D1008G,,0.0000,,D1008G_COIL3,Remain On Board,,0.0000,MZMPM,,,,,,'&amp;TestOperator&amp;',,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,13438,,,,0.000,'&amp;VoyageName&amp;',,,0.0000,,,';

	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedShipManifest[1 : fileTypeUser.name.maxLength];						// ie 63
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// make sure all of the objects are deleted and created correctly.
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);
	
	//verify and DB load
	self.ediLoadVerifyDBLoadActualBasic(ediText, UserDefinedShipManifest, UserDefinedShipManifest&amp;method.name, EDIFileType_UserDefined, true, true, false, false, null);
epilog
	delete unloadArray;
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
end;
</source>
    </JadeMethod>
    <JadeMethod name="uRORODeckPlanActulPrpsd" id="588c571d-e437-4ad2-b927-6a39d9ce24c6">
        <updating/>
        <source>uRORODeckPlanActulPrpsd() updating;
// cnwrs1
// Extract proposed and actual Deck Plan Par 29388
/* Changes

Date		Name	TFS#		Description
============================================================================
07 Nov 2012	cnwrs1	Par 30688 OOTL layouts are missing for proposed
cnwrs1 3 Dec 2012 - Par 30738 test for Ship RORO DECK PLAN check it 
14 Dec 2012	cnwrs1	Par 30907	EDI RORO Proposed Deck Plan Location ID not position ID
31 Dec 2012	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotaion 1X1
16 Jan 2013	cnwmh5	30863 - Add additional rotations
12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
