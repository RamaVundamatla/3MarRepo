    <JadeMethod name="loadRateTableByRow" id="6d6ad217-f868-40a5-8ddd-3e1d11223af4">
        <source>loadRateTableByRow(_row : Integer);
// ---------------------------------------------------------------------------
// Created:     18 November 2008 by cnwab1
//
// Purpose:      // PAR 18489
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 20 Feb 2018		jlgmd1			TFS 36954 SNO - Error in SCT2 Rate Table (Swap $CM_RateEntry.decimalPlaces for terminal config)
// ---------------------------------------------------------------------------

vars
	table : CM_DataTable;
	service : CM_Service;
	rateEntry : CM_RateEntry;
	debtor		: CM_DebtorNode;
	lineGroupDebtor : CM_LineGroupDebtor;
	lastRow, firstRow, firstCol, lastCol, col, row : Integer;
	cellObj,
	colObj: Object;
	tsServer,tsLocal : TimeStamp;
	costPerUnit  : Decimal[12,2];
	rate : CM_Rate;
	dpl : Integer;
	symbol : Character;
begin
	table := self.tblData;
	tsLocal.setDate(self.txtDateDebtor.getDate());		
	tsServer := self.localToSystemTime(tsLocal);// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	firstCol := table.fixedColumns + 1;
	lastCol := table.columns;
	
	// TFS 36954 MPD 20 Feb 2018
	dpl := self.getRateEntryDecimalPlaces;
	symbol := app.myRoot.getInvoiceCurrencySymbol.Character;

	service := table.accessRow(_row).itemObject.CM_Service;
	
	foreach col in firstCol to lastCol do
		cellObj := table.accessCell(_row, col).itemObject;
		
		if global.isValidObject(cellObj) then
			continue;
		endif;
		colObj:=table.accessColumn(col).itemObject;
		if colObj.isKindOf(CM_DebtorNode) then
			debtor := colObj.CM_DebtorNode;
			rateEntry := debtor.getServiceTimeRate(service, tsServer);
		elseif colObj.isKindOf(CM_LineGroupDebtor) then
			lineGroupDebtor:=colObj.CM_LineGroupDebtor;
			rateEntry := lineGroupDebtor.getServiceTimeRate(service.bank,service, tsServer);
		endif;
		
		if rateEntry &lt;&gt; null then
			costPerUnit := rateEntry.getDerivedCostPerUnit(self.effectiveDate.TimeStamp);
			if costPerUnit = 0.0 then
				table.accessedCell.text := null; // PAR 18489
			else
				//table.accessedCell.text := costPerUnit.userCurrencyFormat($CM_RateMoney);
				table.accessedCell.text := symbol &amp; costPerUnit.asStringJMTWithPrecision(dpl, false);	// TFS 36954 MPD 20 Feb 2018
			endif;
			table.accessedCell.itemObject := rateEntry;
			rate:=rateEntry.rate;
			if rate.appliesToDebtor(colObj.CM_Object) then
				table.accessedCell.fontBold := true;
			else
				table.accessedCell.fontBold := false;
			endif;
		else	
			table.accessedCell.text := null; // PAR 18489
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadServices" id="4e934ec9-71f4-4bd2-82b5-dae8278a29f8">
        <source>loadServices();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/06/2014	cnwdap1		PAR #34422 Remvoe beginLock / endLock
vars

	i : Integer;
	obj		: Object;
	service : CM_Service;
	rateTable : CM_DataTable;
	bank : CM_Bank;
	debtorColumns : Boolean;
	savedChargedEffTS : TimeStamp;
begin

	//19 Sep 2012	NDL	Par 30375
	savedChargedEffTS := app.getChargeRateEffectiveDate();
	app.setChargeRateEffectiveDate( self.effectiveDate.TimeStamp );
	
	debtorColumns := true;
	rateTable := self.tblData;
	bank := self.myCurrentBank;

	if debtorColumns then
		rateTable.columns := 1;
		rateTable.fixedColumns := 1;
		
		rateTable.rows := 1;
		
		rateTable.columnWidth[1] := 160;
		i := 1;
		rateTable.text := "Services \ Debtors";
		if self.mode = self.Mode_Debtor then
			foreach obj in self.allSelectedServices do
				service := obj.CM_Service;
				rateTable.addItemObject(service, service.name);
			endforeach;
		else
			foreach service in bank.services where not service.isNotAvailableForEntry do
				rateTable.addItemObject(service, service.name);
			endforeach;
		endif;
	else
		rateTable.rows := 1;
		rateTable.columns := self.allSelectedServices.size + 1;
		rateTable.fixedColumns := 1;
		rateTable.clear;
		rateTable.row := 1;
		rateTable.columnWidth[1] := 160;
		i := 1;
		rateTable.text := "Debtors \ Services";
		foreach obj in self.allSelectedServices do
			service := obj.CM_Service;
			rateTable.addItemObject(service, service.name);
		endforeach;
	endif;
	rateTable.accessColumn(1).backColor := self.colorHeadingColumn;
epilog
	app.setChargeRateEffectiveDate( savedChargedEffTS );	//19 Sep 2012	NDL	Par 30375
end;</source>
    </JadeMethod>
    <JadeMethod name="positionQueryFrame" id="8cf74e98-c752-45c2-8e69-cd3e4e3b1653">
        <source>positionQueryFrame() protected;
// ---------------------------------------------------------------------------
// Created:     July 2010 cnwjre1	copy from base form to set different size for 24052 debtor and service multi-selection
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// Changed On	By			Reason
// ----------	---------	--------------------------------------------------
// 05/02/2025	navlw1		JIRA-33945: MTN | Add Filter MSG to Some Forms
// ---------------------------------------------------------------------------
begin

	self.frmQuery.left		:=	(self.width / 2) - (self.frmQuery.width / 2);
	self.frmQuery.top		:=	40;			// position higher
	self.frmQuery.height	:=	500;		// navlw1 #JIRA-33945 05/02/2025 
											// stretch to fit the debtor and service multi-select group boxes
	self.frmQuery.width		:=	460;		// stretch to fit the debtor and service multi-select group boxes
	
	self.fldQuery.top		:=	self.frmQueryToolbar.clientHeight()+2;
	self.fldQuery.left		:=	0;
	self.fldQuery.height	:=	frmQuery.clientHeight() - (self.frmQueryToolbar.height + 30);
	self.fldQuery.width		:=	self.frmQuery.clientWidth();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setBerthServicesAvailable" id="20f2c94f-5aea-4a5a-92a3-19ea28be9c0d">
        <source>setBerthServicesAvailable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/06/2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
18/07/2018	jlgdap1	TFS 39782 PEL1 Vessel Rates need to filter Services
*/

vars
	col : ObjectSet;
	service : CM_Service;
	
begin
	create col transient;
	foreach service in self.myCurrentBank.services where not service.isNotAvailableForEntry do
		if service.defaultRateTable &lt;&gt; CM_Service.BERTH_RATE_TABLE then		// TFS 39782
			continue;														// TFS 39782
		endif;																// TFS 39782
		col.add(service);
	endforeach;
	self.msgbBerthServ.setAvailable(col, true);
	self.msgbBerthServ.setSelected(self.allSelectedBerthServices);
	
epilog
	delete col;
end;</source>
    </JadeMethod>
    <JadeMethod name="setBerthsAvailable" id="b2f6df4f-b77e-4c4c-934a-a9b6132cbbbc">
        <source>setBerthsAvailable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types

*/

vars
	col : ObjectSet;
	berth : HMS_Berth;
	failedDAC : CM_DataAccessController;
begin
	if self.myTerminal = null then
		return;
	endif;
	if self.myTerminal.myHarbour = null then
		return;
	endif;
	create col transient;
	foreach berth in self.myTerminal.myHarbour.allBerths discreteLock do
		if not berth.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		col.add(berth);
	endforeach;
	/*Pending38953 */
	self.msgbBerths.setAvailable(col, true);
	self.msgbBerths.setSelected(self.allSelectedBerths);	
epilog
	delete col;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCurrentBank" id="652bb421-dd7e-46d7-bd24-e8ef1ba9548b">
        <source>setCurrentBank();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
