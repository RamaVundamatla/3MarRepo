    <JadeMethod name="buBatchCleanup_click" id="c6c4b4d6-59a7-45f9-9a61-58d4bfee7f23">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>buBatchCleanup_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2017	cnwns1	Initial creation

*/

vars
	output : String;
begin
	if 	self.startBatchProcess() then
		output := systemName &amp; " " &amp; "Finished Batch Run";
		
	else
		output := systemName &amp; " " &amp; "FAILED Batch Run";
	endif;
	write output;
	self.caption := output;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buCancel_click" id="257e3555-989b-495d-92bc-07a5735f4402">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>buCancel_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlgns1	Initial creation

*/

vars

begin
	if self.canceled then
		self.canceled := false;
		self.buCancel.caption := "Cancel";
	else
		self.canceled := true;
		self.buCancel.caption := "Uncancel";
	endif;
	
	
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
