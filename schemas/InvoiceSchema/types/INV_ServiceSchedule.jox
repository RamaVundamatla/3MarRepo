    <JadeMethod name="doLstDataMouseMove" id="80fe5331-84e8-406c-84fa-0f4dca07d842">
        <updating/>
        <source>doLstDataMouseMove(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     26 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	if button &lt;&gt; 1 then
		return;
	endif;
	
	if self.viewOnly then // user does not have permision to make changes. 
	 	return;
	endif;

	if app.dragDetected(x, y, origXPos, origYPos) then
		self.lstDataMouseMoveEvent(button, shift, x, y);
		origXPos := null;
		origYPos := null;
	endif;
	

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
