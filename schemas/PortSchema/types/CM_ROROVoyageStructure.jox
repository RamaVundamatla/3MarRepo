    <JadeMethod name="archive" id="2fc63f70-8d36-41a2-bd26-16f25af124df">
        <updating/>
        <source>archive(_cmifArchiveVoy: CMIF_ArchiveVoyage; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2020 cnwma1 Bug 48863: JMT - Voyage Archive, Non Worked Cargo Issue
*/

vars
	objArray	   : ObjectArray;
	obj			   : Object;
	moveController : CMIF_MoveController;
	theMonitor     : CMIF_Monitor;
begin
	
	exclusiveLock(self);
	
	if _cmifArchiveVoy.myMonitor &lt;&gt; null then
		theMonitor := _cmifArchiveVoy.myMonitor;
	endif;
	
	//----------------------
	//Process each bayplan
	//----------------------
	if theMonitor &lt;&gt; null then
		theMonitor.updateProgress(app.getErrorString(ProcessingBayPlans) &amp; '...', null, null);
	endif;
	
	create moveController  transient; //create once - used to unplan/unqueue TIs in slot
	create objArray        transient;
	
	self.allDecks.copy(objArray);
	
	foreach obj in objArray do
		if obj.isKindOf(CM_DeckVoyage) then
			obj.CM_DeckVoyage.archive(_cmifArchiveVoy, moveController, _passport);
		endif;
	endforeach;

epilog
	delete moveController;
	delete objArray;
end;</source>
        <Parameter name="_cmifArchiveVoy" type="CMIF_ArchiveVoyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createDefaultDischargeCC" id="4762ab65-1bf7-4009-9bbb-14b38956f766">
        <updating/>
        <source>createDefaultDischargeCC(_passport : CM_Passport input) updating;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars
	deckVoyageIter : Iterator;
	deckVoyage : CM_DeckVoyage;
begin
	exclusiveLock(self);
	
	deckVoyageIter := self.allDecks.createIterator;
	while deckVoyageIter.next(deckVoyage) do	
		deckVoyage.createDefaultDischargeCC(_passport);
	endwhile;

	// ################################
	// This will update the display on screen of this voyage
//	self.causeEvent(self.myVoyage.myTerminal.getTerminalEvent(EVENT_REFRESH_VOYAGE_AREA), false, null);
epilog
	delete deckVoyageIter;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createOOWAutoAssignJobs" id="75433604-fa6b-4efc-858b-dfcc486dd52f">
        <source>createOOWAutoAssignJobs();
/*

Purpose:	Auto Assigns the jobs to the deck jobs		

Parameters:			

Return Value:		


Date		Who		Reason
14 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	jobSheet	: CM_JobSheet;
	deckJobSheet : CM_VoyageDeckJobSheet;
	allJobSheets : ObjectArray;
	jobSheetTotalItems,
	minTimeJobSheet,
	currentJobSheet,
	workPointItemSize, 
	numJobs, 
	totalItems
	 : Integer;
	totalRate,
 	numMins 	: Real;
	oow 		: CM_OOWCreation;
	workPoint 	: CM_WorkPoint;
	wpTargetRatePHWeight : Integer;	//08 Mar 2018	NDL TFS 37437
begin
	numJobs:=self.allOOWCreations.size;
	
	if numJobs = 0 then
		return;
	endif;
	
	create allJobSheets transient;
	foreach jobSheet in self.myVoyage.allJobSheetsInOrder do
		if jobSheet.isKindOf(CM_VoyageDeckJobSheet) then
			allJobSheets.add(jobSheet);
			workPoint:=jobSheet.CM_VoyageDeckJobSheet.getMyWorkPoint;
			if workPoint.hasDefinedCargoRates then	//08 Mar 2018	NDL TFS 37437
				totalRate := totalRate + workPoint.getDefinedTargetRateWeight( jobSheet.CM_VoyageDeckJobSheet );
			else
				totalRate:=totalRate + workPoint.targetRatePHWeight;
			endif;
		endif;
	endforeach;
	
	if allJobSheets.size = 0 then
		return;
	endif;
	
	foreach oow in self.allOOWCreations do
		totalItems:=totalItems + oow.getTotalItems;
	endforeach;

	minTimeJobSheet:=1;
	currentJobSheet:=1;
	// just do an even split of job numbers to work points
	foreach oow in self.allOOWCreations do
		deckJobSheet:=allJobSheets[currentJobSheet].CM_VoyageDeckJobSheet;
		workPoint:=deckJobSheet.getMyWorkPoint;
		jobSheetTotalItems:=jobSheetTotalItems +  oow.getTotalItems;
		
	//	workPointItemSize:=((workPoint.targetRatePHWeight/totalRate) * totalItems).roundedUp;		
	//	numMins:=numMins + ((oow.getTotalItems/workPoint.targetRatePHWeight) * 60);
	
		//08 Mar 2018	NDL TFS 37437
		if workPoint.hasDefinedCargoRates then	
			wpTargetRatePHWeight := workPoint.getDefinedTargetRateWeight( deckJobSheet );
		else
			wpTargetRatePHWeight := workPoint.targetRatePHWeight;
		endif;
		workPointItemSize:=((wpTargetRatePHWeight/totalRate) * totalItems).roundedUp;		
		numMins:=numMins + ((oow.getTotalItems/wpTargetRatePHWeight) * 60);

		oow.setJobSheet(deckJobSheet);
		if jobSheetTotalItems &gt;= workPointItemSize then
			currentJobSheet:=currentJobSheet + 1;
			jobSheetTotalItems:=0;
			numMins:=0;
		endif;
	endforeach;
epilog
	delete allJobSheets;

end;</source>
    </JadeMethod>
    <JadeMethod name="createQuickCargo" id="c7ca6e46-2b60-4593-9e17-ffbcad34afe9">
        <updating/>
        <source>createQuickCargo(_locn : CM_DeckItem; _is40 : Boolean; _fill : Boolean; _dischargePort: String; _commodity: String) : Boolean updating;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars

	aTerm : CM_Terminal;
	aRoot : CM_Root;
	aVoy : CM_Voyage;
	realTI,
	pxyTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
	slot, aftSlot : CM_LocationsController;
	tmpID : String;
	lcs : CM_LCArray;
	subT : CM_SubTerminal;
	idx, numTI : Integer;
begin
	if _fill then
		if _locn.isKindOf(CM_ROROLocnDefnVoyage) then
			numTI := _locn.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal.size;
		else
			numTI := 1;
		endif;
	else
		numTI := 1;
	endif;
		passport := app.myPassport;
	
	
	while idx &lt; numTI do
		idx := idx + 1;
		if _locn.isKindOf(CM_ROROLocnDefnVoyage) then
			slot :=  _locn.CM_ROROLocnDefnVoyage.getNextFreeSlotController();
			if slot = null then
				break;
			endif;
		
			if slot.allTrackedItems.isNotEmpty() then
				break;
			endif;
		elseif _locn.isKindOf(CM_ROROLaneDefnVoyage) then
			slot :=  _locn.CM_ROROLaneDefnVoyage.myLaneController;
		elseif _locn.isKindOf(CM_ROROGCDefnVoyage) then
			slot :=  _locn.CM_ROROGCDefnVoyage.myGCController;
		endif;
		
		
		if slot = null then
			return false;
		endif;
		
		
		if _is40 then
			if _locn.isKindOf(CM_ROROLocnDefnVoyage) then
				aftSlot := slot.getAftLC();
				if aftSlot = null then
					return false;
				endif;
				if not aftSlot.CM_ROROSlotController.mySlotDefn.isAvailable then
					return false;
				endif;
			endif;
		endif;
		
		aVoy	:= self.myVoyage;
		aTerm := aVoy.myTerminal;
	
		//lets make cargo
		
		passport := app.myPassport;
		passport.setMyTerminal(aTerm);
		passport.setWarningsIgnored(true);
		passport.setWarningsAcknowledged(true);
		cargoType	:= app.myRoot.allCargoTypesById[1];
		state := TI_STATE_ONSHIP;
	
		delete moveController;
		create moveController transient;
		delete lcs;
		create lcs transient;
		
			moveController.setMyToPrimaryLocation(slot);
			tmpID := self.getNextQuickCargoID(TI_CargoType_Container);
			lcs.clear();
			
			pxyTI := aTerm.createTI(cargoType, true);
			pxyTI.zSetPxyTerminal(aTerm);
	
			pxyTI.setCargoType(cargoType.id);
			pxyTI.setMyOperator(app.myRoot.allOperators["MSK"]);
			if pxyTI.myOperator = null then
				pxyTI.setMyOperator(app.myRoot.allOperators["MSL"]);
			endif;
			if pxyTI.myOperator = null then
				pxyTI.setMyOperator(app.myRoot.allOperators.first);
			endif;
			pxyTI.setCommodity(_commodity);
			pxyTI.setImExStatus(TI_IMEX_STATUS_REMAINONBOARD);

			pxyTI.setMyVoyage(aVoy, passport);
			pxyTI.changeState(state, passport);
			pxyTI.setWeight(4000, null,passport);
			pxyTI.setTotalWeight(4000, null,passport);
			//pxyTI.zSetPxyCompany(aTerm.getConfig(DefCompany).CM_Bank);
			pxyTI.zSetPxyCompany(aTerm.getDefaultCompanyBank);//17 Apr 2012 NDL	Par 29393
			if _dischargePort &lt;&gt; null then
				pxyTI.zSetPxyDischargePort(_dischargePort);
			else
				pxyTI.zSetPxyDischargePort(aTerm.getConfig(PortDestCode).String);
			endif;
			if _is40 then
				pxyTI.changeISOType("4200", null, app.myPassport);
//				lcs.add(slot);
//				lcs.add(slot.CM_SlotController.myAftSlot);
//				moveController.updateAllToLocations(lcs);
			else
				pxyTI.changeISOType("2200", null, app.myPassport);
			endif;
			if app.isSubTerminalsOn(aTerm) then
				subT := aTerm.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
																		0,	
																		TI_IMEX_STATUS_IMPORT,
																		"MT",
																		true); 
				pxyTI.setSubTerminal(subT,null);
			endif;
			pxyTI.zSetPxyId(tmpID);
			passport.setWarningsIgnored(true);
			passport.setWarningsAcknowledged(true);
			app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, passport); // this deletes the pxyTI
		if passport.hasErrors() then
			break;
		endif;
	endwhile;
		
		return passport.allErrorWarnings.isEmpty();

epilog

	delete moveController;
	delete lcs;
end;</source>
        <Parameter name="_locn" type="CM_DeckItem"/>
        <Parameter name="_is40" type="Boolean"/>
        <Parameter name="_fill" type="Boolean"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargoGC" id="1c4ab205-2ff1-4b69-bbc8-1e011bdbb41b">
        <updating/>
        <source>createQuickCargoGC(_gcDefn : CM_ROROGCDefnVoyage; _cargoType : CM_CargoType; _xMetres, _yMetres : Decimal; _deck : CM_DeckVoyage; _numTIs : Integer) : Boolean updating;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars

	aTerm : CM_Terminal;
	aRoot : CM_Root;
	aVoy : CM_Voyage;
	realTI,
	pxyTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	product : CM_Product;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
	slot : CM_LocationsController;
	tmpID : String;
	lcs : CM_LCArray;
	subT : CM_SubTerminal;
	idx, numTI : Integer;
		gcDefn : CM_ROROGCDefnVoyage;

begin
	if _cargoType = null then
		return false;
	endif;
	numTI := _numTIs;
	gcDefn := _gcDefn;
	
	while idx &lt; numTI do
		idx := idx + 1;
		
		aVoy	:= self.myVoyage;
		aTerm := aVoy.myTerminal;
	
		cargoType	:= _cargoType;
		state := TI_STATE_ONSHIP;
	
		tmpID := self.getNextQuickCargoID(cargoType.id);
			
		pxyTI := aTerm.createTI(cargoType, true);
		pxyTI.zSetPxyTerminal(aTerm);

		pxyTI.setCargoType(cargoType.id);
		pxyTI.setMyProduct(cargoType.allProducts.first);
		pxyTI.setMyTotalVolume(1234); // cnwdw1 27868

		
		pxyTI.setMyOperator(app.myRoot.allOperators["MSK"]);
		if pxyTI.myOperator = null then
			pxyTI.setMyOperator(app.myRoot.allOperators["MSL"]);
		endif;
		if pxyTI.myOperator = null then
			pxyTI.setMyOperator(app.myRoot.allOperators.first);
		endif;
		pxyTI.setBookingReference("BOOKING");
//		pxyTI.setCommodity("MT");
		pxyTI.setImExStatus(TI_IMEX_STATUS_REMAINONBOARD);
		pxyTI.setMyVoyage(aVoy, passport);
		pxyTI.changeState(state, passport);
		pxyTI.setWeight(4000, null,passport);
		pxyTI.setTotalWeight(4000, null,passport);
		pxyTI.setQVW(1,1234,4000);  // AKB
		//pxyTI.zSetPxyCompany(aTerm.getConfig(DefCompany).CM_Bank);
		pxyTI.zSetPxyCompany(aTerm.getDefaultCompanyBank);//17 Apr 2012 NDL	Par 29393
		pxyTI.zSetPxyDischargePort(aTerm.getConfig(PortDestCode).String);
	//	pxyTI.zSetPxyDischargePort("NZAKL");
		if app.isSubTerminalsOn(aTerm) then
			subT := aTerm.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
																	0,	
																	TI_IMEX_STATUS_IMPORT,
																	"MT",
																	true); 
			pxyTI.setSubTerminal(subT,null);
		endif;
		pxyTI.zSetPxyId(tmpID);

		passport := app.myPassport;
		passport.setMyTerminal(aTerm);
		passport.setWarningsIgnored(true);
		passport.setWarningsAcknowledged(true);
		gcDefn := app.myTrxCA.trxCreateROROGCCargo(false, gcDefn, null, pxyTI, _xMetres, _yMetres, _deck, passport); // pxyTI deleted in TRX
		
		if passport.hasErrors() then
			break;
		endif;
		
	endwhile;
		
	return passport.allErrorWarnings.isEmpty();

epilog

end;</source>
        <Parameter name="_gcDefn" type="CM_ROROGCDefnVoyage"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_numTIs" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargoLane" id="32a811f7-1a59-4271-a12f-71684200fcd4">
        <updating/>
        <source>createQuickCargoLane(_laneDefn : CM_ROROLaneDefn; _cargoType : CM_CargoType; _xMetres, _yMetres : Decimal; _deck : CM_DeckVoyage; _numTIs : Integer) : Boolean updating;
/*
Purpose:			
Date				Who			Reason
NOVEMBER 2011		CNWAB1		Initial creation
*/


vars

	aTerm : CM_Terminal;
	aRoot : CM_Root;
	aVoy : CM_Voyage;
	realTI,
	pxyTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	product : CM_Product;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
	slot : CM_LocationsController;
	tmpID : String;
	lcs : CM_LCArray;
	subT : CM_SubTerminal;
	idx, numTI : Integer;
	laneDefn : CM_ROROLaneDefn;
	thePoints : PointArray;
begin
	if _cargoType = null then
		return false;
	endif;
	
	numTI := _numTIs;
	laneDefn := _laneDefn;
	
	while idx &lt; numTI do
		idx := idx + 1;
		
		aVoy	:= self.myVoyage;
		aTerm := aVoy.myTerminal;
	
		cargoType	:= _cargoType;
		state := TI_STATE_ONSHIP;
	
		tmpID := self.getNextQuickCargoID(cargoType.id);
			
		pxyTI := aTerm.createTI(cargoType, true);
		pxyTI.zSetPxyTerminal(aTerm);

		pxyTI.setCargoType(cargoType.id);
		pxyTI.setMyProduct(cargoType.allProducts.first);
		pxyTI.setMyTotalVolume(356);

		
		pxyTI.setMyOperator(app.myRoot.allOperators["MSK"]);
		if pxyTI.myOperator = null then
			pxyTI.setMyOperator(app.myRoot.allOperators["MSL"]);
		endif;
		if pxyTI.myOperator = null then
			pxyTI.setMyOperator(app.myRoot.allOperators.first);
		endif;
		pxyTI.setBookingReference("BOOKING");

		pxyTI.setImExStatus(TI_IMEX_STATUS_REMAINONBOARD);
		pxyTI.setMyVoyage(aVoy, passport);
		pxyTI.changeState(state, passport);
		pxyTI.setWeight(3500, null,passport);
		pxyTI.setTotalWeight(3500, null,passport);
		pxyTI.setLength(3000);
		//pxyTI.zSetPxyCompany(aTerm.getConfig(DefCompany).CM_Bank);
		pxyTI.zSetPxyCompany(aTerm.getDefaultCompanyBank);//17 Apr 2012 NDL	Par 29393
		pxyTI.zSetPxyDischargePort(aTerm.getConfig(PortDestCode).String);

		if app.isSubTerminalsOn(aTerm) then
			subT := aTerm.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
																	0,	
																	TI_IMEX_STATUS_IMPORT,
																	"MT",
																	true); 
			pxyTI.setSubTerminal(subT,null);
		endif;
		pxyTI.zSetPxyId(tmpID);

		passport := app.myPassport;
		passport.setMyTerminal(aTerm);
		passport.setWarningsIgnored(true);
		passport.setWarningsAcknowledged(true);
		laneDefn := app.myTrxCA.trxCreateROROLaneCargo(false, laneDefn, null, pxyTI, passport); // pxyTI deleted in TRX
		
		if passport.hasErrors() then
			break;
		endif;
		
	endwhile;
		
	return passport.allErrorWarnings.isEmpty();

epilog
	delete thePoints;
end;</source>
        <Parameter name="_laneDefn" type="CM_ROROLaneDefn"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_numTIs" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargoOOTL" id="0684f677-9b8e-40ec-ab1a-c3e4b4653a37">
        <updating/>
        <source>createQuickCargoOOTL(_locnDefn : CM_ROROLocnDefnVoyage; _is40 : Boolean;  _xMetres, _yMetres : Decimal; _deck : CM_DeckVoyage; _numTIs : Integer) : Boolean updating;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars

	aTerm : CM_Terminal;
	aRoot : CM_Root;
	aVoy : CM_Voyage;
	realTI,
	pxyTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	product : CM_Product;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
	slot : CM_LocationsController;
	tmpID : String;
	lcs : CM_LCArray;
	subT : CM_SubTerminal;
	idx, numTI : Integer;
		locnDefn : CM_ROROLocnDefnVoyage;

begin
	numTI := _numTIs;
	locnDefn := _locnDefn;
	
	while idx &lt; numTI do
		idx := idx + 1;
		
		aVoy	:= self.myVoyage;
		aTerm := aVoy.myTerminal;
	
		cargoType	:= app.myRoot.allCargoTypesById[1]; // Container

		state := TI_STATE_ONSHIP;
	
		tmpID := self.getNextQuickCargoID(cargoType.id);
			
		pxyTI := aTerm.createTI(cargoType, true);
		pxyTI.zSetPxyTerminal(aTerm);

		pxyTI.setCargoType(cargoType.id);
		pxyTI.setMyProduct(cargoType.allProducts.first);
		
		
		pxyTI.setMyOperator(app.myRoot.allOperators["MSK"]);
		if pxyTI.myOperator = null then
			pxyTI.setMyOperator(app.myRoot.allOperators["MSL"]);
		endif;
		if pxyTI.myOperator = null then
			pxyTI.setMyOperator(app.myRoot.allOperators.first);
		endif;
		pxyTI.setBookingReference("BOOKING");
		pxyTI.setCommodity("MT");
		pxyTI.setImExStatus(TI_IMEX_STATUS_REMAINONBOARD);
		pxyTI.setMyVoyage(aVoy, passport);
		pxyTI.changeState(state, passport);
		pxyTI.setWeight(4000, null,passport);
		pxyTI.setTotalWeight(4000, null,passport);
			if _is40 then
				pxyTI.changeISOType("4200", null, app.myPassport);
			else
				pxyTI.changeISOType("2200", null, app.myPassport);
			endif;
		//pxyTI.zSetPxyCompany(aTerm.getConfig(DefCompany).CM_Bank);
		pxyTI.zSetPxyCompany(aTerm.getDefaultCompanyBank);//17 Apr 2012 NDL	Par 29393
		pxyTI.zSetPxyDischargePort(aTerm.getConfig(PortDestCode).String);
//		pxyTI.zSetPxyDischargePort("NZAKL");
		if app.isSubTerminalsOn(aTerm) then
			subT := aTerm.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
																	0,	
																	TI_IMEX_STATUS_IMPORT,
																	"MT",
																	true); 
			pxyTI.setSubTerminal(subT,null);
		endif;
		pxyTI.zSetPxyId(tmpID);

		passport := app.myPassport;
		passport.setMyTerminal(aTerm);
		passport.setWarningsIgnored(true);
		passport.setWarningsAcknowledged(true);
		locnDefn := app.myTrxCA.trxCreateROROOOTLCargo(locnDefn, null, pxyTI, true, _xMetres, _yMetres, _deck, passport); // pxyTI deleted in TRX
		if passport.hasErrors() then
			break;
		endif;
	endwhile;
		
	return passport.allErrorWarnings.isEmpty();

epilog

end;</source>
        <Parameter name="_locnDefn" type="CM_ROROLocnDefnVoyage"/>
        <Parameter name="_is40" type="Boolean"/>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_numTIs" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createQuickGCLocation" id="c7035bf6-5e14-4c38-be11-dcb0c2f81a6b">
        <updating/>
        <source>createQuickGCLocation(_gcDefn : CM_ROROGCDefnVoyage; _xMetres, _yMetres : Decimal; _deck : CM_DeckVoyage; _label : String) : Boolean updating;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars

	aTerm : CM_Terminal;
	aRoot : CM_Root;
	aVoy : CM_Voyage;
	realTI,
	pxyTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	product : CM_Product;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
	slot : CM_LocationsController;
	tmpID : String;
	lcs : CM_LCArray;
	subT : CM_SubTerminal;
	idx, numTI : Integer;

	gcLC : CM_ROROGCController;
	pxyDefn, gcDefn : CM_ROROGCDefnVoyage;
	realDefn : CM_DeckItem;
	gcCargo : CM_TrackedItem;
	gcLayer : CM_DeckLayerLayout;
	pxyItemLayout, realItemLayout : CM_DeckItemLayout;
	defnColour : Integer;
begin
	gcDefn := _gcDefn;
		gcLayer := _deck.myDeckLayout.getGCLayer(); // Gets or creates
	
	if gcDefn = null then
		// ### BASIC GRAPHIC for new GC Item - GC Defn and Layout
		pxyItemLayout := gcLayer.setProxyNewItemGC(false, true,_xMetres, _yMetres, _label, defnColour);
		pxyItemLayout.setMyDeckLayer(gcLayer);
		app.myTrxCA.trxCreateDeckItemLayout(pxyItemLayout, realItemLayout, gcLayer, app.myPassport); 
		
		create pxyDefn transient;
		pxyDefn.setProxy(_deck.myVoyageStructure, _label, null, null, realItemLayout, _deck, gcLayer, _xMetres, _yMetres);
		
		
		
		app.myTrxCA.trxCreateRORODeckItem(pxyDefn, realDefn, app.myPassport);
	endif;

		
	return app.myPassport.allErrorWarnings.isEmpty();

epilog
	delete pxyDefn;
	delete pxyItemLayout;	//19 Jun 2019	TFS 42876
end;</source>
        <Parameter name="_gcDefn" type="CM_ROROGCDefnVoyage"/>
        <Parameter name="_xMetres" type="Decimal"/>
        <Parameter name="_yMetres" type="Decimal"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_label" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="b8a5b078-562c-46f1-9ff2-4ed13d6f2720">
        <source>findLocation(_strs: StringArray; _noException : Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
//--------------------------------------------------
// Created:	03 April 2006 By: cnwgd1
//--------------------------------------------------
vars

	theDeck : CM_Deck;
	locnCode : String;
	len : Integer;
	laneDefn	: CM_ROROLaneDefn;
	roroLocnDefn : CM_ROROLocnDefnVoyage;
begin
	if _foundLC &lt;&gt; null or _strs.isEmpty() then
		return;
	endif;
	
	locnCode := _strs[1];
	foreach theDeck in self.allDecks discreteLock do
		// PAR 29375
		if theDeck.CM_DeckVoyage.allSlotDefnByCode[locnCode] &lt;&gt; null then
			_foundLC := theDeck.CM_DeckVoyage.allSlotDefnByCode[locnCode].CM_ROROSlotDefnVoyage.mySlotController;
			
		elseif self.allROROSlotDefnByCode[theDeck, locnCode] &lt;&gt; null then
			_foundLC := self.allROROSlotDefnByCode[theDeck, locnCode].CM_ROROSlotDefnVoyage.mySlotController;
		elseif self.allROROLocnDefnByCode[theDeck, locnCode] &lt;&gt; null then
			roroLocnDefn := self.allROROLocnDefnByCode[theDeck, locnCode].CM_ROROLocnDefnVoyage;
			_foundLC := roroLocnDefn.getNextFreeSlotController();
		elseif self.allROROGCDefnByCode[locnCode] &lt;&gt; null then
			_foundLC := self.allROROGCDefnByCode[locnCode].CM_ROROGCDefnVoyage.myGCController;
		// 29222 Mar 2012 use theDeck collection to get the LanePositionController where the cargo is
		//		check for CM_ROROLaneDefnVoyage just to be safe - both are in the collection
		elseif theDeck.allROROLaneDefnByCode[locnCode] &lt;&gt; null then
			laneDefn := theDeck.allROROLaneDefnByCode[locnCode];
			if laneDefn.isKindOf(CM_ROROLanePositionDefn) then
				_foundLC := laneDefn.CM_ROROLanePositionDefn.myLanePositionController;
			elseif laneDefn.isKindOf(CM_ROROLaneDefnVoyage) then
				_foundLC := laneDefn.CM_ROROLaneDefnVoyage.myLaneController;
			endif;
		elseif theDeck.code = locnCode then
			return;//cnwas3 createnewcargoform
		else
			foreach laneDefn in theDeck.allROROLaneDefnByCode  discreteLock do
				len := laneDefn.code.length;
				
				if len &lt;= locnCode.length 
				and laneDefn.code = locnCode[1:len] then
					if laneDefn.isKindOf(CM_ROROLaneDefnVoyage) then
						_foundLC := laneDefn.CM_ROROLaneDefnVoyage.myLaneController;
					endif;
				endif;
			endforeach;
		endif;
		if _foundLC &lt;&gt; null then
			return;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findLocnDefn" id="6bec1cc8-b0b3-4f0c-b017-dad75cc207f9">
        <source>findLocnDefn(_code : String) : CM_ROROLocnDefnVoyage;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2012	cnwer1	Initial creation CCMS MES 1033

*/

vars
	theDeck : CM_Deck;
	locnDefn : CM_ROROLocnDefnVoyage;
begin
	foreach theDeck in self.allDecks discreteLock do
		locnDefn:=self.allROROLocnDefnByCode[theDeck,_code].CM_ROROLocnDefnVoyage;
		if locnDefn &lt;&gt; null then
			return locnDefn;
		endif;
	
	endforeach;
	return null;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_ROROLocnDefnVoyage"/>
    </JadeMethod>
    <JadeMethod name="findSlotController" id="f0b1eb3c-df2f-4de0-8ef0-40f2980820ed">
        <source>findSlotController(_locnDefnCode :  String; slotHeight : Integer) : CM_ROROSlotController;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2012	cnwer1	Initial creation CCMS MES 1033

*/

vars
	locnDefn : CM_ROROLocnDefnVoyage;
	slotDefn : CM_ROROSlotDefnVoyage;
begin
	locnDefn:= self.findLocnDefn(_locnDefnCode);
	if locnDefn  = null then
		return null;
	endif;
	
	if locnDefn &lt;&gt; null then
		slotDefn:=locnDefn.allROROSlotDefnByOrdinal[locnDefn.ordinal,slotHeight].CM_ROROSlotDefnVoyage;
		if slotDefn &lt;&gt; null then
			return slotDefn.mySlotController;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_locnDefnCode" type="String"/>
        <Parameter name="slotHeight" type="Integer"/>
        <ReturnType type="CM_ROROSlotController"/>
    </JadeMethod>
    <JadeMethod name="getAllUnLinkedRequests" id="21b534b0-7b8a-4872-a232-0ae25233fc0c">
        <updating/>
        <source>getAllUnLinkedRequests(_allRequests : CM_RequestArray input; _typeDischarge : Boolean;_moveType : Integer; _clear : Boolean) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	aDeck : CM_DeckVoyage;
	aSlot : CM_VoyageROROController;
	aRequest,linkRequest : CM_Request;
begin

	if _clear then
		_allRequests.clear;
	endif;
	
	foreach aDeck in self.allDecks do
		foreach aSlot in aDeck.allROROControllers do
			if _typeDischarge then
				aRequest := aSlot.myRORORequestDischarge;
			else
				aRequest := aSlot.myRORORequestLoad;
			endif;
			if aRequest = null then
				continue;
			endif;
			
			if aRequest.isBackEndRequest() then 
				continue;
			endif;
			
			// check if it is linked
			// 11/07/2013 cnwmh5 #31938 - rewritten
			if aRequest.getMoveType() = _moveType then
				linkRequest := aRequest.getDLRSOBRequestLink();
				if linkRequest =null then
					_allRequests.add(aRequest);
				endif;
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="_allRequests" type="CM_RequestArray" usage="input"/>
        <Parameter name="_typeDischarge" type="Boolean"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDeckFromCode" id="3d359cd3-cafa-4377-8fa0-fbc16d712cc6">
        <source>getDeckFromCode(_code : String) : CM_DeckVoyage;
/*
Purpose:			
Date		Who		Reason
19 January 2012	cnwab1	Initial creation
*/

vars
	aDeck,subDeck, theDeck : CM_Deck;
begin
	
	theDeck:= self.allDecksByCode[_code]; // Parent Decks

	
	if theDeck = null then 
		// sub Decks
		foreach aDeck in self.allDecksByCode  discreteLock do
			foreach subDeck in aDeck.CM_DeckVoyage.allSubDecks discreteLock do
				if subDeck.code = _code then
					return subDeck.CM_DeckVoyage;
				endif;
			endforeach;
		endforeach;
	endif;
	
	return theDeck.CM_DeckVoyage;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_DeckVoyage"/>
    </JadeMethod>
    <JadeMethod name="getDeckFromLocationString" id="84305bff-967a-457b-8296-5350978536d3">
        <source>getDeckFromLocationString(_locnString : String) : CM_Deck;
/*
Purpose:	CCMS 1009 28479		
Date		Who		Reason
25 October 2011	cnwab1	Initial creation
*/

vars
	allStateData : CM_StateDataDict;
	idx, len : Integer;
	theDeck : CM_Deck;	roroAutoGenerateStartEnd : Integer;
	roroDeckLabelPrefix,
	roroOOTLSuffix,
	roroRotatedLabel,
	roroSubDeckLabelPrefix	:String;
	roroLocationNumberLength	: Integer;
	roroLocationCodeIsZeroFilled: String;
	newOrd : Integer;
	tmpVessel : CM_Vessel;
	newCode : String;
	deckStr : String;
begin


	if self.myVoyage &lt;&gt; null then
		tmpVessel := self.myVoyage.getMyVessel();
	endif;
	
	if tmpVessel  &lt;&gt; null then
		allStateData:= tmpVessel.allStateData;
		if allStateData = null or allStateData.size = 0 then
			allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
		endif;
	else
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;
	
	global.getExtraData(allStateData,RoRoDeckLabelPrefix,roroDeckLabelPrefix);
	global.getExtraData(allStateData,RoRoLocationNumberLength,roroLocationNumberLength);

	// Strip off Deck Prefix Letters
	if _locnString[1:roroDeckLabelPrefix.length()] = roroDeckLabelPrefix then
		deckStr := _locnString[roroDeckLabelPrefix.length() + 1:end];
	else
		deckStr := _locnString;
	endif;
	 
	len := deckStr.length();
	
	if len = 0 then 
		return null;
	endif;
	
	foreach idx in 1 to len do
		// PAR 28985 theDeck := self.allDecksByCode[deckStr[1:idx]];
		theDeck := self.getDeckFromCode(deckStr[1:idx]);
		if theDeck &lt;&gt; null then
			return theDeck;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_locnString" type="String"/>
        <ReturnType type="CM_Deck"/>
    </JadeMethod>
    <JadeMethod name="getDecksTotal" id="f17c9f47-d086-4068-86fa-5721007a7405">
        <source>getDecksTotal() : Integer;
/*
Date		    Who			Reason
19 September 2011	cnwas3	  Initial creation: returns the number of all the decks (including subdecks) for the current roro voyage structure.
*/

vars
	decksNo : Integer;
	deck 	: CM_DeckVoyage;
begin
	foreach deck in self.allDecks do
		decksNo := decksNo + 1;
		if not deck.allSubDecks.isEmpty() then
			decksNo := decksNo + deck.allSubDecks.size();
		endif;
	endforeach;
	return decksNo;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLocationIDFromLocationStr" id="22af5aae-5e69-4abb-80d7-5ec60308a4aa">
        <source>getLocationIDFromLocationStr(_locnStr : String) : String;

/*

Purpose:		Return the locationID without height or rotation excluding the height and rotation

Date			Who		Reason
14/03/2013		cnwmh5	Initial creation

*/

vars
	allStateData : CM_StateDataDict;
	idx, len : Integer;
	theDeck : CM_Deck;	roroAutoGenerateStartEnd : Integer;
	roroDeckLabelPrefix,
	roroOOTLSuffix,
	roroRotatedLabel,
	roroSubDeckLabelPrefix	:String;
	roroLocationNumberLength	: Integer;
	roroLocationCodeIsZeroFilled: String;
	newOrd : Integer;
	tmpVessel : CM_Vessel;
	newCode : String;
	deckStr : String;
	rotateLabel : String;
	ootlLabel : String;
	rtnLocnStr	: String;
	currentPos : String;
	deckLocPos : Integer;
begin


	if self.myVoyage &lt;&gt; null then
		tmpVessel := self.myVoyage.getMyVessel();
	endif;
	
	if tmpVessel  &lt;&gt; null then
		allStateData:= tmpVessel.allStateData;
		if allStateData = null or allStateData.size = 0 then
			allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
		endif;
	else
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;
	
	global.getExtraData(allStateData,RoRoDeckLabelPrefix,roroDeckLabelPrefix);
	global.getExtraData(allStateData,RoRoLocationNumberLength,roroLocationNumberLength);
	global.getExtraData(allStateData, RoRoRotatedLabel, rotateLabel);
	global.getExtraData(allStateData, RoRoOutOfTwistLockSuffix, ootlLabel);

	theDeck := self.getDeckFromLocationString(_locnStr);
	if theDeck = null then
		return null;
	endif;
	
	rtnLocnStr := _locnStr;
	
	deckLocPos := roroDeckLabelPrefix.length + theDeck.code.length + roroLocationNumberLength+1;
	if deckLocPos &lt;= _locnStr.length then
		if _locnStr[deckLocPos:1] = ootlLabel then
			rtnLocnStr := _locnStr[1:roroDeckLabelPrefix.length + theDeck.code.length + roroLocationNumberLength+1];
		endif;	
	endif;
	
	return rtnLocnStr;
	
epilog

end;</source>
        <Parameter name="_locnStr" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextQuickCargoID" id="f07ff1b2-d9b7-447d-8833-5805994d9575">
        <source>getNextQuickCargoID(_cargoType : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     05 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 05 Jun 2025 navma1 MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
// ---------------------------------------------------------------------------

vars
	nextID     : String;
	nextNum    : Integer;
	prefix     : String;
	cargoType  : CM_CargoType;
	voyage	   : CM_Voyage;
begin
	nextNum := 3112221;
	
	if _cargoType = TI_CargoType_Container then
		prefix := "RORO";
	else
		cargoType := app.myRoot.getCargoTypeForID(_cargoType);			//05.06.2025 navma1 #MTN-34114
		prefix := cargoType.abbreviation[1:4];
	endif;
	
	voyage := self.myVoyage;
	
	while true do
		nextID := prefix &amp; nextNum.String;
		if voyage.allOnshipTIsByIdCargoType[nextID,_cargoType] = null then
			if voyage.myTerminal.allOnsiteTIsByIdCargoType[nextID,_cargoType] = null then
				return nextID;
			endif;
		endif;
		nextNum := nextNum + 1;
	endwhile;
	
	return nextID;
epilog

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextSectionCode" id="cad0200c-cbe3-4c51-894a-7d7c020a01e6">
        <source>getNextSectionCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	idx : Integer;
begin

	idx := self.myVoyage.myStructuralElements.allSections.size;
	
	idx := idx + 1;
	
	return idx.padLeadingWith("0",2);

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPlanningGuideForDeck" id="6cf48a29-6ff3-494d-b2bb-2160ba20ed4c">
        <source>getPlanningGuideForDeck(_guide : CMIF_PlanningGuideBay input);
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	deckVoyage : CM_DeckVoyage;
begin

	if _guide = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'guide', null, null);
	endif;
	//---------------------
	//Clear the structure, it gets passed in multiple times (for each bay)
	//---------------------
	_guide.clear();
	_guide.is40Bay	:= false;
	//---------------------
	//Locate the requested bay
	//---------------------
	deckVoyage := _guide.myDeck;
	if deckVoyage = null then
		deckVoyage := self.allDecksByCode[_guide.id];
	endif;
	if deckVoyage = null then
		app.raiseCMException1(ERR_INVALID_BAY, _guide.id, null, null);
		return;
	endif;
	//--------------------
	//Ask the bay to give us its goodies
	//--------------------

	deckVoyage.getPlanningGuide(_guide);
end;</source>
        <Parameter name="_guide" type="CMIF_PlanningGuideBay" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSectionByPosition" id="473f7ef2-0c8b-4baf-b75c-6590b4002dbf">
        <source>getSectionByPosition(_pos: Decimal; _variance: Decimal): CM_VesselSection;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	return self.myVoyage.myCellularVoyageStructure.getSectionByPosition(_pos, _variance);

epilog

end;</source>
        <Parameter name="_pos" type="Decimal"/>
        <Parameter name="_variance" type="Decimal"/>
        <ReturnType type="CM_VesselSection"/>
    </JadeMethod>
    <JadeMethod name="getTotalColourCode" id="48a291cc-00ee-464a-a5ed-79aad78cb9f7">
        <source>getTotalColourCode(_getLoad : Boolean; _includeDLR : Boolean; _checkJob : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:		August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aDeck : CM_DeckVoyage;	
	tot : Integer;

begin
	
	foreach aDeck in self.allDecks do
	
		tot := tot + aDeck.getTotalColourCode(_getLoad, _includeDLR, _checkJob);
	endforeach;
	
	return tot;
epilog

end;</source>
        <Parameter name="_getLoad" type="Boolean"/>
        <Parameter name="_includeDLR" type="Boolean"/>
        <Parameter name="_checkJob" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalPlanned" id="b4a74739-3553-4076-855d-c01030a1efb8">
        <source>getTotalPlanned(_getLoad : Boolean; _includeDLR : Boolean) : Integer;
/*
Purpose:			
Date				Who			Reason
JANUARY 2015		CNWAB1		Initial creation
*/

vars
	aDeck : CM_DeckVoyage;	
	tot : Integer;

begin
	
	foreach aDeck in self.allDecks do
	
		tot := tot + aDeck.getTotalPlanned(_getLoad, _includeDLR);
	endforeach;
	
	return tot;
end;</source>
        <Parameter name="_getLoad" type="Boolean"/>
        <Parameter name="_includeDLR" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXMLGridSideProfile" id="bf4f2d2c-c6ea-468a-ba50-bb4b3336b16f">
        <source>getXMLGridSideProfile() : String;
// 34696 return a basic XML side profile like the corresponding CM_CellularVoyageStructure method
//	to handle voyages with just RORO structures
vars
	xml		: String;
begin
	
	xml := "&lt;GA&gt;&lt;GO&gt;0101&lt;/GO&gt;&lt;lb&gt;Profile&lt;/lb&gt;&lt;TR&gt;0&lt;/TR&gt;&lt;TC&gt;0&lt;/TC&gt;&lt;AB&gt;0&lt;/AB&gt;&lt;/GA&gt;"; 
	return xml;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasLoadCC" id="a872c2ca-0c9f-46de-8f68-ac481ad1005a">
        <source>hasLoadCC() : Boolean;
/*
Purpose:			
Date		Who		Reason
23 July 2012	cnwab1	Initial creation
*/

vars
	aDeck : CM_DeckVoyage;
	loadCCLayer : CM_DeckLayerLayout;
	ootlLocn : CM_ROROLaneDefn;
begin


	// COLOUR CODING
	if not self.myVoyage.allVoyageAllocations.isEmpty() then
		return true;
	endif;
	
	foreach aDeck in self.allDecks do
		loadCCLayer := aDeck.myDeckLayout.getCCLoadLayer();
		if not loadCCLayer.allDeckItemLayouts.isEmpty then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasOOWCreationGotJobs" id="7d71ceef-53b5-441a-bce7-bccd6f4db078">
        <source>hasOOWCreationGotJobs() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

	oowc : CM_OOWCreation;
begin
	foreach oowc in self.allOOWCreations do
		if not oowc.allJobs.isEmpty then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d6ae0a02-a8c5-46eb-b18c-543c3c5b0459">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	deck, pxyDeck : CM_DeckVoyage;
	pxyROROVoyageStructure : CM_ROROVoyageStructure;
	completedOK		: Boolean;
begin
	pxyROROVoyageStructure:= inheritMethod();

	foreach deck in self.allDecks do
		pxyDeck := deck.pxyCreateUpdateProxy();
		pxyDeck.setMyVoyageStructure(pxyROROVoyageStructure);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyROROVoyageStructure;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyROROVoyageStructure;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeAllLoadColourCoding" id="3f3cd632-b5ec-4990-bf82-b2ad62b6289f">
        <updating/>
        <source>removeAllLoadColourCoding() updating;
/*
Purpose:			
Date		Who		Reason
23 July 2012	cnwab1	Initial creation
*/

vars
	alloc : CM_YardAllocation;
	voyAllocation : CM_VoyageAllocation;
begin

	// COLOUR CODING
	foreach alloc in self.myVoyage.allVoyageAllocations  discreteLock do
		voyAllocation := alloc.CM_VoyageAllocation;
		
		// LOAD ONLY
		if not voyAllocation.isExportAllocation then
			continue;
		endif;
		
		// LOLO colour coding - note the allocation could be mixed lolo and roro, but the EDI Stowage RORO load DB will clear this up
		if not voyAllocation.allSlotRequests.isEmpty() then
			continue;
		endif;
		
		
		app.myPassport.setWarningsAcknowledged(true);
		app.myPassport.setWarningsIgnored(true);
		app.myUtilityDA.utlDeleteVoyageAllocation(voyAllocation, app.myPassport);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="removeAllLoadGC" id="6208046b-3dd3-4c11-a2d7-a4342b49e15c">
        <source>removeAllLoadGC();
/*
Purpose:			
Date		Who		Reason
23 July 2012	cnwab1	Initial creation
*/

vars
	aDeck : CM_DeckVoyage;
	loadCCLayer : CM_DeckLayerLayout;
	gcLocn : CM_ROROGCDefn;
begin

	
	foreach aDeck in self.allDecks do
		loadCCLayer := aDeck.myDeckLayout.getCCLoadLayer();
		if loadCCLayer = null then
			continue;
		endif;
		
		foreach gcLocn in loadCCLayer.allROROGCDefnByCode  discreteLock do
			if gcLocn.isOnLayerLoad() then // PAR 32732 - extra check, when we moved the GC Defn layout to the GC Layer, we were not moving the GC Defn itself to the GC Layer. NOw we are but this covers old GC Defns
				gcLocn.erase(NORMAL_ERASE);
			endif;
		endforeach;
		
	endforeach;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="removeAllLoadLane" id="aa594233-bced-4765-93a9-bd235903496c">
        <source>removeAllLoadLane();
/*
Purpose:			
Date		Who		Reason
23 July 2012	cnwab1	Initial creation
*/

vars
	aDeck : CM_DeckVoyage;
	loadCCLayer : CM_DeckLayerLayout;
	laneLocn : CM_ROROLaneDefn;
begin

	
	foreach aDeck in self.allDecks do
		loadCCLayer := aDeck.myDeckLayout.getCCLoadLayer();
		if loadCCLayer = null then
			continue;
		endif;
		
		foreach laneLocn in loadCCLayer.allROROLaneDefnByOrdinal  discreteLock do
			laneLocn.erase(NORMAL_ERASE);
		endforeach;
		
	endforeach;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="removeAllLoadOOTL" id="a4f700fe-9c9e-44a6-ba74-3b10fb00f2aa">
        <source>removeAllLoadOOTL();
/*
Purpose:			
Date		Who		Reason
23 July 2012	cnwab1	Initial creation
*/

vars
	aDeck : CM_DeckVoyage;
	loadCCLayer, cargoLayer : CM_DeckLayerLayout;
	ootlLocn, standardLocn : CM_ROROLocnDefn;
begin

	
	foreach aDeck in self.allDecks do
		loadCCLayer := aDeck.myDeckLayout.getCCLoadLayer();
		if loadCCLayer = null then
			continue;
		endif;
		
		
		// the only LocnDefn on the LOad CC should be OOTL LocnDefn
		foreach ootlLocn in loadCCLayer.allROROLocnDefnByOrdinal discreteLock  where ootlLocn.isOOTLLocn   do
			ootlLocn.erase(NORMAL_ERASE);
		endforeach;
		
	endforeach;
	

	// REMARKS can be updated from the EDI StowageAdvice so restore from vessel
	foreach aDeck in self.allDecks do
		cargoLayer := aDeck.myDeckLayout.getCargoLayer();
		if cargoLayer = null then
			continue;
		endif;
		
		foreach standardLocn in cargoLayer.allROROLocnDefnByOrdinal discreteLock do
			standardLocn.restoreRemarksFromVessel();
		endforeach;
		
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="removeAllLoadStowageAdvice" id="5f384d93-f408-4d6d-9912-420ea533abf9">
        <updating/>
        <source>removeAllLoadStowageAdvice() updating;
/*
Purpose:			
Date		Who		Reason
23 July 2012	cnwab1	Initial creation
*/

vars

begin
	// COLOUR CODING
	// PAR 32732 self.removeAllLoadColourCoding();	
	
	// OOTL LAYER
	self.removeAllLoadOOTL();
	
	// GC LAYER
	self.removeAllLoadGC();
	
	// Lanes
	self.removeAllLoadLane();
	
	// COLOUR CODING
	self.removeAllLoadColourCoding();	// PAR 32732 - this was the first item (above), but when this erased the LCs, the load GC LCs were erased in the RemoveAllGC code
	
	// UNROTATE LOAD CONTAINER POSITIONS
	self.unrotateAllLoadDefn();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="559cbd67-7a0e-4964-8683-cb6da217733b">
        <updating/>
        <source>setForCreate(_proxyVoyage: CM_VoyageStructure; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2011	cnwer1	Initial creation CCMS MES 1116
14/10/2011	cnwmh5	#28444 - remove setting of tanks and sections
*/

vars
	vessel : CM_Vessel;
	vesselDeck : CM_DeckVessel;
	roroVesselStructure :CM_ROROVesselStructure;
	cellularStructure : CM_CellularVesselStructure;
	extRamp : CM_RORORampExternalVessel;
	vesselSection : CM_VesselSectionVessel;
	vesselTank		: CM_VesselTankVessel;
	iter : Iterator;
begin
	inheritMethod(_proxyVoyage, _passport);

	vessel:=app.myRoot.allVessels[self.myVoyage.vesselCode];
	
	roroVesselStructure:=vessel.myROROVesselStructure;
	
	if roroVesselStructure = null then // PAR 27749
		return;
	endif;
	
	iter:=roroVesselStructure.allDecks.createIterator;
	while iter.next(vesselDeck) do
		vesselDeck.cloneMySelfForVoyage(self,false);
	endwhile;
	
	delete iter;
	
	//have to clone ext ramps
/*	iter:=roroVesselStructure.allRamps.createIterator;
	while iter.next(extRamp) do
		extRamp.cloneMySelfForVoyage(self,false);
	endwhile;
	*/
	delete iter;
	
	/*
	//have to clone sections
	cellularStructure:=vessel.myCellularVesselStructure;
	iter:=cellularStructure.allSections.createIterator;
	while iter.next(vesselSection) do
		vesselSection.cloneMySelfForVoyage(self.myVoyage.myCellularVoyageStructure,false);
	endwhile;
	
	delete iter;
	//have to clone tanks
	
	iter:=cellularStructure.allTanks.createIterator;
	while iter.next(vesselTank) do
		vesselTank.cloneMySelfForVoyage(self.myVoyage.myCellularVoyageStructure,false);
	endwhile;
	*/
	
epilog
	delete iter;
end;</source>
        <Parameter name="_proxyVoyage" type="CM_VoyageStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="204dac43-8a90-461a-a731-895e2a8c997e">
        <updating/>
        <source>setForUpdate(_proxyVoyage: CM_ROROVoyageStructure; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Mar 2011	cnwer1	Initial creation
27 Mar 2013	PJS		PAR #31232

*/

vars
	
begin
	inheritMethod(_proxyVoyage,_passport);
	
	//self.type:=CellularStructureRORO;	// 31232
	self.totalLengthWithRamp:=_proxyVoyage.totalLengthWithRamp;



epilog
	
end;</source>
        <Parameter name="_proxyVoyage" type="CM_ROROVoyageStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sortLoadCCByPortRotation" id="89a80577-119e-4b96-82fc-6a19422360ba">
        <source>sortLoadCCByPortRotation(_col : DynaDictionary input); //_col : CM_ROROReqByDeckXYZPortDict input);
/*
Purpose:			
Date		Who		Reason
04 August 2011	cnwab1	Initial creation
*/

vars
	alloc : CM_YardAllocation;
	voyAlloc : CM_VoyageAllocation;
	roroReq : CM_VoyageRequest;
	
	deckOrd, x1,y1,z1, portIndex : Integer;
begin

	
	foreach alloc in self.myVoyage.allVoyageAllocations discreteLock do
		voyAlloc := alloc.CM_VoyageAllocation;
		foreach roroReq in voyAlloc.allRequests discreteLock do
			if roroReq.isDischarge then
				continue;
			endif;
		//	roroReq.CM_RORORequest.getOrdinalsForPortRotationSort(deckOrd, x1,y1,z1, portIndex);
			_col.putAtKey(deckOrd, portIndex, x1,y1,z1, roroReq.CM_RORORequest);
		endforeach;
	
	endforeach;
	
	
epilog


end;</source>
        <Parameter name="_col" type="DynaDictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unrotateAllLoadDefn" id="51e82db4-6fad-4c7f-8a47-aacc85083e04">
        <source>unrotateAllLoadDefn();
/*
Purpose:			
Date		Who		Reason
23 July 2012	cnwab1	Initial creation
*/
//31 Jan 2013	cnwrs1	Par 31049	EDI remove of stawage advice can fail

vars
	aDeck : CM_DeckVoyage;
	rotatedLocn : CM_ROROLocnDefn;
	isLoad : Boolean;
begin

	
	foreach aDeck in self.allDecks do
		foreach rotatedLocn in aDeck.allROROLocnDefnByCode discreteLock do
			
			if not rotatedLocn.isRotationMaster() then
				continue;
			endif;
			if not rotatedLocn.isOnLayerLoad then
				continue;
			endif;
			// LOAD ROTATE
			if rotatedLocn.myRotateDischarge &lt;&gt; null then
				isLoad := true;
			// ACTUAL ROTATE
			elseif rotatedLocn.myRotateLoad &lt;&gt; null then
				isLoad := false;
			// BOTH ROTATE
			else
				isLoad := true;
			endif;
			
			if not isLoad then
				continue;
			endif;
			
			app.myUtilityUA.utlUpdateROROLocnDefnUnRotate(isLoad, false, rotatedLocn,app.myPassport); 
			
		endforeach;
	endforeach;
	
	
epilog

end;</source>
    </JadeMethod>
</Class>
