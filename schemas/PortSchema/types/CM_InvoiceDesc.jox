    <JadeMethod name="setProxy" id="f957f5b0-b278-496b-913c-339b235fd095">
        <updating/>
        <source>setProxy(_accrualType : Integer; _arrNarrationDesc : HugeStringArray; _description : String;
			_invoiceKey : Integer; _invoiceType : Integer; _myFinancialPeriodEnd : CM_FinancialPeriodEnd;
			_myInvTermsOfTrade : CM_InvoiceTermsOfTrade; 
			_print1LineDay : Boolean; _triggerOnAction : Integer;
			_invoiceGenerationDateFrom, _invoiceGenerationDateTo : Date; _invoiceGenerationStatus : Integer;
			_externalReference : String; _notAvailableForEntry : Boolean; _isApiInvType: Boolean; _isApiCreditNoteType: Boolean; _isAllowManualEditExtRef : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Date			Changed By		Reason
// 15/06/2023	navcs2			ChangeRequest 58434: [58452]: EUP | TAS Invoicing - Invoice Type Configuration
// ---------------------------------------------------------------------------

vars

begin
	self.accrualType := _accrualType;
	self.arrNarrationDesc.clear;
	_arrNarrationDesc.copy(self.arrNarrationDesc);
	self.description := _description;
	self.invoiceKey := _invoiceKey;
	self.invoiceType := _invoiceType;
	self.myFinancialPeriodEnd := _myFinancialPeriodEnd;
	self.myInvTermsOfTrade := _myInvTermsOfTrade;
	self.printSingleLineForDayType := _print1LineDay;
	self.triggerOnAction := _triggerOnAction;
	self.invoiceGenerationDateFrom	:= _invoiceGenerationDateFrom;
	self.invoiceGenerationDateTo	:= _invoiceGenerationDateTo;
	self.invoiceGenerationStatus	:= _invoiceGenerationStatus;
	self.externalReference := _externalReference;  //ccms 1970 par 25387
	self.isNotAvailableForEntry := _notAvailableForEntry;
	self.useForApiInv := _isApiInvType;			// 15.06.2023	navcs2	#58434:[58452]
	self.useForApiCn := _isApiCreditNoteType;	// 15.06.2023	navcs2	#58434:[58452]
	self.allowManualEditExternalRef := _isAllowManualEditExtRef; //08/12/2025	navkc1 JIRA 36262
end;</source>
        <Parameter name="_accrualType" type="Integer"/>
        <Parameter name="_arrNarrationDesc" type="HugeStringArray"/>
