    <JadeMethod name="doShiftChange" id="833fd45f-73ea-4af1-b6b0-c2bf94af4fd3">
        <source>doShiftChange();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwrd1	Initial creation
//22 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	shft : CM_Shift;
	shiftEndTS : TimeStamp;
begin


	shft := self.cmbShifts.listObject.CM_Shift;
	
	if shft &lt;&gt; null then
