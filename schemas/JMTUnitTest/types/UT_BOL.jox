    <JadeMethod name="bolInvoicingCleanup" id="35cba4b1-ccaf-4483-a8aa-2309ce2b651e">
        <source>bolInvoicingCleanup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin

	self.deleteInvoiceService(self.Service1, FORCED_ERASE);
	self.deleteInvoiceService(self.ServiceW, FORCED_ERASE);
	self.deleteInvoiceService(self.ServiceV, FORCED_ERASE);
	self.deleteInvoiceService(self.ServiceNI, FORCED_ERASE);

	self.deleteInvoiceLineType(self.InvLineType1, FORCED_ERASE);
	self.deleteInvoiceLineType(self.InvLineTypeW, FORCED_ERASE);
	self.deleteInvoiceLineType(self.InvLineTypeV, FORCED_ERASE);
	self.deleteInvoiceLineType(self.InvLineTypeNI, FORCED_ERASE);

	self.deleteInvoiceType(self.InvTypeBol);

	self.deleteCalculationType(self.CalcType1, NORMAL_ERASE);
	self.deleteCalculationType(self.CalcTypeW, NORMAL_ERASE);
	self.deleteCalculationType(self.CalcTypeV, NORMAL_ERASE);
	self.deleteCalculationType(self.CalcTypeNI, NORMAL_ERASE);
	
	self.deleteInvoiceTransactionMap(5, self.BOLTranMap);
	
	self.deleteVoyage(VoyageName1);
	self.deleteVessel(VesselName1);
	
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="bolInvoicingCreateVoyCargo" id="ed48122d-2756-4679-a4ab-ca2e09425755">
        <source>bolInvoicingCreateVoyCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2019	jlgndl1	Initial creation	TFS 47100
25/07/2022    navgm20     ChangeRequest 54095: EUP - Outturn Remarks on BOL
*/

vars

	oper : CM_Operator;
	term : CM_Terminal;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cargo : CM_TrackedItem;
	bol : CM_BOL;
	pxyBOL : CM_BOLIn;
	pxyBOLItem : CM_BOLDtl;
	subTerminal : CM_SubTerminal;
	index : Integer;
	cargoType : CM_CargoType;

begin

	
	oper := self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString);
	term := self.getTerminal;

	vessel := addVesselCellular(VesselName1, oper);
	self.assertTrueMsg( vessel &lt;&gt; null, "No Vessel created");
	voyage := addVoyageWithContainerStructur(VoyageName1, VesselName1, oper.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertTrueMsg( voyage &lt;&gt; null, "No Voyage created");
	
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	cargo := self.addContainerOnShip( BaseCargoId &amp; "01", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "03", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "05", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	cargo := self.addContainerOnShip( BaseCargoId &amp; "07", oper, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev('UTBYQ');
	self.assertTrueMsg( cargoType &lt;&gt; null, "Cargo Type 'UTBYQ' Not created during setup");
	self.opts.purge();
	self.opts.addAssoc('CargoType', cargoType.id );
	self.opts.addAssoc('TotalQuantity', '5'.Integer);
	self.opts.addAssoc('TotalWeight', '4000'.Decimal);
	cargo := self.addCargoForVoyage(voyage, BaseCargoId &amp; "02");
	cargo := self.addCargoForVoyage(voyage, BaseCargoId &amp; "06");
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev('UTBYV');
	self.assertTrueMsg( cargoType &lt;&gt; null, "Cargo Type 'UTBYV' Not created during setup");
	self.opts.purge();
	self.opts.addAssoc('CargoType', cargoType.id );
	self.opts.addAssoc('TotalWeight', '4000'.Decimal);
	self.opts.addAssoc('TotalVolume', '22'.Decimal);
	cargo := self.addCargoForVoyage(voyage, BaseCargoId &amp; "04");
	cargo := self.addCargoForVoyage(voyage, BaseCargoId &amp; "08");
	
	self.opts.purge();
	
	if app.isSubTerminalsOn(self.getTerminal) and not self.getTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		subTerminal := self.getSubTerminal(null);								// 29/04/2014 cnwmh5	
		self.assertNotNull(subTerminal);
	endif;
	
	create pxyBOL transient;	
	pxyBOL.setProxy(self.BOL1, voyage, oper, null, 5, BOLType_GeneralBillOfLading, term, subTerminal, null, null, null, false, null, null, null,
																																		null);	//13/07/2022 navgm20 Tfs 54095
	
	create pxyBOLItem transient;
	pxyBOLItem.setProxy(pxyBOL,	//_bol : CM_BOL; 
						TI_CargoType_Container,	//_cargoType : Integer; 
						"GENL",	//_commodity : String; 
						null,	//_colour : String; 
						null,	//_mark : String; 
						8,	//_numbItems : Integer;
						12.0,	//_volume : Decimal;
						12000.0,	//_weight : Decimal; 
						null,	//_length : Decimal; 
						null,	//_width: Decimal; 
						null,	//_height : Decimal; 
						Consignor1,	//_consignor : String; 
						Consignee1,	//_consignee : String; 
						null	//_remarks : String
						);
	pxyBOL.allBOLDtls.add(pxyBOLItem);
	
	app.myTrxCA.trxCreateBOL(pxyBOL, bol, null, app.myPassport);
	self.assertTrueMsg( bol &lt;&gt; null, self.BOL1 &amp; " BOL Not created during setup - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	foreach index in 1 to 8 do
		cargo := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null );
		self.assertTrueMsg( cargo &lt;&gt; null and cargo.id = BaseCargoId &amp; "0" &amp; index.String, BaseCargoId &amp; "0" &amp; index.String &amp; " Cargo Item not found during setup of intitial BOL" );
		beginTransaction;
		cargo.setMyReceivalBOL( bol.CM_BOLIn );
		commitTransaction;
	endforeach;
	
	self.assertTrueMsg(bol.allBOLTransactions.isEmpty, self.BOL1 &amp; " should not have any Transactions set during set up");
	
epilog

	delete pxyBOL;

end;</source>
    </JadeMethod>
    <JadeMethod name="bolInvoicingSetup" id="544b6efe-0d95-4181-aff2-a3726926b798">
        <source>bolInvoicingSetup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2019	jlgndl1	Initial creation	TFS 47100
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type

*/

vars

	calcType1 : CM_CalculationType;
	calcTypeW : CM_CalculationType;
	calcTypeV : CM_CalculationType;
	calcTypeNI : CM_CalculationType;
	
	invType : CM_InvoiceDesc;
	
	service1 : CM_Service;
	serviceW : CM_Service;
	serviceV : CM_Service;
	serviceNI : CM_Service;
	
	services : CM_ServiceByNameDict;
	
	invLineType1 : CM_InvoiceLineDesc;
	invLineTypeW : CM_InvoiceLineDesc;
	invLineTypeV : CM_InvoiceLineDesc;
	invLineTypeNI : CM_InvoiceLineDesc;
	
	debtor : CM_DebtorNode;
	fileContent : String;
	fileName : String;
	bank : CM_Bank;
	bolMap : CM_TranMapBOL;

begin

	// create Calculation Types for BOL test 
	calcType1 := self.addCalculationTypeFull(INV_CALC_TYPE_BOL_VALUEOF1, self.CalcType1, 'UNIT TEST BOL Value of 1', null, null, null, 0, 0, 0, 0, false, false, false, true, 0, null, null, null, null);
	calcTypeW := self.addCalculationTypeFull(INV_CALC_TYPE_BOL_WEIGHT, self.CalcTypeW, 'UNIT TEST BOL Total Weight', null, null, null, 0, 0, 0, 0, false, false, false, true, 0, null, null, null, null);
	calcTypeV := self.addCalculationTypeFull(INV_CALC_TYPE_BOL_VOLUME, self.CalcTypeV, 'UNIT TEST BOL Total Volume', null, null, null, 0, 0, 0, 0, false, false, false, true, 0, null, null, null, null);
	calcTypeNI := self.addCalculationTypeFull(INV_CALC_TYPE_BOL_NUMITEMS, self.CalcTypeNI, 'UNIT TEST BOL Total Num Items', null, null, null, 0, 0, 0, 0, false, false, false, true, 0, null, null, null, null);
	
	self.assertTrueMsg( calcType1 &lt;&gt; null, self.CalcType1 &amp; " BOL Calculation Type Not created during setup" );
	self.assertTrueMsg( calcTypeW &lt;&gt; null, self.CalcTypeW &amp; " BOL Calculation Type Not created during setup" );
	self.assertTrueMsg( calcTypeV &lt;&gt; null, self.CalcTypeV &amp; " BOL Calculation Type Not created during setup" );
	self.assertTrueMsg( calcTypeNI &lt;&gt; null, self.CalcTypeNI &amp; " BOL Calculation Type Not created during setup" );
	
	// create Invoice Type for BOL Test
	invType := self.createInvoiceTypeFull(	CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											self.InvTypeBol,
											CM_InvoiceDesc.Key_BOL,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											0,
											null,
											null,
											0,
											"");
	self.assertTrueMsg( invType &lt;&gt; null, self.InvTypeBol &amp; " Invoice Type Not created during setup" );
	
	// create Services for BOL Test	
	service1 := self.createInvoiceService(self.Service1, "Unit Test Service Single Value", calcType1, null);
	serviceW := self.createInvoiceService(self.ServiceW, "Unit Test Service Weight", calcTypeW, null);
	serviceV := self.createInvoiceService(self.ServiceV, "Unit Test Service Volume", calcTypeV, null);
	serviceNI := self.createInvoiceService(self.ServiceNI, "Unit Test Service Items", calcTypeNI, null);
	
	self.assertTrueMsg( service1 &lt;&gt; null, self.Service1 &amp; " BOL Service Not created during setup" );
	self.assertTrueMsg( serviceW &lt;&gt; null, self.ServiceW &amp; " BOL Service Not created during setup" );
	self.assertTrueMsg( serviceV &lt;&gt; null, self.ServiceV &amp; " BOL Service Not created during setup" );
	self.assertTrueMsg( serviceNI &lt;&gt; null, self.ServiceNI &amp; " BOL Service Not created during setup" );
	
	// create Invoice Line Types for BOL Test	
	// SDT11 = BOL Operator, SDT12 = BOL Consignee, SDT13 = BOL Consignor, SDT14 = BOL Voyage Operator
	create services transient;
	services.clear;
	services.add(service1);
	invLineType1 := self.createInvoiceLineType( self.InvLineType1, calcType1, invType, services, "SDT11");
	services.clear;
	services.add(serviceW);
	invLineTypeW := self.createInvoiceLineType( self.InvLineTypeW, calcTypeW, invType, services, "SDT11"); 
	services.clear;
	services.add(serviceV);
	invLineTypeV := self.createInvoiceLineType( self.InvLineTypeV, calcTypeV, invType, services, "SDT11");
	services.clear;
	services.add(serviceNI);
	invLineTypeNI := self.createInvoiceLineType( self.InvLineTypeNI, calcTypeNI, invType, services, "SDT11"); 
	
	
	// create Rates for BOL Test
	
	beginTransaction;
	delete service1.debtorNodeRates.first.rateEntries.first;
	delete serviceW.debtorNodeRates.first.rateEntries.first;
	delete serviceV.debtorNodeRates.first.rateEntries.first;
	delete serviceNI.debtorNodeRates.first.rateEntries.first;
	commitTransaction;
	
	debtor := CM_RootDebtorGroup.firstInstance;
	self.setServiceRate(service1, debtor, "02/01/2019".Date, 1.00);
	self.setServiceRate(serviceW, debtor, "02/01/2019".Date, 1.25);
	self.setServiceRate(serviceV, debtor, "02/01/2019".Date, 1.33);
	self.setServiceRate(serviceNI, debtor, "02/01/2019".Date, 1.07);
	
	// create 'Bill Of Lading' Transaction Map
	fileName := "BOLMap";
	
	fileContent :=	'TranMap Type,TranMap Name,BOL Trx,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line' &amp; CrLf &amp;
					'Bill Of Lading,'&amp;self.BOLTranMap&amp;',219| BOL Consignee Changed,A1:SDT12,(Default) ›,(Default),All,UT BOL Inv Line Type Weight' &amp; CrLf &amp;
					'Bill Of Lading,'&amp;self.BOLTranMap&amp;',219|BOL Consignee Changed,(Default),(Default) ›,(Default),All,UT BOL Inv Line Type Num Items' &amp; CrLf &amp;
					'Bill Of Lading,'&amp;self.BOLTranMap&amp;',220|BOL Consignor Changed,(Default),(Default) ›,(Default),All,UT BOL Inv Line Type Weight' &amp; CrLf &amp;
					'Bill Of Lading,'&amp;self.BOLTranMap&amp;',221|BOL Operator Changed,(Default),(Default) ›,(Default),All,UT BOL Inv Line Type Volume' &amp; CrLf &amp;
					'Bill Of Lading,'&amp;self.BOLTranMap&amp;',218|BOL Transferred,(Default),(Default) ›,(Default),All,UT BOL Inv Line Type Value of 1' &amp; CrLf &amp;
					'Bill Of Lading,'&amp;self.BOLTranMap&amp;',(Default),(Default),(Default) ›,(Default),All,UT BOL Inv Line Type Value of 1';
					
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := self.getTerminal.getDefaultCompanyBank();
	bolMap := bank.allBOLTranMaps[self.BOLTranMap];
	self.assertNotNullMsg(bolMap,"'Bill Of Lading' transaction map should not be null during setup");
	
	app.myTrxUA.trxUpdateBankTMBOLActive( bolMap, app.myPassport );
	
	self.assertTrueMsg( bank.myCurrentTranMapBOL = bolMap, "BOL Map '" &amp; self.BOLTranMap &amp; "' Not made 'active' during setup - " &amp; app.myPassport.getErrorsAndWarningsAsString );


epilog

	delete services;

end;</source>
    </JadeMethod>
    <JadeMethod name="tBOLInvoicing" id="dc0a055d-91c8-400f-becd-3341ecdb00dd">
        <source>tBOLInvoicing();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2019	jlgndl1	Initial creation	TFS 47100
25/07/2022    navgm20     ChangeRequest 54095: EUP - Outturn Remarks on BOL
*/

vars

	oper : CM_Operator;
	term : CM_Terminal;
	voyage : CM_Voyage;
	contextObject : Object;
	pxyBOL : CM_BOLIn;
	bol1 : CM_BOL;
	bol2 : CM_BOL;
	bolTrx : CM_BOLTransaction;
	invLine : CM_InvoiceLine;
	consignee1 : CM_ConsigneeConsignor;
	consignor1 : CM_ConsigneeConsignor;
	tis : CM_TIArray;
	ti : CM_TrackedItem;
	index : Integer;
	cargoToSplit : CM_Cargo;
	load : Boolean;
	pxyBolDtl : CM_BOLDtl;
	oper2 : CM_Operator;
	tiTrx : CM_TITransaction;
	bolDtl1 : CM_BOLDtl;
	bank : CM_Bank;
	qDef : CM_QueryDefinition;
	myEnqController : CM_EnqControllerBOLTrans;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	criteriaLine : CM_SelectorCriteriaLine;
	user : CM_User;
	startOfTest : TimeStamp;
	querySize : Integer;
	dateArray : DateArray;
	dr : CM_Debtor;

begin

	startOfTest := app.actualTimeServer();
	oper := self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString);
	term := self.getTerminal;
	consignee1 := app.myRoot.allConsigneeConsignors[Consignee1];
	consignor1 := app.myRoot.allConsigneeConsignors[Consignor1];
	oper2 := app.myRoot.allOperators.getAtKey("UTO2");

	//delete anything left over from last time
	self.bolInvoicingCleanup();
	
	// create Calculation Types, Services, Invoice Line Types, Rates and 'Bill Of Lading' Transaction Map, then activate it
	self.bolInvoicingSetup();
	
	// create a Voyage and a BOL with a BOL Detail Object, and add some cargo to the BOL
	self.bolInvoicingCreateVoyCargo();
	
	//TRANS_TYPE_BOLCREATED
	// Create a second BOL. (simulate that it was done on the form by setting the context object so we get the new transactions )
	contextObject := self;
	voyage := self.getVoyage( VoyageName1 );	
	bol1 := voyage.allBOLInByTypeStatusNumDT.first;
		
	create pxyBOL transient;	
	pxyBOL.setProxy(self.BOL2, voyage, oper, null, 5, BOLType_GeneralBillOfLading, term, bol1.mySubTerminal, null, null, null, false, null, null, null,
																																				null);	//13/07/2022 navgm20 Tfs 54095
	app.myTrxCA.trxCreateBOL( pxyBOL, bol2, contextObject, app.myPassport );
	delete pxyBOL;
	
	self.assertTrueMsg( bol2 &lt;&gt; null, self.BOL2 &amp; " BOL not created - Test 1 " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( bol2.allBOLTransactions.size = 1, self.BOL2 &amp; " BOL should have 1 transaction - Test 1" );
	bolTrx := bol2.allBOLTransactions.first; 
	self.assertTrueMsg( bolTrx &lt;&gt; null and bolTrx.type = TRANS_TYPE_BOLCREATED, self.BOL2 &amp; " BOL should have 1 BOL Created transaction - Test 1" );
	invLine := bolTrx.allInvoiceLines.first;
	self.assertTrueMsg( invLine &lt;&gt; null, self.BOL2 &amp; " BOL Created transaction should be invoiced - Test 1" );
	self.assertTrueMsg( invLine.lineTotal = 1, self.BOL2 &amp; " BOL Created transaction invoice line charges s/be $1.00 - Test 1" );
	
	//TRANS_TYPE_BOL_CARGO_TFR - one per group
	//TRANS_TYPE_BOL_TRANSFER - one per item
	//TI trans - TRANS_TYPE_BOL_CARGO_TFR
	// Transfer half the cargo from BOL1 to BOL2
	create tis transient;
	foreach index in 5 to 8 do
		ti := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq( BaseCargoId &amp; "0" &amp; index.String, null );
		self.assertTrueMsg( ti &lt;&gt; null and ti.id = BaseCargoId &amp; "0" &amp; index.String, BaseCargoId &amp; "0" &amp; index.String &amp; " Cargo Item not found during setup of set for move to BOL pre Test 2" );
		tis.add( ti );
	endforeach;
	cargoToSplit := null;
	app.myTrxUA.trxTransferToBOL(	bol2.CM_BOLIn,	//_newBol : CM_BOLIn;
									oper,	//_newOperator : CM_Operator;
									consignee1,	//_newConsignee : CM_ConsigneeConsignor
									tis,	//_tis : CM_TIArray;
									cargoToSplit,	//_tiToSplit : CM_Cargo 10;
									null,	//_newId : String;
									null,	//_splitWeight : Decimal;
									null,	//_splitQuantity : Integer;
									app.myPassport	//_passport : CM_Passport input
									);
									
	//check the transactions on the original BOL								
	self.assertTrueMsg( bol1.allBOLTransactions.size = 5, self.BOL1 &amp; " BOL should have 5 transaction - Test 2" );	// 4 x TRANS_TYPE_BOL_TRANSFER and 1 x TRANS_TYPE_BOL_CARGO_TFR
	bolTrx := bol1.allBOLTransactions.geBolTransOfType( TRANS_TYPE_BOL_TRANSFER, false );
	self.assertTrueMsg( bolTrx &lt;&gt; null and bolTrx.isKindOf( CM_BOLTransferTransaction ), self.BOL1 &amp; " has no 'BOL Transfer' transactions - Test 2" );
	self.assertTrueMsg( bolTrx.CM_BOLTransferTransaction.toBolNumber = self.BOL2, self.BOL1 &amp; " 'BOL Transfer' transaction (transfer) going the wrong way. - Test 2" );
	bolTrx := bol1.allBOLTransactions.geBolTransOfType( TRANS_TYPE_BOL_TFRD, false );
	self.assertTrueMsg( bolTrx &lt;&gt; null and bolTrx.isKindOf( CM_BOLTransferred ), self.BOL1 &amp; " has no 'BOL Transferred' transaction - Test 2" );
	self.assertTrueMsg( bolTrx = bol1.allBOLTransactions.geBolTransOfType( TRANS_TYPE_BOL_TFRD, true ), self.BOL1 &amp; " should have just one 'BOL Transferred' transaction - Test 2" );  // i.e first and last of this type are the same trx
	self.assertTrueMsg( bolTrx.CM_BOLTransferred.weightOfCargoTransferred = 16000, self.BOL1 &amp; " 'BOL Transferred' weight s/be 16000. - Test 2" );
	self.assertTrueMsg( bolTrx.CM_BOLTransferred.numberOfCargoTransferred = 4, self.BOL1 &amp; " 'BOL Transferred' num transferred s/be 4. - Test 2" );
	
	//check the transactions on the new BOL
	self.assertTrueMsg( bol2.allBOLTransactions.size = 5, self.BOL2 &amp; " BOL should have 5 transaction - Test 2a" );	// the original TRANS_TYPE_BOLCREATED AND BOL 4 x TRANS_TYPE_BOL_TRANSFER
	bolTrx := bol2.allBOLTransactions.geBolTransOfType( TRANS_TYPE_BOL_TRANSFER, false );
	self.assertTrueMsg( bolTrx &lt;&gt; null and bolTrx.isKindOf( CM_BOLTransferTransaction ), self.BOL2 &amp; " has no 'BOL Transfer' transactions - Test 2a" );
	self.assertTrueMsg( bolTrx &lt;&gt; bol2.allBOLTransactions.geBolTransOfType( TRANS_TYPE_BOL_TRANSFER, true ), self.BOL2 &amp; " should have multiple 'BOL Transfer' transactions - Test 2a" );  // i.e first and last of this trx typeare the different
	
	//check the new transactions on the transferred cargo
	foreach ti in tis do
		tiTrx := ti.getTransactionOfType( TRANS_TYPE_BOL_CARGO_TFR );
		self.assertTrueMsg( tiTrx &lt;&gt; null and tiTrx.isKindOf( CM_BOLCargoTransferred ), ti.id &amp; " Cargo Item has no 'BOL Cargo Transferred' transaction - Test 2b" );
	endforeach;
	
	//TRANS_TYPE_BOL_CONSEE
	//Change the Consignee on the BOL Detail
	app.cmsBeginLoad(load);
	pxyBOL := bol1.pxyCreateUpdateProxy().CM_BOLIn;
	app.cmsEndLoad(load);
	pxyBolDtl := pxyBOL.allBOLDtls.first();
	pxyBolDtl.setConsignee( consignor1.code );
	app.myTrxUA.trxUpdateBOL( pxyBOL, true, contextObject, app.myPassport );
	self.assertTrueMsg( bol1.allBOLDtls.first.consigneeCode = consignor1.code, self.BOL1 &amp; " BOL, Bol Detail consignee s/be " &amp; consignor1.code &amp; " - Test 3. " &amp; app.myPassport.getErrorsAndWarningsAsString );	
	bolTrx := bol1.allBOLTransactions.geBolTransOfType( TRANS_TYPE_BOL_CONSEE, false );
	self.assertTrueMsg( bolTrx &lt;&gt; null and bolTrx.isKindOf( CM_BOLConsigneeChanged ), self.BOL1 &amp; " has no 'BOL Consignee Changed' transaction - Test 3" );
	self.assertTrueMsg( bolTrx.CM_BOLConsigneeChanged.previousConsigneeCode = consignee1.code, self.BOL1 &amp; " 'BOL Consignee Changed' transaction has wrong previousConsigneeCode - Test 3" );
	self.assertTrueMsg( bolTrx.CM_BOLConsigneeChanged.newConsigneeCode = consignor1.code, self.BOL1 &amp; " 'BOL Consignee Changed' transaction has wrong newConsigneeCode - Test 3" );
	invLine := bolTrx.allInvoiceLines.first();
	self.assertTrueMsg( invLine &lt;&gt; null and invLine.lineTotal = 8.56, self.BOL1 &amp; " 'BOL Consignee Changed' transaction invoice line missing or wrong value - Test 3" );
	delete pxyBOL;
	
	//TRANS_TYPE_BOL_CONSOR
	//Change the Consignor on the BOL Detail
	app.cmsBeginLoad(load);
	pxyBOL := bol1.pxyCreateUpdateProxy().CM_BOLIn;
	app.cmsEndLoad(load);
	pxyBolDtl := pxyBOL.allBOLDtls.first();
	pxyBolDtl.setConsignor( consignee1.code );
	app.myTrxUA.trxUpdateBOL( pxyBOL, true, contextObject, app.myPassport );
	self.assertTrueMsg( bol1.allBOLDtls.first.consignorCode = consignee1.code, self.BOL1 &amp; " BOL, Bol Detail consignor s/be " &amp; consignee1.code &amp; " - Test 4. " &amp; app.myPassport.getErrorsAndWarningsAsString );	
	bolTrx := bol1.allBOLTransactions.geBolTransOfType( TRANS_TYPE_BOL_CONSOR, false );
	self.assertTrueMsg( bolTrx &lt;&gt; null and bolTrx.isKindOf( CM_BOLConsignorChanged ), self.BOL1 &amp; " has no 'BOL Consignor Changed' transaction - Test 4" );
	self.assertTrueMsg( bolTrx.CM_BOLConsignorChanged.previousConsignorCode = consignor1.code, self.BOL1 &amp; " 'BOL Consignor Changed' transaction has wrong previousConsignorCode - Test 4" );
	self.assertTrueMsg( bolTrx.CM_BOLConsignorChanged.newConsignorCode = consignee1.code, self.BOL1 &amp; " 'BOL Consignor Changed' transaction has wrong newConsignorCode - Test 4" );
	invLine := bolTrx.allInvoiceLines.first();
	self.assertTrueMsg( invLine &lt;&gt; null and invLine.lineTotal = 15000, self.BOL1 &amp; " 'BOL Consignor Changed' transaction invoice line missing or wrong value - Test 4" );
	delete pxyBOL;
	
	//TRANS_TYPE_BOL_OPER
	//Change the Operator on the BOL
	app.cmsBeginLoad(load);
	pxyBOL := bol1.pxyCreateUpdateProxy().CM_BOLIn;
	app.cmsEndLoad(load);
	pxyBOL.setPropertyValue( CM_BOL::myOperator.name, oper2 );
	app.myTrxUA.trxUpdateBOL( pxyBOL, true, contextObject, app.myPassport );
	self.assertTrueMsg( bol1.myOperator = oper2, self.BOL1 &amp; " BOL, myOperator s/be " &amp; oper2.code &amp; " - Test 5. " &amp; app.myPassport.getErrorsAndWarningsAsString );	
	bolTrx := bol1.allBOLTransactions.geBolTransOfType( TRANS_TYPE_BOL_OPER, false );
	self.assertTrueMsg( bolTrx &lt;&gt; null and bolTrx.isKindOf( CM_BOLOperatorChanged ), self.BOL1 &amp; " has no 'BOL Operator Changed' transaction - Test 5" );
	self.assertTrueMsg( bolTrx.CM_BOLOperatorChanged.previousOperatorCode = oper.code, self.BOL1 &amp; " 'BOL Operator Changed' transaction has wrong previousOperatorCode - Test 5" );
	self.assertTrueMsg( bolTrx.CM_BOLOperatorChanged.newOperatorCode = oper2.code, self.BOL1 &amp; " 'BOL Operator Changed' transaction has wrong newOperatorCode - Test 5" );
	invLine := bolTrx.allInvoiceLines.first();
	self.assertTrueMsg( invLine &lt;&gt; null and invLine.lineTotal = 15.96, self.BOL1 &amp; " 'BOL Operator Changed' transaction invoice line missing or wrong value - Test 5" );
	delete pxyBOL;
	
	//change the volume value on the BOL Detaill and resync the Invoice Line for Operator (For this tran map, the qty for this line type is derived from volume of all of the BOL Details)
	bank := invLine.getBank();
	bolDtl1 := bol1.allBOLDtls.first();
	beginTransaction;
	bolDtl1.setPropertyValue( CM_BOLDtl::volume.name, '6.0'.Decimal );
	bank.createChargeBOLResync( bolTrx );
	commitTransaction;
	invLine := bolTrx.allInvoiceLines.first();
	self.assertTrueMsg( invLine &lt;&gt; null and invLine.lineTotal = 7.98, self.BOL1 &amp; " 'BOL Operator Changed' transaction invoice line missing or wrong value after a re-sync - Test 5" );
	
	
	// Perform a 'BOL Transaction' Selector Query and check the results 
	create myEnqController;
	create myEnqController.allObjects as  CM_TransactionSet transient;
	create criteriaHolder transient;
	user := app.getMyUser();
	qDef := app.myRoot.allQueryDefinitionObjects[ CM_QueryDefinition.Transaction_Query_Type, CM_QueryDefinition.BOLTransaction_Query_Mode ];
	myEnqController.myTerminal := term;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	//this terminal only
	criteriaLine := qDef.createCriteriaLine(CM_BOLTransaction::myTerminal.name, CM_QueryOperator.Operator_Equal, term);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	//since the start of the test
	create dateArray transient;
	dateArray.add(startOfTest.Date);
	myEnqController.startDateTime.setTime(startOfTest.Time);
	dateArray.add(startOfTest.Date + 1);
	myEnqController.endDateTime.setTime('23:59:59:999'.Time);
	criteriaLine := qDef.createCriteriaLine(CM_BOLTransaction::dateTime.name, CM_QueryOperator.Operator_Between, dateArray);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	// special code so we don't clear the time in the query.
	myEnqController.myContext := self;
	myEnqController.startDateTime.setTime(startOfTest.Time);
	
	myEnqController.doQuery( qDef );
	
	querySize := myEnqController.allObjects.CM_TransactionSet.size;
	self.assertTrueMsg( querySize = 13, "Wrong number of BOL Transactions found in the query.  Expected 13 got " &amp; querySize.String &amp; "- Test 6" );
	
	//Now test 29 Nov 2019 changes
	
	dr := app.myRoot.myRootCompany.debtors["A1"].CM_Debtor;
	beginTransaction;
	consignee1.setDebtor(dr);
	consignor1.setDebtor(dr);
	commitTransaction;
	
	//TRANS_TYPE_BOL_CONSEE
	//Change the Consignee on the BOL Detail with a separately configured debtor matching a different mapping line
	app.cmsBeginLoad(load);
	pxyBOL := bol1.pxyCreateUpdateProxy().CM_BOLIn;
	app.cmsEndLoad(load);
	pxyBolDtl := pxyBOL.allBOLDtls.first();
	pxyBolDtl.setConsignee( consignee1.code );
	app.myTrxUA.trxUpdateBOL( pxyBOL, true, contextObject, app.myPassport );
	self.assertTrueMsg( bol1.allBOLDtls.first.consigneeCode = consignee1.code, self.BOL1 &amp; " BOL, Bol Detail consignee s/be " &amp; consignee1.code &amp; " - Test 7. " &amp; app.myPassport.getErrorsAndWarningsAsString );	
	bolTrx := bol1.allBOLTransactions.geBolTransOfType( TRANS_TYPE_BOL_CONSEE, true );
	self.assertTrueMsg( bolTrx &lt;&gt; null and bolTrx.isKindOf( CM_BOLConsigneeChanged ), self.BOL1 &amp; " has no 'BOL Consignee Changed' transaction - Test 7" );
	invLine := bolTrx.allInvoiceLines.first();
	self.assertTrueMsg( invLine &lt;&gt; null and invLine.lineTotal = 15000, self.BOL1 &amp; " 'BOL Consignee Changed' transaction invoice line missing or wrong value - Test 7" );
	delete pxyBOL;
		
	
	//success, delete it all
	self.bolInvoicingCleanup();

epilog

	self.resetDefaultTranMap();
	
	beginTransaction;
	consignee1.setDebtor(null);
	consignor1.setDebtor(null);
	commitTransaction;

	delete pxyBOL;
	delete tis;
	delete dateArray;
	delete criteriaHolder;
	delete myEnqController;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tBOLInvoicingQueryByBOL" id="2615ba43-b6e7-44d9-b6ba-434b0d5da87b">
        <source>tBOLInvoicingQueryByBOL();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May  2025 navrv30 MTN 34789 MTN | Query by BOL option doesn't return results for BOL-generated invoices

*/

vars

	oper : CM_Operator;
	term : CM_Terminal;
	voyage : CM_Voyage;
	contextObject : Object;
	pxyBOL : CM_BOLIn;
	bol1 : CM_BOL;
	bol2 : CM_BOL;
	bolTrx : CM_BOLTransaction;
	invLine : CM_InvoiceLine;
	consignee1 : CM_ConsigneeConsignor;
	consignor1 : CM_ConsigneeConsignor;
	tis : CM_TIArray;
	oper2 : CM_Operator;
	bank : CM_Bank;
	qDef : CM_QueryDefinition;
	myEnqController : CM_EnqControllerInvoice;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	criteriaLine : CM_SelectorCriteriaLine;
	user : CM_User;
	startOfTest : TimeStamp;
	querySize : Integer;
	dateArray : DateArray;
begin

	startOfTest := app.actualTimeServer();
	oper := self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString);
	term := self.getTerminal;
	consignee1 := app.myRoot.allConsigneeConsignors[Consignee1];
	consignor1 := app.myRoot.allConsigneeConsignors[Consignor1];
	oper2 := app.myRoot.allOperators.getAtKey("UTO2");

	//delete anything left over from last time
	self.bolInvoicingCleanup();
	
	// create Calculation Types, Services, Invoice Line Types, Rates and 'Bill Of Lading' Transaction Map, then activate it
	self.bolInvoicingSetup();
	
	// create a Voyage and a BOL with a BOL Detail Object, and add some cargo to the BOL
	self.bolInvoicingCreateVoyCargo();
	
	//TRANS_TYPE_BOLCREATED
	// Create a second BOL. (simulate that it was done on the form by setting the context object so we get the new transactions )
	contextObject := self;
	voyage := self.getVoyage( VoyageName1 );	
	bol1 := voyage.allBOLInByTypeStatusNumDT.first;
		
	create pxyBOL transient;	
	pxyBOL.setProxy(self.BOL2, voyage, oper, null, 5, BOLType_GeneralBillOfLading, term, bol1.mySubTerminal, null, null, null, false, null, null, null,
																																				null);	//13/07/2022 navgm20 Tfs 54095
	app.myTrxCA.trxCreateBOL( pxyBOL, bol2, contextObject, app.myPassport );
	delete pxyBOL;
	
	self.assertTrueMsg( bol2 &lt;&gt; null, self.BOL2 &amp; " BOL not created - Test 1 " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( bol2.allBOLTransactions.size = 1, self.BOL2 &amp; " BOL should have 1 transaction - Test 1" );
	bolTrx := bol2.allBOLTransactions.first; 
	self.assertTrueMsg( bolTrx &lt;&gt; null and bolTrx.type = TRANS_TYPE_BOLCREATED, self.BOL2 &amp; " BOL should have 1 BOL Created transaction - Test 1" );
	invLine := bolTrx.allInvoiceLines.first;
	self.assertTrueMsg( invLine &lt;&gt; null, self.BOL2 &amp; " BOL Created transaction should be invoiced - Test 1" );
	self.assertTrueMsg( invLine.lineTotal = 1, self.BOL2 &amp; " BOL Created transaction invoice line charges s/be $1.00 - Test 1" );
	
	invLine := bolTrx.allInvoiceLines.first;
	bank := invLine.bank;
	
	// Perform a 'BOL Transaction' Selector Query and check the results 
	create myEnqController;
	create myEnqController.allObjects as  CM_ObjectSet transient;
	create criteriaHolder transient;
	user := app.getMyUser();
	qDef := app.myRoot.allQueryDefinitionObjects[ CM_QueryDefinition.Invoicing_Query_Type, CM_QueryDefinition.Invoice_Query_Mode ];
	//myEnqController.t := term;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	//this terminal only
	criteriaLine := qDef.createCriteriaLine(CM_Invoice::myTerminal.name, CM_QueryOperator.Operator_Equal, term);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	criteriaLine := qDef.createCriteriaLine(CM_Invoice::bank.name, CM_QueryOperator.Operator_Equal, bank);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	criteriaLine := qDef.createCriteriaLine(CM_Invoice::getTrackedItemBOL.name, CM_QueryOperator.Operator_Equal, bol2.number);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );

	myEnqController.myContext := self;

	
	myEnqController.doQuery( qDef );
	
	querySize := myEnqController.allObjects.CM_ObjectSet.size;
	self.assertTrueMsg( querySize = 1, "Wrong number of BOL Transactions found in the query.  Expected 1 got " &amp; querySize.String);
	
	//success, delete it all
	self.bolInvoicingCleanup();

epilog

	self.resetDefaultTranMap();
	
	beginTransaction;
	consignee1.setDebtor(null);
	consignor1.setDebtor(null);
	commitTransaction;

	delete pxyBOL;
	delete tis;
	delete dateArray;
	delete criteriaHolder;
	delete myEnqController;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateBOL" id="69fede68-e2c2-4977-a524-5a7be26ab9e7">
        <source>tCreateBOL();
// jlgmp6
// cnwrh7
// cnwmc5
//15 January 2010	cnwml2
// 10 Sep 2019	cnwrs1	TFS 46030
//
vars
	voyage1 : CM_Voyage;
	bol : CM_BOL;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.deleteVoyage("UTVOY1");
	self.deleteVessel("UTBOAT");
	self.addVesselCellular("UTBOAT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	voyage1 := addVoyageWithContainerStructur("UTVOY1", "UTBOAT", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	self.deleteBOL("UTMATBOL001", null);
	bol := self.addBOL("UTMATBOL001", voyage1,self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString), null, self.getTerminal );
	
	self.assertEqual(bol.allBOLDtls.size, 1);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;</source>
    </JadeMethod>
</Class>
