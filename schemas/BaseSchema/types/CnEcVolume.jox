<Class name="CnEcVolume" id="ac671079-17c9-47ad-a9a0-6edcf9b2d8af">
    <superclass name="CnEcUnitOfMeasure"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
