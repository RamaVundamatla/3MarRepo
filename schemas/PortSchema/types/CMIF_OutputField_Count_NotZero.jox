    <JadeMethod name="updateSelf" id="1dce2290-a63f-45df-aea8-9f4c7ee83ecf">
        <updating/>
        <source>updateSelf(_value: Any; _obj :Object) updating;
// ---------------------------------------------------------------------------
// Created:     15 February 2010 by cnwcs5
// Purpose:     par 22140 - new functions
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/02/2010	cnwcs5		par 22435 - release summary extenstions
// ---------------------------------------------------------------------------
vars

begin
	if _value.isKindOf (CM_SnapshotField_Count_NotZero) then
		self.count 	:= self.count + _value.CM_SnapshotField_Count_NotZero.count;
		return;
	endif;
	
	// _value will be Boolean
	if not _value.Boolean then
		self.count := self.count + 1;
		
		self.allObjects.addNoDuplicates (_obj, false);	// 22/02/2010
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
