    <JadeMethod name="cnwdad1_Test_BinaryPrint" id="36cca86b-e450-4dca-91b3-ddc1a84aec15">
        <source>cnwdad1_Test_BinaryPrint() protected;
// --------------------------------------------------------------------------------
// Created:		19 January 2007 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileName	: String;
	fileData	: Binary;
	fileTS		: TimeStamp;
	
begin
	if fileData.cnEcReadFromFile(fileName) then
		write "Printing " &amp; fileName &amp; "...";
		
		if fileData.cnEcPrintMe(fileName, fileTS, 0) then
			write "'" &amp; fileName &amp; "' has been printed.";
		else
			write "'" &amp; fileName &amp; "' could NOT be printed.";
		endif;
	endif;
end;</source>
        <access>protected</access>
