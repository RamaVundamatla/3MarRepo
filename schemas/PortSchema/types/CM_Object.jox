    <JadeMethod name="shouldAuditProperty" id="5cb16821-8a68-428d-99b7-ef2480add827">
        <source>shouldAuditProperty(_rootClass : Class; _property : Property) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     To allow properties to be excluded from auditing.
//
// Parameters:  The class being audited
//				The property being audited
//
// Returns:     True/False if the property should be audited
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _property = null or
	   _property.name = 'allAuditObjects' or
	   _property.name = 'allAuditObjectsForClass' or	//21 Jan 2021	NDL	TFS 50152
	   _property.name = 'myRoot' then
		return false;
	endif;
	return true;
end;</source>
