    <JadeMethod name="validateForUpdate" id="a1bc58c4-37a4-40f8-a4a5-e6af29a7fd4a">
        <source>validateForUpdate();
/*
Purpose:			

Date		Who		Reason
23 January 2023	navab1	TFS CR 55624 TASK 55698 
*/

vars
	realMe : SelfType;
	typeStr : String;
begin
	inheritMethod();
	
	realMe := self.pxyGetRealObject();
	
	if realMe &lt;&gt; null then
		if self.accumulationType &lt;&gt; realMe.accumulationType then
			if realMe.allAccumulationsByType.isNotEmpty() then // ### TFS BUG 57441 04APR2023 NAVAB1
				if realMe.accumulationType = INV_VOL_BASED_VOYAGE then
					typeStr := INV_VOL_BASED_VOYAGE_STR;
				else
					typeStr := INV_VOL_BASED_PERIOD_STR;
				endif;
				app.raiseCMException1(Canno_chang_accum_type_accum_e,"'" &amp; typeStr &amp; "'",null,null);
			endif;
		
		endif;
	
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
