    <JadeMethod name="createMenuActionSheet" id="c4d59c8e-743d-42af-88be-53292f34a43d">
        <source>createMenuActionSheet(_code : String; 
						_obj : Object);
// ---------------------------------------------------------------------------
// Created:     15 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	menuAction	: GTE_InOutMenuAction;
	mainTblDef,
	extraTblDef,
	headPrefix	: String;

begin
	create menuAction transient;
	menuAction.code := _code;

	if _code = NavObj_GTE_In then
		headPrefix	:= 'In';
		mainTblDef	:= ETDef_InMain;
		extraTblDef	:= ETDef_InExtra;

	elseif _code = NavObj_GTE_OutByType then
		headPrefix	:= 'Out';
		mainTblDef	:= ETDef_OutEmptyMain;

	elseif _code = NavObj_GTE_OutById then
		headPrefix	:= 'Out';
		mainTblDef	:= ETDef_OutFullMain;
		extraTblDef	:= ETDef_OutFullExtra;
		
	elseif _code = NavObj_GTE_Out then
		headPrefix	:= 'Out';
		mainTblDef	:= ETDef_OutMain;
		extraTblDef	:= ETDef_OutExtra;		
	endif;
	
	menuAction.headingPrefix := headPrefix;

	menuAction.setFromSubSchema(self.myMasterMenuAction, mainTblDef, extraTblDef);
	menuAction.myObject := _obj;
	menuAction.setHeading('');
	menuAction.setMyForm(self);
	
	if app.isSubTerminalsOn(self.myTerminal) then
		cmbSubTerminal.automaticCellControl	:=	true;
	else
		tblMain.hideRowByName(ETRow_MySubTerminal, false);
		tblExtra.hideRowByName(ETRow_MySubTerminal, false);
		tblCommon.hideRowByName(ETRow_MySubTerminal, false);
	endif;
	
	self.causeEvent(GTE_InputObject_InOutAdd, true, menuAction);
	app.causeEvent(CMUI_NavObject_Add, true, menuAction);
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
