    <JadeMethod name="validateCMIF_TITransCntrl" id="8b336c5f-71e5-42a5-b722-1c7f3e443420">
        <source>validateCMIF_TITransCntrl( _tiTransCntrl : CMIF_TITransactionController ) : Boolean;

/*
Date			Who		Reason
31 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	stop		: CM_Stops;
	
begin
	stop	:= _tiTransCntrl.myStop;
	if not app.isInProformaMode then
		if stop = null then
		//	app.raiseCMException1( REQUIRED_FIELD, 'myStop', null, null );
			app.raiseCMException(Input_required_field_myStop, null, null ); // cnwdb2	PAR 35364

			return false;
		elseif stop.myStopsTable = null then
		//	app.raiseCMException1( REQUIRED_FIELD, 'myStopTable', null, null );
			app.raiseCMException(Input_required_field_myStopTab, null, null ); // cnwdb2	PAR 35364
			return false;
		endif;
	endif;
	
	
	return inheritMethod( _tiTransCntrl );
	
	
epilog
	
end;
</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
