    <JadeMethod name="tblCash_click" id="5533cbb6-994c-4021-90d5-95dd1a08a334">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCash_click(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2012	cnwndl1	Initial creation

*/

vars

	text : String;
	cash : CM_Cash;

begin

	text := table.getCellText(table.row,table.column);
	if text = "+" or text = "-" then
		self.expandCollapseRow();
	endif;
	
	self.btnPrintRec.enabled := false;
	cash :=  table.accessRow(table.row).itemObject.CM_Cash;
	if cash &lt;&gt; null and app.isValidObject(cash) and ( cash.isPayment or cash.isReceipt ) then
		self.btnPrintRec.enabled := true;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblCash_contextMenu" id="e569a32b-1bef-4167-80e6-a6c6ae492ec5">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCash_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2012	cnwndl1	Initial creation

*/

vars

begin

	if self.doMnuContextBuild(table, conwin, mouse, x, y) then
		return self.showContextMenu(mnuContext, table, conwin, mouse, x, y);
	else
		return false;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblCash_dblClick" id="6bdc4702-e6ed-4084-8d3b-b537f375bbf4">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCash_dblClick(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars
	row		: Integer;
	cash	: CM_Cash;
begin
	row := self.tblCash.row;
	
	if row &gt; self.tblCash.fixedRows and row &lt;= self.tblCash.rows then
		cash := self.tblCash.accessRow( row ).itemObject.CM_Cash;
		if cash &lt;&gt; null and
		   cash.isKindOf(CM_CashReceipt) then
			self.showCashReceipt(cash.CM_CashReceipt);
			return;
		   endif;
	endif;

	self.expandCollapseRow();

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6096d4cf-7e9b-4ef6-89db-af2390f7e087">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 04 July 2019 13:14:41.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018211, locale);
	btnClose.translateCaption(Xlat_0018212, locale);
	btnExport.translateBubbleHelp(Xlat_0021144, locale);
	btnExport.translateCaption(Xlat_0021145, locale);
	btnExport2File.translateBubbleHelp(Xlat_0021146, locale);
	btnExport2File.translateCaption(Xlat_0021147, locale);
	btnExportCSV.translateBubbleHelp(Xlat_0018213, locale);
	btnExportCSV.translateCaption(Xlat_0018214, locale);
	btnPrintRec.translateBubbleHelp(Xlat_0018215, locale);
	btnPrintRec.translateCaption(Xlat_0018216, locale);
	btnPrintTbl.translateBubbleHelp(Xlat_0018217, locale);
	btnPrintTbl.translateCaption(Xlat_0018218, locale);
	btnSearch.translateBubbleHelp(Xlat_0018219, locale);
	btnSearch.translateCaption(Xlat_0018220, locale);
	btnSearchCancel.translateBubbleHelp(Xlat_0018221, locale);
	btnSearchCancel.translateCaption(Xlat_0018222, locale);
	btnSearcher.translateBubbleHelp(Xlat_0018223, locale);
	btnSearcher.translateCaption(Xlat_0018224, locale);
	chkAddTotal.translateCaption(Xlat_0018225, locale);
	chkIncludeArch.translateCaption(Xlat_0018226, locale);
 //	chkIncludeCred.translateCaption(Xlat_0018227, locale);		   // should say Cash Credits
	chkIncludePay.translateCaption(Xlat_0018228, locale);
	chkIncludePro.translateCaption(Xlat_0018229, locale);
	chkIncludeRec.translateCaption(Xlat_0018230, locale);
	chkIncludeRef.translateCaption(Xlat_0018231, locale);
	lblBOL.translateCaption(Xlat_0019466, locale);
	lblBank.translateCaption(Xlat_0023613, locale);
	lblCEN.translateCaption(Xlat_0019467, locale);
	lblCargoIds.translateCaption(Xlat_0019468, locale);
	lblCashDebtor.translateCaption(Xlat_0018232, locale);
	lblFromDate.translateCaption(Xlat_0018233, locale);
	lblReceiptNo.translateCaption(Xlat_0019469, locale);
	lblSearch.translateCaption(Xlat_0018234, locale);
	lblSearchCrit.translateCaption(Xlat_0018235, locale);
	lblTerminal.translateCaption(Xlat_0018236, locale);
	lblToDate.translateCaption(Xlat_0018237, locale);
	lblTypes.translateCaption(Xlat_0018238, locale);
	lblVoyBol.translateCaption(Xlat_0019470, locale);
	mnuAudits.translateCaption(Xlat_0019745, locale);
	mnuCashReceipt.translateCaption(Xlat_0019471, locale);
	mnuContext.translateCaption(Xlat_0018239, locale);
	mnuCreditNote.translateCaption(Xlat_0021141, locale);
	mnuExpand.translateCaption(Xlat_0018240, locale);
	mnuExportCred2File.translateCaption(Xlat_0021148, locale);
	mnuExportCredit.translateCaption(Xlat_0021149, locale);
	mnuExportRec2File.translateCaption(Xlat_0021150, locale);
	mnuExportReceipt.translateCaption(Xlat_0021151, locale);
	mnuInspect.translateCaption(Xlat_0018241, locale);
	mnuInvoice.translateCaption(Xlat_0018242, locale);
	mnuPrintCashRec.translateCaption(Xlat_0018243, locale);
	mnuPrintPayRec.translateCaption(Xlat_0018244, locale);
	mnuShowCargo.translateCaption(Xlat_0018245, locale);
end;</source>
