    <JadeMethod name="create" id="a91192a0-7b1d-4e18-86a4-a7ecbf97d1be">
        <updating/>
        <source>create(_name,
		_documentationTextData	: String;
		_isInterface			: Boolean;
		_reason					: Integer;
		_schema					: DEV_Schema;
		_section 				: DEV_SchemaClassesSection) ::super(_name) updating;
/*

Purpose:			Constructor for DEV_Class class

Parameters:			_name:						String						The name of the class
					_documentationTextData:		String						The documentation text on the class
					_isInterface:				Boolean						Is this class an interface
					_section:					DEV_SchemaClassesSection	The section that holds all the types/classes

Return Value:		

Date		Who		Reason
05 November 2021	navpw1	Initial creation TFS: 52202

*/

begin
	//Set Attributes
	self.name					:= _name;
	self.documentationTextData	:= _documentationTextData;
	self.isInterface			:= _isInterface;
	self.reason					:= _reason;
	
	//Set References
	self.mySection 				:= _section;
	self.mySchema				:= _schema;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_documentationTextData" type="String"/>
        <Parameter name="_isInterface" type="Boolean"/>
        <Parameter name="_reason" type="Integer"/>
        <Parameter name="_schema" type="DEV_Schema"/>
        <Parameter name="_section" type="DEV_SchemaClassesSection"/>
    </JadeMethod>
    <JadeMethod name="getMyClass" id="9bf665fa-b115-4c4a-b186-c43a925364e7">
        <source>getMyClass(_scm : Schema) : Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2023	navpw1	Initial creation

*/

begin
	return _scm.getClass(self.name);
	
end;</source>
        <Parameter name="_scm" type="Schema"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getMySchema" id="2f8598d6-f65a-4bb4-b099-c773a68a5413">
        <source>getMySchema(): Schema;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2023	navpw1	Initial creation

*/

begin
	return rootSchema.getSchema(self.mySchema.name);
	
end;</source>
        <ReturnType type="Schema"/>
    </JadeMethod>
    <JadeMethod name="update" id="4ddc2677-5f17-41c3-816c-f74b48aefeb8">
        <updating/>
        <source>update(_documentationTextData,
		_webServicesClassPropertiesText,
		_webServicesMethodDefinitionsText,
		_implementInterfacesText 			: String;
		_isInterface						: Boolean) updating;
/*

Purpose:			Updates a DEV_Class

Parameters:			_documentationTextData:				The documentation text on the class
					_webServicesClassPropertiesText:	The web services class properties text of the class
					_webServicesMethodDefinitionsText:	The web services method definitions text of the class
					_implementInterfacesText:			The implement interfaces text of the class
Return Value:		

Date		Who		Reason
09 November 2021	navpw1	Initial creation TFS: 52202

*/

begin
	self.setDocumentationText(_documentationTextData);
	self.webServicesClassPropertiesText 	:= _webServicesClassPropertiesText;
	self.webServicesMethodDefinitionsText	:= _webServicesMethodDefinitionsText;
	self.implementInterfacesText			:= _implementInterfacesText;
	self.isInterface						:= _isInterface;
	
end;</source>
        <Parameter name="_documentationTextData" type="String"/>
        <Parameter name="_webServicesClassPropertiesText" type="String"/>
        <Parameter name="_webServicesMethodDefinitionsText" type="String"/>
        <Parameter name="_implementInterfacesText" type="String"/>
        <Parameter name="_isInterface" type="Boolean"/>
    </JadeMethod>
</Class>
