    <JadeMethod name="addLocationController" id="01ce4839-39ed-47cd-bfff-400a03504781">
        <source>addLocationController(_location : CM_LocationsController);
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if not self.allLocationsControllers.includes(_location) then
		self.allLocationsControllers.atPut(1,_location);
	endif;
end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="canUnplanFutureMove" id="013882e4-65cf-409d-95b8-b23456f11c0c">
        <source>canUnplanFutureMove():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 Aug 2008	cnwdz2	Par 16632 it is not allowed to unplan a job that has one or more queued cargoes.				

*/

vars
	tmpToLC	: CM_LocationsController;
begin
	if self.myFutureMovePlanned = null then
		return true;
	endif;
	
	foreach tmpToLC	in self.allLocationsControllers do 
		if self.myFutureMovePlanned.allLocationsControllers.includes(tmpToLC) then
			return false;
		endif;
	endforeach;
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="causeUpdateDisplayEvents" id="fbbab61c-ecbd-457b-a1c1-e55c2b8ddd9c">
        <source>causeUpdateDisplayEvents(_theTI: CM_TrackedItem; _lcArray: CM_LCArray) protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	locnCntrl : CM_LocationsController;
begin
	inheritMethod(_theTI, _lcArray);

	if _theTI = null then
		return;
	endif;
	
	locnCntrl := _theTI.myOSBackEndLocationQd;
	if locnCntrl &lt;&gt; null then
		if CM_SlotController.hasInstance(locnCntrl) then
			app.myEventManager.createSingleObjInfoNoteEvt(locnCntrl.CM_SlotController.myBayVoyage.myCellularVoyageStructure.myVoyage,
				locnCntrl.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), locnCntrl);
		
		elseif locnCntrl.myTerminalArea &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(locnCntrl.myTerminalArea, 
				locnCntrl.myTerminal.getTerminalEvent(EVENT_TI_MOVE),  
				locnCntrl);
		endif;
	
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_lcArray" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="containsTrackedItem" id="caf98e8c-4d27-44e7-bd75-40fe7f269a7f">
        <source>containsTrackedItem(_ti: CM_TrackedItem): Boolean;
/*
------------------------------------------------------------------------
Created:			04 December 2002 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		As above. Special comment:
Returns:			As above. Special comment:
Changed On		Changed By		Reason
