    <JadeMethod name="displayShiftsDays" id="123d5c26-0673-44e1-89c7-e7256c866429">
        <updating/>
        <source>displayShiftsDays() updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22 Jun 2010	cnwkpd1		PAR #24609 - Rework for performance, and to cater for new 
// 							behaviour of CM_Terminal::getShiftsFromRange returning
//							all transients
// 05/05/2017	cnwdap1		TFS 4342 Voyage Event Date Issues - shift timestamps should not be converted
// ---------------------------------------------------------------------------

vars
	iter				: Iterator;
	shift,
	realShift			: CM_Shift;
	tmpString 			: String;
	idxRow,
	oldShiftDay,
	day, idx, shiftDay 	: Integer;
	isFirst				: Boolean;
	realShifts			: CM_ShiftStartDateCodeDict;
	frmTS, toTS 		: TimeStamp;
	
	shiftStartDateTime  : TimeStamp;
	shiftEndDateTime	: TimeStamp;
begin
	oldShiftDay := 0;
	self.initTblShiftDays();
	idxRow := 2;	
	
	frmTS.setDate(self.dmByDate.getDate());
	
	frmTS.setTime(TimeStartOfDay);
	frmTS := self.localToSystemTime(frmTS);
	
	toTS.setDate(self.dmByDate.getDate() + self.txtDayNum.text.Integer);
	
	toTS.setTime(TimeEndOfDay);
	toTS := self.localToSystemTime(toTS);
	
	self.allShiftsDays.purge();
	
	//create shifts transient;
	//self.myTerminal.getShiftsFromRange(shifts,frmTS, toTS);
	self.myTerminal.getShiftsFromRange(self.allShiftsDays, frmTS, toTS);
	
	// Also get the real shifts for the date range
	create realShifts transient;
	self.myTerminal.getShiftsFromRangeReal(realShifts, frmTS, toTS);
	
	//shifts.copy(self.allShiftsDays);
	
	iter := self.allShiftsDays.createIterator();
	while iter.next(shift) do
	
		// Need to check whether there is a real shift for this time
		realShift := realShifts[ shift.startDateTime, shift.code];
		
		// If there is, then load the table with the real shift instead of the transient
		if realShift &lt;&gt; null then
			shift := realShift;
		endif;
				
		//shiftDay := self.systemToLocalTime(shift.startDateTime).Date.dayOfWeek();		// TFS 4342
		//shiftStartDateTime	:= self.systemToLocalTime(shift.startDateTime);			// TFS 4342
		//shiftEndDateTime	:= self.systemToLocalTime(shift.endDateTime); 				// TFS 4342
		shiftDay := shift.startDateTime.Date.dayOfWeek();								// TFS 4342
		shiftStartDateTime	:= shift.startDateTime;										// TFS 4342
		shiftEndDateTime	:= shift.endDateTime; 										// TFS 4342
		tmpString := shift.getShiftDay() &amp; Tab &amp; 
						shiftStartDateTime.Date.shortFormatJMT &amp; " " &amp; shiftStartDateTime.Time.String &amp; Tab &amp; 
						shiftEndDateTime.Date.shortFormatJMT   &amp; " " &amp; shiftEndDateTime.Time.String &amp; Tab &amp; 
						shift.getShiftLengthDesc() &amp; Tab &amp; 
						shift.code &amp; Tab &amp; 
						shift.description;
		
		idx := self.tblShift.addItemObject(shift,tmpString);
		
	endwhile;

	self.tblShift.accessColumn(2).sortType := Table.SortType_TimeStamp;
	self.tblShift.sortColumn[1] := 2; 
	self.tblShift.sortAsc[1] := true;
	self.tblShift.sortCased[1] := false;
	self.tblShift.resort();
	
	foreach idx in self.tblShift.fixedRows + 1 to self.tblShift.rows do
		shift := self.tblShift.accessRow(idx).itemObject.CM_Shift;
		if shift &lt;&gt; null then
			if shift.ignore then
				self.tblShift.accessRow(idx).backColor := Gray;
				self.tblShift.accessedRow.foreColor := White;
				self.tblShift.accessedRow.fontItalic := true;
			else
				shiftDay := shift.startDateTime.Date.dayOfWeek();
				if  oldShiftDay &lt;&gt; shiftDay then
					self.tblShift.accessRow(idx).backColor := self.ColourYellowDark;
					oldShiftDay := shiftDay ;
				else
					self.tblShift.accessRow(idx).backColor := self.ColourYellowLight;
				endif;
				if not shift.isTransient then
					self.tblShift.accessRow(idx).fontBold := true;
				endif;
			endif;
		endif;
	endforeach;
	
epilog
	//shift := self.tblShift.accessRow(3).itemObject.CM_Shift;
	//shifts.deleteObjects(false);
	
	//delete shifts;
	delete iter;
end;
</source>
    </JadeMethod>
    <JadeMethod name="displayShiftsStandard" id="70b6cfed-341a-4c7b-9a51-0a16fb5918c7">
        <updating/>
        <source>displayShiftsStandard() updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	iter		: Iterator;
	shift		: CM_ShiftStd;
	idxRow,
	oldShiftDay,
	day : Integer;
	isFirst		: Boolean;
begin
	oldShiftDay := 0;
	self.initTblShiftStandard();
	idxRow := 2;	
	iter := self.myTerminal.allShiftsStandard.createIterator();
	while iter.next(shift) do
		day := shift.shiftDay;
		if not oldShiftDay = shift.shiftDay then
			isFirst := true;
		else
			isFirst := false;
		endif;
		self.addDisplayRow(shift, idxRow, isFirst);
		idxRow := idxRow + 1;
		oldShiftDay := shift.shiftDay;
	endwhile;
epilog
	delete iter;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doAddShift" id="fa163af8-8aab-4275-8201-8079c3545bc9">
        <updating/>
        <source>doAddShift() updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19/08/2008	concms1		SPar 17766 et zOrder when adding shift 
