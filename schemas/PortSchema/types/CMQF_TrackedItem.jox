    <JadeMethod name="doStats" id="4937457b-1ee6-4a8d-af6b-535bb4a1e416">
        <updating/>
        <source>doStats(_ti : CM_TrackedItem) updating;
//----------------------------------------------------------------
//	Created:	20 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	precisionError : Boolean;
begin
	precisionError := false;
	on Exception do self.handlePrecisionError(exception, precisionError);

	if _ti.cargoType = TI_CargoType_Container then
		if _ti.isAttributeTrue(TI_Attrib_IsForty) then
			self.sum40s := self.sum40s + 1;
		else
			self.sum20s := self.sum20s + 1;
		endif;
	endif;

	//self.sumWeight := self.sumWeight + _ti.weight;			//-cnwml2 MSL CCMS 1017
	self.sumWeight := self.sumWeight + _ti.totalWeight;			//+cnwml2 MSL CCMS 1017
	
	
	/* 
	if precisionError then 
	// Report_SumWeight_ToLarge
		app.raiseCMException(Report_SumWeight_ToLarge); //realy want to do this? //cnwrd1 par 23752
	endif;
	*/
	
	if _ti.receiptTransportMode = TI_TRANSMODE_RAIL then
		self.sumRail := self.sumRail +1;
	elseif _ti.receiptTransportMode = TI_TRANSMODE_ROAD then
		self.sumRoad := self.sumRoad +1;
	else
	
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="9ee9e495-27e9-4e11-8b76-d57226f8cb43">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     06 September 2002 by cnwth2
//
// Purpose:     
// 30 May 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 23 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
// ----------   ----------  --------------------------------------------------
vars
	breakOut			: Boolean;
	sites				: IntegerArray;
	vvr					: CM_VehicleVisitRecord;
	ti					: CM_TrackedItem;
begin

	if (not self.allQueryCriteriaHolders.isEmpty) then
		self.filterSelectorQuery(_collection, _passport);
		return;
	endif;
	
	vvr := self.getMyVehicleVisit();
	if vvr &lt;&gt; null then
		foreach ti in vvr.allReceivedTrackedItems do
			if not _collection.includes(ti) then
				_collection.add(ti);
			endif;
		endforeach;
		foreach ti in vvr.allReleasedTrackedItems do
			if not _collection.includes(ti) then
				_collection.add(ti);
			endif;
		endforeach;
		return;
	endif;

	sites := self.allQrySites;
	if sites.isEmpty then	// use the default of 'Onsite'
		sites.add(TI_SITE_ONSITE);
	endif;

	if sites.size = 1 and sites.includes(TI_SITE_ONSITE) then
		if self.alternativeId &lt;&gt; null then
			//we can exclusively use the alternate identifier to find cargo.
			self.handleOnSiteByAlternateId(_collection, _passport, breakOut);
			return;
		endif;
	endif;
	
	if self.getMyLocationsController &lt;&gt; null then
		self.handleLocationsController(self.getMyLocationsController, _collection, _passport, breakOut);
		return;
	endif;
	
	if self.getMyTerminalArea &lt;&gt; null then
		self.handleTerminalArea(self.getMyTerminalArea, _collection, _passport, breakOut);
		return;	
	endif;
	
	if (not self.terminalAreaTypes.isEmpty) then
		self.handleTATypes(_collection, _passport);
		return;
	endif;
	
	if self.getMyVoyage &lt;&gt; null then
		self.handleVoyage(self.getMyVoyage, _collection, _passport);
		return;
	endif;
	
	if (not self.allTerminals.isEmpty) then
		self.handleTerminals(_collection, _passport);
		return;
	endif;
	
	if self.getMyShippingLine &lt;&gt; null then
		self.handleShippingLine(_collection, _passport, breakOut);		// 30.05.2022 navak20 TFS 53204
		return;
	endif;
	if self.countryOfOriginCode &lt;&gt; null then
		self.handleCountryOfOrigin(_collection, _passport, breakOut);		// 23.08.2022 navak20 TFS 54441
		return;
	endif;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterSelectorQuery" id="08752956-01df-4af6-b704-da7a9a06e01c">
        <source>filterSelectorQuery(_collection  : Collection input;
					_passport : CM_Passport) protected;
// ---------------------------------------------------------------------------
// Created:     02 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	criteriaHolder 		: CM_QueryCriteriaLineHolder;
	qDef				: CM_QueryDefinition;
	enqController		: CM_EnquiryController;
	queryAgent			: CM_QueryAgentFilter;

begin

	// Special one because we need the copy
	on CM_BreakOutException do app.myQAFilter.xHandlerBreakOut(exception);
	
	queryAgent := app.myQAFilter;
	if queryAgent = null then
		return;
	endif;
	
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, self.selectorMode];
	queryAgent.createEnqControllerForMode(self.selectorMode, CM_QueryDefinition.TrackedItem_Query_Type, enqController);
	delete enqController.allObjects;
	create enqController.allObjects as _collection.class transient;
	
	foreach criteriaHolder in self.allQueryCriteriaHolders discreteLock do
		enqController.myCriteriaLineHolder := criteriaHolder;
		enqController.doQuery(qDef);
	endforeach;

	enqController.allObjects.copy(_collection);
	
epilog
	if enqController &lt;&gt; null then
		delete enqController.allObjects;
	endif;
	delete enqController;
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getCountryOfOrigin" id="69dfb880-fdc6-4a67-8407-142d1326d1a6">
        <source>getCountryOfOrigin(): CM_Country;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin

*/

vars

	country : CM_Country;
	edition : Integer;
	invalidObj : Boolean;

begin

	country := app.myRoot.allCountries[self.countryOfOriginCode];

	if country = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, country, invalidObj );
	edition := country.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return country;

epilog

end;</source>
        <ReturnType type="CM_Country"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="5e84772d-0bd9-47c9-b141-5bc98725378c">
        <source>getDisplayStringForAttribute(_attrName : String; _getCalculatedDate : Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
vars
	runDate	: Date;
	oid 	: String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
/*
	if _attrName = ETRow_EndTime or
	   _attrName = ETRow_FirstConnectDT then
		if self.onTime.isValid then
			//return self.onTime.String;
			return self.onTime.asStringJMT();  //par 18944
		else
			//return '23:59:59';
			return '23:59';  //par 18944
		endif;

	elseif _attrName = ETRow_Id then
		return self.id;
	elseif _attrName = ETRow_LoadPort then
		if self.myLoadPort &lt;&gt; null then
			return self.myLoadPort.code;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_IMEXStatuses then
		return self.getQryIMEXLabel();
		
	elseif _attrName = ETRow_Port or
	   _attrName = ETRow_DischargePort then
		if self.myPort &lt;&gt; null then
			return self.myPort.code;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_IsoTypeGroup then
		if self.myISOTypeGroup &lt;&gt; null then
			return self.myISOTypeGroup.code;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_OperatorGroup then
		if self.myOperatorGroup &lt;&gt; null then
			return self.myOperatorGroup.code;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_OnDate then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.onDateTplType, self.onDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.onDateTplType, self.onDateTplFactor);
		endif;
		
	elseif _attrName = ETRow_MyProduct or
		_attrName = ETRow_Product then
		if self.myProduct &lt;&gt; null then
			return self.myProduct.code;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_SiteState then
		return self.getSiteString();
	
	elseif _attrName = ETRow_Stops then
		return self.getStopsString();
		
	elseif _attrName = 	ETRow_SaveToWorkList then 
		return self.saveToWorkList.cnEcGetTableCheckBoxValue();
		
	elseif _attrName = ETRow_Voyage or
		_attrName = ETRow_MyVoyage then
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.code;// &amp; '  ' &amp; self.myVoyage.vesselName;
		else
			return Any_String;
		endif;
	elseif _attrName = ETRow_DaysOnsite then
		return self.daysOnsite.String;
	endif;	//par 14114
	
	return inheritMethod(_attrName, _getCalculatedDate);
*/

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoString" id="8a607980-e0fa-457a-95fa-15413bc24c6e">
        <source>getExtraInfoString(): String;
// -------------------------------------------
// Created 01 April 2005 by cnwdvb1
// -------------------------------------------
vars
	voyage : CM_Voyage;
begin

	// CCMS 1327
	voyage := self.getMyVoyage();
	
	if voyage &lt;&gt; null then
		return voyage.getId();
	endif;
	
	return inheritMethod();


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyBOL" id="dc392bce-6a67-47ab-a548-0c77aa1be8c8">
        <source>getMyBOL():CM_BOL;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	bol : CM_BOL;
	edition : Integer;
	invalidObj : Boolean;

begin

	bol := self.myBOL;

	if bol = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, bol, invalidObj );
	edition := bol.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return bol;

epilog

end;</source>
