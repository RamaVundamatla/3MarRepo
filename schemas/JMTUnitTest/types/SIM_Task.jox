    <JadeMethod name="accept" id="9911e9ef-535a-4e91-b47d-7a93fd6c1118">
        <updating/>
        <source>accept(_machine: SIM_Machine) updating;
vars

begin
	self.myMachine := _machine;
epilog

end;</source>
        <Parameter name="_machine" type="SIM_Machine"/>
    </JadeMethod>
    <JadeMethod name="add" id="edcdfaa2-97f5-4c42-953e-a2159fa6750d">
        <updating/>
        <source>add(_terminal: SIM_Terminal; _id: Integer; _machineType: String; _task: CM_RTQueueTask; _taskType: String; _simPrevTask: SIM_Task io) updating;
vars
	machineName: String;
begin
	self.mySIMTerminal := _terminal;
	self.id := _id;
	self.myTask := _task;
	self.machineType := _machineType;
	self.taskType := _taskType;	
	self.cargoId := self.getTrackedItem.id;
	self.sourceId := _task.sourceLocationId;
	self.targetId := _task.targetLocationId;
	if _machineType = SIM_Machine.MACHINE_CRANE then
		if _task.sourceLocation &lt;&gt; null and _task.sourceLocation.isVoyageController then
			if _task.isMove then
				self.targetId := "IMV";
			else
				self.targetId := _task.queue.CM_VoyageCraneQueue.crane.transferArea.id;
			endif;
		endif;
		if _task.targetLocation &lt;&gt; null and _task.targetLocation.isVoyageController then
			if _task.isMove then
				self.sourceId := "IMV";
			else
				self.sourceId := _task.queue.CM_VoyageCraneQueue.crane.transferArea.id;
			endif;
		endif;
	endif;
	if _machineType =SIM_Machine.MACHINE_LIFTER then
		if _taskType = TASK_TYPE_SETDOWN then
			self.sourceId := _simPrevTask.getSourceId;
		endif;
		if _task.sourceLocation &lt;&gt; null and _task.sourceLocation.isVoyageController then
			self.sourceId := _task.queue.CM_VoyageCraneQueue.crane.transferArea.id;
		endif;
		if _task.targetLocation &lt;&gt; null and _task.targetLocation.isVoyageController then
			self.targetId := _task.queue.CM_VoyageCraneQueue.crane.transferArea.id;
		endif;
	endif;
	self.myPrevTask := _simPrevTask;
	if _simPrevTask &lt;&gt; null then
		_simPrevTask.myNextTask := self;
	endif;
	
epilog

end;</source>
        <Parameter name="_terminal" type="SIM_Terminal"/>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_machineType" type="String"/>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_taskType" type="String"/>
        <Parameter name="_simPrevTask" type="SIM_Task" usage="io"/>
    </JadeMethod>
    <JadeMethod name="canAccept" id="bda95b74-d711-42ee-ac75-b3358abdf990">
        <source>canAccept(_machine: SIM_Machine): Boolean;
vars

begin
	if _machine.getMachineType &lt;&gt; machineType then
		return false;
	endif;
	
	if not self.isTaskReadyForAccept then
		return false;
	endif;
	
	if self.isCompleted then
		return false;
	endif;

	if self.isAccepted then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_machine" type="SIM_Machine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="complete" id="816a4203-bfc5-4559-a8d3-88e12fba9d22">
        <updating/>
        <source>complete() updating;

vars

begin
	self.completed := true;
	self.myMachine := null;
	self.myTask := null;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="display" id="5ea855c8-e109-49bd-88e2-881941089f78">
        <source>display(): String;

vars
	taskId, nextTaskMachine, prevTaskMachine: String;
begin
	if self.myNextTask &lt;&gt; null then
		nextTaskMachine := self.myNextTask.machineType;
	endif;
	if self.myPrevTask &lt;&gt; null then
		prevTaskMachine := self.myPrevTask.machineType;
	endif;
	
	if self.getTask &lt;&gt; null then
		taskId := self.getTask.getTaskId;
	endif;
	
	return "Task " &amp; id.String &amp; " " &amp; taskId &amp;
		   " Type: " &amp; self.taskType &amp;
		   " Machine Type: " &amp; self.machineType &amp;
		   " Next Task Machine: " &amp; nextTaskMachine &amp;
		   " Prev Task Machine: " &amp; prevTaskMachine;
		   
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoId" id="5bdebeee-dcc4-4fe8-9815-c995d8d19afb">
        <source>getCargoId(): String;

vars

begin
	return self.cargoId;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCrane" id="681e137a-c555-4d35-95ee-8329c9dc4ea9">
        <source>getCrane() : SIM_Crane;
vars

begin

