        <source>getPDFPrinters(_allPrinters : CM_PrinterDefsByLogicalPrinter input);
// -------------------------------------------
// Created 11 April 2005 by cnwdvb1
// -------------------------------------------
vars

	printer : CM_PrinterDef;

begin

	_allPrinters.clear();
	foreach printer in app.myRoot.allPrinterDefsByLogicalName discreteLock do
