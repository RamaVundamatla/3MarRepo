    <JadeMethod name="getInaportnetPPKBPandu" id="b069af47-633e-4d7a-a210-9f10cec0bcdb">
        <source>getInaportnetPPKBPandu() : String;
/*

Purpose:			Generate a unique PPKBPANDU reference number from the receiver for the INAPORTNET interface

Parameters:			None

Return Value:		PPKBPANDU number

Date		Who		Reason
19 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

port : CM_Port;
begin
	port:=self.getMyTerminal.getDefaultPort();
	if port &lt;&gt; null then
		return  port.code &amp; "-PPKBPANDU-" &amp; self.getOidString;
	endif;
	return "PPKBPANDU." &amp; self.getOidString;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
