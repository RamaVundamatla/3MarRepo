<Class name="CMQF_SOHLocationGCDetail" id="3e24ea8d-53c5-4d06-b352-663e29f395f7">
    <superclass name="CMQF_SOHLocationGC"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="a5e2a5b8-0672-4540-a94f-c15fd3abd9ae">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     19 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	breakOut	: Boolean;
	int			: Integer;
begin

	int := CM_RepGCItemDetailByPro;
	
	if (not app.getMyUser.canDo(null, Mod_GeneralCargo)) then
		return;
	endif;
	
	if self.getMyLocationsController &lt;&gt; null then
		self.handleLocationsController(self.getMyLocationsController, _collection, _passport, breakOut);
	elseif self.getMyTerminalArea &lt;&gt; null then
		self.handleTerminalArea(self.getMyTerminalArea, _collection, _passport, breakOut);
	elseif self.getMyProduct &lt;&gt; null then
		self.handleProduct(self.getMyProduct, _collection, _passport, breakOut);
	elseif CM_CargoType.hasInstance(self.getMyCargoType) then 
		self.handleCargoType(self.getMyCargoType.CM_CargoType, _collection, _passport, breakOut);
	else
		self.handleAllCargoTypes(_collection, _passport, breakOut);
	endif;

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
