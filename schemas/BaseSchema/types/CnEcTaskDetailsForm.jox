    </JadeMethod>
    <JadeMethod name="cmbNewTask_click" id="09d625b8-45e8-4d7b-9e72-690171380745">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbNewTask_click(combobox: ComboBox input) updating;
// --------------------------------------------------------------------------------
// Created:		07 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	txtTaskId.text	:=	cmbNewTask.text;
