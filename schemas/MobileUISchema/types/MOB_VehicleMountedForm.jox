        </interfaceImplements>
        <source>getGridSizes(_mode : Integer; _ta : CM_TerminalArea; _widthFt : Real io; _heightFt : Real io);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2010	cnwjk3	Initial creation

*/

vars

begin
	if _ta.isKindOf(CM_GridArea) then
		if _ta.isKindOf(CM_StraddleStack) then
			if _mode = CMIF_RDTDrawElement.MODE_TOPDOWN then
				_widthFt := 12;		// defaulting for portrait view
				_heightFt := 20; 	// defaulting for portrait view
			elseif _mode = CMIF_RDTDrawElement.MODE_FACE then
				_widthFt := 8;		// defaulting for portrait view
				_heightFt := 20;	// defaulting for portrait view			
			elseif _mode = CMIF_RDTDrawElement.MODE_END then
				_widthFt := 8;		// defaulting for portrait view
				_heightFt := 8;		// defaulting for portrait view						
			endif;				
		else
			if _mode = CMIF_RDTDrawElement.MODE_TOPDOWN then
				_widthFt := 8;		// defaulting for portrait view
				_heightFt := 20;	// defaulting for portrait view
			elseif _mode = CMIF_RDTDrawElement.MODE_FACE then
				_widthFt := 8;		// defaulting for portrait view
				_heightFt := 20;	// defaulting for portrait view			
			elseif _mode = CMIF_RDTDrawElement.MODE_END then
				_widthFt := 8;		// defaulting for portrait view
				_heightFt := 8;		// defaulting for portrait view									
			endif;							
		endif;
	elseif _ta.isKindOf(CM_Rail) then
			if _mode = CMIF_RDTDrawElement.MODE_TOPDOWN then
				_widthFt := 18;		// defaulting for portrait view
				_heightFt := 10;	// defaulting for portrait view
			elseif _mode = CMIF_RDTDrawElement.MODE_FACE then			
				_widthFt := 8;		// defaulting for portrait view
				_heightFt := 10;	// defaulting for portrait view
			elseif _mode = CMIF_RDTDrawElement.MODE_END then
				// Not supported
			endif;					
	endif;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_widthFt" type="Real" usage="io"/>
        <Parameter name="_heightFt" type="Real" usage="io"/>
    </JadeMethod>
