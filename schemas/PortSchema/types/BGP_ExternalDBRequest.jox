<Class name="BGP_ExternalDBRequest" id="bd3f25a5-a421-4958-8847-c9eec7a54388">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Data Extract Agent&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <Constant name="Extract_Classes_All" id="a372ef87-3d40-4d7a-b2e5-2e7bafe4104f">
        <source>"Extract All Classes"</source>
        <type name="String"/>
    </Constant>
    <Constant name="Extract_Classes_Changed" id="d283a29c-bdcb-4144-9174-aeaf627b95ca">
        <source>"Extract Changed Classes"</source>
        <type name="String"/>
    </Constant>
    <Constant name="Extract_Def_All" id="bdc9834b-6a8e-4ad7-bea1-d4e8278bf0e3">
        <source>"Extract All"</source>
        <type name="String"/>
    </Constant>
    <Constant name="Extract_Def_Changes" id="b3daf81a-d787-43ed-a939-a1dcee65b3d5">
        <source>"Extract Changes"</source>
        <type name="String"/>
    </Constant>
    <ImplicitInverseRef name="allDataDumpExtractClasses" id="b0c34788-5090-476c-8245-2dfba393abc0">
        <memberTypeInverse/>
        <type name="CM_DataDumpExtractClassArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="closeJournal" id="663085d6-5c74-47c9-bd63-7902a8c9d992">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="extractType" id="1b790573-f2e7-4e91-9437-adb91ab472dc">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myDataDumpExtractDef" id="9b2871f6-4900-4c82-988d-08e2b90a06be">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_DataDumpExtractDef"/>
        <access>readonly</access>
        <Inverse name="CM_DataDumpExtractDef::allRequests"/>
    </ExplicitInverseRef>
    <JadeMethod name="action" id="cbc163ee-efe3-435d-b868-e0934ebf3c9c">
        <updating/>
        <source>action(): Boolean updating;

// cnwdvb1 30 June 2003 
// 09 Dec 2015	cnwrs1	Par37170 - SQL Native not recovering from SQL shutdown
// 02 May 2016	cnwkpd1	TFS 1900 - Prevent 1206 exception by not initialising if the 
//						Data Defintion is not active
// 16 Sep 2024	navsp1	JIRA 23326 (TFS Bug 65272): NSW - Unable to Manually Run Data Extract
// 15 Jan 2025	navmd1	JIRA 33803 Fix Data Extract requests created via the auto scheduled not actually *doing* anything

vars
	errCode	: Integer;
	errTxt	: String;
	agent 	: CM_DataDumpExtractionAgent;
	dataDumpExtractClass 	: CM_DataDumpExtractClass; 	//JIRA 23326
	def						: CM_DataDumpExtractDef; 	//JIRA 23326
begin

	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.setUser();
	if self.myDataDumpExtractDef = null then
		// eg. the Extract Definition has been deleted
		return false;
	endif;
	
	if self.myDataDumpExtractDef.isActive then
		def := self.myDataDumpExtractDef;
		create agent transient;
		//Export All Definition (classes)																														//JIRA 23326
		if self.extractType = self.Extract_Def_All then 																										//JIRA 23326
			foreach dataDumpExtractClass in def.allDataDumpExtractClasses do																					//JIRA 23326
				agent.initialise(dataDumpExtractClass.classAlias, false, true);																					//JIRA 23326
				agent.doExtractDefinitonAll(def.description);																									//JIRA 23326
				agent.finalise;																																	//JIRA 23326
			endforeach;																																			//JIRA 23326
		//Export All selected classes																															//JIRA 23326
		elseif self.extractType = self.Extract_Classes_All then																									//JIRA 23326
			foreach dataDumpExtractClass in self.allDataDumpExtractClasses do																					//JIRA 23326
				agent.initialise(dataDumpExtractClass.classAlias, false, true);																					//JIRA 23326
				agent.doExtractDefinitonAll(def.description);																									//JIRA 23326
				agent.finalise;																																	//JIRA 23326
			endforeach;																																			//JIRA 23326
		//Export all changes for the selected classes																											//JIRA 23326
		elseif self.extractType	= self.Extract_Classes_Changed then																								//JIRA 23326
			foreach dataDumpExtractClass in self.allDataDumpExtractClasses do																					//JIRA 23326
				agent.initialise(dataDumpExtractClass.classAlias, false, true);																					//JIRA 23326
				agent.doExtractDefinitonChanges(def.description, self.closeJournal);																			//JIRA 23326
			endforeach;																																			//JIRA 23326
		//Export all Definition changes	(classes)																												//JIRA 23326
		elseif self.extractType = self.Extract_Def_Changes or																									//JIRA 23326
				self.extractType = null then																													//JIRA 33803
			agent.initialise(null, false, true);																												//JIRA 23326
			agent.doExtractDefinitonChanges(def.description, self.closeJournal);																				//JIRA 23326
		endif;																																					//JIRA 23326
	endif;																																						//JIRA 23326

epilog
	delete agent;
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	else																																						//JIRA 23326
		app.createActivityHistory(ActivityHistoryGeneral, null, self, app.getErrorString(BGP_DataExtract_Success), false, false);								//JIRA 23326
	endif;																																						//JIRA 23326
	inheritMethod();
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="c9017d1d-8f17-48f6-82a8-a46f43f5cb9f">
        <source>getDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2024	navsp1	Initial creation JIRA 23326

*/
vars
	str, 
	detail, 
	defDetails 		: String;
	def				: CM_DataDumpExtractDef;
begin	
	str := inheritMethod();
	
	def := self.myDataDumpExtractDef;
	if def &lt;&gt; null then
		defDetails := "["&amp;def.description&amp;"]";
	endif;
	
	if self.extractType = self.Extract_Def_All then
		detail := app.getErrorString1(Extract_all_for_definition, defDetails);		//detail &amp; " Extract 'Full' for definition";
		
	elseif self.extractType = self.Extract_Def_Changes then
		detail := app.getErrorString1(Extract_changes_for_definition, defDetails);	//detail &amp; " Extract 'Changed' for definition";
		
	elseif self.extractType = self.Extract_Classes_All then
		detail := app.getErrorString1(Extract_all_selected_classes, defDetails);	//detail &amp; " Extract 'All' for selected classes";
		
	elseif self.extractType = self.Extract_Classes_Changed then
		detail := app.getErrorString1(Extract_change_selected_classe, defDetails);	//detail &amp; " Extract 'Changed' for selected classes";		
	
	endif;
	return str &amp; Tab &amp; detail;	
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRequestLimit" id="94afbfd0-5af3-4f68-89a3-b93bb47cc4b0">
        <source>getRequestLimit(): Integer;
//  par 27432 cnwjre1 July 2011 this was using the default limit of 50, limit it to 5 instead
vars

begin
	return 5;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="9372cf7e-dbe3-4afd-8e6d-ac973fb921cb">
        <updating/>
        <source>initRequestFromTask(_task: CM_AutoTaskExternalDB) updating;

// cnwdvb1 01 August 2003 

vars

begin

	self.myDataDumpExtractDef := _task.myDataDumpExtractDef;
	inheritMethod(_task);

end;</source>
        <Parameter name="_task" type="CM_AutoTaskExternalDB"/>
    </JadeMethod>
    <JadeMethod name="setExtraActivityHistory" id="8749a405-3bcb-411a-a99b-7c056e2be23a">
        <source>setExtraActivityHistory(_activityHistory: CM_ActivityHistoryGeneral input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2024	navsp1	Initial creation JIRA 23326

*/

vars

begin
	_activityHistory.setExtraDetail(app.getErrorString(Extract_request_initiated) &amp; Tab &amp; self.getDisplay().removeTabCrLfs);
epilog

end;</source>
        <Parameter name="_activityHistory" type="CM_ActivityHistoryGeneral" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="4573786a-d85e-419e-b535-aec7d0d9b0b5">
        <updating/>
        <source>setForCreate(_proxySelf: SelfType input; _def : CM_DataDumpExtractDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2024	navsp1	Initial creation JIRA 23326 (TFS Bug 65272)

*/

vars
	extClass : CM_DataDumpExtractClass;
begin
	self.myDataDumpExtractDef	:= _def;
	self.myUser					:= _proxySelf.myUser;
	self.myTerminal				:= _proxySelf.myTerminal;
	self.extractType 			:= _proxySelf.extractType;
	self.closeJournal			:= _proxySelf.closeJournal;
	if _proxySelf.allDataDumpExtractClasses.size &gt; 0 then
		foreach extClass in _proxySelf.allDataDumpExtractClasses do
			self.allDataDumpExtractClasses.add(extClass);
		endforeach;
	endif;
	
	self.initRequestEvent(true, false, null);
epilog

end;</source>
        <Parameter name="_proxySelf" type="SelfType" usage="input"/>
        <Parameter name="_def" type="CM_DataDumpExtractDef"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="47dcefd7-cef4-4bd0-a03f-cdf57fef3ca6">
        <updating/>
        <source>setProxy(_user : CM_User; _terminal : CM_Terminal; _extractType : String; _objArray : ObjectArray; _closeJournal : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2024	navsp1	Initial creation JIRA 23326 (TFS 65272)

*/

vars
	obj 		: Object;
	extClass 	: CM_DataDumpExtractClass;
begin
	self.myUser 				:= _user;
	self.myTerminal				:= _terminal;
	self.extractType			:= _extractType;
	self.closeJournal			:= _closeJournal;
	
	if _objArray &lt;&gt; null and (_extractType = self.Extract_Classes_All or _extractType = self.Extract_Classes_Changed) then
		foreach obj in _objArray do
			if (not CM_DataDumpExtractClass.hasInstance(obj)) then
				continue;
			endif;
			create extClass transient;
			extClass 	:= obj.CM_DataDumpExtractClass;
			self.allDataDumpExtractClasses.add(extClass);
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_extractType" type="String"/>
        <Parameter name="_objArray" type="ObjectArray"/>
        <Parameter name="_closeJournal" type="Boolean"/>
    </JadeMethod>
</Class>
