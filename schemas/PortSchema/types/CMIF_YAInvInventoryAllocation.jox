    <JadeMethod name="isSpecialStow_Match" id="c7992330-1538-4361-9533-d39951e26443">
        <source>isSpecialStow_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose:			

Date		Who		Reason
24MAY2021	NAVAB1	TFS 51219
*/

vars
	ti : CM_TrackedItem;
begin

	if _yaData.isEmpty() then
		return true;
	endif;
	
	ti := self.myLocationEvent.myTrackedItem;
	if ti = null then
		return false;
	endif;
	
	if _yaData.matches(ti.getSpecialStow()) then
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
