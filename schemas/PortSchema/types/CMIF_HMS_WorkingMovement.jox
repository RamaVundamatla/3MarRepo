    <JadeMethod name="init_MarineServOrderLocations" id="b7adfcbe-f90d-4acc-ac9b-af2933f55002">
        <updating/>
        <source>init_MarineServOrderLocations(pLaunchLocation: Integer io; tugsLocation: Integer io) updating;

vars
   move : CMIF_HMS_WorkingMovement;
begin
	// Returns initialise value for 'MARINE SERVICES ORDER LOCATIONS'
	if self.moveType=HMSMovementTypeArrival then
		pLaunchLocation:=AlongSide;
		tugsLocation:=OnStation;
	elseif self.moveType=HMSMovementTypeShift then
		move := self.getMovementPrevious;
		if move &lt;&gt; null and move.myBerth.noMarineServices = true then
			pLaunchLocation:=AlongSide;
			tugsLocation:=OnStation;
		else
			pLaunchLocation:=AlongSide;
			tugsLocation:=AlongSide;
		endif;
	elseif self.moveType=HMSMovementTypeDeparture then
		pLaunchLocation:=OnStation;
		tugsLocation:=AlongSide;
	endif;
end;</source>
        <Parameter name="pLaunchLocation" type="Integer" usage="io"/>
        <Parameter name="tugsLocation" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="init_MarineServOrderTimes" id="d178f564-3171-446b-96af-88ce13c75a83">
        <source>init_MarineServOrderTimes(timePilot, timeTugs, timeLines : Integer output);

vars
    movePrev : CMIF_HMS_WorkingMovement;
begin
	// Returns initialise value for 'MARINE SERVICES ORDER TIMES'
	if self.moveType = HMSMovementTypeShift then
		movePrev := self.getMovementPrevious;
	endif;
	
	if movePrev &lt;&gt; null then
		self.myHarbour.getOrderTimesForMoveType(self.moveType, movePrev.myBerth, self.myBerth, timePilot, timeTugs, timeLines);			
	else
		self.myHarbour.getOrderTimesForMoveType(self.moveType, null, null, timePilot, timeTugs, timeLines);					
	endif;
	
/*	if moveType=HMSMovementTypeArrival then
		timeLines:=myHarbour.defaultOrderTimesArrive[1];
		timePilot:=myHarbour.defaultOrderTimesArrive[2];
		timeTugs:=myHarbour.defaultOrderTimesArrive[3];
	elseif moveType=HMSMovementTypeShift then
		movePrev := self.getMovementPrevious;
		if movePrev &lt;&gt; null then
			if movePrev.myBerth.noMarineServices = true and 
				self.myBerth.noMarineServices = false then
				timeLines:=myHarbour.defaultOrderTimesArrive[1]; //Eg Anchorage to port
				timePilot:=myHarbour.defaultOrderTimesArrive[2];	//Treat as arrival
				timeTugs:=myHarbour.defaultOrderTimesArrive[3];
			elseif movePrev.myBerth.noMarineServices = false and 
				self.myBerth.noMarineServices = true then
				timeLines:=myHarbour.defaultOrderTimesDepart[1];	//Eg port to anchorage
				timePilot:=myHarbour.defaultOrderTimesDepart[2];//Treat as departure
				timeTugs:=myHarbour.defaultOrderTimesDepart[3];
			else
				timeLines:=myHarbour.defaultOrderTimesShift[1];
				timeTugs:=myHarbour.defaultOrderTimesShift[2];
			endif;
		else
			timeLines:=myHarbour.defaultOrderTimesShift[1];
			timeTugs:=myHarbour.defaultOrderTimesShift[2];
		endif;
	elseif moveType=HMSMovementTypeDeparture then
		timeLines:=myHarbour.defaultOrderTimesDepart[1];
		timePilot:=myHarbour.defaultOrderTimesDepart[2];
		timeTugs:=myHarbour.defaultOrderTimesDepart[3];
	endif;
	*/
end;</source>
        <Parameter name="timePilot" type="Integer" usage="output"/>
        <Parameter name="timeTugs" type="Integer" usage="output"/>
        <Parameter name="timeLines" type="Integer" usage="output"/>
    </JadeMethod>
