	self.tblItems02.cellControl.TextBox.case := TextBox.Case_Upper;
	self.tblItems03.cellControl.TextBox.case := TextBox.Case_Upper;
	self.tblItems04.cellControl.TextBox.case := TextBox.Case_Upper;
	self.tblItems05.cellControl.TextBox.case := TextBox.Case_Upper;
	self.tblItems06.cellControl.TextBox.case := TextBox.Case_Upper;					
	
	self.tblItems01.maxLength := 20;
