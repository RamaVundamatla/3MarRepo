    <JadeMethod name="setHeaderReferences" id="47e98050-a05a-443a-a59b-a8c6286cace3">
        <source>setHeaderReferences(_headerReferences : CMIF_JsonHeaderReferenceArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2023	navra1	Initial creation for 57074 - "EUP - Manifest EDI Operations / Load (EDI Controller Agent)/Task - 
														Task - 58270 - "57074 Load Rail Manifest Message"

*/

vars
	nameValuePair 	: CMIF_JsonHeaderReferenceEUP;
	pair			: CM_NameValuePair;	
	paird			: CM_NameValuePairDict;	
	
begin
	if _headerReferences = null then
		return;
	endif;
	
	foreach nameValuePair in _headerReferences do		
		create pair persistent;
		pair.createNewPair(nameValuePair.referenceName, nameValuePair.referenceValue);	
		self.allHeaderReferences.add(pair);		
	endforeach;
epilog

end;</source>
        <Parameter name="_headerReferences" type="CMIF_JsonHeaderReferenceArray"/>
    </JadeMethod>
