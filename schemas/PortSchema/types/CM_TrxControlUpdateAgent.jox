/*

Date		Who		Reason
09 May 2017	cnwer1	Initial creation TFS TFS TFS 995 moved from MobileServerSchema::CM_TrxControlRTAgent::trxPickupWithTaskNoMediator

*/

vars

begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);
	
	if _machine = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Machine is null.', null, null);
	endif;

	/*if _passport.userCode = "CNWER1" then
		app.raiseCMWarning(CM_WARNING,null,null,null);
		return;
	endif;*/
	
	
	if _passport.hasErrors() then
		return;
	endif;
	

	beginTransaction;
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	
	app.myUtilityUA.utlMachinePickupTask(_machine,null,_quantity,_weight);	
			
	_passport.doDeferredUpdates();

	
epilog

