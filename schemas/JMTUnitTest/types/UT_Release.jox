    <JadeMethod name="tAssignReleaseToRail" id="412a4419-e194-4ba7-880d-b67d95a30dbe">
        <source>tAssignReleaseToRail();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
16 November 2022		jlizm1	Initial creation TFS 54118 Assigning Releases to Wagons
14 February 2025        navbk1  CR 33829: EUP | Completing Any Amount Rail jobs with "Done" button

*/
constants

	VOY_CODE 		: String = "UTZVOY1";
	VES_CODE 		: String = "UTZVES1";
	REL_ID			: String = "UTZR221102";
	REL_ID2			: String = "UTZR221102B";
	TRAIN_CODE 		: String = "UT-TRAIND2";
	WAGON_CODE 		: String = "BO22111";
	WAGON_CODE2 	: String = "BO22112";
	RAIL_AREA_ID 	: String = "ZRA001";
	BBCargoType 	: String = "UTREBAR"; 	// Pre existing Break Bulk cargo type allows duplicates
	BULKCargoType 	: String = "UTDRBULK";	// new bulk cargo type for test
	BSTACKID		: String = "BS54118";
	TIID1			: String = "ZMBB2210031";
	TIID2			: String = "ZMBB2210032";
	TIID3			: String = "ZMBK2210033";
	TOTAL_Q			: Integer = 100;
	REQ_Q			: Integer = 10;
	SPLIT1_Q		: Integer = 7;
	SPLIT2_Q		: Integer = 3;
	TOTAL_W			: Integer = 100;
	REQ_W			: Integer = 10;
	SPLIT1_W		: Integer = 6;
	SPLIT2_W		: Integer = 4;
	
vars

	originalConfig	: Boolean;
	now 			: TimeStamp;
	wagon 			: CM_Wagon;
	wagon2 			: CM_Wagon;
	train 			: CM_Train;
	pxyTrain		: CM_Train;
	railArea 		: CM_Rail;
	railLine 		: CM_RailLine;
	operator		: CM_Operator;
	shipLineStr 	: String;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	bbCargoType 	: CM_CargoType;
	bulkCargoType 	: CM_CargoType;
	releaseRequest1 : CM_BulkRelease;
	releaseRequest2 : CM_BulkRelease;
	cmifObjects 	: ObjectArray;
	intFaceBP 		: CMIF_BuildPriority;
	cmifRequest 	: CMIF_Request;
	railIORake 		: CM_RailJSInOutRake;
	obj 			: Object;
	bs				: CM_BlockStack;
	ti1				: CM_TrackedItem;
	ti2				: CM_TrackedItem;
	ti3				: CM_TrackedItem;
	agent 			: CM_RailProcessingAgent;
	wagonArray		: CM_WagonArray;
	wleArray		: CM_WLEArray;
	testingWleArray1: CM_WLEArray;
	testingWleArray2: CM_WLEArray;
	resDet1			: CM_ReserveDetail;
	resDet2			: CM_ReserveDetail;
	wle 			: CM_WorkListEntry;
	request1		: CM_Request;
	request2		: CM_Request;
	count			: Integer;
	completeCount	: Integer;
	lc				: CM_LocationsController;
	moveController	: CMIF_MoveController;
	cmifToDepartTrain : CMIF_RakeRegion;
	
begin
	// Save terminal config so it can be reset later
	originalConfig := self.getTerminalConfig(RailReleaseAssignEnhance).Boolean;
	self.setTerminalConfig(RailReleaseAssignEnhance, true);
	
	// Get Base Data
	self.opts.purge();
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	bulkCargoType := addCargoType(BULKCargoType, false);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	
	bbCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BBCargoType);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "Cargo Type '" &amp; BBCargoType &amp; "' not found during setup.");
	
	//**********
	// CLEANUP
	//**********
	self.cleanUpRail(WAGON_CODE, WAGON_CODE2, TRAIN_CODE, RAIL_AREA_ID); 
	self.assertNullMsg(getTerminalArea(RAIL_AREA_ID), "Railway track");
	self.deleteVoyage(VOY_CODE);
	self.deleteVessel(VES_CODE);
	self.deleteReleaseRequest(REL_ID);
	self.deleteReleaseRequest(REL_ID2);
	self.deleteTerminalArea(BSTACKID);
	self.deleteCargo(TIID1, bbCargoType);
	self.deleteCargo(TIID2, bbCargoType);
	self.deleteCargo(TIID3, bulkCargoType);
	
	//***************************
	// Setup
	//***************************
	//Create Rail area and then arrive a Train with no cargo.
	train := self.addTrain(TRAIN_CODE, null);
	self.assertTrueMsg(train &lt;&gt; null,"Train not created. ");
	
	railArea :=	self.addRailArea(RAIL_AREA_ID, 4, 5);
	self.assertTrueMsg(railArea &lt;&gt; null,"Rail Area not created. ");
	
	railLine :=	railArea.allRailLinesByIndex[1];
	self.assertTrueMsg(railLine &lt;&gt; null,"Rail line not found. ");
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	self.assertTrueMsg(railIORake &lt;&gt; null, "Failed to set up Rail Rake");
	
	wagon := self.addWagonInRailArea(WAGON_CODE, WAGON_CODE[1:2], railArea, train);
	self.assertTrueMsg(wagon &lt;&gt; null,"Wagon not created. ");
	
	wagon2 := self.addWagonInRailArea(WAGON_CODE2, WAGON_CODE2[1:2], railArea, train);
	self.assertTrueMsg(wagon2 &lt;&gt; null,"Wagon2 not created. ");
	
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	pxyTrain.setProxyDetails(now);
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"Arrive Train failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWagonPosition(railLine, wagon, 1, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"Set Wagon position failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWagonPosition(railLine, wagon2, 2, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"Set Wagon2 position failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK,"Wagon confirm in failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	// Set up voyage
	vessel := self.addVesselGeneralCargo(VES_CODE, operator, 10);
	self.assertNotNullMsg(vessel, 'vessel');
	voyage := self.addVoyageWithGeneralCargoStruc(VOY_CODE, VES_CODE, operator.code, shipLineStr, 0);
	self.assertNotNullMsg(voyage, 'voyage');
	
	// Create Release Request
	self.opts.purge();
	self.opts.addAssoc( "number", 10.Integer);
	self.opts.addAssoc( "FullRelease", true );  // otherwise it defaults to empties only
	self.opts.addAssoc( "Voyage", voyage );
	releaseRequest1 := self.addReleaseByTypeRequestOpts(REL_ID, BR_TYPE_RAIL, bbCargoType.id);
	self.assertTrueMsg(releaseRequest1 &lt;&gt; null, "Failed to set up Rail Release 1");
	
	self.opts.purge();
	self.opts.addAssoc( "weightRequested", 10.Decimal);
	self.opts.addAssoc( "FullRelease", true );  // otherwise it defaults to empties only
	self.opts.addAssoc( "Voyage", voyage );
	releaseRequest2 := self.addReleaseByTypeRequestOpts(REL_ID2, BR_TYPE_RAIL, bulkCargoType.id);
	self.assertTrueMsg(releaseRequest2 &lt;&gt; null, "Failed to set up Rail Release 2");
	
	// Assign release request 1
	create cmifObjects transient;
	create intFaceBP transient;
	cmifObjects.add(intFaceBP);
	intFaceBP.mode := 1;
	releaseRequest1.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	releaseRequest1.setInterfaceBP(intFaceBP, railIORake);
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNull(cmifRequest);
	cmifRequest.isAnyAmount := true;
	cmifRequest.quantityTxt := 1;
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach obj in cmifObjects do
		intFaceBP := obj.CMIF_BuildPriority;
		delete intFaceBP.myProxyRailJob;
		intFaceBP.allCMIFRequests.purge;
		delete intFaceBP;
	endforeach;
	cmifObjects.purge;
	delete cmifObjects;
	
	// Assign release request 2
	create cmifObjects transient;
	create intFaceBP transient;
	cmifObjects.add(intFaceBP);
	intFaceBP.mode := 1;
	releaseRequest2.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	releaseRequest2.setInterfaceBP(intFaceBP, railIORake);
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNull(cmifRequest);
	cmifRequest.isAnyAmount := true;
	cmifRequest.weight := 10;
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach obj in cmifObjects do
		intFaceBP := obj.CMIF_BuildPriority;
		delete intFaceBP.myProxyRailJob;
		intFaceBP.allCMIFRequests.purge;
		delete intFaceBP;
	endforeach;
	cmifObjects.purge;
	delete cmifObjects;
	
	// Create onsite cargo for the request/moves
	bs := self.addBlockStack(BSTACKID, 32, null);
	ti1 := self.addCargoAtLocation(TIID1, bbCargoType, operator, bs.myLocationsController);
	ti2	:= self.addCargoAtLocation(TIID2, bbCargoType, operator, bs.myLocationsController);
	ti3 := self.addCargoAtLocation(TIID3, bulkCargoType, operator, bs.myLocationsController);
	
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("TotalQuantity", 100);
	self.updateTI(ti1);
	self.updateTI(ti2);
	
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("TotalWeight", 100);
	self.updateTI(ti3);
	
	// Assign release details to wagons
	create wagonArray transient;
	wagonArray.add(wagon);
	wagonArray.add(wagon2);
	
	resDet1 := releaseRequest1.allReserveDetails.first();
	self.assertNotNullMsg(resDet1, "Reserve Detail 1");
	request1 := resDet1.allDeliveryRequests.first();
	self.assertNotNullMsg(request1, "Delivery Request 1");
	wle := request1.allWorkListEntries.first();
	self.assertNotNullMsg(wle, "Initial Rail WLE 1");
	
	create wleArray transient;
	create agent transient;
	
	wleArray.add(wle);
	agent.initialise(self.getTerminal);
	agent.doAssignReleasesToWagons( wleArray, wagonArray, false, false );
	delete agent;
	delete wleArray;
	
	resDet2 := releaseRequest2.allReserveDetails.first();
	self.assertNotNullMsg(resDet2, "Reserve Detail 2");
	request2 := resDet2.allDeliveryRequests.first();
	self.assertNotNullMsg(request2, "Delivery Request 2");
	wle := request2.allWorkListEntries.first();
	self.assertNotNullMsg(wle, "Initial Rail WLE 2");
	
	create wleArray transient;
	create agent transient;
	
	wleArray.add(wle);
	agent.initialise(self.getTerminal);
	agent.doAssignReleasesToWagons( wleArray, wagonArray, false, false );
	delete agent;
	delete wleArray;
	
	// Test Wles have been created as expected
	foreach wle in request1.allWorkListEntries do
		count := count + 1;
		self.assertTrueMsg(wle.isAnyAmount, "assigned wle " &amp; count.asStringJMT() &amp; " should be any amount");
		self.assertEqualMsg(wle.status, WLE_UNACTIONED, "assigned wle " &amp; count.asStringJMT() &amp; " should be unacitoned");
	endforeach;
	
	foreach wle in request2.allWorkListEntries do
		count := count + 1;
		self.assertTrueMsg(wle.isAnyAmount, "assigned wle " &amp; count.asStringJMT() &amp; " should be any amount");
		self.assertEqualMsg(wle.status, WLE_UNACTIONED, "assigned wle " &amp; count.asStringJMT() &amp; " should be unacitoned");
	endforeach;
	
	// load part of cargo 1 to wagon 1
	wle := wagon.getWLEforCargo(ti1 ,resDet1);
	lc := wagon.getNextFreeWagonContForWLE(ti1, wle);
	create moveController transient;
	moveController.setMyWorkListEntry(wle);
	moveController.setMyToPrimaryLocation(lc);
	moveController.setMyTrackedItem(ti1);
	moveController.setQuantity( SPLIT1_Q);
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Failed to load wagon");
	delete moveController;
	
	// load rest of cargo 1 to wagon 2
	wle := wagon2.getWLEforCargo(ti1 ,resDet1);
	lc := wagon2.getNextFreeWagonContForWLE(ti1, wle);
	create moveController transient;
	moveController.setMyWorkListEntry(wle);
	moveController.setMyToPrimaryLocation(lc);
	moveController.setMyTrackedItem(ti1);
	moveController.setQuantity( SPLIT2_Q);
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Failed to load wagon");
	delete moveController;
	
	// load part of cargo 2 to wagon 1
	wle := wagon.getWLEforCargo(ti3 ,resDet2);
	lc := wagon.getNextFreeWagonContForWLE(ti3, wle);
	create moveController transient;
	moveController.setMyWorkListEntry(wle);
	moveController.setMyToPrimaryLocation(lc);
	moveController.setMyTrackedItem(ti3);
	moveController.setWeight( SPLIT1_W);
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Failed to load wagon");
	delete moveController;
	
	// load rest of cargo 2 to wagon 2
	wle := wagon2.getWLEforCargo(ti3 ,resDet2);
	lc := wagon2.getNextFreeWagonContForWLE(ti3, wle);
	create moveController transient;
	moveController.setMyWorkListEntry(wle);
	moveController.setMyToPrimaryLocation(lc);
	moveController.setMyTrackedItem(ti3);
	moveController.setWeight( SPLIT2_W);
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Failed to load wagon");
	delete moveController;

	// Test Wles have been completed as expected
	count := 0;
	completeCount := 0;
	
	foreach wle in request1.allWorkListEntries do
		count := count + 1;
		if wle.status = WLE_COMPLETED then
			completeCount := completeCount + 1;
		else
			self.assertEqualMsg(wle.status, WLE_UNACTIONED, "assigned wle " &amp; count.asStringJMT() &amp; " should not be anything other than complete or unactioned");
		endif;
	endforeach;
	
	self.assertEqualMsg(completeCount, 2, "request 1 should have 2 completed wles after loading");
	
	count := 0;
	completeCount := 0;
	
	foreach wle in request2.allWorkListEntries do
		count := count + 1;
		if wle.status = WLE_COMPLETED then
			completeCount := completeCount + 1;
		else
			self.assertEqualMsg(wle.status, WLE_UNACTIONED, "assigned wle " &amp; count.asStringJMT() &amp; " should not be anything other than complete or unactioned");
		endif;
	endforeach;
	
	self.assertEqualMsg(completeCount, 2, "request 2 should have 2 completed wles after loading");
	
	// Complete wagon load
	self.assertFalseMsg(wagon.hasCompletedLoading, "Wagon 1 should not have completed loading yet");
	self.assertFalseMsg(wagon2.hasCompletedLoading, "Wagon 2 should not have completed loading yet");
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWagonLoadComplete(wagon, true, app.myPassport);																		//14.02.2025 navbk1 #33829
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Failed to complete wagon");
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateWagonLoadComplete(wagon2, false, app.myPassport);																		//14.02.2025 navbk1 #33829
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Failed to complete wagon");
	
	self.assertTrueMsg(wagon.hasCompletedLoading, "Wagon 1 should have completed loading");
	//self.assertTrueMsg(wagon2.hasCompletedLoading, "Wagon 2 should have completed loading");													//14.02.2025 navbk1 #33829
	self.assertTrueMsg(wagon2.getLastTransactionOfType(EVT_WagonLoadComplete) = null, "Wagon 2 should not record Load complete transaction");	//14.02.2025 navbk1 #33829	
	
	foreach wle in request1.allWorkListEntries do
		self.assertEqualMsg(wle.status, WLE_COMPLETED, "assigned wle " &amp; count.asStringJMT() &amp; " should be complete");
	endforeach;
	
	self.assertEqualMsg(request1.allWorkListEntries.size, 2, "request 1 should have 2 wles after completing wagon");
	
	foreach wle in request2.allWorkListEntries do
		self.assertEqualMsg(wle.status, WLE_COMPLETED, "assigned wle " &amp; count.asStringJMT() &amp; " should be complete");
	endforeach;
	
	self.assertEqualMsg(request2.allWorkListEntries.size, 2, "request 2 should have 2 wles after completing wagon");

	// Depart the Train.
	self.ignoreTrxWarnings(true);
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), "Failed to confirm train. " &amp; app.myPassport.getAllErrorsWarningsAsString());

	create cmifToDepartTrain transient;	
	cmifToDepartTrain.myTrain := train;
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateRailClearRake(cmifToDepartTrain, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), "Failed to clear rake. " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	
	// Cargo should now be offsite, an release requests completed
	ti1 := wagon.allTIsReleased.first;
	ti2 := wagon.allTIsReleased.last;
	self.assertEqualMsg(wagon.allTIsReleased.size, 2, "wagon1  has more cargo loaded than expected");
	self.assertTrueMsg(ti1.site = TI_SITE_OFFSITE, ti1.id &amp; " should be offsite after departure!");
	self.assertTrueMsg(ti1.getTransRelease() &lt;&gt; null, ti1.id &amp; " no release trnsaction");
	self.checkTIForTxnOfType(ti1, TRANS_TYPE_REL_RAIL);
	
	self.assertEqualMsg(releaseRequest1.status, BR_COMPLETE, "release request 1 should be complete");
	self.assertEqualMsg(releaseRequest2.status, BR_COMPLETE, "release request 1 should be complete");
	
	
	// Clean up after ourselves
	self.cleanUpRail(WAGON_CODE, WAGON_CODE2, TRAIN_CODE, RAIL_AREA_ID); 
	self.assertNullMsg(getTerminalArea(RAIL_AREA_ID), "Railway track");
	self.deleteVoyage(VOY_CODE);
	self.deleteVessel(VES_CODE);
	self.deleteReleaseRequest(REL_ID);
	self.deleteReleaseRequest(REL_ID2);
	self.deleteTerminalArea(BSTACKID);
	self.deleteCargo(TIID1, bbCargoType);
	self.deleteCargo(TIID2, bbCargoType);
	self.deleteCargo(TIID3, bulkCargoType);

epilog

	if process.isInTransactionState then
		abortTransaction;
	endif;
	
	self.setTerminalConfig(RailReleaseAssignEnhance, originalConfig);
	
	if cmifObjects &lt;&gt; null then
		foreach obj in cmifObjects do
			intFaceBP := obj.CMIF_BuildPriority;
			delete intFaceBP.myProxyRailJob;
			intFaceBP.allCMIFRequests.purge;
			delete intFaceBP;
		endforeach;
		cmifObjects.purge;
	endif;
	delete cmifObjects;
	delete pxyTrain;
	delete agent;
	delete wagonArray;
	delete wleArray;
	delete testingWleArray1;
	delete testingWleArray2;
	delete moveController;
	delete cmifToDepartTrain;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAssignShipRRToVoyageJobRORO" id="2517e7aa-057e-440e-ad3c-45613a615c28">
        <updating/>
        <source>tAssignShipRRToVoyageJobRORO() updating;

/*

Purpose:		Check that assigning a Ship Release Request for 40ft's doesn't cause error 87529 to occur

Date			Who		Reason
23/04/2013		cnwmh5	Initial creation - currently not implemented as trx called has tranisent leaks
20/02/2014		cnwmh5	Comment out transient leak section
						Include the following trxs:
						
						trxUpdateROROVesselDecksOrd					Done
						trxUpdateSlotDefnsAttribute					Done
						trxUpdateSlotDefn							Done
						trxDeleteVoyageAllocation					Done
						trxDeleteVoyageJobs							Done
						trxUpdateVoyageJobUnplan					Done
						trxUpdateWLEsUnassignTI						Done
						trxUpdateSlotRequestDirection				Done
						trxUpdateSlotRequestSeqNum					Done
						trxUpdateVoyageJobUnassignTI				Done
						trxShiftJobinJobSheet						Done
						trxUpdateWLEStatus							Done
						trxUpdateWLESeqd							Done
						trxUpdateWLEAutoplan						Done					
										
*/

constants

	VesselId						: String = "Jolly Grigio OFFICIAL";
	NewVesselId						: String = "UTMESGRIG";
	VoyageId						: String = "VOYSHIP31460";
	RORO40ft						: String = "31460RORO40";
	RORO20ft						: String = "31460RORO20";
	RORO40ftMixed					: String = "31460RORO40Mixed";
	RORO20ftMixed					: String = "31460RORO20Mixed";
	
vars
	
	oldVessel						: CM_Vessel;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	operator						: CM_Operator;
	deck							: CM_DeckVoyage;
	roroStructure 					: CM_ROROVoyageStructure;
	dischargePort 					: CM_Port;
	releaseRequest					: CM_BulkRelease;
	bs								: CM_BlockStack;
	job								: CM_VoyageJob;
	wle								: CM_VoyageWLE;
	
	slotsToLoadCC					: StringArray;
	slotsToLoad						: CM_LCArray;
	lcs								: CM_LCArray;
	jobsToDelete					: StringArray;
	jobSet							: CM_VoyageJobSet;
	
begin

	self.setTerminalConfig(AllowRTSwithoutVGM, true);					// 10/06/2016 cnwmh5

	// initialisations
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString];
	self.assertNotNull(operator);
	
	dischargePort := app.myRoot.allPorts["NZAKL"];
	self.assertNotNull(dischargePort);

	// create block stack
	bs := self.addBlockStack("UTMHM1", 50, null);
	self.assertNoTrxErrorsOrWarnings();
	
	create slotsToLoadCC transient;
	create slotsToLoad transient;
	
	// delete voyage
	self.deleteVoyage(VoyageId);
	
	// delete cloned vessel
	self.deleteVessel(NewVesselId);
	
	// clone vessel
	oldVessel := app.myRoot.getVesselByName(VesselId);
	self.assertNotNull(oldVessel);
	
	// clone the vessel
	vessel := self.cloneVessel(NewVesselId, oldVessel);
	self.assertNotNull(vessel);
	
	// update the deck ordinals
	self.xUpdateSlotOrdinals(vessel);
	
	// create a voyage
	voyage := self.addVoyageWithConRORO(VoyageId, NewVesselId, "UTOP", self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNull(voyage);
	
	// update slot attributes
	self.xUpdateSlotAttributesDefn(voyage);
	
	// create the voyage
	self.deleteVoyage(VoyageId);
	voyage := self.getVoyage(VoyageId);
	self.assertIsDeleted(voyage);
	voyage := self.addVoyageWithConRORO(VoyageId, NewVesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, "Unit Test Trade", 0, false, true);
	self.assertNotNull(voyage);

	roroStructure := voyage.myROROStructure;
	self.assertNotNull(roroStructure);
	
	deck := roroStructure.allDecksByCode["2"];
	self.assertNotNull(deck);
	
	// Create 40ft Release Request - RORO
	
	self.opts.purge();
	self.opts.addAssoc("ISOType", "U40G");
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Number", 6);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("DischargePort", dischargePort);
	self.x31460CreateReleaseRequest(RORO40ft, voyage, releaseRequest);
	
	// colour code, select cells and put into a job
	
	slotsToLoad.clear();
	slotsToLoadCC.clear();
	slotsToLoadCC.add("D20491");
	slotsToLoadCC.add("D20501");
	slotsToLoadCC.add("D20511");
	slotsToLoadCC.add("D20492");
	slotsToLoadCC.add("D20502");
	slotsToLoadCC.add("D20512");
	self.x31460CCSelectPutInJob("UT_31460JobR40","U40G", voyage, deck, slotsToLoadCC, slotsToLoad);
	
	// assign the release request to the slots
	
	slotsToLoadCC.clear();
	slotsToLoadCC.add("D20441");
	slotsToLoadCC.add("D20442");
	slotsToLoadCC.add("D20451");
	slotsToLoadCC.add("D20452");
	slotsToLoadCC.add("D20461");
	slotsToLoadCC.add("D20462");
	
	// 20/02/2014 cnwmh5 - Major Leaks which need to be fixed - Commenting out until investigated
	//self.x31460AssignRRToSlots(slotsToLoadCC, releaseRequest, voyage, deck, slotsToLoad);
	
	// Create 20ft Release Request - RORO
	
	self.opts.purge();
	self.opts.addAssoc("ISOType", "U20G");
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Number", 6);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("DischargePort", dischargePort);
	self.x31460CreateReleaseRequest(RORO20ft, voyage, releaseRequest);
	
	// colour code, select cells and put into a job
	
	slotsToLoad.clear();
	slotsToLoadCC.clear();
	slotsToLoadCC.add("D20551");
	slotsToLoadCC.add("D20552");
	slotsToLoadCC.add("D20601");
	slotsToLoadCC.add("D20602");
	slotsToLoadCC.add("D20611");
	slotsToLoadCC.add("D20612");
	self.x31460CCSelectPutInJob("UT_31460JobR20", "U20G", voyage, deck, slotsToLoadCC, slotsToLoad);
	
	// 20/02/2014 cnwmh5 - Major Leaks which need to be fixed - Commenting out until investigated
	/*
	slotsToLoadCC.clear();
	self.x31460AssignRRToSlots(slotsToLoadCC, releaseRequest, voyage, deck, slotsToLoad);
	*/
	
	// delete voyage allocation - trxDeleteVoyageAllocation
	
	self.xDeleteVoyageAllocation(voyage);
		
	
	create jobSet transient;
	self.xCreateLoadContsLoadToOps(voyage, jobSet, bs);
	
	
	self.xChangeSlotReqDoorDirection(voyage);
	
	
	job := jobSet.last;
	self.xMoveLastJobUp(voyage, job);
	
	
	self.xRebuildJobWLEStatus(job);
	
	
	self.xUnplanLoadSlots(voyage, jobSet);
	
	
	job := jobSet.last;
	self.xreSequenceSlotRequests(job);
	
	self.xDeleteVoyageJobs(voyage, jobSet);
	
	
	jobSet.clear();
	self.xCreateDischContsCCAddToJob(voyage, jobSet);
	
	
	wle := jobSet.first.workListEntries.first.CM_VoyageWLE;
	self.assertNotNull(wle);
	app.myTrxUA.trxUpdateWLEAutoplan(wle, PLANNING_MODE, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(wle.myTrackedItem.myPrimaryPlannedLocation);
		
epilog

	delete slotsToLoadCC;
	delete slotsToLoad;
	delete jobsToDelete;
	delete lcs;
	delete jobSet;

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Fails1006&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;WorkPointDeleteIssue&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
