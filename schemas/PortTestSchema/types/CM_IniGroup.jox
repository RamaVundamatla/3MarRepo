<Class name="CM_IniGroup" id="8dea1ef7-6902-4bd3-b664-b03d2ff6025b">
    <superclass name="CM_IniObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="planning"/>
    <ExplicitInverseRef name="allIniItems" id="f968f5c4-08c8-40d1-a46e-519cb6cf1497">
        <updateMode>automatic</updateMode>
        <type name="CM_IniObjectDict"/>
        <Inverse name="CM_IniItem::myIniGroup"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myIniFile" id="cb0e0bf1-7fa4-486e-84ea-aa20f886389c">
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_IniFile"/>
        <Inverse name="CM_IniFile::allIniGroups"/>
    </ExplicitInverseRef>
</Class>
