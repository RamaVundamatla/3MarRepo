    <JadeMethod name="filterObjects" id="7932efed-0713-4136-8b5a-9958dc5631fb">
        <updating/>
        <source>filterObjects(_chkScaleDtlDict : CM_LogCheckScaleByLogIdDict input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     16 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	checkScaleHdr			: CM_LogCheckScaleHdr;
	iter					: Iterator;
	terminal				: CM_Terminal;
	scaleHdrDict			: CM_LogChkScaleHdrByDTNoDict;
	breakOut				: Boolean;
begin
	foreach terminal in self.allTerminals do
		
		if self.batchNo &lt;&gt; null then
			checkScaleHdr := terminal.allLogChkScaleByBatchNo[self.batchNo];
			if checkScaleHdr &lt;&gt; null then
				self.handleCheckScaleHdr(checkScaleHdr, _chkScaleDtlDict, _passport, breakOut);
			endif;
			
			return;
		endif;
		
		scaleHdrDict := terminal.allLogChkScaleByDt;
		delete iter;			// PAR #26678
		iter := scaleHdrDict.createIterator();
		if self.fromDate.isValid then
			scaleHdrDict.startKeyGeq(self.fromDate.TimeStamp, null, iter);
		endif;
		
		while iter.next(checkScaleHdr) do
			if checkScaleHdr.dateTime.date &gt; self.toDate then
				break;
			endif;
		
			self.handleCheckScaleHdr(checkScaleHdr, _chkScaleDtlDict, _passport, breakOut);
			if breakOut then
				break;
			endif;
		endwhile;
	endforeach;	

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_chkScaleDtlDict" type="CM_LogCheckScaleByLogIdDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a3e6e070-0434-4874-820b-066e46914026">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate : Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
vars
	oid : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
/*
	if _attrName = ETRow_BatchNo then
		return self.batchNo.String;
	
	elseif _attrName = ETRow_ScalerCode then
		if self.checkScalerCode &lt;&gt; null then
			return self.checkScalerCode;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_LogGrade then
		if self.gradeCode &lt;&gt; null then
			return self.gradeCode;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_LogLength then
		if self.lengthCode &lt;&gt; null then
			return self.lengthCode;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_OperatorCode then
		if self.operatorCode &lt;&gt; null then
			return self.operatorCode;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_OrigScaler then
		if self.scalerCode &lt;&gt; null then
			return self.scalerCode;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_LogSpecies then
		if self.speciesCode &lt;&gt; null then
			return self.speciesCode;
		else
			return Any_String;
		endif;

	elseif _attrName = ETRow_LogTreatment then
		if self.treatmentCode &lt;&gt; null then
			return self.treatmentCode;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_LogType then
		if self.typeCode &lt;&gt; null then
			return self.typeCode;
		else
			return Any_String;
		endif;
		
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate);
*/

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="de3d2108-b658-4dc7-8a04-2e5477424e80">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate : Boolean; _oid : String output): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
vars

begin
	if _attrName = ETRow_BatchNo then
		return self.batchNo.String;
	
	elseif _attrName = ETRow_ScalerCode then
		if self.checkScalerCode &lt;&gt; null then
			return self.checkScalerCode;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_LogGrade then
		if self.gradeCode &lt;&gt; null then
			return self.gradeCode;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_LogLength then
		if self.lengthCode &lt;&gt; null then
			return self.lengthCode;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_OperatorCode then
		if self.operatorCode &lt;&gt; null then
			return self.operatorCode;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_OrigScaler then
		if self.scalerCode &lt;&gt; null then
			return self.scalerCode;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_LogSpecies then
		if self.speciesCode &lt;&gt; null then
			return self.speciesCode;
		else
			return Any_String;
		endif;

	elseif _attrName = ETRow_LogTreatment then
		if self.treatmentCode &lt;&gt; null then
			return self.treatmentCode;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_LogType then
		if self.typeCode &lt;&gt; null then
			return self.typeCode;
		else
			return Any_String;
		endif;
		
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleCheckScaleDtl" id="221ec030-eaa1-41e7-94b4-83f2e42eda82">
        <source>handleCheckScaleDtl(_scaleDtl : CM_LogCheckScaleDtl; 
					_chkScaleDtlDict : CM_LogCheckScaleByLogIdDict input;
					_passport : CM_Passport;
					_breakOut : Boolean output) protected;
// ---------------------------------------------------------------------------
// Created:     15 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	op			 		: CM_Operator;
	querySelf			: CMQF_LogCheckScaling;
	breakOut			: Boolean;
	failedDAC  :CM_DataAccessController;

begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	
	querySelf.checkStatusIncludesObject(null, _passport, breakOut);
	
	
	if (querySelf.scalerCode &lt;&gt; null and _scaleDtl.scalerCode &lt;&gt; querySelf.scalerCode) or
	   (querySelf.operatorCode &lt;&gt; null and _scaleDtl.operatorCode &lt;&gt; querySelf.operatorCode) or
	   (querySelf.speciesCode &lt;&gt; null and _scaleDtl.speciesCode &lt;&gt; querySelf.speciesCode) or
	   (querySelf.gradeCode &lt;&gt; null and _scaleDtl.gradeCode &lt;&gt; querySelf.gradeCode) or
	   (querySelf.typeCode &lt;&gt; null and _scaleDtl.typeCode &lt;&gt; querySelf.typeCode) or
	   (querySelf.treatmentCode &lt;&gt; null and _scaleDtl.treatmentCode &lt;&gt; querySelf.treatmentCode) or
	   (querySelf.lengthCode &lt;&gt; null and _scaleDtl.lengthCode &lt;&gt; querySelf.lengthCode) then
		//(_scaleDtl.logSEDMean = 0) then //if null mean then it didn't find a log onsite - so don't include in report or it'll distort results
		return;
	endif;

	op := app.myRoot.allOperators[_scaleDtl.operatorCode];
	if (op &lt;&gt; null) and (not op.canUserAccessSelf(null, failedDAC,_passport)) then
		return;
	endif;
	
	querySelf.numFound := querySelf.numFound + 1;
	_chkScaleDtlDict.add(_scaleDtl);
	

end;</source>
        <access>protected</access>
        <Parameter name="_scaleDtl" type="CM_LogCheckScaleDtl"/>
        <Parameter name="_chkScaleDtlDict" type="CM_LogCheckScaleByLogIdDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleCheckScaleHdr" id="074addce-c818-4058-b48b-45d00870630f">
        <updating/>
        <source>handleCheckScaleHdr(_checkScaleHdr : CM_LogCheckScaleHdr; 
					_chkScaleDtlDict : CM_LogCheckScaleByLogIdDict input;
					_passport : CM_Passport;
					_breakOut : Boolean output) protected, updating;
// ---------------------------------------------------------------------------
// Created:     15 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	scaleDtl			: CM_LogCheckScaleDtl;
	querySelf			: CMQF_LogCheckScaling;
begin
	querySelf := self;

	if _checkScaleHdr = null then
		return;
	endif;
	
	if (querySelf.fromDate.isValid and (_checkScaleHdr.dateTime.date &lt; querySelf.fromDate)) or
	   (querySelf.toDate.isValid and (_checkScaleHdr.dateTime.date &gt; querySelf.toDate)) or
	   (querySelf.checkScalerCode &lt;&gt; null and _checkScaleHdr.userCode &lt;&gt; querySelf.checkScalerCode) or
	   (querySelf.batchNo &lt;&gt; null and _checkScaleHdr.batchNo &lt;&gt; querySelf. batchNo) then
	   	return;
	endif;

	
	foreach scaleDtl in _checkScaleHdr.allCheckScaleDtls discreteLock do
		querySelf.handleCheckScaleDtl(scaleDtl, _chkScaleDtlDict, _passport, _breakOut);
		if _breakOut then
			break;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_checkScaleHdr" type="CM_LogCheckScaleHdr"/>
        <Parameter name="_chkScaleDtlDict" type="CM_LogCheckScaleByLogIdDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
</Class>
