    <JadeMethod name="cmbCategory_click" id="b52df400-c5c5-4fa2-af37-2469e3b025ef">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCategory_click(combobox: ComboBox input) updating;
// --------------------------------------------------------------------------------
// Created:		03 April 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.populateGlobalConstants(lstConstants);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCategory_displayEntry" id="e212c0d0-80b2-4674-b569-1c3234468181">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCategory_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
// --------------------------------------------------------------------------------
// Created:		03 April 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
