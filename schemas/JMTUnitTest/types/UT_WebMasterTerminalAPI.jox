ExpectedJsonResponseUsingVoyageTC4In = '{"allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"arrivalDT":&lt;ArrivalDT&gt;,"cargoSummary":null,"departureDT":&lt;DepartureDT&gt;,"externalCode":"","id":"UT_GETVOYAGEUT4IN","inwardsCode":"","operatorId":"LAUR","portRotation":[{"id":"NZAKL","tranship":false},{"id":"NZNSN","tranship":false},{"id":"NZPOE","tranship":false},{"id":"DEBRV","tranship":false},{"id":"NZWLG","tranship":false},{"id":"AUBRI","tranship":false},{"id":"DEBRE","tranship":false},{"id":"JPADO","tranship":false},{"id":"AUSYD","tranship":false},{"id":"NZDUG","tranship":false},{"id":"DEHAM","tranship":false},{"id":"TWKHH","tranship":false},{"id":"SGSIN","tranship":false},{"id":"HKHKG","tranship":false},{"id":"NZBLU","tranship":false},{"id":"MYTPP","tranship":false},{"id":"AFBAG","tranship":false}],"remarks":"Created by unit test UT_WebMasterTerminalAPI::tGetVoyage","shippingLineId":"AAL","status":0,"tradeId":"Unit Test Trade","vessel":{"callSign":"","id":"UATVES35883","imo":"","loa":0,"name":"UATVES35883","operatorId":"LAUR"},"voyageType":{"holds":false,"lolo":true,"roro":false}}';
ExpectedJsonResponseUsingVoyageTC4InWMAST = ' {"allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"arrivalDT":&lt;ArrivalDT&gt;,"cargoSummary":null,"departureDT":&lt;DepartureDT&gt;,"externalCode":"","id":"UT_GETVOYAGEUT4IN","inwardsCode":"","operatorId":"LAUR","portRotation":[{"id":"NZAKL","tranship":false},{"id":"NZNSN","tranship":false},{"id":"NZPOE","tranship":false},{"id":"DEBRV","tranship":false},{"id":"NZWLG","tranship":false},{"id":"AUBRI","tranship":false},{"id":"DEBRE","tranship":false},{"id":"JPADO","tranship":false},{"id":"AUSYD","tranship":false},{"id":"DEHAM","tranship":false},{"id":"TWKHH","tranship":false},{"id":"SGSIN","tranship":false},{"id":"MYTPP","tranship":false},{"id":"HKHKG","tranship":false},{"id":"NZBLU","tranship":false}],"remarks":"Created by unit test UT_WebMasterTerminalAPI::tGetVoyage","shippingLineId":"AAL","status":0,"tradeId":"Unit Test Trade","vessel":{"callSign":"","id":"UATVES35883","imo":"","loa":0,"name":"UATVES35883","operatorId":"LAUR"},"voyageType":{"holds":false,"lolo":true,"roro":false}}';
ExpectJsonResponseUsingVoyageTC5ExtCode	= '{"allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"arrivalDT":&lt;ArrivalDT&gt;,"cargoSummary":null,"departureDT":&lt;DepartureDT&gt;,"externalCode":"","id":"UT_GETVOYAGEUT5EXT","inwardsCode":"","operatorId":"LAUR","portRotation":[{"id":"NZAKL","tranship":false},{"id":"NZNSN","tranship":false},{"id":"NZPOE","tranship":false},{"id":"DEBRV","tranship":false},{"id":"NZWLG","tranship":false},{"id":"AUBRI","tranship":false},{"id":"DEBRE","tranship":false},{"id":"JPADO","tranship":false},{"id":"AUSYD","tranship":false},{"id":"NZDUG","tranship":false},{"id":"DEHAM","tranship":false},{"id":"TWKHH","tranship":false},{"id":"SGSIN","tranship":false},{"id":"HKHKG","tranship":false},{"id":"NZBLU","tranship":false},{"id":"MYTPP","tranship":false},{"id":"AFBAG","tranship":false}],"remarks":"Created by unit test UT_WebMasterTerminalAPI::tGetVoyage","shippingLineId":"AAL","status":0,"tradeId":"Unit Test Trade","vessel":{"callSign":"","id":"UATVES35883","imo":"","loa":0,"name":"UATVES35883","operatorId":"LAUR"},"voyageType":{"holds":false,"lolo":true,"roro":false}}';
ExpectJsonResponseUsingVoyageTC5ExtCodeWMAST = '{"allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"arrivalDT":&lt;ArrivalDT&gt;,"cargoSummary":null,"departureDT":&lt;DepartureDT&gt;,"externalCode":"","id":"UT_GETVOYAGEUT5EXT","inwardsCode":"","operatorId":"LAUR","portRotation":[{"id":"NZAKL","tranship":false},{"id":"NZNSN","tranship":false},{"id":"NZPOE","tranship":false},{"id":"DEBRV","tranship":false},{"id":"NZWLG","tranship":false},{"id":"AUBRI","tranship":false},{"id":"DEBRE","tranship":false},{"id":"JPADO","tranship":false},{"id":"AUSYD","tranship":false},{"id":"DEHAM","tranship":false},{"id":"TWKHH","tranship":false},{"id":"SGSIN","tranship":false},{"id":"MYTPP","tranship":false},{"id":"HKHKG","tranship":false},{"id":"NZBLU","tranship":false}],"remarks":"Created by unit test UT_WebMasterTerminalAPI::tGetVoyage","shippingLineId":"AAL","status":0,"tradeId":"Unit Test Trade","vessel":{"callSign":"","id":"UATVES35883","imo":"","loa":0,"name":"UATVES35883","operatorId":"LAUR"},"voyageType":{"holds":false,"lolo":true,"roro":false}}';

VoyageJsonString = '[{
"id": "'&amp;Voyage1&amp;'",
"arrivalDT" : "2023-04-05T16:02:25Z",
"departureDT" : "2023-04-10T16:02:25.832611Z",
"externalCode": "",
"inwardsCode" : "",
"operatorId" : "LAUR",
"portRotation" : [{
    "id" : "AUBNE",
    "tranship" : false
}],
"remarks" : "Test", 
"shippingLineId" : "ABC",
"tradeId" : "AAL Shipping",
"vessel" :{
"id" : "LAURA OLD VESSEL",
"imo" : "",
"name" : "LAURA Old VESSEL",
"callSign" : "", 
"operatorId" : "LAUR",
"loa" : 1 
}
}]';

UpdateVoyageJsonStringWithoutEstArrDep = '[{
"id": "'&amp;Voyage1&amp;'",
"arrivalDT" : "2023-04-05T16:02:25Z",
"departureDT" :  "2023-05-05T16:02Z",
"externalCode": "",
"inwardsCode" : "",
"operatorId" : "LAUR",
"portRotation" : [{
    "id" : "AUBNE",
    "tranship" : false
}],
"remarks" : "Test", 
"shippingLineId" : "ABC",
"tradeId" : "AAL Shipping",
"vessel" :{
"id" : "LAURA OLD VESSEL",
"imo" : "",
"name" : "LAURA Old VESSEL",
"callSign" : "", 
"operatorId" : "LAUR",
"loa" : 1 
}
}]';

UpdateVoyageJsonString = '[{
"id": "'&amp;Voyage1&amp;'",
"arrivalDT" : "2023-04-05T16:02:25Z",
"departureDT" :  "2023-05-05T16:02Z",
"estimatedDepartureDT" : "2023-05-05T15:00Z",
"estimatedArrivalDT" : "2023-04-05T15:00Z",
"externalCode": "",
"inwardsCode" : "",
"operatorId" : "LAUR",
"portRotation" : [{
    "id" : "AUBNE",
    "tranship" : false
}],
"remarks" : "Test", 
"shippingLineId" : "ABC",
"tradeId" : "AAL Shipping",
"vessel" :{
"id" : "LAURA OLD VESSEL",
"imo" : "",
"name" : "LAURA Old VESSEL",
"callSign" : "", 
"operatorId" : "LAUR",
"loa" : 1 
}
}]';
vars
	terminal 		: CM_Terminal;
	terminalCode,
 	cargo1,
	cargo2,
	cargo3,
	cargo4,
	cargo5,
	params,
	queryParams		: String;
	vessel,
	vessel2,
	vessel3			: CM_Vessel;
	operator		: CM_Operator;
	voyage,
	voyage2			: CM_Voyage;
	dischargePort	: CM_Port;
	ti1, ti2, ti3,
	ti4				: CM_TrackedItem;
	expectFailure	: Boolean;
	blockStack		: CM_BlockStack;
	booking			: CM_BookingRef;
	vvr				: CM_VehicleVisitRecord;
	singleGate		: CM_Gate;
	response,
	expectedResponse,
	loginJson,
	incomingJsonString : String;
	departureDT, 
	arrivalDT,
	estArrivalDT, 
	estDepartDT			: TimeStampOffset;
	departedString,
 	arrivalString, 
	estArrivalString, 
	estDepartString		: String;
	allowDupInwardsCode	: Boolean;
begin
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	
	terminal := app.myPassport.myTerminal;
	self.assertNotNullMsg(terminal.code, "Terminal Code not set in Unit Test Profile");
	
	operator := app.myRoot.allOperators["LAUR"];
	
	// clean up
	self.deleteVoyage(VoyageId);
	self.deleteVoyage(Voyage1);
	self.deleteVoyage(Voyage2);
	self.deleteVoyage(Voyage3);
	self.deleteVessel(VesselID);
	self.deleteVessel(Vessel2);
	self.deleteVessel(Vessel3);
	self.deleteVessel("LAURA OLD VESSEL");
	self.deleteTerminalArea(BlockStack1);
	
	cargo1 := CargoOnShip;
	cargo2 := CargoOnSite;
	cargo3 := CargoOffSite;
	cargo4 := CargoPrenote;
	cargo5 := "UTLWT00001";
	
	self.deleteTrackedItem(cargo1, false); // delete the tracked item if exists
	self.deleteTrackedItem(cargo2, false); // delete the tracked item if exists
	self.deleteTrackedItem(cargo3, false); // delete the tracked item if exists
	self.deleteTrackedItem(cargo5, true);
	self.deleteContainer(CargoPrenote);
	
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	incomingJsonString := VoyageJsonString;
	expectFailure := false;
	
	vessel := self.addVesselBasic("LAURA OLD VESSEL",operator,false,false,false,true);
	self.assertNotNullMsg(vessel, "Vessel not created");
	
	self.addVoyageWithGeneralCargoStruc(Voyage1,vessel.code,operator.code,"AAL",2);
	// check that voyage exists on the terminal
	voyage := terminal.lookupVoyage(Voyage1,null,true);
	self.assertNotNullMsg(voyage, "voyage not created");
	vessel := voyage.myVessel;
	self.assertNotNullMsg(vessel, "Vessel not created");
	
	if voyage.myTrade &lt;&gt; null then
		dischargePort := voyage.myTrade.allPortRotations.first.myPort;
		self.assertNotNullMsg(dischargePort, "No Discharge Port");
	endif;
	
	// create second voyage with external code
	self.opts.purge();
	self.opts.addAssoc(UT_OPTS_ExternalCode, EXTERNALCODE);
	vessel3 := self.addVesselBasic(Vessel3,operator,false,false,false,true);
	vessel2 := self.addVesselBasic(Vessel2,operator,false,false,false,true);
	voyage2 := self.addVoyageWithInwardCode(Voyage2, null,vessel2.code,operator.code,"AAL");
	voyage2 := terminal.lookupVoyage(Voyage2,null,true);
	self.assertNotNullMsg(voyage2, "voyage not created");
	vessel2 := voyage2.myVessel;
	self.assertNotNullMsg(vessel2, "Vessel not created");
	self.assertNotNullMsg(voyage2.voyageCodeExternal, "Voyage should have external code set");
	
	// Create the TrackItem on ship
	self.opts.purge();
	self.opts.addAssoc("Commodity", "GENL");
	self.opts.addAssoc("CargoType", TI_CargoType_Container);
	self.opts.addAssoc("ISOType", '2200');
	self.opts.addAssoc("TotalWeight", 3000.Decimal);
	
	// create cargo on ship
	ti1 := self.addContainerOnShip(cargo1, operator, "2200", "GENL", null, voyage, dischargePort.code, voyage.code);
	self.assertNotNullMsg(ti1, "[Pre Test Validation] cargo item : " &amp; cargo1 &amp; " does not exist therefore test cannot continue");
	self.assertEqualMsg(voyage.allOnshipTIsByCargoTypeId.size, 1, "Wrong number of cargo items on ship");
	
	// create cargo on site
	// create cargo area
	blockStack := self.addBlockStack(BlockStack1,100,null);
	self.assertNotNull(blockStack);
	ti2 := self.addContainerForExport(cargo2, operator,
				"2200",	"MT", TI_IMEX_STATUS_EXPORT, null, voyage.code, dischargePort.code, null).CM_Container;
	self.assertNotNullMsg(ti2, "[Pre Test Validation] cargo item : " &amp; cargo2 &amp; " does not exist therefore test cannot continue");
	self.move(ti2, blockStack.getLocationsController);
	ti3 := self.addContainerForExport(cargo3, operator,
				"2200",	"MT", TI_IMEX_STATUS_EXPORT, null, voyage.code, dischargePort.code, null).CM_Container;
	self.assertNotNullMsg(ti3, "[Pre Test Validation] cargo item : " &amp; cargo3 &amp; " does not exist therefore test cannot continue");
	self.move(ti3, blockStack.getLocationsController);
	
	// create prenoted cargo with booking
	self.deleteBooking(BOOKINGID &amp; "CONT");
	booking := self.addBookingForContainer(BOOKINGID &amp; "CONT", operator, voyage,dischargePort.code, "2200", "GENL");
	self.assertNotNull(booking);
	self.opts.purge();
	
	ti4 := self.addPrenotedContainer(booking.allBookingRefItems.first, CargoPrenote);
	self.assertNotNullMsg(ti4, "[Pre Test Validation] cargo item : " &amp; cargo4 &amp; " does not exist therefore test cannot continue");

	// gate out the container so it will be off site
	self.deleteVehicle(TruckID);
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	assertNotNull(singleGate);
	vvr := self.gateOutContainer(TruckID, "", "UTDRIVER", ti3.CM_Container, true, singleGate , null);
	self.workVehicle(vvr);
	
	assertEqual(vvr.myRoadJob.status, JOB_COMPLETE);
	self.roadExit(vvr);
	
	//Checking  - Stripping the invalid dates and elements																			//JIRA-23126 START &gt;&gt;&gt;&gt;
	//Update voyage without estimated arrival and estimated departure date
	incomingJsonString := UpdateVoyageJsonStringWithoutEstArrDep;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutVoyage.name, loginJson, incomingJsonString, params, expectFailure);
	
	//Make sure the estimatedArrival and departure dates are null
	self.assertNullMsg(voyage.estimatedArrivalDT, "estimatedArrivalDT should be null");
	self.assertNullMsg(voyage.estimatedDepartureDT, "estimatedDepartureDT should be null");
	
	//Check the getVoyage removes the invalid date segments
	// Departure Date
	departureDT.setFromLocalTimeStamp(voyage.departedDT, departureDT.getUTCBias);
	departedString := departureDT.asUTCTimeStamp.asStringJSON.trimBlankCharacters;
	
	// Arrival Date
	arrivalDT.setFromLocalTimeStamp(voyage.arrivedDT, arrivalDT.getUTCBias);
	arrivalString := arrivalDT.asUTCTimeStamp.asStringJSON.trimBlankCharacters;
	
	expectedResponse := ExpectedJsonResponseWithoutEstArrDepDt.replace("&lt;ArrivalDT&gt;", arrivalString);
	expectedResponse := expectedResponse.replace("&lt;DepartureDT&gt;", departedString);
	
	params := "/"&amp;Voyage1;
	queryParams := params &amp; "?MasterTerminalAPI&amp;IncludeCargoSummary=false&amp;IncludeArchivedVoyages=false";
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetVoyage.name, params, queryParams, response, expectFailure);
	self.assertEqualMsg(response.trimBlankCharacters,expectedResponse.trimBlankCharacters,"Json should match");						//JIRA-23126 END &lt;&lt;&lt;&lt;
	
	// update the voyage to say its been departed
	incomingJsonString := UpdateVoyageJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutVoyage.name, loginJson, incomingJsonString, params, expectFailure);
	
	// due to daylight saving we need to do the following:
	// Departure Date
	departureDT.setFromLocalTimeStamp(voyage.departedDT, departureDT.getUTCBias);
	departedString := departureDT.asUTCTimeStamp.asStringJSON.trimBlankCharacters;
	// Arrival Date
	arrivalDT.setFromLocalTimeStamp(voyage.arrivedDT, arrivalDT.getUTCBias);
	arrivalString := arrivalDT.asUTCTimeStamp.asStringJSON.trimBlankCharacters;
	// Estimate Arrival Date
	estArrivalDT.setFromLocalTimeStamp(voyage.estimatedArrivalDT, estArrivalDT.getUTCBias);
	estArrivalString := estArrivalDT.asUTCTimeStamp.asStringJSON;
	// Estimate Departure Date
	estDepartDT.setFromLocalTimeStamp(voyage.estimatedDepartureDT, estDepartDT.getUTCBias);
	estDepartString := estDepartDT.asUTCTimeStamp.asStringJSON;
	
	// currently we need this as we call the getVoyage directly and does not go through the nice framework stuff
	expectedResponse := ExpectedJsonResponse.replace("&lt;ArrivalDT&gt;", arrivalString);
	expectedResponse := expectedResponse.replace("&lt;DepartureDT&gt;", departedString);
	expectedResponse := expectedResponse.replace("&lt;EstimatedDepartureDT&gt;", estDepartString);
	expectedResponse := expectedResponse.replace("&lt;EstimatedArrivalDT&gt;", estArrivalString);

	params := "/"&amp;Voyage1;
	queryParams := params &amp; "?MasterTerminalAPI&amp;IncludeCargoSummary=true&amp;IncludeArchivedVoyages=true";
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetVoyage.name, params, queryParams, response, expectFailure);
	app.writeLog("Actual: " &amp; response.asStringJMT, LogINFO);
	app.writeLog("Expected: " &amp; expectedResponse.trimBlankCharacters, LogINFO);
	voyage := terminal.lookupVoyage(Voyage1,null,true);
	self.assertEqualMsg(response.trimBlankCharacters,expectedResponse.trimBlankCharacters,"Json should match");
	
	// Test TC1
	app.writeLog("", LogINFO);
	app.writeLog("**************Voyage created with voyage code – UT_GETVOYAGEUT1 – Use getVoyage() API Call to get the voyage***********", LogINFO);
	app.writeLog("", LogINFO);
	self.deleteVoyage(VoyageTC1);
	self.opts.purge();
	self.addVoyageWithGeneralCargoStruc(VoyageTC1,vessel.code,operator.code,"AAL",2);
	voyage := terminal.lookupVoyage(VoyageTC1,null,true);
	self.assertNotNullMsg(voyage, "Voyage not created");
	vessel := voyage.myVessel;
	self.assertNotNullMsg(vessel, "Voyage not created");
	
	params := "/"&amp;VoyageTC1;
	queryParams := params &amp; "?MasterTerminalAPI&amp;IncludeCargoSummary=false&amp;IncludeArchivedVoyages=false";
	expectFailure := false;
	
	// Departed Date
	departureDT.setFromLocalTimeStamp(voyage.departedDT, departureDT.getUTCBias);
	departedString := departureDT.asUTCTimeStamp.asStringJSON.trimBlankCharacters;
	// Arrival Date
	arrivalDT.setFromLocalTimeStamp(voyage.arrivedDT, arrivalDT.getUTCBias);
	arrivalString := arrivalDT.asUTCTimeStamp.asStringJSON.trimBlankCharacters;
	if app.isRunningInDMAST() then
		expectedResponse := ExpectedJsonResponseUsingVoyageTC1.replace("&lt;ArrivalDT&gt;", arrivalString);
		expectedResponse := expectedResponse.replace("&lt;DepartureDT&gt;", departedString);
	elseif app.isRunningInWMAST() then
		expectedResponse := ExpectedJsonResponseUsingVoyageTC1WMAST.replace("&lt;ArrivalDT&gt;", arrivalString);
		expectedResponse := expectedResponse.replace("&lt;DepartureDT&gt;", departedString);
	endif;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetVoyage.name, params, queryParams, response, expectFailure);
	app.writeLog("Actual: " &amp; response.asStringJMT, LogINFO);
	app.writeLog("Expected: " &amp; expectedResponse.trimBlankCharacters, LogINFO);
	self.assertEqualMsg(response.trimBlankCharacters,expectedResponse.trimBlankCharacters,"Json should match");
	
	// Test TC2
	app.writeLog("", LogINFO);
	app.writeLog("**************Voyage created with inward code – UT_GETVOYAGEUT2 – Use getVoyage() API Call to get the voyage***********", LogINFO);
	app.writeLog("", LogINFO);
	self.deleteVoyage(VoyageTC2);
	
	self.opts.purge();
	voyage := self.addVoyageWithInwardCode(VoyageTC2, VoyageTC2In,vessel.code,operator.code,"AAL");
	self.assertNotNullMsg(voyage, "Voyage not created");
	vessel := voyage.myVessel;
	self.assertNotNullMsg(vessel, "Voyage not created");
	
	params := "/"&amp;VoyageTC2In;
	queryParams := params &amp; "?MasterTerminalAPI&amp;IncludeCargoSummary=false&amp;IncludeArchivedVoyages=false";
	expectFailure := false;
	
	// Departed Date
	departureDT.setFromLocalTimeStamp(voyage.departedDT, departureDT.getUTCBias);
	departedString := departureDT.asUTCTimeStamp.asStringJSON.trimBlankCharacters;
	// Arrival Date
	arrivalDT.setFromLocalTimeStamp(voyage.arrivedDT, arrivalDT.getUTCBias);
	arrivalString := arrivalDT.asUTCTimeStamp.asStringJSON.trimBlankCharacters;
	if app.isRunningInDMAST() then
		expectedResponse := ExpectedJsonResponseUsingVoyageTC2In.replace("&lt;ArrivalDT&gt;", arrivalString);
		expectedResponse := expectedResponse.replace("&lt;DepartureDT&gt;", departedString);
	elseif app.isRunningInWMAST then
		expectedResponse := ExpectedJsonResponseUsingVoyageTC2InWMAST.replace("&lt;ArrivalDT&gt;", arrivalString);
		expectedResponse := expectedResponse.replace("&lt;DepartureDT&gt;", departedString);
	endif;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetVoyage.name, params, queryParams, response, expectFailure);
	app.writeLog("Actual: " &amp; response.asStringJMT, LogINFO);
	app.writeLog("Expected: " &amp; expectedResponse.trimBlankCharacters, LogINFO);
	self.assertEqualMsg(response.trimBlankCharacters,expectedResponse.trimBlankCharacters,"Json should match");
	
	// Test TC3
	app.writeLog("", LogINFO);
	app.writeLog("**************TC 3 - Voyage created with external code – UT_GETVOYAGEUT3 – Use getVoyage() API Call to get the voyage***********", LogINFO);
	app.writeLog("", LogINFO);
	self.deleteVoyage(VoyageTC3);
	
	self.opts.purge();
	self.opts.addAssoc(UT_OPTS_ExternalCode, VoyageTCExt);
	
	voyage := self.addVoyageWithInwardCode(VoyageTC3, null,vessel3.code,operator.code,"AAL");
	self.assertNotNullMsg(voyage, "Voyage not created");
	vessel := voyage.myVessel;
	self.assertNotNullMsg(vessel, "Voyage not created");
	self.assertNotNullMsg(voyage.voyageCodeExternal, "Voyage ExternalCode is null");
	
	params := "/"&amp;VoyageTCExt;
	queryParams := params &amp; "?MasterTerminalAPI&amp;IncludeCargoSummary=false&amp;IncludeArchivedVoyages=false";
	expectFailure := false;
	
	// Departed Date
	departureDT.setFromLocalTimeStamp(voyage.departedDT, departureDT.getUTCBias);
	departedString := departureDT.asUTCTimeStamp.asStringJSON.trimBlankCharacters;
	// Arrival Date
	arrivalDT.setFromLocalTimeStamp(voyage.arrivedDT, arrivalDT.getUTCBias);
	arrivalString := arrivalDT.asUTCTimeStamp.asStringJSON.trimBlankCharacters;
	if app.isRunningInDMAST() then
		expectedResponse := ExpectedJsonResponseUsingVoyageTC3ExtCode.replace("&lt;ArrivalDT&gt;", arrivalString);
		expectedResponse := expectedResponse.replace("&lt;DepartureDT&gt;", departedString);
	elseif app.isRunningInWMAST then
		expectedResponse := ExpectedJsonResponseUsingVoyageTC3ExtCodeWMAST.replace("&lt;ArrivalDT&gt;", arrivalString);
		expectedResponse := expectedResponse.replace("&lt;DepartureDT&gt;", departedString);
	endif;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetVoyage.name, params, queryParams, response, expectFailure);
	app.writeLog("Actual: " &amp; response.asStringJMT, LogINFO);
	app.writeLog("Expected: " &amp; expectedResponse.trimBlankCharacters, LogINFO);
	self.assertEqualMsg(response.trimBlankCharacters,expectedResponse.trimBlankCharacters,"Json should match");
	
	// Test TC4
	app.writeLog("", LogINFO);
	app.writeLog("**************TC 4 - Voyage created with inward code – UT_GETVOYAGEUT4 – Use getVoyage() API Call to get the voyage***********", LogINFO);
	app.writeLog("", LogINFO);
	
	self.opts.purge();
	self.deleteVoyage(VoyageTC4);
	
	// set the AllowDupVoyageInOutCodes to true so we can test duplicate inwards/external codes 
	allowDupInwardsCode := self.setTerminalConfig(AllowDupVoyageInOutCodes, true).Boolean;
	
	voyage := self.addVoyageWithInwardCode(VoyageTC4, VoyageTC4In, vessel3.code,operator.code,"AAL");
	self.assertNotNullMsg(voyage, "Voyage not created");
	vessel := voyage.myVessel;
	self.assertNotNullMsg(vessel, "Voyage not created");
	self.assertNotNullMsg(voyage.inwardCodeAuto, "Voyage inwardsCodeAuto is null");
	
	params := "/"&amp;VoyageTC4In;
	queryParams := params &amp; "?MasterTerminalAPI&amp;IncludeCargoSummary=false&amp;IncludeArchivedVoyages=false";
	expectFailure := false;
	
	// Departed Date
	departureDT.setFromLocalTimeStamp(voyage.departedDT, departureDT.getUTCBias);
	departedString := departureDT.asUTCTimeStamp.asStringJSON.trimBlankCharacters;
	// Arrival Date
	arrivalDT.setFromLocalTimeStamp(voyage.arrivedDT, arrivalDT.getUTCBias);
	arrivalString := arrivalDT.asUTCTimeStamp.asStringJSON.trimBlankCharacters;
	if app.isRunningInDMAST() then
		expectedResponse := ExpectedJsonResponseUsingVoyageTC4In.replace("&lt;ArrivalDT&gt;", arrivalString);
		expectedResponse := expectedResponse.replace("&lt;DepartureDT&gt;", departedString);
	elseif app.isRunningInWMAST() then
		expectedResponse := ExpectedJsonResponseUsingVoyageTC4InWMAST.replace("&lt;ArrivalDT&gt;", arrivalString);
		expectedResponse := expectedResponse.replace("&lt;DepartureDT&gt;", departedString);
	endif;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetVoyage.name, params, queryParams, response, expectFailure);
	app.writeLog("Actual: " &amp; response.asStringJMT, LogINFO);
	app.writeLog("Expected: " &amp; expectedResponse.trimBlankCharacters, LogINFO);
	self.assertEqualMsg(response.trimBlankCharacters,expectedResponse.trimBlankCharacters,"Json should match");
	
	// Test TC5
	app.writeLog("", LogINFO);
	app.writeLog("*************TC 5 – Voyage created with external code – UT_GETVOYAGEUT5 – Use getVoyage() API Call to get the voyage***********", LogINFO);
	app.writeLog("", LogINFO);
	
	self.opts.purge();
	self.opts.addAssoc(UT_OPTS_ExternalCode, VoyageTC5Ext);
	self.deleteVoyage(VoyageTC5);
	
	voyage := self.addVoyageWithInwardCode(VoyageTC5, null, vessel3.code,operator.code,"AAL");
	self.assertNotNullMsg(voyage, "Voyage not created");
	vessel := voyage.myVessel;
	self.assertNotNullMsg(vessel, "Voyage not created");
	self.assertNotNullMsg(voyage.voyageCodeExternalAuto, "VoyageCodeExternalAuto is null");
	
	params := "/"&amp;VoyageTC5Ext;
	queryParams := params &amp; "?MasterTerminalAPI&amp;IncludeCargoSummary=false&amp;IncludeArchivedVoyages=false";
	expectFailure := false;
	
	// Departed Date
	departureDT.setFromLocalTimeStamp(voyage.departedDT, departureDT.getUTCBias);
	departedString := departureDT.asUTCTimeStamp.asStringJSON.trimBlankCharacters;
	// Arrival Date
	arrivalDT.setFromLocalTimeStamp(voyage.arrivedDT, arrivalDT.getUTCBias);
	arrivalString := arrivalDT.asUTCTimeStamp.asStringJSON.trimBlankCharacters;
	
	if app.isRunningInDMAST() then
		expectedResponse := ExpectJsonResponseUsingVoyageTC5ExtCode.replace("&lt;ArrivalDT&gt;", arrivalString);
		expectedResponse := expectedResponse.replace("&lt;DepartureDT&gt;", departedString);
	elseif app.isRunningInWMAST() then
		expectedResponse := ExpectJsonResponseUsingVoyageTC5ExtCodeWMAST.replace("&lt;ArrivalDT&gt;", arrivalString);
		expectedResponse := expectedResponse.replace("&lt;DepartureDT&gt;", departedString);
	endif;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetVoyage.name, params, queryParams, response, expectFailure);
	app.writeLog("Actual: " &amp; response.asStringJMT, LogINFO);
	app.writeLog("Expected: " &amp; expectedResponse.trimBlankCharacters, LogINFO);
	self.assertEqualMsg(response.trimBlankCharacters,expectedResponse.trimBlankCharacters,"Json should match");
	
	// Test TC6
	app.writeLog("", LogINFO);
	app.writeLog("*************TC 6 – Two Voyages created with inward code – UT_GETVOYAGEUT4 – Use getVoyage() API Call to get the voyage***********", LogINFO);
	app.writeLog("", LogINFO);
	
	self.deleteVoyage(VoyageTC6);
	self.opts.purge();
	
	voyage := self.addVoyageWithInwardCode(VoyageTC6, VoyageTC4In, Vessel2, operator.code,"AAL");
	self.assertNotNullMsg(voyage, "Voyage not created");
	vessel := voyage.myVessel;
	self.assertNotNullMsg(vessel, "Voyage not created");
	self.assertNotNullMsg(voyage.inwardCodeAuto, "inwardCodeAuto is null");
	
	params := "/"&amp;VoyageTC4In;
	queryParams := params &amp; "?MasterTerminalAPI&amp;IncludeCargoSummary=false&amp;IncludeArchivedVoyages=false";
	expectFailure := true;
	
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :96941. Multiple voyages found with identifier "&amp;VoyageTC4In&amp;". Not enough information to get a specific voyage");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetVoyage.name, params, queryParams, response, expectFailure);
	app.writeLog("Error: Code :96941. Multiple voyages found with identifier "&amp;VoyageTC4In&amp;". Not enough information to get a specific voyage", LogINFO);
	
	// Test TC7
	app.writeLog("", LogINFO);
	app.writeLog("*************TC 7 – Two Voyage created with external code – UT_GETVOYAGEUT5 – Use getVoyage() API Call to get the voyage***********", LogINFO);
	app.writeLog("", LogINFO);
	
	self.deleteVoyage(VoyageTC7);
	self.opts.purge();
	self.opts.addAssoc(UT_OPTS_ExternalCode, VoyageTC5Ext);
	
	voyage := self.addVoyageWithInwardCode(VoyageTC7, null, Vessel2, operator.code,"AAL");
	self.assertNotNullMsg(voyage, "Voyage not created");
	vessel := voyage.myVessel;
	self.assertNotNullMsg(vessel, "Voyage not created");
	self.assertNotNullMsg(voyage.voyageCodeExternalAuto, "voyageCodeExternalAuto is null");
	
	params := "/"&amp;VoyageTC5Ext;
	queryParams := params &amp; "?MasterTerminalAPI&amp;IncludeCargoSummary=false&amp;IncludeArchivedVoyages=false";
	expectFailure := true;
	
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :96941. Multiple voyages found with identifier "&amp;VoyageTC5Ext&amp;". Not enough information to get a specific voyage");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetVoyage.name, params, queryParams, response, expectFailure);
	app.writeLog("Error: Code :96941. Multiple voyages found with identifier "&amp;VoyageTC5Ext&amp;". Not enough information to get a specific voyage", LogINFO);
	
	// Test TC8
	app.writeLog("", LogINFO);
	app.writeLog("*************TC 8 – Make sure there exists no voyage named “ABCDXYZ” and retrieve a voyage with code “ABCDXYZ Use getVoyage() API Call to get the voyage***********", LogINFO);
	app.writeLog("", LogINFO);
	
	params := "/ABCDXYZ";
	queryParams := params &amp; "?MasterTerminalAPI&amp;IncludeCargoSummary=false&amp;IncludeArchivedVoyages=false";
	expectFailure := true;
	
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :85914. Voyage ABCDXYZ not found");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetVoyage.name, params, queryParams, response, expectFailure);
	app.writeLog("Error: Code :85914. Voyage ABCDXYZ not found", LogINFO);
	
	// End JIRA-35882 navlw1 10/09/2025
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tInspectionAppIncomingAPIChk" id="ce30b4fb-4334-45a3-afbf-af63e70ece42">
        <source>tInspectionAppIncomingAPIChk();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Jan 2023	navsp1	Initial creation - ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
10 Mar 2023	jlika1	Add width to Trailer Type
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
24 May 2023 navhl20 Defect 58041: MTN - Unable to copy the slots with the status "Booked - Current"
20 Jun 2023	navdap1	TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
*/
constants
	REF 			: String = "55581";
	CARRIERCODE 	: String = REF &amp; "CAR";
	SUBCARRIERCODE 	: String = REF &amp; "SUB";
	DRIVERID    	: String = REF &amp; "DRIVER";
	VEHICLEID   	: String = REF &amp; "VEHICLE";
	ID				: String = "IDUT" &amp; REF;
	TRAILERID 		: String = REF &amp; "TRAILER";
	SOURCE_CARGO 	: Integer= 2;
	TrailerType 	: String = REF &amp; "TT20";
	Cargo_Type 		: String = "UTCHAS";
	Trailer 		: String = REF &amp; "UTTRAILER";
	ContainerID		: String = "CNTU" &amp; REF;
	

JSONTOAPP = '{

}';

vars
	realVbsTimeSlot,
	proxyVbsTimeSlot		: CM_VehicleBookingTimeSlot;
	vbsSlotType				: CM_VehicleBookingTimeSlotType;
	date					: Date;
	startTime,
	endTime					: TimeStamp;
	vbsTimeSlotItem			: CM_VehicleBookingTimeSlotItem;
	trackedItem				: CM_TrackedItem;
	tiStringArray			: StringArray;
	vehicleBookingTerminal	: CM_VehicleBookingTerminal;
	carrier					: CM_Carrier;
	subCarrier				: CM_Carrier;
	driver					: CM_DriverDetails;
	vehicle					: CM_Vehicle;
	allCarriers 			: CM_CarrierByCodeDict;	
	allVehicleMachines 		: CM_VehicleSet; 
	email					: CM_EmailEntityByTypeNameDict;
	bs1 					: CM_BlockStack;
	vvr,pxyVVR				: CM_VehicleVisitRecord;
	trailer 				: CM_TILC;
	tt						: CM_TILCType;
	ct 						: CM_CargoType;

	direction,		
	quantity, 
	sequence,
	sourceType				: Integer;
	pin						: CM_GateArea;
	dualGate 				: CM_Gate;
	carrierCode 			: String;
	truck 					: CM_Vehicle;
	objectArray				: ObjectArray;
	terminalCode,
	jsonStringToMTN: String;
	entity 					: CMGTE_Entity;
	preCheckRequire 		: Boolean;
	postCheckRequire 		: Boolean;
	commodityType 			: String;
	handlingType 			: String;
	commodity 				: String;
	extWebServiceDef		: CM_ExternalWebServiceDef;
	activeWebServiceDef 	: CM_APIEndpointServiceDef;
	agent : CM_APIConsumerAgent;
	url,resultString : String;
	jsonPostData : String;
	resultCode : Integer;
	expectFailure : Boolean;
	truckLicense,checkType,checkDateTime,loginJson,status : String;
	terminal : CM_Terminal;
	vbsProcess	: CM_VBSProcess;
	slot 				: CM_VehicleBookingTimeSlot;
begin
	// TFS 58722 start
	extWebServiceDef := app.myRoot.getFirstActiveEWSForEndpoint( ETRow_GateVehicleInspection );
	self.assertNotNullMsg(extWebServiceDef, "app.myRoot.getFirstActiveEWSForEndpoint( ETRow_GateVehicleInspection )");
	self.assertTrueMsg(extWebServiceDef.isAPIDef, "extWebServiceDef.isAPIDef");
	activeWebServiceDef := extWebServiceDef.CM_APIEndpointServiceDef;
	// TFS 58722 end
	
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	
	terminal := self.getMyTerminal;
	
	//Set the vbs process to Slot Type Validation
	beginTransaction;
		terminal.setMyVBSProcess(app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE]);//getMyVBSProcess();
	commitTransaction;
	
	slot := terminal.myVehicleBookingTerminal.allVBTimeslotsById[ID];			//30.Oct.2023 navsp1 TFS 60874
	if slot &lt;&gt; null then
		if slot.myVehicleVisitRecord &lt;&gt; null then
			self.deleteVVR(slot.myVehicleVisitRecord);
		endif;
		self.deleteVbsTimeSlotAdv(slot.id);
		//self.deleteVbsTimeslotType(REF);	//25.Jul.24 navsp1
	endif;
	self.deleteVbsTimeslotType(REF);		//25.Jul.24 navsp1
	/*Add location*/
	bs1:=self.addBlockStack("BS"&amp;REF,999,null);
	
	ct := app.myRoot.allCargoTypesByDescription[Cargo_Type];
	if ct = null then
		/*add cargo type*/
		app.myPassport.ignoreErrors();
		self.opts.purge;
		self.opts.addAssoc("TrackAs",ProductType_Trailer);
		self.opts.addAssoc("AllowDuplicateId", true);
		ct:=self.addCargoType(Cargo_Type, false);
	endif;
	self.assertNotNull(ct);
	self.assertEqual(ct.productType,ProductType_Trailer);
	self.assertEqual(ct.myClassToCreate, CM_TILC);
	
	/*Add trailer type*/
	tt:=self.addTrailerType(TrailerType,TrailerType,ct,500,1,50,30000,13000,null,null,500);
	self.assertNotNull(tt);
	self.assertEqual(tt.numControllers,1);	
	self.assertEqual(tt.width.asStringJMT,"500.0000");
	
	self.deleteVehicle(VEHICLEID);
	self.deleteDriverDetails(DRIVERID);
	
	/*VBS Timeslot - Booking*/
	vehicleBookingTerminal := self.getMyTerminal.myVehicleBookingTerminal;
	vbsSlotType 		   := self.addVbsTimeslotType(REF, "Slot Type Create" &amp; REF); 	
	create proxyVbsTimeSlot transient;	
	direction  := DIRECTION_DELIVERY;
	quantity   := 0;
	sequence   := 0;
	sourceType := SOURCE_CARGO;
	self.deleteContainer(ContainerID);
	
	create vbsTimeSlotItem transient;
	
	vbsTimeSlotItem.setProxy(direction,
							null,
							null,
							null,
							null,
							trackedItem,
							proxyVbsTimeSlot,
							quantity,
							sequence,
							sourceType,
							0,
							null,
							null);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
							
	
	/* get tracked item*/
	
	create tiStringArray transient;
	
	/* create carrier and subcarrier*/
	create email transient;
	self.deleteCarrier(CARRIERCODE);
	self.deleteCarrier(SUBCARRIERCODE);
	carrierCode := self.getProfileStr(UT_Profile.P_CARRIER);
	carrier := app.myRoot.allCarriers[carrierCode];
	subCarrier := self.addCarrier(SUBCARRIERCODE, SUBCARRIERCODE, email, false, true, true, null);

	/* create vehicle*/
	vehicle := self.addVehicle( VEHICLEID, carrier, self.getTerminal());
	self.assertNotNull(vehicle);
	
	/* create driver details*/
	create allCarriers transient;
	allCarriers.add(carrier);
	create allVehicleMachines transient;
	allVehicleMachines.add(vehicle);
	driver := self.createDriverDetails(DRIVERID, allCarriers, allVehicleMachines);
	
	/*Gate*/
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	
	/*Create vehicle booking with both pre-check and post-check enabled.*/
	startTime.setTime(vbsSlotType.startTime);
	startTime.setDate(date.cnEcAddDays(1));
	
	endTime.setTime(vbsSlotType.startTime.addMinutes(vbsSlotType.duration));
	endTime.setDate(date.cnEcAddDays(1));	
	
	proxyVbsTimeSlot.setProxy(startTime, endTime, vehicleBookingTerminal, carrier, subCarrier, driver, vehicle, null, true, false, tiStringArray, vvr, vbsSlotType, ID, null, null, null, true, true, vbsSlotType.kioskCheck, null, null); // 08 Aug 2024 navcs2	ChangeRequest 63928
	app.myTrxCA.trxCreateVehicleBookingAdv(proxyVbsTimeSlot, realVbsTimeSlot,false, app.myPassport);		//24.5.2023 navhl20 #58041
	
	/*Create VVR*/
	self.opts.purge;
	self.opts.addAssoc("Location", bs1.myLocationsController.getFullId);
	self.opts.addAssoc("VehicleBookingTS",realVbsTimeSlot);	
	vvr:=self.gateInTrailerAndContainer(VEHICLEID,Trailer,ContainerID,tt.code,"2200",self.getProfileSetting(UT_Profile.P_OPERATOR).asString,"MT",dualGate);
	self.assertNotNull(vvr);
	
	truck:=self.getTerminal.vehicles[VEHICLEID,null];
	self.assertNotNull(truck);
	
	/*######################### MTN prevent truck entry if inspection not completed */
	
	/*Trailer*/
	trailer:=vvr.myInCMGTE_Chassis.myTrackedItem.CM_TILC;
	self.assertNotNull(trailer);
	self.assertEqual(trailer.myPrimaryActualLocation,truck.locationsController); 
	self.assertEqual(trailer.width.asStringJMT,"500.0000");
	
	//Gate in 
	pin 		:= self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);	
	self.assertNotNull(pin);
	
	/*Move vehicle to lane*/
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
		
	/*Move vehicle to yard*/
	self.expectedTrxErrors.add(Vehicle_cannot_move_to_yard);
	self.moveVehicleToYard(vvr.vehicle);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode(Vehicle_cannot_move_to_yard), " Should include error " &amp; Vehicle_cannot_move_to_yard.String &amp; " Vehicle cannot move to yard");
	assertTrueMsg(vvr.gateInCheckStatus = vvr.InspectionPending,"Vehicle inspection pending");
	
	/*######################### Inspection app triggers message to MTN on inspection complete*/
	/*Receive vehicle check details from Inspection App*/
	//process incoming json from inspection app
	
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	//28.Mar.2023  navsp1 TFS 57268 -- &gt;&gt;&gt;&gt;
	
	jsonStringToMTN := '{
	"checkDateTime" : "'&amp; app.actualTimeAppServer().asJSONFormat() &amp;'",
	"checkType" : "Gate IN",
	"status" : "Failed",
	"truckLicense" : "'&amp;VEHICLEID&amp;'"
	}';
	expectFailure := false;	

	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTInspectionAppCheck.name,loginJson, jsonStringToMTN, expectFailure);
	assertTrueMsg(vvr.gateInCheckStatus = vvr.InspectionFailed,"Vehicle inspection failed!");	
	
	//28.Mar.2023  navsp1 TFS 57268 -- &lt;&lt;&lt;&lt;
	
	jsonStringToMTN := '{
	"checkDateTime" : "'&amp; app.actualTimeAppServer().asJSONFormat() &amp;'",
	"checkType" : "Gate IN",
	"status" : "Completed",
	"truckLicense" : "'&amp;VEHICLEID&amp;'"
	}';
	
	expectFailure := false;	

	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTInspectionAppCheck.name,loginJson, jsonStringToMTN, expectFailure);
	assertTrueMsg(vvr.gateInCheckStatus = vvr.InspectionCompleted,"Vehicle inspection failed!");	
	
	/*Trx to delete time slot*/
	create objectArray transient;
	objectArray.add(realVbsTimeSlot);
	app.myTrxDA.trxDeleteMultiVehicleBookSlots(objectArray, app.myPassport);
epilog
	beginTransaction;
		terminal.setMyVBSProcess(app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE]);
	commitTransaction;

	delete tiStringArray;
	delete allCarriers;
	delete email;
	delete allVehicleMachines;
	delete proxyVbsTimeSlot;
	delete objectArray;
	delete pxyVVR;
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvPostAndValidateStatus" id="21bd3e00-d379-4a78-b1e1-13215af28d03">
        <source>tInvPostAndValidateStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2024	navrv30	CR 61931 Initial creation

*/

vars
	queryParams : String;	
	pathParams : String;
	testDesc : String;
	jsonString: String;
	testCaseName: String;
	postedInvoice : CM_Invoice;
	ewsActivity : CM_ExternalWebServiceActivity;
begin
	postedInvoice := self.postInvoiceToOracleIntf();
	beginTransaction;
	postedInvoice.setStatus(CM_Invoice.INVOICE_POSTED_PENDING);
	commitTransaction;
	queryParams := "?MasterTerminalAPI&amp;qParam=hi";
	pathParams := "/hello";
	testDesc := "query_hi_path_hello";
	testCaseName := "TESTCASE1";	
	jsonString := '{
						"invoiceMessageUniqueIdentifier": "DFBU-UT--999-1-1-1",
						"responseDate": "string",
						"invoiceProcessingResult": "ERROR",
						"responseMessage": "ERROR message"
					}';	
	ewsActivity := postedInvoice.allEWSInvoiceAPIActivities.first;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTInvPostAndValidateStatus.name, jsonString, testCaseName);
	self.assertEqualMsg(ewsActivity.CM_EWSActivityInvoiceAPI.attemptNumber,1, "Activity Attempt Number");
	self.assertEqualMsg(ewsActivity.CM_EWSActivityInvoiceAPI.fullMsgStatusStr,"Message processed error", "Error processing the activity");
	self.assertEqualMsg(postedInvoice.status,CM_Invoice.INVOICE_POSTED_ERROR, "Error Status");
	
	testCaseName := "TESTCASE2";	
	jsonString := '{
						"invoiceMessageUniqueIdentifier": "DFBU-UT--999-1-1-1",
						"responseDate": "string",
						"invoiceProcessingResult": "SUCCESS",
						"responseMessage": "SUCCESS message"
					}';	
	ewsActivity := postedInvoice.allEWSInvoiceAPIActivities.first;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTInvPostAndValidateStatus.name, jsonString, testCaseName);
	self.assertEqualMsg(ewsActivity.CM_EWSActivityInvoiceAPI.attemptNumber,1, "Activity Attempt Number");
	self.assertEqualMsg(ewsActivity.CM_EWSActivityInvoiceAPI.fullMsgStatusStr,"Message processed successful", "Success processing the activity");
	self.assertEqualMsg(postedInvoice.status,CM_Invoice.INVOICE_POSTED, "Success Status");
	
epilog
	self.deleteExternalWebService("UT_InvoiceOracleIntf");
	self.deleteInvoice(postedInvoice);
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvalidJSONHandler" id="fad6bb44-fa22-431f-be5e-9997ee426dcb">
        <source>tInvalidJSONHandler();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Aug 2025	navnk30	JIRA 35197: CUX - API PUT /voyage response with invalid escaped double quote text

*/
constants
Test_Voyage_ID = "UT-35197";
Test_Vessel_ID = "UT-VESSEL-35197";
VoyageJsonString = '[{
"id": "'&amp;Test_Voyage_ID&amp;'",
"arrivalDT" : "2023-04-05T16:04:25.832611",
"departureDT" : "2023-04-10T16:02:25.832611",
"externalCode": "",
"estimatedArrivalDT" : "2023-04-06T16:02:25.832611",
"inwardsCode" : "",
"operatorId" : "LAUR",
"portRotation" : [{
    "id" : "AUBNE",
    "tranship" : false
}],
"remarks" : "", 
"shippingLineId" : "ABC",
"voyageType":{
"holds":true,
"lolo":false,
"roro":false
},
"vessel" :{
"id" : "'&amp;Test_Vessel_ID&amp;'",
"imo" : "",
"name" : "UT-VESSEL-35197",
"callSign" : "", 
"operatorId" : "LAUR",
"loa" : 1 
}
}]';

VoyageJsonString2 = '[{
"id": "'&amp;Test_Voyage_ID&amp;'",
"arrivalDT" : "2023-04-05T16:04:25.832611",
"departureDT" : "2023-04-10T16:02:25.832611",
"externalCode": "",
"estimatedArrivalDT" : "2023-04-06T16:02:25.832611",
"estimatedDepartureDT" : &lt;estimatedDepartureDT&gt;,
"inwardsCode" : "INW_35197",
"operatorId" : "LAUR",
"portRotation" : [{
    "id" : "AUBNE",
    "tranship" : false
}],
"remarks" : "", 
"shippingLineId" : "ABC",
"voyageType":{
"holds":true,
"lolo":false,
"roro":false
},
"vessel" :{
"id" : "'&amp;Test_Vessel_ID&amp;'",
"imo" : "",
"name" : "UT-VESSEL-35197",
"callSign" : "", 
"operatorId" : "LAUR",
"loa" : 1 
}
}]';

vars
	expectFailure 		: Boolean;
	loginJson,
	incomingJsonString,
	terminalCode,
	escapedJsonStr,
	params				: String;
	root 				: CM_Root;
	terminal 			: CM_Terminal;
	voyage 				: CM_Voyage;
begin
	// do the clean up 
	root := self.getRoot();
	
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	
	terminal := app.myPassport.myTerminal;
	self.assertNotNullMsg(terminal.code, "Terminal Code not set in Unit Test Profile");
	
	deleteVoyage(Test_Voyage_ID);
	deleteVessel(Test_Vessel_ID);
	
	self.opts.purge();
	
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	incomingJsonString := VoyageJsonString;
	expectFailure := false;
	
	// create the voyage first
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);
	
	// check if voyage has been created successfully
	voyage := terminal.lookupVoyage(Test_Voyage_ID, null, true);
	self.assertNotNullMsg(voyage, "Voyage creation unsuccessful");
	
	// try to update the voyage's Estimated Departure DateTime to null, which throws exception that should be handled.
	expectFailure := true;
	incomingJsonString := VoyageJsonString2.replace("&lt;estimatedDepartureDT&gt;", "null");
	
	self.opts.purge();
	
	on Exception do app.handleInvalidJSONException(exception, Ex_Resume_Next, escapedJsonStr);
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutVoyage.name, loginJson, incomingJsonString, params, expectFailure);
	self.assertFalseMsg(JadeRegex@contains(escapedJsonStr, '(?&lt;!\\)"|[\r\n]+', true), "Extended Error text not escaped properly");
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tMAFISAndTrailersAndChildren" id="1bd4bebd-1c30-4062-9369-04d756121c53">
        <updating/>
        <source>tMAFISAndTrailersAndChildren() updating;
//
// Purpose:			Test the creation of MAFIs/trailers with on board cargo on site, on ship and prenoted
//					Test updating the data and make sure the on board cargo stays on board
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/08/2024	navdap1		Initial creation TFS 65549 CUX - Updating Trailer via PUT /cargo Changes Onboard Cargo to Child Cargo
//
constants
	OnshipMAFIId = "ONSHIPMAFI65549";
	OnshipTrailerId = "ONSHIPTRAILER65549";
	OnsiteMAFIId = "ONSITEMAFI65549";
	OnsiteTrailerId = "ONSITETRAILER65549";
	PrenoteMAFIId = "PRENOTEMAFI65549";
	PrenoteTrailerId = "PRENOTETRAILER65549";
	
	ChildShipMAFI01 = "MF_65549_ONSHIP_01";
	ChildShipMAFI02 = "MF_65549_ONSHIP_02";
	ChildShipTrailer01 = "TR_65549_ONSHIP_01";
	ChildShipTrailer02 = "TR_65549_ONSHIP_02";
	ChildSiteMAFI01 = "MF_65549_ONSITE_01";
	ChildSiteMAFI02 = "MF_65549_ONSITE_02";
	ChildSiteTrailer01 = "TR_65549_ONSITE_01";
	ChildSiteTrailer02 = "TR_65549_ONSITE_02";
	ChildPreMAFI01 = "MF_65549_PRE_01";
	ChildPreMAFI02 = "MF_65549_PRE_02";
	ChildPreTrailer01 = "TR_65549_PRE_01";
	ChildPreTrailer02 = "TR_65549_PRE_02";
	
	ThisVessel = "VESS65549";
	ThisVoyage = "VOY65549";
	
	ChildCargoType = "PAPER";
	ChildProduct = "ROLLS";
	
	BlockStack = "BS65549";
	
	OperatorCUX = "Cuxport";
	
vars
	root : CM_Root;
	terminal : CM_Terminal;
	operator : CM_Operator;
	terminalCode,
	operatorCode,
	loginJson,
	incomingJsonString,
	queryParam,
	restOperator : String;
	mafiCT, trailerCT : CM_CargoType;
	mafiTT, trailerTT : CM_TILCType;
	expectFailure : Boolean;
	realTI, child : CM_TrackedItem;
	lc : CM_LocationsController;
	childrenCorrect : Boolean;
	bs : CM_TerminalArea;

begin
	root := app.myRoot;
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Unit Test Profile Terminal Code");
	terminal := root.allTerminals[terminalCode];
	operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).getValue.String;
	self.assertNotNullMsg(operatorCode, "Unit Test Profile Operator Code");
	operator := root.allOperators[operatorCode];
	self.assertNotNullMsg(operator, "Unit Test Operator for " &amp; operatorCode);
	if app.isRunningInDMAST then
		mafiCT := root.allCargoTypesByDescription["MAFI AS TRAIL"];
		mafiTT := root.allTILCTypes[null, "MAFI 40 CUX"];
		trailerCT := root.allCargoTypesByDescription["Trailer"];
		trailerTT := root.allTILCTypes[null, "STRL"];
	elseif app.isRunningInWMAST then
		mafiCT := root.allCargoTypesByDescription["MAFI AS TRAIL"];
		mafiTT := root.allTILCTypes[null, "MAFI 40 CUX"];
		trailerCT := root.allCargoTypesByDescription["Trailer"];
		trailerTT := root.allTILCTypes[null, "SHTTRA"];
	endif;
	self.assertNotNullMsg(mafiCT, "Cargo Type for MAFI");
	self.assertNotNullMsg(trailerCT, "Cargo Type for Trailer");
	self.assertNotNullMsg(mafiTT, "Trailer Type for MAFI");
	self.assertNotNullMsg(trailerTT, "Trailer Type for Trailer");
	
	//////////////
	// CLEAN UP //
	//////////////
	// delete the on ship / on site / prenotified MAFI and Trailer
	self.deleteCargo(OnshipMAFIId, mafiCT);
	self.deleteCargo(OnshipTrailerId, trailerCT);
	self.deleteCargo(OnsiteMAFIId, mafiCT);
	self.deleteCargo(OnsiteTrailerId, trailerCT);
	self.deleteCargo(PrenoteMAFIId, mafiCT);
	self.deleteCargo(PrenoteTrailerId, trailerCT);
	
	// delete the vessel and voyage
	self.deleteVoyage(ThisVoyage);
	self.deleteVessel(ThisVessel);
	
	// delete the block stack
	self.deleteTerminalArea(BlockStack);
	
	////////////
	// SET UP //
	////////////	
	// create the vessel and voyage
	self.createVesselVoyage(ThisVoyage, ThisVessel, operator);
	
	// create the terminal area
	bs := self.addBlockStack(BlockStack, 999999, null);
	
	restOperator := OperatorCUX;
	
	////////////////////////////////////////////////////
	// TEST 1 - POST ON SHIP MAFI WITH CARGO ON BOARD //
	////////////////////////////////////////////////////
	// Create the MAFI and children
	incomingJsonString := self.zTFS65549POSTOnShip(ThisVoyage, ThisVessel, OnshipMAFIId, mafiCT.abbreviation, mafiTT.code, operator.code, ChildCargoType, ChildProduct, ChildShipMAFI01, ChildShipMAFI02);
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString, expectFailure);
	self.assertNoTrxErrorsPassport("TEST 1 MAFI creation failed - " &amp; app.myPassport.getErrorsAsString);
	
	realTI := self.getTrackedItem(OnshipMAFIId);
	self.assertNotNullMsg(realTI, "Test 1 - MAFI on ship");
	self.assertTrueMsg(realTI.allChildren.isEmpty, "Test 1 - MAFI on ship should not have children");
	lc := realTI.CM_TILC.allLCs.first;
	self.assertNotNullMsg(lc, "Test 1 - MAFI on ship locations controller");
	self.assertEqualMsg(lc.allTrackedItems.size, 2, "Test 1 - MAFI on ship does not have 2 onboard cargo items");
	
	///////////////////////////////////////////////////
	// TEST 2 - PUT ON SHIP MAFI WITH CARGO ON BOARD //
	///////////////////////////////////////////////////
	// PUT an update to the MAFI and children
	incomingJsonString := self.zTFS65549PUTOnShip(ThisVoyage, ThisVessel, OnshipMAFIId, mafiCT.abbreviation, mafiTT.code, operator.code, ChildCargoType, ChildProduct, ChildShipMAFI01, ChildShipMAFI02);
	expectFailure := false;
	queryParam := "/Cargo/" &amp; OnshipMAFIId &amp; "/" &amp; mafiCT.abbreviation &amp; "/" &amp; TI_STATE_ONSHIP.String &amp; "?MasterTerminalAPI";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, restOperator, incomingJsonString, queryParam, expectFailure);
	self.assertNoTrxErrorsPassport("TEST 2 MAFI update failed - " &amp; app.myPassport.getErrorsAsString);
	
	// Same checks - MAFI should have no children, and 2 onboard cargo items
	realTI := self.getTrackedItem(OnshipMAFIId);
	self.assertNotNullMsg(realTI, "Test 2 - MAFI on ship");
	self.assertTrueMsg(realTI.allChildren.isEmpty, "Test 2 - MAFI on ship should not have children");
	lc := realTI.CM_TILC.allLCs.first;
	self.assertNotNullMsg(lc, "Test 2 - MAFI on ship locations controller");
	self.assertEqualMsg(lc.allTrackedItems.size, 2, "Test 2 - MAFI on ship does not have 2 onboard cargo items");
	self.assertEqualMsg(realTI.alternativeId, "TEST_CHG", "Test 2 - MAFI on ship alternative ID not updated");
	childrenCorrect := false;
	foreach child in lc.allTrackedItems do
		if child.id = ChildShipMAFI01 and child.alternativeId = "TESTRS_CHG_01" then
			childrenCorrect := true;
		elseif child.id = ChildShipMAFI02 and child.alternativeId = "TESTRS_CHG_02" then
			childrenCorrect := true;
		endif;
	endforeach;
	self.assertTrueMsg(childrenCorrect, "Test 2 - MAFI on board cargo not updated");
	
	/////////////////////////////////////////////
	// TEST 3 - POST TRAILER AND CARGO ON SHIP //
	/////////////////////////////////////////////
	// Create the Trailer and children
	incomingJsonString := self.zTFS65549POSTOnShip(ThisVoyage, ThisVessel, OnshipTrailerId, trailerCT.abbreviation, trailerTT.code, operator.code, ChildCargoType, ChildProduct, ChildShipTrailer01, ChildShipTrailer02);
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString, expectFailure);
	self.assertNoTrxErrorsPassport("TEST 3 Trailer creation failed - " &amp; app.myPassport.getErrorsAsString);
	
	realTI := self.getTrackedItem(OnshipTrailerId);
	self.assertNotNullMsg(realTI, "Test 3 - Trailer on ship");
	self.assertTrueMsg(realTI.allChildren.isEmpty, "Test 3 - Trailer on ship should not have children");
	lc := realTI.CM_TILC.allLCs.first;
	self.assertNotNullMsg(lc, "Test 3 - Trailer on ship locations controller");
	self.assertEqualMsg(lc.allTrackedItems.size, 2, "Test 3 - Trailer on ship does not have 2 onboard cargo items");
	
	//////////////////////////////////////////////////////
	// TEST 4 - PUT ON SHIP TRAILER WITH CARGO ON BOARD //
	//////////////////////////////////////////////////////
	// PUT an update to the Trailer and children
	incomingJsonString := self.zTFS65549PUTOnShip(ThisVoyage, ThisVessel, OnshipTrailerId, trailerCT.abbreviation, trailerTT.code, operator.code, ChildCargoType, ChildProduct, ChildShipTrailer01, ChildShipTrailer02);
	expectFailure := false;
	queryParam := "/Cargo/" &amp; OnshipTrailerId &amp; "/" &amp; trailerCT.abbreviation &amp; "/" &amp; TI_STATE_ONSHIP.String &amp; "?MasterTerminalAPI";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, restOperator, incomingJsonString, queryParam, expectFailure);
	self.assertNoTrxErrorsPassport("TEST 4 Trailer update failed - " &amp; app.myPassport.getErrorsAsString);
	
	// Same checks - Trailer should have no children, and 2 onboard cargo items
	realTI := self.getTrackedItem(OnshipTrailerId);
	self.assertNotNullMsg(realTI, "Test 4 - Trailer on ship");
	self.assertTrueMsg(realTI.allChildren.isEmpty, "Test 4 - Trailer on ship should not have children");
	lc := realTI.CM_TILC.allLCs.first;
	self.assertNotNullMsg(lc, "Test 4 - Trailer on ship locations controller");
	self.assertEqualMsg(lc.allTrackedItems.size, 2, "Test 4 - Trailer on ship does not have 2 onboard cargo items");
	self.assertEqualMsg(realTI.alternativeId, "TEST_CHG", "Test 4 - Trailer on ship alternative ID not updated");
	childrenCorrect := false;
	foreach child in lc.allTrackedItems do
		if child.id = ChildShipTrailer01 and child.alternativeId = "TESTRS_CHG_01" then
			childrenCorrect := true;
		elseif child.id = ChildShipTrailer02 and child.alternativeId = "TESTRS_CHG_02" then
			childrenCorrect := true;
		endif;
	endforeach;
	self.assertTrueMsg(childrenCorrect, "Test 4 - Trailer on board cargo not updated");
	
	////////////////////////////////////////////////////
	// TEST 5 - POST ON SITE MAFI WITH CARGO ON BOARD //
	////////////////////////////////////////////////////
	// Create the MAFI and children
	incomingJsonString := self.zTFS65549POSTOnSite(ThisVoyage, ThisVessel, OnsiteMAFIId, mafiCT.abbreviation, mafiTT.code, operator.code, ChildCargoType, ChildProduct, ChildSiteMAFI01, ChildSiteMAFI02, BlockStack);
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString, expectFailure);
	self.assertNoTrxErrorsPassport("TEST 5 MAFI creation failed - " &amp; app.myPassport.getErrorsAsString);
	
	realTI := self.getTrackedItem(OnsiteMAFIId);
	self.assertNotNullMsg(realTI, "Test 5 - MAFI on site");
	self.assertTrueMsg(realTI.allChildren.isEmpty, "Test 5 - MAFI on site should not have children");
	lc := realTI.CM_TILC.allLCs.first;
	self.assertNotNullMsg(lc, "Test 5 - MAFI on site locations controller");
	self.assertEqualMsg(lc.allTrackedItems.size, 2, "Test 5 - MAFI on site does not have 2 onboard cargo items");
	
	///////////////////////////////////////////////////
	// TEST 6 - PUT ON SITE MAFI WITH CARGO ON BOARD //
	///////////////////////////////////////////////////
	// PUT an update to the MAFI and children
	incomingJsonString := self.zTFS65549PUTOnSite(ThisVoyage, ThisVessel, OnsiteMAFIId, mafiCT.abbreviation, mafiTT.code, operator.code, ChildCargoType, ChildProduct, ChildSiteMAFI01, ChildSiteMAFI02, BlockStack);
	expectFailure := false;
	queryParam := "/Cargo/" &amp; OnsiteMAFIId &amp; "/" &amp; mafiCT.abbreviation &amp; "/" &amp; TI_STATE_NORMAL.String &amp; "?MasterTerminalAPI";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, restOperator, incomingJsonString, queryParam, expectFailure);
	self.assertNoTrxErrorsPassport("TEST 6 MAFI update failed - " &amp; app.myPassport.getErrorsAsString);
	
	// Same checks - MAFI should have no children, and 2 onboard cargo items
	realTI := self.getTrackedItem(OnsiteMAFIId);
	self.assertNotNullMsg(realTI, "Test 6 - MAFI on site");
	self.assertTrueMsg(realTI.allChildren.isEmpty, "Test 6 - MAFI on site should not have children");
	lc := realTI.CM_TILC.allLCs.first;
	self.assertNotNullMsg(lc, "Test 6 - MAFI on site locations controller");
	self.assertEqualMsg(lc.allTrackedItems.size, 2, "Test 6 - MAFI on site does not have 2 onboard cargo items");
	self.assertEqualMsg(realTI.alternativeId, "TEST_CHG", "Test 6 - MAFI on site alternative ID not updated");
	childrenCorrect := false;
	foreach child in lc.allTrackedItems do
		if child.id = ChildSiteMAFI01 and child.alternativeId = "TESTRS_CHG_01" then
			childrenCorrect := true;
		elseif child.id = ChildSiteMAFI02 and child.alternativeId = "TESTRS_CHG_02" then
			childrenCorrect := true;
		endif;
	endforeach;
	self.assertTrueMsg(childrenCorrect, "Test 6 - MAFI on board cargo not updated");
	
	/////////////////////////////////////////////
	// TEST 7 - POST TRAILER AND CARGO ON SITE //
	/////////////////////////////////////////////
	// Create the Trailer and children
	incomingJsonString := self.zTFS65549POSTOnSite(ThisVoyage, ThisVessel, OnsiteTrailerId, trailerCT.abbreviation, trailerTT.code, operator.code, ChildCargoType, ChildProduct, ChildSiteTrailer01, ChildSiteTrailer02, BlockStack);
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString, expectFailure);
	self.assertNoTrxErrorsPassport("TEST 7 Trailer creation failed - " &amp; app.myPassport.getErrorsAsString);
	
	realTI := self.getTrackedItem(OnsiteTrailerId);
	self.assertNotNullMsg(realTI, "Test 7 - Trailer on site");
	self.assertTrueMsg(realTI.allChildren.isEmpty, "Test 7 - Trailer on site should not have children");
	lc := realTI.CM_TILC.allLCs.first;
	self.assertNotNullMsg(lc, "Test 7 - Trailer on site locations controller");
	self.assertEqualMsg(lc.allTrackedItems.size, 2, "Test 7 - Trailer on site does not have 2 onboard cargo items");
	
	//////////////////////////////////////////////////////
	// TEST 8 - PUT ON SITE TRAILER WITH CARGO ON BOARD //
	//////////////////////////////////////////////////////
	// PUT an update to the Trailer and children
	incomingJsonString := self.zTFS65549PUTOnSite(ThisVoyage, ThisVessel, OnsiteTrailerId, trailerCT.abbreviation, trailerTT.code, operator.code, ChildCargoType, ChildProduct, ChildSiteTrailer01, ChildSiteTrailer02, BlockStack);
	expectFailure := false;
	queryParam := "/Cargo/" &amp; OnsiteTrailerId &amp; "/" &amp; trailerCT.abbreviation &amp; "/" &amp; TI_STATE_NORMAL.String &amp; "?MasterTerminalAPI";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, restOperator, incomingJsonString, queryParam, expectFailure);
	self.assertNoTrxErrorsPassport("TEST 8 Trailer update failed - " &amp; app.myPassport.getErrorsAsString);
	
	// Same checks - Trailer should have no children, and 2 onboard cargo items
	realTI := self.getTrackedItem(OnsiteTrailerId);
	self.assertNotNullMsg(realTI, "Test 8 - Trailer on site");
	self.assertTrueMsg(realTI.allChildren.isEmpty, "Test 8 - Trailer on site should not have children");
	lc := realTI.CM_TILC.allLCs.first;
	self.assertNotNullMsg(lc, "Test 8 - Trailer on site locations controller");
	self.assertEqualMsg(lc.allTrackedItems.size, 2, "Test 8 - Trailer on site does not have 2 onboard cargo items");
	self.assertEqualMsg(realTI.alternativeId, "TEST_CHG", "Test 8 - Trailer on site alternative ID not updated");
	childrenCorrect := false;
	foreach child in lc.allTrackedItems do
		if child.id = ChildSiteTrailer01 and child.alternativeId = "TESTRS_CHG_01" then
			childrenCorrect := true;
		elseif child.id = ChildSiteTrailer02 and child.alternativeId = "TESTRS_CHG_02" then
			childrenCorrect := true;
		endif;
	endforeach;
	self.assertTrueMsg(childrenCorrect, "Test 8 - Trailer on board cargo not updated");
	
	/////////////////////////////////////////////////////
	// TEST 9 - POST PRENOTED MAFI WITH CARGO ON BOARD //
	/////////////////////////////////////////////////////
	// Create the MAFI and children
	incomingJsonString := self.zTFS65549POSTNotify(ThisVoyage, ThisVessel, PrenoteMAFIId, mafiCT.abbreviation, mafiTT.code, operator.code, ChildCargoType, ChildProduct, ChildPreMAFI01, ChildPreMAFI02);
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString, expectFailure);
	self.assertNoTrxErrorsPassport("TEST 9 MAFI creation failed - " &amp; app.myPassport.getErrorsAsString);
	
	realTI := self.getTrackedItem(PrenoteMAFIId);
	self.assertNotNullMsg(realTI, "Test 9 - MAFI prenote");
	self.assertTrueMsg(realTI.allChildren.isEmpty, "Test 9 - MAFI prenote should not have children");
	lc := realTI.CM_TILC.allLCs.first;
	self.assertNotNullMsg(lc, "Test 9 - MAFI prenote locations controller");
	self.assertEqualMsg(lc.allTrackedItems.size, 2, "Test 9 - MAFI prenote does not have 2 onboard cargo items");
	
	/////////////////////////////////////////////////////
	// TEST 10 - PUT PRENOTED MAFI WITH CARGO ON BOARD //
	////////////////////////////////////////////////////
	// PUT an update to the MAFI and children
	incomingJsonString := self.zTFS65549PUTNotify(ThisVoyage, ThisVessel, PrenoteMAFIId, mafiCT.abbreviation, mafiTT.code, operator.code, ChildCargoType, ChildProduct, ChildPreMAFI01, ChildPreMAFI02);
	expectFailure := false;
	queryParam := "/Cargo/" &amp; PrenoteMAFIId &amp; "/" &amp; mafiCT.abbreviation &amp; "/" &amp; TI_STATE_NOTIFIED.String &amp; "?MasterTerminalAPI";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, restOperator, incomingJsonString, queryParam, expectFailure);
	self.assertNoTrxErrorsPassport("TEST 10 MAFI prenote update failed - " &amp; app.myPassport.getErrorsAsString);
	
	// Same checks - MAFI should have no children, and 2 onboard cargo items
	realTI := self.getTrackedItem(PrenoteMAFIId);
	self.assertNotNullMsg(realTI, "Test 10 - MAFI prenote");
	self.assertTrueMsg(realTI.allChildren.isEmpty, "Test 10 - MAFI prenote should not have children");
	lc := realTI.CM_TILC.allLCs.first;
	self.assertNotNullMsg(lc, "Test 10 - MAFI prenote locations controller");
	self.assertEqualMsg(lc.allTrackedItems.size, 2, "Test 10 - MAFI prenote does not have 2 onboard cargo items");
	self.assertEqualMsg(realTI.alternativeId, "TEST_CHG", "Test 10 - MAFI prenote alternative ID not updated");
	childrenCorrect := false;
	foreach child in lc.allTrackedItems do
		if child.id = ChildPreMAFI01 and child.alternativeId = "TESTRS_CHG_01" then
			childrenCorrect := true;
		elseif child.id = ChildPreMAFI02 and child.alternativeId = "TESTRS_CHG_02" then
			childrenCorrect := true;
		endif;
	endforeach;
	self.assertTrueMsg(childrenCorrect, "Test 10 - MAFI prenote on board cargo not updated");
	
	/////////////////////////////////////////////////////////
	// TEST 11 - POST PRENOTED TRAILER WITH CARGO ON BOARD //
	/////////////////////////////////////////////////////////
	// Create the Trailer and children
	incomingJsonString := self.zTFS65549POSTNotify(ThisVoyage, ThisVessel, PrenoteTrailerId, trailerCT.abbreviation, trailerTT.code, operator.code, ChildCargoType, ChildProduct, ChildPreTrailer01, ChildPreTrailer02);
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString, expectFailure);
	self.assertNoTrxErrorsPassport("TEST 11 Trailer creation failed - " &amp; app.myPassport.getErrorsAsString);
	
	realTI := self.getTrackedItem(PrenoteTrailerId);
	self.assertNotNullMsg(realTI, "Test 11 - Trailer prenote");
	self.assertTrueMsg(realTI.allChildren.isEmpty, "Test 11 - Trailer prenote should not have children");
	lc := realTI.CM_TILC.allLCs.first;
	self.assertNotNullMsg(lc, "Test 11 - Trailer prenote locations controller");
	self.assertEqualMsg(lc.allTrackedItems.size, 2, "Test 11 - Trailer prenote does not have 2 onboard cargo items");
	
	////////////////////////////////////////////////////////
	// TEST 12 - PUT PRENOTED TRAILER WITH CARGO ON BOARD //
	////////////////////////////////////////////////////////
	// PUT an update to the Trailer and children
	incomingJsonString := self.zTFS65549PUTNotify(ThisVoyage, ThisVessel, PrenoteTrailerId, trailerCT.abbreviation, trailerTT.code, operator.code, ChildCargoType, ChildProduct, ChildPreTrailer01, ChildPreTrailer02);
	expectFailure := false;
	queryParam := "/Cargo/" &amp; PrenoteTrailerId &amp; "/" &amp; trailerCT.abbreviation &amp; "/" &amp; TI_STATE_NOTIFIED.String &amp; "?MasterTerminalAPI";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, restOperator, incomingJsonString, queryParam, expectFailure);
	self.assertNoTrxErrorsPassport("TEST 12 Trailer prenote update failed - " &amp; app.myPassport.getErrorsAsString);
	
	// Same checks - Trailer should have no children, and 2 onboard cargo items
	realTI := self.getTrackedItem(PrenoteTrailerId);
	self.assertNotNullMsg(realTI, "Test 12 - Trailer prenote");
	self.assertTrueMsg(realTI.allChildren.isEmpty, "Test 12 - Trailer prenote should not have children");
	lc := realTI.CM_TILC.allLCs.first;
	self.assertNotNullMsg(lc, "Test 12 - Trailer prenote locations controller");
	self.assertEqualMsg(lc.allTrackedItems.size, 2, "Test 12 - Trailer prenote does not have 2 onboard cargo items");
	self.assertEqualMsg(realTI.alternativeId, "TEST_CHG", "Test 12 - Trailer prenote alternative ID not updated");
	childrenCorrect := false;
	foreach child in lc.allTrackedItems do
		if child.id = ChildPreTrailer01 and child.alternativeId = "TESTRS_CHG_01" then
			childrenCorrect := true;
		elseif child.id = ChildPreTrailer02 and child.alternativeId = "TESTRS_CHG_02" then
			childrenCorrect := true;
		endif;
	endforeach;
	self.assertTrueMsg(childrenCorrect, "Test 12 - Trailer prenote on board cargo not updated");
	
	/////////////////
	// ALL DONE :) //
	/////////////////
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tPostBooking" id="e6a52d91-c852-43f5-9c1e-645e7240f54e">
        <source>tPostBooking();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
30 March 2023	navpw1	Initial creation TFS: 57264 (57434)
28 Feb 2024		navlw1	Defect 62571: CUX | Booking API - Added subTerminal based on Road, Rail, Ship and Packing
08 March 2024 	naviv1	TFS: 62796 - CR - CUX | EDBIC - Modify Booking API to be independent of Prenotes
15 Mar	2024	navlw1	Bug 62948: CUX FR | Unit Test changes to check dimensions and weight not in Json
26 Mar  2024    navsp1  TFS ChangeRequest 63028: CUX FR* | TK 62942 | EDBIC BOOKING APIs - Add field GoLiveCrit 01*
*/

constants
	BookingRef				: String = self.TFS57264;
