    <JadeMethod name="getCalcType" id="43cd4f15-a3b8-4946-aa33-73685fd9d2ea">
        <source>getCalcType() : CM_CalculationType;
/*
----------   ----------  --------------------------------------------------
Created:	16 January 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
