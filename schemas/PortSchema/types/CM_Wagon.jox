    <JadeMethod name="getWLEforCargo" id="dd9aac5a-abb7-4fb7-8946-7a98f4e6802e">
        <source>getWLEforCargo( _ti : CM_TrackedItem; 
				_reserveDet : CM_ReserveDetail):CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Aug 2019	jlger1	Initial creation tfs 45291 - moved from MOB_HHBRLocLoaderAllCargo getWLEforLocation

*/

vars
	validWleSet : CM_WLESet;
	wle : CM_WorkListEntry;
	
	req : CM_Request;
	resDetail : CM_ReserveDetail;
	lc : CM_LocationsController;
begin
	create validWleSet transient;
	foreach lc in self.allLocationsControllersArray discreteLock do
		foreach wle in lc.CM_WagonController.allRailWLELoad do
			if wle.status = WLE_COMPLETED then
				continue;
			endif;
			if wle.myTrackedItem = null
			or wle.myTrackedItem.isRRP
			or wle.myTrackedItem = _ti
			then
				req := wle.myRequest;
				if req = null then
					continue;
				endif;
				if _reserveDet &lt;&gt; null then
					if req.myReserveDetail &lt;&gt; _reserveDet then
						continue;
					endif;
				endif;
				
				if wle.myTrackedItem = _ti then
					// if its actually this one, use it
					return wle;
					break;
				else
					//otherwise add to the valid set of wles to consider
					validWleSet.addNoDuplicates( wle, false );
				endif;
			endif;
		endforeach;
	endforeach;
	
	if validWleSet.isEmpty and _ti &lt;&gt; null  then
		foreach wle in _ti.allWorklistEntries discreteLock do
			if wle.status = WLE_COMPLETED then
				continue;
			endif;
			if wle.job.isKindOf(CM_RailJob) then
				return wle;
			endif;
		endforeach;
	endif;
	
	return validWleSet.first;
epilog
	delete validWleSet;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_reserveDet" type="CM_ReserveDetail"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getWagonControllerForSlot" id="3186819a-ab21-4594-b8a4-a32b7192a37e">
        <source>getWagonControllerForSlot(	_intendedTI : CM_TrackedItem;
							_mode : Integer;
							_intendedIsoType : CM_ISOType;
							_intendedIsoTypeGroup : CM_ISOTypeGroup;
							_doValidations : Boolean;
							_slotNumber :  String) : CM_WagonController;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2009	cnwphb1	Initial creation (Par 21725)

*/

vars
	lc			: CM_WagonController;
	slotNo,
	maxNumInStack,
	posInStack	: Integer;
begin
	slotNo := self.myWagonClass.locationIds.indexOf(_slotNumber);
	if slotNo = 0 or
	   slotNo &gt; self.allLocationsControllersArray.size then
		return null;
	endif;
	
	maxNumInStack := self.myWagonClass.maxNumInStack;
	lc := self.allLocationsControllersArray[slotNo];
	foreach posInStack in 1 to maxNumInStack do
		//if self.isSlotNumberFree(_intendedTI, posInStack, _intendedIsoType, _mode, _doValidations, slotNo, lc) then
		if self.isSlotNumberFree(_intendedTI, posInStack, _intendedIsoType, _intendedIsoTypeGroup, _mode, _doValidations, slotNo, lc) then//10 May 2010	NDL Par 24064
			return lc;
		endif;
	endforeach;	
	
	return null;
end;</source>
        <Parameter name="_intendedTI" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_intendedIsoType" type="CM_ISOType"/>
        <Parameter name="_intendedIsoTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_doValidations" type="Boolean"/>
        <Parameter name="_slotNumber" type="String"/>
        <ReturnType type="CM_WagonController"/>
    </JadeMethod>
    <JadeMethod name="getWagonInfo" id="86cdfe29-a8e1-4e35-a04a-d7eb57b1d516">
        <source>getWagonInfo(_strArray : HugeStringArray input);
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lString : String;
begin
	//_strArray.add("Wagon ID" &amp; Tab &amp; self.id); //- cnwmd1, CCMS 1067, Par 19710
	_strArray.add(app.getErrorString(CM_Wagon_ID) &amp; Tab &amp; self.id); //+ cnwmd1, CCMS 1067, Par 19710
	//_strArray.add("Confirmed" &amp; Tab &amp; self.confirmed.String.toUpper);  //- cnwmd1, CCMS 1067, Par 19710
	_strArray.add(app.getErrorString(Confirmed) &amp; Tab &amp; self.confirmed.String.toUpper); //+ cnwmd1, CCMS 1067, Par 19710
	if self.myTrainInwards &lt;&gt; null then
		//_strArray.add("Train" &amp; Tab &amp; self.myTrainInwards.code &amp; self.myTrainInwards.description); //- cnwmd1, CCMS 1067, Par 19710
		_strArray.add(app.getErrorString(Train) &amp; Tab &amp; self.myTrainInwards.code &amp; self.myTrainInwards.description); //+ cnwmd1, CCMS 1067, Par 19710
		
	endif;
	
	//_strArray.add("Location" &amp; Tab &amp; self.myRailLine.getIdString &amp; " " &amp; self.getWagonPosition); //- cnwmd1, CCMS 1067, Par 19710
	_strArray.add(app.getErrorString(Location) &amp; Tab &amp; self.myRailLine.getIdString &amp; " " &amp; self.getWagonPosition); //+ cnwmd1, CCMS 1067, Par 19710
	//_strArray.add("Load Weight" &amp; Tab &amp; self.getLoadWeight().String &amp; " Kg"); //- cnwmd1, CCMS 1067, Par 19710
	_strArray.add(app.getErrorString(CM_Load_Weight) &amp; Tab &amp; self.getLoadWeight().String &amp; app.getErrorString(Space_Kg)); //+ cnwmd1, CCMS 1067, Par 19710
	//_strArray.add("Status" &amp; Tab &amp; self.getStatus()); //- cnwmd1, CCMS 1067, Par 19710
	_strArray.add(app.getErrorString(Status) &amp; Tab &amp; self.getStatus()); //+ cnwmd1, CCMS 1067, Par 19710
	
	//_strArray.add("Remarks" &amp; Tab &amp; self.remarks); //- cnwmd1, CCMS 1067, Par 19710
	_strArray.add(app.getErrorString(Remarks_GC) &amp; Tab &amp; self.remarks); //+ cnwmd1, CCMS 1067, Par 19710

	if self.myWagonClass &lt;&gt; null then
		if self.isFlatcarVisit then
			lString := (self.myWagonClass.getLenInUnits * 10).String;
		elseif self.isBoxcarVisit then
			lString := self.myWagonClass.getOverallLengthString;
		endif;
	else
		lString := "";
	endif;
	//_strArray.add("Length" &amp; Tab &amp; lString); //- cnwmd1, CCMS 1067, Par 19710
	_strArray.add(app.getErrorString(Length) &amp; Tab &amp; lString); //+ cnwmd1, CCMS 1067, Par 19710
	
	//th2 added 19/03/2007 - color coding attributes - if any
	//_strArray.add("CC Destination" &amp; Tab &amp; self.getCCDestination); //- cnwmd1, CCMS 1067, Par 19710
	_strArray.add(app.getErrorString(ColorCode_Destination) &amp; Tab &amp; self.getCCDestination); //+ cnwmd1, CCMS 1067, Par 19710
	//_strArray.add("CC Freight Fwdr" &amp; Tab &amp; self.getCCFreightForwarder); //- cnwmd1, CCMS 1067, Par 19710
	_strArray.add(app.getErrorString(Freight_fwdr) &amp; Tab &amp; self.getCCFreightForwarder); //+ cnwmd1, CCMS 1067, Par 19710
	//_strArray.add("CC Release No" &amp; Tab &amp; self.getCCReleaseNo); //- cnwmd1, CCMS 1067, Par 19710
	_strArray.add(app.getErrorString(ColorCode_ReleaseNo) &amp; Tab &amp; self.getCCReleaseNo); //+ cnwmd1, CCMS 1067, Par 19710
	_strArray.add(app.getErrorString(ConsigneeCC) &amp; Tab &amp; self.getCCConsignee); //+ cnwmd1, Par 19989

end;</source>
        <Parameter name="_strArray" type="HugeStringArray" usage="input"/>
    </JadeMethod>
