    <JadeMethod name="addObjectsToTable" id="fd19246c-21fb-4317-9de0-6e59aa00e6cc">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2014	cnwmc5	Initial creation

*/

vars
	iter 		: Iterator;
	customsMsg	: CM_CustomsStatusMessage;
	breakOut 	: Boolean;
	
begin
	
	iter := self.myBOL.allCustomsStatMessageByCodeDT.createIterator;

	self.endNotificationForSubscriber(self);
	
	while iter.next(customsMsg) do
		self.addObjectToTable(customsMsg, _numItems, breakOut);
		
		if breakOut then
			break;
		endif;
	endwhile;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="create" id="e20ca504-ee38-4484-9b70-9508771bf090">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2014	cnwmc5	Initial creation

*/

vars

begin
	self.permissionView := PmAdmEDICustomsMsg;						//cnwmc5 - 22 August 2014
	
	self.setCaption(app.getErrorString(Customs_status_message));	//cnwmc5 - 22 August 2014
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="285cd1af-bbbb-49cb-a879-5e28004ac86e">
        <updating/>
        <source>initDataTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2014	cnwmc5	Initial creation

*/

vars

begin
	
	self.setTblDataEntRows(ETDef_CustomsMessageEnquiry);
	
	self.zClearSortColumns();
	self.zAddSortColumn(ETRow_BOL, false);
	
	self.tblData.resetColumns(false);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="22dec232-559e-49f3-a633-0f16de326ac7">
        <updating/>
        <source>initForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2014	cnwmc5	Initial creation

*/

vars

begin
	
	self.isThumbnailVisible		:= true;
	self.hideShowThumbnail();
	
	self.allowDelete := false; // TFS 2734
	self.allowAdd := false; // TFS 2734
	self.allowUpdate := false; // TFS 2734
	
	self.allowSearch			:= false;
	self.allowTblDataHide 		:= false;
	self.showFilterOnStartup 	:= false;
	self.useNumRowsShown		:= true;

epilog

end;</source>
    </JadeMethod>
