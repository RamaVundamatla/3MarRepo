    <JadeMethod name="addTask" id="e6a017ce-2b85-4cf1-aee7-d100d0088cf3">
        <updating/>
        <source>addTask(_taskObj:MB_ToDoTask input) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Purpose:		Adds a To-Do Task to the reciver.
//
// Parameters:	_taskObj - A reference to the To-Do Task.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	rowObj		: JadeTableRow;
	
begin
	rowPointer			:=	self.addItem(_taskObj.description &amp; Tab &amp; Tab &amp; Tab &amp; _taskObj.completedTs.shortCurrentLocaleFormat(true));
	rowObj				:=	self.accessRow(rowPointer);
	rowObj.itemObject	:=	_taskObj;
	
	if rowPointer.isOdd() then
		rowObj.backColor	:=	self.alternateColor;
	endif;
	
	self.setCellImage(rowPointer);
end;</source>
        <Parameter name="_taskObj" type="MB_ToDoTask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cleanUpTasks" id="9139d597-6191-4110-b9c2-9eb9f6742e48">
        <updating/>
        <source>cleanUpTasks() updating;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Purpose:		Purges any transient task objects in the receiver's rows.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	startRow	: Integer;
	lastRow		: Integer;
	taskObj		: MB_ToDoTask;
	
begin
	startRow	:=	self.fixedRows + 1;
	lastRow		:=	self.rows;
	
	foreach rowPointer in startRow to lastRow do
		taskObj	:=	self.accessRow(rowPointer).itemObject.MB_ToDoTask;
		
		if taskObj &lt;&gt; null then
			delete taskObj;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="click" id="2a78f5ca-d85d-4067-a8be-02b2946ed9d5">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(table: Table input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		30 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (not self.userInputEnabled) or
	   self.readOnly or
	   (not self.enabled) then
		return;
	endif;
	app.mousePointer	:=	Busy;
	inheritMethod(table);
	self.doCellClick(self.row, self.column);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="a0319152-4c0d-4197-9660-642d95c03d12">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		03 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isTransient() then
		self.cleanUpTasks();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCellClick" id="c5c166a9-389f-43ba-8157-641938043fff">
        <updating/>
        <source>doCellClick(_rowPointer:Integer; _colPointer:Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		30 January 2006 by cnwdad1
//
// Purpose:		Action a cell click to determine whether we need to tick or cross
//				it, or update a timestamp.  Refer to the "Column_..." class constants
//				which identify the columns that are relevant.
//
// Parameters:	_rowPointer - The row of the cell that was clicked.
//				_colPointer - The column of the cell that was clicked.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	formObj			: MB_CalendarEntryForm;
	taskObj			: MB_ToDoTask;
	taskState		: Integer;
	isChanged		: Boolean;
	cellTS			: TimeStamp;
	
begin
	if _rowPointer &gt; self.fixedRows
	and _rowPointer &lt;= self.rows
	and (_colPointer = self.Column_Complete or _colPointer = self.Column_Select or _colPointer = self.Column_CompDate)
	then
		taskObj		:=	self.accessRow(_rowPointer).itemObject.MB_ToDoTask;
		taskState	:=	taskObj.newState;
		
		if _colPointer = self.Column_CompDate
		and (taskObj.completedTs &lt;&gt; null or taskObj.txnType = 6)
		then
			cellTS	:=	self.accessCell(_rowPointer, _colPointer).text.trimBlanks().TimeStamp;
			
			create formObj transient;
			
			if cellTS &lt;&gt; null and cellTS.isValid() then
				formObj.setDateTime(cellTS.date, cellTS.time, true);
			endif;
			
			if formObj.showModal() = self.MB_MODAL_SELECT then
				cellTS.setDate(formObj.aDate);
				cellTS.setTime(formObj.aTime);
				self.setCellText(_rowPointer, _colPointer, cellTS.shortCurrentLocaleFormat(true));
				self.updateTS(taskObj.code, cellTS);
			endif;
		else
			isChanged	:=	false;
			
			if _colPointer = self.Column_Select then
				if taskState = DTO_ToDoTask.Add
				or taskState = DTO_ToDoTask.Remove
				then
					// They must be unsetting an "Add/Remove" setting, so set state back to original.
					taskObj.setNewState(taskObj.state);
					isChanged	:=	true;
					
				elseif taskState = DTO_ToDoTask.Selected then
					if taskObj.state = DTO_ToDoTask.Selected then
						taskObj.setNewState(DTO_ToDoTask.Remove);
						isChanged	:=	true;
					else
						taskObj.setNewState(DTO_ToDoTask.UnSelected);
						isChanged	:=	true;
					endif;
				
				elseif taskState = DTO_ToDoTask.UnSelected then
					taskObj.setNewState(DTO_ToDoTask.Add);
					isChanged	:=	true;
				endif;
				
			elseif _colPointer = self.Column_Complete then
				if taskState = DTO_ToDoTask.Complete then
					// They must be unsetting an "Complete" setting, so set state back to original.
					taskObj.setNewState(taskObj.state);
					isChanged	:=	true;
					
				elseif taskObj.state = DTO_ToDoTask.Selected then
					taskObj.setNewState(DTO_ToDoTask.Complete);
					isChanged	:=	true;
				else
					// Cannot change the Completed state of a task that hasn't been selected yet.
					return;
				endif;
			endif;
			
			if isChanged then
				self.setCellImage(_rowPointer);
				self.mbSetIsSaveRequired(true);
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_rowPointer" type="Integer"/>
        <Parameter name="_colPointer" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getChangedTasks" id="5b3a84a2-805f-4b55-b2b6-4cfd8f63c9ff">
        <updating/>
        <source>getChangedTasks(_allTasks:ObjectSet input) updating;
// --------------------------------------------------------------------------------
// Created:		30 January 2006 by cnwdad1
//
// Purpose:		Populates the parameter set with all of the task objects that have
//				been changed by the user.
//
// Parameters:	_allTasks - A reference to a set to populate.
//
// Returns:		The populated set of changed tasks.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	startRow	: Integer;
	lastRow		: Integer;
	taskObj		: MB_ToDoTask;
	
begin
	startRow	:=	self.fixedRows + 1;
	lastRow		:=	self.rows;
	
	foreach rowPointer in startRow to lastRow do
		taskObj	:=	self.accessRow(rowPointer).itemObject.MB_ToDoTask;
		
		if taskObj.newState &lt;&gt; taskObj.state then
			_allTasks.add(taskObj);
		endif;
	endforeach;
end;</source>
        <Parameter name="_allTasks" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mbSetIsSaveRequired" id="18299a9f-a580-4ee3-8b95-d778fc32f756">
        <updating/>
        <source>mbSetIsSaveRequired(_isRequired:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		30 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isSaveRequired	:=	_isRequired;
	self.form.mbSetIsSaveRequired(_isRequired);
end;</source>
        <access>protected</access>
        <Parameter name="_isRequired" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCellImage" id="5ad54ce5-781c-4159-b768-3832f78f751c">
        <updating/>
        <source>setCellImage(_rowPointer:Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Purpose:		Sets the image for the specified cell.
//
// Parameters:	_rowPointer - The row of the cell.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowObj		: JadeTableRow;
	taskObj		: MB_ToDoTask;
	taskState	: Integer;
	
begin
	rowObj		:=	self.accessRow(_rowPointer);
	taskObj		:=	rowObj.itemObject.MB_ToDoTask;
	taskState	:=	taskObj.newState;
	
	if taskState = DTO_ToDoTask.Selected then
		self.accessCell(_rowPointer, self.Column_Select).picture	:=	self.imageTick;
		self.accessCell(_rowPointer, self.Column_Complete).picture	:=	null;
	elseif taskState = DTO_ToDoTask.Add then
		self.accessCell(_rowPointer, self.Column_Select).picture	:=	self.imageTick;
		self.accessCell(_rowPointer, self.Column_Complete).picture	:=	null;
	elseif taskState = DTO_ToDoTask.Remove then
		self.accessCell(_rowPointer, self.Column_Select).picture	:=	self.imageCross;
		self.accessCell(_rowPointer, self.Column_Complete).picture	:=	null;
	elseif taskState = DTO_ToDoTask.Complete then
		self.accessCell(_rowPointer, self.Column_Select).picture	:=	self.imageTick;
		self.accessCell(_rowPointer, self.Column_Complete).picture	:=	self.imageTick;
	elseif taskState = DTO_ToDoTask.UnSelected then
		self.accessCell(_rowPointer, self.Column_Select).picture	:=	null;
		self.accessCell(_rowPointer, self.Column_Complete).picture	:=	null;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_rowPointer" type="Integer"/>
    </JadeMethod>
    <ExternalMethod name="updateTS" id="45eeb4f5-3fc0-4fb0-89d7-6c1df1a8eefd">
        <updating/>
        <entrypoint>CallControlEvent</entrypoint>
        <library name="jadpmap"/>
        <source>updateTS(_taskCode:Integer; _timeStamp:TimeStamp):Boolean is "CallControlEvent" in "jadpmap" updating;</source>
        <Parameter name="_taskCode" type="Integer"/>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </ExternalMethod>
    <JadeMethod name="windowCreated" id="d0000683-a6d2-407e-9ad6-74524a055253">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	self.fixed3D				:=	false;
	self.partialTextIndication	:=	true;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
