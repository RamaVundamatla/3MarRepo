    <JadeMethod name="copyToRealWSObject" id="75c57e40-d8ac-4b97-b16c-135571cc453c">
        <source>copyToRealWSObject(_realRequest: SAP13_AutocollInvoiceRequest_DT_T_Ship_Item input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.basePort := self.basePort;
	_realRequest.callSign := self.callSign;
	_realRequest.countryID := self.countryID;
	_realRequest.dataSource := self.dataSource;
	_realRequest.destinationPort := self.destinationPort;
	_realRequest.flag1 := self.flag1;
	_realRequest.invoiceID := self.invoiceID;
	_realRequest.itemNo := self.itemNo;
	_realRequest.lineType := self.lineType;
	_realRequest.prodCode := self.prodCode;
	_realRequest.shipCode := self.shipCode;
	_realRequest.shipGT := self.shipGT;
	_realRequest.shipLOA := self.shipLOA;
	_realRequest.shipName := self.shipName;
	_realRequest.shipType := self.shipType;

epilog

end;</source>
