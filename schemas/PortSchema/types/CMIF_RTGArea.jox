    <JadeMethod name="createTerminalArea" id="c4ad9dcf-94d0-493c-bd94-922f1aa49d93">
        <updating/>
        <source>createTerminalArea() updating;
/*
----------   ----------  --------------------------------------------------
Created:	28 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	
	self.labelLengthRow := self.numRows.String.length;
	
	// because we have BAY IDs for RTGs it means that we can have 3 digit bay ids, so need to zero fill correctly.
	self.labelLengthCol := (self.numColumns * self.incrementColNumBy).String.length;
	
	inheritMethod();
end;</source>
    </JadeMethod>
