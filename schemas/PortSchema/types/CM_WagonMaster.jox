    <JadeMethod name="autoCreateFromWagon" id="34007730-7c8d-409b-91ae-cc70e7d7ac22">
        <updating/>
        <source>autoCreateFromWagon(_wagon : CM_Wagon) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 July 2009	cnwndl1	Initial creation

*/

vars

begin

	self.raiseExceptionIfNotTransient(method);
	
	self.autoCreated := true;
	
	self.setProxy(	_wagon.id,	//_id : String;
					_wagon.myWagonClass,	//_myWagonClass : CM_WagonClass;
					_wagon.myCarrier,	//_myCarrier : CM_Carrier;
					_wagon.getMaxCargoHeight,	//_maxCargoHeight	: Decimal; 	//Par 21924
					_wagon.getMaxCargoWeight,	//_maxCargoWeight	: Decimal;	//Par 21924
					_wagon.getWagonTareWeight	//_tareWeight	: Decimal	//Par 21924
					);
					
	self.setPropogateChanges(false);
	
		
epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
