    <JadeMethod name="doOK" id="c4640341-9e40-4d6b-a3d0-9461f0f02a45">
        <updating/>
        <source>doOK() updating;
/*
------------------------------------------------------------------------
Created:			08 September 2003 by cnwdwq1
Purpose:			Print whatever they have selected.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	requiredCopies : Integer;
	pageData : JadePrintPage;
	currentCopy : Integer;
	i : Integer;
begin
	app.mousePointer := Busy;
	//------------------
	//Validate # of copies requested
	//------------------
	requiredCopies := txtNumPages.text.Integer;
	if requiredCopies &lt; 1 then
		app.msgBox('You must enter &gt; 0 copies to print', 'Invalid Copies', MsgBox_Exclamation_Mark_Icon	);
		global.beep;
		return;
	endif;

	if optSelected.value then
		//If we have text validate it
		if txtSelectedPages.text.trimBlanks &lt;&gt; null  then
			if not processSelectedPages then
				global.beep;
				return;
			endif;
		endif;
	elseif optAllPages.value then
		currentCopy := 1;
		app.printerFixPAR34782(self.myJadeReport);

		while currentCopy &lt;= requiredCopies do
			app.printer.printReport(self.myJadeReport);
			currentCopy := currentCopy +1;
		endwhile;
		return;
	else
		//Current page selected, add to array by itself.
		self.pagesToPrint.clear;
		self.pagesToPrint.add(currentPage);
	endif;
	
	// ### TFS 52590 31Jan2022 NAVPW1 (app.printer.sendMsg('_openPrinter') Was causing issues with printing and raising "1192: Feature is restricted to system processes")
	//app.printer.sendMsg('_openPrinter');	//Hidden method, else we get a CRASH! 
	
	currentCopy := 1;
	while currentCopy &lt;= requiredCopies do
		currentCopy := currentCopy + 1;
		foreach i in self.pagesToPrint do
			pageData := self.myJadeReport.getPage(i);
			// added 20/03/06 re par 11436 HG
			// following two lines code added due to Jade PAR34782 - blank page being printed first 
			app.printer.orientation := pageData.orientation;
			app.printer.documentType := pageData.documentType;
			app.printer.printPage(pageData);
		endforeach;
	endwhile;
	app.printer.close;
	unloadForm;
epilog
	app.mousePointer := Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAPage" id="cce36a16-cc22-4f49-8ea8-0285fc75087d">
        <updating/>
        <source>getAPage(_pos : Integer io ; _text : String; _page : Integer output; _range : Boolean output) : Boolean updating, protected;
/*
------------------------------------------------------------------------
Created:			08 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	length      : Integer;
	hadSpace    : Boolean;
	newString   : String;
	index       : Integer;
begin
	length := _text.length;

	while _pos &lt;= length do
		if _text [ _pos ] &lt;&gt; ' ' then
			if _text [ _pos ].isNumeric then 
				break;
			else
				return false;
			endif;
		endif;
		_pos := _pos + 1;
	endwhile;
	//
	//	Check here for trailing rubbish
	//
	if _pos &gt; length then
		return false;
	endif;
	
	newString := _text [ _pos ];

	_pos := _pos + 1;
	while _pos &lt;= length do
		if _text [ _pos ] &lt;&gt; ' ' then
			if _text [ _pos ].isNumeric then 
				if hadSpace then
					return false;
				else
					newString := newString &amp; _text [ _pos ];
				endif;
			else
				if _text [ _pos ] = ',' then
					_range := false;
					_pos := _pos + 1;
					break;
				endif;
			 	if _text [ _pos ] = '-' then 
			 		_range := true;
					_pos := _pos + 1;			 		
			 		break;
			 	endif;
			 	return false;

			 endif;
		else
			hadSpace := true;
		endif;		
		_pos := _pos + 1;
	endwhile;

	_page := newString.Integer;
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_pos" type="Integer" usage="io"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_page" type="Integer" usage="output"/>
        <Parameter name="_range" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
