<Class name="CMQF_Empty">
    <JadeMethod name="setFromAgent" id="e22a53c3-4496-4601-a222-f4694fa660dc">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
//----------------------------------------------------------------
//	Created:	29 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	value : String;
begin
	inheritMethod(_agent);

	value := _agent.getValueByNameIfVisible(ETRow_PrintMTSummaryRep).String;

//	if value = '0' then
//		self.printMTSummaryRep := false;
//	else
//		self.printMTSummaryRep := true;
//	endif;
// 'true' or 'false' string canbe returned
	if value.length = 0 then 
		self.printMTSummaryRep 		:= false;
	elseif value[1] = '1' then
		self.printMTSummaryRep 		:= true;
	else
		self.printMTSummaryRep 		:= value.Boolean;		
	endif;		

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
