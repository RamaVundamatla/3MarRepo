    <JadeMethod name="aUtlSample" id="041f4978-83be-4371-9b1e-7e18e190e043">
        <source>aUtlSample(_pxyObject : CM_TrxTestObject; _realObject : CM_TrxTestObject output; 
			_controller : CM_TrxTestController; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     03 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.aValSample(_pxyObject, _controller);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	create _realObject as _pxyObject.class persistent;
	_realObject.setForCreate(_pxyObject, _controller);
	
	if _passport.noErrors then
		// only required if the class is audited
		self.myCreateAuditAgent.audCreateGeneric(_realObject);
	endif;

end;</source>
        <Parameter name="_pxyObject" type="CM_TrxTestObject"/>
        <Parameter name="_realObject" type="CM_TrxTestObject" usage="output"/>
        <Parameter name="_controller" type="CM_TrxTestController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="d3f1222e-913d-4f2b-9abd-81a2e400355f">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	// deleted via parent-child relationship
	create self.myCreateAuditAgent transient;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createUpdateVBSFromEDIBR" id="5e1383ed-0a2f-41e9-9b28-b7e3b1dadc0d">
        <updating/>
        <source>createUpdateVBSFromEDIBR(_cmifRelease : CMIF_EDIReleaseRequest; _release : CM_BulkRelease; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/07/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / Data Load
// 28/08/2023	navdap1		TFS 60115 EUP FR CallOff
// 17/10/2023	navdap1		TFS 60856 EUP CallOff - When operational data is updated, VBS information is modified but not able to edit it 
// 08 Aug 2024 	navcs2		ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
// 06 May 2025	naviv1		MTN-34689 - EUP FR | 54084 - CallOff - Weight is not populated on the release detail line in CallOffStockMove
vars
	terminal : CM_Terminal;
	vbsTerminal : CM_VehicleBookingTerminal;
	obj : Object;
	releaseHeader : CM_EDIRequestHeaderTI;
	vbsType : String;
	vbsExternalReference : String;
	carrierCode : String;
	subCarrierCode : String;
	truckReg : String;
	vbs, pxyVbs : CM_VehicleBookingTimeSlot;
	carrier, subCarrier : CM_Carrier;
	truck : CM_Vehicle;
	vbsTypeObj : CM_VehicleBookingTimeSlotType;
	brSet : CM_BulkReleaseSet;
	scheduleStart, scheduleEnd : TimeStamp;
	driver : CM_DriverDetails;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	allSlotItems : CM_VehicleBookingTSItemSet;	// TFS 60115
	reserve : CM_ReserveDetail;					// TFS 60115
	slotItem : CM_VehicleBookingTimeSlotItem;	// TFS 60115
	selection : CM_ReserveSelection;			// TFS 60115
	ediData : CM_EDIData;
	ediDataCallOff : CM_EDIDataCallOff;
	item : CM_VehicleBookingTimeSlotItem;			// TFS 60856
	itemsToDelete : CM_VehicleBookingTSItemSet;		// TFS 60856
	pxyMaxWeight : Decimal[4];
begin
	// get the VBS details from the cmif
	obj := _cmifRelease.allEDITIs.first;
	if not obj.isKindOf(CM_EDIRequestHeaderTI) then
		return;
	endif;
	releaseHeader := obj.CM_EDIRequestHeaderTI;
	if releaseHeader.vbsExternalNumber = null and releaseHeader.vbsSlotType = null then
		return;
	endif;
	terminal := _passport.myTerminal;
	vbsTerminal := terminal.myVehicleBookingTerminal;
	if vbsTerminal = null then
		return;
	endif;
	
	//13.Oct.2023 navsp1 TFS 60785
	//For EDI message type "CallOffWithoutTransport", there are no transport details, so skip Create or Update Vehicle Booking.
	ediData := obj.CM_EDITrackedItem.myEDIData;
	if ediData &lt;&gt; null and ediData.isKindOf(CM_EDIDataRequestMultiLine) then
		ediDataCallOff := ediData.CM_EDIDataRequestMultiLine.myEDIDataCallOff;
		if ediDataCallOff &lt;&gt; null and ediDataCallOff.type = CM_EDIDataCallOff.CallOffWithoutTransport then
			return; 
		endif;
	endif;
	
	// create or update a vehicle booking slot based on data from the EDI release request
	vbsExternalReference := releaseHeader.vbsExternalNumber.toUpper;
	vbsType := releaseHeader.vbsSlotType;
	carrierCode := releaseHeader.carrierCode;
	subCarrierCode := releaseHeader.subCarrierCode;
	truckReg := releaseHeader.regNumber;
	
	carrier := app.myRoot.allCarriers[carrierCode];
	if subCarrierCode &lt;&gt; null then
		subCarrier := app.myRoot.allCarriers[subCarrierCode];
	endif;
	truck := terminal.vehicles[truckReg, null];
	if truck &lt;&gt; null then
		driver := truck.allDrivers.first;
	endif;
	
	// VBS Type - use type from the EDI message, otherwise try to derive one from criteria
	if vbsType &lt;&gt; null then
		vbsTypeObj := terminal.allTerminalVBSSlotTypes[vbsType];
	else
		// try and find one using criteria - Cargo type, cargo subtype, commodity, carrier and operator
		// If we're coming from a CallOff message, we won't have cargo type, cargo subtype or commodity
		cargoType := _release.getMyCargoType();
		operator := _release.myOperator;
		vbsTypeObj := app.findVBSlotTypeWithCriteria(cargoType, null, null, carrier, operator);
	endif;
	if vbsTypeObj = null then
		app.raiseCMException1(VBS_type_invalid, vbsType, null, null);
		return;
	endif;
	
	if releaseHeader.estimatedRequiredDate.isValid then
		scheduleStart := releaseHeader.estimatedRequiredDate;
		scheduleEnd := releaseHeader.estimatedRequiredDate.addMinutes(vbsTypeObj.duration);
	else
		scheduleStart := app.actualTimeServer.addDays(7);
		scheduleEnd := scheduleStart.addMinutes(vbsTypeObj.duration);
	endif;
	
	create brSet transient;
	brSet.add(_release);
	
	vbs := vbsTerminal.allVBTimeslotsByExtRef[vbsExternalReference];
	if vbs = null then
		create pxyVbs transient;
		pxyVbs.setProxy(	scheduleStart, 
							scheduleEnd,
							vbsTerminal,
							carrier,
							subCarrier,
							driver,
							truck,
							releaseHeader.remarks,
							false,
							true,
							null,
							null,
							vbsTypeObj,
							vbsTerminal.generateNextVBSTimeslotId(),
							null,
							brSet,
							null,
							vbsTypeObj.preGateInCheck,
							vbsTypeObj.preGateOutCheck,
							vbsTypeObj.kioskCheck,
							vbsExternalReference,
							null);			// 08 Aug 2024 navcs2	ChangeRequest 63928
	else
		// TFS 60856 get rid of vbs slot items that point to deleted reserve selection objects
		if vbs &lt;&gt; null then
			create itemsToDelete transient;
			foreach item in vbs.allVehicleBookingItems where not app.isValidObject(item.myReserveDetails) do
				itemsToDelete.add(item);
			endforeach;
			itemsToDelete.purge;
		endif;
		// TFS 60856 end
		
		vbs.allBulkReleases.copyNoDuplicates(brSet, false);
		pxyVbs := app.myProxyManager.getProxyObject(vbs).CM_VehicleBookingTimeSlot;
		if pxyVbs = null then
			pxyVbs := vbs.pxyCreateUpdateProxy();
		endif;
		pxyVbs.setProxy(	vbs.bookingTSstart, 
							vbs.bookingTSend,
							vbsTerminal,
							carrier,
							subCarrier,
							vbs.myDriver,
							truck,
							releaseHeader.remarks,
							vbs.includesDelivery,
							true,
							vbs.allTiIds,
							vbs.myVehicleVisitRecord,
							vbsTypeObj,
							vbs.id,
							vbs.allBookingRefs,
							brSet,
							vbs.allVehicleBookingItems,
							vbs.preGateInCheck,
							vbs.preGateOutCheck,
							vbs.kioskCheck,
							vbsExternalReference	,
							null);							// 08 Aug 2024 navcs2	ChangeRequest 63928
	endif;
	
	// TFS 60115 Create VBS Slot items for each item in the release request
	create allSlotItems transient;
	foreach reserve in _release.allReserveDetails where reserve.isKindOf(CM_ReserveSelection) do
		selection := reserve.CM_ReserveSelection;
		create slotItem transient;
		if selection.byTypeByWeight then //MTN-34689 -- passing weightRequested value as maxWeight, since the maxWeight is not defined as part of the callOff EDI message by Euroports
			pxyMaxWeight := selection.weightRequested;
		endif;
		
		slotItem.setProxy(DIRECTION_PICKUP, null, null, _release, reserve, null, pxyVbs, selection.totalRequested, null, 2, selection.weightRequested, selection.volumeSelection,
							pxyMaxWeight); // ### TFS 61525 (61527) 11Jul2024 NAVPW1 //MTN-34689

		allSlotItems.add(slotItem);
	endforeach;
	// TFS 60115 end
	
	if vbs = null then
		self.utlCreateVehicleBookingAdv(pxyVbs, vbs, allSlotItems, false, _passport);
	else
		app.myUtilityUA.utlUpdateVehicleBookingAdv(pxyVbs, null, null, null, _passport);
	endif;
	
epilog
	delete brSet;
	delete pxyVbs;
	delete allSlotItems;		// TFS 60115
	delete itemsToDelete;		// TFS 60856
end;</source>
        <Parameter name="_cmifRelease" type="CMIF_EDIReleaseRequest"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAddHMSResources" id="e7a71d17-58b1-4f4d-9506-4219ea327a1f">
        <source>utlAddHMSResources(	allMarineServiceDetails : CM_WodMarineServiceDetailSet;
					_voyageStatus : CM_VoyageStatus;
					_harbour : HMS_Harbour;
					_movement : HMS_VoyageMovement input;
					_passport : CM_Passport input
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2018	jlgndl1	Initial creation	TFS 39900

*/

vars

	marineServiceDetail : CM_WodMarineServiceDetail;
	pxyResourceUsed : HMS_ResourceUsed;
	resourceUsed : HMS_ResourceUsed;

begin

	foreach marineServiceDetail in allMarineServiceDetails do
		if _voyageStatus &lt;&gt; null and  not _voyageStatus.allHMSResourcesApproval.includes( marineServiceDetail.myHMSResource) then
			continue;
		endif;
		
		create pxyResourceUsed transient;
		pxyResourceUsed.setProxy(	_harbour,	//_harbour : HMS_Harbour;
									null,	//_resourceType : HMS_ResourceType;
									marineServiceDetail.myHMSResource,	//_rescource : HMS_Resource;
									null,	//_pxyVTMISTrans : HMS_VTMISTransaction;
									marineServiceDetail.fromDateTime,	//_fromDateTime : TimeStamp;
									marineServiceDetail.toDateTime,	//_toDateTime : TimeStamp;
									marineServiceDetail.unitsUsed,	//_unitsUsed : Real;
									false,	//_poc : Boolean;
									marineServiceDetail,	//_wodOrderVoyageDtl : CM_WorkOrderVoyageDtl //31 Oct 2018	NDL	TFS 41281 
									marineServiceDetail.myDebtor	//_debtor : CM_Debtor	//26 Nov 2018	NDL	TFS 41980
									);
		create resourceUsed;
		_movement.allResourceUsed.add(resourceUsed);
		resourceUsed.setForCreate(pxyResourceUsed, app.myPassport);
		
		if _passport.hasErrors then
			break;
		endif;
		
		delete pxyResourceUsed;
		
	endforeach;

epilog

	delete pxyResourceUsed;

end;</source>
        <Parameter name="allMarineServiceDetails" type="CM_WodMarineServiceDetailSet"/>
        <Parameter name="_voyageStatus" type="CM_VoyageStatus"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_movement" type="HMS_VoyageMovement" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAddToDoTasks" id="fffeccbb-f97d-4ce7-a4ff-3ad6d551e264">
        <updating/>
        <source>utlAddToDoTasks(_ti : CM_TrackedItem input; _allTasks : CMIF_TiToDoTasksArray; _passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API

*/

vars
	taskDesc    : CM_ToDoTaskDesc;
	cmifToDo    : CMIF_TiToDoTasks;
	todoTask    : CM_ToDoTask;
begin
	self.initialiseActivity();
	
	exclusiveLock(_ti);
	
	foreach  cmifToDo in _allTasks do
		
		taskDesc := cmifToDo.myToDoTaskDesc;
		
	 	todoTask := _ti.addToDoTask(taskDesc.description, _passport);
		
		if not  _passport.hasErrors then
			if todoTask &lt;&gt; null then
				if cmifToDo.remarks &lt;&gt; null then
					todoTask.setRemarks(cmifToDo.remarks);
				endif;
			endif;
		endif;
	endforeach;
	
	if _passport.hasErrors then
		return;
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_allTasks" type="CMIF_TiToDoTasksArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAutoGateIn" id="6b9dbdcf-2e46-4b08-9248-679ea1215ef1">
        <updating/>
        <source>utlAutoGateIn(	_pxyVVR 	: CM_VehicleVisitRecord io;
				_batNumber	: String;
				_vvr		: CM_VehicleVisitRecord output;
				_passport	: CM_Passport input) updating;
/*

Purpose:			Moved from trxAutoGateIn so it can go into a retry loop

Parameters:			

Return Value:		

Date				Who		Reason
22 September 2020	jlgmd1	TFS 50084 STWR - DoAutoGateIn webservice locks - Initial creation

*/

vars
	pxyTIs		: CM_ObjectByStringDict;
	realVVR		: CM_VehicleVisitRecord;
	ti			: CM_TrackedItem;
	gate		: CM_Gate;
	item		: CMGTE_Entity;
	location	: CM_LocationsController;
	wle			: CM_WorkListEntry;
	yIc			: CM_YardInterchangeArea;
	yc			: CM_YardController;
	roadJob		: CM_RoadJob;
	rfidTag		: CM_RFIDTag;
begin
	// This will hold a collection of validated TIs.
	create pxyTIs transient;
	_pxyVVR.validateForCreate(_passport);
	_pxyVVR.validateForCreateJobFlexi(_passport, pxyTIs, false);
	endLoad;		// to clear any locks that may have been held as part of validation
	
	if _passport.hasErrors() then
		return;
	endif;

	app.setContinueCMExceptions(false);

	// Start the transaction
	beginTransaction;
	
	//create the gate in base objects
	app.myUtilityCA.utlCreateVehicleVisitFlexi(_pxyVVR, realVVR, _passport);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	realVVR.createSecGateDetForWebAutoGate( _batNumber );
	
	if _passport.hasErrors() then
		return;
	endif;

	//move the truck to the lane
	gate := realVVR.getGateIn();
	if gate &lt;&gt; null and realVVR.myGateLaneController &lt;&gt; null then
		if realVVR.vehicle.myPrimaryActualLocation &lt;&gt; realVVR.myGateLaneController then 
			app.myUtilityUA.utlMoveVehicle(realVVR.vehicle, realVVR.myGateLaneController, _passport);
		endif;
		yIc := gate.myDefaultInterchangeArea.CM_YardInterchangeArea;
	endif;	

	if _passport.hasErrors() then
		return;
	endif;	
	
	// Try and avoid deadlocks while users are staging cargo
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	//create the road jobs
	app.myUtilityCA.utlCreateInOutFlexiJob(realVVR, _passport, pxyTIs);
	
	if _passport.hasErrors() then
		_passport.clearDeferUpdatesCollections();
		return;
	else
		_passport.doDeferredUpdates();
	endif;
	
	//26 Nov 2015	NDL	Par 37084
	roadJob := realVVR.myRoadJob;
	if roadJob &lt;&gt; null and _batNumber &lt;&gt; null then
		rfidTag := _passport.myTerminal.allRFIDTagsByCode[_batNumber];
		if rfidTag &lt;&gt; null then
			app.myUtilityUA.utlUpdateRoadJobRFIDTag(roadJob,rfidTag);
			if _passport.hasErrors() then
				return;
			endif;
		endif;
	endif;
	
	//move the truck into the yard
	if yIc &lt;&gt; null then
		yc := yIc.getLocationsController.CM_YardController;
		if yc &lt;&gt; null then
			app.myUtilityUA.utlMoveVehicle(realVVR.vehicle, yc, _passport);
		endif;
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;	
	
	if _passport.hasWarnings() and not _passport.warningsAcknowledged then
		// if auto plan has failed because warnings not yet acknowledged, need to go around again.
		return;
	endif;
	
	//move the pre notes off the truck into the yard
	foreach item in realVVR.allGateEntities do
		if item.isKindOf(CMGTE_Receival) and item.CMGTE_Receival.myTrackedItem &lt;&gt; null then
			ti := item.CMGTE_Receival.myTrackedItem;
			location := ti.myPrimaryQueuedLocation;
			if location = null or ti.allWorklistEntries.isEmpty then
				app.raiseCMException1( Auto_plan_failed_find_locati, ti.id, null, null );
				return;
			endif;
			wle := ti.allWorklistEntries.first;
			ti.moveToLocation(location, realVVR.myRoadJob, wle, null, REAL_MODE, false, true, false, false, false,  false, null, null, null, null,realVVR,_passport);
			if _passport.hasErrors() then
				return;
			endif;	
		endif;
	endforeach;
	
	if realVVR &lt;&gt; null then
		realVVR.setIsUpdatable(false);
	endif;
	
	_vvr := realVVR;

epilog
	pxyTIs.purge();
	
	delete pxyTIs;
end;</source>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord" usage="io"/>
        <Parameter name="_batNumber" type="String"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlConvertToNewStorageDetail" id="36b8a7b2-a1a6-4daa-b9ad-34db965b3082">
        <updating/>
        <source>utlConvertToNewStorageDetail(	_operatorTerminal : CM_OperatorTerminal;
								_newStorageConfig : CM_StorageConfig input;
								_passport : CM_Passport input
								) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	jlgndl1	Initial creation	TFS 45574

*/

vars

	operator : CM_Operator;
	operatorCode : String;
	pxyStorageDetail : CM_StorageDetail;
	newStorageDetail : CM_StorageDetail;
	
	proxyCriteria1 : CM_YACriteria;
	proxyCriteria2 : CM_YACriteria;
	proxyCriteria3 : CM_YACriteria;
	
	criteriaType : CM_YACriteriaType;
	itemCode : String;
	value : Any;
	
	contCargoType : CM_CargoType;

begin

	operator := _operatorTerminal.myOperator;
	
	if operator = null then
		return;
	endif;
	operatorCode := operator.code;
	contCargoType := app.myRoot.allCargoTypesById.getAtKey(TI_CargoType_Container);

	if _operatorTerminal.emptyFreeStorageDays &gt; 0 then
		create pxyStorageDetail transient;
		pxyStorageDetail.setValues(	0,	//_chargedDaysType : Integer;
									0,	//_freeDaysType : Integer;
									_operatorTerminal.emptyFreeStorageDays,	//_freeStorageDays : Integer;
									_newStorageConfig,	//_config : CM_StorageConfig;
									0,	//_chargeDays : Integer;
									0,	//_priorityValue : Real;
									0,	//_stopFreeDays : Integer;
									0,	//_recievalDateRule : Integer;
									false, //_noStorageIfNotFullyReceived : Boolean;
									null,	//_futureStorageStop : CM_StopsTable;
									"CONT MT " &amp; operatorCode,	//_desc : String
									-1, //_roadReceival : Integer;
									-1, //_shipReceival : Integer;
									-1, //_railReceival : Integer;
									-1, //_unpackReceival : Integer;
									null, //_allAdditionalCalendars : CM_CalendarByCodeDict
									-1, //_cooFreeStorageDays : Integer;
									-1, // _cooFreeDaysType : Integer
									false, //_includeFirstDay : Boolean;
									false	//_includeLastDay : BOolean
									);
		
		create proxyCriteria1 transient;
		criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]; 
		itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.getLengthForString);
		value := contCargoType.getYAIdentifier();
		proxyCriteria1.setProxy(criteriaType, value, itemCode);
		proxyCriteria1.setYardAllocation(pxyStorageDetail);
		
		create proxyCriteria2 transient;
		criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_OperatorItem]; 
		itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.getLengthForString);
		value := operator.getYAIdentifier();
		proxyCriteria2.setProxy(criteriaType, value, itemCode);
		proxyCriteria2.setYardAllocation(pxyStorageDetail);
		
		create proxyCriteria3 transient;
		criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_ContentsStatus]; 
		itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.getLengthForString);
		value := "MT";
		proxyCriteria3.setProxy(criteriaType, value, itemCode);
		proxyCriteria3.setYardAllocation(pxyStorageDetail);
	
		self.utlCreateStorageDetail( pxyStorageDetail, null, newStorageDetail, _passport);
		
		delete proxyCriteria1;
		delete proxyCriteria2;
		delete proxyCriteria3;
		delete pxyStorageDetail;
		if _passport.hasErrors then
			return;
		endif;
		
		newStorageDetail.recalculateCriteriaPriorities();
	
	endif;
	
	if _operatorTerminal.freeStorageDays &gt; 0 then
		create pxyStorageDetail transient;
		pxyStorageDetail.setValues(	0,	//_chargedDaysType : Integer;
									0,	//_freeDaysType : Integer;
									_operatorTerminal.freeStorageDays,	//_freeStorageDays : Integer;
									_newStorageConfig,	//_config : CM_StorageConfig;
									0,	//_chargeDays : Integer;
									0,	//_priorityValue : Real;
									0,	//_stopFreeDays : Integer;
									0,	//_recievalDateRule : Integer;
									false, //_noStorageIfNotFullyReceived : Boolean;
									null,	//_futureStorageStop : CM_StopsTable;
									"GENERAL CARGO " &amp; operatorCode,	//_desc : String
									-1, //_roadReceival : Integer;
									-1, //_shipReceival : Integer;
									-1, //_railReceival : Integer;
									-1, //_unpackReceival : Integer;
									null, //_allAdditionalCalendars : CM_CalendarByCodeDict
									-1, //_cooFreeStorageDays : Integer;
									-1, // _cooFreeDaysType : Integer
									false, //_includeFirstDay : Boolean;
									false	//_includeLastDay : BOolean
									);
		
		create proxyCriteria2 transient;
		criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_OperatorItem]; 
		itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.getLengthForString);
		value := operator.getYAIdentifier();
		proxyCriteria2.setProxy(criteriaType, value, itemCode);
		proxyCriteria2.setYardAllocation(pxyStorageDetail);
		
		self.utlCreateStorageDetail( pxyStorageDetail, null, newStorageDetail, _passport);
		
		delete proxyCriteria1;
		delete proxyCriteria2;
		delete proxyCriteria3;
		delete pxyStorageDetail;
		if _passport.hasErrors then
			return;
		endif;
		
		newStorageDetail.recalculateCriteriaPriorities();
		
	endif;
	
	if _operatorTerminal.fullFreeStorageDays &gt; 0 then
		create pxyStorageDetail transient;
		pxyStorageDetail.setValues(	0,	//_chargedDaysType : Integer;
									0,	//_freeDaysType : Integer;
									_operatorTerminal.fullFreeStorageDays,	//_freeStorageDays : Integer;
									_newStorageConfig,	//_config : CM_StorageConfig;
									0,	//_chargeDays : Integer;
									0,	//_priorityValue : Real;
									0,	//_stopFreeDays : Integer;
									0,	//_recievalDateRule : Integer;
									false, //_noStorageIfNotFullyReceived : Boolean;
									null,	//_futureStorageStop : CM_StopsTable;
									"CONT FCL " &amp; operatorCode,	//_desc : String
									-1, //_roadReceival : Integer;
									-1, //_shipReceival : Integer;
									-1, //_railReceival : Integer;
									-1, //_unpackReceival : Integer;
									null, //_allAdditionalCalendars : CM_CalendarByCodeDict
									-1, //_cooFreeStorageDays : Integer;
									-1, // _cooFreeDaysType : Integer
									false, //_includeFirstDay : Boolean;
									false	//_includeLastDay : BOolean
									);
									
		create proxyCriteria1 transient;
		criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]; 
		itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.getLengthForString);
		value := contCargoType.getYAIdentifier();
		proxyCriteria1.setProxy(criteriaType, value, itemCode);
		proxyCriteria1.setYardAllocation(pxyStorageDetail);
		
		create proxyCriteria2 transient;
		criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_OperatorItem]; 
		itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.getLengthForString);
		value := operator.getYAIdentifier();
		proxyCriteria2.setProxy(criteriaType, value, itemCode);
		proxyCriteria2.setYardAllocation(pxyStorageDetail);
		
		create proxyCriteria3 transient;
		criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_ContentsStatus]; 
		itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.getLengthForString);
		value := "FCL";
		proxyCriteria3.setProxy(criteriaType, value, itemCode);
		proxyCriteria3.setYardAllocation(pxyStorageDetail);
		
		self.utlCreateStorageDetail( pxyStorageDetail, null, newStorageDetail, _passport);
		
		delete proxyCriteria1;
		delete proxyCriteria2;
		delete proxyCriteria3;
		delete pxyStorageDetail;
		if _passport.hasErrors then
			return;
		endif;
		
		newStorageDetail.recalculateCriteriaPriorities();
		
	endif;

epilog

	delete proxyCriteria1;
	delete proxyCriteria2;
	delete proxyCriteria3;
	delete pxyStorageDetail;

end;</source>
        <Parameter name="_operatorTerminal" type="CM_OperatorTerminal"/>
        <Parameter name="_newStorageConfig" type="CM_StorageConfig" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCopyInvAttachments" id="9c7c87f7-dd77-4df7-b11d-d53e46b76354">
        <source>utlCopyInvAttachments(_invoice : CM_Invoice;
							_directory : String;
							_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2024	navra1	Initial creation for 61803 - EUP |  API - Save a printout of the invoice and its attachments in the directory specified - Task : 61805

*/

vars
	directoryObj				: FileFolder;
	dirName						: String;
	now							: TimeStamp;
	fileData 					: CM_FileData;
	outputFile					: File;
	fileEx 						: FileException;
	fileName					: String;

begin
	on FileException do self.fileExceptionHandler(fileEx);
	
	//delete any existing directory with name as the external number of the invoice and create a directory with the name as the ext invoice number
	dirName := _invoice.externalNumber;
	
	if dirName = null then
		dirName := _invoice.sequenceNum.String;
	endif;
	
	if dirName = null then
		dirName := now.asStringInaportnet();
	endif;
	
	create directoryObj transient;	
	directoryObj.usePresentationFileSystem := false;
	directoryObj.fileName := _directory &amp; "\" &amp; _invoice.externalNumber;	

	if not directoryObj.isValidPathName(directoryObj.fileName) then
		return;
	endif;

	if not directoryObj.isAvailable() then		
		directoryObj.make();		
	else
		app.writeLog("The directory already existed, so deleting it now and recreating a fresh one", LogWARN);
		directoryObj.cnEcRemove();
		directoryObj.make();
	endif;
	
	if not directoryObj.isAvailable() then		
		app.writeLog("Unable to create directory, so exiting without copying attachments", LogERROR);	
		return;
	endif;

	//copy the attachments to the created directory
	if _invoice &lt;&gt; null then		
		//copy the external files to the created directory		
		foreach fileData in _invoice.allFiles where fileData.getInvoiceExternalOnly() do		//navra1 - 12th Mar 2024 - BUG 62882
			app.writeLog("Copying file - " &amp; fileData.fileName, LogINFO);
			create outputFile transient;
			outputFile.allowCreate 				 := true;	
			outputFile.mode						 := File.Mode_IO;
			outputFile.kind					     := File.Kind_Binary;			
			outputFile.usePresentationFileSystem := false;
			fileName 							 := directoryObj.fileName &amp; "\" &amp; fileData.fileName;
			outputFile.openOutput(fileName);			
			outputFile.writeBinary(fileData.getDataAsBinary());			
			outputFile.close();
			delete outputFile;
		endforeach;		
	endif;	
	
epilog
	delete directoryObj;
	delete outputFile;
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_directory" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlCopyInvoiceAndAttachments" id="c78404b2-2c9e-4fe0-add9-1439969d0afd">
        <source>utlCopyInvoiceAndAttachments(_invoice : CM_Invoice;
							_directory : String;
							_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2024	navra1	Initial creation for 61803 - EUP |  API - Save a printout of the invoice and its attachments in the directory specified - Tasks :61804 and 61805

*/
vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myUtilityCA.utlCopyInvAttachments(_invoice, _directory, _passport);
	
	if _passport.allErrors.size() &lt;&gt; 0  then
		app.writeLog("The invoice attachments would not be copied successfully for invoice - " &amp; _invoice.externalNumber&amp; " - ERRORS : " &amp; _passport.getErrorsAndWarningsAsString(), LogERROR);
		return;
	endif;
	
	app.myUtilityCA.utlGenReportAndCopy(_invoice, _directory, _passport);
	
	if _passport.allErrors.size() &lt;&gt; 0  then
		app.writeLog("Issue in Generating and copying invoice report for invoice - " &amp; _invoice.externalNumber &amp; " - ERRORS : " &amp; _passport.getErrorsAndWarningsAsString(), LogERROR);
		return;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_directory" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlCopyInvoiceContract" id="ca5baa74-b752-42f1-8859-32f82165202c">
        <source>utlCopyInvoiceContract(	_pxyContract		: CM_InvoiceContract;
						_newContract		: CM_InvoiceContract output;
						_passport			: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2023	navkc1	Initial creation CR #55652 Task 55681: Jade - Contracts Copy TRX

*/

vars
	pxyRateEntry,
	realRateEntry		: CM_InvoiceContractRateEntry;
	
	pxyRate,
	realRate			: CM_InvoiceContractRate;
	
	pxyContractDetails,
	realContractDetails	: CM_InvoiceContractDetails;
	transientToDelete	: ObjectArray;
	allProcessedContDtl	: CM_InvoiceContractDetailsSet;
	allProcessedRates	: CM_InvoiceContractRateSet;
	allProcessRateEntry	: CM_InvoiceContractRteEntByFrom;
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myUtilityCA.utlCreateInvContract(_pxyContract, _newContract, _passport);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;
	
	create transientToDelete transient;
	create allProcessedContDtl transient;
	create allProcessedRates transient;
	create allProcessRateEntry transient;
	
	foreach pxyContractDetails in _pxyContract.allInvoiceContractDetails do
		transientToDelete.add(pxyContractDetails);
		allProcessedContDtl.add(pxyContractDetails);
		if _newContract &lt;&gt; null then
			pxyContractDetails.setMyInvoiceContract(_newContract);
		endif;
		
		//30/01/2023	navkc1 Bug 61265 - Now we allow user to change star &amp; end date while copying a contract, so we need to make sure the details date are also updated
		pxyContractDetails.setFromTS(_pxyContract.fromTS);
		pxyContractDetails.setToTS(_pxyContract.toTS);
		
		app.myUtilityCA.utlCreateInvContractDtl(pxyContractDetails, realContractDetails, _passport);
		
		if (not self.checkValidationWithPassport(_passport)) then
			// Reset the reference to the proxy
			foreach pxyContractDetails in allProcessedContDtl do
				pxyContractDetails.setMyInvoiceContract(_pxyContract);
			endforeach;
			// Continue instead of return so we display all errors at once
			continue;
		endif;
		
		foreach pxyRate in pxyContractDetails.allInvoiceContractRates do
			transientToDelete.add(pxyRate);
			allProcessedRates.add(pxyRate);
			if realContractDetails &lt;&gt; null then
				pxyRate.setMyInvoiceContractDetails(realContractDetails);
			endif;
			app.myUtilityCA.utlCreateInvContractDtlRt(pxyRate, realRate, _passport);
			
			if (not self.checkValidationWithPassport(_passport)) then
				// Reset the reference to the proxy
				foreach pxyRate in allProcessedRates do
					pxyRate.setMyInvoiceContractDetails(pxyContractDetails);
				endforeach;
				// Continue instead of return so we display all errors at once
				continue;
			endif;
			
			foreach pxyRateEntry in pxyRate.allInvoiceContractRateEntries do
				transientToDelete.add(pxyRateEntry);
				allProcessRateEntry.add(pxyRateEntry);
				if realRate &lt;&gt; null then
					pxyRateEntry.setMyInvoiceContractRate(realRate);
				endif;
				
				//30/01/2023	navkc1 Bug 61265 - Now we allow user to change star &amp; end date while copying a contract, so we need to make sure the rate entry date are also updated
				pxyRateEntry.setFromTS(_pxyContract.fromTS);
				pxyRateEntry.setToTS(_pxyContract.toTS);
				
				app.myUtilityCA.utlCreateInvContractDtlRtEntry(pxyRateEntry, realRateEntry, _passport);
				
				if (not self.checkValidationWithPassport(_passport)) then
					// Reset the reference to the proxy
					foreach pxyContractDetails in allProcessedContDtl do
						pxyContractDetails.setMyInvoiceContract(_pxyContract);
					endforeach;
					
					foreach pxyRate in allProcessedRates do
						pxyRate.setMyInvoiceContractDetails(pxyContractDetails);
					endforeach;
					
					foreach pxyRateEntry in allProcessRateEntry do
						pxyRateEntry.setMyInvoiceContractRate(pxyRate);
					endforeach;
					// Continue instead of return so we display all errors at once
					continue;
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.noErrors() then
		self.myCreateAuditAgent.audCreateGeneric(_newContract);
	endif;
	
	if _passport.noErrors() then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvContractCreate), false, _newContract);
		transientToDelete.purge();
	endif;
epilog
	delete transientToDelete;
	delete allProcessedContDtl;
	delete allProcessedRates;
	delete allProcessRateEntry;
end;</source>
        <Parameter name="_pxyContract" type="CM_InvoiceContract"/>
        <Parameter name="_newContract" type="CM_InvoiceContract" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCopyInvoiceContractDetails" id="f25736b4-a903-4f96-939e-d361529c0c56">
        <source>utlCopyInvoiceContractDetails(	_pxyContractDetails		: CM_InvoiceContractDetails;
								_newContractDetails		: CM_InvoiceContractDetails output;
								_passport						: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2023	navkc1	Initial creation CR #55652 Task 56286: UI - Contract Detail Copy TRX
24 Aug 2023 	navhl20 Bug 59916: FR | EUP 54089 - Inv Contract - Append 'Copy' to copied rates
*/

vars
	pxyRateEntry,
	realRateEntry		: CM_InvoiceContractRateEntry;
	
	pxyRate,
	realRate			: CM_InvoiceContractRate;
	
	transientToDelete	: ObjectArray;
	allProcessedRates	: CM_InvoiceContractRateSet;
	allProcessRateEntry	: CM_InvoiceContractRteEntByFrom;
	desc,
	critDesc,
	revDesc				: String;
	count				: Integer;
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myUtilityCA.utlCreateInvContractDtl(_pxyContractDetails, _newContractDetails, _passport);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;
	
	create transientToDelete transient;
	create allProcessedRates transient;
	create allProcessRateEntry transient;
	
	foreach pxyRate in _pxyContractDetails.allInvoiceContractRates do
		transientToDelete.add(pxyRate);
		allProcessedRates.add(pxyRate);
		
		if _newContractDetails &lt;&gt; null then
			pxyRate.setMyInvoiceContractDetails(_newContractDetails);
		endif;
		
		app.myUtilityCA.utlCreateInvContractDtlRt(pxyRate, realRate, _passport);
		
		if (not self.checkValidationWithPassport(_passport)) then
			// Reset the reference to the proxy
			foreach pxyRate in allProcessedRates do
				pxyRate.setMyInvoiceContractDetails(_pxyContractDetails);
			endforeach;
			// Continue instead of return so we display all errors at once
			continue;
		endif;
		
		foreach pxyRateEntry in pxyRate.allInvoiceContractRateEntries do
			transientToDelete.add(pxyRateEntry);
			allProcessRateEntry.add(pxyRateEntry);
			if realRate &lt;&gt; null then
				pxyRateEntry.setMyInvoiceContractRate(realRate);
			endif;
			app.myUtilityCA.utlCreateInvContractDtlRtEntry(pxyRateEntry, realRateEntry, _passport);
			
			if (not self.checkValidationWithPassport(_passport)) then
				// Reset the reference to the proxy
				foreach pxyRate in allProcessedRates do
					pxyRate.setMyInvoiceContractDetails(_pxyContractDetails);
				endforeach;
				
				foreach pxyRateEntry in allProcessRateEntry do
					pxyRateEntry.setMyInvoiceContractRate(pxyRate);
				endforeach;
				// Continue instead of return so we display all errors at once
				continue;
			endif;
		endforeach;
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if _newContractDetails.myInvoiceContractCriteria &lt;&gt; null then											//24.8.2023 navhl20 #59916
		critDesc := _newContractDetails.myInvoiceContractCriteria.description;
		if critDesc.pos("COPY",1) &lt; 1 then
			desc := critDesc &amp; Space &amp; "COPY 1";
		else
			revDesc := critDesc.reverse;
			count := revDesc[1].Integer;
			count := count + 1;
			revDesc.replaceChar(revDesc[1],count.Character);
			desc := revDesc.reverse;
		endif;
		_newContractDetails.myInvoiceContractCriteria.setDescription(desc);
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.noErrors() then
		self.myCreateAuditAgent.audCreateGeneric(_newContractDetails);
	endif;
	
	if _passport.noErrors() then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvContractDtlCreate), false, _newContractDetails);
		transientToDelete.purge();
	endif;
	
epilog
	delete transientToDelete;
	delete allProcessedRates;
	delete allProcessRateEntry;
end;</source>
        <Parameter name="_pxyContractDetails" type="CM_InvoiceContractDetails"/>
        <Parameter name="_newContractDetails" type="CM_InvoiceContractDetails" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCopyInvoiceMoveTransaction" id="8a3a50a1-f34e-4fe0-905a-91546af98272">
        <source>utlCopyInvoiceMoveTransaction(_currentMoveSb : CM_MoveServiceBroker;
																_parent : CM_CommodityMap;
																_newMoveServiceBroker : CM_MoveServiceBroker output;
																_passport: CM_Passport input);
																
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2018	jlgrh7	Initial creation TFS41632 STWO - copying a move Ship-&gt;Ship configuration does not work as expected

*/

vars

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);
	
	create _newMoveServiceBroker as _currentMoveSb.class persistent;
	
	if _newMoveServiceBroker.isKindOf(CM_MoveServiceBroker) then
		_newMoveServiceBroker.CM_MoveServiceBroker.copyFrom(_currentMoveSb,_parent);
		
		if _passport.noErrors then
			self.myCreateAuditAgent.audCreateGeneric(_newMoveServiceBroker);
		endif;
		if _passport.noErrors then
			_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_REFRESH), false, _newMoveServiceBroker);
		endif;
		
	endif;
	
epilog

end;</source>
        <Parameter name="_currentMoveSb" type="CM_MoveServiceBroker"/>
        <Parameter name="_parent" type="CM_CommodityMap"/>
        <Parameter name="_newMoveServiceBroker" type="CM_MoveServiceBroker" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCopyInvoiceTMCargoTypeMap" id="5e5fd260-b0a3-43a1-b2b8-673ed040d249">
        <source>utlCopyInvoiceTMCargoTypeMap(_tiServiceMap : CM_TIServiceMap; _newCargoType : CM_CargoType; _parent : CM_TranMap; _newTIServiceMap : CM_TIServiceMap output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2013 	cnwjre1
//
// Purpose:		
// 17/02/2017  cnwma1 TFS # 3497:JMT - Invoice Auditing add Copy Function
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	if _parent.allTIServices[_newCargoType] &lt;&gt; null then
		return;
	endif;

	create _newTIServiceMap persistent;

	_newTIServiceMap.copyFrom(_tiServiceMap, _newCargoType, _parent);
	if _passport.noErrors then //17/02/2017  cnwma1 TFs #3497
		self.myCreateAuditAgent.audCreateGeneric(_newTIServiceMap);
	endif;
	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_REFRESH), false, _newTIServiceMap);
	endif;

end;</source>
        <Parameter name="_tiServiceMap" type="CM_TIServiceMap"/>
        <Parameter name="_newCargoType" type="CM_CargoType"/>
        <Parameter name="_parent" type="CM_TranMap"/>
        <Parameter name="_newTIServiceMap" type="CM_TIServiceMap" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCopyInvoiceTMCommodityMap" id="352b3494-6b58-4378-9fdd-6cde76ec9884">
        <updating/>
        <source>utlCopyInvoiceTMCommodityMap(_commodityMap : CM_CommodityMap input; _newCommodityCode : String; _parent : CM_ContentsMap; _newCommodityMap : CM_CommodityMap output; _passport : CM_Passport input) updating;
