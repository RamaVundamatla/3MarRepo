    <JadeMethod name="isPartiallyCleared" id="0510fa30-19f1-4941-be19-ad1ec3ec3142">
        <source>isPartiallyCleared() : Boolean;
/*
Purpose:			

Date		Who		Reason
10 October 2023	navab1	CR 60424 TASK 60549 
*/

vars
	clearedQty : Integer;
	clearedAmount : Decimal[23,4];
	ti : CM_TrackedItem;
begin
	ti := self.myTrackedItem;
	
	if ti.isBulkByWeight() then
		clearedAmount := self.clearedQuantity;
		if clearedAmount &gt; 0 and clearedAmount &lt; ti.totalWeight then
			return true;
		endif;
	elseif ti.isBulkByVolume() then
		clearedAmount := self.clearedVolume;
		if clearedAmount &gt; 0 and clearedAmount &lt; ti.totalVolume then
			return true;
		endif;
	else
		clearedQty := self.clearedQuantity;
		if clearedQty &gt; 0 and clearedQty &lt; ti.totalQuantity then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="fcbc6a37-2d52-40ba-8c7f-c26dd074ad0a">
        <source>pxyCreateUpdateProxy(): SelfType;
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
vars
