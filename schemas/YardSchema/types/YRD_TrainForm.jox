    <JadeMethod name="displayWarnings" id="43a1073b-d0db-458c-a19b-2564cd2fb524">
        <updating/>
        <source>displayWarnings() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwndl1	Initial creation CCMS1067

*/

vars

	warning : CM_Error;
	subject : CM_Object;
	cellText : String;
	
begin

	if not allWarnings.isEmpty then
	
		self.tblWarnings.visible := true;
		tblWarnings.clear();
		tblWarnings.rows := 0;
		tblWarnings.columns := 1;
		self.tblWarnings.left := self.grpTrainDetails.left;
		self.tblWarnings.width := self.grpTrainDetails.width;
		self.tblWarnings.accessColumn(1).width := ( self.tblWarnings.width - 2 ).Integer;
		
		foreach warning in allWarnings do
		/*	cellText := null;
			subject := warning.mySubject;
			if subject &lt;&gt; null then
				cellText := subject.getNiceName &amp; " : ";
			endif;
			cellText := cellText &amp; warning.text;
			if warning.fieldName &lt;&gt; null then
				cellText := cellText &amp; " [" &amp; warning.fieldName &amp; "]";
			endif; */
			cellText := warning.getDetailsForTableDisplay();	//16 Oct 2009	NDL Par 21325
			tblWarnings.rows := tblWarnings.rows + 1;
			tblWarnings.setCellText(tblWarnings.rows,1,cellText);
		endforeach;
		
		if tblWarnings.rows &gt; 3 then	//16 Oct 2009	NDL	Par 21325
			self.tblWarnings.height := self.tblWarnings.accessRow(1).height * 3 + 2;
		else
			self.tblWarnings.height := self.tblWarnings.accessRow(1).height * tblWarnings.rows + 2;
		endif;
		self.tblWarnings.enabled := true;
		self.chkAdvanced.top := self.tblWarnings.top + self.tblWarnings.height + 5;
		
	else
		self.hideTableWarnings();			// 18 Feb 2010- RJS PAR 21951
		//self.tblWarnings.visible := false;
		//self.chkAdvanced.top := 116;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
