    <DbClassMap file="baseshed"/>
    <Constant name="SCHEDULE_JOBS" id="15fc3097-b17d-4acd-9630-7dbc1ed10733">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <ExplicitInverseRef name="allBackShedTasks" id="95eab129-bc54-4b1a-b9dc-96c51a494d96">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="CnEcBackShedTaskDict"/>
        <access>readonly</access>
        <Inverse name="CnEcBackShedTask::myManager"/>
    </ExplicitInverseRef>
    <JadeMethod name="createTask" id="14b83cbc-6719-4bd0-b15a-62a95b04178a">
        <source>createTask(	pTaskType : Class;
			pTaskName : String;
			pStartTime : TimeStamp;
			pIsOneTimeOnly : Boolean;
			pIsRescheduleDaily:Boolean;
			pIsRunEveryNMinutes:Boolean;
			pIsRestartOnFailure : Boolean;
			pDaysToExecute : String;
			pDaysToExecuteTime : Time;
			pMinsBetweenExecution : Integer;
			pUseCustomSchedule : Boolean
			):CnEcBackShedTask;
// -----------------------------------------------------------------------------
// Created:		17 June 2003 by cnwdad1
//
// Purpose:		Creates a new task object.
//
// Parameters:	None
//
// Returns:		A refernce to the new Task object.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 17/06/2003	cnwdad1		Added the isRescheduleDaily and isRunEveryNMinutes
//							to the CnEcBackShedTask class.
// -----------------------------------------------------------------------------
vars
	task : CnEcBackShedTask;
	
begin
	beginTransaction;

	create task as pTaskType;
	
	task.initializeMe(	pTaskName,
						pStartTime,
						pIsOneTimeOnly,
						pIsRescheduleDaily,
						pIsRunEveryNMinutes,
						pIsRestartOnFailure,
						pDaysToExecute,
						pDaysToExecuteTime,
						pMinsBetweenExecution,
						pUseCustomSchedule,
						self);
	
	commitTransaction;
	
	return task;
end;</source>
        <Parameter name="pTaskType" type="Class"/>
        <Parameter name="pTaskName" type="String"/>
        <Parameter name="pStartTime" type="TimeStamp"/>
        <Parameter name="pIsOneTimeOnly" type="Boolean"/>
        <Parameter name="pIsRescheduleDaily" type="Boolean"/>
        <Parameter name="pIsRunEveryNMinutes" type="Boolean"/>
        <Parameter name="pIsRestartOnFailure" type="Boolean"/>
        <Parameter name="pDaysToExecute" type="String"/>
        <Parameter name="pDaysToExecuteTime" type="Time"/>
        <Parameter name="pMinsBetweenExecution" type="Integer"/>
        <Parameter name="pUseCustomSchedule" type="Boolean"/>
        <ReturnType type="CnEcBackShedTask"/>
    </JadeMethod>
    <JadeMethod name="doScheduleJobs" id="177a393a-caff-450f-bb9e-56c7887d6878">
        <source>doScheduleJobs() protected;

vars
	taskObj			: CnEcBackShedTask;
	iterObj			: Iterator;
	option			: Integer; 
	timeRemaining	: Integer;
	
begin
	iterObj := self.allBackShedTasks.createIterator();
	
	while iterObj.next(taskObj) do
	
		if not taskObj.isRunning then
	
			if taskObj.completedTimeStamp &lt;&gt; null then
				continue;
			elseif taskObj.isScheduled then
				continue;
			elseif taskObj.scheduleTimeStamp = null then
				continue;
			else
				if tryLock(	taskObj,
							Exclusive_Lock,
							Transaction_Duration,
							LockTimeout_Server_Defined)
				then
					taskObj.scheduleMe();
				endif;
			endif;
		
		endif;
		
	endwhile;
	
	if not self.getTimerStatus(SCHEDULE_JOBS, option, timeRemaining) then	
		self.beginTimer(30000, Timer_OneShot, self.SCHEDULE_JOBS);
	endif;
epilog
	delete iterObj;	 	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="endApplication" id="51f4cb2c-d808-4fc9-9d04-fb9b71510b70">
        <source>endApplication();

begin
	endTimer(self.SCHEDULE_JOBS);
end;</source>
    </JadeMethod>
