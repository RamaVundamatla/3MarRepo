    <JadeMethod name="getIndexOfTiDisplay" id="addc539f-4bac-423a-93a7-f0fd33658283">
        <source>getIndexOfTiDisplay(_mode : Integer; _ti : CM_TrackedItem) : String;
// -------------------------------------------
// Created 20 January 2004 by cnwdvb1
// -------------------------------------------
vars
	index : Integer;
	tmpTA	: CM_TerminalArea;
begin
	tmpTA := self.myTerminalArea;
	if tmpTA &lt;&gt; null and (not tmpTA.isHeightRequiredForLabel) then
		return null;
	endif;

	index := self.getIndexOfTI(_mode, _ti);
	if index &gt; 0 then
		return index.String;
	endif;
	return null;

end;</source>
