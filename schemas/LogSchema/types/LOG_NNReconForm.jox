    <JadeMethod name="btnSelectAllT_click" id="5416c9be-7700-40a5-b2bc-bcf56c9294ff">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSelectAllT_click(btn: Button input) updating;

vars

begin

	if btn.caption = app.getErrorString(SelectAll) then
		self.selectUnselectAll(true);
		btn.caption := app.getErrorString(Deselect_All);
	else
		self.selectUnselectAll(false);
		btn.caption := app.getErrorString(SelectAll);
	endif;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
