	return 1000;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWeight" id="cf813a92-a3cd-4f64-a1d0-594ebc2a2e3e">
        <source>getWeight(_binResponse: Binary): Decimal protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2019	jlger1	Initial creation CM_WeighBridgeObjType::getWeightResponseForIQ710

*/

constants
	// 14/3/16  cnwns1 PAR 36286 unicode version
	S 	: Binary = #[73];
	CR 	: Binary = #[0d];
	LF 	: Binary = #[0a];
	NEG : Binary = #[2d];

vars

	stx : Binary;
	isPositive : Boolean;
	unitString : String;
	mode : String;
	status : String;
	etx : Binary;
	rawWeight : Decimal[16,4];
	weightType : CM_MeasurementType;
	weightBridgeType : CM_WeighBridgeObjType;
begin

	/*
	response message format - length = 18.
	stx 		1-3 	= 's' &amp; Cr &amp; Lf
	plus/minus 	4 		= "-" for negative, or space for positive.
	weight	 	5-12	= a numbers with leading spaces to represent the number of units of weight
	units		13		= "L" = lbs, " " = none, 'K' = Kgs, 'T' = tons, 'G' = grams, 'O' = ounces
	mode		14		= "G" = gross,  "N" = nett
	status		15		= " " = valid, "I" = invalid, "M" = motion, "O" = over capacipty
	etx 		16-18 	= Cr &amp; Lf &amp; Lf
	*/
	
	if myWeighBridge = null then
		return null;
	endif;
	weightBridgeType:=self.myWeighBridge.myWeighBridgeType;
	
	if _binResponse.length &lt;&gt; 18 then
		self.diagnosticLog( "Response string is not 18 characters long - Invalid format.");
		return null;
	endif;
	stx := ( S &amp; CR &amp; LF ).Binary;	// 14/3/16  cnwns1 PAR 36286 unicode version
	if _binResponse[1:3] &lt;&gt; stx then
		self.diagnosticLog( "Response string has invalid 'stx' value - Invalid format.");
		return null;
	endif;
	etx := ( CR &amp; LF &amp; LF ).Binary;	// 14/3/16  cnwns1 PAR 36286 unicode version
	if _binResponse[16:3] &lt;&gt; etx then
		self.diagnosticLog( "Response string has invalid 'etx' value - Invalid format.");
		return null;
	endif;
	
	isPositive := not _binResponse[4:1] =  NEG.Binary;	// 14/3/16  cnwns1 PAR 36286 unicode version
	rawWeight := _binResponse[5:8].ansiToString().trimBlanks.Integer;	// 14/3/16  cnwns1 PAR 36286 unicode version
	unitString := _binResponse[13:1].String;
	mode := _binResponse[14:1].String;
	status := _binResponse[15:1].String;
	
	if not isPositive and rawWeight &lt;&gt; 0 then
		self.diagnosticLog(  "Weigh Bridge returned a negative weight.");
		return null;
	endif;
	
	if status = " " then
		//all good
	elseif status = "I" then
		self.diagnosticLog(  "Weigh Bridge indicates an 'Invalid' weighing.");
		return null;
	elseif status = "M" then
		self.diagnosticLog( "Weigh Bridge indicates this is an 'in Motion' weighing.");
	elseif status = "O" then
		self.diagnosticLog( "Weigh Bridge indicates an 'Over Capacity' weighing.");
	else
		self.diagnosticLog( "Response string has invalid 'status' value - Invalid format.");
		return null;
	endif;
	
	if mode = "G" then
		//all good -Gross weight
	elseif mode = "N" then
		self.diagnosticLog( "Weigh Bridge indicates this is a 'Nett' weighing.");
	else
		self.diagnosticLog( "Response string has invalid 'mode' value - Invalid format.");
		return null;
	endif;
	
	if unitString = "L" then	//lbs
		weightType := weightBridgeType.myPoundsMeasureType;
		if weightType = null then
			self.diagnosticLog("Weigh Bridge Type 'setup issue', No pounds measure declared.");
			return null;
		endif;
	elseif unitString = 'K' then	//Kgs
		weightType := weightBridgeType.myKilosMeasureType;
		if weightType = null then
			self.diagnosticLog("Weigh Bridge Type 'setup issue', No kilos measure declared.");
			return null;
		endif;
	elseif unitString = 'T' then	//tons
		weightType := weightBridgeType.myTonsMeasureType;
		if weightType = null then
			self.diagnosticLog( "Weigh Bridge Type 'setup issue', No tons measure declared.");
			return null;
		endif;
	elseif unitString = 'G' then	//grams
		weightType := weightBridgeType.myGramsMeasureType;
		if weightType = null then
			self.diagnosticLog("Weigh Bridge Type 'setup issue', No grams measure declared.");
			return null;
		endif;
	elseif unitString = 'O' then	//ounces
		weightType := weightBridgeType.myOuncesMeasureType;
		if weightType = null then
			self.diagnosticLog( "Weigh Bridge Type 'setup issue', No ounces measure declared.");
			return null;
		endif;
	else
		self.diagnosticLog("Response string has invalid 'units' value - Invalid format.");
		return null;
	endif;

	if weightType &lt;&gt; null then
		rawWeight:=app.convertMeasurementForStorage(weightType.shortName,rawWeight);
	endif;
	
	
	return rawWeight;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_binResponse" type="Binary"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWeightCommand" id="f47ee0e2-b698-496f-ab24-388d45d8c62d">
        <source>getWeightCommand(): Binary protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2019	jlger1	Initial creation refactored from CM_WeighBridgeObjType::getRequestStringForIQ710

*/

constants

	RequestWeightString : String = "s" &amp; CrLf;
	
vars

begin

	return RequestWeightString.asANSI(0);

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Binary"/>
    </JadeMethod>
</Class>
