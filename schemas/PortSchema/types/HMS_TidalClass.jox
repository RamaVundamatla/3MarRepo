    <JadeMethod name="getDisplayStringForAttribute" id="732b1d49-977b-4286-9e2a-16686e1e75e8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2014	cnwdb2	PAR 33977
*/

vars

begin
	
	if _attrName = ETRow_MaxFloodTideArrival then
		return self.allMaximumCurrents[1].asStringJMT();
	elseif _attrName = ETRow_MaxEbbTideArrival  then
		return self.allMaximumCurrents[2].asStringJMT() ; 
	elseif _attrName = ETRow_MaxFloodTideDept then 
		return self.allMaximumCurrents[3].asStringJMT() ; 
	elseif _attrName = ETRow_MaxEbbTideDept then
		return self.allMaximumCurrents[4].asStringJMT() ; 
	endif ; 
		
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="c9bc9ad8-6330-4b21-93c9-f568d66ebc6b">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 31 July 2003 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy 			: HMS_TidalClass;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myRoot := self.myRoot;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f6e0ea79-0fcf-4a99-ace2-fcc30a663bd4">
        <updating/>
        <source>setForUpdate(_pxyTidalClass : HMS_TidalClass; _passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
// 03-JUL-2014  cnwma1 CCMS SFW1328 -HMS Not Available For Entry 
//--------------------------------------------------------------
vars

begin
	inheritMethod(_pxyTidalClass, _passport);
	
	self.code 					:= _pxyTidalClass.code.toUpper.trimBlanks;
	self.description 			:= _pxyTidalClass.description;
	self.isNotAvailableForEntry	:= _pxyTidalClass.isNotAvailableForEntry; 	//  cnwma1 3/7/2014   CCMS SFW 1328
	self.myRoot					:= _pxyTidalClass.myRoot;
	
	self.allMaximumCurrents.clear();
	_pxyTidalClass.allMaximumCurrents.copy(self.allMaximumCurrents);

end;</source>
        <Parameter name="_pxyTidalClass" type="HMS_TidalClass"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
