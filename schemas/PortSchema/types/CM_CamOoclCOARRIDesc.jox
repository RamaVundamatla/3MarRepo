    <JadeMethod name="getSenderCode_UNB" id="928ed0ec-b34e-4201-a40e-94c60b85a6cb">
        <source>getSenderCode_UNB(_protocol :CM_CamProtocol):String protected;
/*	
Return Value:	sender code to use in UNB segment

Date		Who		Reason
16 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
vars
	code		:String;
	terminal	:CM_Terminal;
begin
	code 		:= _protocol.camGroup.senderCode.trimBlanks;
	terminal	:= _protocol.terminal;
	
	if code = null then
		code := terminal.getConfig(PortDestCode).String.trimBlanks;
	endif;
	
	// no translation
	
	return code;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageHeader" id="db30909b-fb18-4a01-9884-4fd322476740">
        <updating/>
        <source>makeMessageHeader(_camFile : CM_CamFile input; _camTaskHistory : CM_CamTaskHistory input;
					_unhSeqNumber : Integer io; _type : String; _fileType : String;
					_coll :HugeStringArray input) : String updating;

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camFile/_camTaskHistory parameter usage from io to input
// 16/05/2011	cnwcs5 	CCMS SCT 2058/par 27460 - replace literals with characters defined on protocol
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	protocol	:CM_CamProtocol;	// par 27460 cnwcs5
	strLine : String;
begin
	_unhSeqNumber 	:= _unhSeqNumber + 1;
	protocol		:= _camTaskHistory.camProtocol;	// par 27460 cnwcs5

	// UNH Segment
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeUNHSegment (protocol, _unhSeqNumber, _fileType, "D", "95B", "UN", null, "0", _camTaskHistory.runDateTime), _coll); 	//cnwmc5 - 15 Oct 2014 - CCMS 2380
	// BGM segment
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeBGMSegment (protocol, _type, null, 9, null), _coll);

	_camFile.incrementMessageCount();
	return strLine;
end;</source>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_fileType" type="String"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageLOC" id="c0a09852-ed21-464a-b638-0a1d4c9fb578">
        <source>makeMessageLOC(_protocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer; _ti :CM_TrackedItem) protected;
/*
Purpose: Refactored code

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
// 30 Nov 2017  cnwma1  TFS #7780: SNO - Tranship Discharge needs to use the incoming voyage info
vars
	terminal			:CM_Terminal;
	code, loadPort, 
	dischargePort		:String;
	location			:CM_LocationsController;
begin
	terminal	:= _protocol.terminal;
	
	if _activity = COARRI_SHIPLOAD then
		// LOC+9 - We are the Load Port
		code 		:= _ti.loadPort.trimBlanks;
		loadPort 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
		
		if loadPort = null then
			loadPort := code;
		endif;
		
		self.makeLOCSegment (_protocol, _group, '9', loadPort, '139', '6', _protocol.camGroup.facilityCode, "TER", "ZZZ");
		
		// LOC+11 - Discharge Port
		code 			:= _ti.dischargePort.trimBlanks;
		dischargePort 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
		
		if dischargePort = null then
			dischargePort := code;
		endif;
		
		dischargePort := dischargePort.trimBlanks;
		
		self.makeLOCSegment (_protocol, _group, '11', dischargePort, '139', '6', null, null, null);

	else
		//LOC+9 - Load Port for this discharge
		code 		:= _ti.loadPort.trimBlanks;
		
		//30.11.2017 cnwma1 TFS #7780
		if _activity = COARRI_SHIPDISCHARGE then
			if _ti.isTranshipItem then
				if _ti.myTranshipDetail &lt;&gt; null then
					if  _ti.myTranshipDetail.importOriginalLoadPort &lt;&gt; null then
						code := _ti.myTranshipDetail.importOriginalLoadPort;
					endif;
				endif;
			endif;
		endif;
	
		loadPort 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
		
		if loadPort = null then
			loadPort := code;
		endif;
		
		self.makeLOCSegment (_protocol, _group, '9', loadPort, '139', '6', null, null, null);

		// LOC+11 - We are the Discharge Port
		code 			:= _ti.dischargePort.trimBlanks;
		dischargePort 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
		
		if dischargePort = null then
			dischargePort := code;
		endif;
		
		dischargePort := dischargePort.trimBlanks;
		
		self.makeLOCSegment (_protocol, _group, '11', dischargePort, '139', '6', _protocol.camGroup.facilityCode, "TER", "ZZZ");
	endif;

	if _activity = COARRI_SHIPLOAD then
		// LOC+147 - setup bay position
		location := _ti.getPrimaryLocation(REAL_MODE);
		
		if location &lt;&gt; null and location.isKindOf(CM_SlotController) and not location.isKindOf(CM_ShipBlockController) then
			self.makeLOCSegment (_protocol, _group, '147', location.CM_SlotController.getStowageId(_ti).trimRight, null, '5', null, null, null);
		endif;
	else
		//setup bay position
		if _ti.priorStowage.length &gt;= 6 then
			code := _ti.priorStowage.reverse[1:6].reverse.trimBlanks;
			self.makeLOCSegment (_protocol, _group, '147', code, null, '5', null, null, null);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_ABT" id="b66f8d5c-2273-44e7-8aa9-d6cf42d44b16">
        <source>makeMessageRFF_ABT(_protocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer; _ti :CM_TrackedItem):String protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	msg	:String;
begin
	if _ti.customExportEntryNumber.trimRight &lt;&gt; null then
		msg := self.makeRFFSegment (_protocol, _group, "ABT", _ti.getCustExpEntryNoMinusSlash);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="c930e234-6dc7-4899-88a3-b8e061a0cb3d">
        <source>makeMessages(_trackedItem:CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _secondTrx : CM_TITransaction);

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camMessage parameter usage from io to input
// 10 May 2011	cnwcs5	CCMS SCT 2058/par 27460 - user defined special characters
// 30/05/2016	cnwdap1	TFS #2061 COPARN/CODECO/COARRI/EDI VGM Updates
// 07/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
//23/08/2017	cnwma1  TFS #5834-PNL - EDI Translation - ISO Code foreign out
// 19 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
// 21 Jun 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
vars
	theTI			: CM_TrackedItem;
	imExStatus,
	contStatus		: String;
	isoCode,fIsoCode : String;
	includeVGM 		: Boolean;
begin
// OOCL
	theTI := _transaction.myTrackedItem;
	
	if _camProtocol.useVGM and 
	   _camProtocol.getIncludeExtraVGM and
	   theTI &lt;&gt; null and 
	   theTI.isWeightCertified and 
	   not theTI.isEmpty then		// TFS #2061
		includeVGM := true;
	endif;
	contStatus := self.contentsStatusToString(_transaction.contentsStatus,_camMessage.activity, _transaction.type);
	imExStatus := self.imExStatusToString(theTI);
	
	// EQD segment
	//self.makeEQDSegment (_camProtocol, _camMessage.group3, "CN", theTI.id.trimRight, theTI.CM_Container.isoType, null, null, null, null, contStatus); // par 27460 09/05/2011 cnwcs5 	//23/08/2017 cnwma1 TFS #5834
	isoCode := theTI.CM_Container.isoType;
	fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
	self.makeEQDSegment (_camProtocol, _camMessage.group3, "CN", theTI.id.trimRight, fIsoCode, null, null, null, null, contStatus); //23/08/2017 cnwma1 TFS #5834 	
	_camMessage.eqdCount := _camMessage.eqdCount + 1;

	// RFF+BN
	self.makeMessageRFF_BN (_camProtocol, _camMessage.group3,  theTI);	// par 27460 cnwcs5

	// RFF+BM
	self.makeMessageRFF_BM (_camProtocol, _camMessage.group3,  theTI);	// par 27460 cnwcs5

	// RFF+CN
	self.makeMessageRFF_CN (_camProtocol, _camMessage.group3, theTI);	// par 27460 cnwcs

	// RFF+ABT
	self.makeMessageRFF_ABT (_camProtocol, _camMessage.group3,  _camMessage.activity, theTI);	// par 27460 cnwcs5

	// DTM - transaction date/time
	if _camMessage.activity = COARRI_SHIPLOAD then
		self.makeDTMSegment(_camProtocol, _camMessage.group3, '404', _transaction.dateTime, "203"); // TFS 53754
	else
		self.makeDTMSegment(_camProtocol, _camMessage.group3, '403', _transaction.dateTime, "203"); // TFS 53754
	endif;	
	if includeVGM then
		self.makeMessageDTM_VGM(_camProtocol, _camMessage.group3, theTI);					// TFS 4492
	endif;
	// LOC segments
	self.makeMessageLOC (_camProtocol, _camMessage.group3, _camMessage.activity, theTI);	// par 27460 cnwcs5

	// MEA - weight
	self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group3,theTI,null); //epr par 37551 TFS 1429 16/2/16

	// DIM+ segment
	self.makeMessageDimensionsData (_camProtocol, _camMessage.group3, theTI);		// par 27460 09/05/2011 cnwcs5

	// TMP Segment
	self.makeTMPSegment (_camProtocol, _camMessage.group3, 2, theTI.getTemperature, "CEL");	// par 27460 09/05/2011 cnwcs5 				

	//the SEL for the seal number
	self.makeMessageSealsData( theTI, _camMessage, _camMessage.group3, _camProtocol, contStatus);	//15 Sep 2010	NDL	Par 25608

	// Dangerous Goods
	self.makeMessageHazardsData (theTI, _camProtocol, _camMessage.group3);	// par 27460 09/05/2011 cnwcs5 		
	
	// TFS #2061 NDA for VGM																			// TFS #2061
	if includeVGM then		// TFS #2061
		self.makeMessageNAD_VGM(_camProtocol, _camMessage.group3, theTI);								// TFS #2061
	endif;																								// TFS #2061
end;
</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeUNBSegment" id="2485e724-9b5e-48c7-ab06-2c9b4a177e8e">
        <source>makeUNBSegment(_protocol: CM_CamProtocol; _syntaxId: String; _syntaxVersion: Integer; _senderId: String; _senderQual: String; _recipientId: String; _recipientQual: String; _seqNumber: Integer; _080: String; _useLongYear: Boolean; _runDateTime : TimeStamp): String protected;
/*
Purpose:	This looks wrong but is what 7.8.2 does		

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
vars
	msg					:String;
	plus, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := inheritMethod(_protocol, _syntaxId, _syntaxVersion, _senderId, _senderQual, _recipientId, _recipientQual, _seqNumber, _080, _useLongYear, _runDateTime);

	// strip off segment terminator
	msg := msg [1:msg.length-1];
	
	// add "+++0'"
	// not sure why this is done but adding it so there are no changes for 7.8.2
	msg := msg &amp; plus &amp; plus &amp; plus &amp; '0' &amp; singleQuote;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_syntaxId" type="String"/>
        <Parameter name="_syntaxVersion" type="Integer"/>
        <Parameter name="_senderId" type="String"/>
        <Parameter name="_senderQual" type="String"/>
        <Parameter name="_recipientId" type="String"/>
        <Parameter name="_recipientQual" type="String"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_080" type="String"/>
        <Parameter name="_useLongYear" type="Boolean"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
