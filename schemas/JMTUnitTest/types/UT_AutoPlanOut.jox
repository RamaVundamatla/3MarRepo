    <JadeMethod name="tReleaseByType_CargoGroupNew" id="a145fe7e-9761-42dc-9ad5-d34e79a98bca">
        <source>tReleaseByType_CargoGroupNew();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jun 2025	navhl20 Bug MTN-35180: TPT | Release By Type Cargo Group / Lot Number

*/

constants
	BULK_NAME = "UTCGBYTYPEN";
	TI_ID1 = "UTCGNMEM01";
	TI_ID2 = "UTCGNMEM02";
	TI_ID3 = "UTCGNMEM03";
	TI_ID4 = "UTCGNMEM04";
	TI_ID5 = "UTCGNMEM05";
	CG_ID1 = "UTCGN00001";	
	
vars
	bulkRel 					: CM_BulkRelease;
	ti1,
	ti2,
	ti3,
	ti4,
	ti5,
	ti							: CM_TrackedItem;
	ya 							: CM_YardAllocation;
	locations 					: CM_LCArray;
	source 						: CM_LocationsController;
	yaName 						: String;
	cg 							: CM_CargoGroup;
	allCargoToAssign 			: CM_TISet;
	pxyReleaseMatchCrit 		: CM_ReleaseByTypeCriteria;
	pxyCriteria 				: CM_YACriteria;
	reserveDet 					: CM_ReserveDetail;
	reserveSel 					: CM_ReserveSelection;
	term 						: CM_Terminal;
	cmifYARequest 				: CMIF_YAAutoPlan;
	transUserQuery 				: CM_MenuUserQuery;
	transCriteriaLineHolder 	: CM_QueryCriteriaLineHolder;
	msg 						: String;
	qDef 						: CM_QueryDefinition;
	enqController 				: CM_EnqControllerTI;
	imex						: CM_IMEXStatus;
begin

	term := self.getTerminal;

	self.setTerminalConfig(UseBestPickDirector, false);
	self.disableAllYA(true);
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyYA);
	
	self.deleteReleaseRequest(BULK_NAME);
	self.deleteContainer(TI_ID1);
	self.deleteContainer(TI_ID2);
	self.deleteContainer(TI_ID3);
	self.deleteContainer(TI_ID4);
	self.deleteContainer(TI_ID5);
	self.deleteCargoGroup(CG_ID1);
	
	yaName := self.getProfileSetting(UT_Profile.P_YA).asString;
	self.deleteYA(yaName);
	
	create allCargoToAssign transient;
	
	//create Yard Allocation
	create locations transient;
	locations.add(bs1.allLocationsControllers.first.CM_YardController);
	imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE];
	ya := self.addYA(yaName, YACriteriaType_OperatorItem, operator.code, YACriteriaType_CargoGroup, CG_ID1, YACriteriaType_ImexStatus, imex, locations,null);
	self.assertFalse(ya.isDisabled);
	
	//create Cargo items
	ti1 := self.addContainer(TI_ID1, operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti1, locations.first);
	self.assertEqual(ti1.myPrimaryActualLocation, locations.first);
	
	ti2 := self.addContainer(TI_ID2, operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti2, locations.first);
	self.assertEqual(ti2.myPrimaryActualLocation, locations.first);
	allCargoToAssign.add(ti2);
	
	ti3 := self.addContainer(TI_ID3, operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti3, locations.first);
	assertEqual(ti3.myPrimaryActualLocation, locations.first);
	allCargoToAssign.add(ti3);
	
	ti4 := self.addContainer(TI_ID4, operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti4, locations.first);
	self.assertEqual(ti4.myPrimaryActualLocation, locations.first);
	
	ti5 := self.addContainer(TI_ID5, operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti5, locations.first);
	self.assertEqual(ti5.myPrimaryActualLocation, locations.first);
	allCargoToAssign.add(ti5);
	
	//create CargoGroup and assign cargo
	
	cg := self.addCargoGroup( CG_ID1, allCargoToAssign );
	
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("CargoGroup", cg);
	bulkRel := self.addReleaseByTypeRequestOpts(BULK_NAME, BR_TYPE_ROAD, TI_CargoType_Container);
	self.assertTrueMsg( bulkRel &lt;&gt; null, "BulkRelease not created" );
	self.assertTrueMsg( not bulkRel.allReserveDetails.isEmpty, "Reserve Details not created" );
	reserveDet := bulkRel.allReserveDetails.first;
	self.assertTrueMsg( reserveDet.isKindOf(CM_ReserveSelection), "No Reserve Selection found" );
	reserveSel := reserveDet.CM_ReserveSelection;
	beginTransaction;
		bulkRel.requests.first.setReserveDetail(reserveSel);
	commitTransaction;
	
	// Make sure that the expected source is found by autoplan
	source := app.sourceTisForRequestYA(self.getTerminal(), bulkRel.requests.first);
	self.assertNotNullMsg(source, getYAAutoPlanMessages);
	self.assertEqual(source.getName(), locations.first.getName());
	self.assertTrueMsg( app.myYAAgent &lt;&gt; null, "No YAAgent for 'request'" );
	cmifYARequest := app.myYAAgent.myCMIFYAAutoPlan;
	self.assertTrueMsg( cmifYARequest &lt;&gt; null, "No CMIF on the YA Agent for 'request'" );
	
	// Check the test auto plan for Reserve implemented on te Bulk Release form.
	app.testAutoplanReseveDetails(term, reserveSel);
	self.assertTrueMsg( app.myYAAgent &lt;&gt; null, "No YAA gent for 'reserve selection'" );
	cmifYARequest := app.myYAAgent.myCMIFYAAutoPlan;
	self.assertTrueMsg( cmifYARequest &lt;&gt; null, "No CMIF on the YAAgent for 'reserve selection'" );
	
	
	create transUserQuery transient;
	create transCriteriaLineHolder transient;
	transUserQuery.allCriteriaLineHolders.add(transCriteriaLineHolder);
	msg := reserveSel.buildQueryToMatchDetails( transUserQuery, transCriteriaLineHolder );
	self.assertTrueMsg( msg = null, "YA to Selector query conversion message - " &amp; msg );
	qDef := app.myRoot.allQueryDefinitionObjects[transUserQuery.getType, transUserQuery.queryMode];
	
	create enqController;
	create enqController.allObjects as  CM_TISet transient;
	
	enqController.myTerminal := term;
	enqController.myCriteriaLineHolder := transCriteriaLineHolder;
	
	enqController.doQuery( qDef );
	self.assertTrueMsg( allCargoToAssign.size = enqController.allObjects.size, "Queries found different number of items " &amp; allCargoToAssign.size.String &amp; "/" &amp; enqController.allObjects.size.String );
	foreach ti in allCargoToAssign do
		self.assertTrueMsg( enqController.allObjects.includes(ti), "Selector query missed out " &amp; ti.id );
	endforeach;

epilog
	delete locations;
	delete allCargoToAssign;
	self.disableAllYA(false);
	delete transUserQuery;
	delete enqController.allObjects;
	delete enqController;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseByType_Colour" id="6453e148-288c-405f-bea9-ac94ace0326d">
        <source>tReleaseByType_Colour();
// cnwndl1
//27 Jan 2010	cnwdw1	
// Test that gate out of a "by type" release request for Colour
constants
	RELEASE = "UTRRBYTYPE";
vars
	releaseRequest: CM_BulkRelease;
	ti: CM_TrackedItem;
	ya: CM_YardAllocation;
	locations : CM_LCArray;
	source: CM_LocationsController;
	yaName: String;
	cargoType: CM_CargoType;
begin

	self.setTerminalConfig(UseBestPickDirector, false);
	
	self.disableAllYA(true);
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyYA);
	
	deleteReleaseRequest(RELEASE);
	
	ti := self.addCannonAtLocation("UCAN1", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1);
	self.opts.addAssoc("Colour", "RED");
	self.opts.addAssoc("TotalWeight", 25);
	self.updateTI(ti);
	assertEqual(ti.getColour, "RED");
	
	create locations transient;
	locations.add(bs1.allLocationsControllers.first.CM_YardController);
	yaName := self.getProfileSetting(UT_Profile.P_YA).asString;
	self.deleteYA(yaName);
	ya := self.addYA1(yaName, YACriteriaType_Colour, "Red", locations);
	assertFalse(ya.isDisabled);
	
	// Create the Release
	self.opts.purge;
	self.opts.addAssoc("Colour", "RED");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	cargoType := self.getCargoType("CANNON");
	releaseRequest := addReleaseByTypeRequestOpts(RELEASE, BR_TYPE_ROAD, cargoType.id);
	assertNotNull(releaseRequest);
	
	// Make sure that the expected source is found by autoplan
	source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqual(source.getName(), locations.first.getName());
	
epilog
	delete locations;
	self.disableAllYA(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseByType_DateRange" id="f79d5377-4313-4b15-8cef-3c87b8d62839">
        <source>tReleaseByType_DateRange();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/06/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
constants
	RELBYRECDATE : String = "13861BYREC";
	RELBYPTIDATE : String = "13861BYPTI";
	RELBYSUBDATE : String = "13861BYSUB";
	
	CONT1 : String = "CONT13861_1";
	CONT2 : String = "CONT13861_2";
	CONT3 : String = "CONT13861_3";
	
	YARecDate : String = "13861REC";
	YAPTIDate : String = "13861PTI";
	YASubDate : String = "13861SUB";
	
	SubTerm1Code : String = "UT_DPTC";
	SubTerm2Code : String = "UT_DPTD";
	
	BlockStack1 : String = "138611";
	BlockStack2 : String = "138612";
	
vars
	terminal : CM_Terminal;
	subTerminalsEnabled : Boolean;
	subTerm1, subTerm2 : CM_SubTerminal;
	resetSubTermAreaDefined	: Boolean;
	pxySubTermDef, realSubTermDef : CM_SubTerminalAreaDef;
	selectedObjects : ObjectSet;
	blockStack1, blockStack2 : CM_BlockStack;
	relByRec, relByPTI, relBySub : CM_BulkRelease;
	tiRec, tiPTI, tiSub : CM_TrackedItem;
	source : CM_LocationsController;
	op : CM_Operator;
	tiTrans : CM_TITransaction;
	pxyReleaseMatchCrit : CM_ReleaseByTypeCriteria;
	pxyCriteria : CM_YACriteria;
	reserveDet : CM_ReserveDetail;
	reserveSelRec, reserveSelPTI, reserveSelSub : CM_ReserveSelection;
	cmifYARequest : CMIF_YAAutoPlan;
	tiStops : CM_StopsByIdDict;
	stop : CM_Stops;
	yaRecDate, yaPTIDate, yaSubDate : CM_YardAllocation;
	
begin
	self.setTerminalConfig(UseBestPickDirector, false);
	
	// Disable all yard allocations so we know ours are the only ones in play
	self.disableAllYA(true);
	
	// Set release strategy to Yard Allocations Only
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyBoth);
	
	terminal := self.getTerminal();
	op := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Ensure terminal has sub-teminals turned on
	subTerminalsEnabled := self.getTerminalConfig(IsSubTerminalsOn).Boolean;
	self.setTerminalConfig(IsSubTerminalsOn, true);
	
	self.assertTrueMsg(app.isSubTerminalsLicensed, "Not licensed for sub terminals!");
	self.assertTrueMsg(app.isSubTerminalsOn(terminal), terminal.name &amp; " not set up for sub terminals!");
	
	// Delete data
	self.deleteReleaseRequest(RELBYRECDATE);
	self.deleteReleaseRequest(RELBYPTIDATE);
	self.deleteReleaseRequest(RELBYSUBDATE);
	self.deleteCargo(CONT1, "CONT");
	self.deleteCargo(CONT2, "CONT");
	self.deleteCargo(CONT3, "CONT");
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(BlockStack2);
	self.deleteSubTerminal(SubTerm1Code);
	self.deleteSubTerminal(SubTerm2Code);
	
	// Create the block stacks
	blockStack1 := self.addBlockStack(BlockStack1, 100, null);
	blockStack2 := self.addBlockStack(BlockStack2, 100, null);
	
	// Create sub terminals
	subTerm1 := self.addSubTerminal(SubTerm1Code, SubTermType_Depot_Int);
	subTerm2 := self.addSubTerminal(SubTerm2Code, SubTermType_Depot_Int);
	if not terminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		resetSubTermAreaDefined := true;
		self.setSubTerminalAreaDefined(true);	
	endif;
	
	// Add terminal areas to separate sub-terminals
	create pxySubTermDef transient;
	create selectedObjects transient;
	selectedObjects.add(blockStack1);
	pxySubTermDef.setProxy(subTerm1.code, subTerm1.description, false, selectedObjects, subTerm1, terminal);
	app.myTrxCA.trxCreateSubTerminalAreaDef(pxySubTermDef, realSubTermDef, app.myPassport);
	self.assertEqualMsg(blockStack1.mySubTerminalAreaDef, realSubTermDef, BlockStack1 &amp; " doesn't have the right sub terminal def");
	
	delete pxySubTermDef;
	delete selectedObjects;
	create pxySubTermDef transient;
	create selectedObjects transient;
	selectedObjects.add(blockStack2);
	pxySubTermDef.setProxy(subTerm2.code, subTerm2.description, false, selectedObjects, subTerm2, terminal);
	app.myTrxCA.trxCreateSubTerminalAreaDef(pxySubTermDef, realSubTermDef, app.myPassport);
	self.assertNoTrxErrorsPassport(app.myPassport.getAllErrorsAndWarningsAsStr);
	self.assertEqualMsg(blockStack2.mySubTerminalAreaDef, realSubTermDef, BlockStack2 &amp; " doesn't have the right sub terminal def");
	
	// Add cargo and modify details to suit the release requests we're going to create
	tiRec := self.addContainerAtLocation(CONT1, op, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack1);
	tiPTI := self.addContainerAtLocation(CONT2, op, "22R1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack1);
	tiSub := self.addContainerAtLocation(CONT3, op, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack1);
	
	// tiRec will have its receival date changed to match a Receival Date Range release criteria
	// tiPTI will have its pre-trip inspection date changed to match a Pre-Trip Inspection Date Range release criteria
	// tiSub will be moved from one sub-terminal to another, then have its Sub-Terminal Move date changed
	// to match a Sub-Terminal Move Date Range release criteria
	beginTransaction;
	tiRec.setPropertyValue(CM_TrackedItem::receivedDT.name, "12/05/2025 10:30".TimeStamp);
	tiPTI.setPreTripDT("22/05/2025 11:00".TimeStamp);
	commitTransaction;
	
	self.moveCargo(tiSub, null, blockStack2.myLocationsController, app.myPassport);
	self.assertTrueMsg(tiSub.myPrimaryActualLocation = blockStack2.myLocationsController, CONT3 &amp; " not moved to " &amp; BlockStack2);
	tiTrans := tiSub.allTransactions.findLastSubTermReceivalTrans();
	self.assertNotNullMsg(tiTrans, CONT3 &amp; " has no Sub-Terminal Received transaction");
	beginTransaction;
	tiTrans.setPropertyValue(CM_TITransaction::dateTime.name, "02/05/2025 18:00".TimeStamp);
	commitTransaction;
	self.assertEqualMsg(tiTrans.dateTime.date, "02/05/2025".Date, "Sub-Terminal receival transaction has the wrong date - " &amp; tiTrans.dateTime.date.asStringJMT);
	
	// Clear any stops on the TIs
	tiStops := tiRec.getAllStops();
	foreach stop in tiStops do
		self.clearStopWithExpiry(tiRec, stop.myStopsTable, "Cleared", null);
	endforeach;
	tiStops := tiPTI.getAllStops();
	foreach stop in tiStops do
		self.clearStopWithExpiry(tiPTI, stop.myStopsTable, "Cleared", null);
	endforeach;
	tiStops := tiSub.getAllStops();
	foreach stop in tiStops do
		self.clearStopWithExpiry(tiSub, stop.myStopsTable, "Cleared", null);
	endforeach;
	self.assertTrueMsg(tiRec.getAllStops.isEmpty, CONT1 &amp; " has stops " &amp; tiRec.getStopsCodes());
	self.assertTrueMsg(tiPTI.getAllStops.isEmpty, CONT2 &amp; " has stops " &amp; tiRec.getStopsCodes());
	self.assertTrueMsg(tiSub.getAllStops.isEmpty, CONT3 &amp; " has stops " &amp; tiRec.getStopsCodes());
	
	// Set up Yard Allocations
	// Delete existing
	self.deleteYA(YARecDate);
	self.deleteYA(YAPTIDate);
	self.deleteYA(YASubDate);
	// Create new
	yaRecDate := self.addYA1(YARecDate, YACriteriaType_RecDateRange, "10/05/2025|20/05/2025", blockStack1.allLocationsControllers.first);
	self.assertEqualMsg(yaRecDate.allCriteria.size, 1, "Receival Date allocation has " &amp; yaRecDate.allCriteria.size.String &amp; " criteria");
	self.assertTrueMsg(yaRecDate.allCriteria.first.myYAData.isDateRangeValue, "Receival allocation criteria is the wrong kind");
	
	yaPTIDate := self.addYA1(YAPTIDate, YACriteriaType_PTIDateRange, "20/05/2025|30/05/2025", blockStack1.allLocationsControllers.first);
	self.assertEqualMsg(yaPTIDate.allCriteria.size, 1, "Pre-Trip Inspection Date allocation has " &amp; yaPTIDate.allCriteria.size.String &amp; " criteria");
	self.assertTrueMsg(yaPTIDate.allCriteria.first.myYAData.isDateRangeValue, "Pre-Trip Inspection allocation criteria is the wrong kind");
	
	yaSubDate := self.addYA1(YASubDate, YACriteriaType_STDateRange, "01/05/2025|15/05/2025", blockStack2.allLocationsControllers.first);
	self.assertEqualMsg(yaSubDate.allCriteria.size, 1, "Sub-Terminal Receival Date allocation has " &amp; yaSubDate.allCriteria.size.String &amp; " criteria");
	self.assertTrueMsg(yaSubDate.allCriteria.first.myYAData.isDateRangeValue, "Sub-Terminal Receival allocation criteria is the wrong kind");
	
	// Create the Release Requests
	create pxyReleaseMatchCrit transient;
	create pxyCriteria transient;
	pxyReleaseMatchCrit.allCriteria.add(pxyCriteria);
	pxyCriteria.setProxy(	CM_YATypeReceiveDateRange.firstInstance,	//pCriteriaTypeObj:CM_YACriteriaType;
							"10/05/2025|20/05/2025",					//pDataValue:Any;
							"Received D"								//pCode:String
							);
	self.opts.purge;
	self.opts.addAssoc("ISOType", "22G1");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc(ETRow_SetCriteria, pxyReleaseMatchCrit);
	relByRec := self.addReleaseByTypeRequestOpts(RELBYRECDATE, BR_TYPE_ROAD, TI_CargoType_Container);
	self.assertTrueMsg( relByRec &lt;&gt; null, "BulkRelease not created" );
	self.assertTrueMsg( not relByRec.allReserveDetails.isEmpty, "Reserve Details not created for " &amp; RELBYRECDATE );
	reserveDet := relByRec.allReserveDetails.first;
	self.assertTrueMsg( reserveDet.isKindOf(CM_ReserveSelection), "No Reserve Selection found for " &amp; RELBYRECDATE );
	reserveSelRec := reserveDet.CM_ReserveSelection;
	self.assertTrueMsg( reserveSelRec.myReleaseCriteria &lt;&gt; null, "No Match Criteria on Reserve Selection for " &amp; RELBYRECDATE );
	
	//delete pxyReleaseMatchCrit;	// deleted in the trx - just leaving this comment here for 
	//delete pxyCriteria;			// future people who might steal this code
	create pxyReleaseMatchCrit transient;
	create pxyCriteria transient;
	pxyReleaseMatchCrit.allCriteria.add(pxyCriteria);
	pxyCriteria.setProxy(	CM_YATypePTIDateRange.firstInstance,	//pCriteriaTypeObj:CM_YACriteriaType;
							"20/05/2025|25/05/2025",					//pDataValue:Any;
							"Pre-Trip I"								//pCode:String
							);
	self.opts.purge;
	self.opts.addAssoc("ISOType", "22R1");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc(ETRow_SetCriteria, pxyReleaseMatchCrit);
	relByPTI := self.addReleaseByTypeRequestOpts(RELBYPTIDATE, BR_TYPE_ROAD, TI_CargoType_Container);
	self.assertTrueMsg( relByPTI &lt;&gt; null, "BulkRelease not created" );
	self.assertTrueMsg( not relByPTI.allReserveDetails.isEmpty, "Reserve Details not created for " &amp; RELBYPTIDATE );
	reserveDet := relByPTI.allReserveDetails.first;
	self.assertTrueMsg( reserveDet.isKindOf(CM_ReserveSelection), "No Reserve Selection found for " &amp; RELBYPTIDATE );
	reserveSelPTI := reserveDet.CM_ReserveSelection;
	self.assertTrueMsg( reserveSelPTI.myReleaseCriteria &lt;&gt; null, "No Match Criteria on Reserve Selection for " &amp; RELBYPTIDATE );
	
	//delete pxyReleaseMatchCrit;	// deleted in the trx - just leaving this comment here for 
	//delete pxyCriteria;			// future people who might steal this code
	create pxyReleaseMatchCrit transient;
	create pxyCriteria transient;
	pxyReleaseMatchCrit.allCriteria.add(pxyCriteria);
	pxyCriteria.setProxy(	CM_YATypeSubTermRecDateRange.firstInstance,	//pCriteriaTypeObj:CM_YACriteriaType;
							"01/05/2025|10/05/2025",					//pDataValue:Any;
							"Sub-Termin"								//pCode:String
							);
	self.opts.purge;
	self.opts.addAssoc("ISOType", "22G1");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc(ETRow_SetCriteria, pxyReleaseMatchCrit);
	relBySub := self.addReleaseByTypeRequestOpts(RELBYSUBDATE, BR_TYPE_ROAD, TI_CargoType_Container);
	self.assertTrueMsg( relBySub &lt;&gt; null, "BulkRelease not created" );
	self.assertTrueMsg( not relBySub.allReserveDetails.isEmpty, "Reserve Details not created for " &amp; RELBYSUBDATE );
	reserveDet := relBySub.allReserveDetails.first;
	self.assertTrueMsg( reserveDet.isKindOf(CM_ReserveSelection), "No Reserve Selection found for " &amp; RELBYPTIDATE );
	reserveSelSub := reserveDet.CM_ReserveSelection;
	self.assertTrueMsg( reserveSelSub.myReleaseCriteria &lt;&gt; null, "No Match Criteria on Reserve Selection for " &amp; RELBYPTIDATE );
	
	// Release Criteria Receival Date
	// Make sure that the expected sources are found by autoplan
	source := app.sourceTisForRequestYA(self.getTerminal(), relByRec.requests.first);
	self.assertNotNullMsg(source, self.getYAAutoPlanMessages);
	self.assertEqualMsg(source.getName(), blockStack1.allLocationsControllers.first.getName(), "Wrong Terminal Area found");
	self.assertTrueMsg( app.myYAAgent &lt;&gt; null, "No YAAgent for 'request' for " &amp; RELBYRECDATE );
	cmifYARequest := app.myYAAgent.myCMIFYAAutoPlan;
	self.assertTrueMsg( cmifYARequest &lt;&gt; null, "No CMIF on the YA Agent for 'request' for " &amp; RELBYRECDATE );
	self.assertTrueMsg( cmifYARequest.allKeepTrackedTis.first.id = CONT1, "First Ti found for 'request' for " &amp; RELBYRECDATE &amp; " should be " &amp; CONT1 );
	
	// Check the test auto plan for Reserve implemented on the Bulk Release form.
	app.testAutoplanReseveDetails(terminal, reserveSelRec);
	self.assertTrueMsg( app.myYAAgent &lt;&gt; null, "No YA Agent for 'reserve selection' for Receival Date Release" );
	cmifYARequest := app.myYAAgent.myCMIFYAAutoPlan;
	self.assertTrueMsg( cmifYARequest &lt;&gt; null, "No CMIF on the YAAgent for 'reserve selection' for Receival Date Release" );
	self.assertTrueMsg( cmifYARequest.allKeepTrackedTis.first.id = CONT1, "First Ti found for 'reserve selection' for Receival Date Release should be " &amp; CONT1 );
	
	// Release Criteria Pre-Trip Inspection Date
	// Make sure that the expected sources are found by autoplan
	source := app.sourceTisForRequestYA(self.getTerminal(), relByPTI.requests.first);
	assertNotNullMsg(source, self.getYAAutoPlanMessages);
	assertEqual(source.getName(), blockStack1.allLocationsControllers.first.getName());
	self.assertTrueMsg( app.myYAAgent &lt;&gt; null, "No YAAgent for 'request' for " &amp; RELBYPTIDATE );
	cmifYARequest := app.myYAAgent.myCMIFYAAutoPlan;
	self.assertTrueMsg( cmifYARequest &lt;&gt; null, "No CMIF on the YA Agent for 'request' for " &amp; RELBYPTIDATE );
	self.assertTrueMsg( cmifYARequest.allKeepTrackedTis.first.id = CONT2, "First Ti found for 'request' for " &amp; RELBYPTIDATE &amp; " should be " &amp; CONT2 );
	
	// Check the test auto plan for Reserve implemented on the Bulk Release form.
	app.testAutoplanReseveDetails(terminal, reserveSelPTI);
	self.assertTrueMsg( app.myYAAgent &lt;&gt; null, "No YA Agent for 'reserve selection' for " &amp; RELBYPTIDATE );
	cmifYARequest := app.myYAAgent.myCMIFYAAutoPlan;
	self.assertTrueMsg( cmifYARequest &lt;&gt; null, "No CMIF on the YAAgent for 'reserve selection' for " &amp; RELBYPTIDATE );
	self.assertTrueMsg( cmifYARequest.allKeepTrackedTis.first.id = CONT2, "First Ti found for 'reserve selection' for " &amp; RELBYPTIDATE &amp; " should be " &amp; CONT2 );
	
	// Release Criteria Sub-Terminal Receival Date
	// Make sure that the expected sources are found by autoplan
	source := app.sourceTisForRequestYA(self.getTerminal(), relBySub.requests.first);
	assertNotNullMsg(source, self.getYAAutoPlanMessages);
	assertEqual(source.getName(), blockStack2.allLocationsControllers.first.getName());
	self.assertTrueMsg( app.myYAAgent &lt;&gt; null, "No YAAgent for 'request' for " &amp; RELBYSUBDATE );
	cmifYARequest := app.myYAAgent.myCMIFYAAutoPlan;
	self.assertTrueMsg( cmifYARequest &lt;&gt; null, "No CMIF on the YA Agent for 'request' for " &amp; RELBYSUBDATE );
	self.assertTrueMsg( cmifYARequest.allKeepTrackedTis.first.id = CONT3, "First Ti found for 'request' for " &amp; RELBYSUBDATE &amp; " should be " &amp; CONT3 );
	
	// Check the test auto plan for Reserve implemented on the Bulk Release form.
	app.testAutoplanReseveDetails(terminal, reserveSelSub);
	self.assertTrueMsg( app.myYAAgent &lt;&gt; null, "No YA Agent for 'reserve selection' for " &amp; RELBYSUBDATE );
	cmifYARequest := app.myYAAgent.myCMIFYAAutoPlan;
	self.assertTrueMsg( cmifYARequest &lt;&gt; null, "No CMIF on the YAAgent for 'reserve selection' for " &amp; RELBYSUBDATE );
	self.assertTrueMsg( cmifYARequest.allKeepTrackedTis.first.id = CONT3, "First Ti found for 'reserve selection' for " &amp; RELBYSUBDATE &amp; " should be " &amp; CONT3 );
	
epilog
	// Put the sub-terminals back where they were
	self.setTerminalConfig(IsSubTerminalsOn, subTerminalsEnabled);
	if resetSubTermAreaDefined then
		self.setSubTerminalAreaDefined( false );
	endif;

	// Delete the sub terminals
	self.deleteSubTerminal(SubTerm1Code);
	self.deleteSubTerminal(SubTerm2Code);
	
	// Enable all yard allocations again
	self.disableAllYA(false);
	
	delete pxySubTermDef;
	delete selectedObjects;
	//delete pxyReleaseMatchCrit;	// deleted in the trx - just leaving this comment here for 
	//delete pxyCriteria;			// future people who might steal this code
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseByType_GroupSub" id="f2b71bd0-7f41-42e4-82db-301c443012c2">
        <source>tReleaseByType_GroupSub();
// cnwndl1

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 June 2013	cnwrd1	Initial creation

*/

constants
	RELEASE = "UTRRBYTYPE";
vars
	releaseRequest: CM_BulkRelease;
	ti: CM_TrackedItem;
	ya: CM_YardAllocation;
	locations : CM_LCArray;
	source: CM_LocationsController;
	yaName: String;
begin
	self.setTerminalConfig(UseBestPickDirector, false);
	
	self.disableAllYA(true);
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyYA);
	
	deleteReleaseRequest(RELEASE);
	self.deleteContainer("TEST0000001");
	
	// Setup a YA over a block stack that has a cvontainer that could be released
	ti := self.addContainer("TEST0000001", operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	
	create locations transient;
	locations.add(bs1.allLocationsControllers.first.CM_YardController);
	yaName := self.getProfileSetting(UT_Profile.P_YA).asString;
	self.deleteYA(yaName);
	ya := self.addYA1(yaName, YACriteriaType_OperatorItem, operator.code, locations);
	assertFalse(ya.isDisabled);
	self.move(ti, locations.first);
	assertEqual(ti.myPrimaryActualLocation, locations.first);
	
	// Create the Release
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	releaseRequest := addReleaseByTypeRequestOpts(RELEASE, BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Make sure that the expected source is found by autoplan
	source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqual(source.getName(), locations.first.getName());
	
epilog
	delete locations;
	self.disableAllYA(false);
end;</source>
    </JadeMethod>
