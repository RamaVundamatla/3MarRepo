    <DbClassMap file="basedvum"/>
    <Constant name="CELSIUS" id="38b08a6e-d519-4af6-9a09-a846dc77acd5">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="FAHRENHEIT" id="1a469f7d-93aa-4d33-a18f-282e1df8bdc7">
        <source>2</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="KELVIN" id="186807e5-7a30-4837-a738-2ee235b661cb">
        <source>3</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="RANKINE" id="1535de22-529e-4ea5-9ab3-93367795db9c">
        <source>4</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="REAUMUR" id="3c2005b2-08ba-4654-b83f-27fa734a1327">
        <source>5</source>
        <type name="Integer"/>
    </Constant>
    <JadeMethod name="convertBaseToTarget" id="127c9b6c-1ec8-470e-9c0b-b7cf5938e560">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		26 May 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitTo = self.CELSIUS then
		convertedMeasure	:=	pMeasure - 273.16;
		
	elseif pUnitTo = self.FAHRENHEIT then
		convertedMeasure	:=	(pMeasure * 1.8) - 459.67;

	elseif pUnitTo = self.KELVIN then
		convertedMeasure	:=	pMeasure;

	elseif pUnitTo = self.RANKINE then
		convertedMeasure	:=	pMeasure * 1.8;

	elseif pUnitTo = self.REAUMUR then
		convertedMeasure	:=	(pMeasure - 273.16) / 1.25;

	else
		CnEcBaseSchemaException.raise_(CNEC_X_12004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of temperature to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="063e797f-01d6-4379-a90f-c8d994e09bdf">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		26 May 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.CELSIUS then
		convertedMeasure	:=	self.measure + 273.16;
		
	elseif pUnitFrom = self.FAHRENHEIT then
		convertedMeasure	:=	(self.measure + 459.67) / 1.8;

	elseif pUnitFrom = self.KELVIN then
		convertedMeasure	:=	self.measure;

	elseif pUnitFrom = self.RANKINE then
		convertedMeasure	:=	self.measure / 1.8;

	elseif pUnitFrom = self.REAUMUR then
		convertedMeasure	:=	(self.measure * 1.25) + 273.16;

	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of temperature to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getAllUnits" id="457810bb-98fe-49b7-9dea-011fa0d19c2d">
        <source>getAllUnits(pAllUnits: IntegerArray input);
// --------------------------------------------------------------------------------
// Created:		10 May 2008 by Darrell
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pAllUnits.add(self.CELSIUS);
	pAllUnits.add(self.FAHRENHEIT);
	pAllUnits.add(self.KELVIN);
	pAllUnits.add(self.RANKINE);
	pAllUnits.add(self.REAUMUR);
end;</source>
        <Parameter name="pAllUnits" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBodyTemperature" id="71e219d9-1e8f-4d06-81a4-412cfe1ae567">
        <source>getBodyTemperature(pUnitTo:Integer):Real;
// --------------------------------------------------------------------------------
// Created:		26 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnMeasure	: Real;
	
begin
	if pUnitTo = self.CELSIUS then
		returnMeasure	:=	37;
		
	elseif pUnitTo = self.FAHRENHEIT then
		returnMeasure	:=	98.6;

	elseif pUnitTo = self.KELVIN then
		returnMeasure	:=	310.16;

	elseif pUnitTo = self.RANKINE then
		returnMeasure	:=	self.convertBaseToTarget(310.16, self.RANKINE);

	elseif pUnitTo = self.REAUMUR then
		returnMeasure	:=	self.convertBaseToTarget(310.16, self.REAUMUR);

	endif;
epilog
	return returnMeasure;
end;</source>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getBoilingPoint" id="100c2bad-6057-407f-8319-987eb86894b3">
        <source>getBoilingPoint(pUnitTo:Integer):Real;
// --------------------------------------------------------------------------------
// Created:		26 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnMeasure	: Real;
	
begin
	if pUnitTo = self.CELSIUS then
		returnMeasure	:=	100;
		
	elseif pUnitTo = self.FAHRENHEIT then
		returnMeasure	:=	212;

	elseif pUnitTo = self.KELVIN then
		returnMeasure	:=	373.16;

	elseif pUnitTo = self.RANKINE then
		returnMeasure	:=	self.convertBaseToTarget(373.16, self.RANKINE);

	elseif pUnitTo = self.REAUMUR then
		returnMeasure	:=	self.convertBaseToTarget(373.16, self.REAUMUR);

	endif;
epilog
	return returnMeasure;
end;</source>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getFreezingPoint" id="e8ae2465-1e54-4aaa-98ce-8047e8f6bc71">
        <source>getFreezingPoint(pUnitTo:Integer):Real;
// --------------------------------------------------------------------------------
// Created:		26 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnMeasure	: Real;
	
begin
	if pUnitTo = self.CELSIUS then
		returnMeasure	:=	0;
		
	elseif pUnitTo = self.FAHRENHEIT then
		returnMeasure	:=	32;

	elseif pUnitTo = self.KELVIN then
		returnMeasure	:=	273.16;

	elseif pUnitTo = self.RANKINE then
		returnMeasure	:=	self.convertBaseToTarget(273.16, self.RANKINE);

	elseif pUnitTo = self.REAUMUR then
		returnMeasure	:=	self.convertBaseToTarget(273.16, self.REAUMUR);

	endif;
epilog
	return returnMeasure;
end;</source>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getUnitName" id="5d510747-454f-41d3-9508-c2f897d44fc7">
        <source>getUnitName(pUnit: Integer): String;
// --------------------------------------------------------------------------------
// Created:		09 May 2008 by Darrell
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pUnit = self.CELSIUS then
		return "Celsius";
	elseif pUnit = self.FAHRENHEIT then
		return "Fahrenheit";
	elseif pUnit = self.KELVIN then
		return "kelvin";
	elseif pUnit = self.RANKINE then
		return "Rankine";
	elseif pUnit = self.REAUMUR then
		return "Reaumur";
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnit.String &amp; "] is an unknown unit of Temperature to convert from.");
		return null;
	endif;
end;</source>
        <Parameter name="pUnit" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
