    <JadeMethod name="tblEDITI_mouseMove" id="c2dd5825-84ab-483c-8f43-f3e96d6a8f2c">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEDITI_mouseMove(table: CM_DataTable input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//----------------------------------------------------------------
//	Created:	03 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	intRow	: Integer;
	obj		: CM_EDITrackedItem;
begin
	table.bubbleHelp := "";
	intRow := table.getRowFromY(y);
	
	if intRow &gt; table.fixedRows and intRow &lt;= table.rows then
	
		obj := table.accessRow(intRow).itemObject.CM_EDITrackedItem;
		if obj = null then
			return;
		else 
			if not global.isValidObject(obj) then
				return;
			endif;
		endif;
	else
		return;
	endif;
		
	table.bubbleHelp := obj.getBubbleText();

end;</source>
