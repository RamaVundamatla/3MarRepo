    <JadeMethod name="cmbCranes_click" id="3d854134-36ba-495e-81ab-1f6a10eec76f">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCranes_click(combobox: ComboBox input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.loadCraneRateDetails();

epilog

