    <JadeMethod name="shouldAuditProperty" id="d9ffb4a4-7343-45a1-b2ee-a9e613895003">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	if	propName = CM_TranMapVoyage::myChildQuantityMap.name  or
	propName = CM_TranMapVoyage::myBank.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="71e58030-3675-4163-8712-e042379613b0">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 09/12/2014 cnwdb2 PAR 35364
// ---------------------------------------------------------------------------

vars

begin
	// cnwjre1 May 2010 duplicate test added from general transaction map development, to avoid 1310 exception
	if self.myBank &lt;&gt; null then
		if self.myBank.allJMHTMs[self.name] &lt;&gt; null then
		// 	app.raiseCMException3(ERR_DUPLICATE_KEY,"Transaction map",self.name,null,null,null);
			app.raiseCMException1(Already_exists_transMap,self.name,null,null); //cnwdb2	PAR 35364

		endif;
	endif;
end;</source>
    </JadeMethod>
