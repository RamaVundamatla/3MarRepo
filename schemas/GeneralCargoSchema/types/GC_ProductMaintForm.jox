    <JadeMethod name="doCancel" id="87ae0765-7517-4026-8cdc-7b9d18fcdccf">
        <updating/>
        <source>doCancel(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     21 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	result		: Integer;
begin
//	return inheritMethod();

	if self.isCodesEdited then 
		// reset.
		result := app.msgBox(app.getErrorString(EditChangedAndClosing) &amp; CrLf &amp; CrLf &amp;'PLEASE NOTE: Changes made to codes will not be saved', self.caption &amp; " Window Closing !", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if result = MsgBox_Return_Yes then
			self.isCodesEdited := false;
			return true;	//close form
