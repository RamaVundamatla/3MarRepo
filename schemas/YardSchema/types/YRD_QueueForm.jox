    <JadeMethod name="deleteQueueEntry" id="008fc1db-ad52-45fe-8723-2804bc100a67">
        <updating/>
        <source>deleteQueueEntry(_entry : CM_RTQueueEntry io) protected, updating;
// -------------------------------------------
// Created 10 October 2003 by cnwdvb1
// -------------------------------------------
vars

	lMoveControl	: CMIF_MoveController;
	result		: Integer;
	wleArray,
	wlesWithWarnings	: CM_WLEArray;
	
begin

	if not global.isValidObject(_entry) then
		return;
	endif;

	// Used two separate trx's to handle overstow unqueueing. Very ugly but unfortunately necessary
	// to make sure future moves aren't left behind because overstow tasks are deleted with overstowed
	// boxes queue entry.
	if _entry.myWorkListEntry.myTrackedItem &lt;&gt; null then
		create lMoveControl transient;
		if _entry.isPlanOnPickupNoTarget then //cnwrd1 ccms 2014 pop
			lMoveControl.setMoveMode(QUEUE_PLAN_ON_PICKUP);
		else
			lMoveControl.setMoveMode(QUEUE_MODE);
		endif;
		lMoveControl.setMyTrackedItem(_entry.myWorkListEntry.myTrackedItem);
		lMoveControl.setMyWorkListEntry(_entry.myWorkListEntry);
		lMoveControl.isForcedMove := true;
		
		while true do
			app.myTrxUA.trxUpdateMoveTIUndo(lMoveControl, app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog('Unqueue', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
				if result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					
					continue;
				endif;
			endif;
			break;
		endwhile;
	else
		create wleArray transient;
		create wlesWithWarnings transient;
		wleArray.add(_entry.myWorkListEntry);

		while true do
			app.myTrxUA.trxUpdateWLEsUnqueue(wleArray, wlesWithWarnings, app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog('Unqueue', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
				if result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					
					// only reprocess the wles that had warnings.
					wleArray.clear;
					wlesWithWarnings.copy(wleArray);
					wlesWithWarnings.clear;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endif;
	


epilog
	delete lMoveControl;
	delete wleArray;
	delete wlesWithWarnings;
end;</source>
        <access>protected</access>
        <Parameter name="_entry" type="CM_RTQueueEntry" usage="io"/>
    </JadeMethod>
    <JadeMethod name="deselectRTQueueEntry" id="4d05e144-0819-43fa-a77b-17ea8a7738d4">
        <source>deselectRTQueueEntry( _obj : Object );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2014	cnwndl1	Initial creation	Par 25646

*/

vars

	entry : CM_RTQueueEntry;

begin

	if _obj = null then
		return;
	endif;

	if not _obj.isKindOf(CM_RTQueueEntry) then
		return;
	endif;
	
	entry := _obj.CM_RTQueueEntry;

	if self.allSelectedRTQEntries.includes( entry ) then
		self.allSelectedRTQEntries.remove( entry );
		
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="displayMachineInTable" id="0abd9076-4d33-4fe3-9ee8-25224f994641">
        <source>displayMachineInTable(_machine : CM_Machine; _selectedQueue : CM_RadioTelemetryQueue) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Aug 2011	cnwdz2	27747
16 Sep 2020	jlgdap1	TFS 49316 MTN Machine Idle Time
*/

vars
	bubbleHelpStr	: String;
	theRow			: Integer;
//	object			: Object;
	isInPrimary		: Boolean;
	invalidTask,
	invalidPrim		: Boolean;
	queueString		: String;
	currentTask		: CM_RTQueueTask;
	
	primaryQ		: CM_RadioTelemetryQueue;
	queueDisplayStr : String;
	backColour		: Integer;						// TFS 49316
	
begin
	backColour := self.getTblMachineDisplayString(_machine, _selectedQueue, queueDisplayStr, bubbleHelpStr);		// TFS 49316
	theRow := tblMachines.addItem(queueDisplayStr &amp; Tab &amp; bubbleHelpStr);
	tblMachines.accessRow(theRow).itemObject := _machine;
	self.tblMachines.accessedRow.backColor := backColour;															// TFS 49316
		
	self.setMachineStatusPic(_machine, theRow);
	self.showHideLoggedOffMachines(_machine, theRow);
	
	// TFS 49316 below code refactored into getTblMachineDisplayString method
	/*on Exception do app.handleDeletedObject(exception, primaryQ, invalidPrim);
	on Exception do app.handleDeletedObject(exception, currentTask, invalidTask);
	
	primaryQ := _machine.myPrimaryQueue;					// PAR # 26919
	queueString := null;
	if primaryQ &lt;&gt; null then
		queueString := '/' &amp; primaryQ.id;
	endif;
	queueDisplayStr := _machine.id;
	
	bubbleHelpStr := queueDisplayStr &amp; '  ' &amp; _machine.machineTypeString &amp; queueString;
		
	currentTask := _machine.currentQueueTask;			// PAR #26919
	isInPrimary := false;
	isInPrimary := currentTask &lt;&gt; null and currentTask.queue = primaryQ;
		
	if _machine.loggedOn and _machine.user &lt;&gt; null then
		bubbleHelpStr := bubbleHelpStr &amp; '/' &amp; _machine.user.userName;
	endif;
		
	// For queues other than the master, if the selected queue is a secondary queue for the machine 
	// then the id will be prefixed with "~"
	if _selectedQueue &lt;&gt; self.myMasterQueue then
		if _machine.allQueues.includes(_selectedQueue) and _selectedQueue &lt;&gt; primaryQ then
			queueDisplayStr := '~' &amp; queueDisplayStr;
		endif;
	endif;
		
	if primaryQ = self.myMasterQueue then
		queueDisplayStr := queueDisplayStr &amp; ' (M)';
	endif;
		
	if _machine.myNextPrimaryQueue &lt;&gt; null then	
		if _machine.myPrimaryQueue &lt;&gt; null then
			bubbleHelpStr := bubbleHelpStr &amp; CrLf &amp; "Queued to move from " &amp; _machine.myPrimaryQueue.id &amp; " to " &amp; _machine.myNextPrimaryQueue.id;
		else
			bubbleHelpStr := bubbleHelpStr &amp; CrLf &amp; "Queued to move to " &amp; _machine.myNextPrimaryQueue.id;
		endif;
	
		if _selectedQueue = _machine.myNextPrimaryQueue then
			queueDisplayStr := queueDisplayStr &amp; ' (+Q)';
		elseif _selectedQueue = self.myMasterQueue and primaryQ &lt;&gt; self.myMasterQueue then
			queueDisplayStr := queueDisplayStr &amp; ' (Q)';
		else
			queueDisplayStr := queueDisplayStr &amp; ' (-Q)';
		endif;
	endif;
		
	if currentTask &lt;&gt; null and currentTask.queue &lt;&gt; primaryQ then
		queueDisplayStr := queueDisplayStr &amp; ' (S)';
	endif;	*/
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_selectedQueue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="displayMachinesForInheritedQ" id="ee065c79-6b74-41eb-b08d-5bcdd10c0ea8">
        <source>displayMachinesForInheritedQ(_selectedQueue : CM_RadioTelemetryQueue) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2011	#cnwdz2	 27747
If "show inherited" then machiens currently in the parent queue (and its parents, on upto the master queue)
*/

vars
	machinesForInheritedQ 	: CM_MachineByIdDict;
	machine : CM_Machine;
begin
	
	create machinesForInheritedQ transient;
	_selectedQueue.getMachinesForInheritedQueue(machinesForInheritedQ, false);
	foreach machine in machinesForInheritedQ discreteLock do
		if machine.isCrane() and not machine.hasRadioTelemetry then
			continue;
		endif;
				
		if allViewedMachines.includes(machine) then
			continue;
		endif;
			
		self.displayMachineInTable(machine, _selectedQueue);
	endforeach;
	
epilog
	delete machinesForInheritedQ;
end;</source>
