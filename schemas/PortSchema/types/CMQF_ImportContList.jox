<Class name="CMQF_ImportContList" id="3e93c6fd-10bb-48a9-9838-75026d9d6131">
    <superclass name="CMQF_Import"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="e06694df-757c-4d4d-8719-cfbea4fc3b06">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;

/*
Date			Who		Reason
18 March 2010	cnwar2	#22537

*/
vars
	ta			: CM_TerminalArea;
	ti			: CM_TrackedItem;
	lc			: CM_LocationsController;
	terminal	: CM_Terminal;
	breakOut	: Boolean;
	
begin
	ta := self.getMyTerminalArea;
	
	if ta &lt;&gt; null then
		foreach lc in ta.allLocationsControllers discreteLock do
			foreach ti in lc.allTrackedItems discreteLock do
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
						self.sumWeight := self.sumWeight + ti.totalWeight;
					endif;
				endif;
			endforeach;
		endforeach;
	else
		if self.getMyVoyage &lt;&gt; null then
		//scan voyage collections, need to scan onsite, onship, notified as default when no ta specified
			//search onsite ti's
			foreach ti in self.getMyVoyage.allOnsiteTIsByIdCargoType discreteLock do
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
						self.sumWeight := self.sumWeight + ti.totalWeight;
					endif;
				endif;
			endforeach;
			//search offsite ti's
			foreach ti in self.getMyVoyage.allOffsiteTIsByIdCargoType discreteLock do
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
						self.sumWeight := self.sumWeight + ti.totalWeight;
					endif;
				endif;
			endforeach;
			//search onship ti's for selected voyage
			foreach ti in self.getMyVoyage.allOnshipTIsByIdCargoType discreteLock do
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
						self.sumWeight := self.sumWeight + ti.totalWeight;
					endif;
				endif;
			endforeach;
		endif;
	endif;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="1f440383-dc2f-45ce-b005-cc34270b0e07">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;

/*
Date			Who		Reason
18 March 2010	cnwar2	#22537

*/
vars

begin
	if _ti.isContainer() and 
	inheritMethod(_ti, _passport, _breakOut) then
		return true;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
