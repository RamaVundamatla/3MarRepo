    <JadeMethod name="setForUpdate" id="fd149b8d-58c6-403f-9147-7907829c8389">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604

*/

vars
	prop : Property;
	propDict : PropertyNDict;
begin
	inheritMethod(_proxyEDITI);
	
	propDict := self.class.getProperties;
	foreach prop in propDict do
		if prop.name = CM_EDIHazDetailsTI::allUNDGCodes.name then
			_proxyEDITI.allUNDGCodes.copy( self.allUNDGCodes );
			continue;
		endif;
		if self.canUserSet(prop.name) then
			self.setPropertyValue(prop.name, _proxyEDITI.getPropertyValue(prop.name));
		endif;
	endforeach;
end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
