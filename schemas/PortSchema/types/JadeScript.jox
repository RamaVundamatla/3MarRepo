    <JadeMethod name="adpAdditionalNormal" id="bca890b9-b17f-4e74-a926-83c780c7bd18">
        <source>adpAdditionalNormal(_cmif : CMIF_CalcTypeQuantityHook) : Real;
constants
	CALENDAR 				= 'AKB';		// Calendar code (holiday).
	CALENDAR2				= 'AKB';		// Calendar code (Friday).
	CALENDAR_RAMA			= 'AKB';		// Calendat code (Ramadan).
	
	RESOURCE 				= 'ADPAT';		// To Do Resource code (resource to look for on the transaction).
	
	NORMAL_START			= '07:00';		// 7AM.
	NORMAL_FINISH			= '16:00';		// 4PM.
	
	RAMA_NORMAL_START 		= '07:00';		// 7AM.
	RAMA_NORMAL_FINISH 		= '13:00';		// 1PM.
	
	EXTRA_MINS				= 1;			// Do Not Change.
	
vars
	terminal		: CM_Terminal;
	calendar,
	calendar2,
	calendar3		: CM_Calendar;
	toDoUsage,
	tempToDoUsage 	: CM_ResourceTypeUsage;
	
	fromDateTime,
	toDateTime		: TimeStamp;
	
	minTime,
	maxTime,
	fromTime,
	toTime			: Time;
	
	daysDifference,
	minsDifference 	: Integer;
	totalHours		: Real;
	
	hasRamaFromCalendarDay,
	hasRamaToCalendarDay,
	hasFromCalendarDay,
	hasToCalendarDay,
	hasHolCalendarDay,
	hasRamaCalendarDay 		: Boolean;
	
begin
	// Setup (get termnial and calendar).
	terminal := _cmif.myTransaction.CM_TITransaction.myTerminal;
	calendar := terminal.allCalendars[CALENDAR];
	calendar2 := terminal.allCalendars[CALENDAR2];
	calendar3 := terminal.allCalendars[CALENDAR_RAMA];
	toDoUsage := _cmif.myResourceTypeUsage;
	
	// If I can't find the To Do Resource, then theres nothing to do here.
	if toDoUsage = null or toDoUsage.myResourceType.code &lt;&gt; RESOURCE then
		return _cmif.origQty;
	endif;
	
	// Get the TimeStamps from the To Do Resource Usage.
	fromDateTime := toDoUsage.fromDateTime;
	toDateTime := toDoUsage.toDateTime;
	fromTime := fromDateTime.time;
	toTime := toDateTime.time;
	
	// Get start and finish days off Calendar (check to see if they are holidays).
	if calendar3.getFirstCalendarDateForDay(fromDateTime.date) &lt;&gt; null then
		hasRamaFromCalendarDay := true;
	endif;
	if calendar3.getFirstCalendarDateForDay(toDateTime.date) &lt;&gt; null then
		hasRamaToCalendarDay := true;
	endif;
	
	// Get start and finish days off Calendar (check to see if they are holidays).
	if calendar.getFirstCalendarDateForDay(fromDateTime.date) &lt;&gt; null 
	or calendar2.getFirstCalendarDateForDay(fromDateTime.date) &lt;&gt; null then
		hasFromCalendarDay := true;
	endif;
	if calendar.getFirstCalendarDateForDay(toDateTime.date) &lt;&gt; null
	or calendar2.getFirstCalendarDateForDay(toDateTime.date) &lt;&gt; null then
		hasToCalendarDay := true;
	endif;
	
	// Calculate the difference in days between the first and last.
	daysDifference := toDateTime.date - fromDateTime.date;
	
	// Check start day for holiday.
	if hasFromCalendarDay then
		// Do nothing - holiday.
	elseif hasRamaFromCalendarDay then
		// Check for 07:00 to 13:00.
		if fromTime &gt;= RAMA_NORMAL_START.Time then
			if toDateTime.date = fromDateTime.date and toTime &lt; RAMA_NORMAL_FINISH.Time then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(RAMA_NORMAL_FINISH.Time);
			endif;
		else
			if toDateTime.date = fromDateTime.date and toTime &lt; RAMA_NORMAL_FINISH.Time then
				minsDifference := minsDifference + RAMA_NORMAL_START.Time.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + RAMA_NORMAL_START.Time.cnMinutesDifference(RAMA_NORMAL_FINISH.Time);
			endif;
		endif;
	else
		// Check for 07:00 to 16:00.
		if fromTime &gt;= NORMAL_START.Time then
			if toDateTime.date = fromDateTime.date and toTime &lt; NORMAL_FINISH.Time then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(NORMAL_FINISH.Time);
			endif;
		else
			if toDateTime.date = fromDateTime.date and toTime &lt; NORMAL_FINISH.Time then
				minsDifference := minsDifference + NORMAL_START.Time.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + NORMAL_START.Time.cnMinutesDifference(NORMAL_FINISH.Time);
			endif;
		endif;
	endif;
	
	// Calculate middle days.
	if toDateTime.date &lt;&gt; fromDateTime.date then
		if daysDifference &gt; 1 then
			daysDifference := daysDifference - 1;
			while daysDifference &gt; 0 do
				hasHolCalendarDay := false;
				hasRamaCalendarDay := false;
				if calendar.getFirstCalendarDateForDay(fromDateTime.date + daysDifference) &lt;&gt; null 
				or calendar2.getFirstCalendarDateForDay(fromDateTime.date + daysDifference) &lt;&gt; null then
					hasHolCalendarDay := true;
				endif;
				if calendar3.getFirstCalendarDateForDay(fromDateTime.date + daysDifference) &lt;&gt; null then
					hasRamaCalendarDay := true;
				endif;
	
				if hasHolCalendarDay then
					// Do nothing - holiday.
				elseif hasRamaCalendarDay then
					minsDifference := minsDifference + RAMA_NORMAL_START.Time.cnMinutesDifference(RAMA_NORMAL_FINISH.Time);
				else
					// Normal day - whole overtime for that day.
					minsDifference := minsDifference + NORMAL_START.Time.cnMinutesDifference(NORMAL_FINISH.Time);
				endif;
				daysDifference := daysDifference - 1;
			endwhile;
		endif;
		
		// Check last day for holiday.
		if hasToCalendarDay then
			// Do nothing - holiday.
		elseif hasRamaToCalendarDay then
			// Check for 07:00 to 13:00.
			if toTime &gt; RAMA_NORMAL_START.Time then
				if toTime &lt; RAMA_NORMAL_FINISH.Time then
					minsDifference := minsDifference + RAMA_NORMAL_START.Time.cnMinutesDifference(toTime);
				else
					minsDifference := minsDifference + RAMA_NORMAL_START.Time.cnMinutesDifference(RAMA_NORMAL_FINISH.Time);
				endif;
			endif;
		else
			// Check for 07:00 to 16:00.
			if toTime &gt; NORMAL_START.Time then
				if toTime &lt; NORMAL_FINISH.Time then
					minsDifference := minsDifference + NORMAL_START.Time.cnMinutesDifference(toTime);
				else
					minsDifference := minsDifference + NORMAL_START.Time.cnMinutesDifference(NORMAL_FINISH.Time);
				endif;
			endif;
		endif;
	endif;
	
	// Calculate the total hours worked.
	totalHours := minsDifference / 60;
	if totalHours mod 1 &gt; 0 then
		totalHours := totalHours.Integer + 1;
	endif;
	
	// Return the total number of hours for the for all resources used.
	return _cmif.origQty * totalHours;
end;</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="adpAdditionalOvertime" id="4d9c8ee3-4ef6-4b02-98fa-54fc63ff297f">
        <source>adpAdditionalOvertime(_cmif : CMIF_CalcTypeQuantityHook) : Real;
constants
	CALENDAR_HOL 			= 'AKB';		// Calendar code (holiday).
	CALENDAR_FRI			= 'AKB';		// Calendar code (Friday).
	CALENDAR_RAMA			= 'AKB';		// Calendat code (Ramadan).
	
	RESOURCE 				= 'ADPAT';		// To Do Resource code (resource to look for on the transaction).
	
	OVERTIME_START			= '16:00';		// 4PM
	OVERTIME_FINISH			= '07:00';		// 7AM next day. Must be sometime the following day.
	
	RAMA_OVERTIME_START 	= '13:00';		// 1PM
	RAMA_OVERTIME_FINISH 	= '07:00';		// 7AM next day. Must be sometime the following day.
	
	MAXTIME					= '23:59';		// Do Not Change.
	MINTIME					= '00:00';		// Do Not Change.
	EXTRA_MINS				= 1;			// Do Not Change.
	
vars
	terminal		: CM_Terminal;
	calendar,
	calendar2,
	calendar3		: CM_Calendar;
	toDoUsage,
	tempToDoUsage 	: CM_ResourceTypeUsage;
	
	fromDateTime,
	toDateTime		: TimeStamp;
	
	minTime,
	maxTime,
	fromTime,
	toTime			: Time;
	
	daysDifference,
	minsDifference 	: Integer;
	totalHours		: Real;
	
	hasRamaFromCalendarDay,
	hasRamaToCalendarDay,
	hasFromCalendarDay,
	hasToCalendarDay,
	hasHolFromCalendarDay,
	hasHolToCalendarDay,
	hasMidCalendarDay,
	hasHolMidCalendarDay,
	hasRamaCalendarDay 		: Boolean;
	
	fromDayCalendar,
	toDayCalendar,
	holiday					: CM_CalendarDate;
	
begin
	// Setup (get termnial and calendar).
	terminal := _cmif.myTransaction.CM_TITransaction.myTerminal;
	calendar := terminal.allCalendars[CALENDAR_HOL];
	calendar2 := terminal.allCalendars[CALENDAR_FRI];
	calendar3 := terminal.allCalendars[CALENDAR_RAMA];
	toDoUsage := _cmif.myResourceTypeUsage;
	
	// If I can't find the To Do Resource, then theres nothing to do here.
	if toDoUsage = null or toDoUsage.myResourceType.code &lt;&gt; RESOURCE then
		return _cmif.origQty;
	endif;
	
	// Get the TimeStamps from the To Do Resource Usage.
	fromDateTime := toDoUsage.fromDateTime;
	toDateTime := toDoUsage.toDateTime;
	fromTime := fromDateTime.time;
	toTime := toDateTime.time;
	
	// Get start and finish days off Calendar (check to see if they are holidays).
	if calendar3.getFirstCalendarDateForDay(fromDateTime.date) &lt;&gt; null then
		hasRamaFromCalendarDay := true;
	endif;
	if calendar3.getFirstCalendarDateForDay(toDateTime.date) &lt;&gt; null then
		hasRamaToCalendarDay := true;
	endif;
	
	// Get start and finish days off Calendar (check to see if they are holidays).
	if calendar.getFirstCalendarDateForDay(fromDateTime.date) &lt;&gt; null then
		hasHolFromCalendarDay := true;
	endif;
	if calendar2.getFirstCalendarDateForDay(fromDateTime.date) &lt;&gt; null then
		hasFromCalendarDay := true;
	endif;
	if calendar.getFirstCalendarDateForDay(toDateTime.date) &lt;&gt; null then
		hasHolToCalendarDay := true;
	endif;
	if calendar2.getFirstCalendarDateForDay(toDateTime.date) &lt;&gt; null then
		hasToCalendarDay := true;
	endif;
	
	// Get start and finish days off Calendar (check to see if they are holidays).
	fromDayCalendar := calendar2.getFirstCalendarDateForDay(fromDateTime.date);
	toDayCalendar := calendar2.getFirstCalendarDateForDay(toDateTime.date);
	
	// Calculate the difference in days between the first and last.
	daysDifference := toDateTime.date - fromDateTime.date;
	
	// Check start day for holiday.
	if hasHolFromCalendarDay then
		// Do nothing
	elseif hasFromCalendarDay then
		// Calculate day as overtime.
		minTime := fromDayCalendar.startTime;
		if minTime = null then
			minTime := MINTIME.Time;
		endif;
		maxTime := fromDayCalendar.endTime;
		if maxTime = null then
			maxTime := MAXTIME.Time;
		endif;
		
		if fromTime &gt; minTime then
			minTime := fromTime;
		endif;
		
		if fromDateTime.date = toDateTime.date and toTime &lt; maxTime then
			maxTime := toTime;
		else
			minsDifference := minsDifference + EXTRA_MINS;
		endif;
		minsDifference := minsDifference + minTime.cnMinutesDifference(maxTime);
	elseif hasRamaFromCalendarDay then
		// Check for 00:00 to 07:00.
		if fromTime &lt; RAMA_OVERTIME_FINISH.Time then
			if toTime &lt; RAMA_OVERTIME_FINISH.Time then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(RAMA_OVERTIME_FINISH.Time);
			endif;
		endif;
		
		// Check for 13:00 to 23:59.
		if fromTime &gt;= RAMA_OVERTIME_START.Time then
			if toDateTime.date = fromDateTime.date then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
			endif;
		elseif fromTime &lt; RAMA_OVERTIME_START.Time then
			if toDateTime.date = fromDateTime.date then
				if toTime &gt; RAMA_OVERTIME_START.Time then
					minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(toTime);
				endif;
			else
				minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
			endif;
		endif;
	else
		// Check for 00:00 to 07:00.
		if fromTime &lt; OVERTIME_FINISH.Time then
			if toTime &lt; OVERTIME_FINISH.Time then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(OVERTIME_FINISH.Time);
			endif;
		endif;
		
		// Check for 16:00 to 23:59.
		if fromTime &gt;= OVERTIME_START.Time then
			if toDateTime.date = fromDateTime.date then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
			endif;
		elseif fromTime &lt; OVERTIME_START.Time then
			if toDateTime.date = fromDateTime.date then
				if toTime &gt; OVERTIME_START.Time then
					minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(toTime);
				endif;
			else
				minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
			endif;
		endif;
	endif;
	
	// Calculate middle days.
	if toDateTime.date &lt;&gt; fromDateTime.date then
		if daysDifference &gt; 1 then
			daysDifference := daysDifference - 1;
			while daysDifference &gt; 0 do
				hasHolMidCalendarDay := false;
				hasMidCalendarDay := false;
				hasRamaCalendarDay := false;
				
				holiday := calendar2.getFirstCalendarDateForDay(fromDateTime.date + daysDifference);
				
				if calendar.getFirstCalendarDateForDay(fromDateTime.date + daysDifference) &lt;&gt; null then
					hasHolMidCalendarDay := true;
				endif;
				if calendar2.getFirstCalendarDateForDay(fromDateTime.date + daysDifference) &lt;&gt; null then
					hasMidCalendarDay := true;
				endif;
				if calendar3.getFirstCalendarDateForDay(fromDateTime.date + daysDifference) &lt;&gt; null then
					hasRamaCalendarDay := true;
				endif;
				
				if hasHolMidCalendarDay then
					// Do nothing
				elseif hasMidCalendarDay then
					// Holiday - whole day (or hours specified).
					minTime := holiday.startTime;
					if minTime = null then
						minTime := MINTIME.Time;
					endif;
					maxTime := holiday.endTime;
					if maxTime = null then
						maxTime := MAXTIME.Time;
					endif;
					minsDifference := minsDifference + minTime.cnMinutesDifference(maxTime) + EXTRA_MINS;
				elseif hasRamaCalendarDay then
					// Check for 00:00 to 07:00.
					if toTime &gt; RAMA_OVERTIME_FINISH.Time then
						minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(RAMA_OVERTIME_FINISH.Time);
					else
						minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(toTime);
					endif;
					
					// Check for 13:00 to 23:59.
					if toTime &gt; RAMA_OVERTIME_START.Time then
						minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(maxTime) + EXTRA_MINS;
						//minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(toTime);
					endif;
				else
					// Normal day - whole overtime for that day.
					minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(OVERTIME_FINISH.Time);
					minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
				endif;
				daysDifference := daysDifference - 1;
			endwhile;
		endif;
		
		// Check last day for holiday.
		if hasHolToCalendarDay then
			// Do nothing
		elseif hasToCalendarDay then
			//Calculate holiday hours
			minTime := toDayCalendar.startTime;
			if minTime = null then
				minTime := MINTIME.Time;
			endif;
			maxTime := toDayCalendar.endTime;
			if maxTime = null then
				maxTime := MAXTIME.Time;
			endif;
			
			if toTime &lt; maxTime then
				maxTime := toTime;
			else 
				minsDifference := minsDifference + EXTRA_MINS;
			endif;
			minsDifference := minsDifference + minTime.cnMinutesDifference(maxTime);
		elseif hasRamaToCalendarDay then
			// Check for 00:00 to 07:00.
			if toTime &gt; RAMA_OVERTIME_FINISH.Time then
				minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(RAMA_OVERTIME_FINISH.Time);
			else
				minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(toTime);
			endif;
			
			// Check for 16:00 to 23:59.
			if toTime &gt; RAMA_OVERTIME_START.Time then
				minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(toTime);
			endif;
		else
			// Check for 00:00 to 07:00.
			if toTime &gt; OVERTIME_FINISH.Time then
				minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(OVERTIME_FINISH.Time);
			else
				minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(toTime);
			endif;
			
			// Check for 16:00 to 23:59.
			if toTime &gt; OVERTIME_START.Time then
				minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(toTime);
			endif;
		endif;
	endif;
	
	// Calculate the total hours worked.
	totalHours := minsDifference / 60;
	if totalHours mod 1 &gt; 0 then
		totalHours := totalHours.Integer + 1;
	endif;
	
	// Return the total number of hours for the for all resources used.
	return _cmif.origQty * totalHours;
end;</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="adpAdditionalOvertimeFull" id="13a2085f-3e7c-4ce1-9dc7-a75099028d14">
        <source>adpAdditionalOvertimeFull(_cmif : CMIF_CalcTypeQuantityHook) : Real;
constants
	CALENDAR 				= 'AKB';		// Calendar code (holiday).
	CALENDAR2				= 'AKB';		// Calendar code (Friday).
	CALENDAR_RAMA			= 'AKB';		// Calendat code (Ramadan).
	
	RESOURCE 				= 'ADPAT';		// To Do Resource code (resource to look for on the transaction).
	
	OVERTIME_START			= '16:00';		// 4PM
	OVERTIME_FINISH			= '07:00';		// 7AM next day. Must be sometime the following day.
	
	RAMA_OVERTIME_START 	= '13:00';		// 1PM
	RAMA_OVERTIME_FINISH 	= '07:00';		// 7AM next day. Must be sometime the following day.
	
	MAXTIME					= '23:59';		// Do Not Change.
	MINTIME					= '00:00';		// Do Not Change.
	EXTRA_MINS				= 1;			// Do Not Change.
	
vars
	terminal		: CM_Terminal;
	calendar,
	calendar2,
	calendar3		: CM_Calendar;
	toDoUsage,
	tempToDoUsage 	: CM_ResourceTypeUsage;
	
	fromDateTime,
	toDateTime		: TimeStamp;
	
	minTime,
	maxTime,
	fromTime,
	toTime			: Time;
	
	daysDifference,
	minsDifference 	: Integer;
	totalHours		: Real;
	
	hasRamaFromCalendarDay,
	hasRamaToCalendarDay,
	hasFromCalendarDay,
	hasToCalendarDay,
	hasHolCalendarDay,
	hasRamaCalendarDay 		: Boolean;
	
	fromDayCalendar,
	toDayCalendar,
	holiday					: CM_CalendarDate;
	
begin
	// Setup (get termnial and calendar).
	terminal := _cmif.myTransaction.CM_TITransaction.myTerminal;
	calendar := terminal.allCalendars[CALENDAR];
	calendar2 := terminal.allCalendars[CALENDAR2];
	calendar3 := terminal.allCalendars[CALENDAR_RAMA];
	toDoUsage := _cmif.myResourceTypeUsage;
	
	// If I can't find the To Do Resource, then theres nothing to do here.
	if toDoUsage = null or toDoUsage.myResourceType.code &lt;&gt; RESOURCE then
		return _cmif.origQty;
	endif;
	
	// Get the TimeStamps from the To Do Resource Usage.
	fromDateTime := toDoUsage.fromDateTime;
	toDateTime := toDoUsage.toDateTime;
	fromTime := fromDateTime.time;
	toTime := toDateTime.time;
	
	// Get start and finish days off Calendar (check to see if they are holidays).
	if calendar3.getFirstCalendarDateForDay(fromDateTime.date) &lt;&gt; null then
		hasRamaFromCalendarDay := true;
	endif;
	if calendar3.getFirstCalendarDateForDay(toDateTime.date) &lt;&gt; null then
		hasRamaToCalendarDay := true;
	endif;
	
	// Get start and finish days off Calendar (check to see if they are holidays).
	if calendar.getFirstCalendarDateForDay(fromDateTime.date) &lt;&gt; null 
	or calendar2.getFirstCalendarDateForDay(fromDateTime.date) &lt;&gt; null then
		hasFromCalendarDay := true;
	endif;
	if calendar.getFirstCalendarDateForDay(toDateTime.date) &lt;&gt; null
	or calendar2.getFirstCalendarDateForDay(toDateTime.date) &lt;&gt; null then
		hasToCalendarDay := true;
	endif;
	
	// Get start and finish days off Calendar (check to see if they are holidays).
	fromDayCalendar := calendar.getFirstCalendarDateForDay(fromDateTime.date);
	if fromDayCalendar = null then
		fromDayCalendar := calendar2.getFirstCalendarDateForDay(fromDateTime.date);
	endif;
	toDayCalendar := calendar.getFirstCalendarDateForDay(toDateTime.date);
	if toDayCalendar = null then
		toDayCalendar := calendar2.getFirstCalendarDateForDay(toDateTime.date);
	endif;
	
	// Calculate the difference in days between the first and last.
	daysDifference := toDateTime.date - fromDateTime.date;
	
	// Check start day for holiday.
	if hasFromCalendarDay then
		// Calculate day as overtime.
		minTime := fromDayCalendar.startTime;
		if minTime = null then
			minTime := MINTIME.Time;
		endif;
		maxTime := fromDayCalendar.endTime;
		if maxTime = null then
			maxTime := MAXTIME.Time;
		endif;
		
		if fromTime &gt; minTime then
			minTime := fromTime;
		endif;
		
		if fromDateTime.date = toDateTime.date and toTime &lt; maxTime then
			maxTime := toTime;
		else
			minsDifference := minsDifference + EXTRA_MINS;
		endif;
		minsDifference := minsDifference + minTime.cnMinutesDifference(maxTime);
	elseif hasRamaFromCalendarDay then
		// Check for 00:00 to 07:00.
		if fromTime &lt; RAMA_OVERTIME_FINISH.Time then
			if toTime &lt; RAMA_OVERTIME_FINISH.Time then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(RAMA_OVERTIME_FINISH.Time);
			endif;
		endif;
		
		// Check for 13:00 to 23:59.
		if fromTime &gt;= RAMA_OVERTIME_START.Time then
			if toDateTime.date = fromDateTime.date then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
			endif;
		elseif fromTime &lt; RAMA_OVERTIME_START.Time then
			if toDateTime.date = fromDateTime.date then
				if toTime &gt; RAMA_OVERTIME_START.Time then
					minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(toTime);
				endif;
			else
				minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
			endif;
		endif;
	else
		// Check for 00:00 to 07:00.
		if fromTime &lt; OVERTIME_FINISH.Time then
			if toTime &lt; OVERTIME_FINISH.Time then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(OVERTIME_FINISH.Time);
			endif;
		endif;
		
		// Check for 16:00 to 23:59.
		if fromTime &gt;= OVERTIME_START.Time then
			if toDateTime.date = fromDateTime.date then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
			endif;
		elseif fromTime &lt; OVERTIME_START.Time then
			if toDateTime.date = fromDateTime.date then
				if toTime &gt; OVERTIME_START.Time then
					minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(toTime);
				endif;
			else
				minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
			endif;
		endif;
	endif;
	
	// Calculate middle days.
	if toDateTime.date &lt;&gt; fromDateTime.date then
		if daysDifference &gt; 1 then
			daysDifference := daysDifference - 1;
			while daysDifference &gt; 0 do
				hasHolCalendarDay := false;
				hasRamaCalendarDay := false;
				
				holiday := calendar.getFirstCalendarDateForDay(fromDateTime.date + daysDifference);
				if holiday = null then
					holiday := calendar2.getFirstCalendarDateForDay(fromDateTime.date + daysDifference);
				endif;
				if calendar.getFirstCalendarDateForDay(fromDateTime.date + daysDifference) &lt;&gt; null 
				or calendar2.getFirstCalendarDateForDay(fromDateTime.date + daysDifference) &lt;&gt; null then
					hasHolCalendarDay := true;
				endif;
				if calendar3.getFirstCalendarDateForDay(fromDateTime.date + daysDifference) &lt;&gt; null then
					hasRamaCalendarDay := true;
				endif;
	
				if hasHolCalendarDay then
					// Holiday - whole day (or hours specified).
					minTime := holiday.startTime;
					if minTime = null then
						minTime := MINTIME.Time;
					endif;
					maxTime := holiday.endTime;
					if maxTime = null then
						maxTime := MAXTIME.Time;
					endif;
					minsDifference := minsDifference + minTime.cnMinutesDifference(maxTime) + EXTRA_MINS;
				elseif hasRamaCalendarDay then
					// Check for 00:00 to 07:00.
					if toTime &gt; RAMA_OVERTIME_FINISH.Time then
						minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(RAMA_OVERTIME_FINISH.Time);
					else
						minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(toTime);
					endif;
					
					// Check for 16:00 to 23:59.
					if toTime &gt; RAMA_OVERTIME_START.Time then
						minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(toTime);
					endif;
				else
					// Normal day - whole overtime for that day.
					minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(OVERTIME_FINISH.Time);
					minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
				endif;
				daysDifference := daysDifference - 1;
			endwhile;
		endif;
		
		// Check last day for holiday.
		if hasToCalendarDay then
			//Calculate holiday hours
			minTime := toDayCalendar.startTime;
			if minTime = null then
				minTime := MINTIME.Time;
			endif;
			maxTime := toDayCalendar.endTime;
			if maxTime = null then
				maxTime := MAXTIME.Time;
			endif;
			
			if toTime &lt; maxTime then
				maxTime := toTime;
			else 
				minsDifference := minsDifference + EXTRA_MINS;
			endif;
			minsDifference := minsDifference + minTime.cnMinutesDifference(maxTime);
		elseif hasRamaToCalendarDay then
			// Check for 00:00 to 07:00.
			if toTime &gt; RAMA_OVERTIME_FINISH.Time then
				minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(RAMA_OVERTIME_FINISH.Time);
			else
				minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(toTime);
			endif;
			
			// Check for 16:00 to 23:59.
			if toTime &gt; RAMA_OVERTIME_START.Time then
				minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(toTime);
			endif;
		else
			// Check for 00:00 to 07:00.
			if toTime &gt; OVERTIME_FINISH.Time then
				minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(OVERTIME_FINISH.Time);
			else
				minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(toTime);
			endif;
			
			// Check for 16:00 to 23:59.
			if toTime &gt; OVERTIME_START.Time then
				minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(toTime);
			endif;
		endif;
	endif;
	
	// Calculate the total hours worked.
	totalHours := minsDifference / 60;
	if totalHours mod 1 &gt; 0 then
		totalHours := totalHours.Integer + 1;
	endif;
	
	// Return the total number of hours for the for all resources used.
	return _cmif.origQty * totalHours;
end;</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="adpAllHours" id="a61c8f34-2592-46a5-a1b2-eec0370ecef8">
        <source>adpAllHours(_cmif : CMIF_CalcTypeQuantityHook) : Real;
constants
	RESOURCE 			= 'ADPNT';		// To Do Resource code (resource to look for on the transaction).
	
vars
	toDoUsage 		: CM_ResourceTypeUsage;
	
	fromDateTime, 
	toDateTime		: TimeStamp;
	
	hoursDifference	: Real;
	
begin

	toDoUsage := _cmif.myResourceTypeUsage;
	
	// If I can't find the To Do Resource, then theres nothing to do here.
	if toDoUsage = null or toDoUsage.myResourceType.code &lt;&gt; RESOURCE then
		return _cmif.origQty;
	endif;
	
	// Get the TimeStamps from the To Do Resource Usage.
	fromDateTime := toDoUsage.fromDateTime;
	toDateTime := toDoUsage.toDateTime;
	
	hoursDifference := fromDateTime.differenceInHoursReal(toDateTime);
	
	// Calculate the total hours worked.
	if hoursDifference mod 1 &gt; 0 then
		hoursDifference := hoursDifference.Integer + 1;
	endif;
	
	// Return the total number of hours for the for all resources used.
	return _cmif.origQty * hoursDifference;
	
epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="adpFriday" id="e73bc3d6-e5ea-4b47-82e0-8d1c9e94b1a2">
        <source>adpFriday(_cmif : CMIF_CalcTypeQuantityHook) : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2015	cnwmc5	Initial creation

*/

constants
	CALENDAR 			= 'AKB';		// Calendar code (must belong to working terminal).
	CALENDAR_HOL		= 'AKB';
	RESOURCE 			= 'ADPNT';		// To Do Resource code (resource to look for on the transaction).
	
	MAXTIME				= '23:59';		// Do Not Change.
	MINTIME				= '00:00';		// Do Not Change.
	EXTRA_MINS			= 1;			// Do Not Change.
	
vars
	terminal		: CM_Terminal;
	calendarHol,
	calendar		: CM_Calendar;
	toDoUsage,
	tempToDoUsage 	: CM_ResourceTypeUsage;
	
	fromDateTime,
	toDateTime		: TimeStamp;
	
	fromDayCalendar,
	toDayCalendar,
	holidayFrom,
	holidayTo,
	holiday,
	friday			: CM_CalendarDate;
	
	minTime,
	maxTime,
	fromTime,
	toTime			: Time;
	
	daysDifference,
	minsDifference 	: Integer;
	totalHours		: Real;
	
begin
	// Setup (get termnial and calendar).
	terminal := _cmif.myTransaction.CM_TITransaction.myTerminal;
	calendar := terminal.allCalendars[CALENDAR];
	calendarHol := terminal.allCalendars[CALENDAR_HOL];
	toDoUsage := _cmif.myResourceTypeUsage;
	
	// If I can't find the To Do Resource, then theres nothing to do here.
	if toDoUsage = null or toDoUsage.myResourceType.code &lt;&gt; RESOURCE then
		return _cmif.origQty;
	endif;
	
	// Get the TimeStamps from the To Do Resource Usage.
	fromDateTime := toDoUsage.fromDateTime;
	toDateTime := toDoUsage.toDateTime;
	fromTime := fromDateTime.time;
	toTime := toDateTime.time;
	
	// Get start and finish days off Calendar (check to see if they are holidays).
	fromDayCalendar := calendar.getFirstCalendarDateForDay(fromDateTime.date);
	toDayCalendar := calendar.getFirstCalendarDateForDay(toDateTime.date);
	holidayTo := calendarHol.getFirstCalendarDateForDay(toDateTime.date);
	holidayFrom := calendarHol.getFirstCalendarDateForDay(fromDateTime.date);
	
	// Calculate the difference in days between the first and last.
	daysDifference := toDateTime.date - fromDateTime.date;
	
	// Check start day for holiday.
	if holidayFrom &lt;&gt; null then
		// Do nothing
	elseif fromDayCalendar &lt;&gt; null then
		// Calculate full day as overtime.
		minTime := fromDayCalendar.startTime;
		if minTime = null then
			minTime := MINTIME.Time;
		endif;
		maxTime := fromDayCalendar.endTime;
		if maxTime = null then
			maxTime := MAXTIME.Time;
		endif;
		
		if fromTime &gt; minTime then
			minTime := fromTime;
		endif;
		
		if fromDateTime.date = toDateTime.date and toTime &lt; maxTime then
			maxTime := toTime;
		else
			minsDifference := minsDifference + EXTRA_MINS;
		endif;
		minsDifference := minsDifference + minTime.cnMinutesDifference(maxTime);
	endif;
	
	// Calculate middle days.
	if toDateTime.date &lt;&gt; fromDateTime.date then
		if daysDifference &gt; 1 then
			daysDifference := daysDifference - 1;
			while daysDifference &gt; 0 do
				holiday := calendarHol.getFirstCalendarDateForDay(fromDateTime.date + daysDifference);
				friday := calendar.getFirstCalendarDateForDay(fromDateTime.date + daysDifference);
				if holiday &lt;&gt; null then
					// Do nothing.
				elseif friday &lt;&gt; null then
					// Holiday - whole day (or hours specified).
					minTime := friday.startTime;
					if minTime = null then
						minTime := MINTIME.Time;
					endif;
					maxTime := friday.endTime;
					if maxTime = null then
						maxTime := MAXTIME.Time;
					endif;
					minsDifference := minsDifference + minTime.cnMinutesDifference(maxTime) + EXTRA_MINS;
				endif;
				daysDifference := daysDifference - 1;
			endwhile;
		endif;
		
		// Check last day for holiday.
		if holidayTo &lt;&gt; null then
			// Do nothing.
		elseif toDayCalendar &lt;&gt; null then
			minTime := toDayCalendar.startTime;
			if minTime = null then
				minTime := MINTIME.Time;
			endif;
			maxTime := toDayCalendar.endTime;
			if maxTime = null then
				maxTime := MAXTIME.Time;
			endif;
			
			if toTime &lt; maxTime then
				maxTime := toTime;
			else 
				minsDifference := minsDifference + EXTRA_MINS;
			endif;
			minsDifference := minsDifference + minTime.cnMinutesDifference(maxTime);
		endif;
	endif;
	
	// Calculate the total hours worked.
	totalHours := minsDifference / 60;
	if totalHours mod 1 &gt; 0 then
		totalHours := totalHours.Integer + 1;
	endif;
	
	// Return the total number of hours for the for all resources used.
	return _cmif.origQty * totalHours;
end;</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="adpHoliday" id="4c4e7d1c-c6ca-4b25-8416-5f49e1b9f175">
        <source>adpHoliday(_cmif : CMIF_CalcTypeQuantityHook) : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2015	cnwmc5	Initial creation

*/

constants
	CALENDAR 			= 'AKB';		// Calendar code (must belong to working terminal).
	RESOURCE 			= 'ADPNT';		// To Do Resource code (resource to look for on the transaction).
	
	MAXTIME				= '23:59';		// Do Not Change.
	MINTIME				= '00:00';		// Do Not Change.
	EXTRA_MINS			= 1;			// Do Not Change.
	
vars
	terminal		: CM_Terminal;
	calendar		: CM_Calendar;
	toDoUsage,
	tempToDoUsage 	: CM_ResourceTypeUsage;
	
	fromDateTime,
	toDateTime		: TimeStamp;
	
	fromDayCalendar,
	toDayCalendar,
	holiday			: CM_CalendarDate;
	
	minTime,
	maxTime,
	fromTime,
	toTime			: Time;
	
	daysDifference,
	minsDifference 	: Integer;
	totalHours		: Real;
	
begin
	// Setup (get termnial and calendar).
	terminal := _cmif.myTransaction.CM_TITransaction.myTerminal;
	calendar := terminal.allCalendars[CALENDAR];
	toDoUsage := _cmif.myResourceTypeUsage;
	
	// If I can't find the To Do Resource, then theres nothing to do here.
	if toDoUsage = null or toDoUsage.myResourceType.code &lt;&gt; RESOURCE then
		return _cmif.origQty;
	endif;
	
	// Get the TimeStamps from the To Do Resource Usage.
	fromDateTime := toDoUsage.fromDateTime;
	toDateTime := toDoUsage.toDateTime;
	fromTime := fromDateTime.time;
	toTime := toDateTime.time;
	
	// Get start and finish days off Calendar (check to see if they are holidays).
	fromDayCalendar := calendar.getFirstCalendarDateForDay(fromDateTime.date);
	toDayCalendar := calendar.getFirstCalendarDateForDay(toDateTime.date);
	
	// Calculate the difference in days between the first and last.
	daysDifference := toDateTime.date - fromDateTime.date;
	
	// Check start day for holiday.
	if fromDayCalendar &lt;&gt; null then
		// Calculate full day as overtime.
		minTime := fromDayCalendar.startTime;
		if minTime = null then
			minTime := MINTIME.Time;
		endif;
		maxTime := fromDayCalendar.endTime;
		if maxTime = null then
			maxTime := MAXTIME.Time;
		endif;
		
		if fromTime &gt; minTime then
			minTime := fromTime;
		endif;
		
		if fromDateTime.date = toDateTime.date and toTime &lt; maxTime then
			maxTime := toTime;
		else
			minsDifference := minsDifference + EXTRA_MINS;
		endif;
		minsDifference := minsDifference + minTime.cnMinutesDifference(maxTime);
	endif;
	
	// Calculate middle days.
	if toDateTime.date &lt;&gt; fromDateTime.date then
		if daysDifference &gt; 1 then
			daysDifference := daysDifference - 1;
			while daysDifference &gt; 0 do
				holiday := calendar.getFirstCalendarDateForDay(fromDateTime.date + daysDifference);
				if holiday &lt;&gt; null then
					// Holiday - whole day (or hours specified).
					minTime := holiday.startTime;
					if minTime = null then
						minTime := MINTIME.Time;
					endif;
					maxTime := holiday.endTime;
					if maxTime = null then
						maxTime := MAXTIME.Time;
					endif;
					minsDifference := minsDifference + minTime.cnMinutesDifference(maxTime) + EXTRA_MINS;
				endif;
				daysDifference := daysDifference - 1;
			endwhile;
		endif;
		
		// Check last day for holiday.
		if toDayCalendar &lt;&gt; null then
			minTime := toDayCalendar.startTime;
			if minTime = null then
				minTime := MINTIME.Time;
			endif;
			maxTime := toDayCalendar.endTime;
			if maxTime = null then
				maxTime := MAXTIME.Time;
			endif;
			
			if toTime &lt; maxTime then
				maxTime := toTime;
			else 
				minsDifference := minsDifference + EXTRA_MINS;
			endif;
			minsDifference := minsDifference + minTime.cnMinutesDifference(maxTime);
		endif;
	endif;
	
	// Calculate the total hours worked.
	totalHours := minsDifference / 60;
	if totalHours mod 1 &gt; 0 then
		totalHours := totalHours.Integer + 1;
	endif;
	
	// Return the total number of hours for the for all resources used.
	return _cmif.origQty * totalHours;
end;</source>
