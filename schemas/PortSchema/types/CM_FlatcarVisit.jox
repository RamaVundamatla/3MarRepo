    <JadeMethod name="getLengthInUnitsForWagon" id="fa550da9-cc01-454d-9191-9308a0527ee9">
        <source>getLengthInUnitsForWagon(_obj: CM_Object): Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

begin
	
	if _obj.isKindOf(CM_TrackedItem) then
		return _obj.CM_TrackedItem.getLengthInUnitsForWagon();
	elseif _obj.isKindOf(CM_ISOType) then
		return _obj.CM_ISOType.getLengthInUnitsForWagon();
	elseif _obj.isKindOf(CM_ISOTypeGroup) then
		return _obj.CM_ISOTypeGroup.getLengthInUnitsForWagon();
	else
		return 0;
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Real"/>
    </JadeMethod>
