        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblGridAreaInfo_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;
	table.dragMode := DragMode_None;
	self.frmInfoDrag.visible := false;
end;</source>
