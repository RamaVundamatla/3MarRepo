    <JadeMethod name="myHSCode" id="35b04e10-f33b-4ea4-a7bb-054e29c3d10a">
        <methodInvocation>mapping</methodInvocation>
        <source>myHSCode(set: Boolean; _value: CM_HarmonizedSystem io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
25 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	
	code : CM_HarmonizedSystem;
	
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.hsCode = null then
		return;
	endif;
		
	code := app.myRoot.allHSCodesActive[self.hsCode];
		
	if code = null then
		return;
	endif;
		
	_value := code;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_HarmonizedSystem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="populatePxyFromTi" id="cc0a040a-4b35-4310-b5a0-40ece534cddb">
        <updating/>
        <source>populatePxyFromTi(_ti	: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
10 November 2022	navgm20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements
02 February 2023    navdp20 ChangeRequest 56969:[56288] EUP - [Framework] Constructing methods to populate booking, bill of lading, and release request conversion
*/

vars

begin
	self.cargoType		:=	_ti.cargoType;
	self.commodity		:=	_ti.commodity;
	self.consignorCode	:=	_ti.consignor;
	self.description	:=	_ti.description;
	self.height			:=	_ti.height;
	self.length			:=	_ti.length;
	self.markNumber		:=	_ti.markNumber;
	self.quantity		:=	_ti.totalQuantity;
	self.remarks		:=	_ti.remarks;
	self.volume			:=	_ti.totalVolume;
	self.weight			:=	_ti.totalWeight;
	self.allTrackedItems.add(_ti); 				//02.02.2023 navdp20 TFS #56969[56288]
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
