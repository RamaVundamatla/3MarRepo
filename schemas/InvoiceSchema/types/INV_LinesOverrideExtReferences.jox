    <JadeMethod name="doPopulateSummaryDetails" id="28eec77f-55e5-463a-9fc2-20d5bc07a269">
        <source>doPopulateSummaryDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	cmif		: CMIF_InvoiceExternalRefSummary;
	header : CMIF_InvoiceExternalRefHeader;
	extRef1,
	extRef2, 
	extRef3,
	extRef4		: String;
	numLines : Integer;
	totAmount : Decimal[23,2];
begin
	header := self.myCMIFHeader;
	
	
	if header &lt;&gt; null then
		self.lblInvoiceIDData.caption 		:= header.invoiceID;
	else
		self.lblInvoiceIDData.visible := false;
	endif;
	foreach cmif in self.allCMIFSummaries do
		extRef1.addStringToList(cmif.externalRef1, ",");
		extRef2.addStringToList(cmif.externalRef2, ",");
		extRef3.addStringToList(cmif.externalRef3, ",");
		extRef4.addStringToList(cmif.externalRef4, ",");
		
		numLines += cmif.numberOfLines;
		totAmount += cmif.total;
	endforeach;

	self.lblInvoiceLinesData.caption 	:= numLines.String;
	self.lblTotalData.caption			:= totAmount.asStringJMTWithPrecision(2, true);
	
	self.txtExtRef1.text &amp;= extRef1;
	self.txtExtRef2.text &amp;= extRef2;
	self.txtExtRef3.text &amp;= extRef3;
	self.txtExtRef4.text &amp;= extRef4;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="ecc44c65-4fa7-4009-949b-0a0992c9f220">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	response,
	theReturn 		: Integer;
begin
	
	//23/01/2026	navkc1 JIRA MTN 37053
	if self.fieldHasChanged then
		response := app.msgBox(app.getErrorString(ExtFieldChangedContinue), app.getErrorString(Warning), MsgBox_Information_Icon + MsgBox_Yes_No);
		
		if response = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	self.setAgent();
	
	while true do
		app.myTrxUA.trxUpdateInvLinesExtReferences(self.allCMIFSummaries, app.myPassport);
			
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.beep();
			self.modalResult := self.SaveOK;
			self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog("Update Invoice Line", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			return;
		endif;
		break;
	endwhile;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setAgent" id="92cea330-ca39-48a8-853d-df7520865f50">
        <source>setAgent();
/*
Purpose:	

Date		Who		Reason
09 January 2026	navab1	JIRA 36262
*/


vars
	cmif		: CMIF_InvoiceExternalRefSummary;
	newExtRef	: String;
begin
	
	newExtRef := self.txtExtRef1.text;
	
	foreach cmif in self.allCMIFSummaries do
		if newExtRef &lt;&gt; cmif.externalRef1 then
			cmif.externalRef1Update := true;
			cmif.externalRef1 := newExtRef;
		endif;
	endforeach;
	
	newExtRef := self.txtExtRef2.text;
	
	foreach cmif in self.allCMIFSummaries do
		if newExtRef &lt;&gt; cmif.externalRef2 then
			cmif.externalRef2Update := true;
			cmif.externalRef2 := newExtRef;
		endif;
	endforeach;
	newExtRef := self.txtExtRef3.text;
	
	foreach cmif in self.allCMIFSummaries do
		if newExtRef &lt;&gt; cmif.externalRef3 then
			cmif.externalRef3Update := true;
			cmif.externalRef3 := newExtRef;
		endif;
	endforeach;
	newExtRef := self.txtExtRef4.text;
	
	foreach cmif in self.allCMIFSummaries do
		if newExtRef &lt;&gt; cmif.externalRef4 then
			cmif.externalRef4Update := true;
			cmif.externalRef4 := newExtRef;
		endif;
	endforeach;
		

end;
</source>
    </JadeMethod>
    <JadeMethod name="setMyCMIFSummary" id="fe566844-07d9-4d59-8c47-483662b82f04">
        <updating/>
        <source>setMyCMIFSummary(_cmifSummaries : CMIF_InvoiceExtRefSummaries) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars

begin
