    <JadeMethod name="setTransactionDate" id="a03bbf87-e8a1-4419-afad-c55858cb865f">
        <updating/>
        <source>setTransactionDate(realTI : CM_TrackedItem input; baseDate : Date) updating;

vars
	difference	: Integer;
	tranDate,
	now	: Date;
	tran : CM_TITransaction;
	startTran,
	startStartTran	: CM_TITransaction;
	tranTS : TimeStamp;
begin

	// set transaction date to base date, if not already done
	// handle free storage days CM_Storage - do a pre-pass to get the free days storage date difference from the receive transaction
	foreach tran in realTI.allTransactions do
		if tran.isKindOf(CM_Storage) then
			startTran := tran.CM_Storage.startTransaction;
			if startTran &lt;&gt; null and
			   startTran.isKindOf(CM_Storage) and
			   startTran.noCharge = true then
				startStartTran := startTran.CM_Storage.startTransaction;
				if startStartTran &lt;&gt; null then
					difference := startTran.dateTime.date - startStartTran.dateTime.date;
					break;
				endif;
			endif;
		endif;
	endforeach;
	
	foreach tran in realTI.allTransactions do
		if tran.dateTime.date = now then
			tranTS.setDate(baseDate);
			tranTS.setTime(tran.dateTime.time);
			beginTransaction;
			tran.setPropertyValue("dateTime", tranTS);
			commitTransaction;
			if tran.isKindOf(CM_ReceiveShip) and
			   self.loadStart = null then
				self.loadStart := tran.dateTime;
			endif;
			if tran.isKindOf(CM_ReleaseShip) then
				self.unloadEnd := tran.dateTime;
			endif;
		// handle free storage days CM_Storage - apply the difference found above
			if tran.isKindOf(CM_Storage) then
				startTran := tran.CM_Storage.startTransaction;
				if startTran &lt;&gt; null and
				   startTran.isKindOf(CM_Storage) and
				   startTran.noCharge = true and
				   difference &gt; 0 then
					startStartTran := startTran.CM_Storage.startTransaction;
					if startStartTran &lt;&gt; null then
						tranTS.setDate(startStartTran.dateTime.date + difference);
						tranTS.setTime(startTran.dateTime.time);
						beginTransaction;
						startTran.setPropertyValue("dateTime", tranTS);
						commitTransaction;
					endif;
				endif;
			endif;
		endif;
	endforeach;

end;</source>
        <Parameter name="realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="baseDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setTransactionDate2" id="19430023-3b6c-4fb0-aaca-5ee3b85b4616">
        <updating/>
        <source>setTransactionDate2(realTI : CM_TrackedItem input; baseDate : Date) updating;

vars
	now	: Date;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
begin

	// set transaction date to base date, if not already done
	foreach tran in realTI.allTransactions do
		tranTS.setDate(baseDate);
		tranTS.setTime(tran.dateTime.time);
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;

end;</source>
        <Parameter name="realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="baseDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setUpCargoGroup" id="5308b45a-9c6c-493b-b6ce-0486ad6a3d64">
        <source>setUpCargoGroup(id: String; operator : CM_Operator; tiSet : CM_TISet);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2023 navmv20 TFS 56995 Task 57223: Jade - Invoice Debtor Separation Unit Tests

*/

vars
	now : TimeStamp;
	cgId1 : String;
	cg1 : CM_CargoGroup;
begin
	now := app.actualTimeServer;
	cgId1 := "UTCG" &amp; now.Date.format("yyMMdd") &amp; id; //todays date.
	self.deleteCargoGroup(cgId1);	// to allow for re-running, otherwise leave it there so the archive test has somethng to do in a couple of days.
	self.opts.addAssoc("Operator",operator);
	cg1 := self.addCargoGroup( cgId1, tiSet );
	self.assertTrueMsg(cg1 &lt;&gt; null, cgId1 &amp; " Cargo Group not created " &amp; app.myPassport.getErrorsAndWarningsAsString );
epilog

end;</source>
        <Parameter name="id" type="String"/>
        <Parameter name="operator" type="CM_Operator"/>
        <Parameter name="tiSet" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="setUpTrackedItem" id="54b6c79a-5e26-470c-bda1-2a5efd9ca2ff">
        <source>setUpTrackedItem(tiId,tiName : String;
				imexStatus : Integer;
				voyage : CM_Voyage;
				operator : CM_Operator;
				cargoType: CM_CargoType;
				theSlot : CM_LocationsController;
				aPort : CM_Port) : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2023 navmv20 TFS 56995 Task 57223: Jade - Invoice Debtor Separation Unit Tests

*/
constants
	UT_IsoType	: String = "2200";
	UT_CargoCommodity			: String = "FCL";
	NullMSG						: String = " Expected: 'not null' | Actual: 'null'";
vars
	ti : CM_TrackedItem;
begin
	ti := self.addContainerAtLocnDisch(tiId, UT_IsoType, UT_CargoCommodity, imexStatus, theSlot, aPort, voyage);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(ti &lt;&gt; null, tiName &amp; NullMSG);
	self.assertTrueMsg(ti.cargoType = cargoType.id, tiName &amp; " cargo type Expected: '" &amp; cargoType.id.asStringJMT() &amp; "' | Actual: '" &amp; ti.cargoType.asStringJMT() &amp; "'");
	self.assertTrueMsg(ti.commodity = UT_CargoCommodity,tiName &amp; " commodity Expected: '" &amp; UT_CargoCommodity &amp; "' | Actual: '" &amp; ti.commodity &amp; "'");
	self.assertTrueMsg(ti.getImExStatus() = imexStatus, tiName &amp; " imex status Expected: '" &amp; imexStatus.asStringJMT() &amp; "' | Actual: '" &amp; ti.getImExStatus().asStringJMT() &amp; "'");
	
	beginTransaction;
	ti.setMyOperator(operator);
	commitTransaction;
	return ti;
epilog

end;</source>
        <Parameter name="tiId" type="String"/>
        <Parameter name="tiName" type="String"/>
        <Parameter name="imexStatus" type="Integer"/>
        <Parameter name="voyage" type="CM_Voyage"/>
        <Parameter name="operator" type="CM_Operator"/>
        <Parameter name="cargoType" type="CM_CargoType"/>
        <Parameter name="theSlot" type="CM_LocationsController"/>
        <Parameter name="aPort" type="CM_Port"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setupCalendar2" id="8aa56091-e4df-4d63-b224-0e2b18491159">
        <source>setupCalendar2() : CM_Calendar protected;
// cnwjre1 CCMS 1295 free storage days
//  setup a storage calendar with known weekends only, this year and next
vars
	calendar		: CM_Calendar;
	startDate		: Date;

begin
	self.deleteCalendar("UTS2", "UTDAY2");
	
	// set up the storage calendar for all of 2012 and 2013 with weekends (Saturday and Sunday)
	//  ** extend this in the future **
	calendar := self.createCalendar("UTS2", "Unit test storage calendar", false, false, "UTDAY2");
	startDate := "31/12/2011".Date;	// first Saturday
	self.addBulkCalendarDates(calendar, startDate, 52, "Saturday");
	startDate := "01/01/2012".Date;	// first Sunday
	self.addBulkCalendarDates(calendar, startDate, 52, "Sunday");

	startDate := "5/01/2013".Date;	// first Saturday
	self.addBulkCalendarDates(calendar, startDate, 51, "Saturday");
	startDate := "06/01/2013".Date;	// first Sunday
	self.addBulkCalendarDates(calendar, startDate, 51, "Sunday");

	return calendar;
epilog

end;
</source>
        <access>protected</access>
        <ReturnType type="CM_Calendar"/>
    </JadeMethod>
    <JadeMethod name="setupProductGroup" id="65c5a424-61cd-4c18-bc15-78245959fe88">
        <source>setupProductGroup(_cargoType : CM_CargoType; _pgCount : Integer; _pgId : String; _prodCount : Integer; _prodId : String) protected;
//	cnwjre1	CCMS 1297 testing
vars
	productGroup	: CM_ProductGroup;
	product			: CM_Product;
	operator	: CM_Operator;
	
	id	: String;
	found	: Boolean;
	count1,
	count2	: Integer;
begin
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	

	while count1 &lt; _pgCount do 
		count1 := count1 + 1;
		id := _pgId &amp; count1.String;
		productGroup := _cargoType.allProductGroups[id];
		if productGroup = null then
			productGroup := self.addProductGroup(id, id &amp; " for unit testing", _cargoType);
		endif;
		count2 := 0;
		while count2 &lt; _prodCount do
			count2 := count2 + 1;
			id := _pgId &amp; count1.String &amp; _prodId &amp; count2.String;
			found := false;
			foreach product in productGroup.allProducts do
				if product.code = id then
					found := true;
					break;
				endif;
			endforeach;
			if not found then
				self.opts.purge();
				self.opts.addAssociation("Description", id &amp; " for unit testing");
				self.opts.addAssociation("ProductGroup", productGroup);
				product := self.addProduct(id, operator, _cargoType);
			endif;
		endwhile;
	endwhile;
end;
</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_pgCount" type="Integer"/>
        <Parameter name="_pgId" type="String"/>
        <Parameter name="_prodCount" type="Integer"/>
        <Parameter name="_prodId" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupStorageConfig2" id="a6b6fab6-2d98-48ae-8922-6671a69888b4">
        <source>setupStorageConfig2(_calendar : CM_Calendar; _includeFirstDay : Boolean; _includeLastDay : Boolean; _shipReceivalType : Integer; _shipReleaseType : Integer; _chargedDaysWorking : Boolean;
					_freeDaysWorking : Boolean; _deriveDebtorFrom : CM_DebtorType; _triggers : CM_StorageTriggerByType; _createDetails : Boolean; _importDays : Integer; _exportDays : Integer;
					_stopCompletionFreeDays : Integer) : CM_StorageConfig protected;
// cnwjre1 CCMS 1295 free storage days
//  storage configuration with entered options, hard-coded calendar and criteria (cargo type and imex), entered import and export days free storage
vars
	storageConfig	: CM_StorageConfig;
	storageDetail	: CM_StorageDetail;
	criteriaTypes : CM_YACriteriaTypeArray;
	firstDayTimeCutoff	: Time;
	lastDayTimeCutoff	: Time;
	nullTime		: Time;
	criteria	: IntegerArray;
	values		: ObjectArray;

begin
	self.deleteStorageConfig( false );
	
	// set up the storage config
	nullTime := "00:00".Time;
	firstDayTimeCutoff := nullTime;
	lastDayTimeCutoff := nullTime;
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus]);

	storageConfig := self.createStorageConfig(criteriaTypes, _triggers, _deriveDebtorFrom, firstDayTimeCutoff, _includeFirstDay, _includeLastDay,
											  lastDayTimeCutoff, _shipReceivalType, _shipReleaseType, _calendar, null,null, -1, -1, -1);

	if not _createDetails then
		return storageConfig;
	endif;

	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	criteria.add(YACriteriaType_ImexStatus);
	create values transient;
	values.add(self.getCargoType("CONT"));
	values.add(app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT]);

	storageDetail := self.addStorageDetail(storageConfig, "CONT Import", criteria, values, _importDays, 0, _chargedDaysWorking, _freeDaysWorking, _stopCompletionFreeDays,0,false,null);		// TFS 2570 //21.07.2017 cnwma1 TFS #5409
	values.clear();
	values.add(self.getCargoType("CONT"));
	values.add(app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT]);

	storageDetail := self.addStorageDetail(storageConfig, "CONT Export", criteria, values, _exportDays, 0, _chargedDaysWorking, _freeDaysWorking, _stopCompletionFreeDays,0,false,null);		// TFS 2570 //21.07.2017 cnwma1 TFS #5409

	return storageConfig;
epilog
	delete criteriaTypes;
	delete criteria;
	delete values;

end;
</source>
        <access>protected</access>
        <Parameter name="_calendar" type="CM_Calendar"/>
        <Parameter name="_includeFirstDay" type="Boolean"/>
        <Parameter name="_includeLastDay" type="Boolean"/>
        <Parameter name="_shipReceivalType" type="Integer"/>
        <Parameter name="_shipReleaseType" type="Integer"/>
        <Parameter name="_chargedDaysWorking" type="Boolean"/>
        <Parameter name="_freeDaysWorking" type="Boolean"/>
        <Parameter name="_deriveDebtorFrom" type="CM_DebtorType"/>
        <Parameter name="_triggers" type="CM_StorageTriggerByType"/>
        <Parameter name="_createDetails" type="Boolean"/>
        <Parameter name="_importDays" type="Integer"/>
        <Parameter name="_exportDays" type="Integer"/>
        <Parameter name="_stopCompletionFreeDays" type="Integer"/>
        <ReturnType type="CM_StorageConfig"/>
    </JadeMethod>
    <JadeMethod name="storageDaysCalculation" id="6bd1f60e-901b-4b52-bed3-a3077ba74d7b">
        <updating/>
        <source>storageDaysCalculation(_includeFirstDay, _includeLastDay, _useConfig : Boolean; _numDaysRecAgo, _numEOPStorage, _eopStorageDays1, _eopStorageDays2, _eopStorageDays3, _eopStorageDays4 : Integer; _useInvLine : Boolean) : CM_TrackedItem updating;
//
//08 Mar 2016	cnwrs1	TFS 1479 create storage for inclusive dates over EOP
//
constants
	CARGOID = "UTMTSTORE01";
	TRUCK = "UTTRUCK01";
	TERMINALAREA = "UTSTORE3";
	VOYCODE = "UTSTOR1";
	DRIVER = "UTDRIVER1";
	DEBTORTYPE = "SDT1";
	INVOICETYPE = "UT_InvTypeStore3";
	INVOICESERVICE = "UT_ServiceStore13";
	INVOICELINETYPE1 = "UT_LineTypeStore1";
	INVOICELINETYPE2 = "UT_LineTypeStore2";
	INVOICELINETYPE3 = "UT_LineTypeStore3";
	INVOICELINETYPE4 = "UT_LineTypeStore4";
	CALC_TYPE = "CCT06";
vars
	bs : CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	dateTime : TimeStamp;
	now : TimeStamp;
	operator : CM_Operator;
	releaseRequest : CM_BulkRelease;
	vvr	: CM_VehicleVisitRecord;
	wle	: CM_WorkListEntry;
	cargoMap : CM_TranMap;
	services : CM_ServiceByNameDict;
	invType	: CM_InvoiceDesc;
	theService : CM_Service;
	calType1 : CM_CalculationType;
	invLineType1 : CM_InvoiceLineDesc;
	invLineType2 : CM_InvoiceLineDesc;
	invLineType3 : CM_InvoiceLineDesc;
	invLineType4 : CM_InvoiceLineDesc;
	triggers : CM_StorageTriggerByType;
	storageConfig : CM_StorageConfig;
	calendar : CM_Calendar;
	shipReceivalType : Integer;
	shipReleaseType	: Integer;
	chargedDaysWorking : Boolean;
	freeDaysWorking	: Boolean;
	deriveDebtorFrom : CM_DebtorType;
	eop : TimeStamp;

begin
	if _numEOPStorage &gt; 4 then
		self.assertEqualMsg(true, false, "Number of storage transactions must be less than 4");
	endif;
	if _numEOPStorage &gt; 0 then
		if _numDaysRecAgo &gt; _eopStorageDays1 then
			self.assertEqualMsg(true, false, "_eopStorageDays1 Can't have storage transaction before recival");
		endif;
		if _numEOPStorage &gt; 1 then
			if _numDaysRecAgo &gt; _eopStorageDays2 then
				self.assertEqualMsg(true, false, "_eopStorageDays2 Can't have storage transaction before recival");
			endif;
			if _numEOPStorage &gt; 0 then
				if _numDaysRecAgo &gt; _eopStorageDays3 then
					self.assertEqualMsg(true, false, "_eopStorageDays3 Can't have storage transaction before recival");
				endif;
				if _numEOPStorage &gt; 0 then
					if _numDaysRecAgo &gt; _eopStorageDays4 then
						self.assertEqualMsg(true, false, "_eopStorageDays4 Can't have storage transaction before recival");
					endif;
				endif;
			endif;
		endif;
	endif;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	self.assertNotNull(operator);
	self.deleteVehicle(TRUCK);
	self.deleteStorageConfig( false );
	deriveDebtorFrom := app.myRoot.allDebtorTypes[DEBTORTYPE];		// cargo operator
	calendar := self.setupCalendar2();
	create triggers transient;
	// set the options
	if _useConfig then
		storageConfig := self.setupStorageConfig2(calendar, _includeFirstDay, _includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking, deriveDebtorFrom, triggers, true, 0, 0, 0);	// TFS 2570
	endif;
	
	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);

	bs := self.getTerminalArea(TERMINALAREA).CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea(TERMINALAREA);
	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.deleteInvoiceType(INVOICETYPE);
	self.deleteInvoiceService(INVOICESERVICE, FORCED_ERASE);
	self.deleteInvoiceLineType(INVOICELINETYPE1, FORCED_ERASE);
	self.deleteInvoiceLineType(INVOICELINETYPE2, FORCED_ERASE);
	self.deleteInvoiceLineType(INVOICELINETYPE3, FORCED_ERASE);
	self.deleteInvoiceLineType(INVOICELINETYPE4, FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType(INVOICETYPE, InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");

	calType1 := app.myRoot.allCalculationTypesByCode[CALC_TYPE];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	theService := self.createInvoiceService(INVOICESERVICE, "UT Store1", calType1, null);
	self.assertNotNullMsg(theService, INVOICESERVICE&amp;" not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType(INVOICELINETYPE1, calType1, invType, services, DEBTORTYPE);
	invLineType2 := self.createInvoiceLineType(INVOICELINETYPE2, calType1, invType, services, DEBTORTYPE);
	invLineType3 := self.createInvoiceLineType(INVOICELINETYPE3, calType1, invType, services, DEBTORTYPE);
	invLineType4 := self.createInvoiceLineType(INVOICELINETYPE4, calType1, invType, services, DEBTORTYPE);
	
	self.assertNotNullMsg(invLineType1, INVOICELINETYPE1&amp;" not created");
	self.assertNotNullMsg(invLineType2, INVOICELINETYPE2&amp;" not created");
	self.assertNotNullMsg(invLineType3, INVOICELINETYPE3&amp;" not created");
	self.assertNotNullMsg(invLineType4, INVOICELINETYPE4&amp;" not created");
	if invLineType1 &lt;&gt; null then
		self.assertNotNullMsg(invLineType1.invoiceType, INVOICELINETYPE1&amp;" has null INV TYPE");
	endif;
	if invLineType2 &lt;&gt; null then
		self.assertNotNullMsg(invLineType2.invoiceType, INVOICELINETYPE2&amp;" has null INV TYPE");
	endif;
	if invLineType3 &lt;&gt; null then
		self.assertNotNullMsg(invLineType3.invoiceType, INVOICELINETYPE3&amp;" has null INV TYPE");
	endif;
	if invLineType4 &lt;&gt; null then
		self.assertNotNullMsg(invLineType4.invoiceType, INVOICELINETYPE4&amp;" has null INV TYPE");
	endif;

	if _useInvLine then
	// Need to map to above invoice line types, using quantity ranges
		self.tranMapLoadStorageStorage();
	endif;

	// create a container with retrospective transactions
	voy := self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs := addBlockStack(TERMINALAREA, 100, null);

	// test container
	self.deleteContainer(CARGOID);
	cargo := self.getTrackedItem(CARGOID);
	self.assertNullMsg(cargo, "Container not deleted");
	cargo := self.addContainerAtLocnDisch(CARGOID, "22G1", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController, aPort, voy);
	dateTime.setDate(now.date.addDays(_numDaysRecAgo));
	self.resetTransactionDate(cargo, dateTime);
	
	// create storage transaction
	if _numEOPStorage &gt; 0 then
		eop.setDate(now.date.addDays(_eopStorageDays1));
		eop.setTime("23:59:59:".Time);
		self.createStorageTransactions16(cargo, eop);
		if _numEOPStorage &gt; 1 then
			eop.setDate(now.date.addDays(_eopStorageDays2));
			self.createStorageTransactions16(cargo, eop);
			if _numEOPStorage &gt; 2 then
				eop.setDate(now.date.addDays(_eopStorageDays3));
				self.createStorageTransactions16(cargo, eop);
				if _numEOPStorage &gt; 3 then
					eop.setDate(now.date.addDays(_eopStorageDays4));
					self.createStorageTransactions16(cargo, eop);
				endif;
			endif;
		endif;
	endif;	
		
	// gate out the continer
	self.opts.purge();
	self.opts.addAssoc("ISOType", "22G1");
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc("Commodity", "MT");
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	self.opts.purge();
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer(TRUCK, "", DRIVER, cargo.CM_Container, true, self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()), null);
	self.assertNotNull(vvr);
	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, cargo);
	self.assertEqualMsg(releaseRequest.allRequestsBeingActioned.size, 1, 'Expecting 1 request being actioned');
	wle := vvr.myRoadJob.workListEntries.first;
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1); 
	self.assertEqual(wle.myTrackedItem, cargo);

	self.moveQueuedCargo(wle);
	self.roadExit(vvr);
	self.assertNullMsg(vvr.vehicle.myPrimaryActualLocation, 'Vehicle is still on site');
	self.assertTrueMsg(releaseRequest.status = BR_COMPLETE, 'Release Should be completed'); 
	self.assertTrueMsg(releaseRequest.getTotalReleased = 1, 'Release should have 1 item released'); 
	

	return cargo;
epilog
	//self.deleteStorageConfig( true );
	self.resetDefaultTranMap();								// See Michael before removing
	delete triggers;
	delete services;
end;
</source>
        <Parameter name="_includeFirstDay" type="Boolean"/>
        <Parameter name="_includeLastDay" type="Boolean"/>
        <Parameter name="_useConfig" type="Boolean"/>
        <Parameter name="_numDaysRecAgo" type="Integer"/>
        <Parameter name="_numEOPStorage" type="Integer"/>
        <Parameter name="_eopStorageDays1" type="Integer"/>
        <Parameter name="_eopStorageDays2" type="Integer"/>
        <Parameter name="_eopStorageDays3" type="Integer"/>
        <Parameter name="_eopStorageDays4" type="Integer"/>
        <Parameter name="_useInvLine" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="tAATStorage" id="0c68b4cd-e863-4712-93e8-cdda509de36d">
        <source>tAATStorage();
// cnwma1	test TFS 3588 AAT storage with storage config and escalating storage
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
vars
	triggers : CM_StorageTriggerByType;
	includeFirstDay : Boolean;
	includeLastDay : Boolean;
	storageConfig : CM_StorageConfig;
	calendar : CM_Calendar;
	shipReceivalType : Integer;
	shipReleaseType	: Integer;
	chargedDaysWorking : Boolean;
	freeDaysWorking	: Boolean;

	qtySource,
	rateSource,
	remarksSource: String;
	count		: Integer;
	tiId		: String;
	dateTime	: TimeStamp;
	now			: Date;
	backDate	: Date;
	calcType1,
	calcType2	: CM_CalculationType;
	bs			: CM_BlockStack;
	service		: CM_Service;
	ild			: CM_InvoiceLineDesc;
	invType		: CM_InvoiceDesc;
	services	: CM_ServiceByNameDict;
	allServices	: CM_ServiceByNameDict;
	operator	: CM_Operator;
	cargoType	: CM_CargoType;
	ti			: CM_TrackedItem;
	tran		: CM_TITransaction;
	invLine		: CM_InvoiceLine;
	
begin

	tiId := "AATGC01";
	// delete any old objects
	self.deleteContainer(tiId);

	self.deleteInvoiceService("UT_AATStorage1", FORCED_ERASE);
	self.deleteInvoiceService("UT_AATStorage2", FORCED_ERASE);
	self.deleteInvoiceService("UT_AATStorage3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_AATStorage1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_AATStorage2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_AATStorage3", FORCED_ERASE);
	self.deleteInvoiceType("UT_AATStorage");
	
	self.setTerminalConfig(DeferredCharging, false); // ### TFS CR 58263 TASK 58264 18JAN2024 NAVAB1
	
	// set up storage configuration
	includeFirstDay := true;
	includeLastDay := true;
	freeDaysWorking := true;
	shipReceivalType := CM_StorageConfig.ShipReceivalActualDischarge;
	shipReleaseType := CM_StorageConfig.ShipReleaseActualLoad;
	create triggers transient;
	// 3 free days for Exports and Imports
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking, null, triggers, true, 3, 3, 2);
	
	// days since receival for the services
	calcType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calcType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");

	// calculation type with quantity hook code for freight tonnes, for the invoice line types
	self.deleteCalculationType("UTAATHOOK",NORMAL_ERASE);

	qtySource := 'amendQuantity(_cmif : CMIF_CalcTypeQuantityHook) : Real;
vars
        newQty : Real;
        cargo  : CM_TrackedItem;
        transaction : CM_Transaction;
begin
        newQty := _cmif.origQty;
              
        transaction := _cmif.myTransaction;
        if transaction = null then
            return _cmif.origQty;
        endif;
                
        cargo := transaction.CM_TITransaction.myTrackedItem;
        if cargo = null then
            return _cmif.origQty;
        endif;
                
        if cargo.freightTons &gt; 0 then
            newQty := _cmif.origQty * cargo.freightTons;
        endif;
                
        return newQty;
end;';
	rateSource := 'amendRate(_cmif : CMIF_CalcTypeRateHook) : Real;
vars
	newRate : Real;
begin
	newRate := _cmif.origRate;
	return newRate;
end;';
	calcType2 := self.addCalculationType(INV_CALC_TYPE_DAYS_SINCE_RECVL, "UTAATHOOK", "Has qty rate hook code", qtySource, rateSource, remarksSource, 0, 0, 0, 0, true, false, false, false,0, null, null);
	self.assertNoTrxErrorsOrWarnings();

	// invoice type
	invType := self.getInvoiceType("UT_InvType");
	self.assertNotNullMsg(invType, "Invoice type UT_InvType not created");

	// create new instances
	create services transient;
	create allServices transient;
	invType := self.createInvoiceType("UT_AATStorage", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_AATStorage not created");

	service := self.createInvoiceService("UT_AATStorage1", "UT AAT Storage 1-3", calcType1, null);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.add(service);
	ild := self.createInvoiceLineType("UT_AATStorage1", calcType2, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	service := self.createInvoiceService("UT_AATStorage2", "UT AAT Storage 4-6", calcType1, null);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.clear();
	services.add(service);
	ild := self.createInvoiceLineType("UT_AATStorage2", calcType2, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	service := self.createInvoiceService("UT_AATStorage3", "UT AAT Storage 7+", calcType1, null);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.clear();
	services.add(service);
	ild := self.createInvoiceLineType("UT_AATStorage3", calcType2, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	self.tranMapLoadAATStorage2();

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	

	// no rates are set, the tests are of invoice line quantities only
	
	self.opts.purge();
	bs := self.addBlockStack("UTAATBS1", 999, null);
	self.assertNotNullMsg(bs, "Block stack is null");

	cargoType := self.getCargoType("UT_BB_GC");
	self.assertNotNullMsg(cargoType, "Cargo type is null");
	ti := self.addCargoAtLocation(tiId, cargoType, operator, bs.allLocationsControllers.first);
	self.assertNotNullMsg(ti, "Cargo is null");
	beginTransaction;
		ti.setTotalQuantity(1);
		ti.setTotalWeightWithoutTrans(1000);
		ti.setPropertyValue("totalVolume", 2.Decimal);
		ti.setImExStatus(TI_IMEX_STATUS_IMPORT);
	commitTransaction;
	self.assertEqualMsg(ti.totalQuantity.Integer, 1, "Cargo quantity should be 1");
	self.assertEqualMsg(ti.totalWeight.Integer, 1000, "Cargo weight should be 1000");
	self.assertEqualMsg(ti.freightTons.Integer, 2, "Cargo freight tons should be 2");
	self.assertEqualMsg(ti.getImExStatus(), TI_IMEX_STATUS_IMPORT, "Cargo IMEX status should be import");

	backDate := "14/02/2017".Date;
	dateTime.setDate(backDate);
	self.resetTransactionDate(ti, dateTime);
	self.createDatedTransaction(ti, dateTime, TRANS_TYPE_REC_SHIP);

	// create storage from receive (3 days free in the example) as no-charge
	// this is done automatically from the release road in the real case
	now := "16/02/2017".Date;
	dateTime.setDate(now);
	tran := self.createDatedChargedTransaction(ti, dateTime, TRANS_TYPE_STORAGE, false);

	// create storage from release
	now := "25/02/2017".Date;
	dateTime.setDate(now);
	tran := self.createDatedTransaction(ti, dateTime, TRANS_TYPE_STORAGE);
	
	// 3 lines one for each ILD with quantity 12, 12 and zero with a container
	// with the general cargo, is qty of 6 6 and 0 (using 
	// which MATCHES the test case in DMAST
	// WITH the code fix and the revised transaction map get 3 lines one for each ILD with quantity of 6, 6 and 6 which is the CORRECT result
	
	foreach invLine in tran.allInvoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(invLine.quantity, 6.Real, "First Storage transaction invoice quantity");
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_AATStorage1", "First Storage transaction invoice line type");
		elseif count = 2 then
			self.assertEqualMsg(invLine.quantity, 6.Real, "Second Storage transaction invoice quantity");
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_AATStorage2", "Second Storage transaction invoice line type");
		elseif count = 3 then
			self.assertEqualMsg(invLine.quantity, 6.Real, "Third Storage transaction invoice quantity");
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_AATStorage3", "Third Storage transaction invoice line type");
		endif;
	endforeach;
	self.assertEqualMsg(count, 3, "Storage transaction invoice lines");
	
epilog
	self.resetDefaultTranMap();
	// delete this tran map so following tests can delete the invoice line descs etc
	self.deleteInvoiceTransactionMap(1, 'UT_AATS');
	
	delete services;
	delete allServices;
	delete triggers;
end;</source>
    </JadeMethod>
    <JadeMethod name="tASPA50925" id="9a0d1327-db12-4b92-89bd-98cf7c4cbee9">
        <source>tASPA50925();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Mar 2021	cnwma1 ChangeRequest 50925: ASPA - New Total Column in Invoice Form
26 Apr 2023 navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
//23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
*/

vars
	calcType1	  : CM_CalculationType;
	service		  : CM_Service;
	ild			  : CM_InvoiceLineDesc;
	invType		  : CM_InvoiceDesc;
	services	  : CM_ServiceByNameDict;
	operator	  : CM_Operator;
	bu			  : CM_Bank;
	pxyInvoice, 
	pxyInvoice2,
	realInvoice,
	realInvoice2  : CM_Invoice;
	roundDecimalOpt : Integer;
	ti              : CM_TrackedItem;
begin
	roundDecimalOpt := self.getTerminalConfig(InvoiceRoundLineTotal).Integer;
	self.setTerminalConfig(InvoiceRoundLineTotal,roundDecimalOpt);
	
	self.deleteInvoiceService("UT_ASPA50925" , FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ASPA50925", FORCED_ERASE);
	self.deleteInvoiceType("UT_ASPA50925");
	self.deleteContainer("UTAS50925111");
	self.assertNoTrxErrorsOrWarnings();
	
	calcType1 := app.myRoot.allCalculationTypesByCode['CCT00'];	// INV_CALC_TYPE_UNITY;
	self.assertNotNullMsg(calcType1, "Calculation type INV_CALC_TYPE_UNITY not found");

	// create new instances
	create services transient;
	invType := self.createInvoiceType("UT_ASPA50925", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvRounding not created");

	service := self.createInvoiceService("UT_ASPA50925", "UT_InvRounding", calcType1, null);
	self.assertNoTrxErrorsOrWarnings();
	
	services.add(service);
	ild := self.createInvoiceLineType("UT_ASPA50925", calcType1, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	

	bu := self.getTerminal().getDefaultCompanyBank();
	self.setTerminalConfig(InvoiceRoundLineTotal,CMIF_ConfigTerminal.InvLineRound_Value_NoRound);
	// ### MANUAL INVOICE
	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(bu,
								operator.debtor, 
								null, 
								null,
								invType,
								//false,	
								CM_Invoice.INVOICE_PENDING, // 26.4.2023 navmk20 TFS 57663
								true,	
								null,
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								0,
								null,  // ### BUG 56925 07MAR2023 NAVAB1
								bu.myInvoiceProcess, // 26.4.2023 navmk20 TFS 57663
								null,	//navtnr20 23-05-2023 BUG 58089
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null //14/08/2023	navkc1	Bug 59803
								);
	app.myTrxCA.trxCreateInvoiceManual(pxyInvoice,realInvoice, app.myPassport);
	
	beginTransaction;
	realInvoice.setPropertyValue("status",0); // OPEN
	commitTransaction;
	
	// ### MANUAL INVOICE LINE3
	
	self.createManualInvoiceLineRate(realInvoice, ild, 19969.000000,null);
	self.createManualInvoiceLineRate(realInvoice, ild, 53204.415000,null);
	self.createManualInvoiceLineRate(realInvoice, ild, 4807.227000,null);
	self.createManualInvoiceLineRate(realInvoice, ild, 6304.762815,null);
	self.assertEqualMsg(realInvoice.getTotalAmount().asStringJMTWithPrecision(2,true), "84,285.40", "Rounding is incorrect - TFS 50925"); //Current Method 
	
	//Changing the config 
	self.setTerminalConfig(InvoiceRoundLineTotal,CMIF_ConfigTerminal.InvLineRound_Value_Two);
	// ### MANUAL INVOICE
	create pxyInvoice2 transient;
	pxyInvoice2.setProxyForCreate(bu,
								operator.debtor, 
								null, 
								null,
								invType,
								//false,	//26.4.2023 navmk20	TFS 57663
								CM_Invoice.INVOICE_PENDING, 	//26.4.2023 navmk20	TFS 57663	
								true,	
								null,
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								0,
								null,  // ### BUG 56925 07MAR2023 NAVAB1
								bu.myInvoiceProcess, //26.4.2023 navmk20	TFS 57663
								null,		//navtnr20 23-05-2023 BUG 58089
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null //14/08/2023	navkc1	Bug 59803
								);
	app.myTrxCA.trxCreateInvoiceManual(pxyInvoice2,realInvoice2, app.myPassport);
	
	beginTransaction;
	realInvoice.setPropertyValue("status",0); // OPEN
	commitTransaction;
	
	// ### MANUAL INVOICE LINE3
	
	self.createManualInvoiceLineRate(realInvoice2, ild, 19969.000000,null);
	self.createManualInvoiceLineRate(realInvoice2, ild, 53204.415000,null);
	self.createManualInvoiceLineRate(realInvoice2, ild, 4807.227000,null);
	self.createManualInvoiceLineRate(realInvoice2, ild, 6304.762815,null);
	self.assertEqualMsg(realInvoice2.getTotalAmount(), "84285.410000".Decimal, "Rounding is incorrect - TFS 50925"); //Current Method 
    
	// Check Cash 
	
epilog
	self.setTerminalConfig(InvoiceRoundLineTotal,roundDecimalOpt);
	write "Code : " &amp; Tab &amp; self.getMyTerminal.code &amp;  Tab &amp;" Current Value  : "  &amp;  self.getTerminalConfig(InvoiceRoundLineTotal).Integer.String;
	self.resetDefaultTranMap();
	delete pxyInvoice;
	delete pxyInvoice2;
	delete services;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAuditDisplay" id="dd7110a7-dd8e-45c0-bbc7-f08037715070">
        <source>tAuditDisplay();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2020	jlgndl1	Initial creation	TFS 48660

*/

vars

	audit : CM_AuditTIEdit;
	iter : Iterator;
	str : String;
	lastDate : Date;
	success : Boolean;

begin

	lastDate := app.actualTimeAppServer.Date - 4;  // so we check all audits for the last 4 days.

	iter := CM_AuditTIEdit.instances.createIterator;
	
	while iter.back( audit ) do
		if audit.createdTime.Date &lt; lastDate then
			break;
		endif;
		str := audit.getDetails(); // Was getting UHE 1300 errors on edit transactions with odd number of changes greater than one, i.e. 3, 5 ,7 etc.
	endwhile;
	
	success := true;

epilog

	delete iter;

	self.assertTrueMsg( success, "Must have crashed before it finished. Item being processed was " &amp; audit.String );
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tAutoIdGeneratorExtCnNum" id="5f27236b-cd74-42aa-a4ab-addd0004885c">
        <source>tAutoIdGeneratorExtCnNum();
/*

Purpose:			
		This UT is created for testing the Auto ID Generator for External Invoice number (CM_AutoCreditExtNumberGen)
		
		**NOTE**
		Just in case someone is performing some testing on the Auto ID, we don't want to mess up their testing.
		Therefore, always store the current sequence number/style/year/ any other values that might get changed during the UT.
		Restore these values at epilog
		
Parameters:			

Return Value:		

Date		Who		Reason
19 December 2022	navkc1	Initial creation navkc1	TFS CR 55300 TASK 55523
// 09/02/2023		navkc1	Bug 56444: Jade - Country in Invoice/Credit note Auto Id
*/
constants
	Country 	= "NZ";
	PrefixType	= "CN";
	
vars

	autoGen		: CM_AutoIdGenerator;
	pxyAutoGen, 
	realAutoGen	: CM_AutoCreditExtNumberGen;
	bank		: CM_Bank;
	terminal	: CM_Terminal;
	oriSeq,
	oriStyle,
	year,
	count,
	length		: Integer;
	now			: Date;
	created		: Boolean;
	expected,
	actual,
	msg,
	resetSeqNum	: String;
	idPrefix	: String;
	oriCountry	: String;	 // 09/02/2023	navkc1	Bug 56444
begin
	
	now 		:= app.actualTimeAppServer().Date;
	year		:= now.format("yy").Integer;
	
	terminal 	:= self.getMyTerminal();
	bank		:= terminal.getDefaultCompanyBank();
	realAutoGen	:= bank.allAutoIdGenerators[CM_AutoIdGenerator.CrdExtNumberType].CM_AutoCreditExtNumberGen;
	autoGen 	:= realAutoGen;
	
	if realAutoGen = null then
		create pxyAutoGen transient;
		pxyAutoGen.setProxy(PrefixType,					// Prefix
							4, 							// Seq length
							AutoIdStyle_CC_B_L_YY_SSS, 	// Style
							null, 						// Terminal
							1, 							// Next seq number
							9999);						// Seq reset number
							
		pxyAutoGen.setProxyOtherAttributes(1, 			// curr seq
										year, 		// curr year
										bank,		// business unit
										Country);	// country 		// 09/02/2023	navkc1	Bug 56444
		
		app.myTrxCA.trxCreateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
		created := true;
		realAutoGen := autoGen.CM_AutoCreditExtNumberGen;
	endif;
	
	//==================================================================
	// Get original sequence and style (reset to original after UT)
	//==================================================================
	oriSeq := realAutoGen.currSeq;
	oriStyle := realAutoGen.idStyle;
	idPrefix := realAutoGen.idPrefix;
	oriCountry := realAutoGen.currCountry; // 09/02/2023	navkc1	Bug 56444
	//==========================================
	// Test style AutoIdStyle_CC_T_P_YY_SSS (10)
	//==========================================
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_CC_T_L_YY_SSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(realAutoGen.currSeq, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country		// 09/02/2023	navkc1	Bug 56444

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoCreditExtNumberGen;
	
	actual := realAutoGen.getNextId(null, terminal.code);
	expected := oriCountry &amp; terminal.code &amp; idPrefix &amp; year.String &amp; (oriSeq).String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for style : " &amp; AutoIdStyle_CC_T_L_YY_SSS.String &amp; ". Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
	//==========================================
	// Test style AutoIdStyle_CC_B_P_YY_SSS (11)
	//==========================================
	
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_CC_B_L_YY_SSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(realAutoGen.currSeq, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country 		// 09/02/2023	navkc1	Bug 56444

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoCreditExtNumberGen;
	
	actual := realAutoGen.getNextId(null, terminal.code);
	expected := oriCountry &amp; bank.code &amp; idPrefix &amp; year.String &amp; (oriSeq + 1).String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for style : " &amp; AutoIdStyle_CC_B_L_YY_SSS.String &amp; ". Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
	//============================================
	// Test style AutoIdStyle_CC_T_B_P_YY_SSS (12)
	//============================================
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_CC_T_B_L_YY_SSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(realAutoGen.currSeq, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country		// 09/02/2023	navkc1	Bug 56444

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoCreditExtNumberGen;

	actual := realAutoGen.getNextId(null, terminal.code);
	expected := oriCountry &amp; terminal.code &amp; bank.code &amp; idPrefix &amp; year.String &amp; (oriSeq + 2).String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for style : " &amp; AutoIdStyle_CC_T_B_L_YY_SSS.String &amp; ". Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
	//============================================
	// Test style AutoIdStyle_B_L_YY_SSS (13) //17/01/2025	navkc1 JIRA Bug MTN-33813
	//============================================
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_B_L_YY_SSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(realAutoGen.currSeq, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country		// 09/02/2023	navkc1	Bug 56444

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoCreditExtNumberGen;

	actual := realAutoGen.getNextId(null, terminal.code);
	expected := bank.code &amp; idPrefix &amp; year.String &amp; (oriSeq + 3).String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for style : " &amp; AutoIdStyle_B_L_YY_SSS.String &amp; ". Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
	//============================================
	// Test style AutoIdStyle_L_YY_SSS (14) //17/01/2025	navkc1 JIRA Bug MTN-33813
	//============================================
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_L_YY_SSSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(realAutoGen.currSeq, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country		// 09/02/2023	navkc1	Bug 56444

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoCreditExtNumberGen;

	actual := realAutoGen.getNextId(null, terminal.code);
	expected := idPrefix &amp; year.String &amp; (oriSeq + 4).String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for style : " &amp; AutoIdStyle_L_YY_SSSS.String &amp; ". Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
	//================
	// Test seq reset
	//================
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	length := realAutoGen.idSeqNumLength;
	
	foreach count in 1 to length do
		resetSeqNum := resetSeqNum &amp; "9";
	endforeach;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_CC_T_B_L_YY_SSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(resetSeqNum.Integer, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country		// 09/02/2023	navkc1	Bug 56444

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoCreditExtNumberGen;
	
	realAutoGen.getNextId(null, terminal.code);
	actual := realAutoGen.getNextId(null, terminal.code);
	expected := oriCountry &amp; terminal.code &amp; bank.code &amp; idPrefix &amp; year.String &amp; 1.String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for sequence reset. Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
epilog
	beginTransaction;
	
	// Delete created object
	if created then
		delete realAutoGen;
	// Reset to original
	else
		realAutoGen.setPropertyValue(CM_AutoCreditExtNumberGen::currSeq.name, oriSeq);
		realAutoGen.setPropertyValue(CM_AutoCreditExtNumberGen::idStyle.name, oriStyle);
		realAutoGen.setPropertyValue(CM_AutoCreditExtNumberGen::currCountry.name, oriCountry); // 09/02/2023	navkc1	Bug 56444
	endif;
	
	commitTransaction;
	
	delete pxyAutoGen;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAutoIdGeneratorExtCrdInvNum" id="9412ca87-feef-470e-b172-e03d55874ea1">
        <source>tAutoIdGeneratorExtCrdInvNum();
/*

Purpose:				This UT is created for testing the Auto ID Generator for External Credit Invoice number (CM_AutoIdCrdInvExtNumberGen)
		
						**NOTE**
						Just in case someone is performing some testing on the Auto ID, we don't want to mess up their testing.
						Therefore, always store the current sequence number/style/year/ any other values that might get changed during the UT.
						Restore these values at epilog	

Parameters:			

Return Value:		

Date					Who		Reason
11 September 2024		jlizm1	Initial creation TFS 65953 NSW Dynamics Integration - Auto Generate ID

*/

constants
	Country 	= "NZ";
	PrefixType	= "CI";
	
vars

	autoGen		: CM_AutoIdGenerator;
	pxyAutoGen, 
	realAutoGen	: CM_AutoIdCrdInvExtNumberGen;
	bank		: CM_Bank;
	terminal	: CM_Terminal;
	oriSeq,
	oriStyle,
	year,
	count,
	length		: Integer;
	now			: Date;
	created		: Boolean;
	expected,
	actual,
	msg,
	resetSeqNum	: String;
	idPrefix	: String;
	oriCountry	: String;
	
begin
	
	now 		:= app.actualTimeAppServer().Date;
	year		:= now.format("yy").Integer;
	
	terminal 	:= self.getMyTerminal();
	bank		:= terminal.getDefaultCompanyBank();
	realAutoGen	:= bank.allAutoIdGenerators[CM_AutoIdGenerator.CrdInvExtNumberType].CM_AutoIdCrdInvExtNumberGen;
	autoGen 	:= realAutoGen;
	
	if realAutoGen = null then
		create pxyAutoGen transient;
		pxyAutoGen.setProxy(PrefixType,					// Prefix
							4, 							// Seq length
							AutoIdStyle_CC_B_L_YY_SSS, 	// Style
							null, 						// Terminal
							1, 							// Next seq number
							9999);						// Seq reset number
							
		pxyAutoGen.setProxyOtherAttributes(1, 			// curr seq
										year, 			// curr year
										bank,			// business unit
										Country);		// country
		
		app.myTrxCA.trxCreateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
		created := true;
		realAutoGen := autoGen.CM_AutoIdCrdInvExtNumberGen;
	endif;
	
	//==================================================================
	// Get original sequence and style (reset to original after UT)
	//==================================================================
	oriSeq := realAutoGen.currSeq;
	oriStyle := realAutoGen.idStyle;
	idPrefix := realAutoGen.idPrefix;
	oriCountry := realAutoGen.currCountry;
	
	//==========================================
	// Test style AutoIdStyle_CC_T_P_YY_SSS (10)
	//==========================================
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_CC_T_L_YY_SSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(realAutoGen.currSeq, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoIdCrdInvExtNumberGen;
	
	actual := realAutoGen.getNextId(null, terminal.code);
	expected := oriCountry &amp; terminal.code &amp; idPrefix &amp; year.String &amp; (oriSeq).String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for style : " &amp; AutoIdStyle_CC_T_L_YY_SSS.String &amp; ". Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
	//==========================================
	// Test style AutoIdStyle_CC_B_P_YY_SSS (11)
	//==========================================
	
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_CC_B_L_YY_SSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(realAutoGen.currSeq, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoIdCrdInvExtNumberGen;
	
	actual := realAutoGen.getNextId(null, terminal.code);
	expected := oriCountry &amp; bank.code &amp; idPrefix &amp; year.String &amp; (oriSeq + 1).String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for style : " &amp; AutoIdStyle_CC_B_L_YY_SSS.String &amp; ". Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
	//============================================
	// Test style AutoIdStyle_CC_T_B_P_YY_SSS (12)
	//============================================
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_CC_T_B_L_YY_SSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(realAutoGen.currSeq, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoIdCrdInvExtNumberGen;

	actual := realAutoGen.getNextId(null, terminal.code);
	expected := oriCountry &amp; terminal.code &amp; bank.code &amp; idPrefix &amp; year.String &amp; (oriSeq + 2).String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for style : " &amp; AutoIdStyle_CC_T_B_L_YY_SSS.String &amp; ". Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
	//============================================
	// Test style AutoIdStyle_P_SSS (12)
	//============================================
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_P_SSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(realAutoGen.currSeq, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoIdCrdInvExtNumberGen;

	actual := realAutoGen.getNextId(null, terminal.code);
	expected := idPrefix &amp; (oriSeq + 3).String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for style : " &amp; AutoIdStyle_P_SSS.String &amp; ". Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
	//================
	// Test seq reset
	//================
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	length := realAutoGen.idSeqNumLength;
	
	foreach count in 1 to length do
		resetSeqNum := resetSeqNum &amp; "9";
	endforeach;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_CC_T_B_L_YY_SSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(resetSeqNum.Integer, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoIdCrdInvExtNumberGen;
	
	realAutoGen.getNextId(null, terminal.code);
	actual := realAutoGen.getNextId(null, terminal.code);
	expected := oriCountry &amp; terminal.code &amp; bank.code &amp; idPrefix &amp; year.String &amp; 1.String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for sequence reset. Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
epilog
	beginTransaction;
	
	// Delete created object
	if created then
		delete realAutoGen;
	// Reset to original
	else
		realAutoGen.setPropertyValue(CM_AutoIdCrdInvExtNumberGen::currSeq.name, oriSeq);
		realAutoGen.setPropertyValue(CM_AutoIdCrdInvExtNumberGen::idStyle.name, oriStyle);
		realAutoGen.setPropertyValue(CM_AutoIdCrdInvExtNumberGen::currCountry.name, oriCountry);
	endif;
	
	commitTransaction;
	
	delete pxyAutoGen;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tAutoIdGeneratorExtInvNum" id="df12e60d-bcba-45ef-be9c-d73d90cddab2">
        <source>tAutoIdGeneratorExtInvNum();
/*

Purpose:			
		This UT is created for testing the Auto ID Generator for External Invoice number (CM_AutoInvoiceExtNumberGen)
		
		**NOTE**
		Just in case someone is performing some testing on the Auto ID, we don't want to mess up their testing.
		Therefore, always store the current sequence number/style/year/ any other values that might get changed during the UT.
		Restore these values at epilog
		
Parameters:			

Return Value:		

Date		Who		Reason
19 December 2022	navkc1	Initial creation TFS CR 55300 TASK 55523
09/02/2023			navkc1	Bug 56444: Jade - Country in Invoice/Credit note Auto Id
*/
constants
	Country 	= "NZ";
	PrefixType	= "IN";
	
vars

	autoGen		: CM_AutoIdGenerator;
	pxyAutoGen, 
	realAutoGen	: CM_AutoInvoiceExtNumberGen;
	bank		: CM_Bank;
	terminal	: CM_Terminal;
	oriSeq,
	oriStyle,
	year,
	count,
	length		: Integer;
	now			: Date;
	created		: Boolean;
	expected,
	actual,
	msg,
	resetSeqNum	: String;
	idPrefix	: String;
	oriCountry	: String; // 09/02/2023	navkc1	Bug 56444
begin
	
	now 		:= app.actualTimeAppServer().Date;
	year		:= now.format("yy").Integer;
	
	terminal 	:= self.getMyTerminal();
	bank		:= terminal.getDefaultCompanyBank();
	realAutoGen	:= bank.allAutoIdGenerators[CM_AutoIdGenerator.InvExtNumberType].CM_AutoInvoiceExtNumberGen;
	autoGen 	:= realAutoGen;
	
	if realAutoGen = null then
		create pxyAutoGen transient;
		pxyAutoGen.setProxy(PrefixType,					// Prefix
							4, 							// Seq length
							AutoIdStyle_CC_B_L_YY_SSS, 	// Style
							null, 						// Terminal
							1, 							// Next seq number
							9999);						// Seq reset number
							
		pxyAutoGen.setProxyOtherAttributes(1, 			// curr seq
										year, 		// curr year
										bank,		// business unit
										Country);	// country 			// 09/02/2023	navkc1	Bug 56444
		
		app.myTrxCA.trxCreateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
		created := true;
		realAutoGen := autoGen.CM_AutoInvoiceExtNumberGen;
	endif;
	
	//==================================================================
	// Get original sequence and style (reset to original after UT)
	//==================================================================
	oriSeq := realAutoGen.currSeq;
	oriStyle := realAutoGen.idStyle;
	idPrefix := realAutoGen.idPrefix;
	oriCountry := realAutoGen.currCountry;
	//==========================================
	// Test style AutoIdStyle_CC_T_P_YY_SSS (10)
	//==========================================
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_CC_T_L_YY_SSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(realAutoGen.currSeq, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country		// 09/02/2023	navkc1	Bug 56444

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoInvoiceExtNumberGen;
	
	actual := realAutoGen.getNextId(null, terminal.code);
	expected := oriCountry &amp; terminal.code &amp; idPrefix &amp; year.String &amp; (oriSeq).String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for style : " &amp; AutoIdStyle_CC_T_L_YY_SSS.String &amp; ". Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
	//==========================================
	// Test style AutoIdStyle_CC_B_P_YY_SSS (11)
	//==========================================
	
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_CC_B_L_YY_SSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(realAutoGen.currSeq, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country		// 09/02/2023	navkc1	Bug 56444

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoInvoiceExtNumberGen;
	
	actual := realAutoGen.getNextId(null, terminal.code);
	expected := oriCountry &amp; bank.code &amp; idPrefix &amp; year.String &amp; (oriSeq + 1).String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for style : " &amp; AutoIdStyle_CC_B_L_YY_SSS.String &amp; ". Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
	//============================================
	// Test style AutoIdStyle_CC_T_B_P_YY_SSS (12)
	//============================================
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_CC_T_B_L_YY_SSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(realAutoGen.currSeq, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country	// 09/02/2023	navkc1	Bug 56444

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoInvoiceExtNumberGen;

	actual := realAutoGen.getNextId(null, terminal.code);
	expected := oriCountry &amp; terminal.code &amp; bank.code &amp; idPrefix &amp; year.String &amp; (oriSeq + 2).String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for style : " &amp; AutoIdStyle_CC_T_B_L_YY_SSS.String &amp; ". Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
	//============================================
	// Test style AutoIdStyle_B_L_YY_SSS (13) //17/01/2025	navkc1 JIRA Bug MTN-33813
	//============================================
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_B_L_YY_SSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(realAutoGen.currSeq, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country	// 09/02/2023	navkc1	Bug 56444

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoInvoiceExtNumberGen;

	actual := realAutoGen.getNextId(null, terminal.code);
	expected := bank.code &amp; idPrefix &amp; year.String &amp; (oriSeq + 3).String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for style : " &amp; AutoIdStyle_B_L_YY_SSS.String &amp; ". Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
	//============================================
	// Test style AutoIdStyle_L_YY_SSSS (14) //17/01/2025	navkc1 JIRA Bug MTN-33813
	//============================================
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_L_YY_SSSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(realAutoGen.currSeq, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country	// 09/02/2023	navkc1	Bug 56444

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoInvoiceExtNumberGen;

	actual := realAutoGen.getNextId(null, terminal.code);
	expected := idPrefix &amp; year.String &amp; (oriSeq + 4).String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for style : " &amp; AutoIdStyle_L_YY_SSSS.String &amp; ". Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
	
	//================
	// Test seq reset
	//================
	delete pxyAutoGen;
	beginLoad;
		pxyAutoGen := realAutoGen.pxyCreateUpdateProxy();
	endLoad;
	
	length := realAutoGen.idSeqNumLength;
	
	foreach count in 1 to length do
		resetSeqNum := resetSeqNum &amp; "9";
	endforeach;
	
	pxyAutoGen.setProxy(realAutoGen.idPrefix,
						realAutoGen.idSeqNumLength,
						AutoIdStyle_CC_T_B_L_YY_SSS,
						null,
						realAutoGen.nextSequenceNum,
						realAutoGen.resetSeqOn);
							
	pxyAutoGen.setProxyOtherAttributes(resetSeqNum.Integer, 			// curr seq
									realAutoGen.currYear, 				// curr year
									realAutoGen.myBusinessUnit,			// business unit
									realAutoGen.currCountry);			// country 		// 09/02/2023	navkc1	Bug 56444

	
	app.myTrxUA.trxUpdateAutoIdGenerator(pxyAutoGen, autoGen, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	realAutoGen := autoGen.CM_AutoInvoiceExtNumberGen;
	
	realAutoGen.getNextId(null, terminal.code);
	actual := realAutoGen.getNextId(null, terminal.code);
	expected := oriCountry &amp; terminal.code &amp; bank.code &amp; idPrefix &amp; year.String &amp; 1.String.padLeadingZeros(realAutoGen.idSeqNumLength);
	msg := "Unexpected Auto ID generated for sequence reset. Expected is : " &amp; expected &amp; ", actual is : " &amp; actual;
	assertTrueMsg(expected = actual, msg);
	
epilog
	beginTransaction;
	
	// Delete created object
	if created then
		delete realAutoGen;
	// Reset to original
	else
		realAutoGen.setPropertyValue(CM_AutoInvoiceExtNumberGen::currSeq.name, oriSeq);
		realAutoGen.setPropertyValue(CM_AutoInvoiceExtNumberGen::idStyle.name, oriStyle);
		realAutoGen.setPropertyValue(CM_AutoInvoiceExtNumberGen::currCountry.name, oriCountry); // 09/02/2023	navkc1	Bug 56444
	endif;
	
	commitTransaction;
	
	delete pxyAutoGen;
end;</source>
    </JadeMethod>
    <JadeMethod name="tBillingWithImperialMeasures" id="3132dbb2-4429-40f1-9c2e-a238d7463803">
        <source>tBillingWithImperialMeasures();
// cnwma1
// CNWJRE1
/*
Purpose:			
Date		Who		Reason
21 May 2013	NAVAB1	Initial creation
*/

vars
	bs : CM_BlockStack;
	ct : CM_CargoType;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	ild1, ild2, ild3			: CM_InvoiceLineDesc;
	invType		: CM_InvoiceDesc;
	services	: CM_ServiceByNameDict;
	allServices	: CM_ServiceByNameDict;
	operator	: CM_Operator;
	costs : DecimalArray;
	debtor : CM_DebtorNode;
	ti: CM_TrackedItem;
	invoice	: CM_Invoice;
	selectedTypes: CM_CargoBOLTypeSet;
	stopsTable: CM_StopsTable;
	processAreas: IntegerArray;
	opts : CM_AssociationDict;
	trans : CM_TransactionSet;
	transients	: ObjectArray;
	glCode : CM_GLCode;
	ioClassActual : CM_ExtFinanceIO;
	ioClassForTest : CM_DPHPortusJax;
	origPath : String;
	mesType : CM_MeasurementType;
	tmpLength : Decimal[10,4];
	invLine : CM_InvoiceLine;
	cargoId : String;
begin

	// delete any old objects
	cargoId := "DPHU0002312";
	self.deleteTrackedItem(cargoId, false);
	self.deleteStopsTable(99);
	self.deleteStopsTable(78);
	self.deleteInvoiceService("UT_DPHService1", FORCED_ERASE);
	self.deleteInvoiceService("UT_DPHService2", FORCED_ERASE);
	self.deleteInvoiceService("UT_DPHService3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_DPHInvLineType1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_DPHInvLineType2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_DPHInvLineType3", FORCED_ERASE);
	self.deleteInvoiceGLCode("1235-55654");
	self.deleteInvoiceGLCode("9823-56543");
	self.deleteInvoiceGLCode("4451-66100");
	self.deleteCalculationType("UT_CONVL",NORMAL_ERASE);
	self.deleteCalculationType("UT_CONVW", NORMAL_ERASE);
	self.deleteCalculationType("UT_CONVV", NORMAL_ERASE);
	self.deleteMeasurementType("UTWeight");
	self.deleteMeasurementType("UTLength");
	self.deleteMeasurementType("UTVolume");
	

	ioClassActual := self.getTerminalConfig(FinancialIOClass).CM_ExtFinanceIO;

	// We are going to write out 3 files as part of the normal DPH export, but we should not use the configured export path, instead we will use c_misc on the server
	ioClassForTest := CM_DPHPortusJax.firstInstance().CM_DPHPortusJax;
	if ioClassForTest = null then	
		ioClassForTest := app.myTrxCA.trxCreateExternalFinanceClass(CM_DPHPortusJax).CM_DPHPortusJax;
	endif;
	if ioClassForTest &lt;&gt; null then	
		self.setTerminalConfig(FinancialIOClass,ioClassForTest);
		origPath := ioClassForTest.exportPath;
		beginTransaction;
		ioClassForTest.exportPath := "..\c_misc\";
		commitTransaction;
	endif;
	
	
	
	create transients transient;
	// create new instances
	create services transient;
	create allServices transient;
	invType := self.getInvoiceType("UT_DPHINVTYPE");
	self.assertNotNullMsg(invType, "Terminal - " &amp; self.myBank.terminal.code &amp;  ", BU - " &amp; self.myBank.code &amp; " Invoice type UT_DPHINVTYPE not created. ");

	// #### TEST WEIGHTS
	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, "UTWeight", Type_Weight, "UT Weight Units");
	self.assertNotNullMsg(mesType, "Measurement type UTWeight not created");
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_CARGOWEIGHTCONVT, "UT_CONVW", "UT_CONVW", 0,0,0,0,null, false, null,null, 0,0,INV_CALC_TYPE_UNITY,	null, null, null, "SUPERUSER", true, false, false, null, null, null, mesType);
	
	self.assertNotNullMsg(calcType, "Calculation type UT_CONVW not created");

	glCode := self.createInvoiceGLCode("1235-55654", "UnitTest DPH 1");
	service := self.createInvoiceService("UT_DPHService1", "DPH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.add(service);
	ild1 := self.createInvoiceLineType("UT_DPHInvLineType1", calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	// #### TEST VOLUMES
	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, "UTVolume", Type_Volume, "UT Volume Units");
	self.assertNotNullMsg(mesType, "Measurement type UTVolume not created");
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_CARGOVOLUMECONVT, "UT_CONVV", "UT_CONVV", 0,0,0,0,null, false, null,null, 0,0,INV_CALC_TYPE_UNITY,	null, null, null, "SUPERUSER", true, false, false, null, null, null, mesType);
	self.assertNotNullMsg(calcType, "Calculation type UT_CONVV not created");

	glCode := self.createInvoiceGLCode("9823-56543", "UnitTest DPH 2");
	service := self.createInvoiceService("UT_DPHService2", "DPH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.clear();
	services.add(service);
	ild2 := self.createInvoiceLineType("UT_DPHInvLineType2", calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	// #### TEST LENGTH
	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, "UTLength", Type_Linear, "UT Length Units");
	self.assertNotNullMsg(mesType, "Measurement type UTLength not created");
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_CARGOLENGTHCONVT, "UT_CONVL", "UT_CONVL", 0,0,0,0,null, false, null,null, 0,0,INV_CALC_TYPE_UNITY,	null, null, null, "SUPERUSER", true, false, false, null, null, null, mesType);
	self.assertNotNullMsg(calcType, "Calculation type UT_CONVL not created");

	glCode := self.createInvoiceGLCode("4451-66100", "UnitTest DPH 3");
	service := self.createInvoiceService("UT_DPHService3", "DPH Qty", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.clear();
	services.add(service);
	ild3 := self.createInvoiceLineType("UT_DPHInvLineType3", calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	self.tranMapLoadDPHInterface();

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
	// set rates such that a known invoice line value is the lowest or highest 
	self.cargoDPHInterfaceRates(allServices);

	
	// create a container
	tmpLength := 200.00;
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	self.opts.addAssoc(UTTI_Volume, 1000);
	self.opts.addAssoc(UTTI_Length, tmpLength);
	self.opts.addAssoc(UTTI_TotalWeight, 33000);

	deleteTerminalArea("UTINV");
	bs:= addBlockStack("UTINV", 1000, null);

	ct := self.getCargoType("UTREBAR");
	ti := self.addCargoOpts("DPHU0002312", null,null, operator, ct.id);	
	
	self.move(ti, bs.myLocationsController);
	
	create selectedTypes transient;
	selectedTypes.add(ct);
	create processAreas transient;
	processAreas.add(StopProcessCopyToChild);
	create opts transient;
	opts.addAssoc(ETRow_ProcessStopAreas, processAreas);
	stopsTable := addStopsTable(99, "UT", "Unit Test", selectedTypes, opts);

	self.addStop(ti, stopsTable);
	stopsTable := addStopsTable(78, "UT2", "Unit Test2 ", selectedTypes, opts);
	self.addStop(ti, stopsTable);

	invoice := ti.invoiceLines.first.invoice;
	self.postInvoice(invoice, false, false);
	
	foreach invLine in invoice.invoiceLines discreteLock do
		if invLine.invoiceLineDesc = ild1 then
			self.assertTrueMsg(invLine.quantity = 66000, "Quantity Error on ild1 - " &amp; ild1.narration &amp; ", expecting 66000 got " &amp; invLine.quantity.String); // WEIGHT
		elseif invLine.invoiceLineDesc = ild2 then
			self.assertTrueMsg(invLine.quantity = 2000, "Quantity Error on ild2 - " &amp; ild2.narration &amp; ", expecting 2000 got " &amp; invLine.quantity.String); // VOLUME
		elseif invLine.invoiceLineDesc = ild3 then
			self.assertTrueMsg(invLine.quantity = 400, "Quantity Error on ild3 - " &amp; ild3.narration &amp; ", expecting 400 got " &amp; invLine.quantity.String); // LENGTH
		endif;
	endforeach;
 
epilog
	self.resetDefaultTranMap();
	// delete this tran map so following tests can delete the invoice line descs etc
	self.deleteInvoiceTransactionMap(1, 'UT_CargoDPH');
	if ioClassForTest &lt;&gt; null then	
		beginTransaction;
		ioClassActual.exportPath := origPath;
		commitTransaction;
	endif;
	
	delete services;
	delete allServices;
	delete costs;
	if transients &lt;&gt; null then
		transients.purge();
		delete transients;
	endif;
	delete selectedTypes;
	delete processAreas;
	delete opts;
	delete trans;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tBulkRecShipVolume" id="b648808f-c3c1-4f57-96e0-fedad29d72bd">
        <updating/>
        <source>tBulkRecShipVolume() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 05MAR2024
ADO -  BUG 62748
*/
constants
	VESSEL= "DSEQ300";
	VOYAGE= "DSEQ300";
	CARGOTYPEDESC = "UT_ABGRAV";

vars
	voyage : CM_Voyage;
	bs : CM_TerminalArea;
	location : CM_LocationsController;
	cargoType : CM_CargoType;
	term : CM_Terminal;
	ti, onsiteTI :CM_TrackedItem;
	totalQuantity : Integer;
	totalWeight, totalVolume : Decimal[23,4];
	opCode : String;
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	aPort : CM_Port;
	trans : CM_TITransaction;
	cargoGroup1 : CM_CargoGroup;
begin
	term := self.getTerminal();
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup("CG240305-100");
	self.deleteCargoType(CARGOTYPEDESC);

	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("TrackBy", CargoType_TrackByWeight);

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	totalQuantity := 1;
	totalWeight := 10000;
	totalVolume := 100;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	bs := self.getTerminal.allTerminalAreas.getAtKeyGeq("UTINVBS");
	location := bs.allLocationsControllers.first;
	
	cargoGroup1 := self.addCargoGroup("CG240305-100",null);
	
	ti := self.createBULKOnVoyage(false, "", "GRAVE240305-100", cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
	
	self.assertTrueMsg(ti &lt;&gt; null, "GRAVE240305-100" &amp; " is null, Cargo not created");
	
	
	self.deleteStops(ti);

	self.moveBulk(ti,location,1000);
	
	onsiteTI := ti.allSplitChildrenTis.first;
	self.assertTrueMsg(onsiteTI &lt;&gt; null, "onsiteTI is null");
	
	trans := onsiteTI.getLastTransOfType(TRANS_TYPE_REC_SHIP);
	self.assertTrueMsg(trans &lt;&gt; null, "First receive ship is null");
	self.assertTrueMsg(trans.totalWeight = 1000, "First Transaction weight 1 is wrong");
	self.assertTrueMsg(trans.totalVolume = 10, "First Transaction volume 1 is wrong");
	self.assertTrueMsg(onsiteTI.totalVolume = 10, "First onsiteTI volume 1 is wrong");
	

	self.moveBulk(ti,location,1000);
	trans := onsiteTI.getLastTransOfType(TRANS_TYPE_REC_SHIP);
	self.assertTrueMsg(trans &lt;&gt; null, "Second receive ship is null");
	self.assertTrueMsg(trans.totalWeight = 1000, "Second Transaction weight 1 is wrong");
	self.assertTrueMsg(trans.totalVolume = 10, "Second Transaction volume 1 is wrong");
	self.assertTrueMsg(onsiteTI.totalVolume = 20, "Second onsiteTI volume 1 is wrong");

	self.moveBulk(ti,location,1000);
	trans := onsiteTI.getLastTransOfType(TRANS_TYPE_REC_SHIP);
	self.assertTrueMsg(trans &lt;&gt; null, "Third receive ship is null");
	self.assertTrueMsg(trans.totalWeight = 1000, "Third Transaction weight 1 is wrong");
	self.assertTrueMsg(trans.totalVolume = 10, "Third Transaction volume 1 is wrong");
	self.assertTrueMsg(onsiteTI.totalVolume = 30, "Third onsiteTI volume 1 is wrong");

	self.moveBulk(ti,location,1000);
	trans := onsiteTI.getLastTransOfType(TRANS_TYPE_REC_SHIP);
	self.assertTrueMsg(trans &lt;&gt; null, "Fourth receive ship is null");
	self.assertTrueMsg(trans.totalWeight = 1000, "Fourth Transaction weight 1 is wrong");
	self.assertTrueMsg(trans.totalVolume = 10, "Fourth Transaction volume 1 is wrong");
	self.assertTrueMsg(onsiteTI.totalVolume = 40, "Fourth onsiteTI volume 1 is wrong");
	
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	self.deleteCargoType(CARGOTYPEDESC);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tCPL51081DeborAddress" id="df96ad0c-2919-4323-9ae4-bfaf76b2ee7f">
        <source>tCPL51081DeborAddress();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Apr 2021 cnwma1  Bug 51081: CPL - 2nd Line of Debtor Address cutting off to new line

*/
constants
	DebtorCode1 = "CPL51081-1";
	DebtorCode2 = "CPL51081-2";
vars
	debtorNodeController	: CMIF_DebtorNode;
	pxyDebtor	            : CM_Debtor;
	debtorNode              : CM_DebtorNode;
begin
    self.deleteDebtor(DebtorCode1);
	self.deleteDebtor(DebtorCode2);
	create debtorNodeController transient;
	create pxyDebtor transient;
	self.setDebtorNodeController1(DebtorCode1, debtorNodeController, pxyDebtor);
	
	debtorNodeController.decfinName     := DebtorCode1;
	debtorNodeController.billingAddress := "Pacific International Lines (Pte) Ltd"  &amp; CrLf &amp;
										   "C/- McKay Shipping Holdings Ltd" &amp; CrLf &amp;
											"PO BOX 921" &amp; CrLf &amp;
											"Wellington" &amp; CrLf&amp;
											"New Zealand";

	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(debtorNode.CM_Debtor.decfinName, DebtorCode1, "Debtor decfinName:");	
	self.assertEqualMsg(debtorNode.CM_Debtor.billingAddress[1], 
					    "Pacific International Lines (Pte) Ltd"  &amp; CrLf &amp;
					    "C/- McKay Shipping Holdings Ltd" &amp; CrLf &amp;
						"PO BOX 921" &amp; CrLf &amp;
						"Wellington" &amp; CrLf&amp;
						"New Zealand", "Debtor Address Line1:");	

	//Address using Comma 
	delete debtorNodeController;
	delete pxyDebtor;
	
	create debtorNodeController transient;
	create pxyDebtor transient;
	self.setDebtorNodeController1(DebtorCode2, debtorNodeController, pxyDebtor);
	
	debtorNodeController.decfinName     := DebtorCode2;
	debtorNodeController.billingAddress := "Pacific International Lines (Pte) Ltd,C/- McKay Shipping Holdings Ltd,PO BOX 921,Wellington,New Zealand";
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(debtorNode.CM_Debtor.decfinName, DebtorCode2, "Debtor decfinName:");	
	self.assertEqualMsg(debtorNode.CM_Debtor.billingAddress.size,5 ,"Debtor Address Size");
	self.assertEqualMsg(debtorNode.CM_Debtor.billingAddress[1],"Pacific International Lines (Pte) Ltd","Address Line 1");
	self.assertEqualMsg(debtorNode.CM_Debtor.billingAddress[2],"C/- McKay Shipping Holdings Ltd","Address Line 2");
	self.assertEqualMsg(debtorNode.CM_Debtor.billingAddress[3],"PO BOX 921","Address Line 3");
	self.assertEqualMsg(debtorNode.CM_Debtor.billingAddress[4],"Wellington","Address Line 4");
	self.assertEqualMsg(debtorNode.CM_Debtor.billingAddress[5],"New Zealand","Address Line 5");
epilog
	delete pxyDebtor;
	delete debtorNodeController;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCalcTypeToUseCargoWght" id="eee4219a-b670-47f7-b97c-d49b6be442ed">
        <source>tCalcTypeToUseCargoWght();
/*

Purpose:			This UT check the new option in Calculation Type "Weight To Use" is calculating the amount using Cargo Weight correctly

Parameters:			

Return Value:		

Date		Who		Reason
08/10/2025	navkc1 JIRA 36145 AAT | RotaBox ISO Type and New Attributes - Unit Test

*/
constants
	UTCALCT = 'ROTACALCT';
	UTISOTYPE = 'UR0T';
	UTCONT = 'CONT';
	UTCTYPECONTENTS = 'UR0TA';
	UTPRODCONTENTS = 'UR0TAS';
	UTCONTID = 'UTCROTA-1';
	UTTRUCKID = 'UTROTATRUCK';
	UTMEASTYPE = 'UTROTA';
	UTINVTYPE = 'UTINVTYPEROTA';
	UTLINEINVTYPE = 'UTINVLTYPEROTA';
	UTSERVICE = 'UTROTASVC';
	UTINV = '';
	
vars
	term			: CM_Terminal;
	root			: CM_Root;
	calcType		: CM_CalculationType;
	pxyMeasType,
	measType		: CM_MeasurementType;
	invType 		: CM_InvoiceDesc;
	invLineType		: CM_InvoiceLineDesc;
	pxyService		: CM_Service;
	service			: CM_ServiceObject;
	debtType		: CM_DebtorType;
	services		: CM_ServiceByNameDict;
	cTypeContents,
	cTypeContainer	: CM_CargoType;
	product			: CM_Product;
	iso				: CM_ISOType;
	tiCont			: CM_TrackedItem;
	operator		: CM_Operator;
	vvr				: CM_VehicleVisitRecord;
	tiSet			: CM_TISet;
	inv				: CM_Invoice;
	invLine			: CM_InvoiceLine;
begin
	
	term := self.getMyTerminal();
	root := self.getRoot();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Get Cargo Type Container
		cTypeContainer := self.getCargoType(UTCONT);
		self.assertNotNullMsg(cTypeContainer, "Failed to get Cargo Type Container");
	
	// Get ISO Type
		iso := self.addISOType(UTISOTYPE, "UT ROTA ISO TYPE", cTypeContainer, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, true, 1000);
	
	// Get Cargo Type for Contents
		self.opts.purge();
		self.opts.addAssoc('TrackAs', ProductType_Bulk);
		cTypeContents := self.addCargoType(UTCTYPECONTENTS, true);
	
	// Get Product
		self.opts.purge();
		product := self.addProduct(UTPRODCONTENTS, null, cTypeContents);
	
	// Get Measurement type
		measType := root.allMeasurementTypesByShortName[UTMEASTYPE];
		if measType &lt;&gt; null then
			app.myTrxDA.trxDeleteMeasurementType(measType, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endif;
		
		create pxyMeasType transient;
		pxyMeasType.setProxy(1, 14.3, true, false, true, false, UTMEASTYPE, 'Weight', UTMEASTYPE, 1);
		app.myTrxCA.trxCreateMeasurementType(pxyMeasType, measType, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		
	
	// Get Calculation Type
		self.deleteCalculationType(UTCALCT, NORMAL_ERASE);
		calcType := self.addCalculationType(INV_CALC_TYPE_CARGOWEIGHTCONVT, UTCALCT, UTCALCT, null, null, null, null, null, null, null, true, null, null, null, null, measType, CM_CalculationType.CargoWeight);
		
	// Get Invoice Type
		self.deleteInvoiceType(UTINVTYPE);
		invType := self.createInvoiceType(UTINVTYPE, InvoiceTypeGeneral);
		
	// Get Invoice Line and Service
		self.createInvoiceLineAndRate(invType, UTSERVICE, UTLINEINVTYPE, calcType.code, 'SDT1', 4.4);
		self.assertNoTrxErrorsOrWarnings();
		invLineType := self.getInvoiceLineType(UTLINEINVTYPE);
		self.assertNotNullMsg(invLineType, "Failed to get Invoice Line Type");
	
	// Get TI Container
		// Delete existing one
		tiCont := self.getTrackedItem(UTCONTID);
		self.deleteTrackedItem(tiCont, true);
	
	// Gate in Container
		self.opts.purge();
		self.deleteVehicle(UTTRUCKID);
		self.opts.addAssoc('CargoTypeForContents',cTypeContents);
		self.opts.addAssoc('SubTypeForContents', product);
		self.opts.addAssoc('WeightCargo', 1000);
		vvr := self.gateInContainer(UTTRUCKID, UTCONTID, UTISOTYPE, operator.code, null, self.getProfileSetting(UT_Profile.P_DGATE).asString);
	
	// Do stuff
		self.workVehicle(vvr);
		self.roadExit(vvr);
		
	// Get Tracked Item
		tiCont := self.getTrackedItem(UTCONTID);
		self.assertNotNullMsg(tiCont, "Failed to get the container");
	
	// Create Invoice
		inv := self.createManualInvoice(term.getDefaultCompanyBank(), operator.debtor, null, invType, tiCont);
		self.assertNotNullMsg(inv, 'Failed to create invoice');
		
	// Create invoice line
		create tiSet transient;
		tiSet.add(tiCont);
		self.opts.purge();
		self.opts.addAssoc('useCalculationType', true);
		self.opts.addAssoc('allTrackedItems', tiSet);
		invLine := self.createManualInvoiceLine(invLineType, inv, 1, 'UTROTA', app.actualTimeAppServer().date());
		self.assertNotNullMsg(invLine, 'Failed to create invoice line');
		
	// Check invoice line is using the Cargo weight
		self.assertEqualMsg(invLine.quantity.Integer, tiCont.weightCargo.Integer, 'Quantity on the invoice line does not match with the cargo weight');
	
epilog
	
	self.deleteCalculationType(UTCALCT, NORMAL_ERASE);
	
	delete pxyMeasType;
	if measType &lt;&gt; null then
		app.myTrxDA.trxDeleteMeasurementType(measType, app.myPassport);
	endif;
	
	delete pxyService;
	delete services;
	self.deleteService(UTSERVICE);
	self.deleteInvoiceLineType(UTLINEINVTYPE, NORMAL_ERASE);
	self.deleteInvoiceType(UTINVTYPE);
	delete tiSet;
	self.deleteTrackedItem(tiCont, true);
end;</source>
    </JadeMethod>
