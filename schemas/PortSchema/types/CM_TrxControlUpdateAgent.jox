        <source>trxUpdateRateEntryCSV(_bank : CM_Bank; _allFileRows:ObjectArray; _passportObj:CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		11 December 2008 by cnwdad1
//
// Purpose:		Updates multiple Rate Entries that have been read from a CSV file
//				(in the same format as the Rate Table extract).
//
// Parameters:	_allFileRows - An object array of file rows (each one being a HugeStringArray).
//				_passportObj - A reference to the current user's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passportObj, method);
	
	// Arm our base exception handlers
	on Exception do self.agtPassportExHandler(exception, _passportObj);
	on LockException do self.agtPassportLockExHandler(exception, _passportObj);
	
	app.setContinueCMExceptions(false);
	
	beginTransaction;
	
	app.myUtilityUA.utlUpdateRateEntryCSV(_bank, _allFileRows, _passportObj);
epilog
	self.finaliseActivityWithPassport(_passportObj);
end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
