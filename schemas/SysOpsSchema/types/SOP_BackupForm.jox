    <JadeMethod name="doAbortProcessing" id="738fc891-e229-4f7a-ac6f-cec66f9dd845">
        <source>doAbortProcessing() protected;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
// ---------------------------------------------------------------------------
vars

begin
	if not app.msgBox(app.getErrorString(Do_You_Wish_To_Abort), app.getErrorString(Backup), MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then
		return;
	endif;

	if self.myBackup &lt;&gt; null then
		beginTransaction;
		self.myBackup.setStatus(BackupStatus_Abort);	// CCMS1150 cnwrs1 16 June 2011
		commitTransaction;
		self.btnBackup.enabled := false;
	else
		self.btnBackup.enabled := true;
	endif;
	self.btnAbort.enabled := false;
	self.btnEdit.enabled := true;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBackup" id="65ba3fd8-950d-40de-a44b-66cc64cdf266">
        <updating/>
        <source>doBackup() protected, updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	date: Date;
	whatIsRunning, msg: String;
	result: Boolean;
	schedule: CM_AutoSchedule;	
begin
	if CM_AutoTaskBackupDB.firstInstance = null or
	   CM_AutoTaskBackupDB.firstInstance.allAutoSchedules.first = null then
		app.msgBox("Unable to process backup as no Schedule exists", app.getErrorString(Backup), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	schedule := CM_AutoTaskBackupDB.firstInstance.allAutoSchedules.first;
	if not app.msgBox(app.getErrorString1(DoYouWantToProcess, app.getErrorString(Backup)), app.getErrorString(Backup), MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then
		return;
	endif;
	self.btnBackup.enabled := false;
	self.btnAbort.enabled := true;
	self.btnEdit.enabled := false;	
	app.myTrxUA.trxUpdateAutoScheduleRunTs(schedule, CM_AutoSchedule.Make_Now, app.myPassport);	
epilog	
	self.btnBackup.enabled := true;
	self.btnAbort.enabled := false;
	self.btnEdit.enabled := true;
//	delete self.myBackupDBAgent;
//	self.myBackupDBAgent := null;	
	app.mousePointer := MousePointer_Default;	
end;</source>
        <access>protected</access>
    </JadeMethod>
