    <JadeMethod name="getLatestScanRecord" id="4eb5d6c0-35da-4257-94d5-ee735c841453">
        <updating/>
        <source>getLatestScanRecord(_txtWeightCtrl : CMUI_MeasurementTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2022	navpw1	Initial creation TFS: 54311

*/

vars
	gateScanRecord,
	selectedScanRecord,
	currentScanRecord		: CM_GenericGateScanRecord;
	showModal				: Integer;
	weighBridge				: CM_WeighBridgeObj;
	deviceId,
	scanDeviceId,
	wBdeviceid				: String;
	gate					: CM_Gate;
	gateArea				: CM_GateArea;
	gateLane				: CM_GateAreaLaneController;
	gateAreaUsage			: CM_GateAreaUsage;
	allRecordsForDevice		: CM_GenericGateScanRecs;
	overwriteValues			: Boolean;
begin
	// If we have no generic weightbridges or scan readers for our currently selected gate/lane, then nothing for us to do
	if self.allAssociatedDevices.size = 0 then
		return;
	endif;
	
	if self.myTerminal.allGenericScanRecsUnassigned.size = 0 then
		return;
	else
		create allRecordsForDevice transient;
			
		foreach gateScanRecord in self.myTerminal.allGenericScanRecsUnassigned discreteLock do
			if self.allAssociatedDevices[gateScanRecord.deviceId] &lt;&gt; null then
				allRecordsForDevice.add(gateScanRecord);
			endif;
		endforeach;
		
		// Not a note for us, then we're done here
		if allRecordsForDevice.size = 0 then
			return;
		endif;
		
		if allRecordsForDevice.size = 1 then
			self.myCurrentGateScanRecord := allRecordsForDevice.first;
		else
			//Take latest record
			self.myCurrentGateScanRecord := allRecordsForDevice.last;
			
			allRecordsForDevice.remove(self.myCurrentGateScanRecord); //Remove the record we selected from the list
			
			if allRecordsForDevice.size &gt; 0 then //If we have more than 0 records remaining. Delete the other records
				app.myTrxDA.trxDeleteGateScanRecords(allRecordsForDevice, app.myPassport);
			endif;
			
		endif;
	endif;
	
epilog
	delete allRecordsForDevice;
	
end;</source>
        <Parameter name="_txtWeightCtrl" type="CMUI_MeasurementTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getLogLocationsForSpec" id="3cbbd44d-6349-4aa0-880d-eeb352a084b8">
        <source>getLogLocationsForSpec(_grade : CM_LogGrade ; _type : CM_LogType; _treatment : CM_LogTreatment; _length : CM_LogLength; _locations : CM_LCSet input);
// -----------------------------------------------------------------------------
// Created:		15 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	_locations.clear();
	if _grade &lt;&gt; null then
		_grade.getAvailableLocationsForSpec(_type, _treatment, _length, _locations);
	endif;

end;</source>
        <Parameter name="_grade" type="CM_LogGrade"/>
        <Parameter name="_type" type="CM_LogType"/>
        <Parameter name="_treatment" type="CM_LogTreatment"/>
        <Parameter name="_length" type="CM_LogLength"/>
        <Parameter name="_locations" type="CM_LCSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMachineLiftType" id="50d71ff1-5772-40cc-95f5-57328770b79d">
        <source>getMachineLiftType(_value : Integer; _desc : String) : String;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rtn : String;
begin
	if _desc = null then
		return global.getMachLiftTypeDescFromCode(_value);
	else
		if _desc = "Normal Lift" then
			rtn := NORMAL_LIFT.String;
		elseif _desc = "Twin Lift" then
			rtn := TWIN_LIFT.String;
		elseif _desc = "Tandem Lift" then
			rtn := TANDEM_LIFT.String;
		elseif _desc = "Multi Lift" then  //epr CCMS 1391 warehouse VMT 19/8/14
			rtn := MULTI_LIFT.String;
		endif;		
	endif;
	return rtn;
epilog
end;</source>
        <Parameter name="_value" type="Integer"/>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMatchingObjectSlotTypeVal" id="ac3220e0-0b89-4a10-b7dc-6ce15eabb526">
        <source>getMatchingObjectSlotTypeVal(_vbt : CM_VehicleBookingTerminal; _pCode : String; _callingForm : CM_BaseForm; _vvr : CM_VehicleVisitRecord input; _pickerShown : Boolean output) : Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2023	navpw1	Initial creation TFS: 54049 (55840)
05 Sep 2023 navhl20 ChangeRequest 60417: EUP | FR | 53429 VBS Changes - Assigning of Release lie items to VBS Slots for gate Picker screen
*/

vars
	objArr				: ObjectArray;
	compareCode			: String;
	vbsts				: CM_VehicleBookingTimeSlot;
	allowMultiSelect	: Boolean;
	tmpTI				: CM_TrackedItem;
	bulkRelease			: CM_BulkRelease;
	bookingRef			: CM_BookingRef;
	selectedObject		: Object;
	
	terminal			: CM_Terminal;
	bookingRefItem		: CM_BookingRefItem;
	foundBookingRef		: Boolean;
	vbtsi				: CM_VehicleBookingTimeSlotItem;
	reserveDetail		: CM_ReserveDetail;
	
begin
	create objArr transient;
	compareCode := _pCode.toUpper();
	terminal := self.myTerminal;
	
	//vehicle booking timeslot has refs to all sorts, add them all...
	if terminal &lt;&gt; null and _vbt &lt;&gt; null then
		vbsts := _vbt.allVBTimeslotsById.getAtKey(compareCode);
		if vbsts = null then
			vbsts  := _vbt.allVBTimeslotsByExtRef.getAtKey(compareCode);
		endif;
		
		if vbsts &lt;&gt; null then
			_pickerShown := true;
			foreach tmpTI in vbsts.allBookedTrackedItems discreteLock do
				if _vvr = null or not _vvr.isPrenoteActioned(tmpTI) then
					objArr.addExclusive(tmpTI);
					allowMultiSelect := true;
				endif;
				
			endforeach;
			
			foreach vbtsi in vbsts.allVehicleBookingItems discreteLock do
				if vbtsi.myTrackedItem &lt;&gt; null then
					continue;
				endif;
				
				if vbtsi.myBookingItem &lt;&gt; null then
					objArr.addExclusive(vbtsi.myBookingItem);
					
					if vbtsi.myBookingItem.myReserveDetail &lt;&gt; null then
						reserveDetail := vbtsi.myBookingItem.myReserveDetail;
						if reserveDetail.myReserveHeader.status.isOneOf(BR_ACTIVE, BR_PENDING) then
							if reserveDetail.hasOutstanding and reserveDetail.myReserveHeader.type = BR_TYPE_ROAD then
								objArr.addExclusive(reserveDetail);
							endif;
						endif;
					endif;
					
				elseif vbtsi.myBooking &lt;&gt; null then
					//Do we need to worry about roll booking
					/*foreach splitRollEvt in self.allSplitRollEventsAsOld do
						if splitRollEvt.isKindOf(CMEVT_RollBooking) then
							if self.bookingReference &lt;&gt; splitRollEvt.myNewBookingReference.bookingReference then	//31 Oct 2014	NDL	Par 32671
								return app.getErrorString2(Bookin_been_rolled, self.bookingReference, splitRollEvt.myNewBookingReference.bookingReference);
							endif;
						endif;
					endforeach;*/
					
					foreach bookingRefItem in vbtsi.myBooking.allBookingRefItems do
						if bookingRefItem.quantity &lt; 1 and bookingRefItem.weight = 0 then
							continue;
						endif;
						
						objArr.addExclusive(bookingRefItem);
					endforeach;
					
				elseif vbtsi.myReserveDetails &lt;&gt; null then
					objArr.addExclusive(vbtsi.myReserveDetails);
					
				elseif vbtsi.myBulkRelease &lt;&gt; null then
					foreach reserveDetail in vbtsi.myBulkRelease.allReserveDetails do
						if not vbtsi.myBulkRelease.releaseByType and reserveDetail.hasOutstanding() then
							objArr.addExclusive(vbtsi.myReserveDetails);
						elseif vbtsi.myBulkRelease.releaseByType then
							if vbtsi.myReserveDetails &lt;&gt; null then				//08.9.2023 navhl20 #60417
								objArr.addExclusive(vbtsi.myReserveDetails);
							elseif reserveDetail &lt;&gt; null then
								objArr.addExclusive(reserveDetail);
							endif;
						endif;
					endforeach;
					
				endif;
				
			endforeach;
			
		endif;
	endif;
	
	/// Bring up the picker window if is needed--------------------
	if objArr.isEmpty then
		return null;
		
	elseif objArr.size = 1 then
		if objArr.first.isKindOf(CM_BookingRef) then
			bookingRef := objArr.first.CM_BookingRef;
			if objArr.first.CM_BookingRef.allBookingRefItems.size = 1 then
				return objArr.first.CM_BookingRef.allBookingRefItems.first.CM_BookingRefItem;
			else
				_pickerShown := true;
				self.pickerWindowForObject(objArr, allowMultiSelect, selectedObject, _callingForm, false);
				return selectedObject;
			endif;
		elseif objArr.first.isKindOf(CM_ReserveDetail) then						//08.9.2023 navhl20 #60417
			reserveDetail := objArr.first.CM_ReserveDetail;
			return reserveDetail;
		else
			return objArr.first.CM_Object;
		endif;
	else
		_pickerShown := true;
		self.pickerWindowForObject(objArr, allowMultiSelect, selectedObject, _callingForm, false);
		return selectedObject;
	endif;
	
	
epilog
	if objArr &lt;&gt; null then
		delete objArr;
	endif;	
	
end;</source>
        <Parameter name="_vbt" type="CM_VehicleBookingTerminal"/>
        <Parameter name="_pCode" type="String"/>
        <Parameter name="_callingForm" type="CM_BaseForm"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_pickerShown" type="Boolean" usage="output"/>
        <ReturnType type="Object"/>
    </JadeMethod>
