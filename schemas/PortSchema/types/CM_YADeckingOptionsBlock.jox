    <JadeMethod name="applyDeckingRulesToCellOrder" id="4f8ac115-c9f1-4cb3-a4b5-526b8ee66221">
        <source>applyDeckingRulesToCellOrder();
//----------------------------------------------------------------
//	Created:	26 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin	
	inheritMethod();
/*	no longer need to do this - the order was set on the proxy and should now be on the real

	//IN custom
	if _deckingOptions.isCustomIn then
		_deckingOptions.allYALocationCellsIn.clear;
		_cmifDeckingOptions.allYALocnCellsInCustom.copy(self.myYABlock.allYALocationCellsIn);
	endif;
	//OUT custom
	if _deckingOptions.isCustomOut then
		_deckingOptions.allYALocationCellsOut.clear;
		_cmifDeckingOptions.allYALocnCellsOutCustom.copy(self.myYABlock.allYALocationCellsOut);
	endif;
*/	
	//do non-custom options
	self.myYABlock.applyDeckingRulesToCellOrder();

end;</source>
    </JadeMethod>
    <JadeMethod name="copyInRules" id="a7e00107-3e2b-4318-b90c-155cbb277b0f">
        <updating/>
        <source>copyInRules(_copyFrom: CM_YADeckingOptions) updating;
//----------------------------------------------------------------
//	Created:	11 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	yc		: CM_YardController;
begin
	
	if self.allYALocationCellsIn.isEmpty then
		foreach yc in self.myYABlock.allYardControllers do
			yc.allYAYardLocationCells.copy(self.allYALocationCellsIn);
		endforeach;
	endif;
	
	inheritMethod(_copyFrom);
end;</source>
        <Parameter name="_copyFrom" type="CM_YADeckingOptions"/>
    </JadeMethod>
    <JadeMethod name="copyOutRules" id="8d4e417f-b82d-4571-a79a-34187c92db79">
        <source>copyOutRules(_copyFrom: CM_YADeckingOptions);
//----------------------------------------------------------------
//	Created:	11 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	yc		: CM_YardController;
begin
	
	if self.allYALocationCellsOut.isEmpty then
		foreach yc in self.myYABlock.allYardControllers do
			yc.allYAYardLocationCells.copy(self.allYALocationCellsOut);
		endforeach;
	endif;

	inheritMethod(_copyFrom);
end;</source>
        <Parameter name="_copyFrom" type="CM_YADeckingOptions"/>
    </JadeMethod>
    <JadeMethod name="getDeckingOptionsForDefault" id="11eba42d-fecb-4bec-9606-2ea3ef568453">
        <source>getDeckingOptionsForDefault(): CM_YADeckingOptions;
//----------------------------------------------------------------
//	Created:	07 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridObject		: CM_GridObject;
	gridArea		: CM_GridArea;
begin
	//return decking options for the row or area if no row options
	
	if self.myYABlock &lt;&gt; null then
		gridObject := self.myYABlock.getGridObject();
		if gridObject &lt;&gt; null 
		and gridObject.myDeckingOptions &lt;&gt; null then
			return gridObject.myDeckingOptions;
		endif;
	endif;
	
	gridArea := self.getGridArea();
	if gridArea &lt;&gt; null 
	and gridArea.myYADeckingOptions &lt;&gt; null then
		return gridArea.myYADeckingOptions;
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_YADeckingOptions"/>
    </JadeMethod>
    <JadeMethod name="getDefaultRuleIn" id="3ec69412-6145-4272-9082-eea5b1b8776d">
        <source>getDefaultRuleIn(_height: Integer): Integer;
//----------------------------------------------------------------
//	Created:	07 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridArea	: CM_GridArea;
	rule		: CM_YADeckingRule;
begin
	
	gridArea := self.getGridArea;
	rule := self.getNextLevelRule(1, true);
	
	if self.myYABlock &lt;&gt; null then
		//self.myYABlock.
		return Height_Then_Next_Row_Pos;
		
	elseif gridArea &lt;&gt; null then
		rule := gridArea.myYADeckingOptions.allDeckingRulesIn.getAtKeyLeq(_height);
		if rule &lt;&gt; null then
			return rule.deckingRuleType;
		endif;
	endif;
	
	return inheritMethod(_height);
	
end;</source>
        <Parameter name="_height" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefaultRuleOut" id="529a23e7-a2a0-42a4-b3e5-052adbd78fe1">
        <source>getDefaultRuleOut(_height: Integer): Integer;
//----------------------------------------------------------------
//	Created:	07 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridArea	: CM_GridArea;
	rule		: CM_YADeckingRule;
begin
	
	gridArea := self.getGridArea;
	if gridArea &lt;&gt; null
	and gridArea.myYADeckingOptions &lt;&gt; null then
		rule := gridArea.myYADeckingOptions.allDeckingRulesOut.getAtKeyGeq(_height);
		if rule &lt;&gt; null then
			return rule.deckingRuleType;
		endif;
	endif;
	
	return DeckingRule_ReverseOfOther;
	
end;</source>
        <Parameter name="_height" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
