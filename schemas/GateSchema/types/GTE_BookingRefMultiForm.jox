    <JadeMethod name="doNextBookRefItem" id="590bd634-c1a3-4197-a838-eccf5b48534c">
        <updating/>
        <source>doNextBookRefItem()updating;
/*
	Created on 19 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if self.itemEditMode &lt;&gt; Mode_Add then
		return;
	endif;
	doOKBookRefItem(false);
	doNewBookRefItem;

end;</source>
    </JadeMethod>
    <JadeMethod name="doOKBookRefItem" id="6b731a16-e5b8-48d1-86a0-8de0629726e7">
        <updating/>
        <source>doOKBookRefItem(_blnClose : Boolean)updating;
/*	
	Created on 15 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	passport : CM_Passport;
	
begin
	passport := app.myPassport;
	// 24449 self.myCurrentBRItemInterface is null, unsure why but handle it
	if self.myCurrentBRItemInterface &lt;&gt; null then
		self.setBRItemInterfaceFromTable(self.myCurrentBRItemInterface);
	
		if self.itemEditMode = self.Mode_Add then
			self.myCurrentBRItemInterface.validateForCreate(passport);
		else
			self.myCurrentBRItemInterface.validateForUpdate(passport);
		endif;
	
		if passport.hasErrors() then
			return;
		endif;
	endif;
	
	self.loadBookRefItems(null, true, false);  // load transient items to the 'text' table
	self.myCurrentBRItemInterface := null;
	tblExtra.clearValues();
//	self.setMultiChkEnablement();	//05 Nov 2012	NDL	Par 29859
	
	if _blnClose then
		self.bookRefItemDockbarHide();
		self.itemEditMode := self.Mode_View;
	endif;
end;</source>
        <Parameter name="_blnClose" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOpenReconForm" id="f3b54ddb-da53-49d5-b7a2-7e685a01f403">
        <source>doOpenReconForm(_booking : CM_BookingRef);
// 18 Mar 2010	cnwcs5	Fix exception when reconciliation form is opened for booking without a voyage
vars
	form : CMUI_ReconBookingForm;

begin
	if _booking.myVoyage = null then										// 18/03/2010 cnwcs5
		app.raiseCMException (No_Voyage_No_Booking_Reconcile, null, null);	// 18/03/2010 cnwcs5
	endif;																	// 18/03/2010 cnwcs5
	
	form := app.loadForm(CMUI_ReconBookingForm,
									self.myAssistant.class,
									false,
									false,
									false,
									self.myTerminal, null).CMUI_ReconBookingForm;
	form.setBooking(_booking);
	form.show;
end;</source>
        <Parameter name="_booking" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="doPrint" id="44286d2f-e231-4fbf-ad63-3f2f6cb35cb4">
        <updating/>
        <source>doPrint() updating;
/*
----------   ----------  --------------------------------------------------
Created:	26 June 2006 By cnwth2

Purpose:	

Changed On	Changed By	Reason
----------	----------	--------------------------------------------------
16 Mar 2010	consw1		PAR #22886 - Leaking report transients
*/
vars
	termDict 	: CM_TerminalByCodeDict;
	jadeReport	: JadeReport;
	jrwManager	: JadeReportWriterManager;
	jrwReport	: JadeReportWriterReport;
	obj			: Object;
	jrwTrans 	: CM_JRWBookingRef;
	bookingRef		: CM_BookingRef;
	qryReport		: CM_QryReport;
	ls				: Boolean;
	totalExpected,
	docType			: Integer;
begin
	if tblData.allSelectedObjects.isEmpty then
		app.msgBox("You do not have a booking reference selected", "Nothing Selected", MsgBox_Exclamation_Mark_Icon);	
		return;
	endif;
	
	docType := app.printer.getDefaultDocumentType();
	app.printer.abort();
	create jadeReport transient;
	jadeReport.description := "Booking Reference List";
	app.printer.setReport(jadeReport);
	
	jrwManager := app.createReportWriterManager();
	jrwTrans := app.myQAFilter.createJRWTransient(CM_JRWBookingRef).CM_JRWBookingRef;

	create termDict transient;
	termDict.add(app.myPassport.myTerminal);
	jrwTrans.setAllTerminals(termDict);
	//tblData.allSelectedObjects.copy(jrwTrans.allBookingRefs);
	//th2 - requires loop instead to populate totalQuantityExpected
	jrwTrans.totalQuantityExpected := 0; // dh 28/11/2007 par 15407
	jrwTrans.totalWeightExpected := 0;  // dh 28/11/2007 par 15407
	foreach obj in tblData.allSelectedObjects do
		if (not CM_BookingRef.hasInstance(obj)) then
			continue;
		endif;
		
		bookingRef := obj.CM_BookingRef;
		jrwTrans.allBookingRefs.add(bookingRef);
//		jrwTrans.totalQuantityExpected := jrwTrans.totalQuantityExpected + bookingRef.quantity;
//		jrwTrans.totalWeightExpected := jrwTrans.totalWeightExpected + bookingRef.weight;
// dh 29/2/2008 ccms 1618 replaced these to allow for individual book ref items
		jrwTrans.totalQuantityExpected := jrwTrans.totalQuantityExpected + bookingRef.getTotalQuantity();
		jrwTrans.totalWeightExpected := jrwTrans.totalWeightExpected + bookingRef.getTotalWeight();
	endforeach;
	//test that the design exists
	qryReport := app.myRoot.getQryReport("Booking Reference List");
	jrwReport := jrwManager.getReport(qryReport.jrwReportName.first);
	if jrwReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "report with name " &amp; qryReport.jrwReportName.first &amp; " does not exist");
		return;
	endif;
	
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	
	// params = documentType; orientation; copies; topOfPage; bottomOfPage; leftMargin; rightMargin; borderWidth; collate; duplex
	jrwReport.setPageOptions(docType, Print_Landscape, 1, 0, 0, 0, 20, 0, false, 0);
	jrwReport.setPreviewOptions(false, true, false, false, null);

//	app.cmsBeginLoad(ls);
	jrwReport.run;

	app.printPreview(jadeReport, true);
		
epilog
	delete jrwReport;
	delete jrwTrans;
	delete jrwManager;
	delete termDict;
//	app.cmsEndLoad(ls);
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="3514cb9b-c96c-4745-81d5-a3312400c7bc">
        <updating/>
        <source>doRefresh() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2013	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod();
	
	if self.allColumnFilters &lt;&gt; null and not self.allColumnFilters.isEmpty then
		if self.allColumnFilters.includesFiltersFor( self.tblData ) then
			self.allColumnFilters.replaceAllFiltersForTable( self.tblData, null );
			self.applyColumnFilter( self.tblData );
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRollBooking" id="fdb73ab0-cabb-429c-81ed-de23e12def2b">
        <updating/>
        <source>doRollBooking() updating, protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date			Who		Reason
========================================================
25 March 2010	cnwcs5	par 22602 - refactored code
*/

vars
	form			: Form;
	allBookingRefs	: CM_BookingRefSet;
	bookingRef		: CM_BookingRef;
begin
	create allBookingRefs transient;
	tblData.allSelectedObjects.copy(allBookingRefs);
	
	if allBookingRefs.isEmpty() then
		return;
	endif;

	foreach bookingRef in allBookingRefs do 
		// par 22602 - start
		if bookingRef.isRolledOrClosed then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Attempt to roll a rolled or closed booking');
			return;
		endif;
		// par 22602 - end
		//-cnwml2 PAR24322
		/*if bookingRef.myVoyage = null or bookingRef.myVoyage.isNullVoyage then
			app.raiseCMException1(Must_spec_voyage_before_split, bookingRef.bookingReference.asStringJMT(), null, null);
			return;
		endif;*/
	endforeach;
	
	if allBookingRefs.size = 1 then		// not bulk mode
		self.openSplitRollForm(false);
	else								// bulk roll mode
		form	:= 	app.loadForm(GTE_BookingRollSplitForm, GTE_Assistant, false, false, true, self.myTerminal, null);
		form.GTE_BookingRollSplitForm.setIsBookingBulkRollMode(allBookingRefs);
		
		modalResult := form.showModal;
	endif;
epilog
	delete allBookingRefs;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="fc678cb2-75c2-4b50-8384-5a4d3502e44c">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     01 March 2001 by cnwrs2
//
// Purpose:     Standard method to update the object being edited.
//
// Parameters:  None
//
// Returns:     True if the update was successful, otherwise false.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin 
	return  self.saveBookingRef();
epilog
	itemEditMode := Mode_View;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetReconciled" id="125c0968-f599-4db0-8e23-34f29d4f4b53">
        <source>doSetReconciled();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2013	cnwrd1	Initial creation

*/

vars
	form			: Form;
	allBookingRefs	: CM_BookingRefSet;
	bookingRef		: CM_BookingRef;
	result			: Integer;
begin

	create allBookingRefs transient;
	tblData.allSelectedObjects.copy(allBookingRefs);
	

	
	foreach bookingRef in allBookingRefs do 
		
		// do some validation/filtering here?
		/*
		if bookingRef.isRolledOrClosed then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Attempt to roll a rolled or closed booking');
			return;
		endif;*/

	endforeach;
	
	if allBookingRefs.isEmpty then
		return;
	endif;


	while true do
		app.myTrxUA.trxUpdateBookingsSetReconciled( allBookingRefs, null, null, app.myPassport);

		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Booking', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog
	delete allBookingRefs;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doShowBookingDiscrepancy" id="8e25b6b7-a3a1-473d-8434-ae5ed538ceec">
