    <JadeMethod name="doMnuTaskAdd" id="ecbff38f-4f0e-4451-b504-55fa17a9ff3d">
        <updating/>
        <source>doMnuTaskAdd(menuItem : MenuItem input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------

vars

	lTI	: CM_TrackedItem;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin
	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuTaskAdd then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskAdd(lTI, menuItem.index, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Add Todo Task', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskComplete" id="da19630b-429a-43ba-9ad1-46232f488389">
        <updating/>
        <source>doMnuTaskComplete(menuItem : MenuItem input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------

vars

	lTI	: CM_TrackedItem;
	realTiSet : CM_TISet;
	pxyTiSet : CM_TISet;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	toDoTaskDesc : CM_ToDoTaskDesc;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	lTI := menuItem.userObject.CM_TrackedItem;
	if lTI = null or menuItem = self.mnuTaskComplete then
		return;
	endif;
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[menuItem.index];
	
	create realTiSet transient;
	realTiSet.add(lTI);

	//+cnwml2 MSL CCMS 1017		
	create pxyTiSet transient;
	
	//31 Dec 2009 NDL CCMS MES 1006	- Common code migrated up to assistant
	if not self.myAssistant.doTaskProxySetForComplete( menuItem.index, pxyTiSet, lTI, realTiSet, resourceUsageProxys) = IDOK then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(toDoTaskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Voyage Operations', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog

	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;
	delete realTiSet;

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMove_Autoplan" id="f1e82944-3034-4997-96cd-435cfb6b33e5">
        <updating/>
        <source>doMove_Autoplan(_all : Boolean) updating;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	wlesWithWarnings,
	wleArray : CM_WLEArray;
	result	: Integer;
	wle : CM_WorkListEntry;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	app.myPassport.myActivityCapture.startCaptureDebugMisc('Auto plan job');
	
	create wleArray transient;
	create wlesWithWarnings transient;	
	
	if _all then
		self.getAllWLEsInCurrentTbl(wleArray);
	else
		self.getAllSelectedWLEs(wleArray);
	endif;

	while true do
		app.myTrxUA.trxUpdateWLEsAutoplan(wleArray, wlesWithWarnings, PLANNING_MODE, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			if app.myPassport.allErrorWarnings.size = 1 and app.myPassport.returnCode = INFO_NO_AUTOPLAN then
				//do show it here, ask Q below.
				result := 1;				
			else
				result := app.showErrorWarningDialog('Voyage Auto-Planning', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			endif;
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				wleArray.clear;
				wlesWithWarnings.copy(wleArray);
				wlesWithWarnings.clear;	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
	//30 Oct 2015	NDL	Par 37094
	foreach wle in wleArray do
		if wle.myTrackedItem = null then
			//Its a director task, these don't refresh properly on their own.
			self.doNotificationStorage(wle, self.Mode_Update);
		endif;
	endforeach;

	if app.myPassport.returnCode = INFO_NO_AUTOPLAN then
		if app.msgBox(app.getErrorString(app.myPassport.returnCode), "Information",
					 MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, null);			
		endif;
	endif;
	
epilog
	delete wlesWithWarnings;
	delete wleArray;
	app.mousePointer := MousePointer_Default;
	app.myPassport.myActivityCapture.stopCaptureDebugMisc();
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMove_ForMode" id="991c0dad-6d72-4dfe-a4db-0fc054788cb6">
        <updating/>
        <source>doMove_ForMode(_moveMode : Integer; _all : Boolean) updating;
//-----------------------------------------
//Created: May 2003 By: cnwgd1
//-----------------------------------------
//15/08/2019 	JLGNS1	ChangeRequest 45889: PEN - Move All Command in Road Operation
vars
	wleArray,
	wlesWithWarnings : CM_WLEArray;	
	result	: Integer;
	queueInOrder : Boolean;// ### PAR9342
	aWLE : CM_WorkListEntry;
	queuedWles : CM_WLEArray;
	effectiveTimeStamp : TimeStamp;
begin

	if self.myCurrentTableWLE = null then
		return;
	endif;
	app.mousePointer := MousePointer_HourGlass;
	
	queueInOrder := self.chkQInOrder.value;// ### PAR9342
	
	create wleArray transient;
	if _all then
			
		if _moveMode = REAL_MODE then																																//ChangeRequest 45889
			if 	app.msgBox(app.getErrorString(Sure_want_move)  ,app.getErrorString(WLES_MOVE_ALL),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then//ChangeRequest 45889
				return;																																				//ChangeRequest 45889
			endif;																																					//ChangeRequest 45889
		endif;																																						//ChangeRequest 45889
		
		self.getAllWLEsInCurrentTbl(wleArray);
		//19 Jan 2012	NDL	Par 28951 - drop any already queued..
		//if _moveMode = QUEUE_MODE then
			create queuedWles transient;
			foreach aWLE in wleArray do
				if _moveMode = QUEUE_MODE and aWLE.isQueued then 
					queuedWles.add(aWLE);
					continue;
				endif;
				
				if aWLE.isCompleteForJob and aWLE.myFutureMove = null then 
					queuedWles.add(aWLE);
					continue;
				endif;
			endforeach;
			foreach aWLE in queuedWles do
				wleArray.remove(aWLE);
			endforeach;
		//endif;
		
	else
		self.getAllSelectedWLEs(wleArray);
	endif;
	
	// CCMS 1067 Not ready yet. Just experiment at this stage.
	if _moveMode = QUEUE_MODE and self.chkQTwinReverse.value then
		self.queueTwinLiftsReversed(wleArray);
	endif;
	
	// TFS 3472
	if self.frmToolbar2.visible then
		effectiveTimeStamp.setDate(self.txtEffectiveDate.getDate());
		effectiveTimeStamp.setTime(self.txtEffectiveTime.getTime());
	endif;
	
	create wlesWithWarnings transient;
	
	while true do
		app.myTrxUA.trxUpdateWLEsDoMove(wleArray, wlesWithWarnings, _moveMode, queueInOrder,effectiveTimeStamp, app.myPassport);

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			if app.myPassport.allErrorWarnings.size = 1 and app.myPassport.returnCode = INFO_NO_AUTOPLAN then
				//don't show alerts here, Question asked below, if they wont' to see alerts or not.
				result := 1;				
			elseif queueInOrder then
				//Don't allow them to save ones with warnings if queue in order is ticked
				result := app.showErrorWarningDialog('Voyage Operations Move', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);			
			else
				result := app.showErrorWarningDialog('Voyage Operations Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			endif;
			if result = IDOK then

				app.mousePointer := MousePointer_HourGlass;
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;

				// only reprocess the wles that had warnings.
				wleArray.clear;
				wlesWithWarnings.copy(wleArray);				
				wlesWithWarnings.clear;	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

	if app.myPassport.returnCode = INFO_NO_AUTOPLAN then
		if app.msgBox(app.getErrorString(app.myPassport.returnCode), "Information",
					 MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, null);			
		endif;
	endif;
	
epilog
	delete wlesWithWarnings;
	delete wleArray;
	delete queuedWles;

	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMove_Unplan" id="5b83bfea-c791-487b-a07d-39f1b7ec02e4">
        <updating/>
        <source>doMove_Unplan(_all : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		set self.myCurrentTrackedItem, self.myCurrentWLE and self.myCurrentLocation
//				and this will lan the TI to the location and update the status on the WLE
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 7/5/3		cnwgd1		to take a set of wle's
// ---------------------------------------------------------------------------

vars
	result : Integer;
	wlesWithWarnings,
	wleArray : CM_WLEArray;
begin
	app.mousePointer := MousePointer_HourGlass;	
	create wleArray transient;
	create wlesWithWarnings transient;
		
	if _all then
		self.getAllWLEsInCurrentTbl(wleArray);
	else
		self.getAllSelectedWLEs(wleArray);
	endif;

	while true do
		app.myTrxUA.trxUpdateWLEsUnplan(wleArray, wlesWithWarnings, NO_MODE, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				
				// only reprocess the wles that had warnings.
				wleArray.clear;
				wlesWithWarnings.copy(wleArray);
				wlesWithWarnings.clear;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog 
	delete wleArray;
	delete wlesWithWarnings;
	app.mousePointer := MousePointer_Default;		
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMove_Unqueue" id="112b3e7b-d1ae-4273-bc0d-6383019b7ba6">
        <updating/>
        <source>doMove_Unqueue(_all : Boolean) updating;
//-----------------------------------------
//Created: May 2003 By: cnwgd1
//-----------------------------------------

vars
