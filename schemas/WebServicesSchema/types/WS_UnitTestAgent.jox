/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2024	navkc1	CR 63402 Task 63403: Jade - REST API getProformaDetailsForDebtor
29-Oct-2025	navtr3 MTN-36371 [MasterTerminalAPI] Verbose Unauthenticated Error Objects Expose API Schema
*/

vars
	webService			: MasterTerminalAPIService;
	response 			: WS_Response;						//navtr3 29-Oct-2025 MTN-36371
	dict 				: WS_QueryStringParamDict;
	jsonHelper 			: JMTJadeJson;
	ref 				: String;
	wsHeader			: WS_ProformaHeader;
	wsDetails			: WS_ProformaDetails;
begin
	
	create webService transient;
	
	self.loginREST(webService);
	
	webService.qsData.parseNameValuePair(_queryParamString);
	response := webService.getProformaDetails();
	
	if response.allErrors.isNotEmpty() then
		return response.allErrors.first().text;
	endif;
	
	if response.allInfo.isNotEmpty() then
		return response.allInfo.first().text;
	endif;
	
	create jsonHelper transient;
	_response := jsonHelper.generateJson(response, JadeJson.Format_Json_Microsoft);
	
	wsHeader := response.WS_ProformaDetailsResponse.allProformaHeaders.last();			//navtr3 29-Oct-2025 MTN-36371
	if wsHeader &lt;&gt; null then
		wsDetails := wsHeader.allProformaDetails.last();
		if wsDetails &lt;&gt; null then
			_totalAmount := wsDetails.amountValue;
		endif;
	endif;
	
	return null;
	
	ref := CM_UnitTestAgent::wsRESTGetProformaHeader.name;

epilog
	dict := webService.qsData;
	dict.purge();
	if webService.objectsToBeDeleted.isNotEmpty() then
		webService.objectsToBeDeleted.purge();
	endif;
	delete jsonHelper;
	delete webService;
end;</source>
