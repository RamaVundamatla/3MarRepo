    <JadeMethod name="doReeval" id="a162801c-24d3-4ada-9080-e76a915f505a">
        <updating/>
        <source>doReeval() updating;
//	Nov 2010	cnwjre1		par 26107 CCMS 2020 Invoice storage by first/last cargo item on/off voyage 
/*	Allow re-evaluation of storage and reefer monitoring charges after voyage shipExchangeCompleteDT has been set,
	in case any are dependent on this.
*/
vars
	shipTrans	: CM_TITransaction;
	tiTrans		: CM_TITransaction;
	ti		: CM_TrackedItem;
	controller : CMIF_TiTransactionResync;
	completedDate	: TimeStamp;
	theReturn : Integer;
begin
	app.mousePointer := MousePointer_HourGlass;  	// JLGAB1 18FEB21
  	
	completedDate := self.myCurrentVoyage.shipExchangeCompleteDT;
	create controller transient;
	foreach shipTrans in self.myCurrentVoyage.allTITransactionsByTypeDT do
		ti := shipTrans.myTrackedItem;
		foreach tiTrans in ti.allTransactions do
			if tiTrans.isVoyageVisitRelevant() and
			   tiTrans.dateTime &lt;= completedDate then
				if not controller.allTransactions.includes(tiTrans) then
					controller.allTransactions.add(tiTrans);
				endif;
			endif;
		endforeach;
	endforeach;
	
	if controller.allTransactions.size &gt; 0 then
		while true do
			app.myTrxUA.trxUpdateRsyncTrans(controller, app.myPassport);
			if app.myPassport.trxCompletedOK then
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog("Voyage Transaction Resync", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
					theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			endif;
			break;
		endwhile;
	endif;
epilog
	delete controller;

	app.mousePointer := MousePointer_Default;  	// JLGAB1 18FEB21
end;</source>
    </JadeMethod>
