    <JadeMethod name="lstAreas_pictureClick" id="b2d3c5d6-9f3d-4583-8fe0-1c8823642757">
        <controlMethod name="ListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstAreas_pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
03 November 2008	consw1	Initial creation

*/

vars

begin
	listbox.itemExpanded[picIndex] := not listbox.itemExpanded[picIndex];
epilog

end;</source>
