    <JadeMethod name="utlCreateEDIBayPlan" id="83684f8a-7c06-4502-aaee-1ee48cb7cf34">
        <updating/>
        <source>utlCreateEDIBayPlan(_ediData : CM_EDIData input; _ediTIs : CM_EDITIById; _partialUpdate : Boolean; _control : CMIF_TIUpdateController input; _finalUpdate : Boolean; _passport : CM_Passport input) updating;

// cmwrs1 feb 2006 cnwrs1
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 12 Mar 2018	jlgrs1	TFS 37484 - QNS Allow DB Loading of Bay Plan files
// 20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
vars
	planController : CM_VoyageEDIBayPlanController;
	moveController : CMIF_MoveController;
	location : CM_LocationsController;
	ti : CM_TrackedItem;
	index : Integer;
	startPos : Integer;
	tiCount : Integer;
	foundHeight : Integer;
	strArray : StringArray;
	totalTIs : Integer;
	tmpVoyage : CM_Voyage;
	progressTS : TimeStamp;
	ediTI : CM_EDITrackedItem;
	errorSet : CM_ErrorSet;
begin
	create errorSet transient;
	
	tmpVoyage := _control.myVoyage;
	if tmpVoyage = null then
		return;
	endif;
	
	if _ediData &lt;&gt; null and
	   _ediData.myBayPlanController &lt;&gt; null  and
	   _ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_DBLOADED then
		planController := _ediData.myBayPlanController;
	endif;
	if planController = null then
		planController := tmpVoyage.createEDIBayPlan(_control.comment[1:100], _control.myUserObject.CM_EDIData);
	endif;
	if _passport.hasErrors() then
		return;
	endif;
	
	index := planController.getMyEDIIndex();

	self.createTrackedItems(_control, _passport);
	
	if not _partialUpdate and
	   _passport.hasErrors() then
		return;
	endif;
	app.myPassport.moveErrorsToSet(errorSet);
			
	create strArray transient;
	create moveController transient;
	
// PAR 33644	if tmpVoyage.isNonPlannedVoyage then
	if tmpVoyage.isHOLDSorSHIP() then
		moveController.setMoveMode(REAL_MODE);
	else
		moveController.setMoveMode(PLANNING_MODE);
	endif;
	
	moveController.isSystemMove := true;
	moveController.isEDIMove := true;//added by cnwyl1 for par 12912
	_passport.warningsAcknowledged := true;
	
	startPos := tmpVoyage.code.length + 2;
	 
	totalTIs := _control.allPersistentTIs.size;
	tiCount := null;
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	_ediData.updateProgress(progressTS, "Populating Bay Plan. " &amp; tiCount.String &amp; "/" &amp; totalTIs.String, totalTIs, tiCount, true, _passport);

	foreach ti in _control.allPersistentTIs do
		tiCount := tiCount + 1;
		_ediData.updateProgress(progressTS, "Populating Bay Plan. " &amp; tiCount.String &amp; "/" &amp; totalTIs.String, totalTIs, tiCount, false, _passport);
		
		strArray.clear;
		if _ediTIs &lt;&gt; null then
			ediTI := _ediTIs[ti.id];
		endif;
		if ti.locationId.length &gt;= startPos then
			strArray.add(ti.locationId[startPos:end]);
		else
			strArray.add(ti.locationId);	//cnwrs1 ccms1009 the location id does not have voyagecode in front 
		endif;
		
		tmpVoyage.findLocation(strArray, false, location, foundHeight);

		if location = null then
			app.raiseCMException1(ERR_INVALID_STOWAGE, ti.locationId &amp; ", for ti "&amp; ti.id, 'locationId', null);
		endif;
		
		moveController.setMyToSecondaryLocations(null);
		moveController.setMyTrackedItem(ti);
		moveController.setMyToPrimaryLocation(location);
		moveController.setIndexForEDIBayPlan(index);
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
		app.myPassport.moveErrorsToSet(errorSet);
		if ediTI &lt;&gt; null then
			if _passport.noErrors then
				ediTI.setStatus(CM_EDITrackedItem.EDI_STATUS_DBLOADED);
			else
				ediTI.setStatus(CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS);
			endif;
		endif;

	endforeach;
	app.myPassport.addErrorsFromSet(errorSet);	//restore current errors back to

	_ediData.updateProgress(progressTS, "Populating Bay Plan. " &amp; tiCount.String &amp; "/" &amp; totalTIs.String, totalTIs, tiCount, true, _passport);
	
	if _finalUpdate then
		tmpVoyage.setRemarks(app.getErrorString(EDI) &amp; " #" &amp; index.String &amp; " " &amp; app.getErrorString(Message) &amp; " " &amp; app.getErrorString(Load) &amp; " " &amp; app.getErrorString(Completed), true);
	endif;
	
	_ediData.updateProgress(progressTS, "Committing changes...", totalTIs, tiCount, true, _passport);
	
	if _passport.noErrors then
		planController.setEDIStatus(CM_EDIFile.EDI_STATUS_DBLOADED);
	endif;
epilog
	delete moveController;
	delete strArray;
	delete errorSet;
end;</source>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_ediTIs" type="CM_EDITIById"/>
        <Parameter name="_partialUpdate" type="Boolean"/>
        <Parameter name="_control" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_finalUpdate" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateEDIBayPlanCusCar" id="c48c7f1d-d7c7-4d04-95ea-dc3dbf99f3b4">
        <updating/>
        <source>utlCreateEDIBayPlanCusCar(_control : CMIF_TIUpdateController input; _ediData : CM_EDIData input; _passport : CM_Passport input) updating;

// cmwrs1 June 2006 par 11961 ccms 1022
// 08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
vars
	planController : CM_VoyageEDIBayPlanController;
	moveController : CMIF_MoveController;
	location : CM_LocationsController;
	ti : CM_TrackedItem;
	index : Integer;
	startPos : Integer;
	tiCount : Integer;
	foundHeight : Integer;
	strArray : StringArray;
	totalTIs : Integer;
	updateProgress : Boolean;
	progressTS : TimeStamp;
begin
	planController := _control.myVoyage.createEDIBayPlan(_control.comment[1:100], _control.myUserObject.CM_EDIData);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	index := planController.getMyEDIIndex();

	self.createTrackedItemsCusCar(_control, _passport);
	
	if _passport.hasErrors() then
		return;
	endif;
			
	create strArray transient;
	create moveController transient;
	
// PAR 33644 MOVED DOWN to TI LOOP
// PAR 33644	if _control.myVoyage.isNonPlannedVoyage then
// PAR 33644		moveController.setMoveMode(REAL_MODE);
// PAR 33644	else
// PAR 33644		moveController.setMoveMode(PLANNING_MODE);
// PAR 33644	endif;
	
	moveController.isSystemMove := true;
	_passport.warningsAcknowledged := true;
	
	startPos := _control.myVoyage.code.length + 2;
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	totalTIs := _control.allPersistentTIs.size;
	tiCount := null;
	_ediData.updateProgress(progressTS, "Populating Bay Plan. " &amp; tiCount.String &amp; "/" &amp; totalTIs.String, totalTIs, tiCount, true, _passport);

	foreach ti in _control.allPersistentTIs do
		tiCount := tiCount + 1;
		_ediData.updateProgress(progressTS, "Populating Bay Plan. " &amp; tiCount.String &amp; "/" &amp; totalTIs.String, totalTIs, tiCount, false, _passport);
		
		strArray.clear;

		if ti.locationId.length &gt;= startPos then
			strArray.add(ti.locationId[startPos:end]);
		endif;
		
		 _control.myVoyage.findLocation(strArray, false, location, foundHeight);

		if location = null then // cnwrs1 dec 2006 could crash if strArray was MT 
			app.raiseCMException1(ERR_INVALID_STOWAGE, ti.locationId &amp; ", for ti "&amp; ti.id, 'locationId', null);
		endif;
		
		// PAR 33644
		if location.isShipBlockStack() then
			moveController.setMoveMode(REAL_MODE);
		else
			moveController.setMoveMode(PLANNING_MODE);
		endif;
		
		moveController.setMyToSecondaryLocations(null);
		moveController.setMyTrackedItem(ti);
		moveController.setMyToPrimaryLocation(location);
		moveController.setIndexForEDIBayPlan(index);
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
		
	endforeach;

	_ediData.updateProgress(progressTS, "Populating Bay Plan. " &amp; tiCount.String &amp; "/" &amp; totalTIs.String, totalTIs, tiCount, true, _passport);

	_control.myVoyage.setRemarks(app.getErrorString(EDI) &amp; " #" &amp; index.String &amp; " " &amp; app.getErrorString(Message) &amp; " " &amp; app.getErrorString(Load) &amp; " " &amp; app.getErrorString(Completed), true);

	_ediData.updateProgress(progressTS, "Committing changes...", totalTIs, tiCount, true, _passport);
epilog
	delete moveController;
	delete strArray;
end;</source>
        <Parameter name="_control" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateEDIBayPlanPartial" id="d73f895c-1447-40fc-8955-94634c95a5bd">
        <updating/>
        <source>utlCreateEDIBayPlanPartial(_ti : CM_TrackedItem input; _ediTI : CM_EDITrackedItem input; _control : CMIF_TIUpdateController input; _planControllerIndex : Integer; _currentTIs : CM_TIByIdCargoTypeDict; _passport : CM_Passport input) updating;
//
// 22 Mar 2018	jlgrs1	TFS 37484 - QNS Allow DB Loading of Bay Plan files
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	moveController : CMIF_MoveController;
	location : CM_LocationsController;
	realTI : CM_TrackedItem;
	otherTI : CM_TrackedItem;
	startPos : Integer;
	tiCount : Integer;
	foundHeight : Integer;
	strArray : StringArray;
	tmpVoyage : CM_Voyage;
	error : CM_Error;
	ediData : CM_EDIData;
	monitor : CMIF_Monitor;
	futureMove : CM_FutureMove;
begin
	tmpVoyage := _control.myVoyage;
	if tmpVoyage = null then
		return;
	endif;
	// save off the monitor and put back in epilog
	monitor := _passport.myCMIFMonitor;
	_passport.setMyCMIFMonitor(null);
	ediData := _ediTI.myEDIData;
	_ti.validateTrackedItem(_control, _passport);
	if _passport.noErrors() then
		realTI := _ti.myTerminal.createTrackedItem(_ti, _passport);
	endif;
	foreach error in _passport.allErrorWarnings do
		if error.myUserObject = null then
			error.setMyUserObject(_ediTI);
		endif;
	endforeach;
	if _passport.noErrors and
	   realTI &lt;&gt; null then
		create strArray transient;
		create moveController transient;
		
	// PAR 33644	if tmpVoyage.isNonPlannedVoyage then
		if tmpVoyage.isHOLDSorSHIP() then
			moveController.setMoveMode(REAL_MODE);
		else
			moveController.setMoveMode(PLANNING_MODE);
		endif;
		
		moveController.isSystemMove := true;
		moveController.isEDIMove := true;//added by cnwyl1 for par 12912
		_passport.warningsAcknowledged := true;
		
		startPos := tmpVoyage.code.length + 2;
		tiCount := tiCount + 1;
		
		strArray.clear;
		if realTI.locationId.length &gt;= startPos then
			strArray.add(realTI.locationId[startPos:end]);
		else
			strArray.add(realTI.locationId);	//cnwrs1 ccms1009 the location id does not have voyagecode in front 
		endif;
		
		tmpVoyage.findLocation(strArray, false, location, foundHeight);
	
		if location = null then
			app.raiseCMException1(ERR_INVALID_STOWAGE, realTI.locationId &amp; ", for ti "&amp; realTI.id, 'locationId', null);
		endif;
		otherTI := _currentTIs[realTI.id, realTI.cargoType];
		if otherTI &lt;&gt; null then
//write class.name&amp;'::'&amp;method.name&amp;' delete real='&amp;realTI.id&amp;' other='&amp;otherTI.id&amp;' from real='&amp;realTI.locationId&amp;' other='&amp;otherTI.locationId&amp;' '&amp;realTI.String&amp;' '&amp;otherTI.String;
			futureMove := otherTI.allPlannedFutureMoves.first;
			if futureMove &lt;&gt; null then
				futureMove.erase(NORMAL_ERASE);
			endif;
		endif;
		moveController.setMyToSecondaryLocations(null);
		moveController.setMyTrackedItem(realTI);
		moveController.setMyToPrimaryLocation(location);
		moveController.setIndexForEDIBayPlan(_planControllerIndex);
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
		foreach error in _passport.allErrorWarnings do
			if error.myUserObject = null then
				error.setMyUserObject(_ediTI);
			endif;
		endforeach;
	endif;
	if _passport.noErrors then
		_ediTI.setStatus(CM_EDITrackedItem.EDI_STATUS_DBLOADED);
	else
		_ediTI.setStatus(CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS);
	endif;
epilog
	delete moveController;
	delete strArray;
	_passport.setMyCMIFMonitor(monitor);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_control" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_planControllerIndex" type="Integer"/>
        <Parameter name="_currentTIs" type="CM_TIByIdCargoTypeDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateEDICompCon" id="de7e956b-1264-4857-8550-08a400e303bc">
        <source>utlCreateEDICompCon(_pxyObject : CM_EDIComparisonConfig; _realObject : CM_EDIComparisonConfig output; _passport : CM_Passport input);
// ##### CR 64614 TASK 64643 NAVAB1 03JUL2024
vars

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valEDICompCon(_pxyObject);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	create _realObject as _pxyObject.class persistent;
	_realObject.setForCreate(_pxyObject);
	
	if _passport.noErrors then
		// only required if the class is audited
		self.myCreateAuditAgent.audCreateGeneric(_realObject);
	endif;

end;</source>
        <Parameter name="_pxyObject" type="CM_EDIComparisonConfig"/>
        <Parameter name="_realObject" type="CM_EDIComparisonConfig" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateEDIData" id="0ea84bcf-8a89-40f5-9581-b21c8656d0a4">
        <source>utlCreateEDIData(_realEdiData	: CM_EDIData io;
				 _ediDataClass	: Class;
//				 _singleDataFile: Boolean; // cnwrs1 Par 24207 ccms 1117 11 May 2010
				 _type			: Integer;
				 _ediFileCode : Integer;
				 _ediConfig		: CM_EDIConfig input;
				 _realEdiFile 	: CM_EDIFile input;
				 _ediFileType : CM_EDIFileType;
				 _passport		: CM_Passport input);

// cnwdvb1 29 January 2003 
//04 May 2012	cnwrs1		Par 29531 - EDI Data auditing
//14 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 16 Aug 2016	cnwrs1	TFS 2534 Par 38135 - dead locking between edidata process and edidata deletion
// 19 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 3
// 27 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 4
// 16 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 5
// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
vars
	tmpAuditConfig : CM_AuditConfig;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if _ediConfig = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EDI config is null');
	endif;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

//	if _ediConfig &lt;&gt; null then
//		self.exclusiveLock(_ediConfig);
//	endif;
	create _realEdiData as _ediDataClass persistent;
	
// 19 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 3
	// Lock things in the same order as delete to avoid deadlocks
	// 1. Lock config
	if _ediConfig &lt;&gt; null then
		if not tryLock(_ediConfig, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			self.exclusiveLock(_ediConfig);
		endif;
	endif;
	
	// 2. Lock file type
// 16 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 5
//	if _ediFileType &lt;&gt; null then
//		self.exclusiveLock(_ediFileType);
//	endif;
	self.exclusiveLock(_ediConfig.allEDIFilesByEdiClientRef);
	
	// 3. Lock audits
	app.myAA.getAuditConfigForClass( _realEdiData, _realEdiData.class, tmpAuditConfig);
	if tmpAuditConfig &lt;&gt; null then
		self.exclusiveLock(tmpAuditConfig.allAuditObjects);
	endif;
	
	_realEdiData.setForCreateNoProxy(_ediConfig, _type, _ediFileCode, _realEdiFile, _passport.userCode); // cnwrs1 Par 24207 ccms 1117 11 May 2010
	if _ediFileType &lt;&gt; null then
		_realEdiFile.setEDIFileType(_ediFileType);
	endif;
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_realEdiData);	// 04 May 2012	cnwrs1	par 29531
		global.causeEvent(_ediConfig.myTerminal.getTerminalEvent(EDIData_Create_Event), false, _realEdiData);
	endif;
end;</source>
        <Parameter name="_realEdiData" type="CM_EDIData" usage="io"/>
        <Parameter name="_ediDataClass" type="Class"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_ediFileCode" type="Integer"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="input"/>
        <Parameter name="_realEdiFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediFileType" type="CM_EDIFileType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateEDIDataFromBayPlan" id="4cefc3e5-96cf-48b7-b761-2b1fa18593cf">
        <updating/>
        <source>utlCreateEDIDataFromBayPlan(
	_ediDataBP		: CM_EDIDataBayPlan output;
	_ediConfig		: CM_EDIConfig input;
	_voyage			: CM_Voyage;
	_planType		: Integer;
	_fileName		: String;
	_shipperCode	: String;
	_recipient		: CM_Operator;
	_cargoOperator	: CM_Operator;				// par 29312 - march 2012
	_fileType		: CM_EDIFileType;
	_passport		: CM_Passport input;
	_ediClientRef	: String;					// cnwrl1 12/08/2009 PAR 20318 - MES 1011 Web EDI Link
	_messageType	: String;					// cnwrl1 25/09/2009 PAR 20320 - MES 1011 New Messina Messages
	_message		: Binary;					// cnwrl1 12/08/2009 PAR 20318 - MES 1011 Web EDI Link
	_useInwardsCode	: Boolean ) updating;			// TFS 6851
//----------------------------------------------------------------
//	Created:	23 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 21/03/2012	cnwcs5	CCMS POL 2144 / Par 29312 - Extract Baplie by Operator
// 04/05/2012	cnwrs1	Par 29531 - EDI Data auditing
// 19/09/2017	jlgdap1	TFS 6851 SSL New parameter to decide whether to use inward voyage code 
// 11 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediFile	: CM_EDIFile;
	message : String;
	messageType : String;
	transformedMsg : String;
	ediConfig : CM_EDIConfig;
	ediTI : CM_EDITrackedItem;
	str : String;
	invalidEdiTI : Boolean;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	
	if _ediConfig = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EDI config is null');
	endif;

	app.myValCA.valEDIDataFromBayPlan(_ediConfig, _recipient, _fileName, _fileType);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
// 11 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	ediConfig := _ediConfig;
	if ediConfig.setupEDITransformWrap(_message.String, transformedMsg, messageType) then
		message := transformedMsg.String;
		messageType := System_EDIFileType;
	else
		message := _message.String;
		messageType := _messageType;
	endif;

	if not tryLock(_ediConfig, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(_ediConfig);
	endif;

	create ediFile persistent;

	ediFile.setForCreate(	_fileName,
							app.actualTimeServer,
							CM_EDIFile.EDI_STATUS_EXTRACTED,
							_ediConfig,
							_fileType,
							_ediClientRef,
							messageType,
							message);
	
	if _passport.noErrors then
		create _ediDataBP persistent;
		//_ediDataBP.setForCreateFromVoyage(_voyage, _ediConfig, _planType, ediFile, _passport.userCode, _shipperCode, _cargoOperator);	// par 29312 - march 2012	// TFS 6851
		_ediDataBP.setForCreateFromVoyage(_voyage, _useInwardsCode, _ediConfig, _planType, ediFile, _passport.userCode, _shipperCode, _cargoOperator);				// TFS 6851
		if ediFile.ediData.allEDITrackedItems.size &gt; 0 then
			if not tryLock(ediFile.ediData.ediConfig, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
				self.exclusiveLock(ediFile.ediData.ediConfig);
			endif;
			if not tryLock(ediFile.ediData.ediConfig.allEDITrackedItemsByIdStatus, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
				self.exclusiveLock(ediFile.ediData.ediConfig.allEDITrackedItemsByIdStatus);
			endif;
			foreach ediTI in ediFile.ediData.allEDITrackedItems do
				invalidEdiTI := false;
				str := ediTI.id;
				if not invalidEdiTI then
					ediTI.setMyEDIConfig(ediFile.ediData.ediConfig);
					ediTI.doTranslations(ediFile.ediData.getXlationOperator);
				endif;
			endforeach;
		endif;
	endif;

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_ediDataBP);	// 04 May 2012	cnwrs1	par 29531
		global.causeEvent(_ediConfig.myTerminal.getTerminalEvent(EDIData_Create_Event), false, _ediDataBP);
	endif;
epilog

end;</source>
        <Parameter name="_ediDataBP" type="CM_EDIDataBayPlan" usage="output"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_planType" type="Integer"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_shipperCode" type="String"/>
        <Parameter name="_recipient" type="CM_Operator"/>
        <Parameter name="_cargoOperator" type="CM_Operator"/>
        <Parameter name="_fileType" type="CM_EDIFileType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_ediClientRef" type="String"/>
        <Parameter name="_messageType" type="String"/>
        <Parameter name="_message" type="Binary"/>
        <Parameter name="_useInwardsCode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlCreateEDIDataFromDeckPlan" id="955582ab-3613-4ba2-9c31-e21d2da78956">
        <updating/>
        <source>utlCreateEDIDataFromDeckPlan(
	_ediDataDP		: CM_EDIDataDeckPlan output;
	_ediConfig		: CM_EDIConfig input;
	_voyage			: CM_Voyage;
	_planType		: Integer;
	_fileName		: String;
	_recipient		: CM_Operator;
	_fileType		: CM_EDIFileType;
	_passport		: CM_Passport input;
	_ediClientRef	: String;
	_messageType	: String;
	_message		: Binary ) updating;
/*
Purpose:	Creates an EDI RORO Deck Plan from a voyage in the database			

Date		Who		Reason
28 Dec 2011	cnwgb1	Initial creation for CCMS MSL 1009 Par 29024
04 May 2012	cnwrs1	Par 29531 - EDI Data auditing
29 Oct 2012	cnwcs5	par 30640 - remove redundant code
// 11 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	ediFile	: CM_EDIFile;
	message : String;
	messageType : String;
	transformedMsg : String;
	ediConfig : CM_EDIConfig;
	ediTI : CM_EDITrackedItem;
	str : String;
	invalidEdiTI : Boolean;
begin

	self.initialiseActivity();
		
	if _ediConfig = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EDI config is null');
		return;	// happens anyway
	endif;
	
// 11 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	ediConfig := _ediConfig;
	if ediConfig.setupEDITransformWrap(_message.String, transformedMsg, messageType) then
		message := transformedMsg.String;
		messageType := System_EDIFileType;
	else
		message := _message.String;
		messageType := _messageType;
	endif;

	if not tryLock(_ediConfig, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(_ediConfig);
	endif;

	create ediFile persistent;

	ediFile.setForCreate(_fileName,
							app.actualTimeServer,
							CM_EDIFile.EDI_STATUS_EXTRACTED,
							_ediConfig,
							_fileType,
							_ediClientRef,
							messageType,
							message);
	
	if _passport.noErrors then
		create _ediDataDP persistent;
        
		_ediDataDP.setForCreateFromVoyage(_voyage, _ediConfig, _planType, ediFile, _passport.userCode );
		foreach ediTI in ediFile.ediData.allEDITrackedItems do
			invalidEdiTI := false;
			str := ediTI.id;
			if not invalidEdiTI then
				ediTI.setMyEDIConfig(ediFile.ediData.ediConfig);
				ediTI.doTranslations(ediFile.ediData.getXlationOperator);
			endif;
		endforeach;
	endif;

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_ediDataDP);	// 04 May 2012	cnwrs1	par 29531
		global.causeEvent(_ediConfig.myTerminal.getTerminalEvent(EDIData_Create_Event), false, _ediDataDP);
	endif;
epilog

end;</source>
        <Parameter name="_ediDataDP" type="CM_EDIDataDeckPlan" usage="output"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_planType" type="Integer"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_recipient" type="CM_Operator"/>
        <Parameter name="_fileType" type="CM_EDIFileType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_ediClientRef" type="String"/>
        <Parameter name="_messageType" type="String"/>
        <Parameter name="_message" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="utlCreateEDIDataFromDeckStowag" id="ba2041a6-d817-41d7-9309-f30b34026329">
        <updating/>
        <source>utlCreateEDIDataFromDeckStowag(
	_ediDataDP		: CM_EDIDataDeckStowageAdvice output;
	_ediConfig		: CM_EDIConfig input;
	_voyage			: CM_Voyage;
	_fileName		: String;
	_recipient		: CM_Operator;
	_fileType		: CM_EDIFileType;
	_passport		: CM_Passport input;
	_ediClientRef	: String;
	_messageType	: String;
	_message		: Binary ) updating;
//
//15 Feb 2012	cnwrs1	Par 29124 Fix up Messina RORO Stowage advice in EDI
//04 May 2012	cnwrs1		Par 29531 - EDI Data auditing
// 11 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediFile	: CM_EDIFile;
	message : String;
	messageType : String;
	transformedMsg : String;
	ediConfig : CM_EDIConfig;
	ediTI : CM_EDITrackedItem;
	str : String;
	invalidEdiTI : Boolean;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	if _ediConfig = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EDI config is null');
	endif;

	//####app.myValCA.valEDIDataFromBayPlan(_ediConfig, _recipient, _fileName, _fileType);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
// 11 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	ediConfig := _ediConfig;
	if ediConfig.setupEDITransformWrap(_message.String, transformedMsg, messageType) then
		message := transformedMsg.String;
		messageType := System_EDIFileType;
	else
		message := _message.String;
		messageType := _messageType;
	endif;

	if not tryLock(_ediConfig, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(_ediConfig);
	endif;

	create ediFile persistent;
	ediFile.setForCreate(	
        _fileName,
		app.actualTimeServer,
		CM_EDIFile.EDI_STATUS_EXTRACTED,
		_ediConfig,
		_fileType,
		_ediClientRef,
		messageType,
		message);
	
	if _passport.noErrors then
		create _ediDataDP persistent;
        
		_ediDataDP.setForCreateFromVoyage(
            _voyage, 
            _ediConfig, 
            ediFile, 
           _passport.userCode);
		foreach ediTI in ediFile.ediData.allEDITrackedItems do
			invalidEdiTI := false;
			str := ediTI.id;
			if not invalidEdiTI then
				ediTI.setMyEDIConfig(ediFile.ediData.ediConfig);
				ediTI.doTranslations(ediFile.ediData.getXlationOperator);
			endif;
		endforeach;
	endif;

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_ediDataDP);	// 04 May 2012	cnwrs1	par 29531
		global.causeEvent(_ediConfig.myTerminal.getTerminalEvent(EDIData_Create_Event), false, _ediDataDP);
	endif;
epilog

end;
</source>
