    <JadeMethod name="setupSplitMove" id="5b1b7cc0-7a22-4732-9552-4b1a7d0a0537">
        <updating/>
        <source>setupSplitMove(_col : Collection; _maxNum : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     18 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.allTrackedItemsForSplit.clear;
	_col.copy(self.allTrackedItemsForSplit);

	self.allTISets.clear;

	self.doSessionLockForAll();
	global.splitTISetForMove(self.allTrackedItemsForSplit, 1, _maxNum, self.allTISets);

end;</source>
