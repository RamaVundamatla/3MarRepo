    <JadeMethod name="hasCurrentTask" id="b631f564-c127-474e-bdf3-d38bb42822b6">
        <source>hasCurrentTask(_rtQueue : CM_RTQueueEntry input) : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	task, currentTask : CM_RTQueueTask;
	invalidObject : Boolean;
begin
	
	// cnwjk3 PAR 16720 20/11/08
	// Need to handle the case where the queue entry has been deleted from another screen
	on Exception do app.handleDeletedObject(exception, _rtQueue, invalidObject);
	
	currentTask := _rtQueue.allTasks.first;	

	// cnwjk3 PAR 16720 20/11/08
	if invalidObject then
		return false;
	endif;

	
	if self.myMachine.allCurrentQueueTasks.size = 0 then
		return false;
	endif;
	
	foreach task in self.myMachine.allCurrentQueueTasks do
		if task.myEntry = _rtQueue then
			return true;
		endif;
	endforeach;
	return false;

epilog

end;</source>
        <Parameter name="_rtQueue" type="CM_RTQueueEntry" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBusy" id="15a5c1a2-a573-4c1a-97d7-a8780c1277c5">
        <source>isBusy() : Boolean protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	currentTask : CM_RTQueueTask;
begin

	currentTask:= self.getCurrentTask();
	
	if currentTask = null or currentTask.status = TASK_OFFERED then
		return false;
	else
		return true;
	endif;
epilog

end;</source>
