    <JadeMethod name="updateSchedule" id="ac306b21-c43a-4f2a-8adf-41116273a66f">
        <updating/>
        <source>updateSchedule(_woDetail : CM_WorkOrderDtl; _schedule : CM_WorkOrderSchedule) updating;
// -----------------------------------------------------------------------------
// Created:		17 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	col, row : Integer;
	removeSchedule : Boolean;
	rowDT : TimeStamp;
	tbl : CM_BaseTable;
	monthText,
	dayText: String;
	
begin
	removeSchedule := not global.isValidObject(_schedule);

	tbl := self.tblSchedule;

	col := tbl.fixedColumns + 1;
	
	while col &lt; tbl.columns do
		if self.getWorkOrderTIDtl(col) = _woDetail then
			row := tbl.rows;
			while row &gt; tbl.fixedRows do
				if tbl.accessCell(row,col).itemObject.String = _schedule.String then
					if removeSchedule then
						self.displaySchedule(null, row, col);
						return;
					else
						if _schedule.scheduledDT = self.getScheduledDT(row) then
							//  Update existing schedule details
							self.displaySchedule(_schedule, row, col);
							return;
						else
							//  Scheduled DT has changed.  Remove entry and re-add below.
							self.displaySchedule(null, row, col);
						endif;
					endif;
					break;
				endif;	
				row := row - 1;
			endwhile;
		endif;
		col := col + self.TaskColumns;
	endwhile;
	
	if removeSchedule then
		return;
	endif;

	//  Add schedule entry to table
	
	row := tbl.rows;
	
	while true do
		rowDT := self.getScheduledDT(row);
		
		
		if row &lt;= tbl.fixedRows or rowDT &lt; _schedule.scheduledDT then
			rowDT := _schedule.scheduledDT;
			row := row + 1;
			monthText := rowDT.date.monthName();
			dayText := rowDT.date.dayName()[1:3] &amp; ' ' &amp; rowDT.date.day.asStringJMT();
			
			self.addRowToSchedule(rowDT,monthText  , dayText , rowDT.time.asStringJMT()  , row);			
		endif;
		if rowDT = _schedule.scheduledDT then			
			col := tbl.fixedColumns + 1;
			while col &lt; tbl.columns do
				if self.getWorkOrderTIDtl(col) = _schedule.myParent then
					self.displaySchedule(_schedule, row, col);
					return;
				endif;
				col := col + self.TaskColumns;
			endwhile;
			return;
		endif;
		row := row - 1;
	endwhile;
	
	if _schedule.scheduledDT &gt; self.currentTS and _schedule.scheduledDT &lt; self.timerTS then
		self.timerSetup();
	endif;

epilog

end;</source>
        <Parameter name="_woDetail" type="CM_WorkOrderDtl"/>
        <Parameter name="_schedule" type="CM_WorkOrderSchedule"/>
    </JadeMethod>
    <JadeMethod name="updateSummary" id="3c5b48e1-8377-4d10-a72a-412493789a0e">
        <updating/>
        <source>updateSummary(_woDetail : CM_WorkOrderDtl) updating;
// -----------------------------------------------------------------------------
// Created:		18 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	col : Integer;
	defaultForeColor : Integer;
	numberActioned : Integer;
	numberRemainingToPlan : Integer;
	numberStillToDo : Integer;
	schedule : CM_WorkOrderSchedule;
	tbl : CM_BaseTable;
	totalActioned : Integer;
	totalNotActioned : Integer;
	totalPlanned : Integer;
	totalRequired : Integer;
	totalStillToDo : Integer;
	totalComplete : Integer;
begin
	tbl := self.tblSummary;
	col := self.tblSchedule.fixedColumns + 1;
	
	foreach schedule in _woDetail.CM_WorkOrderTIDtl.allSchedules do
		numberActioned := schedule.getNumberActioned();
		numberStillToDo := schedule.numberScheduled - numberActioned;
		if schedule.scheduledDT &gt; self.currentTS then
			totalStillToDo := totalStillToDo + numberStillToDo;
		else
			totalNotActioned := totalNotActioned + numberStillToDo;
		endif;
		totalActioned := totalActioned + numberActioned;
		totalComplete := totalComplete + schedule.getNumberComplete();
	endforeach;

	totalPlanned := _woDetail.getTotalPlanned();
	totalRequired := _woDetail.myParent.getTotalRequired();
	numberRemainingToPlan := totalRequired -( totalStillToDo + totalActioned);
	//numberRemainingToPlan := totalRequired - totalPlanned;
	
	
	
	while col &lt; tbl.columns do
		if self.tblSchedule.accessColumn(col).itemObject = _woDetail then
			tbl.accessCell(1,col).text := totalPlanned.asStringJMT();
			defaultForeColor := tbl.accessedCell.foreColor;
			tbl.accessCell(2,col).text := totalNotActioned.asStringJMT();
			tbl.accessCell(3,col).text := totalStillToDo.asStringJMT();
			tbl.accessCell(4,col).text := totalActioned.asStringJMT();
			tbl.accessCell(5,col).text := totalComplete.asStringJMT();			
			tbl.accessCell(6,col).text := totalRequired.asStringJMT();
			tbl.accessCell(7,col).text := numberRemainingToPlan.asStringJMT();
			if numberRemainingToPlan &gt; 0 then
				tbl.accessedCell.foreColor := Red;
			else
				tbl.accessedCell.foreColor := defaultForeColor;	
			endif;
			break;
		endif;
		col := col + self.TaskColumns;
	endwhile;
	
epilog

end;</source>
        <Parameter name="_woDetail" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="13141d72-b258-4d6d-bbba-405c625e39de">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// -----------------------------------------------------------------------------
// Created:		17 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// -----------------------------------------------------------------------------

vars
	event : Integer;
	
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);

	if event = Event_WorkOrderSchedule_Update then
		self.currentTS := self.systemToLocalTime(app.actualTimeServer());//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.updateSchedule(theObject.CM_WorkOrderDtl, userInfo.CM_WorkOrderSchedule);
		self.updateSummary(theObject.CM_WorkOrderDtl);
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
