/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/02/2011	cnwdap1	Initial creation PAR #27153 CCMS POL 2000
*/
vars
	loadVoyage	: CM_Voyage;
	
begin
	if self.myRequest &lt;&gt; null and self.myRequest.myOriginatingBulkRelease &lt;&gt; null then
