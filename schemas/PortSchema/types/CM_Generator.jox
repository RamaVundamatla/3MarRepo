    <JadeMethod name="getDataForDefSpecial" id="7264dcf8-025f-4fd4-bca3-c4129bfd92f1">
        <source>getDataForDefSpecial(_attrName: String; _heading: String; _headings: StringArray input; _data: HugeStringArray input): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     27 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/03/2010	cnwdap1		PAR #23111 relatedTo should be reefersRelatedTo
//							Missed from changes for CCMS MES 1007
// ---------------------------------------------------------------------------
vars
	tmpRP		: CM_ReeferProperties;
	tmpTI		: CM_TrackedItem;
	firstTime	: Boolean;
	tmpHeading	: String;
begin
	if _attrName = ETRow_RelatedTo then
		firstTime := true;
		//foreach tmpTI in self.relatedTo do		// PAR #23111
		foreach tmpRP in self.reefersRelatedTo do	// PAR #23111
			tmpTI := tmpRP.myParent.CM_TrackedItem;	// PAR #23111
			if firstTime then
				firstTime := false;
				tmpHeading := _heading;
			else
				tmpHeading := ' ';
			endif;
			_headings.add(tmpHeading);
			_data.add(tmpTI.id);
		endforeach;
		return true;

	else
		return inheritMethod(_attrName, _heading, _headings, _data);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a61b203a-0c1f-4d4c-9458-8d6043ee5629">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     09 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars

begin
	if _attrName = ETRow_FuelledDT then
		return self.systemToLocalTime(self.fuelledDT).shortCurrentLocaleFormat.String;// 05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_RelatedTo then
		return null;
	elseif _attrName = ETRow_TareWeight then	//Par 17775. ccms1045 APM - yard Ops - new generator Type. September 2008
//		return self.weight.asStringWeightJMT(); // cnwrd1 ccms JMT 1060 Imp Measurements					//-cnwml2 MSL CCMS 1017
		return self.weightTare.asStringWeightJMT();
	elseif _attrName = ETRow_MyGeneratorType then	//Par 17775. ccms1045 APM - yard Ops - new generator Type. September 2008
		if self.myGeneratorType = null then
			return null;
		else
			return self.myGeneratorType.getDisplayDetails(false);
		endif;
	elseif _attrName = ETRow_AttachedTo then	//Par 17775. ccms1045 APM - yard Ops - new generator Type. September 2008
		return self.getParentDescriptionDetails();
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
