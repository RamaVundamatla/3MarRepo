    <JadeMethod name="tEscalatingChargesFull" id="5d8939ed-52d7-4f65-ab26-9554580b5c01">
        <updating/>
        <source>tEscalatingChargesFull() updating;
// cnwma1
// cnwjre1 test 1279
//	create an invoice line per range (full escalating)
vars
	start,
	expiry : TimeStamp;
	cStatus : CM_ContentsStatus;
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate, editDate, today : Date;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	pxyDebtorRate	: CM_DebtorRate;
 	rateEntry		: CM_RateEntry;
	storeTrans		: CM_TITransaction;
	invoiceLines	: ObjectArray;
	perDays, rangeStart, rangeEnd	: IntegerArray;
	costs : DecimalArray;
begin

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	bs:= self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");
	self.deleteInvoiceTransactionMap(1, 'UT_StorageEsc1');
	self.deleteInvoiceType("UT_InvTypeStore3");
	self.deleteInvoiceService("UT_ServiceStore13", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree4", FORCED_ERASE);
	self.deleteInvoiceCalcType("UT_ESC");

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore3", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");

	// create an escalating charge cargo calculation type based on INV_CALC_TYPE_DAYS_SINCE_RECVL
	create perDays transient;
	create rangeStart transient;
	create rangeEnd transient;
	/* set up as in the functional spec - 1 to 5 days free
		6 - 10 days at $10 per day, 11 to 20 at $15 per day
		21 days plus at $20 per day, rate increasing by $8 every 10 days
	*/
	perDays.add(0); perDays.add(0); perDays.add(0); perDays.add(10);
	rangeStart.add(1); rangeStart.add(6); rangeStart.add(11); rangeStart.add(21);
	rangeEnd.add(5); rangeEnd.add(10); rangeEnd.add(20); rangeEnd.add(99999999);

	calType1 := self.createInvoiceCalcType(null, INV_CALC_TYPE_DAYS_SINCE_RECVL, "UT_ESC", "Escalating", 
										  0, 0, 0, 0, null, false,
										  null, null, 0, 0, 0,
										  null, null, null, null,
										  true, false, false,
										  perDays, rangeStart, rangeEnd, null);
	self.assertNotNullMsg(calType1, "Calculation type Escalating Storage not created");
	
	theService := self.createInvoiceService("UT_ServiceStore13","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore13 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStoreFree1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStoreFree2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStoreFree3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStoreFree4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStoreFree1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStoreFree2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStoreFree3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStoreFree4 not created");
	if invLineType1 &lt;&gt; null then
		self.assertNotNullMsg(invLineType1.invoiceType, "UT_LineTypeStoreFree1 has null INV TYPE");
	endif;
	if invLineType2 &lt;&gt; null then
		self.assertNotNullMsg(invLineType2.invoiceType, "UT_LineTypeStoreFree2 has null INV TYPE");
	endif;
	if invLineType3 &lt;&gt; null then
		self.assertNotNullMsg(invLineType3.invoiceType, "UT_LineTypeStoreFree3 has null INV TYPE");
	endif;
	if invLineType4 &lt;&gt; null then
		self.assertNotNullMsg(invLineType4.invoiceType, "UT_LineTypeStoreFree4 has null INV TYPE");
	endif;

	// the invoicing debtor is that of the operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadEscalatingChg3();
	
	// set up rates for this debtor and service used
	create costs transient;
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(theService, debtor);
	// rates are: $0 for 1-5, $10 for 6-10, $15 for 11-20, $20 for 21-max with $8 increment every 10 days
	costs.add(0.00);
	costs.add(10.00);
	costs.add(15.00);
	costs.add(20.00);
	costs.add(8.00);
	start.setDate("01/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, expiry, false, costs, 0, 0, null, null);

	// create a container with retrospective transactions (refer example on PAR 24160)
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE3", 100, null);


	// Create Storage Transactions
	cargo := bs.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"STOR4300111"];
	if cargo &lt;&gt; null then
		self.deleteCargo(cargo.id, cargo.myCargoType.abbreviation.toUpper);
	endif;
	cargo := self.addContainerAtLocnDisch("STOR4300111", "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController, aPort, voy);
	
	// set Trans to 65 days ago
	// ##################
	tranDate := tranDate - 65;
	tranTS.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	
	cStatus := app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_FCL];
	self.editIMEXStatus(cargo, TI_IMEX_STATUS_EXPORT,false);
	self.editCommodity(cargo, "GENL");
	
	// this creates the first storage transaction for 5 days
	editDate := tranDate + 5;
	// change the edit and storage tran to be 5 days later than receival
	foreach tran in cargo.allTransactions do
		if tran.dateTime.date &lt;&gt; today then
			continue;
		endif;
		tranTS.setDate(editDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	self.reevalStorageTrans(cargo);

	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	self.roadExit(vvr);		// creates the second storage transaction and invoice lines
	
	self.validateEscalatingCharges3(cargo, 1);
	self.reevalStorageTrans(cargo);
	// the transaction re-evaluate should not have changed anything
	self.validateEscalatingCharges3(cargo, 2);

	storeTrans := cargo.getLastTransOfType(TRANS_TYPE_STORAGE);
	create invoiceLines transient;
	storeTrans.allInvoiceLines.copy(invoiceLines);
	self.invoiceLineReevaluate(invoiceLines);
	// the  invoice line re-evaluate should not have changed anything
	self.validateEscalatingCharges3(cargo, 3);
	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	delete perDays;
	delete rangeStart;
	delete rangeEnd;
	delete costs;
	delete pxyDebtorRate;
	delete invoiceLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tEscalatingChargesSingle" id="3dcb2546-9a7f-4375-9b7e-c3ed4f9acbbc">
        <updating/>
        <source>tEscalatingChargesSingle() updating;
// cnwma1
// cnwjre1 test 1279
//	escalating but a single invoice line for the open-ended range
vars
	start,
	expiry : TimeStamp;
	cStatus : CM_ContentsStatus;
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate, editDate, today : Date;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	debtorRate	: CM_DebtorRate;
	pxyDebtorRate	: CM_DebtorRate;
 	rateEntry		: CM_RateEntry;
	storeTrans		: CM_TITransaction;
	invoiceLines	: ObjectArray;
	perDays, rangeStart, rangeEnd	: IntegerArray;
	costs : DecimalArray;
	transactionTypes : IntegerArray;
	transientInvoiceLines : CM_InvoiceLineBySeqNumDict;
begin

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	self.deleteTransactionMaps();

	bs:= self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");
	self.deleteInvoiceTransactionMap(1, 'UT_StorageEsc1');
	self.deleteInvoiceType("UT_InvTypeStore3");
	self.deleteInvoiceService("UT_ServiceStore13", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree4", FORCED_ERASE);
	self.deleteInvoiceCalcType("UT_ESC");

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore3", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");

	// create an escalating charge cargo calculation type based on INV_CALC_TYPE_DAYS_SINCE_RECVL
	create perDays transient;
	create rangeStart transient;
	create rangeEnd transient;
	/* set up as in the functional spec - 1 to 5 days free
		6 - 10 days at $10 per day, 11 to 20 at $15 per day
		21 days plus at $20 per day, rate increasing by $8 every 10 days
	*/
	perDays.add(0); perDays.add(0); perDays.add(0); perDays.add(10);
	rangeStart.add(1); rangeStart.add(6); rangeStart.add(11); rangeStart.add(21);
	rangeEnd.add(5); rangeEnd.add(10); rangeEnd.add(20); rangeEnd.add(99999999);

	calType1 := self.createInvoiceCalcType(null, INV_CALC_TYPE_DAYS_SINCE_RECVL, "UT_ESC", "Escalating", 
										  0, 0, 0, 0, null, false,
										  null, null, 0, 0, 0,
										  null, null, null, null,
										  true, false, false,
										  perDays, rangeStart, rangeEnd, null);
	self.assertNotNullMsg(calType1, "Calculation type Escalating Storage not created");
	
	theService := self.createInvoiceService("UT_ServiceStore13","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore13 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStoreFree1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStoreFree2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStoreFree3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStoreFree4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStoreFree1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStoreFree2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStoreFree3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStoreFree4 not created");
	if invLineType1 &lt;&gt; null then
		self.assertNotNullMsg(invLineType1.invoiceType, "UT_LineTypeStoreFree1 has null INV TYPE");
	endif;
	if invLineType2 &lt;&gt; null then
		self.assertNotNullMsg(invLineType2.invoiceType, "UT_LineTypeStoreFree2 has null INV TYPE");
	endif;
	if invLineType3 &lt;&gt; null then
		self.assertNotNullMsg(invLineType3.invoiceType, "UT_LineTypeStoreFree3 has null INV TYPE");
	endif;
	if invLineType4 &lt;&gt; null then
		self.assertNotNullMsg(invLineType4.invoiceType, "UT_LineTypeStoreFree4 has null INV TYPE");
	endif;

	// the invoicing debtor is that of the operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadEscalatingChg1();
	
	// set up rates for this debtor and service used
	create costs transient;
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(theService, debtor);
	// rates are: $0 for 1-5, $10 for 6-10, $15 for 11-20, $20 for 21-max with $8 increment every 10 days
	costs.add(0.00);
	costs.add(10.00);
	costs.add(15.00);
	costs.add(20.00);
	costs.add(8.00);
	start.setDate("01/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, expiry, false, costs, 0, 0, null, null);

	// create a container with retrospective transactions (refer example on PAR 24160)
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE3", 100, null);


	// Create Storage Transactions
	cargo := bs.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"STOR4300111"];
	if cargo &lt;&gt; null then
		self.deleteCargo(cargo.id, cargo.myCargoType.abbreviation.toUpper);
	endif;
	cargo := self.addContainerAtLocnDisch("STOR4300111", "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController, aPort, voy);
	
	// set Trans to 65 days ago
	// ##################
	tranDate := tranDate - 65;
	tranTS.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	
	cStatus := app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_FCL];
	self.editIMEXStatus(cargo, TI_IMEX_STATUS_EXPORT,false);
	self.editCommodity(cargo, "GENL");
	
	// this creates the first storage transaction for 5 days
	editDate := tranDate + 5;
	// change the edit and storage tran to be 5 days later than receival
	foreach tran in cargo.allTransactions do
		if tran.dateTime.date &lt;&gt; today then
			continue;
		endif;
		tranTS.setDate(editDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	self.reevalStorageTrans(cargo);

	// TESTING
	create transactionTypes transient;
	transactionTypes.add(1);
	
	create transientInvoiceLines transient;

	// gate it out -  creates a second storage transaction 
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	
	self.roadExit(vvr);

	
	self.validateEscalatingCharges1(cargo);
	
	// change the rates - add a dollar to each
	debtorRate := rateEntry.rate.CM_DebtorRate;
	costs.clear();
	costs.add(0.00);
	costs.add(11.00);
	costs.add(16.00);
	costs.add(21.00);
	costs.add(9.00);
	self.updateInvoiceRateEntry(debtorRate, rateEntry, start, expiry, false, costs, 0, 0, null,null);

	self.validateEscalatingCharges1a(cargo, 1);
	self.reevalStorageTrans(cargo);	
	// the transaction re-evaluate should not have changed anything
	self.validateEscalatingCharges1a(cargo, 2);
	
	storeTrans := cargo.getLastTransOfType(TRANS_TYPE_STORAGE);
	create invoiceLines transient;
	storeTrans.allInvoiceLines.copy(invoiceLines);
	self.invoiceLineReevaluate(invoiceLines);
	// the re-evaluate should not have changed anything
	self.validateEscalatingCharges1a(cargo, 3);
	// TODO change the calculation type
	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	delete perDays;
	delete rangeStart;
	delete rangeEnd;
	delete costs;
	delete pxyDebtorRate;
	delete invoiceLines;
	delete transactionTypes;
	delete transientInvoiceLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tEscalatingChargesSingleCons" id="5c6620f0-ccb9-4bc4-ac0b-1b3039c88489">
        <updating/>
        <source>tEscalatingChargesSingleCons() updating;
// cnwma1
// cnwjre1 test 1279
//	create a single consolidated invoice line for the 21 plus charges
vars
	start,
	expiry : TimeStamp;
	cStatus : CM_ContentsStatus;
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate, editDate, today : Date;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	pxyDebtorRate	: CM_DebtorRate;
 	rateEntry		: CM_RateEntry;
	storeTrans		: CM_TITransaction;
	invoiceLines	: ObjectArray;
	perDays, rangeStart, rangeEnd	: IntegerArray;
	costs : DecimalArray;
begin

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	bs:= self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");
	self.deleteInvoiceTransactionMap(1, 'UT_StorageEsc1');
	self.deleteInvoiceType("UT_InvTypeStore3");
	self.deleteInvoiceService("UT_ServiceStore13", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree4", FORCED_ERASE);
	self.deleteInvoiceCalcType("UT_ESC");

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore3", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");

	// create an escalating charge cargo calculation type based on INV_CALC_TYPE_DAYS_SINCE_RECVL
	create perDays transient;
	create rangeStart transient;
	create rangeEnd transient;
	/* set up as in the functional spec - 1 to 5 days free
		6 - 10 days at $10 per day, 11 to 20 at $15 per day
		21 days plus at $20 per day, rate increasing by $8 every 10 days
	*/
	perDays.add(0); perDays.add(0); perDays.add(0); perDays.add(10);
	rangeStart.add(1); rangeStart.add(6); rangeStart.add(11); rangeStart.add(21);
	rangeEnd.add(5); rangeEnd.add(10); rangeEnd.add(20); rangeEnd.add(99999999);

	calType1 := self.createInvoiceCalcType(null, INV_CALC_TYPE_DAYS_SINCE_RECVL, "UT_ESC", "Escalating", 
										  0, 0, 0, 0, null, false,
										  null, null, 0, 0, 0,
										  null, null, null, null,
										  true, false, false,
										  perDays, rangeStart, rangeEnd, null);
	self.assertNotNullMsg(calType1, "Calculation type Escalating Storage not created");
	
	theService := self.createInvoiceService("UT_ServiceStore13","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore13 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStoreFree1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStoreFree2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStoreFree3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStoreFree4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStoreFree1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStoreFree2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStoreFree3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStoreFree4 not created");
	if invLineType1 &lt;&gt; null then
		self.assertNotNullMsg(invLineType1.invoiceType, "UT_LineTypeStoreFree1 has null INV TYPE");
	endif;
	if invLineType2 &lt;&gt; null then
		self.assertNotNullMsg(invLineType2.invoiceType, "UT_LineTypeStoreFree2 has null INV TYPE");
	endif;
	if invLineType3 &lt;&gt; null then
		self.assertNotNullMsg(invLineType3.invoiceType, "UT_LineTypeStoreFree3 has null INV TYPE");
	endif;
	if invLineType4 &lt;&gt; null then
		self.assertNotNullMsg(invLineType4.invoiceType, "UT_LineTypeStoreFree4 has null INV TYPE");
	endif;

	// the invoicing debtor is that of the operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadEscalatingChg2();
	
	// set up rates for this debtor and service used
	create costs transient;
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(theService, debtor);
	// rates are: $0 for 1-5, $10 for 6-10, $15 for 11-20, $20 for 21-max with $8 increment every 10 days
	costs.add(0.00);
	costs.add(10.00);
	costs.add(15.00);
	costs.add(20.00);
	costs.add(8.00);
	start.setDate("01/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, expiry, false, costs, 0, 0, null, null);

	// create a container with retrospective transactions (refer example on PAR 24160)
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE3", 100, null);


	// Create Storage Transactions
	cargo := bs.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"STOR4300111"];
	if cargo &lt;&gt; null then
		self.deleteCargo(cargo.id, cargo.myCargoType.abbreviation.toUpper);
	endif;
	cargo := self.addContainerAtLocnDisch("STOR4300111", "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController, aPort, voy);
	
	// set Trans to 65 days ago
	// ##################
	tranDate := tranDate - 65;
	tranTS.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	
	cStatus := app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_FCL];
	self.editIMEXStatus(cargo, TI_IMEX_STATUS_EXPORT,false);
	self.editCommodity(cargo, "GENL");
	
	// this creates the first storage transaction for 5 days
	editDate := tranDate + 5;
	// change the edit and storage tran to be 5 days later than receival
	foreach tran in cargo.allTransactions do
		if tran.dateTime.date &lt;&gt; today then
			continue;
		endif;
		tranTS.setDate(editDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	//self.reevaleTrans(cargo);

	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	
	self.roadExit(vvr);
	self.reevalStorageTrans(cargo);
	
	self.validateEscalatingCharges2(cargo, 1);
	self.reevalStorageTrans(cargo);
	// the transaction re-evaluate should not have changed anything
	self.validateEscalatingCharges2(cargo, 2);
	
	storeTrans := cargo.getLastTransOfType(TRANS_TYPE_STORAGE);
	create invoiceLines transient;
	storeTrans.allInvoiceLines.copy(invoiceLines);
	self.invoiceLineReevaluate(invoiceLines);
	// the invoice line re-evaluate should not have changed anything
	self.validateEscalatingCharges2(cargo, 3);
	
	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	delete perDays;
	delete rangeStart;
	delete rangeEnd;
	delete costs;
	delete pxyDebtorRate;
	delete invoiceLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tEscalatingDaysOnSite" id="2c21fbc0-b748-40c0-ab87-440709fe025b">
        <source>tEscalatingDaysOnSite();
// cnwma1

/*
cnwjre1
Purpose:		Create an on-site general cargo item with transactions to test Gulftainer 36438 patch

Parameters:			

Return Value:		


Date		Who		Reason
Nov 2015	cnwjre1	Initial creation
14 Dec 2021	navdap1	Unit test fixups after DMAST -&gt; WMAST code overwrite
*/

vars
	ti		: CM_TrackedItem;
	transParams: CMIF_StorageTransController;
	tran : CM_TITransaction;
	terminal	: CM_Terminal;
	tranTS : TimeStamp;
	tranDate : Date;
	type		 : CM_TerminalAreaType;
	blockStack 	 : CM_BlockStack;
	voyage		: CM_Voyage;
	operator	: CM_Operator;
	bank		: CM_Bank;
	currentMap,
	cargoMap	: CM_TranMap;
	cargoType	: CM_CargoType;
	invLine		: CM_InvoiceLine;
	count		: Integer;
	secondQuantity	: Real;
	secondValue		: Decimal[16, 6];
	roundDecimalOpt : Integer;
	mapName,
	fileName,
	fileContent     : String;
	invLineType : CM_InvoiceLineDesc;
begin
	
	self.opts.purge();
	//self.opts.addAssoc("Terminal", "JT1");
	self.opts.addAssoc("Terminal", "UT");
	terminal := self.getTerminal();
	roundDecimalOpt := terminal.getConfig(InvoiceRoundLineTotal).Integer;
	beginTransaction;
	terminal.setConfig(InvoiceRoundLineTotal,CMIF_ConfigTerminal.InvLineRound_Value_Two);
	commitTransaction;
	// restore the required transaction map
	bank 		:= terminal.getDefaultCompanyBank();
	
	
	invLineType := bank.invoiceLineDescriptors["UT_STORAGE BB 8-14"];
	assertTrueMsg(invLineType &lt;&gt; null, "Line Type UT_STORAGE BB 8-14 is null, someone has changed data in the thin client");
	assertTrueMsg(invLineType.invoiceType &lt;&gt; null, "Line Type UT_STORAGE BB 8-14 invoice type is null, someone has deleted the invoice type on the invoice line type");
	
	invLineType := bank.invoiceLineDescriptors["UT_STORAGE BB 15-Max"];
	assertTrueMsg(invLineType &lt;&gt; null, "Line Type UT_STORAGE BB 15-Max is null, someone has changed data in the thin client");
	assertTrueMsg(invLineType.invoiceType &lt;&gt; null, "Line Type UT_STORAGE BB 15-Max invoice type is null, someone has deleted the invoice type on the invoice line type");
	
	
	
	mapName 	:= "Map36438";
	fileName 	:= "CargoLoaded";
	self.deleteInvoiceTransactionMap(1, 'Map36438');
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested? '&amp; CrLf &amp;
					'Cargo,Map36438,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,**Any**,All,VOID,,,,,,,,,,,,,'&amp; CrLf &amp; 
					'Cargo,Map36438,(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),,,**Any**,All,VOID,,,,,,,,,,,,,'&amp; CrLf &amp; 
					'Cargo,Map36438,UT_BB_GC| UT_BreakBulk GC,(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,**Any**,All,VOID,,,,,,,,,,,,,'&amp; CrLf &amp; 
					'Cargo,Map36438,UT_BB_GC| UT_BreakBulk GC,(Default),(Default),Import,(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,**Any**,All,VOID,,,,,,,,,,,,,'&amp; CrLf &amp; 
					'Cargo,Map36438,UT_BB_GC| UT_BreakBulk GC,(Default),(Default),Import,(Default),(Default),Storage,,(Default),*GT0003* Cargo Weight Convert »,00 to 7,,,**Any**,All,VOID,,,,,,,,,,,,,'&amp; CrLf &amp; 
					'Cargo,Map36438,UT_BB_GC| UT_BreakBulk GC,(Default),(Default),Import,(Default),(Default),Storage,,(Default),*GT0003* Cargo Weight Convert »,08 to 14,,,**Any**,All,UT_STORAGE BB 8-14,,,,,,,,,,,,,'&amp; CrLf &amp; 
					'Cargo,Map36438,UT_BB_GC| UT_BreakBulk GC,(Default),(Default),Import,(Default),(Default),Storage,,(Default),*GT0003* Cargo Weight Convert »,15 to MAX,,,**Any**,All,UT_STORAGE BB 15-Max,,,,,,,,,,,,,'&amp; CrLf;

	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();

	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	operator   := app.myRoot.allOperators["MSC"];
	type 	   := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack := terminal.allTerminalAreasByTypeId.getAtKey( type.type, "BS2").CM_BlockStack;
	cargoType  := app.myRoot.getCargoTypeFromAbbrev("UT_BB_GC");

	self.deleteCargo("MTI-SA-500M", cargoType);
	self.deleteCargo("MTI-SA-501M", cargoType);
	voyage := self.getTerminal.getNullVoyage;
	// create onsite cargo
	ti := self.addCargoAtLocationDetailed("MTI-SA-501M", cargoType, cargoType.allProducts.first, blockStack.allLocationsControllers.first, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	
	beginTransaction;
	ti.setPropertyValue( "totalWeight", "17000".Decimal );		// 17 tonnes
	commitTransaction;

	// cargo created 07/02/2015 (originally as a pre-note, but this tests fiddles the dates and transactions to get the same results)
	tranDate.setDate(7,2,2015);
	tranTS.setDate(tranDate);
	beginTransaction;
	foreach tran in ti.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		tran.setPropertyValue("dateTime", tranTS);
	endforeach;
	commitTransaction;
	
	// do a 'receive road' at 07/03/2015
	create transParams transient;
	transParams.type := TRANS_TYPE_REC_ROAD;
	transParams.noCharge := false;
	transParams.userId := "CNWJRE1";
	transParams.isManual := true; // NAVAB1 23APR2024 - FIXING UTs
	
	beginTransaction;
	tranDate.setDate(7,3,2015);
	tranTS.setDate(tranDate);
	transParams.dateTime := tranTS;
	ti.createTransaction(transParams, app.myPassport);
	commitTransaction;

	// delete the CM_Receive (is replaced with CM_ReceiveRoad), date the CM_Move to after the receive
	tranDate.setDate(8,3,2015);
	tranTS.setDate(tranDate);
	beginTransaction;
	foreach tran in ti.allTransactions do
		if tran.class.name = CM_Receive.name then
			delete tran;
		endif;
		if tran.isKindOf(CM_Move) then
			tranTS.setDate(tranDate);
			tranTS.setTime(tran.dateTime.time);
			tran.setPropertyValue("dateTime", tranTS);
		endif;
	endforeach;
	commitTransaction;

	// do storage for a cash payment at 11/09/2015
	delete transParams;
	create transParams transient;
	transParams.type := TRANS_TYPE_STORAGE;
	transParams.noCharge := false;
	transParams.userId := "CNWJRE1";
	transParams.isManual := true; // NAVAB1 23APR2024 - FIXING UTs

	tranDate.setDate(11,9,2015);
	tranTS.setDate(tranDate);
	transParams.dateTime := tranTS;
	beginTransaction;
	ti.createTransaction(transParams, app.myPassport);
	commitTransaction;

	
		secondQuantity := 2975;
		secondValue := 2975.00;
	

	foreach tran in ti.allTransactions do
		if tran.isKindOf(CM_Storage) then
			foreach invLine in tran.allInvoiceLines do
				count := count + 1;
				if count = 1 then
					self.assertEqualMsg(invLine.quantity, 119.Real, "First invoice line quantity");
					self.assertEqualMsg(invLine.lineTotal, 89.25.Decimal, "First invoice line value");
				elseif count = 2 then
//					self.assertEqualMsg(invLine.quantity, secondQuantity, "Second invoice line quantity");
//					self.assertEqualMsg(invLine.lineTotal, secondValue, "Second invoice line value");
				endif;
			endforeach;
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Storage invoice lines");
epilog
	delete transParams;
	beginTransaction;
	terminal.setConfig(InvoiceRoundLineTotal,roundDecimalOpt);
	commitTransaction;
	
	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="tEscalatingQuantityWeightRange" id="ce51da8e-6ad7-4396-be9c-89827a294bbc">
        <updating/>
        <source>tEscalatingQuantityWeightRange() updating;
// cnwma1
// cnwjre1
/* ---------------------------------------------------------------------------
Created:    June 2014

Purpose:    Replace manual test for escalating quantity range using cargo weight.
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	count	: Integer;
	cargoMap	: CM_TranMap;
	service1,
	service2,
	service3	: CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
  	invLineType2,
	invLineType3	: CM_InvoiceLineDesc;
	invoiceLine	: CM_InvoiceLine;
	services : CM_ServiceByNameDict;
	operator	: CM_Operator;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo1,
	cargo2,
	cargo3	: CM_TrackedItem;
	aPort : CM_Port;
	trans : CM_TransactionSet;

begin

	self.deleteTransactionMaps();

	// block stack
	bs:= self.getTerminalArea("UTSTORE").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteInvoiceTransactionMap(1, 'UT_CargoMultiWeight');
	self.deleteInvoiceType("UT_InvTypeWeight");
	self.deleteInvoiceService("UT_ServiceWeight1", FORCED_ERASE);
	self.deleteInvoiceService("UT_ServiceWeight2", FORCED_ERASE);
	self.deleteInvoiceService("UT_ServiceWeight3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeWeight1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeWeight2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeWeight3", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Types
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeWeight", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeWeight not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT04'];
	self.assertNotNullMsg(calType1, "Calculation type CCT04 not found");
	
	service1 := self.createInvoiceService("UT_ServiceWeight1","weight1", calType1, null);
	self.assertNotNullMsg(service1, "UT_ServiceWeight1 not created");
 	services.add(service1);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeWeight1", calType1, invType, services,"SDT1");
	self.assertNotNullMsg(invLineType1, "UT_LineTypeWeight1 not created");

	service2 := self.createInvoiceService("UT_ServiceWeight2","weight2", calType1, null);
	self.assertNotNullMsg(service2, "UT_ServiceWeight2 not created");
	services.clear();
 	services.add(service2);
	
	invLineType2 := self.createInvoiceLineType("UT_LineTypeWeight2", calType1, invType, services,"SDT1");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeWeight2 not created");

	service3 := self.createInvoiceService("UT_ServiceWeight3","weight3", calType1, null);
	self.assertNotNullMsg(service3, "UT_ServiceWeight3 not created");
	services.clear();
 	services.add(service3);
	
	invLineType3 := self.createInvoiceLineType("UT_LineTypeWeight3", calType1, invType, services,"SDT1");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeWeight3 not created");

	// Need to map to above invoice line types
	self.tranMapLoadEscCargoWeight();
	
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	cargo1 := self.addContainerAtLocation("UACU7894561", operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs);
	// this has weight of 2000
	self.opts.addAssoc("TotalWeight", "2100");
	self.updateTrackedItem(cargo1);

	cargo2 := self.addContainerAtLocation("UACU7894562", operator, "2100", "GENL", TI_IMEX_STATUS_IMPORT, bs);
	self.opts.addAssoc("TotalWeight", "4000");
	self.updateTrackedItem(cargo2);
	
	cargo3 := self.addContainerAtLocation("UACU7894563", operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs);
	self.opts.addAssoc("TotalWeight", "6000");
	self.updateTrackedItem(cargo3);

	count := 0;
	foreach invoiceLine in cargo1.invoiceLines do
		count := count + 1;
		self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, "UT_LineTypeWeight1", "First cargo invoice line type");
		self.assertEqualMsg(invoiceLine.quantity, 2100.Real, "First cargo invoice line quantity");
	endforeach;
	self.assertEqualMsg(count, 1, "First cargo invoice line count");
	
	count := 0;
	foreach invoiceLine in cargo2.invoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, "UT_LineTypeWeight1", "Second cargo invoice line " &amp; count.String &amp; " type");
			self.assertEqualMsg(invoiceLine.quantity, 2100.Real, "Second cargo invoice line " &amp; count.String &amp; " quantity");
		elseif count = 2 then
			self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, "UT_LineTypeWeight2", "Second cargo invoice line " &amp; count.String &amp; " type");
			self.assertEqualMsg(invoiceLine.quantity, 1900.Real, "Second cargo invoice line " &amp; count.String &amp; " quantity");
		endif;
	endforeach;
	self.assertEqualMsg(count, 2, "Second cargo invoice line count");
	
	count := 0;
	foreach invoiceLine in cargo3.invoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, "UT_LineTypeWeight1", "Third cargo invoice line " &amp; count.String &amp; " type");
			self.assertEqualMsg(invoiceLine.quantity, 2100.Real, "Third cargo invoice line " &amp; count.String &amp; " quantity");
		elseif count = 2 then
			self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, "UT_LineTypeWeight2", "Third cargo invoice line " &amp; count.String &amp; " type");
			self.assertEqualMsg(invoiceLine.quantity, 2000.Real, "Third cargo invoice line " &amp; count.String &amp; " quantity");
		elseif count = 3 then
			self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, "UT_LineTypeWeight3", "Third cargo invoice line " &amp; count.String &amp; " type");
			self.assertEqualMsg(invoiceLine.quantity, 1900.Real, "Third cargo invoice line " &amp; count.String &amp; " quantity");
		endif;
	endforeach;
	self.assertEqualMsg(count, 3, "Third cargo invoice line count");
	
epilog
	delete trans;
	delete services;
	// delete this tran map so following tests can delete the invoice line descs etc
	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	self.deleteInvoiceTransactionMap(1, 'UT_CargoMultiWeight');
	self.resetDefaultTranMap();											// 17/04/2013 cnwmh5
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tEscalatingStorage" id="0caf45c4-f67e-4d5d-8627-8889714d7060">
        <updating/>
        <source>tEscalatingStorage() updating;
// cnwma1
// cnwjre1
/* ---------------------------------------------------------------------------
Created:     Oct 2010 by cnwjre1

Purpose:     
        
Change Date	Who		Reason
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
------------------------------------------------------------------------------*/
vars
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	quantityHookCode,
	rateHookCode,
	remarksHookCode: String;
	start,
	expiry : TimeStamp;
	ignoreEntry : Boolean;
	costs : DecimalArray;
	operator	: CM_Operator;
	debtor : CM_DebtorNode;
	debtorRate : CM_DebtorRate;
	rateEntry : CM_RateEntry;

begin

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	bs:= self.getTerminalArea("UTSTORE").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE");
	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.deleteInvoiceTransactionMap(1, 'UT_StorageFree');
	self.deleteInvoiceType("UT_InvTypeStore");
	self.deleteInvoiceService("UT_ServiceStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreE", FORCED_ERASE);
	self.deleteCalculationType('UTESCSTO2', NORMAL_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Calculation type, Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore not created");

	rateHookCode := 'amendRate(_cmif : CMIF_CalcTypeRateHook) : Real;
// _cmif.origRate is the base daily rate 
vars
	start, now : Date;
	newRate : Real;
	days : Integer;
	weeks : Integer;
	daysInLastWeek : Integer;
	total : Integer;
	totalAmount : Real;
begin
	start := _cmif.myTransaction.CM_TITransaction.dateTime.date;
	days := now - start;
	if days = 0 then
		return _cmif.origRate;
	endif;
	weeks := days div 7;
	daysInLastWeek := days - weeks * 7;

	total := (weeks * (weeks + 1)) div 2;		// sum of numbers from 1 to weeks
	totalAmount := _cmif.origRate * 7 * total + daysInLastWeek * (_cmif.origRate * (weeks + 1));
	newRate := totalAmount / days;
	return newRate;
end;';
	calType1 := self.addCalculationType(0, 'UTESCSTO2', 'Escalating Storage UNIT TEST', quantityHookCode, rateHookCode, remarksHookCode, 0,0,0,0, true, false, false, false,0, null, null);
	self.assertNotNullMsg(calType1, "Calculation type Escalating Storage not found");
	
	theService := self.createInvoiceService("UT_ServiceStore1","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore1 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStoreE", calType1, invType, services,"SDT1");
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStoreE not created");
	
	create costs transient;
	// the invoicing debtor is that of the operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	
	// set a base rate for the default debtor and the current service
	create debtorRate transient;
	debtorRate.setProxy(theService, debtor);
	costs.add(10.00);
	start.setDate("01/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, ignoreEntry, costs, 0, 0, null, null);

	// Need to map to above invoice line type
	self.tranMapLoadEscStorage();


	// create a container with retrospective transactions (refer example on PAR 24160)
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE", 100, null);


	// Create Storage Transactions
	cargo := self.addContainerAtLocnDisch("STOR2077441", "2200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	self.createStorageTransactions7(cargo);
	self.validateStorageTransactions7(cargo);

	// Create Storage Transactions
	cargo := self.addContainerAtLocnDisch("STOR2077442", "4200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	self.createStorageTransactions8(cargo);
	self.validateStorageTransactions8(cargo);

	// Create Storage Transactions
	cargo := self.addContainerAtLocnDisch("STOR2077443", "4200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	self.createStorageTransactions9(cargo);
	self.validateStorageTransactions9(cargo);

	cargo := self.addContainerAtLocnDisch("STOR2077444", "4200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	self.createStorageTransactions10(cargo);
	self.validateStorageTransactions10(cargo);

	cargo := self.addContainerAtLocnDisch("STOR2077445", "4200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	self.createStorageTransactions11(cargo);
	self.validateStorageTransactions11(cargo);

epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	delete costs;
	delete debtorRate;
end;</source>
    </JadeMethod>
    <JadeMethod name="tEscalatingStorageFreeDays" id="68a16c7f-937f-4ffe-a300-5b8dd4abbd85">
        <updating/>
        <source>tEscalatingStorageFreeDays() updating;
// cnwma1
// cnwjre1 
//	create an invoice line per range (full escalating) with 5 additional days free
//	33923 container receive date 10/09/2013 effective date 16/04/2014, 
//	simulated by back-dating this number of days and releasing today
//  10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
// 28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
vars
	dateNow		: Date;
	dateDifference	: Integer;
	quantity	: Real;
	terminal	: CM_Terminal;
	invType			: CM_InvoiceDesc;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate	: Date;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	invoiceLine	: CM_InvoiceLine;
	tiArray : CM_TIArray;
begin

	dateDifference :=  "16/04/2014".Date - "10/09/2013".Date;

	terminal := self.getTerminal();

	bs:= self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Types
	////////////////////////////////////////////////////////////////////
	invType := self.addIfNewInvoiceType("UT_InvTypeStore3");
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");
	if invType.invoiceType &lt;&gt; InvoiceTypeStorage then
		beginTransaction;
		invType.invoiceType := InvoiceTypeStorage;
		commitTransaction;
	endif;

	self.addIfNewServiceILD("UT_ServStore1", "CCT06", "UT_LTStore1", null, invType);
	self.addIfNewServiceILD("UT_ServStore1", "CCT06", "UT_LTStore2", null, invType);
	self.addIfNewServiceILD("UT_ServStore1", "CCT06", "UT_LTStore3", null, invType);
	self.addIfNewServiceILD("UT_ServStore1", "CCT06", "UT_LTStore4", null, invType);
	self.addIfNewServiceILD("UT_ServStore1", "CCT06", "UT_LTStore5", null, invType);
	self.addIfNewServiceILD("UT_ServStore1", "CCT06", "UT_LTStore6", null, invType);

	// the invoicing debtor is that of the operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	self.setDebtorCashOnly(debtor, terminal, false);

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadEscFreeStorage();
	
	// create a container with retrospective transactions 
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE3", 100, null);

	cargo := bs.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"STOR4300114"];
	if cargo &lt;&gt; null then
		self.deleteCargo(cargo.id, cargo.myCargoType.abbreviation.toUpper);
	endif;
	cargo := self.addContainerAtLocnDisch("STOR4300114", "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController, aPort, voy);
	
	tranDate := dateNow - dateDifference;		// "10/09/2013".Date;		// receival date
	tranTS.setDate(dateNow);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	beginTransaction; // ### TFS BUG 60548 10OCT2023 NAVAB1
	cargo.evaluateFreeStorageDays(null,true); //10/09/2023 navmv20 CR 58250 Task 58252	//28.05.2024 navma1 #64224
	commitTransaction;
	create tiArray transient;
	tiArray.add(cargo);
	//app.myTrxUA.trxUpdateTIAddStorageDays( cargo, 5, "UT Extra Days", app.myPassport);
	app.myTrxUA.trxUpdateTIAddStorageDays( tiArray, 5, "UT Extra Days", app.myPassport);
	beginTransaction; // ### TFS BUG 60548 10OCT2023 NAVAB1
	cargo.evaluateFreeStorageDays(null,true); //10/09/2023 navmv20 CR 58250 Task 58252		//22.05.2024 navma1 #64224
	commitTransaction;
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(cargo.additionalStorageDays, 5);
	
	// gate it out to get the storage
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	
	self.roadExit(vvr);
	
	foreach invoiceLine in cargo.invoiceLines do
		quantity := quantity + invoiceLine.quantity;
	endforeach;
	self.assertEqualMsg(quantity, 198.Real, "Pro forma invoice line quantity");
	
epilog
	delete tiArray;
	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="tExclusiveStorageDays" id="e6acd0db-cc17-4544-a110-9443baa79886">
        <updating/>
        <source>tExclusiveStorageDays() updating;
// cnwma1
// cnwjre1

// Uses the operator free storage days config.
// receive an MT, then release as a FULL
// Test CCMS 2109 par 26108 - this is the default processing
vars

begin
	self.inclExclStorageDays(false);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tExternalInterfaceGPHA" id="fa818327-a646-4cbe-ad7c-3820dd4fb45c">
        <source>tExternalInterfaceGPHA();
// cnwma1
/*	cnwjre1
Purpose:			
Date		Who		Reason
21 May 2013	NAVAB1	Initial creation
Oct 2015 revised for 37040 using XML not csv
*/
constants
	CONTID = "GPHU0002276";
	GLCODE1 = "1235-993838";
	GLCODE2 = "9823-99575847";
	GLCODE3 = "4451-992012020";
vars
	taxConfig	: Boolean;
	setConfig	: Boolean;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	ild1,
	ild2,
	ild3		: CM_InvoiceLineDesc;
	invType		: CM_InvoiceDesc;
	services	: CM_ServiceByNameDict;
	allServices	: CM_ServiceByNameDict;
	operator	: CM_Operator;
	costs : DecimalArray;
	debtor : CM_DebtorNode;
	ti: CM_TrackedItem;
	invoice	: CM_Invoice;
	selectedTypes: CM_CargoBOLTypeSet;
	stopsTable: CM_StopsTable;
	processAreas: IntegerArray;
	//opts : CM_AssociationDict;
	trans : CM_TransactionSet;
	transients	: ObjectArray;
	glCode : CM_GLCode;
	ioClassActual : CM_ExtFinanceIO;
	ioClassForTest : CM_GPHAInterface;
	origPath : String;
	now	: TimeStamp;
	tiSet	: CM_TISet;
	cmObj 	: CM_Object;
	taxCode : CM_TaxCode;
	taxRate : CM_TaxRate;
begin

	taxConfig := self.myBank.terminal.getConfig(InvoiceMultiTaxRates).Boolean;
	if not taxConfig then
		beginTransaction;
		self.myBank.terminal.setConfig(InvoiceMultiTaxRates, true);
		commitTransaction;
	endif;

	self.setTerminalConfig(FinancialRateDPlaces, 6); //19/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	self.setTerminalConfig(InvoiceRoundLineTotal, 6); //19/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	
	// delete any old objects
	self.deleteContainer(CONTID);
	//self.deleteStopsTable(99); //19/05/2025	navkc1 JIRA EPIC-34131 STORY-34818 - now creating manual invoice line to test 10 decimals
	//self.deleteStopsTable(78); //19/05/2025	navkc1 JIRA EPIC-34131 STORY-34818 - now creating manual invoice line to test 10 decimals
	self.deleteInvoiceLineType("UT_GPHAInvLineType1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_GPHAInvLineType2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_GPHAInvLineType3", FORCED_ERASE);
	self.deleteInvoiceService("UT_GPHAService1", FORCED_ERASE);
	self.deleteInvoiceService("UT_GPHAService2", FORCED_ERASE);
	self.deleteInvoiceService("UT_GPHAService3", FORCED_ERASE);
	self.deleteInvoiceGLCode(GLCODE1);
	self.deleteInvoiceGLCode(GLCODE2);
	self.deleteInvoiceGLCode(GLCODE3);

	ioClassActual := self.getTerminalConfig(FinancialIOClass).CM_ExtFinanceIO;

	// We are going to write out 3 files as part of the normal GPHA export, but we should not use the configured export path, instead we will use c_misc on the server
	ioClassForTest := CM_GPHAInterface.firstInstance().CM_GPHAInterface;
	if ioClassForTest = null then	
		ioClassForTest := app.myTrxCA.trxCreateExternalFinanceClass(CM_GPHAInterface).CM_GPHAInterface;
	endif;
	if ioClassForTest &lt;&gt; null then	
		self.setTerminalConfig(FinancialIOClass,ioClassForTest);
		origPath := ioClassForTest.exportPath;
		beginTransaction;
		ioClassForTest.exportPath := "..\c_misc\";
		commitTransaction;
	endif;
	
	create transients transient;
	create tiSet transient;
	// create new instances
	create services transient;
	create allServices transient;
	invType := self.getInvoiceType("UT_GPHAINVTYPE");
	self.assertNotNullMsg(invType, "Invoice type UT_GPHAINVTYPE not created");

	// three services and invoice line descs, for calc type of Quantity, Weight and Weight (tonnes)
	calcType := app.myRoot.allCalculationTypesByCode['CCT01'];		// Units (Qty)
	self.assertNotNullMsg(calcType, "Calculation type CCT01 not found");
	
	glCode := self.createInvoiceGLCode(GLCODE1, "UnitTest GPHA 1");
	
	
	// Delete existing tax code //19/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	taxCode := self.myBank.allTaxCodes["UT_GPHATAX"];
	if taxCode &lt;&gt; null then
		cmObj := taxCode;
		app.myPassport.setWarningsIgnored(true);
		app.myTrxDA.trxDeleteCMObject(cmObj, app.myPassport);
		app.myPassport.setWarningsIgnored(false);
	endif;
	
	// create new tax code //19/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	taxCode := self.addTaxCode("UT_GPHATAX", "Ghana 17%", null);
	taxRate := self.addTaxRate(taxCode, 17.00, now);
	
	self.opts.purge(); //16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	self.opts.addAssoc("ExternalRef1", "UT_GPHAService1 - ext ref 1"); //16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	self.opts.addAssoc("ExternalRef2", "UT_GPHAService1 - ext ref 2"); //16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	self.opts.addAssoc(UTTI_TaxCode, taxCode);
	service := self.createInvoiceService("UT_GPHAService1", "1235", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.add(service);
	ild1 := self.createInvoiceLineType("UT_GPHAInvLineType1", calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	calcType := app.myRoot.allCalculationTypesByCode['CCT04'];		// Weight (kilos)
	self.assertNotNullMsg(calcType, "Calculation type CCT04 not found");

	glCode := self.createInvoiceGLCode(GLCODE2, "UnitTest GPHA 2");
	self.opts.purge(); //16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	self.opts.addAssoc("ExternalRef1", "UT_GPHAInvLineType2 - ext ref 1"); //16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	self.opts.addAssoc("ExternalRef2", "UT_GPHAInvLineType2 - ext ref 2"); //16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	self.opts.addAssoc(UTTI_TaxCode, taxCode);
	service := self.createInvoiceService("UT_GPHAService2", "9823", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	services.clear();
	services.add(service);
	ild2 := self.createInvoiceLineType("UT_GPHAInvLineType2", calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	calcType := app.myRoot.allCalculationTypesByCode['CCT08'];		// Weight (tonnes)
	self.assertNotNullMsg(calcType, "Calculation type CCT08 not found");

	glCode := self.createInvoiceGLCode(GLCODE3, "UnitTest GPHA 3");
	self.opts.purge(); //16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818 
	self.opts.addAssoc("ExternalRef1", "UT_GPHAService3 - ext ref 1"); //16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	self.opts.addAssoc("ExternalRef2", "UT_GPHAService3 - ext ref 2"); //16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	self.opts.addAssoc(UTTI_TaxCode, taxCode);
	service := self.createInvoiceService("UT_GPHAService3", "4451", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	allServices.add(service);
	
	self.opts.purge(); //16/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	
	services.clear();
	services.add(service);
	ild3 := self.createInvoiceLineType("UT_GPHAInvLineType3", calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	self.tranMapLoadGPHAInterface();

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
	// set rates such that a known invoice line value is the lowest or highest 
	self.cargoGPHAInterfaceRates(allServices);

	
	// create a container
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	ti := self.addContainerOpts(CONTID, "22G1", "GENL", operator);	
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	create processAreas transient;
	processAreas.add(StopProcessCopyToChild);
	
	//19/05/2025	navkc1 JIRA EPIC-34131 STORY-34818 - now creating manual invoice line to test 10 decimals
	//create opts transient;
	//opts.addAssoc(ETRow_ProcessStopAreas, processAreas);
	//stopsTable := addStopsTable(99, "UT", "Unit Test", selectedTypes, opts);
	
	// add manual invoice
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Debtor_separation_missingfield);
	app.myPassport.setWarningsIgnored(true);
	invoice := self.createManualInvoice(self.myBank, debtor.CM_Debtor, null, invType, ti);
	self.assertNotNullMsg(invoice, "Failed to create manual invoice");
	app.myPassport.setWarningsIgnored(false);
	
	tiSet.add(ti);
	self.opts.purge();
	self.opts.addAssoc("allTrackedItems", tiSet);
	self.createManualInvoiceLine(ild1, invoice, 16823.0123654321, "line 1", now.date());
	
	self.opts.purge();
	self.opts.addAssoc("allTrackedItems", tiSet);
	self.createManualInvoiceLine(ild2, invoice, 16823.01236543219, "line 2", now.date());
	
	self.opts.purge();
	self.opts.addAssoc("allTrackedItems", tiSet);
	self.createManualInvoiceLine(ild3, invoice, 16823.01236543215, "line 3", now.date());
	
	self.opts.purge();
	self.opts.addAssoc("allTrackedItems", tiSet);
	self.createManualInvoiceLine(ild1, invoice, 16823.0123654321, "line 4", now.date());
	
	self.opts.purge();
	self.opts.addAssoc("allTrackedItems", tiSet);
	self.createManualInvoiceLine(ild2, invoice, 16823.01236543219, "line 5", now.date());
	
	self.opts.purge();
	self.opts.addAssoc("allTrackedItems", tiSet);
	self.createManualInvoiceLine(ild3, invoice, 16823.01236543215, "line 6", now.date());
	
	//19/05/2025	navkc1 JIRA EPIC-34131 STORY-34818 - now creating manual invoice line to test 10 decimals
	//self.addStop(ti, stopsTable);
	//stopsTable := addStopsTable(78, "UT2", "Unit Test2 ", selectedTypes, opts);
	//self.addStop(ti, stopsTable);

	
	// ##########################
	// ### If need to manually test  uncomment this 'return'
	//return;
	
	invoice := ti.invoiceLines.first.invoice;
	self.postInvoice(invoice, true, false);

	self.validateGPHAInvoiceFiles(invoice);
	
	// TFS 6759 - Check that we can post this voyage invoice then return from posting
	
	self.assertTrueMsg(invoice.isPosted, "Cargo invoice did not post.");
	self.returnInvoice( invoice, true );
	self.assertTrueMsg(invoice.isReversed, "Cargo invoice did not post return.");
	self.assertTrueMsg(invoice.myReversedCreditInvoice &lt;&gt; null, "Cargo invoice 'Reverse Credit' invoice not found.");
	self.assertTrueMsg(invoice.myReversedCreditInvoice.isReverseCredit, "Cargo invoice 'Reverse Credit' invoice status incorrect.");
	self.assertTrueMsg(invoice.myReversedPendingInvoice &lt;&gt; null, "Cargo invoice 'Reverse Pending' invoice not found.");
	self.assertTrueMsg(invoice.myReversedPendingInvoice.isPending, "Cargo invoice 'Reverse Pending' invoice status incorrect.");
	
	
epilog
	self.resetDefaultTranMap();
	// delete this tran map so following tests can delete the invoice line descs etc
	self.deleteInvoiceTransactionMap(1, 'UT_CargoGPHA');
	if ioClassForTest &lt;&gt; null then	
		beginTransaction;
		ioClassActual.exportPath := origPath;
		commitTransaction;
	endif;
	
	delete services;
	delete allServices;
	delete costs;
	if transients &lt;&gt; null then
		transients.purge();
		delete transients;
	endif;
	delete selectedTypes;
	delete processAreas;
	//delete opts;
	delete trans;
	if setConfig then
		beginTransaction;
		self.myBank.terminal.setConfig(InvoiceMultiTaxRates, taxConfig);
		commitTransaction;
	endif;
	cmObj := taxCode;
	app.myTrxDA.trxDeleteCMObject(cmObj, app.myPassport); //19/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tFractionalQuantityRange" id="a6ac4928-85bc-4343-8030-21ca092f7d23">
        <updating/>
        <source>tFractionalQuantityRange() updating;
// cnwma1
// cnwjre1
/* ---------------------------------------------------------------------------
Created:    June 2014

Purpose:    Replace manual test for multiple quantity range using cargo weight.
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	date	: Date;
	ts		: TimeStamp;
	count	: Integer;
	cargoMap	: CM_TranMap;
	service1,
	service2,
	service3	: CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
  	invLineType2,
	invLineType3	: CM_InvoiceLineDesc;
	invoice		: CM_Invoice;
	invoiceLine	: CM_InvoiceLine;
	services : CM_ServiceByNameDict;
	operator	: CM_Operator;
	bs: CM_BlockStack;
	termArea	: CM_TerminalArea;
	loc		: CM_LocationsController;
	grid : CM_GridController;
	voy : CM_Voyage;
	cargo1,
	cargo2,
	cargo3	: CM_TrackedItem;
	aPort : CM_Port;
	trans : CM_TransactionSet;
	tran : CM_TITransaction;
begin

	self.deleteTransactionMaps();

	// block stack
	bs:= self.getTerminalArea("UTSTORE").CM_BlockStack;
	self.deleteInvoiceLines(bs.myLocationsController);
	
	self.deleteInvoiceTransactionMap(1, 'UT_CargoFractionalWeight');
	self.deleteInvoiceType("UT_InvTypeWeight");
	self.deleteInvoiceService("UT_ServiceWeight1", FORCED_ERASE);
	self.deleteInvoiceService("UT_ServiceWeight2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeWeight1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeWeight2", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Types
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeWeight", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeWeight not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT04'];		// cargo weight kilos
	self.assertNotNullMsg(calType1, "Calculation type CCT04 not found");
	
	service1 := self.createInvoiceService("UT_ServiceWeight1","weight1", calType1, null);
	self.assertNotNullMsg(service1, "UT_ServiceWeight1 not created");
 	services.add(service1);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeWeight1", calType1, invType, services,"SDT1");
	self.assertNotNullMsg(invLineType1, "UT_LineTypeWeight1 not created");

	service2 := self.createInvoiceService("UT_ServiceWeight2","weight2", calType1, null);
	self.assertNotNullMsg(service2, "UT_ServiceWeight2 not created");
	services.clear();
 	services.add(service2);
	
	invLineType2 := self.createInvoiceLineType("UT_LineTypeWeight2", calType1, invType, services,"SDT1");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeWeight2 not created");


	// Need to map to above invoice line types
	self.tranMapLoadFractCargoWeight();
	
	voy:=self.createVesselVoyage3();
	
	aPort := app.myRoot.allPorts["NZAKL"];

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	cargo1 := self.addContainerAtLocation("UACU7894561", operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs);
	// this has weight of 2000.1
	// Transaction map has entries for 1-2000 and 2001-MAX.  This falls in the gap.
	self.opts.addAssoc("TotalWeight", "2000.1");
	self.updateTrackedItem(cargo1);

	count := 0;
	// it should round up the weight internally to 2001 and match the second tran map entry which is UT_LineTypeWeight2
	foreach invoiceLine in cargo1.invoiceLines do
		count := count + 1;
		self.assertEqualMsg(invoiceLine.invoiceLineDesc.narration, "UT_LineTypeWeight2", "Cargo invoice line type");
	endforeach;
	self.assertEqualMsg(count, 1, "Cargo invoice line count");
	
	
epilog
	delete trans;
	delete services;
	// delete this tran map so following tests can delete the invoice line descs etc
	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	self.deleteInvoiceTransactionMap(1, 'UT_CargoFractionalWeight');
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSMonthlyCharge" id="b237e6d8-3b61-4a61-b309-938d25500b87">
        <updating/>
        <source>tHMSMonthlyCharge() updating;
// cnwma1
// cnwjre1	par 34744 monthly marine invoices
//	Has a marine invoice type which is monthly.  Three voyages arrive and leave within the month.
//	There should be a single invoice for all voyages, with an invoice line from each voyage.
vars
	date,
	now			: Date;
	time		: Time;
	count		: Integer;
	invCount	: Integer;
	invLine		: CM_InvoiceLine;
	start		: TimeStamp;
	fromDateTime, 
	toDateTime	: TimeStamp;
	costs		: DecimalArray;
	term		: CM_Terminal;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	services	: CM_ServiceByNameDict;
	invType1	: CM_InvoiceDesc;
	ild			: CM_InvoiceLineDesc;
	resourceType	: HMS_ResourceType;
	harbour		: HMS_Harbour;
	berth		: HMS_Berth;
	wharf		: HMS_Wharf;
	resource	: HMS_Resource;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	pxyDebtorRate	: CM_DebtorRate;
	rateEntry	: CM_RateEntry;
	voyage1,
	voyage2,
	voyage3		: CM_Voyage;
	movement	: HMS_VoyageMovement;
	transSet	: CM_TransactionSet;
	invoice		: CM_Invoice;
	invoiceLines : ObjectArray;
	currentFinClass	: CM_ExtFinanceIO;
begin
	
	currentFinClass := getInvoiceFinancialClass();
	self.setInvoiceFinancialClass(CM_DefaultFinanceIO, null);
	
	term := self.getTerminal();
	harbour := term.myHarbour;
	berth := harbour.allBerths.last;
	wharf := berth.myWharf;

	// Water calculation type
	service := self.myBank.services["UTWater"];
	//  delete any invoice (lines, charges) using the service first so can delete the service
	if service &lt;&gt; null then
		self.deleteInvoicesUsingService(service);
	endif;
	service := self.myBank.services["UTWater1"];
	//  delete any invoice (lines, charges) using the service first so can delete the service
	if service &lt;&gt; null then
		self.deleteInvoicesUsingService(service);
	endif;
	// delete the services so can delete the calculation type
	self.deleteInvoiceService("UTWater", FORCED_ERASE);
	self.deleteInvoiceService("UTWater1", FORCED_ERASE);
	self.deleteInvoiceCalcType("UTH2O");	
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_RESOURCE_QTY, "UTH2O", "Water usage", 
										  0, 0, 0, 0, null, false,
										  null, null, 0, 0, 0,
										  null, null, null, null,
										  false, true, false,		// is voyage type=true
										  null, null, null, null);
	
	// Water service
	service := self.createInvoiceService("UTWater1","Water Used", calcType, null);
	
	// Voyage monthly invoice type
	self.deleteInvoiceType("UTVoyageMonthly");
	invType1 := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_For_Financial_Period,
											null,
											"UTVoyageMonthly",
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");
	// delete transaction map
	self.deleteInvoiceTransactionMap(3, 'UT_VTMIS4');
	
	// Water usage invoice line descriptions
	self.deleteInvoiceLineType("UTWaterUsage1", FORCED_ERASE);
	create services transient;
 	services.add(service);
	
	// invoice type
	ild := self.createInvoiceLineType("UTWaterUsage1", calcType, invType1, services, "SDT4");	// charge ship operator
	
	// resource type - delete used resource first
	self.deleteHarbourResource("UTWATER01", harbour);
	resourceType := self.addHMSResourceType("UTWATER", "Water Usage", "m3", 0, true, true,
											false, false, false, false);

	// resource
	resource := self.addHarbourResource("UTWATER01", "Water meter 1 usage", harbour, resourceType, wharf, 
										0, 0, false);
										
	create costs transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
// set a rate ($3.00) for the service and actual debtor
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(service, debtor);
	costs.add(3.00);
	start.setDate("01/05/2010".Date);
	start.setTime("00:00".Time);
	rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, null, false, costs, 0, 0, null, null);

	// load HMS transaction map
	self.tranMapLoadVTMIS4();
	
	// vessel and voyage with HMS data
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	date := "01/06/2014".Date;
	fromDateTime.setDate(date);
	fromDateTime.setTime(time);
	toDateTime := fromDateTime.addDays(2);

	voyage1 := self.createVesselVoyage4("UTINVVSL4A", "UTINVVOY4A", fromDateTime, toDateTime);
	self.updateVoyageHMS(voyage1, 11111, 12222, 20.0, 5.0, 60000, 0);
	
	// movement maintenance, add resource usage (1200 units) 
	movement := voyage1.myHMSVoyageData.allVoyageMovements.first;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime,  1200, false, movement);
	// set the move status so invoicing will take place
	beginTransaction;
	foreach movement in voyage1.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
	endforeach;
	commitTransaction;

	// generate invoice
	self.generateVoyageInvoicing(voyage1);
	
	// test invoice - should be one, with one line
	foreach invoice in voyage1.allInvoices do
		count := count + 1;
		foreach invLine in invoice.invoiceLines do
			invCount := invCount + 1;
			self.assertEqualMsg(invLine.quantity, 1200.Real, "line 1 quantity");
			self.assertEqualMsg(invLine.lineTotal, 3600.Decimal, "line 1 value");
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UTWaterUsage1", "line 1 ILD ");
		endforeach;
		self.assertEqualMsg(invCount, 1, "Invoice lines");
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, voyage 1");
	
	// VOYAGE 2
	date := "10/06/2014".Date;
	fromDateTime.setDate(date);
	fromDateTime.setTime(time);
	toDateTime := fromDateTime.addDays(2);

	voyage2 := self.createVesselVoyage4("UTINVVSL4B", "UTINVVOY4B", fromDateTime, toDateTime);
	self.updateVoyageHMS(voyage2, 11111, 12222, 20.0, 5.0, 60000, 0);
	// movement maintenance, add resource usage (1200 units) 
	movement := voyage2.myHMSVoyageData.allVoyageMovements.first;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime,  1200, false, movement);
	// set the move status so invoicing will take place
	beginTransaction;
	foreach movement in voyage2.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
	endforeach;
	commitTransaction;

	// generate invoice
	self.generateVoyageInvoicing(voyage2);
	
	// test invoice - should be none - the invoice from voyage 1 should be found and re-used
	count := 0;
	foreach invoice in voyage2.allInvoices do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 0, "Voyage 2 Invoices");
	count := 0;
	invCount := 0;
	foreach invoice in voyage1.allInvoices do
		count := count + 1;
		foreach invLine in invoice.invoiceLines do
			invCount := invCount + 1;
			self.assertEqualMsg(invLine.quantity, 1200.Real, "line quantity");
			self.assertEqualMsg(invLine.lineTotal, 3600.Decimal, "line value");
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UTWaterUsage1", "line ILD ");
		endforeach;
		self.assertEqualMsg(invCount, 2, "Voyage 1 invoice lines, voyage 2");
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage 1 invoices, voyage 2");
	
	// VOYAGE 3
	date := "20/06/2014".Date;
	fromDateTime.setDate(date);
	fromDateTime.setTime(time);
	toDateTime := fromDateTime.addDays(2);

	voyage3 := self.createVesselVoyage4("UTINVVSL4C", "UTINVVOY4C", fromDateTime, toDateTime);
	self.updateVoyageHMS(voyage3, 11111, 12222, 20.0, 5.0, 60000, 0);
	// movement maintenance, add resource usage (1200 units) 
	movement := voyage3.myHMSVoyageData.allVoyageMovements.first;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime,  1200, false, movement);
	// set the move status so invoicing will take place
	beginTransaction;
	foreach movement in voyage3.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
	endforeach;
	commitTransaction;

	// generate invoice
	self.generateVoyageInvoicing(voyage3);
	
	// test invoice - should be one, with one line
	count := 0;
	foreach invoice in voyage3.allInvoices do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 0, "Voyage 3 Invoices");
	count := 0;
	invCount := 0;
	foreach invoice in voyage1.allInvoices do
		count := count + 1;
		foreach invLine in invoice.invoiceLines do
			invCount := invCount + 1;
			self.assertEqualMsg(invLine.quantity, 1200.Real, "line quantity");
			self.assertEqualMsg(invLine.lineTotal, 3600.Decimal, "line value");
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UTWaterUsage1", "line ILD ");
		endforeach;
		self.assertEqualMsg(invCount, 3, "Voyage 1 invoice lines, voyage 3");
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage 1 invoices, voyage 3");
	
	// TFS 6759 - Check that we can post this voyage invoice then return from posting
	invoice := voyage1.allInvoices.first;
	self.postInvoice(invoice, true, false);
	self.assertTrueMsg(invoice.isPosted, "Voyage invoice did not post.");
	
	self.returnInvoice( invoice, true );
	self.assertTrueMsg(invoice.isReversed, "Voyage invoice did not post return.");
	self.assertTrueMsg(invoice.myReversedCreditInvoice &lt;&gt; null, "Voyage invoice 'Reverse Credit' invoice not found.");
	self.assertTrueMsg(invoice.myReversedCreditInvoice.isReverseCredit, "Voyage invoice 'Reverse Credit' invoice status incorrect.");
	self.assertTrueMsg(invoice.myReversedPendingInvoice &lt;&gt; null, "Voyage invoice 'Reverse Pending' invoice not found.");
	self.assertTrueMsg(invoice.myReversedPendingInvoice.isPending, "Voyage invoice 'Reverse Pending' invoice status incorrect.");
	
	//Now do it to the pending one.
	invoice := invoice.myReversedPendingInvoice;
	self.postInvoice(invoice, true, false);
	self.assertTrueMsg(invoice.isPosted, "Voyage invoice did not post. (the pending version)");
	
	self.returnInvoice( invoice, true );
	self.assertTrueMsg(invoice.isReversed, "Voyage invoice did not post return. (the pending version)");
	self.assertTrueMsg(invoice.myReversedCreditInvoice &lt;&gt; null, "Voyage invoice 'Reverse Credit' invoice not found. (the pending version)");
	self.assertTrueMsg(invoice.myReversedCreditInvoice.isReverseCredit, "Voyage invoice 'Reverse Credit' invoice status incorrect. (the pending version)");
	self.assertTrueMsg(invoice.myReversedPendingInvoice &lt;&gt; null, "Voyage invoice 'Reverse Pending' invoice not found. (the pending version)");
	self.assertTrueMsg(invoice.myReversedPendingInvoice.isPending, "Voyage invoice 'Reverse Pending' invoice status incorrect. (the pending version)");

epilog
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;
	
	self.resetDefaultTranMap();
	delete services;
	delete costs;
	delete pxyDebtorRate;
	delete transSet;
	delete invoiceLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSMovementValShiftDelete" id="61e92fb6-2770-4a0d-970a-37478eb3a719">
        <updating/>
        <source>tHMSMovementValShiftDelete() updating;
/*
19 Jan 2025 navrv30 JIRA 33641 MTN | Deleting HMS Shift Movement Leaves Arrival and Departure Incorrect
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
*/
constants
	UTINVTYPE = "UT_VOY";
	UTBERT06 = "UTBERT06";
	UTDESC06 = "UT Berthage - 6 Hours";
	UTBERT24 = "UTBERT24";
	UTDESC24 = "UT Berthage - 24 Hours";
vars
	hmsData : HMS_VoyageData;
	pxyVoy, voyage : CM_Voyage;
	arrivalMovement : HMS_VoyageMovement;
	departureMovement : HMS_VoyageMovement;
	shiftMovement : HMS_VoyageMovement;
	calcType : CM_CalculationType;
	theService : CM_Service;
	invLineType : CM_InvoiceLineDesc;
	invType : CM_InvoiceDesc;
	services : CM_ServiceByNameDict;
	bank : CM_Bank;
	now		: Date;
	hmsObject : HMS_Object;
begin
	
	create services transient;
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	self.deleteInvoiceType(UTINVTYPE);
	invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											UTINVTYPE,
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");	
	
	
	self.deleteCalculationType(UTBERT24, FORCED_ERASE);

	calcType := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
											UTBERT24,	//_code : String;
											UTDESC24,	//_description : String;
											null,	//_quantityHookSource : String;
											null,	//_rateHookSource : String
											null	//_remarksHookSource: String;
											,24,0,24,24, false, true, false, false,0, null, null);

	self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT24 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
	
	
	self.deleteInvoiceService(UTDESC24,FORCED_ERASE);
	
	theService := self.createInvoiceService(UTDESC24,"", calcType, null);
	self.assertNotNullMsg(theService, UTDESC24 &amp; " not created");
	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC24,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC24, calcType, invType, services,"SDT1");
	
	
	//Add Calculation Type 6 HOURS
	
	self.deleteCalculationType(UTBERT06, FORCED_ERASE);
//	calcType := app.myRoot.allCalculationTypesByCode.getAtKey(UTBERT06);
//	if calcType = null then
		calcType := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
												UTBERT06,	//_code : String;
												UTDESC06,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,6,24,6,999999, false, true, false, false,0, null, null);

		self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT06 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
	//endif;
	
	self.deleteInvoiceService(UTDESC06,FORCED_ERASE);
	theService := self.createInvoiceService(UTDESC06,"", calcType, null);
	self.assertNotNullMsg(theService, UTDESC06 &amp; " not created");
 	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC06,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC06, calcType, invType, services,"SDT1");
	
	// load HMS transaction map
	self.tranMapLoadVTMIS6(UTDESC06,UTDESC24);
	

	voyage := self.createVesselVoyage6(); // Creates a vessel and voyage with HMS data setup including a wharf and a berth.

	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage is null!"); // TFS 44957

	self.hmsSetMovementsToActual(voyage);
	hmsData := voyage.myHMSVoyageData;
	
	self.assertTrueMsg(hmsData &lt;&gt; null, "HMS Data is null!");
	self.assertTrueMsg(hmsData.allBerthPreferencesByName.size = 2, "Voyage should have 2 berthing preferences, actually has " &amp; hmsData.allBerthPreferencesByName.size.String);

	// ### DEPARTURE
	departureMovement := voyage.getMovementDeparture();
	self.assertTrueMsg(departureMovement &lt;&gt; null, "Departure movement is null");
	
	// ### SHIFT
	shiftMovement := voyage.getMovementShift(1); // get first shift
	self.assertTrueMsg(shiftMovement &lt;&gt; null, "Shift movement is null");
	
	// ### Arrival
	arrivalMovement := voyage.getMovementArrival();
	self.assertTrueMsg(arrivalMovement &lt;&gt; null, "Shift movement is null");
	
	self.assertTrueMsg(shiftMovement.myPreviousMovement = arrivalMovement , "Shift movements previous not linked to arrival");
	self.assertTrueMsg(shiftMovement.myNextMovement = departureMovement , "Shift movements next not linked to departure");
	
	hmsObject := shiftMovement;
	app.myTrxDA.trxDeleteHMSObject(hmsObject, app.myPassport);
	//After deleting the shift make sure that the Ariival and the Departure movements retain their links
	self.assertTrueMsg(departureMovement.myPreviousMovement = arrivalMovement , "Departure movements previous not linked to arrival");
	self.assertTrueMsg(arrivalMovement.myNextMovement = departureMovement , "Arrival movements next not linked to departure");
epilog
	delete pxyVoy;
	delete services;

	self.resetDefaultTranMap();

end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSTidalClass" id="741b3762-2dcc-44c6-897d-893738197134">
        <updating/>
        <source>tHMSTidalClass() updating;
// cnwma1
// cnwjre1 test CCMS SFW 1327 Tidal Class, for each block unit

constants
	TypeName	 = "UTBLOCKUNIT";		// calc type, service, invoice type and invoice line code
	ResourceName = "UTBARNACLE";		// HMS resource
vars
	qtySource,
	rateSource		: String;
	qtyHookSource,
	rateHookSource,
	remarksHookSource: String;
	calcTypeValue 	: Integer;
	now				: Date;
	time			: Time;
	count			: Integer;
	blockUnit		: Integer;
	maxUnits		: Integer;
	start			: TimeStamp;
	fromDateTime, 
	toDateTime		: TimeStamp;
	name			: String;
	costs			: DecimalArray;
	ia				: IntegerArray;
	blockTypes		: IntegerArray;
	term			: CM_Terminal;
	calcType		: CM_CalculationType;
	service			: CM_Service;
	services		: CM_ServiceByNameDict;
	allServices		: CM_ServiceByNameDict;
	invType			: CM_InvoiceDesc;
	ild				: CM_InvoiceLineDesc;
	resourceType	: HMS_ResourceType;
	harbour			: HMS_Harbour;
	berth			: HMS_Berth;
	wharf			: HMS_Wharf;
	resource		: HMS_Resource;
	aVM,
	dVM				: HMS_VoyageMovement;
	arriveTidalClass,
	departTidalClass	: HMS_TidalClass;
	operator		: CM_Operator;
	debtor			: CM_Debtor;
	pxyDebtorRate,
	debtorRate		: CM_DebtorRate;
	rateEntry		: CM_RateEntry;
	allRateEntries	: CM_RateEntrySet;
	voyage			: CM_Voyage;
	movement		: HMS_VoyageMovement;
	invoice			: CM_Invoice;
	tidalClasses	: ObjectArray;
	invoiceLines 	: ObjectArray;
	allTransients	: ObjectArray;
	obj				: Object;
	cpu 			: Decimal[23,6];
	tidalClassRates : CM_RateByTidalClass;
	tidalClassRate  : CM_TidalClassRate;

begin

	calcTypeValue := INV_CALC_TYPE_TIDAL_CLASS;
	create tidalClasses transient;
	self.getSortedTidalClasses(tidalClasses);
	create allTransients transient;
	
	term := self.getTerminal();
	harbour := term.myHarbour;
	berth := harbour.allBerths.last;
	wharf := berth.myWharf;

	// hook code doubles the quantity and doubles the rate
	qtySource := 'amendQuantity(_cmif : CMIF_CalcTypeQuantityHook) : Real;
vars
	newQty  : Real;
begin
	newQty := 2 * _cmif.origQty;
	return newQty;
end;';
	rateSource := 'amendRate(_cmif : CMIF_CalcTypeRateHook) : Real;
vars
	newRate : Real;
begin
	newRate := 2 * _cmif.origRate;
	return newRate;
end;';

	create blockTypes transient;
	blockTypes.add(INV_CALC_TYPE_UNITY);
	blockTypes.add(INV_CALC_TYPE_UNIT_GRT);
	blockTypes.add(INV_CALC_TYPE_UNIT_LENGTH);
	blockTypes.add(INV_CALC_TYPE_UNIT_NRT);
	blockTypes.add(INV_CALC_TYPE_UNIT_BEAM);
	blockTypes.add(INV_CALC_TYPE_UNIT_DEADWEIGHT);
	blockTypes.add(INV_CALC_TYPE_UNIT_DRAFT_MID);
	blockTypes.add(INV_CALC_TYPE_RESOURCE_QTY);
	blockTypes.add(INV_CALC_TYPE_UNITY);		// this second type is for hook code
	maxUnits := blockTypes.size;

	// delete transaction map
	self.deleteInvoiceTransactionMap(3, 'UT_VTMIS3');

	// find the services
	foreach count in 1 to maxUnits do
		name := TypeName &amp; count.String;
		service := self.myBank.services[name];
		//  delete any invoice (lines, charges) using the service first so can delete the service
		if service &lt;&gt; null then
			self.deleteInvoicesUsingService(service);
		endif;
		// delete the service so can delete the calculation types etc
		self.deleteInvoiceService(name, FORCED_ERASE);
		self.deleteInvoiceCalcType(name);
		self.deleteInvoiceLineType(name, FORCED_ERASE);
		self.deleteInvoiceType(name);
	endforeach;
	

	create ia transient;
	create services transient;
	create allServices transient;

	foreach count in 1 to maxUnits do
		name := TypeName &amp; count.String;
		blockUnit := blockTypes[count];
		if count = maxUnits then
			qtyHookSource := qtySource;
			rateHookSource := rateSource;
		else
			qtyHookSource := null;
			rateHookSource := null;
		endif;
		calcType := self.createInvoiceCalcType(null, calcTypeValue, name, "Has block unit " &amp; count.String, 
										  0, 0, 0, 0, ia, false,
										  null, null, 0, 0, blockUnit,
										  qtyHookSource, rateHookSource, remarksHookSource, null,
										  false, true, false,		// is voyage type=true
										  null, null, null, null);
	
		// service
		service := self.createInvoiceService(name, "Block unit " &amp; count.String, calcType, null);
		allServices.add(service);
	
		// Voyage invoice type
		invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											name,
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");
		// Invoice line description
		services.clear();
		services.add(service);
	
		// invoice type
		ild := self.createInvoiceLineType(name, calcType, invType, services, "SDT4");	// charge ship operator
	endforeach;
	
	
	// resource type - delete used resource first
	self.deleteHarbourResource(ResourceName, harbour);
	self.deleteHarbourResource("UTBARN01", harbour);
	resourceType := self.addHMSResourceType(ResourceName, "Some Usage", "m3", 0, true, true,
											false, false, false, false);

	// resource
	resource := self.addHarbourResource("UTBARN01", "Barnacle 1 usage", harbour, resourceType, wharf, 
										0, 0, false);
										
	// vessel and voyage with HMS data
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	voyage := self.createVesselVoyage3();
	// check that the arrive and depart movements have a tidal class and that they are different
	aVM := voyage.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeArrival);
	arriveTidalClass := aVM.myTidalClass;
	dVM := voyage.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeDeparture);
	departTidalClass := dVM.myTidalClass;
	self.assertNotNullMsg(arriveTidalClass, "Arrival tidal class");
	self.assertNotNullMsg(departTidalClass, "Departure tidal class");
	self.assertNotEqualMsg(arriveTidalClass, departTidalClass, "Movement tidal classes");
	
	// populate the various weight/lengths used for the quantity
	self.updateVoyageHMS(voyage, 1000, 1200, 100.0, 10.0, 1400, 5.0);
	
	// load HMS transaction map
	self.tranMapLoadVTMIS3();
	
	// arrival movement maintenance, add resource usage (12 units)
	fromDateTime.setDate(now);
	fromDateTime.setTime(time);
	movement := voyage.myHMSVoyageData.allVoyageMovements.first;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime, 12, false, movement);
	// departure movement maintenance, different tidal class, add resource usage (6 units)
	fromDateTime.setDate(now);
	fromDateTime.setTime(time);
	movement := voyage.myHMSVoyageData.allVoyageMovements.last;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime, 6, false, movement);
	// set the move status so invoicing will take place
	beginTransaction;
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
	endforeach;
	commitTransaction;

	create costs transient;
	create allRateEntries transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
// set rates with a different value for each tidal class, in alphabetic order
// set rates - $3.00 for the non-used tidal classes, $4 for the arrival and $5 for the departure tidal class - for each service and actual debtor
	foreach service in allServices do
		create pxyDebtorRate transient;
		allTransients.add(pxyDebtorRate);
		pxyDebtorRate.setProxy(service, debtor);
		
		//24 Jul 2018	NDL	TFS 39338
		create tidalClassRates transient;
		foreach obj in tidalClasses do
			if obj.HMS_TidalClass = arriveTidalClass then
				cpu := 4.00;
			elseif obj.HMS_TidalClass = departTidalClass then
				cpu := 5.00;
			else
				cpu := 3.00;
			endif;
			create tidalClassRate transient;
			tidalClassRate.setDetails(	cpu,	//_costPerUnit : Decimal;
										obj.HMS_TidalClass,	//_myTidalClass : HMS_TidalClass;
										null	//_myRateEntry : CM_RateEntry
										);
			tidalClassRates.add( tidalClassRate );
		endforeach;
		
		start.setDate("01/05/2010".Date);
		start.setTime("00:00".Time);
		rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, null, false, costs, 0, 0, null, tidalClassRates);
		allRateEntries.add(rateEntry);
		
		//24 Jul 2018	NDL	TFS 39338
		if tidalClassRates &lt;&gt; null then
			if not tidalClassRates.isEmpty then
				tidalClassRates.purge();
			endif;
			delete tidalClassRates;
		endif;
		
	endforeach;

	// generate invoices
	self.generateVoyageInvoicing(voyage);

	// test invoices - should be nine, each with two lines
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		self.validateHMSInvoice5(invoice, count);
	endforeach;
	self.assertEqualMsg(count, maxUnits, "Tidal Class Invoices, test 1");

	// changes the rates to $6.00 for the non-used tidal classes, $7 for the arrival and $8 for the departure tidal class
	foreach rateEntry in allRateEntries do
		debtorRate := rateEntry.rate.CM_DebtorRate;
		
		//24 Jul 2018	NDL	TFS 39338
		create tidalClassRates transient;
		foreach obj in tidalClasses do
			if obj.HMS_TidalClass = arriveTidalClass then
				cpu := 7.00;
			elseif obj.HMS_TidalClass = departTidalClass then
				cpu := 8.00;
			else
				cpu := 6.00;
			endif;
			create tidalClassRate transient;
			tidalClassRate.setDetails(	cpu,	//_costPerUnit : Decimal;
										obj.HMS_TidalClass,	//_myTidalClass : HMS_TidalClass;
										null	//_myRateEntry : CM_RateEntry
										);
			tidalClassRates.add( tidalClassRate );
		endforeach;
		
		start.setDate("01/05/2010".Date);
		start.setTime("00:00".Time);
		self.updateInvoiceRateEntry(debtorRate, rateEntry, start, null, false, costs, 0, 0, null, tidalClassRates);
		
		//24 Jul 2018	NDL	TFS 39338
		if tidalClassRates &lt;&gt; null then
			if not tidalClassRates.isEmpty then
				tidalClassRates.purge();
			endif;
			delete tidalClassRates;
		endif;
		
	endforeach;
	
	// re-test for the new invoice values
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		self.validateHMSInvoice5a(invoice, count);
	endforeach;
	self.assertEqualMsg(count, maxUnits, "Tidal Class Invoices, test 2");

	// increase all of the voyage attributes
	self.updateVoyageHMS(voyage, 2000, 2200, 200.0, 20.0, 2400, 6.0);

	create invoiceLines transient;
	invoiceLines.clear();
	foreach invoice in voyage.allInvoices do
		invoice.invoiceLines.copy(invoiceLines);
	endforeach;

	self.invoiceLineReevaluate(invoiceLines);

	// re-test for the new quantity and value
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		self.validateHMSInvoice5b(invoice, count);
	endforeach;
	self.assertEqualMsg(count, maxUnits, "Tidal Class Invoices, test 3");
	
epilog
	self.resetDefaultTranMap();
	delete ia;
	delete blockTypes;
	delete services;
	delete allServices;
	delete costs;
	delete allRateEntries;
	delete invoiceLines;
	delete tidalClasses;
	delete tidalClassRates;
	if allTransients &lt;&gt; null then
		allTransients.purge();
		delete allTransients;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSTimeBlockCalcType1203" id="cceb7eb6-4a76-4525-9dc4-e06b8e53cd5d">
        <updating/>
        <source>tHMSTimeBlockCalcType1203() updating;
/*
	NOTE - These Units test use berths, wharves, resources and calculation types that already exist.
				The test might fail is some one changes the existing configuration OR adds a new calculation type for berthage.


*/





// cnwma1
// CNWJRE1
/*
Purpose:			test the hms berthage resources, these are normally split over a initial 24 hour block and the remaining time in blocks of 12
Date		Who		Reason
30 December 2014	NAVAB1	Initial creation
*/
constants
	UTINVTYPE = "UT_VOY";
	UTBERT03 = "UTBERT03";
	UTDESC03 = "UT Berthage - 3 Hours No Units";
	UTBERT12 = "UTBERT12";
	UTDESC12 = "UT Berthage - 12 Hours No Units";

vars
	hmsData : HMS_VoyageData;
	berthage : HMS_BerthPreference;
	pxyVoy, voyage : CM_Voyage;
	berth : HMS_Berth;
	wharf : HMS_Wharf;
	wharfRes : HMS_ResourceForWharf;
	movement : HMS_VoyageMovement;
	resUsed : HMS_ResourceUsed;
	proformaResources : CMIF_HMSResourceUsedProforma;
	calcType1, calcType2 : CM_CalculationType;
	theService : CM_Service;
	invLineType : CM_InvoiceLineDesc;
	invType : CM_InvoiceDesc;
	services : CM_ServiceByNameDict;
	bank : CM_Bank;
	invoice : CM_Invoice;
	line : CM_InvoiceLine;
	count	: Integer;
	now		: Date;

begin
	create services transient;
	bank := self.myBank;
	self.deleteInvoiceType(UTINVTYPE);
	invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											UTINVTYPE,
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");
	
	// ### CREATE CALC TYPES
	
	//Add Calculation Type 12 HOURS
	self.deleteCalculationType(UTBERT12, FORCED_ERASE);
//	calcType := app.myRoot.allCalculationTypesByCode.getAtKey(UTBERT12);
//	if calcType = null then
		calcType1 := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
												UTBERT12,	//_code : String;
												UTDESC12,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,12,0,12,12, false, true, false, false,0, null, null);

		self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT12 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
//	endif;
	
	self.deleteInvoiceService(UTDESC12,FORCED_ERASE);
	
	theService := self.createInvoiceService(UTDESC12,"", calcType1, null);
	self.assertNotNullMsg(theService, UTDESC12 &amp; " not created");
	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC12,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC12, calcType1, invType, services,"SDT1");
	
	
	//Add Calculation Type 12 HOURS
	
	self.deleteCalculationType(UTBERT03, FORCED_ERASE);
//	calcType := app.myRoot.allCalculationTypesByCode.getAtKey(UTBERT03);
//	if calcType = null then
		calcType2 := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
												UTBERT03,	//_code : String;
												UTDESC03,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,3,12,3,999999, false, true, false, false,0, null, null);

		self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT03 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
//	endif;
	self.deleteInvoiceService(UTDESC03,FORCED_ERASE);
	theService := self.createInvoiceService(UTDESC03,"", calcType2, null);
	self.assertNotNullMsg(theService, UTDESC03 &amp; " not created");
 	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC03,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC03, calcType2, invType, services,"SDT1");
	
	// load HMS transaction map
	self.tranMapLoadVTMIS6(UTDESC03,UTDESC12);

	voyage := self.createVesselVoyage5(); // Creates a vessel and voyage with HMS data setup including a wharf and a berth.
	
	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage is null!");
	
	
	// ############# CHECK THAT HMS IS SETUP CORRECTLY
	hmsData := voyage.myHMSVoyageData;
	
	self.assertTrueMsg(hmsData &lt;&gt; null, "HMS Data is null!");
	self.assertTrueMsg(hmsData.allBerthPreferencesByName.size = 2, "Voyage should have 2 berthing preferences, actually has " &amp; hmsData.allBerthPreferencesByName.size.String);


	berthage := hmsData.allBerthPreferencesByName["W1"];
	self.assertTrueMsg(berthage.berthName = "W1", "The Berth should be W1, actually is " &amp; berthage.berthName);
	
	berth := berthage.getMyBerth();
	self.assertTrueMsg(berth &lt;&gt; null, "berth is null!");
	
	wharf := berth.myWharf;
	self.assertTrueMsg(wharf &lt;&gt; null, "wharf is null!");
	
	self.assertTrueMsg(wharf.allResourcesForWharf.size = 2, "The Wharf should should have 2 resource settings, actually is " &amp; wharf.allResourcesForWharf.size.String);
	
	wharfRes := wharf.allResourcesForWharf.first;
	self.assertTrueMsg(wharfRes.myDepartResource &lt;&gt; null, "Wharf 1st resource for departure is null");
	self.assertTrueMsg(wharfRes.myShiftResource &lt;&gt; null, "Wharf 1st resource for shift is null");
	self.assertTrueMsg(wharfRes.myDepartResource.code = "B24", "Wharf 1st resource for departure should be B24, actually is "&amp; wharfRes.myDepartResource.code);
	self.assertTrueMsg(wharfRes.myShiftResource.code = "B24", "Wharf 1st resource for shift should be B24, actually is "&amp; wharfRes.myShiftResource.code);
	
	beginTransaction;
	wharfRes.myDepartResource.setPropertyValue("myCalculationTypeQuantity", calcType1);
	commitTransaction;
		
	wharfRes := wharf.allResourcesForWharf.last;
	self.assertTrueMsg(wharfRes.myDepartResource &lt;&gt; null, "Wharf 2nd resource for departure is null");
	self.assertTrueMsg(wharfRes.myShiftResource &lt;&gt; null, "Wharf 2nd resource for shift is null");
	self.assertTrueMsg(wharfRes.myDepartResource.code = "B6", "Wharf 2nd resource for departure should be B6, actually is "&amp; wharfRes.myDepartResource.code); // re use the 6 hour berth resource as it does not matter
	self.assertTrueMsg(wharfRes.myShiftResource.code = "B6", "Wharf 2nd resource for shift should be B6, actually is "&amp; wharfRes.myShiftResource.code);
	
	beginTransaction;
	wharfRes.myDepartResource.setPropertyValue("myCalculationTypeQuantity", calcType2);
	commitTransaction;
	
	// ################## CHECK PROFORMA BERTHAGE RESOURCES
	create proformaResources transient;
	
	proformaResources.initialise();
	
	movement := voyage.getMovementDeparture();
	self.assertTrueMsg(movement &lt;&gt; null, "Departure movement is null");
	
	proformaResources.dummyUpWharfDeparture(movement);
	self.assertTrueMsg(proformaResources.allResUsed.size = 2, "Proforma should have 2 resources, actually has " &amp; proformaResources.allResUsed.size.String);

	// NOTE - if the unit test fails it might be because someone has added a new berthage calculation type
	//  			_move.myHMSVoyageData.getNumberOfBlocksMovement just gets the first berthage calculation type for the correct number of blocks e.g. 24 or 6
	//				_move.myHMSVoyageData.getNumberOfBlocksMovement is only used if the berth resource does not specify the calculation type to use
	//				Some units tests null the calc type on the resource to test this.
	
	resUsed := proformaResources.allResUsed.first.HMS_ResourceUsed;
	self.assertTrueMsg(resUsed.unitsUsed = 1, "Proforma 12 Hr Berthage should be 1, actually is " &amp; resUsed.unitsUsed.String);
	
	resUsed := proformaResources.allResUsed.last.HMS_ResourceUsed;
	self.assertTrueMsg(resUsed.unitsUsed = 12, "Proforma 3 Hr Berthage should be 12, actually is " &amp; resUsed.unitsUsed.String);

	
	self.hmsSetMovementsToActual(voyage);
	
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		
		self.assertTrueMsg(movement.moveStatusNEW=  MovementStatus_Actual, "Movement should be Actual, actually is " &amp; app.movementStatusNumToString(movement.moveStatusNEW));
	endforeach;
	
	
	
	beginLoad;
	pxyVoy := voyage.pxyCreateUpdateProxy();
	endLoad;
	
	app.myTrxUA.trxUpdateVoyageInvoiceGen(pxyVoy, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	foreach invoice in voyage.allInvoices discreteLock do
		foreach line in invoice.invoiceLines discreteLock do
			if line.invoiceLineDesc.narration = UTDESC03 then
				self.assertTrueMsg(line.quantity = 12, "Actual 3 Hr Berthage line should be 12, actually is " &amp; line.quantity.String);
				count := count + 1;
			endif;
 			if line.invoiceLineDesc.narration = UTDESC12 then
				self.assertTrueMsg(line.quantity = 1, "Actual 12 Hr Berthage line should be 1, actually is " &amp; line.quantity.String);
				count := count + 1;
			endif;
 
		endforeach;
 
	endforeach;
	self.assertEqualMsg(count, 2, "Invoice line count");
epilog
	if proformaResources&lt;&gt; null then
		proformaResources.allResUsed.purge;
	endif;
	delete proformaResources;
	delete pxyVoy;
	delete services;

	self.resetDefaultTranMap();

end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSTimeBlockCalcType2400UNIT" id="c1e0f580-4ea9-4bf7-8e72-f78eaf9ff6dd">
        <updating/>
        <source>tHMSTimeBlockCalcType2400UNIT() updating;
/*
	NOTE - These Units test use berths, wharves, resources and calculation types that already exist.
				The test might fail is some one changes the existing configuration OR adds a new calculation type for berthage.


*/




// cnwma1
// CNWJRE1
/*
Purpose:			test the hms berthage resources, these are normally split over a initial 24 hour block and the remaining time in blocks of 12
Date		Who		Reason
23/07/2015	cnwjre1	Initial creation 36605 check visit of less than 24 hours
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
*/
constants
	UTINVTYPE = "UT_VOY";
	UTBERT12 = "UTBERT12U";
	UTDESC12 = "UT Berthage - 12 Hours Units";
	UTBERT24 = "UTBERT24U";
	UTDESC24 = "UT Berthage - 24 Hours Units";

vars
	hmsData : HMS_VoyageData;
	berthage : HMS_BerthPreference;
	pxyVoy, voyage : CM_Voyage;
	berth : HMS_Berth;
	wharf : HMS_Wharf;
	wharfRes : HMS_ResourceForWharf;
	movement : HMS_VoyageMovement;
	resUsed : HMS_ResourceUsed;
	proformaResources : CMIF_HMSResourceUsedProforma;
	calcType1, calcType2 : CM_CalculationType;
	theService : CM_Service;
	invLineType : CM_InvoiceLineDesc;
	invType : CM_InvoiceDesc;
	services : CM_ServiceByNameDict;
	bank : CM_Bank;
	invoice : CM_Invoice;
	line : CM_InvoiceLine;
	count	: Integer;
	now		: Date;

begin
	create services transient;
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	self.deleteInvoiceType(UTINVTYPE);
	invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											UTINVTYPE,
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");
	
	// ### CREATE CALC TYPES
	
	//Add Calculation Type 24 HOURS
	
	self.deleteCalculationType(UTBERT24, FORCED_ERASE);
	calcType1 := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
												UTBERT24,	//_code : String;
												UTDESC24,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,24,0,24,24, false, true, false,false,INV_CALC_TYPE_UNIT_LENGTH,null, null);

	self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT24 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
	
	self.deleteInvoiceService(UTDESC24,FORCED_ERASE);
	
	theService := self.createInvoiceService(UTDESC24,"", calcType1, null);
	self.assertNotNullMsg(theService, UTDESC24 &amp; " not created");
	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC24,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC24, calcType1, invType, services,"SDT1");
	
	
	//Add Calculation Type 12 HOURS
	self.deleteCalculationType("UTBERT12", FORCED_ERASE);
	self.deleteCalculationType(UTBERT12, FORCED_ERASE);
	calcType2 := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
												UTBERT12,	//_code : String;
												UTDESC12,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,12,24,12,999999, false, true, false,false,INV_CALC_TYPE_UNIT_LENGTH,null, null);

	self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT12 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );

	self.deleteInvoiceService(UTDESC12,FORCED_ERASE);
	theService := self.createInvoiceService(UTDESC12,"", calcType2, null);
	self.assertNotNullMsg(theService, UTDESC12 &amp; " not created");
 	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC12,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC12, calcType2, invType, services,"SDT1");
	
	// load HMS transaction map
	self.tranMapLoadVTMIS6(UTDESC12,UTDESC24);

	voyage := self.createVesselVoyage8(); // Creates a vessel and voyage with HMS data setup including a wharf and a berth.
	
	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage is null!");
	
	
	// ############# CHECK THAT HMS IS SETUP CORRECTLY
	hmsData := voyage.myHMSVoyageData;
	
	self.assertTrueMsg(hmsData &lt;&gt; null, "HMS Data is null!");
	self.assertTrueMsg(hmsData.allBerthPreferencesByName.size = 2, "Voyage should have 2 berthing preferences, actually has " &amp; hmsData.allBerthPreferencesByName.size.String);
	
	berthage := hmsData.allBerthPreferencesByName["W1"];
	self.assertTrueMsg(berthage.berthName = "W1", "The Berth should be W1, actually is " &amp; berthage.berthName);
	
	berth := berthage.getMyBerth();
	self.assertTrueMsg(berth &lt;&gt; null, "berth is null!");
	
	wharf := berth.myWharf;
	self.assertTrueMsg(wharf &lt;&gt; null, "wharf is null!");
	
	self.assertTrueMsg(wharf.allResourcesForWharf.size = 2, "The Wharf should should have 2 resource settings, actually is " &amp; wharf.allResourcesForWharf.size.String);
	
	wharfRes := wharf.allResourcesForWharf.first;
	self.assertTrueMsg(wharfRes.myDepartResource &lt;&gt; null, "Wharf 1st resource for departure is null");
	self.assertTrueMsg(wharfRes.myShiftResource &lt;&gt; null, "Wharf 1st resource for shift is null");
	self.assertTrueMsg(wharfRes.myDepartResource.code = "B24", "Wharf 1st resource for departure should be B24, actually is "&amp; wharfRes.myDepartResource.code);
	self.assertTrueMsg(wharfRes.myShiftResource.code = "B24", "Wharf 1st resource for shift should be B24, actually is "&amp; wharfRes.myShiftResource.code);

	beginTransaction;
	wharfRes.myDepartResource.setPropertyValue("myCalculationTypeQuantity", calcType1);
	commitTransaction;
		
	wharfRes := wharf.allResourcesForWharf.last;
	self.assertTrueMsg(wharfRes.myDepartResource &lt;&gt; null, "Wharf 2nd resource for departure is null");
	self.assertTrueMsg(wharfRes.myShiftResource &lt;&gt; null, "Wharf 2nd resource for shift is null");
	self.assertTrueMsg(wharfRes.myDepartResource.code = "B6", "Wharf 2nd resource for departure should be B6, actually is "&amp; wharfRes.myDepartResource.code); // re use the 6 hour berth resource as it does not matter
	self.assertTrueMsg(wharfRes.myShiftResource.code = "B6", "Wharf 2nd resource for shift should be B6, actually is "&amp; wharfRes.myShiftResource.code);

	beginTransaction;
	wharfRes.myDepartResource.setPropertyValue("myCalculationTypeQuantity", calcType2);
	commitTransaction;
	
	// ################## CHECK PROFORMA BERTHAGE RESOURCES
	create proformaResources transient;
	
	proformaResources.initialise();
	
	movement := voyage.getMovementDeparture();
	self.assertTrueMsg(movement &lt;&gt; null, "Departure movement is null");
	
	proformaResources.dummyUpWharfDeparture(movement);
	self.assertTrueMsg(proformaResources.allResUsed.size = 1, "Proforma should have 1 resources, actually has " &amp; proformaResources.allResUsed.size.String);
	
	// NOTE - if the unit test fails it might be because someone has added a new berthage calculation type
	//  			_move.myHMSVoyageData.getNumberOfBlocksMovement just gets the first berthage calculation type for the correct number of blocks e.g. 24 or 6
	//				_move.myHMSVoyageData.getNumberOfBlocksMovement is only used if the berth resource does not specify the calculation type to use
	//				Some units tests null the calc type on the resource to test this.
	resUsed := proformaResources.allResUsed.first.HMS_ResourceUsed;
	self.assertTrueMsg(resUsed.unitsUsed = 1, "Proforma 24 Hr Berthage should be 1, actually is " &amp; resUsed.unitsUsed.String);
	
	///resUsed := proformaResources.allResUsed.last.HMS_ResourceUsed;
	//self.assertTrueMsg(resUsed.unitsUsed = 0, "Proforma 12 Hr Berthage should be 0, actually is " &amp; resUsed.unitsUsed.String);
	///self.assertTrueMsg(resUsed.unitsUsed = 1, "Proforma 12 Hr Berthage should be 1, actually is " &amp; resUsed.unitsUsed.String);

	
	self.hmsSetMovementsToActual(voyage);
	
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		
		self.assertTrueMsg(movement.moveStatusNEW=  MovementStatus_Actual, "Movement should be Actual, actually is " &amp; app.movementStatusNumToString(movement.moveStatusNEW));
	endforeach;
	
	
	
	beginLoad;
	pxyVoy := voyage.pxyCreateUpdateProxy();
	endLoad;
	
	app.myTrxUA.trxUpdateVoyageInvoiceGen(pxyVoy, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	foreach invoice in voyage.allInvoices discreteLock do
		foreach line in invoice.invoiceLines discreteLock do
 			if line.invoiceLineDesc.narration = UTDESC24 then
				self.assertTrueMsg(line.quantity = 100, "Actual 24 Hr Berthage line should be 100, actually is " &amp; line.quantity.String);
				count := count + 1;
			endif;
		endforeach;
	endforeach;
	
	self.assertEqualMsg(count, 1, "Invoice line count");
epilog
	if proformaResources&lt;&gt; null then
		proformaResources.allResUsed.purge;
	endif;
	
	delete proformaResources;
	delete pxyVoy;
	delete services;

	self.resetDefaultTranMap();

end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSTimeBlockCalcType2406" id="444d4659-f005-439a-975c-f1a0d59c05f7">
        <updating/>
        <source>tHMSTimeBlockCalcType2406() updating;
/*
	NOTE - These Units test use berths, wharves, resources and calculation types that already exist.
				The test might fail is some one changes the existing configuration OR adds a new calculation type for berthage.


*/




// cnwma1
// CNWJRE1
/*
Purpose:			test the hms berthage resources, these are normally split over a initial 24 hour block and the remaining time in blocks of 6
Date		Who		Reason
30 December 2014	NAVAB1	Initial creation
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
*/
constants
	UTINVTYPE = "UT_VOY";
	UTBERT06 = "UTBERT06";
	UTDESC06 = "UT Berthage - 6 Hours";
	UTBERT24 = "UTBERT24";
	UTDESC24 = "UT Berthage - 24 Hours";
vars
	hmsData : HMS_VoyageData;
	berthage : HMS_BerthPreference;
	pxyVoy, voyage : CM_Voyage;
	berth : HMS_Berth;
	wharf : HMS_Wharf;
	wharfRes : HMS_ResourceForWharf;
	movement : HMS_VoyageMovement;
	resUsed : HMS_ResourceUsed;
	proformaResources : CMIF_HMSResourceUsedProforma;
	calcType1, calcType2 : CM_CalculationType;
	theService : CM_Service;
	invLineType : CM_InvoiceLineDesc;
	invType : CM_InvoiceDesc;
	services : CM_ServiceByNameDict;
	bank : CM_Bank;
	invoice : CM_Invoice;
	line : CM_InvoiceLine;
	count	: Integer;
	now		: Date;

begin

	create proformaResources transient;
	create services transient;
	bank := self.myBank;
	self.deleteInvoiceType(UTINVTYPE);
	invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											UTINVTYPE,
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");
	
	// ### CREATE CALC TYPES
	
	//Add Calculation Type 24 HOURS
	
	self.deleteCalculationType(UTBERT24, FORCED_ERASE);
//	calcType := app.myRoot.allCalculationTypesByCode.getAtKey(UTBERT24);
//	if calcType = null then
		calcType1 := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
												UTBERT24,	//_code : String;
												UTDESC24,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,24,0,24,24, false, true, false, false,0, null, null);

		self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT24 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
	//endif;
	
	self.deleteInvoiceService(UTDESC24,FORCED_ERASE);
	
	theService := self.createInvoiceService(UTDESC24,"", calcType1, null);
	self.assertNotNullMsg(theService, UTDESC24 &amp; " not created");
	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC24,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC24, calcType1, invType, services,"SDT1");
	
	
	//Add Calculation Type 6 HOURS
	
	self.deleteCalculationType(UTBERT06, FORCED_ERASE);
//	calcType := app.myRoot.allCalculationTypesByCode.getAtKey(UTBERT06);
//	if calcType = null then
		calcType2 := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
												UTBERT06,	//_code : String;
												UTDESC06,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,6,24,6,999999, false, true, false, false,0, null, null);

		self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT06 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
	//endif;
	
	self.deleteInvoiceService(UTDESC06,FORCED_ERASE);
	theService := self.createInvoiceService(UTDESC06,"", calcType2, null);
	self.assertNotNullMsg(theService, UTDESC06 &amp; " not created");
 	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC06,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC06, calcType2, invType, services,"SDT1");
	
	// load HMS transaction map
	self.tranMapLoadVTMIS6(UTDESC06,UTDESC24);
	

	voyage := self.createVesselVoyage5(); // Creates a vessel and voyage with HMS data setup including a wharf and a berth.
	
	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage is null!");
	
	
	// ############# CHECK THAT HMS IS SETUP CORRECTLY
	hmsData := voyage.myHMSVoyageData;
	
	self.assertTrueMsg(hmsData &lt;&gt; null, "HMS Data is null!");
	self.assertTrueMsg(hmsData.allBerthPreferencesByName.size = 2, "Voyage should have 2 berthing preferences, actually has " &amp; hmsData.allBerthPreferencesByName.size.String);


	
	berthage := hmsData.allBerthPreferencesByName["W1"];
	self.assertTrueMsg(berthage.berthName = "W1", "The Berth should be W1, actually is " &amp; berthage.berthName);
	
	berth := berthage.getMyBerth();
	self.assertTrueMsg(berth &lt;&gt; null, "berth is null!");
	
	wharf := berth.myWharf;
	self.assertTrueMsg(wharf &lt;&gt; null, "wharf is null!");
	
	self.assertTrueMsg(wharf.allResourcesForWharf.size = 2, "The Wharf should should have 2 resource settings, actually is " &amp; wharf.allResourcesForWharf.size.String);
	
	wharfRes := wharf.allResourcesForWharf.first;
	self.assertTrueMsg(wharfRes.myDepartResource &lt;&gt; null, "Wharf 1st resource for departure is null");
	self.assertTrueMsg(wharfRes.myShiftResource &lt;&gt; null, "Wharf 1st resource for shift is null");
	self.assertTrueMsg(wharfRes.myDepartResource.code = "B24", "Wharf 1st resource for departure should be B24, actually is "&amp; wharfRes.myDepartResource.code);
	self.assertTrueMsg(wharfRes.myDepartResource.myResourceType.isMarineService, "Wharf 1st resource for departure should be a marine service");
	self.assertTrueMsg(wharfRes.myShiftResource.code = "B24", "Wharf 1st resource for shift should be B24, actually is "&amp; wharfRes.myShiftResource.code);
	self.assertTrueMsg(wharfRes.myShiftResource.myResourceType.isMarineService, "Wharf 1st resource for shift should be a marine service");
	
	beginTransaction;
	wharfRes.myDepartResource.setPropertyValue("myCalculationTypeQuantity", calcType1);
	commitTransaction;
		
	wharfRes := wharf.allResourcesForWharf.last;
	self.assertTrueMsg(wharfRes.myDepartResource &lt;&gt; null, "Wharf 2nd resource for departure is null");
	self.assertTrueMsg(wharfRes.myShiftResource &lt;&gt; null, "Wharf 2nd resource for shift is null");
	self.assertTrueMsg(wharfRes.myDepartResource.code = "B6", "Wharf 2nd resource for departure should be B6, actually is "&amp; wharfRes.myDepartResource.code);
	self.assertTrueMsg(wharfRes.myShiftResource.myResourceType.isMarineService, "Wharf 2nd resource for departure should be a marine service");
	self.assertTrueMsg(wharfRes.myShiftResource.code = "B6", "Wharf 2nd resource for shift should be B6, actually is "&amp; wharfRes.myShiftResource.code);
	self.assertTrueMsg(wharfRes.myShiftResource.myResourceType.isMarineService, "Wharf 2nd resource for shift should be a marine service");
	
	beginTransaction;
	wharfRes.myDepartResource.setPropertyValue("myCalculationTypeQuantity", calcType2);
	commitTransaction;
	
	// ################## CHECK PROFORMA BERTHAGE RESOURCES
	
	proformaResources.initialise();
	
	movement := voyage.getMovementDeparture();
	self.assertTrueMsg(movement &lt;&gt; null, "Departure movement is null");
	
	proformaResources.dummyUpWharfDeparture(movement);
	self.assertTrueMsg(proformaResources.allResUsed.size = 2, "Proforma should have 2 resources, actually has " &amp; proformaResources.allResUsed.size.String);
	
	// NOTE - if the unit test fails it might be because someone has added a new berthage calculation type
	//  			_move.myHMSVoyageData.getNumberOfBlocksMovement just gets the first berthage calculation type for the correct number of blocks e.g. 24 or 6
	//				_move.myHMSVoyageData.getNumberOfBlocksMovement is only used if the berth resource does not specify the calculation type to use
	//				Some units tests null the calc type on the resource to test this.
	resUsed := proformaResources.allResUsed.first.HMS_ResourceUsed;
	self.assertTrueMsg(resUsed.unitsUsed = 1, "Proforma 24 Hr Berthage should be 1, actually is " &amp; resUsed.unitsUsed.String);
	
	resUsed := proformaResources.allResUsed.last.HMS_ResourceUsed;
	self.assertTrueMsg(resUsed.unitsUsed = 4, "Proforma 6 Hr Berthage should be 4, actually is " &amp; resUsed.unitsUsed.String);
	
	
	self.hmsSetMovementsToActual(voyage);
	
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		
		self.assertTrueMsg(movement.moveStatusNEW=  MovementStatus_Actual, "Movement should be Actual, actually is " &amp; app.movementStatusNumToString(movement.moveStatusNEW));
	endforeach;
	

	
	beginLoad;
	pxyVoy := voyage.pxyCreateUpdateProxy();
	endLoad;
	
	app.myTrxUA.trxUpdateVoyageInvoiceGen(pxyVoy, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	foreach invoice in voyage.allInvoices discreteLock do
		foreach line in invoice.invoiceLines discreteLock do
			if line.invoiceLineDesc.narration = UTDESC06 then
				self.assertTrueMsg(line.quantity = 4, "Actual 6 Hr Berthage line should be 4, actually is " &amp; line.quantity.String);
				count := count + 1;
			endif;
 			if line.invoiceLineDesc.narration = UTDESC24 then
				self.assertTrueMsg(line.quantity = 1, "Actual 24 Hr Berthage line should be 1, actually is " &amp; line.quantity.String);
				count := count + 1;
			endif;
 
		endforeach;
 
	endforeach;
	self.assertEqualMsg(count, 2, "Invoice line count");
epilog
	proformaResources.allResUsed.purge;
	delete proformaResources;
	delete pxyVoy;
	delete services;

	self.resetDefaultTranMap();

end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSTimeBlockCalcType2406MShft" id="2342d79f-0b9d-4101-b295-151eede3509c">
        <updating/>
        <source>tHMSTimeBlockCalcType2406MShft() updating;
/*
	NOTE - These Units test use berths, wharves, resources and calculation types that already exist.
				The test might fail is some one changes the existing configuration OR adds a new calculation type for berthage.


*/




// cnwma1
// CNWJRE1
/*
Purpose:			test the hms berthage resources, these are normally split over a initial 24 hour block and the remaining time in blocks of 6
						This test of the berthage is based on a voyage at Prot Nelson called PAEP0004. it has 10 shift movements, 3 of the shifts are to a berth whose wharf has no charges, i.e. has no resources set.
						This means that the time spent at those berths is ignored. 
Date		Who		Reason
30 December 2014	NAVAB1	Initial creation
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
*/
constants
	UTINVTYPE = "UT_VOY";
	UTBERT06 = "UTBERT06";
	UTDESC06 = "UT Berthage - 6 Hours";
	UTBERT24 = "UTBERT24";
	UTDESC24 = "UT Berthage - 24 Hours";
vars
	hmsData : HMS_VoyageData;
	berthage : HMS_BerthPreference;
	pxyVoy, voyage : CM_Voyage;
	berth : HMS_Berth;
	wharf : HMS_Wharf;
	wharfRes : HMS_ResourceForWharf;
	movement : HMS_VoyageMovement;
	resUsed : HMS_ResourceUsed;
	proformaResources : CMIF_HMSResourceUsedProforma;
	calcType : CM_CalculationType;
	theService : CM_Service;
	invLineType : CM_InvoiceLineDesc;
	invType : CM_InvoiceDesc;
	services : CM_ServiceByNameDict;
	bank : CM_Bank;
	invoice : CM_Invoice;
	line : CM_InvoiceLine;
	count	: Integer;
	resource : HMS_Resource;
	now		: Date;

begin

	create proformaResources transient;
	create services transient;
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	self.deleteInvoiceType(UTINVTYPE);
	invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											UTINVTYPE,
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");
	
	// ### CREATE CALC TYPES
	
	//Add Calculation Type 24 HOURS
	
	self.deleteCalculationType(UTBERT24, FORCED_ERASE);
//	calcType := app.myRoot.allCalculationTypesByCode.getAtKey(UTBERT24);
//	if calcType = null then
		calcType := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
												UTBERT24,	//_code : String;
												UTDESC24,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,24,0,24,24, false, true, false, false,0, null, null);

		self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT24 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
	//endif;
	
	self.deleteInvoiceService(UTDESC24,FORCED_ERASE);
	
	theService := self.createInvoiceService(UTDESC24,"", calcType, null);
	self.assertNotNullMsg(theService, UTDESC24 &amp; " not created");
	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC24,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC24, calcType, invType, services,"SDT1");
	
	
	//Add Calculation Type 6 HOURS
	
	self.deleteCalculationType(UTBERT06, FORCED_ERASE);
//	calcType := app.myRoot.allCalculationTypesByCode.getAtKey(UTBERT06);
//	if calcType = null then
		calcType := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
												UTBERT06,	//_code : String;
												UTDESC06,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,6,24,6,999999, false, true, false, false,0, null, null);

		self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT06 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
	//endif;
	
	self.deleteInvoiceService(UTDESC06,FORCED_ERASE);
	theService := self.createInvoiceService(UTDESC06,"", calcType, null);
	self.assertNotNullMsg(theService, UTDESC06 &amp; " not created");
 	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC06,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC06, calcType, invType, services,"SDT1");
	
	// load HMS transaction map
	self.tranMapLoadVTMIS6(UTDESC06,UTDESC24);
	

	voyage := self.createVesselVoyage7(); // Creates a vessel and voyage with HMS data setup including a wharf and a berth.
	self.hmsSetMovementsToActual(voyage);
	
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		
		self.assertTrueMsg(movement.moveStatusNEW=  MovementStatus_Actual, "Movement should be Actual, actually is " &amp; app.movementStatusNumToString(movement.moveStatusNEW));
	endforeach;

	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage is null!");

	// ############# CHECK THAT HMS IS SETUP CORRECTLY
	hmsData := voyage.myHMSVoyageData;
	
	self.assertTrueMsg(hmsData &lt;&gt; null, "HMS Data is null!");
	self.assertTrueMsg(hmsData.allBerthPreferencesByName.size = 3, "Voyage should have 3 berthing preferences, actually has " &amp; hmsData.allBerthPreferencesByName.size.String);


	
	berthage := hmsData.allBerthPreferencesByName["UTNOCHARGE"];
	self.assertTrueMsg(berthage &lt;&gt; null, "The Berth should be UTNOCHARGE, actually is " &amp; berthage.berthName);
	berthage := hmsData.allBerthPreferencesByName["W1"];
	self.assertTrueMsg(berthage.berthName = "W1", "The Berth should be W1, actually is " &amp; berthage.berthName);
	berthage := hmsData.allBerthPreferencesByName["W2"];
	self.assertTrueMsg(berthage &lt;&gt; null, "The Berth should be W2, actually is " &amp; berthage.berthName);
	
	berth := berthage.getMyBerth();
	self.assertTrueMsg(berth &lt;&gt; null, "berth is null!");
	
	wharf := berth.myWharf;
	self.assertTrueMsg(wharf &lt;&gt; null, "wharf is null!");
	
	self.assertTrueMsg(wharf.allResourcesForWharf.size = 2, "The Wharf should should have 2 resource settings, actually is " &amp; wharf.allResourcesForWharf.size.String);
	
	wharfRes := wharf.allResourcesForWharf.first;
	self.assertTrueMsg(wharfRes.myDepartResource &lt;&gt; null, "Wharf 1st resource for departure is null");
	self.assertTrueMsg(wharfRes.myShiftResource &lt;&gt; null, "Wharf 1st resource for shift is null");
	self.assertTrueMsg(wharfRes.myDepartResource.code = "B24", "Wharf 1st resource for departure should be B24, actually is "&amp; wharfRes.myDepartResource.code);
	self.assertTrueMsg(wharfRes.myDepartResource.myResourceType.isMarineService, "Wharf 1st resource for departure should be a marine service");
	self.assertTrueMsg(wharfRes.myShiftResource.code = "B24", "Wharf 1st resource for shift should be B24, actually is "&amp; wharfRes.myShiftResource.code);
	self.assertTrueMsg(wharfRes.myShiftResource.myResourceType.isMarineService, "Wharf 1st resource for shift should be a marine service");
	beginTransaction;
	wharfRes.myDepartResource.setPropertyValue("myCalculationTypeQuantity", null);
	commitTransaction;
		
	wharfRes := wharf.allResourcesForWharf.last;
	self.assertTrueMsg(wharfRes.myDepartResource &lt;&gt; null, "Wharf 2nd resource for departure is null");
	self.assertTrueMsg(wharfRes.myShiftResource &lt;&gt; null, "Wharf 2nd resource for shift is null");
	self.assertTrueMsg(wharfRes.myDepartResource.code = "B6", "Wharf 2nd resource for departure should be B6, actually is "&amp; wharfRes.myDepartResource.code);
	self.assertTrueMsg(wharfRes.myShiftResource.myResourceType.isMarineService, "Wharf 2nd resource for departure should be a marine service");
	self.assertTrueMsg(wharfRes.myShiftResource.code = "B6", "Wharf 2nd resource for shift should be B6, actually is "&amp; wharfRes.myShiftResource.code);
	self.assertTrueMsg(wharfRes.myShiftResource.myResourceType.isMarineService, "Wharf 2nd resource for shift should be a marine service");
	beginTransaction;
	wharfRes.myDepartResource.setPropertyValue("myCalculationTypeQuantity", null);
	commitTransaction;
	
	// if the second (Berth 6) resource on the Wharf has a calculation type, this is incorrect - clear it off
	resource := wharfRes.myDepartResource;
	if resource.myCalculationTypeQuantity &lt;&gt; null and resource.myCalculationTypeQuantity.hoursBlock &lt;&gt; 6 then
		beginTransaction;
		resource.setPropertyValue(HMS_Resource::myCalculationTypeQuantity.name, null);
		commitTransaction;
	endif;
	
	// ################## CHECK PROFORMA BERTHAGE RESOURCES
	
	self.setTerminalConfig(InvoiceHMSNoShiftCharge,true); // Port Nelson have this set to TRUE
	
	proformaResources.initialise();
	
	
	// ### DEPARTURE
	movement := voyage.getMovementDeparture();
	self.assertTrueMsg(movement &lt;&gt; null, "Departure movement is null");
	
	proformaResources.dummyUpWharfDeparture(movement);
	self.assertTrueMsg(proformaResources.allResUsed.size = 2, "Proforma Departure should have 2 resources, actually has " &amp; proformaResources.allResUsed.size.String);

	// NOTE - if the unit test fails it might be because someone has added a new berthage calculation type
	//  			_move.myHMSVoyageData.getNumberOfBlocksMovement just gets the first berthage calculation type for the correct number of blocks e.g. 24 or 6
	//				_move.myHMSVoyageData.getNumberOfBlocksMovement is only used if the berth resource does not specify the calculation type to use
	//				Some units tests null the calc type on the resource to test this.
	resUsed := proformaResources.allResUsed.first.HMS_ResourceUsed;
	self.assertTrueMsg(resUsed.unitsUsed = 1, "Proforma 24 Hr  Departure Berthage should be 1, actually is " &amp; resUsed.unitsUsed.String);
	
	resUsed := proformaResources.allResUsed.last.HMS_ResourceUsed;
	// NOTE - if the unit test fails it might be because someone has added a new berthage calculation type
	//  			_move.myHMSVoyageData.getNumberOfBlocksMovement just gets the first berthage calculation type for the correct number of blocks e.g. 24 or 6
	//				_move.myHMSVoyageData.getNumberOfBlocksMovement is only used if the berth resource does not specify the calculation type to use
	//				Some units tests null the calc type on the resource to test this.
	self.assertTrueMsg(resUsed.unitsUsed = 277, "Proforma 6 Hr Departure Berthage should be 277, actually is " &amp; resUsed.unitsUsed.String);
	
	

	
	beginLoad;
	pxyVoy := voyage.pxyCreateUpdateProxy();
	endLoad;
	
	app.myTrxUA.trxUpdateVoyageInvoiceGen(pxyVoy, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	foreach invoice in voyage.allInvoices discreteLock do
		foreach line in invoice.invoiceLines discreteLock do
			if line.invoiceLineDesc.narration = UTDESC06 then
				self.assertTrueMsg(line.quantity = 277 , "Actual 6 Hr Berthage line should be 277, actually is " &amp; line.quantity.String);
				count := count + 1;
			endif;
 			if line.invoiceLineDesc.narration = UTDESC24 then
				self.assertTrueMsg(line.quantity = 1, "Actual 24 Hr Berthage line should be 1, actually is " &amp; line.quantity.String);
				count := count + 1;
			endif;
 
		endforeach;
 
	endforeach;
	self.assertEqualMsg(count, 2, "Invoice line count");
epilog
	proformaResources.allResUsed.purge;
	delete proformaResources;
	delete pxyVoy;
	delete services;

	self.resetDefaultTranMap();

end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSTimeBlockCalcType2406QM" id="05660537-d6c8-4dde-9b35-778bad33ce95">
        <updating/>
        <source>tHMSTimeBlockCalcType2406QM() updating;
/*
	NOTE - These Units test use berths, wharves, resources and calculation types that already exist.
				The test might fail is some one changes the existing configuration OR adds a new calculation type for berthage.


*/




// cnwma1
// CNWJRE1
/*
Purpose:			test the hms berthage resources, these are normally split over a initial 24 hour block and the remaining time in blocks of 6
					This variant tests the LOA quantity range mapping quantity calculation for 36605
					
Date		Who		Reason
30 December 2014	NAVAB1	Initial creation
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
*/
constants
	UTINVTYPE = "UT_VOY";
	UTBERT06 = "UTBERT06";
	UTDESC06 = "UT Berthage - 6 Hours";
	UTDESC06A = "UT Berthage - 6 Hours A";
	UTDESC06B = "UT Berthage - 6 Hours B";
	UTBERT24 = "UTBERT24";
	UTDESC24 = "UT Berthage - 24 Hours";
	UTDESC24A = "UT Berthage - 24 Hours A";
	UTDESC24B = "UT Berthage - 24 Hours B";
	UTLOA = "UTLOA";
	UTDESCLOA = "UT Length Overall";

vars
	hmsData : HMS_VoyageData;
	berthage : HMS_BerthPreference;
	pxyVoy, voyage : CM_Voyage;
	berth : HMS_Berth;
	wharf : HMS_Wharf;
	wharfRes : HMS_ResourceForWharf;
	movement : HMS_VoyageMovement;
	resUsed : HMS_ResourceUsed;
	proformaResources : CMIF_HMSResourceUsedProforma;
	calcType1, calcType2,
	calcType3	: CM_CalculationType;
	theService : CM_Service;
	invLineType : CM_InvoiceLineDesc;
	invType : CM_InvoiceDesc;
	services : CM_ServiceByNameDict;
	bank : CM_Bank;
	invoice : CM_Invoice;
	line : CM_InvoiceLine;
	count	: Integer;
	now		: Date;

begin

	create proformaResources transient;
	create services transient;
	bank := self.myBank;
	self.deleteInvoiceType(UTINVTYPE);
	invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											UTINVTYPE,
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");

	
	// ### CREATE CALC TYPES
	
	//Add Calculation Type 24 HOURS
	
	self.deleteCalculationType(UTBERT24, FORCED_ERASE);
	calcType1 := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
												UTBERT24,	//_code : String;
												UTDESC24,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,24,0,24,24, false, true, false, false,0, null, null);

	self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT24 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
	
	self.deleteInvoiceService(UTDESC24,FORCED_ERASE);
	
	theService := self.createInvoiceService(UTDESC24,"", calcType1, null);
	self.assertNotNullMsg(theService, UTDESC24 &amp; " not created");
	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC24A,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC24A, calcType1, invType, services,"SDT1");
	self.deleteInvoiceLineType(UTDESC24B,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC24B, calcType1, invType, services,"SDT1");
	
	//Add Calculation Type 6 HOURS
	self.deleteCalculationType(UTBERT06, FORCED_ERASE);
	calcType2 := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
												UTBERT06,	//_code : String;
												UTDESC06,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,6,24,6,999999, false, true, false, false,0, null, null);

	self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT06 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
	

	// add calc type for the transaction map quantity ranges
	self.deleteCalculationType(UTLOA, FORCED_ERASE);
	calcType3 := self.addCalculationType(	INV_CALC_TYPE_VESSEL_TON,	//_calcType : Integer;
												UTLOA,	//_code : String;
												UTDESCLOA,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,0,0,0,0, false, true, false,false,INV_CALC_TYPE_UNIT_LENGTH,null, null);

	self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTLOA &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
	self.deleteInvoiceService(UTDESC06,FORCED_ERASE);
	theService := self.createInvoiceService(UTDESC06,"", calcType2, null);
	self.assertNotNullMsg(theService, UTDESC06 &amp; " not created");
 	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC06A,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC06A, calcType2, invType, services,"SDT1");
	self.deleteInvoiceLineType(UTDESC06B,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC06B, calcType2, invType, services,"SDT1");
	
	// load HMS transaction map with LOA quantity ranges
	self.tranMapLoadVTMIS8(UTDESC24A, UTDESC24B, UTDESC06A, UTDESC06B);

	voyage := self.createVesselVoyage5(); // Creates a vessel and voyage with HMS data setup including a wharf and a berth.
	// vessel LOA is 100
	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage is null!");
	
	
	// ############# CHECK THAT HMS IS SETUP CORRECTLY
	hmsData := voyage.myHMSVoyageData;
	
	self.assertTrueMsg(hmsData &lt;&gt; null, "HMS Data is null!");
	self.assertTrueMsg(hmsData.allBerthPreferencesByName.size = 2, "Voyage should have 2 berthing preferences, actually has " &amp; hmsData.allBerthPreferencesByName.size.String);


	
	berthage := hmsData.allBerthPreferencesByName["W1"];
	self.assertTrueMsg(berthage.berthName = "W1", "The Berth should be W1, actually is " &amp; berthage.berthName);
	
	berth := berthage.getMyBerth();
	self.assertTrueMsg(berth &lt;&gt; null, "berth is null!");
	
	wharf := berth.myWharf;
	self.assertTrueMsg(wharf &lt;&gt; null, "wharf is null!");
	
	self.assertTrueMsg(wharf.allResourcesForWharf.size = 2, "The Wharf should should have 2 resource settings, actually is " &amp; wharf.allResourcesForWharf.size.String);
	
	wharfRes := wharf.allResourcesForWharf.first;
	self.assertTrueMsg(wharfRes.myDepartResource &lt;&gt; null, "Wharf 1st resource for departure is null");
	self.assertTrueMsg(wharfRes.myShiftResource &lt;&gt; null, "Wharf 1st resource for shift is null");
	self.assertTrueMsg(wharfRes.myDepartResource.code = "B24", "Wharf 1st resource for departure should be B24, actually is "&amp; wharfRes.myDepartResource.code);
	self.assertTrueMsg(wharfRes.myDepartResource.myResourceType.isMarineService, "Wharf 1st resource for departure should be a marine service");
	self.assertTrueMsg(wharfRes.myShiftResource.code = "B24", "Wharf 1st resource for shift should be B24, actually is "&amp; wharfRes.myShiftResource.code);
	self.assertTrueMsg(wharfRes.myShiftResource.myResourceType.isMarineService, "Wharf 1st resource for shift should be a marine service");
	
	beginTransaction;
	wharfRes.myDepartResource.setPropertyValue("myCalculationTypeQuantity", calcType1);
	commitTransaction;
		
	wharfRes := wharf.allResourcesForWharf.last;
	self.assertTrueMsg(wharfRes.myDepartResource &lt;&gt; null, "Wharf 2nd resource for departure is null");
	self.assertTrueMsg(wharfRes.myShiftResource &lt;&gt; null, "Wharf 2nd resource for shift is null");
	self.assertTrueMsg(wharfRes.myDepartResource.code = "B6", "Wharf 2nd resource for departure should be B6, actually is "&amp; wharfRes.myDepartResource.code);
	self.assertTrueMsg(wharfRes.myShiftResource.myResourceType.isMarineService, "Wharf 2nd resource for departure should be a marine service");
	self.assertTrueMsg(wharfRes.myShiftResource.code = "B6", "Wharf 2nd resource for shift should be B6, actually is "&amp; wharfRes.myShiftResource.code);
	self.assertTrueMsg(wharfRes.myShiftResource.myResourceType.isMarineService, "Wharf 2nd resource for shift should be a marine service");
	
	beginTransaction;
	wharfRes.myDepartResource.setPropertyValue("myCalculationTypeQuantity", calcType2);
	commitTransaction;
	
	// ################## CHECK PROFORMA BERTHAGE RESOURCES
	
	proformaResources.initialise();
	
	movement := voyage.getMovementDeparture();
	self.assertTrueMsg(movement &lt;&gt; null, "Departure movement is null");
	
	proformaResources.dummyUpWharfDeparture(movement);
	self.assertTrueMsg(proformaResources.allResUsed.size = 2, "Proforma should have 2 resources, actually has " &amp; proformaResources.allResUsed.size.String);
	
	// NOTE - if the unit test fails it might be because someone has added a new berthage calculation type
	//  			_move.myHMSVoyageData.getNumberOfBlocksMovement just gets the first berthage calculation type for the correct number of blocks e.g. 24 or 6
	//				_move.myHMSVoyageData.getNumberOfBlocksMovement is only used if the berth resource does not specify the calculation type to use
	//				Some units tests null the calc type on the resource to test this.
	resUsed := proformaResources.allResUsed.first.HMS_ResourceUsed;
	self.assertTrueMsg(resUsed.unitsUsed = 1, "Proforma 24 Hr Berthage should be 1, actually is " &amp; resUsed.unitsUsed.String);
	
	resUsed := proformaResources.allResUsed.last.HMS_ResourceUsed;
	self.assertTrueMsg(resUsed.unitsUsed = 4, "Proforma 6 Hr Berthage should be 4, actually is " &amp; resUsed.unitsUsed.String);
	
	
	self.hmsSetMovementsToActual(voyage);
	
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		
		self.assertTrueMsg(movement.moveStatusNEW=  MovementStatus_Actual, "Movement should be Actual, actually is " &amp; app.movementStatusNumToString(movement.moveStatusNEW));
	endforeach;
	

	
	beginLoad;
	pxyVoy := voyage.pxyCreateUpdateProxy();
	endLoad;
	
	app.myTrxUA.trxUpdateVoyageInvoiceGen(pxyVoy, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	foreach invoice in voyage.allInvoices discreteLock do
		foreach line in invoice.invoiceLines discreteLock do
			if line.invoiceLineDesc.narration = UTDESC06A then
				self.assertTrueMsg(line.quantity = 4, "Actual 6 Hr Berthage line should be 4, actually is " &amp; line.quantity.String);
				count := count + 1;
			endif;
 			if line.invoiceLineDesc.narration = UTDESC24A then
				self.assertTrueMsg(line.quantity = 1, "Actual 24 Hr Berthage line should be 1, actually is " &amp; line.quantity.String);
				count := count + 1;
			endif;
		endforeach;
	endforeach;
	self.assertEqualMsg(count, 2, "Invoice line count");

epilog
	proformaResources.allResUsed.purge;
	delete proformaResources;
	delete pxyVoy;
	delete services;

	self.resetDefaultTranMap();

end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSTimeBlockCalcType2406Shift" id="369d5f7c-17ac-4ed4-8452-323c7db7ebe7">
        <updating/>
        <source>tHMSTimeBlockCalcType2406Shift() updating;
/*
	NOTE - These Units test use berths, wharves, resources and calculation types that already exist.
				The test might fail is some one changes the existing configuration OR adds a new calculation type for berthage.


*/




// cnwma1
// CNWJRE1
/*
Purpose:			test the hms berthage resources, these are normally split over a initial 24 hour block and the remaining time in blocks of 6
Date		Who		Reason
30 December 2014	NAVAB1	Initial creation
13 Jun 2019	jlgsl4	TFS 44957 - PEL1 - include movement pilot details in voyage-movement UT
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
*/
constants
	UTINVTYPE = "UT_VOY";
	UTBERT06 = "UTBERT06";
	UTDESC06 = "UT Berthage - 6 Hours";
	UTBERT24 = "UTBERT24";
	UTDESC24 = "UT Berthage - 24 Hours";
vars
	hmsData : HMS_VoyageData;
	berthage : HMS_BerthPreference;
	pxyVoy, voyage : CM_Voyage;
	berth : HMS_Berth;
	wharf : HMS_Wharf;
	wharfRes : HMS_ResourceForWharf;
	movement : HMS_VoyageMovement;
	resUsed : HMS_ResourceUsed;
	proformaResources : CMIF_HMSResourceUsedProforma;
	calcType : CM_CalculationType;
	theService : CM_Service;
	invLineType : CM_InvoiceLineDesc;
	invType : CM_InvoiceDesc;
	services : CM_ServiceByNameDict;
	bank : CM_Bank;
	invoice : CM_Invoice;
	line : CM_InvoiceLine;
	count	: Integer;
	now		: Date;
begin

	create proformaResources transient;
	create services transient;
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	self.deleteInvoiceType(UTINVTYPE);
	invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											UTINVTYPE,
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");
	
	// ### CREATE CALC TYPES
	
	//Add Calculation Type 24 HOURS
	
	self.deleteCalculationType(UTBERT24, FORCED_ERASE);
//	calcType := app.myRoot.allCalculationTypesByCode.getAtKey(UTBERT24);
//	if calcType = null then
		calcType := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
												UTBERT24,	//_code : String;
												UTDESC24,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,24,0,24,24, false, true, false, false,0, null, null);

		self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT24 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
	//endif;
	
	self.deleteInvoiceService(UTDESC24,FORCED_ERASE);
	
	theService := self.createInvoiceService(UTDESC24,"", calcType, null);
	self.assertNotNullMsg(theService, UTDESC24 &amp; " not created");
	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC24,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC24, calcType, invType, services,"SDT1");
	
	
	//Add Calculation Type 6 HOURS
	
	self.deleteCalculationType(UTBERT06, FORCED_ERASE);
//	calcType := app.myRoot.allCalculationTypesByCode.getAtKey(UTBERT06);
//	if calcType = null then
		calcType := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
												UTBERT06,	//_code : String;
												UTDESC06,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,6,24,6,999999, false, true, false, false,0, null, null);

		self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT06 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
	//endif;
	
	self.deleteInvoiceService(UTDESC06,FORCED_ERASE);
	theService := self.createInvoiceService(UTDESC06,"", calcType, null);
	self.assertNotNullMsg(theService, UTDESC06 &amp; " not created");
 	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC06,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC06, calcType, invType, services,"SDT1");
	
	// load HMS transaction map
	self.tranMapLoadVTMIS6(UTDESC06,UTDESC24);
	

	voyage := self.createVesselVoyage6(); // Creates a vessel and voyage with HMS data setup including a wharf and a berth.

	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage is null!"); // TFS 44957

	self.hmsSetMovementsToActual(voyage);
	
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		
		self.assertTrueMsg(movement.moveStatusNEW=  MovementStatus_Actual, "Movement should be Actual, actually is " &amp; app.movementStatusNumToString(movement.moveStatusNEW));
	endforeach;

	//self.assertTrueMsg(voyage &lt;&gt; null, "Voyage is null!"); // TFS 44957 - do null voyage check immediately after trying to create it

	// ############# CHECK THAT HMS IS SETUP CORRECTLY
	hmsData := voyage.myHMSVoyageData;
	
	self.assertTrueMsg(hmsData &lt;&gt; null, "HMS Data is null!");
	self.assertTrueMsg(hmsData.allBerthPreferencesByName.size = 2, "Voyage should have 2 berthing preferences, actually has " &amp; hmsData.allBerthPreferencesByName.size.String);


	
	berthage := hmsData.allBerthPreferencesByName["W1"];
	self.assertTrueMsg(berthage.berthName = "W1", "The Berth should be W1, actually is " &amp; berthage.berthName);
	berthage := hmsData.allBerthPreferencesByName["W2"];
	self.assertTrueMsg(berthage &lt;&gt; null, "The Berth should be W2, actually is " &amp; berthage.berthName);
	
	berth := berthage.getMyBerth();
	self.assertTrueMsg(berth &lt;&gt; null, "berth is null!");
	
	wharf := berth.myWharf;
	self.assertTrueMsg(wharf &lt;&gt; null, "wharf is null!");
	
	self.assertTrueMsg(wharf.allResourcesForWharf.size = 2, "The Wharf should should have 2 resource settings, actually is " &amp; wharf.allResourcesForWharf.size.String);
	
	wharfRes := wharf.allResourcesForWharf.first;
	self.assertTrueMsg(wharfRes.myDepartResource &lt;&gt; null, "Wharf 1st resource for departure is null");
	self.assertTrueMsg(wharfRes.myShiftResource &lt;&gt; null, "Wharf 1st resource for shift is null");
	self.assertTrueMsg(wharfRes.myDepartResource.code = "B24", "Wharf 1st resource for departure should be B24, actually is "&amp; wharfRes.myDepartResource.code);
	self.assertTrueMsg(wharfRes.myDepartResource.myResourceType.isMarineService, "Wharf 1st resource for departure should be a marine service");
	self.assertTrueMsg(wharfRes.myShiftResource.code = "B24", "Wharf 1st resource for shift should be B24, actually is "&amp; wharfRes.myShiftResource.code);
	self.assertTrueMsg(wharfRes.myShiftResource.myResourceType.isMarineService, "Wharf 1st resource for shift should be a marine service");
	beginTransaction;
	wharfRes.myDepartResource.setPropertyValue("myCalculationTypeQuantity", null);
	commitTransaction;
		
	wharfRes := wharf.allResourcesForWharf.last;
	self.assertTrueMsg(wharfRes.myDepartResource &lt;&gt; null, "Wharf 2nd resource for departure is null");
	self.assertTrueMsg(wharfRes.myShiftResource &lt;&gt; null, "Wharf 2nd resource for shift is null");
	self.assertTrueMsg(wharfRes.myDepartResource.code = "B6", "Wharf 2nd resource for departure should be B6, actually is "&amp; wharfRes.myDepartResource.code);
	self.assertTrueMsg(wharfRes.myShiftResource.myResourceType.isMarineService, "Wharf 2nd resource for departure should be a marine service");
	self.assertTrueMsg(wharfRes.myShiftResource.code = "B6", "Wharf 2nd resource for shift should be B6, actually is "&amp; wharfRes.myShiftResource.code);
	self.assertTrueMsg(wharfRes.myShiftResource.myResourceType.isMarineService, "Wharf 2nd resource for shift should be a marine service");
	beginTransaction;
	wharfRes.myDepartResource.setPropertyValue("myCalculationTypeQuantity", null);
	commitTransaction;
	
	// ################## CHECK PROFORMA BERTHAGE RESOURCES
	
	self.setTerminalConfig(InvoiceHMSNoShiftCharge,false);
	
	proformaResources.initialise();
	
	
	// ### DEPARTURE
	movement := voyage.getMovementDeparture();
	self.assertTrueMsg(movement &lt;&gt; null, "Departure movement is null");
	
	proformaResources.dummyUpWharfDeparture(movement);
	self.assertTrueMsg(proformaResources.allResUsed.size = 2, "Proforma Departure should have 2 resources, actually has " &amp; proformaResources.allResUsed.size.String);
	
	// NOTE - if the unit test fails it might be because someone has added a new berthage calculation type
	//  			_move.myHMSVoyageData.getNumberOfBlocksMovement just gets the first berthage calculation type for the correct number of blocks e.g. 24 or 6
	//				_move.myHMSVoyageData.getNumberOfBlocksMovement is only used if the berth resource does not specify the calculation type to use
	//				Some units tests null the calc type on the resource to test this.
	resUsed := proformaResources.allResUsed.first.HMS_ResourceUsed;
	self.assertTrueMsg(resUsed.unitsUsed = 1, "Proforma 24 Hr  Departure Berthage should be 1, actually is " &amp; resUsed.unitsUsed.String);
	
	resUsed := proformaResources.allResUsed.last.HMS_ResourceUsed;
	self.assertTrueMsg(resUsed.unitsUsed = 28, "Proforma 6 Hr Departure Berthage should be 28, actually is " &amp; resUsed.unitsUsed.String);
	
	
	proformaResources.allResUsed.purge;
	proformaResources.initialise();
	// ### SHIFT
	movement := voyage.getMovementShift(1); // get first shift
	self.assertTrueMsg(movement &lt;&gt; null, "Shift movement is null");
	
	proformaResources.dummyUpWharfDeparture(movement);
	proformaResources.dummyUpPilot(movement); // TFS 44957
	self.assertTrueMsg(proformaResources.allResUsed.size = 3, "Proforma Shift should have 3 resources, actually has " &amp; proformaResources.allResUsed.size.String); // TFS 44957 - 2 -&gt; 3
	
	
	
	resUsed := proformaResources.allResUsed.first.HMS_ResourceUsed;
	self.assertTrueMsg(resUsed.unitsUsed = 1, "Proforma 24 Hr Shift Berthage should be 1, actually is " &amp; resUsed.unitsUsed.String);
	
	resUsed := proformaResources.allResUsed.at(2).HMS_ResourceUsed; // TFS 44957 - get the B6 berth resource
	self.assertTrueMsg(resUsed.unitsUsed = 12, "Proforma 6 Hr Shift Berthage should be 12, actually is " &amp; resUsed.unitsUsed.String);	
	
	resUsed := proformaResources.allResUsed.last.HMS_ResourceUsed; // TFS 44957 - get the Pilot resource
	self.assertTrueMsg(resUsed.unitsUsed = 1, "Pilot resource should be 1, actually is " &amp; resUsed.unitsUsed.String); // TFS 44957
	
	beginLoad;
	pxyVoy := voyage.pxyCreateUpdateProxy();
	endLoad;
	
	app.myTrxUA.trxUpdateVoyageInvoiceGen(pxyVoy, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	foreach invoice in voyage.allInvoices discreteLock do
		foreach line in invoice.invoiceLines discreteLock do
			if line.invoiceLineDesc.narration = UTDESC06 then
				self.assertTrueMsg(line.quantity = 28 or line.quantity = 12, "Actual 6 Hr Berthage line should be 28 or 12, actually is " &amp; line.quantity.String);
				count := count + 1;
			endif;
 			if line.invoiceLineDesc.narration = UTDESC24 then
				self.assertTrueMsg(line.quantity = 1, "Actual 24 Hr Berthage line should be 1, actually is " &amp; line.quantity.String);
				count := count + 1;
			endif;
 
		endforeach;
 
	endforeach;
	self.assertEqualMsg(count, 4, "Invoice line count");
epilog
	proformaResources.allResUsed.purge;
	delete proformaResources;
	delete pxyVoy;
	delete services;

	self.resetDefaultTranMap();

end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSTimeBlockCalcType2412" id="ffbd68c8-bf5e-42ec-acb7-598645bf43bf">
        <updating/>
        <source>tHMSTimeBlockCalcType2412() updating;
/*
	NOTE - These Units test use berths, wharves, resources and calculation types that already exist.
				The test might fail is some one changes the existing configuration OR adds a new calculation type for berthage.


*/




// cnwma1
// CNWJRE1
/*
Purpose:			test the hms berthage resources, these are normally split over a initial 24 hour block and the remaining time in blocks of 12
Date		Who		Reason
30 December 2014	NAVAB1	Initial creation
*/
constants
	UTINVTYPE = "UT_VOY";
	UTBERT12 = "UTBERT12";
	UTDESC12 = "UT Berthage - 12 Hours No Units";
	UTBERT24 = "UTBERT24";
	UTDESC24 = "UT Berthage - 24 Hours No Units";

vars
	hmsData : HMS_VoyageData;
	berthage : HMS_BerthPreference;
	pxyVoy, voyage : CM_Voyage;
	berth : HMS_Berth;
	wharf : HMS_Wharf;
	wharfRes : HMS_ResourceForWharf;
	movement : HMS_VoyageMovement;
	resUsed : HMS_ResourceUsed;
	proformaResources : CMIF_HMSResourceUsedProforma;
	calcType1, calcType2 : CM_CalculationType;
	theService : CM_Service;
	invLineType : CM_InvoiceLineDesc;
	invType : CM_InvoiceDesc;
	services : CM_ServiceByNameDict;
	bank : CM_Bank;
	invoice : CM_Invoice;
	line : CM_InvoiceLine;
	count	: Integer;
	now		: Date;

begin
	create services transient;
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	self.deleteInvoiceType(UTINVTYPE);
	invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											UTINVTYPE,
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");
	
	// ### CREATE CALC TYPES
	
	//Add Calculation Type 24 HOURS
	
	self.deleteCalculationType(UTBERT24, FORCED_ERASE);
//	calcType := app.myRoot.allCalculationTypesByCode.getAtKey(UTBERT24);
//	if calcType = null then
		calcType1 := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS,	//_calcType : Integer;
												UTBERT24,	//_code : String;
												UTDESC24,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,24,0,24,24, false, true, false, false,0, null, null);

		self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT24 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
//	endif;
	
	self.deleteInvoiceService(UTDESC24,FORCED_ERASE);
	
	theService := self.createInvoiceService(UTDESC24,"", calcType1, null);
	self.assertNotNullMsg(theService, UTDESC24 &amp; " not created");
	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC24,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC24, calcType1, invType, services,"SDT1");
	
	
	//Add Calculation Type 12 HOURS
	
	self.deleteCalculationType(UTBERT12, FORCED_ERASE);
//	calcType := app.myRoot.allCalculationTypesByCode.getAtKey(UTBERT12);
//	if calcType = null then
		calcType2 := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS,	//_calcType : Integer;
												UTBERT12,	//_code : String;
												UTDESC12,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,12,24,12,999999, false, true, false, false,0, null, null);

		self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT12 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
//	endif;

	self.deleteInvoiceService(UTDESC12,FORCED_ERASE);
	theService := self.createInvoiceService(UTDESC12,"", calcType2, null);
	self.assertNotNullMsg(theService, UTDESC12 &amp; " not created");
 	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC12,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC12, calcType2, invType, services,"SDT1");
	
	// load HMS transaction map
	self.tranMapLoadVTMIS6(UTDESC12,UTDESC24);
	// load HMS transaction map
//	self.tranMapLoadVTMIS7();

	voyage := self.createVesselVoyage5(); // Creates a vessel and voyage with HMS data setup including a wharf and a berth.
	
	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage is null!");
	
	
	// ############# CHECK THAT HMS IS SETUP CORRECTLY
	hmsData := voyage.myHMSVoyageData;
	
	self.assertTrueMsg(hmsData &lt;&gt; null, "HMS Data is null!");
	self.assertTrueMsg(hmsData.allBerthPreferencesByName.size = 2, "Voyage should have 2 berthing preferences, actually has " &amp; hmsData.allBerthPreferencesByName.size.String);

	
	berthage := hmsData.allBerthPreferencesByName["W1"];
	self.assertTrueMsg(berthage.berthName = "W1", "The Berth should be W1, actually is " &amp; berthage.berthName);
	
	berth := berthage.getMyBerth();
	self.assertTrueMsg(berth &lt;&gt; null, "berth is null!");
	
	wharf := berth.myWharf;
	self.assertTrueMsg(wharf &lt;&gt; null, "wharf is null!");
	
	self.assertTrueMsg(wharf.allResourcesForWharf.size = 2, "The Wharf should should have 2 resource settings, actually is " &amp; wharf.allResourcesForWharf.size.String);
	
	wharfRes := wharf.allResourcesForWharf.first;
	self.assertTrueMsg(wharfRes.myDepartResource &lt;&gt; null, "Wharf 1st resource for departure is null");
	self.assertTrueMsg(wharfRes.myShiftResource &lt;&gt; null, "Wharf 1st resource for shift is null");
	self.assertTrueMsg(wharfRes.myDepartResource.code = "B24", "Wharf 1st resource for departure should be B24, actually is "&amp; wharfRes.myDepartResource.code);
	self.assertTrueMsg(wharfRes.myShiftResource.code = "B24", "Wharf 1st resource for shift should be B24, actually is "&amp; wharfRes.myShiftResource.code);

	beginTransaction;
	wharfRes.myDepartResource.setPropertyValue("myCalculationTypeQuantity", calcType1);
	commitTransaction;
				
	wharfRes := wharf.allResourcesForWharf.last;
	self.assertTrueMsg(wharfRes.myDepartResource &lt;&gt; null, "Wharf 2nd resource for departure is null");
	self.assertTrueMsg(wharfRes.myShiftResource &lt;&gt; null, "Wharf 2nd resource for shift is null");
	self.assertTrueMsg(wharfRes.myDepartResource.code = "B6", "Wharf 2nd resource for departure should be B6, actually is "&amp; wharfRes.myDepartResource.code); // re use the 6 hour berth resource as it does not matter
	self.assertTrueMsg(wharfRes.myShiftResource.code = "B6", "Wharf 2nd resource for shift should be B6, actually is "&amp; wharfRes.myShiftResource.code);

	beginTransaction;
	wharfRes.myDepartResource.setPropertyValue("myCalculationTypeQuantity", calcType2);
	commitTransaction;
			
	// ################## CHECK PROFORMA BERTHAGE RESOURCES
	create proformaResources transient;
	
	proformaResources.initialise();
	
	movement := voyage.getMovementDeparture();
	self.assertTrueMsg(movement &lt;&gt; null, "Departure movement is null");
	
	proformaResources.dummyUpWharfDeparture(movement);
	self.assertTrueMsg(proformaResources.allResUsed.size = 2, "Proforma should have 2 resources, actually has " &amp; proformaResources.allResUsed.size.String);
	
	// NOTE - if the unit test fails it might be because someone has added a new berthage calculation type
	//  			_move.myHMSVoyageData.getNumberOfBlocksMovement just gets the first berthage calculation type for the correct number of blocks e.g. 24 or 6
	//				_move.myHMSVoyageData.getNumberOfBlocksMovement is only used if the berth resource does not specify the calculation type to use
	//				Some units tests null the calc type on the resource to test this.
	resUsed := proformaResources.allResUsed.first.HMS_ResourceUsed;
	self.assertTrueMsg(resUsed.unitsUsed = 1, "Proforma 24 Hr Berthage should be 1, actually is " &amp; resUsed.unitsUsed.String);
	
	resUsed := proformaResources.allResUsed.last.HMS_ResourceUsed;
	self.assertTrueMsg(resUsed.unitsUsed = 2, "Proforma 12 Hr Berthage should be 2, actually is " &amp; resUsed.unitsUsed.String);

	
	self.hmsSetMovementsToActual(voyage);
	
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		
		self.assertTrueMsg(movement.moveStatusNEW=  MovementStatus_Actual, "Movement should be Actual, actually is " &amp; app.movementStatusNumToString(movement.moveStatusNEW));
	endforeach;
	
	return;
	
	beginLoad;
	pxyVoy := voyage.pxyCreateUpdateProxy();
	endLoad;
	
	app.myTrxUA.trxUpdateVoyageInvoiceGen(pxyVoy, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	foreach invoice in voyage.allInvoices discreteLock do
		foreach line in invoice.invoiceLines discreteLock do
			if line.invoiceLineDesc.narration = UTDESC12 then
				self.assertTrueMsg(line.quantity = 2, "Actual 12 Hr Berthage line should be 2, actually is " &amp; line.quantity.String);
				count := count + 1;
			endif;
 			if line.invoiceLineDesc.narration = UTDESC24 then
				self.assertTrueMsg(line.quantity = 1, "Actual 24 Hr Berthage line should be 1, actually is " &amp; line.quantity.String);
				count := count + 1;
			endif;
 
		endforeach;
 
	endforeach;
	self.assertEqualMsg(count, 2, "Invoice line count");
epilog
	if proformaResources&lt;&gt; null then
		proformaResources.allResUsed.purge;
	endif;
	
	delete proformaResources;
	delete pxyVoy;
	delete services;

	self.resetDefaultTranMap();

end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSTimeBlockCalcType2412UNIT" id="70ecc9dd-d8c3-41c8-83f7-48850140483f">
        <updating/>
        <source>tHMSTimeBlockCalcType2412UNIT() updating;
/*
	NOTE - These Units test use berths, wharves, resources and calculation types that already exist.
				The test might fail is some one changes the existing configuration OR adds a new calculation type for berthage.


*/




// cnwma1
// CNWJRE1
/*
Purpose:			test the hms berthage resources, these are normally split over a initial 24 hour block and the remaining time in blocks of 12
Date		Who		Reason
30 December 2014	NAVAB1	Initial creation
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
*/
constants
	UTINVTYPE = "UT_VOY";
	UTBERT12 = "UTBERT12U";
	UTDESC12 = "UT Berthage - 12 Hours Units";
	UTBERT24 = "UTBERT24U";
	UTDESC24 = "UT Berthage - 24 Hours Units";

vars
	hmsData : HMS_VoyageData;
	berthage : HMS_BerthPreference;
	pxyVoy, voyage : CM_Voyage;
	berth : HMS_Berth;
	wharf : HMS_Wharf;
	wharfRes : HMS_ResourceForWharf;
	movement : HMS_VoyageMovement;
	resUsed : HMS_ResourceUsed;
	proformaResources : CMIF_HMSResourceUsedProforma;
	calcType1, calcType2 : CM_CalculationType;
	theService : CM_Service;
	invLineType : CM_InvoiceLineDesc;
	invType : CM_InvoiceDesc;
	services : CM_ServiceByNameDict;
	bank : CM_Bank;
	invoice : CM_Invoice;
	line : CM_InvoiceLine;
	count	: Integer;
	now		: Date;

begin
	create services transient;
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	self.deleteInvoiceType(UTINVTYPE);
	invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											UTINVTYPE,
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");
	
	// ### CREATE CALC TYPES
	
	//Add Calculation Type 24 HOURS
	
	self.deleteCalculationType(UTBERT24, FORCED_ERASE);
//	calcType := app.myRoot.allCalculationTypesByCode.getAtKey(UTBERT24);
//	if calcType = null then
		calcType1 := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
												UTBERT24,	//_code : String;
												UTDESC24,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,24,0,24,24, false, true, false,false,INV_CALC_TYPE_UNIT_LENGTH, null, null);

		self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT24 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
//	endif;
	
	self.deleteInvoiceService(UTDESC24,FORCED_ERASE);
	
	theService := self.createInvoiceService(UTDESC24,"", calcType1, null);
	self.assertNotNullMsg(theService, UTDESC24 &amp; " not created");
	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC24,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC24, calcType1, invType, services,"SDT1");
	
	
	//Add Calculation Type 12 HOURS
	
	self.deleteCalculationType(UTBERT12, FORCED_ERASE);
//	calcType := app.myRoot.allCalculationTypesByCode.getAtKey(UTBERT12);
//	if calcType = null then
		calcType2 := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
												UTBERT12,	//_code : String;
												UTDESC12,	//_description : String;
												null,	//_quantityHookSource : String;
												null,	//_rateHookSource : String
												null	//_remarksHookSource: String;
												,12,24,12,999999, false, true, false,false,INV_CALC_TYPE_UNIT_LENGTH, null, null);

		self.assertTrueMsg( not app.myPassport.hasErrors, "Failed to create Calculation Type of '" &amp; UTBERT12 &amp; "' during setup - " &amp; app.myPassport.getErrorsAsString );
//	endif;

	self.deleteInvoiceService(UTDESC12,FORCED_ERASE);
	theService := self.createInvoiceService(UTDESC12,"", calcType2, null);
	self.assertNotNullMsg(theService, UTDESC12 &amp; " not created");
 	services.clear();
	services.add(theService);
	self.deleteInvoiceLineType(UTDESC12,FORCED_ERASE);
	invLineType := self.createInvoiceLineType(UTDESC12, calcType2, invType, services,"SDT1");
	
	// load HMS transaction map
	self.tranMapLoadVTMIS6(UTDESC12,UTDESC24);
	// load HMS transaction map
//	self.tranMapLoadVTMIS7();

	voyage := self.createVesselVoyage5(); // Creates a vessel and voyage with HMS data setup including a wharf and a berth.
	
	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage is null!");
	
	
	// ############# CHECK THAT HMS IS SETUP CORRECTLY
	hmsData := voyage.myHMSVoyageData;
	
	self.assertTrueMsg(hmsData &lt;&gt; null, "HMS Data is null!");
	self.assertTrueMsg(hmsData.allBerthPreferencesByName.size = 2, "Voyage should have 2 berthing preferences, actually has " &amp; hmsData.allBerthPreferencesByName.size.String);

	
	berthage := hmsData.allBerthPreferencesByName["W1"];
	self.assertTrueMsg(berthage.berthName = "W1", "The Berth should be W1, actually is " &amp; berthage.berthName);
	
	berth := berthage.getMyBerth();
	self.assertTrueMsg(berth &lt;&gt; null, "berth is null!");
	
	wharf := berth.myWharf;
	self.assertTrueMsg(wharf &lt;&gt; null, "wharf is null!");
	
	self.assertTrueMsg(wharf.allResourcesForWharf.size = 2, "The Wharf should should have 2 resource settings, actually is " &amp; wharf.allResourcesForWharf.size.String);
	
	wharfRes := wharf.allResourcesForWharf.first;
	self.assertTrueMsg(wharfRes.myDepartResource &lt;&gt; null, "Wharf 1st resource for departure is null");
	self.assertTrueMsg(wharfRes.myShiftResource &lt;&gt; null, "Wharf 1st resource for shift is null");
	self.assertTrueMsg(wharfRes.myDepartResource.code = "B24", "Wharf 1st resource for departure should be B24, actually is "&amp; wharfRes.myDepartResource.code);
	self.assertTrueMsg(wharfRes.myShiftResource.code = "B24", "Wharf 1st resource for shift should be B24, actually is "&amp; wharfRes.myShiftResource.code);

	beginTransaction;
	wharfRes.myDepartResource.setPropertyValue("myCalculationTypeQuantity", calcType1);
	commitTransaction;
		
	wharfRes := wharf.allResourcesForWharf.last;
	self.assertTrueMsg(wharfRes.myDepartResource &lt;&gt; null, "Wharf 2nd resource for departure is null");
	self.assertTrueMsg(wharfRes.myShiftResource &lt;&gt; null, "Wharf 2nd resource for shift is null");
	self.assertTrueMsg(wharfRes.myDepartResource.code = "B6", "Wharf 2nd resource for departure should be B6, actually is "&amp; wharfRes.myDepartResource.code); // re use the 6 hour berth resource as it does not matter
	self.assertTrueMsg(wharfRes.myShiftResource.code = "B6", "Wharf 2nd resource for shift should be B6, actually is "&amp; wharfRes.myShiftResource.code);

	beginTransaction;
	wharfRes.myDepartResource.setPropertyValue("myCalculationTypeQuantity", calcType2);
	commitTransaction;
	
	// ################## CHECK PROFORMA BERTHAGE RESOURCES
	create proformaResources transient;
	
	proformaResources.initialise();
	
	movement := voyage.getMovementDeparture();
	self.assertTrueMsg(movement &lt;&gt; null, "Departure movement is null");
	
	proformaResources.dummyUpWharfDeparture(movement);
	self.assertTrueMsg(proformaResources.allResUsed.size = 2, "Proforma should have 2 resources, actually has " &amp; proformaResources.allResUsed.size.String);
	
	// NOTE - if the unit test fails it might be because someone has added a new berthage calculation type
	//  			_move.myHMSVoyageData.getNumberOfBlocksMovement just gets the first berthage calculation type for the correct number of blocks e.g. 24 or 6
	//				_move.myHMSVoyageData.getNumberOfBlocksMovement is only used if the berth resource does not specify the calculation type to use
	//				Some units tests null the calc type on the resource to test this.
	resUsed := proformaResources.allResUsed.first.HMS_ResourceUsed;
	self.assertTrueMsg(resUsed.unitsUsed = 1, "Proforma 24 Hr Berthage should be 1, actually is " &amp; resUsed.unitsUsed.String);
	
	resUsed := proformaResources.allResUsed.last.HMS_ResourceUsed;
	self.assertTrueMsg(resUsed.unitsUsed = 2, "Proforma 12 Hr Berthage should be 2, actually is " &amp; resUsed.unitsUsed.String);

	
	self.hmsSetMovementsToActual(voyage);
	
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		
		self.assertTrueMsg(movement.moveStatusNEW=  MovementStatus_Actual, "Movement should be Actual, actually is " &amp; app.movementStatusNumToString(movement.moveStatusNEW));
	endforeach;
	
	
	
	beginLoad;
	pxyVoy := voyage.pxyCreateUpdateProxy();
	endLoad;
	
	app.myTrxUA.trxUpdateVoyageInvoiceGen(pxyVoy, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	foreach invoice in voyage.allInvoices discreteLock do
		foreach line in invoice.invoiceLines discreteLock do
			if line.invoiceLineDesc.narration = UTDESC12 then
				self.assertTrueMsg(line.quantity = 200, "Actual 12 Hr Berthage line should be 200, actually is " &amp; line.quantity.String);
				count := count + 1;
			endif;
 			if line.invoiceLineDesc.narration = UTDESC24 then
				self.assertTrueMsg(line.quantity = 100, "Actual 24 Hr Berthage line should be 100, actually is " &amp; line.quantity.String);
				count := count + 1;
			endif;
 
		endforeach;
 
	endforeach;
	self.assertEqualMsg(count, 2, "Invoice line count");
epilog
	if proformaResources&lt;&gt; null then
		proformaResources.allResUsed.purge;
	endif;
	
	delete proformaResources;
	delete pxyVoy;
	delete services;

	self.resetDefaultTranMap();

end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSTimeBlockUnit" id="a531aacd-27d0-4218-8238-ba9502762aa3">
        <updating/>
        <source>tHMSTimeBlockUnit() updating;
// cnwma1
// cnwjre1 35339
vars

begin
	self.hmsTimeBlockUnit();
end;
</source>
