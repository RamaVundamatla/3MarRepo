    <JadeMethod name="buildCMIFDeckReporters" id="7b24fc99-8833-45c4-85c9-30e1ed47ad7b">
        <source>buildCMIFDeckReporters(_cmifDeckItemReportHeaderSet : CMIF_DeckItemReportHeaderSet input; _trackedItem : CM_TrackedItem);
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 20 October 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
// 20/10/2011	cnwsh3		CCMS MES 1009 PLAN Interface PAR28479
//							Build a reporting object that can be used in a report design. 
//							We don't necessarily know if it will be a layout for a cargo item,
//							piece of equipment or a general area.
//----------------------------------------------------------------------
vars

begin
	if self.myLayout = null then
		self.buildCMIFDeckReportersNOLayout(_cmifDeckItemReportHeaderSet , _trackedItem);
	else
		self.buildDeckReportersForLayouts(_cmifDeckItemReportHeaderSet , _trackedItem);
	endif;
	
epilog
end;</source>
        <Parameter name="_cmifDeckItemReportHeaderSet" type="CMIF_DeckItemReportHeaderSet" usage="input"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="buildCMIFDeckReportersNOLayout" id="cae1b083-d250-447c-a90b-e923aa7dbe1b">
        <source>buildCMIFDeckReportersNOLayout(_cmifDeckItemReportHeaderSet : CMIF_DeckItemReportHeaderSet input; _trackedItem: CM_TrackedItem) protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 20 October 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
//
//----------------------------------------------------------------------
vars
	cmifDeckItemReporterHeader	: CMIF_DeckItemReporterHeader;
begin
	create cmifDeckItemReporterHeader transient;
	
	cmifDeckItemReporterHeader.type := self.getJRWReportingType();
	cmifDeckItemReporterHeader.weight := self.getWeight();
	cmifDeckItemReporterHeader.myDeckItem := self;
	
	_cmifDeckItemReportHeaderSet.add(cmifDeckItemReporterHeader);
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_cmifDeckItemReportHeaderSet" type="CMIF_DeckItemReportHeaderSet" usage="input"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="buildDeckReportersForLayoutTIs" id="1d56294b-1af9-4a72-ae57-6b1cc180f1f8">
        <source>buildDeckReportersForLayoutTIs(_cmifDeckItemReportHeaderSet : CMIF_DeckItemReportHeaderSet input; _trackedItem : CM_TrackedItem) protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 20 October 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
// 20/10/2011	cnwsh3		CCMS MES 1009 PLAN Interface PAR28479
//----------------------------------------------------------------------
vars
	cmifDeckItemReporterHeader : CMIF_DeckItemReporterHeader;
	cmifDeckItemPointReporter : CMIF_DeckItemPointReporter;
	cmifDeckItemReporterLayout : CMIF_DeckItemLayoutReporter;
	arraySize, 
	index,
	cmifPositionIndex : Integer;
	xValue,
	yValue : Decimal[12,2];
	deckArray	: DecimalArray;
	layout : CM_DeckItemLayout;
begin
	index := 1;
	cmifPositionIndex := 1;
	layout := self.myLayout;
	deckArray := layout.myPolygonCMs;
	arraySize := deckArray.size();
	
	create cmifDeckItemReporterHeader transient;
	if _trackedItem &lt;&gt; null then
		cmifDeckItemReporterHeader.myTrackedItem := _trackedItem;
	endif;
	
	cmifDeckItemReporterHeader.type := self.getJRWReportingType();
	//cmifDeckItemReporterHeader.weight := self.getWeight();
	cmifDeckItemReporterHeader.myDeckItem := self;	
		
	create cmifDeckItemReporterLayout transient;
		if self.myLayout &lt;&gt; null then
		cmifDeckItemReporterLayout.myDeckItemLayout := self.myLayout;
		cmifDeckItemReporterLayout.isRotationMaster := self.isRotationMaster();
		cmifDeckItemReporterLayout.rotation := self.getRotationStringForJRW();
	endif;

	cmifDeckItemReporterHeader.allDeckItemLayoutReporters.add(cmifDeckItemReporterLayout );
	
	while true do
		if index &gt; arraySize then
			break;
		endif;
		
		xValue := deckArray[index];
		//We should always have an even number entries here as at least one x and one y is included in the polygon coordinates.
		//x are the odd index values and y are the evens.
		index := index + 1;
		yValue := deckArray[index];
		
		create cmifDeckItemPointReporter  transient;
		cmifDeckItemPointReporter.x := xValue;
		cmifDeckItemPointReporter.y := yValue;
		cmifDeckItemPointReporter.myLayout := layout;
		cmifDeckItemPointReporter.index := cmifPositionIndex;
		cmifDeckItemPointReporter .myDeckItem := self;
		
		cmifDeckItemReporterLayout.allDeckItemPointReporters.add(cmifDeckItemPointReporter);
		
		//Increment ready for the next pass in the loop.
		index := index + 1;
		cmifPositionIndex := cmifPositionIndex + 1;
	endwhile;
	
	_cmifDeckItemReportHeaderSet.add(cmifDeckItemReporterHeader);
end;</source>
        <access>protected</access>
        <Parameter name="_cmifDeckItemReportHeaderSet" type="CMIF_DeckItemReportHeaderSet" usage="input"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="buildDeckReportersForLayouts" id="b2233f50-5235-4312-a26b-aee31b57d326">
        <source>buildDeckReportersForLayouts(_cmifDeckItemReportHeaderSet : CMIF_DeckItemReportHeaderSet input; _trackedItem : CM_TrackedItem) protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 20 October 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
// 20/10/2011	cnwsh3		CCMS MES 1009 PLAN Interface PAR28479
//----------------------------------------------------------------------
vars
	cmifDeckItemReporterHeader : CMIF_DeckItemReporterHeader;
	cmifDeckItemPointReporter : CMIF_DeckItemPointReporter;
	cmifDeckItemReporterLayout : CMIF_DeckItemLayoutReporter;
	arraySize, 
	index,
	cmifPositionIndex : Integer;
	xValue,
	yValue : Decimal[12,2];
	deckArray	: DecimalArray;
	layout : CM_DeckItemLayout;
begin
	index := 1;
	cmifPositionIndex := 1;
	layout := self.myLayout;
	deckArray := layout.myPolygonCMs;
	arraySize := deckArray.size();
	
	create cmifDeckItemReporterHeader transient;
	if _trackedItem &lt;&gt; null then
		cmifDeckItemReporterHeader.myTrackedItem := _trackedItem;
	endif;
	
	cmifDeckItemReporterHeader.type := self.getJRWReportingType();
	//cmifDeckItemReporterHeader.weight := self.getWeight();
	cmifDeckItemReporterHeader.myDeckItem := self;	
		
	create cmifDeckItemReporterLayout transient;
		if self.myLayout &lt;&gt; null then
		cmifDeckItemReporterLayout.myDeckItemLayout := self.myLayout;
		cmifDeckItemReporterLayout.isRotationMaster := self.isRotationMaster();
		cmifDeckItemReporterLayout.rotation := self.getRotationStringForJRW();
	endif;

	cmifDeckItemReporterHeader.allDeckItemLayoutReporters.add(cmifDeckItemReporterLayout );
	
	while true do
		if index &gt; arraySize then
			break;
		endif;
		
		xValue := deckArray[index];
		//We should always have an even number entries here as at least one x and one y is included in the polygon coordinates.
		//x are the odd index values and y are the evens.
		index := index + 1;
		yValue := deckArray[index];
		
		create cmifDeckItemPointReporter  transient;
		cmifDeckItemPointReporter.x := xValue;
		cmifDeckItemPointReporter.y := yValue;
		cmifDeckItemPointReporter.myLayout := layout;
		cmifDeckItemPointReporter.index := cmifPositionIndex;
		cmifDeckItemPointReporter .myDeckItem := self;
		
		cmifDeckItemReporterLayout.allDeckItemPointReporters.add(cmifDeckItemPointReporter);
		
		//Increment ready for the next pass in the loop.
		index := index + 1;
		cmifPositionIndex := cmifPositionIndex + 1;
	endwhile;
	
	_cmifDeckItemReportHeaderSet.add(cmifDeckItemReporterHeader);
end;</source>
        <access>protected</access>
        <Parameter name="_cmifDeckItemReportHeaderSet" type="CMIF_DeckItemReportHeaderSet" usage="input"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
