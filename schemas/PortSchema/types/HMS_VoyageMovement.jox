    <JadeMethod name="getTugOrderTime" id="7ed5cc1d-7772-459e-bf58-1557bfb5411e">
        <source>getTugOrderTime(): TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2018	jlger1	Initial creation 39322

*/

vars
	tugOrderTime : TimeStamp;
	
begin
	if self.relativeOrderTimeTugs  &lt; 0 then
		tugOrderTime:=self.occursOnDT.addMinutes(self.relativeOrderTimeTugs.Integer*-1);
	else
		tugOrderTime:=self.occursOnDT.addMinutes(self.relativeOrderTimeTugs.Integer);
	endif;
	
	return tugOrderTime;

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getTugsString" id="1b8809c5-d6a6-4c16-a54b-23e1b64732ba">
        <source>getTugsString(_desc : Boolean ;_separator : String):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
ChangeRequest 41987: PEL1 - In JRW, provide a method on HMS_VoyageMovement to return Tugs description of all tugs used (separated by CrLf)

*/

vars
  tug : HMS_Tug;
  str,
  sep : String;
begin
	
	if _separator  = null then
		sep := ",";
	elseif _separator = "CrLf" then
		sep := CrLf;
	else
		sep := _separator ;
	endif;
	
	if not  self.allTugsUsed.isEmpty then
		foreach tug in self.allTugsUsed do
			if str &lt;&gt; null then
				if _desc then
					str := str &amp; sep &amp; tug.description;
				else
					str := str &amp; sep &amp; tug.code;
				endif;
			else
				if _desc then
					str := tug.description;
				else
					str := tug.code;
				endif;
			endif;
		endforeach;
	endif;
	return str;
epilog

end;</source>
        <Parameter name="_desc" type="Boolean"/>
        <Parameter name="_separator" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTugsUsedSummary" id="4e532904-e814-45c9-8505-7a46898c434a">
        <source>getTugsUsedSummary(): String;

vars
	tmpTug	: HMS_Tug;
	tmpStr	: String;
begin
	
	foreach tmpTug in self.allTugsUsed do
	//	changed to ; from , for CSV output hg 30/08/05
		tmpStr := tmpStr &amp; "; " &amp; tmpTug.code;
	endforeach;
 	
 	if tmpStr.length &gt; 2 then
	 	return tmpStr[3:end];
 	else
 		return tmpStr;
 	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUnConvertedMyPilotRef" id="136e23d0-afdc-4a00-b99d-544ee22fbc53">
