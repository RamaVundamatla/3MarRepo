    <JadeMethod name="setupForm" id="e31259ba-e4b4-4878-b6f2-f760bf0b42b2">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:	30 December 2008 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars

	ti : CM_TrackedItem;
	
begin

	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	ti := app.myMobileCargoFindAgent.myTrackedItemToProcess;
	if ti &lt;&gt; null then
		//returning from a specific search
		self.setMyTrackedItem(  app.myMobileCargoFindAgent.myTrackedItemToProcess );
	else
		// populated on one of the other maint forms
		self.setMyTrackedItem( self.getSessionAgent().mySelectedTI );
	endif;
	
	self.setupCmdButtons( 1, BACK_BUTTON, null, null, null, null );
	
	inheritMethod();
	
	//28 Sep 2015 NDL	Par 36338 - don't want to try and use as input to other forms by default.
	if ti &lt;&gt; null and ti.isCargoGroupItem then
		app.myMobileAgent.setMySelectedTI(null);
	endif;
	
	self.setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupMenu" id="a9737523-1184-4690-a828-fadea59e9d78">
        <updating/>
        <source>setupMenu() updating, protected;
// ---------------------------------------------------------------------------
// Created:	09 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars

	passport : CM_Passport;
	term : CM_Terminal;
	resDetailSet : CM_ReserveDetailSet;
	bookingItemSet : CM_BookingRefItemSet;
	
begin

	create resDetailSet transient;
	create bookingItemSet transient;
		
	//28 Sep 2015	NDL	Par 36338
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isCargoGroupItem then
		self.mnuDocActions.visible := false;	//29 Sep 2016	NDL	TFS 2654
		self.mnuMove.visible := false;
		self.mnuGrading.visible := false;
		self.mnuStops.visible := false;
		self.mnuTasks.visible := false;
		self.isMenuItemsVisible := false;
		return;
	endif;
	
	passport := app.myPassport;
	term := passport.myTerminal;
	if not app.myCurrentUserCan(term, PmHHMove) then
	// This menu is doing funny things on the handheld - possible JADE fault
		self.mnuMove.visible := false;
		//self.mnuMove.enabled := false;
	endif;
	if not app.myCurrentUserCan(term, PmHHGrading) then
		self.mnuGrading.visible := false;
	endif;
	
	if not app.myCurrentUserCan(term, PmHHMaintainStops) then
		self.mnuStops.visible := false;
	endif;
	if not app.myCurrentUserCan(term, PmHHMaintainTasks) then
		self.mnuTasks.visible := false;
	endif;
	
	//29 Sep 2016	NDL	TFS 2654
	if self.myTrackedItem = null or not self.myTrackedItem.hasDocumentActions( resDetailSet, bookingItemSet ) then
		self.mnuDocActions.visible := false;
	endif;
	
	self.isMenuItemsVisible := self.mnuMove.visible or
						self.mnuStops.visible or
						self.mnuTasks.visible or
						self.mnuDocActions.visible or		//29 Sep 2016	NDL	TFS 2654
						self.mnuGrading.visible;
						
epilog

	delete resDetailSet;
	delete bookingItemSet;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="909e0524-b27d-45ce-80f3-7b01b9bd92c7">
        <updating/>
        <source>setupTable() updating, protected;
// ---------------------------------------------------------------------------
// Created:	30 December 2008 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 16/11/2016	cnwdap1		TFS 2842 STWR Hazardous Details Enhancements
vars
	
begin

	self.myHandHeldConfig := self.myTerminal.getHandHeldConfig( null );	//20 Dec 2016	NDL	TFS 3052
	
	if self.myHandHeldConfig &lt;&gt; null then
	
		self.tblResults.parentAspect:=Table.ParentAspect_StretchBoth;
		self.tblResults.rows := 1;
		self.tblResults.fixedRows := 1;
		self.tblResults.columns := 2;
		self.tblResults.fixedColumns := 1;
		self.tblResults.accessColumn(1).inputType := Table.InputType_None;
		self.tblResults.accessColumn(2).inputType := Table.InputType_None;
		self.tblResults.selectMode := Table.SelectMode_None;
	
	else

		self.tblResults.fontName := "Tahoma";
		//self.tblResults.rows := 14;						// TFS 2842
		self.tblResults.rows := 15;							// TFS 2842
		self.tblResults.columns := 2;
	
		self.tblResults.accessCell(1,1).text := app.getErrorString(AlternativeID);
		self.tblResults.accessCell(2,1).text := app.getErrorString(Operator);
		self.tblResults.accessCell(3,1).text := app.getErrorString(Received);
		self.tblResults.accessCell(4,1).text := app.getErrorString(Location);
		self.tblResults.accessCell(5,1).text := app.getErrorString(ISO_Type);
		self.tblResults.accessCell(6,1).text := app.getErrorString(Remarks);
		self.tblResults.accessCell(7,1).text := app.getErrorString(Commodity);
		self.tblResults.accessCell(8,1).text := app.getErrorString(Voyage);
		self.tblResults.accessCell(9,1).text := app.getErrorString(CM_Weight) &amp; self.myMobileDataAgent.getMeasureLabelUnit(null,Type_Weight);  //cnwrd1 ccms 1321 15.3.13
		self.tblResults.accessCell(10,1).text := app.getErrorString(Imex_status);
		self.tblResults.accessCell(11,1).text := app.getErrorString(CM_Discharge_Port);
		self.tblResults.accessCell(12,1).text := app.getErrorString(Stops);
		self.tblResults.accessCell(13,1).text := app.getErrorString(Tasks);
		self.tblResults.accessCell(14,1).text := app.getErrorString(AvailabilityGrade);
		self.tblResults.accessCell(15,1).text := app.getErrorString(Hazards);				// TFS 2842
		
		self.tblResults.accessRow(8).wordWrap := true;	
		self.tblResults.accessRow(6).wordWrap := true;
		self.tblResults.accessRow(12).wordWrap := true;
		self.tblResults.accessRow(13).wordWrap := true;
		self.tblResults.accessRow(14).wordWrap := true;
		self.tblResults.accessRow(15).wordWrap := true;										// TFS 2842
	
	endif;
	
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="cfa262d8-c8cb-4779-aed1-ace93184086b">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 October 2016 09:06:46.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013018, locale);
	mnuContext.translateCaption(Xlat_0013019, locale);
	mnuDocActions.translateCaption(Xlat_0021403, locale);
	mnuGrading.translateCaption(Xlat_0013020, locale);
	mnuMove.translateCaption(Xlat_0013021, locale);
	mnuStops.translateCaption(Xlat_0013022, locale);
	mnuTasks.translateCaption(Xlat_0013023, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
