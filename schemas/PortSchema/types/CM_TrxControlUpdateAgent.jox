    <JadeMethod name="trxUpdateWagonConfirmRailLine" id="d046c9a7-b21c-4a6c-adf1-07a6809869bf">
        <updating/>
        <source>trxUpdateWagonConfirmRailLine(_moveController : CMIF_WagonMoveController; pRailLine : CM_RailLine input; doAutoPlan : Boolean;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result : Boolean; // ccms 1031 cnwrs1 june 2006
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	result := pRailLine.validateTIsForConfirm(_passport);
	if (not result) then
		endLoad;
		return;
	endif;
	
	endLoad;

	app.setContinueCMExceptions(false);

	beginTransaction;
	
	_passport.useTIDictDeferUpdate 			:= true;
	_passport.useTITransactionDeferUpdate 	:= true;
	_passport.useEventDeferUpdate			:= true;
	
	pRailLine.confirmRake( _moveController, doAutoPlan, _passport);

	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="pRailLine" type="CM_RailLine" usage="input"/>
        <Parameter name="doAutoPlan" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWagonConfirmToRail" id="f938c821-0f3a-40d9-bec2-5ffe479f2a81">
        <updating/>
        <source>trxUpdateWagonConfirmToRail(control : CMIF_WagonMoveController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 02 May 2024 		navma1 			ChangeRequest 63936: MTN - Use Deferred Updates When Confirm Wagons
// ---------------------------------------------------------------------------

vars
	wagons : CM_WagonArray;
	wagon  : CM_Wagon;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	if control.allWagons.isEmpty() then
		return;
	endif;
	
	beginTransaction;

	_passport.useTIDictDeferUpdate 			:= true;		//02.05.2024 navma1 #63936
	_passport.useTITransactionDeferUpdate 	:= true;		//02.05.2024 navma1 #63936
	_passport.useEventDeferUpdate := true; // ### TFS CR 63938 TASK 63942 02MAY2024 NAVAB1
	
	
	// ### MOVE TO RAIL
	if control.myTargetRailLine &lt;&gt; null then
		reserveLock(control.myTargetRailLine);
	endif;
	if control.myTargetTrain &lt;&gt; null then
		reserveLock(control.myTargetTrain);
	endif;

	app.myUtilityUA.utlMoveWagons(control, _passport);
	if _passport.hasErrorsOrWarnings() then
		return;
	endif;
	
	// ### CONFIRM WAGONS 
	create wagons transient;
	control.allWagons.copy(wagons);
	app.myUtilityUA.utlUpdateWagonConfirm(wagons, true, control, _passport);
	
	
	if _passport.noErrors then								//02.05.2024 navma1 #63936
		_passport.doDeferredUpdates();
	endif;

	if _passport.hasErrorsOrWarnings() then
		return;
	endif;

	// ### get train bodge
	wagon := wagons.first;
	if wagon &lt;&gt; null then
		if wagon.myTrainInwards &lt;&gt; null then
			wagon.myTrainInwards.moveOutwardJobsToRail(control, _passport);
		endif;
	endif;

epilog
	delete wagons;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="control" type="CMIF_WagonMoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWagonConfirmTrain" id="ea48e895-39b6-47b3-afad-bc49fda82a01">
        <updating/>
        <source>trxUpdateWagonConfirmTrain( _wagonMoveControl : CMIF_WagonMoveController;
							_inward 		  : Boolean;
							_train 			  : CM_Train input; 
							_doAutoPlan 	  : Boolean;
							_passport 		  : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 Oct 2024 navma1 MTN-33231 MTN - Enable Deferred Updates For Train and Wagon Events 
// ---------------------------------------------------------------------------
vars
	result : Boolean; // ccms 1031 cnwrs1 june 2006
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	if (not _train.validateTIsForConfirm(_passport)) then
		endLoad;
		return;
	endif;
	
	endLoad;

	app.setContinueCMExceptions(false);

	beginTransaction;
	
	_passport.useTIDictDeferUpdate 		  := true;
	_passport.useTITransactionDeferUpdate := true;
	_passport.useEventDeferUpdate		  := true;					//25.10.2024 navma1 #MTN-33231
	
	_train.confirmWagons( _wagonMoveControl, _inward, _doAutoPlan, _passport);
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_wagonMoveControl" type="CMIF_WagonMoveController"/>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_train" type="CM_Train" usage="input"/>
        <Parameter name="_doAutoPlan" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
