    <JadeMethod name="zDEV_CreateMOVINS" id="9c6750c8-2275-4293-a516-494bec2c61b2">
        <source>zDEV_CreateMOVINS() : String;
/*
Purpose:			
Date		Who		Reason
JANUARY 2017	8cnwab1	Initial creation
*/


	
vars
	vessel			: CM_Vessel;
	ediFile			: CM_EDIFile;
	text			: String;
	tempStr			: String;
	container		: CM_Container;
	operatorCode 	: String;
	operator		: CM_Operator;
	ti : CM_TrackedItem;
	ediTI			: CM_EDITrackedItem;
	nextLC : CM_LocationsController;
	containerId, isoType, dPort, lPort, locationCode, opCode : String;
	voyageName, vesselCode, lloydsNumber, reeferComm, hazardComm, loadPort, nowYear, nowTime, recipient, version : String;
	lcsUsed : CM_LCSet;
	now : TimeStamp;
		tis : CM_TIArray;

begin
	recipient := "AUMEL";
	version := "D:95B";
	
	operatorCode 	:= self.myOperator.code;
	voyageName := self.code;
	vesselCode := self.vesselCode;
	lloydsNumber := self.lloydsNumber;
	loadPort := self.myTerminal.getConfig(PortDestCode).String;
	
	nowYear := now.date.shortYearEDI();
	nowTime := now.time.hour.padLeadingWith("0",2);
	nowTime := nowTime &amp; now.time.minute.padLeadingWith("0",2);
	
	create lcsUsed transient;
	
	text :=
"UNB+UNOA:2+" &amp; loadPort &amp; "+" &amp; recipient &amp; "+" &amp; nowYear &amp; ":" &amp; nowTime &amp; "+44+++++DOUG'
UNH+MZEN7" &amp; voyageName &amp; loadPort &amp; "+MOVINS:"&amp;version&amp;":UN:SMDG20'
BGM++3801+9'
DTM+137:" &amp; nowYear &amp; nowTime&amp; ":201'
TDT+20+"&amp;voyageName&amp;"+++"&amp;operatorCode&amp;":172:20+++" &amp; lloydsNumber &amp; ":146::"&amp;vesselCode&amp;"'
LOC+5+"&amp;loadPort&amp;":139:6'
LOC+61+:139:6'
DTM+132:" &amp; nowYear &amp; nowTime &amp; ":201'
RFF+VON:"&amp;voyageName&amp;"'
HAN+LOA'";

	tis := zDEV_GetMOVINSCargo();

	foreach ti in tis discreteLock do
		if not ti.isExport then
			continue;
		endif;
		
		if not ti.isContainer() then
			continue;
		endif;
		
		containerId := ti.id;
		isoType := ti.getISOType();
		dPort := ti.dischargePort;
		lPort := ti.loadPort;
		opCode := ti.operatorCode;
		
		nextLC := self.zGetNextEmptyLoadPosition(lcsUsed, true, not ti.is20, dPort);
		locationCode := "##";
		if nextLC &lt;&gt; null then
			locationCode := "0" &amp; nextLC.getIdBayCellTier(ti);
		endif;
		
		text := text &amp; 


"LOC+147+" &amp; locationCode  &amp;" ::5'
MEA+WT++KGM:18881'
LOC+9+" &amp; lPort &amp; "'
LOC+11+" &amp; dPort &amp; "'
RFF+BM:1'" &amp;
"EQD+CN+" &amp; containerId &amp; "+" &amp; isoType &amp; "++4+5'
NAD+CA+"&amp; opCode &amp;":172:20'";
	

	endforeach;

		 
		 
		
	text := text &amp; "TMP+2+-20:CEL UNZ+1+44'";

		return text;
			
epilog
	delete lcsUsed;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zDEV_GetMOVINSCargo" id="7ac76a8d-05d3-4cef-864b-a2484c9b4378">
        <source>zDEV_GetMOVINSCargo() : CM_TIArray;
// ---------------------------------------------------------------------------
// Created:     17 January 2017 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	dynaDict					: DynaDictionary;
	ti : CM_TrackedItem;
	length, ordinal : Integer;
	tis : CM_TIArray;
begin
	create dynaDict transient;
	
	dynaDict.setMembership(CM_TrackedItem);
	dynaDict.addExternalKey(Integer, 8, false,true); // DPort Ordinal
	dynaDict.addExternalKey(Integer, 8, false,true); // Length
	dynaDict.endKeys(true);

	foreach ti in self.allOnsiteTIsByCargoTypeId discreteLock do
		if not ti.isExport then
			continue;
		endif;
		
		if not ti.isContainer() then
			continue;
		endif;
		length := ti.getLengthInUnits().Integer;
		ordinal := self.getDischargePortOrdinal(ti.dischargePort);
		
		dynaDict.putAtKey(ordinal, length, ti);
	endforeach;

	foreach ti in self.allNotifiedTIsByIdCargoType discreteLock do
		if not ti.isExport then
			continue;
		endif;
		
		if not ti.isContainer() then
			continue;
		endif;
		length := ti.getLengthInUnits().Integer;
		ordinal := self.getDischargePortOrdinal(ti.dischargePort);
		dynaDict.putAtKey(ordinal, length, ti);
	endforeach;
	
	create tis transient;
	
	dynaDict.copy(tis);
	
	return tis;
epilog
	delete dynaDict;
end;</source>
        <ReturnType type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="zGetNextEmptyLoadPosition" id="4375dad1-6b2a-46d7-bd27-09904ee30f20">
        <source>zGetNextEmptyLoadPosition(_lcsUsed : CM_LCSet input; _lolo : Boolean; _is40 : Boolean; dport : String) : CM_LocationsController;
/*
Purpose:			For Dev Scripts
Date		Who		Reason
JANUARY 2017		cnwab1	Initial creation
*/

vars
	bay : CM_Bay;
	slotDefn, slotAbove : CM_SlotDefn;
	slotLC, aftSlot : CM_SlotController;
	tis : CM_TIArray;
	slotsAbove : CM_SlotDefnByDeckCellTier;
begin
	if _lcsUsed = null then
	
		return null;
	endif;
	
	
	create tis transient;
	if _lolo then
		foreach bay in self.myCellularVoyageStructure.allBayVoyagesByOrdinal discreteLock do
			foreach slotDefn in bay.allSlotsByOrdinal discreteLock do : slotloop
				if slotDefn.unavailable then
					continue;
				endif;
				
				slotLC := slotDefn.CM_SlotDefnVoyage.mySlotController;
				
				slotLC.getProposedTIs(tis);
				
				if not tis.isEmpty() then // there are TIs here so ignore
					continue slotloop;
				endif;
				if not _is40 then
					slotsAbove := slotDefn.getAllSlotAbove();
					
					foreach slotAbove in slotsAbove discreteLock do
						slotLC := slotDefn.CM_SlotDefnVoyage.mySlotController;
						
						slotLC.getProposedTIs(tis);
						
						if not tis.isEmpty() then // there are TIs here so ignore
							continue slotloop;
						endif;
						
					endforeach;
					
					delete slotsAbove;
				endif;
				
				if not _lcsUsed.includes(slotLC) then
					if _is40 then
						// put the aft in so that another 20 does not try to use it
						aftSlot := slotLC.myNextSlotInHold(); // get the AFT
						if aftSlot &lt;&gt; null then
							if not _lcsUsed.includes(aftSlot) then
								_lcsUsed.add(aftSlot);
							else
								continue slotloop; // this is not a suitable slot for the front end of a 40
							endif;
						else
							continue slotloop; // this is not a suitable slot for the front end of a 40
						endif;
					endif;
					
					_lcsUsed.add(slotLC);
					return slotLC;
				endif;
				
			endforeach;
		endforeach;
	
	endif;
epilog
	delete tis;
end;</source>
        <Parameter name="_lcsUsed" type="CM_LCSet" usage="input"/>
        <Parameter name="_lolo" type="Boolean"/>
        <Parameter name="_is40" type="Boolean"/>
        <Parameter name="dport" type="String"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
</Class>
