    <JadeMethod name="handleNotifications" id="4dff24c8-bd06-4b2e-b1c0-3ca15d5a6a8f">
        <updating/>
        <source>handleNotifications(eventType: Integer; _theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Feb 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
07 Feb 2023	navcs2	ChangeRequest 55440 (54990)
19 Apr 2023 navhl20	Defect 57642: MTN - Booking Item is not added to the list of Booking Items unless refreshed the work order form
04 Jul 2023 namva1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
11 Jul 2023 navhl20 Defect 59092: EUP - On the Add Cargo form the Cargo SubType list is empty
11 Mar 2024	navma1  Bug 62810: MTN - Notifications causing updates to combo box in cargo work order
23 Dec 2024	navbs1	Bug MTN-33524: MTN - Notifications in the work order details screen update the release request assigned as a new work order is created
*/

vars
	termEvent,
	idx				: Integer;
	invalidObject	: Boolean;
	user			: CM_User;
	edition			: Integer;
	woUserCode		: String;
	objUserCode		: String;
begin
	on Exception do app.handleDeletedObject(exception, _theObject, invalidObject);
	
	if _theObject = null then				//11.03.2023 navma1 #62810
		return;
	endif;
	
	edition := _theObject.edition;			//11.03.2023 navma1 #62810
	
	if invalidObject then
		return;
	endif;

	if self.myTerminal &lt;&gt; null then
		termEvent := self.myTerminal.getEventFromTerminalEvent(eventType);
	endif;
	
	if self.myPxyWorkOrder &lt;&gt; null then
		woUserCode := self.myPxyWorkOrder.userCode;
	endif;
	//commenting the code as we no longer updating the form based on the notifications
	/*if termEvent = Event_BookingRefAdd then
		
		if self.myPxyTask.isKindOf(CM_WodReceive) or  self.myPxyTask.isKindOf(CM_WodRelease) then
			user := _theObject.CM_BookingRef.getCreatedByUser();		//11.03.2023 navma1 #62810
			if user &lt;&gt; null then
				objUserCode := user.code;
			endif;
			
			if  woUserCode = objUserCode then						   //11.03.2023 navma1 #62810
				self.cmbBooking.addItemObject(_theObject.CM_BookingRef.bookingReference,_theObject.CM_BookingRef);
				self.cmbBooking.listObject := _theObject.CM_BookingRef;
				self.cmbBooking_click(self.cmbBooking);
			endif;
		endif;
		
	elseif termEvent = Event_BOLUpdate then							//19.4.2023 navhl20 #57642
		idx := self.cmbBol.listIndex;								//11.7.2023 navhl20 #59092
		self.buildCmbBol(self.cmbTransport.listObject.CM_Voyage);	//11.7.2023 navhl20 #59092
		self.cmbBol.listIndex := idx;								//11.7.2023 navhl20 #59092
		self.cmbBol_click(self.cmbBol);
	elseif termEvent = Event_BookingRefUpdate then					//19.4.2023 navhl20 #57642
		self.cmbBooking_click(self.cmbBooking);
	
	elseif termEvent = Event_BOLAdd then
		user := _theObject.CM_BOL.getCreatedByUser();				//11.03.2023 navma1 #62810
		if user &lt;&gt; null then
			objUserCode := user.code;
		endif;
		
		if woUserCode = objUserCode then
			self.cmbBol.addItemObject(_theObject.CM_BOL.number,_theObject.CM_BOL);
			self.cmbBol.listObject := _theObject.CM_BOL;
			self.cmbBol_click(self.cmbBol);
		endif;
	elseif termEvent = TIEvent_PreNote_Add then
		self.maintainBtnAttachCargo();
	elseif termEvent = BulkRelease_Update_Event then														// 07.02.2023 navcs2 #55440:[54990]
		
		user := _theObject.CM_BulkRelease.getCreatedByUser();												//11.03.2023 navma1 #62810
		if user &lt;&gt; null then
			objUserCode := user.code;
		endif;
		
		if woUserCode = objUserCode then
			self.cmbReleaseRequest.addItemObject(_theObject.CM_BulkRelease.code,_theObject.CM_BulkRelease);		// 07.02.2023 navcs2 #55440:[54990]
			self.cmbReleaseRequest.listObject := _theObject.CM_BulkRelease;										// 07.02.2023 navcs2 #55440:[54990]
			self.cmbReleaseRequest_click(self.cmbReleaseRequest);												// 07.02.2023 navcs2 #55440:[54990]
		endif;
	endif;*/
epilog
	endLoad;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
