    <JadeMethod name="clickBtnViewRakeWagons" id="1215160c-368b-4ea0-9833-2eb8c39ee8a5">
        <updating/>
        <source>clickBtnViewRakeWagons() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	rake : CM_RailLine;
	mess : String;
	
begin

	rake := lstRakes.listObject.CM_RailLine;
	if rake = null then
		mess := app.getErrorString(Please_select_rail_rake_view);
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return;
	endif;
	app.mousePointer :=	Busy;
	self.myMobileGenericAgent.setMyCurrentRailLine(rake);
	self.gotoForm( MOB_HHRailRakeView, false );

epilog
	app.mousePointer :=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="253ecf6b-102e-4ce8-8914-ec17a65308e0">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	width : Real;
	left : Real;
	lstHeight : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin - 8 ;
	stdHeight := self.getStdControlHeight;
	
	if _initialSetup then
		self.lblWagonCargo.setAndIncrementTabIndex( tabIndex );
		self.lblWagonCargo.visible := true;
	endif;
	self.lblWagonCargo.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
	
	top := self.lblWagonCargo.top + self.lblWagonCargo.height + self.resizedMargin;
	// total form height - height of button area at bottom - room for rake btn - room for to opt buttons below - some spare room + offset.
	//lstHeight := self.height - self.getCMDHeight() - top - ( stdHeight * 1.5 )  - stdHeight +  self.getSessionAgent().deviceHeightOffset;
	lstHeight := self.clientHeight - self.getCMDHeight() - top - ( stdHeight * 1.5 )  - stdHeight;	//26 Jun 2017	NDL	TFS 4647
	if _initialSetup then
		self.lstRakes.setAndIncrementTabIndex( tabIndex );
		self.lstRakes.visible := true;
	endif;
	self.lstRakes.move(	stdLeft,
							top,
							stdWidth,
							lstHeight );
							
	width := btnViewRake.width;
	left := ( stdWidth - width ) / 2;
	top := self.lstRakes.top + self.lstRakes.height + ( stdHeight / 2 ) + self.resizedMargin;
	if _initialSetup then
		self.btnViewRake.setAndIncrementTabIndex( tabIndex );
		self.btnViewRake.visible := true;
	endif;
	self.btnViewRake.move(	left,
							top,
							width,
							stdHeight );
								
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getHelpDescr" id="bf67013f-432c-4eda-9df8-b57024e286d8">
        <source>getHelpDescr(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars
	
begin

	return app.getErrorString(RAILHHHELP_WAG001) &amp; CrLf  &amp; CrLf &amp;
			//This shows detail of each rake for the train being worked on.
			app.getErrorString(RAILHHHELP_WAG002) &amp; CrLf  &amp; CrLf &amp;
			//The Notified line contains known totals for wagons and cargo on that rake.
			app.getErrorString(RAILHHHELP_WAG003) &amp; CrLf  &amp; CrLf &amp;
			//The Confirmed line is the number of wagons and cargo entered as checked during this session by the current user.
			app.getErrorString(RAILHHHELP_WAG004);
			//Press Train to go back to the Train and Rake selection form.
				
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
