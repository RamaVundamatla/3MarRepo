    <JadeMethod name="cmbTermArea_gotFocus" id="097ce766-0217-4e9e-94a8-00c7ab37c91a">
        <controlMethod name="ComboBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTermArea_gotFocus(combobox: ComboBox input) updating;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.origValueStr := combobox.text;
