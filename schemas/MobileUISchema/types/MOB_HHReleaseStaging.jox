    <JadeMethod name="doResizeControls" id="78e33fc3-5f1f-437c-b0c9-29c7f9df171d">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtRequestId.setAndIncrementTabIndex( tabIndex );
		self.txtRequestId.visible := true;
	endif;
	self.txtRequestId.move( 	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtRequestId.height + ( self.resizedMargin );
	if _initialSetup then
		self.lblRequest.setAndIncrementTabIndex( tabIndex );
		self.lblRequest.visible := true;
	endif;
	self.lblRequest.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight ); 
								
	cTop := cTop + self.lblRequest.height;
	if _initialSetup then
		self.cmbTargetArea.setAndIncrementTabIndex( tabIndex );
		self.cmbTargetArea.visible := true;
	endif;
	self.cmbTargetArea.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight ); 
							 
	cTop := cTop + self.cmbTargetArea.height + ( self.resizedMargin );
	if _initialSetup then
		self.cmbMoveMode.setAndIncrementTabIndex( tabIndex );
		self.cmbMoveMode.visible := true;
	endif;
	self.cmbMoveMode.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight ); 
							 
	cTop := cTop + self.cmbMoveMode.height + ( self.resizedMargin ) + stdHeight;
	if _initialSetup then
		self.optById.setAndIncrementTabIndex( tabIndex );
		self.optById.visible := true;
	endif;
	self.optById.move( self.resizedMargin + stdHeight,
							 cTop,
							 cWidth,
							 cHeight );
							 
	 if _initialSetup then
		self.optById.value := false;
	endif;
							 
	cTop := cTop + optById.height + ( self.resizedMargin );
	if _initialSetup then
		self.optFIFO.setAndIncrementTabIndex( tabIndex );
		self.optFIFO.visible := true;
	endif;
	self.optFIFO.move( self.resizedMargin + stdHeight,
							 cTop,
							 cWidth,
							 cHeight );
							 
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findRequest" id="aa7a9df5-deef-4826-8cd8-565e469f248e">
        <updating/>
        <source>findRequest() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2014	cnwndl1	Initial creation

*/

vars

	requestString : String;
	request : CM_Request;
	term : CM_Terminal;
	selectedBulkRelease : CM_BulkRelease;

begin

	requestString := self.txtRequestId.text;
	self.myBulkRelease := null;
	self.requestedItemCount := 0;
	
	if requestString.trimBlanks = null or requestString = self.lblRequestId.caption.toUpper then
		if requestString = null then
			self.txtRequestId.text := self.lblRequestId.caption.toUpper;
		endif;
			
	else
		//find an active road release.
		term := self.myMobileDataAgent.myTerminal;
		selectedBulkRelease := self.getActiveBulkRelease( term, BR_TYPE_ROAD, false, requestString );
		
		if selectedBulkRelease &lt;&gt; null then
			self.myBulkRelease := selectedBulkRelease;
		
		endif;
		
	endif;

	if self.myBulkRelease = null then
		self.lblRequest.caption := app.getErrorString(No_request_found);
	else
		if self.myBulkRelease.releaseByType then
			self.requestedItemCount := self.myBulkRelease.getTotalOutstanding;
			self.lblRequest.caption := app.releaseRequestTypeEnumToString( self.myBulkRelease.type ) &amp; " " &amp; app.getErrorString(Release_by_Type) &amp; " ["
			&amp; self.requestedItemCount.String &amp; " " &amp; app.getErrorString(YAM_Msg_Items) &amp; "]";
		else
			self.requestedItemCount := self.myBulkRelease.allTrackedItemsAssigned.size;
			self.lblRequest.caption := app.releaseRequestTypeEnumToString( self.myBulkRelease.type ) &amp; " " &amp; app.getErrorString(Release_by_ID) &amp; " ["
			&amp; self.requestedItemCount.String &amp; " " &amp; app.getErrorString(YAM_Msg_Items) &amp; "]";
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="d967d597-f2b8-4de3-921c-cf77de389dd5">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2014	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod();

	self.myMobileGenericAgent.setMyBulkRelease( self.myBulkRelease );
	self.myMobileGenericAgent.setMyYardLocation( self.cmbTargetArea.listObject.CM_LocationsController );
	if self.optById.value then
		self.myMobileGenericAgent.setStringField1( self.optById.name );
	elseif self.optFIFO.value then
		self.myMobileGenericAgent.setStringField1( self.optFIFO.name );
	endif;
	if self.cmbMoveMode.text = app.getErrorString( Queued_Move ) then
		self.myMobileGenericAgent.setChecksState( QUEUE_MODE );
	else
		self.myMobileGenericAgent.setChecksState( REAL_MODE );
	endif;
	
	self.gotoForm( MOB_HHStagingCargo, false );

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
