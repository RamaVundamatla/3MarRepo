    <JadeMethod name="zMSDSLFinExportCreateDebtors" id="7c96c01a-a0b1-4086-977e-7a7353a16863">
        <source>zMSDSLFinExportCreateDebtors(_debtors : CM_DebtorSet input) protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 25 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	debtorName	: String;
	debtorNode	: CM_DebtorNode;
	proxyDebtor	: CM_Debtor;
	debtorNodeController	: CMIF_DebtorNode;
begin

	// delete debtors first
	debtorName := "UT_DebtorSL";
	debtorNode := app.myRoot.myRootCompany.debtors[debtorName];
	if debtorNode &lt;&gt; null then
		self.deleteDebtor(debtorNode);
	endif;
	
	// new debtors
	debtorName := "UT_DebtorSL";
	create debtorNodeController transient;
	create proxyDebtor transient;
	self.setDebtorNodeController(debtorName, "600555", "", "", debtorNodeController, proxyDebtor);
	
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(debtorNode.CM_Debtor.decfinName, "600555", "Debtor1 decfinName");
	_debtors.add(debtorNode.CM_Debtor);	
	
epilog

	delete proxyDebtor;
	delete debtorNodeController;
end;</source>
        <access>protected</access>
        <Parameter name="_debtors" type="CM_DebtorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zMSDSLFinExportCreateILTs" id="9c162886-19b4-4759-8f3a-1def0e64c1f9">
        <source>zMSDSLFinExportCreateILTs(_invType : CM_InvoiceDesc; _services : CM_ServiceByNameDict) protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 25 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	count			: Integer;
	code			: String;
	calType1 		: CM_CalculationType;
	service			: CM_Service;
	serviceList 	: CM_ServiceByNameDict;
	invLineType  	: CM_InvoiceLineDesc;

begin
	calType1 := app.myRoot.allCalculationTypesByCode["CCT126"];	// units
	create serviceList transient;

	foreach service in _services do
		count := count + 1;
		code := "UT_MSDSL" &amp; count.String;
		self.deleteInvoiceLineType(code, FORCED_ERASE);
		serviceList.clear();
		serviceList.add(service);
		invLineType := self.createInvoiceLineType(code, calType1, _invType, serviceList, "SDT1");
	endforeach;

epilog
	delete serviceList;
end;
</source>
        <access>protected</access>
        <Parameter name="_invType" type="CM_InvoiceDesc"/>
        <Parameter name="_services" type="CM_ServiceByNameDict"/>
    </JadeMethod>
    <JadeMethod name="zMSDSLFinExportCreateInvoices" id="5914688c-c5e5-4f14-a8ed-4311a6d52ced">
        <source>zMSDSLFinExportCreateInvoices(_debtors : CM_DebtorSet; _invType : CM_InvoiceDesc; _voyage : CM_Voyage) : CM_InvoiceSet protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 25 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	date		: Date;
	count		: Integer;
	bank		: CM_Bank;
	debtor		: CM_Debtor;
	invLineType	: CM_InvoiceLineDesc;
	invoice		: CM_Invoice;
	invoiceLine	: CM_InvoiceLine;
	invoices	: CM_InvoiceSet;
begin

	bank := self.myBank;
	create invoices transient;
	
	// create invoices
	foreach debtor in _debtors do
		invoice := self.createManualInvoice(bank, debtor, _voyage, _invType, null);
		count := count + 1;
		if count = 1 then		
			invLineType := self.getInvoiceLineType("UT_MSDSL1");		
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 100, "Line 1", date);			
		else
			break;		
		endif;
		
		beginTransaction;
		invoice.setVoyage(_voyage);
		commitTransaction;
		
		invoices.add(invoice);
	
	endforeach;
	
	return invoices;
	
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_debtors" type="CM_DebtorSet"/>
        <Parameter name="_invType" type="CM_InvoiceDesc"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_InvoiceSet"/>
    </JadeMethod>
    <JadeMethod name="zMSDSLFinExportCreateRates" id="43c8fcd5-8caa-4055-8c75-8479a0065bad">
        <source>zMSDSLFinExportCreateRates(_debtors : CM_DebtorSet; _services : CM_ServiceByNameDict) protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 25 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	start,
	expiry 		: TimeStamp;
	costs 		: DecimalArray;
	service		: CM_Service;
	debtorRate  : CM_DebtorRate;
	rateEntry 	: CM_RateEntry;
	debtor		: CM_Debtor;
begin
	
	// set up rates for these debtors and services
	create costs transient;
	create debtorRate transient;
	foreach debtor in _debtors do
		foreach service in _services do
			debtorRate.setProxy(service, debtor);
			costs.clear();
			costs.add(50.00);			
			start.setDate("01/01/2010".Date);
			start.setTime("00:00".Time);
			expiry := null;
			rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, false, costs, 0, 0, null, null);
		endforeach;
	endforeach;
	
epilog
	delete costs;
	delete debtorRate;
end;</source>
        <access>protected</access>
        <Parameter name="_debtors" type="CM_DebtorSet"/>
        <Parameter name="_services" type="CM_ServiceByNameDict"/>
    </JadeMethod>
    <JadeMethod name="zMSDSLFinExportCreateServices" id="e1498585-8955-4e1a-a050-f62865ac8ad7">
        <source>zMSDSLFinExportCreateServices(_services : CM_ServiceByNameDict input) protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 25 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
constants
	GLCODE		: String = "5944-128024";
vars
	servCode	: String;
	calType1 	: CM_CalculationType;
	glCode		: CM_GLCode;
	service		: CM_Service;
begin

	// recreate the GL codes and services
	calType1 := app.myRoot.allCalculationTypesByCode["CCT126"];	// units

	// create GL codes and associated services - delete service first then GL code and create in reverse order
	servCode := "UT_ServiceSL";
	self.deleteInvoiceService(servCode, FORCED_ERASE);	
	self.deleteInvoiceGLCode(GLCODE);
	glCode := self.createInvoiceGLCode(GLCODE, "");
	service := self.createInvoiceService(servCode, "", calType1, glCode);
	_services.add(service);	
end;</source>
        <access>protected</access>
        <Parameter name="_services" type="CM_ServiceByNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zMSDSLFinExportPostInvoices" id="890e8c98-11d8-48ed-937e-1ff1b7f91031">
        <source>zMSDSLFinExportPostInvoices(_invoices : CM_InvoiceSet) protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 25 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	count				: Integer;
	status				: Integer;
	isZeroRated 		: Boolean;
	termsOfTrade 		: CM_InvoiceTermsOfTrade;
	purchaseOrderNumber : String;
	narration		 	: String;
	endDate 			: Date;
	doExport 			: Boolean;	
	invoice				: CM_Invoice;
begin

	foreach invoice in _invoices do
		count := count + 1;
		status := CM_Invoice.INVOICE_PENDING;
		self.updateInvoiceStatus(invoice, status, isZeroRated, termsOfTrade, purchaseOrderNumber, narration, endDate, doExport);
		self.assertEqualMsg(invoice.status, CM_Invoice.INVOICE_PENDING, "Invoice " &amp; count.String &amp; " Pending");

		status := CM_Invoice.INVOICE_POSTED;
		isZeroRated := true;
		purchaseOrderNumber := "ABC123";
		narration := "Unit test";
		doExport := true;
		self.updateInvoiceStatus(invoice, status, isZeroRated, termsOfTrade, purchaseOrderNumber, narration, endDate, doExport);
		self.assertEqualMsg(invoice.status, CM_Invoice.INVOICE_POSTED, "Invoice " &amp; count.String &amp; " POSTED");
		self.assertEqualMsg(invoice.exportedCount, 1, "Invoice " &amp; count.String &amp; " exported");
	endforeach;
	self.assertEqualMsg(count, 1, "Posted invoices");
end;
</source>
        <access>protected</access>
        <Parameter name="_invoices" type="CM_InvoiceSet"/>
    </JadeMethod>
    <JadeMethod name="zMSDSLFinExportTest" id="55a7a365-c0a5-4576-af7d-fc0b8cb4a1ff">
        <source>zMSDSLFinExportTest(_invoice : CM_Invoice; _filePrefix : String) protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 25 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		         Description
14 Mar 2023     navmp20     ChangeRequest 56278: PRP - Financial Data Extract Additional Attributes
****************************************************/
constants
	DELIMITER = ",";
vars
	ioFin 			: CM_ENTNewHaven;
	oArray 			: ObjectArray;
	path, 
	line, 
	expectedLine, 
	invNarr 		: String;
	file 			: File;
	idx	 			: Integer;
	glQty, 
	glLineTotal 	: Decimal[6,2];
	invLine 		: CM_InvoiceLine;
begin


	create oArray transient;
	CM_ENTNewHaven.allInstances(oArray,0,false);
	ioFin := oArray[1].CM_ENTNewHaven;
	
	path := ioFin.exportPath.normaliseDirectory().substituteDirectory();
	
	create file;
	file.kind := File.Kind_Unknown_Text; 	
	// ### CHECK ENT SALES HEADER
	idx := 0;
	file.fileName := path &amp; _filePrefix.String &amp; "SalesHeader.csv"; 
	while not file.endOfFile do
		line := file.readLine();
		idx := idx + 1;
		if idx &gt; 1 then // ignore the first line
			expectedLine := "3," &amp; "TOSINV".String.asDoubleQuotedString &amp; "," &amp; _invoice.sequenceNum.String &amp; "," &amp; _invoice.toDT.date.format("MM/dd/yy") &amp; ","&amp;"TRX FROM TOS".String.asDoubleQuotedString &amp;
			","&amp;"600555".String.asDoubleQuotedString &amp; ","&amp;"HVN".String.asDoubleQuotedString &amp; ",,,,,,," &amp; "UTINVVSL3".String.asDoubleQuotedString; 
			self.assertTrueMsg((expectedLine = line), "SalesHeader File Incorrect. Expected:" &amp; CrLf &amp; "'" &amp; expectedLine &amp; "'" &amp; CrLf &amp; "'" &amp; line &amp; "'" );
		endif;
	endwhile;
	delete file;
	
	create file;
	// ### CHECK ENT SALES LINES
	idx := 0;
	file.fileName := path &amp; _filePrefix.String &amp; "SalesLines.csv"; 
	while not file.endOfFile do
	
		line := file.readLine();
		idx := idx + 1;
		if idx &gt; 1 then // ignore the first line
			foreach invLine in _invoice.invoiceLines discreteLock do
				break;
			endforeach;
			//expectedLine := _invoice.sequenceNum.String &amp; "," &amp; invLine.invoiceLineDesc.services.first.remarks &amp; ",100.0000,50.0000," &amp; "UT_MSDSL1".String.asDoubleQuotedString &amp; ",";
		    expectedLine := _invoice.sequenceNum.String &amp; "," &amp; invLine.invoiceLineDesc.services.first.remarks &amp; ",100.0000,50.0000," &amp; "UT_MSDSL1".String.asDoubleQuotedString &amp; "," 
			                 &amp; invLine.invoiceLineDesc.unitNarration.String.asDoubleQuotedString &amp; "," &amp; "ISO Container".String.asDoubleQuotedString;									//14.03.2023 navmp20 TFS 56278

			self.assertTrueMsg((expectedLine = line), "SalesLine File Incorrect. Expected:" &amp; CrLf &amp;  "'" &amp; expectedLine &amp; "'" &amp; CrLf &amp;  "'" &amp; line &amp; "'");
			
			break; // only check 1 line
		endif;
	endwhile;
	
	delete file;
	
	create file;
	
	// ### CHECK ENT GENERAL LEDGER LINES
	file.fileName := path &amp; _filePrefix.String &amp;  "SalesDistribution.csv"; 
	idx := 0;
	while not file.endOfFile do
		line := file.readLine();
		line := file.readLine();
		foreach invLine in _invoice.invoiceLines discreteLock do
			
			if invNarr = "" or invNarr = invLine.invoiceLineDesc.narration then
				idx := idx + 1;
				
				invNarr := invLine.invoiceLineDesc.narration;
				
				glQty := glQty + invLine.quantity;
				glLineTotal := glLineTotal + invLine.lineTotal;

				if idx = 2 then
					break;
				endif;
			endif;
			
			
		endforeach;
		expectedLine := _invoice.sequenceNum.String &amp; "," &amp; invLine.charges.first.glCode &amp; "," &amp; "1" &amp; ",," &amp; glLineTotal.String&amp;",";
		self.assertTrueMsg((expectedLine = line), "SalesDistribution File Incorrect. Expected:" &amp; CrLf &amp;  "'" &amp; expectedLine &amp; "'" &amp; CrLf &amp;  "'" &amp; line &amp; "'");
		break;
	endwhile;
	
epilog
	delete oArray;
	delete file;
end;</source>
        <access>protected</access>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_filePrefix" type="String"/>
    </JadeMethod>
    <JadeMethod name="zMSDSLFinExportTestInvoices" id="09263681-52c4-4f00-b4fd-c69b2e1ae1e7">
        <source>zMSDSLFinExportTestInvoices(_invoices : CM_InvoiceSet) protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 25 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	count		: Integer;
	invoice		: CM_Invoice;
begin

	foreach invoice in _invoices do
		count := count + 1;
		self.zMSDSLFinExportTest(invoice, self.getTerminal().code &amp; invoice.sequenceNum.String);		
	endforeach;
	self.assertEqualMsg(count, 1, "Number of files");
	
epilog
end;
</source>
        <access>protected</access>
        <Parameter name="_invoices" type="CM_InvoiceSet"/>
    </JadeMethod>
</Class>
