    <JadeMethod name="setLastColumnMaxWidth" id="8569f607-9409-4bbd-ac5e-e037c544d248">
        <source>setLastColumnMaxWidth(_table : Table input);
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx, aColumns, barWidth : Integer;
begin

	foreach idx in 1 to _table.columns - 1 do
		if _table.accessColumn(idx).visible then
			aColumns := aColumns + _table.accessColumn(idx).width;
		endif;
	endforeach;
	_table.accessColumn(_table.columns).width := ( _table.width - aColumns - 18).Integer;


end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMenus" id="c3dc0e00-a793-411f-88f7-7536e4fa6471">
        <updating/>
        <source>setMenus() updating;
// ---------------------------------------------------------------------------
// Created:     28 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	10/09/2008	concms1		par 17903/ccms 1741 Welcome form - interim solution
//	10 Oct 2017	cnwma1  	TFS #7257 JMT - Refactoring - Commodity Planning
//  28/04/2021	navmd1		TFS 51086 - Explicitly enable the MDI menu post JADE 2020
// ---------------------------------------------------------------------------
vars
	tmpUser	: CM_User;
begin
	tmpUser := app.getMyUser();
	if tmpUser &lt;&gt; null then
		self.mnuOptPreferences.visible 		:= true;
	else
		self.mnuOptPreferences.visible 		:= false;
	endif;


	if app.isSpecial() then
		self.mnuOptionsDeveloper.visible 	:= true;
		self.mnuOptsChkTransOnClose.visible	:= true;
		self.mnuOptsShowProxiesNow.visible	:= true;
		self.mnuOptsShowTransNow.visible	:= true;
		self.mnuOptsClearProxies.visible 	:= true;
		self.mnuOptsTrxTest.visible			:= true;
		self.mnuOptsFileManager.visible		:= true;
		self.mnuOptsHideDebug.visible		:= true;
		self.mnuOptsScriptWindow.visible	:= true;
		//self.mnuOptVoyComodityPlan.visible	:= true;	//10.10.2017	cnwma1  TFS #7257
		self.mnuFindErrorName.visible		:= true;
		self.mnuFindErrorName.enabled		:= true;
	else
		self.mnuOptionsDeveloper.visible 	:= false;
		self.mnuOptsChkTransOnClose.visible	:= false;
		self.mnuOptsShowProxiesNow.visible	:= false;
		self.mnuOptsShowTransNow.visible	:= false;
		self.mnuOptsClearProxies.visible 	:= false;
		self.mnuOptsTrxTest.visible			:= false;
		self.mnuOptsFileManager.visible		:= tmpUser &lt;&gt; null and ( tmpUser.isSuperUser or tmpUser.isJmtSupportUser );	//09 Sep 2021	NDL	TFS 50505
		self.mnuOptsHideDebug.visible		:= false;
		self.mnuOptsScriptWindow.visible	:= false;
		self.mnuFindErrorName.visible		:= false;
		self.mnuFindErrorName.enabled		:= false;
		//self.mnuOptVoyComodityPlan.visible	:= false;	//(app.isDevelopmentSystem()); //10.10.2017	cnwma1  TFS #7257
	endif;
	//cnwth2 temporary
	self.mnuDownloadHelp.caption := 'Help file version checker...';
	self.mnuViewToolbar.checked := (not app.toolbarHidden);
	
	if tmpUser &lt;&gt; null then	//Par 18068
		self.mnuSendMessage.visible	:=	tmpUser.canDo(null, PmSendMessageView);		// cnwdad1 01/12/2008 - PAR 18564.
		self.mnuViewWelcome.visible	:=	tmpUser.hasWelcomeForm;						// par 17903
		self.mnuViewWelcome.checked	:=	tmpUser.getShowWelcomeScreen;				// par 17903
	else
		self.mnuSendMessage.visible	:=	false;										// cnwdad1 01/12/2008 - PAR 18564.
		self.mnuViewWelcome.visible	:=	false;
	endif;
	
	// TFS 51086 - Enable the MDI menu options
	//self.showMdiCloseAllButPinnedMenu	:= true;			// Disabling until we know if this actually works
	self.showMdiCloseAllButThisMenu		:= true;
	self.showMdiCloseMenu				:= true;
	self.showMdiDockMenu				:= true;
	self.showMdiFloatMenu				:= true;
	//self.showMdiPinMenu				:= true;

end;</source>
    </JadeMethod>
