<Class name="WS_JobSheet" id="f1521264-7bfc-40b5-89a5-036a52ff3a6d">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="description" id="e9c37020-1676-4960-a026-25dc672083ed">
        <length>101</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="id" id="9a2eeb3f-8c9a-4916-8f85-3dda7be108dd">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="da5a59e6-e934-4acd-b3cb-0a8603c733b3">
        <updating/>
        <source>setProxyFromObject(_object: CM_JobSheet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2021	jlizm1	Initial creation TFS 52028 Work hold jobs in handheld app
22 Nov 2023 navhl20 Bug 61048: EUP - Spinning wheel appears when performing the Rail Load using WO Operations app.
*/

vars

begin
	inheritMethod(_object);
	
	if _object.isKindOf(CM_VoyageJobSheet) then
		self.id := _object.CM_VoyageJobSheet.crane;
	elseif _object.isKindOf(CM_WorkPointJobSheet) then			//22.11.2023 navhl20 #61048
		self.id := _object.CM_WorkPointJobSheet.externalName;
	endif;
	self.description := _object.getNiceName();

epilog

end;</source>
        <Parameter name="_object" type="CM_JobSheet"/>
    </JadeMethod>
</Class>
