    <JadeMethod name="btnSave_click" id="a4a0d79b-6098-4ace-a531-48b6af214ba7">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSave_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		23 December 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.doFormUpdate() then
		self.resetIsChanged();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
