    </JadeMethod>
    <JadeMethod name="checkUnitTestRunnerRunning" id="4544114d-c382-4f8e-9242-6f10208dd419">
        <source>checkUnitTestRunnerRunning(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 March 2025	navcs2	MTN-34411	MTN - Create a Popup to Display when you Start the Unit Test App in Debug Mode while the Unit Test Runner is Running - Phase1

*/

vars
	jadeNodes		: NodeDict;
	jadeNode		: Node;
	allProcesses	: ProcessDict;
	jadeProcess 	: Process;
	invalidJadeNode	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, jadeNode, invalidJadeNode);
	create jadeNodes transient;
	create allProcesses transient;
	
	system.nodes.copy(jadeNodes);
	
	if jadeNodes.isEmpty then
		return null;
	endif;
	
	foreach jadeNode in jadeNodes do :nodeLoop
		allProcesses.clear();
		if invalidJadeNode then
			invalidJadeNode := false;
			continue;
		endif;
		
		jadeNode.processes.copy(allProcesses);
		
		if allProcesses.isEmpty then
			continue nodeLoop;
		endif;
		
		foreach jadeProcess in allProcesses do
			if not jadeProcess.persistentApp.name = "JMTUnitTestRunner" then
				continue;
			endif;
			
			return true;	
		endforeach;
	endforeach;
	
	return false;
epilog
	delete jadeNodes;
	delete allProcesses;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
