    <JadeMethod name="getEffectiveTimeStamp" id="f8fbbe1a-fcc1-4716-a475-dea0b894bfdc">
        <source>getEffectiveTimeStamp(): TimeStamp;
//--------------------------------------------------
// Created:	12 September 2003 By: cnwgd1
//--------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	tmpVoyage	: CM_Voyage;
	
begin

	tmpVoyage := self.myVoyage;
	if tmpVoyage = null then
		return inheritMethod();
	endif;
	
// PAR 33644	if (tmpVoyage.isNonPlannedVoyage or 
// PAR 33644	   tmpVoyage.isNonWorkedVoyage) and
	if tmpVoyage.isHOLDSorSHIP() and
	   tmpVoyage.nonPlannedEffectiveDT.isValid then
		// PAR 21745 CCMS MES 1031 - We treat RORO/Planned voyages as Planned
		
		
	// PAR 33644	if tmpVoyage.isNonPlannedOrNotCellularRORO then
			return tmpVoyage.nonPlannedEffectiveDT;
	//	endif;
	endif;

	return inheritMethod();

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="7d3e7c3c-0f18-4112-a1e4-bc1153993cdf">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	block : CM_DataContainerBlock;
	passport : CM_Passport;
	allBlocksArray : CM_DataContainerBlockArray;
	quantityTotal : Integer;
	qdQuantityTotal : Integer;
	pdQuantityTotal : Integer;
	idx, idxSt, idxEnd : Integer;
	cargoSort, lastCargoSort : String;
	sohCargoS : StringArray;
	sohVolumeS : DecimalArray;
	sohWeightS : DecimalArray;
	sohItemS : IntegerArray;
	sohQuantityS : IntegerArray;
	totVolume : Decimal[16,4];
	totWeight : Decimal[14,4];
	failedDAC :CM_DataAccessController;
	sortTIs : CM_TIByCargoTypeDict;
	allTIs : CM_TIArray;
	ti : CM_TrackedItem;

begin
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Location), DC_Label, 1, null);
	block.addNewItem(self.getFullId(), DC_Data, 1, null);

	create allBlocksArray transient;
	
	passport := app.myPassport;
	
	if (not self.canUserAccessSelf(null, failedDAC, passport)) then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_You_Do_Not_Have_Access), DC_Header, 1, null);
		return;
	endif;
		
	create sortTIs transient;
	create allTIs transient;
	create sohVolumeS transient; 
	sohVolumeS[10] := 0;
	create sohWeightS transient; 
	sohWeightS[10] := 0;
	create sohCargoS transient; 
	sohCargoS[10] := "";
	create sohItemS transient; 
	sohItemS[10] := 0;
	create sohQuantityS transient; 
	sohQuantityS[10] := 0;
	
	self.getTIs(allTIs, REAL_MODE, true);
	allTIs.copy(sortTIs);
	self.getTotalsByMode(REAL_MODE, totVolume, totWeight, quantityTotal);
	qdQuantityTotal := self.getNumTIs(QUEUE_MODE);
	pdQuantityTotal := self.getNumTIs(PLANNING_MODE);
	idx := 1;
	cargoSort := "";
	
	foreach ti in sortTIs discreteLock do
		//epr par 35905 26/3/15
		cargoSort := ti.getProductOrISODescr();
		if lastCargoSort &lt;&gt; "" and cargoSort &lt;&gt; lastCargoSort then
			idx := idx + 1;
		endif;
		//epr par 35905 26/3/15
		if sohCargoS.size &lt; idx then
			sohCargoS.add(null);
			sohVolumeS.add(null);
			sohWeightS.add(null);
			sohQuantityS.add(null);
			sohItemS.add(null);
		endif;
		
		if sohCargoS[idx] = "" then
			sohCargoS[idx] := cargoSort;
		endif;
		lastCargoSort := cargoSort;
		sohVolumeS[idx] := sohVolumeS[idx] + ti.totalVolume;
		sohWeightS[idx] := sohWeightS[idx] + ti.totalWeight;
		sohQuantityS[idx] := sohQuantityS[idx] + ti.totalQuantity;
		sohItemS[idx] := sohItemS[idx] + 1;
	endforeach;	
	
	if sohCargoS.size &gt; 0 then
		idxEnd := sohCargoS.size;
		idxSt := 1;
		foreach idx  in idxSt to idxEnd discreteLock do
			if sohCargoS[idx] = "" then
				break;
			endif;
			create block transient;
			allBlocksArray.add(block);
			block.addNewItem(sohCargoS[idx], DC_Data, 1, null);
			block.addNewItem(sohQuantityS[idx].String, DC_Data, 1, null); // ACTUAL
			block.addNewItem("-", DC_Data, 1, null); // PLANNED
			block.addNewItem("-", DC_Data, 1, null); // QUEUED
			block.addNewItem(app.getVolumeForDefaultDisplay(sohVolumeS[idx]), DC_Data, 1, null);
			block.addNewItem(app.getWeightForDefaultDisplay(sohWeightS[idx]), DC_Data, 1, null);		

		endforeach;
	endif;
		
	block := _dataContainer.addNewBlock;
	block.addNewItem("", DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(Actual), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(Queued), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(Planned), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Volume), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Weight), DC_LabelHeader, 1, null);
	
	block := _dataContainer.addNewBlock();
	block.addNewItem(app.getErrorString(Total).toUpper &amp; "   ", DC_Data, 1, null);
	block.addNewItem(quantityTotal.cnEcNumberFormat(), DC_Data, 1, null);
	block.addNewItem(qdQuantityTotal.cnEcNumberFormat(), DC_Data, 1, null);
	block.addNewItem(pdQuantityTotal.cnEcNumberFormat(), DC_Data, 1, null);
	block.addNewItem(app.getVolumeForDefaultDisplay(totVolume), DC_Data, 1, null);
	block.addNewItem(app.getWeightForDefaultDisplay(totWeight), DC_Data, 1, null);
	
	if app.isSpecial() then
		block := _dataContainer.addNewBlock();
		block.addNewItem("GC Controller", DC_MoreInfo, 2, self);
		block.addNewItem(self.String, DC_Data, 2, self);
		block.addNewItem("Voyage", DC_MoreInfo, 2, self.myVoyage);
		block.addNewItem(self.myVoyage.String, DC_Data, 2, self.myVoyage);
	endif;
	
	// Add the spec details after the summary details.
	_dataContainer.addMultipleBlocks(allBlocksArray);

epilog
	delete allBlocksArray;
	delete sortTIs;
	delete sohVolumeS;
	delete sohWeightS;
	delete sohCargoS;
	delete sohItemS;
	delete sohQuantityS;
	delete allTIs;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoForMode" id="639bb30e-b8a5-4f55-b0fb-e8ac3a295d97">
        <source>getExtraInfoForMode(_dataContainer: CM_DataContainer; _mode : Integer);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	block : CM_DataContainerBlock;
	isFirst : Boolean;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	move : CM_FutureMove;

begin
	block := _dataContainer.addNewBlock;
	block.addNewItem("Location", DC_Label, 1, self);
	block.addNewItem(self.getFullId(), DC_Data, 1, self);

	create tiArray transient;
	
	if _mode = ShpDisplayMode_Actual then
		self.allTrackedItems.copy(tiArray);
	elseif _mode = ShpDisplayMode_Proposed then
		foreach move in self.allPlannedFutureMoves where move.myWorkListEntry &lt;&gt; null and move.myWorkListEntry.myTrackedItem &lt;&gt; null do
			tiArray.add(move.myWorkListEntry.myTrackedItem);
		endforeach;
	elseif _mode = ShpDisplayMode_Queued then
		foreach move in self.allQueuedFutureMoves where move.myWorkListEntry &lt;&gt; null and move.myWorkListEntry.myTrackedItem &lt;&gt; null do
			tiArray.add(move.myWorkListEntry.myTrackedItem);
		endforeach;
	endif;
	
	if not tiArray.isEmpty then
		isFirst := true;
		foreach ti in tiArray do
			if isFirst then
				if ti.isContainer() then
					block.addNewItem("Containers", DC_MoreInfo, 1, null);
				else
					block.addNewItem("Cargo", DC_MoreInfo, 1, null);
				endif;
				isFirst := false;
			endif;
			block := _dataContainer.addNewBlock;
			block.addNewItem("ID", DC_Label, 1,  ti);
			block.addNewItem(ti.id, DC_Data, 1,  ti);
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
