    <JadeMethod name="getChildNiceName" id="a1fb1384-fad8-4c85-81c1-5edd419d464d">
        <source>getChildNiceName(_object : CM_Object): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if _object = null then
		return null ;
	endif;
	return _object.CM_DeckItem.code;

epilog

end;</source>
