    <JadeMethod name="enableSeals" id="745cb67b-1b02-44b4-b65e-0e7cfb23bfb3">
        <source>enableSeals(_clear, _fwd : Boolean; _enable : Boolean);

vars
	enableSealTxtBoxes : Boolean;
begin
	enableSealTxtBoxes:=_enable;

	if _enable then
		enableSealTxtBoxes:=app.myHandHeldShipLanderGuiAgent.checkSealsForDischarge;
	endif;
	
	if _fwd then
		if _clear then
			self.lblCaptionFoward.caption := "FORWARD";
		elseif _enable then
			self.lblCaptionFoward.caption := "FORWARD IMPORT";
			enableSealTxtBoxes:=app.myHandHeldShipLanderGuiAgent.checkSealsForDischarge;
		else
			self.lblCaptionFoward.caption := "FORWARD EXPORT";
		endif;
		self.txtSealCustFowar.visible := enableSealTxtBoxes;
		self.txtSealOpFoward.visible := enableSealTxtBoxes;
		self.txtSealShipFowar.visible := enableSealTxtBoxes;
		self.lblSealCustFowar.visible := enableSealTxtBoxes;
		self.lblSealOpFoward.visible := enableSealTxtBoxes;
		
		if not enableSealTxtBoxes then
			self.clearFowardContainerSealCust;
			self.clearFowardContainerSealOp;
			self.clearFowardContainerSealShip;
		endif;
		
		if _enable then
			self.grpFwdSeals.visible:=not enableSealTxtBoxes;
		else
			self.grpFwdSeals.visible:=false;
		endif;
		self.btnDamageFoward.visible := _enable;
	else
		if _clear then
			self.lblCaptionAft.caption := "AFT";
		elseif _enable then
			self.lblCaptionAft.caption := "AFT IMPORT";
		else
			self.lblCaptionAft.caption := "AFT EXPORT";
		endif;
		self.txtSealCustAft.visible := enableSealTxtBoxes;
		self.txtSealOpAft.visible := enableSealTxtBoxes;
		self.txtSealShipAft.visible := enableSealTxtBoxes;
		self.lblSealCustAft.visible := enableSealTxtBoxes;
		self.lblSealOpAft.visible := enableSealTxtBoxes;
		
		
		if not enableSealTxtBoxes then
			self.clearAftContainerSealCust;
			self.clearAftContainerSealOp;
			self.clearAftContainerSealShip;
		endif;
		
		if _enable then
			self.grpAftSeals.visible:=not enableSealTxtBoxes;
		else
			self.grpAftSeals.visible:=false;
		endif;
//		self.chkHazAft.visible := _enable;
		self.btnDamageAft.visible := _enable;
	endif;
	
end;
</source>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_fwd" type="Boolean"/>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
