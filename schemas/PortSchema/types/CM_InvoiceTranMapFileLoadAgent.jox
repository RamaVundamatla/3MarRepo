    <JadeMethod name="getBOLDetails" id="8045411c-5e38-45d9-9965-6db6c80a3877">
        <updating/>
        <source>getBOLDetails(	_bolTransName : String;
				_default : Boolean output;
				_trantype : CM_TransactionType output
				) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	tranType : CM_TransactionType;
begin
	if _bolTransName = CM_FinancialObject.Extract_Default then
		_default := true;
	else
		tranType := findBOLType(_bolTransName);
		if tranType = null then
			self.validationError("Invalid Bol Transaction name", _bolTransName);
		endif;
	endif;

	_trantype := tranType;
end;
</source>
        <access>protected</access>
        <Parameter name="_bolTransName" type="String"/>
        <Parameter name="_default" type="Boolean" usage="output"/>
        <Parameter name="_trantype" type="CM_TransactionType" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeDetails" id="25ea3a5b-ea53-418c-ae96-621d1c1bf73a">
        <updating/>
        <source>getCargoTypeDetails(_cargoType : String; _default : Boolean output; _cargoTypeObj : CM_CargoType output) updating, protected;

vars
	pos		: Integer;
	foundDelim	: String;
	id		: String;
	cargoTypeObj : CM_CargoType;
begin
	cargoTypeObj := null;
	if _cargoType = CM_FinancialObject.Extract_Default then
		_default := true;
	else
		pos := 1;
		id := _cargoType.getDelimitedToken(pos, '|', foundDelim);		// 33095 just the code portion, with '|' delimiter
		if foundDelim &lt;&gt; '|' then
			pos := 1;
			id := _cargoType.getDelimitedToken(pos, ' ', foundDelim);		// existing extract files, look for space
		endif;
		cargoTypeObj := myRoot.getCargoTypeFromAbbrev(id);
		if cargoTypeObj = null then
			self.validationError("Invalid cargo type in row ", id);
		
		endif;
	endif;
	
	_cargoTypeObj := cargoTypeObj;

end;
</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="String"/>
        <Parameter name="_default" type="Boolean" usage="output"/>
        <Parameter name="_cargoTypeObj" type="CM_CargoType" usage="output"/>
    </JadeMethod>
