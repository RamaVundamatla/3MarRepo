    <JadeMethod name="createAuditedClassProperty" id="6f0a07c0-abe6-49b9-a8a5-226b98a2f285">
        <source>createAuditedClassProperty(_class : Class; _propName, _niceName : String; _isAudited : Boolean; _clsCol :ClassColl); //protected;	// 10/02/2010 cnwar2 CCMS 1849/#22324
// ---------------------------------------------------------------------------
// Created:     01 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	create the audit property for this _class and all subclasses (_clsCol)
// ---------------------------------------------------------------------------
vars
	audClassProp	: CM_AuditedClassProperty;
	cls				: Class;
begin
	
	create audClassProp persistent;
	audClassProp.setForCreate(_class, _propName, _niceName, _isAudited, self);



	foreach cls in _clsCol do

		create audClassProp persistent;
		audClassProp.setForCreate(cls, _propName, _niceName, _isAudited, self);
//global.writeForUser('CNWJC2', false,class.name &amp; " " &amp; method.name &amp; " " &amp; cls.name &amp; " " &amp; _propName);

	endforeach;

end;</source>
