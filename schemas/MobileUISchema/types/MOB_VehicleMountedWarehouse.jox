    <JadeMethod name="doReject" id="e7d989cd-43bc-423f-a418-b457f9ab4727">
        <updating/>
        <source>doReject() updating;
/*

Date		Who		Reason
12 August 2014	cnwer1	Initial creation PAR

*/

vars

	rtQueueEntry : CM_RTQueueEntry;
	task 			: CM_RTQueueTask;
	tasks 			: CM_RTQueueTaskArray;
begin
	rtQueueEntry:=self.getSelectedWorkingRTEntry();
	if rtQueueEntry = null then
		return;
	endif;
	task:=rtQueueEntry.getDirectorOrPickupTask();
	if task = null then
		return;
	endif;
	if task.isSetDown or task.status = TASK_COMPLETE then
		return;
	endif;
	
	create tasks transient;
	tasks.add(task);
	
	app.myVMAgent.doCancelTasks(tasks,false,false,null);
	
	if app.myVMAgent.myMachine.allCurrentQueueTasks.size = 0 then
		self.showSelectTasks();
	endif;
epilog
	delete tasks;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="b07fe6ab-1150-48ae-8a2a-48d7a8b46793">
        <source>doResetSearch();
/*

Date		Who		Reason
06 August 2014	cnwer1	Initial creation PAR

*/

vars

begin
	self.clearTableData(self.tblSelectTasks);
	//app.myVMAgent.initTable(self.tblSelectTasks);
	app.myVMAgent.loadRTTaskTable(self.tblSelectTasks,null);
	self.clearTableData(self.tblWorkingTasks);
	app.myVMAgent.loadRTTaskTable(self.tblWorkingTasks,null);
	self.txtSearch.text:=null;
	self.txtSearch.lostFocus(self.txtSearch);	
	self.txtSearch.setFocus;          //+cnwmwa1 PAR#33722
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="393bd436-3eb1-416a-bc97-97ad1c9d0d71">
        <source>doResize();
/*

Date		Who		Reason
07 August 2014	cnwer1	Initial creation PAR

*/

vars

begin
	self.tblSelectTasks.width:=self.dkcTasks.clientWidth;
	self.tblWorkingTasks.width:=self.dkcTasks.clientWidth;
	self.tblSelectTasks.height:=self.dkcTasks.clientHeight;
	self.tblWorkingTasks.height:=self.dkcTasks.clientHeight;
	self.grpAccept.height := self.frmBottom.clientHeight;
	self.grpWorking.height:=self.frmBottom.clientHeight;
	self.doResizeTaskDetails();
epilog

end;</source>
