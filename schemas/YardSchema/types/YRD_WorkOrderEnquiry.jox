/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes

*/

vars

	frm : YRD_WorkOrderRejectForm;
	remark : CM_PredefinedRemark;
	
begin

	frm := app.loadForm(YRD_WorkOrderRejectForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrderRejectForm;
	
	if frm = null then
		return;
	endif;

	frm.myParentForm := self;	
	frm.showModal();
	
	if frm.modalResult = IDOK then
		self.doSetNotApproved(frm.selectedRemark);
	endif;
	
epilog

	delete frm;
	
end;</source>
