    <JadeMethod name="btnGo_click" id="43c018a3-23b5-4fce-b092-12dea05f2e7a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnGo_click(btn: Button input) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
28 October 2004	cnwkpd1	Initial creation

*/

vars
	
begin
	setupMaximumConnections;
	
	beginTransaction;

	myControl.numMessages 				:= txtNumMsgs.text.Integer;
	myControl.state 					:= TestAppControl.STATE_GO;
	myControl.silentMode 				:= chkSilent.value;
	myControl.logWebServiceStatistics 	:= chkLogStats.value;
	myControl.logonForEachIteration		:= chkLogonEach.value;
	myControl.endpointURL 				:= txtWebURL.text.trimBlanks;
	
	commitTransaction;
	

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnStartApps_click" id="72e691d7-8370-4e4b-b8f2-56e1d6ac7675">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStartApps_click(btn: Button input) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
28 October 2004	cnwkpd1	Initial creation

*/

vars
	i				: Integer;
		
begin
	foreach i in 1 to txtNumApps.text.Integer do
		app.startApplication(currentSchema.name, "TestApplication");
	endforeach;
	

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnStop_click" id="7343d23f-a74a-46b0-8672-b81fb937e059">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStop_click(btn: Button input) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
03 November 2004	cnwkpd1	PAR #4801 - Web Service application

*/

vars

begin
	beginTransaction;
	myControl.state := TestAppControl.STATE_STOP;
	commitTransaction;
	

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnTerminate_click" id="4aa5e35d-9b06-4d7b-b6f6-69ec0457e70a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
