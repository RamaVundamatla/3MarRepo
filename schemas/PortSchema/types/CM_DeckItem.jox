    <JadeMethod name="canIBeErased" id="020bf4ad-3605-4b78-8f02-8eced62d5557">
        <source>canIBeErased() : Boolean;
/*
Purpose:			PAR 31442
Date		Who		Reason
31 May 2013	cnwab1	Initial creation
*/

vars

begin
	if self.hasColourCoding(DISCHARGE_MOVETYPE) &lt;&gt; null
	or self.hasColourCoding(LOAD_MOVETYPE) &lt;&gt; null then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkCanProcessDeckItem" id="ca82d4e9-6180-48a1-bafb-3c9946a089df">
        <source>checkCanProcessDeckItem(_mode : Integer) : Boolean;

/*

Purpose:			

Date			Who		Reason
08 August 2012	cnwmh5	Initial creation #30077
07 Nov 2012	cnwrs1	Par 30688 OOTL layouts are missing for proposed
03 Dec 2012	cnwrs1	Par 30738 OOTL layous still missing
*/
//29 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
//11 Feb 2012	cnwrs1	Par 31119 undo mistak in 30951 fix
vars

	ti							: CM_Container;
	obj							: Object;

	tiArray						: CM_TIArray;

	canProcess					: Boolean;
	fwdSlot						: Boolean;

begin

	// check to see whether we are fwd slot
	fwdSlot := (self.CM_ROROLocnDefnVoyage.getAftLocnDefn() &lt;&gt; null or self.CM_ROROLocnDefnVoyage.myAdjacentSlotFwd = null).Boolean;

	create tiArray transient;
	if _mode = REAL_MODE then
		self.getAllTIs(_mode, tiArray, true);
		if fwdSlot then
			if not tiArray.isEmpty() then
				canProcess := true;
			endif;
		else
			foreach obj in tiArray do
				ti := obj.CM_Container;
				if ti.is20 then
					canProcess := true;
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	if _mode = PLANNING_MODE then
		self.getAllTIs(PLANNING_MODE, tiArray, true);
		if fwdSlot then
			if not tiArray.isEmpty() then
				canProcess := true;
			endif;
		else
			foreach obj in tiArray do
				ti := obj.CM_Container;
				if ti.is20 then
					canProcess := true;
					break;
				endif;
			endforeach;
		endif;
		self.getAllTIsRoB(tiArray, true, true);	//29 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
		foreach obj in tiArray do
			ti := obj.CM_Container;
			if fwdSlot or	//cnwrs1	11 Feb 2012	Par 31119 undo mistak in 30951 fix
			   ti.is20 then
				canProcess := true;
				break;
			endif;
		endforeach;
	endif;

	return canProcess;

epilog
	delete tiArray;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
