    <JadeMethod name="actionCargoUpdateCustomsAgent" id="a0c2955d-994f-4003-a913-6b42f493b785">
        <updating/>
        <source>actionCargoUpdateCustomsAgent(_passport : CM_Passport input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 June 2015	cnwndl1	Initial creation	Par 36543

*/

vars
	
begin
	//cnwmc5 - 11 Jan 2016 - PAR 37275
	if self.clearCustomsAgent then
		self.myTrackedItem.setCustomsAgentBreakBulkMulti(null);
		
		return;
	endif;
	
	if _passport.noErrors and self.myCustomsAgent &lt;&gt; null then		//cnwmc5 - 11 Jan 2016 - PAR 37275
		self.myTrackedItem.setCustomsAgentBreakBulkMulti(self.myCustomsAgent);	//cnwmc5 - 11 Jan 2016 - PAR 37275
	endif;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionCargoUpdateGrade" id="89d4d524-d1d5-4ddc-928c-17a547e40b6b">
        <updating/>
        <source>actionCargoUpdateGrade(_passport		: CM_Passport input ) updating, protected;
/*

Date		Who		Reason
05 May 2014	cnwer1	Initial creation CCMS 2289

*/

vars
	tiUpdateCntrl 	: CMIF_TIUpdateController;
begin
	
	tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	
	self.myTrackedItem.setAvailabilityGrade(self.myGrade.code,tiUpdateCntrl,_passport);
	
	self.updateStatusAndStatusInfo(EventRequestActioned, null);
epilog
	delete tiUpdateCntrl;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionCargoUpdateRemarks" id="f48c75da-41c3-4de7-a4bf-7f2036dae068">
        <updating/>
        <source>actionCargoUpdateRemarks(_passport : CM_Passport input) updating, protected;
/*

Date		Who		Reason
05 May 2014	cnwer1	Initial creation CCMS 2289

*/

vars
	tiUpdateCntrlr : CMIF_TIUpdateController;
begin
	
	//epr par 34113 21/5/14
	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	
	self.myTrackedItem.setRemarksTrans(self.cargoRemarks, true,tiUpdateCntrlr, _passport);
	
	self.updateStatusAndStatusInfo(EventRequestActioned, null);
	
epilog
	delete tiUpdateCntrlr;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionCargoUpdateRequest" id="79ffa358-ad7b-4c3c-9fe0-97b22fb90cbd">
        <updating/>
        <source>actionCargoUpdateRequest(	_trackedItem	: CM_TrackedItem input;
							_ignorePermissionValidation : Boolean;
							_passport		: CM_Passport input ) updating;
//--------------------------------------------------
// Created:	17 May 2005 By: cnwgd1
//--------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 04/11/2011   cnwrs1      PAR 28390 - Add _preAuthorised flag as Event Stop Request updates are preauthorised other are not
// 16 Jan 2017	cnwma1		TFS #2885:QNS - Additional Data Mapping in Customs Message

vars
	tmpTerm			: CM_Terminal;
	sendEmail		: Boolean;
begin
	if (not self.setMyTrackedItem(_trackedItem, _passport)) then
		// either not set or user does not have access
		return;
	endif;
	
	tmpTerm := _trackedItem.myTerminal;
	
	if tmpTerm = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'null terminal');
		return;
	endif;
	
	
	if self.type = EventRequestTypeStops then
		self.actionCargoUpdateStops(_ignorePermissionValidation,sendEmail,_passport);
		//cnwmc5 - 11 Jan 2016 - PAR 37275
		self.actionCargoUpdateCustomsAgent(_passport);
		self.actionCargoUpdateTIBOL(_passport);
		// 16/01/2017 cnwma1 TFS #2885
		if self.ediNotificationType = CM_EventRequestStops.EDI_NOTIFICATION_AMEND_DUES or
		   self.ediNotificationType = CM_EventRequestStops.EDI_NOTIFICATION_SUBMIT_DUES then
			self.actionCargoUpdateTIDesc(_passport);   // 16/01/2017 cnwma1 TFS #2885
			if self.myCargoType.id =TI_CargoType_Container then
				self.actionCargoUpdateTIOperSeal(_passport);// 16/01/2017 cnwma1 TFS #2885
			endif;
		endif;
	else 
		//epr TFS 17/4/18 webportal development of cargo update requests
		sendEmail:=self.isNotify;
	endif;
	
	if self.type = EventRequestTypeToDo then
		self.actionCargoUpdateToDoTask(_ignorePermissionValidation,_passport);
	endif;
	
	
	if self.type = EventRequestTypeRemarks then
		self.actionCargoUpdateRemarks(_passport);
	endif;
	
	if self.type = EventRequestTypeGrade then
		
		self.actionCargoUpdateGrade(_passport);
	endif;
	
	//epr par 37551 TFS 1429
	if self.type = EventRequestTypeWeight then
		self.actionCargoUpdateWeight(_passport);
	endif;
	
	if sendEmail then	// 24/09/2012 cnwar2 #30345
		self.sendEmail(_passport);
	endif;
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;
</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_ignorePermissionValidation" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionCargoUpdateStops" id="27ae752b-28c6-4d4c-9d72-186b45bb13fe">
        <updating/>
        <source>actionCargoUpdateStops(	_ignorePermissionValidation : Boolean;
						_sendEmail 				    : Boolean output;
						_passport 				    : CM_Passport input)  protected, updating;
/*

Date		Who		Reason
05 May 2014	cnwer1	Initial creation PAR
14 Mar 2016 cnwgb1  TFS 1618 Only change the number if there is already one there in the modify case
04 Dec 2019 cbwna1	Bug 47730: ADP - Customs Clearance Expiry date
20 Oct 2022	navsj20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
14 Feb 2023 navdp20 Bug 55792: SNO -- Entering the Additional Info field AND the Clearance Expiry Date field in the web portal when adding a stop the details are not persisting against the container
*/

vars
	allStops		: CM_StopsByIdDict;				// cnwrl1 18/11/2010 PAR 26235.
	existingStops	: CM_StopsByIdDict;				// cnwrl1 18/11/2010 PAR 26235.
	proxyStop		: CM_Stops;						// cnwrl1 18/11/2010 PAR 26235.
	realStop		: CM_Stops;						// cnwrl1 18/11/2010 PAR 26235.
	tmpStopTable	: CM_StopsTable;
	txnParams		: CMIF_TITransactionController ;
begin
	create txnParams transient;
	
	if self.isClear then
		txnParams.type := TRANS_TYPE_STOPCLEAR;
	else
		txnParams.type := TRANS_TYPE_STOPSET;
	endif;
	txnParams.dateTime      		       := app.serverTimestampAtTrxStart;
	txnParams.myTrackedItem 			   := self.myTrackedItem;
	txnParams.userId 		        	   := self.myUser.code;
	txnParams.eventRequestEnteredDT 	   := self.enteredDT;
	txnParams.isEventRequest 			   := true;
	txnParams.remarks 					   := self.remarks;
	txnParams.warningsHaveBeenAcknowledged :=_ignorePermissionValidation;
	
	tmpStopTable := self.myStopsTable;
	
	create allStops transient;							     // cnwrl1 18/11/2010 PAR 26235.
	create existingStops transient;						     // cnwrl1 18/11/2010 PAR 26235.
	self.myTrackedItem.getAllStops().copy( existingStops );	 // cnwrl1 18/11/2010 PAR 26235.
	
	_sendEmail := self.isNotify;	// 24/09/2012 cnwar2 #30345
	
	if self.isClear then
		// Remove stop
		if not _ignorePermissionValidation and not self.myUser.canUpdateStop(self.myTerminal, tmpStopTable) then
			self.actionFailedReason := app.getErrorString1(NoPermission, app.getErrorString1(Remove_The_Stop, tmpStopTable.heading));
		else
			
			if self.clearanceExpiryDate = null or not tmpStopTable.allowClearanceExpiryDate then
				if self.myTrackedItem.hasStopOfType(tmpStopTable) then
					self.myTrackedItem.deleteStop( true, tmpStopTable.id, false, self.additionalRequiredInfo, null, false, txnParams, _passport );
				else
					//01 Jul 2015	NDL	Par 36543 - Stop has already been cleared, just wanting to update the required info
					if self.isEDI and tmpStopTable.requiresInfo and self.additionalRequiredInfo &lt;&gt; null then
						if tmpStopTable.requiresInfoType = CEDO then
                            if self.myTrackedItem.customExportEntryNumber &lt;&gt; null then //cnwgb1 14/3/2016 TFS 1618 Only change the number if there is already one there in the modify case
                                self.myTrackedItem.setCEDO( self.additionalRequiredInfo[ 1 : self.myTrackedItem.customExportEntryNumber.maxLength ] );
                            endif;
						elseif tmpStopTable.requiresInfoType = CustomsEntryNumber then
                            if self.myTrackedItem.customsEntryNumber &lt;&gt; null then //cnwgb1 14/3/2016 TFS 1618 Only change the number if there is already one there in the modify case
                                self.myTrackedItem.setCustomsEntryNumber( self.additionalRequiredInfo[ 1 : self.myTrackedItem.customsEntryNumber.maxLength ] );
                            endif;
						elseif tmpStopTable.requiresInfoType = ExportReleaseNumber then
							if self.myTrackedItem.myOperator.getRequiresExportOperatorNo() then
                                if self.myTrackedItem.getOperatorExpReleaseNo() &lt;&gt; null then //cnwgb1 14/3/2016 TFS 1618 Only change the number if there is already one there in the modify case
                                    self.myTrackedItem.setOperatorExpReleaseNo( self.additionalRequiredInfo[ 1 : 20 ] );
                                endif;
							endif;
						elseif tmpStopTable.requiresInfoType = ImportReleasePIN then
							if self.myTrackedItem.myOperator.getRequiresImpOperatorPIN() then
                                if self.myTrackedItem.getOperatorImportReleasePIN() &lt;&gt; null then //cnwgb1 14/3/2016 TFS 1618 Only change the number if there is already one there in the modify case
                                    self.myTrackedItem.setOperatorImportReleasePIN( self.additionalRequiredInfo[ 1 : 6 ] );
                                endif;
							endif;
						elseif tmpStopTable.requiresInfoType = DeliveryRelease then
                            if self.myTrackedItem.deliveryRelease &lt;&gt; null then //cnwgb1 14/3/2016 TFS 1618 Only change the number if there is already one there in the modify case
                                self.myTrackedItem.setDeliveryRelease( self.additionalRequiredInfo[ 1 : self.myTrackedItem.deliveryRelease.maxLength ] );
                            endif;
						elseif tmpStopTable.requiresInfoType = CustomsReference then	
                            if self.myTrackedItem.customsReference &lt;&gt; null then //cnwgb1 14/3/2016 TFS 1618 Only change the number if there is already one there in the modify case
                                self.myTrackedItem.setCustomsReference( self.additionalRequiredInfo[ 1 : self.myTrackedItem.customsReference.maxLength ] );
                            endif;
						endif;
					endif;
					
					_sendEmail := false;	// 24/09/2012 cnwar2 #30345 - ti doesn't have stop to be cleared, don't send email
				endif;
			else
				// Update Stop
				// If the user is setting the clearance expiry date then it is really an update,Not A Delete for the stop!
				// get the real stop if it exists, if it does not exist nothing to actually clear.
				
				//05.12.2019 cnwma1 #47730
				realStop	:= self.myTrackedItem.getStop( tmpStopTable.id );
				if realStop &lt;&gt; null then
					//Start navdp20 Bug TFS 55792
					//self.myTrackedItem.updateStopsForCargoMulti(tmpStopTable,tmpStopTable.requiresInfoString,self.remarks,self.clearanceExpiryDate,allStops,existingStops,_passport); //04.12.2019 cnwma1 #47730
					self.myTrackedItem.updateStopsForCargoMulti(tmpStopTable,self.additionalRequiredInfo,self.remarks,self.clearanceExpiryDate,allStops,existingStops,_passport);
					//End navdp20 Bug TFS 55792
					/*
					04.12.2019 cnwma1 #47730
					proxyStop	:= realStop.pxyGetProxyObject();
					if proxyStop = null then
						// create a suitable proxy
						beginLoad;
						proxyStop	:=	realStop.pxyCreateUpdateProxy();
						endLoad;
					endif;
					
					proxyStop.setClearanceExpiryDate( self.clearanceExpiryDate );	// set the expiry date
					
					// record any information that must be captured to clear the stop
					if tmpStopTable.requiresInfo then
						self.myTrackedItem.setRequiresInformation( tmpStopTable.requiresInfoType, self.additionalRequiredInfo );
					endif;
					
					// add to stops collection to be processed
					allStops.addNoDuplicates( proxyStop, false );
					
					// Get a proxy copy of ALL of the existing real stops on this TI
					// - ie regardless of overrides and clearance expiry dates,
					// exclude any already added in this method.
					foreach realStop in existingStops do
						proxyStop	:= realStop.pxyGetProxyObject();
						if proxyStop = null then
							// create a suitable proxy
							beginLoad;
							proxyStop	:=	realStop.pxyCreateUpdateProxy();
							endLoad;
						endif;
						allStops.addNoDuplicates( proxyStop, false );
					endforeach;
					
					// now update this TrackedItem with all of these stops.
					self.myTrackedItem.updateProxyStops(allStops, self.remarks, true, _passport);	// pars 28390 and 28930
					*/
				else
					_sendEmail := false;	// 24/09/2012 cnwar2 #30345 - ti doesn't have stop to be cleared, don't send email
				endif;
			endif;
			
			self.updateStatusAndStatusInfo(EventRequestActioned, null);
		endif;
		
	else
		// Add stop
		if not txnParams.warningsHaveBeenAcknowledged	and	  not self.myUser.canUpdateStop(self.myTerminal, tmpStopTable) then
			self.actionFailedReason := app.getErrorString1(NoPermission, app.getErrorString1(Add_The_Stop, tmpStopTable.heading));
		
		//elseif not tmpStopTable.isValidForCargoType(self.myTrackedItem.cargoType) then	//20.10.2022	navsj20	TFS 53862
		elseif not tmpStopTable.isValidForStopCriteria(self.myTrackedItem) then		//20.10.2022	navsj20	TFS 53862
			//self.actionFailedReason := app.getErrorString2(StopCargoTypeMismatch, tmpStopTable.heading, self.myTrackedItem.cargoTypeDescr);		//20.10.2022	navsj20	TFS 53862
			self.actionFailedReason := app.getErrorString2(StopTrackedItemMismatch, tmpStopTable.heading, self.myTrackedItem.id);				//20.10.2022	navsj20	TFS 53862
		
		// NOTE: Even though isStopRelevant covers isValidForCargoType, I have left the original check here as well!
		elseif not tmpStopTable.isStopRelevant( self.myTrackedItem ) then
			self.actionFailedReason := app.getErrorString(CannotSetStop);

		else
			realStop	:= self.myTrackedItem.getStop( tmpStopTable.id );
			if realStop = null then
				create proxyStop transient;
				
				proxyStop.id	:= tmpStopTable.id;
				if not proxyStop.setMyTrackedItem( self.myTrackedItem ) then
					// should never happen because of previous checking!
					delete proxyStop;
					return;
				endif;
			else
				// if the stop already exists then need to make sure the clearance expiry date,
				// override reason and any required additional information are reset.
				proxyStop	:= realStop.pxyGetProxyObject();
				if proxyStop = null then
					// create a suitable proxy
					beginLoad;
					proxyStop	:=	realStop.pxyCreateUpdateProxy();
					endLoad;
				endif;
			endif;
			
			// now reset the required data.
			proxyStop.setClearanceExpiryDate( null );
			proxyStop.setMyStopOverrideTxn( null );
			
			// reset any information that must be captured to clear the stop
			if tmpStopTable.requiresInfo then
				self.myTrackedItem.setRequiresInformation( tmpStopTable.requiresInfoType, null );
			endif;
			
			// add to stops collection to be processed
			allStops.addNoDuplicates( proxyStop, false );
			
			// Get a proxy copy of ALL of the existing real stops on this TI
			// - ie regardless of overrides and clearance expiry dates,
			// exclude any already added in this method.
			foreach realStop in existingStops do 
				proxyStop	:= realStop.pxyGetProxyObject();
				if proxyStop = null then
					// create a suitable proxy
					beginLoad;
					proxyStop	:=	realStop.pxyCreateUpdateProxy();
					endLoad;
				endif;
				allStops.addNoDuplicates( proxyStop, false );
			endforeach;
			
			// now update this TrackedItem with all of these stops.
			self.myTrackedItem.updateProxyStops(allStops, self.remarks, true, _passport);	// pars 28390 and 28930
			
			self.updateStatusAndStatusInfo(EventRequestActioned, null);
		endif;
	endif;
epilog
	endLoad;							// 08/04/2011 cnwmh5 #27347
	if allStops &lt;&gt; null then			//par 28390 cnwrs1 4 Nov 2011
		allStops.purge();				//cnwrs1 10 jan 2011 removing memory leaks in unit tests
	endif;
	delete allStops;					// cnwrl1 18/11/2010 PAR 26235.
	delete existingStops;			   // cnwrl1 18/11/2010 PAR 26235.
	delete txnParams;
end;</source>
        <access>protected</access>
        <Parameter name="_ignorePermissionValidation" type="Boolean"/>
        <Parameter name="_sendEmail" type="Boolean" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionCargoUpdateTIBOL" id="35e5f02b-49be-4a7e-8def-2ec2c700825c">
        <updating/>
        <source>actionCargoUpdateTIBOL(_passport : CM_Passport input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Dec 2016	cnwmc5	Initial creation	PAR 37275

*/

vars
	
begin
	
	if _passport.noErrors and self.tiBillOfLading &lt;&gt; null then
		self.myTrackedItem.setBOLBreakBulkMulti(self.tiBillOfLading);
	endif;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionCargoUpdateTIDesc" id="2793456d-a557-4458-a778-1ce7d615e194">
        <updating/>
        <source>actionCargoUpdateTIDesc(_passport : CM_Passport input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Jan 2017	cnwma1	TFS #2885:QNS - Additional Data Mapping in Customs Message
*/

vars

begin
	if _passport.noErrors  then
		self.myTrackedItem.setDescription(self.tiDescription);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionCargoUpdateTIOperSeal" id="ef1ff147-102a-48bd-be69-8800c1dc1240">
        <updating/>
        <source>actionCargoUpdateTIOperSeal(_passport : CM_Passport input) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Jan 2017	cnwma1	TFS #2885:QNS - Additional Data Mapping in Customs Message

*/

vars

begin
	if _passport.noErrors  then
		self.myTrackedItem.setSealNumOperators(self.tiSealNumOperator);
	endif;
epilog

end;</source>
