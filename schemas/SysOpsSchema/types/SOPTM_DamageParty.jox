epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="3d3bf376-6976-48ce-b05e-07db13b9618a">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	theForm	: SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_DamageParty);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_DamageParty);
	theForm.shtTblInput1.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="5e84be3d-2117-4a63-b46f-241e3ce2b574">
        <updating/>
        <source>showThumbnail(_damageParty : CM_DamageParty) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2022	navds20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
*/

vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	
	theForm.tblInput1.setValueByName(ETRow_Code, _damageParty.code);
	theForm.tblInput1.setValueByName(ETRow_Description, _damageParty.description);
	theForm.tblInput1.setValueByName(ETRow_IsNotAvailableForEntry, _damageParty.isNotAvalableForEntry);
	

epilog

end;</source>
        <Parameter name="_damageParty" type="CM_DamageParty"/>
    </JadeMethod>
</Class>
