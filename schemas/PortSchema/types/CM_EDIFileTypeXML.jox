        <source>create() updating;
//----------------------------------------------------------------
//	Created:	06 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.name	:= "XML File";
	self.type	:= EDIFileType_XML;
end;</source>
