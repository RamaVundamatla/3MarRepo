        <updating/>
        <source>trxCreateWagonSealsCheckTrans(	_moveController : CMIF_WagonMoveController; 	
								_wagon : CM_Wagon;
								_newWagonTrx : CMEVT_WagonTransaction output;
								_pxyWagonCheckDetailArray : ObjectArray;
								_pxyUpdateSealsArray : CM_ObjectArray;
								_context : Integer;
								_passport : CM_Passport input
								) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 July 2015		cnwndl1	Initial creation
04 November 2022	jlizm1	TFS 54118 Assigning Releases to Wagons

*/

vars

	obj : Object;
	pxyWagonSeal : CM_WagonSeal;
	realWagonSeal : CM_WagonSeal;
	effectiveDate : TimeStamp;	//23 Feb 2021	NDL	TFS 50837

begin

	//23 Feb 2021	NDL	TFS 50837
	effectiveDate := null;
	if _moveController &lt;&gt; null and _moveController.effectiveTimeStamp.date.isValid then
		effectiveDate := _moveController.effectiveTimeStamp;
	endif;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	// Start the transaction
	beginTransaction;
	
	if _wagon &lt;&gt; null and not _pxyWagonCheckDetailArray.isEmpty then
		if _context = WAGON_CHECK_CONTEXT_PLACE_IN then
			_newWagonTrx := _wagon.createTransaction(effectiveDate, EVT_WagonSealCheck, _wagon.myTrainInwards, _wagon.getMyPositionTrainInwards, null, true, null, null, null);
		elseif _context = WAGON_CHECK_CONTEXT_PLACE_OUT or _context = WAGON_CHECK_LOAD_COMPLETE then
			_newWagonTrx := _wagon.createTransaction(effectiveDate, EVT_WagonSealCheck, _wagon.myTrainOutwards, _wagon.getMyPositionTrainOutwards, null, false, null, null, null);
		endif;
		
		if app.myPassport.hasErrorsOrWarnings then	//03 Aug 2015	NDL	Par 36658
			return;
		endif;
		
		_newWagonTrx.setWagonSealCheckDetails( _pxyWagonCheckDetailArray );
		
		if app.myPassport.hasErrorsOrWarnings then	//03 Aug 2015	NDL	Par 36658
			return;
		endif;
		
		if _pxyUpdateSealsArray &lt;&gt; null and not _pxyUpdateSealsArray.isEmpty then
			
			foreach obj in _pxyUpdateSealsArray do
				pxyWagonSeal := obj.CM_WagonSeal;
				realWagonSeal := _wagon.allWagonSeals.getAtKey( pxyWagonSeal.sealType );
				
				app.myUtilityUA.utlUpdateWagonSeal( _moveController, pxyWagonSeal, realWagonSeal, app.myPassport );
			
				if app.myPassport.hasErrorsOrWarnings then	//03 Aug 2015	NDL	Par 36658
					return;
				endif;
			endforeach;
		
		endif;
		
	else
		//nothing to do
		return;
	endif;

epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_newWagonTrx" type="CMEVT_WagonTransaction" usage="output"/>
        <Parameter name="_pxyWagonCheckDetailArray" type="ObjectArray"/>
        <Parameter name="_pxyUpdateSealsArray" type="CM_ObjectArray"/>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
