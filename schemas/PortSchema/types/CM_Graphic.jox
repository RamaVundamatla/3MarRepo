    <JadeMethod name="getExtremePoint" id="779f1f0d-bf99-4d14-b055-bf25cc82f938">
        <source>getExtremePoint(_poistion : Integer) : Point;
// ---------------------------------------------------------------------------
// Created:     10 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	minX, maxX,minY, maxY : Integer;
	aPoint, returnPoint : Point;
begin

	if _poistion = self.Position_Right then
		foreach aPoint in self.pointsPolygon discreteLock do
			if aPoint.x &gt; maxX then
				maxX := aPoint.x;
				returnPoint := aPoint;
			endif;
		endforeach;
	elseif _poistion = self.Position_Left then
		minX := 999999999;
		foreach aPoint in self.pointsPolygon discreteLock do
			if aPoint.x &lt; minX then
				minX := aPoint.x;
				returnPoint := aPoint;
			endif;
		endforeach;
	elseif _poistion = self.Position_Bottom then
		foreach aPoint in self.pointsPolygon discreteLock do
			if aPoint.y &gt; maxY then
				maxY := aPoint.y;
				returnPoint := aPoint;
			endif;
		endforeach;
	elseif _poistion = self.Position_Top then
		minY := 999999999;
		foreach aPoint in self.pointsPolygon discreteLock do
			if aPoint.y &lt; minY then
				minY := aPoint.y;
				returnPoint := aPoint;
			endif;
		endforeach;
	endif;
	
	return returnPoint;
epilog

end;</source>
        <Parameter name="_poistion" type="Integer"/>
        <ReturnType type="Point"/>
    </JadeMethod>
    <JadeMethod name="getExtremePoints" id="f3527b90-6140-4c60-9650-d4ba532e064c">
        <source>getExtremePoints(_x1, _y1, _x2, _y2 : Integer io);
/*

Purpose:			Get the extreme edges of the polygone
					x1 is left must be initialised by calling method to 99999999
					y1 is top must be initialised to 99999999
					x2 is right 
					y2 is bottom

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	aPoint  ,firstPoint: Point;
begin
	firstPoint:=self.pointsPolygon.first;
	if firstPoint = null then
		return;
	endif;

	// passed in X1 and Y1 must be initialised to 99999999
	foreach aPoint in self.pointsPolygon discreteLock do
//		if _x1  = 0 then
//			_x1:=aPoint.x;
//		else
			_x1:=aPoint.x.min(_x1);
//		endif;
		_x2:=aPoint.x.max(_x2);
		
//		if _y1 = 0 then
//			_y1:=aPoint.y;
//		else
			_y1:=aPoint.y.min(_y1);
//		endif;
		_y2:=aPoint.y.max(_y2);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_x1" type="Integer" usage="io"/>
        <Parameter name="_y1" type="Integer" usage="io"/>
        <Parameter name="_x2" type="Integer" usage="io"/>
        <Parameter name="_y2" type="Integer" usage="io"/>
    </JadeMethod>
