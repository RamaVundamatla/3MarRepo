<Class name="CM_AuditLineMoved" id="6be20d87-d588-432f-9ce9-74ae436cddd9">
    <superclass name="CM_Audit"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <PrimAttribute name="fromInvoiceSeqNum" id="62cc372c-6e56-41ce-97d6-ed9667da686f">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="movedBy" id="ae561857-86d1-4990-a1eb-9a01fb637ac0">
        <length>11</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="movedDT" id="eb47e62a-ac33-4c80-bbe5-33d0100896a7">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <JadeMethod name="getDateTime" id="0ff4877e-1007-4b9e-ab75-0c4d178df937">
        <source>getDateTime() : TimeStamp;

begin
	return movedDT;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDateTimeLocalTZ" id="62c4e5c4-f850-4ed1-b471-d06fed91bb64">
        <source>getDateTimeLocalTZ() :TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2016	cnwns1	Initial creation
// 01 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.movedDT);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b17d78f9-22a4-475e-9f9f-a48794ff85ea">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _attrName = ETRow_SequenceNum  then
		return self.sequenceNum.String;	
	elseif _attrName = ETRow_Description  then
		return self.remarks;	
	elseif _attrName = ETRow_User  then
		return self.movedBy;	
	elseif _attrName = ETRow_EndDate  then
		return self.systemToLocalTime(self.movedDT).String;		// 5/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_Ti  then
		return null;	
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMovedDTLocalTZ" id="1e24d8f2-72bf-455d-9b1b-a039661cfd49">
        <source>getMovedDTLocalTZ():TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
19 May 2016	cnwns1	TFS 488 - Multi Timezone Support


*/

vars

begin
	return self.systemToLocalTime(self.movedDT);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getPropertyCol" id="22e3f8c5-b372-455e-9f61-edfc6c8fff93">
        <source>getPropertyCol(): String;

vars
	str : String;
begin
	str := sequenceNum.String &amp; Tab;
	str := str &amp; remarks &amp; Tab;
	str := str &amp; movedBy &amp; Tab;
	str := str &amp; movedDT.date.shortFormatJMT() &amp; " " &amp; movedDT.time.currentLocaleFormatJMT() &amp; Tab;
	str := str &amp; "";

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTypeDescription" id="40ebe22b-5547-4a7b-944d-796d134d8298">
        <source>getTypeDescription(): String;

begin
	return "Line Move";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUserId" id="24fcd3a8-f586-416e-8dcc-675ab733c7a6">
        <source>getUserId() : String;

begin
	return movedBy;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setRemarks" id="125aa143-04bf-4a6e-832c-4f809381662f">
        <updating/>
        <source>setRemarks() updating;

begin
	remarks := "Moved from Invoice No. " &amp; fromInvoiceSeqNum.String;
end;</source>
    </JadeMethod>
</Class>
