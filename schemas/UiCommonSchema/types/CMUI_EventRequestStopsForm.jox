    <JadeMethod name="initSearcher" id="827d63e8-0af0-4102-aa31-619835fd84c9">
        <source>initSearcher();
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	self.myAssistant.comboBoxCargoUpdateRequestType(self.cmbUpdateType);
	self.cmbUpdateType.addItemWithData(null,0);
	self.tblSearch.hideRowByName(ETRow_Event,false);
	
