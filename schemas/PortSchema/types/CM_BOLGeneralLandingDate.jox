<Class name="CM_BOLGeneralLandingDate" id="86337dff-14b4-4735-b9b8-a5314dfcaac9">
    <superclass name="CM_BOLTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>

TFS 4272</text>
    <DbClassMap file="transactbol"/>
    <PrimAttribute name="dateNew" id="93b37a3b-30c3-42eb-adce-7e270bf003db">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <PrimAttribute name="datePrevious" id="8dfd3cf6-7c75-4a5a-8e49-aa8cd12c23d4">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <JadeMethod name="getDisplayID" id="50b512f4-5499-4d97-ba51-e05411cb6b52">
        <source>getDisplayID(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	return inheritMethod() &amp; " General Landing Date " &amp; self.datePrevious.shortFormatJMT &amp; " =&gt; " &amp; self.dateNew.shortFormatJMT;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="13f64489-cdc3-4a3f-a9d4-5df7b9232e81">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			
Date		Who		Reason
19 June 2017	cnwab1	Initial creation
*/

vars

begin
	if _attrName = ETRow_Details then
		return  self.datePrevious.shortFormatJMT &amp; " =&gt; " &amp; self.dateNew.shortFormatJMT;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
