    <JadeMethod name="getDisplayStringForAttribute" id="d865170f-1c5d-4eec-bb0e-5d41b47299f7">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------
//	Created:	06 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//05 Apr 2012	cnwrs1		Par 29391 - EDI RORO Stowage Advice hazard codes
//23 Apr 2014	cnwdap1		PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
//29 Apr 2016	cnwdap1		TFS #1699 Verified Gross Mass changes
// 04 Mar 2019	jlgrs1		TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 28 July 2022 navvt20 	Bug 54199: EUP - Tables with Operator/Stevedore not adhering to the configuration
//21 Nov 2022	navma1		ChangeRequest 55424: MTN - Improve the performance of Edi file loading
//
vars
	str,
	strReturn	: String;
	strSize		: Integer;
	rowName, 
	type		: String;							// PAR #33005
	iConsign	: CM_ConsigneeConsignor;
	root		: CM_Root;
begin
	if _attrName = ETRow_Temperature then
		if self.temperature &lt;= NULL_TEMPERATURE then
			return null;
		endif;
	elseif _attrName = ETRow_IsTranshipItem then
		return null;
	elseif _attrName = ETRow_Consignee then	//ccms 1915 - PAR 22271
		//TFS#53362 navsp1 20Jun2022
		root := app.myRoot;												//21.11.2022 navma1 #55424
		if root.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then  	//21.11.2022 navma1 #55424
			iConsign := root.allConsigneeConsignors[self.consignee];	//21.11.2022 navma1 #55424
			if iConsign &lt;&gt; null then
				return iConsign.description;
			endif;
		endif;
		return self.consignee;
	elseif _attrName = ETRow_Ventilation or
	       _attrName = ETRow_Vent then 									//par18451 nov 2008 cnwrs1
		return self.vent.asNullDecimal(); 								//par18451 nov 2008 cnwrs1
	elseif _attrName = ETRow_Humidity then
		return self.getHumidity.asNullHumidity(); 						//par18451 nov 2008 cnwrs1
	elseif _attrName = ETRow_CarbonDioxide then
		return self.getCarbonDioxide.asNullCarbonDioxide;
	elseif _attrName = ETRow_Oxygen then
		return self.getOxygen.asNullOxygen;
	elseif _attrName = ETRow_CurtainsIn then
		return self.curtainsIn.String;
	elseif _attrName = ETRow_VoyageCode then
		if self.myEDIData &lt;&gt; null then
			return self.myEDIData.CM_EDIDataLoadList.voyageCode;
		endif;
	elseif _attrName = ETRow_OperatorCode then
		// START 28.07.2022 navvt20 TFS 54199
		root := app.myRoot;																		//21.11.2022 navma1 #55424
		if root.getConfig(ComboByNameOperator).Boolean and self.operatorCode &lt;&gt; null then		//21.11.2022 navma1 #55424
			return root.allOperators[self.operatorCode].description;							//21.11.2022 navma1 #55424								
		endif;																						
		return self.operatorCode;	
		// End 28.07.2022 navvt20 TFS 54199
	
	/*
	elseif _attrName = ETRow_ImCodes then
		foreach str in self.imCodes do
			if strReturn = null then
				strReturn := str;	
			else
				strReturn := strReturn &amp; " " &amp; str;
			endif;
		endforeach;
		return strReturn;
	*/
	elseif _attrName = ETRow_LocationId then
		strSize := self.locationId.length;
		if strSize &gt;= 6 then
			//hide the leading zero
			return self.locationId[strSize-5:6];
		endif;
	elseif _attrName = ETRow_State then
		return null;
	//elseif _attrName = ETRow_Weight then // cnwrd1 par 19589 4.5.09 				//-cnwml2 MSL CCMS 1017
	elseif _attrName = ETRow_TotalWeight then										//+cnwml2 MSL CCMS 1017
		return self.weight.asStringWeightJMT();	
	elseif _attrName = ETRow_Height then
		return self.height.asStringMeasurementJMT();		
	elseif _attrName = ETRow_Width then
		return self.width.asStringMeasurementJMT();		
	elseif _attrName = ETRow_Length then
		return self.length.asStringMeasurementJMT();				
	elseif _attrName = ETRow_MyTranshipToPort then
		return self.myTranshipToPort.asStringJMT();				
	elseif _attrName = ETRow_ImexStatus then	//19 May 2010	NDL Par 24243
		return null;
	elseif _attrName = ETRow_TranshipPortCodes then //cnwrs1 CCMS 1137 08 June 2010
		strReturn := null;
		foreach str in self.transhipPortCodes do
			if strReturn = null then
				strReturn := str;	
			else
				strReturn := strReturn &amp; " " &amp; str;
			endif;
		endforeach;
		return strReturn;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverHeight then
		if self.overHeight = NULL_INTEGER then
			return null;
		else
			return self.overHeight.String;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverLengthBack then
		if self.overLengthBack = NULL_INTEGER then
			return null;
		else
			return self.overLengthBack.String;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverLengthFront then
		if self.overLengthFront = NULL_INTEGER then
			return null;
		else
			return self.overLengthFront.String;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverWidthLeft then
		if self.overWidthLeft = NULL_INTEGER then
			return null;
		else
			return self.overWidthLeft.String;
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _attrName = ETRow_OverWidthRight then
		if self.overWidthRight = NULL_INTEGER then
			return null;
		else
			return self.overWidthRight.String;
		endif;
		
	elseif _attrName = ETRow_IsoTypeGroup then	//18 Aug 2015	NDL	Par 36779
		if self.isoGroup &lt;&gt; null then
			return self.isoGroup;
		else
			return null;
		endif;
			
	elseif _attrName = ETRow_IsCertifiedWeight then						// TFS #1699
		return self.isWeightCertified.getYes;							// TFS #1699
	elseif _attrName = ETRow_WeightCertifiedName then					// TFS #1699
		return self.weightCertifiedName;								// TFS #1699
	elseif _attrName = ETRow_WeightCertifiedReference then				// TFS #1699
		return self.weightCertifiedReference;							// TFS #1699
	elseif _attrName = ETRow_HasValidId then	//15 Jan 2020	NDL	TFS 48256
		return self.hasValidId.getYesNo;	
	elseif _attrName = ETRow_ImCodes or _attrName = ETRow_Hazards or _attrName = ETRow_Hazardous then	//21.11.2022 navma1 #55424
		return self.getHazardsAsString();
	
	elseif _attrName = ETRow_SealNumberVent then							//21.11.2022 navma1 #55424
		if self.myAttachedItems.isNotEmpty then
			return self.sealNumberVent;
		endif;
		return null;
	elseif _attrName = ETRow_SealShipper then								//21.11.2022 navma1 #55424
		if self.myAttachedItems.isNotEmpty then
			return self.sealShipper;
		endif;
		return null;
	elseif _attrName = ETRow_SealTerminalOperator then						//21.11.2022 navma1 #55424
		if self.myAttachedItems.isNotEmpty then
			return sealTerminalOperator;
		endif;
		return null;
	elseif _attrName = ETRow_SealCustoms then								//21.11.2022 navma1 #55424
		if self.myAttachedItems.isNotEmpty then
			return self.sealCustoms;
		endif;
		return null;
	elseif _attrName = ETRow_SealUnknown then								//21.11.2022 navma1 #55424
		if self.myAttachedItems.isNotEmpty then
			return self.sealUnknown;
		endif;
		return null;
	elseif _attrName = ETRow_SealNum then									//21.11.2022 navma1 #55424
		if self.myAttachedItems.isNotEmpty then
			return self.sealNum;
		endif;
		return null;
	elseif _attrName.isMeasurementType then										// PAR #33005
		_attrName.getRowNameMeasureType(rowName, type);							// PAR #33005
		return self.getMeasurementStringForAttrib(rowName, type, _short);		// PAR #33005
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="dad41544-d9ab-48fe-8bec-c1e203b8de2b">
        <source>getExtraInfo(_dataCont: CM_DataContainer);
//----------------------------------------------------------------
//	Created:	04 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

//DO NOT DELETE THIS METHOD - it's being used for the macro info table

vars
	block : CM_DataContainerBlock;

begin
	inheritMethod(_dataCont);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_TemperatureExtra), DC_Label, 1, null);
	block.addNewItem(self.getDisplayStringForAttribute('temperature', false), DC_Data, 1, null);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Ventilation), DC_Label, 1, null);
	block.addNewItem(self.getDisplayStringForAttribute('vent', false), DC_Data, 1, null);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Humidity), DC_Label, 1, null);
	block.addNewItem(self.getDisplayStringForAttribute('humidity', false), DC_Data, 1, null);
		
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Over_Dimension), DC_Label, 1, null);
	block.addNewItem(self.getDisplayStringForAttribute('outOfGauge', false), DC_Data, 1, null);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Hazardous), DC_Label, 1, null);
	block.addNewItem(self.getDisplayStringForAttribute('hazardous', false), DC_Data, 1, null);

	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(Operator_GC), DC_Label, 1, null);
	block.addNewItem(self.getDisplayStringForAttribute('operatorCode', false), DC_Data, 1, null);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_VoyageExtra), DC_Label, 1, null);
	block.addNewItem(self.getDisplayStringForAttribute('voyageCode', false), DC_Data, 1, null);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Commodity_GC), DC_Label, 1, null);
	block.addNewItem(self.getDisplayStringForAttribute('commodity', false), DC_Data, 1, null);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Load), DC_Label, 1, null);
	block.addNewItem(self.getDisplayStringForAttribute('loadPort', false), DC_Data, 1, null);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Discharge), DC_Label, 1, null);
	block.addNewItem(self.getDisplayStringForAttribute('dischargePort', false), DC_Data, 1, null);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Destination), DC_Label, 1, null);
	block.addNewItem(self.getDisplayStringForAttribute('destinationPort', false), DC_Data, 1, null);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_ISO_Type), DC_Label, 1, null);
	block.addNewItem(self.getDisplayStringForAttribute('isoType', false), DC_Data, 1, null);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Weight), DC_Label, 1, null);
	block.addNewItem(self.getDisplayStringForAttribute('weight', false), DC_Data, 1, null);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Booking_Reference), DC_Label, 1, null);
	block.addNewItem(self.getDisplayStringForAttribute('bookingRef', false), DC_Data, 1, null);

end;
</source>
