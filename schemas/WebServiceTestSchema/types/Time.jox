<PrimType name="Time">
    <JadeMethod name="displayWithMilliseconds" id="219144a5-391f-4a87-94a0-19d6334f42a8">
        <source>displayWithMilliseconds() : String;

/*

Purpose:			


Return Value:		


Date		Who		Reason
02 November 2004	cnwkpd1	PAR #4801 - Web Service application

*/

vars

begin
	return self.String &amp; "." &amp; self.milliSecond.String.padLeadingZeros(3);


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
