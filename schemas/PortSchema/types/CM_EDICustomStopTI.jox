    <JadeMethod name="doTranslations" id="442fc0a9-e8f0-451c-947f-43b0a9537d35">
        <updating/>
        <source>doTranslations(_xlationOperator: CM_Operator) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Aug 2018	jlgsl4	TFS 39133 - Trade Single Window
29 Mar 2019 jlgsl4	TFS 44123 - TSW - translate BOL voyage details correctly
20 May 2020	jlgdap1	TFS 49328 / TFS 49416 CPL Unable to load Custom Stops files for Motor Vehicles
19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
*/

vars
	operator : CM_Operator; // TFS 44123
	voyCode : String; // TFS 44123
	foundMatch : Boolean; // TFS 44123
	voyage : CM_Voyage;		// TFS 49328
begin
	inheritMethod(_xlationOperator);
	if isValidTSWMessage() and self.id = self.billOfLading then // TFS 39133 - Voyage is used for BOL-based TSW files - 04/12/18 BOL *only*
		operator := app.myRoot.allOperators[NZCS_Operator]; // TFS 44123
		if operator &lt;&gt; null then // TFS 44123
			// TFS 49328 If there was a translation set up for the voyage code from the raw file data, inheritMethod will
			// find the correct voyage and set the voyageCode to that voyage.
			// If we now look for a translation again, it will use the correct translated voyage code and NOT find a translation
			// So check to see if we can find a voyage first before translating again
			voyage := myEDIFile.ediConfig.myTerminal.allVoyagesByCode.getAtKeyGeq(self.voyageCode, null);
			if voyage &lt;&gt; null and voyage.code = self.voyageCode then
				voyCode := self.voyageCode;
				foundMatch := true;
			else
				voyCode := operator.getXlationSystemCode_Voyage(self.voyageCode, self.vesselName, null, null, foundMatch); // TFS 44123		//19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
			endif;
			// TFS 49328 end
			if foundMatch then // TFS 44123
				self.setVoyage(myEDIFile.ediConfig.myTerminal.allVoyagesByCode.getAtKeyGeq(voyCode, null));
			endif; // TFS 44123
		endif; // TFS 44123		
	endif;
epilog

end;</source>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
