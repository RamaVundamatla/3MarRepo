<Class name="CM_JRWBookingRef" id="e7b48d1f-799d-4194-9f5e-e5ecc8708756">
    <superclass name="CM_JRWTransient"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="allBookingRefs" id="410a39fc-fe8e-4a66-aaf0-bdb5e332033a">
        <memberTypeInverse/>
        <type name="CM_BookingRefsByRefDups"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myCommodity" id="11dacfc1-f406-45e9-bec8-5f1d0ef1fda6">
        <embedded/>
        <type name="CM_Commodity"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myVoyage" id="9b7575a8-e756-42fd-9209-e4794e62c49e">
        <embedded/>
        <type name="CM_Voyage"/>
    </ImplicitInverseRef>
    <PrimAttribute name="qryBookingRef" id="92b282bb-8f06-4a8e-8958-7c84c16c26fa">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="totalQuantityExpected" id="b56db57b-a4f9-41a9-abef-dd69a1dea054">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="totalWeightExpected" id="5ffe0a60-7967-4389-9940-29139280aa56">
        <precision>12</precision>
        <scaleFactor>3</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="voyageArrivalDateFrom" id="9f574fcd-4478-49d1-86a6-b13fb6010f69">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <PrimAttribute name="voyageArrivalDateTo" id="81ceea9e-9fba-4ae7-9111-779d89e866b8">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <JadeMethod name="getVoyageArivalDateFromLocalTZ" id="eb6d1778-48c0-4330-93f7-8d0cdf476a1f">
        <source>getVoyageArivalDateFromLocalTZ() : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2016	cnwns1	Initial creation
// 03 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	sysTS : TimeStamp;
begin
	sysTS.cnEcSetDateAndTime(self.voyageArrivalDateFrom,TimeStartOfDay);
	return self.systemToLocalTime(sysTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getVoyageArrivalDateToLocalTZ" id="bab28832-ef64-458c-88b5-233b8b51be2a">
        <source>getVoyageArrivalDateToLocalTZ() :Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2016	cnwns1	Initial creation
// 03 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	sysTS : TimeStamp;
begin
	sysTS.cnEcSetDateAndTime(self.voyageArrivalDateTo,TimeEndOfDay);
	return self.systemToLocalTime(sysTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="c3a9a161-9151-4f46-bcb0-522e2f872f8c">
        <source>noOutputReturned(): Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	23 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return self.allBookingRefs.isEmpty;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
