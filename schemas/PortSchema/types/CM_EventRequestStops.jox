    <JadeMethod name="actionCargoUpdateToDoTask" id="4251c76c-fa33-47d4-a9cd-1050caf6bf12">
        <updating/>
        <source>actionCargoUpdateToDoTask(	_ignorePermissionValidation : Boolean;							
							_passport : CM_Passport input) protected, updating;
/*

Date		Who		Reason
05 May 2014	cnwer1	Initial creation PAR
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes

*/

vars
	toDoTask : CM_ToDoTask;
	task : CM_ToDoTask;
	tiTask : CM_TiToDoTask;	
	trans : CM_TITransaction;
begin
	
	if (not _ignorePermissionValidation) and
		(	not self.myUser.canAddRemoveTodoTask(self.myTerminal,self.myToDoTaskDesc)) then
		if self.isClear then
			self.actionFailedReason := app.getErrorString1(ErrToDoTaskRemove,self.myToDoTaskDesc.description);
			
		else
			self.actionFailedReason := app.getErrorString1(ErrToDoTaskAdd,self.myToDoTaskDesc.description);
		endif;
		
		return;
	endif;
	
	if self.isClear then
		self.myTrackedItem.removeToDoTask(self.myToDoTaskDesc.description,_passport);
		
		self.updateStatusAndStatusInfo(EventRequestActioned, null);
		
	else
		
		if (not self.myToDoTaskDesc.isAvailableForCargoType(self.myTrackedItem.cargoType)) then
			self.actionFailedReason := app.getErrorString2(ERR_NotAvailableForCargoType,  self.myToDoTaskDesc.description, self.myTrackedItem.id);
			return;
		endif;
		
		if self.myToDoTaskDesc.isForGenSetAttachDetach() and self.myTrackedItem.isKindOf(CM_Container) and (not self.myTrackedItem.CM_Container.isReefer) then
			 self.actionFailedReason := app.getErrorString2(ERR_NotValidForReefer, app.getErrorString( Task ) &amp;' '&amp; self.myToDoTaskDesc.description, self.myTrackedItem.id);
			return ;
		endif;
		//Par 17775. ccms1045 - Yard ops, generator sets. When a generator attached, we cannot to do Attach Generator and vice versa
		if self.myTrackedItem.isKindOf(CM_Container) or self.myTrackedItem.isKindOf(CM_TILC) then
			if not self.myToDoTaskDesc.isValidForGenSet(self)then
				if self.myTrackedItem.hasGeneratorSetAttached then
					  self.actionFailedReason := app.getErrorString2(ERR_IsNotValid, app.getErrorString( Task ) &amp;' '&amp; self.myToDoTaskDesc.description, app.getErrorString(CM_GenSetAttached) &amp; " to " &amp;  self.myTrackedItem.id);
				else
					 self.actionFailedReason := app.getErrorString2(ERR_IsNotValid, app.getErrorString( Task ) &amp;' '&amp; self.myToDoTaskDesc.description, app.getErrorString(CM_NoGenSetAttached) &amp; " to " &amp;  self.myTrackedItem.id);
				endif;
				return;
			endif;
		
		endif;
		
		if  self.myToDoTaskDesc.trxTypeOnCompletion = TRANS_TYPE_CHILL_TEST and (not self.myTrackedItem.isIntegral)then
			 self.actionFailedReason := app.getErrorString3(ERR_INVALID_ISOTYPE, "Not an Integral Container",
							'the todo task', self.myToDoTaskDesc.description );
			return;
		endif;
		
		//epr par 35153 11/1/14
		if not self.myTrackedItem.hasToDoTaskToDoWithCode(self.myToDoTaskDesc.code) then
			create tiTask persistent;
			trans:=tiTask.setForCreate(STATUS_TODO,self.myToDoTaskDesc, self.toDoRemarks, _passport, self.myTrackedItem); // ADD
			if trans &lt;&gt; null then
				//epr par 35153 12/11/14 added some context for debugging
				trans.setExtraData(TrnsExtraDataContext, "Added from Cargo Update Request");
			endif;
			//self.myTrackedItem.causeEvent(Object_Update_Event, false, self.myTrackedItem);
			self.updateObjectEdition(self.myTrackedItem);
		else	//06 Oct 2015	NDL	Par 37011
			tiTask := self.myTrackedItem.getToDoTaskToDoWithCode(self.myToDoTaskDesc.code).CM_TiToDoTask;
			if tiTask &lt;&gt; null then
				tiTask.setRemarks( self.toDoRemarks );
			endif;
		endif;	
		
		self.updateStatusAndStatusInfo(EventRequestActioned, null);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ignorePermissionValidation" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionCargoUpdateWeight" id="06bfaeea-9f5d-48a6-8eb0-414ffde50b36">
        <updating/>
        <source>actionCargoUpdateWeight(_passport : CM_Passport input) protected, updating;
/*

Date		Who		Reason
03/02/2016	cnwer1	Initial creation PAR 37551 TFS 1429 EDI VGM
06/05/2016	cnwdap1	TFS #1699 Verified Gross Mass changes
29/06/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
*/

vars
	tiUpdateCntrl 	: CMIF_TIUpdateController;
	vgmDetails : CM_VGMDetails;							// TFS 4492
	authSig, commsType, docDetails, ediTrans, email, 	// TFS 4492
	mail, phone, fax, telephone : String;				// TFS 4492
	docsIssued, determination : TimeStamp;				// TFS 4492
	isCertified :Boolean;
begin
	
	
	
	tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	//epr TFS 38876 25/7/18 
	isCertified:=self.isWeightCertified;
	if not self.myTrackedItem.myCargoType.canWeightBeCertified then
		isCertified:=false;
	endif;
	self.myTrackedItem.setTotalWeightAndCertified(self.totalWeight, self.myTrackedItem.weightCargo, self.myTrackedItem.weightTare, isCertified,tiUpdateCntrl,_passport);
	//self.myTrackedItem.setWeightCertifiedReference(self.reference,tiUpdateCntrl,_passport);				// TFS #1699	// TFS 4492
	//if self.weightCertifiedName &lt;&gt; null then																// TFS #1699	// TFS 4492
	//	self.myTrackedItem.setWeightCertifiedName(self.weightCertifiedName, tiUpdateCntrl, _passport);		// TFS #1699	// TFS 4492
	//endif;																								// TFS #1699	// TFS 4492
	if isCertified then
		vgmDetails := self.myTrackedItem.getMyVGMDetails();																		// TFS 4492
		if vgmDetails &lt;&gt; null then																								// TFS 4492
			authSig := vgmDetails.vgmAuthSignature;																				// TFS 4492
			commsType := vgmDetails.vgmCommsType;																				// TFS 4492
			docDetails := vgmDetails.vgmDocumentDetails;																		// TFS 4492
			ediTrans := vgmDetails.vgmEDITransmission;																			// TFS 4492
			email := vgmDetails.vgmElectronicMail;																				// TFS 4492
			mail := vgmDetails.vgmMail;																							// TFS 4492
			phone := vgmDetails.vgmPhone;																						// TFS 4492
			fax := vgmDetails.vgmTelefax;																						// TFS 4492
			telephone := vgmDetails.vgmTelephone;																				// TFS 4492
			docsIssued := vgmDetails.vgmDocsIssuedDT;																			// TFS 4492
			determination := vgmDetails.vgmDeterminationDT;																		// TFS 4492
		endif;																													// TFS 4492
		self.myTrackedItem.setMyVGMDetails(		self.reference, self.weightCertifiedName, 										// TFS 4492
												authSig, commsType, docDetails, ediTrans, email, mail, 							// TFS 4492
												phone, fax, telephone, docsIssued, determination, tiUpdateCntrl	);				// TFS 4492
		
		//epr TFS 1946 24/5/16
		self.myTrackedItem.checkVGMDetails(_passport);
	endif;
	
	self.updateStatusAndStatusInfo(EventRequestActioned, null);
epilog
	delete tiUpdateCntrl;

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
