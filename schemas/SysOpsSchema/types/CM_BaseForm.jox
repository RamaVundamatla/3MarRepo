<GUIClass name="CM_BaseForm">
    <JadeMethod name="doConfigSearch" id="bbbe35d9-7513-47a2-a8e3-899f8781e510">
        <source>doConfigSearch(_searchText: String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 March 2011	cnwndl1	Initial creation

*/
// 28 May 2013		cnwrs1	ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send

vars

	entDef : EntTableDef;
	entRow : EntTableRow;
	tabName : String;
	category : ConstantCategory;
	constant : Constant;
	match : Boolean;
	constantName : String;
	index : Integer;
	outputText : String;
	int : Integer;
	isFirst : Boolean;

begin

	category := currentSchema.getCategory(ConfigConstants);

	isFirst := true;
		
	foreach index in 1 to 11 do 
		if index = 1 then
			//Settings sheet;
			tabName := "Settings";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TerminalSettings];
		elseif index = 2 then
			//Gate sheet;
			tabName := "Gate";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_GateConfig];
		elseif index = 3 then
			//Defaults sheet;
			tabName := "Defaults";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TerminalDefaultsConfig];
		elseif index = 4 then
			//Financial sheet;
			tabName := "Financial";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TerminalFinancial];
		elseif index = 5 then
			//cams sheet;
			tabName := "Cams";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_CamsConfig];
		elseif index = 6 then
			//edi  sheet
			tabName := "EDI";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_EDIConfig];
		elseif index = 7 then
			//logs
			tabName := "Log Specific";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TerminalLogSpecific];
		elseif index = 8 then
			//ship
			tabName := "Ship Sequencing";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_ShipSettings];
		elseif index = 9 then
			//rail
			tabName := "Rail";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RailConfig];
		elseif index = 10 then
			//reefer
			tabName := "refCon";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RefConConfig];
		elseif index = 11 then
			//reefer
			tabName := "Email Read Server";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_EmailReadServerConfig];
		elseif index = 12 then
			tabName := "VGM";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_VGMConfig];
		endif;
		
		if entDef &lt;&gt; null then
			int := 0;
			foreach entRow in entDef.allEntTableRows do
				int := int + 1;
				match := false;
				constantName := null;
				if entRow.name.toUpper.pos(_searchText,1) &gt; 0 then
					match := true;
				elseif entRow.getRawHeadingValue.toUpper.pos(_searchText,1) &gt; 0 then
					match := true;
				endif;
				if entRow.name.toUpper[1:11] = "ZTABLEBREAK" then
					continue;
				endif;
				if match then
					//First check constants where the value doesn't match its name have not been followed 
					// or hard coded attributes exist.
					if entRow.name = ETRow_RelReqOnRailLoadList then
						constantName := ShowRelReqOnRailLoadList;
					elseif entRow.name = ETRow_RelReqOnShipLoadList then
						constantName := ShowRelReqOnShipLoadList;
					elseif entRow.name = ETRow_DefCommodityMT then
						constantName := EmptyCommodity;
					elseif entRow.name = ETRow_ShpLinearMeterWidthRORO then
						constantName := RoRoLinearMeteringWidth;
					elseif entRow.name = ETRow_TerminalsForRelease then
						constantName := "No constant, hard coded!";		// CM_Terminal.allTerminalsForRelease
					elseif entRow.name = ETRow_TerminalsForVoyInland then
						constantName := "No constant, hard coded!";		// CM_Terminal.allTerminalsForVoyageInland
					elseif entRow.name = ETRow_FinancialsCalendar then
						constantName := "No constant, hard coded!";	// CM_Terminal.myCalendar
					else
						// all others
						foreach constant in category.getConstants do
							if constant.name.toUpper = entRow.name.toUpper then
								constantName := constant.name;
								break;
							endif;
						endforeach;
					endif;
					if isFirst then
						isFirst := false;
						write "Terminal Config form.";
					endif;
					if constantName = null then
						// fix any more that appear because of this....
						write "***** '" &amp; entRow.name &amp; "' not set up properly in SysOpsSchema::" &amp; method.name;
					endif;
					outputText := ("Constant = '" &amp; constantName &amp; "'").padBlanks(43) &amp; Tab;
					outputText := outputText &amp; ("Tab = '" &amp; tabName &amp; "'").padBlanks(22) &amp; Tab;
					outputText := outputText &amp; ("Row = " &amp; int.String).padBlanks(9) &amp; " - '"&amp; entRow.getRawHeadingValue &amp; "'";
					write outputText;
				endif;
			endforeach;
		endif;
	
	endforeach;
		
	isFirst := true;	
	foreach index in 1 to 4 do 
		if index = 1 then
			//Settings sheet;
			tabName := "Defaults";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RootDefaults];
		elseif index = 2 then
			//Security sheet;
			tabName := "Security";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_SecurityConfig];
		elseif index = 3 then
			//Auto Admin sheet;
			tabName := "Auto Admin";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_AutoConfig];
		elseif index = 4 then
			//Email sheet;
			tabName := "Email Server";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_EmailServerConfig];
		endif;
		
		if entDef &lt;&gt; null then
			int := 0;
			foreach entRow in entDef.allEntTableRows do
				int := int + 1;
				match := false;
				constantName := null;
				if entRow.name.toUpper.pos(_searchText,1) &gt; 0 then
					match := true;
				elseif entRow.getRawHeadingValue.toUpper.pos(_searchText,1) &gt; 0 then
					match := true;
				endif;
				if match then
					foreach constant in category.getConstants do
						if constant.name.toUpper = entRow.name.toUpper then
							constantName := constant.name;
							break;
						endif;
					endforeach;
					if isFirst then
						isFirst := false;
						write " ";
						write "System Config form.";
					endif;
					outputText := ("Constant = '" &amp; constantName &amp; "'").padBlanks(43) &amp; Tab;
					outputText := outputText &amp; ("Tab = '" &amp; tabName &amp; "'").padBlanks(22) &amp; Tab;
					outputText := outputText &amp; ("Row = " &amp; int.String).padBlanks(9) &amp; " - '"&amp; entRow.getRawHeadingValue &amp; "'";
					write outputText;
				endif;
			endforeach;
		endif;
	
	endforeach;
	
	
epilog

end;</source>
        <Parameter name="_searchText" type="String"/>
    </JadeMethod>
</GUIClass>
