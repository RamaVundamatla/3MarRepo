    <JadeMethod name="doDelete" id="4f358e8e-51f0-4812-9d54-e17be4483e25">
        <updating/>
        <source>doDelete() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 February 2010	conkc1	Initial creation
*/
vars
	result : Boolean;
	index  : Integer;
	msgStr : String;
begin
	result := checkForChanges(false);
	if result = false then
		return;
	endif;

	if cmbConfigName.listIndex &lt; 1 then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Information_Icon);
	   	return;
	endif;

	msgStr := app.getErrorString2(ConfirmDelete, '', 'the selected item');
	if app.msgBox(msgStr, 'Confirm Deletion', MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then
	
		self.vMode := Mode_Delete;
		index      := cmbConfigName.listIndex;
		result := self.doSave;
		if result = true then
			cmbConfigName.removeItem(index);
		endif;
		self.clearAll;

	endif;
epilog

end;</source>
    </JadeMethod>
