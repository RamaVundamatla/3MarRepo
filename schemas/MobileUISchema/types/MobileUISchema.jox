    <JadeMethod name="setApplicationColors" id="f88dea67-a73c-4ad1-bc0b-779b2fc4acac">
        <updating/>
        <source>setApplicationColors(_sysBackColorGeneral, _sysForeColorGeneral, _sysBackColorTable, _sysForeColorTable : Integer) updating;
/*
	Created on 02 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if _sysBackColorGeneral = 0
	and _sysForeColorGeneral = 0
	and _sysBackColorTable = 0
	and _sysForeColorTable = 0
	then
		self.initialiseScreenColours();
	else
		app.colorBackGeneral	:=	_sysBackColorGeneral;
		app.colorForeGeneral	:=	_sysForeColorGeneral;
		app.colorBackTables		:=	_sysBackColorTable;
		app.colorForeTables		:=	_sysForeColorTable;
	endif;
end;</source>
        <Parameter name="_sysBackColorGeneral" type="Integer"/>
        <Parameter name="_sysForeColorGeneral" type="Integer"/>
        <Parameter name="_sysBackColorTable" type="Integer"/>
        <Parameter name="_sysForeColorTable" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTerminal" id="f1e0787f-9d95-42fd-972e-4d6706c852e1">
        <updating/>
        <source>setTerminal() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwer1	Initial creation

*/

vars

begin
	

	if app.myLogonAgent = null or app.myLogonAgent.myTerminal = null then
		return;
	endif;
	
	if self.myHandHeldCheckerAgent &lt;&gt; null then
		self.myHandHeldCheckerAgent.myMobileGenericAgent.setMyTerminal(app.myLogonAgent.myTerminal );
	endif;
	
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showErrorWarningDialog" id="2a8522da-3ae7-47d3-99ee-7c175d71d9c6">
        <source>showErrorWarningDialog(_heading : String; _passport : CM_Passport; 
					_mode : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     30 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  Mode	= ErrWarnMode_Update
//						= ErrWarnMode_AddUpdate
//						= ErrWarnMode_Add + ErrWarnMode_CanAckWarnings
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form	: MOB_ErrorWarningForm;
	result	: Integer;
	hhForm  : MOB_HandHeldEWForm;
	
begin

	if self.name = HandHeldApp or
		 app.name =VehicleMountedApp or
		 app.name = VehicleMountedWithDevice1 or
		  app.name = HandHeldWithDevApp1 then
		create hhForm transient;
		hhForm.init(_heading, _passport, _mode);
		result := hhForm.showModal();
		return result;
	else
		create form transient;
		form.init(_heading, _passport, _mode);
		result := form.showModal();
		return result;
	endif;
epilog
delete form;
delete hhForm;
	
end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showTruckCargoSwap" id="53c1463d-93c0-4e16-ba4a-d7b6c7367088">
        <source>showTruckCargoSwap(_wle: CM_WorkListEntry; _job: CM_RoadJob): CM_WorkListEntry;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 November 2013	cnwrd1	Initial creation

*/

vars
	form	: Mob_HandHeldCargoSwap;
	aWLE	:  CM_WorkListEntry;
	result 	: Integer;
	oldMousePointer : Integer;
	
begin

	oldMousePointer := app.mousePointer;
	app.mousePointer := 0;	
	
	create form transient;
	form.init(_wle, _job);
	result := form.showModal();
	
	aWLE := form.getMySwapWle;
	
	if result = IDCANCEL then
		return null;
	else
		return aWLE;
	endif;

epilog
	delete form;
	app.mousePointer := oldMousePointer;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_job" type="CM_RoadJob"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
</Class>
