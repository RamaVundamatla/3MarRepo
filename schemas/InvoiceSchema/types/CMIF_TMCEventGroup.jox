    <JadeMethod name="hasEventResources" id="ffadbcf0-fff6-4255-b12b-15b9ca9b2f81">
        <source>hasEventResources() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map

*/

vars
	toDoTask		: CM_ToDoTaskDesc;
begin
	if self.myEventType &lt;&gt; null then
		foreach toDoTask in self.myEventType.allToDoTaskDesc discreteLock do
			if not toDoTask.allResourceTypes.isEmpty() then
				return true;
			endif;
		endforeach;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="463432af-5853-4980-a1ea-fe5312355181">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------
vars
	tmcDebtor 			: CMIF_TMCDebtorGroup;
	aDM 				: CM_DebtorMap;
	tmcResourceHeader 	: CMIF_TMCTaskResourceTypeHeader;	// 15/05/2023	navkc1	CR 57927 Task 54268
	tmcBroker 			: CMIF_TMCTaskResourceTypeGroup;	// 15/05/2023	navkc1	CR 57927 Task 54268
	serviceBroker		: CM_ToDoResourceServiceBroker;		// 15/05/2023	navkc1	CR 57927 Task 54268
begin
	self.myTMCController := self.myGroup.myTMCController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
	self.hidePictures := self.myTMCController.hidePictures;

	create tmcDebtor as CMIF_TMCDebtorGroupDefault;
	tmcDebtor.myDebtor := null;
	tmcDebtor.myDebtorMap := null;
	tmcDebtor.myServiceBroker := self.myEventBroker;
	tmcDebtor.itemName := tmcDebtor.getItemName();
	tmcDebtor.extractName := tmcDebtor.getItemCode();		// 23659
	tmcDebtor.myGroup := self;
	tmcDebtor.initialise(_groupCount);
	
	// 15/05/2023	navkc1	CR 57927 Task 54268
	if self.myEventBroker &lt;&gt; null then
		if self.myEventBroker.allToDoResourceServiceBrokers.isNotEmpty() then
			create tmcResourceHeader;
			tmcResourceHeader.myTransServiceBroker := self.myEventBroker;
			tmcResourceHeader.itemName := "Resource Mappings"; 
			tmcResourceHeader.extractName := tmcResourceHeader.itemName;
			tmcResourceHeader.myTMCController := self.myTMCController;
			tmcResourceHeader.myGroup := self;
			_groupCount := _groupCount + 1;
		endif;
		// 15/05/2023	navkc1	CR 57927 Task 54268
		foreach serviceBroker in self.myEventBroker.allToDoResourceServiceBrokers discreteLock do
			create tmcBroker;
			tmcBroker.myTransResourceServiceBroker := serviceBroker;
			tmcBroker.itemName := serviceBroker.getResourceName();
			tmcBroker.extractName := serviceBroker.getResourceCode();
			tmcBroker.myGroup := tmcResourceHeader;
			tmcBroker.initialise(_groupCount);
		endforeach;
	endif;
	
	foreach aDM in self.myEventBroker.allDebtorMapsByDebtor do
		create tmcDebtor;
		tmcDebtor.myDebtor := aDM.myDebtorNode;
		tmcDebtor.myDebtorMap := aDM;
		tmcDebtor.itemName := tmcDebtor.getItemName();
		tmcDebtor.extractName := tmcDebtor.getItemCode();		// 23659
		tmcDebtor.myGroup := self;
		tmcDebtor.initialise(_groupCount);
	endforeach;
	_groupCount := _groupCount + 1; //epr TFS 3051 2/12/16
end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="f1f7032b-bdc5-48e8-a489-9eea9a78e5bf">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars

begin
	inheritMethod();
	
	myTMCController.myCurrentMapTMEvent := self.myEventBroker.myTranMap;
	myTMCController.myCurrentMapServiceBroker := self.myEventBroker;

end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="3b1ffb2f-e2a9-4582-99f0-57438d084d1b">
        <source>setEnableObjects(form: INV_TransactionMap io);
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(form);

	form.menuTMEnew.visible := true;  // MAIN EVENT NEW MENU
	form.menuSItemNew.visible := false;  // MAIN CARGO NEW MENU	
	form.modePropertyNew := INV_TransactionMap.ModeProperty_Debtor;
	form.modePropertyUpdate := INV_TransactionMap.ModeProperty_TransType;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_Event;

	form.menuTMEnew.enabled := true;
	form.menuTMEdebtor.visible := true;
	form.menuSItemDelete.enabled := true;
	
	// 15/05/2023	navkc1	CR 57927 Task 54268
	if self.myEventBroker.isEventServiceBroker() then
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Event;
		if self.hasEventResources() then
			form.menuTMETransType.visible := true;
			form.menuTMEResourceType.visible := true;
			form.mnuResourceType.enabled := true;
		endif;
	endif;
	
	// 15/05/2023	navkc1	CR 57927 Task 54268
	form.menuTMETransType.visible := true;
	form.menuTMEResourceType.visible := true;
	
	form.btnDelete.enabled := true;
	form.btnNew.enabled := true;

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="1d1ada6c-adbe-4169-967e-28bbd18b43eb">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(form);
	
	form.myCurrentMapTMEvent := self.myEventBroker.myTranMap;
	form.myCurrentMapServiceBroker := self.myEventBroker;
	
	// 15/05/2023	navkc1	CR 57927 Task 54268
	form.myTMCEG := self;
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
