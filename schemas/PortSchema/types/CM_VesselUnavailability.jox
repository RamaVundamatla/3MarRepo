        <type name="Date"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myReasonCode" id="520c0996-9f41-4484-82df-8414b42ebbd0">
        <embedded/>
        <type name="HMS_VesselUnavailCode"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myVessel" id="56decd4d-bac8-4e32-b2d9-00577db4ece1">
