    <JadeMethod name="userNotification" id="cc7978b8-8a07-48aa-8f72-7f8367655d2e">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	
begin
	if eventType = EVENT_TWISTLOCK_TERMINATE then
		terminate;
	endif;


	inheritMethod(eventType, theObject, eventTag, userInfo);
	
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="writeLog" id="9e625c88-9922-4785-b1a7-2bbb7bc2c4ce">
        <source>writeLog(_message : String input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	if self.myHandHeldGuiAgent &lt;&gt; null then
		self.myHandHeldGuiAgent.writeLog(_message);
	elseif self.myLogonGuiAgent &lt;&gt; null then
		self.myLogonGuiAgent.writeLog(_message);
	endif;
epilog

end;</source>
        <Parameter name="_message" type="String" usage="input"/>
    </JadeMethod>
