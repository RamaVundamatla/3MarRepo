    <JadeMethod name="trxUpdateRsyncTrans" id="ffd87a9b-30da-4d52-9296-266c2e43f7b3">
        <updating/>
        <source>trxUpdateRsyncTrans(_controller:CMIF_TiTransactionResync; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*	Date		Who		Reason
	08/05/2018	jlgmd1	TFS #38663 QNS - Jade Lock issue
*/
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	// Defer our actual updates until the end
	_passport.useTITransactionDeferUpdate := true;		// TFS 38663
	_passport.useTIDictDeferUpdate := true;				// TFS 38663

	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateResyncTrans(_controller, _passport);
	
	if _controller.readonly then // ### TFS 2682
		abortTransaction; // ### TFS 2682
		beginTransaction; // ### TFS 2682
	endif;

	if _passport.noErrors then				// TFS 38663
		_passport.doDeferredUpdates();		// TFS 38663
	endif;									// TFS 38663
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_controller" type="CMIF_TiTransactionResync"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
