    <JadeMethod name="doCmbServicesBuild" id="d7f3cef9-e4d3-4303-8bac-f14e2b05709d">
        <updating/>
        <source>doCmbServicesBuild() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2023  navmv20 TFS 55651 Task 57072: UI - Contract Bulk Edit UI
*/

vars
	idx      : Integer;
	service  : CM_Service;
	bank     : CM_Bank;
	invoice  : CM_InvoiceLineDesc;
	objSet   : ObjectSet;
	contract : CM_InvoiceContract;
	detail   : CM_InvoiceContractDetails;
	rate     : CM_InvoiceContractRate;
	
begin
	self.cmbService.clear();
	
	create objSet transient;
	foreach contract in self.allInvoiceContracts do
		foreach detail in contract.allInvoiceContractDetails do
			foreach rate in detail.allInvoiceContractRates do
				if rate.myService &lt;&gt; null and not objSet.includes(rate.myService) then
					objSet.add(rate.myService);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	self.cmbService.addItem("");
	foreach service in objSet as CM_Service do
		idx := self.cmbService.addItem(service.name);
		self.cmbService.itemObject[idx] := service;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
