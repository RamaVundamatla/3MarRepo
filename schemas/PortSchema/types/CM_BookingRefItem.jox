    <JadeMethod name="numOnsiteTIs" id="16dcc128-c344-4bed-9ef7-80a5230717c4">
        <source>numOnsiteTIs(): Integer;
/*

Purpose:			Copied from CM_BookingRef for CCMS 1618

Parameters:			null

Return Value:		number of received items

Date		Who		Reason
11 Jan 2008 Debby Hutchison initial creation
13 Jun 2013	cnwcs5	par 31670 - breakbulk changes
03 Apr 2019	jlgzm1	TFS43864 Booking screen performance

*/
vars
	ti 		: CM_TrackedItem;
	total	: Integer;
	item 	: CM_BookingRefItem;
	iter 	: Iterator; //43864
begin
	//make sure we are working with the real object
	if self.isTransient then
		item := app.myProxyManager.getRealObject(self).CM_BookingRefItem;
		if item &lt;&gt; null then
			return item.numOnsiteTIs;
		endif;
	endif;
	
	//tfs43864 start
	iter := self.allTIsByState.createIterator();
	
	//get all items with state &lt; prenote
	self.allTIsByState.startKeyGeq(TI_STATE_UNDEFINED, "", 0,iter);
	while iter.next(ti) do
		if iter.getCurrentKey(1).Integer &gt;= TI_STATE_NOTIFIED then
			break;
		endif;
		total := total + 1;
	endwhile;

	//get all items with state &gt; prenote and state &lt; merged
	self.allTIsByState.startKeyGeq(TI_STATE_OFFSITE, "", 0, iter);
	while iter.next(ti) do
		if iter.getCurrentKey(1).Integer &gt;= TI_STATE_MERGED then
			break;
		endif;
		total := total + 1;
	endwhile;
	//tfs43864 end
	
	return total;
	
epilog
	delete iter; //43864
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="numPrenotedTIs" id="63ad92cd-80a0-4179-abc6-b136530814c2">
        <source>numPrenotedTIs():Integer;
/*

Purpose:			Get number of prenoted items

Parameters:			null

Return Value:		total number of prenoted items

Date		Who		Reason
14 Sep 2009	cnwml2
12 Jun 2013	cnwcs5	par 31670 - fix counting for break bulk
01 Apr 2019	jlgzm1	tfs43864 Booking screen performance

*/


vars
	ti			: CM_TrackedItem;
	qty, total	: Integer;
	item 		: CM_BookingRefItem;
	iter		: Iterator;
begin
	if self.isBulkMulti then
		return 0;
	endif;
	
	//make sure we're working with the real object
	if self.isTransient then
		item := app.myProxyManager.getRealObject(self).CM_BookingRefItem;
		
		if item &lt;&gt; null then
			return item.numPrenotedTIs;
		endif;
	endif;

	//tfs43864 start
	iter := self.allTIsByState.createIterator();
	self.allTIsByState.startKeyGeq(TI_STATE_NOTIFIED, "", 0, iter);

	beginLoad;
		while iter.next(ti) do
			if iter.getCurrentKey(1).Integer &lt;&gt; TI_STATE_NOTIFIED then
				break;
			endif;
			//epr 34935 29/9/14
			if ti.myCargoType.isBulkMulti then
				continue;
			endif;
			//get total quantity
			qty := iter.getCurrentKey(3).Integer;
			if qty = 0 then 
				// just in case we have old data with no totalQuantity
				qty := 1;
			endif;
			
			total := total + qty;
		endwhile;
	endLoad;
	//tfs43864 end
	
	return total;

epilog
	delete iter;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="numTIs" id="fbdf9850-b15a-4b96-91cd-d5a54d3a1775">
        <methodInvocation>mapping</methodInvocation>
        <source>numTIs(set : Boolean; _value : Integer io) mapping;
/*

Purpose:			Get number of tracked items

Parameters:			null

Return Value:		number of tracked items

Date		Who		Reason
17 Jan 2008 Debby Hutchison Initial creation
13 Jun 2013	cnwcs5	par 31670 - breakbulk changes
03 Apr 2019	jlgzm1	tfs43864 Booking screen performance

*/
vars
	ti 		:CM_TrackedItem;
	iter	: Iterator;
begin
	if set then
		//cannot manually set
		app.raiseSetVirtualError(class.name,method.name);
	else
	
		//tfs43864 start
		iter := self.allTIsByState.createIterator();
		self.allTIsByState.startKeyLss(TI_STATE_MERGED, "", 0, iter);

		beginLoad;
			while iter.back(ti) do
				_value := _value + 1;
			endwhile;
		endLoad;
		//tfs43864 end
	endif;
	
epilog
	delete iter;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="populatePxyFromReserveDetail" id="fd2e6b53-f321-43f1-848b-072b7b30904d">
        <updating/>
        <source>populatePxyFromReserveDetail(_proxy	:	CM_ReserveDetail) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Nov 2022	navgm20	ChangeRequest 54979: EUP - Transport Mode change - PortSchema Changes

*/

vars

begin
	self.remarks	:=	_proxy.remarks;
	self.sequence	:=	_proxy.sequence;
	self.weight		:=	_proxy.weightRequested;
