    <JadeMethod name="getXMLSettingsForSave" id="bcdc41b1-2dfa-4aba-a3a5-1911879b79b4">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theXML : String;
	theGridArea : CMUI_GridArea;
begin

	theXML := inheritMethod();

	theXML := theXML &amp; global.formatAsXML(XMLTag_ScaleFactor,self.xmlScaleFactor.String);
	theXML := theXML &amp; global.formatAsXML(XMLTag_HideLegend,self.xmlHideLegend.Integer.String);
	theXML := theXML &amp; global.formatAsXML(XML_Tag_ShowCargoHeights,self.xmlShowCargoHeights.Integer.String);
	theXML := theXML &amp; global.formatAsXML(self.XMLTag_FlipV,self.btnFlipV.value.Integer.String);
	theXML := theXML &amp; global.formatAsXML(self.XMLTag_FlipH,self.btnFlipH.value.Integer.String);

	return theXML;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="b477dcbe-d129-456c-aa20-6101e62c4858">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	flipH, flipV, bigFont,hideL,hideT,hideM,showCH : Boolean;
	zoomScale : Real;
begin

	userWindow := app.getUserWindow(self.name, false);
	self.xmlScaleFactor := 1; // This gets overwritten if there is a userWindow	

	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;
 	// #### HIDE LEGEND
 	theXMLValue := theXML.cnEcGetTagValueOfName(self.XMLTag_HideLegend);
 	hideL := false;
 	if theXMLValue &lt;&gt; null then
 		hideL := theXMLValue.Integer.Boolean;
 	endif;
	self.xmlHideLegend := hideL;

	// #### ZOOM SCALE
 	zoomScale := theXML.cnEcGetTagValueOfName(self.XMLTag_ScaleFactor).Real;
 	if zoomScale = null then
	 	zoomScale := 1;
	 endif;
	self.xmlScaleFactor := zoomScale;
 	// #### Show Cargo Heights
 	theXMLValue := theXML.cnEcGetTagValueOfName(self.XML_Tag_ShowCargoHeights);
 	showCH := false;
 	if theXMLValue &lt;&gt; null then
 		showCH := theXMLValue.Integer.Boolean;
 	endif;

	self.xmlShowCargoHeights := showCH;
	self.btnFlipV.visible := showCH;
	self.btnFlipH.visible := showCH;
	
	// #### FLIPV
 	self.btnFlipV.value := theXML.cnEcGetTagValueOfName(self.XMLTag_FlipV).Integer.Boolean;
 	self.btnFlipH.value := theXML.cnEcGetTagValueOfName(self.XMLTag_FlipH).Integer.Boolean;
 
end;</source>
    </JadeMethod>
    <JadeMethod name="initTableDimensions" id="4ce7c58c-3ab1-4fd7-8945-c9a85bcf31ee">
        <source>initTableDimensions();
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTable : CM_EntryTable;
begin
	theTable := self.tblDim;
	theTable.rows := 0;
	theTable.columns:= 3;
	theTable.addItem("" &amp; Tab &amp; "X" &amp; Tab &amp; "Y");
	theTable.fixedRows := 1;
	theTable.fixedColumns := 1;
	theTable.userInputEnabled := true;
	theTable.accessColumn(COLUMN_Y).inputType := Table.InputType_TextNumeric;
	theTable.accessColumn(COLUMN_X).inputType := Table.InputType_TextNumeric;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="5e31f88a-fc73-465f-b021-87e1cbd2f83b">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      30 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	self.frmLegend.myLegendTable.bubbleHelp := self.ColourHelp;
	self.initTableDimensions();
	self.doDrawGraphics();
	if self.xmlShowCargoHeights and self.mode = self.Mode_Display then
		self.doMnuCargoHeightsAllClick(self.mnuCargoHeightAll);
	endif;
	self.cmbAreas.bubbleHelp := "Areas marked with '&lt;' have dimensions that are very small and may need attention";
end;</source>
        <access>protected</access>
    </JadeMethod>
