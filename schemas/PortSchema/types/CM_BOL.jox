    <JadeMethod name="handleOpsView" id="5bc94a0e-e9a1-4112-94f4-edf8bd743599">
        <updating/>
        <source>handleOpsView(_updateAction : Character) updating;
/*
Purpose:			

Date		Who		Reason
30 May 2022	navab1	TFS 53105
*/

vars
	detail : CM_BOLDtl;
begin
	 // ### TFS 53105 30MAY2022 NAVAB1
	if app.myPassport.isOpsViewEnabled(self.myTerminal) then
		self.createOpsViewEWSActivity(_updateAction,BGP_OpsViewWSRequest.OPS_TYPE_DOCUMENT, self);
		
		foreach detail in self.allBOLDtls discreteLock do
			detail.createOpsViewEWSActivity(_updateAction,BGP_OpsViewWSRequest.OPS_TYPE_DOCDETAIL, detail);
	
		endforeach;
		
	endif;

epilog

end;</source>
        <Parameter name="_updateAction" type="Character"/>
    </JadeMethod>
    <JadeMethod name="hasCargoForSite" id="ccd0f6a4-5a4a-41f8-8d09-5dde2ec9397f">
        <source>hasCargoForSite(_site : Integer) : Boolean;
//--------------------------------------------------
// Created:	24 March 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
begin

	foreach tmpTI in self.allTrackedItems do
		if tmpTI.site = _site then
			return true;
		endif;
	endforeach;

	return false;
end;</source>
