    <JadeMethod name="cnwdad1_Test_CnHttp_GetFile" id="2c8d4ead-d5b4-4448-aeca-56262951899f">
        <source>cnwdad1_Test_CnHttp_GetFile();
// --------------------------------------------------------------------------------
// Created:		01 August 2000 by cnwdad1
//
// Purpose:		Test the CardSchema's CnHttp::cnGetFile method.
//
// Parameters:	None
//
// Returns:		Nothing, but generates a disk file is successful.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	karmaControl	: CnKarmaCntrl;	// CardSchema's "KarmaControl" class.
	httpConnect		: CnHttp;		// The CardSchema implementation of an HTTP class.
	webServer		: String;		// The web server from which to source the file.
	sourceFile		: String;		// The location of the file on the web server (copied from).
	targetFile		: String;		// The local name of the file (copied to).
 	requestResult	: String;		// The response from the CardSchema HTTP class.
 	startTime		: Integer;

begin
	startTime	:=	app.clock();

	// Fetch a GIF image from Darrell's intranet site.
	webServer	:=	"cnwdad1a.cnw.co.nz";
	sourceFile	:=	"TestImages/austmap.gif";
	targetFile	:=	"c:\temp\__picture.gif";

	create karmaControl transient;
	create httpConnect transient;

	httpConnect.setServerName(webServer);
	requestResult	:=	httpConnect.cnConnect;

	if requestResult = CN_OK then
		write "Connected OK, fetching the file (source=[" &amp; webServer &amp; "/" &amp; sourceFile &amp; "]  target=[" &amp; targetFile &amp; "])...";
		requestResult	:=	httpConnect.cnGetFile(sourceFile, targetFile, true);

		if requestResult = CN_OK then
			write "File successfully retrieved !  See the '" &amp; targetFile &amp; "' file.";
		else
			write requestResult;
		endif;
	else
		write requestResult;
   endif;
epilog
	delete httpConnect;
	delete karmaControl;

	write "Done in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_Collection_Move" id="6caebb47-0066-46b7-bd9e-96b39a80937e">
        <source>cnwdad1_Test_Collection_Move() protected;
// --------------------------------------------------------------------------------
// Created:		19 April 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cnecarray	: CnEcArray;
	stringarray	: CnEcSubstringArray;
	dualarray	: CnEcDualStringArray;
	
begin
	create cnecarray transient;
	create stringarray transient;
	create dualarray transient;
	
	cnecarray.addString("test");
	stringarray.addString("test two");
	
	if stringarray.cnEcMove(cnecarray) then
		cnecarray.inspectModal();
		stringarray.inspectModal();
	else
		write "First move failed!";
	endif;
	
	if cnecarray.cnEcMove(dualarray) then
		dualarray.inspectModal();
		cnecarray.inspectModal();
	else
		write "Second move failed!";
	endif;
epilog
	delete cnecarray;
	delete stringarray;
	delete dualarray;
end;</source>
        <access>protected</access>
    </JadeMethod>
