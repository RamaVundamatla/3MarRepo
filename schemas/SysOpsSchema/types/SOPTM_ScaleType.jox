    <JadeMethod name="setTypeWeightConvRows" id="51ea62a1-3239-4ce4-b6d2-b7a5f514fddd">
        <source>setTypeWeightConvRows( _type : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2019	jlgndl1	Initial creation	TFS 44965

*/

vars

	theForm : SOP_TableMaintForm;

begin

	theForm := self.myForm;
	 
	theForm.tblInput1.hideRowByName( ETRow_GramsConv, false );
	theForm.tblInput1.hideRowByName( ETRow_KilosConv, false );
	theForm.tblInput1.hideRowByName( ETRow_OuncesConv, false );
	theForm.tblInput1.hideRowByName( ETRow_PoundsConv, false );
	theForm.tblInput1.hideRowByName( ETRow_TonsConv, false );

	if _type = CM_WeighBridgeObjType.IQ710 then
		theForm.tblInput1.showRowByName( ETRow_GramsConv, false );
		theForm.tblInput1.showRowByName( ETRow_KilosConv, false );
		theForm.tblInput1.showRowByName( ETRow_OuncesConv, false );
		theForm.tblInput1.showRowByName( ETRow_PoundsConv, false );
		theForm.tblInput1.showRowByName( ETRow_TonsConv, false );
		
	elseif _type = CM_WeighBridgeObjType.SeriesW then
		theForm.tblInput1.showRowByName( ETRow_KilosConv, false );
		
	endif;

epilog

end;</source>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="3e1abeaf-7967-4677-b5e7-39ce13f8c30e">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	theForm : SOP_TableMaintForm;
	
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	
	theForm.setTblDataEntRows(ETDef_WeighBridgeType);
	
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_WeighBridgeType);
	theForm.shtTblInput1.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupValidCodes" id="44f4ec6c-df2c-4b77-8962-6d5c8db59200">
        <source>setupValidCodes( _cmb : ComboBox );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2019	jlgndl1	Initial creation	TFS 44965

*/

vars

begin

	_cmb.clear();
	
	_cmb.addItem( CM_WeighBridgeObjType.IQ710 );
	_cmb.addItem( CM_WeighBridgeObjType.Kubota );
	_cmb.addItem( CM_WeighBridgeObjType.GenericScanAPI ); // ### TFS 52773 1APR2022 NAVPW1
	_cmb.addItem( CM_WeighBridgeObjType.MT226 );
	_cmb.addItem( CM_WeighBridgeObjType.SeriesW );

epilog

end;</source>
        <Parameter name="_cmb" type="ComboBox"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="48fa82f5-cf85-4e79-99a1-3c74857a0143">
        <updating/>
        <source>showThumbnail(pObj: CM_WeighBridgeObjType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars
	theForm : SOP_TableMaintForm;
	
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	
	self.setTypeWeightConvRows( pObj.code );	//05 Jul 2019	NDL	TFS 44965
	self.setupValidCodes( theForm.cmbScaleTypes );	//05 Jul 2019	NDL	TFS 44965

	theForm.tblInput1.setValueByName(ETRow_Code, pObj.code);
	theForm.tblInput1.setValueByName(ETRow_Description, pObj.description);
	
	if pObj.myGramsMeasureType &lt;&gt; null then
		theForm.cmbGrams.listIndex := theForm.cmbGrams.findObject(pObj.myGramsMeasureType);
		theForm.tblInput1.setValueByName(ETRow_GramsConv, pObj.myGramsMeasureType.name);
	else
		theForm.cmbGrams.listIndex := -1;
		theForm.tblInput1.setValueByName(ETRow_GramsConv, null);
	endif;
	
	if pObj.myKilosMeasureType &lt;&gt; null then
		theForm.cmbKilos.listIndex := theForm.cmbKilos.findObject(pObj.myKilosMeasureType);
		theForm.tblInput1.setValueByName(ETRow_KilosConv, pObj.myKilosMeasureType.name);
	else
		theForm.cmbKilos.listIndex := -1;
		theForm.tblInput1.setValueByName(ETRow_KilosConv, null);
	endif;
	
	if pObj.myOuncesMeasureType &lt;&gt; null then
		theForm.cmbOunces.listIndex := theForm.cmbOunces.findObject(pObj.myOuncesMeasureType);
		theForm.tblInput1.setValueByName(ETRow_OuncesConv, pObj.myOuncesMeasureType.name);
	else
		theForm.cmbOunces.listIndex := -1;
		theForm.tblInput1.setValueByName(ETRow_OuncesConv, null);
	endif;
	
	if pObj.myPoundsMeasureType &lt;&gt; null then
		theForm.cmbPounds.listIndex := theForm.cmbPounds.findObject(pObj.myPoundsMeasureType);
		theForm.tblInput1.setValueByName(ETRow_PoundsConv, pObj.myPoundsMeasureType.name);
	else
		theForm.cmbPounds.listIndex := -1;
		theForm.tblInput1.setValueByName(ETRow_PoundsConv, null);
	endif;
	
	if pObj.myTonsMeasureType &lt;&gt; null then
		theForm.cmbTons.listIndex := theForm.cmbTons.findObject(pObj.myTonsMeasureType);
		theForm.tblInput1.setValueByName(ETRow_TonsConv, pObj.myTonsMeasureType.name);
	else
		theForm.cmbTons.listIndex := -1;
		theForm.tblInput1.setValueByName(ETRow_TonsConv, null);
	endif;
	

end;</source>
        <Parameter name="pObj" type="CM_WeighBridgeObjType"/>
    </JadeMethod>
</Class>
