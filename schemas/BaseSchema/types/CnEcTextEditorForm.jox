    <JadeMethod name="btnCancel_click" id="ab36d113-e5d9-45b2-868d-dcbe64ab3849">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	modalResult	:=	0;
	unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="7914f3e0-29c5-4055-8a22-11bee47d5f1c">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.statusMsg('Changing property value...');

	if self.formValidate() then
		self.formUpdate();
		modalResult			:=	1;
		unloadForm();
	endif;
epilog
	self.statusMsg('');
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="formLoad" id="9395dd7a-4f85-42f0-9537-52d1b6ac4f69">
        <updating/>
        <source>formLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	btnOk.enabled		:=	false;
	self.caption		:=	self.caption &amp; ': ' &amp; self.propertyName;
	lblProperty.caption	:=	self.propertyName;
	txtValue.text		:=	self.stringValue;
	lblSize.caption		:=	txtValue.text.length().String;

	if self.stringLength &gt; 0 then
		txtValue.maxLength		:=	self.stringLength;
		lblMaxLength.caption	:=	self.stringLength.String;
	else
		lblMaxLength.caption	:=	'None';
	endif;

	modalResult			:=	0;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formUpdate" id="5434b51e-060e-4696-9ae3-812f1f1e0bcd">
        <updating/>
        <source>formUpdate() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 cnwdad1
//
// Purpose:		Standard form update method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.stringValue	:=	txtValue.text;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getStringValue" id="2f7806cb-d9ea-4326-9e5b-a489ca15af45">
        <source>getStringValue() : String;
// --------------------------------------------------------------------------------
// Created:		20 February 1999 cnwdad1
//
// Purpose:		Returns the string value being edited.
//
// Parameters:	None
// Returns:		The edited text.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return  stringValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="load" id="24a1d009-1785-4ca3-a6ef-0474f33c4b07">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	centreWindow();
	self.formLoad();
epilog
	self.statusMsg('');
end;</source>
    </JadeMethod>
    <JadeMethod name="resize" id="89f12348-c5a8-43ab-8df4-1635fbdaafae">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		23 January 1999 cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	btnCancel.move(((self.width - btnCancel.width) - 18), ((self.height - btnCancel.height) - 36), btnCancel.width, btnCancel.height);
	btnOk.move(((btnCancel.left - btnOk.width) - 6), ((self.height - btnOk.height) - 36), btnOk.width, btnOk.height);
	txtValue.move(txtValue.left, txtValue.top, (self.width - (txtValue.left * 3) + 2), ((btnCancel.top - txtValue.top) - 8));
	lblMaxLengthLabel.move(lblMaxLengthLabel.left, ((self.height - lblMaxLengthLabel.height) - 36), lblMaxLengthLabel.width, lblMaxLengthLabel.height);
	lblMaxLength.move(lblMaxLength.left, ((self.height - lblMaxLength.height) - 36), lblMaxLength.width, lblMaxLength.height);
end;</source>
    </JadeMethod>
    <JadeMethod name="setPropertyName" id="4a30d5d9-7893-4f04-80fd-3adfcb401ebc">
        <updating/>
        <source>setPropertyName(pValue: String) updating;
// --------------------------------------------------------------------------------
// Created:		20 February 1999 cnwdad1
//
// Purpose:		Sets the name of the property who's text is being edited.
//
// Parameters:	pValue - The name of the property who's text is to be edited.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.propertyName &lt;&gt; pValue then 
		self.propertyName := pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="setStringLength" id="8b885c13-d23a-41a5-b8d1-fe9f90d89083">
        <updating/>
        <source>setStringLength(pValue: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		20 February 1999 by cnwdad1
//
// Purpose:		Sts the length of the text being edited.
//
// Parameters:	pValue - The length of the text to be edited.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.stringLength &lt;&gt; pValue then 
		self.stringLength := pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setStringValue" id="8e607dab-8ef0-42e6-b270-0d884152f52e">
        <updating/>
        <source>setStringValue(pValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		20 February 1999 by cnwdad1
//
// Purpose:		Sets the value of the text being edited.
//
// Parameters:	pValue - The text to be edited.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.stringValue &lt;&gt; pValue then
		self.stringValue	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="txtValue_change" id="9b385eb6-1545-4f4f-8308-c7d9375557d5">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtValue_change(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		20 February 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	lblSize.caption		:=	txtValue.text.length.String;

	if (not btnOk.enabled) then
		btnOk.enabled	:=	true;
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
