    <JadeMethod name="isCMIFDataMatch" id="b2623392-6922-49f7-b650-9652cf476139">
        <source>isCMIFDataMatch(_cmifAutoPlan : CMIF_YAAutoPlan; _yaData: CM_YADataBoolean): Boolean;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
vars

	
begin

	return _cmifAutoPlan.isFortyFive_Match(_yaData);
	
end;</source>
