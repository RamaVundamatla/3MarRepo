    <JadeMethod name="getValueFromObject" id="eab7c774-5aae-46ea-a32e-db28cdd8c073">
        <source>getValueFromObject(_trackedItem: CM_TrackedItem): Any;
//08 December 2008	cnwdw1	
//
vars
	obj: CM_Object;
	processIt : Boolean;
begin
	if _trackedItem &lt;&gt; null then
		self.getCriteriaObjectForTi(_trackedItem, obj, processIt);
		if obj &lt;&gt; null then
			return self.getDisplay(obj);
		endif;
	endif;
	return null;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getValueFromTrackedItem" id="3549f437-0197-4afb-82c3-583517a1d06d">
        <source>getValueFromTrackedItem(_ti : CM_TrackedItem) : String;
// CCMS 1295 free storage days, storage detail processing
vars
	result	: Any;
begin
	self.getCriteriaValueForTi(_ti, result);
	
	return result.String;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYAPriorityValueForCriteria" id="461f1bf0-9dbd-44d2-ab3e-148060955d9f">
        <source>getYAPriorityValueForCriteria(_yaCriteria : CM_YACriteria; _terminal : CM_Terminal) : Real;
// -------------------------------------------
// Created 14 March 2005 by cnwdvb1
// -------------------------------------------
/*	This method compares the configuration of a CM_YACriteria against
	priorities of the same type for the specified terminal and returns
	a priority value. */
vars

	priority		: CM_YAPriority;
	priorityValue	: Real;

begin

	foreach priority in self.allYAPriorities discreteLock do
		if priority.myTerminal &lt;&gt; _terminal then
			continue;
		endif;
		self.sharedLock(priority);
		priorityValue := priorityValue + priority.getYAPriorityValueForCriteria(_yaCriteria);
		self.unlock(priority);
	endforeach;
	
	return priorityValue;
	
epilog
	if priority &lt;&gt; null then
		self.unlock(priority);
	endif;
end;</source>
        <Parameter name="_yaCriteria" type="CM_YACriteria"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Real"/>
    </JadeMethod>
