    <JadeMethod name="runTest" id="c89a29de-5bf7-4e50-b64c-30e9e6356022">
        <updating/>
        <source>runTest():Integer updating;

vars
	sa:StringArray;
	meth:String;
begin
	create sa transient;
	sa.add('ce002_CSAF_picture_click');
	sa.add('ce004_CN_lstTest_click');
	sa.add('ce006_CN_lstTest_dblClick');
	sa.add('ce008_SOOWF_cmbVoyage_click');
	sa.add('ce010_SOOWF_picture_click');
	sa.add('ce012_CN_lstTest_click');
	sa.add('ce014_CN_lstTest_click');
	sa.add('ce016_CN_lstTest_dblClick');
	sa.add('ce018_SPAF_cmbArea_click');
	sa.add('ce020_CN_lstTest_click');
	sa.add('ce022_CN_lstTest_dblClick');
	sa.add('ce024_GVVEF_picture_click');
	sa.add('ce999_tidyUp');

	foreach meth in sa do
		if meth[6:2] &lt;&gt; "v_" then
			app.doWindowEvents(longPause);
		endif;
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		if app.atcgReplayFailure then
			app.atcgReplayFailure:=false;
			break;
		elseif retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			break;
		endif;
	endforeach;
	app.atcgDetectMissedMsgBoxes;
	app.logMessage("Finished");
	return 0;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
