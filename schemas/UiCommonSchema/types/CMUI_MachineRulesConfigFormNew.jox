    <JadeMethod name="cmbFromTA_lostFocus" id="fe78b0b7-807a-47d4-a4ad-60f81e91ba44">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbFromTA_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwer1	Initial creation

*/

vars
	obj : Object;
begin
	
	obj:=combobox.listObject;
	
	if self.myProxyMultiRule.isKindOf(CM_RTQueueMultiRuleTAType) then
		if self.myProxyMultiRule.CM_RTQueueMultiRuleTAType.myFromTAType = obj then
			return;
		endif;
		self.myProxyMultiRule.CM_RTQueueMultiRuleTAType.setForProxyTAType(obj.CM_TerminalAreaType,self.myProxyMultiRule.CM_RTQueueMultiRuleTAType.myToTAType,self.myProxyMultiRule.myTerminal);
	elseif self.myProxyMultiRule.isKindOf(CM_RTQueueMultiRuleTAMaster) then
		if self.myProxyMultiRule.CM_RTQueueMultiRuleTAMaster.myFromTAMaster = obj then
			return;
		endif;
		self.myProxyMultiRule.CM_RTQueueMultiRuleTAMaster.setForProxyTAMaster(obj.CM_TerminalArea,self.myProxyMultiRule.CM_RTQueueMultiRuleTAMaster.myToTAMaster,self.myProxyMultiRule.myTerminal);
		self.loadSourceICCombo();
	endif;
	
	self.cmbMoveMethod.initialise(true);
	self.doSelectRTMoveMethodRule;
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbMoveMethod_click" id="f57417a5-9fce-4caa-b0c6-43c4b9650b13">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbMoveMethod_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwer1	Initial creation
02 September 2011	cnwdap1	PAR #25693 CCMS POL 2008 added Queuing Rule
*/

vars
	selectedMoveMethod : CM_RTMoveMethod;
	sourceMG,
	targetMG : CM_MachineTypeGroup;
	rtMoveMethodRule : CM_RTMoveMethodRule;		// PAR #25693
begin
	self.cmbSourceIC.enabled:=false;
	self.cmbSourceIC.listIndex:=-1;
	self.cmbTargetIC.enabled:=false;
	self.cmbTargetIC.listIndex:=-1;
	if combobox.listIndex &lt; 0 then	
		return;
	endif;
	selectedMoveMethod:=combobox.itemObject[ combobox.listIndex ].CM_RTMoveMethod;
	if selectedMoveMethod = null then
		return;
	endif;
	
	// 28874 Mar 2012 move this code from after to before the 25693 code, so it still gets executed
	if self.myProxyMultiRule &lt;&gt; null then
		if not self.myProxyMultiRule.isTATypeRule then
			sourceMG:=app.myRoot.allMachineTypeGroups[MACHINETYPEGRP_SOURCEIC];
			if selectedMoveMethod.allMachineTypeGroups.includes(sourceMG) then
				self.cmbSourceIC.enabled:=true;
				if self.cmbSourceIC.listCount = 1 then
					self.cmbSourceIC.listIndex:=1;
				endif;
			endif;
	
			targetMG:=app.myRoot.allMachineTypeGroups[MACHINETYPEGRP_TARGETIC];
			if selectedMoveMethod.allMachineTypeGroups.includes(targetMG) then
				self.cmbTargetIC.enabled:=true;
				if self.cmbTargetIC.listCount = 1 then
					self.cmbTargetIC.listIndex:=1;
				endif;
			endif;
		endif;
	endif;

	//cnwrd1 par 31524 6.6.13
	self.cmbQueuingRule.enabled := true;
	if self.tblMoveRules.row &lt;= 1 then
		self.cmbQueuingRule.text := LegMoveQueuing;
		return;
	endif;
	rtMoveMethodRule := self.tblMoveRules.accessRow(self.tblMoveRules.row).itemObject.CM_RTMoveMethodRule;
	if rtMoveMethodRule &lt;&gt; null then
		self.cmbQueuingRule.text := rtMoveMethodRule.queuingRule;
	endif;


	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
