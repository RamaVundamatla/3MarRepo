vars
	canEditTT : Boolean;
begin
	canEditTT := (app.myPassport.myUser.canDo(app.myPassport.myTerminal, self.permissionMaint) );  //par 21296

	// developer mode functions
	self.btnNew.enabled 		:= self.isDeveloperMode and fldData.topSheet = shtMessages;
