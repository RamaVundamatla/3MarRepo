    <JadeMethod name="cancelVoyageDelay" id="53edb4e6-6638-4370-984d-3dfd3337de15">
        <updating/>
        <source>cancelVoyageDelay(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 28 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	// Delay deleted, create transaction
	self.createTransaction(TRANS_TYPE_DeleteVoyageDelay, null, null, _passport);

	self.archive(_passport);
		
end;</source>
