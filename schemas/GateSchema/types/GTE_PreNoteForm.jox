    <JadeMethod name="addObjectsToTable" id="39012519-fad2-4592-acb8-5ff9482276d8">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
    iter	: Iterator;
    ti		: CM_TrackedItem;
    transMode	: String;
    passport	: CM_Passport;
  	breakOut	: Boolean; 
	pin		: CM_PinNo;
 	obj		: Object;
begin

	passport := app.myPassport;
	
	transMode := self.viewTransportMode;

	//if transMode = ViewAdditions then
	if transMode =  app.getErrorString(View_Additions) then // cnwrd1 par 18519 6.3.09
		iter := self.allAddedPreNotes.createIterator;
		while iter.next(ti) do
			self.addObjectToTable(ti, _numItems, breakOut);
			if breakOut then
				break;
			endif;
		endwhile;
	elseif self.filtPIN &lt;&gt; null then
		pin := self.myTerminal.allPinNos[self.filtPIN];
		if pin &lt;&gt; null then
			foreach obj in pin.allItems discreteLock do //+ cnwmd1 Par 25448 added dicreteLock
				if CM_TrackedItem.hasInstance(obj) and
		   	       self.includeObject(obj.CM_TrackedItem, passport) then
					self.addObjectToTable(obj.CM_TrackedItem, _numItems, breakOut);
				endif;
				if breakOut then
					break;
				endif;
			endforeach;
		endif;
	else
		iter := self.myTerminal.allNotifiedTIsByCargoTypeId.createIterator();
		while iter.next(ti) do
			//if ti.id = "DEBSPECIAL" then
			//	 self.includeObject(ti, passport);
			//endif;
		   	if self.includeObject(ti, passport) then
   				self.addObjectToTable(ti, _numItems, breakOut);
   			endif;
			if breakOut then
				break;
			endif;
		endwhile;
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addPreNote" id="f77123aa-276b-4d5d-aeae-f5d151d5171d">
        <updating/>
        <source>addPreNote(_preNote : CM_TrackedItem) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2009	cnwdap1	Initial creation
*/
vars

begin
	self.allAddedPreNotes.add(_preNote);
epilog

end;</source>
        <Parameter name="_preNote" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="147ed17d-bc6c-44ed-8dc6-5f12404e3217">
        <source>addToolbarControls() protected;
//----------------------------------------------------------------
//	Created:	01 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	toolbar			: CMUI_Toolbar;
//	showCaptions	: Boolean;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	
	// cnwrl1 17/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - start of coding
	if self.bAllowSummaryDefn then
		toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
		toolbar.addButton( self.btnSummariseAll, CMUI_Toolbar.Control_Alignment_Left );
	endif;
	// cnwrl1 17/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - end of coding
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResendCarrier, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnBookingRefDis, CMUI_Toolbar.Control_Alignment_Left);	// 26 Aug 2009	NDL:	Par 20521 CCMs 1609
	
//	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addFrame(self.frmTransportMode, CMUI_Toolbar.Control_Alignment_Left);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="armNotesForObject" id="a9700164-d289-4462-bc81-79ddbda8f035">
        <source>armNotesForObject(_obj: Object);
// ---------------------------------------------------------------------------
// Created:     29 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 10/7/17 jlgns1 TFS 4812 CPL - Updates not refreshing - Pre Notes 
vars

begin
	inheritMethod(_obj);//TFS 4812

	self.beginNotification(_obj, self.myTerminal.getTerminalEvent(TIEvent_PreNote_Update),   Response_Continuous, 0);
	self.beginNotification(_obj, self.myTerminal.getTerminalEvent(TIEvent_PreNote_Delete),   Response_Continuous, 0);
	self.beginNotification(_obj, self.myTerminal.getTerminalEvent(TIEvent_Terminal_Receival), Response_Continuous, 0);
	self.beginNotification(_obj, Object_Delete_Event, Response_Continuous, 0);                  
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
