<Class name="CM_QStrCustomerPriorityMethod" id="2594e613-8499-44ac-818e-cb56b70626cd">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="120d761e-3c9c-460f-b45f-41d3a927f8e5">
        <updating/>
        <source>create() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 November 2023
TFS#		: 61132
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	queryOperator	: CM_QueryOperator;
begin

	if self.isTransient then	
		return;
	endif;

	create queryOperator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(queryOperator);	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="d9040391-cdcd-4a7c-9e2a-6a1f7c10689c">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 November 2023
TFS#		: 61132
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	customerPriority : CM_CustomerPriority;
	dict 			 : CM_CustomerPriorityByCodeDict;		

begin
	_combo.clear;
	dict := app.myRoot.allCustomerPriorities;
	
	foreach customerPriority in dict discreteLock do																	
		_combo.itemObject[_combo.addItem(customerPriority.getDisplayDetails(false))] := customerPriority;																				
	endforeach;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := dict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := dict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="745ee0ad-9eb8-48dc-90ed-1b0aa534ac2e">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 November 2023
TFS#		: 61132
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	customerPriority 	: CM_CustomerPriority;
	dict 				: CM_CustomerPriorityByCodeDict;
	selectionValue, 
	idx 				: Integer;
	array				: ObjectArray;

begin
	dict := app.myRoot.allCustomerPriorities;
	
	_tbl.rows := _tbl.fixedRows;
	array := _tbl.getPropertyValue("allSelectedObjects").ObjectArray;
	array.clear;
	
	foreach	customerPriority in dict discreteLock do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.CM_QStringIsOneOf.allSelectionValues.includes(customerPriority.code) then
			selectionValue := 1;
			array.add(customerPriority);
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; customerPriority.code &amp; " (" &amp; customerPriority.description &amp; ")");
		_tbl.accessRow(idx).itemObject := customerPriority;
	endforeach;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="2f178303-0314-4a39-96f5-e64c884d71fc">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 November 2023
TFS#		: 61132
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	customerPriority 	: CM_CustomerPriority;
	str 				: String;
	numRows, 
	idx 				: Integer;
	sArray				: StringArray;

begin
	create sArray transient;
	
	numRows := _tbl.rows;
	foreach idx in _tbl.fixedRows + 1 to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			customerPriority := _tbl.accessRow(idx).itemObject.CM_CustomerPriority;
			sArray.add(customerPriority.code);
		endif;
	endforeach;
	
	_op.setSearchValue(sArray);

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="1e721438-4c36-482a-8595-20807cfde0c8">
        <source>translateToDisplayValue(_value: Any): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 November 2023
TFS#		: 61132
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	if _value.isKindOf(CM_CustomerPriority) then
		if _value &lt;&gt; null then
			return _value.CM_CustomerPriority.getDisplayDetails(false);
		else
			return null;
		endif;
	else
		return _value.String;
	endif;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="b726c090-6010-49dc-9ffb-8afabac9410e">
        <source>translateToSearchValue(_value: Any): Any;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 November 2023
TFS#		: 61132
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	invalidObj 	: Boolean;
	object 		: CM_CustomerPriority;
	returnVal 	: String;	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;
		
		if _value.isKindOf(CM_CustomerPriority) then
			object := _value.CM_CustomerPriority;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
