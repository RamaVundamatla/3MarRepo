    <JadeMethod name="comboBoxAssignedLocations" id="b6286a55-cdbf-424c-8f7d-28e4a3f7249f">
        <source>comboBoxAssignedLocations(pCmb: ComboBox input; _voy : CM_Voyage; _lc : CM_LocationsController);
//--------------------------------------------------------------
//Created: 17 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	
begin

	self.allLotAssignedLocations.clear();

	if _voy &lt;&gt; null then
		_voy.getAllAllocatedRows(allLotAssignedLocations);
	endif;

	pCmb.listCollection(allLotAssignedLocations, false, 0);

	if _lc &lt;&gt; null and self.allLotAssignedLocations.includes(_lc) then
		pCmb.text := self.displayEntryLocationController(_lc);
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_voy" type="CM_Voyage"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="comboBoxAssignedLocationsSpecs" id="42961033-99ca-45d7-b115-91c9ab41e3e6">
        <source>comboBoxAssignedLocationsSpecs(	_cmb: ComboBox input; _voy : CM_Voyage; _species : CM_LogSpecies; _grade : CM_LogGrade;
								_type : CM_LogType; _treat : CM_LogTreatment; _length : CM_LogLength; _lc : CM_LocationsController);

/*
Date		Who		Reason
26 May 2010	cnwar2	#24188

*/
vars
	lc 		: CM_LocationsController;
	lr 		: CM_LocationRestrictLog;
	objSet	: CM_ObjectSet;
	obj		: Object;
	
begin
	self.allLotAssignedLocations.clear();

	if _voy &lt;&gt; null then
		_voy.getAllAllocatedRows(allLotAssignedLocations);
	endif;
	
	// remove locations that do not match specs
	create objSet transient;
	foreach lc in self.allLotAssignedLocations do
		lr := lc.CM_LogController.myLocationRestriction.CM_LocationRestrictLog;
		if lr &lt;&gt; null then
			if (_species &lt;&gt; null and not lr.allLogSpecies.isEmpty and not lr.allLogSpecies.includes(_species))
			or (_grade &lt;&gt; null and not lr.allLogGrades.isEmpty and not lr.allLogGrades.includes(_grade))
			or (_type &lt;&gt; null and not lr.allLogTypes.isEmpty and not lr.allLogTypes.includes(_type))
			or (_treat &lt;&gt; null and not lr.allLogTreatments.isEmpty and not lr.allLogTreatments.includes(_treat))
			or (_length &lt;&gt; null and not lr.allLogLengths.isEmpty and not lr.allLogLengths.includes(_length)) then
				objSet.add(lc);
			endif;
		endif;
	endforeach;
	foreach obj in objSet do
		self.allLotAssignedLocations.remove(obj.CM_LogController);
	endforeach;
	
	_cmb.listCollection(allLotAssignedLocations, false, 0);

	if _lc &lt;&gt; null and self.allLotAssignedLocations.includes(_lc) then
		_cmb.text := self.displayEntryLocationController(_lc);
	endif;
	
epilog
	delete objSet;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_voy" type="CM_Voyage"/>
        <Parameter name="_species" type="CM_LogSpecies"/>
        <Parameter name="_grade" type="CM_LogGrade"/>
        <Parameter name="_type" type="CM_LogType"/>
        <Parameter name="_treat" type="CM_LogTreatment"/>
        <Parameter name="_length" type="CM_LogLength"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="comboBoxConsigneeConsignor" id="badb3425-bef4-4999-a00c-29dbf23ac8eb">
        <source>comboBoxConsigneeConsignor(_cmb : ComboBox input; _consignee : CM_ConsigneeConsignor);
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	_cmb.listCollection(app.myRoot.allConsigneeConsignors, true, 0);
	
	if _consignee &lt;&gt; null then
		_cmb.text := self.displayEntryConsignor(_consignee);
		if _cmb.text &lt;&gt; null then
			_cmb.listObject := _consignee;
		endif;
	endif;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_consignee" type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHatch" id="77abdf6d-084e-466e-8ad9-9feeb59e0cba">
        <source>comboBoxHatch(pTbl : CM_EntryTable input; pAttrName : String; _numHatches : Integer);
//--------------------------------------------------------------
//Created: April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	str	: String;
	cnt : Integer;
begin
	
	cnt := _numHatches;
	while cnt &gt; 0 do
		str := cnt.String &amp; Tab &amp; str;
		cnt := cnt - 1;
	endwhile;

	pTbl.setComboValues(pTbl.getRow(pAttrName), str);

end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="_numHatches" type="Integer"/>
    </JadeMethod>
