    <JadeMethod name="setJob" id="43c922f8-e5f9-45e4-a31a-0d7b29038b25">
        <updating/>
        <source>setJob(_job: CM_Job) updating;
/*
Purpose:			

Date		Who		Reason
16 February 2022	navab1	TFS 51855
*/

vars

begin
	inheritMethod(_job);
	
	if self.myRequest &lt;&gt; null  // ### TFS 51855 17FEB2022 NAVAB1
	and  self.myRequest.isDLR 
	and self.myRequest.isLinked()
	and self.myRequest.getAttrIsLoad() then
		if app.myPassport.isOpsViewEnabled(self.getMyTerminal()) then
			self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_WLE, self); 
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="setJobSheetAndCompletedRate" id="f344072a-7adc-46e8-bfad-3c9f79a8e1c3">
        <updating/>
        <source>setJobSheetAndCompletedRate() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 Feb 2011	cnwer1	Initial creation
14 Dec 2024 navma1	MTN-33673 SNO - Unable to Discharge any container
*/

vars
	duration,
	totalWLEs,
	compRate	: Integer;
begin
	if  self.job.myJobSheet = null  then
		return;
	endif;
	// check to see if already added into dict
	if self.myJobSheet &lt;&gt; null then
		return;
	endif;

	// this will add to dict, we reset size on dict below
	self.myJobSheet := self.job.myJobSheet;

	if self.completedDate.isValid and self.myJobSheet.workStarted.isValid then					//14.12.2024 navma1 #MTN-33673
		duration  := self.myJobSheet.workStarted.cnSecondsDifference(self.completedDate);
	endif;
	
	totalWLEs := self.myJobSheet.allCompletedWLEsByDate.size;

	self.myJobSheet.setCompletedWLEsByDateSize(totalWLEs); // AKB2004OCT

	self.myJobSheet.setWorkStartedDate(self.completedDate);
	
	// check for divide by zero
	if duration = 0 or totalWLEs = 0 then
		compRate := 1;
	else
		if (duration / totalWLEs) &gt; 0 then
			compRate :=  (SecondsPerHour / (duration / totalWLEs)).Integer;
		endif;
		if compRate &lt; 1 then
			compRate := 1;
		endif;
	endif;
	self.completedRate := compRate;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="eed6151d-cac2-4127-968b-7697f7954cc8">
        <updating/>
        <source>setMyTrackedItem(_ti: CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 15/12/2010	cnwdap1		PAR #26426 CCMS MES 1102 If we have a TBA TI already, delete it
// 14/05/2013	cnwer1		CCMS 2274 refactored 
// 28/11/2013 	cnwer1		CCMS 2323 
vars
	aFM 	: CM_FutureMovePlanned;
	oldTI : CM_TrackedItem;
	voyage : CM_Voyage;
	term : CM_Terminal;
begin
	oldTI:=_ti;
	//inherit to set ti
	inheritMethod(_ti);
	
	//epr ccms 2323 28/11/13
	if job &lt;&gt; null and job.CM_VoyageJob.isLoadedToOperations then
		if oldTI &lt;&gt; _ti then
			self.getVoyage.incrementPlanningVersion();
		endif;		
	endif;	
	
	if _ti &lt;&gt; null and _ti.isRehandle and self.isRehandle() then
		if not self.isReceipt then
		// a LOAD DLR
			aFM := _ti.getFutureMoveOfType(PLANNING_MODE, TI_FutureMoveDLRDischarge).CM_FutureMovePlanned;
			// if there is no DLR Discharge FM yet we cannot know where this load is from
			if aFM &lt;&gt; null then
				// WAS PAR 23152 self.setLocations(aFM.getAllLocationsString(),self.locationTarget);
				self.setLocations(aFM.getPrimaryLocationId(),self.locationTarget);	
			endif;
		endif;
	endif;
	
	if self.isBulkRelease() then // PAR 37122 ship release request
		voyage := self.getVoyage(); // PAR 37122
		term := self.getMyTerminal(); // PAR 37122
		
		if term &lt;&gt; null and voyage  &lt;&gt; null then // PAR 37122
			app.myEventManager.createSingleObjInfoNoteEvt(voyage, term.getTerminalEvent(WLE_Update_Event), self);	 // PAR 37122
		endif;
	endif;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
