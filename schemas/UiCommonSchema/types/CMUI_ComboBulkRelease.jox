    <ImplicitInverseRef name="myTerminal" id="1cda24b4-871a-42fb-80f5-3a26a4cdec46">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <JadeMethod name="displayEntry" id="4a1a00d8-cd1c-46e3-8619-755bd430fd66">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _bulkRelease: CM_BulkRelease; lstIndex: Integer): String updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     13 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tmpBulkRelease,
	tmpBR			 : CM_BulkRelease;
	failedDAC  :CM_DataAccessController;
begin
	tmpBulkRelease := _bulkRelease;

	if tmpBulkRelease = null then
		return null;
	endif;
	
	if tmpBulkRelease.type &lt;&gt; BR_TYPE_ROAD then 
		return null;
	endif;
	
	if tmpBulkRelease.status &lt;&gt; BR_ACTIVE then
		return null;
	endif;
		

	if (not tmpBulkRelease.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;


	tmpBR := tmpBulkRelease.myTerminal.getBulkReleaseFromCode(tmpBulkRelease.code); // ### AKB2005MAY - cope with duplicate codes.
		
	if tmpBR = tmpBulkRelease then
		return tmpBulkRelease.code;
	else
		return tmpBulkRelease.code &amp; Tab &amp; tmpBulkRelease.dateRequested.date.String; // ### AKB2005MAY - cope with duplicate codes.
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="10b00a1f-6acb-47c7-821f-1bb36d4f9a70">
        <source>getCollectionJMT(): Collection protected;
// ---------------------------------------------------------------------------
// Created:     13 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	if self.myTerminal &lt;&gt; null then
		return self.myTerminal.allBulkReleasesByCodeDate;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="ccac617d-93f5-4974-8889-0d76d667cf37">
        <controlMethod name="CMUI_ComboBoxObject::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>windowCreated(cntrl: CMUI_ComboBoxObject input; persistCntrl: CMUI_ComboBoxObject) updating;
// ---------------------------------------------------------------------------
// Created:		20 October 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(cntrl, persistCntrl);
	cntrl.style	:= ComboBox.Style_DropDown;

end;</source>
        <Parameter name="cntrl" type="CMUI_ComboBoxObject" usage="input"/>
        <Parameter name="persistCntrl" type="CMUI_ComboBoxObject"/>
    </JadeMethod>
