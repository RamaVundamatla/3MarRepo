    <JadeMethod name="doUserNote" id="74d207de-b139-481a-95b1-e6a0d1440190">
        <updating/>
        <source>doUserNote(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	event : Integer;
	theFinancialPeriodDateTime : CM_FinancialPeriodDateTime;
	idx,idy,level, idxSt, idxEnd, newIdx : Integer;
	theListBox : ListBox;
begin
	if userInfo.isKindOf(CM_FinancialPeriodDateTime) then
		self.doUserNoteDate(eventType, theObject, eventTag, userInfo);
	elseif userInfo.isKindOf(CM_FinancialPeriodEnd) then
		self.doUserNoteType(eventType, theObject, eventTag, userInfo);
	else
	
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteDate" id="8663b15b-ab9b-4d54-a206-19b11f0c0cf6">
        <updating/>
        <source>doUserNoteDate(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	event : Integer;
	theName : String;
	theFinancialPeriodDateTime : CM_FinancialPeriodDateTime;
	idx,idy,level, idxSt, idxEnd, newIdx : Integer;
	theListBox : ListBox;
begin
	theListBox := self.lstData;

//	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	event := eventType;
	theFinancialPeriodDateTime := userInfo.CM_FinancialPeriodDateTime;
	
	if event = EVENT_FINPERIOD_DELETE then
		idx := self.lstData.findObject(theFinancialPeriodDateTime);
		if self.myCurrentFPDate = theFinancialPeriodDateTime then
			self.myCurrentFPDate := null;
		endif;
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
		endif;
		return;
	endif;
	
	theName := theFinancialPeriodDateTime.getDisplayStringForAttribute(ETRow_Name, false);

	if event = EVENT_FINPERIOD_CREATE then
		// ## insert the new FinancialPeriodDateTime by finding the group then insert under that.
		idx := self.lstData.findObject(theFinancialPeriodDateTime.myFinancialPeriodEnd);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
		endif;
		idx := idx -1;
		self.loadFP(theFinancialPeriodDateTime.myFinancialPeriodEnd, idx);
		newIdx := idx;
		self.loadDates(theFinancialPeriodDateTime.myFinancialPeriodEnd,idx);
		if self.myCurrentFPType = theFinancialPeriodDateTime.myFinancialPeriodEnd then
			self.lstData.itemExpanded[newIdx] := true;
			idx := self.lstData.findObject(theFinancialPeriodDateTime);
			if idx &gt; 0 then
				self.lstData.listIndex := idx;
			endif;
		endif;
/*
		if idx &gt; 0 then
			newIdx := idx + 1;
			theListBox.addItemAt(theName, newIdx);
			theListBox.itemObject[newIdx] := theFinancialPeriodDateTime;
			theListBox.itemLevel[newIdx] := 3;
			theListBox.itemPicture[newIdx] := self.picDate.picture;
		endif;
*/
	elseif event = EVENT_FINPERIOD_UPDATE then
		idx := self.lstData.findObject(theFinancialPeriodDateTime);
		if idx &gt; 0 then
			self.lstData.itemText[idx] := theName ;
		endif;
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteType" id="310cfe92-ce9b-4057-8e93-1690377f3315">
        <updating/>
        <source>doUserNoteType(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	event : Integer;
	theName : String;
	theFinancialPeriodEnd : CM_FinancialPeriodEnd;
	idx,idy,level, idxSt, idxEnd, newIdx,itemLevel : Integer;
	theListBox : ListBox;
	isDefault : Boolean;
begin
	theListBox := self.lstData;

//	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	event := eventType;
	theFinancialPeriodEnd := userInfo.CM_FinancialPeriodEnd;
	
	if event = EVENT_FINPERIOD_DELETE then
		idx := self.lstData.findObject(theFinancialPeriodEnd);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
		endif;
		if self.myCurrentFPType = theFinancialPeriodEnd then
			self.myCurrentFPType := null;
		endif;
		return;
	endif;
	
	theName := theFinancialPeriodEnd.description;
	isDefault := theFinancialPeriodEnd.isDefault;

	if event = EVENT_FINPERIOD_CREATE then
		// ## insert the new FinancialPeriodEnd by finding the group then insert under that.
		idx := self.lstData.findObject(theFinancialPeriodEnd.myBank);
		level := self.lstData.itemLevel[idx] + 1;

		newIdx := idx;
		// ## insert alphabetically under parent.
		idxSt := idx + 1;
		idxEnd := self.lstData.listCount();
		foreach idy in idxSt to idxEnd do
			itemLevel := self.lstData.itemLevel[idy];
			if itemLevel = level then
				if self.lstData.itemText[idy] &gt; theFinancialPeriodEnd.description  then
					newIdx := idy;
					break;
				endif;
			elseif itemLevel &lt; level then
				newIdx := idy;
				break;
			endif;

		endforeach;
		if newIdx = 1 then		
			if newIdx = idxEnd then  //par 22896
				newIdx := newIdx + 1;	//par 22896
			else
				newIdx := idxEnd + 1; // put on the end,		//par 22896
			endif;
		endif;
		if newIdx &gt; 0 then
			theListBox.addItemAt(theName, newIdx);
			theListBox.itemObject[newIdx] := theFinancialPeriodEnd;
			theListBox.itemLevel[newIdx] := level;
			theListBox.itemPicture[newIdx] := self.picRoot.picture;
		endif;
	elseif event = EVENT_FINPERIOD_UPDATE then
		idx := self.lstData.findObject(theFinancialPeriodEnd);
		if idx &gt; 0 then
			if isDefault then
				theName := theName &amp;  " (default)";
			endif;				
			self.lstData.itemText[idx] := theName;
		endif;
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="enableControls" id="926c238c-e74e-4254-8619-2477787a28b6">
        <source>enableControls();
// enableControls(_enable: Boolean);	// cnwrl1 06/11/2009 PAR 192778 - what it was
//-----------------------------------------------------------------------
//	Created:	29 March 2006	by Jason Chapman  (cnwjc2)
//-----------------------------------------------------------------------
vars
	enable	: Boolean;
	
begin
	// cnwrl1 06/11/2009 PAR 19278 - start of coding
	enable						:= app.myPassport.myUser.canDo( null, self.permissionMaint );
	
	self.btnNew.enabled			:= enable and self.myCurrentFPType &lt;&gt; null;
	self.mnuFPDate.enabled		:= self.btnNew.enabled;
	
	self.btnNewType.enabled		:= enable and self.myCurrentFPType = null;
	self.mnuFPType.enabled		:= self.btnNewType.enabled;
	
	self.btnUpdate.enabled		:= enable and ( self.myCurrentFPDate &lt;&gt; null or self.myCurrentFPType &lt;&gt; null );
	self.mnuFPUpdate.enabled	:= self.btnUpdate.enabled;
	
	self.btnDelete.enabled		:= enable and ( self.myCurrentFPDate &lt;&gt; null or self.myCurrentFPType &lt;&gt; null );
	self.mnuFPDelete.enabled	:= self.btnDelete.enabled;
	
	self.btnRefresh.enabled		:= enable;
	
	self.btnBulk.enabled		:= enable; // TFS 2198
	// cnwrl1 06/11/2009 PAR 19278 - end of coding
	
	/* cnwrl1 06/11/2009 PAR 19278 - what it was
	self.btnDelete.enabled		:= _enable;
	self.btnNew.enabled			:= _enable;
	self.btnNewType.enabled		:= _enable;
	self.btnUpdate.enabled		:= _enable;
	self.mnuFPDelete.enabled	:= _enable;
	self.mnuFPType.enabled		:= _enable;
	self.mnuFPDate.enabled		:= _enable;
	self.mnuFPUpdate.enabled	:= _enable;
	cnwrl1 06/11/2009 PAR 19278 - end of what it was */
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDates" id="5b99d657-ed3c-4821-b3d0-f634c536c455">
        <source>loadDates(_fp : CM_FinancialPeriodEnd; _pIDX : Integer io);
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theLevel : Integer;
	aDateTime : CM_FinancialPeriodDateTime;
	theListBox : ListBox;

begin
	theListBox := self.lstData;
	
	foreach aDateTime in _fp.allFinancialPeriodEndDates reversed do
		theLevel := 3;
//		idx := theListBox.addItem(aDateTime.dateTime.String &amp; Tab &amp; aDateTime.remarks);
		_pIDX := _pIDX + 1;
// cnwdad1 18/06/2009 - PAR #19942.
		//theListBox.addItemAt(aDateTime.dateTime.String &amp; Tab &amp; aDateTime.remarks, _pIDX);
		theListBox.addItemAt(aDateTime.dateTime.asStringJMT() &amp; Tab &amp; aDateTime.remarks, _pIDX);
		theListBox.itemObject[_pIDX] := aDateTime;
		theListBox.itemLevel[_pIDX] := theLevel;
		theListBox.itemPicture[_pIDX] := self.picDate.picture;
	endforeach;
end;</source>
        <Parameter name="_fp" type="CM_FinancialPeriodEnd"/>
        <Parameter name="_pIDX" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadDebtors" id="aeea2b80-35e4-4460-b056-7d848f976788">
        <source>loadDebtors();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theDebtorsIn, theDebtorsOut : CM_DebtorByNameDict;
	aDebtor : CM_Debtor;
begin
	create theDebtorsIn transient;
	create theDebtorsOut transient;

	foreach aDebtor in app.myRoot.myRootCompany.debtors
		where aDebtor.myFinancialPeriodEnd = null do
		theDebtorsOut.add(aDebtor);
	endforeach;	

	if self.updateMode = self.UpdateMode_Update then	
		foreach aDebtor in app.myRoot.myRootCompany.debtors do
		// do not show Debtors that have already been chosen by other FPE
			if  aDebtor.myFinancialPeriodEnd = self.myCurrentFPType  then
				theDebtorsIn.add(aDebtor);
			endif;
		endforeach;
	endif;
	theDebtorsIn.copy(theDebtorsOut);
	self.msgPropTwo.setAvailable(theDebtorsOut, true);
	self.msgPropTwo.setSelected(theDebtorsIn);
epilog
	delete theDebtorsIn;
	delete theDebtorsOut;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadFP" id="a3643043-6a10-4ac4-8c10-e58e50c3a83b">
        <source>loadFP(_fp : CM_FinancialPeriodEnd; _pIDX : Integer io);
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theLevel : Integer;
	aDateTime : CM_FinancialPeriodDateTime;
	theListBox : ListBox;
	desc : String;
begin
	theListBox := self.lstData;

	theLevel := 2;
	desc := _fp.description;
	if _fp.isDefault then
		desc := desc &amp; " (default)";
	endif;
//	idx := theListBox.addItem(desc);
	_pIDX := _pIDX + 1;
	theListBox.addItemAt(desc, _pIDX);
	theListBox.itemObject[_pIDX] := _fp;
	theListBox.itemLevel[_pIDX] := theLevel;
	theListBox.itemPicture[_pIDX] := self.picRoot.picture;

end;</source>
        <Parameter name="_fp" type="CM_FinancialPeriodEnd"/>
        <Parameter name="_pIDX" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadPeriods" id="3e0da0d1-7909-4ca4-85b9-3875128e91af">
        <source>loadPeriods();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aFP			: CM_FinancialPeriodEnd;
	idx			: Integer;
	theLevel	: Integer;
	theListBox	: ListBox;
	
begin
	theListBox := self.lstData;
	theListBox.enabled := true;
	theListBox.backColor := White;
	theListBox.clear;
	theListBox.hasTreeLines := true;
	theListBox.hasPlusMinus := true;
	theListBox.defaultLineHeight := 13;
	theListBox.multiSelect := ListBox.MultiSelect_Extended;
	
	theLevel := 1;
	idx := theListBox.addItem("Financial Periods");
	theListBox.itemObject[idx] := app.myRoot.myRootCompany;
	theListBox.itemLevel[idx] := theLevel;
	theListBox.itemPicture[idx] := self.picType.picture;
	theListBox.itemExpanded[idx] := true;
	
	foreach aFP in app.myRoot.myRootCompany.allFinancialPeriods do
		self.loadFP(aFP, idx);
		self.loadDates(aFP,idx);
	endforeach;
	
	self.lstData.listIndex	:= 1;			// cnwrl1 06/11/2009 PAR 19278
	theListBox.itemExpanded[1] := true;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mnuFPDate_click" id="f1dd2276-18c8-405a-a561-829a8cf1995f">
