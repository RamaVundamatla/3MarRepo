epilog

end;</source>
        <Parameter name="default" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="529c9c2d-9cc5-49cf-a085-a6e9595ce3cc">
        <updating/>
        <source>setProxy(_code ,
		 _description,
		 _address1,
		 _address2,
		 _address3,
		 _region,
		 _postCode,
		 _countryCode,
		 _city,
		 _email,
		 _delInstructions : String;
		 _isDefault,
		 _isAlternate	  : Boolean;		 
		 _debtor     	  : CM_Debtor) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
27 June 2022 jlier1 TFS 53678
02 Sept 2022	navkc1	ChangeRequest 54564(54372.020): Alternate address for Debtor
01 May 2023		navra1	TFS 57086 - EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
27 Jan 2025	jlier1  	TFS 33694
*/

vars

begin
	self.isDefault			:= _isDefault;
	self.isAlternative		:= _isAlternate; // 02/09/22	navkc1	#54564(54372.020)
	self.code 				:= _code;
	self.description		:= _description;
	self.addr1 				:= _address1[1:100];
	self.addr2 				:= _address2[1:100];
	self.addr3 				:= _address3[1:100];
	self.postCode 			:= _postCode[1:20];
	self.region 			:= _region[1:60];
	self.countryCode		:= _countryCode[1:4];
	self.myDebtor	 		:= _debtor;
	self.deliveryInstructions:=_delInstructions;
	self.city				:= _city;
	self.email				:= _email;			//navra1 - TFS 57086 - 1st May 2023
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_address1" type="String"/>
        <Parameter name="_address2" type="String"/>
        <Parameter name="_address3" type="String"/>
        <Parameter name="_region" type="String"/>
        <Parameter name="_postCode" type="String"/>
        <Parameter name="_countryCode" type="String"/>
        <Parameter name="_city" type="String"/>
        <Parameter name="_email" type="String"/>
        <Parameter name="_delInstructions" type="String"/>
        <Parameter name="_isDefault" type="Boolean"/>
        <Parameter name="_isAlternate" type="Boolean"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="update" id="5d959a1e-94fb-414a-9c7c-c5e6efe7f59a">
        <updating/>
        <source>update(_addr1, _addr2, _addr3, _postCode, _region, _countryCode : String) updating;
// 31448 add Address to consignor/ee, truncating input if needed
vars

begin
	self.addr1 := _addr1[1:100];
	self.addr2 := _addr2[1:100];
	self.addr3 := _addr3[1:100];
	self.postCode := _postCode[1:20];
	self.region := _region[1:60];
	self.countryCode := _countryCode[1:4];
end;
</source>
        <Parameter name="_addr1" type="String"/>
        <Parameter name="_addr2" type="String"/>
        <Parameter name="_addr3" type="String"/>
        <Parameter name="_postCode" type="String"/>
        <Parameter name="_region" type="String"/>
        <Parameter name="_countryCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="8660f51f-3ea3-4c8b-98e4-874e408a14c2">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
22 Sept 2022	navkc1	ChangeRequest 54564(54372.020): Alternate address for Debtor
21/11/2025	navcs2	MTN-36684 LNX | No validation for Email Address when creating a Debtor, but it exists during update.
*/

vars
	alternateAddress,
	defaultAddress	: CM_Address;
	emails : StringArray;				// 21/11/2025	navcs2	MTN-3668
	emailStr : String;					// 21/11/2025	navcs2	MTN-3668
begin
	if self.code = null then
		app.raiseCMException(Input_required_field_Id,null,null); 
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc,null,null); 
	endif;
	
	if self.myDebtor &lt;&gt; null then
		if self.myDebtor.allAddressesByCode[self.code] &lt;&gt; null then
			app.raiseCMException1(ERR_CANNOT_CREATE_ADDRESS, self.code,null,null);
		endif;
	
		if self.isDefault then
			if self.myDebtor.getDefaultDebtorAddress &lt;&gt; null then
				defaultAddress := self.myDebtor.getDefaultDebtorAddress;
				app.raiseCMException1(ERR_ADDR_ALREADY_DEFAULT, defaultAddress.code,null,null);
			endif;
		endif;
		
		// 02/09/22	navkc1	#54564(54372.020) --&gt;
		if self.isAlternative then
			if self.myDebtor.getDebtorAlternativeAddress() &lt;&gt; null then
				alternateAddress := self.myDebtor.getDebtorAlternativeAddress();
				app.raiseCMException1(ERR_ADDR_ALREADY_ALT, alternateAddress.code ,null,null);
			endif;
		endif;
		// 02/09/22	navkc1	#54564(54372.020) &lt;--
	elseif self.myDeliveryParty &lt;&gt; null then  //jlier1  TFS 53678 27/6/22
		if self.myDeliveryParty.allAddresses[self.code] &lt;&gt; null and  self.myDeliveryParty.allAddresses[self.code] &lt;&gt; self then
			app.raiseCMException1(ERR_CANNOT_CREATE_ADDRESS, self.code,null,null);
		endif;
	
		if self.isDefault then
			defaultAddress := self.myDeliveryParty.getDefaultAddress;
			if defaultAddress &lt;&gt; null and defaultAddress &lt;&gt; self then		
				app.raiseCMException1(There_alrea_defau_addre_this_d, defaultAddress.code,null,null);
			endif;
		endif;
		
	endif;
	
	// 21/11/2025	navcs2	MTN-36684 Start
	if self.email &lt;&gt; null then
		emailStr := self.email.replaceString(",", " ");
		emails := emailStr.getTokens();
		foreach emailStr in emails do
			if not JadeRegex@isMatch(emailStr, EMAILREGEX, true) then
				app.raiseCMException1(Email_address_wrong, emailStr,null,null);
			
			endif;
		endforeach;
	
	endif;
	//21/11/2025	navcs2	MTN-36684 End
epilog
	delete emails;				//26.11.2025 navlc30 #36684
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="dd17659f-2f44-459d-be55-541a06c75926">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle

*/

vars

begin
	if not self.allInvoices.isEmpty then
		app.raiseCMException2(ERR_CANNOT_DELETE_BANK, "Address '" &amp; self.code &amp; "'","It is used by Invoice: " &amp; self.allInvoices.first.sequenceNum.String,null, null);
	endif;
	
	if self.isDefault then
		app.raiseCMException1(ERR_CANNOT_DELETE_ADDR,self.code,null,null);
	endif;
	
	//jlier1 TFS 53678 21/6/22
	if self.allReserveDetails.first &lt;&gt; null then
		app.raiseCMException2(Addre_canno_delet_becau_used_r,self.code,self.allReserveDetails.size.asStringJMT,null,null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="bfaa3a8a-e1d0-4c48-ab14-b792839b61e8">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jul 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
07 Feb 2025	navhl20 Bug MTN-34019: MTN - Getting a 1090 when trying to update a Delivery Party
*/

vars
	realAddress,
	defaultAddress	: CM_Address;
	emails : StringArray;
	emailStr : String;
begin

	if self.isTransient then
		realAddress := self.pxyGetRealObject;
	else
		realAddress := self;
	endif;
	
	if self.code = null then
		app.raiseCMException(Input_required_field_Id,null,null); 
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc,null,null); 
	endif;
	
	if self.myDebtor &lt;&gt; null then
		if self.code &lt;&gt; realAddress.code then
			if self.myDebtor.allAddressesByCode[self.code] &lt;&gt; null then
				app.raiseCMException1(ERR_CANNOT_CREATE_ADDRESS, self.code,null,null);
			endif;
		endif;
		
		if not self.isDefault then
			defaultAddress := self.myDebtor.getDefaultDebtorAddress();
			if defaultAddress &lt;&gt;  null  then
				if defaultAddress.code = self.code then
					app.raiseCMException(ERR_DEBTOR_DEF_ADDRESS,null,null);
				endif;
			endif;
		endif;
	elseif self.myDeliveryParty &lt;&gt; null then //jlier1  TFS 53678 27/6/22
		if realAddress &lt;&gt; null and self.code &lt;&gt; realAddress.code then	//07.02.2025 navhl20 #34019
			if self.myDeliveryParty.allAddresses[self.code] &lt;&gt; null then
				app.raiseCMException1(ERR_CANNOT_CREATE_ADDRESS, self.code,null,null);
			endif;
		endif;	
		if self.isDefault then
			defaultAddress := self.myDeliveryParty.getDefaultAddress;
			if defaultAddress &lt;&gt; null and defaultAddress &lt;&gt; self then		
				app.raiseCMException1(There_alrea_defau_addre_this_d, defaultAddress.code,null,null);
			endif;
		endif;
	endif;
	
	 // ### JIRA 35465 28JUL2025 NAVAB1
	if self.email &lt;&gt; null then
		emailStr := self.email.replaceString(",", " ");
		emails := emailStr.getTokens();
		foreach emailStr in emails do
			if not JadeRegex@isMatch(emailStr, EMAILREGEX, true) then
				app.raiseCMException1(Email_address_wrong, emailStr,null,null);
			
			endif;
		endforeach;
	
	endif;
	
epilog
	delete emails;

end;</source>
    </JadeMethod>
</Class>
