    <JadeMethod name="getDescription" id="ed1962b0-5854-4f39-9f6c-a1e26747eda8">
        <source>getDescription(): String;
// reporting
vars

	typeString	: String;
	id			: String;
	invoice		: CM_Invoice;

begin

	typeString := app.getErrorString(Received);

	if self.myPaymentMethod &lt;&gt; null then
		typeString := self.myPaymentMethod.code &amp; " " &amp; typeString;
	endif;
	// from 33885 show external number as well as invoice number
	id := self.getExternalInvoiceNumber();
	if id &lt;&gt; null then
		typeString := typeString &amp; " " &amp; id;
	endif;
	// extended to show the duty doc number as well
	if self.myTerminal.isDutyDocEnabled() then
		id := self.getDutyDocBillNumber();
		if id &lt;&gt; null then
			typeString := typeString &amp; " Bill Number " &amp; id;
		endif;
	endif;
	invoice := self.getCashInvoice;
	if invoice &lt;&gt; null then
		typeString := typeString &amp; " " &amp; app.getErrorString(INV_Invoice) &amp; " " &amp; invoice.sequenceNum.String;
	endif;
	
	//09 Oct 2018	NDL	TFS 41281
	if self.paymentType &gt; 0 then
		typeString := typeString &amp; " (" &amp; app.paymentTypeEnumToString(self.paymentType) &amp; ") ";
	endif;
	
	if self.myUser &lt;&gt; null then
		typeString := typeString &amp; " " &amp; self.myUser.code;
	endif;

	return typeString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b82be482-23d4-44a9-89bf-22c431b33ed5">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/09/2025	navkc1 JIRA 35574 MTN | Selector Cash Receipt Columns are wrong

*/

vars
	drTerm		: CM_DebtorTerminal;
	debtor		: CM_Debtor;
	returnStr 	: String;
	terminal	: CM_Terminal;
	bank		: CM_Bank;
begin
	
	if _attrName = ETRow_Receipt then
		return self.getExternalInvoiceNumber();
	elseif _attrName = ETRow_Date then
		return self.systemToLocalTime(self.dateTime).asStringJMT();
	elseif _attrName = ETRow_Debtor then
		drTerm := self.getDebtorTerminal();
		
		if drTerm &lt;&gt; null then
			debtor := drTerm.myDebtor;
			
			if debtor &lt;&gt; null then
				returnStr := debtor.name;
			endif;
		endif;
		
		return returnStr;
	elseif _attrName = ETRow_Terminal then
		terminal := self.myTerminal;
		
		if terminal &lt;&gt; null then
			returnStr := terminal.code;
		else
			drTerm := self.getDebtorTerminal();
			
			if drTerm &lt;&gt; null then
				terminal := drTerm.myTerminal;
				
				if terminal &lt;&gt; null then
					returnStr := terminal.code;
				endif;
			endif;
		endif;
		
		return returnStr;
	elseif _attrName = ETRow_Bank then
		bank := self.myBank;
		
		if bank &lt;&gt; null then
			returnStr := bank.code;
		endif;
		
		return returnStr;
	elseif _attrName = ETRow_Exported then
		return app.getYesBlank(self.exportedCount &lt;&gt; 0);
	elseif _attrName = ETRow_Type then
		return self.getDescription().replaceString(Tab, " ");
	elseif _attrName = ETRow_CargoId then
		return null;
	elseif _attrName = ETRow_Detail then
		return null;
	elseif _attrName = ETRow_Narration then
		return null;
	elseif _attrName = ETRow_Amount then
		return self.getTotalChargable().asCurrencyJMT();
	elseif _attrName = ETRow_Tax then
		return self.getTotalChargable().asCurrencyJMT();
	elseif _attrName = ETRow_Total then
		return (self.getTotalChargable() + self.getTotalTaxValue()).asCurrencyJMT();
	elseif _attrName = ETRow_ExternalFinancialId then
		return self.externalFinancialId;
	elseif _attrName = ETRow_ExternalInvoiceNumber then
		return self.externalInvoiceNumber;
	elseif _attrName = ETRow_ExternalReceiptNumber then
		return self.externalReceiptNumber;
	elseif _attrName = ETRow_ExternalTransaction then
		return self.externalTransaction;
	elseif _attrName = ETRow_PaymentStatus then
		return app.paymentStatusCashEnumToString(self.paymentStatus);
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
	elseif _attrName = ETRow_SequenceNumber then
		return self.sequenceNum.asStringJMT();
	elseif _attrName = ETRow_ExternalRef1 then
		return self.externalRef1;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDutyDocBillNumber" id="6d6071ed-9337-4860-b97f-6e2f67e57993">
