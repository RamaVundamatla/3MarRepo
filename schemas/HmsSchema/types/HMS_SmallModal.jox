    <JadeMethod name="doOK" id="90763e79-9247-4a7d-86ce-42be585450b1">
        <updating/>
        <source>doOK() updating;

vars

begin
	modalResult := IDOK;
	unloadForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="handleNotificationRefreshView" id="5c1d61c2-197c-4847-8592-0d7323e16fe7">
        <updating/>
        <source>handleNotificationRefreshView(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars

begin

