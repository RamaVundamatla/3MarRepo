    <JadeMethod name="delayEnd" id="9bb5415b-292f-4f1e-8be5-3fbacd620520">
        <updating/>
        <source>delayEnd(_event :CMEVT_DelayEnd; _machine :CM_Machine)updating;
// ---------------------------------------------------------------------------
// Created:     31 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _event = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Event cannot be null");
	endif;
	
	if _machine = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Machine cannot be null");
	endif;
	
	self.dateTime		:= _event.dateTime;
	self.myDelayEndEvent:= _event;
	
	self.setDetails(CM_MachineHistory.Type_DelayEnd,machine,_event.userCode);
	self.setDelayType;
epilog

end;</source>
        <Parameter name="_event" type="CMEVT_DelayEnd"/>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="delayStart" id="bb43dd5c-a974-4af8-8121-bacdb7fef11a">
        <updating/>
        <source>delayStart(_event :CMEVT_DelayStart; _machine :CM_Machine)updating;
// ---------------------------------------------------------------------------
// Created:     31 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if _event = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Event cannot be null");
	endif;
	
	if _machine = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Machine cannot be null");
	endif;
	
	self.dateTime		:= _event.dateTime;
	self.myDelayStartEvent	:= _event;
	self.setDetails(CM_MachineHistory.Type_DelayStart,machine,_event.userCode);
		
	self.setDelayType;
epilog

end;</source>
        <Parameter name="_event" type="CMEVT_DelayStart"/>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="getDelay" id="69d8f366-8cbb-46d7-ba82-fb33371c6471">
        <source>getDelay():CM_Delay;
// ---------------------------------------------------------------------------
// Created:     01 April 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	type	:Integer;
	event	:CM_EventTransaction;
	delay	:CM_Delay;
begin
	type := self.type;
	
	if type = self.Type_DelayStart then
		event 	:= self.myDelayStartEvent;
		
		if event &lt;&gt; null then
			delay	:= event.CMEVT_DelayStart.myDelay; 
		endif;
	elseif type = self.Type_DelayEnd then
		event 	:= self.myDelayEndEvent;
		
		if event &lt;&gt; null then
			delay	:= event.CMEVT_DelayEnd.myDelay; 
		endif;
	endif;
	
	return delay;
epilog

end;</source>
        <ReturnType type="CM_Delay"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="1f37fd74-d050-47aa-bef0-7048eaa3aeab">
        <source>getDisplayString(): String;
// ---------------------------------------------------------------------------
// Created:     31 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str			:String;
begin
	str := inheritMethod();

	if delayType &lt;&gt; null then
		str := str &amp; Tab &amp; self.delayType;
	endif;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isDelayEndHistory" id="7a656396-20e4-43e5-90c2-2d23605882c8">
        <source>isDelayEndHistory():Boolean;
// ---------------------------------------------------------------------------
// Created:     31 March 2011 by cnwcs5
// Purpose:     Self explanatory
// Parameters:  None
