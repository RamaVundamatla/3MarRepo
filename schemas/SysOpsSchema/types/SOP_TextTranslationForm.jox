    <JadeMethod name="getTotalTableRows" id="386d2133-307c-4d3a-bfa8-f5946a1acfb8">
        <source>getTotalTableRows():Integer protected;

vars
	table 		: CM_TextTranslationTable;
	count		: Integer;
begin
	foreach table in self.allDataTables do
		count := count + (table.rows - tblMessages.fixedRows);
	endforeach;
	
	return count;
end;</source>
