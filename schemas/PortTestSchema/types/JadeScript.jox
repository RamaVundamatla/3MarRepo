    <JadeMethod name="loadAndExtractIniFile" id="86a7ebf8-7983-418b-9dd7-c4007ea02556">
        <source>loadAndExtractIniFile();

vars
	fileIn : File;
	fileOut : File;
	str : String;
	iniFile : CM_IniFile;
	iniObject1, iniObject2 : CM_IniObject;
	iniGroup : CM_IniGroup;
	iniItem : CM_IniItem;
	startPos, endPos : Integer;
	obj : Object;
	iniFileIn : String;
begin
	iniFileIn := "c:\jade.ini\PON-JMT1.ini";
	create fileIn transient;
	fileIn.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
	fileIn.fileName := iniFileIn;
	fileIn.mode := File.Mode_Input;
	fileIn.open;
	create fileOut transient;
	fileOut.fileName := iniFileIn&amp;'s';
	fileOut.mode := File.Mode_Output;
	fileOut.open;
	beginTransaction;
	create iniFile;
	iniFile.name := fileIn.fileName;
	while (not fileIn.endOfFile) do
		str := fileIn.readLine();
		if str &lt;&gt; null then
			while str.pos(Tab, 1) &gt; 0 do
				str.replaceChar(Tab, null);
			endwhile;
			startPos := str.pos('[',1);
			if startPos &gt; 0 then
				endPos := str.pos(']',1);
				create iniGroup;
				iniGroup.myIniFile := iniFile;
				iniGroup.name := str[startPos+1:endPos-2].trimBlanks;
				continue;
			endif;
			startPos := str.pos('=',1);
			if startPos &gt; 0 then
				create iniItem persistent;
				iniItem.myIniGroup := iniGroup;
				iniItem.name := str[1:startPos-1].trimBlanks;
				if startPos &lt; str.length then
					iniItem.value := str[startPos+1:end].trimBlanks;
				endif;
			endif;
		endif;
	endwhile;
	commitTransaction;
	foreach iniFile in CM_IniFile.instances do 
		fileOut.writeLine(iniFile.name);
		foreach iniObject1 in iniFile.allIniGroups do
			iniGroup := iniObject1.CM_IniGroup;
			fileOut.writeLine(null);
			fileOut.writeLine('['&amp;iniGroup.name&amp;']');
			foreach iniObject2 in iniGroup.allIniItems do
				iniItem := iniObject2.CM_IniItem;
				fileOut.writeLine(iniItem.name&amp;' '&amp;'='&amp;' '&amp;iniItem.value);
			endforeach;
		endforeach;
	endforeach;
	fileIn.close;
	fileOut.close;
//	beginTransaction;
//	CM_IniFile.instances.purge;
//	CM_IniGroup.instances.purge;
//	CM_IniItem.instances.purge;
//	commitTransaction;
epilog
	delete fileIn;
	delete fileOut;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadAttributePlan" id="d2642621-8050-4d45-899a-52d0326f1d7b">
        <source>loadAttributePlan(_proxyObject: CM_Object io):Boolean protected;

vars
	realObject, proxyObject: CM_AttributePlan;
	error: CM_Error;
	theUser: CM_User;
	result: Boolean;
begin
	result := false;
	proxyObject := _proxyObject.CM_AttributePlan;
	app.myTrxCA.trxCreateAttributePlan(proxyObject, realObject, app.myPassport);
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.id&amp;" OK";
		result := true;
	else
		foreach error in app.myPassport.allWarnings do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.id&amp;" WARNING: "&amp;error.text;
		endforeach;
		foreach error in app.myPassport.allErrors do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.id&amp;" ERROR: "&amp;error.text;
		endforeach;	
	endif;
epilog
	return result;
end;</source>
        <access>protected</access>
        <Parameter name="_proxyObject" type="CM_Object" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
