    <JadeMethod name="setLocnDefnsToRotate" id="2abc3eec-1419-4bab-85f0-a3f0ad191b21">
        <updating/>
        <source>setLocnDefnsToRotate(_isPlannedRotated : Boolean; _myPreRotatePoints : PointArray; _locns : CM_RORODeckItemByOrd1Ord2) updating;
/*
Purpose:			
Date		Who		Reason
14 July 2011	cnwab1	Initial creation
*/

vars

	isOOTLLocn : Boolean;
	locnDefn : CM_DeckItem;
begin
	isOOTLLocn := self.isOOTL();


	if self.isPlannedRotated &lt;&gt; _isPlannedRotated then
		// Un rotate
		if self.isPlannedRotated then // currently am planned rotated so unrotate me
			if not self.isOOTL() then // PAR 28886   do not disconnect OOTL 40 from their aft
//				self.myAdjacentSlotFwd := self.myPreRotateFwdLocn;
//				self.myAdjacentSlotAft := self.myPreRotateAftLocn;
				
				
//#########

			// PAR 28990 
			if self.myPreRotateAftLocn &lt;&gt; null then
				self.myPreRotateAftLocn.setFwdLocn(null);
				// If my pre rotate aft is now itself rotated, link to it's clone
				if self.myPreRotateAftLocn.myRotateLoad &lt;&gt; null then
					self.myPreRotateAftLocn.myRotateLoad.setFwdLocn(null);
					self.setAftLocn(self.myPreRotateAftLocn.myRotateLoad);
				else
					// If my pre rotate aft is NOT rotated, link to it my pre rotate forward
					self.setAftLocn(self.myPreRotateAftLocn);
				endif;
			endif;
			if self.myPreRotateFwdLocn &lt;&gt; null then
				self.myPreRotateFwdLocn.setAftLocn(null);
				// If my pre rotate forward is now itself rotated, link to it's clone
				if self.myPreRotateFwdLocn.myRotateLoad &lt;&gt; null then
					self.myPreRotateFwdLocn.myRotateLoad.setAftLocn(null);
					self.setFwdLocn(self.myPreRotateFwdLocn.myRotateLoad);
				else
				// If my pre rotate forward is NOT rotated, link to it my pre rotate forward
					self.setFwdLocn(self.myPreRotateFwdLocn);
				endif;
			endif;

//#########
				
				
				
			endif;
			self.isPlannedRotated := false;
			self.setOppositeOrientation();
		else // Rotating
			self.myPreRotateFwdLocn := self.myAdjacentSlotFwd;
			self.myPreRotateAftLocn := self.myAdjacentSlotAft;
			
/* PAR 28968 we are now doing this outside the loop, else the next location has nulls			
			if not self.isOOTL() then // PAR 28886 do not disconnect OOTL 40 from their aft
				self.myAdjacentSlotFwd := null;
				self.myAdjacentSlotAft := null; // PAR 28880
			endif;
			*/
			self.isPlannedRotated := true;
			self.setOppositeOrientation();
			
			if self.myPreRotatePoints = null then
				create self.myPreRotatePoints;
			endif;
			
			_myPreRotatePoints.copy(self.myPreRotatePoints);
			
			// PAR 31129 DMAST ONLY 821 - self.allPlannedRotatedLocnDefns.clear();
			self.clearAllPlannedRotatedLocnDefn();
			if _locns &lt;&gt; null then
				// PAR 31129 DMAST ONLY 821 - _locns.copy(self.allPlannedRotatedLocnDefns);
				foreach locnDefn in _locns discreteLock do
					locnDefn.CM_ROROLocnDefn.setMyPlannedRotatedMaster(self);
				endforeach;
			endif;

		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="_isPlannedRotated" type="Boolean"/>
        <Parameter name="_myPreRotatePoints" type="PointArray"/>
        <Parameter name="_locns" type="CM_RORODeckItemByOrd1Ord2"/>
    </JadeMethod>
    <JadeMethod name="setMyPlannedRotatedMaster" id="82a8ea82-9a22-42a7-81fe-0215c9daeb83">
