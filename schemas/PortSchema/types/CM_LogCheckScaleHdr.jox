// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := self.dateTime.date();
end;</source>
        <Parameter name="set" type="Boolean"/>
