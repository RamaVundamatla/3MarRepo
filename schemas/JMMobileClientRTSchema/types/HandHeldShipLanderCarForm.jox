    <JadeMethod name="doMove" id="7ecb6b0d-84c1-406d-ba8b-7741337ed29a">
        <updating/>
        <source>doMove() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	errorMsgs		: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	numWLEs			: Integer;
	error			: DTO_HandHeldGateError;
	mess, primLocn : String;
	theTI : CM_TrackedItem;
	yc : CM_YardController;
	dPort : String;
begin

	if not app.myHandHeldCarGuiAgent.myHandHeldCarAgent.haveValidDetails() then
		app.msgBox("Please enter a valid voyage and a valid location",'Errors occurred', MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	create errorMsgs transient;
	self.doClearErrors();

	app.myHandHeldCarGuiAgent.doMoveTI(self.txtAltID.text.trimBlanks(), self.txtVehicle.text.trimBlanks(),errorMsgs);

	
	if (not errorMsgs.isEmpty) then
		self.doApplyErrors(errorMsgs);
		if self.txtWrongData.text &lt;&gt; null then
			app.msgBox('Errors occured whilst processing this job. They will now be displayed','Errors occurred', MsgBox_Exclamation_Mark_Icon);
			self.fldMain.topSheet := self.shtError;
			self.fldMain.zOrder(1);
		endif;
	else
		dPort := app.myHandHeldCarGuiAgent.myHandHeldCarAgent.getTIPort();
		if dPort &lt;&gt; null then
			app.msgBox(CrLf &amp; 'Discharge Port : ' &amp; CrLf &amp; CrLf &amp; dPort,'Job Success', MsgBox_Exclamation_Mark_Icon);
		else
			app.msgBox('Job processing successful.' &amp; CrLf &amp; mess,'Job Success', MsgBox_Exclamation_Mark_Icon);
		endif;
		
		
		self.txtVehicle.text := null;
		if self.doAutoTab then
			self.txtLocation.text := null;
		endif;
		self.txtAltID.text := null;
		
		self.fldMain.topSheet := self.shtError;
		self.fldMain.topSheet := self.shtJobs;
		
	endif;
	
epilog
	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
		delete errorMsgs;
	endif;
	self.setLogicalFocus();

end;





</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSendAlertTXTToControl" id="66c34f63-1b3b-47c3-bba2-9e2e01e79737">
