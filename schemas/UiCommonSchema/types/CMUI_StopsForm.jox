    <JadeMethod name="refreshFormWithMessage" id="5fad7a25-c44c-44a6-9991-9d4799dbc878">
        <updating/>
        <source>refreshFormWithMessage() updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 July 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// display message saying things have changed
	app.msgBox(app.getErrorString1(Stops_Updated_Another_User, self.caption), 
						app.getErrorString (Warning), 
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	// reload form
	self.resetFirstChangeFlag;
	self.loadStops (self.getCurrentObject);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setExpiryDateForRow" id="a0ef5e39-607f-4785-859e-bf6f4892129c">
        <source>setExpiryDateForRow(_table: CM_DataTable input; _row: Integer) protected;
// ---------------------------------------------------------------------------
// Created:     22 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

