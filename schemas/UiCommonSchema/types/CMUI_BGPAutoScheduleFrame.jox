		self.tblT.setValueByName(ETRow_RecurNumber, self.myProxyAutoSchedule.recurValue);
		self.tblT.setValueByName(ETRow_RecurType, self.myProxyAutoSchedule.recurUnit);	
		self.cmbTimeUnit.listIndex := self.cmbTimeUnit.findStringExact(1, self.myProxyAutoSchedule.recurUnit);
	else
