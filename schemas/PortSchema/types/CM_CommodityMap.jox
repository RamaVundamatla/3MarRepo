    <JadeMethod name="getServiceBroker" id="2d787ba6-3149-4c36-8c13-d8ff62e92dfd">
        <source>getServiceBroker(transaction: CM_TITransaction): CM_ServiceBroker;

/*
Date		Who		Reason
12/03/2024	navkc1 	Bug 62879: MTN - Move Transaction Performance
18 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/
vars
	serviceBroker			: CM_ServiceBroker;
	strGrossFromLocation	: String;
	strGrossToLocation		: String;
	sourceTA, 
	targetTA 				: String;
	canLogExtra				: Boolean;
begin
	
	canLogExtra	:= app.canLogExtraDetail();
	
	if transaction.class &lt;&gt; CM_Move then

		serviceBroker := self.allTransServiceBrokersByType[transaction.type];
		if serviceBroker &lt;&gt; null then
			if canLogExtra then
				app.invLog("Transaction map found for " &amp; transaction.typeString, LogINFO.String);  								// navlw1 #MTN-33107
			endif;
		endif;
	else
		
		//12/03/2024	navkc1 Bug 62879 - if don't have any mapping, just return the default one. Building up location string and look up an empty collection is wasting time
		if self.moveMap.isEmpty() then
			if canLogExtra then
				app.invLog("Transaction map for DEFAULT", LogINFO.String);  														// navlw1 #MTN-33107
			endif;
			return self.getDefaultServiceBroker();
		endif;
		
		sourceTA := transaction.CM_Move.getInvMoveSourceString();
		targetTA := transaction.CM_Move.getInvMoveTargetString();
		
		serviceBroker := moveMap[sourceTA, targetTA];
		if serviceBroker &lt;&gt; null then
			if canLogExtra then
				app.invLog("Transaction map for MOVE " &amp; sourceTA &amp; " to " &amp; targetTA, LogINFO.String);  							// navlw1 #MTN-33107
			endif;
		endif;
		
		if serviceBroker = null then
			strGrossToLocation  := getGrossTerminalArea(targetTA);
			serviceBroker 		:= moveMap[sourceTA, strGrossToLocation];
			if serviceBroker &lt;&gt; null then
				if canLogExtra then
					app.invLog("Transaction map for MOVE " &amp; sourceTA &amp; " to " &amp; strGrossToLocation, LogINFO.String); 				// navlw1 #MTN-33107
				endif;
			endif;
		endif;

		if serviceBroker = null then
			strGrossFromLocation := getGrossTerminalArea(sourceTA);
			serviceBroker        := moveMap[strGrossFromLocation, targetTA];
			
			if serviceBroker &lt;&gt; null then
				if canLogExtra then
					app.invLog("Transaction map for MOVE " &amp; strGrossFromLocation &amp; " to " &amp; targetTA, LogINFO.String);  			// navlw1 #MTN-33107
				endif;
			endif;
		endif;

		if serviceBroker = null then
			serviceBroker := moveMap[strGrossFromLocation, strGrossToLocation];
			if serviceBroker &lt;&gt; null then
				if canLogExtra then
					app.invLog("Transaction map for MOVE " &amp; strGrossFromLocation &amp; " to " &amp; strGrossToLocation, LogINFO.String);  // navlw1 #MTN-33107
				endif;
			endif;
		endif;
	endif;		

	if serviceBroker = null then
		if canLogExtra then
			app.invLog("Transaction map for DEFAULT", LogINFO.String); 												 			// navlw1 #MTN-33107
		endif;
		serviceBroker := self.getDefaultServiceBroker();
	endif;

	return serviceBroker;

end;</source>
        <Parameter name="transaction" type="CM_TITransaction"/>
        <ReturnType type="CM_ServiceBroker"/>
    </JadeMethod>
    <JadeMethod name="getServiceBrokerFromStrings" id="e9f40d0e-c1a8-45cd-9714-0f3ddecaf2a8">
