<Class name="CM_QRefTITransactionMethod" id="74f9f205-80bd-4e52-b7a5-738c73f68bd7">
    <superclass name="CM_QReferenceMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="43c78cf7-31d2-4c60-96a9-08a5ea219fc6">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		TFS#			Reason
========================================================================
19 June 2015	cnwndl1	Par 36338		Initial creation	
28 August 2018	jlgka1	40200			Remove "equal to" Operation.
========================================================================
*/

vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
	
	self.allAllowedOperators.purge();
	
	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);


end;</source>
    </JadeMethod>
