    <JadeMethod name="createInitialTrackedItem" id="aaf59d83-bf0b-4df6-9fe2-8a9d63abd1f3">
        <source>createInitialTrackedItem();
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 April 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	count : Integer;
	//lc : CM_TILCRow;
begin
	/*create ti with 
		- num of controllers 
		- length
		- height
		- weight
		
		- also if intial move to location and with operator
	
		create ti as self.myCargoType.myClassToCreate persistent;
	
		if ti.isKindOf(CM_TILC) then
			ti.setMyType(self);
			foreach count in 1 to self.numOfController do
				create lc  persistent;
				lc.setMYTILC(ti);
			endforeach;
		
		endif;
	
	*/

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="fc02ed15-d021-4e2e-973c-b3d2b0872bbf">
        <updating/>
        <source>delete() updating;
/*

Date		Who		Reason
14 Jan 2015	cnwkpd1	tidy up YA data objects using this trailer type
	
*/
vars
	yaType 		: CM_YATypeTrailerType;
	
begin
	if not self.isTransient then
		yaType := CM_YATypeTrailerType.firstInstance();
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(self);
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayForXlation" id="a5808535-31b0-4d77-a34a-31fe31705fa8">
        <source>displayForXlation(_codeFirst: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
12 June 2023		jlizm1	Initial creation TFS 58500 add EDI Xlation for Operational Instruction and trailer type

*/

vars

begin
	if _codeFirst then
		return self.code.trimBlanks&amp;' ['&amp;self.description.trimBlanks&amp;']';
	else
		return self.description.trimBlanks&amp;' ['&amp;self.code.trimBlanks&amp;']';
	endif;
	
epilog

end;</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
