    <JadeMethod name="set" id="7f666878-a8e3-45b4-b5a4-fe95407e7586">
        <updating/>
        <source>set(pFileRecord:JSSFileRecord;
	pFieldNo:Integer;
	pFieldName:String;
	pFieldValue:String;
	pIsValid:Boolean) updating;
// --------------------------------------------------------------------------------
// Purpose:		Public interface to set the Field properties.
//
// Parameters:	None
// Returns:		Nothing
// --------------------------------------------------------------------------------
begin
	if self.fieldNo &lt;&gt; pFieldNo then
		self.fieldNo	:=	pFieldNo;
	endif;

	self.fieldName		:=	pFieldName;
	self.fieldValue		:=	pFieldValue;
	self.isValid		:=	pIsValid;
	self.myFileRecord	:=	pFileRecord;
end;</source>
        <Parameter name="pFileRecord" type="JSSFileRecord"/>
        <Parameter name="pFieldNo" type="Integer"/>
        <Parameter name="pFieldName" type="String"/>
        <Parameter name="pFieldValue" type="String"/>
        <Parameter name="pIsValid" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFieldName" id="196c9230-b9b2-41b3-bee4-ca22b51f3dac">
        <updating/>
        <source>setFieldName(value:String) updating;
// --------------------------------------------------------------------------------
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
// --------------------------------------------------------------------------------
