    <JadeMethod name="xmlDef_Stops" id="71cfd5a3-ec43-4c43-8289-d10907a54b95">
        <source>xmlDef_Stops(_userDefined : String) : String protected;
//
//Purpose:	This method contains the required EDI User File Type Definition XML for test 
//
vars
	xmlBlock : String;
begin
	xmlBlock :=
'&lt;CM_EDIFileTypeUser&gt;
&lt;CM_EDIFileTypeUserAttributes&gt;
&lt;applyTranslations&gt;false&lt;/applyTranslations&gt;
&lt;controlColumn&gt;0&lt;/controlColumn&gt;
&lt;dataType&gt;29&lt;/dataType&gt;
&lt;dateDelimeter&gt;&lt;/dateDelimeter&gt;
&lt;dateFormat&gt;&lt;/dateFormat&gt;
&lt;delimiter&gt;,&lt;/delimiter&gt;
&lt;emailActive&gt;false&lt;/emailActive&gt;
&lt;emailNumLinesToSearch&gt;1&lt;/emailNumLinesToSearch&gt;
&lt;emailSearchWords&gt;Stop Unit Testing Keywords&lt;/emailSearchWords&gt;
&lt;fileType&gt;1&lt;/fileType&gt;
&lt;isLoadList&gt;false&lt;/isLoadList&gt;
&lt;name&gt;' &amp; _userDefined &amp; '&lt;/name&gt;
&lt;numLinesToIgnore&gt;1&lt;/numLinesToIgnore&gt;
&lt;permission&gt;0&lt;/permission&gt;
&lt;type&gt;87&lt;/type&gt;
&lt;/CM_EDIFileTypeUserAttributes&gt;
&lt;CM_EDIFileTypeUserReferences&gt;
&lt;/CM_EDIFileTypeUserReferences&gt;
&lt;CM_EDIFileTypeUserCollections&gt;
&lt;allEDIFieldMappingTypes&gt;
&lt;CM_EDIFieldMappingType&gt;
&lt;CM_EDIFieldMappingTypeAttributes&gt;
&lt;controlValue&gt;&lt;/controlValue&gt;
&lt;ediDataType&gt;29&lt;/ediDataType&gt;
&lt;/CM_EDIFieldMappingTypeAttributes&gt;
&lt;CM_EDIFieldMappingTypeReferences&gt;
&lt;/CM_EDIFieldMappingTypeReferences&gt;
&lt;CM_EDIFieldMappingTypeCollections&gt;
&lt;allEDIFieldMappings&gt;
&lt;CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMappingAttributes&gt;
&lt;allStripChars&gt;&lt;/allStripChars&gt;
&lt;fieldDescr&gt;Stop Action&lt;/fieldDescr&gt;
&lt;fieldNum&gt;1&lt;/fieldNum&gt;
&lt;length&gt;0&lt;/length&gt;
&lt;propName&gt;stopAction&lt;/propName&gt;
&lt;usePreviousValueIfNull&gt;false&lt;/usePreviousValueIfNull&gt;
&lt;userDesc&gt;Stop Action&lt;/userDesc&gt;
&lt;/CM_EDIFieldMappingAttributes&gt;
&lt;/CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMappingAttributes&gt;
&lt;allStripChars&gt;&lt;/allStripChars&gt;
&lt;fieldDescr&gt;Cargo Type Descr&lt;/fieldDescr&gt;
&lt;fieldNum&gt;2&lt;/fieldNum&gt;
&lt;length&gt;0&lt;/length&gt;
&lt;propName&gt;cargoTypeDescr&lt;/propName&gt;
&lt;usePreviousValueIfNull&gt;false&lt;/usePreviousValueIfNull&gt;
&lt;userDesc&gt;Cargo Type Descr&lt;/userDesc&gt;
&lt;/CM_EDIFieldMappingAttributes&gt;
&lt;/CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMappingAttributes&gt;
&lt;allStripChars&gt;&lt;/allStripChars&gt;
&lt;fieldDescr&gt;ID&lt;/fieldDescr&gt;
&lt;fieldNum&gt;3&lt;/fieldNum&gt;
&lt;length&gt;0&lt;/length&gt;
&lt;propName&gt;id&lt;/propName&gt;
&lt;usePreviousValueIfNull&gt;false&lt;/usePreviousValueIfNull&gt;
&lt;userDesc&gt;ID&lt;/userDesc&gt;
&lt;/CM_EDIFieldMappingAttributes&gt;
&lt;/CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMappingAttributes&gt;
&lt;allStripChars&gt;&lt;/allStripChars&gt;
&lt;fieldDescr&gt;Stop Code&lt;/fieldDescr&gt;
&lt;fieldNum&gt;4&lt;/fieldNum&gt;
&lt;length&gt;0&lt;/length&gt;
&lt;propName&gt;stopCode&lt;/propName&gt;
&lt;usePreviousValueIfNull&gt;false&lt;/usePreviousValueIfNull&gt;
&lt;userDesc&gt;Stop Code&lt;/userDesc&gt;
&lt;/CM_EDIFieldMappingAttributes&gt;
&lt;/CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMapping&gt;
&lt;CM_EDIFieldMappingAttributes&gt;
&lt;allStripChars&gt;&lt;/allStripChars&gt;
&lt;fieldDescr&gt;Additional Required Informatio&lt;/fieldDescr&gt;
&lt;fieldNum&gt;5&lt;/fieldNum&gt;
&lt;length&gt;0&lt;/length&gt;
&lt;propName&gt;deliveryReleaseNumber&lt;/propName&gt;
&lt;usePreviousValueIfNull&gt;false&lt;/usePreviousValueIfNull&gt;
&lt;userDesc&gt;Additional Required Informatio&lt;/userDesc&gt;
&lt;/CM_EDIFieldMappingAttributes&gt;
&lt;/CM_EDIFieldMapping&gt;
&lt;/allEDIFieldMappings&gt;
&lt;allEDIFieldHookCodes&gt;
&lt;/allEDIFieldHookCodes&gt;
&lt;/CM_EDIFieldMappingTypeCollections&gt;
&lt;/CM_EDIFieldMappingType&gt;
&lt;/allEDIFieldMappingTypes&gt;
&lt;/CM_EDIFileTypeUserCollections&gt;
&lt;/CM_EDIFileTypeUser&gt;';
	
	return xmlBlock;
	
epilog
	
end;
</source>
