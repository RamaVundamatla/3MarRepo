<Class name="NR_NodeDiskSpaceRequest" id="27bdee54-4c29-4804-816f-4854e17dbbfd">
    <superclass name="NR_NodeRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="nodereq"/>
    <PrimAttribute name="alertFreeDisk" id="b6ce7213-a470-4e88-947d-a1585dca738d">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="actionOnTargetNode" id="62278edb-49b4-4859-b2f3-43be0e3664df">
        <updating/>
        <source>actionOnTargetNode() updating;
// -------------------------------------------
// Created 12 September 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	on Exception do self.exHandler(exception);
	self.setupFoldersToList();
	beginTransaction;
	self.allLogEntries.clear();
	commitTransaction;
	self.checkDrives();
	self.causeEvent(NR_NodeDiskSpaceRequest.NR_NodeRequestCompleteEvent, true, null);

end;</source>
    </JadeMethod>
    <JadeMethod name="checkDrives" id="5394d0e3-8c62-49aa-a389-0b6df809f23c">
        <updating/>
        <source>checkDrives() protected, updating;
// -------------------------------------------
// Created 15 September 2003 by cnwdvb1
// -------------------------------------------
constants

	MEGABYTE	= (1024 * 1024);
vars

	str,
	drive		: String;
	array		: StringArray;
	freeSpaceOnDisk, totalBytestOnDisk, totalFreeBytesOnDisk : Decimal[20];

begin

	create array transient;
	foreach str in self.allFoldersToList do
		drive := str[1:1].toUpper;
		if not array.includes(drive) then
			array.add(drive);
		endif;		
	endforeach;
	
	foreach drive in array do
		app.getFreeSpaceForDisk(drive &amp; ':\', freeSpaceOnDisk, totalBytestOnDisk, totalFreeBytesOnDisk, false);
		if (freeSpaceOnDisk &lt; self.alertFreeDisk) and freeSpaceOnDisk &lt;&gt; 0 then
			self.logEntry(app.getErrorString4(Err_DBSpace, drive, app.getErrorString(App_Server), process.node.name, freeSpaceOnDisk.roundedTo(0).String));
		else
			// This ends up in a log file.
			self.logEntry('*_*There is ' &amp; freeSpaceOnDisk.roundedTo(0).String &amp; ' Megabytes of space available on drive ' &amp; drive &amp; ' for App Server machine ' &amp; process.node.name);
		endif;
	endforeach;
	
epilog	
	delete array;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sendRequest" id="978dd86f-7e08-4eab-9a8e-e0843c25f081">
        <updating/>
        <source>sendRequest(_useCardLogDir, _useJadeLogDir, _useJadeCrashLogDir, _useTempDir : Boolean; _freeDisk : Real) updating;
// -------------------------------------------
// Created 12 September 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	self.useCardLogDir		:= _useCardLogDir;
	self.useJadeLogDir		:= _useJadeLogDir;
	self.useJadeCrashLogDir	:= _useJadeCrashLogDir;
	self.useTempDir			:= _useTempDir;
	self.alertFreeDisk		:= _freeDisk;
end;</source>
        <Parameter name="_useCardLogDir" type="Boolean"/>
        <Parameter name="_useJadeLogDir" type="Boolean"/>
        <Parameter name="_useJadeCrashLogDir" type="Boolean"/>
        <Parameter name="_useTempDir" type="Boolean"/>
        <Parameter name="_freeDisk" type="Real"/>
    </JadeMethod>
</Class>
