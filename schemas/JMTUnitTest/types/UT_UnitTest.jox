	delete self.allTerminalsUsed;
	delete self.allSavedTermCargoMapsLocal;						// 20/03/2013 cnwmh5
	delete self.myMergeIter;									// 24/11/2014 cnwmh5
	delete self.leakChecker;
	self.testResults.purge;
	delete self.testResults;
	if self.isKindOf(UT_Helper) then
		return;
	endif;
	app.setLogger(null);
end;</source>
