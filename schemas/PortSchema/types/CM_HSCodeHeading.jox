    <JadeMethod name="shouldAuditProperty" id="548bc727-4633-4d8e-b424-f8493efc772a">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if 	propName = CM_HSCodeHeading::allHSCodes.name or
		propName = CM_HSCodeHeading::myHSChapter.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="7bafe10a-1cc4-49eb-bf91-0fab614c94db">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	inheritMethod();
	
	self.validateForUpdate();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="b349ca25-78d6-4ee4-ad15-e8867ae57b30">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	realHS,
	exisitngHS : CM_HSCodeHeading;
	chapter : CM_HSCodeChapter;
	
begin
	inheritMethod();
	
	if self.id = null then
		app.raiseCMException(Input_required_field_Id, null, null);
		return;
	endif;
	
	if self.id.length &lt;&gt; 4 then
		app.raiseCMException2(Field_length_characters_long, self.id &amp; ": " &amp; app.getErrorString(Id), "4", null, null);
	endif;
	
	if self.myHSChapter = null then
		chapter := app.myRoot.allHSChapters[self.id[1:2]];
		if chapter = null then
			app.raiseCMException2(Related_obj_does_not_exist, app.getErrorString(Chapter), self.id[1:2], null, null);
		endif;
	endif;
	
	realHS := self.pxyGetRealObject();
	exisitngHS := app.myRoot.allHSHeadings[self.id];
	
	if exisitngHS &lt;&gt; null and (realHS = null or exisitngHS &lt;&gt; realHS) then
		app.raiseCMException3(ERR_DuplicateItemWith, app.getErrorString(Heading), app.getErrorString(Id), self.id, null, null);
		return;
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
