    <JadeMethod name="doBulkCombo" id="3390e62e-974f-4637-befe-64343aad799d">
        <updating/>
        <source>doBulkCombo() protected, updating;

// cnwdvb1 29 November 2002 

vars

	theDate : Date;

begin

	theDate := self.tblSelection.getValueByName(ETRow_DateTime).String.asDateJMT();
	if theDate &lt;&gt; null then
		self.myTerminal.getAllBulkLogsForTypeDate(self.allBulkRejects, TRANS_TYPE_REJECT, theDate);
		if self.allBulkRejects.size &gt; 0 then
			self.myAssistant.comboBoxBulkTisAudit(self.allBulkRejects, self.cmbStockMovement, self.myBulk);
			return;
		endif;
	endif;

	self.cmbStockMovement.clear();
	self.tblSelection.setValueByName(ETRow_StockMovement, null);
	self.myBulk := null;

end;</source>
        <access>protected</access>
    </JadeMethod>
