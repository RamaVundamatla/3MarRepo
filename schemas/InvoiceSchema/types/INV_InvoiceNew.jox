    <JadeMethod name="setMyCaption" id="47ab8c08-e0d4-4a4b-b7ba-60d34379f4f2">
        <updating/>
        <source>setMyCaption() protected, updating;
/*

Purpose:			Sets the caption on the form to include the bank as well as terminal

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
03 October 2022	navpw1	Initial creation TFS: 54565 (54384)
20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes
*/

vars
	theCaption	: String;
	
begin
	//20/07/2023	navkc1	Bug 58995
	if self.isCreditNote then
		theCaption := app.getErrorString(INV_CreditNote_New);
	else
		theCaption := app.getErrorString(INV_Invoice_New);
	endif;
	theCaption &amp;= " " &amp; self.myCurrentBank.code;
	self.caption := theCaption;
	self.setCaption(theCaption);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
