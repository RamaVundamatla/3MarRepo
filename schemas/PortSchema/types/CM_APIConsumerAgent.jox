<Class name="CM_APIConsumerAgent" id="99521986-bf70-4aa4-ae2f-e029a65e2f86">
    <superclass name="CM_ExtWebServiceConsumerAgent"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
