    <JadeMethod name="loadGateAreaUsage" id="e10f11db-d282-49ca-8f17-aa547a85793b">
        <source>loadGateAreaUsage(_usage :CM_GateAreaUsage)protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	table	:CM_DataTable;
	area	:CM_GateArea;
	str		:String;
	row		:Integer;
begin 
	table 	:= tblGateAreas; 
	str		:= _usage.getAttributeStringForDefArray(table.allTblDataEntRows);
	
	row := table.addItemObject (_usage, str);
	
	self.setGateAreaPicture (_usage, row);
	
	// the id field can be changed for any gate areas that are being added
	area	:= _usage.myGateArea;

	if area.pxyIsProxy and area.pxyGetRealObject &lt;&gt; null then
		// existing gate area
		table.accessCell (row, table.getColumnByRowName (ETRow_Area_id)).inputType	:= Table.InputType_None;
	elseif self.mode = self.Mode_Add or self.mode = self.Mode_Update then
		// new gate area
		table.accessCell (row, table.getColumnByRowName (ETRow_Area_id)).cellControl	:= txtAreaID;
		table.accessedCell.maxLength	:= 6;	
	else
		// not in add/edit mode
		table.accessCell (row, table.getColumnByRowName (ETRow_Area_id)).inputType	:= Table.InputType_None;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_usage" type="CM_GateAreaUsage"/>
    </JadeMethod>
    <JadeMethod name="loadGateAreas" id="a851170c-eb68-4bcf-b5e6-fa4998757e4f">
        <source>loadGateAreas(_gate :CM_Gate)protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/10/2012	cnwcs5	par 30629 - clear out selected objects before loading table
// ---------------------------------------------------------------------------
vars
	table	:CM_DataTable;
	usage	:CM_GateAreaUsage;
	col		:Integer;
begin 
	table := tblGateAreas;
	// clear any data in table
	table.clearAllSelected;			// par 30629 October 2012
	
	table.rows	:= table.fixedRows;
	
	foreach usage in _gate.allGateAreas_IN do
		self.loadGateAreaUsage (usage);
	endforeach;
	
	foreach usage in _gate.allGateAreas_OUT do
		self.loadGateAreaUsage (usage);
	endforeach;
	
	// set alignment for some columns
	col := table.getColumnByRowName (ETRow_Area_in_out);
	
	if col &gt; 0 then
		table.accessColumn(col).alignment := Table.Alignment_Center_Middle;
	endif;
	
	col := table.getColumnByRowName (ETRow_Area_Type);
	
	if col &gt; 0 then
		table.accessColumn(col).alignment := Table.Alignment_Center_Middle;
	endif;
	
	col := table.getColumnByRowName (ETRow_Area_laneCount);
	
	if col &gt; 0 then
		table.accessColumn(col).alignment := Table.Alignment_Center_Middle;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_gate" type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="loadGateLanes" id="125af55c-9d07-4127-851f-c6c040377fea">
        <source>loadGateLanes()protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/07/2022	navmd1	TFS 52773 Tidy up/review code
// ---------------------------------------------------------------------------
constants
	
vars
	table		:CM_DataTable;
	usage		:CM_GateAreaUsage;
	gateArea	:CM_GateArea;
	lc			:CM_LocationsController;
	lane		:CM_GateAreaLaneController;
	row, col	:Integer;
	laneId		:String;
	printer		:CM_PrinterDef;
	reader		:CM_RFIDTagReader;
	boom		:CM_Boom;
	kiosk		:CM_Kiosk;
begin 
	table		:= tblGateAreas; 
	
	if table.row &lt;= table.fixedRows then
		tblGateLanes.rows := tblGateLanes.fixedRows;
		return;	// no areas in table
	endif;
	
	// get the selected gate area
	usage		:= table.accessRow (table.row).itemObject.CM_GateAreaUsage;
	gateArea	:= usage.myGateArea;
	
	// now load the lanes
	table		:= tblGateLanes;
	table.rows	:= table.fixedRows;
	
	// some columns not valid for all gate area types

	if gateArea.laneCount = 0 then
		table.hideColumnByColName (ETRow_Lane_in);
		table.hideColumnByColName (ETRow_Lane_out);
		table.hideColumnByColName (ETRow_Lane_closed);
		table.hideColumnByColName (ETRow_Lane_direction_locked);
	else
		table.showColumnByColName (ETRow_Lane_in);
		table.showColumnByColName (ETRow_Lane_out);
		table.showColumnByColName (ETRow_Lane_direction_locked);
		table.showColumnByColName (ETRow_Lane_closed);
	endif;
	
//	if app.myRoot.canDo(PmRoadGateKiosk) and gateArea.isAGate then
	if gateArea.isAGate then//07 Oct 2019	NDL	TFS 46169
		table.showColumnByColName (ETRow_Lane_kiosk);
	else
		table.hideColumnByColName (ETRow_Lane_kiosk);
	endif;
	
	if gateArea.allGridColumns.isEmpty then
		// we expect to find a single column - rows within the column are lanes
		return;
	endif;
	
	foreach lc in gateArea.allGridColumns.first.allControllersByRow do
		lane	:= lc.CM_GateAreaLaneController;
		
		if gateArea.laneCount = 0 then
			// only show default in if area is an inward gate area for this gate
			// only show default out if area is an outward gate area for this gate
			if (lane.isIn and not usage.myGate.hasGateArea_IN (gateArea)) or
				(lane.isOut and not usage.myGate.hasGateArea_OUT (gateArea)) then
				continue;
			endif;
		endif;
		
		row		:= table.addItemObject (lane, lane.getAttributeStringForDefArray(table.allTblDataEntRows));
	endforeach;
	
	col := table.getColumnByRowName (ETRow_Lane_in);
	if col &gt; 0 then
		table.accessColumn (col).alignment	:= Table.Alignment_Center_Middle;
	endif;
	
	col := table.getColumnByRowName (ETRow_Lane_out);
	if col &gt; 0 then
		table.accessColumn (col).alignment	:= Table.Alignment_Center_Middle;
	endif;
	
	col := table.getColumnByRowName (ETRow_Lane_direction_locked);
	if col &gt; 0 then
		table.accessColumn (col).alignment	:= Table.Alignment_Center_Middle;
	endif;
	
	col := table.getColumnByRowName (ETRow_Lane_closed);
	if col &gt; 0 then
		table.accessColumn (col).alignment	:= Table.Alignment_Center_Middle;
	endif;
	
	if self.myTerminal.allWeighBridges.isEmpty then
		table.hideColumnByColName (ETRow_Lane_scale);
	else
		table.showColumnByColName (ETRow_Lane_scale);
		col := table.getColumnByRowName (ETRow_Lane_scale);
		if col &gt; 0 then
			table.accessColumn (col).alignment	:= Table.Alignment_Center_Middle;
		endif;
	endif;
	
	// TFS 52773 Generic API / Scan Readers
	if self.myTerminal.allScanReaders.isEmpty then
		table.hideColumnByColName(ETRow_Lane_scan_reader);
	else
		table.showColumnByColName(ETRow_Lane_scan_reader);
		col := table.getColumnByRowName (ETRow_Lane_scan_reader);
		if col &gt; 0 then
			table.accessColumn (col).alignment	:= Table.Alignment_Center_Middle;
		endif;
	endif;
	
epilog
	self.setGateLaneTableNeedsRefresh (false);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadInterchangeAreaCombo" id="f882bfda-aedb-46a5-8f52-e8d3d510b459">
