    <JadeMethod name="loadCSV" id="92b50174-cd6b-424c-b913-7d8da36afd91">
        <source>loadCSV(_allStringArrays: ObjectArray);
//----------------------------------------------------------------
//	Created:	15 November 2004	by Jason Chapman  (cnwjc2)
//
// 	Each string array represents a column of data.
//
//----------------------------------------------------------------
constants
	ColsLines = 50;
vars
	idx 	: Integer;
	obj		: Object;
	tmpStr	: String;
	dispStr	: String;
begin

	self.setForCSV();
	
	self.tblCSVDisplay.columns := self.tblCSVDisplay.fixedColumns + ColsLines + 2;

	idx := self.tblCSVDisplay.addItem("Field names? &gt;&gt;" &amp; Tab );
	self.tblCSVDisplay.accessRow(idx).inputType := Table.InputType_CheckBox;

	foreach obj in _allStringArrays do
		tmpStr := obj.StringArray.getFirstElementsDelimited(ColsLines, Tab);

		idx := self.tblCSVDisplay.addItem((idx).String &amp; Tab &amp; tmpStr &amp; Tab &amp; "...");
	
	endforeach;
	
	
end;</source>
        <Parameter name="_allStringArrays" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="loadCSVFromConstantXML" id="7fd2e144-c2d3-4a11-aadb-d41f6bc0425f">
        <source>loadCSVFromConstantXML(_xml: JadeXMLElement);
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	subElem,
	xmlElement			: JadeXMLElement;
	xmlElemArray		: JadeXMLElementArray;
	fieldName			: String;
	columnIdx			: Integer;
	idx					: Integer;
	xmlAttrib			: JadeXMLAttribute;
begin
	self.setForCSV();
	
	if _xml = null then
		return;
	endif;
	
	create xmlElemArray transient;
	
	_xml.getElementsByTagName('CSVHeader', xmlElemArray);
	
	self.tblCSVDisplay.columns := 2;
	idx := self.tblCSVDisplay.addItem("Field names? &gt;&gt;" &amp; Tab &amp; "1");
	self.tblCSVDisplay.accessRow(idx).inputType := Table.InputType_CheckBox;
	self.tblCSVDisplay.column := 2;
	self.tblCSVDisplay.change(self.tblCSVDisplay);
	
	foreach xmlElement in xmlElemArray do
		
		fieldName := xmlElement.textData;
		xmlAttrib := xmlElement.getAttributeByName('index');
		columnIdx := xmlAttrib.value.Integer;
		self.tblCSVDisplay.addItem(columnIdx.String &amp; Tab &amp; fieldName);
		
	endforeach;
	
	
	
end;</source>
        <Parameter name="_xml" type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="loadXMLDoc" id="d43bdfcd-39f6-4e60-aa2b-2674717e8b34">
        <source>loadXMLDoc();
//----------------------------------------------------------------
//	Created:	07 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	xmlNode	: JadeXMLNode;
begin
	self.setForXML();
	
	if self.myXMLDoc = null then
		return;
	endif;
	
	foreach xmlNode in self.myXMLDoc.childNodes do
		if JadeXMLElement.hasInstance(xmlNode) then
			self.loadXMLElement(xmlNode.JadeXMLElement, 1);
			
		endif;
	endforeach;
	
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadXMLElement" id="c8a614ac-19bd-4d35-bee4-6046570f1657">
        <source>loadXMLElement(xmlElement: JadeXMLElement; _level: Integer);
//----------------------------------------------------------------
//	Created:	07 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx			: Integer;
	xmlElem		: JadeXMLNode;
	xmlAttr		: JadeXMLAttribute;
	attrib		: String;
begin

	if not xmlElement.attributes.isEmpty then
		foreach xmlAttr in xmlElement.attributes do
			attrib := attrib &amp; "/" &amp; xmlAttr.value;
		endforeach;
	endif;
		
	idx := self.lstXMLDisplay.addTreeObject(xmlElement.tagName &amp; attrib &amp; " (" &amp; xmlElement.textData &amp; ")", xmlElement, _level, true);
	//self.lstBox1.itemObject[idx] := xmlElement;
	
	foreach xmlElem in xmlElement.childNodes do
		self.loadXMLElement(xmlElem.JadeXMLElement, _level + 1);
	endforeach;

end;</source>
        <Parameter name="xmlElement" type="JadeXMLElement"/>
        <Parameter name="_level" type="Integer"/>
    </JadeMethod>
