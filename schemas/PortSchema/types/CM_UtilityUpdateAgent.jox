    <JadeMethod name="utlUpdateResourceTypeUsage" id="5a4ee431-4b4b-410b-8223-8f6f952dec3d">
        <source>utlUpdateResourceTypeUsage(pProxyResourceTypeUsage : CM_ResourceTypeUsage; _doAudit : Boolean; _passport : CM_Passport input);

vars
	realResourceTypeUsage : CM_ResourceTypeUsage;
	expectedEdition       : Integer;
	
begin

	self.initialiseActivity();

	pProxyResourceTypeUsage.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyResourceTypeUsage.pxyGetRealObjectAndEdition(realResourceTypeUsage, expectedEdition);
	
	if realResourceTypeUsage = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_ResourceTypeUsage.name, null, null);
		return;
	endif;

	app.myValUA.valResourceTypeUsage(realResourceTypeUsage, pProxyResourceTypeUsage);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realResourceTypeUsage);

	if _passport.noErrors and realResourceTypeUsage.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'ResourceTypeUsage', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		if _doAudit = true then
			self.myUpdateAuditAgent.audUpdateGeneric(realResourceTypeUsage, true);
		endif;
	endif;
	
	if _passport.noErrors then
		realResourceTypeUsage.setForUpdate(pProxyResourceTypeUsage);
	endif;

	if _passport.noErrors then
		if _doAudit = true then
			self.myUpdateAuditAgent.audUpdateGeneric(realResourceTypeUsage, false);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="pProxyResourceTypeUsage" type="CM_ResourceTypeUsage"/>
        <Parameter name="_doAudit" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRestrictionLabour" id="23b25ebc-1abd-4ca3-83ab-65173a0cbc31">
        <source>utlUpdateRestrictionLabour(pProxyRestriction : CM_LabourRestriction; 
				pRealRestriction : CM_LabourRestriction input;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aTA : CM_TerminalArea;
begin
	self.initialiseActivity();

	pProxyRestriction.raiseExceptionIfNotProxy(method); 

	if pRealRestriction = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_LabourRestriction.name, null, null);
		return;
	endif;
	exclusiveLock(pRealRestriction);

	app.setContinueCMExceptions(true);
	
	app.myValUA.valRestrictionLabour(pProxyRestriction);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(pRealRestriction, true);
	endif;
	
	if _passport.noErrors then
		pRealRestriction.setForUpdate(pProxyRestriction);
	endif;

	if _passport.noErrors then
		aTA := pRealRestriction.myTerminalArea;
		aTA.causeEvent(aTA.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,aTA); //epr par 16956 11/6/08
		aTA.causeEvent(aTA.myTerminal.getTerminalEvent(Event_TALocation_Update),false,pRealRestriction); //epr par 16956 11/6/08
		
		self.myUpdateAuditAgent.audUpdateGeneric(pRealRestriction, false);
	endif;

epilog
end;</source>
        <Parameter name="pProxyRestriction" type="CM_LabourRestriction"/>
        <Parameter name="pRealRestriction" type="CM_LabourRestriction" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateResyncTrans" id="a7e25ec0-9f8d-4599-a5b8-e3b182b39193">
        <source>utlUpdateResyncTrans(_controller:CMIF_TiTransactionResync; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	useTrxTI	: Boolean;
	txn : CM_Transaction;
	controller	: CMIF_TiTransactionResync;
	invLine : CM_InvoiceLine;
	controllerTI : CM_TrackedItem;
	invsBefore : CM_InvoiceSet;
	inv : CM_Invoice;
begin

	self.initialiseActivity();
	controller := _controller;
	controllerTI := controller.myTrackedItem;
	// Feb 2012 CCMS 1262 resync from transaction enquiry may be for multiple transactions with controller myTrackedItem not set
	//  in this case use the transaction tracked item
	
	 // ### TFS CR 62992 TASK 62994 02APR2024 NAVAB1
	 create invsBefore transient;

	foreach txn in controller.allTransactions discreteLock do
		// Feb 2012 CCMS 1262 Transaction Enquiry, added event and HMS transaction resync, moved no-charge test up to CM_Transaction
		if txn.isNoCharge() then
			app.log("'" &amp; txn.getTypeString &amp; "' Transaction is no-charge");
			continue;
		endif;

		exclusiveLock(txn);
	
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(txn, true);
		endif;
		
		if _passport.noErrors then
			 // ### TFS CR 62992 TASK 62994 02APR2024 NAVAB1
			invLine := txn.getInvoiceLine(); 
			if invLine &lt;&gt; null then
				inv := invLine.invoice;
				if inv &lt;&gt; null then
					invsBefore.addNoDuplicates(inv,false);
				endif;
			endif;
			
			if txn.isKindOf(CM_TITransaction) then
				//epr TFS 2996 8/12/16 
				if txn.CM_TITransaction.myTrackedItem &lt;&gt; null  then
					controller.myTrackedItem := txn.CM_TITransaction.myTrackedItem;
				else
					controller.myTrackedItem := controllerTI;
				endif;
				txn.CM_TITransaction.setForUpdateResync(controller, _passport);
			elseif txn.isKindOf(CM_EventTransaction) then
				txn.CM_EventTransaction.setForUpdateResync(controller, _passport);
			elseif txn.isKindOf(HMS_VTMISTransaction) then
				txn.HMS_VTMISTransaction.setForUpdateResync(controller, _passport);
			elseif txn.isKindOf(CM_WOTransaction) then // TFS 39237
				txn.CM_WOTransaction.setForUpdateResync(controller, _passport); // TFS 39237
			elseif txn.isKindOf(CM_BOLTransaction) then //01 Nov 2019	NDL	TFS 47100
				txn.CM_BOLTransaction.setForUpdateResync(controller, _passport);
			endif;	
		endif;
		
	
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(txn, false);
			 // ### TFS CR 62992 TASK 62994 02APR2024 NAVAB1 - get any new ones as well
			invLine := txn.getInvoiceLine(); 
			if invLine &lt;&gt; null then
				inv := invLine.invoice;
				if inv &lt;&gt; null then
					invsBefore.addNoDuplicates(inv,false);
				endif;
			endif;
		endif;
		
	endforeach;
	
	// ### TFS CR 62992 TASK 62994 02APR2024 NAVAB1
	if _passport.noErrors then
		foreach inv in invsBefore discreteLock do
		
			inv.setTaxDetailsFromLines();
			inv.setTotalAmountFromLines(); // ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
		endforeach;
	endif;
	
	
	
	// just on the last one
	if txn &lt;&gt; null then
		txn.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRAN_RESYNC), false, txn);// PAR 16550
	endif;
epilog
	
		delete invsBefore;
end;</source>
        <Parameter name="_controller" type="CMIF_TiTransactionResync"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateReticketTI" id="814348ef-98ab-4b51-b7b1-f936fd84be86">
        <updating/>
        <source>utlUpdateReticketTI(_tiReticketSet		: CMIF_TIReticketSet;
					_errorReticketSet	: CMIF_TIReticketSet input; 
					_cargoType			: Integer;
					_taType				: Integer;
					_newLocation		: CM_LocationsController;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     18 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	validReticketSet	: CMIF_TIReticketSet;
	cancelSave 			: Boolean;
	tiReticket			: CMIF_TIReticket;
	ti					: CM_TrackedItem;
	match				: Integer;
	tiUpdateCntrl		: CMIF_TIUpdateController;
	moveController		: CMIF_MoveController;
	allTis				: CM_TISet;
	tmpTerminal			: CM_Terminal;
	tiAuditCntrl	: CM_TIAuditController;
	sa				: StringArray;
	
begin

	create validReticketSet transient;
	create allTis transient;
	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	tmpTerminal := _passport.myTerminal;
	
	app.myValUA.valReticketTI(_tiReticketSet, 
							_errorReticketSet, 
							validReticketSet,
							_cargoType,
							tmpTerminal, 
							_taType,
							_newLocation);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	tiUpdateCntrl.transactionType := TRANS_TYPE_EDIT;

	tiAuditCntrl := _passport.getTIAuditController();
	create sa transient;
	sa.add(CM_TrackedItem::id.name);
	tiAuditCntrl.setAuditSpecific(CM_TrackedItem, sa);

	if _passport.noErrors then
		foreach tiReticket in validReticketSet do
			ti := tmpTerminal.lookupTrackedItem(tiReticket.oldId, _cargoType, TI_STATE_NORMAL, null, false);
			ti.changeId(tiReticket.newId, tiUpdateCntrl, _passport);
			allTis.add(ti);
		endforeach;
	endif;

	if _passport.noErrors and _newLocation &lt;&gt; null then
		create moveController transient;
		moveController.setMoveMode(REAL_MODE);
		moveController.isSystemMove := true;
		moveController.setMyToPrimaryLocation(_newLocation);
		app.myUtilityUA.utlUpdateMoveTrackedItems(allTis, moveController, _passport);
	endif;

epilog
	if tiAuditCntrl &lt;&gt; null then
		tiAuditCntrl.resetIsAudited(true);
	endif;
	delete validReticketSet;
	delete allTis;
	delete moveController;
	delete tiUpdateCntrl;
	delete sa;
end;</source>
        <Parameter name="_tiReticketSet" type="CMIF_TIReticketSet"/>
        <Parameter name="_errorReticketSet" type="CMIF_TIReticketSet" usage="input"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_taType" type="Integer"/>
        <Parameter name="_newLocation" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
