    <JadeMethod name="handleProductObj" id="17e47ddc-d83f-4b4d-b05b-f2b55f4a3aa9">
        <source>handleProductObj(_code:String; _codesArray:StringArray input; _colorArray:IntegerArray input; _objArray:ObjectArray input);
// --------------------------------------------------------------------------------
// Created:		01 December 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iter		: Iterator;
	trimCode	: String;
	theCode		: String;
	codeKey		: String;
	theColor	: Integer;
	colorKey	: Integer;
	tmpProduct	: CM_Product;

begin
	trimCode	:=	_code.trimBlanks();

	iter	:=	self.myIterProduct;
	self.allProducts.startKeyGeq(trimCode, 0, iter);
	self.allProducts.getIteratorKeys(codeKey, colorKey, iter);
	
	if codeKey = trimCode then
		// found the right one
		theCode		:=	_code;
		theColor	:=	colorKey;
	else
		tmpProduct	:=	self.allUsedProducts[trimCode];
		
		if tmpProduct &lt;&gt; null then
			self.allProducts.add(tmpProduct);
			theCode		:= trimCode;
			theColor	:= tmpProduct.colour;
		else
			theCode		:= null;
			theColor	:= NullColour;
		endif;
	endif;

	_codesArray.atPut(TI_ColourMode_Product, theCode);
	_colorArray.atPut(TI_ColourMode_Product, theColor);
	_objArray.atPut(TI_ColourMode_Product, tmpProduct);
end;</source>
