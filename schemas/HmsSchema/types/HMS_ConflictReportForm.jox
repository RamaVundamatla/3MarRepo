    <JadeMethod name="chkStockpile_click" id="678924de-c699-40b9-99d6-b1f18278921e">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkStockpile_click(checkbox: CheckBox input) updating;
// --------------------------------------------------------------------------------
// Created:		04 March 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if checkbox.value then
		lblProducts.enabled	:=	true;
		lstProducts.enabled	:=	true;
	else
		lstProducts.clearAllSelected();
		lblProducts.enabled	:=	false;
		lstProducts.enabled	:=	false;
	endif;
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
