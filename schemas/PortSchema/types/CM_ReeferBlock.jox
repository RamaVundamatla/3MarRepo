    </JadeMethod>
    <JadeMethod name="setForUpdate" id="36aaf890-1477-4547-80cc-59fc3cff366b">
        <updating/>
        <source>setForUpdate( _pxyReeferBlock : CM_ReeferBlock; _reeferWalkPositionArray : CM_ReeferBlockPositionArray ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	pxyWalkPosition : CM_ReeferBlockPosition;
	walkPositionIndex : Integer;
	asTrans : Boolean;
	walkPosition : CM_ReeferBlockPosition;

begin

	self.name := _pxyReeferBlock.name;
	self.myTerminalArea := _pxyReeferBlock.myTerminalArea;
	
	asTrans := self.isTransient;
	
	self.allReeferPositions.purge();
	foreach pxyWalkPosition in _reeferWalkPositionArray do
		walkPositionIndex := walkPositionIndex + 1;
		if asTrans then
			create walkPosition transient;
		else
			create walkPosition persistent;
		endif;
		walkPosition.setDetails(pxyWalkPosition.myLocationController,	//_myLocationController : CM_LocationsController;
								self,	//_myReeferBlock : CM_ReeferBlock;
								walkPositionIndex,	//_position : Integer;
								pxyWalkPosition.tier	//_tier : Integer
								);
	endforeach;

epilog

end;</source>
        <Parameter name="_pxyReeferBlock" type="CM_ReeferBlock"/>
        <Parameter name="_reeferWalkPositionArray" type="CM_ReeferBlockPositionArray"/>
    </JadeMethod>
