begin

	self.validateMe( _passport );
	

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="f2dab8e4-0d7f-4308-96a4-abc1f89eb64a">
        <source>validateMe(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2015	cnwndl1	Initial creation	Par 36906

*/

vars

	cargoId : String;
	ti : CM_TrackedItem;
	cargoTypeInt : Integer;

begin

	if self.myTerminal = null then
		app.raiseCMException( Terminal_reference_set, null, null );
		return;
	endif;

	if self.myCargoType &lt;&gt; null then
		cargoTypeInt := myCargoType.id;
	endif;

	foreach cargoId in self.allCargoIds do
		ti := self.myTerminal.allOnsiteTIsByIdCargoType.getAtKeyGeq( cargoId, cargoTypeInt );
		if ti = null or ti.id &lt;&gt; cargoId or ( cargoTypeInt &lt;&gt; 0 and ti.cargoType &lt;&gt; cargoTypeInt ) then
			app.raiseCMException1( Cargo_item_not_found_site, cargoId, null, null );
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
