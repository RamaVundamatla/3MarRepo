    <JadeMethod name="excludeKnownLeaks" id="07452f7b-2eac-41b6-8693-c5ea2b922c74">
        <source>excludeKnownLeaks(_obj : Object) : Boolean protected;
// report writer has leaks, don't report as can't do anything about them
//  also have a number of JadeLog instances floating around from the background report (etc) processing
/*

Date		Who		Reason
23 Nov 2011	cnwkpd1	Rework to specifically exclude known JRD StringArray instances
03 Nov 2016	cnwkpd1	Add check for leaked notifications to Unit Test framework

*/

vars
	str,
	test	: String;
	testLen	: Integer;
	jrdObjectMatch : Object;
	
begin
	if _obj = process.profiler then
		return true;
	endif;
	if _obj.isKindOf(UM_Notification) and self.startingNotifications.includes(_obj.UM_Notification) then
		return true;
	endif;
	test := _obj.String;
	testLen := test.length;
	if testLen &gt; 3 then
		if test[1:3] = "JRD" then
			return true;
		elseif testLen &gt; 9 and test[1:10]="JadeMethod" then
			return true;
		elseif testLen &gt; 11 and test[1:12]="DictIterator" then
			str := _obj.Iterator.getCollection().String;
			if str.length &gt; 3 and str[1:3] = "JRD" then
				return true;
			endif;
		endif;
	endif;
	if testLen &gt; 7 and
	   test[1:7] = "JadeLog" then
		return true;
	endif;
		
	if testLen &gt; 11 and test[1:11] = StringArray.name then
		jrdObjectMatch := rootSchema.getSchema('JadeReportWriterSchema').getClass('JRDObjectMatch').firstProcessTransientInstance();
		if jrdObjectMatch &lt;&gt; null then
			if _obj = jrdObjectMatch.getPropertyValue('newObjectIds').Object or
			   _obj = jrdObjectMatch.getPropertyValue('oldObjectIds').Object then
				return true;
			endif;
		endif;
	endif;
	
	if test.startsWith("CMIF_StateChange") or test.startsWith("CMIF_StateFeature") or test.startsWith("CMIF_StateClass") then
		return true;
	endif;
	
	if _obj.isKindOf(CMIF_StateClassMap) or _obj.isKindOf(CMIF_StateFeatureMap) then
		return true;
	endif;
	
	// ### JIRA: MTN-36370 17Nov2025 NAVPW1 - In case of failed road gate trx's. We don't really need to check these??
	if _obj.isKindOf(CMIF_TrxActionTransport) or _obj.isKindOf(CMIF_TrxActionInspection) then
		return true;
	endif;
	// ### JIRA: MTN-36370 17Nov2025 NAVPW1
	
	return false;

end;
</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="excludeKnownLeaksPublic" id="ba6fe331-4d19-4c98-b23c-e48ea0ed8e0e">
        <source>excludeKnownLeaksPublic(_obj : Object) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/03/2016	cnwdap1		Initial creation PAR #37675 Transient leaks in getLogRows web service
//
vars

begin
	return self.excludeKnownLeaks(_obj);
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="excludeKnownNoteLeaks" id="17ab5b44-0664-4996-b7ce-72c537ff923a">
        <source>excludeKnownNoteLeaks(_note : Notification) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Nov 2016	cnwkpd1	TFS 1832 - TSW Web Client


*/

vars

begin
	if _note.subscriber() = app.myPassport and _note.target() = app.myPassport.myUser and _note.eventType = EVENT_DAC_UPDATE then
		return true;
	endif;
	
	return false;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_note" type="Notification"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="finialise" id="70a312d5-25fd-4acc-b494-c0f09a43ffd4">
        <source>finialise() protected;

vars
	audCont : CM_TIAuditController;
	oa : ObjectArray;
	
begin
	app.myHookAgent.allCMIFHookCodes.purge;	// cnwdad1 31/05/2010.
	app.myEventManager.dispatchAllEvents;	// to get rid of transient CM_SingleObjectUserInfoNoteEvt generated in the cmif move controller
	audCont := app.myPassport.getTIAuditController();
	if audCont &lt;&gt; null then
		audCont.initialiseTransaction;	// deletes the subTransactionController transient.
	endif;
	
	/*if app.myPassport &lt;&gt; null and app.myPassport.myStateChangeController &lt;&gt; null then
		delete app.myPassport.myStateChangeController;
	endif;*/
	
	self.endingTransients.clear();
	create oa transient;
	process.allTransientInstances(oa, 0);
	oa.copy(self.endingTransients);
	self.endingTransients.remove(oa);
	
epilog
	delete oa;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getIteratorTransientLeakDetail" id="83c4aa3b-03ad-44c9-8d56-4e6917677433">
        <source>getIteratorTransientLeakDetail(_obj : Object) : String;

/*

Purpose:	If is of type Iterator then get the details
			MergeIterator has multiple collections and get collection isn't implemented in it

Parameters:			

Return Value:		


Date			Who		Reason
07 July 2011	cnwmh5	Initial creation

*/

vars
	message			: String;	
	collectionSize	: Integer;
	index			: Integer;
begin

	if not _obj.isKindOf(Iterator) then
		return null;
	endif;
	
	if _obj.isKindOf(MergeIterator) then
		collectionSize := _obj.MergeIterator.getCollectionCount();
		if collectionSize &gt; 0 then
			index := 1;
			while true and index &lt;= collectionSize do
				message := message &amp; " " &amp; _obj.MergeIterator.getCollectionAt(index).display;
				index := index + 1;
			endwhile;
		else
			message := message &amp; " *** Iterator collection has been deleted but iterator has not been deleted **** " &amp; _obj.MergeIterator.String;
		endif;		
	elseif _obj.isKindOf(Iterator) and _obj.Iterator.getCollection() &lt;&gt; null then
		if global.isValidObject(_obj.Iterator.getCollection()) then
			message := message &amp; " " &amp; _obj.Iterator.getCollection().display();
		else
			message := message &amp; " *** Iterator collection has been deleted but iterator has not been deleted **** " &amp; _obj.Iterator.getCollection().String;
		endif;
	endif;

	return message;
	
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLeaks" id="b4afb5e9-99ae-44f5-b348-c8e58687da71">
        <source>getLeaks( _minimumOuput : Boolean ): String;
//16 July 2008	cnwdw1	
//
/*

Date		Who		Reason
24 Sep 2009	cnwkpd1	Added check for leaked locks as well
07/07/2011	cnwmh5	Change to use getIteratorTransientLeakDetail which handles MergeIterators
03 Nov 2016	cnwkpd1	Add check for leaked notifications to Unit Test framework

*/

vars
	obj 			: Object;
	message 		: String;
	notes			: NotificationArray;
	note			: Notification;
	umNote			: UM_Notification;
	
begin
	self.finialise();
	
	foreach obj in self.endingTransients do
		if self.startingTransients.includes(obj) then
			continue;
		endif;
		
		if self.excludeKnownLeaks(obj) then
			continue;
		endif;
			
		//message := message &amp; CrLf &amp; "----Transient Leak---- " &amp; CrLf &amp; obj.display();
		message := message &amp; CrLf &amp; "----Transient Leak---- " &amp; CrLf &amp; getObjectDisplayString(obj, _minimumOuput);
		message := message &amp; self.getIteratorTransientLeakDetail(obj);		// 07/07/2011 cnwmh5
		message := message &amp; CrLf &amp; "-----End Transient Leak-----" &amp; CrLf;
	endforeach;
	
	// Check for Notification leaks here
	create notes transient;
	system.getNotes(notes, true, Max_Notes);
	system.getNotes(notes, false, Max_Notes);
	
	foreach note in notes do
		if note.getPropertyValue(Notification::requestedBy.name).Process &lt;&gt; process then
			continue;
		endif;
		
		if self.excludeKnownNoteLeaks(note) then
			continue;
		endif;
		
		if self.startingNotifications[note.subscriber(), note.target(), note.eventType] &lt;&gt; null then 
			continue;
		endif;
		
		message := message &amp; CrLf &amp; "----Notification Leak---- " &amp; CrLf;
		message := message &amp; 'subscriber=' &amp; note.subscriber().String &amp; ' target=' &amp; note.target().String &amp; ' eventType=' &amp; note.eventType.String;
		message := message &amp; CrLf &amp; "-----End Notification Leak-----" &amp; CrLf;
	endforeach;
	
	return message;

epilog
	if notes &lt;&gt; null then
		notes.purge();
		delete notes;
	endif;
	
end;</source>
        <Parameter name="_minimumOuput" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLeaksOf" id="05dcde36-cb18-43c5-ac35-e94b2212fa91">
        <source>getLeaksOf( _class : Class ): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 December 2010	cnwndl1	Initial creation
07/07/2011	cnwmh5	Change to use getIteratorTransientLeakDetail which handles MergeIterators
*/

vars
	obj 			: Object;
	message 		: String;
	
begin
	self.finialise();
	
	foreach obj in self.endingTransients do
	
		if not obj.isKindOf(_class) then
			continue;
		endif;
		if self.startingTransients.includes(obj) then
			continue;
		endif;
			
		//message := message &amp; CrLf &amp; "----Transient Leak---- " &amp; CrLf &amp; obj.display();
		message := message &amp; CrLf &amp; "----Transient Leak---- " &amp; CrLf &amp; getObjectDisplayString(obj,false);
		message := message &amp; self.getIteratorTransientLeakDetail(obj);			// 07/07/2011 cnwmh5
		message := message &amp; CrLf &amp; "-----End Transient Leak-----" &amp; CrLf;
	endforeach;
	
	return message;
	
end;</source>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjectDisplayString" id="0680f80d-4ff7-4143-a56a-3d594bb7188d">
        <source>getObjectDisplayString( _obj : Object; _minimumOuput : Boolean ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 December 2010	cnwndl1	Initial creation

*/

vars

	str : String;
	invalidObject : Boolean;
	objOidString : String;
	invalidTransObject : Boolean;
	ts : TimeStamp;
	name : String;
	display : String;

begin

	on Exception do self.handleNullRefInDisplayCall(exception, invalidObject );
	on Exception do app.handleDeletedObject(exception, _obj, invalidTransObject );
	
	objOidString := _obj.String;
	str := objOidString;
	
	if _minimumOuput then
		return str;
	endif;
	
	name := _obj.getName;
	if invalidTransObject then
		str := str &amp; " - Actually it has been deleted!";
		return str;
	endif;
	
	display := _obj.display().trimBlanks;
	if display = null then
		if invalidObject then
			str := str &amp; " - call of 'display' method for this object failed!";
		elseif display = null then
			str := str &amp; " - call of 'display' method returned nothing!";
		endif;
	else
		if display.pos(objOidString,1) &lt; 1 then
			str := objOidString &amp; " - " &amp; display;
		endif;
	endif;
	
epilog

	return str;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_minimumOuput" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleNullRefInDisplayCall" id="2191e7db-d546-44b1-bc87-b2d7086336f4">
        <source>handleNullRefInDisplayCall(_exc : Exception; _invalidObject : Boolean io) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 December 2010	cnwndl1	Initial creation

*/

constants
	ObjectNotFound	= 4;
	ObjectDeleted	= 1072;
	InvalidClass	= 1046;
	
vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	if _exc.errorCode = ObjectNotFound or _exc.errorCode = ObjectDeleted or _exc.errorCode = InvalidClass then
		_invalidObject := true;
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

epilog
	return returnVal;
	
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_invalidObject" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="0b1024cb-df60-46a9-a271-8e3f2efdf2b8">
        <source>initialise() protected;
/*

Date		Who		Reason
03 Nov 2016	cnwkpd1	Add check for leaked notifications to Unit Test framework
	
*/

vars
	oa	: ObjectArray;
	
begin
	app.myHookAgent.allCMIFHookCodes.purge;	// cnwdad1 31/05/2010.
	self.startingTransients.clear;
	create oa transient;
	process.allTransientInstances(oa, 0); 
	oa.copy(self.startingTransients);
	self.startingTransients.remove(oa);
	
	self.initialiseNotes();
	
epilog
	delete oa;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initialiseNotes" id="ebae4baa-1f4a-43d4-ab90-d63befaaf96a">
        <source>initialiseNotes() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Nov 2016	cnwkpd1	Add check for leaked notifications to Unit Test framework

*/

vars
	notes			: NotificationArray;
	note			: Notification;
	umNote			: UM_Notification;
	
begin
	self.startingNotifications.purge();
	
	create notes transient;
	system.getNotes(notes, true, Max_Notes);
	system.getNotes(notes, false, Max_Notes);
	
	foreach note in notes do
		if note.getPropertyValue(Notification::requestedBy.name).Process &lt;&gt; process then
			continue;
		endif;
		
		create umNote transient;
		umNote.eventType := note.eventType;
		umNote.subscriber := note.subscriber();
		umNote.target := note.target();
	
		self.startingNotifications.add(umNote);
	endforeach;
		

epilog
	if notes &lt;&gt; null then
		notes.purge;
		delete notes;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
