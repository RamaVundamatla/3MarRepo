/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	elapsed : TimeStampInterval; 

begin

	if not self.exchangeStart.Date.isValid then	// 28 Aug 2012	NDL	Par 30279
		// this one has no details yet.
		return 0;
	endif;

	elapsed := self.getExchangeEnd - self.exchangeStart;
	
	return elapsed.asHours();

epilog

