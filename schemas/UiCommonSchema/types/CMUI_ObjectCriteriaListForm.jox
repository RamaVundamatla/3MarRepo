        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMain_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2014	cnwndl1	Initial creation

*/

vars

begin
		// TFS 2198 CNWAB1
		if not app.myCurrentUserCan(self.myTerminal, PmGteVehSchBgp) then
			return;
		endif;

