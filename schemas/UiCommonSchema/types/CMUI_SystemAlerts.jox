    <JadeMethod name="handleAlertAdd" id="e28946e0-450a-4a94-b6e4-d7282866ee3f">
        <updating/>
        <source>handleAlertAdd(_alert : CM_SystemAlert)updating;
// ---------------------------------------------------------------------------
// Created:     08 December 2003 by cnwrs2
//09 JAN 2015 cnwma1 PAR #33173 14049 in CMUI_SystemAlerts::displayAlert
// Purpose:     
// ---------------------------------------------------------------------------
vars
	invalidAlert	: Boolean;
	
begin
	/*
	Date		      Who		Reason
	31 July 2008	cnwdz2	    Par16737 - Use app.handleDeletedObject() to handle invalid object reference instead of isValidObject().
	*/
	on Exception do app.handleDeletedObject(exception, _alert, invalidAlert);
	
	if (not self.includeAlert(_alert, self.currentButton)) then
		return;
	endif;

	self.displayAlert(_alert, self.tblAlerts.fixedRows + 1);

end;</source>
        <Parameter name="_alert" type="CM_SystemAlert"/>
    </JadeMethod>
