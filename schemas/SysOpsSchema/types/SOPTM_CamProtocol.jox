    <JadeMethod name="clearThumbnailData" id="88f3a93d-e73a-400e-b75a-d18c51c22ec3">
        <updating/>
        <source>clearThumbnailData() updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15 May 2014	cnwrs1	Par 34159 - include Chassis in Codeco
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
    theForm := self.myForm;
	theForm.tblInput1.clearValues();
	theForm.tblInput2.clearValues();
	theForm.mulSelect1.setSelected(null);
 	theForm.mulSelect2.setSelected(null);
 	theForm.mulSelect3.setSelected(null);
	theForm.mulSelect6.setSelected(null);
	theForm.mulSelect7.setSelected(null);	// PAR 21905 CCMS MES 1008 - PHB
	theForm.mulSelect8.setSelected(null);
	theForm.chkAnyTriggField.value	:= false;
	theForm.mulSelect41.setSelected(null);
	theForm.mulSelect42.setSelected(null);
	theForm.txtDelayMins.text := null;	//01 Oct 2015	NDL	Par 36998
	theForm.timelistBox1.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="69206609-c594-43d5-a46f-b9ef8aabad78">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
/* Changes

Date		Name	TFS#		Description
============================================================================
15 May 2014	cnwrs1	Par 34159 	include Chassis in Codeco
18 Nov 2014 cnwgb1  Par 35255 	Remove setup of allTrainEventTypes
28 Jun 2016 cnwma1  TFS #2226 	POL - Update to VERMAS structure from Ship Operators
05 Oct 2016	cnwma1  TFS #2712 	CPL - Container Number in VERMAS DOC segment
12 Jul 2017	jlgrs1	TFS 4465 	SNO standard Codedo/Coarri
22 Aug 2017	jlgrs1	TFS 6560 	SNO Damaged/Repair
19 Sep 2017	jlgrs1	TFS 6957 	Codeco/Coarri VGM extra details
18 Dec 2017	jlgrh7 	TFS 7781 	SNO - VERMAS with EDIFACT codes required
12 Nov 2018	jlgsl4	TFS 39345 	SNO - add LOC+7,LOC+PDS/LOC+11 to TDT+30
19 Mar 2019	jlgsl4	TFS 41786 	SNO - output DAM segment for Standard Coarri/Codeco
28 May 2019	jlgsl4	TFS 43706 	PEN - output Enhanced Genset segment details
26 Jun 2019	jlgka1	TFS 44737 	PNL Hapag CODECO on Weighing.
11 Mar 2020	jlgdap1	TFS 48785	SNO COARRI Issue
03 Feb 2021	jlgdap1	TFS 50726	GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery
29 Mar 2022	jlika1	TFS 53181	GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
18 Jul 2022	jlizm1	TFS 54142 	AAT - Add NAD+MS to Standard COARRI SMDG213
============================================================================*/
begin
	self.name := SOP_TableMaintForm.Table_CamProtocol;
	self.permissionView	 := PmAdmCamprotocolView;
	self.permissionMaint := PmAdmCamprotocolMaint;
	self.myDataClass := CM_CamProtocol;
	create self.chkReprocessChangeID transient;
	create self.chkHLCSel_Suppress transient;
	create self.chkIncludeChassis transient;
	create self.chkPackUnpackStatusChange transient;
	create self.chkIncludeRestowShifter transient;
	create self.chkCOARRIBGM transient;			//cnwmc5 - 4 Feb 2016 - PAR 37503
	create self.chkCOARRIBGM4446 transient;		// 26Jan2023 navsp1 TFS 56282
	create self.chkVERMASNAD transient;          //28/06/2016 cnwma1 TFS #2226  
	create self.chkVERMASDOC transient;			// 05/10/2016 cnwma1 TFS #2712
	create self.lblBGMRepCode transient;
	create self.txtBGMRepCode transient;
	create self.lblBGMDamCode transient;
	create self.txtBGMDamCode transient;
	create self.chkIncludeExtraVGM transient;
	create self.chkVERMASVer10 transient;					//+TFS7781
	create self.chkCoarri95BLocPDS transient;	// TFS 39345
	create self.chkProduceDAMSegment transient;	// TFS 41786
	create self.chkEnhancedGensetInfo transient; // TFS 43706
	create self.lblVGMBGMMsgCode transient;		 // jlgka1 TFS 44737
	create self.txtVGMBGMMsgCode transient;		 // jlgka1 TFS 44737
	create self.chkTShipImports transient;		// TFS 48785
	create self.chkIncludeRFFBM162 transient;	//26 Jan 2021	NDL	TFS 50708
	create self.chkIncludeLOC7InterTerm transient;		// TFS 50726
	create self.chkIsCustomsProtocol transient;		// TFS 53181
	create self.chkIncludeNADMSForSMDG213 transient;	// TFS 54142
	self.populateCamEditTriggerFields;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="c62666d5-7716-487d-a2ee-89cc8e8263a5">
        <updating/>
        <source>delete() updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
15 May 2014	cnwrs1	Par 34159 	include Chassis in Codeco
28 Jun 2016 cnwma1  TFS #2226 	POL - Update to VERMAS structure from Ship Operators
05 Oct 2016	cnwma1	TFS #2712 	CPL - Container Number in VERMAS DOC segment
12 Jul 2017	jlgrs1	TFS 4465 	SNO standard Codedo/Coarri
22 Aug 2017	jlgrs1	TFS 6560 	SNO Damaged/Repair
19 Sep 2017	jlgrs1	TFS 6957 	Codeco/Coarri VGM extra details
18 Dec 2017 jlgrh7 	TFS 7781 	SNO - VERMAS with EDIFACT codes required
12 Nov 2018	jlgsl4	TFS 39345 	SNO - add LOC+7,LOC+PDS/LOC+11 to TDT+30
19 Mar 2019	jlgsl4	TFS 41786 	SNO - output DAM segment for Standard Coarri/Codeco
28 May 2019	jlgsl4	TFS 43706 	PEN - output Enhanced Genset segment details
26 Jun 2019	jlgka1	TFS 44737 	PNL Hapag CODECO on Weighing.
11 Mar 2020	jlgdap1	TFS 48785	SNO COARRI Issue
03 Feb 2021	jlgdap1	TFS 50726	GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery
29 Mar 2022	jlika1	TFS 53181	GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
18 Jul 2022	jlizm1	TFS 54142 	AAT - Add NAD+MS to Standard COARRI SMDG213
============================================================================*/
begin
	delete self.chkReprocessChangeID;
	delete self.chkHLCSel_Suppress;
	delete self.chkIncludeChassis;
	delete self.chkPackUnpackStatusChange;
	delete self.chkIncludeRestowShifter;
	delete self.chkCOARRIBGM;			//cnwmc5 - 4 Feb 2016 - PAR 37503
	delete self.chkCOARRIBGM4446;		//26Jan2023 navsp1 TFS 56282
	delete self.chkVERMASNAD;            //28/06/2016 cnwma1 TFS #2226 
	delete self.chkVERMASDOC;   // 05/10/2016 cnwma1 TFS #2712
	delete self.lblBGMRepCode;
	delete self.txtBGMRepCode;
	delete self.lblBGMDamCode;
	delete self.txtBGMDamCode;
	delete self.chkIncludeExtraVGM;
	delete self.chkVERMASVer10;				//+TFS7781
	delete self.chkCoarri95BLocPDS;	// TFS 39345 - enable LOC+PDS, LOC+7 for 95B
	delete self.chkProduceDAMSegment; // TFS 41786
//	delete self.chkSeperatePackArea;
	delete self.chkEnhancedGensetInfo; // TFS 43706
	delete self.lblVGMBGMMsgCode;	  // jlgka1 TFS 44737
	delete self.txtVGMBGMMsgCode;	  // jlgka1 TFS 44737
	delete self.chkTShipImports;		// TFS 48785
	delete self.chkIncludeRFFBM162;	//26 Jan 2021	NDL	TFS 50708
	delete self.chkIncludeLOC7InterTerm;		// TFS 50726
	delete self.chkIsCustomsProtocol;		// TFS 53181
	delete self.chkIncludeNADMSForSMDG213;	// TFS 54142
end;
</source>
    </JadeMethod>
    <JadeMethod name="displayHistory" id="6312fa89-065f-448e-9a44-90c226c2a7ea">
        <updating/>
        <source>displayHistory(_camProtocol: CM_CamProtocol; _table: CM_DataTable; isRefresh: Boolean)updating;
// ---------------------------------------------------------------------------
// Created:		27 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
/* Changes
Date		By		Changes
20/04/2009	cnwmd1	Par 23363 _displayAll Param added.  So not all history can be shown.  Displaying all history can take a long time to populate
06/05/2010	cnwcs5	Par 23801 - only display history when history tab is visible
//21 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask cleanup
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/
vars
	form				: SOP_TableMaintForm;
	camTaskHist			: CM_CamTaskHistory;
	idx, max,
	count, size			: Integer;
	table				: CM_DataTable;
	numHistoryItems  	: Integer;
	numHistoryItemsStr 	: String;
begin 
// 06/05/2010 cnwcs5 par 23801 - start
	form := self.myForm;
	// if we are not displaying the history sheet then just set the flag to say we need to
	if not form.fldInput.topSheet = form.shtViewTable1 then
		self.isHistoryCurrent := false; 
		return;
	endif;
	self.isHistoryCurrent := true;	// because we are about to load it
// par 23801 - end
	table 			:= _table;
	table.clearAllSelected;		// par 23801
	table.rows 		:= 1;
	table.column 	:= 1;
	max				:= self.historyDisplayCount;	// par 23801
	
	form.setColorsForTable(table);
	
	foreach camTaskHist in _camProtocol.taskHistoryByProtocolSeq reversed do
		idx := table.addItem(camTaskHist.displayString);
		table.accessRow(idx).itemObject := camTaskHist;
		if camTaskHist.seqNumber.isEven then
			table.accessedRow.backColor := self.myForm.colorRow1;
		else
			table.accessedRow.backColor := self.myForm.colorRow2;
		endif;
		// par 23801 - start
		count := count + 1;
		if max &lt;&gt; 0 and count &gt;= max then
			break;
		endif;
		// par 23801 - end
	endforeach;	
	
	// par 23801 - start
	size := _camProtocol.taskHistoryByProtocolSeq.size;
	
	if max = 0 or max &gt; size then
		form.shtViewTable1.caption := app.getErrorString1 (Protocol_task_history_count, size.String);
	else
		form.shtViewTable1.caption := app.getErrorString2 (Protocol_task_history_count2, count.String, size.String);
	endif;
	// par 23801 - end

end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="isRefresh" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doColumnHeadings" id="d01db2f4-bcea-4f40-8328-bca1f294b36b">
        <source>doColumnHeadings(_theTable : CM_BaseTable input);
// ---------------------------------------------------------------------------
// Created:		22 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
begin
	_theTable.accessCell(1,1).text := 'Seq. No.  ';
	_theTable.accessCell(1,2).text := 'Run Date  ';
	_theTable.accessCell(1,3).text := 'Start Date';
	_theTable.accessCell(1,4).text := 'End Date  ';
	_theTable.accessCell(1,5).text := 'Task Status ';
	_theTable.accessCell(1,6).text := 'Email# ';
	_theTable.accessCell(1,7).text := 'Msgs ';
	_theTable.accessCell(1,8).text := 'Computer ';
	_theTable.accessCell(1,9).text := 'File Name ';
	_theTable.accessCell(1,10).text := 'Error Message  ';

end;</source>
        <Parameter name="_theTable" type="CM_BaseTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="21888eef-ddf0-457d-b3a6-95d0ee095fac">
        <updating/>
        <source>doDelete(pObj: CM_Object io) updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	app.myTrxDA.trxDeleteCamProtocol(pObj.CM_CamProtocol, app.myPassport);

end;</source>
        <Parameter name="pObj" type="CM_Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doMnuContext1Click" id="270702b4-5eaa-4a21-ad78-c96df628eef3">
        <updating/>
        <source>doMnuContext1Click(theMenuItem: MenuItem) updating;
// ---------------------------------------------------------------------------
// Created:		27 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//restart
vars
	camTaskHistory		: CM_CamTaskHistory;
	camProtocol			: CM_CamProtocol;
	answer				: Integer;
	table				: CM_DataTable;
//	objectArray			: ObjectArray;
	controller			: Object;
	obj					: Object;
	taskHs				: CM_CamTaskHistoryByProtocolSeq;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	

	camProtocol	:= self.myForm.myCurrentObject.CM_CamProtocol;
	
	if camProtocol = null then
		return;
	endif;
	
	if theMenuItem.caption = app.getErrorString(Put_hold) 
	or theMenuItem.caption = app.getErrorString(Take_hold) then
		self.setProtocolOnHold(camProtocol);
		return;
	endif;
	
	table := self.myForm.tblDataView1; 
	
	answer := app.msgBox("Are you sure you want to restart the selected CAM Tasks?",
			"Restart CAM Tasks", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	if answer = MsgBox_Return_No then
		return;
	endif;

	
	if app.isAppropriateBGPRunning(BGP_CamsRequest.name) then
		create taskHs transient;
			
		foreach obj in table.allSelectedObjects do
			if CM_CamTaskHistory.hasInstance(obj) then
				camTaskHistory := obj.CM_CamTaskHistory;
				taskHs.add(camTaskHistory);
			endif;			
		endforeach;
			
		foreach camTaskHistory in taskHs reversed do
		
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxCA.trxCreateRestartCamsRequest(camTaskHistory,null,null, app.myPassport); //jlier1 TFS 58637 20/6/23
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog("Restart CAM Tasks", app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;
				
			if not app.myPassport.trxCompletedOK then
				break;
			endif;
		endforeach;
			
		if app.myPassport.trxCompletedOK then
			self.myForm.clearErrorWarnings();
			app.msgBox("Process requests have been initiated for each task history selected." &amp; CrLf &amp; 
					"There is at least one controller available to process these requests.",
					"Restart CAM Tasks", MsgBox_OK_Only + MsgBox_Information_Icon);
		endif;
		return;
	endif;

	//didn't find a running controller
	app.msgBox("A process request could not be initiated.  Make sure a Background Process to action CAM tasks exists and is running.",
				"Restart CAM Tasks", MsgBox_OK_Only + MsgBox_Information_Icon);
epilog
	delete taskHs;	
end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuContext2Click" id="40e651ef-9ad8-4b66-bc40-cb3763629521">
        <updating/>
        <source>doMnuContext2Click(theMenuItem: MenuItem) updating;
// ---------------------------------------------------------------------------
// Created:		27 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//delete history
//21 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask cleanup
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	answer			: Integer;
	camTaskHistory	: CM_CamTaskHistory;
	taskHistArray	: ObjectArray;
	camProtocol		: CM_CamProtocol;
	table			: CM_DataTable;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	camProtocol := self.myForm.myCurrentObject.CM_CamProtocol;
	
	answer := app.msgBox("Are you sure you want to delete the selected tasks for CAM Protocol " &amp; camProtocol.code &amp; "?",
				"Delete Task History", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	if answer = MsgBox_Return_No then
		return;
	endif;
	
	table := self.myForm.tblDataView1;
	
	create taskHistArray transient; 
	
	table.allSelectedObjects.copy(taskHistArray);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteCamsHistories(camProtocol, taskHistArray, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.displayHistory(camProtocol, table, false);
			break;
		else
			theResult := app.showErrorWarningDialog("Delete Task History", app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	delete taskHistArray;	
end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuContext3Click" id="1e30e0eb-01c4-40fc-b026-53181ce21101">
        <updating/>
        <source>doMnuContext3Click(theMenuItem: MenuItem) updating;
// ---------------------------------------------------------------------------
// Created:		27 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//view file
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//20 Jul 2023	navmd1	TFS 58947 Show JSON CAMS messages in a better viewer
//06 May 2024   navsp1  Bug 61182: EUP - Damage &amp; Repair message is not formatted correctly in Display when large
//30 Aug 2024   navhn30 Bug 65667: MTN - Reverse Changes made for 61182 for handling large JSON messages
vars
	table		: CM_DataTable;
	fileName	: String;
	aFile		: File;
	taskHistory	: CM_CamTaskHistory;
	obj			: Object;
	answer		: Integer;
	theLines, hgStr : HugeStringArray;
	messageLogForm	: CMUI_MessageLogForm;
	//allMsgs     : String;//TFS 61182
	//maxLength   : Integer;//TFS 61182
begin
	table := self.myForm.tblDataView1;
	
	obj := table.accessRow(table.row).itemObject;
	
	if obj = null then
		if table.row &gt; table.fixedRows then
			app.msgBox(app.getErrorString(ERR_CAMS_OPENFILE),  app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Information_Icon);
		endif;
		return;
	endif;
	
	taskHistory := obj.CM_CamTaskHistory;
	
	//fileName := app.getMyTerminalConfig(CamsFileDirectory).String &amp; "\" &amp; table.accessCell(table.row,6).text;
//	fileName := app.getMyTerminalConfig(CamsFileDirectory).String &amp;'\'&amp; protocol.code.trimBlankCharacters.removeInvalidChars &amp; "\" &amp; taskHistory.fileName;
	fileName := app.getMyTerminalDO_NOT_USE.getConfig_FileDirectory(CamsFileDirectory).String.trimRight&amp;'\'&amp;taskHistory.camProtocol.code.trimBlankCharacters.removeInvalidChars &amp; "\" &amp; taskHistory.fileName; //cnwrs1 par19312 June 2009 
	
	create aFile transient;
	aFile.kind := File.Kind_Unknown_Text; // 1/3/16  cnwns1 PAR 36286 unicode version	
	aFile.fileName := fileName;
	aFile.mode := File.Mode_Input;
	//create hgStr transient;							//TFS 61182		//30.08.24	navhn30	TFS 65667
	//allMsgs 	:= taskHistory.getRawDataString();	//TFS 61182			//30.08.24	navhn30	TFS 65667
	//maxLength 	:= hgStr.getMaxLength();			//TFS 61182		//30.08.24	navhn30	TFS 65667
	if aFile.tryOpen 
	and (app.computerName.toUpper = taskHistory.computerName.toUpper) then 
	//and allMsgs.length &lt; maxLength then				//TFS 61182		//30.08.24	navhn30	TFS 65667
		aFile.close;
		app.createExternalProcess("notepad.exe " &amp; fileName, false );
	else
		aFile.close;
		
		answer := app.msgBox(app.getErrorString(ERR_CAMS_OPENFILE) &amp; CrLf &amp; CrLf &amp; app.getErrorString(ViewStoredFile), app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Information_Icon);
		if answer = MsgBox_Return_Yes then
			if taskHistory.camProtocol.isJson then
				create messageLogForm transient;
				messageLogForm.setMyObject(taskHistory);
				messageLogForm.show;
			else
				create theLines transient;
				
				taskHistory.rawDataToHSA(theLines);
				app.msgBoxScroll(null, theLines, null, taskHistory.computerName, null);
			endif;
		endif;
	endif;
epilog	
	delete aFile;
	delete theLines;
	//delete hgStr;//TFS 61182
end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuContext4Click" id="20f485f1-325a-4c72-acc8-cd06ee1d2fa9">
        <updating/>
        <source>doMnuContext4Click(theMenuItem: MenuItem) updating;
// ---------------------------------------------------------------------------
// Created:		27 May 2003  by Jason Chapman  (cnwjc2)
