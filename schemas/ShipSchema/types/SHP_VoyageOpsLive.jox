    <JadeMethod name="translateForm" id="4aa19173-4a80-4d4d-9172-7da7dcd0a8e7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 February 2024 10:40:57.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025737, locale);
	btnAdditionalConfigs.translateBubbleHelp(Xlat_0026577, locale);
	btnCargoChecks.translateCaption(Xlat_0025738, locale);
	btnClear.translateCaption(Xlat_0025739, locale);
	btnConfirmToLocation.translateCaption(Xlat_0025740, locale);
	btnCreateCargo.translateBubbleHelp(Xlat_0025741, locale);
	btnCreateCargo.translateCaption(Xlat_0025742, locale);
	btnCustomerPri1.translateCaption(Xlat_0026641, locale);
	btnCustomerPri2.translateCaption(Xlat_0026642, locale);
	btnCustomerPri3.translateCaption(Xlat_0026643, locale);
	btnDeselectAll.translateCaption(Xlat_0026574, locale);
	btnExports.translateCaption(Xlat_0025743, locale);
	btnImports.translateCaption(Xlat_0025744, locale);
	btnMoveToLocation.translateCaption(Xlat_0025745, locale);
	btnQueue.translateCaption(Xlat_0025749, locale);
	btnQueueRTL.translateBubbleHelp(Xlat_0025814, locale);
	btnQueueRTL.translateCaption(Xlat_0025750, locale);
	btnRTL.translateBubbleHelp(Xlat_0025815, locale);
	btnRTL.translateCaption(Xlat_0025751, locale);
	btnRunVoyDisSum.translateCaption(Xlat_0026694, locale);
	btnRunVoyLoadSum.translateCaption(Xlat_0026695, locale);
	btnSearch.translateCaption(Xlat_0025752, locale);
	btnShortlandManiCargo.translateCaption(Xlat_0026696, locale);
