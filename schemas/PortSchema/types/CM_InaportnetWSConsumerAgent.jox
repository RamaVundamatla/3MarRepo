    <JadeMethod name="setupFromWebServiceDefinition" id="fe010b06-7479-490e-87fe-4ad2b2e190f6">
        <updating/>
        <source>setupFromWebServiceDefinition(_definition: CM_InaportnetWebService) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	inheritMethod(_definition);
	//epr TFS 45207 19/6/19
	if _definition.versionString = CM_InaportnetWebService.Version1_3 then
		create self.myIPNEntryRpkroConsumer transient;
		//epr TFS 45207 7/10/19
		self.myIPNEntryRpkroConsumer.setEndpointURL(_definition.baseEndpoint);	
		self.myIPNConsumer.setEndpointURL(_definition.baseEndpoint);
	endif;
	
	self.restAPIAuthEndpoint := _definition.restAPIAuthEndpoint;
	self.setRestAPIBaseEndpoint(_definition.restAPIBaseEndpoint);
	
epilog

end;</source>
        <Parameter name="_definition" type="CM_InaportnetWebService"/>
    </JadeMethod>
</Class>
