    <JadeMethod name="lastChangeReason" id="548492c8-3e07-43dc-9472-a7bce93e2202">
        <methodInvocation>mapping</methodInvocation>
        <source>lastChangeReason(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     28 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	lastNote : CM_Message;
	
begin
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
	else
		// get code here
		lastNote := self.allChangeNotes.last;
		if lastNote &lt;&gt; null then
			_value := lastNote.text;
		else
			_value := null;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="670d67b2-51d3-4bdd-8344-0caa6d97b294">
        <updating/>
        <source>setForUpdate(_pxySnapShot: CM_UserTISnapShot; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	15 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_pxySnapShot, _passport);
	self.ignore := _pxySnapShot.ignore;
	self.isOD 	:= _pxySnapShot.isOD;
	
	
end;</source>
        <Parameter name="_pxySnapShot" type="CM_UserTISnapShot"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setFromTISnapShot" id="5a3d5713-623b-4b61-b601-59b85c6fc84c">
        <updating/>
        <source>setFromTISnapShot(_tiSnapShot: CM_TISnapShot) updating;
//----------------------------------------------------------------
//	Created:	10 May 2006	by Jason Chapman  (cnwjc2)
//	13 May 2022	navgm20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
//	14 Sep 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
//----------------------------------------------------------------
vars

		realhaz, proxyhaz : CM_HazardSnapShot;
	snapshot : CM_SnapShot;
begin

//	virtuals
//	self.createdTime		:= _tiSnapShot.createdTime;
//	self.deleted			:= _tiSnapShot.deleted;
//	self.isEmpty			:= _tiSnapShot.isEmpty;
//	self.isHazardous		:= _tiSnapShot.isHazardous;
//	self.isOverDimensions	:= _tiSnapShot.isOverDimensions;
//	self.isReefer			:= _tiSnapShot.isReefer;
//	self.requiresPower		:= _tiSnapShot.requiresPower;
//	self.requiresTemperature:= _tiSnapShot.requiresTemperature;

	if not self.isTransient then
		self.myTISnapShot		:= _tiSnapShot;
	endif;

	self.availabilityGrade	:= _tiSnapShot.availabilityGrade;
	self.cargoType			:= _tiSnapShot.cargoType;
	self.commodity			:= _tiSnapShot.commodity;
	self.consignee			:= _tiSnapShot.consignee;
	self.consignor			:= _tiSnapShot.consignor;
	self.shippingLineCode 	:= _tiSnapShot.shippingLineCode;   	//13 may 2022 navgm20 tfs 53195
	self.myCountryOfOrigin 	:= _tiSnapShot.myCountryOfOrigin; 	//14.09.2022 navtnr20 54441
	self.contentsStatus		:= _tiSnapShot.contentsStatus;
	self.dischargePort		:= _tiSnapShot.dischargePort;
	self.height				:= _tiSnapShot.height;
	self.id					:= _tiSnapShot.id;
	self.imExStatus			:= _tiSnapShot.imExStatus;
	self.is40				:= _tiSnapShot.is40;
	self.isClean			:= _tiSnapShot.isClean;
	self.isoType			:= _tiSnapShot.isoType;
	self.isoTypeGroup		:= _tiSnapShot.isoTypeGroup;
	self.isToBeInspected	:= _tiSnapShot.isToBeInspected;
	self.isTransship		:= _tiSnapShot.isTransship;
	self.length				:= _tiSnapShot.length;
	self.loadPort			:= _tiSnapShot.loadPort;
	self.locationId			:= _tiSnapShot.locationId;
	self.operatorCode		:= _tiSnapShot.operatorCode;
	self.site				:= _tiSnapShot.site;
	self.sizeAttributes		:= _tiSnapShot.sizeAttributes;
	self.snapShotCreatedBy	:= _tiSnapShot.snapShotCreatedBy;
	self.snapShotDateTime	:= _tiSnapShot.snapShotDateTime;
	self.snapShotOf			:= _tiSnapShot.snapShotOf;
	self.temperature		:= _tiSnapShot.temperature;
	self.transitStatus		:= _tiSnapShot.transitStatus;
	self.typeAttributes		:= _tiSnapShot.typeAttributes;
	self.weight				:= _tiSnapShot.weight;
	self.width				:= _tiSnapShot.width;
	
	// TFS 40336
	self.hazard := _tiSnapShot.hazard;
	self.billOfLading := _tiSnapShot.billOfLading;
	self.cargoGroupId := _tiSnapShot.cargoGroupId;
	self.cargoSubtypeCode := _tiSnapShot.cargoSubtypeCode;
	self.cargoSubtypeDescription := _tiSnapShot.cargoSubtypeDescription;
	self.cargoTypeCode := _tiSnapShot.cargoTypeCode;
	self.cargoTypeDescription := _tiSnapShot.cargoTypeDescription;
	self.colour := _tiSnapShot.colour;
	self.commodity := _tiSnapShot.commodity;
	self.consignee := _tiSnapShot.consignee;
	self.consignor := _tiSnapShot.consignor;
	self.customsAgentCode := _tiSnapShot.customsAgentCode;
	self.description := _tiSnapShot.description;
	self.destinationPortCode := _tiSnapShot.destinationPortCode;
	self.destinationPortDescription := _tiSnapShot.destinationPortDescription;
	self.dischargePortDescription := _tiSnapShot.dischargePortDescription;
	self.isotypeDescription := _tiSnapShot.isotypeDescription;
	self.loadPortDescription := _tiSnapShot.loadPortDescription;
	self.mark := _tiSnapShot.mark;
	self.markNumber := _tiSnapShot.markNumber;
	self.remarks := _tiSnapShot.remarks;
	self.orderNumber := _tiSnapShot.orderNumber;
	self.temperature := _tiSnapShot.temperature;
	self.totalQuantity := _tiSnapShot.totalQuantity;
	self.totalVolume := _tiSnapShot.totalVolume;
	self.totalWeight := _tiSnapShot.totalWeight;
	self.voyageCode := _tiSnapShot.voyageCode;
	
	_tiSnapShot.stops.copy(self.stops);
	

	// TFS 40336
	foreach snapshot in _tiSnapShot.allHazSnapShots	discreteLock do
		 realhaz := snapshot.CM_HazardSnapShot;
		 
		 proxyhaz := realhaz.pxyGetProxyObject();
		 if proxyhaz = null then
			proxyhaz := app.createUpdateProxy(realhaz).CM_HazardSnapShot;
			
			proxyhaz.setMyTISnapShot( self);
		endif;
	endforeach;
	
	

end;</source>
        <Parameter name="_tiSnapShot" type="CM_TISnapShot"/>
    </JadeMethod>
