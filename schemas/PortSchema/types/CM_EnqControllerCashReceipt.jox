<Class name="CM_EnqControllerCashReceipt" id="2fc275a1-1098-4204-a71e-fd7bf6af6275">
    <superclass name="CM_EnquiryController"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="myBank" id="277b5855-a209-4c91-93a7-3dc52876f896">
        <embedded/>
        <type name="CM_Bank"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myDebtor" id="a77079ed-e554-4270-a67a-fe13dc38394f">
