        <updating/>
        <source>btnActual_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     08 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if (not self.toolbarClickPreProcessing(VIEW_BAYVIEW)) then
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;
	self.switchDisplayMode(ShpDisplayMode_Actual, true);

epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
