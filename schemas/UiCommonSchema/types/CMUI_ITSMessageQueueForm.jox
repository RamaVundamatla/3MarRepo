    <JadeMethod name="initSearcher" id="16de4f53-5ca0-46f3-a324-03ce390168b2">
        <source>initSearcher();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	#cnwdz2	 par21593

*/

vars
	
begin
	self.tblSearch.setEntTableDef(app.myController.getEntTableDef(ETDef_ITSInterfaceMsgSearch), null, null);
	self.setColorsForEntryTable(self.tblSearch);
	self.myAssistant.comboBoxMachineId(self.cmbMachineFilter,null);
