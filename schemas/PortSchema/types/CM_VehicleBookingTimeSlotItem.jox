    <JadeMethod name="setForUpdate" id="0ae24e59-95a8-4e15-9727-8746eb6b4f5a">
        <updating/>
        <source>setForUpdate(_proxyVBTimeSlotItem : CM_VehicleBookingTimeSlotItem; _vBTimeSlot : CM_VehicleBookingTimeSlot) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
02 June 2023	navpw1	TFS: 58256 - Added volume to be set on vbs time slot item
11 July 2024	navpw1	TFS: 61525 (61527) - Added Max Weight Field

*/

begin
	self.raiseExceptionIfTransient(method);
	
	self.myBooking 				:= _proxyVBTimeSlotItem.myBooking;
	self.myBookingItem 			:= _proxyVBTimeSlotItem.myBookingItem;
	self.myBulkRelease 			:= _proxyVBTimeSlotItem.myBulkRelease;
	self.myReserveDetails		:= _proxyVBTimeSlotItem.myReserveDetails;
	self.direction 				:= _proxyVBTimeSlotItem.direction;
	self.myTrackedItem			:= _proxyVBTimeSlotItem.myTrackedItem;
	self.myVehicleBookingSlot	:= _vBTimeSlot;
	self.quantity				:= _proxyVBTimeSlotItem.quantity;
	self.sequence				:= _proxyVBTimeSlotItem.sequence;
	self.sourceType				:= _proxyVBTimeSlotItem.sourceType;
	self.weight					:= _proxyVBTimeSlotItem.weight;
	self.volume					:= _proxyVBTimeSlotItem.volume;		// ### TFS 58256 02Jun2023 NAVPW1
	self.maxWeight				:= _proxyVBTimeSlotItem.maxWeight;	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
end;</source>
        <Parameter name="_proxyVBTimeSlotItem" type="CM_VehicleBookingTimeSlotItem"/>
        <Parameter name="_vBTimeSlot" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
