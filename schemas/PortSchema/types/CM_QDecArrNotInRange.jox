    <JadeMethod name="doMatch" id="f8dda2d5-5ed8-4046-bc7a-d615417e6196">
        <source>doMatch(_value: DecimalArray): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	decimalVal : Decimal[23,4];
begin
	foreach decimalVal in _value do
		if not ((decimalVal.Decimal &gt;= self.lowerValue) and (decimalVal.Decimal &lt;= self.searchValue)) then
			return true;
		endif;
	endforeach;
	return false;

epilog

end;</source>
        <Parameter name="_value" type="DecimalArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getLowerValue" id="fe586f0b-a9e4-421c-b391-4a8888756775">
        <source>getLowerValue(_prop: CM_QueryProperty): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/
vars

begin
	return _prop.translateToDisplayValue(self.lowerValue);
end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueRange" id="6400b8d7-e0e5-4240-b3ee-a60259f5aea2">
        <source>getSearchValueRange(_prop: CM_QueryProperty): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	weightRange : CM_WeightRange;
	measure : CM_MeasurementType;
	measureStr 	: String;
	pos : Integer;
begin
	pos := _prop.propertyName.pos(CN_UNDERSCORE, 1);
	if pos = null then
		return null;
	endif;
	
	measureStr := _prop.propertyName[1:pos-1];
	measure:=app.myRoot.allMeasurementTypesByShortName[measureStr];
	if measure &lt;&gt; null then
		weightRange:=app.myRoot.allWeightRanges[measure,self.searchValue.Integer];
	endif;
	
	return weightRange;

epilog

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="0752d3e1-e104-43e6-bd77-1e71f42f2ecf">
        <source>getSearchValueStr(_prop: CM_QueryProperty): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/
vars

begin
	
	return lowerValue.Integer.String &amp; "-" &amp; searchValue.Integer.String;
end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setLowerValue" id="45f9e59d-9226-4fb6-8815-f2f54c56cb98">
        <updating/>
        <source>setLowerValue(_value: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/
vars
	stringValue		: String;
	decimalValue	: Decimal[14,4];
begin
	if _value &lt;&gt; null then 
		stringValue := _value.String;
		if stringValue.isDecimal then
			decimalValue := stringValue.Decimal;
		else
			app.raiseCMException1(VB_INVALID_NUM, stringValue, null, null);
		endif;		
	endif;
	
	self.lowerValue := decimalValue;
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="c2298041-5888-4a7f-8356-29b301707006">
        <updating/>
        <source>setSearchValue(_value: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/
vars
	stringValue		: String;
	decimalValue	: Decimal[14,4];
begin
	if _value &lt;&gt; null then
		stringValue := _value.CM_WeightRange.value.String;
		if stringValue.isDecimal then
			decimalValue := stringValue.Decimal;
		else
			app.raiseCMException1(VB_INVALID_NUM, stringValue, null, null);
		endif;		
	endif;
	
	self.searchValue := decimalValue;
	self.lowerValue := _value.CM_WeightRange.lower;
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
</Class>
