    <JadeMethod name="doSaveChangeLocale" id="60aa54b3-5a3d-4387-8333-8483d8bead12">
        <source>doSaveChangeLocale();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation

*/

vars

begin
	app.setLocale(self.cmbLocale.listObject.CM_Locale);
	self.btnAbout.click(self.btnAbout);
	self.loadInfoTable();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveChangeQueue" id="79dd6658-b95d-4c82-b04c-9e56a089adea">
        <source>doSaveChangeQueue() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation

*/

vars
	errorMsgs : DTO_HandHeldGateErrorDict;
	queue		: CM_RadioTelemetryQueue;
begin

	create errorMsgs transient;
	queue:=self.tblChgQ.accessedRow.itemObject.CM_RadioTelemetryQueue;
	app.myVMAgent.doChangeQueue(queue, errorMsgs);
	
	if self.checkErrors(errorMsgs) then
		return;
	else
		self.btnAbout.click(self.btnAbout);
		self.loadInfoTable();
	endif;
epilog
	delete errorMsgs;
end;	</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSavePassword" id="ffbb45ef-f86b-4432-8be6-3c261362fb99">
        <source>doSavePassword()  protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation
20 Oct 2011	cnwkpd1	PAR #28510 - Problems logging on in Windows Mobile 6.5 device

*/

vars
	oldPW,
	newPW,
	confirmPW	: String;
	tmpError	: CM_Error;
begin
	oldPW 	:= self.txtOldPW.getPasswordText();			// PAR #28510
	newPW 	:=  self.txtNewPW.getPasswordText();
	confirmPW	:= self.txtConfirmPW.getPasswordText();

	app.myTrxUA.trxUpdatePassword(true, app.getMyUserCode, oldPW, newPW, confirmPW, app.myPassport);
	if app.myPassport.trxCompletedOK then
	 	self.btnAbout.click(self.btnAbout);
	else
		app.msgBox(app.myPassport.allErrors.last.text,app.getErrorString(Error),MsgBox_OK_Only);  // showErrorWarningDialog('Error(s)', app.myPassport, ErrWarnMode_Update);
		tmpError := app.myPassport.allErrors.first;
		if tmpError &lt;&gt; null and tmpError.errorCode = ERR_PASSWORD then
			txtOldPW.setFocus;
		else
			txtNewPW.setFocus;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadComboLocale" id="00100c88-64d9-4d6b-9be9-5e396597030d">
        <source>loadComboLocale() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation

*/

vars
	currentLocale : CM_Locale;
begin
	self.cmbLocale.listCollection(app.myRoot.allLocales,false,0);
	
	//cnwjo3 par 25670
	currentLocale := app.myCurrentLocale;
	if self.cmbLocale.findObject(currentLocale) &gt; 0 then
		self.cmbLocale.listObject:=currentLocale;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadComboScreenSize" id="df9b822e-2b90-4e82-8222-43112329d2a8">
        <source>loadComboScreenSize() protected;
/* ---------------------------------------------------------------------------
Created:     17 September 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.cmbScreenSize.sorted := true;
	self.cmbScreenSize.addItem(ScreenSize_Descr_Resizeable);
	self.cmbScreenSize.addItem(ScreenSize_Descr_HalfSVGA);
	self.cmbScreenSize.addItem(ScreenSize_Descr_SVGA);
	self.cmbScreenSize.addItem(ScreenSize_Descr_VGA);
	self.cmbScreenSize.addItem(ScreenSize_Descr_QVGA);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadInfoTable" id="d4bfa49e-a20e-4d06-98d5-68d7c13701ac">
        <source>loadInfoTable()  protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation

*/

vars
	tableDetailDecorator : CMIF_EntTableLikeFormDecorator;
	entTableDef				: EntTableDef;
	entRow					: EntTableRow;
begin
	create tableDetailDecorator transient;
	entTableDef:= app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RTMachineDetails];
	tableDetailDecorator.initDecorator(app.myVMAgent.myTerminal,self.tblDetails,entTableDef);
	tableDetailDecorator.initTable;

	

	tableDetailDecorator.addDataForEntRowName(ETRow_User,app.myPassport.getUserCode);
	tableDetailDecorator.addDataForEntRowName(ETRow_Terminal,app.myVMAgent.myTerminal.code);
	tableDetailDecorator.addDataForEntRowName(ETRow_Machine,app.myVMAgent.myMachine.id);
	tableDetailDecorator.addDataForEntRowName(ETRow_Device,app.myVMAgent.myRTDevice.id);
	tableDetailDecorator.addDataForEntRowName(ETRow_Queue,app.myVMAgent.myRTQueue.id);
	tableDetailDecorator.addDataForEntRowName(ETRow_Locale,app.myCurrentLocale.localeDescription);
	self.tblDetails.visible:=true;
	self.tblDetails.readOnly:=true;
	
	self.btnSave.visible:=false;
epilog
	delete tableDetailDecorator;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadQInfo" id="63524579-a7a8-495c-b423-06f99ff4d6e5">
        <source>loadQInfo()  protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation

*/

vars
	addedRow : JadeTableRow;
	rowIdx	: Integer;
	coll : CM_RadioTelemQueueByIdDict;
	queue 	: CM_RadioTelemetryQueue;

begin
	self.tblChgQ.rows:=0;
	self.tblChgQ.columns:=3;

	
	rowIdx:=self.tblChgQ.addItem(app.getErrorString(Queue) &amp; Tab &amp; app.getErrorString(Entries) &amp; Tab &amp; app.getErrorString(Machines));
	self.tblChgQ.fixedRows:=1;
	self.tblChgQ.accessRow(1).backColor:=app.myVMAgent.getMyScreenMode.screenBackColour;
	create coll transient;
	app.myVMAgent.getAllQueuesForType(coll,VehicleMountedAgent.Primary);
	
	foreach queue in coll do
		//epr par 25838 28/9/10
		if queue.allEntries.size = 0 and queue.allSubQueuesByOrder.size = 0 then
			continue;
		endif;
	
		rowIdx:=self.tblChgQ.addItem(queue.id &amp; Tab &amp; queue.allEntries.size.asStringJMT &amp; Tab &amp; queue.allMachines.size.asStringJMT);
		addedRow:=self.tblChgQ.accessRow(rowIdx);
		addedRow.itemObject:=queue;
		addedRow.marginTop:=5;
	endforeach;

epilog
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
