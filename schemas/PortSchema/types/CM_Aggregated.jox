    <JadeMethod name="validateForUpdate" id="22ddf278-8ac1-4332-a7af-34c3534cda4f">
        <source>validateForUpdate(pProxyTransaction: CM_TITransaction);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2017	jlgndl1	Initial creation	TFS 5744

*/

vars

begin

	// You cannot edit any fields for this transaction type
	app.raiseCMException(ERR_INVALID_TRANS_EDIT, null, null);
	
	inheritMethod(pProxyTransaction);

epilog

end;</source>
