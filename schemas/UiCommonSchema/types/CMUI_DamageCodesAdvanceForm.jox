    <JadeMethod name="translateForm" id="e4d815f4-a3e7-46fa-877c-f041a98310d6">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 December 2024 11:21:22.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010884, locale);
	btnAdd.translateCaption(Xlat_0010885, locale);
	btnAddImage.translateCaption(Xlat_0027010, locale);
	btnNew.translateCaption(Xlat_0024992, locale);
	btnRemove.translateCaption(Xlat_0010886, locale);
	btnUpdate.translateCaption(Xlat_0010887, locale);
	lblDamage.translateCaption(Xlat_0010889, locale);
	lblDamageReason.translateCaption(Xlat_0024993, locale);
	lblDamageRemarks.translateCaption(Xlat_0024994, locale);
	lblDateTime.translateCaption(Xlat_0024995, locale);
	lblLocation.translateCaption(Xlat_0024996, locale);
	lblNewDamage.translateCaption(Xlat_0011879, locale);
	lblPosition.translateCaption(Xlat_0010890, locale);
	lblQuantity.translateCaption(Xlat_0010891, locale);
	lblRepairDateTime.translateCaption(Xlat_0024997, locale);
	lblRepairReason.translateCaption(Xlat_0024998, locale);
	lblRepairedRemarks.translateCaption(Xlat_0024999, locale);
	lblResponsible.translateCaption(Xlat_0025000, locale);
	lblSeverity.translateCaption(Xlat_0010893, locale);
	lblSize.translateCaption(Xlat_0025001, locale);
	lblStatus.translateCaption(Xlat_0025002, locale);
	mnuTblInspectObject.translateCaption(Xlat_0023575, locale);
	mnuTblViewContext.translateCaption(Xlat_0023576, locale);
	optNo.translateCaption(Xlat_0010894, locale);
	optYes.translateCaption(Xlat_0010895, locale);
end;</source>
    </JadeMethod>
