    <JadeMethod name="fixupStockOnHand" id="55f52f5c-e18a-4e1e-a01c-3e1460bba07e">
        <updating/>
        <source>fixupStockOnHand(_passport : CM_Passport input; _comment :String; _parent : Object; 
				_cmifMonitor : CMIF_Monitor input; _localTransactions : Boolean) updating;
//--------------------------------------------------------------
//Created: 29 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	lc			: CM_LocationsController;
	saveMsg		: String;
begin

	if (not self.isStockControlled) then
		app.writeLog('Fixup Stock on Hand :: Terminal Area ' &amp; self.id &amp; ' skipped - not stock controlled', LogINFO);
		return;
	endif;
	
	if _cmifMonitor &lt;&gt; null then
		saveMsg := _cmifMonitor.message;
	endif;
	
	foreach lc in self.allLocationsControllers do
		app.writeLog('Fixup Stock on Hand :: Checking Location ' &amp; lc.getID, LogINFO);
		if _cmifMonitor &lt;&gt; null then
			_cmifMonitor.message := 'Location ' &amp; lc.getID;
		endif;
		if _localTransactions then
			beginTransaction;
		endif;
		exclusiveLock(lc);
		lc.fixupStockOnHand(_passport, _comment, _parent, _cmifMonitor);
		if (not _passport.noErrors) then
			return;
		endif;
		if _localTransactions then
			app.cmsCommitTransaction(_passport);
		endif;
	endforeach;

	if _cmifMonitor &lt;&gt; null then
		_cmifMonitor.message := saveMsg;		
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_parent" type="Object"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <Parameter name="_localTransactions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllLCsWithCargo" id="839c7d6e-f4e2-48f8-b46a-e55288a7ea45">
        <source>getAllLCsWithCargo(_locationControllerArray : ObjectArray io);

/*

Purpose:	Get all locations controllers and return if have tracked items		

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2010	cnwmh5	Initial creation

*/

vars
	locController : CM_LocationsController;
begin
	
	foreach locController in self.allLocationsControllers discreteLock do
		// no tracked items then don't require it
		if locController.allTrackedItems.isEmpty then
			continue;
		endif;
		// if not already in the array then add to the array
		if not _locationControllerArray.includes(locController) then
			_locationControllerArray.add(locController);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_locationControllerArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllLocationsControllers" id="d12d7072-d1ee-4fe6-ae07-f808e7180310">
        <source>getAllLocationsControllers(_locationControllerArray : ObjectArray io);

/*

Purpose:	Get all locations controllers and return if have tracked items		

*/

vars
	locController : CM_LocationsController;
begin
	
	foreach locController in self.allLocationsControllers discreteLock do
		if not _locationControllerArray.includes(locController) then
			_locationControllerArray.add(locController);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_locationControllerArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllLocationsTrackedItems" id="daf3a460-3e3b-4416-afb6-666e02cc62c5">
        <source>getAllLocationsTrackedItems( _objectSet : Collection input );

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
16 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)
17/9/25  			 jlier1 MTN-35637
*/
	
vars
	cm_LocationsController	: CM_LocationsController;
	cm_TrackedItem			: CM_TrackedItem;
	iter1					: Iterator;
	iter2					: Iterator;
	
begin
	// Return all Tracked Items for all of the location controllers of this terminal area.
	iter1	:= self.allLocationsControllers.createIterator;
	while iter1.next( cm_LocationsController ) do : cm_LocationsController_loop
		iter2	:= cm_LocationsController.allTrackedItems.createIterator;
		while iter2.next( cm_TrackedItem ) do : cm_TrackedItem_loop
			_objectSet.tryAddIfNotNull( cm_TrackedItem );
		endwhile cm_TrackedItem_loop;
		delete iter2;
	endwhile cm_LocationsController_loop;
	
epilog
	delete iter1;
	delete iter2;
	
end;
</source>
        <Parameter name="_objectSet" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllMachineVehicleConts" id="560e5170-0fb3-4f71-a8d1-1c2b28fa82f5">
        <source>getAllMachineVehicleConts( _locationControllerArray : ObjectArray io );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2019	jlgndl1	Initial creation	TFS 47954

*/

vars

	roadJobSheet : CM_RoadJobSheet;
	vehicle : CM_Vehicle;
	lastLocation : CM_LocationsController;
	machine : CM_Machine;

begin

	_locationControllerArray.clear();

	roadJobSheet := self.myTerminal.myRoadJobSheet;
	if roadJobSheet &lt;&gt; null then
		foreach vehicle in roadJobSheet.allInTerminalVehicles do
			if vehicle.myPrimaryActualLocation &lt;&gt; null then
				if vehicle.myPrimaryActualLocation.getMyTerminalArea = self then
					_locationControllerArray.add( vehicle.locationsController );
				endif;
			endif;
		endforeach;
	endif;
	
	foreach machine in self.myTerminal.machines do
		lastLocation := machine.myLastKnownLocation;
		if lastLocation &lt;&gt; null then
			if lastLocation.getMyTerminalArea = self then
				_locationControllerArray.add( machine.myMachineController );
			endif;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_locationControllerArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllProducts" id="0c532f11-eec7-4f9d-8f76-0bed70321323">
        <source>getAllProducts(_allProductsObj:CM_ProductByCodeCargoTypeDict input);
// --------------------------------------------------------------------------------
// Created:		02 December 2005 by cnwdad1
//
// Purpose:		Populates the specified collection with all Products that are in use
//				by the receiver's Grid Areas.
//
// Parameters:	_allProductsObj - A reference to the collection to populate.
//
// Returns:		The populated collection parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//	10 Jun 2015	NDL	Par 36392
// --------------------------------------------------------------------------------
vars
	lControllerOPbj	: CM_LocationsController;
	
begin
	foreach lControllerOPbj in self.allLocationsControllers do
		lControllerOPbj.getAllProducts(_allProductsObj);
	endforeach;
end;</source>
        <Parameter name="_allProductsObj" type="CM_ProductByCodeCargoTypeDict" usage="input"/>
    </JadeMethod>
