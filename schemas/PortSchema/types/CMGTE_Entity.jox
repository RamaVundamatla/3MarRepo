        <updating/>
        <source>setForCreateIfSubItem(_pxyGTE : CMGTE_Entity; _masterItem : CMGTE_Entity input; _tranNum : String) updating;
/* ---------------------------------------------------------------------------
Created:     12 May 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.setParentObject(_masterItem);
	self.setForCreate(_pxyGTE, null); //cnwrd1 par 24792 9.7.2010 was going to set the vvr here but it gets skipped underneatht his because we are a child item
	self.setTranNumber(_tranNum);


epilog

end;</source>
