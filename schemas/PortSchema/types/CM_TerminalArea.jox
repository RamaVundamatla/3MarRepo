    <JadeMethod name="hasReeferWalkIncluding" id="f923813b-1fc7-48aa-a88e-ac0d72b6e8cc">
        <source>hasReeferWalkIncluding( _lc : CM_LocationsController; _tier : Integer ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	iterBlock : Iterator;
	reeferBlock : CM_ReeferBlock;

begin

	iterBlock := self.allReeferBlocks.createIterator;
	while iterBlock.next( reeferBlock ) do
		if reeferBlock.hasReeferWalkIncluding( _lc, _tier ) then
			return true;
		endif;
	endwhile;
	
	return false;

epilog

	delete iterBlock;

end;</source>
