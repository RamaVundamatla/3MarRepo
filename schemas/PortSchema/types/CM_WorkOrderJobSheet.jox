<Class name="CM_WorkOrderJobSheet" id="110c88b0-3158-4268-a1c8-c73d9411e5f2">
    <superclass name="CM_JobSheet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Single Job Sheet for each Terminal
CM_Terminal::myWOJobSheet</text>
    <DbClassMap file="operatn"/>
    <ExplicitInverseRef name="myTerminal" id="f7cf427b-dd22-419d-be67-dc3a6372c1a0">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
        <Inverse name="CM_Terminal::myWOJobSheet"/>
    </ExplicitInverseRef>
</Class>
