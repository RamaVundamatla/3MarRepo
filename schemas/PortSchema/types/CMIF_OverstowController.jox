*/

vars

begin
	self.myCurrentLC :=_lc;
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setMachine" id="ec6c1a4f-e47f-45c0-9c2e-719feb522936">
        <updating/>
        <source>setMachine( _machine : CM_Machine) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2018	jlger1	Initial creation tfs 37584

*/

vars

begin
	if _machine &lt;&gt; null then
		self.accessMaxLocationReach := _machine.accessMaxLocationReach;
		self.accessMaxHeightDiff	:= _machine.accessMaxHeightDiff;
		self.accessMaxOverstowHeight := _machine.accessMaxOverstowHeight;
	endif;
epilog	

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="setMode" id="0c4c6c7b-2de0-4ecb-8306-9335de21b00b">
        <updating/>
        <source>setMode(_mode : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2018	jlger1	Initial creation

*/

vars

begin
	self.mode :=_mode;
	if self.myTI &lt;&gt; null then						
		self.myCurrentLC := self.myTI.getPrimaryLocation(self.mode);
		if self.myCurrentLC  &lt;&gt; null then
			self.currentHeight:=self.myCurrentLC.allTrackedItems.indexOf(self.myTI);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setParams" id="86ce05b7-9430-47fc-a04c-dda2bc972a35">
        <updating/>
        <source>setParams(	_accessDirection : Integer;
			_ti: CM_TrackedItem;
			_checkQueueEntry : Boolean;
			_queueEntry : CM_RTQueueEntry;
			_machine : CM_Machine ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2018	jlger1	Initial creation tfs 37584

*/

vars

begin
	self.accessDirection := _accessDirection;
	self.myTI := _ti;
	self.setMode(REAL_MODE);
	if _checkQueueEntry then
		self.myQueueEntry :=_queueEntry;
		if self.myTI &lt;&gt; null then
			if self.myQueueEntry = null then
				self.myQueueEntry := _ti.getQueueEntry;		
			endif;
		endif;
	endif;
	
	self.setMachine(_machine);
	
	
epilog

end;</source>
        <Parameter name="_accessDirection" type="Integer"/>
