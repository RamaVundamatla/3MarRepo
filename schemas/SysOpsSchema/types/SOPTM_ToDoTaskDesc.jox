    <JadeMethod name="doSave" id="4cf93c2d-91cb-418d-b14a-656bd35fb196">
        <updating/>
        <source>doSave(): Boolean updating;
// 19/06/2013	cnwcs5	par 31657 - tidy up while fixing par
// 02/11/2022   navds20 ChangeRequest 56634[54259]: EUP - Todo Task Description Maintenance
// 22 May 2023  navmv20 CR 57924 Task 57920: UI - Work Order Trans Types on TO DO Tasks
// 11/12/2023	jlizm1	TFS 61654 CUX ToDo Task don't block RTL
// 13/03/2024   navra1  BUG 62783 - FR - System Admin / To Do Task Description and Resources Type Edits
vars
	form				: SOP_TableMaintForm;
	table				: CM_EntryTable;
	lEmptyReportColumn	: Integer;
	rtnValue			: Boolean;
	proxy				: CM_ToDoTaskDesc;
	lDescription		: String;
	lSortKey			: Integer;
	lReportDescription	: String;
	lShortDescription	: String;
	trxComplete, trxCreate : CM_TransactionType; //cnwrs1 CCMS 1826 29 July 2010
	selectedCargoTypes	: ObjectArray;
	requiresWO			: Boolean;
	requiredExtraInfo   : String;
	selectedResourceTypes : CM_ObjectSet;
	allResourceTypes	: CM_ObjectSetActual;
	resourceType		: CM_ResourceType;
	mandatoryResources	: StringArray;
	str 				: String;
	mandatoryResourcesStr : String;
	doNotBlockRTL		: Boolean;
	selectedTerminals 		: CM_TerminalSet;	//13 Oct 2010	NDL Par 23991
	selectedSubTerminals 	: CM_SubTerminalByCodeDict;	//13 Oct 2010	NDL Par 23991
	realToDoTaskDesc 		: CM_ToDoTaskDesc;	//13 Oct 2010	NDL Par 23991
	term 					: CM_Terminal;	//13 Oct 2010	NDL Par 23991
	failedDAC  				: CM_DataAccessController;	//13 Oct 2010	NDL Par 23991
	type 					: Integer;
	eventComplete, eventCreate : CM_EventType;	//02/11/2022 navds20 TFS 56634[54259
	lObjcomplete,						//22/05/2023  navmv20 CR 57924 Task 57920
	lObjCreation			: Object; 	//22/05/2023  navmv20 CR 57924 Task 57920
	criteria				: CM_TaskCriteria;			//navra1 - 13th March 2024 - BUG 62783
begin
    form 	:= self.myForm; 
	table	:= form.tblInput1;
	proxy 	:= form.myProxyObject.CM_ToDoTaskDesc;

	
	lDescription			:=	table.getValueByName(ETRow_Description).String;
	lSortKey				:=	table.getValueByName(ETRow_SortKey).Integer;
	lReportDescription		:=	table.getValueByName(ETRow_ReportDescription).String;
	lShortDescription		:=	table.getValueByName(ETRow_ShortDescription).String;
	requiresWO				:=  table.getValueByName(ETRow_RequiresWorkOrder).Boolean;
	requiredExtraInfo       :=  table.getValueByName(ETRow_RequiredExtraInfo).String;
	doNotBlockRTL			:=	table.getValueByName(ETRow_DoNotBlockRTL).Boolean;

	type := app.getToDoTaskStringToInt(form.tblInput1.getValueByName(ETRow_Type).String); 						//31/10/2022 navds20 TFS 56634[54259]
	
	//22/05/2023  navmv20 CR 57924 Task 57920 - START
	/*
	if type = TODO_TYPE_GROUP_TI 																				// ### TFS 56634[54259] 28NOV2022 NAVAB1 
	or type = TODO_TYPE_GROUP_CARGOGROUP then // ### TFS 56634[54259] 21NOV2022 NAVAB1
	// ### TFS 56634[54259] 21NOV2022 NAVAB1 if form.cmbTransaction.listObject.isKindOf(CM_TransactionType) then		//02/11/2022 navds20 TFS 56634[54259]
		trxComplete := form.cmbTransaction.listObject.CM_TransactionType;
		trxCreate 	:= form.cmbTrxOnCreation.listObject.CM_TransactionType; 
	//start 02/11/2022 navds20 TFS 56634[54259]
	else
		eventComplete := form.cmbTransaction.listObject.CM_EventType;
		eventCreate := form.cmbTrxOnCreation.listObject.CM_EventType;
	endif;
	//end 02/11/2022 navds20 TFS 56634[54259]
	*/
	
	lObjcomplete := form.cmbTransaction.listObject;
	lObjCreation := form.cmbTrxOnCreation.listObject;
		
	if lObjcomplete.isKindOf(CM_TransactionType) then
		trxComplete := lObjcomplete.CM_TransactionType;
	elseif lObjcomplete.isKindOf(CM_EventType) then
		eventComplete := lObjcomplete.CM_EventType;
	endif;	
			
	if lObjCreation.isKindOf(CM_TransactionType) then
		trxCreate := lObjCreation.CM_TransactionType;
	elseif lObjCreation.isKindOf(CM_EventType) then
		eventCreate := lObjCreation.CM_EventType;
	endif;
	//22/05/2023  navmv20 CR 57924 Task 57920- END
	
	if type = TODO_TYPE_GROUP_TI 													// ### TFS 56634[54259] 21NOV2022 NAVAB1 
	or type = TODO_TYPE_GROUP_CARGOGROUP then 										// ### TFS 56634[54259] 28NOV2022 NAVAB1
		if form.cmbMTReportCol.listIndex &gt; MTReportTaskColumn_Null then
			lEmptyReportColumn	:=	form.cmbMTReportCol.listIndex;
		endif;
	endif;
	
	if proxy = null then
		if form.mode = form.Mode_Add then
			create proxy transient;
			
			form.myProxyObject := proxy;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	create selectedCargoTypes transient;
	if type = TODO_TYPE_GROUP_TI 													// ### TFS 56634[54259] 21NOV2022 NAVAB1 
	or type = TODO_TYPE_GROUP_CARGOGROUP then 										// ### TFS 56634[54259] 28NOV2022 NAVAB1
		form.mulSelect1.getSelected(selectedCargoTypes);
	endif;
	
	//18 Dec 2009	NDL	CCMS MES 1006
	create selectedResourceTypes transient;
	form.mulSelect2.getSelected(selectedResourceTypes);
	
	//13 Oct 2010	NDL Par 23991
	create selectedTerminals transient;		
	create selectedSubTerminals transient;
	if type = TODO_TYPE_GROUP_TI 													// ### TFS 56634[54259] 21NOV2022 NAVAB1 
	or type = TODO_TYPE_GROUP_CARGOGROUP then										// ### TFS 56634[54259] 28NOV2022 NAVAB1
		form.mulSelect3.getSelected(selectedTerminals);
	
		// Also need to include those terminals that were already selected, that this user doesn't have access to.
		// Because, we don't want them accidently removing someone elses data.
		realToDoTaskDesc := form.myCurrentObject.CM_ToDoTaskDesc;
		
		if realToDoTaskDesc &lt;&gt; null then
			foreach term in realToDoTaskDesc.allAllowedReleaseTerms do
				if not term.canUserAccessSelf( app.getMyUser(), failedDAC, app.myPassport) then
					if not selectedTerminals.includes(term) then
						selectedTerminals.add(term);
					endif;
				endif;
			endforeach; 
		endif;
		
		form.mulSelect6.getSelected(selectedSubTerminals);
		//end of //13 Oct 2010	NDL Par 23991
	endif;
	
	/* TFS 8117 JLGAB1 REMOVING
	Not sure why this code was written. It is not part of the original CCMS - MES 1006
	F:\Archive\PORT\CCMS-Specs\MessinaLine\Spec-Yard\7.8.1
	
	It seems to think that if a resource is in the transaction map that it becomes mandatory.
	It checks to see if any of the task resources in the whole system are mapped in the transaction map to the selected transaction type in the UI
	if it is it thinks that this means that the updating todo task type must have it as a resource.
	This is wrong and makes no sense. 
	It didn't even check if the mapped resource types were on an active transaction map, or if it was mapped to an invoice line
	and it only did it during an update of the todo task description.

	create mandatoryResources transient;
	
	if form.mode = form.Mode_Update and trxComplete &lt;&gt; null then
		foreach resourceType in app.myRoot.allTaskResourceTypes do	
			if not resourceType.isAvailable then
				continue;
			endif;
			
			if resourceType.isMapped( trxComplete ) then
				if not selectedResourceTypes.includes(resourceType) then
					selectedResourceTypes.add(resourceType);
					mandatoryResources.add(resourceType.description);
				endif;
			endif;
		endforeach;
	endif; 
	
	if not mandatoryResources.isEmpty then
		foreach str in mandatoryResources do
			if mandatoryResourcesStr = null then
				mandatoryResourcesStr := str;
			else
				mandatoryResourcesStr := mandatoryResourcesStr &amp; ", " &amp; str;
			endif;
		endforeach;
		
		if app.msgBox( app.getErrorString2(Trans_map_auto_select,trxComplete.description,mandatoryResourcesStr), app.getErrorString(Warning),MsgBox_Yes_No) = MsgBox_Return_No + MsgBox_Exclamation_Mark_Icon then
			return false;
		endif;
	endif;
	*/

	proxy.setProxy(	lDescription,
								lShortDescription,
								lSortKey,
								lReportDescription,
								lEmptyReportColumn,
								trxComplete,
								trxCreate,
								selectedCargoTypes,
								selectedResourceTypes,
								requiresWO,
								requiredExtraInfo,
								selectedTerminals,		//_selectedTerminals : CM_TerminalSet;	//13 Oct 2010	NDL Par 23991
								selectedSubTerminals,	//CM_SubTerminalByCodeDict	//13 Oct 2010	NDL Par 23991
								type,					//02/11/2022 navds20 TFS 56634[54259]
								eventComplete,			//02/11/2022 navds20 TFS 56634[54259]
								eventCreate,			//02/11/2022 navds20 TFS 56634[54259]
								doNotBlockRTL			//TFS 61654
								); 						//cnwrs1 CCMS 1826 29 July 2010
								

	if form.mode = form.Mode_Add then
		app.myTrxCA.trxCreateToDoTaskDesc(proxy, form.myCurrentObject, app.myPassport);
		
		rtnValue :=	app.myPassport.trxCompletedOK;
		
	elseif form.mode = form.Mode_Update then
		//navra1 - 13th March 2024 - BUG 62783 - start
		realToDoTaskDesc := form.myCurrentObject.CM_ToDoTaskDesc;
		
		app.myPassport.clearErrorsWarnings();
		
		if realToDoTaskDesc &lt;&gt; null then
			//clean up any collections while changing the type
			if realToDoTaskDesc.type &lt;&gt; proxy.type then
				if realToDoTaskDesc.type = TODO_TYPE_GROUP_TI or realToDoTaskDesc.type = TODO_TYPE_GROUP_CARGOGROUP then
					if proxy.type &lt;&gt; TODO_TYPE_GROUP_TI and proxy.type &lt;&gt; TODO_TYPE_GROUP_CARGOGROUP then
						proxy.allCargoTypes.clear();
						proxy.allAllowedEditSubTerms.clear();
						proxy.allAllowedReleaseTerms.clear();						
						foreach criteria in realToDoTaskDesc.allTaskCriteria do
							app.myTrxDA.trxDeleteObjMatchCrit(criteria, app.myPassport);
						endforeach;
					endif;					
				endif;
			endif;
		endif;
		
		if app.myPassport.hasErrors() then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Errors :' &amp; app.myPassport.getAllErrorsWarningsAsString());
			return false;
		endif;
		//navra1 - 13th March 2024 - BUG 62783 - end
		
		app.myTrxUA.trxUpdateToDoTaskDesc(proxy, app.myPassport);
		
		rtnValue :=	app.myPassport.trxCompletedOK;
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; form.mode.String &amp; ')');
		return false;
		
	endif;
	
	return rtnValue;
epilog
	delete selectedCargoTypes;
	delete selectedResourceTypes;
	delete allResourceTypes;
	delete mandatoryResources;
	delete selectedTerminals;		//13 Oct 2010	NDL Par 23991
	delete selectedSubTerminals;	//13 Oct 2010	NDL Par 23991
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblData1DblClick" id="6274ef61-3650-49eb-9a90-cefe53c404ea">
        <source>doTblData1DblClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2016	cnwmp6	Initial creation	TFS 2443
16 July   2019  cnwma1	Bug 45579: JMT - To Do Task Description causing a 1090 error to occur when saving
*/

vars
	form		: SOP_TableMaintForm;
	table		: CM_DataTable;
	row			: JadeTableRow;
	toDoDesc	: CM_ToDoTaskDesc;
	taskCrit	: CM_TaskCriteria;
	term		: CM_Terminal;
	critForm	: CMUI_ObjectCriteriaLineForm;
	
begin
	form := self.myForm;
	if form.mode = form.Mode_View or  form.myCurrentObject = null then  // 16.07.2019 cnwma1 Bug #45579
		return;
	endif;
	table := form.tblData1;
	row := table.accessedRow;
	term := row.itemObject.CM_Terminal;
	toDoDesc := form.myCurrentObject.CM_ToDoTaskDesc;
	if form.myProxyObject &lt;&gt; null then
		taskCrit := form.myProxyObject.CM_ToDoTaskDesc.allTaskCriteria.getAtKey(term, toDoDesc.code);	// ### TFS 62186 (62196) 02Feb2024 NAVPW1
	endif;
	create critForm transient;
	critForm.setMyTerminal(term);
	critForm.setBaseData(	CM_ObjectMatchCriteria.TaskCriteriaInt,	//_context : Integer;
							toDoDesc,	//_contextObj : CM_Object;
							taskCrit,	//_myObjectMatchCriteria : CM_ObjectMatchCriteria;
							null,	//_myListForm : CMUI_ObjectCriteriaListForm
							null	//_myParentForm: CM_BaseForm
							);
	critForm.showModal;
	if taskCrit &lt;&gt; null then
		delete taskCrit;
	endif;
	delete form.myProxyObject;
	
	if form.myCurrentObject &lt;&gt; null then  // 16.07.2019 cnwma1 Bug #45579
		form.myProxyObject := app.createUpdateProxy(form.myCurrentObject.CM_ToDoTaskDesc);
	endif;
	
	self.showThumbnail_Terminal(toDoDesc);
	
epilog
	delete critForm;
end;</source>
    </JadeMethod>
