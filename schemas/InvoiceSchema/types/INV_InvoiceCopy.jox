    <JadeMethod name="doBaseFormSave" id="f940ad4b-2742-48bf-8c66-0c707069b863">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Purpose:			Saves the data entered on the form for an invoice

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
10 Apr 2023 navtnr20	TFS CR 55303	Task 55531: UI - Invoice NEW UI Changes Invoice Copy
26 Apr 2023 navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 		navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
05 June 2023 		navtnr20	Bug 58389: EUP - Show Confirmation Message for Copied Invoice
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/

vars
	realInvoice,pxyInvoice : CM_Invoice;
	theReturn	: Integer;
	dateStr : String;
	cmifInvoiceList : CMIF_InvoiceCopy;
	now   : TimeStamp;
	status : Integer;		// 26.4.2023 navmk20 TFS 57663
	allWorkOrders : CM_WorkOrderSet;
begin
	status := self.cmbStatusInvProp.itemData[self.cmbStatusInvProp.listIndex];	// 26.4.2023 navmk20 TFS 57663
	create allWorkOrders transient;		//navtnr20 31-05-2023 58089
	self.mulWorkOrder.getSelected(allWorkOrders);
	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(self.myCurrentBank,
								self.cmbDebtorInvProp.listObject.CM_Debtor,
								self.cmbDebtorAddressProp.listObject.CM_Address,		    //22.07.2019 cnwma1 TFS #45577
								self.cmbVoyageInvProp.listObject.CM_Voyage,
								self.cmbInvTypeInv.listObject.CM_InvoiceDesc,
								//self.cmbStatusInvProp.text = app.getErrorString(Suspense),	// for manual invoice - is it Suspense status? default is Pending. Par17895 september 2008 // 26.4.2023 navmk20 TFS 57663
								status, // 26.4.2023 navmk20 TFS 57663
								true,	//isManual
								self.myCurrentTI,
								self.myBillOfLading,		//For manual invoice creation
								self.myBookingRef,			//For manual invoice creation
								self.myCurrentCargoGroup,	//For manual invoice creation
								self.myReleaseRequest,		//For manual invoice creation
								self.cmbCategory.itemData[self.cmbCategory.listIndex], // 01/02/2023	navkc1	TFS CR 55305 TASK 55537
								self.tblInvProperties.getValueByName(ETRow_PurchaseOrderNumber).String,  // ### BUG 56925 07MAR2023 NAVAB1
								self.myCurrentInvoice.myInvoiceProcess, // 26.4.2023 navmk20 TFS 57663
								allWorkOrders,	 //navtnr20 23-05-2023 BUG 58089
								self.txtNarr.text, //14/08/2023	navkc1	Bug 59803
								self.cmbTermsTrade.listObject.CM_InvoiceTermsOfTrade, //14/08/2023	navkc1	Bug 59803
								self.tblInvProperties.getValueByName(ETRow_DebtorReference).String,	//14/08/2023	navkc1	Bug 59803
								self.cmbCurrencyType.listObject.CM_CurrencyType, //14/08/2023	navkc1	Bug 59803
								self.cmbLocale.listObject.CM_Locale, //14/08/2023	navkc1	Bug 59803
								self.cmbDebtorAltAddrProp.listObject.CM_Address //14/08/2023	navkc1	Bug 59803
								);	
								
	
	//13/01/2025	navkc1 JIRA Bug MTN-33142 - Also link the selected invoice to the credit note
	if self.isCreditNote then
		self.allInvoicesToLink.copyNoDuplicates(pxyInvoice.allCreditInvoices, false);
	endif;
	
	create cmifInvoiceList transient;
	cmifInvoiceList.myProxyInvoice := pxyInvoice;
	cmifInvoiceList.myInvoice := self.myCurrentInvoice;

	// ### JIRA 19932 21OCT2024 NAVAB1
	if not self.doSaveDLRT(cmifInvoiceList) then
		return;
	endif;
	
	/*// ### JIRA 19932 21OCT2024 NAVAB1
	while true do
		app.myTrxCA.trxCopyInvoiceList(cmifInvoiceList, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			// START //navtnr20 05-06-2023 BUG 58389
			if cmifInvoiceList.myInvoice.isCreditNote() then
				if cmifInvoiceList.myInvoice.externalNumber = null then	//navtnr20 05-06-2023 BUG 58389
					app.msgBox( app.getErrorString1(Credit_note_create_success, cmifInvoiceList.myInvoice.sequenceNum.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				else
					app.msgBox( app.getErrorString2(Credit_note_ext_create_success, cmifInvoiceList.myInvoice.sequenceNum.String, cmifInvoiceList.myInvoice.externalNumber), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				endif;
			else
				if cmifInvoiceList.myInvoice.externalNumber = null then
					app.msgBox( app.getErrorString1(Invoice_created_successful, cmifInvoiceList.myInvoice.sequenceNum.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				else
					app.msgBox( app.getErrorString2(Invoice_ext_created_successful, cmifInvoiceList.myInvoice.sequenceNum.String, cmifInvoiceList.myInvoice.externalNumber), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				endif;
			endif;
			//END navtnr20 05-06-2023 BUG 58389
			self.clearErrorWarnings();
			global.beep;
			break;
			
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Manual_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	*/
	
	self.unloadForm();
	
epilog
	delete allWorkOrders;  //navtnr20 23-05-2023 BUG 58089
	delete cmifInvoiceList; //navtnr20 23-05-2023 BUG 58089
	delete pxyInvoice; //navtnr20 23-05-2023 BUG 58089
	
end;</source>
        <access>protected</access>
    </JadeMethod>
