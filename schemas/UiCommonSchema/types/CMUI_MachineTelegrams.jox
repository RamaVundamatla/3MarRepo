    <JadeMethod name="doDelete" id="6d156364-bcf4-408d-852a-67a62bd6943e">
        <updating/>
        <source>doDelete()updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

	result			: Integer;
	msgStr			: String;
	selectedObj 	: Object;
	objectArray		: CM_ObjectArrayActual;
	
begin

	while true do
		foreach selectedObj in self.tblTelegrams.allSelectedObjects discreteLock do 
			app.myTrxDA.trxDeleteCMObject(selectedObj.CM_Object, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
				if result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
		
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
		endforeach;
		break;
	endwhile;	

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doGetLogSuccessful" id="111d2400-ff02-45de-b447-5597d7ebec80">
        <source>doGetLogSuccessful(_param : String);
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	app.msgBox(_param &amp; " to C:\Temp", "File Saved",MsgBox_OK_Only);

epilog

end;</source>
        <Parameter name="_param" type="String"/>
    </JadeMethod>
    <JadeMethod name="doGetLogs" id="80cc0067-66bf-46c3-af3b-d24cc6de1934">
        <source>doGetLogs();
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	filePath,fileName :String;
	file : File;
	errText : String;
	found : Boolean;
	log : JadeLog;
	binary : Binary;
	nfr  : NR_NodeFileRequest;
	msg :String;
begin

	filePath:=app.getProfileStringAppServer(app.getIniFileNameAppServer,'JadeLog','LogDirectory',null);
	fileName:="JMTTwistLockReader_" &amp; self.myMachine.id;
	create log transient;
	fileName:=fileName.toLower;
	log.fileName:=fileName;
	fileName:= log.getActualFileNameServer;
	


	delete log;
	
	create nfr transient;
	nfr.getFile(fileName);
	nfr.outputDetails("C:\Temp",self,CMUI_MachineTelegrams::doGetLogSuccessful.name);
	
	
	
	
epilog
delete nfr;
	delete file;
	
end;</source>
    </JadeMethod>
