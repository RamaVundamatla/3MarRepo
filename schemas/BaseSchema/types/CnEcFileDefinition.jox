    <JadeMethod name="set" id="4b4e2b58-bb62-4d4d-b8e4-af021e4a6bcb">
        <updating/>
        <source>set(pFileTitle:String;
	pFileName:String;
	pFilePath:String) updating;
// --------------------------------------------------------------------------------
// Method:		set
//
// Purpose:		Public interface to set the File Definition properties.
//
// Parameters:	None
// Returns:		Nothing
// --------------------------------------------------------------------------------
begin
	if (self.fileName &lt;&gt; pFileName) then
		self.fileName	:=	pFileName;
	endif;

	self.filePath	:=	pFilePath;

	// Finally, set the key title property.

	if (self.fileTitle &lt;&gt; pFileTitle) then
		self.fileTitle	:=	pFileTitle;
	endif;
end;</source>
        <Parameter name="pFileTitle" type="String"/>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pFilePath" type="String"/>
    </JadeMethod>
    <JadeMethod name="setHeaderRecord" id="a374c3d7-926e-4bc7-bef5-084a013f08bd">
        <updating/>
        <source>setHeaderRecord(pRecordObj:CnEcFileRecord) updating;
// --------------------------------------------------------------------------------
// Method:		setHeaderRecord
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
// --------------------------------------------------------------------------------
begin
	if (self.myHeaderRecord &lt;&gt; pRecordObj) then
		self.myHeaderRecord	:=	pRecordObj;
	endif;
end;</source>
        <Parameter name="pRecordObj" type="CnEcFileRecord"/>
    </JadeMethod>
