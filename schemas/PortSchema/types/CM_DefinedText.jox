    <JadeMethod name="setForUpdate" id="ed0b5a3e-bf0d-4f64-a674-a9cd512832c9">
        <updating/>
        <source>setForUpdate(_pxyDefinedText : CM_DefinedText) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 October 2022	navvt20	ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars
   
begin
	self.sortOrder				:= _pxyDefinedText.sortOrder;
	self.context 				:= _pxyDefinedText.context;
	self.isNotAvailableForEntry := _pxyDefinedText.isNotAvailableForEntry;
	self.text					:= _pxyDefinedText.text;
	self.myTerminal				:= _pxyDefinedText.myTerminal;
epilog

end;</source>
        <Parameter name="_pxyDefinedText" type="CM_DefinedText"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="8e23cb81-4b2c-4bb5-a173-7588f76e8f06">
        <updating/>
        <source>setProxy( _context ,
		  _sortorder : Integer;
		  _isNotAvailableForEntry : Boolean;
		  _text : String;
		  _terminal : CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 October 2022	navvt20 ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars

begin
	raiseExceptionIfNotTransient(method);
	self.context 				:= _context;
	self.sortOrder 				:= _sortorder;
	self.text					:= _text;
	self.isNotAvailableForEntry := _isNotAvailableForEntry;
	self.myTerminal				:= _terminal;
epilog

end;</source>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_sortorder" type="Integer"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="56723f91-82cb-4948-a3a4-32c14786bcd5">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2022	navhl20	ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName  = CM_DefinedText::context.name then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
