    <JadeMethod name="testRTSSave" id="b8f6826e-cf0e-4fbf-854e-30b511d3aea7">
        <updating/>
        <source>testRTSSave(): Boolean updating;
//----------------------------------------------------------------
//	Created:	03 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.rtsSaved or (not self.myLLCAgent.comparisonComplete) then
		return true;
	endif;

	return doRTSSave();
end;</source>
        <ReturnType type="Boolean"/>
