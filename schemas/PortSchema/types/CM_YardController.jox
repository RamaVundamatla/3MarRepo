    <JadeMethod name="createTALocationsAudits_Power" id="c3002756-9036-4ad4-abfa-9b3012a17794">
        <updating/>
        <source>createTALocationsAudits_Power(_realLC, _proxy :CM_YardController; _ta :CM_TerminalArea) updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 March 2011 by cnwcs5 CCMS CPL 2027 / PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	newValue, oldValue	:Boolean;
begin
	oldValue := _realLC.power;
	newValue := _proxy.power;
	
	if oldValue &lt;&gt; newValue then
		if newValue then
			app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (_ta, self, CM_AuditTALocations.LocnTypeUpdate_PowerAvail, AuditCreated, null);
		else
			app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (_ta, self, CM_AuditTALocations.LocnTypeUpdate_PowerAvail, AuditDeleted, null);
		endif;	
	endif;
	
	oldValue := _realLC.powerDamaged;
	newValue := _proxy.powerDamaged;
	
	if oldValue &lt;&gt; newValue then
		if newValue then
			app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (_ta, self, CM_AuditTALocations.LocnTypeUpdate_PowerDamage, AuditCreated, null);
		else
			app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (_ta, self, CM_AuditTALocations.LocnTypeUpdate_PowerDamage, AuditDeleted, null);
		endif;	
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_realLC" type="CM_YardController"/>
        <Parameter name="_proxy" type="CM_YardController"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="erase" id="a29236de-bdda-43fa-b813-4b180524d26d">
        <updating/>
        <source>erase(_eraseLevel:	Integer) updating;

vars

	canDeleteSpecial : Boolean;
begin

	exclusiveLock(self);
	
	canDeleteSpecial := (self.status = LC_Status_Archived and app.isGarbageCollectionProcess);
	
	if (not self.isTransient) then
		if self.numTIs &gt; 0 then
			app.setContinueCMExceptions(false);
			// PAR 20584 AKB2009SEP app.raiseCMException2(ERR_LC_HAS_TIS," ACTUAL ",self.getFullId, null, null);
			app.raiseCMException1(ERR_LC_HAS_TIS_ACTUAL, self.getFullId, null, null);// PAR 20584 AKB2009SEP
			return;	
		elseif self.numPlannedTIs &gt; 0 and not canDeleteSpecial then
			app.setContinueCMExceptions(false);
			// PAR 20584 AKB2009SEP app.raiseCMException2(ERR_LC_HAS_TIS," PLANNED ", self.getFullId, null, null);
			app.raiseCMException1(ERR_LC_HAS_TIS_PLANNED, self.getFullId, null, null);// PAR 20584 AKB2009SEP
			return;	
		elseif self.numQueuedTIs &gt; 0 and not canDeleteSpecial then
			app.setContinueCMExceptions(false);
			// PAR 20584 AKB2009SEP app.raiseCMException2(ERR_LC_HAS_TIS," QUEUED ",self.getFullId, null, null);
			app.raiseCMException1(ERR_LC_HAS_TIS_QUEUED, self.getFullId, null, null);// PAR 20584 AKB2009SEP
			return;		
		endif;
	endif;
	
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="executeDisplayNotesForMove" id="42b4783f-bf32-4d1e-9c29-74b6df2b237c">
        <source>executeDisplayNotesForMove(_controller : CMIF_MoveController);
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theVoyage 	: CM_Voyage;	
	theTerminal : CM_Terminal;
	theTI 		: CM_TrackedItem;
	termArea    : CM_TerminalArea;
begin
	theTerminal := self.myTerminal;
	theTI 		:= _controller.myTrackedItem;
	theVoyage 	:= theTI.myVoyage;
	termArea    := self.myTerminalArea;

	// Par 11095 Terminal Area Enquiry Screen not Refreshing
	if self &lt;&gt; null and termArea &lt;&gt; null then
		app.myEventManager.createSingleObjInfoNoteEvt(termArea,	theTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),self);
	endif;
	// Par 11095 end
	
	if self &lt;&gt; null and termArea &lt;&gt; null then
		
		// PAR 10328
		if  self = _controller.myOriginatingLocation then
			app.myEventManager.createSingleObjInfoNoteEvt(termArea, theTerminal.getTerminalEvent(EVENT_TI_MOVE_FROM_LOCATION),theTI);
		elseif self = _controller.myToPrimaryLocation then
			app.myEventManager.createSingleObjInfoNoteEvt(termArea, theTerminal.getTerminalEvent(EVENT_TI_MOVE_TO_LOCATION),theTI);
		endif;
		app.myEventManager.createSingleObjInfoNoteEvt(termArea, theTerminal.getTerminalEvent(EVENT_TI_MOVE),self);
			
	endif;

	// update the load list
	if termArea &lt;&gt; null then
		if not _controller.isUndoMove and _controller.moveMode = PLANNING_MODE then
			// this is used in the load list
			app.myEventManager.createSingleObjInfoNoteEvt(termArea,theTerminal.getTerminalEvent(EVENT_PLANNING_TI_PLANNED),
				theTI);
		endif;

		// calling this event whether unplanning or not means that the TI is added to the load list as it arrives in the yard
		// this is used in the load list
		if theVoyage &lt;&gt; null then
			// PAR 33644 if theVoyage.isNonPlannedVoyage or theVoyage.isNonWorkedVoyage then
			if theVoyage.isHOLDSorSHIP() then
				app.myEventManager.createSingleObjInfoNoteEvt(theVoyage,theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
					theVoyage);								
			elseif (_controller.isUndoMove 
					// ### Just arrived by road/rail.
					or (_controller.isSystemMove and _controller.isForcedMove and _controller.myOriginatingLocation = null ) ) then 
				app.myEventManager.createSingleObjInfoNoteEvt(theVoyage,theTerminal.getTerminalEvent(EVENT_PLANNING_TI_UNPLANNED),theTI);
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_controller" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="executePostMoveForToLocation" id="274f67d2-c2ed-4b53-a565-3e1ffb3c8504">
        <updating/>
        <source>executePostMoveForToLocation(control: CMIF_MoveController; _passport : CM_Passport input)updating;
/*
 ------------------------------------------------------------------------
Created:			19 December 2001 by cnwdwq1
Purpose:			Move has been done, transaction has been written. Prior location has been set.
							(see CM_TrackedItem::executeControlPostMove). Do any work required on the
							locations controller here.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	inheritMethod(control, _passport);

end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEs" id="48b26ea4-712f-4f26-a8d3-952b062501fa">
        <source>getAllWLEs(_wleArray: CM_WLEArray input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	vm : CM_VehicleMachine;
	vehicle : CM_Vehicle;
begin
	foreach vm in self.allVehicleMachines discreteLock do
		if vm.isKindOf(CM_Machine) then
			continue;
		else
			vehicle:=vm.CM_Vehicle;
		endif;
		
		vehicle.getAllWLEs(_wleArray);
	endforeach;

epilog

end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllYardAllocations" id="13b1753f-e004-4b70-8ccc-cf63a6023bc3">
        <source>getAllYardAllocations(_allAllocationsObj:CM_YardAllocationSet input);
// --------------------------------------------------------------------------------
// Created:		03 June 2008 by cnwdad1
//
// Purpose:		Populates the specified set with all of the receiver's Yard Allocations.
//
// Parameters:	_allAllocationsObj - A reference to a Yard Allocation set.
//
// Returns:		The populated set of Yard Allocations in the output parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allYardAllocations.copy(_allAllocationsObj);
end;</source>
        <Parameter name="_allAllocationsObj" type="CM_YardAllocationSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDirectorTasks" id="51821b9b-664e-4ef2-972d-bdbe4ca17f01">
        <source>getDirectorTasks(arbiter: CM_RTQueueArbiter io);
/*
	method that returns the work required to goto a location to get a TI to satisfy
 	a request for a TYPE of container.
 	At this stage, its just a single task...
*/
vars
	task	: CM_RTQueueTask;
begin
	create task;
	task.setDetails(	self,
						arbiter.targetLocation,
						TASK_UNACTIONED,
						TASK_DIRECTOR,
						null);
	
	//epr par 30376 27/9/12
	if arbiter.myCurrentMachineTypeGroup &lt;&gt; null then
		task.machineTypeGroup:=arbiter.myCurrentMachineTypeGroup.type;
	endif;
	
	task.setMyBestPickTI(arbiter.myBestPickTI); //jlier1 MTN-35637 17/9/25
	arbiter.entry.addTask(task);
end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDiscrepancy" id="858f73a7-e2cf-41e8-b72a-fc5c22bdc210">
        <source>getDiscrepancy(aStr: String output): Boolean;

begin
	aStr := null;
	if self.powerDamaged then
		aStr := app.getErrorString1(DiscrepancyLocnPowerDamaged, self.getFullId);
		return true;
	endif;
	return false;
end;</source>
        <Parameter name="aStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDontMatchYAForTI" id="4169db65-aa4d-45f2-a3c4-60ea22928700">
        <source>getDontMatchYAForTI(_ti : CM_TrackedItem; _cmifAutoPlan : CMIF_YAAutoPlanNormal input; _yallocs :  CM_YardAllocationsByCodeDict input);
// ---------------------------------------------------------------------------
// Created:		03 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	blkObj : CM_YABlock;
	ya : CM_YardAllocation;
begin
	foreach ya in self.allYardAllocations discreteLock where ya.class = CM_YardAllocation do
		if not ya.compareCriteriaToCMIF(null, _cmifAutoPlan) then
			_yallocs.addNoDuplicates(ya, false);
		endif;
	
	endforeach;
	/*
	foreach blkObj in self.allYABlocks discreteLock do
		if not blkObj.myYardAllocationIn.compareCriteriaToCMIF(null, _cmifAutoPlan) then
			_yallocs.addNoDuplicates(blkObj.myYardAllocationIn, false);
		endif;

	endforeach;
	*/
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlanNormal" usage="input"/>
        <Parameter name="_yallocs" type="CM_YardAllocationsByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDrawingAttributes" id="3a0c4e9b-3cbb-4958-93b4-05852bca7718">
        <source>getDrawingAttributes(pDisplay, pView : Integer;pHeight: Integer; pColour: Integer output; 
					pLetter : String output);
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pDisplay, pView,pHeight, pColour, pLetter);

	if self.hasRestrictions(LABOUR_RESTRICTION) then
		pLetter := GridPointType_RestLab ;
		pColour := self.allLabourRestrictions.first.colour;

	elseif self.hasRestrictions(LOCATION_RESTRICTION) then
		pLetter := GridPointType_RestLoc ;
		pColour := self.myLocationRestriction.colour;
	endif;


end;</source>
        <Parameter name="pDisplay" type="Integer"/>
        <Parameter name="pView" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pColour" type="Integer" usage="output"/>
        <Parameter name="pLetter" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="5824cdff-7c2b-4d73-bf1a-30954f6612d8">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;
	yal : CM_YardAllocation;
	aTI : CM_TrackedItem;
	isFirst : Boolean;
begin
	block := _dataContainer.addNewBlock;
	block.addNewItem("Location", DC_Label, 1, self);
	block.addNewItem(self.getFullId(), DC_Data, 1, self);


	if not self.allTrackedItemsById.isEmpty then
		isFirst := true;
		foreach aTI in self.allTrackedItems do
			if isFirst then
				if aTI.isContainer() then
					block.addNewItem("Containers", DC_MoreInfo, 1, null);
				else
					block.addNewItem("Cargo", DC_MoreInfo, 1, null);
				endif;
				isFirst := false;
			endif;
			block := _dataContainer.addNewBlock;
			block.addNewItem("ID", DC_Label, 1,  aTI);
			block.addNewItem(aTI.id, DC_Data, 1,  aTI);
		
		endforeach;
	endif;
	if not self.allYardAllocations.isEmpty then
		// CCMS 1013
		//foreach yal in self.allYardAllocations do
		foreach yal in self.allYardAllocations where yal.includeInYardDisplays() do
			block := _dataContainer.addNewBlock;
			block.addNewItem("Yard Allocation", DC_MoreInfo, 1, null);
			yal.getExtraInfo(_dataContainer);
		endforeach;
	endif;

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
