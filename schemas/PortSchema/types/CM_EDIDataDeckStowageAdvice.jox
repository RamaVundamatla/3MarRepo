    <JadeMethod name="loadDB" id="6879ee6f-fb02-48af-9061-c3858494e348">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
/*
Purpose:			
Date		Who		Reason
02 November 2011	cnwab1	Initial creation
*/


vars

begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(false);
	
	app.myTrxCA.trxCreateEDIDeckStowageAdvice(false,  self, _passport);
epilog
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processDeckItemLayout" id="16a06335-a39b-45ae-95c7-3f3ce0dc2861">
        <source>processDeckItemLayout(_voyage : CM_Voyage; _deckItemLayout : CM_DeckItemLayout);
//
//15 Feb 2012	cnwrs1	Par 29124 Fix up Messina RORO Stowage advice in EDI
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediLayoutTI : CM_EDILayoutTI;
	ediLayoutPointTI : CM_EDILayoutPointTI;
	str : String;
	count : Integer;
	point : Decimal[12,2];
begin
	create ediLayoutTI persistent;
	
	ediLayoutTI.setForCreateNew(self);
	ediLayoutTI.setVoyageCode(_voyage.code);
	ediLayoutTI.layoutId := _deckItemLayout.code;
	if _deckItemLayout.myDeckItem &lt;&gt; null then
		str := _deckItemLayout.myDeckItem.getEDITypeCode();
		ediLayoutTI.layoutType := str[1:1];
	endif;
	count := 0;
	foreach point in _deckItemLayout.myPolygonCMs do
		count := count + 1;
		if count mod 2 &lt;&gt; 0 then	// ie odd
			create ediLayoutPointTI persistent;
			ediLayoutPointTI.setForCreateNew(self);
			ediLayoutPointTI.setVoyageCode(_voyage.code);
			ediLayoutPointTI.layoutId := _deckItemLayout.code;
			ediLayoutPointTI.pointOrder := (count/2 + 1).Integer;
			ediLayoutPointTI.longPos := point;
		else
			ediLayoutPointTI.transPos := point;
		endif;
	endforeach;

end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="processDeckItemLayoutRotation" id="b86660d1-44fb-45e7-90c1-c1f252f6b790">
        <source>processDeckItemLayoutRotation(_voyage : CM_Voyage; _deckItemLayout : CM_DeckItemLayout; _rotatedItemCount : Integer);
//
//09 Mar 2012	cnwrs1		Par 29246 - EDI RORO Deck Plan Extract not including rotation
//
//07 Jan 2013	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotation 1X1
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
vars
	ediLayoutTI : CM_EDILayoutTI;
	str 		: String;
begin
	create ediLayoutTI persistent;
	
	ediLayoutTI.setForCreateNew(self);
	ediLayoutTI.setVoyageCode(_voyage.code);
	
	ediLayoutTI.layoutId 			:= _deckItemLayout.code[1:10];
	ediLayoutTI.isRotationMaster 	:= true;
	
	if _rotatedItemCount = 10 then
		str := "2X5";
	elseif _rotatedItemCount = 6 then
		str := "2X3";
	elseif _rotatedItemCount = 5 then
		str := "1X5";
	elseif _rotatedItemCount = 3 then
		str := "1X3";
	elseif _rotatedItemCount = 1 then
		str := "1X1";
	endif;
	
	ediLayoutTI.rotation := str;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_rotatedItemCount" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processLayout" id="a62fe076-bb31-42e2-abb8-bd2e7c3db735">
        <updating/>
        <source>processLayout(_voyage : CM_Voyage) updating;
//
//15 Feb 2012	cnwrs1	Par 29124 Fix up Messina RORO Stowage advice in EDI//
// 21 Mar 2012	cnwrs1	Par 29308
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	roroStructure : CM_ROROVoyageStructure;
	roroGCDefn : CM_ROROGCDefn;
	roroGCDefnVoyage : CM_ROROGCDefnVoyage;
	roroGCController : CM_ROROGCController;
	roroLocnDefnVoyage : CM_ROROLocnDefn;
	roroSlotDefnVoyage : CM_ROROSlotDefn;
	roroSlotController : CM_ROROSlotController;
	deckItemLayout : CM_DeckItemLayout;
	ediLayoutTI : CM_EDILayoutTI;
	ediLayoutPointTI : CM_EDILayoutPointTI;
	point : Decimal[12,2];
	count : Integer;
	str : String;
begin
	roroStructure := _voyage.myROROStructure;
	foreach roroGCDefn in roroStructure.allROROGCDefnByCode do
		deckItemLayout := roroGCDefn.myLayout;
		if deckItemLayout &lt;&gt; null and
			roroGCDefn.isKindOf(CM_ROROGCDefnVoyage) then
			roroGCDefnVoyage := roroGCDefn.CM_ROROGCDefnVoyage;
			roroGCController := roroGCDefnVoyage.myGCController;
			if roroGCController.myRORORequestDischarge &lt;&gt; null or
			   roroGCController.myRORORequestLoad &lt;&gt; null then
				self.processDeckItemLayout(_voyage, deckItemLayout);
				self.processRORORequest(roroGCController.myRORORequestDischarge);
				self.processRORORequest(roroGCController.myRORORequestLoad);
			endif;
		endif;
	endforeach;
	foreach roroLocnDefnVoyage in roroStructure.allROROLocnDefnByCode where (roroLocnDefnVoyage.isOOTLLocn = true) do
		foreach roroSlotDefnVoyage in roroLocnDefnVoyage.allROROSlotDefnByOrdinal do
			roroSlotController := roroSlotDefnVoyage.CM_ROROSlotDefnVoyage.mySlotController;
			deckItemLayout := roroLocnDefnVoyage.myLayout;
			if deckItemLayout &lt;&gt; null then
				if roroSlotController.myRORORequestDischarge &lt;&gt; null or
				   roroSlotController.myRORORequestLoad &lt;&gt; null then
					self.processDeckItemLayout(_voyage, deckItemLayout);
					self.processRORORequest(roroSlotController.myRORORequestDischarge);
					self.processRORORequest(roroSlotController.myRORORequestLoad);
				endif;
			endif;
		endforeach;
	endforeach;
	foreach roroLocnDefnVoyage in roroStructure.allROROLocnDefnByCode where (roroLocnDefnVoyage.isOOTLLocn = false) do
		foreach roroSlotDefnVoyage in roroLocnDefnVoyage.allROROSlotDefnByOrdinal do
			roroSlotController := roroSlotDefnVoyage.CM_ROROSlotDefnVoyage.mySlotController;
			deckItemLayout := roroLocnDefnVoyage.myLayout;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;deckItemLayout.code;
			if deckItemLayout &lt;&gt; null then
				if roroSlotController.myRORORequestDischarge &lt;&gt; null or
				   roroSlotController.myRORORequestLoad &lt;&gt; null then
//					self.processDeckItemLayout(_voyage, deckItemLayout);
					self.processRORORequest(roroSlotController.myRORORequestDischarge);
					self.processRORORequest(roroSlotController.myRORORequestLoad);
				endif;
			endif;
		endforeach;
	endforeach;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="processRORORequest" id="31fbf2ea-01a9-45c5-acbd-5df481e5834f">
        <updating/>
        <source>processRORORequest(_roroRequest : CM_VoyageRequest) updating;
//
//15 Feb 2012	cnwrs1	Par 29124 Fix up Messina RORO Stowage advice in EDI
//
// 21 Mar 2012	cnwrs1	Par 29308
// 31/05/2012	cnwcs5	CCMS SFW 1284 - EDI BGP Split - use setStatus instead of status := 
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediTrackedItem : CM_EDIStowAdviceTI;
	commodity : CM_Commodity;
	allocation : CM_YardAllocation;
	voyageAllocation : CM_VoyageAllocation;
	criteria : CM_YACriteria;
	yaData : CM_YAData;
	obj : Object;
begin
	if _roroRequest = null then
		return;
	endif;
	
	create ediTrackedItem persistent;
	ediTrackedItem.setForCreateNew(self);
	
	ediTrackedItem.setIdDefault(null);
	ediTrackedItem.stowageId 	:= _roroRequest.code;
	ediTrackedItem.weight		:=	_roroRequest.weight;
	
	if _roroRequest.isDischarge then
		ediTrackedItem.mode := CM_EDIStowAdviceTI.MODE_DIS;
	elseif _roroRequest.isLoad then
		ediTrackedItem.mode := CM_EDIStowAdviceTI.MODE_LOA;
	elseif _roroRequest.isSoB then
		ediTrackedItem.mode := CM_EDIStowAdviceTI.MODE_SHI;
	elseif _roroRequest.isRehandle then
		ediTrackedItem.mode := CM_EDIStowAdviceTI.MODE_RES;
	endif;
	
	if _roroRequest.isKindOf(CM_RORORequest) then
		foreach allocation in _roroRequest.CM_RORORequest.allAllocations do
			voyageAllocation := allocation.CM_VoyageAllocation;
			foreach criteria in voyageAllocation.allCriteria do
				yaData := criteria.myYAData;
				ediTrackedItem.setFromVoyAllocationCriteria(criteria);
				if yaData.isKindOf(CM_YADataObjects) then
					foreach obj in yaData.CM_YADataObjects.allObjects do
					endforeach;
				endif;
			endforeach;
		endforeach;
	endif;

//	self.setStatus (CM_EDIFile.EDI_STATUS_LOADED);	// CCMS SFW 1284 May 2012
end;

</source>
        <Parameter name="_roroRequest" type="CM_VoyageRequest"/>
    </JadeMethod>
    <JadeMethod name="processSlotRequest" id="8bc253e1-f358-4843-b560-f8df0e1a5392">
        <updating/>
        <source>processSlotRequest(_slotRequest : CM_SlotRequest) updating;
//
//15 Feb 2012	cnwrs1	Par 29124 Fix up Messina RORO Stowage advice in EDI
// 31/05/2012	cnwcs5	CCMS SFW 1284 - EDI BGP Split - use setStatus instead of status := 
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
vars
	ediTrackedItem : CM_EDIStowAdviceTI;
	commodity : CM_Commodity;
begin
	if _slotRequest = null then
		return;
	endif;
	
	if _slotRequest.cargoType = TI_CargoType_LCL then// or _slotRequest.myParent &lt;&gt; null then				//PAR7955	or any attached item
		return;
	endif;
		
	create ediTrackedItem persistent;
	ediTrackedItem.setForCreateNew(self);

	ediTrackedItem.setCargoType(_slotRequest.cargoType);
	
	ediTrackedItem.setIdDefault(null);//_slotRequest.id;
	ediTrackedItem.commodity := _slotRequest.commodity;
	commodity := app.myRoot.allCommodities[_slotRequest.commodity];
	if commodity &lt;&gt; null then
		ediTrackedItem.commodityDescription := commodity.description;
	endif;
	
	ediTrackedItem.dischargePort	:= _slotRequest.dischargePort;
	ediTrackedItem.isoType			:= _slotRequest.getISOType;
	ediTrackedItem.stowageId := _slotRequest.mySlotDefinition.id;
	ediTrackedItem.weight	:=	_slotRequest.weight;

	if _slotRequest.isDischarge then
		ediTrackedItem.mode := CM_EDIStowAdviceTI.MODE_DIS;
	endif;

	self.setStatus (CM_EDIFile.EDI_STATUS_LOADED);	// CCMS SFW 1284 May 2012

end;
</source>
        <Parameter name="_slotRequest" type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="processVoyage" id="11c0b998-6bda-44b7-acec-a81472ca9035">
        <updating/>
        <source>processVoyage(_voyage : CM_Voyage) updating;
//
//15 Feb 2012	cnwrs1	Par 29124 Fix up Messina RORO Stowage advice in EDI
// 31/05/2012	cnwcs5	CCMS SFW 1284 - EDI BGP Split - use setStatus instead of status := 
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediTrackedItem : CM_EDIVoyageHeaderTI;
begin
	create ediTrackedItem persistent;
	
	ediTrackedItem.setForCreateNew(self);
	ediTrackedItem.setVoyageCode(_voyage.code);
	
	ediTrackedItem.vesselName := _voyage.vesselName;
	
//	self.setStatus (CM_EDIFile.EDI_STATUS_LOADED);	// ccms sfw 1284 May 2012
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFromVoyage" id="67347a8e-bde9-46ec-885d-ced3e1d6c186">
        <updating/>
        <source>setForCreateFromVoyage(_voyage : CM_Voyage; 
					  _ediConfig : CM_EDIConfig input;
					  _realEdiFile : CM_EDIFile input; 
                      _userCode : String ) updating;
/*

Purpose:
Creates an EDI RORO Deck Stowage Advice from a voyage in the database			

Called in Transaction State


Date		Who		Reason
15 Feb 2012	cnwrs1	Par 29124 Fix up Messina RORO Stowage advice in EDI
31/05/2012	cnwcs5	CCMS SFW 1284 - EDI BGP Split - use setStatus instead of status := 
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/

vars
    request : CM_VoyageRequest;
	voyAlloaction : CM_YardAllocation;
	slotRequest : CM_SlotRequest;
begin
    //Check transaction State.
    
    // Sort out the EDIData
    self.setForCreateNoProxy(_ediConfig, EDIDataType_DeckStowageAdvice, null, _realEdiFile, _userCode);
	if _voyage.myOperator &lt;&gt; null then
		self.operatorCode := _voyage.myOperator.code;
	endif;
	
	self.setStatus (CM_EDIFile.EDI_STATUS_EXTRACTED);	// CCMS SFW 1284 May 2012
    // Now Sort out the EDITracked Items
    //Voyage Header
	self.processVoyage(_voyage);
	self.processLayout(_voyage);
   //Tracked Items

    //Layouts
    //Layout Points
	//Deck Items (Null)
    //Layouts
    //Layout Points
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="input"/>
        <Parameter name="_realEdiFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
