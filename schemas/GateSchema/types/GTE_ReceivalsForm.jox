    <JadeMethod name="setSysSubTypeDetails" id="5e152568-8023-4e02-b7d9-55646e2e5a50">
        <updating/>
        <source>setSysSubTypeDetails(_obj : Object) protected, updating;

/*

Purpose:		Load the Sys Sub Type Combo and display		

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2009	cnwmh5	Initial creation

*/
constants
	NULLSTRING = "|~~NULL~~|";
vars
	type				: String;
	product				: CM_Product;
	cargoTypeCombo		: CM_CargoType;
	cargoTypeBookRef	: CM_CargoType;
	brItem				: CM_BRefItemContainer;
begin

	// if not CM_CargoType then don't require
	if not self.cmbTiType.listObject.isKindOf(CM_CargoType) then	// 13/09/2010 cnwmh5 #25727
		return;
	endif;
	
	// clear values
	type := NULLSTRING;
	cargoTypeCombo := self.cmbTiType.listObject.CM_CargoType;
	
	// depending on type get the product
	if _obj = null then
	elseif _obj.isKindOf(CM_BreakBulkGeneric) then
		product := _obj.CM_BreakBulkGeneric.myProduct;
		if product = null then
			product := _obj.CM_BreakBulkGeneric.myCargoType.mySystemProductType;
		endif;
		if _obj.CM_BreakBulkGeneric.type = null then
		endif;
		type := _obj.CM_BreakBulkGeneric.type;
	elseif _obj.isKindOf(CM_BRefItemContainer) then
		product := _obj.CM_BRefItemContainer.myProduct;
		type := _obj.CM_BRefItemContainer.typeString;
	elseif _obj.isKindOf(CMIF_BookingRefItem) then
		product := _obj.CMIF_BookingRefItem.myProduct;
		type := _obj.CMIF_BookingRefItem.typeString;
	else
		type := self.myAssistant.mainExtraGetValue(tblMain, tblExtra, ETRow_MyType).String;
	endif;
	
	if product = null and self.cmbProduct.listObject.CM_Product &lt;&gt; null then
		product := self.cmbProduct.listObject.CM_Product;
	endif;
	
	// product still null and cargo type isn't then use cargo types' system proudct type
	if product = null and self.cmbTiType.listObject.CM_CargoType &lt;&gt; null then
		product := self.cmbTiType.listObject.CM_CargoType.mySystemProductType;
	endif;
	
	//if product = null and self.cmbProduct.listObject.CM_Product &lt;&gt; null then
//		product := self.cmbProduct.listObject.CM_Product;
//	endif;
	
	// load the type combo based on the details supplied
	self.tblExtra.showRowByName(ETRow_MyType, false);
	self.myAssistant.comboboxSysSubType(product, self.cmbTiType.listObject.CM_CargoType, type, self.cmbSysSubType, self.tblExtra);
	
	// decide whether to display the type combo or not
	if cargoTypeCombo &lt;&gt; null then
		if cargoTypeCombo.classNameToCreate = CM_BreakBulkGeneric.name then
			self.tblExtra.showRowByName(ETRow_MyType, false);
		else
			self.tblExtra.hideRowByName(ETRow_MyType, false);
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setTiTypeFields" id="edab748d-a462-4409-b173-ba0ba11f74af">
        <updating/>
        <source>setTiTypeFields() updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------

vars
	obj			: Object;
	cargoBOLType: CM_CargoBOLType;
	cargoType	: CM_CargoType;
	isoType		: CM_ISOType;
	assistant	: GTE_Assistant;
begin

	cargoBOLType := self.cmbTiType.listObject.CM_CargoBOLType;
	if cargoBOLType = null then
		return;
	endif;
	
//	isoType := self.cmbISOType.listObject.CM_ISOType;
	isoType := cmbISOType.myObject.CM_ISOType;

	assistant := self.myAssistant.GTE_Assistant;
	assistant.setTIHeading(cargoBOLType.idHeading, tblMain, (self.class = GTE_PreNoteForm));
	if cargoBOLType.isKindOf(CM_CargoType) then
		cargoType := cargoBOLType.CM_CargoType;
		self.cmbProduct.setCargoType(cargoType);
	endif;	
		
	// 8/6/2006 Lorcan Only show iso type if necessary
	if self.cmbTiType.listObject.CM_CargoBOLType.isISOType then
		tblMain.showRowByName(ETRow_IsoType, false);
		tblMain.enableRowByName(ETRow_IsoType);
	else
		tblMain.hideRowByName(ETRow_IsoType, false);
	endif;
	
	//06/08/2010 cnwdz2 25210  put the following line back. It was accidently removed in 7.8.1
	assistant.receival_ShowRows(cargoBOLType, isoType, tblMain, tblExtra, self.myTerminal);
	
	// 24/02/2010 cnwar2 #22457
	//if cargoType.id = TI_CargoType_Chassis then
	//if cargoType &lt;&gt; null and cargoType.id = TI_CargoType_Chassis then	// 13/09/2010 cnwmh5 #25727
	if cargoType &lt;&gt; null and cargoType.classNameToCreate = CM_TILC.name then	// 01/06/2011 cnwar2 #27596 - include user-defined trailer cargo types
		tblExtra.showRowByName(ETRow_TrailerType, false);
		assistant.comboBoxTrailerType(cmbTrailerType, cargoType, null, self.myTerminal);
		tblExtra.hideRowByName(ETRow_Commodity, false);							// 01/06/2011 cnwar2 #27596 - hide commodity for trailer cargo types
	else
		tblExtra.hideRowByName(ETRow_TrailerType, false);
	endif;
	
	//show/hide GC rows in the view
	assistant.showHideGenCargoRows(cargoType, tblExtra);
//	tblExtra.setValueByName ( ETRow_MyProduct, null);  // dh 30/6/2008 this is breaking this field
	tblMain.hideRowByName(ETRow_YardLocationTxt, false);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setType" id="d39bc400-12e7-4890-8146-c9130fe62dc7">
        <updating/>
        <source>setType() updating;
// ---------------------------------------------------------------------------
