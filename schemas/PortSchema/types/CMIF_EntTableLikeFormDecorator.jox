        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setRowVisibleAfterEntRow" id="b7f14c94-eb0f-4b06-ad4c-33dc0d84a6b0">
        <source>setRowVisibleAfterEntRow(_entRowName: String; _visible: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 October 2010	cnwer1	Initial creation

*/

vars
	row			 : Integer;
	heading : String;
begin
	
	

	row:=self.findRowWithEntRowName(_entRowName);
	if row = 0 then
		return;
	endif;
	
	self.myTable.accessRow(row+1).visible:=_visible;
	self.myTable.accessRow(row+ 2).visible:=_visible;

epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_visible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="splitCellsInEntRows" id="82035062-4ddc-461b-ab47-a747a7669d07">
        <source>splitCellsInEntRows(_entRows: StringArray input; _column: Integer; _numNewColumns: Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwer1	Initial creation

*/

vars
	entRowName : String;
	sheet : JadeTableSheet;
	newColumn,row : Integer;
	theRow,
	theAccessedRow: JadeTableRow;
	theCell		: JadeTableCell;
	addNewColumn	: Boolean;
	entRow 		: EntTableRow;
	entRowArray : EntTableRowArray;
begin
	if _entRows = null or _entRows.isEmpty then
		return;
	endif;
		
	create entRowArray transient;
	//self.myEntTableDef.allEntTableRows.copy(entRowArray);
	foreach entRowName in _entRows do
		entRow:=self.myEntTableDef.getEntTableRow(entRowName);
		if entRow = null then
			continue;
		endif;
		if not entRowArray.includes(entRow) then
			entRowArray.add(entRow);
		endif;
	endforeach;
	
	sheet:=self.myTable.accessSheet(1);
	if _numNewColumns &lt;&gt; null then
		addNewColumn:=true;
		sheet.insertColumn(_column+1);
	endif;
	

	self.myTable.accessColumn(_column).alignment:=Table.Alignment_Left_Middle;
	self.myTable.accessColumn(_column).width:=40;
	self.myTable.accessColumn(_column).marginLeft:=20;
	
	//merge all the other rows
	if addNewColumn then
		row:=1;
		while row &lt; self.myTable.rows do
			theAccessedRow:=self.myTable.accessRow(row);
			if (theAccessedRow.itemObject &lt;&gt; null and _entRows.includes(theAccessedRow.itemObject.EntTableRow.name )) or
				not theAccessedRow.enabled or
				self.myTable.accessCell(row,_column).mergeCells =  Table.MergeCells_Merge  then
					row:=row+1;
				continue;
			endif;
			self.mergeTableCells(row,_column,_numNewColumns,self.myTable.accessCell(row,_column).inputType);
		
			row:=row+1;
		endwhile;	
	endif;
	foreach entRow in entRowArray do
		row:=self.findRowWithEntRow(entRow);
		self.myTable.accessCell(row,_column).mergeCells:=null;
		self.myTable.accessCell(row,_column).alignment:=Table.Alignment_Left_Middle;
		self.myTable.accessCell(row,_column).marginLeft:=10;
		self.removeGridAroundCell(row,_column);
		self.myTable.accessCell(row,_column+1).mergeCells:=null;
		self.myTable.accessCell(row,_column+2).mergeCells:=null;
		self.addGridAroundCell(row,_column+1);
	endforeach;

epilog
	delete entRowArray;
end;</source>
        <Parameter name="_entRows" type="StringArray" usage="input"/>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_numNewColumns" type="Integer"/>
    </JadeMethod>
</Class>
