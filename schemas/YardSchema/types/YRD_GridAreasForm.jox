vars

begin

	self.myAssistant.showLabourRestrictForm(_ta,_termArea, self.myMasterMenuAction);
end;</source>
        <Parameter name="_ta" type="CM_TerminalSubArea"/>
        <Parameter name="_termArea" type="CM_TerminalArea"/>
