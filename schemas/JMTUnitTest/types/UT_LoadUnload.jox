    <JadeMethod name="tTruckUsedWithoutTrailer" id="36df3184-e86a-4f3c-8472-71a68f9fee7a">
        <source>tTruckUsedWithoutTrailer();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 12 July 2019
TFS#		: 45289
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	releaseRequest	: CM_BulkRelease;
	truck			: CM_Vehicle;
	trackedItem		: CM_TrackedItem;
	yardAllocation	: CM_YardAllocation;
	locations 		: CM_LCArray;
	yaName			: String;
	blockStack		: CM_BlockStack;
	vehicleArray	: CM_VehicleArray;
begin
	
	deleteReleaseRequest("UTRR001");
	deleteVehicle("UTVEH01");
	self.deleteContainer("UTLOAD001");
	
	// Setup a YA over a block stack that has a cvontainer that could be released
	trackedItem := self.addContainer("UTLOAD001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_REMAINONBOARD);
	
	blockStack := addBlockStack("UTBS1", 100, null);
	
	create locations transient;
	locations.add(blockStack.allLocationsControllers.first.CM_YardController);
	yaName := self.getProfileSetting(UT_Profile.P_YA).asString;
	self.deleteYA(yaName);
	yardAllocation := self.addYA1(yaName, YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	
	self.move(trackedItem, locations.first);
	assertEqual(trackedItem.myPrimaryActualLocation, locations.first);
	
	// Create the Release
	releaseRequest := addReleaseByTypeRequest("UTRR001", BR_TYPE_ROAD, TI_CargoType_Container, "2200");
	assertNotNull(releaseRequest);
	
	// Gate Out
	self.gateOutPinRelease(releaseRequest.myPinNo.pinNo, "UTVEH01");
	
	truck := self.getVehicle("UTVEH01");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "RT");
	
	create vehicleArray transient;
	releaseRequest.getTrucksUsed(vehicleArray);
	
	assertEqual(vehicleArray.size, 1);
		
	deleteReleaseRequest("UTRR001");
	deleteVehicle("UTVEH01");

epilog
	delete locations;
	delete vehicleArray;
end;</source>
    </JadeMethod>
</Class>
