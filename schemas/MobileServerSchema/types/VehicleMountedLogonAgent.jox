    <JadeMethod name="initWithDevice" id="f1b746c6-a7c6-4e00-b063-5770e684cdd6">
        <updating/>
        <source>initWithDevice(_rtDevice : CM_RadioTelemetryDevice) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2010	cnwer1	Initial creation

*/

vars

begin
	
	inheritMethod(_rtDevice);
	
	if  self.myRTDevice &lt;&gt; null and self.myRTDevice.isKindOf(CM_RTDeviceVehicleMount) then
		self.myMachine:=self.myRTDevice.CM_RTDeviceVehicleMount.myMachine;
		
	endif;
	
	if self.myMachine &lt;&gt; null then
		self.myRTQueue:=self.myMachine.myPrimaryQueue;
	endif;
epilog

end;</source>
        <Parameter name="_rtDevice" type="CM_RadioTelemetryDevice"/>
    </JadeMethod>
    <JadeMethod name="isRTDeviceValid" id="521493e7-a759-4a23-8aa1-7130c5e94543">
        <source>isRTDeviceValid(_device : CM_RadioTelemetryDevice input;
				_computerName : String;
				_checkAlt : Boolean io) :CM_RadioTelemetryDevice;
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 June 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	
begin
	//return inheritMethod(_device,_computer,_checkAlt);
	_checkAlt:=false;
	if not _device.isKindOf(CM_RTDeviceVehicleMount) then
		return null;
	elseif  _device.CM_RTDeviceVehicleMount.myMachine = null then
		return null;
	endif;

	if _device.computerName.toUpper = _computerName.toUpper  then
		/*if  app.isDevelopmentSystem then
			if not _device.CM_RTDeviceVehicleMount.myMachine.loggedOn then
				return _device;
			endif;
		else*/
			return _device;
		//endif;
	else
		if app.isDevelopmentSystem then
			if (not _device.CM_RTDeviceVehicleMount.myMachine.loggedOn) then
				_checkAlt:=true;	
			endif;
		endif;
	endif;

	return null;
epilog

end;</source>
        <Parameter name="_device" type="CM_RadioTelemetryDevice" usage="input"/>
        <Parameter name="_computerName" type="String"/>
        <Parameter name="_checkAlt" type="Boolean" usage="io"/>
        <ReturnType type="CM_RadioTelemetryDevice"/>
    </JadeMethod>
    <JadeMethod name="validateRTDeviceDetails" id="9676a68b-738d-480e-84bc-be2f6ce05b75">
        <source>validateRTDeviceDetails(_errorStr: String io): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2010	cnwer1	Initial creation

*/

vars

begin
	if not inheritMethod(_errorStr) then
		return false;
	endif;
	
	//doing this here so when getAppPermission is called it knows about its machine
	if not self.myRTDevice.isKindOf(CM_RTDeviceVehicleMount) then
		_errorStr :=  app.getErrorString2(ERROR_DEV_INVALID_TYPE_FOR_APP,self.myRTDevice.id,"Vehicle Mounted device");	
		return false;
	endif;
	
	if self.myMachine = null then
		_errorStr :=  app.getErrorString1(ERR_DEV_NO_MACH,self.myRTDevice.id);
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_errorStr" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateUserPermissions" id="9b01ef05-b1c3-4eb9-8dfa-fa11a345d013">
        <updating/>
        <source>validateUserPermissions(_errorStr: String io): Boolean protected, updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 Oct 2006	cnwer1	Initial creation - PAR#xxxx
01 Jul 2014	cnwkpd1	PAR #34490 - 1090 exception during logon of Gdansk machine apps

*/

vars

begin
	if not inheritMethod(_errorStr) then
		return false;
	endif;
	
	//doing this here so when getAppPermission is called it knows about its machine
	if self.myRTDevice.isKindOf(CM_RTDeviceVehicleMount) then
		self.myMachine:= self.myRTDevice.CM_RTDeviceVehicleMount.myMachine;		//Vehicles have a ref to a machine
		if self.myMachine = null then
			_errorStr :=  app.getErrorString1(ERR_DEV_NO_MACH,self.myRTDevice.id);
			return false;
		endif;
	else
		_errorStr :=  app.getErrorString2(ERROR_DEV_INVALID_TYPE_FOR_APP,self.myRTDevice.id,"Vehicle Mounted device");	
		return false;
	endif;

	if app.myMobileAgent &lt;&gt; null then
		if not self.findFormsForUser() then
			_errorStr := app.getErrorString1(NotLicensedToPerformAction, app.getLicenseName(Mod_WebApps) );
			return false;
		endif;
	endif;
	
	// PAR #34490 - For JBL benchmark running the old Gdansk apps, myMediator hasn't been set up at this point, 
	// so need to check to prevent logon exception
	if self.myMediator &lt;&gt; null then
		beginTransaction;
		self.myMediator.user:=self.user;

		commitTransaction;
	endif;
		
	return true;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_errorStr" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
