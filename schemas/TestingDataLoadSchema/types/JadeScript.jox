TO_LOCATION_TYPE_NAME&gt;PA Anch&lt;/TO_LOCATION_TYPE_NAME&gt;&lt;DOMAIN_ID&gt;67&lt;/DOMAIN_ID&gt;&lt;DOMAIN_NAME&gt;Brisbane&lt;/DOMAIN_NAME&gt;&lt;DOMAIN_CODE&gt;BNE&lt;/DOMAIN_CODE&gt;&lt;REGION_TYPE&gt;115010&lt;/REGION_TYPE&gt;&lt;REGION_NAME&gt;Brisbane&lt;/REGION_NAME&gt;&lt;created_by&gt;Tim Martin&lt;/created_by&gt;&lt;Last_Update_Date&gt;2023-01-05T03:28:31.03+10:00&lt;/Last_Update_Date&gt;&lt;ASSESSMENT_LEVEL&gt;9020&lt;/ASSESSMENT_LEVEL&gt;&lt;AllPermitAcknowledged /&gt;&lt;LOA&gt;184.7500&lt;/LOA&gt;&lt;VESSEL_BEAM&gt;30.6000&lt;/VESSEL_BEAM&gt;&lt;VESSEL_DWT&gt;38191.0000&lt;/VESSEL_DWT&gt;&lt;VESSEL_GRT&gt;23950.000000&lt;/VESSEL_GRT&gt;&lt;DEEPEST_DRAFT&gt;6.1100&lt;/DEEPEST_DRAFT&gt;&lt;VESSEL_MAIN_TYPE&gt;Bulk Carrier&lt;/VESSEL_MAIN_TYPE&gt;&lt;TANKER_STATUS /&gt;&lt;FROM_ORIENTATION_NAME /&gt;&lt;TO_ORIENTATION_NAME /&gt;&lt;RES_COMMIT /&gt;&lt;HAS_PILOT_JOBS&gt;false&lt;/HAS_PILOT_JOBS&gt;&lt;DEFECT_COUNT&gt;0&lt;/DEFECT_COUNT&gt;&lt;changed_by&gt;Angela Moore&lt;/changed_by&gt;&lt;EARLY_BERTH&gt;false&lt;/EARLY_BERTH&gt;&lt;max_deepest_draft&gt;false&lt;/max_deepest_draft&gt;&lt;is_pec&gt;false&lt;/is_pec&gt;&lt;tbc&gt;false&lt;/tbc&gt;&lt;TOW&gt;0&lt;/TOW&gt;&lt;Pilot_Required_On_Early_Arr&gt;false&lt;/Pilot_Required_On_Early_Arr&gt;&lt;voyage_status_type&gt;865&lt;/voyage_status_type&gt;&lt;last_port_name&gt;Brisbane&lt;/last_port_name&gt;&lt;next_port_name&gt;Port Kembla&lt;/next_port_name&gt;&lt;ship_flag&gt;Hong Kong&lt;/ship_flag&gt;&lt;departure_delay_amount&gt;7&lt;/departure_delay_amount&gt;&lt;arrival_delay_amount&gt;7&lt;/arrival_delay_amount&gt;&lt;agent_name&gt;Sturrock Grindrod Maritime (Brisbane)&lt;/agent_name&gt;&lt;allocated_tugs /&gt;&lt;/VOYAGEJOBEXPORT&gt;&lt;/NewDataSet&gt;&lt;/diffgr:diffgram&gt;&lt;/GetVoyageExportDataByDomainAndDatesResult&gt;&lt;/GetVoyageExportDataByDomainAndDatesResponse&gt;&lt;/soap:Body&gt;&lt;/soap:Envelope&gt;';
vars
	terminalCode		: String;
	terminal			: CM_Terminal;
	passport			: CM_Passport;
	pxyExtWebServiceDef : CM_QshipsWebServiceDef;
	webService 			: CM_QshipsWebServiceDef;	
	bgpObject			: BGP_QshipsRequest;
	edifile				: CM_EDIFile;
	lastSuccessfullTS	: TimeStamp;
begin
	app.initialize();
	terminal := app.myRoot.allTerminals["JBL"];
	//self.assertNotNullMsg(terminal, "No terminal set, unable to run test");	
	
	passport := app.myPassport;
	
	//Create/Update the web service def, select both send in &amp; out and make active
	webService := app.myRoot.allExternalWebServices.getAtKey(ExternalWebServiceQships).CM_QshipsWebServiceDef;
	if webService = null then
		create pxyExtWebServiceDef as CM_QshipsWebServiceDef transient;
	else
		pxyExtWebServiceDef :=  app.createUpdateProxy( webService ).CM_QshipsWebServiceDef;
	endif;
	
	create bgpObject transient;
	
	edifile := bgpObject.processResponse(Input, null, pxyExtWebServiceDef, lastSuccessfullTS, terminal);
	//self.assertNotNullMsg(edifile, "No edifile has been created.");	
	
epilog
delete bgpObject;
end;</source>
    </JadeMethod>
    <JadeMethod name="releaseMthErrorsAcrossSchemas" id="ca978ccc-fa6b-456f-a84c-7919c6c2c724">
        <source>releaseMthErrorsAcrossSchemas();

/*
Purpose:	This script will list all methods in errors across all schemas.
*/

vars
	oSchema				: Schema;
	oType				: Type;
	oMethod				: Method;
	oAllClasses			: ClassColl;
	oAllTypes			: PrimTypeNDict;
	oAllMethods			: MethodNDict;
	iErrorsFound		: Integer;
	iErrorsTotal		: Integer;
	tempStr				: String;
	
begin
	create oAllClasses transient;
	create oAllTypes transient;
	create oAllMethods transient;

	tempStr	:= "Starting checking for Methods in Error";
	write tempStr;
	
	foreach oSchema in Schema.instances do : schema_loop
		tempStr	:= "Checking Schema " &amp; oSchema.name;
		write tempStr;
		
		delete oAllClasses;
		oAllClasses	:= oSchema.getAllClasses( true );
		
		foreach oType in oAllClasses do : class_loop
			oAllMethods.clear;
			oType.getMethods( oAllMethods ) ;
			foreach oMethod in oAllMethods do : method_loop
				if oMethod.getSchema &lt;&gt; oSchema then
					continue method_loop;
				endif;
				// display if in error and this method is actually in this schema not a super schema
				if oMethod.inError or oMethod.notCompiled then
					iErrorsFound := iErrorsFound + 1;
					tempStr	:= oSchema.name &amp; Tab &amp; oType.name &amp; Tab &amp; oMethod.name;
					write tempStr;
				endif;
			endforeach method_loop;
		endforeach class_loop;
		
		if iErrorsFound &lt;&gt; null then
			tempStr	:= 'Number of errors for schema ' &amp; oSchema.name &amp; ' is ' &amp; iErrorsFound.display &amp; CrLf;
			write tempStr;
		endif;
		iErrorsTotal	:= iErrorsTotal + iErrorsFound;
		iErrorsFound	:= null;
	endforeach schema_loop;
	
epilog
	if iErrorsTotal = null then
		tempStr	:= CrLf &amp; "Completed - No errors found" &amp; CrLf &amp; "Finished checking for Methods in Error";
	else
		tempStr	:= CrLf &amp; "Completed - " &amp; iErrorsTotal.display &amp; " Errors Found" &amp; CrLf &amp; "Finished checking for Methods in Error";
	endif;
	write tempStr;
	
	delete oAllTypes;
	delete oAllClasses;
	delete oAllMethods;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="reset37172" id="1c020fbd-e971-4e17-b956-e26c5b17ef0c">
        <source>reset37172();

constants

	VehicleID				: String = "37172";
	ReleaseRequestID		: String = "JLGRRROAD37172A01";


vars

	terminal				: CM_Terminal;
	dsl						: UT_DSL;
	iMove					: CM_InterTerminalMove;
	iConfig					: CM_InterTerminalConfig;
	ti						: Object;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId			: String;
				
	
begin

	
	app.initialize();
	
	create dsl transient;
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	dsl.opts.purge();
	dsl.opts.addAssoc("Terminal", terminal.code);
	
	// delete the vehicle
	dsl.deleteVehicle(VehicleID);
	
	// delete the release request
	dsl.deleteReleaseRequest(ReleaseRequestID);
		
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG37172A01");
	
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			dsl.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;

epilog

	delete dsl;
	delete tisToDelete;
	delete tiSet;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="reset37209" id="d6d6ce9a-4757-4f34-85f9-6f5d1e3ce1b4">
        <source>reset37209();

vars

	scripts					: UT_Scripts;
	
	

begin

	app.initialize();
	 
	create scripts transient;
	scripts.setActiveProfileMDHONLY();
	
	scripts.uDeleteTrain();
	
	
epilog

	delete scripts;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="reset37279" id="b3569416-67c9-46fa-8f50-a26572704a9d">
