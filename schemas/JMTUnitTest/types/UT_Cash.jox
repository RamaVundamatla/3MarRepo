		elseif count = 2 then
			self.assertEqualMsg(line.lineTotal, 5000.Decimal, "Second invoice line after last release");
		elseif count = 3 then
			self.assertEqualMsg(line.lineTotal, 1000.Decimal, "Third invoice line after last release");
		endif;
	endforeach;
	self.assertEqualMsg(count, 3, "Invoice lines after last release");

end;
