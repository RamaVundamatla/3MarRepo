    <JadeMethod name="doActionTaskKnown" id="0d41822e-7a96-4488-a4c3-ee8f5fcb04c5">
        <updating/>
        <source>doActionTaskKnown(_woActionIF: CMIF_WorkOrderAction; _realJob: CM_Job io; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1 ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks

*/

vars
	completeTIs : CM_TISet;
	ti			: CM_TrackedItem;
	workOrder 	: CM_WorkOrderTI;
begin

	inheritMethod(_woActionIF, _realJob, _passport);

	workOrder := self.myParent.CM_WorkOrderTI;
	
	create completeTIs transient;
	self.allActionedTIs.copy(completeTIs);
	
	foreach ti in completeTIs do
		ti.changeVoyage(self.myNewVoyage, _passport);
		if _passport.noErrors and (_passport.noWarnings or _passport.warningsAcknowledged) then
			self.allActionedTIs.remove(ti);
			//self.allCompleteTIs.add(ti);
			self.setTIComplete(ti,null);
		endif;
	endforeach;
	/*
	if _passport.noErrors  then
		self.completeMe;
		workOrder.completeMe();
		return;
	endif;
	*/
epilog
	delete completeTIs;
end;	</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAdvWOTransactionType" id="848a8fcc-ebd1-4800-89cb-100bc143c3a8">
        <source>getAdvWOTransactionType(transType : Integer): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 October 2022		navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions

*/

vars

begin
	if transType = TRANS_CREATED then
		return TRANS_TYPE_WO_TICHGVOY_CREATED;
	elseif transType = TRANS_UPDATED then
		return TRANS_TYPE_WO_TICHGVOY_UPDATED;
	else
		return TRANS_TYPE_WO_TICHGVOY_COMPLET;
	endif;
epilog

end;</source>
        <Parameter name="transType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="4f8f110f-26f7-437d-878a-35ef5c22ad40">
        <source>getDisplayString(_useShortDesc: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
// 29 Sep 2021  navma1      ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
// 06 Mar 2023  navma1 		ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
//
vars
	displayStr : String;
	typeDesc	  : String;
	code		  : String;	
begin
	
	typeDesc := self.getTypeDescription();											//29.09.2021 navma1 #51925
	
	if _useShortDesc then
		displayStr := typeDesc &amp;" Task #" &amp; self.getTaskSequenceNumber().String;	//06.03.2023 navma1 #56457:[56458]	
	else
		if self.myNewVoyage &lt;&gt; null then
			code := self.myNewVoyage.code;
		endif;
		
		displayStr :=  self.getLongDescription(typeDesc,null);					//29.09.2021 navma1 #51925

	endif;
	
	return displayStr;
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
