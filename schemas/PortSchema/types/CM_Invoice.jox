    </JadeMethod>
    <JadeMethod name="sendSAPPrePayWSDL112" id="9e6f0b38-d155-4241-af3f-f67526e394b0">
        <updating/>
        <source>sendSAPPrePayWSDL112()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2019	jlgndl1	Initial creation	TFS 44248
12/06/2024	navcs2	MTN-34987 MTN -  Disable SAP Integration
*/

vars

	invoice : CM_Invoice;
	invLineSet : CM_InvoiceLineSet;
	invLine : CM_InvoiceLine;
	iter : Iterator;
	msg : String;

begin
	// No longer used 12/06/2024	navcs2	MTN-34987 MTN -  Disable SAP Integration
	
	/*
	app.writeLog(method.qualifiedName,LogINFO);
	if not self.myTerminal.isSapPerformanceEnabled then
		return;
	endif;
	 
	if self.paymentType &lt;&gt; PaymentType_PrePay then
		return;
	endif;
	 
	if self.myWorkOrder = null then
		return;
	endif;
	 
	create invLineSet transient;
	
	if self.myWorkOrder.isWorkOrderForNullVoyage()
	or self.myWorkOrder.isWorkOrderForExportReturn()
	then
		foreach invoice in self.myWorkOrder.allInvoices do
			invLineSet.clear();
		//	invoice.invoiceLines.copy( invLineSet );
			//14 May 2019	NDL	TFS 44248
			delete iter;
			iter := invoice.invoiceLines.createIterator;
			while iter.next( invLine ) do
				if invLine.externalTS05.date.isValid then
					continue;
				endif;
				if invoice.hasWSDL112BgpForLine( invLine ) then
					continue;
				endif;
				invLineSet.add( invLine );
			endwhile;
			if not invLineSet.isEmpty then
				self.sendSAP( 0, INVOICE_SEND_WSDL112, invLineSet );
			else	//14 May 2019	NDL	TFS 44248
				msg := method.qualifiedName &amp; " - already all sent";
				app.writeLog(msg,LogINFO);
			endif;
		endforeach;
	endif;

epilog

	delete invLineSet;
	delete iter;
	*/
end;</source>
    </JadeMethod>
    <JadeMethod name="sendSAPRecheck" id="16570bfb-3be0-4cab-8abd-86a309d39bef">
        <source>sendSAPRecheck();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 Oct 2018	cnwma1   ChangeRequest 41380: PEL1 - Resend option for failed SAP WSDLs
15 Nov 2018  cnwma1   ChangeRequest 42045: PEL1 - SAP Integration : Additional Changes - Extended
11/06/2025	navcs2	MTN-34987  MTN -  Disable SAP Integration
*/

vars
	bgpRequest 		: BGP_ExternalWSRequest;
	proxyBGPRequest : BGP_SAPWSRequest;
	wsdl            : String;
	msg				: String;
begin
	return; // 11/06/2025	navcs2	MTN-34987  No onger using this so we just return;
	/*
	if not self.myTerminal.isSapFinancialEnabled then
		return;
	endif;
	
	if self.paymentType = PaymentType_None then
		return;
	endif;
	
	create proxyBGPRequest transient;
	
	if self.status = CM_Invoice.INVOICE_PENDING then
		//PaymentType_AutoCollection
		if self.paymentType = PaymentType_AutoCollection then 
			if self.paymentStatus = CM_Invoice.INVOICE_PAYMENT_NOTPAID then
				/*
					37189.004 Send Release Hold and Debit for Auto-Collection Customer
					WSDL 1.2: Auto-Collection - Release Hold/Debit
					PaymentType_AutoCollection
				*/
				/*
				proxyBGPRequest.myInvoice := self;
				proxyBGPRequest.isSAPReleaseHoldDebit := true;
				wsdl := BGP_SAPWSRequest.WSDL12;
			endif;
		
		//PaymentType_PostPay	
		elseif self.paymentType = PaymentType_PostPay then 
			if self.paymentStatus = CM_Invoice.INVOICE_PAYMENT_NOTPAID or
				self.paymentStatus = CM_Invoice.INVOICE_PAYMENT_CANCEL then
				/*
					37189.007 Send Invoice/Data for Post-Billing Customer
					WSDL 1.7: Post-Billing - Billing Payment Process
					PaymentType_PostPay 
				*/
				/*
				proxyBGPRequest.myInvoice := self;
				proxyBGPRequest.isSAPPostBillInvReq := true;
				wsdl := BGP_SAPWSRequest.WSDL17;
			endif;
		//PaymentType_PrePay
		elseif self.paymentType = PaymentType_PrePay then  
			if self.paymentStatus = CM_Invoice.INVOICE_PAYMENT_NOTPAID then
				/*
					37189.002 Perform Credit Check for Pre-Billing Customer
					WSDL 1.4: Pre-Billing - Credit Limit + Billing Payment Process
					PaymentType_PrePay
				*/
				/*
				proxyBGPRequest.myInvoice := self;
				proxyBGPRequest.isSAPPreBillCheckLimitReq := true;
				wsdl := BGP_SAPWSRequest.WSDL14;
			elseif self.paymentStatus = CM_Invoice.INVOICE_PAYMENT_PAID then
				/* 
					37189.006 Send Invoice/Data for Pre-Billing Customer
					WSDL 1.5: Pre-Billing - Revenue Journal + Incoming Cash Journal
					PaymentType_PrePay
				*/
				/*
				proxyBGPRequest.myInvoice := self;
				proxyBGPRequest.isSAPPreBillInvoiceReq := true;
				wsdl :=BGP_SAPWSRequest.WSDL15;
			endif;
		endif;
	elseif self.status = CM_Invoice.INVOICE_POSTED then
		if self.paymentType = PaymentType_AutoCollection then 
			if self.paymentStatus = CM_Invoice.INVOICE_PAYMENT_PAID then
			/* 
				37189.005 Send Invoice / Data for Auto-Collection Customer
				WSDL 1.3: Auto-Collection - Revenue Journal + Incoming Cash Journal
				PaymentType_AutoCollection
			*/
			/*
				proxyBGPRequest.myInvoice := self;
				proxyBGPRequest.isSAPAutoInvReq := true;
				wsdl := BGP_SAPWSRequest.WSDL13;
			endif;
		
		elseif self.paymentType = PaymentType_PrePay then
			if self.paymentStatus = CM_Invoice.INVOICE_PAYMENT_PAID then
			/*  
				15.11.2018 cnwma1 TFS #42045
				41022.020 Re-sending failed transactions to SAP
				WSDL 1.12: Pre-Billing - Revenue Journal + Incoming Cash Journal
				PaymentType_PrePay	
			*/
			/*
				proxyBGPRequest.myInvoice := self;
				proxyBGPRequest.isSAPPreBillProdDataReq := true;
				wsdl := BGP_SAPWSRequest.WSDL112;
			endif;
		endif;
	endif;
	
	if proxyBGPRequest.myInvoice &lt;&gt; null then
		if self.allSapRequests.isEmpty then
			if app.msgBox("Are you sure you want send WSDL : " &amp; wsdl.String &amp; " for invoice # " &amp; self.exportCurrencyCode &amp; "?  " ,
							"Send WSDL :" &amp; wsdl,
				MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_No  then
				return;
			endif;
			proxyBGPRequest.setTerminal(self.myTerminal);
			app.myTrxCA.trxCreateBGPRequestExtWS(proxyBGPRequest, bgpRequest, app.myPassport);
			msg :=  method.qualifiedName &amp; 		
					' ' &amp; "SAP Recheck Finance " &amp; 
					' ' &amp; "WSDL :" 		  &amp; wsdl &amp;
					' ' &amp; "Invoice# : "      &amp; self.exportCurrencyCode;
			app.writeLog(msg,LogINFO);
		endif;
	endif;

epilog
	delete proxyBGPRequest;
	*/
end;</source>
    </JadeMethod>
