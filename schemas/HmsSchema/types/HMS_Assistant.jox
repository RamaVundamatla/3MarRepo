    <JadeMethod name="setMyHarbour" id="56e77340-7f19-4263-a8af-71f4fb76afec">
        <updating/>
        <source>setMyHarbour(_harbour : HMS_Harbour) updating;
//--------------------------------------------------
// Created:	09 February 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	self.endNotificationForSubscriber(self);
	self.myHarbour := _harbour;

	if self.myHarbour &lt;&gt; null
	and self.myForm &lt;&gt; null then
		self.beginNotification(self.myHarbour, Object_Update_Event, Response_Continuous, 0);		
		self.beginNotification(self.myHarbour, Object_Delete_Event, Response_Continuous, 0);			
	elseif self.myTerminal &lt;&gt; null then
		self.beginNotification(self.myTerminal, Object_Update_Event, Response_Continuous, 0);	
	endif;
				
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminal" id="6a04d2f6-d88e-475b-8dce-a06fd96d6331">
        <updating/>
        <source>setMyTerminal(_terminal: CM_Terminal) updating;
//--------------------------------------------------
// Created:	09 February 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_terminal);

	if _terminal &lt;&gt; null then
		self.setMyHarbour(_terminal.myHarbour);	
	endif;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="showHMSReportInitForm" id="3335d931-4987-4dbd-b255-fd6d645ff924">
        <source>showHMSReportInitForm(_terminal : CM_Terminal; _hmsFormName : String; _reportType : Integer;_startDT, _endDT : TimeStamp);
//--------------------------------------------------
// Created:	November 2004 By: cnwgd1
//--------------------------------------------------
vars
	formCls,
	assistCls	: Class;
	reportInitFrm : HMS_ReportInitiatorBase;
	subSys : CMUI_SubSystem;	
begin

	subSys := app.myController.allSubSystems['HmsSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails(_hmsFormName, formCls, assistCls);
	endif;

	create reportInitFrm as formCls;
	reportInitFrm.initDateRange(_startDT, _endDT);
	reportInitFrm.reportType := _reportType;
	reportInitFrm.setMyTerminal(self.myTerminal);	
	reportInitFrm.createMyAssistant(assistCls);
	reportInitFrm.myHarbour := self.myHarbour;
	reportInitFrm.show();

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_hmsFormName" type="String"/>
        <Parameter name="_reportType" type="Integer"/>
        <Parameter name="_startDT" type="TimeStamp"/>
        <Parameter name="_endDT" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="showHMSTidalModel" id="91377dec-0179-4ce9-ab0a-c5c822f08f2a">
        <source>showHMSTidalModel(_workingMovement: CMIF_HMS_WorkingMovement; _masterMenuAction: CMUI_MenuAction) : HMS_TidalModelForm;
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------
// 10/02/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements - new return type so we can return the created form
vars
	theForm : HMS_TidalModelForm;
	menuAction : CMUI_MenuAction;
begin
	menuAction := app.myController.createMenuAction(PmHMSTidalModelInterfaceView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		//return;						// PAR #33337
		return null;					// PAR #33337
	endif;
	
	theForm := menuAction.goToObject(null, null, false, null).HMS_TidalModelForm;
	if theForm = null then
		//return;						// PAR #33337
		return null;					// PAR #33337
	endif;
	theForm.myWorkingMovement := _workingMovement;
	theForm.show();
	return theForm;						// PAR #33337
end;</source>
        <Parameter name="_workingMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <ReturnType type="HMS_TidalModelForm"/>
    </JadeMethod>
    <JadeMethod name="showSavedConflictReportForm" id="39d7b82e-256c-4324-9569-7d0a29392f61">
