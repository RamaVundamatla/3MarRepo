<Class name="JSSAccountCard" id="6a032ca4-58ac-403b-9ac6-558cdf77eef5">
    <superclass name="JSSPrimitiveValue"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
