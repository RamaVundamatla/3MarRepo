    <JadeMethod name="addItem" id="5c3d8645-dc7c-4642-9adc-b7fb0a2711c0">
        <executionLocation>client</executionLocation>
        <source>addItem(str: String): Integer clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2024	navcs2	ChangeRequest 66181
*/

vars

begin
	return inheritMethod(str);

epilog

end;</source>
        <Parameter name="str" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addParentAndChildren" id="5ebd7300-4cbd-4dac-9a2a-36b4b098de95">
        <source>addParentAndChildren(_text, _displayAttribute : String; _obj : Object; _children: ObjectSet; _parentLevel : Integer; _expanded : Boolean) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2024	navcs2	ChangeRequest 66181
*/

vars
	idx			: Integer;
	childObj	: Object;
begin

	idx := self.addItem(_text);
	self.itemLevel[idx] 	:= _parentLevel;
	self.itemExpanded[idx] 	:= _expanded;
	self.itemObject[idx] 	:= _obj;
	
	foreach childObj in _children do
		self.addTreeObject(childObj.getPropertyValue(_displayAttribute).String, childObj, _parentLevel+1, false);
	endforeach;	
	
	return idx;

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_displayAttribute" type="String"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_children" type="ObjectSet"/>
        <Parameter name="_parentLevel" type="Integer"/>
        <Parameter name="_expanded" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addTreeObject" id="98b8bf5c-9701-4779-acc2-6c58cedb0a25">
        <source>addTreeObject(_text : String; _obj : Object; _level : Integer; _expanded : Boolean) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2024	navcs2	ChangeRequest 66181
*/
vars
	idx		: Integer;
begin

	idx := self.addItem(_text);
	self.itemLevel[idx] 	:= _level;
	self.itemExpanded[idx] 	:= _expanded;
	self.itemObject[idx] 	:= _obj;

	return idx;

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_expanded" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="click" id="1049e10c-faa6-4843-976e-8c89a3362683">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(listbox: ListBox input) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2024	navcs2	ChangeRequest 66181

*/

vars
	subItem : Object;
	count,
	parentIdx	: Integer;
	selected : Boolean;
	allSelectedItems : CM_IntegerArray;
begin
	parentIdx := self.listIndex;
	
	selected := self.itemSelected[parentIdx];
	
	create allSelectedItems transient;
	
	self.getSelectedEntries(allSelectedItems);
	
	foreach parentIdx in allSelectedItems do
		if self.itemHasSubItems(parentIdx) then
			count := parentIdx + 1;
			while not self.itemLevel[count] = self.itemLevel[parentIdx] do
				self.itemSelected[count] := selected;
				count := count +1;
				if self.listCount &lt; count then
					return;
				endif;
			endwhile;
		endif;
	endforeach;	
	
epilog
	delete allSelectedItems;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pictureClick" id="4c462dec-2cc3-43df-b014-e0ad8e535ccc">
        <controlMethod name="ListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2024	navcs2	ChangeRequest 66181
*/

vars

begin
	self.expandItem(picIndex);
	
	inheritMethod(listbox, picIndex, whatClicked);

epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setup" id="1f49f320-4d90-4391-a379-5f6670eada87">
        <updating/>
        <source>setup()updating; 
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2024	navcs2	ChangeRequest 66181
*/

vars

begin
	self.clear;
	self.multiSelect  := 2;
	self.hasPlusMinus := true;
	self.hasTreeLines := true;
epilog

end;</source>
    </JadeMethod>
