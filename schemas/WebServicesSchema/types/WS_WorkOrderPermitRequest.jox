    <JadeMethod name="setProxyFromObject" id="4c2fcc99-b910-4309-9d5f-148a8cb2d537">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodPermitRequest ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/10/2018	jlger1	Initial creation
11/12/2018	jlgdap1	TFS 42456 PEL1 More details in security role
24/01/2022  navma1	Bug 52662: SAL - Permit Request allowed edit after complete from Web Portal
23 Feb 2024	navsck1	ChangeRequest 62237 [62238]: MTN | Manage Work Order Documents in Web Portal
*/

vars
	wodCargoRequest 	: CM_WodCargoRequest;
	wsDetail 			: WS_VoyageHoldCargo;
	marineServiceDetail : CM_WodMarineServiceDetail;
	wsHMSResourceUsed 	: WS_HMSResourceUsed;
	failedDAC  			:CM_DataAccessController;
	file : CM_FileData;
	wsDocument 	: WS_Document;
	wo : CM_WorkOrder;
begin
	inheritMethod(_object);
	
	if _object.myOperator &lt;&gt; null then
		self.permitOperator:=_object.myOperator.getOidAsString;
	endif;
	
	foreach wodCargoRequest in  _object.allCargoDetails  discreteLock do
		create wsDetail  transient;
		wsDetail.setProxyFromObject(wodCargoRequest);
		self.allCargo.add(wsDetail);
	endforeach;

	foreach marineServiceDetail in  _object.allMarineServiceDetails discreteLock do
		create wsHMSResourceUsed transient;
		wsHMSResourceUsed.setProxyFromMarineService(marineServiceDetail);
		self.allHMSResourcesUsed.add(wsHMSResourceUsed);
		
	endforeach;
	
	
	//if self.canEdit and _object.myOperator &lt;&gt; null then																								// TFS 42456
	if self.canEdit and _object.myOperator &lt;&gt; null and not app.myPassport.myUser.canDo(_object.getMyParent.getMyTerminal, PmWebVoyWOCargoMaint) then	// TFS 42456
		if not _object.myOperator.canUserAccessSelf(app.myPassport.myUser, failedDAC, app.myPassport) then
			self.canEdit:=false;
		endif;
	endif;
	if not self.canEdit and app.myPassport.myUser.canDo(_object.getMyParent.getMyTerminal, PmWebVoyWOCargoMaint) then									// TFS 42456
		//24.01.22 navma1 #52662
		if _object.getStatus &lt; WO_STATUS_APPROVED then
			self.canEdit := true;																														// TFS 42456
		endif;
	endif;																																				// TFS 42456
	
	wo := _object.myParent;							// 23.02.2024 navsck1 #62237
	if wo &lt;&gt; null then								// 23.02.2024 navsck1 #62237
		foreach file in wo.allFiles do				// 23.02.2024 navsck1 #62237
			create wsDocument transient;			// 23.02.2024 navsck1 #62237
			wsDocument.setProxyFromObject(file);	// 23.02.2024 navsck1 #62237
			self.allDocuments.add(wsDocument);		// 23.02.2024 navsck1 #62237
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_WodPermitRequest"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="dd6bda35-549d-48ee-9579-30df23d8df67">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WodPermitRequest input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Oct 2018	jlger1	Initial creation tfs 41310
02 Feb 2022 navma1	Bug 52663: SAL - Permit Request Duplicating attachments
26 Feb 2024	navsck1	ChangeRequest 62237 [62238]: MTN | Manage Work Order Documents in Web Portal
*/

vars
	pxyResourceUsed 		: HMS_ResourceUsed;
	wsHMSResourceUsed 		: WS_HMSResourceUsed;
	allPxyHMSResourcesUsed  : HMS_ResourceUsedSet;
	wodCargoRequest, 
	pxyWorkOrder 			: CM_WodCargoRequest;
	wsDocument 				: WS_Document;
	wsCargoDetail 			: WS_VoyageHoldCargo;
	allFiles 				: CM_FileDataSet;
	pxyFile 				: CM_FileData;
	allPxysToDelete 		: ObjectSet;
	allDocuments			: ObjectArray;
begin
	
	inheritMethod(_pxyWorkOrder);
	
	_pxyWorkOrder.myParent.setProxyTaskStatus(WO_STATUS_PENDING);
	create allPxyHMSResourcesUsed transient;
	
	foreach wsHMSResourceUsed in self.allHMSResourcesUsed discreteLock do
		create pxyResourceUsed transient;
		wsHMSResourceUsed.setProxyHMSResorceUsed(pxyResourceUsed);
			
		allPxyHMSResourcesUsed.add(pxyResourceUsed);		
	endforeach;
	
	_pxyWorkOrder.setMarineDetsFromResourceUsed(allPxyHMSResourcesUsed);

	
	/*create allFiles transient;
	foreach wsDocument in self.allDocuments discreteLock do
		create pxyFile transient;
		wsDocument.setProxyFileData(pxyFile);
		allFiles.add(pxyFile);
	endforeach;	
	*/
	/*create allDocuments transient;							// 26.02.2024 navsck1 #62237
	beginLoad;												// 26.02.2024 navsck1 #62237
	self.allDocuments.setProxyDocuments(allDocuments);		// 26.02.2024 navsck1 #62237
	endLoad;												// 26.02.2024 navsck1 #62237
	*/
	//epr TFS 42254 28/11/18
	create allPxysToDelete transient;
	_pxyWorkOrder.allCargoDetails.copy(allPxysToDelete);
	
	foreach wsCargoDetail in self.allCargo	discreteLock do	
		pxyWorkOrder:=null;
		
		if wsCargoDetail.cmObjectId &lt;&gt; null then
			wodCargoRequest:=app.myPassport.getObjectOfTypeFromOid(wsCargoDetail.cmObjectId,CM_WodCargoRequest).CM_WodCargoRequest;
			if wodCargoRequest &lt;&gt; null then
				pxyWorkOrder := wodCargoRequest.pxyGetProxyObject;
				if pxyWorkOrder &lt;&gt; null then
					allPxysToDelete.remove(pxyWorkOrder);
				endif;
			endif;
		endif;	
			
		if pxyWorkOrder = null then
			create pxyWorkOrder transient;
			_pxyWorkOrder.allCargoDetails.add(pxyWorkOrder);
		endif;

		wsCargoDetail.setProxyWodCargoRequest(pxyWorkOrder);
		
	endforeach;
	
	//02.02.2022 navma1 #52663
	/*if not allFiles.isEmpty then
		allFiles.copy(pxyWorkOrder.allFiles);
	endif;*/
	/*if not allDocuments.isEmpty then									// 28.02.2024 navsck1 #62237
		foreach pxyFile in allDocuments as CM_FileData do
			pxyWorkOrder.allFiles.addNoDuplicates(pxyFile, false);
		endforeach;
	endif;																// 28.02.2024 navsck1 #62237
	*/
epilog
	
	if allPxysToDelete &lt;&gt; null then
		allPxysToDelete.purge;	
	endif;
	delete allPxysToDelete;
	
	if allPxyHMSResourcesUsed &lt;&gt; null then
		allPxyHMSResourcesUsed.purge;
	endif;
	delete allPxyHMSResourcesUsed;
	
	delete allFiles;
	//delete allDocuments; // 28.02.2024 navsck1 #62237
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WodPermitRequest" usage="input"/>
    </JadeMethod>
</Class>
