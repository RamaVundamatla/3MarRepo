    <JadeMethod name="createWLE" id="49709c49-234b-41aa-8384-0f4e9312f2e4">
        <source>createWLE() : CM_WorkListEntry;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwrd1	Initial creation

*/

vars

	wle	: CM_UnpackWLE;

begin

	create wle;
	wle.setForCreate(self.myJob, self);
	wle.causeEvent(wle.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, wle);	

	return wle;
epilog

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="2aed6889-a85e-4088-abfc-2e83b36efdda">
        <updating/>
        <source>createWLEs() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwrd1	Initial creation

*/

vars

	i,
	numReq,
	numTIs		:	Integer;
	aWLE		:	CM_WorkListEntry;
	theTI		: 	CM_TrackedItem;
	iter		: 	Iterator;
begin
	//------------
	//Create the appropriate WLEs
	// 1 for each ti on the job and extra up to totalRequested
	//------------
	
	numTIs := self.myJob.CM_UnpackJob.allTrackedItems.size;
	
	numReq := self.totalRequested;
	i := 1;		
	
	if numReq &lt; numTIs then
		numReq := numTIs;
	endif;
	
	iter := self.myJob.CM_UnpackJob.allTrackedItems.createIterator;

	// step through all real ti's on the job 
	//then continue untill we have all we need
	
	while iter.next(theTI) do
	// create WLE , create pack  on ti link that to the wle			
		aWLE := self.createWLE();
		aWLE.setMyTrackedItem( theTI); // set the tracked item
		i := i+1;	
	endwhile;
		
	while true do
		if i &gt; numReq then
			//If total requested = 0 then we always create 1
			break;
		endif;

		//create 'empty' WLE's will fill them later
		aWLE := self.createWLE();
		i := i+1;		
	endwhile;

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d279e8bb-a8af-425e-8404-545651d59fbb">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwrd1	Initial creation
18 July 2017	cnwma1	TFS #5410:Yard Operations - Invalid property value issues
*/

vars

begin
	if _attrName = ETRow_IsoType or  _attrName = ETRow_IsoGroup   then //cnwma1 TFS #5410 18/07/2017  
		return null;
	
	elseif _attrName=ETRow_Id then  //cnwma1 TFS #5410 18/07/2017  
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.id;
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
