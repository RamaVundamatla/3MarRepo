<Class name="File">
    <JadeMethod name="copy" id="f8877fd1-9bf4-44cf-bb21-201d4bc01241">
        <updating/>
        <source>copy(_newFileName:String) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	newFile:File;
	binary:Binary;
begin
	self.kind := File.Kind_Binary;
	create newFile transient;
	newFile.kind := File.Kind_Binary;
	newFile.openOutput(_newFileName);
	binary := self.readBinary(self.fileLength);
	newFile.writeBinary(binary);
epilog
	delete newFile;		
end;</source>
        <Parameter name="_newFileName" type="String"/>
    </JadeMethod>
</Class>
