    <JadeMethod name="getExtraInfo" id="f19a2d3d-b695-4752-bf57-1e6b23faca14">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*
Purpose:	TFS 42221		
Date				Who			Reason
DECEMBER 2018		CNWAB1		Initial creation
27 Jan 2021 navma1	Bug 52681: SAL - Display of Total Weight in Kgs in macro information - Cargo/Permit request
*/

vars
	block  : CM_DataContainerBlock;
	cargo  : CM_WodCargoRequest;
	wodres : CM_WodMarineServiceDetail;
	str	   : String;
begin
	inheritMethod(_dataContainer);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Permit_type), DC_Label, 1, null);
	block.addNewItem(app.workOrderPermitsString(self.permitType), DC_Data, 1, null);

	//10.01.2022 navma1 #52681
	if self.myOperator &lt;&gt; null then
		str := self.myOperator.code.trimRight &amp; '  ' &amp; self.myOperator.description;
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Operator	), DC_Label, 1, null);
		block.addNewItem(str, DC_Data, 1, null);
	endif;
	
	foreach cargo in self.allCargoDetails	discreteLock do
		cargo.getExtraInfo(_dataContainer);
	endforeach;
	
	foreach wodres in self.allMarineServiceDetails discreteLock do
		wodres.getExtraInfo(_dataContainer);
	endforeach;	
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
