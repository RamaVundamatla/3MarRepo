    <JadeMethod name="trxInvoiceRecalculate" id="700c0b0f-48d9-4992-b7a5-bcba263f6e0b">
        <updating/>
        <source>trxInvoiceRecalculate(_invoice : CM_Invoice input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     May 2012 by cnwjre1
//
// Purpose:     Recalculate rate and quantity on invoice print or on demand
//
// Parameters:  invoice to be recalculated, passport
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	//04 Sep 2017	NDL	TFS 6759
	if _invoice.status = CM_Invoice.INVOICE_POSTED_REVERSE	
	or _invoice.status = CM_Invoice.INVOICE_PENDING_REVERSE //31.10.2018 cnwma1 TFS #41703
	or _invoice.status = CM_Invoice.INVOICE_POSTED_CREDIT	
	then
		return;
	endif;
	
	beginTransaction;

	app.myUtilityUA.utlInvoiceRecalculate(_invoice, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxLanderDischargeToGround" id="643850b3-905e-4094-8fdb-773f078e6008">
        <updating/>
        <source>trxLanderDischargeToGround(_groundOption : Integer;	
							_ti : CM_TrackedItem input;
							_groundLC : CM_LocationsController input;
							_job : CM_VoyageJob;
							_wle : CM_WorkListEntry input;
							_passport : CM_Passport input) updating;
/*
Purpose:			
Date		Who		Reason
07 July 2015	cnwab1	Initial creation
12 July 2017	jlgrh7 TFS #37523 SNO - (re Ticket 8412) - Error when discharging RORO+LOLO containers (Object has been deleted)
04 Jan 2019	NDL	TFS 42738
*/

vars

	invalidJob : Boolean;	//02 Feb 2018	NDL	TFS 36879
	id : String;	//02 Feb 2018	NDL	TFS 36879
	moveController : CMIF_MoveController;	//02 Feb 2018	NDL	TFS 36879
	priorLocation : CM_LocationsController;	//02 Feb 2018	NDL	TFS 36879
	params : CMIF_AutoplanParams;	//02 Feb 2018	NDL	TFS 36879
	invalidWLD : Boolean;							//+TFS37523
	edition : Integer;
	vWle : CM_WorkListEntry;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	priorLocation := _ti.myPrimaryActualLocation;	//02 Feb 2018	NDL	TFS 36879
	
	beginTransaction;

	app.myUtilityUA.utlUpdateLanderDischargeGround(	_groundOption, _ti ,_groundLC ,_job,_wle,_passport);
	
	
	on Exception do app.handleDeletedObject(exception, _wle, invalidWLD);
	vWle := _wle;
	if _wle &lt;&gt; null then
		edition := _wle.edition;
		if invalidWLD then
			vWle := null;
		endif;
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	
	//02 Feb 2018	NDL	TFS 36879 - migrated from CMIF_MobileGenericAgent::doLanderDischargeToGround so we have just one transaction
	if _groundOption = GroundInTransit and ( not _ti.isQueued ) and ( priorLocation &lt;&gt; _ti.myVoyage.myNotNotifiedStack ) then																					
		if _ti.isPlanned(PLANNING_MODE) then	//13 Aug 2012	NDL	Par 29961
			create moveController transient;
			moveController.setMyTrackedItem(_ti);
			moveController.setMyOriginatingLocation(_ti.myPrimaryActualLocation);
			moveController.setMoveMode(QUEUE_MODE);	
			moveController.setMyToPrimaryLocation(_ti.myPrimaryPlannedLocation);
			moveController.setMyWorkListEntry(vWle);
			
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	
		else
			on Exception do app.handleDeletedObject(exception, _job, invalidJob);							
			id := _job.id;
			
			create params transient;
			params.allTrackedItems.add( _ti );
			params.moveMode := QUEUE_MODE;
			params.myTerminalArea := null;
			if invalidJob then
				params.myJob := null;
			else
				params.myJob := _job;
			endif;
			params.isHHInTransitMove := true;
			
			app.myUtilityUA.utlUpdateAutoplanTrackedItems(params, _passport);
			
		endif;
		
	//	on Exception do app.handleDeletedObject(exception, _wle, invalidWLD);	//+TFS37523 To handle invalid wel as it has been set to null and deleted after moving
	//	id := _wle.id;
	//	if not invalidWLD  and ( vWle = null or vWle.getTargetLocation = null ) then //+TFS37523
	//	if invalidWLD  or vWle = null or vWle.getTargetLocation = null then	//04 Jan 2018	NDL	TFS 42738
		if not invalidWLD  and vWle &lt;&gt; null and vWle.getTargetLocation = null then		// 4/9/19 MAP TFS45903
			//Can't ground under the crane as an in 'transit type move' when we are not in transit to somewhere else...
			app.raiseCMException1(ERR_NO_AUTOPLAN, _ti.id, null, null);
		endif;
		
	endif;
	
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();	
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
	
	delete moveController;	//02 Feb 2018	NDL	TFS 36879
	delete params;	//02 Feb 2018	NDL	TFS 36879

end;</source>
        <Parameter name="_groundOption" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_groundLC" type="CM_LocationsController" usage="input"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxLoadFileCustDocExtRef" id="b33fd9b0-258c-4eaf-a8a6-68ff0ef3670c">
        <updating/>
        <source>trxLoadFileCustDocExtRef(_file : File; _terminal : CM_Terminal; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2023	navkc1	CR 60347  Task 60348: Jade - TRX to Accept CSV File For Updating Ext Ref on Custom Document

*/

vars

begin
