    <JadeMethod name="processFile" id="542e7a8e-daa3-4780-9b58-d050697bbaaa">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26 May 2023	navdap1		Initial creation TFS 57074 EUP - Manifest EDI Operations / Load (EDI Controller Agent)
// 7 June 2023	navra1		TFS 57074 - 57074 Load Rail Manifest Message - Task - 58270
// 8 June 2023	navsp1		TFS 57074 - 57074 Load Rail Manifest Message
// 3 Aug  2023	navra1 		TFS 59648 - EUP - Train Cancel - Cancel file for a non-existing manifest number can be DB loaded
// 07 Aug 2023	navdap1		TFS 59719 EUP - EDI Sender Field - Financial ID
// 16 Aug 2023	navmd1		TFS 59811 Handle parsing errors when reloading JSON
// 21 Aug 2023	navmd1		TFS 59024 Look for the transformed JSON data elsewhere for web messages
// 18 Sep 2023	jlika1		TFS 60465 EUP | FR 53824 Manifest - Operator Level Translations To Also Be Used For EDI File Loads
// 10 Oct 2023	navmd1		TFS 60588 Accept both 'Sea' and 'Ship' messages
vars
	manifestMessage				: String;
	json 						: JadeJson;
	manifest 					: CM_EDIDataTransManifest;
	objectArray					: ObjectArray;
	jsonManifestMsg 			: CMIF_JsonManifestEUP;
	header 						: CMIF_JsonHeaderEUP;
	transportJson				: CMIF_JsonTransportFullEUP;
	operatorCode				: String;
	senderOperator				: CM_Operator;
	messageMode					: String;
	status						: String;
	existEdiFile				: CM_EDIFile;
	ediConfig 					: CM_EDIConfig;
	statusString				: String;
	debtorCode					: String;			// TFS 59719
	debtor						: CM_Debtor;		// TFS 59719
	jsonException				: Boolean;
	errorText,
	extendedErrorText			: String;
begin	

	create json transient;
	create objectArray transient;
	
	manifestMessage := _ediFile.getRawDataString();					// Manual File Load / Web message Post-Transform
	if manifestMessage = null then
		manifestMessage := _ediFile.getOriginalFileDataString();	// Web Message - Pre-Transformed JSON. NB. this will not parse correctly... or will, but everything will be empty
	endif;
	
	on Exception do self.handleJSONException(exception, jsonException, errorText, extendedErrorText);
	jsonManifestMsg := json.parse(manifestMessage, CMIF_JsonManifestEUP, objectArray).CMIF_JsonManifestEUP;
	on Exception do null;
	
	if jsonException or jsonManifestMsg.header = null then
		if errorText = null then
			// If the JSON isn't what we expect, but manages to be 'parsed' because its just thrown away, then at least complain about *something*
			errorText := "Unable to parse JSON data";
		endif;
		self.addFileErrors(errorText, 0, _ediFile);
		if extendedErrorText &lt;&gt; null then
			self.addFileErrors(extendedErrorText, 0, _ediFile);
		endif;
		return;
	endif;
	
	status := jsonManifestMsg.header.status;	
	header := jsonManifestMsg.header;
	ediConfig := _ediFile.ediConfig;	
	
	self.findExistingEDIFile(header.number, _ediFile,  existEdiFile);//04.Jul.2023 navsp1 TFS 58055
	
	if existEdiFile &lt;&gt; null then
		
		//10.Mar.24 navsp1 TFS 60793
		if existEdiFile.ediData &lt;&gt; null then
			if existEdiFile.ediData.status = CM_EDIFile.EDI_STATUS_LOADING or existEdiFile.ediData.status = CM_EDIFile.EDI_STATUS_VERIFYING or existEdiFile.ediData.status = CM_EDIFile.EDI_STATUS_DBLOADING then
				app.writeLog(app.getErrorString1(Exist_file_not_db_loaded, header.number), LogERROR);
				app.raiseCMException1(Exist_file_not_db_loaded, header.number, null, null);
				return;
			endif;
		endif;
		
		if header.status = CMIF_JsonHeaderEUP.Status_Cancel then
			messageMode	:= CM_EDITrackedItem.EDI_ACTION_DELETE;
			statusString := CMIF_JsonHeaderEUP.Status_Cancel;
		else
			messageMode	:= CM_EDITrackedItem.EDI_ACTION_UPDATE;
			statusString := CMIF_JsonHeaderEUP.Status_Replace;
		endif;
	else
		if header.status = CMIF_JsonHeaderEUP.Status_Cancel then	//navra1 - TFS 59648 - 3rd Aug 2023
			messageMode	:= CM_EDITrackedItem.EDI_ACTION_DELETE;
			statusString := CMIF_JsonHeaderEUP.Status_Cancel;
		else														//navra1 - TFS 59648 - 3rd Aug 2023
			messageMode	:= CM_EDITrackedItem.EDI_ACTION_ADD;		//navra1 - TFS 59648 - 3rd Aug 2023
			statusString := CMIF_JsonHeaderEUP.Status_Create;		//navra1 - TFS 59648 - 3rd Aug 2023
		endif;														//navra1 - TFS 59648 - 3rd Aug 2023
	endif;	

	// create manifest EDI data object, link to the EDI file
	if _ediFile.ediData = null then
		create manifest persistent;
		manifest.setForCreateNoProxy(ediConfig, EDIDataType_TransportManifest, EDIFileType_TransportManifest, _ediFile, app.myPassport.getUserCode());
	endif;
	
	manifest := _ediFile.ediData.CM_EDIDataTransManifest;
	manifest.setStatus(CM_EDIFile.EDI_STATUS_LOADING);	//11.Mar.24 navsp1 TFS 60793 - Set status as loading
	
	//Check the sender operator is valid
	// TFS 59719 Sender code in the message is actually the financial ID of a debtor
	// - find the debtor and its related Operator entity, then use that Operator for translations
	
	debtorCode := header.sender.toUpper;
	operatorCode := header.sender.toUpper;		//25.Sep.2023 navsp1 TFS 60473 - code restored	
	debtor := app.myRoot.myRootCompany.allDebtorsByCode[debtorCode];
	if debtor &lt;&gt; null then
		senderOperator := debtor.operators.first;
		if senderOperator &lt;&gt; null then			//25.Sep.2023 navsp1 TFS 60473 - code restored	
			operatorCode := senderOperator.code;
		endif;
	else
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Unable to find a Debtor by code " &amp; debtorCode, LogDEBUG);
	endif;
	// TFS 59719 end
	
	if senderOperator = null then				//25.Sep.2023 navsp1 TFS 60473 - code restored	
		senderOperator	:= app.myRoot.allOperators[operatorCode];
	endif;
	
	if senderOperator = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Sender operator not found from sender code of " &amp; debtorCode, LogERROR);
	endif;
	
	//set details in the manifest	
	manifest.guid			:=	header.id;
	manifest.sender			:=	header.sender.toUpper();		 //navra1 - TFS 59671 - 8th Aug 2023
	manifest.receiver		:=	header.receiver.toUpper();		 //navra1 - TFS 59671 - 8th Aug 2023
	manifest.statusString 	:=	statusString;//header.status; //13.Jul.2023 navsp1 TFS 58055
	manifest.type			:=  header.type;
	manifest.operatorCode 	:=	operatorCode[1:CM_Operator::code.length-1];
	manifest.setManifestNumber(header.number);
	
	//set details in the edifile
	_ediFile.setEdiClientRef(header.number);
	_ediFile.setGuid(header.id);
	_ediFile.setFileSenderCode(header.sender.toUpper());			//navra1 - TFS 59671 - 8th Aug 2023
	_ediFile.setFileRecipientCode(header.receiver.toUpper());		//navra1 - TFS 59671 - 8th Aug 2023
	_ediFile.setEdiMessageType(header.type);
	_ediFile.mode := header.status;
	_ediFile.setHeaderReferences(header.headerReferences);
	
	if jsonManifestMsg.transports.size &gt; 1 then
		//we dont support multiple transports inside one message for now
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Multiple transport strctures inside manifest message, this is not supported for now - returning", LogERROR);
	endif;
	
	transportJson := jsonManifestMsg.transports.first();
	
	if transportJson = null then		
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No transport structure inside manifest message - returning", LogERROR);
		return;
	endif;
	
	if transportJson.transportationMode = self.TRANSPORT_MODE_SEA or transportJson.transportationMode = TI_TRANSMODE_SHIP_STR then
		
		self.processShipMessage(_ediFile, jsonManifestMsg, senderOperator, messageMode);			
		
	elseif transportJson.transportationMode = self.TRANSPORT_MODE_ROAD then
		
		self.processRoadMessage(manifest, _ediFile, jsonManifestMsg, senderOperator, messageMode);
		
	elseif transportJson.transportationMode = self.TRANSPORT_MODE_RAIL then
		
		self.processRailMessage(manifest, _ediFile, jsonManifestMsg, senderOperator, messageMode);
		
	elseif header.type = self.TYPE_CARGOONSITE then
		
		self.processOnSiteMessage(_ediFile, jsonManifestMsg, senderOperator, messageMode);		//05.Oct.2023 navsp1 TFS 58058
		
	else		
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Unknown Transport Mode " &amp; transportJson.transportationMode &amp; " - returning", LogERROR);
		app.raiseUnexpectedProgramError(class.name, method.name, method.qualifiedName);
	endif;	
	
epilog
	delete json;
	objectArray.purge;
	delete objectArray;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processOnSiteMessage" id="defc9249-77cc-4aad-89e1-c4e00b1a4197">
        <source>processOnSiteMessage(_ediFile: CM_EDIFile input; 
					_manifestMsg : CMIF_JsonManifestEUP; 
					_xlationOperator : CM_Operator; 
					_messageMode : String) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/06/2023	navdap1		Initial creation TFS 56747 EUP Manifest Processing - Internal (Zimmer) - Create
// 12/09/2023	navdap1		TFS 60453 EUP | FR 53824 - EDI Operations Date Range Filter Sometimes Omits Valid or Includes Invalid EDI Data Items
// 06/10/2023	navcs2		ChangeRequest 60787: EUP | Add system alert for File Loading fails 
// 16/05/2024   navsp1      TFS Bug 62254: EUP | FR - Transport Manifest - "Itemised" Field is not Working Correctly.
vars
	manifest : CM_EDIDataTransManifest;
	terminal : CM_Terminal;
	header : CMIF_JsonHeaderEUP;
	cargoOnSite : CM_EDIDataCargoOnSite;
	good : CMIF_JsonGoodEUP;
	item : CMIF_JsonItemEUP;
	transport : CMIF_JsonTransportFullEUP;
	tiOnSite : CM_EDICargoOnSiteTI;
	parentOnSite : CM_EDICargoTI;
	oldOnSite : CM_EDIDataCargoOnSite;		// TFS 60453
	errorMessages 	: StringArray;							//06/10/2023 navcs2	ChangeRequest 60787
	errorMessage	: String;								//06/10/2023 navcs2	ChangeRequest 60787
	itemised 		: Boolean;
begin
	manifest := _ediFile.ediData.CM_EDIDataTransManifest;
	
	create errorMessages transient;							//06/10/2023 navcs2	ChangeRequest 60787
	
	terminal := app.myPassport.myTerminal;
	header := _manifestMsg.header;
	transport := _manifestMsg.transports.first;
	if transport = null then
		errorMessage := method.qualifiedName &amp; Tab &amp; "No Transport in Transports section - nothing to do";	//06/10/2023 navcs2	ChangeRequest 60787
		app.writeLog(errorMessage , LogERROR);																//06/10/2023 navcs2	ChangeRequest 60787
		errorMessages.add(errorMessage);																	//06/10/2023 navcs2	ChangeRequest 60787
		return;
	endif;
	
	// TFS 60453 If there is already a cargoOnSite object attached to the manifest (because we're doing a reload/retranslate), delete it
	// TFS 60453 otherwise it gets orphaned when the new cargoOnSite object is created below
	if manifest &lt;&gt; null and manifest.myCargoOnSite &lt;&gt; null then
		oldOnSite := manifest.myCargoOnSite;
		oldOnSite.erase(NORMAL_ERASE);
	endif;
	// TFS 60453 end
	
	// create and populate the CM_EDIDataGateDoc object

	
	// create a EDI Data Cargo On Site object
	create cargoOnSite persistent;
	cargoOnSite.setForCreateNoProxy(_ediFile.ediConfig, EDIDataType_CargoOnSite, EDIFileType_UserDefined, _ediFile, app.myPassport.getUserCode());		//05.Oct.2023 navsp1 TFS 58058
	manifest.setMyCargoOnSite(cargoOnSite);

	// create cargo on site for each good and item
	foreach good in transport.goods do
		itemised := good.items.size &gt; 0;					//24.Jan.24 navsp1 TFS 61660//TFS 62254 - changed from 1 to 0
		//Create a cargo group to represent the Goods/Good
		create parentOnSite persistent;				//TFS 62254 - changed from tiOnSite to parentOnSite
		parentOnSite.setFromGoodAndItem(good, null, parentOnSite, manifest.myCargoOnSite, _xlationOperator, manifest, null, _messageMode, itemised);				//05.Oct.2023 navsp1 TFS 58058 //TFS 62254
		
		//if itemsJson has 0 item, it represents non-itemized cargo, otherwise it represents itemized cargo
		foreach item in good.items do			
			create tiOnSite persistent;			
			tiOnSite.setFromGoodAndItem(good, item, parentOnSite, manifest.myCargoOnSite, _xlationOperator, manifest, null, _messageMode, itemised);				//05.Oct.2023 navsp1 TFS 58058					
		endforeach;
	endforeach;
	
epilog
	if not app.myPassport.hasErrors and manifest.myCargoOnSite &lt;&gt; null then
		manifest.myCargoOnSite.setStatus(CM_EDIFile.EDI_STATUS_LOADED);
	endif;	

	self.writeAlerts("Errors - ", false, errorMessages);						//06/10/2023 navcs2	ChangeRequest 60787
	
	delete errorMessages;			//11.Oct.2023 navsp1 TFS 58058
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_manifestMsg" type="CMIF_JsonManifestEUP"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <Parameter name="_messageMode" type="String"/>
    </JadeMethod>
    <JadeMethod name="processRailMessage" id="7e42fe65-b6d0-4e3a-ab11-609b703242ad">
        <source>processRailMessage(_manifest : CM_EDIDataTransManifest input; _ediFile: CM_EDIFile input; _jsonManifestMessage : CMIF_JsonManifestEUP; _xlationOperator : CM_Operator; _messageMode : String) protected;
/*

Purpose:			

Parameters:			EDIControllerAgent

Return Value:		

Date		Who		Reason
07 Jun 2023	navra1	Initial creation for TFS 57074 - 57074 Load Rail Manifest Message - Task - 58270
04 Jun 2023	navra1	EUP - Manifest Processing - Train - Update/Cancel
07 Sep 2023	navra1	TFS 60386 - EUP | FR 53824 - Rail Manifest - Carrier Code
12 Sep 2023	navdap1	TFS 60453 EUP | FR 53824 - EDI Operations Date Range Filter Sometimes Omits Valid or Includes Invalid EDI Data Items
28 Feb 2024 navsp1  Bug 61725: MTN - Transport Manifest Date/Time Issue
16 May 2024 navsp1  TFS Bug 62254: EUP | FR - Transport Manifest - "Itemised" Field is not Working Correctly.
*/

vars	
	headerJson 					: CMIF_JsonHeaderEUP;	
	trainInfoJson				: CMIF_JsonTrainInfoEUP;	
	trainConsist 				: CM_EDIDataTrainConsist;
	transportJson				: CMIF_JsonTransportFullEUP;
	ediPrenoteTI 				: CM_EDIPrenoteTI;
	parentPrenote				: CM_EDIPrenoteTI;
	allGoodsJson 				: CMIF_JsonGoodsArray;
	singleGoodJson 				: CMIF_JsonGoodEUP;
	itemsJson					: CMIF_JsonItemsArray;
	singleItem					: CMIF_JsonItemEUP;		
	wagonTI						: CM_EDIWagonTI;	
	wagonClassStr				: String;
	wagon,
	checkWagon 					: CM_Wagon;
	train						: CM_Train;
	nullTrain					: CM_Train;	
	terminal					: CM_Terminal;
	iter 						: Iterator;
	trainTI						: CM_EDITrainTI;
	wagonUpdateCtrl 			: CMIF_WagonUpdateController;
	newWagon					: CM_Wagon;
	pxyWagon					: CM_Wagon;
	wagonClass					: CM_WagonClass;
	carrier						: CM_Carrier;
	translatedCarrierCode		: String;							//navra1 - TFS 60386 - 7th Sep 2023
	foundMatch					: Boolean;							//navra1 - TFS 60386 - 7th Sep 2023
	oldTrainConsist				: CM_EDIDataTrainConsist;	// TFS 60453
	itemised 					: Boolean;
begin	
	
	if _jsonManifestMessage.transports = null or _jsonManifestMessage.transports.size() = 0 then
		app.writeLog("The _jsonManifestMessage.transports is null or 0 size, returning", LogERROR);
	endif;
	
	terminal		:= app.myPassport.myTerminal;
	transportJson 	:= _jsonManifestMessage.transports.first();
	trainInfoJson 	:= transportJson.trainInfo;
	headerJson 		:= _jsonManifestMessage.header;
	
	//navra1 - TFS 60386 - 7th Sep 2023 - start
	if transportJson.carrierParty &lt;&gt; null then						//to fix the 1090 - 09.feb.24 navsp1
		translatedCarrierCode := transportJson.carrierParty.code;
		if _xlationOperator &lt;&gt; null then
			translatedCarrierCode := _xlationOperator.getXlationSystemCode(translatedCarrierCode, XLATION_TYPE_CARRIER_BYOP, foundMatch);
		endif;
	endif;
	//navra1 - TFS 60386 - 7th Sep 2023 - end
	
	if transportJson = null or trainInfoJson = null or headerJson = null then
		app.writeLog("transportInfo, trainInfo or header info is missing in this manifest message", LogERROR);
		return;
	endif;	
	
	//_manifest.setOperatorCode(headerJson.sender);//04.Aug.2023 navsp1 TFS 59656 - Already setting the translated code in the previous method
	
	//check if we can derive a wagon class
	wagonClassStr := trainInfoJson.type;
	wagonClass := app.myRoot.allWagonClasses[wagonClassStr];
	
	if wagonClass = null then
		// if null, use hook code to get the wagon type
		wagonClassStr := app.myRoot.getWagonClassViaHookCode(app.myPassport.myTerminal, trainInfoJson.wagonNumber, null);
		if wagonClassStr = null then
			app.writeLog("The wagon class specified is unknown, check wagon class hook code is set correctly", LogERROR);
		endif;
	endif;
	
	// try to find the wagon on the null train, if none is found, create one
	if wagon = null then	
		nullTrain := app.myPassport.myTerminal.getNullTrain();		
		iter := nullTrain.allWagonsByIdInward.createIterator;
		nullTrain.allWagonsByIdInward.startKeyGeq(trainInfoJson.wagonNumber, iter);
		while iter.next(checkWagon) do
			if checkWagon.id &lt;&gt; trainInfoJson.wagonNumber then				
				continue;
			endif;
			if checkWagon.isDeparted then
				continue;
			endif;
			wagon := checkWagon;
			train := checkWagon.myTrainInwards;
			break;
		endwhile;
	endif;
	
	//if the wagon was not found anywhere, create one on the null train and use it for further processing
	if wagon = null and wagonClass &lt;&gt; null then	
		nullTrain := app.myPassport.myTerminal.getNullTrain();
		//carrier := app.myRoot.allCarriers[transportJson.carrierParty.code];		//navra1 - TFS 60386 - 7th Sep 2023
		carrier := app.myRoot.allCarriers[translatedCarrierCode];					//navra1 - TFS 60386 - 7th Sep 2023
		
		create wagonUpdateCtrl transient;
		
		wagonUpdateCtrl.setBasicDetails(CMIF_WagonUpdateController.Mode_Add,	//_mode : Integer;
											null,// rake
											nullTrain,	//_train : CM_Train;
											null, //_wagonPosition : Integer;
											true// isTrainMode
											);											
	
		create pxyWagon as wagonClass.getWagonVisitClassToCreate() transient;	//15 Mar 2013	NDL	Par 31278
		pxyWagon.setProxy(	terminal,	//_term : CM_Terminal; 
							trainInfoJson.wagonNumber,	//_id : String; 
							wagonClass,	//_class : CM_WagonClass;
							nullTrain,	//_train : CM_Train;
							nullTrain,	//_outTrain : CM_Train;
							null,	//_remark  : String;
							wagonClass.maxCargoHeight,	//_maxCargoHeight : Decimal; 
							wagonClass.maxLoadWeight,	//_maxCargoWeight : Decimal;
							wagonClass.tareWeight,	//_tareWeight : Decimal;
							carrier,	//_carrier : CM_Carrier
							null,     //02.10.2020 cnwma1 TFS #50112
							null	//02.10.2020 cnwma1 TFS #50112
							);
		
		wagonUpdateCtrl.myProxyWagon := pxyWagon;
		
		app.myPassport.clearErrorsWarnings();
		app.myPassport.setWarningsIgnored(true);
	
		if not process.isInTransactionState() then
			app.myTrxCA.trxCreateWagonFromCMIF(wagonUpdateCtrl, wagon, false, app.myPassport);
		else
			app.myUtilityCA.utlCreateWagonFromCMIF(wagonUpdateCtrl, wagon, false, true, app.myPassport);
		endif;
		
		if app.myPassport.hasErrors then		
			app.raiseCMException(Wagon_could_not_creat_null_tra, null, null);
			return;
		endif;		
	endif;
	
	if wagon &lt;&gt; null and wagonClassStr &lt;&gt; null and wagon.wagonClassCode &lt;&gt; wagonClassStr then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Wagon is not of type " &amp; wagonClassStr, LogERROR);
	endif;	
	
	// TFS 60453 If there's an existing train consist (because we're reloading/retranslating), delete it
	// TFS 60453 otherwise it ends up getting orphaned when the new one is assigned below
	if _manifest &lt;&gt; null and _manifest.myTrainConsist &lt;&gt; null then
		oldTrainConsist := _manifest.myTrainConsist;
		oldTrainConsist.erase(NORMAL_ERASE);
	endif;
	// TFS 60453 end
	
	//create a trainconsist
	create trainConsist persistent;
	trainConsist.setForCreateNoProxy(_ediFile.ediConfig, EDIDataType_TrainConsist, EDIFileType_UserDefined, _ediFile, app.myPassport.getUserCode());
	
	if train &lt;&gt; null then
		trainConsist.setCurrentTrainCode(train.code);
	else
		trainConsist.setCurrentTrainCode(NULL_TRAIN_CODE);
	endif;
	
	//CREATE WAGON TI - start
	//create the wagon TI as required based on trainInfoJson
	create wagonTI persistent;
	wagonTI.wagonClass	:= wagonClassStr;
	wagonTI.wagonNumber	:= trainInfoJson.wagonNumber;
	if transportJson.carrierParty &lt;&gt; null then						//navra1 - TFS 57808 - 21st June 2023
		//wagonTI.carrierCode := transportJson.carrierParty.code;		//navra1 - TFS 57808 - 21st June 2023		//navra1 - TFS 60386 - 7th Sep 2023
		wagonTI.carrierCode := translatedCarrierCode;					//navra1 - TFS 60386 - 7th Sep 2023
	endif;															//navra1 - TFS 57808 - 21st June 2023
	if wagon &lt;&gt; null then
		wagonTI.maxCargoWeight := wagon.maxCargoWeight;
		wagonTI.maxCargoHeight := wagon.maxCargoHeight;
		if train &lt;&gt; null then
			wagonTI.trainCode := train.code;
		endif;
		if wagon.myCarrier &lt;&gt; null then
			wagonTI.carrierCode := wagon.myCarrier.code;
		endif;
	endif;
	
	wagonTI.setMyEDIData(trainConsist);	
	
	if headerJson.status = "Create" or headerJson.status = "Update" then
		//The wagon exists, you are adding or updating a TI on it, so its an update wrt the wagon
		wagonTI.messageMode := CM_EDITrackedItem.EDI_ACTION_UPDATE;	
	endif;
	
	trainConsist.setCurrentWagonCode(trainInfoJson.wagonNumber);	
	
	//Create train TI
	create trainTI persistent;	
	trainTI.assignValueSpecial(CM_EDITrainTI::trainCode.name, trainConsist.currentTrainCode, _xlationOperator);	
	trainTI.assignValueSpecial(CM_EDITrainTI::scheduledArrivalDT.name, transportJson.estimatedDateTimeOfArrival.asUTCTimeStamp.utcToLocalTime.String, _xlationOperator);		//TFS 61725	
	trainTI.assignValueSpecial(CM_EDITrainTI::scheduledDepartureDT.name, transportJson.estimatedDateTimeOfDeparture.asUTCTimeStamp.utcToLocalTime.String, _xlationOperator);	//TFS 61725
	trainTI.setMyEDIData(trainConsist);		
	
	//The train exists, you are updating a wagon on it with the TI - either create, update or delete, so its an update wrt the train whatever case
	trainTI.messageMode := CM_EDITrackedItem.EDI_ACTION_UPDATE;		//navra1 - TFS 58057 - 4th July 2023
	
	if _manifest.myTrainConsist = null or _manifest.myTrainConsist &lt;&gt; trainConsist then
		_manifest.setMyTrainConsist(trainConsist);
	endif;	
	
	if transportJson.estimatedDateTimeOfArrival.isValid then
		_manifest.estimatedDateTimeOfArrival := transportJson.estimatedDateTimeOfArrival.asUTCTimeStamp.utcToLocalTime;//TFS 61725
	endif;
	if transportJson.estimatedDateTimeOfDeparture.isValid then
		_manifest.estimatedDateTimeOfDeparture := transportJson.estimatedDateTimeOfDeparture.asUTCTimeStamp.utcToLocalTime; //TFS 61725
	endif;	
	
	//populate goods/items information
	allGoodsJson := transportJson.goods;
	foreach singleGoodJson in allGoodsJson  do
		
		itemsJson := singleGoodJson.items;
		itemised  := itemsJson.size &gt; 0;			//24.Jan.24 navsp1 TFS 61660//TFS 62254 - changed from 1 to 0
		if itemised then							//TFS 62254
			//if itemsJson has 0 item, it represents non-itemized cargo, otherwise it represents itemized cargo
			foreach singleItem in itemsJson do			
				create ediPrenoteTI persistent;			
				ediPrenoteTI.setFromGoodAndItem(transportJson, singleGoodJson, singleItem, parentPrenote, trainConsist, _xlationOperator, _manifest, _messageMode, itemised);						
			endforeach;
		else										//TFS 62254
			create ediPrenoteTI persistent;			//TFS 62254	
			ediPrenoteTI.setFromGoodAndItem(transportJson, singleGoodJson, null, parentPrenote, trainConsist, _xlationOperator, _manifest, _messageMode, itemised);//TFS 62254
		endif;										//TFS 62254
	endforeach;	
epilog
	if not app.myPassport.hasErrors and _manifest.myTrainConsist &lt;&gt; null then
		_manifest.myTrainConsist.setStatus(CM_EDIFile.EDI_STATUS_LOADED);
	endif;	
	delete iter;
	delete wagonUpdateCtrl;
	delete pxyWagon;
end;</source>
        <access>protected</access>
        <Parameter name="_manifest" type="CM_EDIDataTransManifest" usage="input"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_jsonManifestMessage" type="CMIF_JsonManifestEUP"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <Parameter name="_messageMode" type="String"/>
    </JadeMethod>
    <JadeMethod name="processRoadMessage" id="f4b73f6d-d778-4590-9fc7-0df957ac2fee">
        <source>processRoadMessage(_manifest : CM_EDIDataTransManifest input; _ediFile: CM_EDIFile input; _jsonManifestMessage : CMIF_JsonManifestEUP; _xlationOperator : CM_Operator; _messageMode : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2023	navsp1	Initial creation TFS ChangeRequest 57074: EUP - Manifest EDI Operations / Load (EDI Controller Agent)
03 Jul 2023	navsp1	ChangeRequest 58055: EUP - Manifest Processing - Truck - Update/Cancel
12 Sep 2023	navdap1	TFS 60453 EUP | FR 53824 - EDI Operations Date Range Filter Sometimes Omits Valid or Includes Invalid EDI Data Items
28 Feb 2024 navsp1  Bug 61725: MTN - Transport Manifest Date/Time Issue
16 May 2024 navsp1  TFS Bug 62254: EUP | FR - Transport Manifest - "Itemised" Field is not Working Correctly.
*/

vars
	vesselInfo			: CMIF_JsonVesselInfoEUP;
	arrival, departure 	: TimeStamp;	
	header 				: CMIF_JsonHeaderEUP;
	carrierParty 		: CMIF_JsonCarrierPartyEUP;	
	vesselAgent 		: CMIF_JsonVesselAgentEUP;
	good 				: CMIF_JsonGoodEUP;
	item 				: CMIF_JsonItemEUP;
	gateDoc 			: CM_EDIDataGateDoc;
	prenoteParent		: CM_EDIPrenoteTI;
	prenoteTIItem 		: CM_EDIPrenoteTI;
	transport			: CMIF_JsonTransportFullEUP;
	truckInfo			: CMIF_JsonTruckInfoEUP;
	bookingRefStr		: String;
	oldGateDoc			: CM_EDIDataGateDoc;		// TFS 60453
	itemised			: Boolean;
begin
	
	app.writeLog(method.name &amp; Tab &amp; "Start processing the road message", LogDEBUG);
	transport 		:= _jsonManifestMessage.transports.first;
	if transport = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No Transport in Transports section - nothing to do" , LogERROR);
		return;
	endif;
	
	header			:= _jsonManifestMessage.header;
	vesselInfo 		:= transport.vesselInfo;
	carrierParty 	:= transport.carrierParty;
	truckInfo		:= transport.truckInfo;
	
	if vesselInfo &lt;&gt; null then
		vesselAgent := vesselInfo.vesselAgent;
	endif;
	
	// TFS 60453 If there's an existing gate doc (because we're reloading/retranslating), delete it
	// TFS 60453 otherwise it (and all its EDI TIs) gets orphaned when the new one is created below
	if _manifest &lt;&gt; null and _manifest.myGateDocument &lt;&gt; null then
		oldGateDoc := _manifest.myGateDocument;
		oldGateDoc.erase(NORMAL_ERASE);
	endif;
	// TFS 60453 end
	
	// create and populate the CM_EDIDataGateDoc object
	create gateDoc persistent;
	gateDoc.setForCreateNoProxy(_ediFile.ediConfig, EDIDataType_GateDocument, EDIFileType_UserDefined, _ediFile, app.myPassport.getUserCode());
	
	_manifest.setGateDocument(gateDoc);
	//_manifest.setOperatorCode(header.sender);//04.Aug.2023 navsp1 TFS 59656 - Already setting the translated code in the previous method.
	
	arrival 	:= null;
	departure 	:= null;
	
	if transport.estimatedDateTimeOfArrival.isValid then
		arrival := transport.estimatedDateTimeOfArrival.asUTCTimeStamp.utcToLocalTime;	//TFS 61725	
	endif;
	
	if transport.estimatedDateTimeOfDeparture.isValid then
		departure := transport.estimatedDateTimeOfDeparture.asUTCTimeStamp.utcToLocalTime;	//TFS 61725
	endif;
	
	_manifest.estimatedDateTimeOfArrival 	:= arrival;
	_manifest.estimatedDateTimeOfDeparture 	:= departure;
	_manifest.type							:= header.type;
	_manifest.vehicleBookingSlotRemarks		:= transport.remarks;
	
	if truckInfo &lt;&gt; null then
		bookingRefStr							:= truckInfo.transportReferenceInternal;
		_manifest.transportReferenceCustomer	:= truckInfo.transportReferenceCustomer;
		_manifest.transportReferenceInternal	:= bookingRefStr;
		_manifest.vehicleBookingSlotType		:= truckInfo.slot;		
	endif;
	
	// Each Goods/Good is a cargo group, with associated cargo items in Items/Item
	foreach good in transport.goods do
		itemised := good.items.size &gt; 0;			//24.Jan.24 navsp1 TFS 61660//TFS 62254 - changed from 1 to 0
		if itemised then								 						//TFS 62254
			//Add prenote TI for each Items/Item
			foreach item in good.items do			
				
				//Create prenote item
				create prenoteTIItem persistent;
				prenoteTIItem.condition		:= good.productCondition;	//16.Jun.2023 navsp1 TFS 57805
				prenoteTIItem.setFromGoodAndItem(transport , good, item, prenoteParent, gateDoc, _xlationOperator, _manifest, _messageMode, itemised);
				
			endforeach;
		else														//TFS 62254
			//Create cargo group and dummy cargo					//TFS 62254
			create prenoteTIItem persistent;						//TFS 62254
			prenoteTIItem.condition		:= good.productCondition;	//TFS 62254
			prenoteTIItem.setFromGoodAndItem(transport , good, null, prenoteParent, gateDoc, _xlationOperator, _manifest, _messageMode, itemised);//TFS 62254
		endif;														//TFS 62254
	endforeach;	
	
	  
epilog
	if not app.myPassport.hasErrors and _manifest.myGateDocument &lt;&gt; null then
		_manifest.myGateDocument.setStatus(CM_EDIFile.EDI_STATUS_LOADED);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_manifest" type="CM_EDIDataTransManifest" usage="input"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_jsonManifestMessage" type="CMIF_JsonManifestEUP"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <Parameter name="_messageMode" type="String"/>
    </JadeMethod>
    <JadeMethod name="processShipMessage" id="0ea72232-a655-411a-b79c-70c8580d4faa">
        <source>processShipMessage(_ediFile : CM_EDIFile input; 
				_jsonManifestMsg : CMIF_JsonManifestEUP; 
				_xlationOperator : CM_Operator; 
				_messageMode : String) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07 Jun 2023	navdap1		Initial creation TFS 
// 03 Jul 2023	jlirs1		TFS 58884 (57807) - Support Delete Update
// 06 Sep 2023	navra1		TFS 60144 - EUP | FR EDI Sender field
// 12 Sep 2023	navdap1		TFS 60453 EUP | FR 53824 - EDI Operations Date Range Filter Sometimes Omits Valid or Includes Invalid EDI Data Items
// 28 Feb 2024  navsp1      Bug 61725: MTN - Transport Manifest Date/Time Issue
// 29 Feb 2024	navhn30		Bug 62674: EUP | FR - 53824 - Transport Manifest - Shipping Line Code For TI Validation Issues
// 16 May 2024  navsp1      TFS Bug 62254: EUP | FR - Transport Manifest - "Itemised" Field is not Working Correctly.
// 25 Mar 2025  navsp1      JIRA-34428 EUP FR | 53824-Wrong Cargo Type for BOL
vars
	vesselInfo			: CMIF_JsonVesselInfoEUP;
	bolNumbers 			: CM_StringArray;
	bols 				: CM_EDIBOLHdrTIArray;
	manifest 			: CM_EDIDataTransManifest;
	header 				: CMIF_JsonHeaderEUP;
	transportJson		: CMIF_JsonTransportFullEUP;	
	carrierParty 		: CMIF_JsonCarrierPartyEUP;
	ediData 			: CM_EDIData;
	vesselAgent 		: CMIF_JsonVesselAgentEUP;
	
	good 				: CMIF_JsonGoodEUP;
	item 				: CMIF_JsonItemEUP;
	shipManifest 		: CM_EDIDataShipManifest;
	onShip, onShipItem 	: CM_EDICargoOnShipTI;
	onShipParent 		: CM_EDICargoTI;
	bol, checkBol 		: CM_EDIBOLHdrTI;
	bolItem, checkItem 	: CM_EDIBOLDtlTI;
	itemised 			: Boolean;
	voyageCode 			: String;
	vesselName 			: String;
	//mode 				: String;
	loadStr, destStr, dischStr : String;
	foundMatch 			: Boolean;
	xlatShippingLine 	: String;
	oldShipManifest 	: CM_EDIDataShipManifest;		// TFS 60453
	cargoTypeId			: Integer;
begin
	transportJson := _jsonManifestMsg.transports.first();
	
	if transportJson = null then		
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No transport structure inside manifest message - returning", LogERROR);
		return;
	endif;
	header := _jsonManifestMsg.header;
	vesselInfo := transportJson.vesselInfo;
	carrierParty := transportJson.carrierParty;
	if vesselInfo &lt;&gt; null then
		voyageCode := vesselInfo.voyageNumber.toUpper();		//navra1 - TFS 59671 - 8th Aug 2023
		vesselName := vesselInfo.vesselName;
		vesselAgent := vesselInfo.vesselAgent;
	endif;	
	create bolNumbers transient;
	create bols transient;

	// get rid of any old ship manifests
	foreach ediData in _ediFile.allEDIData where ediData.isKindOf(CM_EDIDataShipManifest) do
		_ediFile.allEDIData.remove(ediData);
	endforeach;
	
	manifest := _ediFile.ediData.CM_EDIDataTransManifest;
	// TFS 60453 If there's already a ship manifest (because we're reloading/retranslating), delete it
	// TFS 60453 otherwise it (and all its EDI TIs) ends up getting orphaned when the new one is created below
	if manifest.myShipManifest &lt;&gt; null then
		oldShipManifest := manifest.myShipManifest;
		oldShipManifest.erase(NORMAL_ERASE);
	endif;
	// TFS 60453 end
	
	// create and populate a CM_EDIDataShipManifest object
	create shipManifest persistent;
	shipManifest.setForCreateNoProxy(_ediFile.ediConfig, EDIDataType_ShipManifest, EDIFileType_UserDefined, _ediFile, app.myPassport.getUserCode());
	manifest.setShipManifest(shipManifest);
	if transportJson.estimatedDateTimeOfArrival.isValid then
		manifest.estimatedDateTimeOfArrival := transportJson.estimatedDateTimeOfArrival.asUTCTimeStamp.utcToLocalTime;		//TFS 61725
	endif;
	if transportJson.estimatedDateTimeOfDeparture.isValid then
		manifest.estimatedDateTimeOfDeparture := transportJson.estimatedDateTimeOfDeparture.asUTCTimeStamp.utcToLocalTime;	//TFS 61725
	endif;
	
	/*05.Oct.2023 navsp1 TFS 58058 - commented to using the passed-in parameter _messageMode
	if manifest.statusString = CMIF_JsonHeaderEUP.Status_Create then
		mode := CM_EDITrackedItem.EDI_ACTION_ADD;
	elseif manifest.statusString = CMIF_JsonHeaderEUP.Status_Replace then
		mode := CM_EDITrackedItem.EDI_ACTION_UPDATE;
	elseif manifest.statusString = CMIF_JsonHeaderEUP.Status_Cancel then
		mode := CM_EDITrackedItem.EDI_ACTION_DELETE;
	endif;*/

	// get goods / items
	foreach good in transportJson.goods do
		itemised := good.items.size &gt; 0;			//24.Jan.24 navsp1 TFS 61660 	//TFS 62254 - changed from 1 to 0
		create onShip persistent;
		onShip.setMyEDIData(shipManifest);
		onShip.setFromGoodAndItem(good, null, onShipParent, shipManifest, _xlationOperator, manifest, carrierParty, _messageMode, itemised);
		
		// do we have to create a BOL and BOL item?
		if good.bOLNumber &lt;&gt; null then
			if not bolNumbers.includes(good.bOLNumber) then
				create bol persistent;
				bol.messageMode := _messageMode;
				bol.id := good.bOLNumber;
				bol.setMyEDIData(shipManifest);
				voyageCode := good.bOLReference.toUpper();				//navra1 - TFS 59671 - 8th Aug 2023
				if _xlationOperator &lt;&gt; null then
					voyageCode := _xlationOperator.getXlationSystemCode_Voyage(voyageCode, null, null, null, foundMatch);
				endif;
				bol.setVoyageCode(voyageCode);
				if carrierParty &lt;&gt; null then									//17.Aug.2023 navsp1 TFS 59858
					//bol.carrierCode := transportJson.carrierParty.code.toUpper();			//navra1 - TFS 59671 - 8th Aug 2023 //17.Aug.2023 navsp1 TFS 59858
					xlatShippingLine := carrierParty.code.toUpper();				//navra1 - TFS 60144 - 6th Sep 2023
					if _xlationOperator &lt;&gt; null then								//navra1 - TFS 60144 - 6th Sep 2023
						xlatShippingLine := _xlationOperator.getXlationSystemCode(xlatShippingLine, XLATION_TYPE_SHIPPINGLINE_BYOP, foundMatch);
						if not foundMatch then											//29.02.24	navhn30		TFS #53824
							xlatShippingLine := _xlationOperator.getXlationSystemCode(xlatShippingLine, XLATION_TYPE_SHIPPINGLINE, foundMatch);
						endif;
					endif;															//navra1 - TFS 60144 - 6th Sep 2023
					bol.shippingLineCodeForTI := xlatShippingLine;
				endif;
				destStr := good.finalDestinationPort.toUpper();			//navra1 - TFS 59671 - 8th Aug 2023
				dischStr := good.unloadingPort.toUpper();				//navra1 - TFS 59671 - 8th Aug 2023
				loadStr := good.loadingPort.toUpper();					//navra1 - TFS 59671 - 8th Aug 2023
				if _xlationOperator &lt;&gt; null then
					destStr := _xlationOperator.getXlationSystemCode(destStr, XLATION_TYPE_PORT_BYOP, foundMatch);
					dischStr := _xlationOperator.getXlationSystemCode(dischStr, XLATION_TYPE_PORT_BYOP, foundMatch);
					loadStr := _xlationOperator.getXlationSystemCode(loadStr, XLATION_TYPE_PORT_BYOP, foundMatch);
				endif;
				bol.destinationPort := destStr[1:5];
				bol.dischargePort := dischStr[1:5];
				bol.loadPort := loadStr[1:5];
				//bol.operatorCode := good.goodsOwner.code;
				if _xlationOperator &lt;&gt; null then
					bol.operatorCode := _xlationOperator.code;
				else
					bol.operatorCode := shipManifest.operatorCode;
				endif;
				bol.transportMode := TI_TRANSMODE_SHIP_STR;
				
				bolNumbers.add(good.bOLNumber);
				bols.add(bol);
			else
				foreach checkBol in bols where checkBol.id = good.bOLNumber do
					bol := checkBol;
					break;
				endforeach;
			endif;
			
		endif;
		
		//itemised := good.items.size &lt;&gt; 1;
		
		// create items under the cargo group
		foreach item in good.items do
			// create a cargo on ship item
			create onShipItem persistent;
			onShipItem.messageMode := _messageMode;
			onShipParent := onShip;
			onShipItem.setMyEDIData(shipManifest);
			onShipItem.setFromGoodAndItem(good, item, onShipParent, shipManifest, _xlationOperator, manifest, carrierParty, _messageMode, itemised);
		endforeach;
		
		cargoTypeId := onShipItem.cargoType;												//JIRA-34428
		
		//BOL Items
		if good.bOLNumber &lt;&gt; null and bol &lt;&gt; null then										//JIRA-34428
			bol.numItems := bol.numItems + 1;
			onShip.myEDIBOLHeader := bol;
			
			// need to create a bol item?
			bolItem := null;
			foreach checkItem in bol.allDetails 
			where checkItem.cargoType = cargoTypeId											//JIRA-34428
			and checkItem.commodity = null or (checkItem.commodity = onShip.commodity) 
			and checkItem.colour = null or (checkItem.colour = onShip.colour) do
				bolItem := checkItem;
				break;
			endforeach;
			if bolItem = null then
				create bolItem persistent;
				bolItem.messageMode := _messageMode;
				bolItem.setMyEDIData(shipManifest);
				bolItem.id := good.bOLNumber;
			endif;
			bolItem.setCargoType(cargoTypeId);												//JIRA-34428
			bolItem.commodity := onShip.commodity;
			bolItem.colour := onShip.colour;
			bolItem.consignee := onShip.consignee;
			bolItem.consignor := onShip.consignor;
			onShip.myEDIBOLDtl := bolItem;
			bolItem.myHeader := bol;
		endif;
	endforeach;

epilog
	delete bolNumbers;
	delete bols;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_jsonManifestMsg" type="CMIF_JsonManifestEUP"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <Parameter name="_messageMode" type="String"/>
    </JadeMethod>
    <JadeMethod name="writeAlerts" id="5272f2ea-7694-4de1-9981-a9ecf096f84f">
        <source>writeAlerts(_msgText:  String; _email: Boolean; _allExtraData: StringArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 October 2023	navcs2	ChangeRequest 60787: EUP | Add system alert for File Loading fails 

*/

vars

begin
	app.remoteErrorWarningToAlert(_msgText, null, app.myPassport.allErrors, _allExtraData, _email, false);
epilog

end;</source>
        <Parameter name="_msgText" type="String"/>
        <Parameter name="_email" type="Boolean"/>
        <Parameter name="_allExtraData" type="StringArray"/>
    </JadeMethod>
</Class>
