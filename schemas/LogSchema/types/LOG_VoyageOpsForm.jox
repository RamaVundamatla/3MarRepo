    <JadeMethod name="unload" id="7571382c-4bba-4f89-990d-480b2312e7d0">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
//--------------------------------------------------------------
//Created: 14 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.allocateRowClearNotes();
	self.endNotificationForSubscriber(self);
	self.clearProxies();	
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="35bf58c6-e9ba-4ed5-a171-27a1b08a9421">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//--------------------------------------------------------------
//Created: 14 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.handleUserNotification(userInfo.Object, eventType);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
