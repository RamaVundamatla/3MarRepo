        <updating/>
        <source>setAckTIConnectError(_value : Boolean) updating;
/*

Date		Who		Reason
14 May 2015	cnwer1	Initial creation PAR 36103

*/

vars

begin
	self.ackTIConnectError:=_value;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
