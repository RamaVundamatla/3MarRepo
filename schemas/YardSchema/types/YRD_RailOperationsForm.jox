    <JadeMethod name="dragSelectEnd" id="c3522b2b-531c-4d4f-b181-23a8b047474c">
        <updating/>
        <source>dragSelectEnd(_x, _y : Real) updating;

/*

Purpose:			End of selection with dragged rectangle

Parameters:			

Return Value:		


Date		Who		Reason
10 Jun 2009	consw1	Initial creation

*/

vars
	dragSelectFrame : CMUI_GridAreaDrawingFrame;
	frame			: CMUI_GridAreaFrame;
	gridArea		: CMUI_GridArea;
	x1, y1, x2, y2 	: Real;
	
begin
	dragSelectFrame := self.frmDragSelect;

	x1 := _x.min(self.origXPos);
	x2 := _x.max(self.origXPos);
	y1 := _y.min(self.origYPos);
	y2 := _x.max(self.origYPos);

	dragSelectFrame.windowToScreen(x1, y1);
	self.mySDF.myDrawingFrame.screenToWindow(x1, y1);
	dragSelectFrame.windowToScreen(x2, y2);
	self.mySDF.myDrawingFrame.screenToWindow(x2, y2);

	dragSelectFrame.clearGraphics;
	dragSelectFrame.dragMode := DragMode_None;
	dragSelectFrame.visible := false;

	//  Select wagons

	self.mySDF.clearAllSelectedPoints();
	
	foreach gridArea in self.mySDF.allGridAreasByRowColumn do
		frame := gridArea.myGridAreaFrame;
		if frame &lt;&gt; null
		and frame.left &lt; x2
		and frame.top &lt; y2
		and frame.left + frame.width &gt; x1
		and frame.top + frame.height &gt; y1 then
			gridArea.YRD_WagonArea.selectWagon();
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragSelectStart" id="c0604d3d-44e7-43bc-a362-d7a93ff36ec5">
        <updating/>
        <source>dragSelectStart(frame: Frame input; _x, _y : Real) updating;

/*

Purpose:			Start selection with dragged rectangle

Parameters:			

Return Value:		


Date		Who		Reason
10 Jun 2009	consw1	Initial creation

*/

vars
	dragSelectFrame : CMUI_GridAreaDrawingFrame;
	x1, y1 : Real;

begin
	dragSelectFrame := self.frmDragSelect;
	
	dragSelectFrame.move(0,0,self.mySDF.width,self.mySDF.height);
	dragSelectFrame.visible := true;
	dragSelectFrame.zOrder(1);
	
	dragSelectFrame.isDrawDeskTopRectangle := true;
	dragSelectFrame.dragMode := DragMode_Drag;
	dragSelectFrame.dragCursor := self.picYAAreaCur.picture;
	
	x1 := self.origXPos;
	y1 := self.origYPos;

	if frame &lt;&gt; null then
		frame.windowToScreen(x1, y1);
		dragSelectFrame.screenToWindow(x1, y1);
	endif;

	self.origXPos := x1;
	self.origYPos := y1;

epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragWagon" id="f5be6a7e-761c-4593-8e47-4e93fd045df3">
        <updating/>
        <source>dragWagon(_wagon : CM_Wagon; _control : Control input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 Jun 2009	consw1	Initial creation
// 19/08/2022 	navsj20		ChangeRequest 54281: EUP - Wagon Track Planning


*/

vars
	moveController	: CMIF_WagonMoveController;
	picture			: Picture;
	msg : String;

begin
	if global.isValidObject(app.myMoveController) then
		delete app.myMoveController;
	endif;

	app.myMoveController := null;
	
	if global.isValidObject(app.myWagonMoveController) then
		delete app.myWagonMoveController;
	endif;

	create moveController transient;	
	app.myWagonMoveController := moveController;
	
	moveController.isFromTrain := self.myCurrentTrain &lt;&gt; null;
	moveController.setMoveMode(self.getMoveMode); 		//19 Aug 2022	navsj20	TFS 54281

	self.getSelectedWagons( moveController.allWagons, _wagon );

	if moveController.allWagons.isEmpty then
		delete app.myWagonMoveController;
		return;
	endif;
	
	//23 Feb 2021	NDL	TFS 50837
	if not validateRetrospectiveTS(moveController) then
		return;
	endif;
		
	_control.dragMode := DragMode_Drag;
	
	create picture transient;
	self.setPictureDragCursor(picture);
	if picture &lt;&gt; null then
		_control.dragCursor := picture.picture;
	endif;
	
	_control.dragCursor := self.picMvWagon.picture;
	// START 19 Aug 2022	navsj20	TFS 54281
	if self.moveModeForm = PLANNING_MODE then
		_control.dragCursor := self.picDragWagonPln.picture;
	endif;
	// END 19 Aug 2022	navsj20	TFS 54281
	
epilog
	if picture &lt;&gt; null then
		delete picture;
	endif;
end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_control" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawDragSelectFrame" id="6dfaad70-9174-47f2-8d79-050981ac065f">
        <updating/>
        <source>drawDragSelectFrame(_x, _y: Real) updating;

/*

Purpose:			Draw dragged selection rectangle

Parameters:			

Return Value:		


Date		Who		Reason
10 Jun 2009	consw1	Initial creation

*/
vars
	dragSelectFrame : CMUI_GridAreaDrawingFrame;

begin
	dragSelectFrame := self.frmDragSelect;

	dragSelectFrame.clearGraphics;

	dragSelectFrame.drawStyle := Frame.DrawFillStyle_Transparent;
	dragSelectFrame.drawWidth := 1;

	dragSelectFrame.drawFillStyle := Frame.DrawFillStyle_Transparent;
	dragSelectFrame.drawFillColor := Black;

	dragSelectFrame.drawFilledRectangle(self.origXPos.Integer, self.origYPos.Integer, _x, _y, Black);

epilog
	
end;</source>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
