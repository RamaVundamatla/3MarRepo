    <JadeMethod name="clearYAMFilter" id="5c995919-ade2-438f-9ca8-2b6941901f38">
        <source>clearYAMFilter( _rebuildTable : Boolean );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

begin
	
	if self.allColumnFilters &lt;&gt; null and not self.allColumnFilters.isEmpty then
		self.allColumnFilters.replaceAllFiltersForTable( self.tblData, null );
	endif;
	
	if _rebuildTable then
		self.tblData.applyColumnFilter( null );
	endif;

epilog

end;</source>
        <Parameter name="_rebuildTable" type="Boolean"/>
    </JadeMethod>
