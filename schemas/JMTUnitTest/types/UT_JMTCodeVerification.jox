    <JadeMethod name="checkMethodOnClasses" id="3fc8db51-7d8d-4c9a-9d00-d86fc6767035">
        <source>checkMethodOnClasses(_superClassStr : String; _methName : String; _classesToIgnore : StringArray);
/*
Purpose - 	
Who - NAVAB1
Date - 13JAN2025
ADO - JIRA 33506
*/

vars

	schema							: Schema;
	klass, subClass, superClass							: Class;
	meth							: Method;
	
	subClasses, sclasses							: ClassColl;
	methodsDict						: MethodNDict;
	
	initActWithPassport				: StringArray;
	found, sfound : Boolean;
begin

	
	// get the schema
	schema := rootSchema.getSchema("PortSchema");
	self.assertNotNullMsg(schema, "Unable to find schema (PortSchema)");
		
	// get the class
	superClass := schema.getClass(_superClassStr);
	self.assertNotNullMsg(superClass, "Unable to find class (" &amp; _superClassStr &amp; ")");
	
	create initActWithPassport transient;
	
	// get the classes to check
	create sclasses transient;
	create subClasses transient;
	superClass.allLocalSubclasses(subClasses);
	
	// read through the classes
	foreach klass in subClasses do : outerloop
		if klass.abstract then
			continue outerloop;
		endif;
		
		if _classesToIgnore.includes(klass.name) then
			continue;
		endif;
		
		
		found := false;
		// get the methods
		methodsDict := klass.cnGetMethods();
			
		// process the methods
		foreach meth in methodsDict do : innerloop
		
			if meth.name = _methName then
				found := true;
				break innerloop;
			endif;
		endforeach;

		if not found then
			sclasses.clear();
			sfound := false;
			
			klass.allSuperclassesUpTo(sclasses,superClass);
			foreach subClass in sclasses do : sloop
				if subClass &lt;&gt; superClass then
					if subClass = klass then
						continue sloop;
					endif;
		
					if _classesToIgnore.includes(subClass.name) then
						continue;
					endif;
						
					methodsDict := subClass.cnGetMethods();
						
					// process the methods
					foreach meth in methodsDict do : innersloop
					
						if meth.name = _methName then
							sfound := true;
							break sloop;
						endif;
					endforeach;

				else
					break sloop;
				endif;
			endforeach;
			if not sfound then
				initActWithPassport.add(klass.name &amp; "::" &amp; _methName &amp; "() ");
			endif;
		endif;
	endforeach;
	
	// check to see if anything failed.
	if not initActWithPassport.isEmpty() then
		app.writeLog(CrLf &amp; CrLf &amp; "The following method(s) do not have the " &amp; _methName &amp; " method implemented: " &amp; CrLf &amp;
			initActWithPassport.concatenate(CrLf), LogINFO);
	endif;
	
	self.assertEqual(initActWithPassport.size, 0);
	
epilog
	delete sclasses;
	delete subClasses;
	delete initActWithPassport;
end;</source>
        <Parameter name="_superClassStr" type="String"/>
        <Parameter name="_methName" type="String"/>
        <Parameter name="_classesToIgnore" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="findBeginEndLoadMethods" id="6afce727-f602-4593-ab32-daf1d1b419bc">
        <source>findBeginEndLoadMethods(_class : Class; _failingMethods : MethodColl io);

/*

Purpose:			Find methods with cmsBeginLoad / cmsEndLoad / beginLoad / endLoad in them
					Check that epilog has cmsEndLoad / endLoad

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2011	cnwmh5	Initial creation

*/

constants
	//MaxTokens		: Integer = 4000;
	CheckReturn		: Boolean = true;
	SortRefs		: Boolean = true;

vars
	meth			: Method;
	methodsDict		: MethodNDict;
	dd				: DynaDictionary;
	iter			: Iterator;
	
	cmsBeginEndLoadVarArray	: StringArray;
	methodsToIgnore	: StringArray;
	
	methodSource	: String;
	tokensSize		: Integer;
	tokens			: HugeStringArray;
	token,
	arrayToken		: String;
	inEpilog		: Boolean;
		
	cmsBeginLoadStr,
	cmsEndLoadEpilogStr,
	cmsEndLoadStr, 
 	cmsBeginEndLoadVars : String;
	
	beginLoadStr,
	endLoadEpilogStr,
	endLoadStr		: String;
	
	str				: String;
	
	posStart, 
	posEnd			: Integer;
	
	isOK			: Boolean;

begin

	// class is null just return
	if _class = null then
		return;
	endif;	
	
	create methodsToIgnore transient;
	methodsToIgnore.add("JmtTransactionGenerator::zAllocateRTGCrane");
	methodsToIgnore.add("Ship::zAllocatePortainerCrane");
	methodsToIgnore.add("WS_HoldDefn::createProxy");
	methodsToIgnore.add("WS_VesselDefn::createProxy");
	methodsToIgnore.add("JadeScript::eprTestUpdateHold");
	methodsToIgnore.add("YRD_TrainWagonForm::setWagonPxy");
	
	// Get all the references to the named class
	methodsDict := _class.cnGetMethods();
	iter:= methodsDict.createIterator;

	create cmsBeginEndLoadVarArray transient;	
	
	while iter.next(meth) do
		
			// don't want my search methods
			if meth.name.cnContains("eginLoad") or meth.name.cnContains("ndLoad") then
				continue;
			endif;
	
			// don't need to check the following methods
			if methodsToIgnore.includes(meth.schemaType.name &amp; "::" &amp; meth.name) then				// 19/04/2013 cnwmh5
				continue;
			endif;	
	
			methodSource := self.removeCommentsFromSource(meth.getSource());
			methodSource.replaceChar(Cr, " ");
			methodSource.replaceChar(Lf, " ");
			
			if not methodSource.cnContains("beginLoad") then
				continue;
			endif;

			// Break method source into tokens
			delete tokens;
			tokens := methodSource.getHugeTokens;
			tokensSize := tokens.size;
		
			// Add 4 tokens at the end to ensure we process them all
			tokens.add(null);

			inEpilog := false;

			token := null;
			
			cmsBeginLoadStr := null;
			cmsEndLoadEpilogStr := null;
			cmsEndLoadStr := null;
			isOK := false;
			cmsBeginEndLoadVars := null;
			
			beginLoadStr := null;
			endLoadStr := null;
			endLoadEpilogStr := null;
			
			cmsBeginEndLoadVarArray.clear();

			foreach arrayToken in tokens do
				token := arrayToken;

				if token.cnContains("cmsBeginLoad") then
					cmsBeginLoadStr := token;
					posStart := token.pos("(", 1) + 1;
					posEnd := token.pos(")", 1);
					if posEnd &gt; 0 then
						str := token[posStart:posEnd-posStart];
					else
						str := token;
					endif;
					if not cmsBeginEndLoadVarArray.includes(str) then
						cmsBeginEndLoadVarArray.add(str);
					endif;
				elseif token.cnContains('cmsEndLoad') then
					if inEpilog then
						cmsEndLoadEpilogStr := token;
					else
						cmsEndLoadStr := token;
					endif;
					posStart := token.pos("(", 1) + 1;
					posEnd := token.pos(")", 1);
					if posEnd &gt; 0 then
						str := token[posStart:posEnd-posStart];
					else
						str := token; 
					endif;
					if not cmsBeginEndLoadVarArray.includes(str) then
						cmsBeginEndLoadVarArray.add(str);
					endif;
				elseif token = "beginLoad" then
					beginLoadStr := token;
				elseif token = "endLoad" then
					if inEpilog then
						endLoadEpilogStr := token;
					else
						endLoadStr := token;
					endif;
				elseif token = "epilog" then
					inEpilog := true;
				endif;
			
			endforeach;
		
			// no cmsBeginLoad or beginLoad so next method
			if cmsBeginLoadStr = null and beginLoadStr = null then
				continue;
			endif;
			
			if cmsBeginLoadStr &lt;&gt; null then
				if not cmsBeginEndLoadVarArray.isEmpty() then
					foreach str in cmsBeginEndLoadVarArray do
						cmsBeginEndLoadVars := cmsBeginEndLoadVars &amp; str &amp; ",";
					endforeach;
					cmsBeginEndLoadVars := cmsBeginEndLoadVars[1:cmsBeginEndLoadVars.length-1];
				endif;
			endif;
	
			if cmsEndLoadEpilogStr = null and endLoadEpilogStr = null then
				_failingMethods.add(meth);
			endif;
		
			delete tokens;

	endwhile;

epilog
	
	delete cmsBeginEndLoadVarArray;
	delete iter;
	delete tokens;
	delete dd;
	delete methodsToIgnore;
	
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_failingMethods" type="MethodColl" usage="io"/>
    </JadeMethod>
    <JadeMethod name="iCheckTrxInitialise1stLineCode" id="f98172e1-6080-480a-96ee-df5a84ba98b3">
        <source>iCheckTrxInitialise1stLineCode();

/*

Purpose:		Check for trxs methods have initialise as the first line of code	

Date			Who		Reason
11/10/2012		cnwmh5	Initial creation

*/

vars

	schema							: Schema;
	klass							: Class;
	meth							: Method;
	
	classes							: ClassColl;
	methodsDict						: MethodNDict;
	methodsToIgnore					: StringArray;
	
	initActWithPassport				: StringArray;
	
	beginFound						: Boolean;
	lineCount						: Integer;
	linePos							: Integer;
	posSlash						: Integer;
	line 							: String;
	initialiseFound					: Boolean;
	returnFound						: Boolean;
	epilogFound						: Boolean;

begin

	// get the schema
	schema := rootSchema.getSchema("PortSchema");
	self.assertNotNullMsg(schema, "Unable to find schema (PortSchema)");
		
	// get the class
	klass := schema.getClass("CM_TrxControlAgent");
	self.assertNotNullMsg(klass, "Unable to find class (CM_TrxControlAgent)");
	
	create initActWithPassport transient;
	create methodsToIgnore transient;
	methodsToIgnore.add("trxImportCustomsAgent");
	methodsToIgnore.add("trxImportDebtorNode");
	methodsToIgnore.add("trxImportServiceObject");
	methodsToIgnore.add("trxImportShippingAgent");
	methodsToIgnore.add("trxLoadErrMsgsGlbConstsExtUser");
	methodsToIgnore.add("trxLoadErrMsgsFromGlbConsts");
	methodsToIgnore.add("trxMoveTrackedItemAssignToJobU");
	methodsToIgnore.add("trxSetupCams");
	methodsToIgnore.add("trxUpdateMovePlan");
	methodsToIgnore.add("trxUpdateSlotRequestAttribute");
	methodsToIgnore.add("trxUpdateSlotRequestLoadCC");
	methodsToIgnore.add("trxMoveTIsAUTOAssignToJob");
	methodsToIgnore.add("trxUpdateYALastBlock");
	methodsToIgnore.add("trxUpdateYAGroupLastBlock");
	methodsToIgnore.add("trxCreateProformaInvoiceLines");
	
	// get the classes to check
	create classes transient;
	klass.allLocalSubclasses(classes);
	
	// read through the classes
	foreach klass in classes do
		
		// get the methods
		methodsDict := klass.cnGetMethods();
			
		// process the methods
		foreach meth in methodsDict do
		
			// don't care about it if the method name doesn't start with trx
			if meth.name[1:3] &lt;&gt; "trx" then
				continue;
			endif;
		
			// check to see if there are any methods to ignore
			if methodsToIgnore.includes(meth.name) then
				continue;
			endif;		
		
			beginFound := false;
			initialiseFound := false;
			returnFound := false;
			epilogFound := false;
			lineCount := 0;
			linePos := 1;
			while linePos &gt; 0 do
				line := meth.getSource.cnEcGetNextLine(linePos);
				if not beginFound then
					// haven't found the begin code yet so check to see if we have and update
					// variables accordingly
					if line[1:5] = "begin" then
						beginFound := true;
					endif;
					continue;
				else
					// found begin code so now start checking what the first line of code is
					// don't care about blank lines
					line.cnReplaceString(Tab, "");
					if line.trimBlanks = null then
						continue;
					endif;
					// if we hit the epilog then don't care either
					if line.cnContains("epilog") then
						linePos := -1;
						epilogFound := true;
						continue;
					endif;
					// don't care if its this comment
					if line.cnContains("// Always initialize the activity first") then
						continue;
					endif;
					// check to see if there is any code before the comment
					posSlash := line.pos("//", 1);
					if posSlash &gt; 0 and line[1:posSlash-1] = null then
						continue;
					endif;
					// check to see if the line contains initialiseActivityWithPassport(_passport, method)
					line.cnReplaceString(" ", "");
					if line.cnContains("initialiseActivityWithPassport(") or line.cnContains(".initialiseTransaction") then
						lineCount := lineCount + 1;
						linePos := -1;
						initialiseFound := true;
						continue;
					endif;
					// allowable 
					if line.cnContains("thePassport:=_passport") or line.cnContains("theRoot:=app.myRoot") or line.cnContains("passport:=_passport") or 
							line.cnContains("passport:=app.myPassport") or line.cnContains("_passport:=app.createPassport()") then
						continue;
					endif;
					if line.cnContains("return") and not initialiseFound then
						returnFound := true;
						linePos := -1;
						continue;
					endif;
					
					lineCount := lineCount + 1;
					
				endif;
			endwhile;
			
			if epilogFound then
				continue;
			endif;
				
			// check to see what lineCount is.  If &gt; 1 then put into array
			if lineCount = 1 then
				continue;
			endif;
			initActWithPassport.add(klass.name &amp; " :: " &amp; meth.name);
			
		endforeach;
		
	endforeach;
	
	// check to see if anything failed.
	if not initActWithPassport.isEmpty() then
		app.writeLog(CrLf &amp; CrLf &amp; "The following trx method(s) do not have self.initialiseActivityWithPassport(_passport, method); as the first line of code: " &amp; CrLf &amp;
			initActWithPassport.concatenate(CrLf), LogINFO);
	endif;
	
	self.assertEqual(initActWithPassport.size, 0);
	
epilog
	
	delete classes;
	delete initActWithPassport;
	delete methodsToIgnore;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="multiExcHandler" id="4910467b-e526-4cef-a97f-1186fc4538de">
        <source>multiExcHandler(exObj : Exception):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2012	cnwndl1	Initial creation	Par 30366

*/

vars

begin

	if exObj.isKindOf(CM_Exception) then
		if exObj.CM_Exception.isWarning then
			app.myPassport.addWarningFull(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, exObj.CM_Exception.mySubject);
			return Ex_Continue;
		elseif exObj.CM_Exception.continuable then
			app.myPassport.addErrorFull(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, exObj.CM_Exception);
			return Ex_Continue;
		endif;
	endif;
	
	return Ex_Pass_Back;

epilog

end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tCheckAppIsAttributesReset" id="137af96d-f4aa-4b5a-8fb2-a144dcc8b405">
        <source>tCheckAppIsAttributesReset();

/*

Purpose:		Check app.is props are set correctly

Date			Who		Reason
18/11/2014		cnwmh5	Initial creation

*/

vars

	klass						: Class;
	prop						: Property;
	meth						: Method;
	
	propertyDict				: PropertyNDict;
	methodSet					: MethodSet;
	propertyToIgnore			: StringArray512;
	methodsToIgnore				: StringArray512;
	attribArray					: StringArray512;
	errorArray					: StringArray512;
	tempErrorArray				: StringArray512;
	
	methodSource				: String;
	pos							: Integer;
	posEpilog					: Integer;
	stringToSearchFor			: String;
	checkingEpilog				: Boolean;
	tempStr						: String;
	tempPos						: Integer;
	trueCount					: Integer;
	classMethodName				: String;
	trueFound					: Boolean;
	
begin

	klass := currentSchema.getClass("JMTUnitTest");
	self.assertNotNull(klass);
		
	create propertyDict transient;
	klass.getPropertiesAllSuperclass(propertyDict);
	
	create propertyToIgnore transient;
	propertyToIgnore.add('isCashOnlyEnabled');
	propertyToIgnore.add("isSubTerminalsLicensed");
	
	create methodsToIgnore transient;
	methodsToIgnore.add("JMTUnitTest::isUnitTestGarbageCollect");
	methodsToIgnore.add("UT_UnitTest::unitTestBeforeClass");
	
	create attribArray transient;
	create errorArray transient;
	create tempErrorArray transient;
	
	create methodSet transient;
	foreach prop in propertyDict where prop.name[1:2] = "is" do
		
		if propertyToIgnore.includes(prop.name) then
			continue;
		endif;
		
		methodSet.clear();
		prop.getMethodRefs(methodSet);
		foreach meth in methodSet do
		
			classMethodName := meth.schemaType.name &amp; "::" &amp; meth.name;
		
			if methodsToIgnore.includes(classMethodName) then
				continue;
			endif;		
		
			if meth.getSchema().name &lt;&gt; currentSchema.name then
				continue;
			endif;
			
			methodSource := self.removeCommentsFromSource(meth.getSource());
			methodSource.cnReplaceString(Tab, " ");
			methodSource.cnReplaceString(Cr, "~");
			methodSource.cnReplaceString(Lf, "~");
			
			stringToSearchFor := "." &amp; prop.name;
			
			if not methodSource.cnContains(stringToSearchFor) then
				continue;
			endif;
			
			pos := 1;
			posEpilog := 1;
			posEpilog := methodSource.pos("epilog", posEpilog);
			attribArray.clear();
			tempErrorArray.clear();
			checkingEpilog := false;
			tempPos := 1;
			trueFound := false;
			
			while true do
			
				pos := methodSource.pos(stringToSearchFor, pos);
				if pos = 0 then
					break;
				endif;
			
				if not checkingEpilog and pos &gt; posEpilog then
					checkingEpilog := not checkingEpilog;
				endif;
				
				// need to check what is going on 
				tempPos := pos + stringToSearchFor.length;
				tempStr := methodSource.scanUntil(";", tempPos).trimBlanks.trimBlanks();
				pos := tempPos;
				
				if tempStr[1:4] = "then" then
					// don't do anything
					continue;
				elseif tempStr[1:2] = ":=" then
					tempPos := 3;
					tempStr := tempStr.scanUntil(";", tempPos).trimBlanks();
					if tempStr = 'true' then
						trueCount := 1;
						trueFound := true;
					elseif tempStr = 'false' then
						if checkingEpilog then
							trueCount := trueCount - 1;
						endif;
					else
						if not checkingEpilog then
							attribArray.add(tempStr);
						else
							if not attribArray.includes(tempStr) then
								tempErrorArray.add(classMethodName &amp; " doesn't reset " &amp; tempStr &amp; " for property " &amp; prop.name);
							else	
								trueCount := 0;
							endif;
						endif;	
					endif;
					continue;
				else
					tempPos := methodSource.reversePosIndex("~", pos);
					tempPos := tempPos + 1;
					tempStr := methodSource.scanUntil(":", tempPos).trimBlanks();
					if not checkingEpilog then
						attribArray.add(tempStr);
						continue;
					elseif not attribArray.includes(tempStr) then
						tempErrorArray.add(classMethodName &amp; " doesn't reset " &amp; tempStr &amp; " for property " &amp; prop.name);
						continue;
					endif;	
				endif;
				
			endwhile;
			
			if attribArray.isEmpty() and trueFound and trueCount &gt; 0 then
				tempErrorArray.add(classMethodName &amp; " doesn't reset property " &amp; prop.name);	
			elseif not attribArray.isEmpty() and tempErrorArray.isEmpty() and trueFound and trueCount &gt; 0 then
				tempErrorArray.add(classMethodName &amp; " doesn't reset property " &amp; prop.name);	
			endif;	
			tempErrorArray.copy(errorArray);
			
		endforeach;
		
	endforeach;
	
	if not errorArray.isEmpty then
		app.writeLog("-------------------------------------------------------------" &amp; CrLf &amp;
			"The following methods don't reset an property correctly:", LogINFO);
	endif;
	foreach tempStr in errorArray do
		app.writeLog(tempStr, LogINFO);
	endforeach;
	
	if not errorArray.isEmpty() then
		app.writeLog("Count: " &amp; errorArray.size.String, LogINFO);
		app.writeLog("-------------------------------------------------------------", LogINFO);
	endif;
	
	self.assertEqual(errorArray.size, 0);
	
epilog

	delete propertyDict;
	delete methodSet;

	delete propertyToIgnore;
	delete methodsToIgnore;
	
	delete attribArray;
	delete errorArray;
	delete tempErrorArray;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Fails&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tCheckDeprecatedWSClasses" id="2440860d-4b62-47a7-a12a-9a73d0024f25">
        <source>tCheckDeprecatedWSClasses();
/*

Purpose:			Make sure no-one changes the JMTHandheldService or JMTPortSystemsAPIService classes
					And instead uses the MasterTerminalAPI or MTNInternalAPI instead.

Parameters:			

Return Value:		

Date			Who		Reason
07 April 2022	navmd1	Initial creation TFS 52829 REST Refactor

*/

constants
	// Change this timestamp to the most recent 'OK' check in the event that methods are recompiled for some reason
	CheckFromTS	: TimeStamp = "08/04/2025 13:56:00".TimeStamp; //navpw1
	
	HHService	: String = "JMTHandheldService";
	PSService	: String = "JMTPortSystemsAPIService";
vars
	scm			: Schema;
	cls1,
	cls2		: Class;
	mth			: Method;
	
	allErrors	: StringArray;	// Whoo for maxlength string arrays now
	msg,
	err			: String;
begin
	scm := rootSchema.getSchema(WebServicesSchemaName);
	cls1 := scm.getClass(HHService);
	cls2 := scm.getClass(PSService);
	
	create allErrors transient;
	
	// Check for class changes
	if cls1.cnGetModifiedTimeStamp &gt; CheckFromTS then
		allErrors.add("CLass " &amp; cls1.name &amp; " has been modified by " &amp; cls1.getModifiedBy &amp; " on " &amp; cls1.cnGetModifiedTimeStamp.shortCurrentLocaleFormatSecs);
	endif;
	if cls2.cnGetModifiedTimeStamp &gt; CheckFromTS then
		allErrors.add("Class " &amp; cls2.name &amp; " has been modified by " &amp; cls2.getModifiedBy &amp; " on " &amp; cls1.cnGetModifiedTimeStamp.shortCurrentLocaleFormatSecs);
	endif;
	
	// Check for method changes
	foreach mth in cls1.cnGetMethods do
		if mth.cnGetModifiedTimeStamp &gt; CheckFromTS then
			allErrors.add(mth.qualifiedName &amp; " has been modified by " &amp; mth.getModifiedBy &amp; " on " &amp; mth.cnGetModifiedTimeStamp.shortCurrentLocaleFormatSecs);
		endif;
	endforeach;
	foreach mth in cls2.cnGetMethods do
		if mth.cnGetModifiedTimeStamp &gt; CheckFromTS then
			allErrors.add(mth.qualifiedName &amp; " has been modified by " &amp; mth.getModifiedBy &amp; " on " &amp; mth.cnGetModifiedTimeStamp.shortCurrentLocaleFormatSecs);
		endif;
	endforeach;
	if allErrors.size &gt; 1 then
		msg := "Deprecated classes changed, check the following for errors:" &amp; CrLf;	// Add some more white space
		foreach err in allErrors do
			msg &amp;= CrLf &amp; err;
		endforeach;
		self.assertTrueMsg(false, msg);
	endif;
epilog
	delete allErrors;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckDisableAllYAReset" id="8c5270c8-a9ad-4465-bed2-38d6e45e3210">
        <source>tCheckDisableAllYAReset();

/*

Purpose:		Check to see that disableAllYA is reset

Date			Who		Reason
30/01/2015		cnwmh5	Initial creation
*/

vars

	klass						: Class;
	meth						: Method;

	errorArray					: StringArray512;
	methSet						: MethodSet;
	methodsToIgnore				: StringArray;
	
	methodSource				: String;
	pos 						: Integer;
	line						: String;
	attrib						: String;
	testForString				: String;
	setCount					: Integer;
	falseFound					: Boolean;
	
begin

	klass := currentSchema.getClass("UT_DSL");
	self.assertNotNull(klass);
	
	meth := klass.getMethodInHTree("disableAllYA");
	self.assertNotNull(meth);
	
	testForString := meth.name &amp; "(";
	
	create methSet transient;
	meth.getMethodRefs(methSet);
	
	create errorArray transient;
	create methodsToIgnore transient;
	methodsToIgnore.add("UT_Scripts::uDisableAllYardAllocations");
	
	foreach meth in methSet do
	
		if methodsToIgnore.includes(meth.schemaType.name &amp; "::" &amp; meth.name) then
			continue;
		endif;
		
		methodSource := self.removeCommentsFromSource(meth.getSource());
		methodSource.cnReplaceString(Tab, "");
		methodSource.cnReplaceString(Cr, "");
		methodSource.cnReplaceString(Lf, "");
		methodSource.cnReplaceString(" ", "");
		
		pos := 1;
		falseFound := false;
		setCount := 0;
		
		while true do  : noMoreToFind 
		
			pos := methodSource.pos(testForString, pos);
			if pos = 0 then
				break noMoreToFind;
			endif;
			
			if (pos + testForString.length) &gt; methodSource.length then
				break noMoreToFind;
			endif;
			
			pos := pos + testForString.length;
			attrib := methodSource.scanUntil(")", pos).trimBlanks();
			if attrib.Boolean = true then
				setCount := setCount + 1;
			else	
				setCount := setCount - 1;
				falseFound := not attrib.Boolean;
			endif;
			
		endwhile;
		
		if not falseFound then
			errorArray.add(meth.schemaType.name &amp; "::" &amp; meth.name);
		endif;
		
	endforeach;
		
	if not errorArray.isEmpty then
		app.writeLog("-------------------------------------------------------------" &amp; CrLf &amp;
			"The following methods don't reset " &amp; testForString &amp; ":", LogINFO);
		foreach line in errorArray do
			app.writeLog(line, LogINFO);
		endforeach;
		app.writeLog("Count: " &amp; errorArray.size.String, LogINFO);
		app.writeLog("-------------------------------------------------------------", LogINFO);
	endif;
	
	self.assertEqual(errorArray.size, 0);
	
epilog

	delete methSet;
	delete errorArray;
	delete methodsToIgnore;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCheckEDIBundleSubclasses" id="1b64da1d-5002-411c-b33c-922b0b618312">
        <source>tCheckEDIBundleSubclasses();
/*
Purpose:	

Date		Who		Reason
13 January 2025	navab1	JIRA 33506
*/

vars
	classesToIgnore : StringArray;
begin
	create classesToIgnore transient;
	// some sub classes are not used
	classesToIgnore.add("CM_EDIFileTypeXLS");
	
	self.checkMethodOnClasses("CM_EDIFileType", "create", classesToIgnore);
	self.checkMethodOnClasses("CM_EDIFileType", "getEDIBundle", classesToIgnore);
	
	classesToIgnore.clear;
	classesToIgnore.add("CM_CamMaerskDesc");
	classesToIgnore.add("CM_CamTasmanOrientDesc");
	classesToIgnore.add("CM_CamTOLDepotRelease");
	classesToIgnore.add("CM_CamTOLDepotReturn");
	
	self.checkMethodOnClasses("CM_CamProtocolDesc", "create", classesToIgnore);
	self.checkMethodOnClasses("CM_CamProtocolDesc", "getEDIBundle", classesToIgnore);
epilog
	delete classesToIgnore;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckEDIBundleValue" id="1bd66165-4eaf-40d7-9f88-2d2b27bac738">
        <source>tCheckEDIBundleValue();
/*
Purpose:	

Date		Who		Reason
14 January 2025	navab1	JIRA 33506
*/

vars
	agent : CM_EDIFileTypeAgent;
	camsType : CM_CamProtocolDesc;
	ediType : CM_EDIFileType;
	ediBundle : Integer;
	className : String;
begin
	create agent transient;
	
	agent.init();

	foreach ediType in agent.allEDIFileTypes do
		ediBundle:= ediType.getEDIBundle();
		className := ediType.getClassForObject(ediType).name;
		
		self.assertTrueMsg(ediBundle &lt;&gt; CM_EDIFileType.EDI_Bundle_UNKNOWN,"EDI File Type " &amp; className &amp; " - '" &amp;  ediType.name &amp; "' does not have a correct getEDIBundle() method. Cannot return value CM_EDIFileType.EDI_Bundle_UNKNOWN");
		self.assertTrueMsg(ediBundle.isOneOf(CM_EDIFileType.EDI_Bundle_BASE, 
															CM_EDIFileType.EDI_Bundle_CUSTOM, 
															CM_EDIFileType.EDI_Bundle_X12, 
															CM_EDIFileType.EDI_Bundle_EDIFACT,
															CM_EDIFileType.EDI_Bundle_SUZANO
															),"EDI File Type " &amp; className &amp; " - '" &amp; ediType.name &amp; "' does not have a correct getEDIBundle() method. Must return a valid bundle type:" &amp; CrLf &amp; 
															"CM_EDIFileType.EDI_Bundle_BASE, CM_EDIFileType.EDI_Bundle_CUSTOM, CM_EDIFileType.EDI_Bundle_EDIFACT,	CM_EDIFileType.EDI_Bundle_SUZANO");
	endforeach;
	
	
	foreach camsType in agent.allCAMProtocolDescs do
		ediBundle:= camsType.getEDIBundle();
		className := camsType.getClassForObject(camsType).name;

		self.assertTrueMsg(ediBundle &lt;&gt; CM_EDIFileType.EDI_Bundle_UNKNOWN,"CAMS Protocol " &amp; className &amp; " - '" &amp;  camsType.name &amp; "' does not have a correct getEDIBundle() method.. Cannot return value CM_EDIFileType.EDI_Bundle_UNKNOWN");
		self.assertTrueMsg(ediBundle.isOneOf(CM_EDIFileType.EDI_Bundle_BASE, 
															CM_EDIFileType.EDI_Bundle_CUSTOM, 
															CM_EDIFileType.EDI_Bundle_X12, 
															CM_EDIFileType.EDI_Bundle_EDIFACT,
															CM_EDIFileType.EDI_Bundle_SUZANO
															),"CAMS Protocol " &amp; className &amp; " - '"  &amp; ediType.name &amp; "' does not have a correct getEDIBundle() method. Must return a valid bundle type:" &amp; CrLf &amp; 
															"CM_EDIFileType.EDI_Bundle_BASE, CM_EDIFileType.EDI_Bundle_CUSTOM, CM_EDIFileType.EDI_Bundle_EDIFACT,	CM_EDIFileType.EDI_Bundle_SUZANO");
	endforeach;
epilog
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckExpectTrxError" id="d033d491-688c-45a5-aa6e-4885f2c5611a">
        <source>tCheckExpectTrxError();

/*

Purpose:		Check the code for expectTrxError method and see that 
				constants are used not the constants number	

Date			Who		Reason
05/04/2012		cnwmh5	Initial creation

*/

vars

	klass						: Class;
	meth						: Method;
	constant					: Constant;
	
	methodsSet					: MethodSet;
	methodsToIgnoreArray		: StringArray;
	
	methodSource				: String;
	posText						: Integer;
	tmpStr						: String;
	count						: Integer;
	errorString					: String;

begin

	// get the class that has the method expectTrxError
	klass := rootSchema.getSchema("JMTUnitTest").getClass("UT_UnitTest");
	self.assertNotNull(klass);
	
	meth := klass.getMethodInHTree("expectTrxError");
	self.assertNotNull(meth);
	
	// setup the methods to ignore array
	create methodsToIgnoreArray transient;
	methodsToIgnoreArray.add("UT_DSL::testMachineAcceptTaskWithError");
	methodsToIgnoreArray.add("UT_DSL::testMoveContainerToLocWithErr");
	
	create methodsSet transient;
	meth.getMethodRefs(methodsSet);
	
	foreach meth in methodsSet do
	
		// check to see if the method is in the list to ignore
		if methodsToIgnoreArray.includes(meth.getSchemaType().name &amp; '::' &amp; meth.name) then
			continue;
		endif;
	
		methodSource := self.removeCommentsFromSource(meth.getSource());
		
		posText := 1;
		count := 0;
		
		while posText &gt; 0 do
		
			// find the position of expectTrxError(
			posText := methodSource.pos("expectTrxError(", posText);
			if posText = 0 then
				break;
			endif;
			
			// get the constant string
			posText := posText + "expectTrxError(".length;
			tmpStr := methodSource.scanUntil(")", posText);
			
			// check the constant exists
			constant := rootSchema.getSchema(PortSchemaName).getConstant(tmpStr);
			if constant = null then
				count := count + 1;
			endif;
		
		endwhile;
		
		// if we have found an expectTrxError without a constant then write it our
		if count &gt; 0 then
			errorString := klass.name &amp; '::' &amp; meth.name &amp; ' expectTrxError does not contain a constant name';
			if count &gt; 1 then
				errorString := errorString &amp; " (" &amp; count.String &amp; " found)" &amp; CrLf;
			endif;
			app.writeLog(errorString, LogINFO);
		endif;
	
	endforeach;
	
	self.assertNull(errorString);

epilog

	delete methodsSet;
	delete methodsToIgnoreArray;

end;
</source>
    </JadeMethod>
    <JadeMethod name="tCheckForFollowingCodingNoNos" id="aaf107f1-1c0a-45e9-aae4-8c78515783fc">
        <source>tCheckForFollowingCodingNoNos();

/*

Purpose:		Check for the following coding no nos
				.addHours
				opts.clear
				app.myRoot.allTerminals.last
				
				
				found : Contains what has been found.  
					found[1] = addHours
					found[2] = opts.clear
					found[3] = app
					found[4] = .allSubTerminals.first
					found[5] = .allSubTerminals.last

Date			Who		Reason
30/03/2012		cnwmh5	Initial creation 

*/
constants
	Alpha				: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz";
vars

	klass				: Class;
	meth				: Method;
	localVar 			: JadeLocalVar;
	value				: Any;
	
	classes				: ClassColl;
	methodsDict			: MethodNDict;
	
	iter				: Iterator;
	
	itemsFoundArray		: StringArray512;
	itemsToCheckArray	: StringArray512;
	methodsToIgnore		: StringArray512;
	
	str					: String;
	msgStr				: String;
	methodSource		: String;
	found				: String[10];
	index				: Integer;
	pos					: Integer;
	posCrLf				: Integer;
	attrib				: String;
	tempStr				: String;

begin

	// create the array and details of what we need to check for
	create itemsToCheckArray transient;
	itemsToCheckArray.add(".addHours");
	itemsToCheckArray.add("opts.clear");
	itemsToCheckArray.add("app.myRoot.allTerminals.last");
	itemsToCheckArray.add(".allSubTerminals.first");								// 29/04/2014 cnwmh5	
	itemsToCheckArray.add(".allSubTerminals.last");									// 29/04/2014 cnwmh5	
	
	
	// don't add tCheckForFolloingCodingNoNos to the collection only add methods which need opts.clear
	create methodsToIgnore transient;
	methodsToIgnore.add("CLEAR::UT_DSL::addContainers");
	methodsToIgnore.add("ALLSUBTERMINALS::UT_Gate::tReceiveMTWithSTYA");
	methodsToIgnore.add("ALLSUBTERMINALS::UT_DSL::setSubTerminalAreaDefined");	
	methodsToIgnore.add("ALLSUBTERMINALS::UT_Terminal::tSubTerminalAreaDefs");	
	methodsToIgnore.add("ALLSUBTERMINALS::UT_DSL::deleteTrackedItem");	
	methodsToIgnore.add("ALLSUBTERMINALS::UT_DSL::deleteTrackedItemChildren");
	methodsToIgnore.add("ALLSUBTERMINALS::UT_Scripts::uTFS37377");
	methodsToIgnore.add("ALLSUBTERMINALS::UT_Train::uTrainReleasePerfSTW");
	methodsToIgnore.add("ALLSUBTERMINALS::UT_Train::tTrainReleasePerfSTW");
	
	// get the class
	klass := currentSchema.getClass("UT_DSL");
	assertNotNull(klass);
	
	// get all the subclasses
	create classes transient;
	klass.allLocalSubclasses(classes);
	classes.add(klass);
	
	create itemsFoundArray transient;
	
	// read through all the class methods source code to see if any of the no nos are found
	foreach klass in classes do
		
		methodsDict := klass.cnGetMethods();
		delete iter;
		iter := methodsDict.createIterator;
		while iter.next(meth) do
		
			if meth.name = "tCheckForFollowingCodingNoNos" then
				continue;
			endif;
					
			found := 0.String.padLeadingZeros(10);
		
			methodSource := self.removeCommentsFromSource(meth.getSource());
			methodSource.replaceChar(Cr, " ");
			methodSource.replaceChar(Lf, " ");
			
			foreach index in 1 to itemsToCheckArray.size do
				if methodSource.cnContains(itemsToCheckArray[index]) then
					if index = 1 then
						attrib := null;
						pos := methodSource.pos(itemsToCheckArray[index], 1);
						if pos &gt; 0 then
							posCrLf := methodSource.pos(";", pos);
							if posCrLf = 0 then
								continue;
							endif;
							posCrLf := methodSource.pos(";", posCrLf+1);
							if posCrLf = 0 then
								continue;
							endif;
							// check to see if .setTime appears in the next line
							tempStr := methodSource[pos:posCrLf - pos];
							if not tempStr.cnContains('.setTime') then
								continue;
							endif;
							// ok found .setTime in the next line so need to sse if everything is ok.
							while pos &gt; 0 do
								pos := pos - 1;
								if not Alpha.cnContains(methodSource[pos:1]) then
									break;
								endif;
								attrib := methodSource[pos:1] &amp; attrib;
							endwhile;
							if attrib &lt;&gt; null then
								foreach localVar in meth.JadeMethod.cnGetLocalVars do
									if localVar.name = attrib then
										value := localVar.type;
										if value.getName() &lt;&gt; TimeStamp.getName() then
											found[index:1] := true.Integer.String;
										endif;
									endif;
								endforeach;
							endif;
						endif;					
					else
						found[index:1] := true.Integer.String;
					endif;					
				endif;
			endforeach;
			
			foreach index in 1 to found.length do
				if found[index:1].Integer = true.Integer then
					if index = 1 then
						itemsFoundArray.add(klass.name &amp; "::" &amp; meth.name &amp; " is using .addHours on a Time rather than .addHours on a TimeStamp");
					elseif index = 2 and not methodsToIgnore.includes("CLEAR::" &amp; klass.name &amp; "::" &amp; meth.name) then
						itemsFoundArray.add(klass.name &amp; "::" &amp; meth.name &amp; " is using opts.clear rather than opts.purge");
					elseif index = 3 then
						itemsFoundArray.add(klass.name &amp; '::' &amp; meth.name &amp; " is using app.myRoot.allTerminals.last");
					elseif (index = 4 or index = 5) and not methodsToIgnore.includes("ALLSUBTERMINALS::" &amp; meth.qualifiedName)	then						// 29/04/2014 cnwmh5
						itemsFoundArray.add(klass.name &amp; '::' &amp; meth.name &amp; " is using .allSubTerminals.first / .allSubTerminals.last");
					endif;
				endif;
			endforeach;
			
		endwhile;
		
	endforeach;
	
	foreach str in itemsFoundArray do
		msgStr := msgStr &amp; str &amp; CrLf;
	endforeach;
	
	assertEqualMsg(itemsFoundArray.size, 0, msgStr);	
	
epilog

	delete classes;
	delete iter;
	delete itemsFoundArray;
	delete itemsToCheckArray;
	delete methodsToIgnore;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;fails02122014&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tCheckForLocalSelfOpts" id="d2228f0c-2a88-43c6-90f2-889a0d853a51">
        <source>tCheckForLocalSelfOpts();
// cnwmk3
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2012	cnwmc5	Initial creation

*/

vars
	klass				: Class;
	meth				: Method;
	
	classes				: ClassColl;
	methodsDict			: MethodNDict;
	
	iter				: Iterator;
	
	itemsFoundArray		: StringArray512;
	methodsToIgnore		: StringArray512;
	
	str					: String;
	msgStr				: String;
	methodSource		: String;
	
begin
	// methods we don't want to check
	create methodsToIgnore transient;
	methodsToIgnore.add("UT_JMTCodeVerification::tCheckForLocalSelfOpts"); // THIS METHOD
	
	methodsToIgnore.add("UT_DSL::getOpts");	// Has to have it..
	methodsToIgnore.add("UT_DSL::addStopsTable");	// Will eventually be removed..
	methodsToIgnore.add("UT_DSL::addContainers");	// Has to have it..
	methodsToIgnore.add("UT_Verification_Admin::vUTSetTerminalConfig");
	
	// get the class
	klass := currentSchema.getClass("UT_DSL");
	assertNotNull(klass);
	
	// get all the subclasses
	create classes transient;
	klass.allLocalSubclasses(classes);
	classes.add(klass);
	
	create itemsFoundArray transient;
	
	// read through all the class methods source code to see if any of the no nos are found
	foreach klass in classes do
		
		methodsDict := klass.cnGetMethods();
		delete iter;
		iter := methodsDict.createIterator;
		while iter.next(meth) do
		
			methodSource := self.removeCommentsFromSource(meth.getSource());
			methodSource.replaceChar(Cr, " ");
			methodSource.replaceChar(Lf, " ");
			
			if methodSource.cnContains("CM_AssociationDict") and not methodsToIgnore.includes(klass.name &amp; "::" &amp; meth.name) then
				if methodSource.cnContains("self.opts") then
					// remove this 'if' once 'addStopsTable' issue has been sorted.. (this includes about 8 methods)
					if not methodSource.cnContains("addStopsTable") then
						itemsFoundArray.add(klass.name &amp; "::" &amp; meth.name &amp; " is using a CM_AssociationDict and contains self.opts");
					endif;
				endif;
			else
				continue;
			endif;
			
		endwhile;
		
	endforeach;
	
	foreach str in itemsFoundArray do
		msgStr := msgStr &amp; str &amp; CrLf;
	endforeach;
	
	assertEqualMsg(itemsFoundArray.size, 0, msgStr);	
	
epilog
	delete classes;
	delete iter;
	delete itemsFoundArray;
	delete methodsToIgnore;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckForSysSetIncorrectReset" id="4a4a7e4d-b658-4341-9923-37f075a1c999">
        <source>tCheckForSysSetIncorrectReset();

/*

Purpose:		Check to system (Terminal / System) stuff getting set but not getting reset in the epilog

				Checking for the following:
				1) .setConfig/.setTerminalConfig with not corresponding set in the epilog
				2) .allCargoTypesNew.remove not getting added back

Date			Who		Reason
29/04/2014		cnwmh5	Initial creation
23/07/2014		cnwmh5	Change to check for .setConfig( only.
13/11/2014		cnwmh5  Change to now also takes into account .setTerminalConfig(
*/

vars

	klass						: Class;
	meth						: Method;

	classes						: ClassColl;
	methodsDict					: MethodNDict;
	ignoreClassMethod			: StringArray512;
	changedAttribArray			: StringArray512;
	errorArray					: StringArray512;
	tempErrorArray				: StringArray512;
	stringsToCheckFor			: StringArray;
	
	iter						: Iterator;
	
	methodSource				: String;
	pos 						: Integer;
	line						: String;
	classMethodName				: String;
	attrib						: String;
	matchFound					: Boolean;
	index						: Integer;
	scanFor						: String;
	posEpilog					: Integer;
	checkingEpilog				: Boolean;
	posAttrib					: Integer;
	foundCount					: Integer;
	singleMethod				: Boolean;
	attribNotAdded				: Boolean;
	startTS						: TimeStamp;
	
begin

	klass := currentSchema.getClass("UT_DSL");
	self.assertNotNull(klass);
	
	create classes transient;
	classes.add(klass);
	klass.allSubclasses(classes);
	
	create ignoreClassMethod transient;
	ignoreClassMethod.add(method.schemaType.name &amp; "::" &amp; method.name);
	ignoreClassMethod.add("UT_DSL::deleteCarrier");
	ignoreClassMethod.add("UT_DSL::deleteCommodity");
	ignoreClassMethod.add("UT_DSL::deleteOperator");
	ignoreClassMethod.add("UT_DSL::ndlDeleteTerminalNotComplete");
	ignoreClassMethod.add("UT_DSL::setTerminalConfig");
	ignoreClassMethod.add("UT_DSL::setTerminalConfigPw");
	ignoreClassMethod.add("UT_DSL::setSystemConfig");
	ignoreClassMethod.add("UT_Fixup::uFixupSwapConfig");
	ignoreClassMethod.add("UT_Verification_Admin::vUTSubTerminalSet");
	ignoreClassMethod.add("UT_JMT::tGetTIsToDelete");
	ignoreClassMethod.add("UT_JMT::uGetTIsToDelete");
	ignoreClassMethod.add("UT_Verification_Admin::vGetTIsToDelete");
	ignoreClassMethod.add('UT_Verification_Admin::vUTSubTerminalSetCashNotEnable');
	ignoreClassMethod.add('UT_JMTCodeVerification::tCheckForSysSetIncorrectReset');
	ignoreClassMethod.add('UT_Verification_Admin::vUTSetTerminalConfig');
	ignoreClassMethod.add('UT_EDI::tPrenoteNPI_CSV');
	ignoreClassMethod.add('UT_DSL::addTerminal');
	ignoreClassMethod.add('UT_DSL::setDefaultBankCashInvoiceType');
	ignoreClassMethod.add('UT_EDI::tPrenoteDBLoadPartial');
	ignoreClassMethod.add('UT_Pelindo::tPelindo1TAT_1');
	ignoreClassMethod.add('UT_Pelindo::tPelindo1TAT_2');
	ignoreClassMethod.add('UT_Cash::unitTestAfterClass');
	ignoreClassMethod.add('UT_Cash::unitTestBeforeClass');
	ignoreClassMethod.add('UT_Pelindo::tPelindo1TAT_1A');
	ignoreClassMethod.add('UT_DirectDelivery::uSalalahDirectToShipByQuantity');
	ignoreClassMethod.add("UT_HelperAdmTerm::xDeleteCarrier");
	
	create changedAttribArray transient;
	create errorArray transient;
	create tempErrorArray transient;
	
	create stringsToCheckFor transient;
	////stringsToCheckFor.add("setTerminalConfig(");
	stringsToCheckFor.add("setConfig(");
	
	
	foreach klass in classes do : noMoreCheckingToDo
	
		methodsDict := klass.cnGetMethods();
		delete iter;
		iter := methodsDict.createIterator;
		while iter.next(meth) do
			
			if ignoreClassMethod.includes(meth.schemaType.name &amp; "::" &amp; meth.name) then
				continue;
			endif;
			
			//if meth.name &lt;&gt; "tCamTrainArriveDepartEvents" then
			//	singleMethod := true;
			//	continue;
			//endif;
			
			classMethodName := meth.schemaType.name &amp; "::" &amp; meth.name;
			
			methodSource := self.removeCommentsFromSource(meth.getSource());
			methodSource.cnReplaceString(Tab, " ");
			
			foundCount := 0;
			foreach index in 1 to stringsToCheckFor.size step 1 do
				if methodSource.cnContains(stringsToCheckFor[index]) then
					foundCount := foundCount + 1;
				endif;		
			endforeach;
			if foundCount = 0 then
				continue;
			endif;
			
			pos := 1;
			posEpilog := 1;
			posEpilog := methodSource.pos("epilog", posEpilog);
			checkingEpilog := false;
			posAttrib := 0;
			changedAttribArray.clear();
			tempErrorArray.clear();
			matchFound := false;
			startTS := app.actualTimeServer();
			attribNotAdded := false;
			
			while true do : noMoreToFind
				
				attribNotAdded := false;
				
				// fail safe exit if get into a endless loop
				if startTS.cnMinutesDifference(app.actualTimeServer) &gt;= 1 then
					if not tempErrorArray.includes(classMethodName &amp; " unable to complete validation") then
						tempErrorArray.add(classMethodName &amp; " unable to complete validation");
					endif;
					break noMoreToFind;
				endif;
				
				foreach index in 1 to stringsToCheckFor.size step 1 do
					pos := methodSource.pos(stringsToCheckFor[index], pos);
					if changedAttribArray.isEmpty() and pos = 0 then
						pos := 1;
						continue;
					elseif index &lt; stringsToCheckFor.size and pos = 0 then 
						pos := posAttrib;
						continue;
					endif;
					scanFor := ",";
					break;
				endforeach;
				if pos = 0 then
					break noMoreToFind;
				endif;
				
				if not checkingEpilog and pos &gt; posEpilog then
					checkingEpilog := true;
				endif;
			
				pos := pos + stringsToCheckFor[index].length;
				attrib := methodSource.scanUntil(scanFor, pos).trimBlanks();
				posAttrib := pos + scanFor.length;
				
				if not changedAttribArray.includes(attrib) then
					changedAttribArray.add(attrib);
					continue;
				else
					attribNotAdded := true;
				endif;
				
				if checkingEpilog then
					if not attribNotAdded then
						if not tempErrorArray.includes(classMethodName &amp; " doesn't reset " &amp; attrib) then
							tempErrorArray.add(classMethodName &amp; " doesn't reset " &amp; attrib);
						endif;
					endif;
				endif;
				
				matchFound := true;
				
			endwhile;
		
			if tempErrorArray.isEmpty() and not matchFound then
				foreach attrib in changedAttribArray do
					tempErrorArray.add(classMethodName &amp; " doesn't reset " &amp; attrib);
				endforeach;
			endif;
			tempErrorArray.copy(errorArray);
			
		endwhile;
	
	endforeach;
	
	matchFound := false;
	if not errorArray.isEmpty then
		app.writeLog("-------------------------------------------------------------" &amp; CrLf &amp;
			"The following methods don't reset a terminal / system config:", LogINFO);
	endif;
	foreach line in errorArray do
		app.writeLog(line, LogINFO);
		matchFound := true;
	endforeach;
	
	if matchFound then
		app.writeLog("Count: " &amp; errorArray.size.String, LogINFO);
		app.writeLog("-------------------------------------------------------------", LogINFO);
	endif;
	
	self.assertEqual(errorArray.size, 0);
	
epilog

	delete classes;
	delete iter;
	delete ignoreClassMethod;
	delete changedAttribArray;
	delete errorArray;
	delete tempErrorArray;
	delete stringsToCheckFor;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckFormForNullControls" id="eb103be4-ff23-4962-9a34-c72957823a75">
        <source>tCheckFormForNullControls();

/*

Purpose:		Should never happen but you never know	

Date			Who		Reason
02/07/2015		cnwmh5	Initial creation

*/

vars
	
	schema						: Schema;
	class						: Class;
	form						: Form;
	control						: Control;
	
	schemaArray					: SchemaColl;
	classesArray				: ClassColl;
	allowableSchemasArray		: StringArray;
	errorArray					: StringArray;
	
	index						: Integer;
	errorStr					: String;

	
begin

	create allowableSchemasArray transient;									// 12/04/2013 cnwmh5
	allowableSchemasArray.add(UiCommonSchemaName);
	allowableSchemasArray.add(MobileUISchemaName);
	allowableSchemasArray.add(PortSchemaName);
	allowableSchemasArray.add(GateSchemaName);
	allowableSchemasArray.add(GeneralCargoSchemaName);
	allowableSchemasArray.add(HmsSchemaName);
	allowableSchemasArray.add(InvoiceSchemaName);
	allowableSchemasArray.add(LogSchemaName);
	allowableSchemasArray.add(ShipSchemaName);
	allowableSchemasArray.add(SysOpsSchemaName);
	allowableSchemasArray.add(YardSchemaName);

	create schemaArray transient;
	schemaArray.add(rootSchema.getSchema(UiCommonSchemaName));
	schemaArray.add(rootSchema.getSchema(MobileUISchemaName));
	
	create classesArray transient;
	
	foreach schema in schemaArray do
		if schema.name &lt;&gt; MobileUISchemaName then
			schema.getClass("CM_BaseForm").allSubclasses(classesArray);
			schema.getClass("CM_BaseForm").allSubclassesInSubschemas(classesArray);
		else
			schema.getClass('MOB_BaseForm').allSubclasses(classesArray);
			schema.getClass('MOB_BaseForm').allSubclassesInSubschemas(classesArray);
		endif;
	endforeach;
	
	create errorArray transient;
	
	foreach class in classesArray do
		if not allowableSchemasArray.includes(class.schema.name) then						
			continue;
		endif;	
		foreach form in Form.instances do
			if form.name = class.name then
				break;
			endif;
		endforeach;
		
		foreach index in 1 to form.controlCount do
			control := form.controls(index);
			if control = null then
				errorArray.add(form.name &amp; Tab &amp; form.controls(index).String &amp; Tab &amp; index.String);
			endif;
		endforeach;
	endforeach;
	
	if not errorArray.isEmpty() then
		errorStr := "The following Form(s) have null controls:" &amp; CrLf &amp; errorArray.concatenate(CrLf);	
	endif;	
	
	self.assertTrue(errorStr = null);
	
epilog

	delete schemaArray;
	delete classesArray;
	delete allowableSchemasArray;
	delete errorArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckHardCodedCargoTypeID" id="809edbe6-9d3d-471c-9297-f30f4ce8d355">
        <source>tCheckHardCodedCargoTypeID();

/*

Purpose:		Check for hardcoding of products, cargo types and to do tasks	

Date			Who		Reason
27/06/2013		cnwmh5	Initial creation

*/

vars

	klass				: Class;
	meth				: Method;
	localVar 			: JadeLocalVar;
	value				: Any;
	portSchema			: Schema;
	
	classes				: ClassColl;
	methodsDict			: MethodNDict;
	globalConstDict		: ConstantNDict;
	
	iter				: Iterator;
	
	itemsFoundArray		: StringArray512;
	itemsToCheckArray	: StringArray512;
	methodsToIgnore		: StringArray512;
	
	str					: String;
	msgStr				: String;
	methodSource		: String;
	found				: String[10];
	index				: Integer;
	pos					: Integer;
	posCrLf				: Integer;
	attrib				: String;
	tempStr				: String;
	
	length				: Integer;
	sourceLine			: String;	
	posSearchText		: Integer;
	posOpenSqBracket	: Integer;
	posCloseSqBracket	: Integer;
	textToCheck			: String;
	posCommented		: Integer;
	digitCount			: Integer;

begin

	// get PortSchema
	portSchema := rootSchema.getSchema("PortSchema");
	assertNotNull(portSchema);
	
	// get the global constants
	globalConstDict := portSchema.cnGetGlobalConstants();
	
	// methods to ignore
	create methodsToIgnore transient;
	methodsToIgnore.add("UT_JMTCodeVerification::uCheckForHardCodedIds");
	methodsToIgnore.add("UT_JMTCodeVerification::tCheckHardCodedCargoTypeID");
	methodsToIgnore.add("UT_Stops::tCCMS1791_PAR20466");
	methodsToIgnore.add("UT_Stops::tStopsTableTemplateTest");
	methodsToIgnore.add("UT_PackUnpack::tPackWeightCheckMobile");
	methodsToIgnore.add("UT_Invoicing::addInvoiceCargoAllocation");
	methodsToIgnore.add("UT_Invoicing::addInvoiceInventoryAllocation");  // ### TFS 51219 18JUN2021 NAVAB1
	methodsToIgnore.add("UT_OwnershipChange::addReleaseByTypeRequests");
	
	// get the class
	klass := currentSchema.getClass("UT_DSL");
	assertNotNull(klass);
	
	// get all the subclasses
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	create itemsFoundArray transient;
	
	// read through all the class methods source code to see if any of the no nos are found
	foreach klass in classes do
		
		methodsDict := klass.cnGetMethods();
		delete iter;
		iter := methodsDict.createIterator;
		while iter.next(meth) do
		
			// check see if method to ignore
			if methodsToIgnore.includes(klass.name &amp; '::' &amp; meth.name) then
				continue;
			endif;
		
			methodSource := meth.getSource();
			
			if not methodSource.cnContains(".allCargoTypesById") then
				continue;
			endif;
			
			length := methodSource.length;
			posCrLf := -1;
			
			// Read the source and see what is currently already defined
			// read through the file getting current constants
			while true do
			
				if methodSource &lt;&gt; null then
					if posCrLf = -1 then
						posCrLf := 1;
					else
						posCrLf := posCrLf + 2;
					endif;
					if (posCrLf + 2) &gt; methodSource.length then
						break;
					endif;
					methodSource := methodSource[posCrLf:end];
				endif;
			
				posCrLf := 1;
				posCrLf := methodSource.pos(CrLf, posCrLf);
				if posCrLf = 0 or (posCrLf + 1) &gt; length then
					break;
				endif;
				sourceLine := methodSource[1:posCrLf];	
				
				// check to see if search text on the line if not then next line
				posSearchText := sourceLine.pos(".allCargoTypesById", 1);
				if posSearchText = 0 then
					continue;
				endif;
				
				// check to see if [ after search text, if not then don't require
				posOpenSqBracket := sourceLine.pos("[", posSearchText);
				if posOpenSqBracket = 0 then
					continue;
				endif;
				
				// check the text to see if harcoded number
				posOpenSqBracket := posOpenSqBracket + 1;
				textToCheck := sourceLine.scanUntil("]", posOpenSqBracket).trimBlanks;
				
				// following code is fine in these methods
				//if (klass.name = "UT_Stops" and (meth.name = "tCCMS1791_PAR20466" or meth.name = "tStopsTableTemplateTest")) or 
				//		(klass.name = "UT_PackUnpack" and meth.name = "tPackWeightCheckMobile") then
				//	continue;
				//endif;
							
				// check to see if it's a class constant
				if klass.findConstant(textToCheck) &lt;&gt; null and klass.findConstantInSuperschema(textToCheck) &lt;&gt; null then
					continue;
				endif;
			
				// check to see if global constant
				if globalConstDict[textToCheck] &lt;&gt; null then
					continue;
				endif;
			
				digitCount := 0;
				foreach index in 1 to textToCheck.length do
					if textToCheck[index].isNumeric then
						digitCount := digitCount + 1;
					endif;
				endforeach;
				
				// check to see if uses .getCargoTypeIDFromAbbrev
				if sourceLine.cnContains(".getCargoTypeIDFromAbbrev") then
					continue;
				endif;
				
				// check if passed in and check passed in code
				///if self.xCheckCalledMethodsOk(meth, textToCheck, itemsFoundArray, globalConstDict) then
				///	continue;
				///endif;
				
				// putting this in at the moment, need to revisit this so can check calling methods
				if klass.name = "UT_DSL" then
					continue;
				endif;
				
				app.writeLog(klass.name &amp; '::' &amp; meth.name &amp; Tab &amp; textToCheck &amp; Tab &amp; klass.findConstant(textToCheck).String &amp; Tab &amp; 
					klass.findConstantInSuperschema(textToCheck).String &amp; Tab &amp; portSchema.findGlobalConstantInBranch(textToCheck).String &amp; Tab &amp; 
					globalConstDict[textToCheck].String, LogINFO);
			
				// add to the array of items found
				if not itemsFoundArray.includes(klass.name &amp; '::' &amp; meth.name) then
					itemsFoundArray.add(klass.name &amp; '::' &amp; meth.name);
				endif;
				
			endwhile;
			
		endwhile;
		
	endforeach;
	
	foreach str in itemsFoundArray do
		msgStr := msgStr &amp; str &amp; CrLf;
	endforeach;
	
	assertEqualMsg(itemsFoundArray.size, 0, msgStr);

epilog

	delete iter;
	delete classes;
	delete itemsFoundArray;
	delete methodsToIgnore;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckHardCodedToDoTaskID" id="b5403deb-3e6e-44e7-a9f7-f16ce5c7eec8">
        <source>tCheckHardCodedToDoTaskID();

/*

Purpose:		Check for hardcoding of to do tasks	

Date			Who		Reason
01/07/2013		cnwmh5	Initial creation

*/

vars

	klass				: Class;
	meth				: Method;
	portSchema			: Schema;
	
	classes				: ClassColl;
	methodsDict			: MethodNDict;
	globalConstDict		: ConstantNDict;
	
	iter				: Iterator;
	
	itemsFoundArray		: StringArray512;
	methodsToIgnore		: StringArray512;
	
	str					: String;
	msgStr				: String;
	methodSource		: String;
	index				: Integer;
	posCrLf				: Integer;
	
	length				: Integer;
	sourceLine			: String;	
	posSearchText		: Integer;
	posOpenSqBracket	: Integer;
	textToCheck			: String;
	digitCount			: Integer;

begin

	// get PortSchema
	portSchema := rootSchema.getSchema("PortSchema");
	assertNotNull(portSchema);
	
	// get the global constants
	globalConstDict := portSchema.cnGetGlobalConstants();
	
	// methods to ignore
	create methodsToIgnore transient;
	methodsToIgnore.add("UT_JMTCodeVerification::uCheckForHardCodedIds");
	methodsToIgnore.add("UT_Trx_Misc::tTrackedItemMisc");
	methodsToIgnore.add("UT_HelperAdmTerm::xCreateWoTaskCargo");
	methodsToIgnore.add("UT_WorkOrders::xCreateWorkOrderDetail");
	
	// get the class
	klass := currentSchema.getClass("UT_DSL");
	assertNotNull(klass);
	
	// get all the subclasses
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	create itemsFoundArray transient;
	
	// read through all the class methods source code to see if any of the no nos are found
	foreach klass in classes do
		
		methodsDict := klass.cnGetMethods();
		delete iter;
		iter := methodsDict.createIterator;
		while iter.next(meth) do
		
			// check see if method to ignore
			if methodsToIgnore.includes(klass.name &amp; '::' &amp; meth.name) then
				continue;
			endif;
		
			methodSource := self.removeCommentsFromSource(meth.getSource());
			
			if not methodSource.cnContains(".allToDoTaskDescriptions") then
				continue;
			endif;
			
			length := methodSource.length;
			posCrLf := -1;
			
			// Read the source and see what is currently already defined
			// read through the file getting current constants
			while true do
			
				if methodSource &lt;&gt; null then
					if posCrLf = -1 then
						posCrLf := 1;
					else
						posCrLf := posCrLf + 2;
					endif;
					if (posCrLf + 2) &gt; methodSource.length then
						break;
					endif;
					methodSource := methodSource[posCrLf:end];
				endif;
			
				posCrLf := 1;
				posCrLf := methodSource.pos(CrLf, posCrLf);
				if posCrLf = 0 or (posCrLf + 1) &gt; length then
					break;
				endif;
				sourceLine := methodSource[1:posCrLf];	
				
				// check to see if search text on the line if not then next line
				posSearchText := sourceLine.pos(".allToDoTaskDescriptions", 1);
				if posSearchText = 0 then
					continue;
				endif;
				
				// check to see if [ after search text, if not then don't require
				posOpenSqBracket := sourceLine.pos("[", posSearchText);
				if posOpenSqBracket = 0 then
					continue;
				endif;
				
				// check the text to see if harcoded number
				posOpenSqBracket := posOpenSqBracket + 1;
				textToCheck := sourceLine.scanUntil("]", posOpenSqBracket).trimBlanks;
				
				// check to see if it's a class constant
				if klass.findConstant(textToCheck) &lt;&gt; null and klass.findConstantInSuperschema(textToCheck) &lt;&gt; null then
					continue;
				endif;
			
				// check to see if global constant
				if globalConstDict[textToCheck] &lt;&gt; null then
					continue;
				endif;
			
				digitCount := 0;
				foreach index in 1 to textToCheck.length do
					if textToCheck[index].isNumeric then
						digitCount := digitCount + 1;
					endif;
				endforeach;
				
				// check if passed in and check passed in code
				///if self.xCheckCalledMethodsOk(meth, textToCheck, itemsFoundArray, globalConstDict) then
				///	continue;
				///endif;
				
				// putting this in at the moment, need to revisit this so can check calling methods
				if klass.name = "UT_DSL" then
					continue;
				endif;
				
				app.writeLog(klass.name &amp; '::' &amp; meth.name &amp; Tab &amp; textToCheck &amp; Tab &amp; klass.findConstant(textToCheck).String &amp; Tab &amp; 
					klass.findConstantInSuperschema(textToCheck).String &amp; Tab &amp; portSchema.findGlobalConstantInBranch(textToCheck).String &amp; Tab &amp; 
					globalConstDict[textToCheck].String, LogINFO);
			
				// add to the array of items found
				if not itemsFoundArray.includes(klass.name &amp; '::' &amp; meth.name) then
					itemsFoundArray.add(klass.name &amp; '::' &amp; meth.name);
				endif;
				
			endwhile;
			
		endwhile;
		
	endforeach;
	
	foreach str in itemsFoundArray do
		msgStr := msgStr &amp; str &amp; CrLf;
	endforeach;
	
	assertEqualMsg(itemsFoundArray.size, 0, msgStr);

epilog

	delete iter;
	delete classes;
	delete itemsFoundArray;
	delete methodsToIgnore;
	
end;</source>
