    <JadeMethod name="amountInWords" id="8dd0b0a3-7151-4957-bfd3-d04f05254d9d">
        <source>amountInWords(pWholeUnits:String; pDecimalUnits:String):String;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Returns the receiver's currency amount expressed in words.
//
// Parameters:	pWholeUnits - The name of the whole currency units, e.g. "Dollars".
//				pDecimalUnits - The name of the decimal currency units, e.g. "Cents".
//
// Returns:		The currency amount expressed in words.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	localeInfoObj	: LocaleFullInfo;
	wholeAmount		: String;
	decimalAmount	: String;
	wordedAmount	: String;
	
begin
	create localeInfoObj transient;
	self.getLocaleFullInfo(localeInfoObj, true);
	
	self.getDecimalCurrency().cnEcAsWords(localeInfoObj, wholeAmount, decimalAmount);

	if pWholeUnits = null then
		wordedAmount	:=	wholeAmount &amp; " " &amp; $CNEC_LIT_AND;
	else
		wordedAmount	:=	wholeAmount &amp; " " &amp; pWholeUnits &amp; " " &amp; $CNEC_LIT_AND;
	endif;
	
	if pDecimalUnits = null then
		wordedAmount	:=	wordedAmount &amp; " " &amp; decimalAmount;
	else
		wordedAmount	:=	wordedAmount &amp; " " &amp; decimalAmount &amp; " " &amp; pDecimalUnits;
	endif;
epilog
	delete localeInfoObj;
	
	return wordedAmount;
end;</source>
        <Parameter name="pWholeUnits" type="String"/>
        <Parameter name="pDecimalUnits" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="17800955-7083-4db8-8283-82fc9cd1dc6d">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		06 July 2001 by cnwdad1
//
// Purpose:		Default the remote locale to the client's current locale, and
//				default the exchange rate to "1".
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setRemoteLocaleInfo(app.currentLocaleInfo);
	self.setExchangeRate(1);
end;</source>
    </JadeMethod>
    <JadeMethod name="doConvertAmount" id="4261eae6-50ef-401a-a1d9-9752abb55e68">
        <source>doConvertAmount():Decimal protected;
// --------------------------------------------------------------------------------
// Created:		15 May 2001 by cnwdad1
//
// Purpose:		Convert the currency amount using the exchange rate.
//
// Parameters:	None
//
// Returns:		The converted currency value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currencyObj		: CurrencyFormat;
	convertedAmount	: Real;
	decimalPlaces	: Integer;
	rateDivisor		: Integer;
	
begin
	create currencyObj transient;
	self.getCurrencyFormat(currencyObj, false);
	
	decimalPlaces	:=	currencyObj.intlDecimalPlaces;
	rateDivisor		:=	10 ^ decimalPlaces;
	convertedAmount	:=	self.amount * (self.exchangeRate / rateDivisor);
epilog
	delete currencyObj;
	
	return convertedAmount.Decimal.roundedTo(decimalPlaces);
end;</source>
        <access>protected</access>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getConvertedAmount" id="cab9d6e1-f5f7-4662-99dd-0e686b09eb35">
        <source>getConvertedAmount():Decimal;
// --------------------------------------------------------------------------------
// Created:		15 May 2001 by cnwdad1
//
// Purpose:		Returns the receiver's value after converting it using the exchange
//				rate.
//
// Parameters:	None
//
// Returns:		The converted amount.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.doConvertAmount();
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getConvertedAndFormattedAmount" id="32390c96-0c84-4c5c-81ad-b112b9effd11">
        <source>getConvertedAndFormattedAmount():String;
// --------------------------------------------------------------------------------
// Created:		15 May 2001 by cnwdad1
//
// Purpose:		Returns the receiver's value after converting it using the exchange
//				rate, and then formatting it as a string.
//
// Parameters:	None
//
// Returns:		The converted and formatted amount, as a string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currencyObj		: CurrencyFormat;
	
begin
	create currencyObj transient;
	self.getCurrencyFormat(currencyObj, false);
	
	return self.doConvertAmount().userCurrencyFormat(currencyObj);
epilog
	delete currencyObj;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDecimalCurrency" id="ba14219f-5974-4b97-b513-eb57638da9e6">
        <source>getDecimalCurrency():Decimal;
// --------------------------------------------------------------------------------
// Created:		22 August 2001 by cnwdad1
//
// Purpose:		Returns the receiver's "amount" (by default, a Real value), as a
//				Decimal currency value.  The current locale's defined decimal
//				places will be used to determine the number of places required.
//
// Parameters:	None
//
// Returns:		The receiver's converted amount.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/11/2001	cnwdad1		The decimal amount wasn't being padded to its proper
//							length, thus 1 cent was interpreted as 10 cents.
// --------------------------------------------------------------------------------
vars
	currencyObj			: CurrencyFormat;
	numberObj			: NumberFormat;
	decimalPlaces		: Integer;
	stringValue			: String;
	wholeAmount			: Integer;
	decimalAmount		: Integer;
	decimalSeparator	: String;
	separatorPosition	: Integer;
	decimalString		: String;
	
begin
	create currencyObj transient;
	self.getCurrencyFormat(currencyObj, true);
	decimalPlaces		:=	currencyObj.decimalPlaces;
	
	wholeAmount			:=	self.amount.abs.Integer;
	stringValue			:=	self.amount.String;
	
	create numberObj transient;
	self.getNumberFormat(numberObj, true);
	
	decimalSeparator	:=	numberObj.decimalSeparator;
	separatorPosition	:=	stringValue.reversePos(".");
	
	if separatorPosition &gt; 0 and separatorPosition &lt;= stringValue.length then
//		decimalAmount	:=	stringValue[(separatorPosition + 1):end].Integer;
		decimalString	:=	stringValue[(separatorPosition + 1):end];
	else
//		decimalAmount	:=	0;
		decimalString	:=	null;
	endif;
	
//	decimalString	:=	decimalAmount.cnEcPadTrailingZeros(decimalPlaces);
	decimalString	:=	decimalString.cnEcPadTrailing(decimalPlaces, "0");
	stringValue		:=	wholeAmount.String &amp; decimalSeparator &amp; decimalString;
epilog
	delete currencyObj;
	delete numberObj;
	
	return stringValue.Decimal;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDecimalizedAmount" id="8d50182b-8bc2-4e38-986c-812cf0406e74">
        <source>getDecimalizedAmount():Decimal;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Returns the receiver's amount, with any excess decimals truncated
//				according to the locale's defined number of decimal places.
//
// Parameters:	None
//
// Returns:		The decimalized amount.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currencyObj		: CurrencyFormat;
	convertedAmount	: Real;
	decimalPlaces	: Integer;
	rateDivisor		: Integer;
	
begin
	create currencyObj transient;
	self.getCurrencyFormat(currencyObj, true);
	
	decimalPlaces	:=	currencyObj.intlDecimalPlaces;
	convertedAmount	:=	self.amount.truncatedTo(decimalPlaces);
epilog
	delete currencyObj;
	
	return convertedAmount.Decimal;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getFormattedAmount" id="d11865f7-c3d1-4a2e-b55f-51b915511f23">
        <source>getFormattedAmount():String;
// --------------------------------------------------------------------------------
// Created:		15 May 2001 by cnwdad1
//
// Purpose:		Returns the receiver's amount, formatted according to the locale's
//				defined characteristics.
//
// Parameters:	None
//
// Returns:		The formatted amount, as a string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currencyObj		: CurrencyFormat;
	
begin
	create currencyObj transient;
	self.getCurrencyFormat(currencyObj, true);
	
	return self.amount.userCurrencyFormat(currencyObj);
epilog
	delete currencyObj;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocalDecimalSeparator" id="f5604c4d-e8bb-40af-aff8-c01f786037dd">
        <source>getLocalDecimalSeparator():String;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Returns the decimal separator for the currency's locale.
