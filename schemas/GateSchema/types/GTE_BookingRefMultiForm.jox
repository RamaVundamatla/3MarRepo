    <JadeMethod name="tblDataDisplayRow" id="32cd385a-93f7-41a3-96b0-244904792052">
        <updating/>
        <source>tblDataDisplayRow(_table: Table input; _obj: Object): String updating;
// ---------------------------------------------------------------------------
// Created:     01 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	bookingRef	: CM_BookingRef;
	opCode,
	voyCode,
	str			: String;
	entTableDef	: EntTableDef;
	failedDAC	: CM_DataAccessController;
	
begin
	if _obj.isKindOf(CM_BookingRef) then
		bookingRef := _obj.CM_BookingRef;
		
		if bookingRef.myOperator &lt;&gt; null then
			if (not bookingRef.myOperator.canUserAccessSelf(null, failedDAC, app.myPassport)) then
				return null;
			endif;
			opCode := bookingRef.myOperator.code;
		endif;
		
		str := bookingRef.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		return str;
	else
		str := _obj.CM_BookingRefItem.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);			//+cnwml2 PAR20173 SFW CCMS 1091
		return str;
	endif;
	/*
	
	if self.isDataFiltered then
		// data is filtered
		if filterOperatorCode &lt;&gt; null and
		   filterOperatorCode &lt;&gt; opCode then
		   	return null;
		endif;
		if filterBookingReference &lt;&gt; null and
		   filterBookingReference &lt;&gt; bookingRef.bookingReference then
		   	return null;
		endif;
	endif;
	
	if bookingRef.myOperator &lt;&gt; null then
		opCode := bookingRef.myOperator.code;
	endif;
	
	if bookingRef.myVoyage &lt;&gt; null then
		voyCode := bookingRef.myVoyage.code;
	endif;
	
	/*
	str := opCode &amp; Tab &amp;
		   bookingRef.bookingReference &amp; Tab &amp;
		   bookingRef.vesselCode &amp; Tab &amp;
		   voyCode &amp; Tab &amp;
		   bookingRef.numOnsiteTIs.String &amp; "/" &amp; bookingRef.quantity.String;
	*/
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblDataSelectRow" id="7e54885c-0022-47c9-a999-460f20b9507c">
        <source>tblDataSelectRow(_tbl: CM_DataTable; _idx: Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars

begin
	inheritMethod(_tbl, _idx);
	self.doInstructions();	
epilog

end;</source>
        <Parameter name="_tbl" type="CM_DataTable"/>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="76bedfcb-c689-46b2-b29b-75e7cfbbbc38">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
/*
----------   ----------  --------------------------------------------------
Created:	12 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ti 			: CM_TrackedItem;
	bookRef 	: CM_BookingRef;
	isPrenote 	: Boolean;
begin
	if (not CM_BookingRef.hasInstance(_obj)) then
		return;
	endif;
	
	bookRef := _obj.CM_BookingRef;
	
//	if bookRef.quantity = bookRef.allTIs.size then
	if bookRef.getTotalQuantity = bookRef.allTIs.size then
		//Ignore coloring zero quantities
		if bookRef.getTotalQuantity &lt;&gt; 0 then
			//Find out if any of my items are yet to be delivered.
			foreach ti in bookRef.allTIs do
				if ti.state = TI_STATE_NOTIFIED then
					isPrenote := true;
					break;
				endif;
			endforeach;
			if isPrenote then
				//self.tblData.accessRow(_idxRow).backColor := PaleGreen;
				self.tblData.accessRow(_idxRow).backColor := LightRed;		// 04/02/2013 cnwar2 #29861
			else
				//self.tblData.accessRow(_idxRow).backColor := LightRed;
				self.tblData.accessRow(_idxRow).backColor := PaleGreen;		// 04/02/2013 cnwar2 #29861
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
