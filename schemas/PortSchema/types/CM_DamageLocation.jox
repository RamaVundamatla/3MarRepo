    <JadeMethod name="setFromDamageInstance" id="f6210d43-1f99-4036-8ce1-c3ab8317dcad">
        <updating/>
        <source>setFromDamageInstance( _pxyDamageInstance : CM_DamageInstance; _damLocation : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2016	cnwndl1	Initial creation	TFS 1593
02 Oct 2019	jlgsl4	TFS 46657 - STWO - Damage Location not created when Damage updated
24 June 2022 navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details
24 June 2022 navsj20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
*/

vars
	dsLevel : Integer;	//28 June 2022 navhl20 TFS 53862
begin

	self.damagedInLocation := _damLocation;

	if _pxyDamageInstance &lt;&gt; null then
		if _pxyDamageInstance.myDamageDefinition &lt;&gt; null then
			self.damageDefCode := _pxyDamageInstance.myDamageDefinition.code;
		endif;
		if _pxyDamageInstance.myDamagePosition &lt;&gt; null then
			self.damagePosCode := _pxyDamageInstance.myDamagePosition.code;
		endif;
		self.damageQuantity := _pxyDamageInstance.quantity;
		
		//Start 24 June 2022 navhl20 TFS 53862
		//self.damageSeverity := _pxyDamageInstance.severity;			
		if _pxyDamageInstance.myDamageSeverity &lt;&gt; null then
			dsLevel := _pxyDamageInstance.myDamageSeverity.level;
		endif;
		self.damageSeverity := dsLevel;	
		//End;24 June 2022 navhl20 TFS 53862
		
		self.damageDescription := _pxyDamageInstance.getAuditText()[1:100];
		self.isNewDamage := _pxyDamageInstance.isNewDamage; // TFS 46657
		self.remarks := _pxyDamageInstance.remarks; // TFS 46657
		
		// START 24 June 2022 navsj20 TFS 53862
		if _pxyDamageInstance.myDamageParty &lt;&gt; null then
			damagePartyCode		:= _pxyDamageInstance.myDamageParty.code;
			damagePartyDesc		:= _pxyDamageInstance.myDamageParty.description;
		endif;
		if _pxyDamageInstance.myDamagePlace &lt;&gt; null then
			damagePlaceCode		:= _pxyDamageInstance.myDamagePlace.code;
			damagePlaceDesc		:= _pxyDamageInstance.myDamagePlace.description;
		endif;
		if _pxyDamageInstance.myDamageReason &lt;&gt; null then
			damageReasonCode	:= _pxyDamageInstance.myDamageReason.code;
			damageReasonDesc	:= _pxyDamageInstance.myDamageReason.description;
		endif;
		if _pxyDamageInstance.myDamageSeverity &lt;&gt; null then
			damageSeverityCode	:= _pxyDamageInstance.myDamageSeverity.code;
			damageSeverityDesc	:= _pxyDamageInstance.myDamageSeverity.description;
		endif;
		if _pxyDamageInstance.status &lt;&gt; null then
			self.damageStatus := _pxyDamageInstance.status;
		endif;
		// END 24 June 2022 navsj20 TFS 53862
		
		//10/04/2024	navkc1 Bug 63387
		self.damageSize := _pxyDamageInstance.damageSize;
endif;
	
epilog

end;</source>
        <Parameter name="_pxyDamageInstance" type="CM_DamageInstance"/>
        <Parameter name="_damLocation" type="String"/>
    </JadeMethod>
</Class>
