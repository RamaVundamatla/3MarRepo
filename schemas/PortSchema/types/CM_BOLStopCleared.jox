    <JadeMethod name="getDisplayStringForAttribute" id="53c81cae-d216-416d-96a7-8cc285757680">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Date		Who		Reason
29 January 2015	cnwer1	Initial creation PAR

*/

vars

begin
	if _attrName = ETRow_Details then
		return  app.getErrorString( TransType_99 ) &amp; ColonAndSpace &amp; self.stopDescription;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
