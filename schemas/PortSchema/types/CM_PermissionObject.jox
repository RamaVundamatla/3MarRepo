        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="outputAsXML" id="5c46fb70-6b38-40ad-b2dd-28199fb73c59">
        <source>outputAsXML() :String;
// ---------------------------------------------------------------------------
// Created:     22 May 2002 by cnwrs2
//
// Purpose:     
// 
// Date			Name	TFS#		Description
// ============================================================================
// 03 Sep 2019	jlgdi1	45802		Added formType attribute in the output
// 23 Sep 2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
// ---------------------------------------------------------------------------

vars
	permStr,
	menuStr,
	tmpChildrenStr		: String;
	tmpValue			: Integer;
	tmpWebservice,
	tmpWebserviceStr	: String;
	tmpHandHeld,
	tmpHandHeldStr 		: String;
	tmpMobileApp,
	tmpMobileAppStr 	: String;
begin
	
	foreach tmpValue in self.allChildValues do
		if tmpValue = 0 then
			continue;
		endif;
		tmpChildrenStr := tmpChildrenStr &amp;
				self.formatAsXML(XMLTag_Child, (tmpValue - Mod_BaseView).String);
	endforeach;
	
	if tmpChildrenStr &lt;&gt; null then
		// done just for formatting
		tmpChildrenStr := CrLf &amp; tmpChildrenStr;
	endif;
	
	//epr TFs 36402 31/1/18
	foreach tmpWebservice in self.allWebservices do
		if tmpWebservice = null then
			continue;
		endif;
		tmpWebserviceStr := tmpWebserviceStr &amp;
				self.formatAsXML(XMLTag_Webservice, tmpWebservice);
	endforeach;
	
	foreach tmpHandHeld in self.allHandheldApps do
		if tmpHandHeld = null then
			continue;
		endif;
		tmpHandHeldStr := tmpHandHeldStr &amp;
				self.formatAsXML(XMLTag_HandHeld, tmpHandHeld);
	endforeach;
	
	foreach tmpMobileApp in self.allMobileApps do
		if tmpMobileApp = null then
			continue;
		endif;
		tmpMobileAppStr := tmpMobileAppStr &amp;
				self.formatAsXML(XMLTag_MobileApp, tmpMobileApp);
	endforeach;
	

	permStr := self.formatAsXMLPrefix(XMLPrefix) &amp; 
	       self.formatAsXML(XMLTag_Description, self.description) &amp; 
	       self.formatAsXML(XMLTag_Category, self.category) &amp; 
	       self.formatAsXML(XMLTag_Internal, self.isInternal.String) &amp;
	       self.formatAsXML(XMLTag_PermType, self.permType.String) &amp;
		   self.formatAsXML(XMLTag_FormType, self.formType.String) &amp;		// 45802
	       self.formatAsXML(XMLTag_Children, tmpChildrenStr) &amp;
	       self.formatAsXML(XMLTag_Explanation, self.explanation) &amp;
		    self.formatAsXML(XMLTag_Webservices, tmpWebserviceStr) &amp;
			self.formatAsXML(XMLTag_HandHelds, tmpHandHeldStr) &amp;
			self.formatAsXML(XMLTag_MobileApps, tmpMobileAppStr) &amp;
	       self.formatAsXMLSuffix(XMLSuffix);
/*
&lt;Permission&gt;
&lt;Description&gt;View Add vehicle Window&lt;/Description&gt;
&lt;Category&gt;Administration&lt;/Category&gt;
&lt;Internal&gt;false&lt;/Internal&gt;
&lt;PermType&gt;0&lt;/PermType&gt;
&lt;Children&gt;
&lt;Child&gt;1&lt;/Child&gt;
&lt;Child&gt;1&lt;/Child&gt;
&lt;/Children&gt;
&lt;Explanation&gt;&lt;/Explanation&gt;
&lt;/Permission&gt;
*/	
	if self.hasMenuDtls() then
		menuStr := 
			self.formatAsXMLPrefix(CM_MenuEntity.XMLTag_MenuDtl) &amp;
			self.formatAsXML(CM_MenuEntity.XMLTag_Heading, self.heading) &amp; 
			self.formatAsXML(CM_MenuEntity.XMLTag_ActionClass, self.actionClass) &amp; 
			self.formatAsXML(CM_MenuEntity.XMLTag_Id, self.id) &amp; 
			self.formatAsXML(CM_MenuEntity.XMLTag_ExtraTableDef, self.extraTableDef) &amp; 
			self.formatAsXML(CM_MenuEntity.XMLTag_MainTableDef, self.mainTableDef) &amp; 
			self.formatAsXML(CM_MenuEntity.XMLTag_SchemaName, self.schemaName) &amp;  
			self.formatAsXML(CM_MenuEntity.XMLTag_WindowClass, self.windowClass) &amp; 
			self.formatAsXML(CM_MenuEntity.XMLTag_Attr1, self.attr1) &amp; 
			self.formatAsXML(CM_MenuEntity.XMLTag_Param1, self.param1) &amp; 
			self.formatAsXML(CM_MenuEntity.XMLTag_PictureButton, self.pictureStringButton) &amp; 
			self.formatAsXML(CM_MenuEntity.XMLTag_PictureButtonDown, self.pictureStringButtonDown) &amp; 
			self.formatAsXML(CM_MenuEntity.XMLTag_PictureIcon, self.pictureStringIcon) &amp; 
			self.formatAsXML(CM_MenuEntity.XMLTag_ToolTip, self.toolTip) &amp; 
			self.formatAsXMLSuffix(CM_MenuEntity.XMLTag_MenuDtl);
	endif;

	return permStr &amp; menuStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="resetConstText" id="746240ba-e562-45b2-9e01-5746c4a0e0a0">
