	else
		foreach obj in self.tblData.allSelectedObjects do	
			obj.CM_BookingRef.getPrenotedTrackedItems (_coll,null);				//24.07.2023 navma1 #59275
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_coll" type="ObjectArray" usage="input"/>
    </JadeMethod>
