    <JadeMethod name="cancelAllVoyages" id="7fed4b06-2f7f-4423-a2c9-f55be1ab73b6">
        <source>cancelAllVoyages();
/*
Purpose:			

Date		Who		Reason
09 December 2021	navab1	TFS 51853
*/

vars
	root : CM_Root;
	term : CM_Terminal;
	voy : CM_Voyage;
begin

	root := CM_Root.firstInstance;
	term := root.allTerminals["BISH"];
	
	foreach voy in term.allVoyagesByCode discreteLock do
		beginTransaction;
		if voy.isMTNWOVoyageProcess then
			voy.setPropertyValue("status", Voyage_Status_VoyCancelled);
		
		else
			voy.setPropertyValue("status", Voyage_Status_Cancelled);
		endif;
		
		commitTransaction;
	
	endforeach;
	


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cancelDepartedVoyages" id="ecec25e7-b939-43c6-a461-ba48b899aa20">
        <source>cancelDepartedVoyages();
/*
Purpose:			

Date		Who		Reason
09 December 2021	navab1	TFS 51853
*/

vars
	root : CM_Root;
	term : CM_Terminal;
	voy : CM_Voyage;
begin

	root := CM_Root.firstInstance;
	term := root.allTerminals["BISH"];
	
	foreach voy in term.allVoyagesByCode discreteLock do
		beginTransaction;
		if voy.isMTNWOVoyageProcess then
			if voy.status = Voyage_Status_VesselDeparted then
				voy.setPropertyValue("status", Voyage_Status_VoyCancelled);
			endif;
		else
			if voy.status = Voyage_Status_Departed then
				voy.setPropertyValue("status", Voyage_Status_Cancelled);
			endif;
		endif;
		
		commitTransaction;
	
	endforeach;
	


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="checkNullOwnerShipchangeDetails" id="22842120-a4c9-4e2e-b1f6-c9723aa1c3dd">
        <source>checkNullOwnerShipchangeDetails();
/*
Purpose:	AN onsite TI should  only have multiple storage expiry details if it has had a chnage of ownership, otherwise the TI should always have 1 storage expiry detail

Date		Who		Reason
07 June 2024	navab1	CR 64297 TASK 64299
*/

vars
	root : CM_Root;
	term : CM_Terminal;
	ti : CM_TrackedItem;
	objToDelete : ObjectSet;
	deleteMode : Boolean;
	cood 		: CM_OwnershipChangeDetail;
	count 		:Integer;
	collection : CM_OwnershipChangeDetailSet;
begin
	deleteMode := false;
	
	
	
	root := CM_Root.firstInstance;
	create objToDelete transient;
	create collection transient;
	foreach term in root.allTerminals discreteLock do
		foreach ti in term.allOnsiteTIsByCargoTypeId discreteLock do
			foreach cood in ti.allOwnershipChangeDetails discreteLock do
				
			if cood.myParentOwnershipChangeDetail = null and cood.myOwnershipChange = null then
				count := count +1; 
				write cood.myTrackedItem.id  &amp; "    " &amp;cood.myTrackedItem.myTerminal.name;
			endif;	
			collection.add(cood);
			endforeach;		
		endforeach;	
	endforeach;
	write "COUNT ===================" &amp; count.String;
	beginTransaction;
	collection.purge();
	delete collection;
	commitTransaction;
end;</source>
    </JadeMethod>
