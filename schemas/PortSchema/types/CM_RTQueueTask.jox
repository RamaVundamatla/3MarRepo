        <source>isWorkingOrAccepted():Boolean condition;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 January 2009	cnwer1	Initial creation

*/

begin
	return self.status = TASK_WORKING or self.status = TASK_ACCEPTED;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
