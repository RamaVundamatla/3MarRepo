    <JadeMethod name="addAttribute" id="d02aaee7-5d1a-4b36-a59f-2f6c5e47cbec">
        <updating/>
        <source>addAttribute(pAttrName, pAttrHeading : String; pInputType : Integer; pTmpNum : Integer; pVisible : Boolean) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     03 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     The row in the table that the attribute was added to.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	return self.addAttributeAt(pAttrName, pAttrHeading, pInputType, pTmpNum, pVisible, 0);

end;</source>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pAttrHeading" type="String"/>
        <Parameter name="pInputType" type="Integer"/>
        <Parameter name="pTmpNum" type="Integer"/>
        <Parameter name="pVisible" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addAttributeAt" id="5555025a-8bf6-4977-9daa-dc58c9a24f95">
        <updating/>
        <source>addAttributeAt(pAttrName, pAttrHeading : String; pInputType : Integer; pTmpNum : Integer; pVisible : Boolean;
			pRow : Integer) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     03 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     The row in the table that the attribute was added to.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// ---------------------------------------------------------------------------
vars
	newRow				: Integer;
	cell				: JadeTableCell;
	entRowTrans			: EntTableRowTransient;

begin
	if pRow = 0 then
		newRow := self.addItem('');
	else
		self.addItemAt('', pRow);
		newRow := pRow;
	endif;
	
	create entRowTrans transient;
	self.allEntRowTransients.insert(newRow, entRowTrans);
	
	self.accessRow(newRow).itemObject := entRowTrans;
	
	entRowTrans.setBasicDetails(pAttrName, pAttrHeading, pInputType, true, pVisible);

	self.accessCell(newRow, ColumnHeading).text := pAttrHeading;
	
	cell := self.accessCell(newRow, ColumnValue);

	if pInputType = InputType_Picture or pInputType = InputType_PictureViewOnly then
		self.picturesUsed := true;
		
		cell.inputType := InputType_ComboBox;
		if pInputType = InputType_PictureViewOnly then
			cell.comboList := PictureNoneText &amp; Tab &amp; PictureViewText;
		else
			cell.comboList := PictureNoneText &amp; Tab &amp; PictureLoadText &amp; Tab &amp;
							  PictureExtractText &amp; Tab &amp; PictureViewText;
		endif;

	elseif pInputType = InputType_Date then
		self.initCellForDate(cell);

	elseif pInputType = InputType_Time then
		self.initCellForTime(cell);

	elseif pInputType = InputType_ColourSelection then
		cell.inputType := InputType_ComboBox;
		cell.comboList := ColourCurrentText &amp; Tab &amp;
						  ColourSelectText &amp; Tab &amp;
						  ColourNoneText;
						  cell.cellControl.ignoreSkin := true; // PAR 31661

	elseif pInputType &gt;= InputType_JMTBase then
		// at this stage we don't handle this input type in
		// the CM_EntryTable so set to readonly
		cell.inputType := Table.InputType_None;
	else
		cell.inputType := pInputType;
	    if pInputType = InputType_SignedNumeric or
	       pInputType = InputType_TextNumeric then
			cell.decimals := pTmpNum;
		elseif pInputType = InputType_TextBox and pTmpNum &lt;&gt; 0 then
			cell.maxLength := pTmpNum;
		endif;
	endif;
	
	if pVisible then
		if topEntryRow = 0 then
			// must be adding the first row
			self.topEntryRow := newRow;
		endif;
		// PAR #31155 This method can add a row anywhere in the table, so assuming it is
		// the bottom row is incorrect. Just use the resetBottomEntryRow method instead.
		// This was causing tabbing issues in the Create New Cargo Form when tabbing out
		// of a CMUI_MeasurementTable control (which are all added by addAttributeAt after
		// the table rows have all been created, so are NOT the last rows in the table)
		//self.bottomEntryRow := newRow;		// PAR #31155
		self.resetBottomEntryRow();				// PAR #31155
	else
		// as new row will be visible by default
		self.accessRow(newRow).visible := false;
	endif;
	
	return newRow;
	
end;</source>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pAttrHeading" type="String"/>
        <Parameter name="pInputType" type="Integer"/>
        <Parameter name="pTmpNum" type="Integer"/>
        <Parameter name="pVisible" type="Boolean"/>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="adjustHeight" id="a79d08f4-bc7f-4ac6-9b2f-0a5bddea6a9e">
        <updating/>
        <source>adjustHeight(pMaxHeight : Real) updating;
// ---------------------------------------------------------------------------
// Created:     10 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx			: Integer;
	numRows		: Integer;
	totHeight	: Real;

begin

	numRows := self.rows;
	
	foreach idx in 1 to numRows do
		if self.accessRow(idx).visible then
			totHeight := totHeight + self.accessedRow.height;
			if totHeight &gt; pMaxHeight then
				break;
			endif;
		endif;
	endforeach;

	if totHeight &gt; 0 then
		totHeight := totHeight + 2;
		if self.show3D = self.Show3D_Use3D then
			totHeight := totHeight + 2;
		endif;
	endif;
	
	if totHeight &gt; pMaxHeight then
		totHeight := pMaxHeight;
	endif;
	
	self.height := totHeight;
	
end;</source>
        <Parameter name="pMaxHeight" type="Real"/>
    </JadeMethod>
    <JadeMethod name="allowCellEnabled" id="bf618e5f-7d4a-45e7-b340-e1adb2544a0a">
        <updating/>
        <source>allowCellEnabled(_entRowTrans : EntTableRowTransient): Boolean updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 18 December 2008
//
// Implemented version: 7.7.1 
// PAR17950 - cnwsh3 18/12/2008  There is one specific case where we want to allow the user to 
//  							 click in the cell but not make changes. Double clicking to open 
//								 another form.  
//----------------------------------------------------------------------
vars
	
begin
	if _entRowTrans = null then
		return false;
	endif;
	
	if _entRowTrans.name = ETRow_EmailOptions then
		return true;
	endif;
	
	return false;
epilog
end;</source>
        <Parameter name="_entRowTrans" type="EntTableRowTransient"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cellInputReady" id="1006e345-bb61-4008-a42c-e6911bc06ef4">
        <updating/>
        <source>cellInputReady(table: Table input; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
// ---------------------------------------------------------------------------
// Created:     06 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(table, inputControl, cleft, ctop, cwidth, cheight);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="change" id="1a68a78a-8175-4609-af32-0ca83f870305">
        <updating/>
        <source>change(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     11 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pic		: Binary;
	tmpCell	: JadeTableCell;
	tmpText	: String;
	entRowTrans		: EntTableRowTransient;
	theRow		: Integer;
	tmpForm		: Form;
	tmpBaseForm	: CM_BaseForm;
	obj : Object;
	value : String;	
	criteriaLine : CM_SelectorCriteriaLine;
	controlType : Integer;
begin

	inheritMethod(table);
	
	
	theRow := table.row;
	
	if theRow &lt; 1 then
		return;
	endif;
	
	obj:=table.accessRow(theRow).itemObject;
	if obj = null then
		return;
	endif;
	
	if obj.isKindOf(EntTableRowTransient) then
		
		entRowTrans := obj.EntTableRowTransient;
	//epr TFS 47132 19/11/19
	elseif obj.isKindOf(CM_SelectorCriteriaLine) then 
		criteriaLine:=obj.CM_SelectorCriteriaLine;
		controlType := criteriaLine.getControlType();
		value:=self.accessCell(theRow,ColumnValue).text;
		if  controlType = QueryControl_TextBox or controlType = QueryControl_Date or controlType = QueryControl_Time then
			obj.CM_SelectorCriteriaLine.myQueryOperator.setSearchValue( value );
		elseif controlType = QueryControl_TimeRange then
			if self.accessCell(theRow,ColumnHeading).text.pos(Space &amp; app.getErrorString(From),1) &gt; 0 then
				obj.CM_SelectorCriteriaLine.myQueryOperator.CM_QTimeRange.setFromTime(value.asTimeJMT);
			else
				obj.CM_SelectorCriteriaLine.myQueryOperator.CM_QTimeRange.setToTime(value.asTimeJMT);
			endif;
		elseif controlType = QueryControl_DateRange then
			if self.accessCell(theRow,ColumnHeading).text.pos(Space &amp; app.getErrorString(From),1) &gt; 0 then
				obj.CM_SelectorCriteriaLine.myQueryOperator.CM_QDateRange.setFromDate(value.asDateJMT);
			else
				obj.CM_SelectorCriteriaLine.myQueryOperator.CM_QDateRange.setToDate(value.asDateJMT);
			endif;
		elseif controlType = QueryControl_NumTextBoxRange then
			if self.accessCell(theRow,ColumnHeading).text.pos(Space &amp; app.getErrorString(From),1) &gt; 0 then
				obj.CM_SelectorCriteriaLine.myQueryOperator.CM_QDateDayRange.setFromNumDays(value.asIntegerJMT);
			else
				obj.CM_SelectorCriteriaLine.myQueryOperator.CM_QDateDayRange.setToNumDays(value.asIntegerJMT);
			endif;
		endif;
	endif;
	
	
	if entRowTrans = null then
		return;
	endif;
	
	tmpForm := self.form;
	if CM_BaseForm.hasInstance(tmpForm) then
		tmpBaseForm := tmpForm.CM_BaseForm;
	endif;
	
	if (entRowTrans.inputType = InputType_Picture) or (entRowTrans.inputType = InputType_PictureViewOnly) then
		tmpCell := table.accessCell(theRow, ColumnValue).cloneSelf(true);
		tmpText := tmpCell.text;
		if tmpText = PictureViewText then
			if tmpBaseForm &lt;&gt; null then
				tmpBaseForm.picViewMethod(tmpCell.picture);
			elseif self.pictureViewMethod &lt;&gt; null then
				self.form.sendMsgWithParams(self.pictureViewMethod, tmpCell.picture);
			else
				if self.warningMethod &lt;&gt; null then
					tmpForm.sendMsgWithParams(self.warningMethod, self.name, method.name,
								'Cannot handle InputType_Picture - pictureViewMethod property not set');
				endif;
			endif;

		elseif tmpText = PictureLoadText then
			if tmpBaseForm &lt;&gt; null then
				pic := tmpBaseForm.picLoadMethod();
				tmpCell.picture := pic;
			elseif self.pictureLoadMethod &lt;&gt; null then
				pic := self.form.sendMsg(self.pictureLoadMethod).Binary;
				tmpCell.picture := pic;
			else
				if self.warningMethod &lt;&gt; null then
					tmpForm.sendMsgWithParams(self.warningMethod, self.name, method.name,
								'Cannot handle InputType_Picture - pictureLoadMethod property not set');
				endif;
			endif;

		elseif tmpText = PictureExtractText then
			if tmpBaseForm &lt;&gt; null then
				tmpBaseForm.picExtractMethod(tmpCell.picture);
			elseif self.pictureExtractMethod &lt;&gt; null then
				self.form.sendMsgWithParams(self.pictureExtractMethod, tmpCell.picture);
			else
				if self.warningMethod &lt;&gt; null then
					tmpForm.sendMsgWithParams(self.warningMethod, self.name, method.name,
								'Cannot handle InputType_Picture - pictureExtractMethod property not set');
				endif;
			endif;

		elseif tmpText = PictureNoneText then
			tmpCell.picture := null;
		endif;
		tmpCell.text := null;

	elseif entRowTrans.inputType = InputType_ColourSelection then
		self.handleColourSelectChange(table, theRow);
	endif;
	
epilog
	if tmpCell &lt;&gt; null then
		delete tmpCell;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clearAttributes" id="26cc41eb-3865-40dc-9a4f-39fa22313004">
        <updating/>
        <source>clearAttributes() updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.rows := self.fixedRows;
	self.previousRow := 0;
	self.clear;
	self.picturesUsed := false;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="clearEntTableRowTransients" id="15ecb946-e259-4daa-ab00-7ff95fbe053a">
        <updating/>
        <source>clearEntTableRowTransients() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwer1	Initial creation

*/

vars
	changedColor,
	minRows,
	numRows,
	idx					: Integer;
	entRowTrans			: EntTableRowTransient;
begin
	numRows := self.rows;
	changedColor := self.hasChangedColor;
	
	minRows := self.fixedRows + 1;
	
	foreach idx in minRows to numRows do
		entRowTrans := self.accessRow(idx).itemObject.EntTableRowTransient;
		if entRowTrans = null then
			continue;
		endif;
		entRowTrans.originalValue:= self.accessCell(idx, ColumnValue).text;
		self.accessRow(idx).itemObject:=null;
		if self.changeMode = self.ChangeMode_All then
			if (self.accessCell(idx, self.ColumnValue).backColor = changedColor) then
				self.accessedCell.backColor := White;
			endif;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clearHasChanged" id="922a7b09-dc96-4674-8b00-25b1d4d20840">
        <updating/>
        <source>clearHasChanged() updating;
// ---------------------------------------------------------------------------
// Created:     27 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	changedColor,
	valueColumn,
	minRows,
	numRows,
	idx					: Integer;
	entRowTrans			: EntTableRowTransient;
	obj : Object;
begin
	numRows := self.rows;
	changedColor := self.hasChangedColor;
	
	minRows := self.fixedRows + 1;
	
	foreach idx in minRows to numRows do
		//epr TFS 47132 16/12/19
		obj := self.accessRow(idx).itemObject;
		if obj = null then
			return;
		endif;
		
		if not obj.isKindOf(EntTableRowTransient) then
			continue;
		endif;
		
		entRowTrans := self.accessRow(idx).itemObject.EntTableRowTransient;
		if entRowTrans = null then
			continue;
		endif;
		entRowTrans.hasChanged := false;
		entRowTrans.isOriginalValueSet := false;
		entRowTrans.originalValue := null;
		
		if self.changeMode = self.ChangeMode_All then
			if (self.accessCell(idx, self.ColumnValue).backColor = changedColor) then
				self.accessedCell.backColor := White;
			endif;
		endif;
	endforeach;

	self.hasChanged := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="clearMeasurementValues" id="eace8295-e502-43d5-9ac1-75cca9cb85e4">
        <updating/>
        <source>clearMeasurementValues() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	idx, maxRows : Integer;
	obj : Object;
	cell : JadeTableCell;
	ctrl : Control;

begin
	// we are clearing the values	
	maxRows := self.rows;

	foreach idx in topNonHeadingRow to maxRows do
		obj := self.accessRow(idx).itemObject;
		
		if (obj = null) 
		or (not EntTableRowTransient.hasInstance(obj)) then
			continue;
		endif;
		
		cell := self.accessCell(idx, ColumnValue);
		ctrl := cell.cellControl;
		if ctrl &lt;&gt; null and ctrl.name[1] &lt;&gt; '_' then
		   	// this is one of our controls
		   	if CMUI_MeasurementTable.hasInstance(ctrl) then
				ctrl.CMUI_MeasurementTable.setValue(null);
		   	endif;
		endif;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clearValues" id="79093d09-bf1e-47ec-a1a6-1aa984d0cab4">
        <updating/>
        <source>clearValues() updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
	maxRows	: Integer;
	obj		: Object;
	cell	: JadeTableCell;
	ctrl	: Control;
begin

	// we are clearing the values	
	maxRows := self.rows;

	foreach idx in topNonHeadingRow to maxRows do
		/* Don't use setValue() as it does more than necessary
		 and has changed to allow the display of '0' for numeric fields when the field value is zero
		//self.setValue(idx, null);
		*/

		//self.setValue(idx, null);

		obj := self.accessRow(idx).itemObject;
		
		if (obj = null) 
		or (not EntTableRowTransient.hasInstance(obj)) then
			continue;
		endif;
		
		cell := self.accessCell(idx, ColumnValue);
		// clear text
		if cell.text &lt;&gt; null then // this needs to be in else cell input types of combobox will crash if no null in combo box list
			cell.text := null;
			cell.alignment := Alignment_Left_Top;
			if self.optimiseRowHeight then
				// PAR 9317 
				self.optimiseHeightForRow(cell.inputType, idx, null);
			endif;
		endif;
		
		cell.picture := null;//&lt;&lt;--was leaving logo/ship pics so clear picture as well		
		// clear our controls	
		ctrl := cell.cellControl;
		if ctrl &lt;&gt; null 
		and ctrl.name[1] &lt;&gt; '_' then // This is NOT one of our controls.
		   	// this is one of our controls
		   	if ComboBox.hasInstance(ctrl) then
				ctrl.ComboBox.listObject := null;
	   		elseif TextBox.hasInstance(ctrl) then
		   		ctrl.TextBox.text := null;
			
		   	endif;
		endif;

	endforeach;
	
	self.clearHasChanged();

end;</source>
    </JadeMethod>
