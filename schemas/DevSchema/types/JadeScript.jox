    <JadeMethod name="sdlFindVGMwithCommsType" id="8edcc3ef-b9bc-4326-880f-2679af6aefa1">
        <updating/>
        <source>sdlFindVGMwithCommsType() updating;
/*

Purpose:	find a container which has non-null 		

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2017	jlgsl4	Initial creation for TFS 6563

*/

vars
	container : CM_Container;
	count : Integer;
	
begin
	app.initialize();
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	write "There are " &amp; CM_Container.instances.size.String &amp; " containers to examine";

	foreach container in CM_Container.instances discreteLock do
		count := count + 1;
		if count mod 10000 = 0 then
			write Tab &amp; "processed " &amp; count.String &amp; " containers ";
		endif;
		if container.id.String = "RJD10090310" then //ANR60003200 RUSS0001478 GLDU5559775 CNCU1518809
			//write "vgmCommsType is " &amp; container.myVGMDetails.vgmCommsType.String;
			//write "Terminal is " &amp; container.myTerminal.name.String;
			beginTransaction;
				container.myVGMDetails.setPropertyValue("vgmCommsType", "SM1");
				container.myVGMDetails.setPropertyValue("vgmDocumentDetails", "Batman.doc");
			commitTransaction;
			break;
		endif;
//		if container.myVGMDetails &lt;&gt; null then
//			if container.myVGMDetails.vgmCommsType &lt;&gt; null then
//				write container.id.String;
//			endif;
//		endif;
	endforeach;

epilog
	write "Finished B-)";	
end;
</source>
    </JadeMethod>
