    <JadeMethod name="noOutputReturned" id="fe046abb-1ead-4b46-9fee-76f7d953fe93">
        <source>noOutputReturned(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2010	#cnwdz2	 

*/

vars

begin	
	if self.allLogSummaryData.isEmpty() and 
	    self.allTrackedItems.isEmpty then  // PAR24002 - CCMS1108 - checks for log reports using tracked item type (in Report Maint form) were not being returned correctly.
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
