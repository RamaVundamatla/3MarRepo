    <JadeMethod name="getMoveMode" id="0dac9067-e741-4d6e-a89c-96224b476e4b">
        <source>getMoveMode(): Integer;
/*

Date		Who		Reason
28 May 2014	cnwer1	Initial creation PAR

*/

vars

begin
	return QUEUE_PLAN_ON_PICKUP;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPrimaryLocationId" id="f293c99e-fd80-4b84-a8a1-1ca458dd41b4">
        <source>getPrimaryLocationId(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2011	cnwrd1	Initial creation
24/04/2013		cnwcs5		par 30652 - remove resynch/resynchObject method calls

*/


vars
	lc	: CM_LocationsController;
begin
	
	if self.allLocationsControllers.isEmpty then
		return app.getErrorString(Autoplan);
	endif;
	
	lc := self.allLocationsControllers.first;

	if lc = null then
		return null;
	endif;

	return lc.getFullIdForTIForMode(QUEUE_MODE);

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="911f14aa-9c7e-422d-adac-d7292d28d3cc">
        <updating/>
        <source>setForCreate(_control: CMIF_MoveController; _moveType: Integer; arrayIndex: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2011	cnwrd1	Initial creation

*/


vars
	theTI : CM_TrackedItem;
	wle : CM_WorkListEntry;
	lc : CM_LocationsController;
	control : CMIF_MoveController;
	anFM : CM_FutureMove;
	source, target : String;
begin

	theTI := _control.myTrackedItem;
	wle := _control.myWorkListEntry;
	
	self.moveType := _moveType;
	
	//self.allLocationsControllers.clear;	
		
	theTI.setQueuedFutureMove(arrayIndex, self);
	self.myTerminal := self.myTrackedItem.myTerminal;		

	/*
	if _control.allToLocations.isEmpty then		
		//! Hmm, maybe this is a delete case?
		return;
	endif;*/
	
//	self.setLocations(_control.allToLocations);
	//_control.allToLocations.copy(self.allLocationsControllers);
	
	/*
	lc := _control.myToPrimaryLocation;
	if wle &lt;&gt; null then
		anFM := wle.myFutureMove; // PAR 8061
		if anFM &lt;&gt; null and anFM.isKindOf(CM_FutureMovePlanned) then // PAR 8061
			self.myFutureMovePlanned :=  anFM.CM_FutureMovePlanned; // PAR 8061
		endif; // PAR 8061
	endif;
	if self.myFutureMovePlanned = null then // PAR 8061
		self.myFutureMovePlanned := lc.getFutureMoveOfTypeForTI(PLANNING_MODE, TI_FutureMovePlannedOrDLR, self.myTrackedItem).CM_FutureMovePlanned;
	endif;*/
		
	theTI.refreshMyFutureLocations(QUEUE_MODE,null);

	control := _control;
	if wle = null then
		// see if the job has a wle for this TI.
		if control.jobForMove &lt;&gt; null then
			wle := control.jobForMove.getWLEForTI(theTI);
			control.setMyWorkListEntry(wle);
		endif;
	endif;

	if wle = null or control.isDirectorMove then
		// create a yard internal job/tasks for the RT queue.
		control.createYardInternalQueueJobPOP(self);
	endif;	
	
	if not control.isOverstowMove then
		self.setMyWorkListEntry(control.myWorkListEntry, false);			
	endif;
	// ### PAR 8712
	if wle &lt;&gt; null then
		if wle.locationTarget = null then

			source := wle.locationSource;
			//target := _control.getPrimaryLocationId();
			//target := control.myToPrimaryLocationString;

			wle.setLocations(source,target);		
		endif;
	endif;
		
end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="arrayIndex" type="Integer"/>
    </JadeMethod>
</Class>
