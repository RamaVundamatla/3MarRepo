    <JadeMethod name="setControlsForAddEdit" id="1d0097f5-9ef9-4cc3-9033-76e2dbec5b38">
        <updating/>
        <source>setControlsForAddEdit() updating;
//------------------------------------------------
// Created: 06 April 2006 By: cnwgd1
//------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm.SOP_TableMaintForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect2.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;	


	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;

		theForm.tblInput1.setFocus;
		theForm.tblInput1.gotFocus(theForm.tblInput1);	// sets case etc.	
		theForm.fldInput.initSheetBackColors();						
							
		if theForm.mulSelect1.visible then
			theForm.mulSelect1.setSelected(null);										
		endif;
		theForm.tblInput1.moveFirst();	
	
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_LoadingCompany);

		// PAR 12727
		if theForm.mulSelect1.visible then
			theForm.mulSelect1.setSelected(theForm.myProxyObject.CM_LoadingCompany.allContacts);										
		endif;
	endif;
	
	self.enableMulSelect1Contents();
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="fe0783af-3b53-4be9-a870-3326f5c73a88">
        <updating/>
        <source>setCtrlsForView() updating;
//------------------------------------------------
// Created: 06 April 2006 By: cnwgd1
//------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
begin
	//cnwmc5 - 17 Oct 2013 - PAR 32622
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput2.userInputEnabled := false;
	theForm.tblInput3.userInputEnabled := false;
	theForm.mulSelect2.userInputEnabled := false;
	theForm.mulSelect1.userInputEnabled := false;
	theForm.mulSelect3.userInputEnabled := false;
	theForm.mulSelect41.userInputEnabled := false;		
	theForm.mulSelect42.userInputEnabled := false;	      
	theForm.tblInput1.showRowByName(ETRow_IsNotAvailableForEntry, false);				  
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="f557f299-0736-4032-8f36-822797ca4996">
        <updating/>
        <source>setupThumbnailDetails() updating;
//------------------------------------------------
// Created: 06 April 2006 By: cnwgd1
//------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
	tmpCol : ObjectSet;
begin
  
 	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_DataTable);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_Loader);
	theForm.shtTblInput1.visible := true;


end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="9239e9c7-7222-4630-907a-396ed84f13e5">
        <updating/>
        <source>showThumbnail(pObj: CM_LoadingCompany) updating;
//------------------------------------------------
// Created: 06 April 2006 By: cnwgd1
//------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setTableFromObject(pObj, 'setTableFromObjectSpecial');

	theForm.tblInput1.setValueByName(ETRow_Code, pObj.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pObj.description);
	theForm.tblInput1.setValueByName(ETRow_IsNotAvailableForEntry, pObj.isNotAvailableForEntry);	
	theForm.mulSelect1.setSelected(pObj.allContacts);		
	self.disableMulSelect1Contents();	
end;</source>
        <Parameter name="pObj" type="CM_LoadingCompany"/>
    </JadeMethod>
</Class>
