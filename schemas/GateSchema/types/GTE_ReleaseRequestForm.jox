    <JadeMethod name="getTblDataXML" id="106c2c30-104b-470f-b88d-f8b27cdeb3f4">
        <updating/>
        <source>getTblDataXML(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed on	By			Reason
// ----------	----------	--------------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 Bulk release type is no longer translatable, replaced by string constants
//								Swap Ship and Packing order, to now match the new constant values
// 23/11/2011	cnwcs5		CCMS POL 2122 / par 28696 - new type Unknown
// 10 Feb 2015	NDL	Par 35650
vars
	tagStr, tmpStr, tmpTypeStr	: String;
begin
	tagStr := self.tblData.XMLTag_Table &amp; self.tblData.name;
	
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(BR_TYPE_ROAD_STR);								// PAR #27972
	xmlRoad := tmpTypeStr.trimCharacters(CrLf);
	
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(BR_TYPE_RAIL_STR);								// PAR #27972
	xmlRail := tmpTypeStr.trimCharacters(CrLf);
		
	//Added Ship, par 18525
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(BR_TYPE_SHIP_STR);								// PAR #27972
	xmlShip := tmpTypeStr.trimCharacters(CrLf);											// PAR #27972
	
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(BR_TYPE_ALL_STR);								// PAR #27972
	xmlAll := tmpTypeStr.trimCharacters(CrLf);				// cnwjre1 Oct 2014 from testing with all columns selected

	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(BR_TYPE_PACKING_STR);							// PAR #27972
	xmlPack := tmpTypeStr.trimCharacters(CrLf);				// cnwjre1 Oct 2014 from testing with all columns selected											// PAR #279772
	
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(BR_TYPE_UNKNOWN_STR);							// par 28696
	xmlUnknown := tmpTypeStr.trimCharacters(CrLf);											// par 28696
	
	tmpStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(tagStr);
	//PAR14117 The CrLf causes 1035 UHE in StringArrays so have to be specifically handled here to avoid this
	//tmpStr := tmpStr.trimCharacters(CrLf);
	
	self.xmlStrTblData := global.formatAsXMLPrefix(tagStr) &amp; tmpStr &amp; CrLf &amp; global.formatAsXMLSuffix(tagStr);
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="64ac6130-ce8f-4016-a892-28bf04be521b">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 07/02/2012	cnwcs5	par 28756
vars
	theXML 		: String;
	theGridArea : CMUI_GridArea;
	hideMacro 	: Boolean;
	imexStatus 	:CM_IMEXStatus;
begin

	theXML := inheritMethod();

	theXML := theXML &amp; global.formatAsXML(XML_USEFILTER,self.filterForCargo.Integer.String);
	theXML := theXML &amp; global.formatAsXML(XML_TYPE,self.cmbType.text);
	theXML := theXML &amp; global.formatAsXML(XML_SHOWTHUMB, self.tblThumb.visible.String);
	
	return theXML;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="200cac2a-69db-47db-8b80-c194d86d3afa">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed on	By			Reason
// ----------	----------	--------------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 Bulk release type is no longer translatable, replaced with string constants
// 23/11/2011	cnwcs5		CCMS POL 2122 / par 28696 - new type Unknown
// 07/02/2012	cnwcs5		par 28756 - refactoring
vars
	userWindow			: CM_UserWindow;
	theXML, theXMLValue : String;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	
	theXML := userWindow.xmlInfo;

 	theXMLValue 		:= theXML.cnEcGetTagValueOfName(XML_USEFILTER);
 	self.filterForCargo := false;
	
 	if theXMLValue &lt;&gt; null then
 		self.filterForCargo := theXMLValue.Integer.Boolean;
 	endif;

 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_TYPE);
	
	if theXMLValue &lt;&gt; null then
 		self.cmbType.text 	:= theXMLValue;
 		self.typeMode 		:= theXMLValue;
 		
		// ### if what they could see and what they can see now is different then change it, else they can see what they are not allowed to see.
 		if (theXMLValue = BR_TYPE_ROAD_STR and not self.canViewRoad) or								// PAR #27972
			(theXMLValue = BR_TYPE_RAIL_STR and not self.canViewRail) or							// PAR #27972
			(theXMLValue = BR_TYPE_PACKING_STR and not self.canViewPacking) or 						// PAR #27972
			(theXMLValue = BR_TYPE_SHIP_STR and not self.canViewShip) or							// PAR #27972
			(theXMLValue = BR_TYPE_UNKNOWN_STR and not self.canViewUnknown) then	// par 28696
 			
			if self.canViewRoad then
 				self.typeMode := BR_TYPE_ROAD_STR;														// PAR #27972
 			elseif self.canViewRail then
 				self.typeMode := BR_TYPE_RAIL_STR;														// PAR #27972
 			elseif self.canViewPacking then
 				self.typeMode := BR_TYPE_PACKING_STR;													// PAR #27972
			elseif self.canViewShip then
				self.typeMode := BR_TYPE_SHIP_STR;														// PAR #27972
			elseif self.canViewUnknown then				// par 28696
				self.typeMode := BR_TYPE_UNKNOWN_STR;	// par 29696
 			endif;
 		endif;
 	endif;
 	
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_SHOWTHUMB);
	
	if theXMLValue = null then	//first time
 		self.hideShowThumbnail();
 	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="handleTblDataDblClick" id="3cf1a06b-a8b9-4824-9e00-3c8f8dd8fc79">
        <updating/>
        <source>handleTblDataDblClick(_row: Integer) updating;
//----------------------------------------------------------------
//	Created:	04 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 14 June 2023 navhl20 Bug 58634: MTN - Release by Type option should be disabled if there is no VAS subscription 
vars
	obj			: CM_Object;
begin
	inheritMethod(_row);

	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	obj := self.tblData.accessRow(self.tblData.row).itemObject.CM_Object;
	if obj.isKindOf(CM_BulkRelease) then
		if obj.CM_BulkRelease.isForBookingRef() and obj.CM_BulkRelease.type &lt;&gt; BR_TYPE_PACKING then	// editing enhanced booking request, instead of bulk release. PAR 20296, Sep 2009 // cnwrd1 ccms pol 2103 par 27856 14.7.2011 but not if we are a packing release
			self.myAssistant.GTE_Assistant.doAddEditBookRequest(obj.CM_BulkRelease.myBookingRefStock);
		else
			self.myAssistant.releaseRequestUpdate(obj.CM_BulkRelease, self.myMasterMenuAction,null);					//14.6.2023 navhl20 #58634
		endif;
	elseif obj.isKindOf(CM_ReserveSelection) then
		self.myAssistant.releaseRequestUpdate(obj.CM_ReserveSelection.myReserveHeader, self.myMasterMenuAction,null);	//14.6.2023 navhl20 #58634
	endif;
	
end;</source>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hideThumbnailRow" id="7e7d8e23-beb0-4022-bb11-053d48ec0984">
        <source>hideThumbnailRow(_table :CM_ThumbnailTable input; _rowName :String; _entTableDef :EntTableDef; _locale :CM_Locale) protected;
/*
Purpose:	Hide row in thumbnail table based on ent table row name

Date		Who		Reason
07 February 2012	cnwcs5	Initial creation - par 28756
*/
vars
	entRow	:EntTableRow;
begin
	entRow  := _entTableDef.getEntTableRow (_rowName);
			
	if entRow &lt;&gt; null then
		_table.hideRowFromHeading (entRow.getHeading (null, null, _locale));
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_ThumbnailTable" usage="input"/>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <Parameter name="_locale" type="CM_Locale"/>
    </JadeMethod>
