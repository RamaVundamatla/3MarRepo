    <JadeMethod name="doBtnDeleteInput4" id="0303a7a7-807b-43d4-af4b-de50420000f0">
        <source>doBtnDeleteInput4();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	table : CM_DataTable;
	obj : Object;
	pilotExempt : HMS_PilotExemptionCertificate;
	master : HMS_Master;

begin
	
	table := self.myForm.tblShtData4;
	
	if table.row &gt; table.fixedRows then
		obj := table.accessRow (table.row).itemObject;
		if obj.isKindOf( HMS_PilotExemptionCertificate ) then
			pilotExempt := obj.HMS_PilotExemptionCertificate;
		endif;
	endif;
	
	if pilotExempt = null then
		return;
	endif;
	master := pilotExempt.myMaster;

	
	app.myTrxDA.trxDeletePilotExemptCert(pilotExempt, app.myPassport);
	
	self.setTblShtData4( master );
	
	self.myForm.tblDataRefresh( master );	// 13/09/2012 cnwar2 #30239
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnEditInput4" id="d8285ef4-2afc-4a32-b8e0-b7cd094d32ed">
        <source>doBtnEditInput4();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	table : CM_DataTable;
	obj : Object;
	pilotExempt : HMS_PilotExemptionCertificate;
	form : CMUI_HMSPilotExemptCertMaint;

begin
	
	table := self.myForm.tblShtData4;
	
	if table.row &gt; table.fixedRows then
		obj := table.accessRow (table.row).itemObject;
		if obj.isKindOf( HMS_PilotExemptionCertificate ) then
			pilotExempt := obj.HMS_PilotExemptionCertificate;
		endif;
	endif;
	
	if pilotExempt = null then
		return;
	endif;
	
	form	:=	app.loadForm(CMUI_HMSPilotExemptCertMaint, CMUI_Assistant, false, false, true, self.myForm.myTerminal, null).CMUI_HMSPilotExemptCertMaint;
	if form = null then
		return;
	endif;
	
	form.setMyPilotExemptionCertificate( pilotExempt );
	form.showModal();
	
	self.setTblShtData4( pilotExempt.myMaster );
	
	self.myForm.tblDataRefresh( pilotExempt.myMaster );	// 13/09/2012 cnwar2 #30239

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnNewInput4" id="95b160d8-05f9-4e11-9f6a-d0614808c4e3">
        <source>doBtnNewInput4();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	form : CMUI_HMSPilotExemptCertMaint;
	obj : Object;
	master : HMS_Master;
	harbour : HMS_Harbour;

begin

	obj := self.myForm.SOP_HMS_TableMaintForm.myCurrentObject.HMS_Master;
	if obj = null then
		return;
	endif;
	master := obj.HMS_Master;
	
	harbour := self.myForm.SOP_HMS_TableMaintForm.myHarbour;
	if harbour = null then
		return;
	endif;

	form :=	app.loadForm(CMUI_HMSPilotExemptCertMaint, CMUI_Assistant, false, false, true, self.myForm.myTerminal, null).CMUI_HMSPilotExemptCertMaint;
	if form = null then
		return;
	endif;
	
	form.setMyMasterAndHarbour( master, harbour );
	form.showModal();
	
	self.setTblShtData4( master );
	
	self.myForm.tblDataRefresh( master );	// 13/09/2012 cnwar2 #30239
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuContext1Click" id="432011cd-87d1-4c19-8e9d-d1a4109b58c0">
        <updating/>
        <source>doMnuContext1Click(theMenuItem: MenuItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 May 2012	cnwndl1	Initial creation

*/

vars
	theForm 	: SOP_TableMaintForm;
	pilotExempt : HMS_PilotExemptionCertificate;

begin

	theForm := self.myForm;
	pilotExempt := theMenuItem.userObject.HMS_PilotExemptionCertificate;
	
	if pilotExempt &lt;&gt; null and pilotExempt.hasAudits then
		app.viewAuditForm(pilotExempt, theForm.myAssistant.class, theForm.myTerminal);
	endif;

epilog

end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="3f62d6cb-bac7-487c-8b60-927f33a669d3">
        <source>doResize();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2012	cnwndl1	Initial creation

*/

vars

	theForm : SOP_HMS_TableMaintForm;
	toolbar	: CMUI_Toolbar;
	btn : Button;
	prevBtn : Button;
	bLeft, bTop, bWidth, bHeight : Real;

begin
	inheritMethod();
	
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	toolbar := theForm.frmShtInput4Btns;
	
	bWidth := 75;
	bTop := 3;
	bHeight := 20;
	bLeft := ( toolbar.width - bWidth) - 5;
	btn := theForm.btnDeleteInput4;
	btn.parent := toolbar;
	btn.move( bLeft, bTop, bWidth, bHeight);
	prevBtn := btn;
	
	bLeft := ( prevBtn.left - bWidth) - 5;
	btn := theForm.btnEditInput4;
	btn.parent := toolbar;
	btn.move( bLeft, bTop, bWidth, bHeight);
	prevBtn := btn;
	
	bLeft := ( prevBtn.left - bWidth) - 5;
	btn := theForm.btnNewInput4;
	btn.parent := toolbar;
	btn.move( bLeft, bTop, bWidth, bHeight);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="4f4008d4-d177-4522-a24c-9dbf9010bfbb">
        <updating/>
        <source>doSave(): Boolean updating;
//-----------------------------------------------------------------------
//	Created:	28 July 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	pxyMaster	: HMS_Master;
	theForm 	: SOP_HMS_TableMaintForm;
	table		: CM_EntryTable;
begin

  	theForm := self.myForm.SOP_HMS_TableMaintForm; 
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_Master transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyMaster := theForm.myProxyObject.HMS_Master;
	table := theForm.tblInput1;
	table.setObjectFromTable(pxyMaster, null, false);
	pxyMaster.setProxy(theForm.myHarbour);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(pxyMaster, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyMaster, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="39ad233a-e43e-42be-b9cd-b7f5a1892a81">
