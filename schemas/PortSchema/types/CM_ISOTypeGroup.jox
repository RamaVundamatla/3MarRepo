    <JadeMethod name="checkEntriesDict" id="5901a8f4-112f-4ba5-a746-be21c8f41449">
        <source>checkEntriesDict();

vars
	isoType:CM_ISOType;
	object:Object;
begin
	if entries.size &lt;&gt; allISOTypes.size then
		app.writeStatement( "ISOType size mismatch by " &amp; (entries.size - allISOTypes.size).String);
	endif;
	foreach object in entries do
		isoType := object.CM_ISOType;
		if not allISOTypes.includes(isoType) then
			app.writeStatement( "ISOType " &amp;  isoType.code &amp; " is not in old entries for " &amp; code &amp; ".");
		endif; 
	endforeach;
	foreach isoType in allISOTypes do
		if not entries.includes(isoType) then
			app.writeStatement("ISOTypee " &amp;  isoType.code &amp; " is not in new entries for " &amp; code &amp; ".");
		endif; 
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcGetDuplicate" id="dc75f3a9-3132-47f4-b20b-9c07904b23eb">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	code : String;
	group : CM_ISOTypeGroup;

begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).String; 
	
	if code &lt;&gt; null then
		group := app.myRoot.allISOTypeGroups.getAtKey( code );
	endif;

epilog

	return group;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="doObjectVolatilityConversion" id="dfcc45d6-b948-4d14-a97d-c1b9236409a5">
        <updating/>
        <source>doObjectVolatilityConversion(_converter: CM_ObjectVolatilityConverter input; _logIndent: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 Jun 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars
	indent			: Integer;
	
begin
	//_converter.logMessage("Processing collections for " &amp; self.String, _logIndent);			navma1 14.01.2026
	indent := _logIndent + 1;

	inheritMethod(_converter, indent);

	_converter.doChangeVolatilityOfObject(self.allISOTypes, _logIndent);
	
	//_converter.logMessage("Finished processing collections for " &amp; self.String, _logIndent);  navma1 14.01.2026
	
	
epilog

end;</source>
        <Parameter name="_converter" type="CM_ObjectVolatilityConverter" usage="input"/>
        <Parameter name="_logIndent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="2dae161c-26b1-446a-86ad-473664626f1a">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     18 April 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txt		: String;
	tmpStr	: String;
	isoType  : CM_ISOType;
	isoGroup : CM_ISOTypeGroup;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach isoType in self.allISOTypes do
		if tmpStr = null then
			tmpStr := isoType.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; isoType.code;
		endif;
	endforeach;
	txt := txt &amp; 'Selected ISOTypes' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	//cnwrd1 par 30414 25.9.2012
	tmpStr := null;
	foreach isoGroup in self.allSubstitutingISOGroups do
		if tmpStr = null then
			tmpStr := isoGroup.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; isoGroup.code;
		endif;
	endforeach;
	
	txt := txt &amp; 'Selected ISO Group Substitutes' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="4b93e9ab-579e-4c51-aa77-703994b24ab8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2014	cnwndl1	Initial creation

*/

vars

	type : String;					
	str	: String;					
	value : Decimal [23,10];

begin

	if _attrName.isMeasurementType then											
		// _attrName will be formatted as WTRow_&lt;real ent row name&gt;_&lt;weight unit&gt;	
		_attrName.getRowNameMeasureType(str, type);									
		return self.getMeasurementStringForAttrib(str, type, _short);				
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLengthInFeet" id="f624bd3c-3914-4f27-bf73-b17707aca331">
        <source>getLengthInFeet():Integer;
// ---------------------------------------------------------------------------
// Created:     06 May 2010 by cnwcs5
// Purpose:     return 20, 30, 40 etc for first ISO type in collection
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	iso : CM_ISOType;
begin
	iso := self.allISOTypes.first;
	
	if iso = null then 
		return 0;
	endif;
	
	return iso.getLengthInFeet;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLengthInUnitsForWagon" id="4126bd26-bc2e-454b-9c7b-83c6b7b1db32">
        <source>getLengthInUnitsForWagon():Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 May 2010	cnwndl1	Initial creation	Par 24064

*/

vars

begin

	if self.is20ftLong() then 
		return 2;
	elseif self.is40ftLong() then 
		return 4;
	elseif self.is30ftLong() then 
		return 3;
	elseif self.is45ftLong() then   
		return 5;
	elseif self.is53ftLong() then 
		return 6;
	else
		return 1;
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="4ef6e778-ac53-4bd5-8f44-e2b0c481f3e9">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin

	if _attrName = ETRow_MaxTareWeight then
		return app.convertMeasurementForDisplay(_measureType,self.maxTareWeight );
	elseif _attrName = ETRow_MaxTotalWeight then
		return app.convertMeasurementForDisplay(_measureType,  self.maxTotalWeight);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
