    <JadeMethod name="comboBoxBookingRef" id="2ce76e07-8246-494e-9f24-5b469fdf9833">
        <source>comboBoxBookingRef(_comboboxObj:CMUI_ComboBoxObject input; _bookingRefObj:CM_BookingRef);
// --------------------------------------------------------------------------------
// Created:		30 April 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//	#26289		cnwvu1		Method recoded ot deal with Active and Pending bookings and using an iterator.
//							There was 14025 exception - bookings reached 32000 and failed to be populated onto the combobox.
//							Now we are displaying only Active and Pending bookings, plus the current booking on a selected release.
// --------------------------------------------------------------------------------
vars
	reachedMaxSize	: Boolean;
	iter			: Iterator;
	booking			: CM_BookingRef;
	terminal		: CM_Terminal;
	bookingStatus	: Integer;
	isFound			: Boolean;
	
begin

	on Exception do app.handleUE14025(exception, reachedMaxSize);	//#26289 26/01/2011. If number of bookings reached maximum size of allowable entries for the combobox, it will be trapped and a warning will be raised for a user.
	
	//_comboboxObj.listCollection(self.myTerminal.allBookingRefsByRef, false, 0);	//commented by #26289 26/01/2011. Now, we are gopingto use iterator to filter Active and Pending bookings.


	_comboboxObj.clear();
	
	terminal := self.myTerminal;
	
	iter	:= terminal.allBookingRefsByStatusRef.createIterator();
	
 	terminal.allBookingRefsByStatusRef.startKeyGeq(BOOKING_REF_PENDING, null, iter);

	while iter.next(booking) do
	
		bookingStatus := iter.getCurrentKey(1).Integer;
	
		if (bookingStatus &lt;&gt; BOOKING_REF_PENDING) and (bookingStatus &lt;&gt; BOOKING_REF_ACTIVE) then
			/*	BOOKING_REF_PENDING = 0
				BOOKING_REF_ACTIVE = 1*/
			break;
		endif;
	
		if booking = _bookingRefObj then
			isFound := true;
		endif;
		
		_comboboxObj.addItemObject(booking.bookingReference, booking);
	
	endwhile;
	
	
	if _bookingRefObj &lt;&gt; null then
		if (not isFound) then
			if reachedMaxSize then	//Exception occurred, i.e. there are 32000 items reached, it would be impossible to add 32001st item.
				_comboboxObj.removeItem(_comboboxObj.listCount);		// need to remove the last item so we can add one more. 
			endif;
			_comboboxObj.addItemObject(booking.bookingReference, booking);
		endif;
		_comboboxObj.setObject(_bookingRefObj);
	endif;

	if reachedMaxSize then
		app.msgBox(app.getErrorString(NumberOfBookingsReachedMaxSize), app.getErrorString(Bookings), MsgBox_Exclamation_Mark_Icon);
	endif;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_comboboxObj" type="CMUI_ComboBoxObject" usage="input"/>
        <Parameter name="_bookingRefObj" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="comboBoxBookingRefStatus" id="0246c12c-46ac-4a82-a869-2a9ee5d637b8">
        <source>comboBoxBookingRefStatus(_comboboxObj:CMUI_ComboBox input; _status:Integer);
// --------------------------------------------------------------------------------
// Created:		27 May 2009 by cnwdad1
//
// Purpose:		Populates the specified combobox control with Booking Ref Status codes.
//
// Parameters:	_comboboxObj - A reference to the combobox control.
//				_status - The default status to set the combobox to.
//
// Returns:		The populated combobox control.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_comboboxObj.clear();					//+cnwml2 PAR20815
	
	_comboboxObj.cnEcAddItemDataObject(app.bookingRefStatusEnumToString(BOOKING_REF_ACTIVE), BOOKING_REF_ACTIVE, null);
	_comboboxObj.cnEcAddItemDataObject(app.bookingRefStatusEnumToString(BOOKING_REF_ARCHIVED), BOOKING_REF_ARCHIVED, null);
	_comboboxObj.cnEcAddItemDataObject(app.bookingRefStatusEnumToString(BOOKING_REF_CLOSED), BOOKING_REF_CLOSED, null);
	_comboboxObj.cnEcAddItemDataObject(app.bookingRefStatusEnumToString(BOOKING_REF_PENDING), BOOKING_REF_PENDING, null);
	
	_comboboxObj.cnEcSetItemData(_status);
end;</source>
        <Parameter name="_comboboxObj" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
