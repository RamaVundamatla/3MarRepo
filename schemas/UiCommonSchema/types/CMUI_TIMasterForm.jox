    <JadeMethod name="doRefresh" id="f9b1a4f3-1dbb-4ee7-8c1d-f7d3410fcc29">
        <updating/>
        <source>doRefresh() updating, protected;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars
		idx,
	fixed,
	numRows : Integer;
	obj : CM_Object;
	col : CM_ObjectSet;
	invalidObj : Boolean;
	theTable : CM_DataTable;
begin
	inheritMethod();
		
	on Exception do app.handleDeletedObject(exception, obj , invalidObj);

	theTable := self.tblData;
	
	


	// get all the objects displayed in the table
	create col transient;
	numRows := theTable.rows;
	fixed := theTable.fixedRows + 1;
	foreach idx in fixed to numRows do
		obj := theTable.accessRow(idx).itemObject.CM_Object;
		if obj &lt;&gt; null then
		//and global.isValidObject(obj) then
			col.add(obj);
		endif;
	endforeach;

	// This method will clear the table and display the saved col
	//self.displaySelectorResults(col, self.filterCargoTypeId);
	
	if self.isWagonMaster then	// 03 Jul 2009	NDL	CCMS 1067
		self.displayWagonMasters( col );
	else
		self.displayTiMasters( col );
	endif;

	
epilog
	delete col;	
end;</source>
        <access>protected</access>
    </JadeMethod>
