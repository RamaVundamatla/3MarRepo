    <JadeMethod name="validateMasterTI" id="a286fb36-6378-4df7-9f0e-1a525a59e445">
        <updating/>
        <source>validateMasterTI(_master: CM_TIMaster; _passport: CM_Passport) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2009	cnwjk3	Initial creation

*/

vars
	masterGenerator : CM_TIMasterGenerator;
	tiGenDesc,
	masterGenDesc	: String;
begin
	if _master = null then 
		return;
	endif;
	inheritMethod(_master, _passport);
	masterGenerator := _master.CM_TIMasterGenerator;
	if self.myGeneratorType &lt;&gt; masterGenerator.myGeneratorType then
		if self.myGeneratorType = null then
			tiGenDesc :=   app.getErrorString(Null);
		else
			tiGenDesc := self.myGeneratorType.code;
		endif;
		if masterGenerator.myGeneratorType = null then
			masterGenDesc :=  app.getErrorString(Null);
		else
			masterGenDesc := masterGenerator.myGeneratorType.code;
		endif;
		app.raiseCMWarning3(WARN_FLEETFILE_DISCREP,"Generator Type for " &amp; self.id, tiGenDesc, masterGenDesc,"",null,self);		
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_master" type="CM_TIMaster"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateMyGeneratorType" id="e7dfa87d-a5e7-4efe-84c3-7667f704fce6">
        <source>validateMyGeneratorType( _control : CMIF_TIUpdateController ) protected;
/* ---------------------------------------------------------------------------
Created:	14 October 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	realGen	: CM_Generator;
	
begin

	if self.myGeneratorType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Generator_type), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Generator_type), null, null); // cnwdb2	PAR 35364
		return;
	endif;

	//self.inspectModal;
	realGen := app.myProxyManager.getRealObject(self).CM_Generator;
	
	//when changing generator type, the generator shouldn't be attached or connected
	if realGen &lt;&gt; null then // during create 'we' are transient without a real
		if self.myGeneratorType &lt;&gt; realGen.myGeneratorType then
			if realGen.isGeneratorAttachedToParent() then
				app.raiseCMException2( ERR_ChangeGeneratorType, realGen.myGeneratorType.getDisplayDetails(null), realGen.id, app.getErrorString(Generator_type), _control.myUserObject );
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_TIUpdateController"/>
    </JadeMethod>
