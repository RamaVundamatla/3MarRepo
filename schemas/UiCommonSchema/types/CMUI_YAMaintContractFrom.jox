    <JadeMethod name="doSetupCriteriaFrames" id="178fa1cd-d037-4369-adb4-f71f57963edf">
        <updating/>
        <source>doSetupCriteriaFrames()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2023 navtnr20	TFS CR 55646  Task 55666: UI - Contracts Criteria

*/

vars

	opCriteria: CM_YACriteriaArray;
	criteriaType: CM_YACriteriaType;
	allCriteria : CMIF_Array;
	criteria : CM_YACriteria;
	proxyCriteria : CM_YACriteria;
	
begin

	self.allOperationalCriteria.purge();
	self.allTemplateCriteria.purge();
	
	create opCriteria transient;
	foreach criteriaType in app.myRoot.allYACriteriaTypes do
		if allCriteria &lt;&gt; null and allCriteria.size &gt; 0 then
			criteria:=self.getCriteriaOfTypeFromTI(allCriteria,criteriaType.type);
		endif;
		create proxyCriteria transient;
		if criteria = null then
			proxyCriteria.setProxy(criteriaType, "", "");			
		else
			proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
			opCriteria.add(criteria);
		endif;
		self.allOperationalCriteria.add( proxyCriteria.getTransient());
	endforeach;

	if self.myObjectMatchCriteria &lt;&gt; null then
		foreach criteria in self.myObjectMatchCriteria.allCriteria do
			create proxyCriteria transient;
			proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
			self.allTemplateCriteria.add( proxyCriteria.getTransient() );
		endforeach; 
	endif; 
	
	self.populateCriteriaFrames(true);
	
epilog

	if allCriteria &lt;&gt; null then
		allCriteria.purge();
		delete allCriteria;
	endif;
	
	delete opCriteria;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="formatDescription" id="5a4d1a12-7288-421a-9231-3754f9400336">
        <source>formatDescription();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2023 navtnr20	TFS CR 55646  Task 55666: UI - Contracts Criteria

*/

vars
	criteriaCtrl	: CMUI_YACriteriaCntl;
	criteriaValue	: Any;
	i				: Integer;
	groupName		: String;
	yaTemplate		: CM_YATemplate;
	bValue 			: Any;

	yaConfig: CM_YAConfig;
	yaIMEXConfig: CM_YAIMEXConfig;
	yaCriteriaType : CM_YACriteriaType;

	term : CM_Terminal;
	
	existingName : String;
	
begin
	if self.mode then   // ### TFS BUG 56908 15MAR2023 NAVAB1 is overriding the manually entered description
		return;
	endif;

	term := self.getTerminal();
	
	if self.myYardAllocation &lt;&gt; null and self.txtDescription.text.trimBlanks &lt;&gt; null then
		existingName := self.myYardAllocation.description;
	endif;

	if existingName &lt;&gt; null then//09 Jan 2016	NDL	TFS 3174
		groupName := existingName;
		
	else
		while true do
			i := i + 1;
			criteriaCtrl := self.frmCriteria.getControl(i);
			if criteriaCtrl = null then
				break;
			endif;
			if criteriaCtrl.visible then
				criteriaValue := criteriaCtrl.getDisplayForGroupNameNumbers();
				if criteriaValue &lt;&gt; null then
					bValue := criteriaCtrl.getValue();
					if bValue &lt;&gt; null then
						if (bValue &lt;&gt; criteriaValue and bValue.Integer &lt;&gt; CM_YADataBoolean.VALUE_FALSE) 
						or	bValue = criteriaValue then
							if groupName = "" then 
								groupName := criteriaValue.String; 
							else
								groupName := groupName &amp; " " &amp; criteriaValue.String;
							endif;
						endif;
					endif;
				endif;
			endif;
		endwhile;
	endif;

	
	txtGroupName.text := groupName;
	
	yaTemplate := cmbYATemplate.listObject.CM_YATemplate;

	if yaTemplate = null then
		txtDescription.text := groupName;
	else
		txtDescription.text := groupName &amp; " - " &amp; yaTemplate.code;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCriteriaAllCMIF" id="eeffac90-ac19-4acb-8bd0-a49a7b7f9392">
        <source>getCriteriaAllCMIF(_cmifArray: CMIF_Array input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2023 navtnr20	TFS CR 55646  Task 55666: UI - Contracts Criteria

*/

vars
	cmifCriteria 	: CMIF_YACriteriaPriority;
	criteria 		: CM_YACriteria;
	criteriaCtrl	: CMUI_YACriteriaCntl;
	i				: Integer;
	objSet			: CM_ObjectSet;
	strArray		: CnStringArray;
	value			: String;
begin

	// Because criteria might be added and some deleted we will mark all existing as DELETED and then next 
	//		go through what is on the screen and those that are still used we will mark as CHANGED and the rest as CREATED.
	//  Create transient maintenance objects for all existing criteria and mark for delete action

	if self.myObjectMatchCriteria &lt;&gt; null then
		foreach criteria in self.myObjectMatchCriteria.allCriteria do
			cmifCriteria := criteria.getTransient();
			cmifCriteria.setFlag(false, false, true);	// set to be DELETED
			_cmifArray.add(cmifCriteria);
		endforeach;
	endif;

	//  For each criteria control - update/add transient maintenance object
	while true do
		i := i + 1;
		criteriaCtrl := self.frmCriteria.getControl(i);
		if criteriaCtrl = null then
			break;
		endif;
		if criteriaCtrl.visible and criteriaCtrl.hasValue() then
			value := criteriaCtrl.getValue().String;
			self.getCriteriaSingleCMIF( _cmifArray, criteriaCtrl.getCriteriaType(), value ); // decide what is to be CHANGED or CREATED
		endif;
	endwhile;

	
epilog
	delete objSet;
	delete strArray;
end;</source>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
    </JadeMethod>
