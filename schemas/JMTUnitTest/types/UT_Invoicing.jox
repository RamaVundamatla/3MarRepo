    <JadeMethod name="createStorageTransactions12" id="3aa17a57-066d-4075-929a-b1badf13518d">
        <source>createStorageTransactions12(realTI : CM_TrackedItem input; transDate : Date);
// 10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
//28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
vars
	transParams: CMIF_StorageTransController;
	tranTS	: TimeStamp;
	date	: Date;
begin

	// create storage transaction for given date
	create transParams transient;
	transParams.type := TRANS_TYPE_STORAGE;
	transParams.noCharge := false;
	transParams.userId := "CNWUT1";
	transParams.isManual := true; // NAVAB1 23APR2024 - FIXING UTs
	
	date := transDate;
	if realTI.id = "GENL2X22331" or
	   realTI.id = "GENL2X22334" or
	   realTI.id = "GENL2X22335" then
		date := date - 2;
	endif;
	beginTransaction;
	tranTS.setDate(date);
	transParams.dateTime := tranTS;
	realTI.evaluateFreeStorageDays(null,true); //10/09/2023 navmv20 CR 58250 Task 58252	//28.05.2024 navma1 #64224
	realTI.createTransaction(transParams, app.myPassport);
	commitTransaction;
	
	if realTI.id = "GENL2X22331" or
	   realTI.id = "GENL2X22334" or
	   realTI.id = "GENL2X22335" then
		date := transDate;
		beginTransaction;
		tranTS.setDate(date);
		transParams.dateTime := tranTS;
		realTI.evaluateFreeStorageDays(null,true); //10/09/2023 navmv20 CR 58250 Task 58252	//22.05.2024 navma1 #64224
		realTI.createTransaction(transParams, app.myPassport);
		commitTransaction;
	endif;


epilog
	delete transParams;
end;</source>
        <Parameter name="realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="transDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="createStorageTransactions13" id="1fcc50b6-dbc9-478b-8171-3b284adb6b75">
        <source>createStorageTransactions13(realTI : CM_TrackedItem input) : CM_TITransaction;
// ---------------------------------------------------------------------------
// Created:     Feb 2010 by cnwjre1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
 // ### JIRA 35228 11JUL2025 NAVAB1 return the new transaction
vars
	transParams: CMIF_StorageTransController;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate : Date;
	trans : CM_TITransaction;
begin
		
	// ##################
	tranDate.setDate(1,5,2010);
	tranTS.setDate(tranDate);
	foreach tran in realTI.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	

	create transParams transient;
	transParams.type := TRANS_TYPE_STORAGE;
	transParams.noCharge := false;
	transParams.userId := "NAVAB1";
	transParams.isManual := true; // NAVAB1 23APR2024 - FIXING UTs
	
	beginTransaction;
	tranDate.setDate(23,5,2010);
	tranTS.setDate(tranDate);
	transParams.dateTime := tranTS;
	trans := realTI.createTransaction(transParams, app.myPassport);
	commitTransaction;
	
	return trans;
epilog

	delete transParams;
end;</source>
        <Parameter name="realTI" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
