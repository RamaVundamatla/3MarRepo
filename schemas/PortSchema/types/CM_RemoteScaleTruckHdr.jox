<Class name="CM_RemoteScaleTruckHdr" id="299ce31c-edff-4bd0-acb4-c9749176b1e2">
    <superclass name="CM_RemoteDataHdr"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Scale Truck&lt;/display&gt;</text>
    <DbClassMap file="remoteDataProcessing"/>
    <JadeMethod name="getDescription" id="07a430e2-a83e-40fa-8669-48b4bded034b">
        <source>getDescription(): String;

vars

begin
	return 'Scaling';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMessageResponseType" id="83b726bd-89ea-44bc-a57e-e770d97a9325">
        <source>getMessageResponseType(): String;

vars

begin
	return CM_RemoteDataManager.SCLTRUCKRSP;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processExternal" id="c040679f-b1a0-4b9b-95f7-12d8099b5430">
        <updating/>
        <source>processExternal(_parseAgent: CM_RemoteParseAgent io): String updating;

vars

	response		: String;
	err				: Integer;
	errTxt			: String;
	realRemoteHdr	: CM_RemoteDataHdr;
	headerCast		: CM_RemoteDataHdr;

begin
	
	response := inheritMethod(_parseAgent);
	if response = null then
		if _parseAgent.createScaleTruckDetail(self) then
			app.myTrxCA.trxCreateRemoteData(self, realRemoteHdr, true, app.myPassport);
			if app.myPassport.trxCompletedOK then
				return self.doBuildMessage(self.xmlResponse(err, errTxt));	
			endif;
		endif;			
		response := app.getErrorString1(Err_XML, 'scaling');
		return self.doBuildMessage(self.xmlResponse(Err_XML , response));
	endif;
	headerCast := self;
	return self.doBuildMessage(self.xmlDefaultResponse(headerCast, Err_XML , response));
end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="runProcess" id="1328caa4-a30c-4a1a-8013-67c36bac25c4">
        <source>runProcess(_errorSet : CM_ErrorSet input; _isBackGround : Boolean) : Boolean;

vars

	scaleDetail					: CM_RemoteDataDtl;
	

begin

	foreach scaleDetail in self.allRemoteDataDtl where not scaleDetail.isProcessed do
		scaleDetail.CM_RemoteScaleTruckDtl.doScaleJob(_errorSet);
		process.sleep(2000);
	endforeach;
	return inheritMethod(_errorSet, _isBackGround);

end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_isBackGround" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
