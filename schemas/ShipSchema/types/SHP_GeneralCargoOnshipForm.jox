    <JadeMethod name="doClonedMenuClickSpecial" id="9fce3296-ab8b-4b6e-8e24-36547d5838fe">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2015	cnwndl1	Initial creation	Par 37011

*/

vars

	obj	: Object;
	ti : CM_TrackedItem;
	realTiSet : CM_TISet;
	taskFormName : String;
	taskFormNameLength : Integer;
	passedAction : Integer;

begin
	
	taskFormName := CMUI_TasksForm.name;
	taskFormNameLength := taskFormName.length;
	if menuItem.helpKeyword.length &gt; taskFormNameLength and menuItem.helpKeyword[1:taskFormNameLength] = taskFormName then
		passedAction := menuItem.helpKeyword[taskFormNameLength + 2:1].Integer;
		create realTiSet transient;
		ti  := menuItem.userObject.CM_TrackedItem;
		if ti = null then
			return;
		endif;
		realTiSet.add(ti);
		self.myAssistant.showTasksForm (ti, realTiSet, true, passedAction );
		return;
	endif;

	inheritMethod(menuItem);

epilog

	delete realTiSet;
	
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doComboCargoBuild" id="aab55197-b702-4ede-ac9f-95448e86e75f">
        <source>doComboCargoBuild()protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2010	cnwmd1	Initial creation
27/04/2010	cnwmh5	PAR 23943 - Don't default to Container, all cargo types need to be selected
*/

vars

	aCargoType : CM_CargoType;
	idx : Integer;
	object			: Object;
	terminalArea	: CM_TerminalArea;
	cargoTypeDict 	: CM_CargoTypeByAbbrDict;
	cargoBOLType	: CM_CargoBOLType;
	anArray : ObjectArray;
begin
	self.lstCargoTypes.rows := 0;
	self.lstCargoTypes.zOrder(1);
// 23596 show cargo types from terminal, not all available.  As term.allCargoBOLTypes is an array, copy into
//  a dictionary to get the ordering by abbreviation.  Filter out non-cargo types.
	//foreach aCargoType in app.myRoot.allCargoTypesById do
	create cargoTypeDict transient;
	foreach cargoBOLType in self.myTerminal.allCargoBOLTypes do
		if cargoBOLType.isCargoType() then
			aCargoType := cargoBOLType.CM_CargoType;
			cargoTypeDict.add(aCargoType);
		endif;
	endforeach;
	create anArray transient;									// 27/04/2010 cnwmh5 PAR23943  - moved
	foreach aCargoType in cargoTypeDict do
	// end 23596
		self.lstCargoTypes.addItemObject(aCargoType.abbreviation &amp; " - " &amp; aCargoType.description,aCargoType);
		
		// #################
		// DEFAULT TO CONTAINER
		//if aCargoType.id = TI_CargoType_Container then		// 27/04/2010 cnwmh5 PAR23943 - Removed
		self.lstCargoTypes.rowChecked(lstCargoTypes.rows);
		if not self.allCargoTypes.includes(aCargoType) then	// include in allCargoTypes for initial BOL display
			self.allCargoTypes.add(aCargoType);
		endif;
		if not self.lstCargoTypes.allSelectedObjects.includes(aCargoType) and aCargoType &lt;&gt; null then
			self.lstCargoTypes.allSelectedObjects.add(aCargoType);
		endif;

		anArray.add(aCargoType);							// 27/04/2010 cnwmh5 PAR23943 - Moved
		
		//endif;											// 27/04/2010 cnwmh5 PAR23943 - Removed
	endforeach;
	//aCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];	// 27/04/2010 cnwmh5 PAR23943 - Removed
	//create anArray transient;												// 27/04/2010 cnwmh5 PAR23943 - Removed
	//anArray.add(aCargoType);												// 27/04/2010 cnwmh5 PAR23943 - Removed
	self.lstCargoTypes.setSelected(anArray);
	
epilog
	delete anArray;
	delete cargoTypeDict;
end;</source>
        <access>protected</access>
    </JadeMethod>
