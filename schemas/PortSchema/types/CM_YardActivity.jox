    <JadeMethod name="getDisplayStringForAttribute" id="cdd83150-e152-48a5-9bf4-ca92a0f7e564">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jul 2020	jlgndl1	Initial creation	TFS 49581
02 Nov 2022	navsp1	TFS 54899 PEN Reefer Monitor App Changes
*/

vars

begin

	if _attrName = ETRow_ReeferId then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.id;
		endif;
		return null;
		
	elseif _attrName = ETRow_JobType then
		return self.getTypeString;
		
	elseif _attrName = ETRow_ActionTime then
		return self.getActionTimeDateLocalTZ.asStringJMT;
		
	elseif _attrName = ETRow_IsConnected or
			_attrName = ETRow_IsExternallyMonitored or
			_attrName = ETRow_AnyJob or
			_attrName = ETRow_AnyConnectJob or
			_attrName = ETRow_AnyDisconnectJob or
			_attrName = ETRow_AnyMonitorJob or
			_attrName = ETRow_CurrentJob or
			_attrName = ETRow_CurrentAlarmJob or
			_attrName = ETRow_CurrentConnectJob or
			_attrName = ETRow_CurrentDisconnectJob or
			_attrName = ETRow_WalkBlockName or
			_attrName = ETRow_WalkBlockNameAny or
			_attrName = ETRow_CurrentMonitorJob then
			
			if self.myTrackedItem &lt;&gt; null then
				return self.myTrackedItem.getDisplayStringForAttribute( _attrName, _short );
			endif;
			return null;
	elseif _attrName = ETRow_ReeferJobCreationTS then	//27Sep2022 navsp1 TFS 54899
		return self.getCreatedTimeLocalTZ.asStringJMT;
	else
		return inheritMethod(_attrName, _short);
		
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
