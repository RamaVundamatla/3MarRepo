    <JadeMethod name="doMatch" id="39239a87-c9fa-4a83-a368-b381843d0f1d">
        <source>doMatch(
//_value: Integer //16/10/2023	navmv20	Bug 60677
_value : Any //16/10/2023	navmv20	Bug 60677
): Boolean;
// ---------------------------------------------------------------------------
// Created:     17 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
//16 October 2023	navmv20	Bug 60677: FR | EUP 54086 - Invoicing Maintenance enhancements - Selector Query - Invoice mode
vars

