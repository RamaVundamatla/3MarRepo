    <JadeMethod name="comboBoxRowArea" id="7d4f4c93-a8db-408a-8e06-dae70cdfc36c">
        <source>comboBoxRowArea(_cmb : ComboBox input; 
				_whArea : CM_RowArea);
// ---------------------------------------------------------------------------
// Created:     13 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if (_whArea &lt;&gt; null) and
		(_whArea.allRowControllersById.size &gt; 0) then
		_cmb.listCollection(_whArea.allRowControllersById, true, 0);
