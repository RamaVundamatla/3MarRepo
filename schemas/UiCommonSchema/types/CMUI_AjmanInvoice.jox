    <JadeMethod name="createNextPage" id="b480c2ba-22ef-4d4b-ab17-831596cfb962">
        <updating/>
        <source>createNextPage( _invLine : CM_InvoiceLine )protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2012	cnwndl1	Initial creation	Par 30683

*/

vars

	nextPage : CMUI_AjmanInvoice;
	invLine : CM_InvoiceLine;
	foundIt : Boolean;

begin

	//create nextPage transient;
	nextPage := CMUI_AjmanInvoice.createPrintForm;
	nextPage.initiateForm( self.baseLeftOffset, self.baseTopOffset );
	self.myNextPage := nextPage;
	
	// set the debtor reference - just in case.
	nextPage.myDebtor := self.myDebtor;
	// add the invoice lines we haven't printed yet.
	foreach invLine in self.invoiceLines do
		if invLine = _invLine then
			foundIt := true;
		endif;
		if foundIt then
			nextPage.invoiceLines.add(invLine);
		endif;
	endforeach;
	
	//set up the other fields to be the same as mine
	nextPage.lblA.caption := "";	//leave address line blank on subsequent pages
	nextPage.lblB.caption := self.lblB.caption;
	nextPage.lblC.caption := self.lblC.caption;
	nextPage.lblD.caption := self.lblD.caption;
	
	nextPage.lblE.caption := "";	//multi-line label populated directly in "doProcessLabelContents"
	nextPage.lblF.caption := "";	//multi-line label populated directly in "doProcessLabelContents"
	
	nextPage.lblG.caption := self.lblG.caption;
	nextPage.lblH.caption := self.lblH.caption;
	
	//now clear my totals values
	
	self.lblG.caption := "";
	self.lblH.caption := "...";

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="doProcessLabelContents" id="6fb8b909-beb5-4714-b027-06a3b2f696df">
        <updating/>
        <source>doProcessLabelContents(_label: CMUI_Label input):Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2012	cnwndl1	Initial creation	Par 30683

*/

vars
	
	invLine : CM_InvoiceLine;
	
	invLineNum : String;
	tiString : String;
	dateStr : String;
	desc : String;
	str : String;
	
	top : Integer;
	lineHeight : Integer;
	
	tempStrings : CM_StringDict;

begin

	if _label = self.lblA then	// address details;
		if not _label.caption = null then
			//allow test line up data to work.
			return inheritMethod(_label);
		endif;
		
		create tempStrings transient;
		top := ( _label.top + 1 ).Integer;
		lineHeight := _label.getTextHeight( "X" );
		
		if self.myDebtor &lt;&gt; null then
			self.createTempSubLabelText( _label, self.myDebtor.name, top, tempStrings, 0 );
			foreach str in self.myDebtor.billingAddress do
				if ( top + lineHeight ) &lt;= ( _label.top + _label.height ) then
					self.createTempSubLabelText( _label, str, top, tempStrings, 0 );
				else
					// truncation of address details is probably ok. and shouldn't ever happen.
					break;
				endif;
			endforeach;
			if ( top + lineHeight ) &lt;= ( _label.top + _label.height ) then
				// if it doesn't fit too bad..
				self.createTempSubLabelText( _label, self.myDebtor.decfinName.String, top, tempStrings, 0 );
			endif;
			
			self.addMultiplePrintLines( tempStrings );
			
		endif;
		return true;
		
	elseif _label = self.lblE then	// invoice lines
		if not _label.caption = null then
			//allow test line up data to work.
			return inheritMethod(_label);
		endif;
	
		create tempStrings transient;
		top := ( _label.top + 1 ).Integer;
		lineHeight := _label.getTextHeight( "X" );
		
		foreach invLine in self.invoiceLines do
			if not tempStrings.isEmpty then
				tempStrings.purge();
			endif;
			invLineNum := invLine.sequenceNum.String;
			self.createTempSubLabelText( _label, invLineNum, top, tempStrings, 0 );
			if invLine.trackedItem &lt;&gt; null then
				tiString := invLine.trackedItem.id;
				self.createTempSubLabelText( _label, tiString, top, tempStrings, 0 );
			endif;
			dateStr := invLine.chargeTime.Date.asStringJMT;
			self.createTempSubLabelText( _label, dateStr, top, tempStrings, 0 );
			desc := invLine.invoiceLineDesc.narration;
			self.createTempSubLabelText( _label, desc, top, tempStrings, 0 );
			
			if ( top + lineHeight ) &lt;= ( _label.top + _label.height ) then
				//these lines will fit
				self.createTempSubLabelText( self.lblF, invLine.lineTotal.asCurrencyJMT, top, tempStrings, 0 ); // add the line total in teh adjacent label
				self.addMultiplePrintLines( tempStrings );
			else
				// the lines wont fit, create a continuation page.
				self.createNextPage( invLine );
				break;
			endif;
			
		endforeach;
		return true;
	
	elseif _label = self.lblF then	// invoice line amounts, populated in parallel to invoice lines in code above
		if not _label.caption = null then
			//allow test line up data to work.
			return inheritMethod(_label);
		endif;
		return true;
		
	else
		return inheritMethod(_label);
		
	endif;

epilog

	if tempStrings &lt;&gt; null then
		if not tempStrings.isEmpty then
			tempStrings.purge();
		endif;
		delete tempStrings;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="CMUI_Label" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="makeLabelsAvailable" id="264a50cc-2780-4144-93e2-75d98c1a4322">
        <source>makeLabelsAvailable() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2012	cnwndl1	Initial creation	Par 30683

*/

vars

begin

	self.allLabelsArray.add( self.lblA );
	self.allLabelsArray.add( self.lblB );
	self.allLabelsArray.add( self.lblC );
	self.allLabelsArray.add( self.lblD );
	self.allLabelsArray.add( self.lblE );
	self.allLabelsArray.add( self.lblF );
	self.allLabelsArray.add( self.lblG );
	self.allLabelsArray.add( self.lblH );
	
	self.lblA.alignment := Label.Alignment_Left_Top;
	self.lblB.alignment := Label.Alignment_Left_Top;
	self.lblC.alignment := Label.Alignment_Left_Top;
	self.lblD.alignment := Label.Alignment_Left_Top;
	self.lblE.alignment := Label.Alignment_Left_Top;
	self.lblF.alignment := Label.Alignment_Right_Top;
	self.lblG.alignment := Label.Alignment_Left_Top;
	self.lblH.alignment := Label.Alignment_Right_Top;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateLineUp" id="47b6a645-09ad-4248-b265-4d2fc10e5335">
        <updating/>
        <source>populateLineUp(): String protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2012	cnwndl1	Initial creation	Par 30683

*/

vars

	xxString : String;
	repDetails : String;
//	wordString : String;
//	fits : String;
//	doesnt : String;

begin

	repDetails := inheritMethod();
	
	xxString := self.lblD.caption;
	
	self.lblD.caption := "XX  '" &amp; repDetails &amp; "'  " &amp; xxString;
	
//	wordString := "The quick brown fox jumps over the lazy dog. John's helicopter is green. Fire engines are visiting the hospital. Software engineers do not make good typists. They lack the imagination to come up with text that presents nicely in controls. ";
//	fits := wordString &amp; CrLf &amp; " Hillbilly" &amp; CrLf &amp; " " &amp; wordString &amp; wordString &amp; wordString;
//	doesnt := fits &amp; fits &amp; fits;
//	self.lblE.caption := doesnt;
	
	return repDetails;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="repositionLabels" id="bff868ef-4c8d-494b-8229-5af627ea933e">
        <source>repositionLabels() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2012	cnwndl1	Initial creation	Par 30683

*/

vars
	
	 topMMs : Real;
	 leftMMs : Real;
	 rightMMs : Real;
	 bottomMMs : Real;

begin

	topMMs := 64;
	bottomMMs := 104;
	leftMMs := 10;	rightMMs := 100;	self.moveLabel( self.lblA, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 73;
	bottomMMs := 79;
	leftMMs := 145;	rightMMs := 178;	self.moveLabel( self.lblB, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 82;
	bottomMMs := 87;
	leftMMs := 145;	rightMMs := 178;	self.moveLabel( self.lblC, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 106;
	bottomMMs := 116;
	leftMMs := 10;	rightMMs := 178;	self.moveLabel( self.lblD, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 124;
	bottomMMs := 248;
	leftMMs := 1;	rightMMs := 132;	self.moveLabel( self.lblE, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 134;	rightMMs := 178;	self.moveLabel( self.lblF, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 255;
	bottomMMs := 263;
	leftMMs := 1;	rightMMs := 132;	self.moveLabel( self.lblG, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 134;	rightMMs := 178;	self.moveLabel( self.lblH, topMMs, leftMMs, rightMMs, bottomMMs );
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDataFieldsFromObject" id="2a349db4-828c-4516-806b-7c9966636076">
        <updating/>
        <source>setDataFieldsFromObject(_obj: CM_Object; _lineUp: Boolean; _showLabelArea: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2012	cnwndl1	Initial creation	Par 30683

*/

vars

begin

	if _showLabelArea then
		//app.printer.print( self.testFrame );
		self.printLabelFieldAreaBoundary();	//21 July 2014	NDL Par 34611
	endif;
		
	if _lineUp then
		self.populateLineUp();
		return;
			
	elseif _obj &lt;&gt; null then
	
		self.myPopulatingObject := _obj;	//31 Jan 2014	NDL	Par 33181
	
		if _obj.isKindOf( CM_Invoice ) then
			self.setFromInvoice( _obj.CM_Invoice );
		else
			self.populateLineUp();
		endif;
	
		return;
		
	endif;
	
	inheritMethod( _obj, _lineUp, _showLabelArea );

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_lineUp" type="Boolean"/>
        <Parameter name="_showLabelArea" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromInvoice" id="753ccee4-78b8-4d2f-a7dd-9ff9f7214491">
        <updating/>
        <source>setFromInvoice( _invoice : CM_Invoice ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2012	cnwndl1	Initial creation	Par 30683

*/

vars

	addressDetailStr : String;
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	voyDetailsStr : String;
	vesselName : String;
	arrivalDateStr : String;
	hmsVoy : HMS_VoyageData;
	loa : Integer;
	totalAmount : Decimal[12,2];
	
begin

	self.myDebtor := _invoice.debtor;
	if self.myDebtor &lt;&gt; null then
		addressDetailStr := self.myDebtor.name &amp; CrLf &amp; self.myDebtor.getBillingAddressString &amp; CrLf &amp; self.myDebtor.decfinName.String;
	endif;
	voyage := _invoice.myVoyage;
	if _invoice.myTrackedItem &lt;&gt; null and  _invoice.myTrackedItem.myVoyage &lt;&gt; null then
		voyage := _invoice.myTrackedItem.myVoyage;
	endif;
	if voyage &lt;&gt; null then
		vessel := voyage.getMyVessel();
		if vessel &lt;&gt; null then
			vesselName := vessel.name;
		else
			vesselName := app.getErrorString(Unknown);
		endif;
		voyDetailsStr := app.getErrorString(CM_Vessel_GC) &amp; " : " &amp; vesselName;
		
		if _invoice.myTrackedItem &lt;&gt; null then
			voyDetailsStr := voyDetailsStr &amp; "  " &amp; voyage.code;
		endif;
		
		if voyage.arrivedDT.Date.isValid then
			arrivalDateStr := app.getErrorString(Arrival_date) &amp; " : " &amp; voyage.arrivedDT.Date.asStringJMT;
		endif;
		
		if _invoice.myTrackedItem = null then
			hmsVoy := voyage.myHMSVoyageData;
			if hmsVoy &lt;&gt; null then
				loa := hmsVoy.dim_LengthOverall.Integer;
			endif;
			if loa &gt; 0 then
				voyDetailsStr := voyDetailsStr &amp; "  " &amp; app.getErrorString(LOA) &amp; " : " &amp; loa.String;
			endif;
		endif;
		
	endif;

	self.lblA.caption := "";	//multi-line label populated directly in "doProcessLabelContents"
	self.lblB.caption := _invoice.sequenceNum.String;
	self.lblC.caption := _invoice.createdTime.Date.asStringJMT;
	self.lblD.caption := voyDetailsStr;
	
	
	self.lblE.caption := "";	//multi-line label populated directly in "doProcessLabelContents"
	self.lblF.caption := "";	//multi-line label populated directly in "doProcessLabelContents"
	self.invoiceLines.clear();
	if not _invoice.invoiceLines.isEmpty then
		_invoice.invoiceLines.copy( self.invoiceLines );
	endif;
	
	totalAmount :=  _invoice.getTotalAmount;
	self.lblG.caption := totalAmount.asCurrencyJMTWords;
	self.lblH.caption := totalAmount.asCurrencyJMT;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
</GUIClass>
