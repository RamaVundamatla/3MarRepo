<Class name="DEV_SchemaFile" id="fd28dc96-2a4d-4357-afc1-df216aae84aa">
    <superclass name="DEV_SchemaObjectEntity"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <PrimAttribute name="commandFileData" id="091616f7-3268-4c84-8f19-ca85f08e0720">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="jadeVersion" id="a0f599d8-cd4b-4e27-a0ea-b10500aff12b">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="mySchema" id="cb9133e0-a884-4b19-84b8-4e4875ffbfdd">
        <embedded/>
        <type name="DEV_Schema"/>
        <access>readonly</access>
        <Inverse name="DEV_Schema::mySchemaFile"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="5eda3135-719d-4b59-a63e-4f53a97532c3">
        <updating/>
        <source>create(_name : String) ::super(_name) updating;
/*

Purpose:			Constructor for DEV_SchemaFile class

Parameters:			_name:		The name of the schema file
					_schema:	The schema we are loading
					
Return Value:		

Date		Who		Reason
28 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	
end;</source>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="7fe25dab-817f-4ce0-9182-44b65c7bfe91">
        <updating/>
        <source>delete() updating;
/*

Purpose:			Delete for DEV_SchemaFile class

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2021	navpw1	Initial creation TFS: 52202

*/


begin
	//Deleting transient properties
	delete self.mySchema;

end;</source>
    </JadeMethod>
    <JadeMethod name="extractCommandData" id="f9288447-9632-43ab-b231-b9635fcbf635">
        <source>extractCommandData() : String protected;
/*

Purpose:			Extracts command data to file

Parameters:			

Return Value:		A string containing command data

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	if (self.commandFileData &lt;&gt; null) then
		return self.commandFileData &amp; CrLf;
	else
		return "";
	endif;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractJadeVersion" id="ada02968-0692-4e57-bbb0-324d59cd06a7">
        <source>extractJadeVersion() : String protected;
/*

Purpose:			Extracts jade version to file

Parameters:			

Return Value:		A string containing the Jade version

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	return "jadeVersionNumber " &amp; self.jadeVersion &amp; ";";

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractToFile" id="b9112c39-cb84-4147-8780-484956d04211">
        <source>extractToFile(_outputFile: File io);
/*

Purpose:			Extracts all the schema file data to file

Parameters:			_outputFile: The file to write the schema data to

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	_outputFile.writeLine(self.extractCommandData() &amp; self.extractJadeVersion());
	self.mySchema.extractToFile(_outputFile);
	self.mySchema.extractSectionsToFile(_outputFile);
	
end;</source>
        <Parameter name="_outputFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setSchema" id="7cfe05f9-dc65-42ec-888c-39986c1fa765">
        <updating/>
        <source>setSchema(_devSchema : DEV_Schema) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2021	navpw1	Initial creation TFS: 52202

*/

begin
	self.mySchema := _devSchema;

end;</source>
        <Parameter name="_devSchema" type="DEV_Schema"/>
    </JadeMethod>
    <JadeMethod name="update" id="66a81f48-66b5-43aa-a0c8-419b2ce9c935">
        <updating/>
        <source>update(_jadeVersion,
		_commandFileData : String) updating;
/*

Purpose:			Update method for DEV_SchemaFile class (Sets optional attributes)

Parameters:			_jadeVersion:		The jade version to set the attribute to
					_commandFileData:	The command data to set the attribute to

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	//Set Attributes
	self.jadeVersion := _jadeVersion;
	self.commandFileData := _commandFileData;
	
end;</source>
        <Parameter name="_jadeVersion" type="String"/>
        <Parameter name="_commandFileData" type="String"/>
    </JadeMethod>
</Class>
