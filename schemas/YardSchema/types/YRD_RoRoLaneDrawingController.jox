    <JadeMethod name="notableObjectArmNotes" id="0f6ec646-00e3-45ce-a520-2716031757a5">
        <source>notableObjectArmNotes(_obj: Object);
// ---------------------------------------------------------------------------
// Created:		09 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
aTA : CM_TerminalArea;
begin
	inheritMethod(_obj);
	if CM_TerminalArea.hasInstance(_obj) then
		aTA := _obj.CM_TerminalArea;
		self.beginNotification(aTA, self.noteTAMove, Response_Continuous, null);
		self.beginNotification(aTA, self.noteTIUpdate, Response_Continuous, null);
		self.beginNotification(aTA, self.noteTALocationUpdate, Response_Continuous, null);
		self.beginNotification(aTA, self.noteTALocationCreate, Response_Continuous, null);
		self.beginNotification(aTA, self.noteTALocationDelete, Response_Continuous, null);

		self.beginNotification(aTA, self.noteTAYardAllocationCreate, Response_Continuous, null);
		self.beginNotification(aTA, self.noteTAYardAllocationUpdate, Response_Continuous, null);
		self.beginNotification(aTA, self.noteTAYardAllocationDelete, Response_Continuous, null);

	endif;
end;</source>
