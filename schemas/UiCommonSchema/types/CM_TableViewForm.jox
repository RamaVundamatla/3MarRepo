        <source>tblData_rowColumnChg(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/10/2023	jlika1		TFS 60823	CUX | Can't drag and drop cargo to the ground in a MAFI heap
// ---------------------------------------------------------------------------
vars
	theObject	: Object;

begin
	

	if table.row &gt; table.fixedRows then
		// 24/07/2025	navkc1	JIRA MTN-35546
		if table.CM_DataTable.isPaginated() then
			if table.CM_DataTable.fromRowColumnChanged then //jlier1 9/6/25 MTN-34771
				self.zTblDataSelectRow(table.row);
			endif;
		else
			self.zTblDataSelectRow(table.row);
		endif;
	else
		self.handleHeaderSelect();
	endif;

epilog

	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_scrolled" id="2a5ba0c0-6e12-42ca-8080-48760d147b3a">
        <controlMethod name="CM_BaseTable::scrolled"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_scrolled(table: Table input; scrollBar: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2025	jlier1	Initial creation 34711

*/

vars
	timerType,
	remaining		: Integer;
begin
	
	if scrollBar = ScrollBar_Vertical and table.CM_DataTable.isPaginated then
		//give some time to finish scrolling before coloring rows/cells
		if self.getTimerStatus(Timer_Scrolled, timerType, remaining) then
			self.endTimer(Timer_Scrolled);
		endif;
		self.beginTimer(100, Timer_OneShot, Timer_Scrolled);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="scrollBar" type="Integer"/>
    </JadeMethod>
