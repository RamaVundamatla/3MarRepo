    <JadeMethod name="load" id="46473cc6-21e0-41cf-af3d-ed54d28c26fa">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	centreWindow();
	self.formLoad();
epilog
	self.statusMsg("");
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCollection" id="612ef8d7-91e6-4fa0-b90f-bb7251b35f6f">
        <source>loadCollection(pClass:Class) protected;
// --------------------------------------------------------------------------------
// Created:		16 January 1999 by cnwdad1
//
// Purpose:		Loads all instances of a collection's Class into the JAC Design Table,
//				and pre-selects all instances that are included in the collection.
//
// Parameters:	pClass (Class) - The collection's class.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/06/1999	cnwdad1		Added logic for a table column to show the name of each
//							object's class.  Also changed where the collection of
//							instances is loaded to also load instances of all
//							subclasses of the target class.
// 11/07/1999	cnwdad1		Added checks for whether the memberType property of the
//							collection is null (such as for an ObjectArray).
// 11/05/2000	cnwdad1		The new version of the CnEcDesignTable control now has
//							the "selectedObjects" property protected and accessible
//							via the "getSelectedObjects" method.
//
// --------------------------------------------------------------------------------
vars
	collClass		: CollClass;
	memberType		: Class;
	thePropertyColl	: PropertyColl;
	property		: Property;
	theKeyColl		: KeyColl;
	any				: Any;
	propertyName	: String;
	index			: Integer;
	classInstances	: ObjectArray;

begin
	if pClass.isKindOf(CollClass) then
		collClass	:=	pClass.CollClass;
		theKeyColl	:=	collClass.getKeys();

		if (not collClass.memberType = null) then
			memberType	:=	collClass.memberType.Class;
		endif;
	else
		return;
	endif;

	tblObjects.CnEcDesignTable.clear();
	tblObjects.multiSelect	:=	1;		// 0 = None, 1 = Simple.
	lblClass.caption		:=	collClass.name;

	if memberType = null then
		lblCollection.caption	:=	pClass.getName;
	else
		lblCollection.caption	:=	memberType.name &amp; ".allInstances";
	endif;

	tblObjects.rows			:=	1;
	tblObjects.columns		:=	3;	// Column 1 is the JACDesign tables hidden column, column 2 is for the OID.

	if memberType = null then
		lblInfo.caption	:=	'';
	else
		if collClass.duplicatesAllowed then
			lblInfo.caption	:=	"Duplicates allowed";
		else
			lblInfo.caption	:=	"Duplicates NOT allowed";
		endif;
	endif;

	/*
		Note that the JAC Design Table has 1 hidden column (column 1).
		Two additional columns (column 2 &amp; 3) are added to display the
		object OID, which will always display as column 1 &amp; 2 (because
		the real column 1 is hidden).  Additional columns will be
		dynamically added for each of the class's properties - references
		to these columns are therefore offset by 3.
	*/

	tblObjects.setCellText(1, 2, 'Object OID');
	tblObjects.setCellText(1, 3, 'Class');

	if tblObjects.columnWidth[2] &lt; (tblObjects.getTextExtent(tblObjects.getCellText(1, 2)) + 10) then
		tblObjects.columnWidth[2]	:=	tblObjects.getTextExtent(tblObjects.getCellText(1, 2)) + 10;
	endif;

	index	:=	3;

	if memberType = null then

	else
		thePropertyColl	:=	memberType.allProperties();
		
		foreach property in thePropertyColl where (not property.isSystemObject()) do
			index	:=	index + 1;

			if tblObjects.columns &lt; index then
				tblObjects.columns	:=	index;
			endif;

			tblObjects.setCellText(1, index, property.name);

			if tblObjects.columnWidth[index] &lt; (tblObjects.getTextExtent(tblObjects.getCellText(1, index)) + 10) then
				tblObjects.columnWidth[index]	:=	tblObjects.getTextExtent(tblObjects.getCellText(1, index)) + 10;
			endif;
			
			foreach any in theKeyColl do
				propertyName	:=	any.Object.getPropertyValue("property").getName;

				if propertyName = property.name then
					tblObjects.cnEcSetCellForeColor(1, index, Red);
				endif;
			endforeach;
		endforeach;
	endif;

	tblObjects.sizeColumnArrays();
	tblObjects.rebuildColumnHeadingArray();
	self.myObjectSet.clear();

	if memberType = null then
		pClass.instances.copy(self.myObjectSet);
	else
		create classInstances transient;
		memberType.allInstances(classInstances, 0, true);

		if (classInstances.cnEcIsNotEmpty()) then
			classInstances.copy(self.myObjectSet);
		endif;
	endif;

//	lblEntries.caption		:=	classInstances.size.String;
	lblEntries.caption		:=	self.myObjectSet.size().String;
//	self.myCollection.copy(tblObjects.selectedObjects);
	self.myCollection.copy(tblObjects.getSelectedObjects());
	tblObjects.listCollection(self.myObjectSet, false, 0);

	if self.myObject &lt;&gt; null then
		btnOk.enabled	:=	true;
	else
		btnOk.enabled	:=	false;
	endif;
epilog
	delete classInstances;
	delete thePropertyColl;
end;</source>
        <access>protected</access>
        <Parameter name="pClass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="loadReference" id="3684213b-0ade-496a-aa24-ddf76517bd09">
        <source>loadReference(pClass:Class) protected;
// --------------------------------------------------------------------------------
// Created:		16 January 1999 by cnwdad1
//
// Purpose:		Loads all instances of an Object's Class instances into the JAC Design Table,
//				and pre-selects the Object's instance.
//
// Parameters:	pClass (Class) - The reference's class.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/06/1999	cnwdad1		Added logic for a table column to show the name of each
//							object's class.  Also changed where the collection of
//							instances is loaded to also load instances of all
//							subclasses of the target class.
// 11/05/2000	cnwdad1		The new version of the CnEcDesignTable control now has
//							the "selectedObjects" property protected and accessible
//							via the "getSelectedObjects" method.
//
// --------------------------------------------------------------------------------
vars
	thePropertyColl	: PropertyNDict;
	property		: Property;
	index			: Integer;
	classInstances	: ObjectArray;		// Will include all instances of subclasses.

begin
	tblObjects.CnEcDesignTable.clear();
	lblClass.caption		:=	pClass.name;
	lblCollection.caption	:=	"allInstances";
	tblObjects.rows			:=	1;
	tblObjects.columns		:=	3;	// Column 1 is the JACDesign tables hidden column, column 2 is for the OID, column 3 is for the class name.

	/*
		Note that the JAC Design Table has 1 hidden column (column 1).
		Two additional columns (column 2 &amp; 3) are added to display the
		object OID and Object's Class name, which will always display
		as column 1 and 2 (because the real column 1 is hidden).
		Additional columns will be dynamically added for each of the
		class's properties - references to these columns are therefore
		offset by 3.
	*/

	tblObjects.setCellText(1, 2, 'Object OID');
	tblObjects.setCellText(1, 3, 'Class');

	if (tblObjects.columnWidth[2] &lt; tblObjects.getTextExtent(tblObjects.getCellText(1, 2)) + 10) then
		tblObjects.columnWidth[2]	:=	tblObjects.getTextExtent(tblObjects.getCellText(1, 2)) + 10;
	endif;

	index			:=	3;
	thePropertyColl	:=	pClass.getProperties();
	
	foreach property in thePropertyColl where (not property.isSystemObject()) do
		index	:=	index + 1;

		if (tblObjects.columns &lt; index) then
			tblObjects.columns	:=	index;
		endif;

		tblObjects.setCellText(1, index, property.name);

		if (tblObjects.columnWidth[index] &lt; tblObjects.getTextExtent(tblObjects.getCellText(1, index)) + 10) then
			tblObjects.columnWidth[index]	:=	tblObjects.getTextExtent(tblObjects.getCellText(1, index)) + 10;
		endif;
	endforeach;

	tblObjects.sizeColumnArrays();
	tblObjects.rebuildColumnHeadingArray();
	self.myObjectSet.clear();

	create classInstances transient;
	pClass.allInstances(classInstances, 0, true);

	if (classInstances.cnEcIsNotEmpty()) then
		classInstances.copy(self.myObjectSet);
	endif;

	lblEntries.caption		:=	classInstances.size().String;
	tblObjects.getSelectedObjects().add(self.myObject);
	tblObjects.listCollection(self.myObjectSet, false, 0);
	tblObjects.selectRow();

	if (self.myObject &lt;&gt; null) then
		btnOk.enabled	:=	true;
	else
		btnOk.enabled	:=	false;
	endif;
epilog
	delete thePropertyColl;
	delete classInstances;
end;</source>
        <access>protected</access>
        <Parameter name="pClass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="mnuPopupBrowse_click" id="d8ea050b-8a1d-498f-bfde-87d4a8fea873">
        <controlMethod name="MenuItem::click"/>
