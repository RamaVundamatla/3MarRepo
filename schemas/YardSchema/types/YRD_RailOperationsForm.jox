    </JadeMethod>
    <JadeMethod name="switchViewMode" id="1d18164a-fcfe-4525-9b4c-49c214594594">
        <updating/>
        <source>switchViewMode(_theIndex : Integer; _btn : Button input) updating;
//-----------------------------------------
// Created: 16 October 2003 By: cnwgd1
//-----------------------------------------
vars

begin

	if _btn &lt;&gt; null then
		_btn.value := true;
	endif;

	self.mySDF.setViewMode(_theIndex);	
	self.mySDF.drawSelf();
	if not self.frmLegend.displayViewModeCodes(self.mySDF.viewMode, self.mySDF.myDrawingAttrController) then
		self.frmLegend.doChangeViewMode(_theIndex);
	endif;
end;</source>
        <Parameter name="_theIndex" type="Integer"/>
        <Parameter name="_btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="7ee20bb1-4dd1-409d-bc33-be77743f0629">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
26/09/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
//17 Nov 2016 cnwrs1	Par 37738 TFS 2949 incorrect UPSP rail location being displayed
16 Apr 2025 navnk30		JIRA 34157: MTN | Rail Operations - Handle Notifications
----------  ----------  --------------------------------------------------
*/
vars

begin
	if self.notificationLevel = self.NoteLevelDoNotes then								//16.04.2025 navnk30 JIRA 34157
		self.beginTimerForNotifications(theObject, eventType, eventTag, theObject);
	endif;

	/*		This system notification handling part is done in YRD_RailOperationsForm::handleSysNotification() through Notification framework
	
	on Exception do app.handleDeletedObject(exception, train, invalid);		 // PAR 37738

	inheritMethod(eventType, theObject, eventTag);
	if CM_Train.hasInstance(theObject) then
		train := theObject.CM_Train;
		str := train.asStringJMT;
		if invalid then
			return;
		endif;
		if eventType = Object_Delete_Event then
			if self.myCurrentTrain = train then
				//self.myCurrentTrain := null;
				self.setMyTrain( null );	//14 May 2021	NDL	TFS 51199
				self.cmbTrain.listObject := null;
				self.doRefreshGraphicView();
			endif;
		else
			//18 Sep 2009	NDL
			if not self.tblTrains.findObjectInRow(train,idx) then
				theDataLine := train.getAttributeStringForDefArray(self.tblTrains.allTblDataEntRows);
				idx := self.tblTrains.addItem(theDataLine);
				self.tblTrains.accessRow(idx).itemObject := train;
			endif;
		endif;
		self.myAssistant.comboBoxTrain(self.cmbTrain, self.cmbTrain.listObject.CM_Train, false, true, false);
	endif;
	
	*/
		
end;


</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblTrains_click" id="29c0ae30-ebdc-41b8-b71e-4eb0fe98bb1a">
