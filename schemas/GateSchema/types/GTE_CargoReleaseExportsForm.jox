        <source>resetNotifications();
//--------------------------------------------------
// Created:	29 October 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	beginClassNotification(CM_TrackedItem, false, Object_Update_Event, Response_Continuous, 0);	
	beginClassNotification(CM_TrackedItem, false, self.myTerminal.getTerminalEvent(TIEvent_PreNote_Add), Response_Continuous, 0);
end;</source>
