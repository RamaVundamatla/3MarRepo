        <updating/>
        <source>doTblDataMouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2022	navsj20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars

begin
	//inheritMethod(table, button, shift, x, y);
	if button &lt;&gt; 1 or (not app.dragDetected(x, y, self.origXPos, self.origYPos)) then
		return;
	endif;

	self.dragWagon();
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
