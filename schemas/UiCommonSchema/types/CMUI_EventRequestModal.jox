    <JadeMethod name="doOptClearChange" id="caf1f8fd-7364-4211-9b19-963621b5356e">
        <updating/>
        <source>doOptClearChange( _optionbutton : OptionButton input ) updating, protected;

/*
Purpose:	This method handles the toggling of the add/clear option buttons and
			how it effects the additonal required information textbox.
			If the add option is choosen then the textbox is cleared and disabled.
			
Date				Who		Reason
18 September 2009	cnwrl1	Initial creation as part of PAR 20230 - New Messina Messages
12/01/2010			cnwrl1	PAR 21889 - allow for entering of Stops Clearance Expiry Date
*/
	
vars
	
begin
	if _optionbutton.value then
		// ie clear has been set
		self.txtReqInfo.enabled		:= true;
		// cnwrl1 12/01/2010 PAR 21889 - start of coding
		self.txtExpiryDate.enabled	:= true;
		if self.myEventRequest &lt;&gt; null and CM_EventRequestStops.hasInstance( self.myEventRequest ) then
			self.txtReqInfo.text	:= self.myEventRequest.CM_EventRequestStops.additionalRequiredInfo;
			self.txtExpiryDate.setDate( self.myEventRequest.CM_EventRequestStops.clearanceExpiryDate );
		endif;
		// cnwrl1 12/01/2010 PAR 21889 - end of coding
	else
		// ie add has been set
		self.txtReqInfo.text		:= null;
		self.txtReqInfo.enabled		:= false;
		self.txtExpiryDate.enabled	:= false;		// cnwrl1 12/01/2010 PAR 21889
		self.txtExpiryDate.setDate( null );			// cnwrl1 12/01/2010 PAR 21889
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
