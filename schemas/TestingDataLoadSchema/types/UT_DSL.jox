    <JadeMethod name="updateDamageDefinition" id="9b47d89f-0728-4e3a-ac1c-30f49ce387ee">
        <source>updateDamageDefinition(_damageDef : Any);

/*

Purpose:		Update Damange Definition

Date			Who		Reason
03/04/2014		cnwmh5	Initial creation

*/

vars

	pxyDamageDef				: CM_DamageDefinitionCode;
	damageDef					: CM_DamageDefinitionCode;
	
	loadState					: Boolean;
	description 				: String;

begin

	if _damageDef.isKindOf(String) then
		damageDef := app.myRoot.allDamageDefinitionCodes[_damageDef.String];	
	else
		damageDef := _damageDef.CM_DamageDefinitionCode;
	endif;
	
	if damageDef = null then
		return;
	endif;
	
	app.cmsBeginLoad(loadState);
	pxyDamageDef := damageDef.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	description := damageDef.description;
	if self.opts.includesKey("Description") then
		description := self.opts.str("Description");
	endif;
	
	pxyDamageDef.setProxy(damageDef.code, description, damageDef.allCargoTypes,damageDef.allMachineTypesByType);
	
	app.myTrxUA.trxUpdateDamageDefCode(pxyDamageDef, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	app.cmsEndLoad(loadState);

	delete pxyDamageDef;

end;</source>
        <Parameter name="_damageDef" type="Any"/>
    </JadeMethod>
