    <JadeMethod name="validateCubicMetres" id="39301b91-73bd-4f48-8d05-83ea25c7f008">
        <source>validateCubicMetres(pControl: CMIF_TIUpdateController) protected;
// ---------------------------------------------------------------------------
// Created:     11 July 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14 Jul 2011	NDL		Par 27485 - Should be checking volume NOT totalVolume.
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pControl);

	if self.getMyTotalVolume &gt; 999999 then
		//fd for 1885 nicely validate the cubicMetres
		app.raiseCMWarning2(WARN_LARGE_NUMBER, self.getMyTotalVolume.String, 'volume', 'volume', pControl.myUserObject, self);
	endif;
	if self.getMyTotalVolume &lt; 0 then // and self.volume &lt;&gt; NULL_VOLUME then
		//fd for 1885 nicely validate the cubicMetres
		app.raiseCMWarning2(WARN_SMALL_NUMBER, self.getMyTotalVolume.String, 'volume', 'volume', pControl.myUserObject, self);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
