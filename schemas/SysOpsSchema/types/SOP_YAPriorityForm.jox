// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return obj.CMIF_YACriteriaPriority.getTableDisplay();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblPriorities_keyUp" id="d4d63c32-353d-499f-8f53-6bc4b2861a2e">
        <controlMethod name="Table::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblPriorities_keyUp(table: Table input; keyCode: Integer io; shift: Integer) updating;
//26 July 2010	cnwml2
//+cnwml2 PAR24472


vars

begin
	if  keyCode = J_key_DownArrow or keyCode = J_key_UpArrow then
		self.tblPriorities.click(self.tblPriorities);
