    <JadeMethod name="doViewAudits" id="68054c70-927f-4da3-9bca-01612cd5d08a">
        <source>doViewAudits() protected;

vars
	transText : XLAT_TranslatableText;
	translation : XLAT_Translation;
	form : SOP_ViewAuditsForm;

begin
	// Identify the sheet being displayed and find the selected translatable text row in the table.
	if fldData.topSheet = shtMessages then
		if tblMessages.accessedRow &lt;&gt; null and tblMessages.accessedRow.row = tblMessages.row then
			transText := tblMessages.accessedRow.itemObject.XLAT_TranslatableText;
		endif;
	elseif fldData.topSheet = shtFormCaptions then
		if tblFormCaptions.accessedRow &lt;&gt; null and tblFormCaptions.accessedRow.row = tblFormCaptions.row then
			transText := tblFormCaptions.accessedRow.itemObject.XLAT_TranslatableText;
		endif;
	elseif fldData.topSheet = shtMenuEntities then
		if tblMenuEntities.accessedRow &lt;&gt; null and tblMenuEntities.accessedRow.row = tblMenuEntities.row then
			transText := tblMenuEntities.accessedRow.itemObject.XLAT_TranslatableText;
		endif;
	elseif fldData.topSheet = shtPermissions then
		if tblPermissions.accessedRow &lt;&gt; null and tblPermissions.accessedRow.row = tblPermissions.row then
			transText := tblPermissions.accessedRow.itemObject.XLAT_TranslatableText;
		endif;
	elseif fldData.topSheet = shtReportNames then
		if tblReportNames.accessedRow &lt;&gt; null and tblReportNames.accessedRow.row = tblReportNames.row then
			transText := tblReportNames.accessedRow.itemObject.XLAT_TranslatableText;
		endif;
	elseif fldData.topSheet = shtTableEntitys then
		if tblTableEnts.accessedRow &lt;&gt; null and tblTableEnts.accessedRow.row = tblTableEnts.row then
			transText := tblTableEnts.accessedRow.itemObject.XLAT_TranslatableText;
		endif;
	endif;

	create form;
	form.transText := transText;
	form.showModal;

end;</source>
        <access>protected</access>
    </JadeMethod>
