<Class name="Object">
    <JadeMethod name="mbRaiseException" id="58cfc921-5ac5-4053-b75f-eaaeb4b64926">
        <source>mbRaiseException(_error : String) protected;
// --------------------------------------------------------------------------------
// Created:		12 October 2005 by cnwdad1
//
// Purpose:		This method is the standard means of presenting error messages to a
//				user or some other interface.
//
// Parameters:	_error - The error message.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	FATAL_ERROR		: Integer = 999999;
	
vars
	exceptionObj	: MB_Exception;
	
begin
	create exceptionObj transient;
	
	exceptionObj.errorCode			:=	FATAL_ERROR;
	exceptionObj.continuable		:=	false;
	exceptionObj.resumable			:=	true;
	exceptionObj.extendedErrorText	:=	_error;
	
	raise exceptionObj;
end;</source>
        <access>protected</access>
        <Parameter name="_error" type="String"/>
    </JadeMethod>
</Class>
