<Class name="WS_Carrier" id="ead94457-7628-40b9-85ff-97af3b280810">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Repressents Carriers defined in the system</text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allDrivers" id="3e346a22-c77b-4d05-a856-e7f8cc09366c">
        <memberTypeInverse/>
        <type name="WS_DriverArray"/>
        <access>readonly</access>
        <text>Internal use only. No external support</text>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allVehicles" id="db9cb6fa-a11f-438d-87cb-b34b250cce79">
        <memberTypeInverse/>
        <type name="WS_VehicleArray"/>
        <text>Internal use only. No external support</text>
    </ImplicitInverseRef>
    <PrimAttribute name="code" id="04d3eaba-6601-460b-b7b6-392fdc74ab8d">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <text>Carrier Code</text>
    </PrimAttribute>
    <PrimAttribute name="comboboxDescription" id="da468e53-8554-42f6-93a6-0b155d8df8cf">
        <length>91</length>
        <embedded/>
        <type name="String"/>
        <text>Concatenated code and description of the carrier.</text>
    </PrimAttribute>
    <PrimAttribute name="description" id="f45c60e0-d562-4a83-add6-f4ff415403e3">
        <length>71</length>
        <embedded/>
        <type name="String"/>
        <text>Carrier Description</text>
    </PrimAttribute>
    <JadeMethod name="delete" id="7b1a74df-57b3-4465-9507-1c13ada0cc31">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	self.allDrivers.purge();
	self.allVehicles.purge();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="4189ca09-95af-45f8-96f8-e8bc8c98b7fa">
        <updating/>
        <source>setProxyFromObject(_object: CM_Carrier) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
13 Mar 2009	cnwkpd1	PAR #19109 - Add in comboboxDescription

*/

vars

	driver : CM_DriverDetails;
	wsDriver : WS_Driver;
	vehicle : CM_Vehicle;
	wsVehicle : WS_Vehicle;

begin

	inheritMethod(_object);

	self.code := _object.code;
	self.description := _object.description;
	self.comboboxDescription := self.code &amp; " " &amp; self.description;
	
	//08 May 2013	NDL	Par 31393
	/*foreach driver in _object.allDrivers discreteLock do
		create wsDriver transient;
		wsDriver.setProxyFromObject( driver );
		self.allDrivers.add( wsDriver );
	endforeach;
	
	foreach vehicle in _object.vehicles discreteLock do
		create wsVehicle transient;
		wsVehicle.setProxyFromObject( vehicle );
		self.allVehicles.add( wsVehicle );
	endforeach;*/
	
	
epilog

end;</source>
        <Parameter name="_object" type="CM_Carrier"/>
    </JadeMethod>
</Class>
