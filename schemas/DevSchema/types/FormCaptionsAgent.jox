    <JadeMethod name="createFileFolder" id="7043f66b-510c-4e17-92e8-ae05c1fc81ee">
        <updating/>
        <source>createFileFolder(_directoryName : String) updating;

/*

Purpose:		Create the file folder

Date			Who		Reason
05 April 2013	cnwmh5	Initial creation

*/

vars

	today					: TimeStamp;

begin
	
	today := app.actualTimeServer;	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	create self.fileFolder transient;
	//self.fileFolder.fileName := app.cnGetServerMiscPath() &amp; "\translationsRun\" &amp; app.computerName &amp; "\" &amp;
	self.fileFolder.fileName := "c:\temp\translationsRun\" &amp; app.computerName &amp; "\" &amp; _directoryName &amp;
		today.date.year.String &amp; today.date.month.padLeadingWith("0", 2) &amp; today.date.day.padLeadingWith("0", 2);
	self.fileFolder.usePresentationFileSystem := true;
	if not self.fileFolder.isAvailable then
		self.fileFolder.make();
	endif;
	
epilog

end;</source>
        <Parameter name="_directoryName" type="String"/>
    </JadeMethod>
    <JadeMethod name="createJDOForComparisonMethod" id="e27f0ca2-0669-4909-a5f9-0ceaf152bd37">
        <source>createJDOForComparisonMethod(_file : File input; _dict : DynaDictionary io);

/*

Purpose:		Create the JDO used for the comparison		

Date			Who		Reason
01/02/2012		cnwmh5	Initial creation

*/
constants
	AlphaCharacter				: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz";
vars

	jdo							: JadeDynamicObject;
	
	nextLineOfFile 				: String;
	previousLineOfFile			: String;
	currentClassName			: String;
	currentMethodName			: String;
	attribute					: String;
	text						: String;
	propertyType				: String;
	jdoCommentedOut				: Boolean;
	
	isCommentedOut				: Boolean;
	pos							: Integer;

begin

	if not _file.isAvailable then
		return;
	endif;
	
	_file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	
	while not _file.endOfFile do
	
		isCommentedOut := false;
		
		previousLineOfFile := nextLineOfFile;
		nextLineOfFile := _file.readLine();
		
		if nextLineOfFile.trimBlanks() = "{" then
			currentClassName := previousLineOfFile[1:previousLineOfFile.pos("::", 1) - 1];
			currentMethodName := previousLineOfFile[previousLineOfFile.pos("::", 1) + 2:end];
			continue;
		endif;
	
		if nextLineOfFile.trimBlanks() = "}" then
			currentClassName := null;
			currentMethodName := null;
			continue;
		endif;
	
		// if line doesn't contain ".translate" then don't want to know about it
		if not nextLineOfFile.cnContains(".translate") then
			continue;
		endif;
	
		// have a .tranlate line of code need to get the attribute, whether it's commented and create dynamic object
		nextLineOfFile.cnReplaceString(Tab, "");
		nextLineOfFile.cnReplaceString("( ", "(");
		nextLineOfFile.cnReplaceString(" )", ")");
		text := nextLineOfFile;
		
		// check to see if commented out
		pos := 1;
		if nextLineOfFile[1:2] = "//" then				
			isCommentedOut := true;
			pos := 3;
		endif;
		// get the starting point of the text
		nextLineOfFile.scanUntil(AlphaCharacter, pos);
		
		// get the attribute
		attribute := nextLineOfFile.scanUntil(".", pos);
		nextLineOfFile := nextLineOfFile[pos+1:end];
		
		// get what we are translation
		pos := 1;
		propertyType := nextLineOfFile.scanUntil("(", pos);
		propertyType := propertyType[10:end].trimBlanks();
		propertyType[1:1] := propertyType[1:1].toLower();
		
		jdo := _dict[currentClassName, currentMethodName, attribute, propertyType].JadeDynamicObject;
		write jdo.String &amp; Tab &amp; currentClassName &amp; Tab &amp; currentMethodName &amp; Tab &amp; attribute &amp; Tab &amp; propertyType &amp; Tab &amp; isCommentedOut.String;
		if jdo = null then
			create jdo transient;
			jdo.addProperty("className", String);
			jdo.setPropertyValue("className", currentClassName);
			jdo.addProperty("methodName", String);
			jdo.setPropertyValue("methodName", currentMethodName);
			jdo.addProperty("attribute", String);
			jdo.setPropertyValue("attribute", attribute);
			jdo.addProperty("propertyType", String);
			jdo.setPropertyValue("propertyType", propertyType);
			jdo.addProperty("isCommentedOut", Boolean);
			jdo.setPropertyValue("isCommentedOut", isCommentedOut);
			jdo.addProperty("text", String);
			jdo.setPropertyValue("text", text);
			_dict.putAtKey(currentClassName, currentMethodName, attribute, propertyType, jdo);
		else
			jdoCommentedOut := jdo.getPropertyValue("isCommentedOut").Boolean;
			write Tab &amp; jdoCommentedOut.String &amp; Tab &amp; text;
			
			if jdoCommentedOut then
				if not isCommentedOut then
					jdo.setPropertyValue('isCommentedOut', isCommentedOut);
				endif;
				jdo.setPropertyValue('text', text);
			else
				write jdo.String &amp; Tab &amp; currentClassName &amp; Tab &amp; currentMethodName &amp; Tab &amp; attribute &amp; Tab &amp; propertyType &amp; Tab &amp; isCommentedOut.String &amp; Tab &amp; 
					jdoCommentedOut.String &amp; Tab &amp; text;
				if not isCommentedOut then
					jdo.setPropertyValue('text', text);
				endif;
			endif;
		endif;	
		
	endwhile;
	
epilog

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_dict" type="DynaDictionary" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createTranslateFormScm" id="44a6ea5d-6c6b-44da-857a-d3213e7cd290">
        <updating/>
        <source>createTranslateFormScm() updating;

vars

begin
	self.log(method.qualifiedName &amp; ' - starting (form control caption translation: create translateForm methods and associated global constants)', true);

	// these are the application schemas we are interested in
	self.fillSchemas;

	// find all control classes that have a caption property
	self.z1_IdentifyControlsWithText;
	
	// put all global constants in a collection for conflict checking
//	zFindAllGlobalConstants;

	// put existing caption constants in a collection so we can check for changes
	if (not self.loadDefinedFormConstants) then
		return;
	endif;

	// Examine usage for each control class, to identify new or changed items
	self.z3_FindNewAndChangedControls;

	
	create fileFolder transient;
	self.z4_WriteSchemaFiles;
	
	
//	z5_SummariseConstants;
	
	self.log(method.qualifiedName &amp; ' - complete', true);
epilog
	delete fileFolder;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="d2867fc6-c932-419b-b130-66d5900e4850">
        <updating/>
        <source>delete() updating;

/*

Purpose:		

Date			Who		Reason
16/03/2015		cnwmh5	Initial creation

*/

vars
	
begin
	
	self.allConstantsByName.purge();
	self.allControlClassesWithTextProp.purge();
	self.allDefinedFormCaptionConstants.purge();
	self.allForms.purge();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="extractOutXLAT_FormCaptions" id="b19bc5e1-25d5-4bca-9f96-39499ff3a53b">
        <source>extractOutXLAT_FormCaptions();

/*

Purpose:		Extract out all XLAT_FormCaptions for checking	

Date			Who		Reason
13/02/2012		cnwmh5	Initial creation

*/
vars

	file					: File;
	constantCategory 		: ConstantCategory;
	constant				: Constant;
	constantNumber			: Integer;
	lsSchema 				: LSschema;
	lsClass 				: LSclass;
	lsConstant 				: LSconstant;
	text 					: String;
	constantNumberOut 		: Integer;
	
begin
	create file transient;
	file.usePresentationFileSystem := self.fileFolder.usePresentationFileSystem;
	file.openOutput(self.fileFolder.fileName &amp; '\PortSchema_xlats.scm');
	if file.isAvailable() then
		file.purge;
	endif;

	self.log('Creating PortSchema XLAT-FormCaptions scm: ' &amp; file.fileName, false);	
	
	file.writeLine(self.allSchemas.first.zScmHeader);
	
	constantCategory := rootSchema.getSchema(PortSchemaName).getConstantCategory(XLAT_FormCaptions);
	file.writeLine('constantDefinitions');

	// constant category
	file.writeLine(Tab &amp; 'categoryDefinition ' &amp; constantCategory.name);
	file.writeLine(Tab &amp; 'documentationText');
	file.writeLine('`' &amp; XML_Version &amp; 'TranslationClass ClassName="' &amp; XLAT_FormCaption.name &amp; '"&gt;');
	file.writeLine('&lt;/TranslationClass&gt;`');
	
	foreach constant in constantCategory.getConstants do
		
		// now write the constant definition to the scm file	
		file.writeLine(Tab &amp; Tab &amp; constant.name &amp; ':	Integer = ' &amp; constant.getSource() &amp; ';');
		file.writeLine(Tab &amp; 'documentationText');
		file.writeLine('`' &amp; constant.text &amp; '`');
		
	endforeach;

	self.log('	Complete: ' &amp; file.fileLength.String &amp; ' bytes', false);
epilog
	delete file;
end;
</source>
    </JadeMethod>
    <JadeMethod name="fillControls" id="00a464aa-9978-4ffe-b193-4322778f0e03">
        <source>fillControls() protected;

vars
	lsSchema : LSschema;
	class : Class;
	subs : ClassColl;

begin
	create subs transient;
	foreach lsSchema in allSchemas do
		subs.clear;
		lsSchema.mySchema.getClass(Form.name).allLocalSubclasses(subs);
		foreach class in subs do
			lsSchema.getLSclass(class.name);
		endforeach;
	endforeach;
epilog
	delete subs;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getLogString" id="a024b1e7-02d0-4b08-9428-1055a789f095">
        <source>getLogString(_value : String) : String protected;

/*

Purpose:			Get the string to log for the passed in value - if the input has blank spaces
					at either end, then return it quoted, otherwise return it as it is

Parameters:			value to be logged

Return Value:		String to be logged, including quotes iof required


Date		Who		Reason
18 Jun 2008	cnwkpd1	PAR #17145 - Form translation isssues

*/

vars

begin
	if _value &lt;&gt; _value.trimBlanks then
		return '"' &amp; _value &amp; '"';
	else
		return _value;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMaxConNumFromDict" id="f309f1e7-0b04-4725-92b4-ae8fb1600c5c">
        <source>getMaxConNumFromDict(_lsDict : LSconstantDictionary):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2017	cnwns1	Initial creation
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/

vars
	constantNumber : Integer;
	lsConstant : LSconstant;
begin
	if _lsDict &lt;&gt; null  then
		foreach lsConstant in _lsDict do
			constantNumber := constantNumber.max(lsConstant.LSconstant.number);
		endforeach;
	endif;
	
	return constantNumber;
epilog

end;</source>
        <Parameter name="_lsDict" type="LSconstantDictionary"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleFormTranslation" id="f826a84c-6809-49fe-bed9-6382ec101668">
        <source>handleFormTranslation(_obj : Object; _schemaName, _formName, _propertyName : String;
	lsSchema : LSschema input; lsClass : LSclass input; numToCreate : Integer io) protected;
// ---------------------------------------------------------------------------
// Created:     01 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
vars
	lsConstant 	: LSconstant;
	controlName	: String;
	tmpText		: String;
	logMsg		: String;
	highestConstantNumber : Integer;	//TFS 36423
begin
	// _obj can be a Form, Control or MenuItem instance
	tmpText := _obj.getPropertyValue(_propertyName).String.trimBlanks;
	controlName := _obj.getPropertyValue('name').String;
	
	highestConstantNumber := self.highestConstantNumber;	//TFS 36423
	
	if tmpText &lt;&gt; null then
		
		lsConstant := self.allDefinedFormCaptionConstants[_schemaName, _formName, controlName, _propertyName];

		// If necessary, create the new LSconstant object and add to LSclass and LSschema collections.
		if lsConstant = null then

			// Skip forms where caption has not been changed from its default of the form name
			if _formName = controlName and tmpText = _formName then
				self.log('NOT ' &amp; _formName &amp; Tab &amp; controlName &amp; Tab &amp; _propertyName &amp; ' (value has not been changed from the default form name)', true);
				return;
			endif;
		
			numToCreate := numToCreate + 1;
			create lsConstant transient;
			lsConstant.schemaName := _schemaName;
			lsConstant.formName := _formName;
			lsConstant.controlName := controlName;
			lsConstant.controlProperty := _propertyName;
	//		lsConstant.name := self.makeConstantNameOld(_formName, controlName, _propertyName);	//TFS 36423
			lsConstant.name := self.makeConstantName(lsConstant,highestConstantNumber);			//TFS 36423
			highestConstantNumber := highestConstantNumber +1;									//TFS 36423
			
			lsConstant.text := tmpText;
			self.allConstantsByName.add(lsConstant);
			lsClass.allConstants.add(lsConstant);
			lsSchema.allConstants.add(lsConstant);
			
			self.log('NEW ' &amp; lsConstant.name &amp; Tab &amp;
				lsConstant.formName &amp; Tab &amp; 
				lsConstant.controlName &amp; Tab &amp;
				lsConstant.controlProperty &amp; Tab &amp;
				self.getLogString(lsConstant.text), true);

		elseif _formName = controlName and tmpText = _formName then
			logMsg	:=	'*** WARNING - Form name caption is still set at default ' &amp; lsConstant.name &amp; Tab &amp;
						lsConstant.formName &amp; Tab &amp; 
						lsConstant.controlName &amp; Tab &amp;
						lsConstant.controlProperty &amp; Tab &amp;
						self.getLogString(lsConstant.text);
			self.log(logMsg, true);
			app.createAlert(logMsg.replaceString(Tab, " "), true);
				
		elseif tmpText.trimBlanks.toUpper = lsConstant.text.trimBlanks.toUpper then
			self.log('OLD ' &amp; lsConstant.name &amp; Tab &amp;
				lsConstant.formName &amp; Tab &amp; 
				lsConstant.controlName &amp; Tab &amp;
				lsConstant.controlProperty &amp; Tab &amp;
				self.getLogString(lsConstant.text), true);
		
		else
			logMsg	:=	'*** WARNING - Existing constant has different value ' &amp; 
						lsConstant.name &amp; Tab &amp;
						lsConstant.formName &amp; Tab &amp; 
						lsConstant.controlName &amp; Tab &amp;
						lsConstant.controlProperty &amp; Tab &amp;
						self.getLogString(lsConstant.text) &amp; Tab &amp;
						self.getLogString(tmpText);
			self.log(logMsg, true);
			app.createAlert(logMsg.replaceString(Tab, " "), true);
				
			// KPD - Testing - uncomment following lines to force extract of changes as well
			lsConstant.text := tmpText;
			lsClass.allConstants.add(lsConstant);
			lsSchema.allConstants.add(lsConstant);
				
		endif;
		
		// 09/06/2011 cnwmh5 #27657 - remove from global constants to delete if exists in collection
		///if self.allSchemas[PortSchemaName].allGlbConstantsToDelete.includes(lsConstant) then
		///	self.allSchemas[PortSchemaName].allGlbConstantsToDelete.remove(lsConstant);
		///endif;
		
	else
		self.log('NOT ' &amp; _formName &amp; Tab &amp; controlName &amp; Tab &amp; _propertyName &amp; ' (value is null)', true);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_schemaName" type="String"/>
        <Parameter name="_formName" type="String"/>
        <Parameter name="_propertyName" type="String"/>
        <Parameter name="lsSchema" type="LSschema" usage="input"/>
        <Parameter name="lsClass" type="LSclass" usage="input"/>
        <Parameter name="numToCreate" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="handleFormTranslation2" id="f76beeda-cb88-4851-98eb-f354ee7b759e">
        <updating/>
        <source>handleFormTranslation2(_lsSchema : LSschema io; _lsClass : LSclass io; _constantName, _controlName, _controlProperty, _text, 
	_commentedOutTextStartOfLine, _commentedOutTextEndOfLine : String; _isCommentedOut, _updateSchema : Boolean) updating;

/*

Purpose:		Create / Update the LSconstant with the correct details	

Date			Who		Reason
17/01/2012		cnwmh5	Initial creation
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/

vars

	xmlDoc					: JadeXMLDocument;
	xmlElement				: JadeXMLElement;
	textElement				: JadeXMLElement;
	xmlAttribute			: JadeXMLAttribute;
	
	constantObj				: Constant;
	lsConstant				: LSconstant;
	lsSchema				: LSschema;
	
	controlName				: String;
	constantName 			: String;
	constantNumber			: Integer;
	captionText				: String;
	updateSchema			: Boolean;
	formClass				: String;
	text					: String;

begin

	text := _text;

	constantObj := rootSchema.getSchema(PortSchemaName).getConstant(_constantName);
	controlName := _controlName;
	
	if constantObj &lt;&gt; null then
		// no xml then error as should have xml
		if constantObj.text = null then
			app.writeStatement("*** Error - No XML Text (" &amp; constantObj.name &amp; " - " &amp; constantObj.getSource() &amp; ")");
			write "*** Error - No XML Text (" &amp; constantObj.name &amp; " - " &amp; constantObj.getSource() &amp; ")";
			return;
		endif;
		
		delete xmlDoc;
		create xmlDoc transient;
		xmlDoc.parseString(constantObj.text);
		xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);
		// Get the text
		textElement := xmlElement.findElement(XMLTag_Msg, null);
		text := textElement.text;
		// Get the controlName
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_ControlName);
		if xmlAttribute = null then
			app.writeStatement("***** ERROR - Constant (" &amp; constantObj.name &amp; " - " &amp; constantObj.getSource() &amp; ") isn't a Form Translation Constant");
			write "***** ERROR - Constant (" &amp; constantObj.name &amp; " - " &amp; constantObj.getSource() &amp; ") isn't a Form Translation Constant";
			return;
		endif;
		controlName := xmlAttribute.value;
		// get the form class
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_FormClass);
		if xmlAttribute = null then
			app.writeStatement("***** ERROR - Constant (" &amp; constantObj.name &amp; " - " &amp; constantObj.getSource() &amp; ") isn't a Form Translation Constant");
			write "***** ERROR - Constant (" &amp; constantObj.name &amp; " - " &amp; constantObj.getSource() &amp; ") isn't a Form Translation Constant";
			return;
		endif;
		formClass := xmlAttribute.value;
		if _controlName = "self" then
			controlName := _lsClass.name;
			formClass := controlName;
		//elseif formClass = _lsClass.name and _controlName &lt;&gt; controlName then
		elseif _controlName &lt;&gt; controlName then
			controlName := _controlName;
		endif;
		constantNumber := constantObj.getSource().Integer;
	else
		if _controlName = "self" then
			controlName := _lsClass.name;
			if text = null then
				text := controlName;
			endif;
		endif;
	endif;

	lsConstant := _lsClass.allConstants[_lsSchema.name, _lsClass.name, controlName, _controlProperty];		
	if lsConstant = null then
		if _controlName = "self" or text &lt;&gt; null then
			create lsConstant transient;
			lsConstant.schemaName := _lsSchema.name;
			lsConstant.formName := _lsClass.name;
			lsConstant.controlName := controlName;
			lsConstant.controlProperty := _controlProperty;
			if _constantName = null then																				//TFS 36423
				lsConstant.name := self.makeConstantName(lsConstant,self.getMaxConNumFromDict(_lsClass.allConstants));	//TFS 36423
			else																										//TFS 36423
				lsConstant.name :=  _constantName;																		//TFS 36423
				lsConstant.number := constantNumber;																	//TFS 36423
			endif;																										//TFS 36423
			lsConstant.commentedOutTextStartOfLine := _commentedOutTextStartOfLine;
			lsConstant.isCommentedOut := _isCommentedOut;			
			lsConstant.text := text;
			lsConstant.commentedOutTextEndOfLine := _commentedOutTextEndOfLine;
			_lsClass.allConstants.add(lsConstant);
			if self.allConstantsByName[lsConstant.name] = null then
				self.allConstantsByName.add(lsConstant);
			endif;
			if _updateSchema or updateSchema then
				_lsSchema.allConstants.add(lsConstant);
			endif;
		endif;
	else
		if lsConstant.isCommentedOut and not _isCommentedOut then
			lsConstant.isCommentedOut := _isCommentedOut;
			lsConstant.name := _constantName;
			lsConstant.number := constantNumber;
			lsConstant.commentedOutTextEndOfLine := null;
			lsConstant.commentedOutTextStartOfLine := null;
			lsConstant.text := text;
		elseif lsConstant.isCommentedOut and _isCommentedOut then
			lsConstant.name := _constantName;
			lsConstant.number := constantNumber;
			lsConstant.commentedOutTextEndOfLine := _commentedOutTextEndOfLine;
			lsConstant.commentedOutTextStartOfLine := _commentedOutTextStartOfLine;
			lsConstant.text := text;
		elseif not lsConstant.isCommentedOut and not _isCommentedOut then
			if lsConstant.name &lt;&gt; _constantName then
				lsConstant.name := _constantName;
				lsConstant.number := constantNumber;
				lsConstant.commentedOutTextEndOfLine := _commentedOutTextEndOfLine;
				lsConstant.isCommentedOut := _isCommentedOut;
				lsConstant.commentedOutTextStartOfLine := _commentedOutTextStartOfLine;
				lsConstant.text := text;
			endif;
		endif;
	endif;
	
epilog

	delete xmlDoc;
	
end;
</source>
        <Parameter name="_lsSchema" type="LSschema" usage="io"/>
        <Parameter name="_lsClass" type="LSclass" usage="io"/>
        <Parameter name="_constantName" type="String"/>
        <Parameter name="_controlName" type="String"/>
        <Parameter name="_controlProperty" type="String"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_commentedOutTextStartOfLine" type="String"/>
        <Parameter name="_commentedOutTextEndOfLine" type="String"/>
        <Parameter name="_isCommentedOut" type="Boolean"/>
        <Parameter name="_updateSchema" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="highestConstantNumber" id="b68306d5-d2a1-4f18-a7ac-372e06360a92">
        <source>highestConstantNumber() : Integer;

vars
	number : Integer;
	constant : Constant;
begin
	foreach constant in rootSchema.getSchema(PortSchemaName).getCategory("XLAT_FormCaptions").getConstants discreteLock do
		number := number.max(constant.getPropertyValue("source").Integer);
	endforeach;
	return number;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initAllForms" id="e53d0e10-a2ef-4c96-8fe3-d924f5c1a786">
        <source>initAllForms();
// ---------------------------------------------------------------------------
// Created:     01 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	subs : ClassColl;

begin
	self.allForms.clear;

	self.log("Identifying form subclasses of CM_BaseForm ...", true);
	create subs transient;

	rootSchema.getSchema(UiCommonSchemaName).getClass(CM_BaseForm.name).allSubclasses(subs);
	rootSchema.getSchema(UiCommonSchemaName).getClass(CM_BaseForm.name).allSubclassesInSubschemas(subs);

	//
	// Have to use literal as we can not see MOB_BaseForm from here
	//
	self.log("Identifying form subclasses of MOB_BaseForm ...", true);
	rootSchema.getSchema(MobileUISchemaName).getClass('MOB_BaseForm').allSubclasses(subs);
	rootSchema.getSchema(MobileUISchemaName).getClass('MOB_BaseForm').allSubclassesInSubschemas(subs);

	subs.copy(self.allForms);
	self.log("	Count: " &amp; self.allForms.size.String, true);
epilog
	delete subs;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDefinedFormConstants" id="e48c9ad9-f2c4-4551-bc55-cf8de43b7900">
        <source>loadDefinedFormConstants() : Boolean;

/*

Date		Who		Reason
18 Jun 2008	cnwkpd1	PAR #17145 - Form translation issues
09/06/2011	cnwmh5	#27657 - Add additional checking in and change processing to accommodate
*/

vars
	constantObj		: Constant;
	allMethodRefs	: MethodSet;
	lsSchema		: LSschema;
	lsClass			: LSclass;
	otherConstant	: LSconstant;
	lsConstant		: LSconstant;
	controlName		: String;
	controlProperty	: String;
	schemaName		: String;
	formClass		: String;
	xmlDoc			: CM_XMLDocument;
	xmlElement		: JadeXMLElement;
	errStr			: String;
	textElement		: JadeXMLElement;
	textValue		: String;
	logMsg			: String;
	actualFormClass	: String;
	classesUsedIn	: String;
	meth			: Method;
	warningUnRef	: Boolean;
	warningNoJade	: Boolean;
	xmlDoc2			: CM_XMLDocument;
	xmlElement2		: JadeXMLElement;
	textElement2	: JadeXMLElement;
	textValue2		: String;
	tmpConstantObj	: Constant;
	usageWrong		: Boolean;
	usedInClasses	: StringArray;
	ignore			: Boolean;
	usedInJadeScript : Boolean;
	
begin
	self.log("Getting a list of all existing defined Form Caption constants...", true);
	create allMethodRefs transient;
	create usedInClasses transient;
	
	foreach constantObj in rootSchema.getSchema(PortSchemaName).getCategory(XLAT_FormCaptions).getConstants do
	
		logMsg := null;
		errStr := null;
		classesUsedIn := null;
		textValue := null;
		textValue2 := null;
		
		if constantObj.text = null then
			logMsg	:=	"*** WARNING no xml text: " &amp; constantObj.name;
			self.log(logMsg, true);
			app.createAlert(logMsg, true);
			continue;
		endif;
		
		//allMethodRefs.clear();
		//constantObj.getMethodRefs(allMethodRefs);
		
		//if allMethodRefs.isEmpty() then
		//	self.log("Unreferenced Global Constant: " &amp; constantObj.name, true);
		//endif;
		
		delete xmlDoc;
		create xmlDoc transient;

		xmlDoc.parseString(constantObj.text);
		xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);

		// get local transient schema &amp; class objects
		schemaName := xmlElement.getAttributeByName(XML_Tag_SchemaName).value;
		formClass := xmlElement.getAttributeByName(XML_Tag_FormClass).value;
		actualFormClass := formClass;
		lsSchema := allSchemas[schemaName];
		
		if lsSchema = null then
			// assume not one of the schemas we have selected to look at
			continue;
		endif;
		
		lsClass := lsSchema.getLSclass(formClass);
		
		// 09/06/2011 cnwmh5 #27657
		usedInJadeScript := false;
		allMethodRefs.clear();
		usedInClasses.clear();
		constantObj.getMethodRefs(allMethodRefs);
		foreach meth in allMethodRefs do
			if meth.schemaType.name &lt;&gt; "JadeScript" then
				usedInClasses.add(meth.schemaType.name);
			else
				usedInJadeScript := true;
			endif;
		endforeach;
		
		warningUnRef := false;
		if allMethodRefs.isEmpty() then
			logMsg	:=	"*** INFO - Unreferenced Global Constant (" &amp; formClass &amp; "): " &amp; constantObj.name;
			self.log(logMsg, true);
			//app.createAlert(logMsg, true);
			warningUnRef := true;
		endif;
		
		warningNoJade := false;
		if lsClass = null and not warningUnRef then
			if allMethodRefs.size = 1 then
				logMsg := "*** INFO - No JADE Class (" &amp; formClass &amp; "): " &amp; constantObj.name &amp; " " &amp; usedInClasses.concatenate(" / ");
				self.log(logMsg, true);
			else
				logMsg	:=	"*** WARNING - No JADE Class (" &amp; formClass &amp; "): " &amp; constantObj.name &amp; " " &amp; usedInClasses.concatenate(" / ");
				self.log(logMsg, true);
				app.createAlert(logMsg, true);
			endif;
			warningNoJade := true;
		endif;
		
		//if lsClass = null then
		//	logMsg	:=	"*** WARNING - No JADE Class (" &amp; formClass &amp; "): " &amp; constantObj.name;
		//	self.log(logMsg, true);
		//	app.createAlert(logMsg, true);
		//	continue;
		//endif;

		controlName := xmlElement.getAttributeByName(XML_Tag_ControlName).value;
		controlProperty := xmlElement.getAttributeByName(XML_Tag_ControlProperty).value;
		
		textElement := xmlElement.findElement(XMLTag_Msg, null);
		if textElement &lt;&gt; null then
			textValue := textElement.text;
		else
			textValue := null;
		endif;
				
		// PAR #17145 - changed duplicate check to a warning, because we can have manually defined 
		// constants for controls with more than one alternate caption
		ignore := false;
		foreach classesUsedIn in usedInClasses do
			otherConstant := self.allDefinedFormCaptionConstants[schemaName, classesUsedIn, controlName, controlProperty];
			if otherConstant = null then
				continue;
			endif;
	
			if otherConstant &lt;&gt; null then //and (not warningUnRef and not usageWrong) then
				errStr := 'Duplicate constant (' &amp; otherConstant.name &amp; ') found for ' &amp;
					schemaName &amp; ' - ' &amp; classesUsedIn &amp; ' - ' &amp; controlName &amp; ' - ' &amp; controlProperty &amp;
					'  -&gt; ' &amp; constantObj.name;
				tmpConstantObj := rootSchema.getSchema(PortSchemaName).getConstant(otherConstant.name);
				if tmpConstantObj &lt;&gt; null then
					delete xmlDoc2;
					create xmlDoc2 transient;
					xmlDoc2.parseString(tmpConstantObj.text);
					xmlElement2 := xmlDoc2.getElementByTagName(XMLTag_Header);
					textElement2 := xmlElement2.findElement(XMLTag_Msg, null);
					if textElement2 &lt;&gt; null then
						textValue2 := textElement2.text;
					else
						textValue2 := null;
					endif;
					logMsg	:=	"*** WARNING - " &amp; errStr &amp; Tab &amp; textValue &amp; Tab &amp; textValue2;
					self.log(logMsg, true);
					app.createAlert(logMsg, true);
				else
					logMsg	:=	"*** WARNING - " &amp; errStr &amp; Tab &amp; textValue &amp; Tab &amp; textValue2;
					self.log(logMsg, true);
					app.createAlert(logMsg, true);
				endif;
			endif;
			
			if textValue &lt;&gt; textValue2 then
				continue;
			endif;
			
			create lsConstant transient;
			lsConstant.schemaName := schemaName;
			lsConstant.formName := classesUsedIn;
			lsConstant.controlName := controlName;
			lsConstant.controlProperty := controlProperty;
			lsConstant.name := constantObj.name;
			lsConstant.text := textValue;
			lsConstant.number := constantObj.getSource().Integer;
			if allConstantsByName[lsConstant.name] = null then
				allConstantsByName.add(lsConstant);
			endif;
			if allDefinedFormCaptionConstants[schemaName, classesUsedIn, controlName, controlProperty] = null then
				allDefinedFormCaptionConstants.add(lsConstant);
			endif;
			lsSchema := allSchemas[schemaName];
			lsClass := lsSchema.getLSclass(classesUsedIn);
			///lsClass.allConstForMethFix.add(lsConstant);
			///if usedInClasses.size = 1 and not usedInJadeScript then
			///	allSchemas[PortSchema.name].allGlbConstantsToDelete.add(lsConstant);
			///endif;
			if lsSchema.allClasses[lsClass.name] = null then
				lsSchema.allClasses.add(lsClass);
			endif;
			lsSchema.allConstants.add(lsConstant);
			ignore := true;
		endforeach;

		if ignore then
			continue;
		endif;
		
		// Create the new LSconstant object and add to allDefinedFormCaptionConstants
		create lsConstant transient;
		lsConstant.schemaName := schemaName;
		//lsConstant.formName := formClass;
		lsConstant.formName := actualFormClass;
		lsConstant.controlName := controlName;
		lsConstant.controlProperty := controlProperty;
		lsConstant.name := constantObj.name;
		lsConstant.text := textValue;
		lsConstant.number := constantObj.getSource().Integer;
		allConstantsByName.add(lsConstant);
		allDefinedFormCaptionConstants.add(lsConstant);
		///if warningUnRef then
		///	allSchemas[PortSchemaName].allGlbConstantsToDelete.add(lsConstant);
		if warningNoJade then
			allSchemas[PortSchemaName].allConstants.add(lsConstant);
		endif;
		
		/*
		otherConstant := self.allDefinedFormCaptionConstants[schemaName, formClass, controlName, controlProperty];
		
		if otherConstant &lt;&gt; null then
			errStr := 'Duplicate constant (' &amp; otherConstant.name &amp; ') found for ' &amp;
				schemaName &amp; ' - ' &amp; formClass &amp; ' - ' &amp; controlName &amp; ' - ' &amp; controlProperty &amp;
				'  -&gt; ' &amp; constantObj.name;
			logMsg	:=	"*** WARNING - " &amp; errStr;
			self.log(logMsg, true);
			app.createAlert(logMsg, true);
		endif;

		// Create the new LSconstant object and add to allDefinedFormCaptionConstants
		create lsConstant transient;
		lsConstant.schemaName := schemaName;
		lsConstant.formName := formClass;
		lsConstant.controlName := controlName;
		lsConstant.controlProperty := controlProperty;
		lsConstant.name := constantObj.name;
		lsConstant.text := textValue;
		lsConstant.number := constantObj.getSource().Integer;
		allConstantsByName.add(lsConstant);
		allDefinedFormCaptionConstants.add(lsConstant);
		*/
		
	endforeach;

	self.log("	Existing defined Form Caption constants: " &amp; allDefinedFormCaptionConstants.size.String, true);
	
	return true;
epilog
	delete xmlDoc;
	delete allMethodRefs;
	delete xmlDoc2;
	delete usedInClasses;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="makeConstantName" id="bdebb235-fa14-4fdd-827e-c05d1401f2df">
        <source>makeConstantName(_lsConstant : LSconstant io ; _highestNumberOnForm : Integer ) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2017	cnwns1	Initial creation
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/
constants
	
vars
	constantNumber : Integer;
	otherConst : Object ;
	highestNumber : Integer;
	constantName : String;
begin

	if not app.isDevelopmentSystemMain() then
		return null;
	endif;

	if _lsConstant &lt;&gt; null and _lsConstant.number &gt; 0 then
		constantNumber := _lsConstant.number;
	elseif _highestNumberOnForm &gt; 0 then	
		constantNumber := _highestNumberOnForm + 1;
	else	
		constantNumber := self.highestConstantNumber + 1;
	
		if _lsConstant &lt;&gt; null then
			_lsConstant.number := constantNumber;
		endif;
	endif;
		
	constantName := self.makeConstantNameString(constantNumber);
	
	if _lsConstant &lt;&gt; null and _lsConstant.number = 0 then
		_lsConstant.number := constantNumber;
	endif;
	
	return constantName;
	
epilog

end;</source>
        <Parameter name="_lsConstant" type="LSconstant" usage="io"/>
        <Parameter name="_highestNumberOnForm" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeConstantNameForGenLoadForm" id="5195759f-a0e4-4f01-9f49-cae9d5d052f2">
        <source>makeConstantNameForGenLoadForm(_lsConstant : LSconstant io; _highestNumberOnForm : Integer) : String;

//makeConstantNameForGenLoadForm(formClass : String; controlName : String; controlProperty : String) : String;

/*

Purpose:		Get the constant name for the Generate / Load translateForm Method form		

Date			Who		Reason
27/01/2012		cnwmh5	Initial creation
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/

vars
	constantName				: String;
begin

//	constantName := self.makeConstantNameOld(formClass, controlName, controlProperty);
	constantName := self.makeConstantName(_lsConstant,_highestNumberOnForm);
	return constantName;
	
epilog

end;</source>
        <Parameter name="_lsConstant" type="LSconstant" usage="io"/>
        <Parameter name="_highestNumberOnForm" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeConstantNameOld" id="503a21bf-e079-4794-82f0-57192d80db0c">
        <source>makeConstantNameOld(formClass : String; controlName : String; controlProperty : String) : String protected;

// make a unique constant name up to max 30 chars based on form (class) and control name
// &lt;class-part&gt;_&lt;control-name-part&gt;
// &lt;class-part&gt; minimum length ClassPartMin, &lt;control-name-part&gt; gets priority, up to remainder
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
constants
	ClassPartMin = 9;
	MaxLength	 = 30;
	MaxTries = 30;
	AscSpace = ' '.Character.Integer;
	Suffices = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwx';
	
vars
	classPart	: String;
	prefix		: String;
	overflow	: Integer;
	remainder	: Integer;
	classPartLen: Integer;
	randomChar	: String[1];
	constantName: String;
	triesCount	: Integer;
	logMsg		: String;

begin
	if controlProperty = 'caption' then
		prefix := 'C';
	elseif  controlProperty = 'bubbleHelp' then
		prefix := 'B';
	else
		beginTransaction;beginTransaction; // error
	endif;

	overflow := (formClass.length + controlName.length - MaxLength);

	if overflow &gt; 0 then
		classPartLen := (MaxLength - controlName.length).max(ClassPartMin);
	else
		classPartLen := MaxLength - controlName.length;
	endif;

	classPart := formClass[1:classPartLen] &amp; '_' &amp; prefix;
	remainder := MaxLength - classPart.length;

	constantName := classPart &amp; controlName[1:remainder];


	// make sure the constant name is unique (simple algorithm swaps last character)
	while allConstantsByName[constantName] &lt;&gt; null do
		write class.name &amp; '::' &amp; method.name &amp; Tab &amp; constantName;

		randomChar := Suffices[app.random(Suffices.length-1)+1].String;
		if constantName.length &lt; MaxLength then
			// append another character
			constantName := constantName &amp; randomChar;
		else
			constantName := constantName[1:constantName.length-1] &amp; randomChar;
//			constantName := classPart[1:classPart.length-2] &amp; randomChar &amp; '_' &amp; controlName[1:remainder];
		endif;

		logMsg	:=	"*** INFO *** Control constant name conflict, resolved for " &amp; formClass &amp; '::' &amp; controlName &amp; ' -&gt; ' &amp; constantName;
		self.log(logMsg, false);
		////app.createAlert(logMsg, true);	// #27657

		// get out of jail card
		triesCount := triesCount + 1;
		if triesCount &gt; MaxTries then
			logMsg	:=	"*** ERRROR *** Control constant name conflict, could not be resolved for " &amp; formClass &amp; '::' &amp; controlName &amp; ' -&gt; ' &amp; constantName;
			self.log(logMsg, true);
			app.createAlert(logMsg, true);
//			process.debug;
			break;
		endif;
	endwhile;

	return constantName;			
end;</source>
        <access>protected</access>
        <Parameter name="formClass" type="String"/>
        <Parameter name="controlName" type="String"/>
        <Parameter name="controlProperty" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeConstantNameString" id="3e65a3bf-efb2-4542-af04-fe4ff06ba04c">
        <source>makeConstantNameString(_constantNumber :Integer ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2017	cnwns1	Initial creation
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/
constants
	XLat = "Xlat_";
vars

begin
	return	XLat &amp; _constantNumber.padLeadingWith("0",7);
epilog

end;</source>
        <Parameter name="_constantNumber" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processAllForms" id="5e1ac2a9-c95d-4782-8448-273818c94bb7">
        <updating/>
        <source>processAllForms() updating;
// ---------------------------------------------------------------------------
// Created:     01 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	obj			: Object;
	numToCreate	: Integer;
	
begin
	self.log("Looking for new global constants that are required ...", true);
	
	foreach obj in self.allForms do
		//if obj.Class.name &lt;&gt; 'CM_BaseForm' then
		//	continue;
		//endif;

		self.processForm(obj.Class);
	endforeach;

	self.log("	Forms: " &amp; self.zCountForms.String, true);
end;</source>
    </JadeMethod>
    <JadeMethod name="processForm" id="39d68a10-8aa6-4d1e-b1aa-91b4efa36b73">
        <updating/>
        <source>processForm(_form : Class) updating;
// ---------------------------------------------------------------------------
// Created:     01 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 30/01/2012	cnwmh5	Call new process form methods method
// ---------------------------------------------------------------------------
vars
	formClass		: Class;
	constDict       : ConstantNDict;
	constant        : Constant;
	constantSource  : String;
	cntrl			: Control;
	lsSchema		: LSschema;
	lsClass			: LSclass;
	schemaName		: String;
	formClassName	: String;
	numToCreate		: Integer;
	tmpForm			: Form;
	tmpMenu			: MenuItem;
	i				: Integer;
	numControls		: Integer;
	numMenus		: Integer;
	logMsg			: String;

begin
	formClass := _form;
	formClassName := formClass.name;
	schemaName := formClass.schema.name;
	
	foreach tmpForm in Form.instances do
		if tmpForm.name = formClassName then
			break;
		endif;
	endforeach;
	
	if tmpForm = null or tmpForm.name &lt;&gt; formClassName then
		self.log('No form found for ' &amp; formClassName, true);
		return;
	endif;
	
	schemaName := formClass.schema.name;
	lsSchema := self.allSchemas[formClass.schema.name];
	
	if lsSchema = null then
		self.log('Schema not found for (' &amp; formClass.schema.name &amp; ') - skipping', true);
		return;
	endif;
	
	lsClass := lsSchema.getLSclass(formClass.name);
	if lsClass = null then
		logMsg	:=	"*** WARNING no JADE Class (" &amp; formClassName &amp; ")";
		self.log(logMsg, true);
		app.createAlert(logMsg, true);
		return;
	endif;
	
	// At this point we need to read through all the classes on the form and setup the class and constant data
	self.processFormMethodDetails(lsSchema, lsClass);
	
	
	//
	// This code requires that each form has a Constant of 'TranslationRequired'
	// The type must be 'String' and the definition either 'yes' or 'no'
	//
	// commented out until decision is made on how to use
	/*
	create constDict transient;
	
	lsClass.myClass.getConstants(constDict);
	if constDict.size = 0 then
		self.log(formClassName &amp; '::' &amp; 'no TranslationRequired constant', true);
		return;
	endif;
	
	constant := constDict['TranslationRequired'];
	
	if constant = null then
		self.log(formClassName &amp; '::' &amp; 'no TranslationRequired constant', true);
	else

		constantSource := constant.getSource.toLower;
		
		if constantSource = "'#no'" or constantSource = '"#no"'  then
			self.log(formClassName &amp; '::' &amp; 'Translation not required', true);
			//return;
		endif;
	
		if constantSource &lt;&gt; "'#yes'" or constantSource &lt;&gt; '"#yes"' then
		else
			self.log(formClassName &amp; '::' &amp; 'TranslationRequired literal invalid ' &amp; constantSource, true);
			//return;
		endif;
	endif;
	*/
	/*
	self.handleFormTranslation(tmpForm, schemaName, formClassName, 'caption', lsSchema, lsClass, numToCreate);
	
	numControls := tmpForm.controlCount;
	foreach i in 1 to numControls do
		cntrl := tmpForm.controls(i);
		
		if cntrl.isKindOf(Button)
		or cntrl.isKindOf(Label)
		or cntrl.isKindOf(JadeDockBase)
		or cntrl.isKindOf(StatusLine)
		or cntrl.isKindOf(GroupBox)
		or cntrl.isKindOf(Frame)
		or cntrl.isKindOf(CheckBox)
		or cntrl.isKindOf(OptionButton)
		then
			self.handleFormTranslation(cntrl, schemaName, formClassName, 'bubbleHelp', lsSchema, lsClass, numToCreate);
			self.handleFormTranslation(cntrl, schemaName, formClassName, 'caption', lsSchema, lsClass, numToCreate);
		endif;
	endforeach;
	
	numMenus := tmpForm.menuItemCount;
write class.name &amp; '::' &amp; method.name &amp; '  ' &amp; tmpForm.name &amp; '  ' &amp; numMenus.String;
	foreach i in 1 to numMenus do
		tmpMenu := tmpForm.menuItems(i);
		
		if tmpMenu.isSeparatorJMT() then
			self.log(class.name &amp; '::' &amp; method.name &amp; ' SEPARATOR ' &amp; tmpMenu.name, true);
			continue;
		endif;
		
		if tmpMenu.name = null then
			self.log(class.name &amp; '::' &amp; method.name &amp; ' NULL MENU NAME ', true);//&amp; tmpMenu.name;
			continue;
		endif;
		
write class.name &amp; '::' &amp; method.name &amp; '  ' &amp; tmpForm.name &amp; '  ' &amp; tmpMenu.name &amp; ' &gt;&gt;&gt;&gt;  ' &amp; tmpMenu.caption;
		self.handleFormTranslation(tmpMenu, schemaName, formClassName, 'caption', lsSchema, lsClass, numToCreate);
	endforeach;
	*/
	
epilog
	delete constDict;
end;</source>
        <Parameter name="_form" type="Class"/>
    </JadeMethod>
    <JadeMethod name="processFormMethodDetails" id="61f10d7f-18c5-4dae-9473-2555173e58cd">
        <updating/>
        <source>processFormMethodDetails(_lsSchema : LSschema io; _lsClass : LSclass io) updating;

/*

Purpose:		Get / Create the constants required to build the translateForm method

The following rules cause an error / warning to occur.  I've included those that are checked but don't cause an error / warning to occur.
		
		No Warning / Error
		------------------
		* Constant doesn't exist and line is commented out
		
		Warning
		-------
		* Constant has no XML in its text (Needs to be addressed)
		* Form caption is still default
		* Constant exists with different text (Needs to be addressed)
		
		Error
		-----
		* Unable to find Xlat_FormCaption constant (Needs to be addressed)
		* Constant isn't a Xlat_FormCaption constant (Needs to be addressed)

Date			Who		Reason
16 January 2012	cnwmh5	Initial creation
15/10/2012		cnwmh5 	Fix issue with meth = null
12/04/2013		cnwmh5	Fix issue where bubbleHelp isn't getting found for at least ComboBox, Picture, TextBox, Table controls.
						These are the ones that were found so fix will do all controls.
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out						

*/
constants
	TranslateCaption		: String = "translateCaption";
	TranslateCaption2		: String = ".caption";
	TranslateBubbleHelp		: String = "translateBubbleHelp";
	TranslateBubbleHelp2	: String = ".bubbleHelp";
	AlphaCharacters			: String = "abcdefghijklmnopqrstuvwxyz";
vars

	meth					: Method;
	lsConstant				: LSconstant;
	form					: Form;
	cntrl					: Control;
	tmpMenu					: MenuItem;
	prop					: Property;
		
	methSource				: String;
	attribute				: String;
	constant				: String;
	sourceLine				: String;
	str						: String;
	controlName				: String;
	constantProperty		: String;
	commentedOutStartOfLine	: String;
	commentedOutEndOfLine	: String;
	logMsg					: String;
	
	posCrLf					: Integer;
	length					: Integer;
	pos1					: Integer;
	pos2					: Integer;
	isCommentedOut			: Boolean;
	numControls				: Integer;
	index					: Integer;
	numMenus				: Integer;
	multiCommentOut			: Boolean;

begin
	
	meth := _lsClass.myClass.getMethod("translateForm");
	///if meth = null then
	///	return;
	///endif;
	if meth &lt;&gt; null then
		methSource := meth.getSource();
		length := methSource.length;
	
		posCrLf := -1;
		
		//create captionsAgent transient;
		
		// Read the source and see what is currently already defined
		// read through the file getting current constants
		while true do
		
			if methSource &lt;&gt; null then
				if posCrLf = -1 then
					posCrLf := 1;
				else
					posCrLf := posCrLf + 2;
				endif;
				if (posCrLf + 2) &gt; methSource.length then
					break;
				endif;
				methSource := methSource[posCrLf:end];
			endif;
		
			posCrLf := 1;
			posCrLf := methSource.pos(CrLf, posCrLf);
			if posCrLf = 0 or (posCrLf + 1) &gt; length then
				break;
			endif;
			sourceLine := methSource[1:posCrLf];		
			
			pos1 := 1;
			attribute := null;
			constant := null;
			isCommentedOut := multiCommentOut;
			commentedOutStartOfLine := null;
			commentedOutEndOfLine := null;
			
			// ok have translate need to get the details
			sourceLine.cnReplaceString(Tab, " ");
			sourceLine.cnReplaceString("( ", "(");
			sourceLine.cnReplaceString(" )", ")");
			
			// check to see if the following exist on the line and cause error message
			if sourceLine.cnContains(TranslateCaption2) or sourceLine.cnContains(TranslateBubbleHelp2) then
				pos1 := 1;
				str := sourceLine.scanUntil(AlphaCharacters, pos1);
				str.cnReplaceString(Tab, "");
				if str.trimBlanks().length = 0 and not isCommentedOut then
					logMsg := "*** Error - Unable to find Translation Global Constant for " &amp; _lsSchema.name &amp; ", " &amp; 
						_lsClass.name &amp; ', ' &amp; sourceLine;
					self.log(logMsg, true);
				endif;
				continue;
			endif;
	
			// if line doesn't have .translate then don't want to know about it
			pos1 := 1;
			pos1 := sourceLine.pos(".translate", pos1);
			if pos1 = 0 then
				continue;
			endif;
			
			// get the starting point of the text
			pos2 := sourceLine.reversePosIndex(" ", pos1);
			attribute := sourceLine[pos2+1:pos1-pos2-1];
			if pos2 &gt; 0 then
				commentedOutStartOfLine := sourceLine[1:pos2].trimBlanks();
				if commentedOutStartOfLine &lt;&gt; null and commentedOutStartOfLine.cnContains("//") then
					isCommentedOut := true;
				endif;
			endif;
			
			// get the attribute
			if attribute[1:2] = "//" then	
				pos2 := 1;
				commentedOutStartOfLine :=  sourceLine.scanUntil(AlphaCharacters, pos2);
				if commentedOutStartOfLine &lt;&gt; null and commentedOutStartOfLine.cnContains("//") then
					isCommentedOut := true;
				endif;
				attribute := sourceLine[pos2:pos1-pos2];
			endif;
			if attribute = "self" then
				if sourceLine[pos1:10] &lt;&gt; ".translate" then
					pos1 := pos1 + 1;
					attribute := sourceLine.scanUntil(".", pos1);
				endif;
			endif;
			sourceLine := sourceLine[pos1+1:end];
			
			// get what we are translation
			pos1 := 1;
			constantProperty := sourceLine.scanUntil("(", pos1);
			constantProperty := constantProperty[10:end].trimBlanks();
			constantProperty[1:1] := constantProperty[1:1].toLower();
			sourceLine := sourceLine[pos1+1:end];
			
			// get the constant
			pos1 := 1;
			constant := sourceLine.scanUntil(",", pos1);
			
			// if commented out see if there is a comment on the end of the line
			sourceLine.scanUntil(";", pos1);
			if pos1+1 &lt; sourceLine.length then
				commentedOutEndOfLine := sourceLine[pos1+1:end];
				commentedOutEndOfLine.cnReplaceString(Tab, "");
				commentedOutEndOfLine.cnReplaceString(Cr, "");
				commentedOutEndOfLine.cnReplaceString(Lf, "");
			endif;
			
			self.handleFormTranslation2(_lsSchema, _lsClass, constant, attribute, constantProperty, null, 
				commentedOutStartOfLine, commentedOutEndOfLine, isCommentedOut, false);
			
		endwhile;
	endif;
	
	// read through the form and see what is left to define
	foreach form in Form.instances do
		if form.name = _lsClass.name then
			break;
		endif;
	endforeach;
	
	lsConstant := _lsClass.allConstants[_lsSchema.name, form.name, form.name, 'caption'];			
	if lsConstant = null then
		
		self.handleFormTranslation2(_lsSchema, _lsClass, self.makeConstantName(lsConstant,self.getMaxConNumFromDict(_lsClass.allConstants)), 			//TFS 36423
			"self", 'caption', form.getPropertyValue('caption').String, null, null, false, true);														//TFS 36423
		//self.handleFormTranslation2(_lsSchema, _lsClass, self.makeConstantNameOld(_lsClass.name, form.getPropertyValue('name').String, 'caption'), 	//TFS 36423
		//	"self", 'caption', form.getPropertyValue('caption').String, null, null, false, true);														//TFS 36423
	else
		if lsConstant.text &lt;&gt; form.getPropertyValue('caption').String then
			logMsg	:=	'*** WARNING - Existing constant has different value ' &amp; lsConstant.name &amp; Tab &amp; lsConstant.formName &amp; Tab &amp; 
				lsConstant.controlName &amp; Tab &amp; lsConstant.controlProperty &amp; Tab &amp; lsConstant.text &amp; Tab &amp; form.getPropertyValue('caption').String;
			self.log(logMsg, true);
		endif;
	endif;
	
	numControls := form.controlCount;
	foreach index in 1 to numControls do
		cntrl := form.controls(index);
				
		controlName := cntrl.getPropertyValue('name').String;
		write method.qualifiedName() &amp; Tab &amp; controlName;			//TFS 36423		
		
		// 12/04/2013 cnwmh5 - Fix issue not finding all bubbleHelp
		prop := cntrl.class.getPropertyInHTree("caption");		
		write method.qualifiedName() &amp; Tab &amp; 'prop caption: ' &amp; prop.String;	//TFS 36423
		if prop &lt;&gt; null then
			lsConstant := _lsClass.allConstants[_lsSchema.name, form.name, controlName, 'caption'];			
			if lsConstant = null then
				self.handleFormTranslation2(_lsSchema, _lsClass, self.makeConstantNameOld(_lsClass.name, cntrl.getPropertyValue('name').String, 'caption'), 	//TFS 36423
					cntrl.getPropertyValue('name').String, 'caption', cntrl.getPropertyValue('caption').String, null, null, false, true);
			else
				if lsConstant.text &lt;&gt; cntrl.getPropertyValue('caption').String then
					if not lsConstant.isCommentedOut then
						logMsg	:=	'*** WARNING - Existing constant has different value ' &amp; lsConstant.name &amp; Tab &amp; lsConstant.formName &amp; Tab &amp; 
							lsConstant.controlName &amp; Tab &amp; lsConstant.controlProperty &amp; Tab &amp; lsConstant.text &amp; Tab &amp;
							cntrl.getPropertyValue('caption').String;
						self.log(logMsg, true);
					endif;
				endif;
			endif;
		endif;
		
		prop := cntrl.class.getPropertyInHTree("bubbleHelp");	
		write method.qualifiedName() &amp; Tab &amp; 'prop buttonHelp: ' &amp; prop.String;																				//TFS 36423
		lsConstant := _lsClass.allConstants[_lsSchema.name, form.name, controlName, 'bubbleHelp'];
		if lsConstant = null then
			self.handleFormTranslation2(_lsSchema, _lsClass, self.makeConstantNameOld(_lsClass.name, cntrl.getPropertyValue('name').String, 'bubbleHelp'), 	//TFS 36423
				cntrl.getPropertyValue('name').String, 'bubbleHelp', cntrl.getPropertyValue('bubbleHelp').String, null, null, false, true);
		else
			if lsConstant.text &lt;&gt; cntrl.getPropertyValue('bubbleHelp').String then
				logMsg	:=	'*** WARNING - Existing constant has different value ' &amp; lsConstant.name &amp; Tab &amp; lsConstant.formName &amp; Tab &amp; 
					lsConstant.controlName &amp; Tab &amp; lsConstant.controlProperty &amp; Tab &amp; lsConstant.text &amp; Tab &amp; cntrl.getPropertyValue('bubbleHelp').String;
				self.log(logMsg, true);
			endif;
		endif;
		
	endforeach;
	
	numMenus := form.menuItemCount;
	foreach index in 1 to numMenus do
		tmpMenu := form.menuItems(index);
		
		if tmpMenu.isSeparatorJMT() then
			//self.log(class.name &amp; '::' &amp; method.name &amp; ' SEPARATOR ' &amp; tmpMenu.name, true);
			continue;
		endif;
		
		if tmpMenu.name = null then
			//self.log(class.name &amp; '::' &amp; method.name &amp; ' NULL MENU NAME ', true);//&amp; tmpMenu.name;
			continue;
		endif;
		
		controlName := tmpMenu.getPropertyValue('name').String;
		
		lsConstant := _lsClass.allConstants[_lsSchema.name, form.name, tmpMenu.name, 'caption'];
		if lsConstant = null then
			self.handleFormTranslation2(_lsSchema, _lsClass, self.makeConstantNameOld(_lsClass.name, tmpMenu.getPropertyValue('name').String, 'caption'), 	//TFS 36423
					tmpMenu.getPropertyValue('name').String, 'caption', tmpMenu.getPropertyValue('caption').String, null, null, false, true);
		else
		if lsConstant.text &lt;&gt; tmpMenu.getPropertyValue('caption').String then
			logMsg	:=	'*** WARNING - Existing constant has different value ' &amp; lsConstant.name &amp; Tab &amp; lsConstant.formName &amp; Tab &amp; 
					lsConstant.controlName &amp; Tab &amp; lsConstant.controlProperty &amp; Tab &amp; lsConstant.text &amp; Tab &amp; tmpMenu.getPropertyValue('caption').String;
			self.log(logMsg, true);
		endif;
	endif;
	endforeach;
	
epilog

	/*
	write "**********************SCHEMA**********************";
	foreach lsConstant in _lsSchema.allConstants do
		write lsConstant.String &amp; Tab &amp; lsConstant.isCommentedOut.String &amp; Tab &amp; lsConstant.commentedOutTextStartOfLine &amp; Tab &amp; 
		lsConstant.commentedOutTextEndOfLine &amp; Tab &amp; lsConstant.schemaName &amp; Tab &amp; lsConstant.formName &amp; Tab &amp; 
		lsConstant.controlName &amp; Tab &amp; lsConstant.name &amp; Tab &amp; lsConstant.controlProperty &amp; Tab &amp; lsConstant.text;
	endforeach;
	write "**********************CLASS**********************";
	foreach lsConstant in _lsClass.allConstants do
		write lsConstant.String &amp; Tab &amp; lsConstant.isCommentedOut.String &amp; Tab &amp; lsConstant.commentedOutTextStartOfLine &amp; Tab &amp; 
		lsConstant.commentedOutTextEndOfLine &amp; Tab &amp; lsConstant.schemaName &amp; Tab &amp; lsConstant.formName &amp; Tab &amp; 
		lsConstant.controlName &amp; Tab &amp; lsConstant.name &amp; Tab &amp; lsConstant.controlProperty &amp; Tab &amp; lsConstant.text;
	endforeach;
	//*/
	
	//delete captionsAgent;
	
end;

</source>
        <Parameter name="_lsSchema" type="LSschema" usage="io"/>
        <Parameter name="_lsClass" type="LSclass" usage="io"/>
    </JadeMethod>
    <JadeMethod name="writeCurrentTranslateFormMeths" id="6dba5e9a-9b74-42f8-8ace-125d75a59f61">
        <source>writeCurrentTranslateFormMeths(_fileName : String) : Boolean;

/*

Purpose:		Extract out the translateForm Methods

Date			Who		Reason
10/02/2012		cnwmh5	Initial creation
16/03/2015		cnwmh5	Transient Leaks
*/

vars

	file 					: File;
	fileFolder				: FileFolder;
	fileNodeObj				: FileNode;

	allFiles				: FileNodeArray;
	
	args					: StringArray512;
		
	result 					: Integer;
	rtnStr					: String;
	schemaName				: String;
	failedToExtract			: Boolean;
	iniFileName				: String;
	unlFileName				: String;
	sourceName				: String;
	serverPath				: String;
	dir 					: String;
	command 				: String;
	result2					: Integer;
	today					: TimeStamp;
	
begin

	create fileFolder transient;
	fileFolder.usePresentationFileSystem := self.fileFolder.usePresentationFileSystem;
	fileFolder.fileName := _fileName;
	fileFolder.mask := "*.unl";
	allFiles := fileFolder.files();
	
	serverPath := self.fileFolder.fileName;
	iniFileName		:= node.getIniFileName();
	command := 'jadclient';
	dir := node.getJadeInstallDirectory();
	
	create args transient;
	
	foreach fileNodeObj in allFiles do
		
		args.clear();
		
		schemaName := fileNodeObj.fileName[fileNodeObj.fileName.reversePos("\") + 1:end];
		schemaName := schemaName[1:schemaName.length - 4];
		
		result := -1;
		
		unlFileName		:= serverPath &amp; "\" &amp; schemaName &amp; ".unl";
		sourceName		:= serverPath &amp; "\" &amp; schemaName;
		
		rtnStr := CrLf &amp; CrLf &amp; "Extracting schema file for " &amp; fileNodeObj.fileName;
		
		// setup the args
		args.clear();
		args.add("path=" &amp; app.dbPath);								rtnStr := rtnStr &amp; CrLf &amp;  'path="' &amp; app.dbPath &amp; '"';		
		args.add("ini=" &amp; iniFileName);								rtnStr := rtnStr &amp; CrLf &amp;  'ini="' &amp; iniFileName &amp; '"';
		args.add("server=multiUser");								rtnStr := rtnStr &amp; CrLf &amp;  'server=multiUser';
		args.add("schema=JadeSchema");								rtnStr := rtnStr &amp; CrLf &amp;  'schema=JadeSchema';
		args.add("app=JadeBatchExtract");							rtnStr := rtnStr &amp; CrLf &amp;  'app=JadeBatchExtract';
		args.add("endJade");										rtnStr := rtnStr &amp; CrLf &amp;  'endJade';
		args.add("File");											rtnStr := rtnStr &amp; CrLf &amp;  'File';
		args.add(sourceName &amp; ".scm");								rtnStr := rtnStr &amp; CrLf &amp;  sourceName &amp; ".scm";
		args.add(sourceName &amp; ".ddb");								rtnStr := rtnStr &amp; CrLf &amp;  sourceName &amp; ".ddb";
		args.add(unlFileName);										rtnStr := rtnStr &amp; CrLf &amp;  unlFileName;
		args.add(schemaName);										rtnStr := rtnStr &amp; CrLf &amp;  schemaName;
		
		result := node.createExternalProcess(dir, dir &amp; command, args, null, false, true, result2);
		rtnStr := rtnStr &amp; CrLf &amp;  ' externalProcess = ' &amp; result.String &amp; CrLf &amp; ' jadloadb result = ' &amp; result2.String;
		
		write rtnStr;
		app.log(rtnStr);
		if result &lt;&gt; Node.ExternalProcess_Successful or result2 &lt;&gt; 0 then
			app.log("Failed to extract translateForm method for " &amp; schemaName);
			failedToExtract := true;
		endif;
	
	endforeach;
	
	return failedToExtract;
	
epilog

	delete args;
	delete fileFolder;

end;</source>
        <Parameter name="_fileName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeSchemaFile" id="54284dbe-6edc-4dcf-8c56-872ee9ea5dd1">
        <updating/>
        <source>writeSchemaFile(_folderName:String) updating;
// ---------------------------------------------------------------------------
// Created:     12 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 09/06/2011	cnmwh5	#27657 - Add production of JCF file
vars
	lsSchema : LSschema;

begin
	///create self.fileFolder transient;

	self.log('Writing schema files for translateForm method to "' &amp; self.fileFolder.fileName &amp; '"...', true);
	
	//self.fileFolder.fileName := 'C:\tmp\xlat';
////	self.fileFolder.fileName := fileFolder.browseForFolder('Scm filefolder', fileFolder.fileName);
	//self.fileFolder.fileName	:=	_folderName;
	
	if fileFolder.isValidPathName(self.fileFolder.fileName) = false then
		self.log('Invalid path, no scm files produced ' &amp; self.fileFolder.fileName, true);
		return;
	endif;
	
	foreach lsSchema in self.allSchemas do
		if lsSchema.name = PortSchemaName then
			// all global constants are defined in PortSchema
			// but first find the constant with the highest number
			lsSchema.produceScmFile_FormXlatGlbCnst(fileFolder, allSchemas, highestConstantNumber);
		//elseif lsSchema.allConstants.size &gt; 0 then
		else
			lsSchema.produceScmFile_FormXlatMethods(fileFolder);
		endif;
	endforeach;	

	// create the jcf to delete non required global constants
	self.allSchemas[PortSchema.name].produceJCFForDelXlatGlbCnst(fileFolder);
	
	self.log('Schema files complete', true);
epilog
	///delete self.fileFolder;
end;</source>
        <Parameter name="_folderName" type="String"/>
    </JadeMethod>
    <JadeMethod name="writeUNLForTranslateFormMethod" id="5bafd4dc-22c0-4948-aa11-3232b7e21f3a">
        <source>writeUNLForTranslateFormMethod();

/*

Purpose:		Create the UNL so can extract translateForm methods for comparison	

Date			Who		Reason
10/02/2012		cnwmh5	Initial creation

*/

vars

	lsSchema					: LSschema;
	lsClass						: LSclass;
	unlFile						: File;
	meth						: Method;

begin

	self.log('Extracing out UNL for translateForm methods for schemas to "' &amp; self.fileFolder.fileName &amp; '"...', true);
	
	foreach lsSchema in self.allSchemas do
	
		self.log('Extracing UNL for schemas: ' &amp; lsSchema.name, true);
		
		delete unlFile;
		create unlFile transient;
		unlFile.usePresentationFileSystem := self.fileFolder.usePresentationFileSystem;
		unlFile.fileName := self.fileFolder.fileName &amp; "\" &amp; lsSchema.name &amp; ".unl";
		if unlFile.isAvailable then
			unlFile.purge;
		endif;
		
		foreach lsClass in lsSchema.allClasses do
			meth := lsClass.myClass.getMethod("translateForm");
			if meth &lt;&gt; null then
				unlFile.writeLine("Method " &amp; lsClass.name &amp; " translateForm");
			endif;
		endforeach;
	
	endforeach;
	unlFile.close();
	
	// create the PortSchema one so that the global constants are extracted
	delete unlFile;
	create unlFile transient;
	unlFile.usePresentationFileSystem := self.fileFolder.usePresentationFileSystem;
	unlFile.fileName := self.fileFolder.fileName &amp; "\PortSchema_unl";
	if unlFile.isAvailable then
		unlFile.purge;
	endif;
	
	unlFile.writeLine("Method JadeScript appJadeScript");
	
	self.log('Finished extracing out UNL for translateForm methods for schemas...', true);

epilog

	delete unlFile;

end;</source>
    </JadeMethod>
    <JadeMethod name="z1_IdentifyControlsWithText" id="8cf59245-fd78-4e69-a74b-c0ee7c8d2966">
        <source>z1_IdentifyControlsWithText() protected;

vars
	cls : Class;
	subs : ClassColl;

begin
	self.log("Identifying control classes with 'caption' or 'bubbleHelp' property ...", true);
	create subs transient;

	rootSchema.getSchema(PortSchemaName).getClass(Control.name).allSubclasses(subs);
	rootSchema.getSchema(PortSchemaName).getClass(Control.name).allSubclassesInSubschemas(subs);

	subs.copy(self.allControlClassesWithTextProp);
	self.log("	Count: " &amp; self.allControlClassesWithTextProp.size.String, true);
epilog
	delete subs;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="z3_FindNewAndChangedControls" id="1e20f13f-548a-4178-847c-8951c810682e">
        <source>z3_FindNewAndChangedControls() protected;

//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out

vars
	controlClass	: Class;
	obj				: Object;
	cntrl			: Control;
	cls				: Class;
	lsSchema		: LSschema;
	lsClass			: LSclass;
	lsConstant		: LSconstant;
	schemaName		: String;
	formClass		: String;
	controlName		: String;
	numToCreate		: Integer;
	logMsg			: String;

begin
	self.log("Looking for new global constants that are required ...", true);
	foreach controlClass in self.allControlClassesWithTextProp do
		foreach obj in controlClass.instances where app.isValidObject(obj) and app.isValidObject(obj.Control.form) do
			cntrl := obj.Control;
			formClass := cntrl.form.name;
			controlName := cntrl.name;
			cls := findClassInSchemas(formClass);

			if not self.zzIncludeClass(cls) then
				continue; // not in application schemas, subschema copy, etc
			endif;

			// Create transient representation of form class and control.
			schemaName := cls.schema.name;
			lsSchema := allSchemas[cls.schema.name];
			lsClass := lsSchema.getLSclass(cls.name);
			if lsClass = null then
				logMsg	:=	"*** WARNING no JADE Class (" &amp; formClass &amp; "): " &amp; controlName;
				self.log(logMsg, true);
				app.createAlert(logMsg, true);
				continue;
			endif;

			// If control has bubbleHelp text, there should be an associated global constant.
			if cntrl.getPropertyValue('bubbleHelp').String.trimBlanks &lt;&gt; null then
				lsConstant := allDefinedFormCaptionConstants[schemaName, formClass, controlName, 'bubbleHelp'];

				// If necessary, create the new LSconstant object and add to LSclass and LSschema collections.
				if lsConstant = null then
					numToCreate := numToCreate + 1;
					create lsConstant transient;
					lsConstant.schemaName := schemaName;
					lsConstant.formName := formClass;
					lsConstant.controlName := controlName;
					lsConstant.controlProperty := 'bubbleHelp';
	//				lsConstant.name := makeConstantNameOld(formClass, controlName, 'bubbleHelp');									//TFS 36423
					lsConstant.name := self.makeConstantName(lsConstant,self.getMaxConNumFromDict(allDefinedFormCaptionConstants));	//TFS 36423
					//lsConstant.myControl := cntrl;
					lsConstant.text := cntrl.getPropertyValue('bubbleHelp').String.trimBlanks;
					allConstantsByName.add(lsConstant);
					lsClass.allConstants.add(lsConstant);
					lsSchema.allConstants.add(lsConstant);
				endif;
			endif;
			
			// If control has caption text, there should be an associated global constant.
			if cntrl.class.getPropertyInHTree('caption') &lt;&gt; null and
				cntrl.getPropertyValue('caption').String.trimBlanks &lt;&gt; null then
				lsConstant := allDefinedFormCaptionConstants[schemaName, formClass, controlName, 'caption'];
				
				// If necessary, create the new LSconstant object and add to LSclass and LSschema collections.
				if lsConstant = null then
					numToCreate := numToCreate + 1;
					create lsConstant transient;
					lsConstant.schemaName := schemaName;
					lsConstant.formName := formClass;
					lsConstant.controlName := controlName;
					lsConstant.controlProperty := 'caption';
				//	lsConstant.name := makeConstantNameOld(formClass, controlName, 'caption');										//TFS 36423
					lsConstant.name := self.makeConstantName(lsConstant,self.getMaxConNumFromDict(allDefinedFormCaptionConstants));	//TFS 36423
					//lsConstant.myControl := cntrl;
					lsConstant.text := cntrl.getPropertyValue('caption').String.trimBlanks;
					allConstantsByName.add(lsConstant);
					lsClass.allConstants.add(lsConstant);
					lsSchema.allConstants.add(lsConstant);
				endif;
			endif;
		
		endforeach; // control
	endforeach;	// control class

	self.log("	Forms: " &amp; zCountForms.String &amp; ", Constants: to create: " &amp; numToCreate.String, true);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="z4_WriteSchemaFiles" id="cc928b37-1c75-4206-b6ea-6502a8a2d34b">
        <updating/>
        <source>z4_WriteSchemaFiles() updating, protected;

vars
	lsSchema : LSschema;

begin
	self.log('Writing schema files for translateForm method ...', true);
	
	/* rmb testing */ fileFolder.fileName := 'C:\FormAndLabelCaptions\cnwdmast';
	fileFolder.fileName := fileFolder.browseForFolder('Scm filefolder', fileFolder.fileName);
	
	if fileFolder.isValidPathName(fileFolder.fileName) = false then
		self.log('Invalid path, no scm files produced', true);
		return;
	endif;
	
	foreach lsSchema in allSchemas do

		if lsSchema.name = PortSchemaName then
			// all global constants are defined in PortSchema
			// but first find the constant with the highest number
			lsSchema.produceScmFile_FormXlatGlbCnst(fileFolder, allSchemas, highestConstantNumber);
		elseif lsSchema.allConstants.size &gt; 0 then
			lsSchema.produceScmFile_FormXlatMethods(fileFolder);
		endif;

	endforeach;	

	// create the jcf to delete non required global constants
	self.allSchemas[PortSchema.name].produceJCFForDelXlatGlbCnst(fileFolder);
	
	self.log('Schema files complete', true);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="z5_SummariseConstants" id="2a32b578-9b5a-4dd0-935c-4058bb9126a3">
        <source>z5_SummariseConstants() protected;

vars
	lsControl	: LScontrol;
	newFile		: File;

begin
//	log('Writing NEW constants summary: ' &amp; allNeededFormCaptionConstants.size.String, true);
	create newFile transient;
	newFile.usePresentationFileSystem := true;
	newFile.openOutput(fileFolder.fileName &amp; '\summary-new-constants.txt');

//	foreach lsControl in allNeededFormCaptionConstants do
		newFile.writeLine(lsControl.vDisplayEntity);
//	endforeach;
	
epilog
	delete newFile;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zzIncludeClass" id="6a6f606f-2ca8-4f5c-a59a-683b22a5638a">
        <source>zzIncludeClass(cls : Class):Boolean protected;

vars

begin
//return cls &lt;&gt; null and cls.name = 'SOP_TextTranslationForm';
	return cls &lt;&gt; null and
		   cls.rootType.schema = cls.schema and // skip subschema copies
		   allSchemas.includesKey(cls.schema.name) and // application schemas only
		   cls.inheritsFrom(CM_BaseForm);
		   //and rootSchema.getSchema('BaseSchema').getClass(cls.name) = null;	// exclude baseschema classes

end;
</source>
        <access>protected</access>
        <Parameter name="cls" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
