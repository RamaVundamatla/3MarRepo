// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="loadBerthPrefRow" id="2d3c2724-91e6-4705-bff6-f57090656bf5">
        <updating/>
        <source>loadBerthPrefRow(berthPref: HMS_BerthPreference) updating;

vars
	newRow 			: Integer;
	newCntrl 		: Control;
	newBerthCombo,
	newCombo 		: CMUI_ComboBox;
	tmpTable 		: CM_DataTable;
	tmpHarbour	 	: HMS_Harbour;
	tmpBerth		: HMS_Berth;
	
begin
	tmpHarbour := self.myCurrentHarbour;
	if tmpHarbour = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Harbour', null, null);
		app.raiseCMException(Input_required_field_harbour, null, null); // cnwdb2	PAR 35364
		return;
	endif;

	if berthPref &lt;&gt; null then
		tmpBerth := berthPref.getMyBerth;
	else
		tmpBerth := tmpHarbour.getDefaultBerthForMoveType(HMSMovementTypeArrival);
		if tmpBerth = null then	 // This raises an error
			return;
		endif;
	endif;
	
	// Check for errors above before adding row to table	31/03/2008 cnwar2 #16320
	tmpTable 		:= self.tblPrefBerth;
	tmpTable.clearAllSelected();
	newRow 			:= tmpTable.rows + 1;
	tmpTable.rows 	:= newRow;
	tmpTable.row 	:= newRow;
	
	if berthPref &lt;&gt; null then
		tmpTable.itemObject := berthPref;
	endif;			

	// load berth combobox
	newIndex := newIndex + 1;
	tmpTable.column := tmpTable.getColumnByRowName(ETRow_MyBerth);				
	newBerthCombo := self.cmbBerth.loadControl(newIndex).CMUI_ComboBox;
	self.allClonedControls.add(newBerthCombo);
	tmpTable.accessCell(newRow, tmpTable.column).cellControl := newBerthCombo;
	self.myAssistant.comboBoxHMSBerth(newBerthCombo, tmpHarbour, tmpBerth, true);	
	
	// load orientaion combobox
	newIndex := newIndex + 1;
	tmpTable.column := tmpTable.getColumnByRowName(ETRow_Orientation);		
	newCombo := self.cmbOrientation.loadControl(newIndex).CMUI_ComboBox;
	self.allClonedControls.add(newCombo);
	tmpTable.accessCell(newRow, tmpTable.column).cellControl := newCombo;
	newCombo.addItem(app.getErrorString(PortSideToBerth));
	newCombo.addItem(app.getErrorString(StarboardSideToBerth));

	// Set orientation
	if berthPref &lt;&gt; null then	
		if berthPref.orientation = OrientPortSideTo then
			newCombo.listIndex := 1;
		else
			newCombo.listIndex := 2;
		endif;
	else
		newCombo.listIndex := 1;
	endif;
	tmpTable.text := newCombo.text;

	// load bow mark textbox
	newIndex := newIndex + 1;
	tmpTable.column := tmpTable.getColumnByRowName(ETRow_DefaultBowMark);	
	newCntrl := self.txtBow.loadControl(newIndex);
	self.allClonedControls.add(newCntrl);
	tmpTable.accessCell(newRow, tmpTable.column).cellControl := newCntrl;
	tmpTable.maxLength 	:= 8;
	tmpTable.inputType 	:= tmpTable.InputType_TextNumeric;
	tmpTable.decimals 	:= 2;			

	// Set bow
	if berthPref &lt;&gt; null then	
		tmpTable.text := berthPref.defaultBowMark.asStringJMT;
		newCntrl.TextBox.text := berthPref.defaultBowMark.asStringJMT;
	endif;

	// Set bridge
	tmpTable.column := tmpTable.getColumnByRowName(ETRow_DefaultBridgeMark);
	if berthPref &lt;&gt; null then	
		tmpTable.text := berthPref.defaultBridgeMark.asStringJMT;
	endif;

	// Set stern
// cnwdad1 30/08/2006 - Constant is no longer used.
//	tmpTable.column := tmpTable.getColumnByRowName(ETRow_DefaultSternMark);
//	if berthPref &lt;&gt; null then	
//		tmpTable.text := berthPref.defaultSternMark.asStringJMT;
//	endif;

	self.btnDeleteBerthPr.enabled := true;	
	

	// Centre ship on berth after all controls have been add to the row
	self.lastValidRow := newRow;	
	newBerthCombo.click(newBerthCombo);


end;</source>
        <Parameter name="berthPref" type="HMS_BerthPreference"/>
    </JadeMethod>
    <JadeMethod name="loadBerthPreferences" id="05a51bac-418b-42d2-ac07-413ba1ab37de">
        <updating/>
        <source>loadBerthPreferences(_vesselDataHarbour : HMS_VesselDataHarbour)updating;
//-----------------------------------------
// Created: August 2005 By: cnwgd1
//-----------------------------------------
vars
	berthPrefArray : HMS_BerthPrefArray;
	berthPref:	HMS_BerthPreference;
	tmpTable : CM_DataTable;
begin

 	// This method loads berthPref objs into the table tblBerthPref

	tmpTable := self.tblPrefBerth;
	tmpTable.rows := tmpTable.fixedRows;
	tmpTable.userObject := null;	

	if _vesselDataHarbour = null then
		return;
	endif;
		 	
	berthPrefArray := _vesselDataHarbour.allBerthPrefByOrder;
	
	foreach berthPref in berthPrefArray do
		self.loadBerthPrefRow(berthPref);
	endforeach; 
	
	tmpTable.colourRows(self.colorRow1, self.colorRow2);
	tmpTable.userObject := _vesselDataHarbour;

	// Set selected row
 	self.setRowTblPrefBerth();
		
end;</source>
        <Parameter name="_vesselDataHarbour" type="HMS_VesselDataHarbour"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="b656595c-a4c0-40bf-9241-c27ecdbff31c">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	05 September 2005 By: cnwgd1
//--------------------------------------------------
//constants
//	SHIPTYPE_BALLAST	: String = "Default Ballast Draught";
//	SHIPTYPE_LOADED	: String = "Default Loaded Draught";
	
begin
	inheritMethod();

	self.initComboBoxes();	
	
	if self.myCurrentVessel &lt;&gt; null then
		if self.cmbVessel.findObject(self.myCurrentVessel) &gt; 0 then
			self.cmbVessel.setObject(self.myCurrentVessel);
			self.setMyCurrentVessel(self.myCurrentVessel);
		else
			self.setMyCurrentVessel(null);
		endif;
	endif;
	
	if (not self.viewModeOnly) then
		// user has update rights
		if self.myCurrentVessel &lt;&gt; null then
			if self.mode = self.Mode_Update then
				self.doBtnEdit();
			else
				self.setToViewMode(); 
				self.cmbVessel.setFocus();
			endif;
		elseif self.mode = self.Mode_Add then
			self.doBtnNew();
		else
			self.setToViewMode();
			self.cmbVessel.setFocus();				
		endif;

	else
		// user is read only user
		self.setToViewMode();
		self.setNavigatorHeading(self.caption); 
		self.cmbVessel.setFocus();
	endif;
	

	self.doResize();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDimensionsTbl" id="832cedc6-a433-4ee1-9efb-513a6a221e91">
        <source>loadDimensionsTbl(_hmsVessel : HMS_VesselData);
//-----------------------------------------
// Created: August 2005 By: cnwgd1
// CCMS 1020 Remove unnessesary decimal points (i.e. if .00) with cnEcStripDecimalZeros
//-----------------------------------------
vars
	tmpVessel			: CM_Vessel;
	row 		: Integer;
	entRow		: EntTableRow;


begin
	
	tmpVessel			:= self.myCurrentVessel;
	
	if tmpVessel = null then
		return;
	endif;
	row:=2;
	while row &lt;= self.tblDimensions.rows do
		entRow:= self.tblDimensions.accessRow(row).itemObject.EntTableRow;
		if entRow = null then
			return;
		endif;
		self.tblDimensions.accessCell(row,2).text:=tmpVessel.getDisplayStringForAttribute(entRow.name,false);
		//self.tblDimensions.accessCell(row,2).text:=tmpVessel.getDisplayStringForAttribute(entRow.name,false).asStringJMT;
		row:=row+1;
	endwhile;
	self.tblDimensions.resort;
	
end;</source>
        <Parameter name="_hmsVessel" type="HMS_VesselData"/>
    </JadeMethod>
    <JadeMethod name="loadExternalRampTable" id="f6db3e75-3534-4bee-904c-2b0ab5ef2a3a">
        <source>loadExternalRampTable() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	iter : Iterator;
	ramp : CM_RORORampExternalVessel;
	str	 : String;
begin

	self.tblExtRamps.clearAllData;
	if self.myCurrentVessel = null then
		return;
	endif;
	if self.myCurrentVessel.myStructuralElements = null then
		return;
	endif;
	iter:=self.myCurrentVessel.myStructuralElements.allRamps.createIterator;
	
	while iter.next(ramp) do
		str := ramp.getAttributeStringForDefArray(self.tblExtRamps.allTblDataEntRows);		
		self.tblExtRamps.addItemObject(ramp,str);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadSectionsTable" id="d3bd5c78-a279-47f1-b036-751a4dbe64b1">
        <source>loadSectionsTable() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	iter : Iterator;
	section : CM_VesselSection;
	str	 : String;
	aStructure : CM_VesselStructuralElements;
	
begin
	self.tblSections.clearAllData;
	if self.myCurrentVessel = null then
		return;
	endif;
	
		//cnwrd1 par 31874
	aStructure := self.myCurrentVessel.getMyPrimaryVesselStructure;
	if aStructure = null then
		return;
	endif;
	
	iter:=aStructure.allSections.createIterator;	

	
	
	while iter.next(section) do
		str := section.getAttributeStringForDefArray(self.tblSections.allTblDataEntRows);
		self.tblSections.addItemObject(section,str);
	endwhile;
	
epilog
	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTankTable" id="0083a449-5411-4778-9bfc-1a367dc3d23b">
        <source>loadTankTable() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	aStructure : CM_VesselStructuralElements;
	iter : Iterator;
	tank : CM_VesselTank;
	str  : String;	
begin
	self.tblTanks.clearAllData;
	if self.myCurrentVessel = null then
		return;
	endif;

		//cnwrd1 par 31874
	aStructure := self.myCurrentVessel.getMyPrimaryVesselStructure;
	if aStructure = null then
		return;
	endif;
	
	iter:=aStructure.allTanks.createIterator;	

	while iter.next(tank) do
		str := tank.getAttributeStringForDefArray(self.tblTanks.allTblDataEntRows);
		self.tblTanks.addItemObject(tank,str);
	endwhile;
	
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTidalClassTbl" id="d82d4d6d-abe1-40b9-8ff1-4ae33e093b83">
        <source>loadTidalClassTbl();

vars
	tmpTable	: CM_DataTable;
 	count		: Integer;
 	tidalClass	: HMS_TidalClass;
begin

	// Arrival tidal class	
	tmpTable := self.tblCurrentsArriv;
	// Set entries in "Values" column
	tmpTable.column := 2;
	tidalClass := self.cmbTidalClassAr.listObject.HMS_TidalClass;
	count := 1;
	while count &lt;= 4 do
		tmpTable.row := count+1;
		if tidalClass &lt;&gt; null then
			tmpTable.text := tidalClass.allMaximumCurrents[count].asStringJMT;
		else
			tmpTable.text := null;
		endif;
		count := count+1;
	endwhile;
	
	// Departure tidal class
	tmpTable := self.tblCurrentsDepar;
	// Set entries in "Values" column
	tmpTable.column := 2;
	tidalClass := self.cmbTidalClassDpt.listObject.HMS_TidalClass;
	count := 1;
	while count &lt;= 4 do
		tmpTable.row := count+1;
		if tidalClass &lt;&gt; null then			
			tmpTable.text := tidalClass.allMaximumCurrents[count].asStringJMT;
		else
			tmpTable.text := null;
		endif;
		count := count+1;
	endwhile;

end;</source>
    </JadeMethod>
