    <JadeMethod name="setVesselArrivalDateStr" id="ca1d8143-f333-41d9-8523-2601bab04353">
        <updating/>
        <source>setVesselArrivalDateStr( _tiSet : CM_TISet; _nullVoyage: CM_Voyage; _delim : String ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	voyage : CM_Voyage;
	allVoyages : CM_VoyageSet;
	ti : CM_TrackedItem;
	completeStr : String;
	arrivalDate : Date;

begin

	create allVoyages transient;
	
	foreach ti in _tiSet do
		voyage := ti.myVoyage;
		if voyage = null or voyage = _nullVoyage then
			continue;
		endif;
		allVoyages.addNoDuplicates( voyage, false );
	endforeach;
	
	foreach voyage in allVoyages do
		arrivalDate  := voyage.arrivedDT.Date;
		if arrivalDate &lt;&gt; null and arrivalDate.isValid then
			if completeStr = null then
				completeStr := arrivalDate.format("dd-MMM-yyy");
			else
				completeStr := completeStr &amp; _delim &amp; arrivalDate.format("dd-MMM-yyy");
			endif;
		endif;
	endforeach;
	
	self.vesselArrivalDateStr := completeStr;

epilog

	delete allVoyages;

end;</source>
        <access>protected</access>
