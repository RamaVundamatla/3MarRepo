    <JadeMethod name="setupForm" id="4e793921-3b85-40f3-af8f-2af9213f6566">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
21/12/2022 	navcs2 	ChangeRequest 56006:[56008] EUP - New VAS Workorder Subscription 
16/12/2022	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
*/

vars
	term : CM_Terminal;
	
begin
	inheritMethod();
	
	term 					:= self.myTerminal;					
	self.isUseYardJobs		:= term.isUseYardJobsForCargoWo;    	
	self.hasVasSubscription := app.myPassport.isVASEnabled();  // 21/12/2022 navcs2  #56006:[56008]
	
	if self.workOrderType = WorkOrderMode_Cargo then
		self.setupWorkOrderCargo();
	elseif self.workOrderType = WorkOrderMode_Voyage then
		self.setupWorkOrderVoyage();
	else														//16/12/2022	navcs2 #56840:[54265]
		self.setupWorkOrderToDo();								//16/12/2022	navcs2 #56840:[54265]
	endif;														//16/12/2022	navcs2 #56840:[54265]
	
	self.loadWorkOrderDetails();
	self.doPermissionCheck();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupOOWConfirmTable" id="e6af751d-5720-44d4-a972-7c0978c260d3">
        <source>setupOOWConfirmTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 April 2022	navhl20 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	headingStr : String;
	voyTfrType : CM_VoyageJobTransferType;

begin
	
	self.tblOOWConfirm.clear();
	self.tblOOWConfirm.visible		    := true;
	self.tblOOWConfirm.rows 			:= 1;
	self.tblOOWConfirm.fixedRows 		:= 1;
	self.tblOOWConfirm.columns 			:= self.HoldTotalCol;
	self.tblOOWConfirm.fixedColumns 	:= 0;
	
	headingStr := 	app.getErrorString(Hold)               &amp; Tab
				&amp;	app.getErrorString(Workpoint)          &amp; Tab
				&amp;	app.getErrorString(CM_Type)            &amp; Tab
				&amp;	app.getErrorString(Operator_GC)        &amp; Tab
				&amp;	app.getErrorString(Consignee)          &amp; Tab
				&amp;	app.getErrorString(CM_Commodity_GC)    &amp; Tab
				&amp;	app.getErrorString(Move_amount)        &amp; Tab
				&amp;	app.getErrorString(Transfer_type)      &amp; Tab
				&amp;	app.getErrorString(Gangs) 			   &amp; Tab
				&amp;	app.getErrorString(HoursPerDay) 	   &amp; Tab
				&amp;	app.getErrorString(Hourly_target_rate) &amp; Tab
				&amp;	app.getErrorString(Days_complete) 	   &amp; Tab
				&amp;	app.getErrorString(Hold_sub_total);
	
	self.tblOOWConfirm.setCellText(1,1,headingStr);
	self.tblOOWConfirm.tabKey := J_key_Tab;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupWorkOrderCargo" id="fffb4aa4-d3de-4f1b-8f6a-2f9627ece48c">
        <updating/>
        <source>setupWorkOrderCargo()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Mar 2022	navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
15 Dec 2022	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - Allowing different sets of cargo items per work order task [Refactor]
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
23 May 2024 navhl20 Bug 64258: MTN - Cargo work order takes significant time to click between tasks
18 Dec 2024	navbs1	Bug MTN-33554: EUP | 53729 - Show Work Order for multiple Work Orders
*/

vars

begin
	self.setCaption(app.getErrorString(Cargo) &amp; " " &amp; self.caption); // ### TFS CR 54345 TASK 58281 01JUN2023 NAVAB1
	
	self.fldCargo.visible  := true;
	self.fldToDo.visible   := false;  			  			 //15.12.2022 navcs2 #56840:[54265]
	self.fldVoyage.visible := false;
	self.grpCargo.visible  := false;  			  			 //08.02.2023 navma1 #56457:[56458]
	self.grpTasks.top      := self.grpCargo.top; 			 //08.02.2023 navma1 #56457:[56458]
	
	self.txtJobRequiredByDT.enabled := not self.isApproved;	 //06.06.2023 navma1 #58339
	self.txtJobRequiredByTM.enabled := not self.isApproved;  //06.06.2023 navma1 #58339
	
	if self.myPxyTask &lt;&gt; null then
		self.loadCargoTaskDetails(self.myPxyTask.detailType);
	endif;
	
	if self.workOrderMode = self.MODE_UPDATE or self.workOrderMode = self.MODE_UPDATECOMPLETED then		//18.12.2024 navbs1 #33554	
		self.buildListTasks(self.myPxyTask);
	endif;
	
	if self.workOrderMode = self.MODE_ADD then				//23.05.2024 navhl20 #64258
		self.loadTabCargoTis();
	endif;
	self.updateCargoTabNumber();							//23.05.2024 navhl20 #64258
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupWorkOrderToDo" id="671cb85f-ad09-474d-8760-90a60377d9bd">
        <updating/>
        <source>setupWorkOrderToDo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Dec 2022	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - Allowing different sets of cargo items per work order task [Refactor]
20 Mar 2023 navma1  Defect 57195: MTN - WO - Priority is showing some random number on the to do work orders on the yard operations form 
03 Oct 2023 navhl20 Bug 60373: MTN - Expected to see a validation message to save the changes before closing the work order form.
18 Dec 2024	navbs1	Bug MTN-33554: EUP | 53729 - Show Work Order for multiple Work Orders
*/

vars

begin
	self.setCaption(app.getErrorString(Todo_task) &amp; " " &amp; self.caption); // ### TFS CR 54345 TASK 58281 01JUN2023 NAVAB1

	self.mulToDoEntity.myBaseForm 		    := self;
	self.mulToDoSecondaryEntites.myBaseForm := self;
	
	self.mulToDoTasks.parent := self.shtDetails;
	
	self.fldCargo.visible  := false;
	self.fldVoyage.visible := false;
	self.fldToDo.visible   := true;
	self.grpCargo.visible  := false;								//08.02.2023 navma1 #56457:[56458]
	self.grpTasks.top      := self.grpCargo.top; 					//08.02.2023 navma1 #56457:[56458]
	
	if self.myPxyTask &lt;&gt; null then
		self.loadToDoTaskDetails(self.myPxyTask.detailType);
	endif;
	
	if self.workOrderMode = self.MODE_UPDATE or self.workOrderMode = self.MODE_UPDATECOMPLETED then		//18.12.2024 navbs1 #33554
		self.buildListTasks(self.myPxyTask);
	endif;

	self.setParentAspect(false);									//03.10.2023 navhl20 #60373
	self.loadTabToDoDetails();
	self.loadTabToDoEntities();
	//self.updateEntitesRequestedRequired();						//20.03.2023 navma1 #57195	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupWorkOrderVoyage" id="38972cbc-165f-492b-beb5-97d697900f20">
        <updating/>
        <source>setupWorkOrderVoyage() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 March 1522		navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
03/08/2022			navcs2	Bug 54309: MTN - Voyage Work Orders - Unable to add a task for the Voyage Work Orders
9 Aug 2022 			navhl20 Bug 54347: MTN - Voyage Work Orders - When selecting any task the voyage gets disappeared
15 December	2022	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
06 Apr 2023 		navhl20 Bug 57458: EUP - Work Order Remarks
14 Apr 2023 		navhl20	Defect 57572: MTN - WO - Issue with the fields alignment on the Voyage Work Order screen
30 Oct 2025 		navhl20 Bug MTN-36436: SAL - Workorder Enquiry - Initial Cargo Request details not visible after Complete
*/

vars

begin
	self.setCaption(app.getErrorString(Voyage) &amp; " " &amp; self.caption); // ### TFS CR 54345 TASK 58281 01JUN2023 NAVAB1
	
	self.fldCargo.visible  		    := false;
	self.fldToDo.visible 			:= false;	// 15/12/2022 navcs2 #56840:[54265]	
	self.fldVoyage.visible 			:= true;
	self.grpVoyageDetails.visible   := true;		
	self.grpVoyageDetails.top 		:= self.grpCargo.top;
	self.grpTasks.top 				:= self.grpVoyageDetails.top + self.grpVoyageDetails.height + 10;
	
	//self.lblApprovalExpiry.visible	:= false;					//06.4.2023 navhl20	#57458			
	//self.txtAprovalExpDT.visible	:= false;						//06.4.2023 navhl20	#57458
	//self.txtJobApprvalExpTM.visible	:= false;					//06.4.2023 navhl20	#57458
	
	/*
	//12.4.2023 navhl20	#57572
	self.lblStatus.top			:=	self.lblStatus.top 			- 20;
	self.cmbWorkOrderStatus.top	:=  self.cmbWorkOrderStatus.top - 20;
	self.lblRefrence.top		:=	self.lblRefrence.top 		- 20;
	self.txtReference.top		:=	self.txtReference.top 		- 20;
	self.lblOrgainisation.top	:=	self.lblOrgainisation.top	- 15;
	self.cmbOgrainisation.top	:=	self.cmbOgrainisation.top 	- 15;
	self.chkSendEmail.top		:=	self.chkSendEmail.top 		- 15;
	self.txtEmail.top			:=	self.txtEmail.top 			- 15;
	self.btnEmail.top			:=	self.btnEmail.top 			- 15;
	self.lblJobRemarks.top		:=	self.lblJobRemarks.top 		- 10;
	self.txtRemarks.top			:=	self.txtRemarks.top 		- 10;*/
	
	self.myAssistant.comboBoxVoyageWO(self.cmbVoyageDetails,false,true,true, true, false, true, true, false, true, false, false);		//9.8.2022 navhl20 TFS 54347
	
	if self.workOrderMode = self.MODE_UPDATE or self.workOrderMode = self.MODE_UPDATECOMPLETED then		//30.10.2025 navhl20 #36436
		self.buildListTasks(self.myPxyTask);
	endif;
	
	if self.myPxyTask &lt;&gt; null then
		self.loadVoyageTaskDetails(self.myPxyTask.detailType);
	endif;
	
	// 03/08/2022	navcs2	54309
	if self.workOrderMode = self.MODE_ADD then
		self.canMaintainTasks(WO_STATUS_USERENTRY);
	else
		self.canMaintainTasks(self.myPxyWorkOrder.taskStatus);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="cd8138a5-5efb-4d16-bf32-fd4452dde577">
        <source>showColumnOrganiser();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 April 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
25 Jan 2022 	navhl20 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
*/

vars

begin		
	//self.tblSelectedCargo.showColumnOrganiserFrm(self.myTerminal,null);			//25.1.2023 navhl20 #55443[54991]
	if self.mnuColumnOrganiser.userObject = self.tblSelectedCargo then				//25.1.2023 navhl20 #55443[54991]
		self.tblSelectedCargo.showColumnOrganiserFrm(self.myTerminal,null);
