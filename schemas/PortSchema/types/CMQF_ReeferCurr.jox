<Class name="CMQF_ReeferCurr" id="1b6fca6b-3ee2-45f6-ba34-5f9f396f7422">
    <superclass name="CMQF_Reefer"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="includesObject" id="52894970-43dc-4493-9295-068aa957e048">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------
//	Created:	11 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	reefer	: CM_Container;
begin
	if CM_Container.hasInstance(_ti) and
	   (_ti.CM_Container.isConnected) and 
	   inheritMethod(_ti, _passport, _breakOut) then
		reefer := _ti.CM_Container;
		if reefer.getLastConnectDT.isValid then
			return self.getConnectedDT.cnEcIsLessThanOrEqual(reefer.getLastConnectDT);
		elseif reefer.getFirstConnectDT.isValid then
			return self.getConnectedDT.cnEcIsLessThanOrEqual(reefer.getFirstConnectDT);
		else
			return true;
		endif;
		
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
