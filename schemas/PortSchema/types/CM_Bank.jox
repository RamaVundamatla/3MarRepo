    <JadeMethod name="shouldAuditProperty" id="1327b046-4f4e-473a-a136-8441b56e6444">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Dec 2016	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up


*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_Bank::alertService.name or
		propName = CM_Bank::code.name or
		propName = CM_Bank::addInvoiceTax.name or
		propName = CM_Bank::chargeSeqNum.name  or
		propName = CM_Bank::currentTransactionMap.name or
		propName = CM_Bank::myChildQuantityMap.name or
		propName = CM_Bank::myCurrentTranMapCargo.name or
		propName = CM_Bank::myCurrentTranMapCargoAlloc.name or
		propName = CM_Bank::myCurrentTranMapEvent.name or
		propName = CM_Bank::myCurrentTranMapSnapShot.name or
		propName = CM_Bank::myCurrentTranMapVoyage.name or
		propName = CM_Bank::useAlertService.name or
		propName = CM_Bank::voidInvoiceLineDesc.name or
		propName = CM_Bank::voidService.name  or
		propName = CM_Bank::onsiteStorageChargeTime.name or
		propName = CM_Bank::retrospectiveRates.name or
		propName = CM_Bank::mailingAddress.name  or 
		propName = CM_Bank::rootServiceGroup.name  or 
		propName = CM_Bank::rootGLCode.name  or 
		propName = CM_Bank::rootDebtorGroup.name  or
		propName = CM_Bank::taxPercentageRate.name  or
		propName = CM_Bank::isRootCompany.name  or
		propName = CM_Bank::myCurrentTranMapCargo.name  or
		propName = CM_Bank::myRootIfRootCompany.name  or
		propName = CM_Bank::mailingName.name  
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="suspend" id="f50ef155-1794-4214-a94d-1443c5ac2733">
        <updating/>
        <source>suspend(_terminal : CM_Terminal) updating;

vars
	subCo	: CM_Bank;
	iter	: Iterator;
begin

	iter := self.subCompanies.createIterator;
	self.subCompanies.startKeyGeq(_terminal, null, iter);
	while iter.next(subCo) do
		if subCo.terminal &lt;&gt; _terminal then
			break;
		endif;
		subCo.suspend(_terminal);
	endwhile;

	if (not isSuspended) then
		isSuspended := true;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="userCanSet" id="d9654f58-6594-4e54-b5c9-1b5d13233de1">
        <source>userCanSet(_status : Integer) : Boolean;
/*

Purpose:	// TFS 39618 PATCH 1 		

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2019	jlgab1	Initial creation

*/

vars
	invStatus : CM_InvoiceStatus;
	term : CM_Terminal;
begin
	term := self.getMyTerminal();
	if term = null then
		return false;
	endif;
	
	if self.getMyInvoiceProcess = null then
		return false;
	endif;
	
	invStatus := self.getMyInvoiceProcess.allStatuses[_status];
	
	if invStatus = null then
		return false;
	endif;
	
	return invStatus.userCanSet(term);
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="83ee113d-b286-40fa-a8b0-cfb6e582030b">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 15/12/2014  cnwdb2	PAR 35364
// ---------------------------------------------------------------------------

vars
	company : CM_Bank;
	myTerminal : CM_Terminal;
	invProc : CM_InvoiceProcess;
begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD,"'Code'",null,null);
		app.raiseCMException(Input_required_field_code,null,null); // cnwdb2	PAR 35364
	endif;
	if self.mailingName = null then
	//	app.raiseCMException1(REQUIRED_FIELD,"'Name'",null,null);
		app.raiseCMException(Input_required_field_name,null,null); // cnwdb2	PAR 35364
	endif;
	
	/*
		Date		      Who		Reason
		23 July 2008	cnwdz2	    Par15180 - Key duplication should be checked as a part of company creation validation process.
	*/
	myTerminal := app.getMyTerminalDO_NOT_USE;
	if myTerminal.companies.includesKey(self.code) then
		app.raiseCMException1(ERR_CANNOT_CREATE_BANK, self.code,null,null);
	endif;
	
	//13 Jan 2021	NDL	TFS 50600
	if self.myInvoiceProcess = null then
	// 22 Jan 2021 NDL	TFS 50600 - will need other changes before this can be done.  I.e. Transient - Persistant 
	// on the 'parentCompany', then populate from cmif in setProxy then do this validation this only if parentCompany is set
	// because create of 'company' form doesn't support this attribute, but create of 'business unit' does.
	
	//	app.raiseCMException( Must_select_invoice_process, null, null );
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="35f72a18-cb8f-44b2-ab0a-6a08d8c155bb">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aLbl, aMess : String;
	whereUsed : String;
	
begin
	if self.isInUse(aMess) then
		if self.isBusinessUnit then
			aLbl := "Business Unit " &amp; self.code;
		else
			aLbl := "Company " &amp; self.code;
		endif;
		app.raiseCMException2(ERR_CANNOT_DELETE_BANK,aLbl, aMess,null,null);
	endif;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.code, whereUsed, null, self);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="0e305da2-d66d-43f0-ac07-b6018dd54f1b">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	allSuspended	: Boolean;
	currentDefaultBank : CM_Bank;
	realBank : CM_Bank;
	company	: CM_Bank;
	term : CM_Terminal;
	invProc : CM_InvoiceProcess;
begin

	if self.isTransient then
		realBank := self.pxyGetRealObject;
	else
		realBank := self;
	endif;
	if realBank &lt;&gt; null then
		term := realBank.terminal;
	endif;

	if term &lt;&gt; null then
		currentDefaultBank := term.getConfig(DefCompany).CM_Bank;
	
		if realBank = currentDefaultBank then
			if self.isSuspended then
				app.raiseCMException2(Company_Default_Suspended, self.code, term.code,null,null);
			endif;
		endif;
		// 34318 don't suspend the last non-suspended company
		if self.isSuspended then
			allSuspended := true;
			foreach company in term.companies where company.isBusinessUnit do
				if company.code &lt;&gt; self.code then
					if not company.isSuspended then
						allSuspended := false;
						break;
					endif;
				endif;
			endforeach;
			if allSuspended then
				app.raiseCMException(Cant_suspend_all_companies, null, null);
			endif;
		endif;
		// June 2012 do duplicate code test on update as well as add
		if self.code &lt;&gt; realBank.code and
		   term.companies.includesKey(self.code) then
			app.raiseCMException1(ERR_CANNOT_CREATE_BANK, self.code, null, null);
		endif;
	endif;
	
	//13 Jan 2021	NDL	TFS 50600
	if self.myInvoiceProcess = null then
		invProc := self.getMyInvoiceProcess; // will fall back to CM_InvoiceProcessDefault.firstInstance
		if invProc &lt;&gt; null then
			app.raiseCMWarning1( Invoic_proces_select_will_used, invProc.code, null, null, null );
		endif;
	endif;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="validateInvLineDescUsedChMaps" id="051ce37a-ab69-45eb-b8d4-b25b95828de8">
        <source>validateInvLineDescUsedChMaps(_invLineDesc : CM_InvoiceLineDesc) : Boolean;
// ---------------------------------------------------------------------------
// Created:		12 October 2009 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aMap : CM_InvoiceLineChargeMapping;
begin
	
	foreach aMap in self.allInvLineChargeMappings discreteLock do
		if aMap.myInvoiceLineDesc = _invLineDesc then
			return true;
		endif;
	endforeach;
	
	return false;
epilog
end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateInvLineDescUsedTranMap" id="d4ea2f82-7abe-404d-8b86-bc6ab439b8a5">
        <source>validateInvLineDescUsedTranMap(_invLineDesc : CM_InvoiceLineDesc) : Boolean;
// ---------------------------------------------------------------------------
// Created:		12 October 2009 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cargoTM : CM_TranMap;
	hmsTM : CM_TranMapVoyage;
	eventTM : CM_TranMapEvent;
begin
	
	foreach cargoTM in self.myCurrentTranMapCargo discreteLock do
		if cargoTM.validateInvLineDescUsedTranMap(_invLineDesc) then
			return true;
		endif;
	endforeach;
	
	foreach hmsTM in self.allJMHTMs discreteLock do
		if hmsTM.validateInvLineDescUsedTranMap(_invLineDesc) then
			return true;
		endif;
	
	endforeach;
	foreach eventTM in self.allEventTranMaps discreteLock do
		if eventTM.validateInvLineDescUsedTranMap(_invLineDesc) then
			return true;
		endif;
	
	endforeach;
	
	return false;
epilog
end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zRemoveInvLineTypeFromChrgeMap" id="678de4d1-7be2-4630-bdbe-66573379c6b5">
        <source>zRemoveInvLineTypeFromChrgeMap(invLine : CM_InvoiceLineDesc input);
/*
Purpose: switch the passed in invoice line type with the void line			
Date		Who		Reason
29 May 2013	cnwab1	Initial creation
02NOV2021 NAVAB1 change to use business unit collection
*/

vars

	theRange : CM_InvoiceLineChargeMapping;
	voidLine, tmpLine : CM_InvoiceLineDesc;
begin

	if not  app.isJMTUnitTest then
		return;
	endif;

	voidLine := self.getVoidInvoiceLineType();
	
	foreach theRange in self.allInvLineChargeMappings do
		if theRange.myInvoiceLineDesc = invLine then
			theRange.setMyInvoiceLineDesc(voidLine);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="invLine" type="CM_InvoiceLineDesc" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zRemoveInvLineTypeFromDebtMap" id="f4dc0222-f64e-47e6-82ee-7aaa5bc655c8">
        <source>zRemoveInvLineTypeFromDebtMap(invLine : CM_InvoiceLineDesc input);
/*
Purpose: switch the passed in invoice line type with the void line			
Date		Who		Reason
29 May 2013	cnwab1	Initial creation
02NOV2021 NAVAB1 change to use business unit collection

*/

vars
	theRange : CM_DebtorInvoiceLineDesc;
	voidLine, tmpLine : CM_InvoiceLineDesc;
begin

	if not  app.isJMTUnitTest then
		return;
	endif;
	
	voidLine := self.getVoidInvoiceLineType();

	foreach theRange in self.allInvoiceLineDescDebtors as CM_DebtorInvoiceLineDesc do
		if theRange.allConsolidatingInvLineDesc.includes(invLine)then
			invLine.allConsolidatedDebtorInvLineD.remove(theRange);
			voidLine.allConsolidatedDebtorInvLineD.add(theRange);
		endif;
	endforeach;


epilog

end;</source>
        <Parameter name="invLine" type="CM_InvoiceLineDesc" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zRemoveInvoiceLineFromDebtMap" id="be80ea12-3fb4-4916-9cd0-2d5ebd38ab4a">
        <source>zRemoveInvoiceLineFromDebtMap(invLine : CM_InvoiceLineDesc);
/*
Purpose: switch the passed in invoice line type with the void line			
Date		Who		Reason
29 May 2013	cnwab1	Initial creation
02NOV2021 NAVAB1 change to use business unit collection

*/

vars

	theRange : CM_InvoiceLineDescMapping;
	voidLine : CM_InvoiceLineDesc;
begin

	if not  app.isJMTUnitTest then
		return;
	endif;
	voidLine := self.getVoidInvoiceLineType();
	
	foreach theRange in self.allInvoiceLineDescMappings do
		if theRange.myInvoiceLineDesc = invLine then
			theRange.myInvoiceLineDesc := voidLine;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="invLine" type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="zRemoveInvoiceLineFromTranMap" id="75e03db0-e0f4-4c6b-88d8-ae5ad27831d6">
        <source>zRemoveInvoiceLineFromTranMap(invLine : CM_InvoiceLineDesc);
/*
Purpose: switch the passed in invoice line type with the void line			
Date		Who		Reason
29 May 2013	cnwab1	Initial creation
*/

vars

	iter01 : Iterator;
	theRange : CM_QuantityRangeMap;
	oArray : ObjectArray; 
	voidLine, tmpLine : CM_InvoiceLineDesc;
	iter : Iterator;
	itKey : Integer;
	tmInvLine : CM_TranMapInvoiceLineMapping;
	found : Boolean;
begin

	if not  app.isJMTUnitTest then
		return;
	endif;

	create oArray transient;
	CM_QuantityRangeMap.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;
	voidLine := self.getVoidInvoiceLineType();
	
	while iter01.next(theRange) do
		found := false;
		
		foreach tmInvLine in theRange.allTMInvoiceLineMappings discreteLock do
			if tmInvLine.myTMInvoiceLineDesc = invLine then
				found := true;
				break;
			endif;
		endforeach;

		if found then
			foreach tmInvLine in theRange.allTMInvoiceLineMappings discreteLock do
				if tmInvLine.myTMInvoiceLineDesc = invLine then
					tmInvLine.update(tmInvLine.mapValue,voidLine, tmInvLine.myQuantityRangeMap, tmInvLine.myTMInvoiceLineGroupType, tmInvLine.myTransferType, tmInvLine.myVesselCategory, tmInvLine.myCargoType, tmInvLine.myCargoSubtype, tmInvLine.myCommodity);
				endif;
			endforeach;
		endif;
	endwhile;

epilog
	delete oArray;
	delete iter;
	delete iter01;
end;</source>
        <Parameter name="invLine" type="CM_InvoiceLineDesc"/>
    </JadeMethod>
</Class>
