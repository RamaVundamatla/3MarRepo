    </JadeMethod>
    <JadeMethod name="getWorkDepartureTargetRatePH" id="63c2bef7-8cdd-4602-9418-294560ada800">
        <source>getWorkDepartureTargetRatePH() : Integer;
// ---------------------------------------------------------------------------
// Created:     24 May 2005 by cnwrs2
//
// Purpose:		They can enter when they want the voyage to depart, so this method works out how many moves per hour they need to do to reach that
// ---------------------------------------------------------------------------
vars
	duration : Integer;
	totHours : Decimal[16,2];
	tmpHours : Real;
	movesDone,movesToDo, movesTotal : Integer;
	targetDepart : TimeStamp;
begin
	targetDepart := self.myVoyage.departTargetDT;
	if not targetDepart.isValid then // PAR 9475
		targetDepart := self.actualTime;
	endif;

	duration := self.myVoyage.getWorkDurationTime(targetDepart); // get total seconds 
	movesDone := self.movesCompleted;
	movesToDo := self.movesIncomplete;
	if movesDone = 0 then
		return null;
	endif;
	movesTotal := movesDone + movesToDo;

	tmpHours := (duration / SecondsPerHour).roundedTo(2);

	if tmpHours &gt; 0 then
		return (movesTotal / tmpHours).Integer;
	else
		return (movesTotal / 1).Integer;
	endif;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWorkETCActual" id="61d28563-99ac-43dc-a309-8bf8b43c29b2">
        <source>getWorkETCActual() : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     24 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	ratePH, movesDone,movesToDo, numSecs : Integer;
	etc : TimeStamp;
	numHours : Real;
begin
	
	movesDone := self.movesCompleted;
	movesToDo := self.movesIncomplete;
	if movesDone = 0 then
		return null;
	endif;
	
	ratePH := self.actualRate.Integer;

	if ratePH &lt;&gt; 0 then // PAR 9393
		numHours := (movesToDo /ratePH);	
	endif;
	numSecs := (numHours * SecondsPerHour).Integer;
	
	etc := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	etc.addSecondsInterval(numSecs);
	return etc;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWorkETCEntered" id="855cac2d-2040-4dae-9ab9-a3b74fdc9398">
        <source>getWorkETCEntered(_ratePH: Integer) : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     24 May 2005 by cnwrs2
//
// Purpose:		get Estimated Time to Completion using the Entered TI Per Hour Rate
// ---------------------------------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	ratePH, movesDone,movesToDo, numSecs : Integer;
	etc : TimeStamp;
	numHours : Real;
begin

	movesDone := self.movesCompleted;
	movesToDo := self.movesIncomplete;
	if movesDone = 0 then
		return null;
	endif;
	
	//ratePH := self.myVoyage.tiPerHour;
	ratePH := _ratePH;
	
	if ratePH &lt;&gt; 0 then // PAR 9393
		numHours := (movesToDo /ratePH);	
	endif;
	numSecs := (numHours * SecondsPerHour).Integer;
	
	etc := app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	etc.addSecondsInterval(numSecs);
	return etc;
end;</source>
        <Parameter name="_ratePH" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="hasJobSheetsCranesChanged" id="edcfc291-beb2-4c6f-a3e8-18f28589cdc6">
        <source>hasJobSheetsCranesChanged() : Boolean;
/*
Purpose:	Created to check to see if the job sheets has changed		

Parameters:			

Return Value:		


Date		Who		Reason
28 May 08	cnwer1	Initial creation Par 16697

*/



vars
	jobSheet, cmifJobSheet : CM_JobSheet;
	currentCranes : StringArray;
	cmifJobSheetStats : CMIF_JobSheetStats;
	invalidObject : Boolean;
begin
	
	if self.myVoyage = null then
		return false;
	endif;
		
	create currentCranes transient;	
	on Exception do app.handleDeletedObject(exception,jobSheet,invalidObject);
	
	foreach cmifJobSheetStats in self.allJobSheetStats do
		//shouldn't happen but just incase
		if cmifJobSheetStats.myJobSheet = null then
			continue;
		endif;
		jobSheet := cmifJobSheetStats.myJobSheet;
		if jobSheet = null or not jobSheet.isKindOf(CM_VoyageJobSheet) then
			continue;
		endif;
		
		currentCranes.add(jobSheet.CM_VoyageJobSheet.crane);
		if invalidObject then
			continue;
		endif;
	endforeach;
	
	if currentCranes.size &lt;&gt; self.myVoyage.allJobSheets.size then
		return true;
	endif;
	
	
	foreach jobSheet in self.myVoyage.allJobSheets do
		if not jobSheet.isKindOf(CM_VoyageJobSheet) then
			continue;
		endif;
		if not currentCranes.includes(jobSheet.CM_VoyageJobSheet.crane) then
			return true;
		endif;
		if invalidObject then
			continue;
		endif;
	endforeach;
	
	return false;
epilog
	if currentCranes &lt;&gt; null then
		delete currentCranes;
	endif;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="5e35a9e3-67a3-48ed-938a-12f7655cbf80">
        <updating/>
        <source>init(_voyage : CM_Voyage) updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
22 Jun 2010	cnwkpd1	PAR #24609 - Change in behaviour of CM_Terminal::getShiftsFromRange - all entries are transient, so can 
					purge for performance 

*/

vars
	tmpSheet	: CM_JobSheet;
	tmpSheetStats	: CMIF_JobSheetStats;
	delay : CM_Delay;
	terminal : CM_Terminal;
begin

	self.myVoyage := _voyage;
	
	self.allJobSheetStats.purge;
	// setting jobAdditionalMins so don't have to call terminal.getConfig all the time
	self.jobAdditionalMins:=self.myVoyage.myTerminal.getConfig(JobAdditionalTime).Integer;
	if _voyage = null then
		return;
	endif;
	
	foreach tmpSheet in _voyage.allJobSheets do
		self.createStatsObjectForJobSheet(tmpSheet);
	endforeach;

	//self.getStats(false);
	
	self.allShifts.purge();			// PAR #24609

	_voyage.getShiftsFromRange(self.allShifts);
	
	if self.allVoyageDelays.size &gt; 0 then
		self.allVoyageDelays.clear;
	endif;
	
	self.allVoyageDelays.setMembership(CM_Delay);
	self.allVoyageDelays.addExternalKey(TimeStamp,8,false,false);	
	self.allVoyageDelays.endKeys(true);
	
	foreach delay in _voyage.allDelays do
		self.allVoyageDelays.putAtKey(delay.getEndDT,delay);
	endforeach;
	
	terminal:= self.getMyTerminal();
	if terminal &lt;&gt; null then
		self.include30s	:= terminal.getConfig (Is30IncludedForReports).Integer = ISOTypeOtherIncludedAsOwn;	//CNWAB1 PAR 30342
		self.include45s:= terminal.getConfig (Is45IncludedForReports).Integer = ISOTypeOtherIncludedAsOwn;	//CNWAB1 PAR 30342
		self.include53s := terminal.getConfig (Is53IncludedForReports).Integer= ISOTypeOtherIncludedAsOwn;	//CNWAB1 PAR 30342
	
	endif;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setActualRate" id="6503b1d4-1b39-4580-87a7-3658b421e4e5">
        <updating/>
        <source>setActualRate() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	numCranes: Integer;
	tmpRate  : Decimal[12,4];
	tmpJobSheetStats : CMIF_JobSheetStats;
begin
	
	foreach tmpJobSheetStats in self.allJobSheetStats do
		if tmpJobSheetStats.myJobSheet.allJobsByOrder.isEmpty then
			continue;
		endif;
		
		numCranes := numCranes + 1;
		tmpRate := tmpRate + tmpJobSheetStats.actualRate;
	endforeach;


/*	not an average - rate for all cranes
	if numCranes &gt; 0 then // PAR 9712
		rate := (tmpRate / numCranes).Integer;
	endif;
*/

	self.actualRate := tmpRate;

end;</source>
        <access>protected</access>
    </JadeMethod>
