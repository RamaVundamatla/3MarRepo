    <JadeMethod name="clearTIProxies" id="fab7dca2-8ed2-4d08-9eaf-980731a914ff">
        <source>clearTIProxies() protected;
/*
----------   ----------  --------------------------------------------------
Created:	28 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	row,
	numRows		: Integer;
	tbl			: CM_DataTable;
begin
	tbl := self.tblAttachments;
	numRows := tbl.rows;
	
	foreach row in numRows to tbl.fixedRows + 1 step -1  do
		delete tbl.accessRow(row).itemObject;
		tbl.removeItem(row);
	endforeach;

end;



</source>
        <access>protected</access>
    </JadeMethod>
