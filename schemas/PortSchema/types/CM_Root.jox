    <JadeMethod name="isDeprecated" id="4fbb9245-3afd-4a52-9b91-e444ed29207d">
        <source>isDeprecated(_checkVersion : String) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2012	cnwmc5	Initial creation SFW 1323

*/

vars
	initVersionArray 	: StringArray;
	checkVersionArray 	: StringArray;
	initVersion			: Integer;
	checkVersion		: Integer;

begin

	create initVersionArray transient;
	create checkVersionArray transient;
	
	if self.initialVersion &lt;&gt; null then
		self.initialVersion.asStringArrayByDelimiter(initVersionArray, ".");
		initVersion := ((initVersionArray[1].Integer * 10000) + (initVersionArray[2].Integer * 100) + initVersionArray[3].Integer);
	endif;
	
	_checkVersion.asStringArrayByDelimiter(checkVersionArray, ".");
	checkVersion := ((checkVersionArray[1].Integer * 10000) + (checkVersionArray[2].Integer * 100) + checkVersionArray[3].Integer);
	
	if initVersion &gt;= checkVersion then
		//dont show old things..
		return true;
	else
		//show old things..
		return false;
	endif;
epilog
	delete initVersionArray;
	delete checkVersionArray;
end;</source>
        <Parameter name="_checkVersion" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
