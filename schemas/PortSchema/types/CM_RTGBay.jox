    <JadeMethod name="areaSeqNo" id="ad06e09b-9001-4f63-a2ff-2f2bbf64f745">
        <methodInvocation>mapping</methodInvocation>
        <source>areaSeqNo(set: Boolean; _value: Integer io) mapping;
/*
----------   ----------  --------------------------------------------------
Created:	15 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		//epr par 17760 19/8/08
		_value:= self.myRTGLane.allTAsByTypeId.indexOf(self.myRTGArea);
	endif;

end;


</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getFullID" id="7feba20a-7bf8-47b2-a087-95a87ed12cdd">
        <source>getFullID(_is40 : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		15 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpLbl : String;
	bayNum : Integer;
	iter : Iterator;
	nextBay : CM_RTGBay;
begin
	tmpLbl := self.getLabel();

	if _is40 then
	
		iter:=self.myRTGArea.allRTGBays.createIterator;
		iter.startAtObject(self);
		iter.next(nextBay);
		if iter.next(nextBay) then
			bayNum:=((self.label.Integer + nextBay.label.Integer)/2).Integer;
			if bayNum &lt; 100 then
				tmpLbl := bayNum.padLeadingWith("0",2);
			else
				tmpLbl := bayNum.padLeadingWith("0",3);
			endif;
		endif;
		delete iter;
		/*if tmpLbl.isInteger() then
			bayNum := tmpLbl.Integer + 1;
			if bayNum &lt; 100 then
				tmpLbl := bayNum.padLeadingWith("0",2);
			else
				tmpLbl := bayNum.padLeadingWith("0",3);
			endif;
		endif;*/
	endif;
	
	tmpLbl := self.myRTGArea.getID()  &amp; self.myRTGLane.getID()  &amp;  tmpLbl;
	
	return tmpLbl;

end;</source>
        <Parameter name="_is40" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullLabel" id="93dc6a4d-9cec-4ca9-88d5-71c5f4068290">
        <source>getFullLabel(): String;
// ---------------------------------------------------------------------------
// Created:		18 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	
	if self.myRTGLane = null then
		return "Orphaned " &amp; inheritMethod();
	else
		return self.myRTGLane.getID() &amp; " " &amp; self.getLabel();
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLabel" id="0aa51575-8aa3-46d8-ad1d-4ac3ba9bd9f6">
        <source>getLabel(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 August 2008	cnwer1	Initial creation 17760

*/

vars

begin
	return self.myRTGArea.id &amp; " " &amp; inheritMethod();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
