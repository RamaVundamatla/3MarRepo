        <source>iconDownString(set: Boolean; _value: String io) updating, mapping;
//--------------------------------------------------
// Created:	24 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if set then
		if _value &lt;&gt; null then
			self.iconDownState := app.myRoot.getConfig(_value).Binary;
		else
			self.iconDownState := null;
		endif;
	endif;
end;</source>
