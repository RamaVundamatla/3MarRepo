    <JadeMethod name="doMnuInspectObject" id="b0d60ee5-fd46-4b6e-8e3d-46a08c43d34e">
        <source>doMnuInspectObject();
//--------------------------------------------------
// Created:	12 December 2003 By: cnwgd1
//--------------------------------------------------
vars

	invalidTrain : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myCurrentTrain, invalidTrain); //10/10/08 cnwdz2 Par 17732
	
	if self.mnuInspectObject.userObject &lt;&gt; null then
		self.mnuInspectObject.userObject.inspectModal;
	else
		if self.myCurrentTrain &lt;&gt; null then
			self.myCurrentTrain.inspectModal;
			if invalidTrain then						
				return;
			endif;
		else
			inheritMethod();
		endif;
	endif;
end;</source>
    </JadeMethod>
