    <JadeMethod name="setForUpdateVessel" id="258bafe2-89b9-497b-a653-9ee771064c1c">
        <updating/>
        <source>setForUpdateVessel( _pxyVessStruct : CM_VesselStructuralElements; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 September 2013	cnwrd1	Initial creation

*/

vars
	pxySection, realSection : CM_VesselSectionVessel;
	aSection : CM_VesselSection;
	pxyTank, realTank : CM_VesselTankVessel;
	aTank : CM_VesselTank;
begin
	
	// ### SECTIONS
	foreach aSection in self.allSections discreteLock do
		pxySection := aSection.pxyGetProxyObject().CM_VesselSectionVessel;
		
		if pxySection = null then
			delete realSection;
		endif;
		
	endforeach;
	foreach aSection in _pxyVessStruct.allSections discreteLock do
		realSection := aSection.pxyGetRealObject().CM_VesselSectionVessel;
		
		if realSection = null then
			create realSection persistent;
			realSection.setForCreate(aSection.CM_VesselSectionVessel,_passport);
			realSection.setMyVesselStructElements(self);
		else
			realSection.setForUpdate(aSection.CM_VesselSectionVessel,_passport);
		endif;
	endforeach;
	
	
	// ### TANKS
	foreach aTank in self.allTanks discreteLock do
		pxyTank := aTank.pxyGetProxyObject().CM_VesselTankVessel;
		
		if pxyTank = null then
			delete realTank;
		endif;
		
	endforeach;
	foreach aTank in _pxyVessStruct.allTanks discreteLock do
		realTank := aTank.pxyGetRealObject().CM_VesselTankVessel;
		
		if realTank = null then
			create realTank persistent;
			realTank.setForCreate(aTank.CM_VesselTankVessel);
			realTank.setMyVesselStructElements(self);
		else
			realTank.setForUpdate(aTank.CM_VesselTankVessel);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_pxyVessStruct" type="CM_VesselStructuralElements"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyVesselFromXML" id="498d4704-1a58-4f63-8567-2bcf3e4261cb">
        <updating/>
        <source>setProxyVesselFromXML(_theXML : String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 September 2013	cnwrd1	Initial creation

*/

vars
	theXML : String;

begin

	self.raiseExceptionIfNotTransient(method);
	
	// SECTIONS
	theXML := _theXML.cnEcGetTagValueOfName("SECTIONS");
	self.doCreateProxySectionsFromXML(theXML);

	// TANKS
	theXML := _theXML.cnEcGetTagValueOfName("TANKS");
	self.doCreateProxyTanksFromXML(theXML);
	
epilog

end;</source>
        <Parameter name="_theXML" type="String"/>
    </JadeMethod>
</Class>
