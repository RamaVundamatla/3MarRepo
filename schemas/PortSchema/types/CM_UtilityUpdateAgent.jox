    <JadeMethod name="utlUpdateWOTransportToRoad" id="9595f4fd-8cf7-4f8c-9a0c-48e7ca6ad750">
        <updating/>
        <source>utlUpdateWOTransportToRoad(_pxyworkOrder 		: CM_WorkOrder;
							_pxyWorkOrderDtl	: CM_WorkOrderDtl;
							_pxyNewWorkOrderDtl	: CM_WorkOrderTIDtl io;
							_transport			: CM_Object;
							_booking 			: CM_BookingRef;
							_releaseRequest		: CM_BulkRelease;
							_newTIsArr			: ObjectArray;
							_passport		 	: CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 May 2023 	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
27 June 2023	navlw1	ChangeRequest 58730: EUP | Link bill of lading item to Receive work orders
30 Aug 2023 	navhl20 Bug 60135: MTN - Error 1090 when using Transport Mode Change
13 Dec 2023 	naviv1	ChangeRequest 61543: EUP - Transport  Mode Change should create a new Work Order 
19 Feb 2024		navpw1	TFS: 59411 (61868) - Made changes for Release Work Order Details. Added exceptions to help with flow and 
												assist developer if they are passing in incorrect things
25 Mar 2025		navah1	Bug 34412: MTN | When changing Transport Mode from Rail to Road - Getting Error
*/

vars
	voyage				: CM_Voyage;
	ti					: CM_TrackedItem;
	pxyNewWODtlReceive	: CM_WodReceive;
	pxyNewWODtlRelease	: CM_WodRelease;
	pxyWodDtlReceive	: CM_WodReceive;
	pxyWodDtlRelease	: CM_WodRelease;
	bkRefItem			: CM_BookingRefItem;
	reserveDetail		: CM_ReserveDetail;
	
begin
	if _pxyNewWorkOrderDtl.isWodReceive then
		pxyNewWODtlReceive := _pxyNewWorkOrderDtl.CM_WodReceive;
		
	elseif _pxyNewWorkOrderDtl.isWodRelease then
		pxyNewWODtlRelease := _pxyNewWorkOrderDtl.CM_WodRelease;
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "This method only supports CM_WodReceive and CM_WodRelease, work order details");
		return;
	endif;
	
	if _transport &lt;&gt; null then  	//25.03.2025 navah1 #34412
		if not _transport.isKindOf(CM_Voyage) then
			app.raiseUnexpectedProgramError(class.name, method.name, "We were expecting to have a voyage (CM_Voyage), however we received: " &amp; _transport.class.name);
			return;
		else
			voyage := _transport.CM_Voyage;
		endif;
	endif;
	
	if pxyNewWODtlReceive &lt;&gt; null then
		
		if _booking &lt;&gt; null and _booking.allBookingRefItems.isNotEmpty() then		//30.8.2023 navhl20 #60135
			bkRefItem := _booking.allBookingRefItems.first;
		endif;
		pxyNewWODtlReceive.setProxyWodReceival(_booking,
								bkRefItem,											//30.8.2023 navhl20 #60135
								null,
								null,
								null,
								voyage,
								TI_TRANSMODE_ROAD);
		pxyNewWODtlReceive.setRequiredByDT(_pxyWorkOrderDtl.requiredByDT);					//13.12.2023 naviv1 #61543
		
		pxyWodDtlReceive := _pxyWorkOrderDtl.CM_WodReceive;
		
		if pxyWodDtlReceive.allToDoRequests.isNotEmpty then
			pxyNewWODtlReceive.setProxyAllToDoRequests(pxyWodDtlReceive.allToDoRequests.first.CM_WodToDo.allToDoTasksDescs);
		endif;
		
		pxyNewWODtlReceive.allSelectedTIs.clear();
		_newTIsArr.copyNoDups(pxyNewWODtlReceive.allSelectedTIs);
		
		foreach ti in pxyWodDtlReceive.allSelectedTIs do
			if _newTIsArr.includes(ti) then
				pxyWodDtlReceive.allSelectedTIs.remove(ti);
			endif;
		endforeach;
		
		foreach ti in pxyWodDtlReceive.allAvailableTIs do
			if _newTIsArr.includes(ti) then
				pxyWodDtlReceive.allAvailableTIs.remove(ti);
			endif;
		endforeach;
		
		foreach ti in pxyWodDtlReceive.allActionedTIs do
			if _newTIsArr.includes(ti) then
				pxyWodDtlReceive.allActionedTIs.remove(ti);
			endif;
		endforeach;
		
		if pxyWodDtlReceive.allToDoRequests.isNotEmpty() then												//13.12.2023 naviv1 #61543
			foreach ti in pxyWodDtlReceive.allToDoRequests.first.CM_WodToDo.allSelectedTIs do
				if _newTIsArr.includes(ti) then
					pxyWodDtlReceive.allToDoRequests.first.CM_WodToDo.allSelectedTIs.remove(ti);
				endif;
			endforeach;
			
			foreach ti in pxyWodDtlReceive.allToDoRequests.first.CM_WodToDo.allAvailableTIs do
				if _newTIsArr.includes(ti) then
					pxyWodDtlReceive.allToDoRequests.first.CM_WodToDo.allAvailableTIs.remove(ti);
				endif;
			endforeach;
			
			foreach ti in pxyWodDtlReceive.allToDoRequests.first.CM_WodToDo.allActionedTIs do
				if _newTIsArr.includes(ti) then
					pxyWodDtlReceive.allToDoRequests.first.CM_WodToDo.allActionedTIs.remove(ti);
				endif;
			endforeach;
		endif;
		
	elseif pxyNewWODtlRelease &lt;&gt; null then
		if _releaseRequest &lt;&gt; null and _releaseRequest.releaseByType then
			reserveDetail := _releaseRequest.allReserveDetails.first;
			//app.raiseUnexpectedProgramError(class.name, method.name, "Release by type is not supported for a CM_WodRelease in this method");
			//return;
		endif;
		
		pxyNewWODtlRelease.setProxyWodRelease(_releaseRequest,
								TI_TRANSMODE_ROAD,											
								voyage,
								null,
								null,
								null,
								reserveDetail);
		
		pxyNewWODtlRelease.setRequiredByDT(_pxyWorkOrderDtl.requiredByDT);	
		
		pxyWodDtlRelease := _pxyWorkOrderDtl.CM_WodRelease;
		
		if pxyWodDtlRelease.allToDoRequests.isNotEmpty then
			pxyNewWODtlRelease.setProxyAllToDoRequests(pxyWodDtlRelease.allToDoRequests.first.CM_WodToDo.allToDoTasksDescs);
		endif;
		
		if _newTIsArr.isNotEmpty and _newTIsArr.first.isKindOf(CM_WorkListEntry) then
			return;
		endif;
		
		pxyNewWODtlRelease.allSelectedTIs.clear();
		_newTIsArr.copyNoDups( pxyNewWODtlRelease.allSelectedTIs);
		
		foreach ti in pxyWodDtlRelease.allSelectedTIs do
			if _newTIsArr.includes(ti) then
				pxyWodDtlRelease.allSelectedTIs.remove(ti);
			endif;
		endforeach;
		
		foreach ti in pxyWodDtlRelease.allAvailableTIs do
			if _newTIsArr.includes(ti) then
				pxyWodDtlRelease.allAvailableTIs.remove(ti);
			endif;
		endforeach;
		
		foreach ti in pxyWodDtlRelease.allActionedTIs do
			if _newTIsArr.includes(ti) then
				pxyWodDtlRelease.allActionedTIs.remove(ti);
			endif;
		endforeach;
		
		if pxyWodDtlRelease.allToDoRequests.isNotEmpty() then
			foreach ti in pxyWodDtlRelease.allToDoRequests.first.CM_WodToDo.allSelectedTIs do
				if _newTIsArr.includes(ti) then
					pxyWodDtlRelease.allToDoRequests.first.CM_WodToDo.allSelectedTIs.remove(ti);
				endif;
			endforeach;
			
			foreach ti in pxyWodDtlRelease.allToDoRequests.first.CM_WodToDo.allAvailableTIs do
				if _newTIsArr.includes(ti) then
					pxyWodDtlRelease.allToDoRequests.first.CM_WodToDo.allAvailableTIs.remove(ti);
				endif;
			endforeach;
			
			foreach ti in pxyWodDtlRelease.allToDoRequests.first.CM_WodToDo.allActionedTIs do
				if _newTIsArr.includes(ti) then
					pxyWodDtlRelease.allToDoRequests.first.CM_WodToDo.allActionedTIs.remove(ti);
				endif;
			endforeach;
		endif;
		
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyworkOrder" type="CM_WorkOrder"/>
        <Parameter name="_pxyWorkOrderDtl" type="CM_WorkOrderDtl"/>
        <Parameter name="_pxyNewWorkOrderDtl" type="CM_WorkOrderTIDtl" usage="io"/>
        <Parameter name="_transport" type="CM_Object"/>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_releaseRequest" type="CM_BulkRelease"/>
        <Parameter name="_newTIsArr" type="ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWOTransportToShip" id="6f228273-f0b4-4ac0-9957-6464b0e03ba9">
        <updating/>
        <source>utlUpdateWOTransportToShip(_pxyworkOrder 		: CM_WorkOrder;
							_pxyWorkOrderDtl	: CM_WorkOrderDtl;
							_pxyNewWokorderDtl	: CM_WorkOrderTIDtl io;
							_transport			: CM_Object;
							_bol		 		: CM_BOL;
							_booking			: CM_BookingRef;	// ### TFS 59411 (61855) 26Jan2024 NAVPW1
							_releaseRequest		: CM_BulkRelease;	// ### TFS 59411 (62272) 14Feb2024 NAVPW1
							_newTIsArr			: ObjectArray;
							_passport		 	: CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2023 navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
27 Jun 2023 navlw1	ChangeRequest 58730: EUP | Link bill of lading item to Receive work orders
05 Sep 2023 navhl20 Bug 60135: MTN - Error 1090 when using Transport Mode Change
13 Dec 2023 naviv1	ChangeRequest 61543: EUP - Transport  Mode Change should create a new Work Order 
30 Jan 2024	navpw1	TFS: 59411 (61855) - Release Trnsport Mode Changes
13 Feb 2024	navpw1	TFS: 59411 (62272) - Added Release Request

*/

vars
	voyage				: CM_Voyage;
	ti					: CM_TrackedItem;
	pxyWODtl			: CM_WodReceive;
	pxyWODtlRelease		: CM_WodRelease;		// ### TFS 59411 (61855) 26Jan2024 NAVPW1
	wodDtl				: CM_WodReceive;
	wodDtlRelease		: CM_WodRelease;		// ### TFS 59411 (61855) 26Jan2024 NAVPW1
	bolDtl				: CM_BOLDtl;
	bookingRefItem		: CM_BookingRefItem;	// ### TFS 59411 (61855) 26Jan2024 NAVPW1
	reserveDetail		: CM_ReserveDetail;		// ### TFS 59411 (62272) 14Feb2024 NAVPW1
	
begin
	if _pxyNewWokorderDtl.isWodReceive then
		pxyWODtl := _pxyNewWokorderDtl.CM_WodReceive;
		voyage   := _transport.CM_Voyage;
		
		if _bol &lt;&gt; null and _bol.allBOLDtls.isNotEmpty() then				//05.9.2023 navhl20 #60135
			bolDtl := _bol.allBOLDtls.first;
		endif;
		
		// 28.6.2023 navlw1 TFS# 58730
		pxyWODtl.setProxyWodReceival(null,
									null,
									_bol,
									bolDtl,									//05.9.2023 navhl20 #60135
									null,
									voyage,
									TI_TRANSMODE_SHIP);
		pxyWODtl.setRequiredByDT(_pxyWorkOrderDtl.requiredByDT);			//13.12.2023 naviv1 #61543
									
		wodDtl := _pxyWorkOrderDtl.CM_WodReceive;
		
		if wodDtl.allToDoRequests.isNotEmpty then
			pxyWODtl.setProxyAllToDoRequests(wodDtl.allToDoRequests.first.CM_WodToDo.allToDoTasksDescs);
		endif;
		
		pxyWODtl.allSelectedTIs.clear();
		_newTIsArr.copyNoDups( pxyWODtl.allSelectedTIs);
		
		foreach ti in wodDtl.allSelectedTIs do
			if _newTIsArr.includes(ti) then
				wodDtl.allSelectedTIs.remove(ti);
			endif;
		endforeach;
		
		foreach ti in wodDtl.allAvailableTIs do
			if _newTIsArr.includes(ti) then
				wodDtl.allAvailableTIs.remove(ti);
			endif;
		endforeach;
		
		foreach ti in wodDtl.allActionedTIs do
			if _newTIsArr.includes(ti) then
				wodDtl.allActionedTIs.remove(ti);
			endif;
		endforeach;
		
		if wodDtl.allToDoRequests.isNotEmpty() then												//13.12.2023 naviv1 #61543
			foreach ti in wodDtl.allToDoRequests.first.CM_WodToDo.allSelectedTIs do
				if _newTIsArr.includes(ti) then
					wodDtl.allToDoRequests.first.CM_WodToDo.allSelectedTIs.remove(ti);
				endif;
			endforeach;
			
			foreach ti in wodDtl.allToDoRequests.first.CM_WodToDo.allAvailableTIs do
				if _newTIsArr.includes(ti) then
					wodDtl.allToDoRequests.first.CM_WodToDo.allAvailableTIs.remove(ti);
				endif;
			endforeach;
			
			foreach ti in wodDtl.allToDoRequests.first.CM_WodToDo.allActionedTIs do
				if _newTIsArr.includes(ti) then
					wodDtl.allToDoRequests.first.CM_WodToDo.allActionedTIs.remove(ti);
				endif;
			endforeach;
		endif;
	// ### TFS 59411 (61855) 26Jan2024 NAVPW1
	elseif _pxyNewWokorderDtl.isWodRelease then
		pxyWODtlRelease := _pxyNewWokorderDtl.CM_WodRelease;
		voyage   := _transport.CM_Voyage;
		
		if _booking &lt;&gt; null and _booking.allBookingRefItems.isNotEmpty() then
			bookingRefItem := _booking.allBookingRefItems.first; //Are we supposed to be handling first here
		elseif _releaseRequest &lt;&gt; null then
			reserveDetail := _releaseRequest.allReserveDetails.first;
		endif;
		
		pxyWODtlRelease.setProxyWodRelease(_releaseRequest,
									TI_TRANSMODE_SHIP,
									voyage,
									null,
									_booking,
									bookingRefItem,
									reserveDetail
									);
		pxyWODtlRelease.setRequiredByDT(_pxyWorkOrderDtl.requiredByDT);
		
		wodDtlRelease := _pxyWorkOrderDtl.CM_WodRelease;
		
		if wodDtlRelease.allToDoRequests.isNotEmpty then
			pxyWODtlRelease.setProxyAllToDoRequests(wodDtlRelease.allToDoRequests.first.CM_WodToDo.allToDoTasksDescs);
		endif;
		
		if _newTIsArr.isNotEmpty and _newTIsArr.first.isKindOf(CM_WorkListEntry) then
			return;
		endif;
		
		pxyWODtlRelease.allSelectedTIs.clear();
		_newTIsArr.copyNoDups( pxyWODtlRelease.allSelectedTIs);
		
		foreach ti in wodDtlRelease.allSelectedTIs do
			if _newTIsArr.includes(ti) then
				wodDtlRelease.allSelectedTIs.remove(ti);
			endif;
		endforeach;
		
		foreach ti in wodDtlRelease.allAvailableTIs do
			if _newTIsArr.includes(ti) then
				wodDtlRelease.allAvailableTIs.remove(ti);
			endif;
		endforeach;
		
		foreach ti in wodDtlRelease.allActionedTIs do
			if _newTIsArr.includes(ti) then
				wodDtlRelease.allActionedTIs.remove(ti);
			endif;
		endforeach;
		
		//The below can be done from a CM_WorkOrderTIDtl as all collections are on that object
		if wodDtlRelease.allToDoRequests.isNotEmpty() then
			foreach ti in wodDtlRelease.allToDoRequests.first.CM_WodToDo.allSelectedTIs do
				if _newTIsArr.includes(ti) then
					wodDtlRelease.allToDoRequests.first.CM_WodToDo.allSelectedTIs.remove(ti);
				endif;
			endforeach;
			
			foreach ti in wodDtlRelease.allToDoRequests.first.CM_WodToDo.allAvailableTIs do
				if _newTIsArr.includes(ti) then
					wodDtlRelease.allToDoRequests.first.CM_WodToDo.allAvailableTIs.remove(ti);
				endif;
			endforeach;
			
			foreach ti in wodDtlRelease.allToDoRequests.first.CM_WodToDo.allActionedTIs do
				if _newTIsArr.includes(ti) then
					wodDtlRelease.allToDoRequests.first.CM_WodToDo.allActionedTIs.remove(ti);
				endif;
			endforeach;
		endif;
	// ### TFS 59411 (61855) 26Jan2024 NAVPW1
	endif;
epilog

end;</source>
        <Parameter name="_pxyworkOrder" type="CM_WorkOrder"/>
        <Parameter name="_pxyWorkOrderDtl" type="CM_WorkOrderDtl"/>
        <Parameter name="_pxyNewWokorderDtl" type="CM_WorkOrderTIDtl" usage="io"/>
        <Parameter name="_transport" type="CM_Object"/>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_releaseRequest" type="CM_BulkRelease"/>
        <Parameter name="_newTIsArr" type="ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWagonClass" id="0eabb299-405b-4538-ad2c-b8729ac53c9d">
        <source>utlUpdateWagonClass(pProxyWagonClass:CM_WagonClass; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave:Boolean;
	realWagonClass:CM_WagonClass;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	pProxyWagonClass.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyWagonClass.pxyGetRealObjectAndEdition(realWagonClass, expectedEdition);
	
	if realWagonClass = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WagonClass.name, null, null);
		return;
	endif;

	app.myValUA.valWagonClass(realWagonClass, pProxyWagonClass);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realWagonClass);

	if _passport.noErrors and realWagonClass.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'WagonClass', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWagonClass, true);
	endif;
	
	if _passport.noErrors then
		realWagonClass.setForUpdate(pProxyWagonClass);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWagonClass, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyWagonClass" type="CM_WagonClass"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWagonConfirm" id="941d235b-2fad-422c-8ada-ff00bbc0f9fb">
        <source>utlUpdateWagonConfirm(	_wagons   : CM_WagonArray input; 
						_inward   : Boolean;
						_control  : CMIF_WagonMoveController input;
						_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     May 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 02/06/2023	navkc1	Bug 58384: FR 53740 | EUP - Wagon Track Planning (part II)
// ---------------------------------------------------------------------------

vars
	wagon : CM_Wagon;
	ap 	  : Boolean;
begin

	self.initialiseActivity();

	self.raiseExceptionIfNull(_wagons, 'Wagons');
	
	ap := false;
	if _control &lt;&gt; null then
		ap := _control.doAutoPlanOfCargo;
	endif;
	
	foreach wagon in _wagons discreteLock do
		exclusiveLock(wagon);
		if (_inward and not wagon.confirmed) then					//26 Aug 2020	NDL	TFS 49950
			wagon.confirmWagonInwards( _control, ap, _passport);
		elseif (not _inward and not wagon.confirmedOutwards) then	//26 Aug 2020	NDL	TFS 49950
			wagon.confirmWagonOutwards( _control, _passport);
		endif;
		
		app.myEventManager.createSingleObjInfoNoteEvt(wagon, _passport.myTerminal.getTerminalEvent(Wagon_Update_Event), wagon); // ### TFS BUG 58951 19JUL2023 NAVAB1
	endforeach;
end;</source>
        <Parameter name="_wagons" type="CM_WagonArray" usage="input"/>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_control" type="CMIF_WagonMoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWagonConfirmOut" id="98b98ae1-e81f-42e8-aec3-7376e095f003">
        <source>utlUpdateWagonConfirmOut(	_moveController : CMIF_WagonMoveController;
							pWagon : CM_Wagon input; 
							_confirm : Boolean;
							_passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	01 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	self.raiseExceptionIfNull(pWagon, 'Wagon');
	if (not pWagon.confirmed) then
		app.raiseCMException1(Wagon_must_confi_inwar_befor_c, pWagon.id ,null, null);
	endif;
	
	//app.raiseCMWarning1(CONFIRM_WAGON_CONFIRM, pWagon.id, null, null, null);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;
	
	exclusiveLock(pWagon);

	app.setContinueCMExceptions(false);
	if _confirm then
		pWagon.confirmWagonOutwards( _moveController, _passport);
	else
		pWagon.unconfirmWagonOutwards(_passport);
	endif;
			
end;

</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="pWagon" type="CM_Wagon" usage="input"/>
        <Parameter name="_confirm" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWagonController" id="e0281ea1-d5dc-4b42-bc39-527819310eeb">
        <source>utlUpdateWagonController(pRealWagon : CM_Wagon; _wagonPosition : CMIF_TIWagonPosition input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lController : CM_WagonController;
	ti : CM_TrackedItem;
begin

	lController := pRealWagon.allLocationsControllersArray[_wagonPosition.position];
	//15 Oct 2014	NDL	Par 35040
	if _wagonPosition.allTrackedItems.isEmpty then
		lController.setController(	null, _wagonPosition.hasTwistLocks, 
									_wagonPosition.twistLocksAreUp, _wagonPosition.available,_passport);
	endif;
							
	//14 Oct 2014	NDL	Par 35040
	foreach ti in _wagonPosition.allTrackedItems do
		if ti.myPrimaryActualLocation &lt;&gt; lController then
			lController.setController(ti, _wagonPosition.hasTwistLocks, 
							_wagonPosition.twistLocksAreUp, _wagonPosition.available,_passport);
		endif;
	endforeach;

end;</source>
        <Parameter name="pRealWagon" type="CM_Wagon"/>
        <Parameter name="_wagonPosition" type="CMIF_TIWagonPosition" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWagonDeparture" id="6927a6f1-96a3-4715-8e18-36869895bbfe">
        <source>utlUpdateWagonDeparture(_wagons : CM_WagonSet input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     May 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
// ---------------------------------------------------------------------------

vars
	wagon : CM_Wagon;
	trainDepartEvent : CMEVT_TrainTransaction; 
	wagMoveController : CMIF_WagonMoveController;
begin

	self.initialiseActivity();

	self.raiseExceptionIfNull(_wagons, 'Wagons');
	
	//26 Feb 2021	NDL	TFS 50837
	create wagMoveController transient;
	wagMoveController.autoSetEffectiveTimeStamp();
	
	
	foreach wagon in _wagons discreteLock do
		exclusiveLock(wagon);
	
		wagon.departureProcess( wagMoveController, trainDepartEvent);
		if trainDepartEvent &lt;&gt; null then	//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
			trainDepartEvent.setCAMSTimeStamp(app.actualTimeServer);	
		endif;
	endforeach;

epilog
	delete wagMoveController;
end;

</source>
        <Parameter name="_wagons" type="CM_WagonSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWagonFMove" id="62afbdb5-b040-449b-b4ec-cfc6f3ef954c">
        <source>utlUpdateWagonFMove(_wagonPlanned :CM_FutureMoveWagonPlanned; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	realWagonPlanned		: CM_FutureMoveWagonPlanned;
	expectedEdition 		: Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_wagonPlanned, 'Wagon Future Planned Move proxy');
	
	_wagonPlanned.pxyGetRealObjectAndEdition(realWagonPlanned, expectedEdition);
	self.raiseExceptionIfNull(realWagonPlanned, 'Wagon Future Planned Move');
	
	_wagonPlanned.validationForUpdate();
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWagonPlanned, true);
	endif;
	
	realWagonPlanned.setUpdate(_wagonPlanned);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWagonPlanned, false);
	endif;
epilog

end;</source>
        <Parameter name="_wagonPlanned" type="CM_FutureMoveWagonPlanned"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWagonFromCMIF" id="3220c393-b6bd-4558-a192-f0415f90ff9b">
        <updating/>
        <source>utlUpdateWagonFromCMIF(	_wagonController : CMIF_WagonUpdateController input;
						_isValidate : Boolean;
						_isInitialise : Boolean;
						_passport : CM_Passport input)updating;
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//-----------------------------------------
//28/07/2010	cnwdad1		PAR #25120, added parameter for calling "initialiseActivity".

vars
	realWagon		: CM_Wagon;
	
begin
	if _isInitialise then
		self.initialiseActivity();
	endif;
	
	app.setContinueCMExceptions(true);
	_wagonController.validate(_passport);

	if not self.checkValidationWithPassport(_passport) or _isValidate then
		return;
	endif;

	app.setContinueCMExceptions(false);

	//_wagonController.actionForUpdate(_passport); //- cnwmd1, CCMS 1067, Par 19919
	_wagonController.actionForUpdate(_passport, self.myUpdateAuditAgent); ///+ cnwmd1, CCMS 1067, Par 19919
end;</source>
        <Parameter name="_wagonController" type="CMIF_WagonUpdateController" usage="input"/>
        <Parameter name="_isValidate" type="Boolean"/>
        <Parameter name="_isInitialise" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWagonInTransit" id="d16d8473-5085-48e7-a0d2-087dc5366458">
        <source>utlUpdateWagonInTransit(_wagons : CM_WagonSet input; 
						_status : Integer;
							_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     May 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	wagon : CM_Wagon;
begin

	self.initialiseActivity();

	self.raiseExceptionIfNull(_wagons, 'Wagons');
	
	foreach wagon in _wagons discreteLock do
		exclusiveLock(wagon);
	
		wagon.setInTransit(_status);
	endforeach;
			
end;

</source>
        <Parameter name="_wagons" type="CM_WagonSet" usage="input"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWagonLoadComplete" id="782ebee7-910e-434d-b9ca-0168925a7b27">
        <source>utlUpdateWagonLoadComplete(_wagon : CM_Wagon input; _completeWagonLoad: Boolean; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
14 November 2022	jlizm1	Initial creation TFS 54118 Assigning Releases to Wagons
14 March    2025    navbk1  Defect 34242: Halt Timer is displayed when clicking on Done on an Any Amount Rail Job

*/

vars
	delRequests : CM_DeliveryRequestSet;
	delRequest 	: CM_DeliveryRequest;

begin
	
	self.initialiseActivity();
	self.raiseExceptionIfNull(_wagon, 'Wagon');
	
	exclusiveLock(_wagon);
	
	create delRequests transient;
	_wagon.getAllAssignedDelRequests(delRequests);
	
	_wagon.cleanupUnactionedWLEs();
	
	foreach delRequest in delRequests do
		if (app.myPassport.isVASEnabled and not _completeWagonLoad) or (delRequest.myReserveDetail &lt;&gt; null and delRequest.myReserveDetail.isFullyLoaded()) then		//14.03.25 navbk1 #34242
			delRequest.completeUnactionedWLEs();
		endif;
	endforeach;
	
epilog
	delete delRequests;

end;</source>
        <Parameter name="_wagon" type="CM_Wagon" usage="input"/>
        <Parameter name="_completeWagonLoad" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWagonMaster" id="f1fe64ff-0440-48a8-af77-0c9382dfb018">
        <source>utlUpdateWagonMaster(pProxyWagonMaster:CM_WagonMaster; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2009	cnwndl1	Initial creation

*/

vars
	cancelSave:Boolean;
	realWagonMaster:CM_WagonMaster;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	pProxyWagonMaster.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyWagonMaster.pxyGetRealObjectAndEdition(realWagonMaster, expectedEdition);
	
	if realWagonMaster = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WagonMaster.name, null, null);
		return;
	endif;

	app.myValUA.valWagonMaster(pProxyWagonMaster);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realWagonMaster);

	if _passport.noErrors and realWagonMaster.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Wagon_master), null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWagonMaster, true);
	endif;
	
	if _passport.noErrors then
		realWagonMaster.setForUpdate(pProxyWagonMaster);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWagonMaster, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyWagonMaster" type="CM_WagonMaster"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWagonPosition" id="ce10da76-9e04-4a15-94d4-070a04c3e89a">
        <updating/>
        <source>utlUpdateWagonPosition( _moveController : CMIF_WagonMoveController; pRailLine : CM_RailLine input; pWagon : CM_Wagon input; 
				pIndex : Integer; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if pRailLine.myRailArea.myTerminal &lt;&gt; pWagon.myTerminal then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Wagon Terminal differs to Rail Line Terminal.');
		return;
	endif;
	
	if pIndex &gt; pRailLine.maximumWagons then
		app.raiseCMException2(ERR_LOWER_GT_UPPER, 'rake position', 'maximum Wagons allowed of ' &amp; pRailLine.maximumWagons.String, null, null);		
		return;
	endif;		
	
	if pRailLine.allWagons.includes(pWagon) then
		// if the wagon is already here at the same position then leave it
		if pRailLine.allWagons.indexOf(pWagon) = pIndex then
			return;
		endif;
	//	pRailLine.allWagons.remove(pWagon);
	endif;
	pRailLine.addWagon( _moveController, pWagon, pIndex, false);
	// get rid of null references on the end the wagon array
	pRailLine.tidyWagons();
	
	//app.myEventManager.createSingleObjInfoNoteEvt(pWagon, _passport.myTerminal.getTerminalEvent(Wagon_Update_Event), pWagon);
	// 03/12/2010 cnwar2 #26467 - get terminal off wagon rather than passport
	app.myEventManager.createSingleObjInfoNoteEvt(pWagon, pWagon.myTerminal.getTerminalEvent(Wagon_Update_Event), pWagon);

end;</source>
        <Parameter name="_moveController" type="CMIF_WagonMoveController"/>
        <Parameter name="pRailLine" type="CM_RailLine" usage="input"/>
        <Parameter name="pWagon" type="CM_Wagon" usage="input"/>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWagonPositionalRule" id="0ebc9aaa-2fe8-44e7-8546-92945211d945">
