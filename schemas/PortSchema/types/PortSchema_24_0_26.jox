    <JadeMethod name="convertAutoVoyageStatuses" id="eb762f8a-7f78-4975-8919-889b74150209">
        <source>convertAutoVoyageStatuses(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2024	navra1	Initial creation for //navra1 - MTN-33086 - 21st Oct 2024	//navra1 - MTN-33366 - 6th Nov 2024

*/

vars
	objArr 		: ObjectArray;
	damage			: CM_DamageInstance;
	objSet	: ObjectSet;
	severity, default : CM_DamageSeverity;
	root : CM_Root;
	term, defterm : CM_Terminal;
	
	voyStatus : CM_VoyageStatus;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Beginning to convert Auto voyage statuses", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Beginning to convert Auto voyage statuses") ;	
	endif;
	
	root := CM_Root.firstInstance;
	
	voyStatus := root.allVoyageStatuses[Voyage_Status_AutoOn_Auto];
	if voyStatus &lt;&gt; null then
		beginTransaction;
		voyStatus.setPropertyValue("description",Voyage_Status_AutoOn_Auto_Str);
		commitTransaction;
	endif;
	
	voyStatus := root.allVoyageStatuses[Voyage_Status_Autoff_Auto];
	if voyStatus &lt;&gt; null then
		beginTransaction;
		voyStatus.setPropertyValue("description",Voyage_Status_Autoff_Auto_Str);
		commitTransaction;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Completed convertion of Auto voyage statuses", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Completed convertion of Auto voyage statuses") ;
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
