    <JadeMethod name="getNextId" id="d59db5db-5464-4adc-8ed7-47180098b9cf">
        <source>getNextId():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2018	jlgndl1	Initial creation	TFS 37444

*/

vars

	index : Integer;

begin

	if not app.myRoot.allVoyageJobTransferTypes.isEmpty then
		index := app.myRoot.allVoyageJobTransferTypes.last.id + 1;
	endif;
	
	if index &lt; 10001 then
		index := 10001;
	endif;
	
	return index;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
