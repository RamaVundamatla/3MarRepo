        <updating/>
        <source>tblAllocatedGang_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyge Operations Enhancements
// 18/07/2109	jlgzm1		TFS 42872 JMT - Direct Delivery Between HOLD Voyages and Rail
//
vars

begin
	if button = Window.MouseButton_Left then 	// TFS 42872
		self.origXPos := x;						// TFS 42872
		self.origYPos := y;						// TFS 42872
	endif;
	// TFS 47085 jlgzm1	05/11/2019 moved to tblAllocatedGang_rowColumnChg
	//self.tableRowChange(table.CM_DataTable, table.row);
epilog

end;</source>
