    <JadeMethod name="createOverlapReport" id="22c7ea33-b317-4595-9de1-694ae24cd336">
        <source>createOverlapReport();

/*

Purpose:		Add the overlap details to the Dumped Test Runs	

Date			Who		Reason
07/03/2013		cnwmh5	Initial creation

*/
constants

	DELIM					: String = ",";
	
vars

	dict					: DynaDictionary;
	jdo						: JadeDynamicObject;
	obj						: Object;
	
	inputFile				: File;
	outputFile				: File;
	
	
	lineArray				: StringArray;
	
	line 					: String;
	currStartTS				: TimeStamp;
	currFinishTS			: TimeStamp;
	prevStartTS				: TimeStamp;
	prevFinishTS			: TimeStamp;
	prevSet					: Boolean;
	overlapStr				: String;
	nonOlapTime				: Time;
	overlapAmount			: Time;
	nonOlapTimeStr			: String;
	overlapAmountStr		: String;
	count					: Integer;
	posNeg					: Integer;
	days					: Integer;
	schedule				: String;
	elapsed					: String;
	elapsedHours			: Decimal[5,2];

begin

	// initialisations
	create lineArray transient;

	// create the dict to save stuff in
	create dict transient;
	dict.setMembership(JadeDynamicObject);
	dict.addExternalKey(Date, 8, true, false);			// Start Date 
	dict.addExternalKey(Time, 8, true, false);			// Start Time 
	dict.addExternalKey(Integer, 8, false, false);			// count 
	dict.endKeys(false);

	// create the input file;
	create inputFile transient;
	inputFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version	
	inputFile.fileName := "C:\Temp\Unit_Test_Run_Details.csv";
	
	// load the file details up
	while not inputFile.endOfFile do
	
		lineArray.clear();
	
		// get rid of the header
		if line = null then
			line := inputFile.readLine();
		endif;
	
		// read the line and get the individual details
		line := inputFile.readLine();
		///lineArray := line.cnGetTokens(DELIM);
		line.getTokensForDelimiter(",", lineArray);
		
		create jdo transient;
		jdo.addProperty("system", String);
		jdo.setPropertyValue("system", lineArray[1]);
		jdo.addProperty("startDate", Date);
		jdo.setPropertyValue("startDate", lineArray[2].Date);
		jdo.addProperty("startTime", Time);
		jdo.setPropertyValue("startTime", lineArray[3].Time);
		jdo.addProperty("finishDate", Date);
		jdo.setPropertyValue("finishDate", lineArray[4].Date);
		jdo.addProperty("finishTime", Time);
		jdo.setPropertyValue("finishTime", lineArray[5].Time);
		jdo.addProperty("runnable", Integer);
		jdo.setPropertyValue("runnable", lineArray[6].Integer);
		jdo.addProperty("testsRun", Integer);
		jdo.setPropertyValue("testsRun", lineArray[7].Integer);
		jdo.addProperty("elapsed", Real);
		jdo.setPropertyValue("elapsed", lineArray[8].Real);
		jdo.addProperty("schedule", String);
		jdo.setPropertyValue("schedule", lineArray[9]);
		jdo.addProperty("logResult", Boolean);
		if lineArray.size = 10 then
			jdo.setPropertyValue("logResult", lineArray[10].Boolean);
		else 
			jdo.setPropertyValue("logResult", false);
		endif;
		count := count + 1;
				
		dict.putAtKey(lineArray[2].Date, lineArray[3].Time, count, jdo);
		
		
	endwhile;
	inputFile.close();
	
	// create the output file;
	create outputFile transient;
	outputFile.fileName := "C:\Temp\Unit_Test_Run_Details_Overlap.csv";
	if outputFile.isAvailable() then
		outputFile.purge;	
	endif;
	outputFile.writeLine('System' &amp; DELIM &amp; 'Start Date' &amp; DELIM &amp; "Start Time" &amp; DELIM &amp; "Finish Date" &amp; DELIM &amp; "Finish Time" &amp; DELIM &amp; 
		"Runnable" &amp; DELIM &amp; "Tests Run" &amp; DELIM &amp; "Elapsed (mins)" &amp; DELIM &amp; "Elapsed (hours)" &amp; DELIM &amp; "Schedule" &amp; DELIM &amp; 
		"LogResult" &amp; DELIM &amp; "Overlapped" &amp; DELIM &amp; "Non Overlap Time" &amp; DELIM &amp; "Overlap Amount");	
	
	
	// now loop through the details and work out any overlaps
	prevSet := false;
	foreach obj in dict do
		
		currStartTS.setDate(obj.JadeDynamicObject.getPropertyValue('startDate').Date);
		currStartTS.setTime(obj.JadeDynamicObject.getPropertyValue('startTime').Time);
		currFinishTS.setDate(obj.JadeDynamicObject.getPropertyValue('finishDate').Date);
		currFinishTS.setTime(obj.JadeDynamicObject.getPropertyValue('finishTime').Time);
		schedule := obj.JadeDynamicObject.getPropertyValue('schedule').String;
		schedule := schedule.replaceString("^^", "");
		elapsed := obj.JadeDynamicObject.getPropertyValue('elapsed').String;
		elapsed := elapsed.replaceString("^^", "");
		elapsedHours := (elapsed.Real / 60).Decimal;
		
		overlapStr := null;
		nonOlapTimeStr := null;
		overlapAmountStr := null;

		// work out that is overlapped and what isn't
		if prevSet then
		
			if currFinishTS &gt; prevStartTS then
				overlapAmount := currFinishTS.differenceAsTime(prevStartTS, posNeg, days);
				if overlapAmount &lt;&gt; "00:00:00".Time then
					overlapAmountStr := overlapAmount.String;
					overlapStr := "Overlap";
					
					nonOlapTime := currStartTS.differenceAsTime(prevStartTS, posNeg, days);
					nonOlapTimeStr := nonOlapTime.String;
					
				endif;
			endif;
			
		endif;
		
		// set the previous details
		prevStartTS := currStartTS;
		prevFinishTS := currFinishTS;
		prevSet := true;
				
		outputFile.writeLine(obj.JadeDynamicObject.getPropertyValue('system').String  &amp; DELIM &amp; currStartTS.date.String &amp; DELIM &amp; currStartTS.time.String &amp; DELIM &amp; 
			currFinishTS.date.String &amp; DELIM &amp; currFinishTS.time.String &amp; DELIM &amp; obj.JadeDynamicObject.getPropertyValue('runnable').String &amp; DELIM &amp; 
			obj.JadeDynamicObject.getPropertyValue('testsRun').String &amp; DELIM &amp;	elapsed &amp; DELIM &amp; elapsedHours.String &amp; DELIM &amp; schedule &amp; 
			DELIM &amp; obj.JadeDynamicObject.getPropertyValue('logResult').String &amp; DELIM &amp; overlapStr &amp; DELIM &amp; nonOlapTimeStr &amp; DELIM &amp; overlapAmountStr);
	
	endforeach;
	outputFile.close();
	
epilog

	foreach obj in dict do
		delete obj;
	endforeach;
	delete dict;
	
	delete inputFile;
	delete outputFile;
	delete lineArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="53f5e7fe-dcb6-4b09-ab39-943d32901aac">
        <source>doFilterTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2025	navhn30 MTN-35092: MTN - Unit Test Results Improvements - Enable Free Text Search for Failure Messages
02 Jul 2025 navah1	Story 35269: MTN - Unit Test Results Improvements - Add a status bar with a count of items in table
*/ 

vars
	filterText 	: String;
	rowIdx,
	colIdx,
	start,
	rows		: Integer;
	cell 		: JadeTableCell;
	cellText 	: String;
	tbl			: CM_Table;
	count		: Integer;
begin
    rows		:= 0;
	filterText  := self.txtRSearch.text.toUpper();	
	tbl			:= self.tblResults;
	
	if filterText = "" then
		self.populateResultsTable();
		return;
	endif;
	
	start := tbl.fixedRows + 1;

	foreach rowIdx in start to tbl.rows do : rowLoop
		tbl.accessRow(rowIdx);
		
		foreach colIdx in 1 to tbl.columns do
			cell 	 := tbl.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then   
				tbl.accessedRow.visible := true;
				rows := rows+1;
				continue rowLoop;
			endif;
		endforeach;
		
		tbl.accessedRow.visible := false;
	endforeach;
	
	self.lblResultsCount.caption := app.getErrorString1(Num_Rows_Found, rows.String);  //02.07.2025 navah1 #35269
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="dumpRunDetails2" id="7a3ef39c-b82b-487a-a5d2-1f7f0472e9f5">
        <source>dumpRunDetails2();

/*

Purpose:		Dump Unit Test runs details to a CSV

Date			Who		Reason
19/02/2015		cnwmh5	Initial creation

*/

constants

	DELIM						: String = ",";

vars

	root						: UM_Root;
	testRun						: UM_UnitTestRun;
	file						: File;

begin

	root := UM_Root.firstInstance;
	if root = null then
		return;
	endif;
	
	create file transient;
	file.fileName := "c:\temp\UnitTestRunDetails2.csv";
	if file.isAvailable() then
		file.purge;
	endif;
	file.writeLine("Date,Time,Runnable,Run,Elapsed");
	
	foreach testRun in root.allUnitTestRuns discreteLock do
		file.writeLine(testRun.startTS.date.String &amp; DELIM &amp; testRun.startTS.time.String &amp; DELIM &amp;
			testRun.totalRunnable.String &amp; DELIM &amp; testRun.numRun.String &amp; DELIM &amp; 
			testRun.elapsedTime.String);
	endforeach;

epilog

	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="extractBrokenTestFromFile" id="aacfd8e9-8d9b-4ada-80a4-e68379314eab">
        <source>extractBrokenTestFromFile();

/*

Purpose:	Convert the fails taken from the email to a unl file so can be loaded
			into GUI

Date		Who		Reason
24/06/2014	cnwmh5	Initial creation

*/

vars

	file						: File;
	outFile						: File;
	openDialog 					: CMDFileOpen;
	
	tokens						: StringArray;
	
	line						: String;
	className					: String;
	methodName					: String;
	pos							: Integer;
	foundTRF					: Boolean;
	countEqual					: Integer;

begin

	create openDialog transient;
	openDialog.filter := 'txt Files| *.txt|eml Email| *eml';
	openDialog.initDir := "c:\temp\";
	openDialog.filterIndex := 1;
	
	if openDialog.open() = 0 then
		create file transient;
		file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version	
		file.fileName := openDialog.fileName;
		create outFile transient;
		outFile.mode := File.Mode_Output; // 29/2/16  cnwns1 PAR 36286 unicode version
		outFile.fileName := openDialog.fileName[1:openDialog.fileName.length-3] &amp; "unl";
	endif;
	
	if file = null then
		return;
	endif;
	
	if outFile = null then
		return;
	endif;	
	
	create tokens transient;
	
	foundTRF := false;
	countEqual := 0;
	
	while not file.endOfFile do
	
		line := file.readLine();
		
		if not foundTRF then
			if line.cnContains("Test Runner Failures") then
				foundTRF := true;
			endif;
			continue;
		endif;
		
		if line.cnContains("====================") then
			countEqual := countEqual + 1;
			if countEqual = 2 then
				break;
			endif;
			continue;
		endif;
				
		tokens.clear();
		line.getTokensForDelimiter(" ", tokens);
		
		pos := tokens[2].pos("::", 1);
		className := tokens[2][1:pos-1];
		methodName := tokens[2][pos+2:end];
		
		outFile.writeLine("Method " &amp; className &amp; " " &amp; methodName);
	
	endwhile;
	
	file.close;
	outFile.close;
	
epilog

	delete file;
	delete openDialog;
	delete tokens;
	delete outFile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="extractFailsFromTableCSV" id="50daa087-dcb5-4a38-b83c-4213d1fcb2c6">
        <source>extractFailsFromTableCSV();
/*
Purpose - 	
Who - NAVAB1
Date - 08JAN2024
ADO -  CR 58085 TASK 61342
*/

vars

	csvFile						: File;
	testRun						: UM_UnitTestRun;
	fileFolder					: FileFolder;

	row							: Integer;
	systemName					: String;
	runTS						: String;

begin

	// dont do if not selected as we are using the table.
	if self.chkFailed.value = false or self.tblResults.rows = 1 then
		return;
	endif;
	
	systemName := CM_Version.VERSION;
	systemName := systemName.removeString(".");
	
	testRun := self.cmbDate.listObject.UM_UnitTestRun;
	runTS := testRun.startTS.date.year.String &amp; testRun.startTS.date.month.padLeadingWith("0", 2) &amp;  
		testRun.startTS.date.day.padLeadingWith("0", 2) &amp; testRun.startTS.time.hour.padLeadingWith("0", 2) &amp; 
		testRun.startTS.time.minute.padLeadingWith("0", 2) &amp; testRun.startTS.time.second.padLeadingWith("0", 2);
	
	create fileFolder transient;
	fileFolder.usePresentationFileSystem := true;
	fileFolder.fileName := "c:\temp\FailingTests" &amp; systemName &amp; runTS;
	if not fileFolder.isAvailable then
		fileFolder.make();
	endif;
	
	create csvFile transient;
	csvFile.usePresentationFileSystem := true;
	csvFile.fileName := fileFolder.fileName &amp; "\FailingTests" &amp; systemName &amp; runTS &amp; ".csv";
	if csvFile.isAvailable() then
		csvFile.purge();
	endif;
	
	row := 1;
	csvFile.writeLine( self.tblResults.accessCell(row, 1).text.trimBlanks() &amp; Comma &amp;
								 self.tblResults.accessCell(row, 2).text.trimBlanks() &amp; Comma &amp;
								self.tblResults.accessCell(row, 3).text.trimBlanks() &amp; Comma &amp;
								self.tblResults.accessCell(row, 4).text.trimBlanks() &amp; Comma &amp;
								self.tblResults.accessCell(row, 5).text.trimBlanks() &amp; Comma &amp;
								self.tblResults.accessCell(row, 6).text.trimBlanks() &amp; Comma &amp;
								self.tblResults.accessCell(row, 7).text.trimBlanks() &amp; Comma &amp;
								self.tblResults.accessCell(row, 8).text.trimBlanks() &amp; Comma &amp;
								self.tblResults.accessCell(row, 9).text.trimBlanks());
	
	foreach row in 2 to self.tblResults.rows step 1 do
	
		if not process.isPW and (self.tblResults.accessCell(row, 1).text.trimBlanks() &lt;&gt; "FAIL" or self.tblResults.accessCell(row, 1).foreColor &lt;&gt; Red) then
			continue;
		endif;
	
		csvFile.writeLine( self.tblResults.accessCell(row, 1).text.trimBlanks() &amp; Comma &amp;
								 self.tblResults.accessCell(row, 2).text.trimBlanks() &amp; Comma &amp;
								self.tblResults.accessCell(row, 3).text.trimBlanks() &amp; Comma &amp;
								self.tblResults.accessCell(row, 4).text.trimBlanks() &amp; Comma &amp;
								self.tblResults.accessCell(row, 5).text.trimBlanks() &amp; Comma &amp;
								self.tblResults.accessCell(row, 6).text.trimBlanks() &amp; Comma &amp;
								self.tblResults.accessCell(row, 7).text.trimBlanks() &amp; Comma &amp;
								self.tblResults.accessCell(row, 8).text.trimBlanks() &amp; Comma &amp;
								self.tblResults.accessCell(row, 9).text.trimBlanks()
			);
		
	endforeach;
	csvFile.close;
	
	app.msgBox("File: " &amp; csvFile.fileName &amp; " created.", "Created", MsgBox_OK_Only);
	
epilog

	delete csvFile;
	delete fileFolder;

end;</source>
    </JadeMethod>
    <JadeMethod name="extractFailsFromTableUNL" id="388f88df-0e9b-407c-9743-8ff252282f19">
        <source>extractFailsFromTableUNL();

/*

Purpose:		Extract the fails from the table into a unl file	

Date			Who		Reason
20/08/2015		cnwmh5	Initial creation

*/

vars

	unlFile						: File;
	testRun						: UM_UnitTestRun;
	fileFolder					: FileFolder;

	row							: Integer;
	systemName					: String;
	runTS						: String;

begin

	// dont do if not selected as we are using the table.
	if self.chkFailed.value = false or self.tblResults.rows = 1 then
		return;
	endif;
	
	systemName := CM_Version.VERSION;
	systemName := systemName.removeString(".");
	
	testRun := self.cmbDate.listObject.UM_UnitTestRun;
	runTS := testRun.startTS.date.year.String &amp; testRun.startTS.date.month.padLeadingWith("0", 2) &amp;  
		testRun.startTS.date.day.padLeadingWith("0", 2) &amp; testRun.startTS.time.hour.padLeadingWith("0", 2) &amp; 
		testRun.startTS.time.minute.padLeadingWith("0", 2) &amp; testRun.startTS.time.second.padLeadingWith("0", 2);
	
	create fileFolder transient;
	fileFolder.usePresentationFileSystem := true;
	fileFolder.fileName := "c:\temp\FailingTests" &amp; systemName &amp; runTS;
	if not fileFolder.isAvailable then
		fileFolder.make();
	endif;
	
	create unlFile transient;
	unlFile.usePresentationFileSystem := true;
	unlFile.fileName := fileFolder.fileName &amp; "\FailingTests" &amp; systemName &amp; runTS &amp; ".unl";
	if unlFile.isAvailable() then
		unlFile.purge();
	endif;
	
	foreach row in 2 to self.tblResults.rows step 1 do
	
		if self.tblResults.accessCell(row, 1).text.trimBlanks() &lt;&gt; "FAIL" or self.tblResults.accessCell(row, 1).foreColor &lt;&gt; Red then
			continue;
		endif;
	
		unlFile.writeLine("Method" &amp; Space &amp; self.tblResults.accessCell(row, 2).text.trimBlanks() &amp; Space &amp; 
			self.tblResults.accessCell(row, 3).text.trimBlanks());
		
	endforeach;
	unlFile.close;
	
	app.msgBox("File: " &amp; unlFile.fileName &amp; " created.", "Created", MsgBox_OK_Only);
	
epilog

	delete unlFile;
	delete fileFolder;

end;</source>
    </JadeMethod>
    <JadeMethod name="extractMethodAverages" id="ae15680e-f7c7-4884-aded-d527ae767bab">
        <source>extractMethodAverages();

/*

Purpose:		Extract Test Method Averages (ALL)

Date			Who		Reason
18/09/2015		cnwmh5	Initial creation

*/

vars

	result						: UM_UnitTestResult;
	utRun						: UM_UnitTestRun;
	root						: UM_Root;
	classMethod					: UM_UnitTestClassMethod;
	file						: File;
		
	detailsDict					: DynaDictionary;
	
	iter						: Iterator;
	iter2						: Iterator;
	
	className					: String;
	methodName					: String;
	runTS						: TimeStamp;
	weekOfYear					: Integer;
	currentWeek					: Integer;
	elapsedTime					: Real;
	currentClassName			: String;
	currentMethodName			: String;
	shortWeek					: Boolean;
	dayCount					: Integer;
	currentYear					: Integer;
	avgTime						: Real;
	today						: TimeStamp;
	version						: String;

begin

	app.mousePointer := MousePointer_HourGlass;

	root := UM_Root.firstInstance;
	if root = null then
		return;
	endif;

	create detailsDict transient;
	detailsDict.setMembership(UM_UnitTestResult);
	detailsDict.addExternalKey(String, 32, false, false);					// Class Name
	detailsDict.addExternalKey(String, 32, false, false);					// Method name
	detailsDict.addExternalKey(TimeStamp, 8, true, false);					// Result start time
	detailsDict.endKeys(false);

	version := CM_Version.VERSION;
	version := version.replaceString(".", "");
	
	today := app.cnGetServerTime();
	
	create file transient;
	file.fileName := "c:\temp\TestAverages_" &amp; version &amp; "_" &amp; today.date.year.padLeadingWith("0", 2) &amp; 
		today.date.month.padLeadingWith("0", 2) &amp; today.date.day.padLeadingWith("0", 2) &amp; "_" &amp;
		today.time.hour.padLeadingWith("0", 2) &amp; today.time.minute.padLeadingWith("0", 2) &amp; 
		today.time.second.padLeadingWith("0", 2) &amp; ".csv";
	if file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("ClassName,MethodName,Year,WeekNo,Elpased,Average");
	
	iter := root.allUnitTestRuns.createIterator;
	while iter.next(utRun) do
		
		delete iter2;
		iter2 := utRun.allFailed.createIterator;
		while iter2.next(result) do
			classMethod := result.myClassMethod;
			detailsDict.putAtKey(classMethod.className, classMethod.methodName, utRun.startTS, result);
		endwhile;
		
		delete iter2;
		iter2 := utRun.allPassed.createIterator;
		while iter2.next(result) do
			classMethod := result.myClassMethod;
			detailsDict.putAtKey(classMethod.className, classMethod.methodName, utRun.startTS, result);
		endwhile;

	endwhile;	

	delete iter;
	iter := detailsDict.createIterator;
	while iter.next(result) do
		detailsDict.getIteratorKeys(className, methodName, runTS, iter);
		
		// get Week No
		weekOfYear := runTS.date.getISOWeekNumber();
		
		if currentWeek &lt;&gt; weekOfYear then
		
			if currentWeek &gt; 0 then
				if dayCount &lt; 6 then
					shortWeek := true;
				endif;
				avgTime := (elapsedTime / 7).Real;
				file.writeLine(currentClassName &amp; "," &amp; currentMethodName &amp; "," &amp; currentYear.String &amp; "," &amp; currentWeek.String &amp; "," &amp; 
					elapsedTime.String &amp; "," &amp; avgTime.roundedTo(2).String);
			endif;
			
			currentClassName := className;
			currentMethodName := methodName;
			elapsedTime := 0;
			currentWeek := weekOfYear;
			shortWeek := false;
			dayCount := 0;
			currentYear := runTS.date.year;
		endif;
		
		elapsedTime := elapsedTime + result.elapsedTime.Real;
		dayCount := dayCount + 1;
		
	
	endwhile;
	
	avgTime := (elapsedTime / 7).Real;
	file.writeLine(currentClassName &amp; "," &amp; currentMethodName &amp; "," &amp; currentYear.String &amp; "," &amp; currentWeek.String &amp; "," &amp; 
		elapsedTime.String &amp; "," &amp; avgTime.roundedTo(2).String);
	
epilog

	app.mousePointer := MousePointer_Default;

	delete detailsDict;
	delete iter;
	delete iter2;
	delete file;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="fldUnitTests_click" id="eb00f4db-dda7-41c6-acc3-7f3dcf30b4aa">
        <controlMethod name="Folder::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldUnitTests_click(folder: Folder input) updating;

/*

Purpose:			

Date			Who		Reason
20/08/2015		cnwmh5	Initial creation

*/

vars

begin
	
	// set whether btnExtractFails is visible
	self.btnExtractFailsUNL.visible := false;
	if self.fldUnitTests.topSheet = self.shtResults then
		self.btnExtractFailsUNL.visible := true;
	endif;

epilog

end;</source>
