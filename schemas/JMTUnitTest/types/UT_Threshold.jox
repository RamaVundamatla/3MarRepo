						_operator,	//_operator : CM_Operator;
						cargoType,	//_cargoType : CM_CargoType;
						TI_TRANSMODE_RAIL	//_transMode : Integer
						);
						
	self.addPreNotes(	"THRS1110115",	//_id : String;
						isoType,	//_isoType : String;
