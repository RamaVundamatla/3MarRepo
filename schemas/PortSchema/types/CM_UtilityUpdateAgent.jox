    <JadeMethod name="utlUpdateInvContractDtlRtEntry" id="9762e8cc-2581-4b6b-bf6d-e6f53dc7b4b7">
        <updating/>
        <source>utlUpdateInvContractDtlRtEntry(_pxyObject : CM_InvoiceContractRateEntry; _passport : CM_Passport input) updating;
/*
Purpose:			

Date		Who		Reason
09DEC2022	NAVAB1	TFS CR 55623 TASK 55677
*/
vars
	realObject		: CM_InvoiceContractRateEntry;
	expectedEdition	: Integer;
	debtor : CM_Debtor;
	contractRate : CM_InvoiceContractRate;
	rateChanged : Boolean;

begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyObject, 'Invoice Contract Rate Entry');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valUpdateInvContractDtlRtEntry(_pxyObject);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realObject := self.getRealObjectAndEditionCheck(_pxyObject, 'Invoice Contract Rate Entry', _passport).CM_InvoiceContractRateEntry;
	
	rateChanged := _pxyObject.costPerUnit &lt;&gt; realObject.costPerUnit; // ### TFS BUG 64886 14AUG2024 NAVAB1

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
		app.myEventManager.createSingleObjInfoNoteEvt(_pxyObject.myInvoiceContractRate,app.myPassport.myTerminal.getTerminalEvent(Event_InvContractRateEntUpdate),_pxyObject);	//16-02-2023 navtnr20 TFS CR 55646 TASK 55664
	endif;

	if _passport.noErrors then
		// do updates
		realObject.setForUpdate(_pxyObject);
	endif;
	
	// ### TFS BUG 64886 14AUG2024 NAVAB1
	if rateChanged and _passport.noErrors then
		contractRate := realObject.myInvoiceContractRate;
		debtor := contractRate.getDebtor();
		contractRate.updateCharges(debtor);
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;

end;</source>
        <Parameter name="_pxyObject" type="CM_InvoiceContractRateEntry"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvContractRtEntryBlk" id="8c796bea-2623-412b-8f34-6a98d81e0414">
        <updating/>
        <source>utlUpdateInvContractRtEntryBlk(_agent1 : CMIF_InvoiceContractBulkRates; _passport : CM_Passport input) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 28NOV2023
ADO -  BUG 61268
*/

vars
	proxyRateEntry, realObject		: CM_InvoiceContractRateEntry;
	expectedEdition	: Integer;
	debtor : CM_Debtor;
	contractRate : CM_InvoiceContractRate;
	rates : CM_InvoiceContractRateSet;
	rateChanged : Boolean;
begin

	self.initialiseActivity();
	
	// do validation
	app.setContinueCMExceptions(true);

	foreach proxyRateEntry in _agent1.allPxyRateEntries as CM_InvoiceContractRateEntry do
		app.myValUA.valUpdateInvContractDtlRtEntry(proxyRateEntry);

		if not self.checkValidationWithPassport(_passport) then
			return;
		endif;
	endforeach;
	
	create rates transient;
	
	// do updates
	foreach proxyRateEntry in _agent1.allPxyRateEntries as CM_InvoiceContractRateEntry do
		realObject := self.getRealObjectAndEditionCheck(proxyRateEntry, 'Invoice Contract Rate Entry', _passport).CM_InvoiceContractRateEntry;
		
		rateChanged := proxyRateEntry.costPerUnit &lt;&gt; realObject.costPerUnit;
		
		if _passport.noErrors then
			// This is only required if the class is being auditted
			self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
			app.myEventManager.createSingleObjInfoNoteEvt(proxyRateEntry.myInvoiceContractRate,app.myPassport.myTerminal.getTerminalEvent(Event_InvContractRateEntUpdate),proxyRateEntry);	
		endif;

		if _passport.noErrors then
			// do updates
			realObject.setForUpdate(proxyRateEntry);
		endif;
		
		// ### TFS BUG 64886 14AUG2024 NAVAB1
		contractRate := realObject.myInvoiceContractRate;
		if rateChanged then
			rates.addNoDuplicates(contractRate,false);
		endif;
		
		if _passport.noErrors then
			// This is only required if the class is being auditted
			self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
		endif;
	endforeach;
	
	// ### TFS BUG 64886 14AUG2024 NAVAB1
	if _passport.noErrors then
		foreach contractRate in rates do
			debtor := contractRate.getDebtor();
			contractRate.updateCharges(debtor);
		endforeach;
	endif;
epilog

	delete rates;
end;</source>
        <Parameter name="_agent1" type="CMIF_InvoiceContractBulkRates"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateInvContractShpngTerms" id="6eec620b-a790-4773-b101-e18eb5875baf">
        <source>utlUpdateInvContractShpngTerms(_pxyInvoiceContractShipTerm : CM_InvoiceContractShipTerm io;
							  _passport 		       : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
15 Dec 2022 navtnr20	TFS CR 55622 Task 55690: Jade - Shipping Terms TRX

*/

vars
	realShippingLine:CM_InvoiceContractShipTerm;
	expectedEdition:Integer;
	theTerminal : CM_Terminal;
begin

	self.initialiseActivity();

	_pxyInvoiceContractShipTerm.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyInvoiceContractShipTerm.pxyGetRealObjectAndEdition(realShippingLine, expectedEdition);
	
	if realShippingLine = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceContractShipTerm.name, null, null);
		return;
	endif;

	app.myValUA.valInvShipTerm(_pxyInvoiceContractShipTerm);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realShippingLine);

	if _passport.noErrors and realShippingLine.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Shipping Term', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realShippingLine, true);
	endif;
	
	if _passport.noErrors then
		realShippingLine.setForUpdate(_pxyInvoiceContractShipTerm);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realShippingLine, false);
		app.myEventManager.createSingleObjInfoNoteEvt(realShippingLine.myBusinessUnit,app.myPassport.myTerminal.getTerminalEvent(Event_InvShipTermUpdate),realShippingLine);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_pxyInvoiceContractShipTerm" type="CM_InvoiceContractShipTerm" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
