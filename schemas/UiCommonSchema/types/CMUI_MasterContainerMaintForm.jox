    <JadeMethod name="cmbISOType_keyUp" id="5f998d60-1abe-455f-b1bf-83617d2fc6da">
        <controlMethod name="ComboBox::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbISOType_keyUp(combobox: ComboBox input; keyCode: Integer io; shift: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2008	cnwrd1	Initial creation
03/11/2009	cnwmh5	PAR21501 - Add test for tmpIsoType = null

*/

vars
	tmpIsoType : CM_ISOType;
begin

	tmpIsoType := combobox.listObject.CM_ISOType;
	if tmpIsoType &lt;&gt; null then						// 03/11/2009 cnwmh5 PAR21501
		setForReefer ( tmpIsoType.isReefer );
	endif;
	
epilog

end;</source>
