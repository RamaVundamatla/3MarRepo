    <JadeMethod name="doShowHideProfiles" id="e066b997-554f-4153-ba07-c4bf30e405ee">
        <updating/>
        <source>doShowHideProfiles(_report : JadeReportWriterReport input; _defaultValue: String) updating;
// ---------------------------------------------------------------------------
// Created:     24 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	defaultProfile,
	profile			: String;
	profileNames	: StringArray;
	cmb				: CMUI_ComboBox;
	idx, defIdx		: Integer;
//	tbl				: CM_BaseTable;
begin
	cmb := self.myCmbProfile; 
	cmb.clear();
	
	if _report = null then
		return;
	endif;
/*	
	if self.myEntryTable &lt;&gt; null then
		tbl := self.myEntryTable;
		if (not self.myEntryTable.isRowVisible(ETRow_ReportProfile)) then
			return;
		endif;
	elseif self.myBaseTable &lt;&gt; null then
		tbl := self.myBaseTable;
		
	endif;			
	
	if tbl = null then
		return;
	endif;
*/	
	if _defaultValue &lt;&gt; null then
		defaultProfile := _defaultValue;
	else
		defaultProfile := _report.getDefaultProfile();
	endif;
	
	profileNames := _report.getProfiles();
	foreach profile in profileNames do
		idx := cmb.addItem(profile);
		if profile = defaultProfile then
			defIdx := idx;
		endif;
	endforeach;
	
	if defIdx &gt; 0 then
		cmb.listIndex := defIdx;
	endif;
	
	self.setValueByName(ETRow_ReportProfile, cmb.text);
	
end;</source>
        <Parameter name="_report" type="JadeReportWriterReport" usage="input"/>
        <Parameter name="_defaultValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="doTblTerminalsClick" id="0480aaad-b499-42bc-81dd-994782b38b35">
        <source>doTblTerminalsClick();
// ---------------------------------------------------------------------------
// Created:     08 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
04 Dec 2015	cnwkpd1	PAR #36903 - Invoice Report Template editing issue
28 Aug 2023 navhl20 Bug 60056: FR | 53429 - VBS Selector issues
*/

vars
	row,
	numRows			: Integer;
	tbl				: CMUI_ListTable;
	obj				: Object;
	terminal		: CM_Terminal;
	entDef			: EntTableDef;
	entTbl			: CM_EntryTable;
	codeActual,
	codeAllocated,
	voyCode			: String;
	intRow			: Integer;
	enableSubTerminal : Boolean;
begin
	enableSubTerminal := false;
	self.allTerminals.clear();
	tbl := self.myLstTblTerminals;
	numRows := tbl.rows;
	
	//don't rely on tbl.allSelectedObjects - go by ticks at this stage as this is called from ::change
	//allSelectedObjects has not been updated at this point
	foreach intRow in 1 to numRows do
		terminal := tbl.accessRow(intRow).itemObject.CM_Terminal;
		if tbl.rowChecked(intRow) then
			if (not self.allTerminals.includes(terminal)) then
				self.allTerminals.add(terminal);
				//9/11/2009 cnwdz2 par21400
				if app.isSubTerminalsOn(terminal) then
					enableSubTerminal := true;
				endif;
			endif;
		endif;
	endforeach;

	if self.myQryReport = null then
		return;
	endif;

	//9/11/2009 cnwdz2 par21400
	if enableSubTerminal then
		self.myEntryTable.showRowByName(ETRow_MySubTerminal, false);
	else
		self.myEntryTable.hideRowByName(ETRow_MySubTerminal, false);
	endif;
	
	// Par 9708. Reselect global voyages.	Changed to remember what
	// voyage was select. Not sure why code is reloading everything?
	if (self.state &lt;&gt; self.STATE_TEMPLATE_EDIT) then

		if self.myCmbActualVoy.listObject &lt;&gt; null then
			codeActual := self.myCmbActualVoy.listObject.CM_VoyageGlobal.code;
		endif;
		entTbl := self.myEntryTable;		
		if entTbl.isRowVisible(ETRow_VoyageActual) then
			self.doLoadGlobalVoyActual(self.myCmbActualVoy, codeActual);
			self.doLoadLotHatchPlace(self.myCmbActualVoy.listObject.CM_VoyageGlobal);
		elseif entTbl.isRowVisible(ETRow_VoyageAllocated) then //18/05/2009 cnwdz2 par19257 changed ETRow_Voyage to ETRow_VoyageAllocated
			if self.myCmbAllocatedVoy.listObject &lt;&gt; null then
				codeAllocated := self.myCmbAllocatedVoy.listObject.CM_VoyageGlobal.code;
			endif;
			self.doLoadGlobalVoyAllocated(self.myCmbAllocatedVoy, codeAllocated);
			self.doLoadAllocatedRows(self.myCmbRowId, self.myCmbAllocatedVoy.listObject.CM_VoyageGlobal, null);
			self.doLoadCellularVoyages(self.myCmbCellularVoy, null, codeAllocated);
			self.doLoadLotHatchPlace(self.myCmbAllocatedVoy.listObject.CM_VoyageGlobal);//PAR11511
		elseif entTbl.isRowVisible(ETRow_GatePass) then
			self.doLoadGatePasses(self.myCmbGatePass,Any_String);
		endif;
		
		if entTbl.isRowVisible(ETRow_InvoiceType) then
			self.doLoadInvoiceType(self.myCmbInvoiceType, null, null); // SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface 23/04/2010
		endif;
		if entTbl.isRowVisible(ETRow_InvLineType) then
			self.doLoadInvoiceLineType(self.myCmbInvoiceLineType, null, null);	// CCMS 2348 Financial reporting
		endif;
		
		if entTbl.isRowVisible(ETRow_TsType) then													//28.8.2023 navhl20 #60056
			self.doLoadVBSTsType(self.myLstTblVBSTsType, null);
			self.setValueByName(ETRow_TsType, self.myLstTblVBSTsType.getSelectedFromDisplay);
		endif;
		
		if entTbl.isRowVisible(ETRow_Company) then
			self.doLoadCompanies(self.myCmbCompany, null); // SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface 23/04/2010
		
		endif;

		//cnwth2 - previously re-loaded every combo - this was unneccessary
		//self.myParent.CMUI_ReportRunner.loadControlsForReport(entDef);

	else
		// PAR #36903 - If Terminals table is changed need to reload Companies
		if self.myCmbCompany &lt;&gt; null then
			self.doLoadCompanies(self.myCmbCompany, self.myCmbCompany.text);
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="filterSelectorQuery" id="4669f939-6672-4ea5-8db3-4b161fa4ad77">
        <source>filterSelectorQuery() : Integer;
// ---------------------------------------------------------------------------
// Created:     20 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	criteriaHolder 		: CM_QueryCriteriaLineHolder;
	criteriaLine		: CM_SelectorCriteriaLine;
	userQuery			: CM_MenuUserQuery;
	qDef				: CM_QueryDefinition;
	enqController		: CM_EnquiryController;
	jrwTrans			: CM_JRWTrackedItems;
	queryAgent			: CM_QueryAgentFilter;

begin

	on CM_BreakOutException do app.myQAFilter.xHandlerBreakOut(exception);
	
	userQuery := self.myQryReport.mySelectorQuery;
	queryAgent := app.myQAFilter;
	
	if queryAgent = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myQAFilter was null');
		return null;
	endif;
	
	jrwTrans := queryAgent.createJRWTransient(CM_JRWTrackedItems).CM_JRWTrackedItems;
	qDef := app.myRoot.allQueryDefinitionObjects[userQuery.getType, userQuery.queryMode];
	
	if qDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Query definition for mode ' &amp;
										userQuery.queryMode.String &amp; ' could not be found in app.myRoot.allQueryDefinitionObjects');
		return null;
	endif;
	
	queryAgent.createEnqControllerForMode(userQuery.queryMode, userQuery.getType, enqController);
	delete enqController.allObjects;
	create enqController.allObjects as jrwTrans.allTrackedItems.class transient;
	
	foreach criteriaHolder in self.allCriteriaLineHolders do
		enqController.myCriteriaLineHolder := criteriaHolder ;
		enqController.doQuery(qDef);
	endforeach;
	
	enqController.allObjects.copy(jrwTrans.allTrackedItems);	
	
	return enqController.allObjects.size();
	
epilog
	delete enqController.allObjects;
	delete enqController;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
