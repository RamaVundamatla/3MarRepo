<GUIClass name="MOB_CEBookingRefForm" id="87f56c57-116b-4da0-9f4e-cbebbd2f03ea">
    <superclass name="MOB_CETableForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myBookingRef" id="0cdd4976-5c81-4e99-820f-3e3986a98184">
        <embedded/>
        <type name="CM_BookingRef"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="addItemToTable" id="3303c366-ce43-477f-9e5b-e0be66ac025c">
        <source>addItemToTable(_tbl : CM_MobTable io; _obj : CM_Object);
// ---------------------------------------------------------------------------
// Created:     30 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	row : Integer;
	colour	: Integer;
	bookingRef : CM_BookingRef;
	bookingRefItem : CM_BookingRefItem;
begin
	if _obj.isKindOf(CM_BookingRefItem) then
		bookingRefItem := _obj.CM_BookingRefItem;
		row := _tbl.addItem(getBRItemDisplay(bookingRefItem));
		colour := self.getColorForBookingRefItem(bookingRefItem);
	elseif _obj.isKindOf(CM_BookingRef) then
		bookingRef := _obj.CM_BookingRef;
		row := _tbl.addItem(getBookingRefDisplay(bookingRef));
		colour := self.getColorForBookingRef(bookingRef);
	endif;
	_tbl.accessRow(row).itemObject := _obj;
	
	//21/02/2009 cnwdz2 ccms1801	
	_tbl.accessRow(row).backColor := colour;
	_tbl.accessRow(row).foreColor := colour.getInverseColour;
end;</source>
        <Parameter name="_tbl" type="CM_MobTable" usage="io"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="calculateColor" id="56d7b970-7498-43e6-aa35-b7985c4c5cd4">
        <source>calculateColor(_packed,_onSite,_total:Integer):Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2009	#cnwdz2	 ccms1801

*/

vars

begin
	if _packed &gt;= _total then // packed completed
		return Green;
	elseif _packed = 0 then // packed not started 
		return Blue;
	elseif  _packed + _onSite &gt;= _total then // the packed items + the number of cargo on site ready to be packed,
		return 33023; // this is Orange 				is enough to complete the packing request =&gt; in progress	
	else 
		return Red;
	endif;
epilog

end;</source>
        <Parameter name="_packed" type="Integer"/>
        <Parameter name="_onSite" type="Integer"/>
        <Parameter name="_total" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBtnDetailsClick" id="b21efed3-7fd9-439d-ba15-ac6e865129ef">
        <source>doBtnDetailsClick();
// ---------------------------------------------------------------------------
// Created:     19 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	form : Form;
	txt : String;
	bookingRef : CM_BookingRef;
	requestObj : CM_BulkRelease;
begin
	bookingRef := self.myBookingRef;
	if bookingRef &lt;&gt; null then
		if bookingRef.allReleaseRequests.size &gt; 0 then
			txt := bookingRef.allReleaseRequests.first.code;
		else
			txt := bookingRef.bookingReference;
		endif;
	endif;
	// find release request 
	requestObj := self.myMobileDataAgent.getPackReleaseById(txt);
	if requestObj &lt;&gt; null then
		form := app.myMobileGUIAgent.findOrShowForm(MOB_PackCargoForm, null, false);
		if form.isKindOf(MOB_PackCargoForm) then
			form.MOB_PackCargoForm.myRequest := requestObj;
			form.MOB_PackCargoForm.txt_RequestNo.text := requestObj.code;
		endif;
	else
		app.msgBox("Release not found to be active or for packing",null, MsgBox_Exclamation_Mark_Icon);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getBRItemDisplay" id="06bead80-1243-4347-8d3e-b016e8df79c9">
        <source>getBRItemDisplay(_brItem : CM_BookingRefItem): String;
// ---------------------------------------------------------------------------
// Created:     30 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	item,
	total,
	locations, marks 	: String;
	packed,
	onSite		:  Integer;
begin
	item 		:= _brItem.getPlainDescription;	
	marks		:= _brItem.shippingMarks;
	total 		:= _brItem.quantity.String;
	onSite 		:= _brItem.getNumOnsiteItemsUnpacked;
	packed 		:= _brItem.getNumPackedItems;
	locations	:= _brItem.getOnSiteLocations();
	
	return item &amp; Tab &amp; marks &amp; Tab &amp; total &amp; Tab &amp; packed.String &amp; Tab &amp;onSite.String &amp; Tab &amp; locations ;

end;</source>
        <Parameter name="_brItem" type="CM_BookingRefItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBookingRefDisplay" id="6669d147-4016-4f29-a802-c981d1da26f3">
        <source>getBookingRefDisplay(_br : CM_BookingRef):String;
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 24/12/2012	cnwdap1		PAR #30882 CCMS PNL 2244 If the booking has a release request,
//							use the release request to derive the details
vars
	item,
	locations, marks 	: String;
	total,
	packed,
	onsite,
	expected :  Integer;
	release				: CM_BulkRelease;		// PAR #30882
begin
	if _br &lt;&gt; null then
		if not _br.allReleaseRequests.isEmpty then												// PAR #30882
			release := _br.allReleaseRequests.first;// is actually 1-to-1						// PAR #30882
			release.getTICategoryDetails(false, packed, onsite, total, expected, locations);	// PAR #30882
		else																					// PAR #30882
			_br.getTICategoryDetails(false, packed, onsite, total, expected, locations);
		endif;																					// PAR #30882
		item 		:= "Unspecified";	
		marks		:= '';
		return item &amp; Tab &amp; marks &amp; Tab &amp; total.String &amp; Tab &amp; packed.String &amp; Tab &amp; onsite.String &amp; Tab &amp; locations ;
	endif;
	return null;
end;
</source>
        <Parameter name="_br" type="CM_BookingRef"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getColorForBookingRef" id="518ac18e-2d21-4f98-a47d-3b2c1934e499">
        <source>getColorForBookingRef(_bookingRef:CM_BookingRef) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2009	#cnwdz2	 ccms1801
24 dec 2012	cnwdap1	PAR #30882 CCMS PNL 2244 Use bulk release if the booking has one
*/
vars
	item,
	locations, marks 	: String;
	total,
	packed,
	onsite,
	expected :  Integer;
	release				: CM_BulkRelease;			// PAR #30882
begin
	if _bookingRef &lt;&gt; null then
		if not _bookingRef.allReleaseRequests.isEmpty then										// PAR #30882
			release := _bookingRef.allReleaseRequests.first;	// actually 1-to-1				// PAR #30882
			release.getTICategoryDetails(false, packed, onsite, total, expected, locations);	// PAR #30882
		else																					// PAR #30882
			_bookingRef.getTICategoryDetails(false, packed, onsite, total, expected, locations);
		endif;																					// PAR #30882
	endif;
	return self.calculateColor(packed, onsite, total);
end;</source>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getColorForBookingRefItem" id="2ad38de7-c303-4341-9bc4-d8a7924c9ecc">
        <source>getColorForBookingRefItem(_bookingRefItem:CM_BookingRefItem) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2009	#cnwdz2	 ccms1801

*/
vars
	total,
	packed,
	onSite   :  Integer;
begin
	total 		:= _bookingRefItem.quantity;
	onSite 		:= _bookingRefItem.getNumOnsiteItemsUnpacked;
	packed 		:= _bookingRefItem.getNumPackedItems;
	
	return self.calculateColor(packed, onSite, total);
end;</source>
        <Parameter name="_bookingRefItem" type="CM_BookingRefItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTableSettings" id="0f19d931-740a-4c43-ba7d-8e1c5c51e0d9">
        <source>getTableSettings(_columns: Integer output; _header: String output);
// ---------------------------------------------------------------------------
// Created:     30 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	_columns := 6;
	_header := app.getErrorString(Pack) &amp; Tab &amp; app.getErrorString(Marks) &amp; 
			Tab &amp; app.getErrorString(Total)&amp; Tab &amp; app.getErrorString(TransType_14) &amp; 
			Tab &amp; app.getErrorString(INV_On_Site)&amp; Tab &amp; app.getErrorString(Location);
end;</source>
        <Parameter name="_columns" type="Integer" usage="output"/>
        <Parameter name="_header" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="loadTable" id="97762b17-823f-4405-907d-40777dc7e9c6">
        <updating/>
        <source>loadTable() updating;
// ---------------------------------------------------------------------------
// Created:     30 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	brItem : CM_BookingRefItem;
	allBRItems : CM_BookingRefItemDict;
begin
	self.tbl_Items.rows := 1;
	if self.myBookingRef &lt;&gt; null then
		self.addItemToTable(self.tbl_Items, myBookingRef);
		allBRItems := self.myBookingRef.allBookingRefItems;
		foreach brItem in allBRItems do
			if brItem &lt;&gt; null then
				self.addItemToTable(self.tbl_Items, brItem);
			endif;
		endforeach;	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setBookingRef" id="cd2d8116-6136-4fea-9b58-8314d0ea62a0">
        <updating/>
        <source>setBookingRef(_br : CM_BookingRef) updating;
// ---------------------------------------------------------------------------
// Created:     30 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myBookingRef := _br;
end;</source>
        <Parameter name="_br" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="102b3eae-85a6-417d-99d1-340a0982b862">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	self.btn_Menu.caption := "Back";
	self.btn_Details.caption := "Pack";
	self.tbl_Items.accessColumn(3).alignment := Table.Alignment_Center_Middle;
	self.tbl_Items.accessColumn(4).alignment := Table.Alignment_Center_Middle;
	self.tbl_Items.accessColumn(5).alignment := Table.Alignment_Center_Middle;
	self.tbl_Items.accessColumn(1).width := 230;
	self.lbl_Head.caption := app.getErrorString(Order) &amp; " : " &amp; self.myBookingRef.bookingReference;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="15c05170-457d-49f3-ade8-1308c652d467">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018465, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
