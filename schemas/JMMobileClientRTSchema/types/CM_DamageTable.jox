        <source>queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer): Boolean updating, clientExecution;
/*
----------   ----------  --------------------------------------------------
Created:	25 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	/*
	if self.row &lt;= self.fixedRows then
		return true;
	endif;
	
	if self.column = 1 then
		self.setCellText(self.row, self.column, self.myCmbPosition.text);
	
	elseif self.column = 2 then
		self.setCellText(self.row, self.column, self.myCmbCode.text);
	
	elseif self.column = 3 then
		self.setCellText(self.row, self.column, self.myCmbSeverity.text);
	endif;
	*/
	return true;
	
end;


</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromTable" id="d5dffad9-db8f-4c8e-a4e2-88932b6da2cb">
        <updating/>
        <source>setProxyFromTable(_damageInstancesDict : MobileHandHeldThin::CM_DamageInstanceByDmgePos input;
					_pxyTI : CM_TrackedItem input;
					_errors : String output) updating;
/*
----------   ----------  --------------------------------------------------
Created:	21 September 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
26/08/2009	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.	
						Changed method signature from CM_DamageInstanceByLoc to CM_DamageInstanceByDmgePos
01/07/2022  navak20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
----------   ----------  --------------------------------------------------
*/
vars
	damageInstance		: CM_DamageInstance;
	fixed,
	numberRows,
	row					: Integer;
	posStr,
	codeStr,
	remarks,
	severityStr,
	qty,
	isNew				: String;
	quantity,
	position,
	severity			: Integer;
	damageCode			: CM_DamageDefinitionCode;
	damageCodeDict		: MobileHandHeldThin::CM_DamageDefinitionByCodeDict;
	damagePos			: CM_DamagePosition;
	isNewDamage,
	isRepaired			: Boolean;
begin
	numberRows := self.rows;
	fixed := self.fixedRows;
	_damageInstancesDict.clear();
	
	damageCodeDict := app.myHandHeldGuiAgent.getDamageDefintionCodes();
	foreach row in fixed + 1 to numberRows do
		posStr		:= self.getCellText(row, 1).trimBlanks;
		codeStr		:= self.getCellText(row, 2).trimBlanks.toUpper;
		severityStr	:= self.getCellText(row, 3).trimBlanks;
		isNew := self.getCellText(row, 4).trimBlanks;
		qty	:= self.getCellText(row, 5).trimBlanks;
		if posStr = null and codeStr = null and severityStr = null then
			continue;
		endif;
		//isNew.
		if posStr = null or codeStr = null or severityStr = null then
			_errors := _errors &amp; 'Incomplete damage information specified on row ' &amp; (row - fixed).String &amp; ' of the damage entry table. The row will be skipped';
			continue;
		endif;
		damagePos := app.myHandHeldGuiAgent.getDamagePositionForDescr(posStr);

		damageCode := damageCodeDict[codeStr];
		if damageCode = null then
			_errors := _errors &amp; 'No damage code was found to match "' &amp; codeStr &amp; '"';
			continue;
		endif;
		//Duplicated??
/*		position := app.myHandHeldGuiAgent.getDamageLocForDescr(posStr);
		if position = null then
			_errors := _errors &amp; 'No valid damage position was found to match the description "' &amp; posStr &amp; '". The row will be skipped';
			continue;
		endif;
*/
		severity := severityStr.Integer;
		if severity = null then
			_errors := _errors &amp; 'Invalid damage severity specified on row ' &amp; (row - fixed).String &amp; ' of the damage entry table. The row will be skipped';
			continue;
		endif;
		
		create damageInstance transient;
		damageInstance.setProxy(_pxyTI, 
								null,
								damageCode, 
								damagePos,
								remarks,
								isNewDamage,
								quantity,
								//position,		//05.10.2022 navak20 TFS 53862
								//severity,		//05.10.2022 navak20 TFS 53862
								//isRepaired,	//05.10.2022 navak20 TFS 53862
								//null	//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593	//05.10.2022 navak20 TFS 53862
								null,	// 11.07.2022 navak20 TFS 53862
								null,	//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593
								null, null, null, null, null, null, null, null, null	// July 1, 2022 navak20 TFS 53862
								);
		_damageInstancesDict.add(damageInstance);
	endforeach;

end;


</source>
        <Parameter name="_damageInstancesDict" type="MobileHandHeldThin::CM_DamageInstanceByDmgePos" usage="input"/>
        <Parameter name="_pxyTI" type="MobileHandHeldThin::CM_TrackedItem" usage="input"/>
        <Parameter name="_errors" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setTableFromTI" id="40966e26-3cb3-47e8-a48d-da59932ef7dc">
        <updating/>
        <source>setTableFromTI(_damageInstancesDict : MobileHandHeldThin::CM_DamageInstanceByDmgePos) updating;
/*//setTableFromTI(_damageInstancesDict : MobileHandHeldThin::CM_DamageInstanceByLocDict) updating;
----------   ----------  --------------------------------------------------
Created:	21 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//							Change parameter from MobileHandHeldThin::CM_DamageInstanceByLocDict
//							to 
----------   ----------  --------------------------------------------------
*/
vars
	damageInstance		: CM_DamageInstance;
	
begin
	self.init();
	self.rows := self.fixedRows;

	foreach damageInstance in _damageInstancesDict do
		self.addDamageRow(damageInstance);
	endforeach;
	
	self.addNewRow();
end;


</source>
        <Parameter name="_damageInstancesDict" type="MobileHandHeldThin::CM_DamageInstanceByDmgePos"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="a4bcb384-3e98-4d90-9d71-49681a750ac1">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
/*
----------   ----------  --------------------------------------------------
Created:	25 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	row			: Integer;
begin
	inheritMethod(cntrl, persistCntrl);
	
	self.fixed3D	:= false;
	if self.isInPainter then
		return;
	endif;
	create self.myCmbPosition transient;
	self.form.addControl(self.myCmbPosition);
	self.myCmbPosition.automaticCellControl := true;
	
	create self.myCmbCode transient;
	self.form.addControl(self.myCmbCode);
	self.myCmbCode.automaticCellControl := true;
	
	create self.myCmbSeverity transient;
	self.form.addControl(self.myCmbSeverity);
	self.myCmbSeverity.automaticCellControl := true;
	
	
	
	self.tabKey := J_key_Tab;
	self.init();
end;





</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
