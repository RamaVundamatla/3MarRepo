    <JadeMethod name="doSave" id="d00f1757-e599-4d9e-906f-76968fda1d70">
        <updating/>
        <source>doSave(): Boolean updating;
vars
	errObj				: CM_Error;
	idx					: Integer;
	ignoreWarnings,
	rtnValue			: Boolean;
	proxyEDIAction		: CM_EDIAction;
	actionType,
	keySegment,
	actName,keyWord		: String;
	theForm				: SOP_TableMaintForm;
	actionObject		: CM_Object;
	ediFileType			: CM_EDIFileType;		
begin

	theForm := self.myForm; 
	
	actName			:= theForm.tblInput1.getValueByName(ETRow_Name).String;
	keyWord			:= theForm.tblInput1.getValueByName(ETRow_Keyword).String;
	keySegment		:= theForm.tblInput1.getValueByName(ETRow_KeyFileSegment).String;
	actionType		:= theForm.tblInput1.getValueByName(ETRow_ActionType).String;
	actionObject	:= theForm.cmbActionObject.listObject.CM_Object;
	ediFileType		:= theForm.cmbEDIFileType.listObject.CM_EDIFileType;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_EDIAction transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyEDIAction := theForm.myProxyObject.CM_EDIAction;
	proxyEDIAction.setProxy(actName, keyWord, keySegment, actionType, actionObject, ediFileType, "", "", 0, null);	// ### TFS 58831 (58833) 03July2023 NAVPW1

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateEDIAction(proxyEDIAction, theForm.myCurrentObject.CM_EDIAction, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateEDIAction(proxyEDIAction,app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
