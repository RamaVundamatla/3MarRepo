    <JadeMethod name="btn_Cancel_click" id="2041d34d-fd4e-4727-a6bc-449058cb5da8">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btn_Cancel_click(btn: Button input) updating;

vars

begin
	app.mousePointer	:=	Busy;
	modalResult := ModalResultCancel;
	self.doCloseForm();
epilog
	app.mousePointer	:=	Idle;
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btn_OK_click" id="b7791e3d-c76a-42bd-a21b-5de351bd97d9">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btn_OK_click(btn: Button input) updating;

vars

begin
	if self.doSave() then
		modalResult := ModalResultOK;
		self.unloadForm();
	endif;	
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="4edb6e08-d425-4a4a-b798-dca32ed50e2d">
        <updating/>
        <source>doSave():Boolean updating, protected;
/*
	Created on 03 April 2008
	
	by Debby Hutchison
	
	Purpose:

Date		Who		Reason

20 Oct 2011	cnwkpd1	PAR #28510 - Problems logging on in Windows Mobile 6.5 device
*/

vars

	errorString	: String;
	warnings	: Boolean;
	state		: Integer;
	userName	: String;
	oldPSW		: String;
	newPSW		: String;
	confirmPSW	: String;
begin
	userName	:=	txtName.text.trimBlanks();
	oldPSW		:=	txtOldPSW.getPasswordText().trimBlanks();			// PAR #28510
	newPSW		:=	txtNewPSW.getPasswordText().trimBlanks();
	confirmPSW	:=	txtConfirmPSW.getPasswordText().trimBlanks();
	
	if self.myMobileDataAgent.changePassword(userName, oldPSW, newPSW, confirmPSW, null) then
		return true;
	else
		errorString := app.myPassport.getAllErrorsWarningsAsString;
		app.msgBox(errorString, app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		txtNewPSW.setFocus;
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
