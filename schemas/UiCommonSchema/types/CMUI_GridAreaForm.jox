    <JadeMethod name="doBtnPopupEnqClick" id="1d318c0c-6815-4ae2-8867-a03e9410a4cf">
        <source>doBtnPopupEnqClick();
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theTI : CM_TrackedItem;
	theObject : Object;
begin
	theObject := self.frmPopupInfo.userObject;
	if theObject = null then
		return;
	endif;
	
	if theObject.isKindOf(CM_TrackedItem) then
		theTI := theObject.CM_TrackedItem;
