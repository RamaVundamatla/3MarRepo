    <JadeMethod name="isSlotNumberFree" id="f537fd37-781b-43a5-88a3-bc961c14f43a">
        <source>isSlotNumberFree(	_intendedTI: CM_TrackedItem;
					_posInStack: Integer;
					_intendedIsoType: CM_ISOType;
					_intendedIsoTypeGroup: CM_ISOTypeGroup;
					_mode: Integer;
					_doValidations: Boolean;
					_slotNo: Integer;
					_slotLC: CM_WagonController
					): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	cmifControl			: CMIF_MoveController;
	trackClearance		: CM_TrackClearance;
	clearanceError		: String;
	maxTiDimension		: Decimal [16,4];
	
begin

	if _intendedIsoType &lt;&gt; null then
		return false; // We don't automatically take iso types in a boxcar
	elseif _intendedIsoTypeGroup &lt;&gt; null then
		return false; // We don't automatically take iso types in a boxcar
	else
		maxTiDimension := _intendedTI.length;
		maxTiDimension := maxTiDimension.max(_intendedTI.getActualHeightRaw);
		maxTiDimension := maxTiDimension.max(_intendedTI.getActualWidthRaw);
		
		if maxTiDimension &gt; self.myWagonClass.getMaxBoxcarInternalDimension then
			return false;
		endif;
	endif;

	// Slot is free
	if _doValidations then
		create cmifControl transient;
		cmifControl.setMyToPrimaryLocation(self.allLocationsControllersArray[_slotNo]);
		cmifControl.setMyTrackedItem(_intendedTI);
		
		if self.myTrainOutwards &lt;&gt; null then
			trackClearance := self.myTrainOutwards.myTrackClearance;
			if trackClearance &lt;&gt; null then
				clearanceError := self.validateUsingTrackClearance(cmifControl, trackClearance, _mode, false, false);
				if clearanceError &lt;&gt; null then
					// Exceeds track clearance settings in this pos.
					return false;
				endif;
			endif;
		endif; 
	endif;

	return true;
	
epilog
	delete cmifControl;
end;</source>
        <Parameter name="_intendedTI" type="CM_TrackedItem"/>
        <Parameter name="_posInStack" type="Integer"/>
        <Parameter name="_intendedIsoType" type="CM_ISOType"/>
        <Parameter name="_intendedIsoTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_doValidations" type="Boolean"/>
        <Parameter name="_slotNo" type="Integer"/>
        <Parameter name="_slotLC" type="CM_WagonController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
