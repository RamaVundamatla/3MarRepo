    <JadeMethod name="validate" id="0ea7517e-36d9-4d7f-b168-a10338f45766">
        <source>validate(_passport :CM_Passport input)protected;
/*
Date		Who		Reason
16 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	rule	:CM_EDIRule;
begin
	if self.myEDIConfig = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'EDI Config not set');
	endif;

	if self.myEDIFileType = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'EDI FileType not set');
	endif;
	
	foreach rule in self.allEDIPartyRules do
		rule.validateCreate (_passport);
	endforeach;
	
	// don't really care about rules being deleted
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="0a3ba06d-09ce-4a25-a85d-0798a51451ed">
        <source>validateCreate(_passport: CM_Passport input);
/*
Date		Who		Reason
16 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	
begin
	self.raiseExceptionIfNotTransient (method);
	
	self.validate (_passport);
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
