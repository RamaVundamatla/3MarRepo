    <JadeMethod name="setProxyOverRideFlags" id="f42a1cd4-1fbb-4bce-9905-7b42a110876c">
        <updating/>
        <source>setProxyOverRideFlags(pRealEntry : CM_RTQueueEntry) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		This toggle on /off the flags on the proxy entry ready for update
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	flags : Integer;
begin
	self.raiseExceptionIfNotTransient(method);

	// toggle on and off
	if pRealEntry.overRideFlags = null then
		flags := null;
		flags := flags.bitOr(MP_RT_AUTOPLAN );
		flags := flags.bitOr(MP_RT_IGNORE_WARNINGS );
	else
		flags := null;
	endif;		
	self.overRideFlags := flags;
end;</source>
        <Parameter name="pRealEntry" type="CM_RTQueueEntry"/>
    </JadeMethod>
