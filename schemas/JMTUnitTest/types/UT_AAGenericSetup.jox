<Class name="UT_AAGenericSetup" id="86200537-5e78-4f0b-91d6-c8b6858975f2">
    <superclass name="UT_DSL"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="tCreateTatVoyage" id="5e1f20ef-b42f-4239-8233-583b16649f8d">
        <source>tCreateTatVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2020	jlgndl1	Initial creation - This voyage is used in multiple Tests DO NOT change it

*/

constants

	VesselCode1 : String = "UT_TATVESS";
	VoyageCode1 : String = "UT_TATVOY";
	LloydsNumber : String = "16661990";
	TiId1 : String = "GENL2022334"; 
	TiId2 : String = "GENL2022335";  
	TiId3 : String = "GENL2022336"; 
	TiId4 : String = "GENL2022337";  
	TiId5 : String = "GENL2022338"; 
	
vars

	term : CM_Terminal;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	shippingLineCode : String;
	aPort : CM_Port;
	strs : StringArray;
	theSlot : CM_LocationsController;
	idx : Integer;
	cargo : CM_TrackedItem;
	
begin

	term := self.getTerminal;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	shippingLineCode := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	
	self.deleteContainer( TiId1 );
	self.deleteContainer( TiId2 );
	self.deleteContainer( TiId3 );
	self.deleteContainer( TiId4 );
	self.deleteContainer( TiId5 );
	
	self.deleteVoyage( VoyageCode1 );
	self.deleteVessel( VesselCode1 );
	
	
	vessel := self.addVesselCellularWithCode( VesselCode1, "Unit Test - Don't Touch", operator );
	beginTransaction;
	vessel.setPropertyValue("lloydsNumber",LloydsNumber);
	commitTransaction;
	
	voyage := self.addVoyageWithContainerStructur( VoyageCode1, VesselCode1, operator.code, shippingLineCode );
	
	beginTransaction;
	voyage.sendMsgWithParams("updateInwardCode","UT_TATVOYIN", app.myPassport);
	commitTransaction;
	
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	create strs transient;
	strs.add("090688");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(TiId1, "UT20", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, voyage);
	self.assertTrueMsg((cargo.getImExStatus() =TI_IMEX_STATUS_IMPORT), "30ft ImEx on Imports is wrong" );
	strs.clear;
	strs.add("090488");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(TiId2, "UT20", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, voyage);
	strs.clear;
	strs.add("090288");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(TiId3, "UT20", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, voyage);
	strs.clear;
	strs.add("090188");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(TiId4, "UT20", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, voyage);
	strs.clear;
	strs.add("090388");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(TiId5, "UT20", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, aPort, voyage);
	
epilog

	delete strs;

end;</source>
    </JadeMethod>
</Class>
