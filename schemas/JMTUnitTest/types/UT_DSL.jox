    <JadeMethod name="updateBoom" id="097ba2b6-28c3-407e-b25f-3a1461910518">
        <source>updateBoom(_boom : CM_Boom; _description : String);

/*

Purpose:		Update the boom

Date			Who		Reason
21/03/2014		cnwmh5	Initial creation

*/

vars

	pxyBoom						: CM_Boom;
	
	loadState					: Boolean;

begin

	app.cmsBeginLoad(loadState);
	pxyBoom := _boom.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	pxyBoom.setProxy(_boom.code, _description, _boom.ipAddress, _boom.portNumber, _boom.myTerminal,
						pxyBoom.getDisplayValueForChannel,	//_channel : String;	//14 Feb 2019	NDL	TFS 43403
						pxyBoom.userCode,	//_userCode : String;	//14 Feb 2019	NDL	TFS 43403
						pxyBoom.password	//_password : String	//14 Feb 2019
						);

	app.myTrxUA.trxUpdateBoom(pxyBoom, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	app.cmsEndLoad(loadState);
	
	delete pxyBoom;

end;</source>
        <Parameter name="_boom" type="CM_Boom"/>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateCamGroup" id="7efd1f07-f1b7-44b9-9e9b-6512279d796c">
        <source>updateCamGroup(_camGroup : CM_CamGroup);
/*

Purpose:	Update Cam Group		

Date		Who		Reason
24/04/2014	cnwma1	Initial creation

*/

vars

	pxyCamGroup 	: CM_CamGroup;
	camDescription		: String;
begin
	
	beginLoad;
	pxyCamGroup := _camGroup.pxyCreateUpdateProxy();
	endLoad;
	
	camDescription := _camGroup.description.asStringJMT();
	
	if self.opts.includesKey("CamDesc") then
		camDescription := self.opts.str("CamDesc");
	endif;
	
	
	pxyCamGroup.setPropertyValue("description",camDescription);
								  
	app.myTrxUA.trxUpdateCamGroup(pxyCamGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	
epilog
	delete pxyCamGroup;
end;</source>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
    </JadeMethod>
    <JadeMethod name="updateCamProtocol" id="7256f80f-1539-48b2-a175-aa249a81bf4f">
        <source>updateCamProtocol(_camProtocol : Any);
/*
Purpose:		Update Cam Protocol
/* Changes

Date		Name	TFS#		Description
============================================================================
27/05/2015	cnwmh5				Initial creation
26/05/2016	cnwrs1				Fix up LogExcludedTransactions setting
12/07/2017	jlgrs1	TFS 4465 	SNO standard Codedo/Coarri
12/03/2019	jlgka1	TFS 41641	Add relaxed id checking.
24/04/2019 jlgka1	TFS 43785	Add useCodecoForNonStrucVoy field.
============================================================================*/
vars
	camProtocol		: CM_CamProtocol;
	pxyCamProtocol	: CM_CamProtocol;	
	description		: String;
	delayMinutes 	: Integer;	//08 Sep 2015	NDL	)ar 36876
begin

	if _camProtocol.isKindOf(String) then
		camProtocol := self.getTerminal().camProtocols[_camProtocol.String];
	elseif _camProtocol.isKindOf(CM_CamProtocol) then
		camProtocol := _camProtocol.CM_CamProtocol;
	endif;
	
	if camProtocol = null then
		return;
	endif;

	description := camProtocol.description;
	if self.opts.includesKey("Description") then
		description := self.opts.str("Description");
	endif;
	
	delayMinutes := 0;
	if self.opts.includesKey("DelayMins") then
		delayMinutes := self.opts.int("DelayMins");
	endif;
	
	beginLoad;
	pxyCamProtocol := camProtocol.pxyCreateUpdateProxy();
	endLoad;
	pxyCamProtocol.setProxy(	camProtocol.code,
								description,
								camProtocol.allCoarriExportPorts,
								camProtocol.camGroup,
								camProtocol.camISOPortDesc,
								camProtocol.myEmailEntity,
								camProtocol.emailCopy,
								camProtocol.allCopyEmailEntities,
								camProtocol.emailFileImbedded,
								camProtocol.emailMessage,
								camProtocol.emailSubject,
								camProtocol.firstRunDateTime,
								camProtocol.lastRunDateTime,
								camProtocol.specialFileName,
								camProtocol.filePrefix,
								camProtocol.fileSuffix,
								camProtocol.operatorXlationCode,
								camProtocol.packOperators,
								camProtocol.packExportConsignees,
								camProtocol.packConsignor,
								camProtocol.protocolDesc,
								camProtocol.registeredTransactions,
								camProtocol.sendMtFiles,
								camProtocol.sendType,
								camProtocol.useVoyageOp,
								camProtocol.scheduleTimes,
								camProtocol.x12UseClientRefAsBooking,
								false, 
								camProtocol.gateInForNullVoyageChange,
								camProtocol.gateInForNullOperatorChange,
								false,
								false,
								camProtocol.special_MSCForNZPOE,
								camProtocol.daysToLookBack,
								camProtocol.tempLeadingZerosNoDecimal,
								camProtocol.supressSealNumbers,
								camProtocol.singleContainerPerBGM,
								camProtocol.singleTransactionPerFile,
								camProtocol.reprocessOnIdChange,
								camProtocol.sendCancellationMessage,
								camProtocol.sendUpdateMessage,
								camProtocol.debug,
								camProtocol.useContainerOperator_NAD_CF,
								camProtocol.sendCarrier_RFF_CN,
								camProtocol.useCarrierForBooking,
								camProtocol.isIncludeChild,
								camProtocol.isEmailEnabled,
								camProtocol.isSingleTransPerFile,
								camProtocol.isFileTransferEnabled,
								camProtocol.anyEditTriggerField,
								camProtocol.transferFileRollOver,
								camProtocol.transferFileSeqLength,
								camProtocol.transferFileStartSeq,
								camProtocol.lastSequenceNumberUsed,	 
								camProtocol.transferFileFormat,
								camProtocol.destinationFilePath,
								camProtocol.jrwReportName,
								camProtocol.allEditTriggerFields,
								camProtocol.allTrainEventTypes,	
								camProtocol.myQFCamTransactionTemplate,
								camProtocol.noCrLfInMessage,
								camProtocol.status,
								camProtocol.terminal,
								camProtocol.terminalActivity,
								camProtocol.depotActivity,
								camProtocol.useSubTerminals,
								camProtocol.packGateInFull,
								camProtocol.packGateOutMT,
								camProtocol.unpackGateInMT,	
								camProtocol.unpackGateOutFull,
								camProtocol.prcNullVoyageTransaction,
								camProtocol.useTiOperator,
								camProtocol.allPackAreas,
								camProtocol.myConsignee,
								camProtocol.myFTPEntity,
								camProtocol.decimalCharacter,		
								camProtocol.elementSeparator,		
								camProtocol.escapeCharacter,			
								camProtocol.segmentTerminator,		
								camProtocol.subElementSeparator,	
								camProtocol.allRegisteredCargoTypes,
								camProtocol.mySelector,
								delayMinutes,
								false,
								false, //27Jan2023 navsp1 TFS 56282
								false,
								camProtocol.useRelaxedIdChecking,			//jlgka1 TFS 41641
								camProtocol.useCodecoForNonStrucVoyage,		//jlgka1 TFS 43785
								camProtocol.dgsDetailsInGroup14				//JIRA-20814
								);
	pxyCamProtocol.setIncludeChassis(camProtocol.getIncludeChassis());
	pxyCamProtocol.setLogIncludedTransactions(camProtocol.getLogIncludedTransactions());
	pxyCamProtocol.setLogExcludedTransactions(camProtocol.getLogExcludedTransactions());
	pxyCamProtocol.setPackUnpackStatusChange(camProtocol.getPackUnpackStatusChange());
	pxyCamProtocol.setIncludeRestowShifter(camProtocol.getIncludeRestowShifter());
	
	app.myTrxUA.trxUpdateCamProtocol(pxyCamProtocol, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete pxyCamProtocol;

end;</source>
        <Parameter name="_camProtocol" type="Any"/>
    </JadeMethod>
    <JadeMethod name="updateCargoCheckItem" id="d4e170a4-b997-4eb6-ac84-8bfeea44230b">
        <source>updateCargoCheckItem(_cargoCheckItem : CM_CargoCheckItem);

/*

Purpose:		

Date			Who		Reason
18/06/2015		cnwmh5	Initial creation

*/

vars

	pxyCargoCheckItem 				: CM_CargoCheckItem;
	
	cmifArray						: CMIF_Array;

begin

	beginLoad;
	pxyCargoCheckItem := _cargoCheckItem.pxyCreateUpdateProxy();
	endLoad;
	pxyCargoCheckItem.setPropertyValue("myCargoCheck", _cargoCheckItem.myCargoCheck);
	
	create cmifArray transient;
	_cargoCheckItem.allCriteria.copy(cmifArray);
	
	if self.opts.includesKey("Required") then
		pxyCargoCheckItem.setPropertyValue("required", self.opts.bool("Required"));
	endif;
		
	app.myTrxUA.trxUpdateCargoCheckItem(pxyCargoCheckItem, cmifArray, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

	delete pxyCargoCheckItem;
	delete cmifArray;

end;</source>
        <Parameter name="_cargoCheckItem" type="CM_CargoCheckItem"/>
    </JadeMethod>
    <JadeMethod name="updateCargoPhoto" id="d1232dc6-a0ef-49f2-bbae-cd43a8745941">
        <source>updateCargoPhoto(_photo:CM_Photo; _desc:String);
//30 November 2009	cnwdz2	
// Add a photo to a tracked item
vars
	proxyPhoto : CM_Photo;
begin
	proxyPhoto := app.createUpdateProxy(_photo).CM_Photo;
	proxyPhoto.setDescription(_desc);
	app.myTrxUA.trxUpdateCargoPhoto(proxyPhoto, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete proxyPhoto;
end;</source>
        <Parameter name="_photo" type="CM_Photo"/>
        <Parameter name="_desc" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateCargoType" id="df2e62b4-7d8d-48f7-bb61-067a8440a41c">
        <source>updateCargoType(_cargoType : CM_CargoType);

/*

Purpose:		Update Cargo Type

Date			Who		Reason
21/05/2015		cnwmh5	Initial creation
07/03/2019		jlgdap1	TFS 41570 PNL No PIN for Cargo Type
18 May 2022     navnk20 ChangeRequest 53504: EUP - Cargo Uniqueness - PortSchema
10/08/2022    	navds20	ChangeRequest 54219: EUP - Cargo Group to be mandatory
11 July 2023 navmv20 CR 58244 Task 58245: UI - Multiple Operators
*/

vars

	pxyCargoType			: CM_CargoType;
	pxyDraw					: CM_DrawingAttribute;
	selectedDamagePos		: CM_ObjectSet;
	allDamageCodes 			: CM_ObjectSet;
	ignoreWarnings 			: Boolean;
	allowAutoWeightCalc 	: Boolean;
	useTareCargoWeight 		: Boolean;
	allowDuplicates 		: Boolean;
	isCargoGroupRequired    : Boolean; //10/08/2022 navds20 TFS 54219
	allowMultiOperators     : Boolean; //11/07/2023 navmv20 CR 58244 Task 58245
	autoTareCargoWeightCalc : Boolean;	//navra1 - TFS 63624 - 15th Apr 2024
	
begin

	self.assertNotNull(_cargoType);
	
	create selectedDamagePos transient;
	_cargoType.allDamagePositions.copy(selectedDamagePos);
	
	if self.opts.includesKey("DamagePosition") then
		self.opts.obj("DamagePosition").CM_ObjectSet.copy(selectedDamagePos);	
	endif;
		
	
	if self.opts.includesKey("RemoveDamagePos")then
		selectedDamagePos.remove(self.opts.obj("RemoveDamagePos"));
	endif;
		
	create allDamageCodes transient;				// 07/04/2016	cnwmk3
	if self.opts.includesKey("DamageCodes") then
		self.opts.obj("DamageCodes").CM_ObjectSet.copy(allDamageCodes);	
	else
		_cargoType.allDamageDefinitionCodes.copy(allDamageCodes);
	endif;
	
	if self.opts.includesKey("RemoveDamageCode")then
		allDamageCodes.remove(self.opts.obj("RemoveDamageCode"));
	endif;
	
	if self.opts.includesKey("AllowAutoWeightCalc") then
		allowAutoWeightCalc := self.opts.bool("AllowAutoWeightCalc");
	else
		allowAutoWeightCalc := _cargoType.allowAutoWeightCalc;
	endif;
	
	if self.opts.includesKey("UseTareCargoWeight") then
		useTareCargoWeight := self.opts.bool("UseTareCargoWeight");
	else
		useTareCargoWeight := _cargoType.useTareCargoWeight;
	endif;
	
	//navra1 - TFS 63624 - 15th Apr 2024 - start
	if self.opts.includesKey("AutoTareCargoWeightCalc") then
		autoTareCargoWeightCalc := self.opts.bool("AutoTareCargoWeightCalc");
	else
		autoTareCargoWeightCalc := _cargoType.autoTareCargoWeightCalc;
	endif;
	//navra1 - TFS 63624 - 15th Apr 2024 - end
	
	if self.opts.includesKey("AllowDuplicates") then
		allowDuplicates := self.opts.bool("AllowDuplicates");
	else
		allowDuplicates := _cargoType.allowDuplicates;
	endif;
	
	//11/07/2023 navmv20 CR 58244 Task 58245 - START
	if self.opts.includesKey("allowMultiOperators") then
		allowMultiOperators := self.opts.bool("allowMultiOperators");
	else
		allowMultiOperators := _cargoType.allowMultiOperators;
	endif;
	//11/07/2023 navmv20 CR 58244 Task 58245 - END

	beginLoad;
		pxyCargoType := _cargoType.pxyCreateUpdateProxy();
	endLoad;
	
	pxyCargoType.setProxy(_cargoType.id,
		_cargoType.abbreviation, 
		_cargoType.description,
		_cargoType.productType,
		_cargoType.isWeighable,
		_cargoType.isCheckMaxLift,
		_cargoType.includeInStorageProcess,
		_cargoType.showDamageCodes,
		_cargoType.isDynamicallyCreated,
		_cargoType.isShownInGateInOut,
		allowDuplicates,
		_cargoType.colour, 
		_cargoType.myDefaultHandlingType,
		_cargoType.myDefHandlingSubType,	//31 Mar 2017	NDL	TFS 3414
		_cargoType.createBOL,
		_cargoType.isSubCargoTypeRequired,
		_cargoType.isCommodityRequired,
		_cargoType.isNotAvailableForEntry,
		_cargoType.defaultCommodityCode,
		_cargoType.allCommodities,
		allDamageCodes,
		selectedDamagePos,
		_cargoType.allSealTypes,
		useTareCargoWeight,
		_cargoType.canWeightBeCertified,
		_cargoType.myTIBehaviourType,
		_cargoType.trackByMeasureType,
		_cargoType.myWeightMeasurementType,
		_cargoType.myVolumeMeasurementType,
		_cargoType.chgToStorageOnUnpack,
		_cargoType.allowAutoVolumeCalc,				//10 Jun 2016	NDL	TFS 2141
		allowAutoWeightCalc,						//18 Jan 2018	NDL	TFS 36697
		_cargoType.canGeneratePIN,					// TFS 41570
		_cargoType.requiresWeighing,				//_requiresWeighing : Boolean		//05 Jul 2019	NDL	TFS 44965
		_cargoType.saveLocationActivity,			//_saveLocationActivity : Boolean	// 13 Apr 2021	NDL	TFS 50906
		_cargoType.useCargoGroupForUniqueness,		// _cargoUniqueness : Boolean 		//18 May 2022 navnk20 TFS 53504
		_cargoType.useCargoSubtypeForUniqueness,
		isCargoGroupRequired,  						//10/08/2022   navds20	54219
		allowMultiOperators,						//11/07/2023 navmv20 CR 58244 Task 58245
		autoTareCargoWeightCalc,					//navra1 - TFS 63624 - 15th Apr 2024
		_cargoType.externalReference
		);
	
	app.myTrxUA.trxUpdateCargoType(pxyCargoType, pxyDraw, null, app.myPassport);
	
	if self.opts.includesKey("IgnoreWarnings") then
		ignoreWarnings :=	self.opts.bool("IgnoreWarnings");		
	endif;
	
	if not ignoreWarnings then
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

	delete pxyDraw;
	delete pxyCargoType;
	delete allDamageCodes;
	delete selectedDamagePos;

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="updateCarrier" id="7946bcf4-0ba0-4495-9145-53cbdd2e5d49">
