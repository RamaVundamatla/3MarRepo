	tbl.fontItalic := false;
	tbl.fontStrikethru := false;
	tbl.fontUnderline := false;

	tbl := self.tblStats;
	
	tbl.fontName := "Arial";
	tbl.fontSize := 8;
	tbl.fontBold := false;
	tbl.fontItalic := false;
	tbl.fontStrikethru := false;
	tbl.fontUnderline := false;
end;</source>
