        <source>btnReconciled_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwml2	Initial creation

*/

vars
	booking : CM_BookingRef;
begin
	if not self.tblData.allSelectedObjects.isEmpty then
		if btnShowBookItms.value then
			booking := self.tblData.allSelectedObjects.first.CM_BookingRefItem.myBookingReference;
			self.doOpenReconForm(booking);
		else
			self.doOpenReconForm(self.tblData.allSelectedObjects.first.CM_BookingRef);
		endif;
	endif;
end;</source>
