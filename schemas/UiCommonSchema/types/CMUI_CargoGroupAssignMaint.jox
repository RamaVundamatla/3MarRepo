    <JadeMethod name="doDelete" id="db0bfbf3-f575-4af2-a8db-601d84f4a0c2">
        <updating/>
        <source>doDelete(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	cmObject : CM_Object;
	invalid : Boolean;
	edition : Integer;
	objectArray : CM_ObjectArrayActual;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815

begin

	cmObject := self.myCurrentObject.CM_CargoGroupAssignment;
	
	if cmObject = null then
		return false;
	endif;
	on Exception do app.handleDeletedObject( exception, cmObject, invalid );
	edition := cmObject.edition;
	if invalid then
		return false;
	endif;

	if self.tblData.allSelectedObjects.size &gt; 1 then
		create objectArray transient;
		self.tblData.allSelectedObjects.copy(objectArray);
		
		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteCMObjects( objectArray, app.myPassport );
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(Cargo_group_assignment), app.myPassport, ErrWarnMode_Delete);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return false;
			
		endwhile;
	
	else
		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteCMObject( cmObject, app.myPassport );
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(Cargo_group_assignment), app.myPassport, ErrWarnMode_Delete);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return false;
			
		endwhile;
		
	endif;

	app.setMyCurrentCargoType(null);		
	self.showThumbnailData(null);
	return true;
	
epilog

	delete objectArray;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuColumnOrganiserClick" id="549bca9d-71ab-4100-a6ea-40c62635e645">
        <source>doMnuColumnOrganiserClick(menuItem: MenuItem);
