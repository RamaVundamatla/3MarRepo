<CollClass name="CM_DeckVoyageByOrdDict" id="c4fb3cc9-ac0e-4297-8e99-6b5a41ae0b4b">
    <loadFactor>66</loadFactor>
    <memberType name="CM_DeckVoyage"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyageStructures"/>
    <MemberKey>
        <property name="CM_Deck::ordinal"/>
    </MemberKey>
    <JadeMethod name="moveElement" id="b679893f-01d1-45b3-ac30-3569896dbe42">
        <lockReceiver/>
        <updating/>
        <source>moveElement(ordinal1, ordinal2 : Integer; _deck : CM_DeckVoyage input; _isMoveUp : Boolean) lockReceiver, updating;
/*
Date		    Who			Reason
30 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	
	moveDeck1, moveDeck2			: CM_DeckVoyage;

begin
	
	moveDeck1 := self.getAtKey(ordinal1);
	moveDeck2 := self.getAtKey(ordinal2);
	self.remove(moveDeck1);
	self.remove(moveDeck2);
	//moveDeck1.setOrdinal(1000);
	//moveDeck2.setOrdinal(1001);
	moveDeck1.setOrdinal(ordinal2);
	moveDeck2.setOrdinal(ordinal1);
	self.add(moveDeck1);
	self.add(moveDeck2);
	
	
epilog

end;</source>
        <Parameter name="ordinal1" type="Integer"/>
        <Parameter name="ordinal2" type="Integer"/>
        <Parameter name="_deck" type="CM_DeckVoyage" usage="input"/>
        <Parameter name="_isMoveUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rearrangeOrdinals" id="4fe3891e-3b07-4b45-89e3-9e148dde2904">
        <source>rearrangeOrdinals(_pxyDecks : CM_DeckVoyageByOrdDict input);
/*
Date		    Who			Reason
30 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	pxyDeck,deck : CM_DeckVoyage;
	idx, size : Integer;
begin
	size := self.size();
	idx := 1;
	foreach deck in self do
		if idx &gt; size then
			break;
		endif;
		deck.setOrdinal(deck.ordinal + 10000);
		idx := idx + 1;		
	endforeach;
	foreach pxyDeck in _pxyDecks do
		foreach deck in self where deck.code = pxyDeck.code do
			deck.setOrdinal(pxyDeck.ordinal);
			break;
		endforeach;
	endforeach;
epilog
	//foreach pxyDeck in _pxyDecks do
	//	delete pxyDeck;
	//endforeach;	
end;</source>
        <Parameter name="_pxyDecks" type="CM_DeckVoyageByOrdDict" usage="input"/>
    </JadeMethod>
</CollClass>
