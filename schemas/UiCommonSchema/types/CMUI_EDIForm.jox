/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 10 January 2019
TFS#		: 42014
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	self.reloadDate	:= null;
	self.isReload	:= false;
end;</source>
    </JadeMethod>
    <JadeMethod name="saveEDITIChanges" id="5cb6a521-4e20-4941-a90f-119ec866fa5b">
        <source>saveEDITIChanges(_passport: CM_Passport input);
//----------------------------------------------------------------
//	Created:	08 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars	
	ediTIs : CM_EDITIById;
	index : Integer;
	table : CM_DataTable;
	ediUIAgent  : CMUI_EDIAgent;
begin
	create ediTIs transient;
	create ediUIAgent transient;
	index := 0; 
	while true do //Handle Cloned tables Messina MES 1011 cnwgb1 28.9.09 PAR 20320
		table := self.tblEDITI.getControl(index);
		if table = null or not table.visible then
			break; //cnwrs1 sept 2009 was return;
		endif;
		//epr TFS 2606 16/9/16 - refactored code block into new method
		ediUIAgent.saveEDITIChangesToPxy(table,ediTIs,_passport);
		index := index+1;
	endwhile;
	
	app.myTrxUA.trxUpdateEDITIs(ediTIs, _passport);
		
epilog

	ediTIs.purge();//clear proxies
	delete ediTIs;
	delete ediUIAgent;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
