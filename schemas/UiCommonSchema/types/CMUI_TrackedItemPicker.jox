    <JadeMethod name="setDisabledItems" id="4dfcb2af-0e22-4185-ab55-a6d6ba3991bb">
        <updating/>
        <source>setDisabledItems(_disabledRows : IntegerArray) updating;
// --------------------------------------------------------------------------------
// Created:		12 August 2010 by cnwjo3
//
// Purpose:		Disable rows and make them look disabled
//
vars

	theRow,
	idx		: Integer;
	e : Boolean;
	rows : Integer;
begin
	rows := self.tblList.rows;
	
	foreach idx in _disabledRows do
		tblList.accessRow(idx).enabled := false;
		tblList.accessRow(idx).backColor := #E9E9E9;
		tblList.accessRow(idx).foreColor := Gray;
	endforeach;
	
	//need to reselect top row since it may now be disabled
	self.defaultSelectRow();
end;</source>
        <Parameter name="_disabledRows" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="setHeadings" id="98dde817-63b4-4e92-988f-c640babb6602">
        <source>setHeadings(pCols : Integer; pHeading : String);

vars

begin

	tblList.columns := pCols;
	tblList.rows	:= 1;
	tblList.accessCell(1,1).text := pHeading;
end;</source>
        <Parameter name="pCols" type="Integer"/>
        <Parameter name="pHeading" type="String"/>
    </JadeMethod>
