    <JadeMethod name="setupThumbnailDetails" id="d6258705-3fc7-4b76-a483-da36b295c983">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.myForm.useProxyObject := true;
	self.myForm.setTblDataEntRows(ETDef_DutyDocExchangeRate);
	
	self.myForm.shtTblInput1.caption := 'Details';
	self.myForm.initTblInput(self.myForm.tblInput1, ETDef_DutyDocExchangeRate);	
	self.myForm.shtTblInput1.visible := true;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="d61c00a9-01c7-4d30-bd0f-e658dfe26864">
        <updating/>
        <source>showThumbnail(_exchangeRate : CM_DutyDocExchangeRate) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.myForm.tblInput1.clearValues;

	self.myForm.tblInput1.setValueByName(ETRow_Code, _exchangeRate.code);
	self.myForm.tblInput1.setValueByName(ETRow_Rate, _exchangeRate.rate);
	self.myForm.tblInput1.setValueByName(ETRow_DateChanged, _exchangeRate.dateChanged.asStringJMT());

epilog

end;</source>
        <Parameter name="_exchangeRate" type="CM_DutyDocExchangeRate"/>
    </JadeMethod>
</Class>
