<Class name="CM_EDIReleaseRequestTI">
    <JadeMethod name="getColoursForEDITrackedItem" id="8032b6cb-adef-4e55-85f5-94ae0c5e0e01">
        <source>getColoursForEDITrackedItem(_ediData: CM_EDIData; _localPort: String; _foreColor: Integer output; _backColor: Integer output);
/*
Date		Who		Reason
20 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	status	:Integer;
begin
	if _ediData &lt;&gt; null and _ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED then
		_foreColor	:= Black; 								
		_backColor	:=  CM_BaseForm.ColorGreenLight;
		
		status		:= self.getStatus;											

		if status = CM_EDITrackedItem.EDI_STATUS_DBLOADED then
			// grey/green
			_foreColor	:= CM_BaseForm.ColorGreyDark;
						
		elseif status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
			// black/light yellow
			_backColor 	:= CM_BaseForm.ColourYellowLight;
			
		elseif status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING then
			// dark grey/light yellow
			_backColor 	:= CM_BaseForm.ColourYellowLight;
			_foreColor	:= CM_BaseForm.ColorGreyDark;
		endif;
	else
		inheritMethod (_ediData, _localPort, _foreColor, _backColor);
	endif;
epilog

end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_localPort" type="String"/>
        <Parameter name="_foreColor" type="Integer" usage="output"/>
        <Parameter name="_backColor" type="Integer" usage="output"/>
    </JadeMethod>
</Class>
