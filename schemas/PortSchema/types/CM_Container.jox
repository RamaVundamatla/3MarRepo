    <JadeMethod name="isOverStowable" id="d0300db0-5e2e-4ccb-8395-dbd2cfa8f544">
        <source>isOverStowable(byTrackedItem: CM_TrackedItem; _byIsoType : CM_ISOType; _byIsoTypeGroup : CM_ISOTypeGroup): Boolean;
/*
 ------------------------------------------------------------------------
Created:			09 October 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    20MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
20 Aug 2009 NDL Added parameter for isotype CCMS 1094
10 May 2010	NDL Par 24064 Added parameter for isoTypeGroup
*/
vars
	cont : CM_Container;
begin

	if _byIsoType &lt;&gt; null then
		if self.getLengthInUnitsForWagon &lt;&gt; _byIsoType.getLengthInUnitsForWagon then
			return false;
		endif;
		return true;
	endif;
	
	//10 May 2010	NDL Par 24064
	if _byIsoTypeGroup &lt;&gt; null then
		if self.getLengthInUnitsForWagon &lt;&gt; _byIsoTypeGroup.getLengthInUnitsForWagon then
			return false;
		endif;
		return true;
	endif;
	
	if byTrackedItem = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(MethodWithNullParam, method.name, "TrackedItem Reference", null, null);
		return false;
	endif;
	if not byTrackedItem.isKindOf(CM_Container) then
		return false;
	endif;
	
	cont := byTrackedItem.CM_Container;
	
	 // PAR 16415 CCMS 1029
	if self.is45 &lt;&gt; cont.is45 then
		return false;
	endif;
	if self.is40 &lt;&gt; cont.is40 then
		return false;
	endif;
	 // PAR 16415 CCMS 1029
	if self.is30 &lt;&gt; cont.is30 then
		return false;
	endif;
	if self.is53 &lt;&gt; cont.is53 then
		return false;
	endif;
//	if not self.is40 and cont.is40 then
//		return false;
//	endif;
	return true;
end;</source>
        <Parameter name="byTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_byIsoType" type="CM_ISOType"/>
        <Parameter name="_byIsoTypeGroup" type="CM_ISOTypeGroup"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOverStowableOnWagon" id="c1860c16-8856-4c60-915e-b3a66e26b77d">
        <source>isOverStowableOnWagon(_wagon: CM_Wagon; _byTrackedItem: CM_TrackedItem; _byIsoType: CM_ISOType; _byIsoTypeGroup: CM_ISOTypeGroup): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars
	obj : CM_Object;
begin

	if _wagon &lt;&gt; null then
	
		if _byIsoType &lt;&gt; null then
			obj := _byIsoType;
		elseif _byIsoTypeGroup &lt;&gt; null then
			obj := _byIsoTypeGroup;
		elseif _byTrackedItem &lt;&gt; null then
			obj := _byTrackedItem;
		else
			return false;
		endif;
	
		if _wagon.getActualLengthFor(self) &gt; _wagon.getActualLengthFor(obj) then
			return false;
		endif;
			
		return true;
	endif;
			
end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_byTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_byIsoType" type="CM_ISOType"/>
        <Parameter name="_byIsoTypeGroup" type="CM_ISOTypeGroup"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOverStowableYA" id="acfea758-1ec5-4ac3-9300-9e78801e3d3c">
        <source>isOverStowableYA(byTrackedItem: CMIF_YAAutoPlan): Boolean;
/*
 ------------------------------------------------------------------------
Created:			09 October 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	cont 	: CM_Container;
	ti		: CM_TrackedItem;
	
begin
	if byTrackedItem = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(MethodWithNullParam, method.name, "TrackedItem Reference", null, null);
		return false;
	endif;
	if not byTrackedItem.isKindOf(CMIF_YAAutoPlan) then
		return false;
	endif;
	
	ti := byTrackedItem.getMyTrackedItem();
	if  ti = null then
		return false;
	endif;
	
	if not ti.isContainer() then
		return false;
	endif;

	if self.is45 &lt;&gt; byTrackedItem.is45() then // PAR 16415 CCMS 1029
		return false;
	endif;
	if self.is40 &lt;&gt; byTrackedItem.is40() then
		return false;
	endif;
	if self.is30 &lt;&gt; byTrackedItem.is30() then // PAR 16415 CCMS 1029
		return false;
	endif;
	if self.is53 &lt;&gt; byTrackedItem.is53() then // PAR 16415 CCMS 1029
		return false;
	endif;

	return true;
end;</source>
        <Parameter name="byTrackedItem" type="CMIF_YAAutoPlan"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOverStowed" id="3eff0dcb-7f3d-479f-9583-a812b0b70bb4">
        <source>isOverStowed(mode: Integer): Boolean;
/*
 ------------------------------------------------------------------------
Created:			14 September 2001 by cnwdwq1
Purpose:			Returns True if we are overstowed by another object.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

	overstowController : CMIF_OverstowController;
begin
	//epr TFS 37584 4/5/18
	create overstowController transient;
	overstowController.setParams(null,self,false,null,null);
	overstowController.setMode(mode);
	return overstowController.getAllOverstows;
epilog
	delete overstowController;
end;</source>
        <Parameter name="mode" type="Integer"/>
        <ReturnType type="Boolean"/>
