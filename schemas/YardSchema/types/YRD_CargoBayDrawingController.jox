	elseif self.scaleFactor = 3 then
		yOffsetFnt := 6;
		theFrame.drawFontSize := 14;
	elseif self.scaleFactor = 4 then
		yOffsetFnt := 8;
		theFrame.drawFontSize := 20;
	elseif self.scaleFactor = 6 then
		yOffsetFnt := 8;
		theFrame.drawFontSize := 30;
	elseif self.scaleFactor = 9 then
		yOffsetFnt := 20;
		theFrame.drawFontSize := 40;
	endif;

	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawFillColor := White;
	if self.scaleFactor &gt; 2 then
		offset := (self.scaleFactor + 2).Integer;
	else
		offset := self.scaleFactor.Integer;
	endif;
	theFrame.drawFilledRectangle(_theX1 + offset, _theY1 + offset, _theX2 - offset, _theY2 - offset,  Black);

	aReal :=  _theX1 + ((_theX2 - _theX1) / 2);
	offset := aReal.Integer;
	theFrame.drawTextAt(theLetter, offset, _theY1 + yOffsetFnt, Black); 
epilog
	theFrame.drawWidth := 1;
