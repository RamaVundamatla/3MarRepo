    <JadeMethod name="makeMessage_W2" id="63dfdab9-f6f0-492f-8492-410fa7c19cb1">
        <source>makeMessage_W2( _protocol :CM_CamProtocol ;_containerPrefix, _containerNumeric,_containerCheckDigit,_commodity, _equipDescCode,_equipStatusDesc , _equipInitial, _equipNumber : String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2014	cnwrd1	Initial creation

Equipment Identification (W2)

Equipment Initial					W201	(N701)
Equipment Number					W202	(N702)
Commodity Code						W203	 Commodity2
Equipment Description Code			W204	CN
Equipment Status Code				W205	L
Net Tons							W206
Intermodal Service Code				W207
Car Service Order Code				W208
Date								W209
Type of Locomotive Maintenance Code	W210
Equipment Initial 					W211
Equipment Number 					W212
Equipment Number Check Digit		W213	(N718)
Position 							W214
Car type Code						W215
Yes/No Condition or Response Code	W216
 
Notes
Harmonised codes will be used if available, otherwise normal translated Commodity description will be used.
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time

constants
	MESSAGE	= "W2";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	//colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
			plus &amp; _containerPrefix &amp; 
			plus &amp; _containerNumeric &amp; 
			plus &amp; _commodity &amp; 
			plus &amp; _equipDescCode &amp; 			
			plus &amp; _equipStatusDesc &amp;  //equipment status code //cnwrd1 par 34352
			plus &amp;  // net tons
			plus &amp;  //intermodal service code
			plus &amp;  //car service order code
			plus &amp;  //date
			plus &amp;  //type of locomotive maintanance code
			plus &amp;  _equipInitial &amp; //equipment initial
			plus &amp;  _equipNumber &amp; //equipment number
			plus &amp; _containerCheckDigit &amp; 
			plus &amp;  //position
			plus &amp;  //car type code
			plus &amp;  //yes no response
			singleQuote;

			
	return msg;

epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_containerPrefix" type="String"/>
        <Parameter name="_containerNumeric" type="String"/>
        <Parameter name="_containerCheckDigit" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_equipDescCode" type="String"/>
        <Parameter name="_equipStatusDesc" type="String"/>
        <Parameter name="_equipInitial" type="String"/>
        <Parameter name="_equipNumber" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeTrailer_GE" id="f7c27c4d-feea-46ae-94d3-b36240933f7b">
        <source>makeTrailer_GE(_protocol :CM_CamProtocol; _groupControlNo : String ): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwrd1	Initial creation


Functional Group Trailer (GE)

Number of Transaction Sets Included		GE01	1
Group Control Number					GE02
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time

constants
	MESSAGE	= "GE";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
			plus &amp;'1' &amp; 
			plus &amp; _groupControlNo &amp; //cnwrd1 #35645
			singleQuote;
			
	return msg;

epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_groupControlNo" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeTrailer_IEA" id="a8311de4-b026-4189-bf11-41a7f52551a1">
        <source>makeTrailer_IEA(_protocol :CM_CamProtocol; _intControlHeader : String ): String;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwrd1	Initial creation


Functional Group Trailer (IEA)

Number of Functional Groups Included		IEA01	1
Interchange Control Header					IEA02	(ISA12) 
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time


constants
	MESSAGE	= "IEA";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
			plus &amp; '1'  &amp; 
			plus &amp; _intControlHeader &amp; 
			singleQuote;
			
	return msg;

epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_intControlHeader" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeTrailer_SE" id="65653b61-6bbb-4379-ac4b-380126ff14d3">
        <source>makeTrailer_SE(_protocol :CM_CamProtocol ; _includedSegments , _tranControlNumber : String): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2014	cnwrd1	Initial creation

*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time

constants
	MESSAGE	= "SE";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	

	msg := MESSAGE &amp; 
			plus &amp; _includedSegments &amp; 
			plus &amp; _tranControlNumber &amp; 
			singleQuote;
			
	return msg;
epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_includedSegments" type="String"/>
        <Parameter name="_tranControlNumber" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputFile" id="bf32ce30-3af5-4d20-8a5e-de4cb896b6c1">
        <updating/>
        <source>outputFile(_protocol: CM_CamProtocol input; _camAgent: CM_CamControllerAgent; _camFile: CM_CamFile input; _runDateTime: TimeStamp; _camTaskHistory: CM_CamTaskHistory input; _unhSeqNumber: Integer io; _seqNumber: Integer; _terminal: CM_Terminal; _contextObj : CM_Object; _transactions : CM_TITransactionSet) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Mar 2014	cnwrd1	Initial creation
25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
09 Jan 2020	jlgdap1	TFS 48016 SNO Deletion CODECO - new _transactions parameter
*/

vars
	camVoyage 		: CM_CamVoyage;
	camMessage 		: CM_CamMessage;
	code, str, outputStr 		: String;
	termPortCode 	: String;
	messageType 	: String;
	singleQuote	:Character;
	strLine : String;
begin

	singleQuote	:= _protocol.segmentTerminator;
	
	app.writeLog("===================================", LogWARN);
	
	if _camFile.camVoyages.size &gt; 0 then
		foreach camVoyage in _camFile.camVoyages do
			foreach camMessage in camVoyage.camMessages do
				
				//BGM header
				/*if camMessage.activity = CODECO_GATEIN then
					messageType := "TREC";
					camMessage.segmentCount :=  1;
				elseif camMessage.activity = CODECO_GATEOUT then
					messageType := "TDEL";
					camMessage.segmentCount :=  1;
				endif;
				
				code 			:= _terminal.getConfig(PortDestCode).String;
				termPortCode 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _terminal);

				//00 header
				self.outputFileMessage(_camTaskHistory, 
										"00" &amp; messageType.padBlanks(4) &amp; termPortCode.padBlanks(6)[1:6] &amp; camVoyage.voyageOid.vesselCode.padBlanks(6)[1:6] &amp; 
										camVoyage.getSanitisedVoyageCode().padBlanks(6)[1:6] &amp; "1",
										camMessage.header);*/
				
			//	i := 1;
				
				foreach str in camMessage.group3 do
				
					if str[str.length:1] = singleQuote then
						outputStr := outputStr &amp; str;
						strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, outputStr, null);
						outputStr := null; //reset this now
					else
						//we dont end with a segment terminator so lest just collect data						
						outputStr := outputStr &amp; str;
					endif;
									
				endforeach;
				
				/*while i &lt;= camMessage.group3.size do
					str := camMessage.group3[i].String;
					outputFileMessage(_camTaskHistory, str, null);
					
					str := camMessage.group4[i].String;
					outputFileMessage(_camTaskHistory, str, null);
					
					str := camMessage.group5[i].String;
					outputFileMessage(_camTaskHistory, str, null);
					
					camMessage.segmentCount := camMessage.segmentCount + 1;
					i := i + 1;
				endwhile;*/

				//99 trailer same as 00 header but has number of records  rather than the version number
			/*	camMessage.segmentCount := camMessage.segmentCount + 1; // allow for this trailer
				
				outputFileMessage(_camTaskHistory, "99" &amp;
									messageType.padBlanks(4) &amp;
									"NZPOE".padBlanks(6) &amp;
									camVoyage.voyageOid.vesselCode.padBlanks(6)[1:6] &amp;
									camVoyage.getSanitisedVoyageCode().padBlanks(6)[1:6] &amp;
									camMessage.segmentCount.String.padZeros(6)[1:6],
									camMessage.trailer);*/

			endforeach;
		endforeach;
	endif;

	app.writeLog("===================================", LogWARN);
	_camTaskHistory.setRawDataString(strLine);
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="outputFileMessage" id="d32b8013-34ba-4572-b776-77c9e4fa1b89">
        <updating/>
        <source>outputFileMessage(_camTaskHistory: CM_CamTaskHistory input; _message: String; _coll: HugeStringArray input) : String updating;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
19 March 2014	cnwrd1	Initial creation
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//21 Jul 2015	cnwrs1	Par 35544 - Switch Cams to camtaskhistory::rawData
//29 Sep 2015	cnwrs1	Par 35544 - Change Cams task hisoty to use JadeBytes  
vars
	str	: String;
	ending : String;
	camProtocol : CM_CamProtocol;
begin
	camProtocol := _camTaskHistory.camProtocol;
//	if camProtocol.noCrLfInMessage then
	ending := Cr;
//	endif;
//	_camTaskHistory.addFileDataLineRAW(_message &amp; ending);
	
	str := _message;
	
	if _coll &lt;&gt; null then
//		if str.length &gt; 61 then
//			str := str [1:61];
//		endif;
		
		_coll.add (str);
	endif;
	
	return str &amp; ending;
end;</source>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="splitChassisID" id="a182e201-f43b-43bf-bc04-ddeded2453f5">
        <source>splitChassisID( _id: String; _prefix : String io; _numeric : String io) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2014	cnwrd1	Initial creation

*/

vars
	idx	: Integer;
	lIDToCheck,
	lCharString,
	lNumString: String;

begin

	lIDToCheck := _id.toUpper.trimBlanks;
	/*if lIDToCheck.length &lt;&gt; ContainerID_Length then
		return false;
	endif;*/
	foreach idx in 1 to lIDToCheck.length do
		if lIDToCheck[idx:1].isInteger then
			lCharString := lIDToCheck[1:idx - 1];
			lNumString := lIDToCheck[idx:end]; 
			break;
		endif;
	endforeach;

	_prefix := lCharString;
	//_checkDigit := lNumString[lNumString.length:lNumString.length];
	_numeric := lNumString[1:lNumString.length];
	
	return true;
epilog

end;
</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_prefix" type="String" usage="io"/>
        <Parameter name="_numeric" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="splitContainerID" id="91b3029e-6141-4311-b3a8-702396b3605f">
        <source>splitContainerID( id: String; 
				  prefix : String io; 
				  numeric : String io; 
				  checkDigit : String io;
				  camProtocol : CM_CamProtocol) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#	Description
============================================================================
13/03/2014	cnwrd1			Initial creation
15/03/2019	jlgka1	41641	SSL - X12 322 Equipment ID Check.
============================================================================*/

vars
	idx				: Integer;
	lIDToCheck		: String;
	lCharString		: String;
	lNumString		: String;
begin

	lIDToCheck := id.toUpper.trimBlanks;
	if lIDToCheck.length &lt;&gt; ContainerID_Length then
		//jlgka1 TFS 41641 --&gt;
		if camProtocol.useRelaxedIdChecking then 
			prefix := "";
			numeric := lIDToCheck[1:10];
			checkDigit := "";
		endif;
		//jlgka1 TFS 41641 &lt;--
		return false;
	endif;
	
	foreach idx in 1 to lIDToCheck.length do
		if lIDToCheck[idx:1].isInteger then
			lCharString := lIDToCheck[1:idx - 1];
			lNumString := lIDToCheck[idx:end]; 
			break;
		endif;
	endforeach;
	//jlgka1 TFS 41641 --&gt;
	if lCharString.length &lt;&gt; 4 and camProtocol.useRelaxedIdChecking	then		
		prefix := "";
		numeric := lIDToCheck[1:10];
		checkDigit := "";
	else //jlgka1 TFS 41641 &lt;--
		prefix := lCharString;
		checkDigit := lNumString[lNumString.length:lNumString.length];
		numeric := lNumString[1:lNumString.length-1];	
	endif;
	return true;
end;</source>
        <Parameter name="id" type="String"/>
        <Parameter name="prefix" type="String" usage="io"/>
        <Parameter name="numeric" type="String" usage="io"/>
        <Parameter name="checkDigit" type="String" usage="io"/>
        <Parameter name="camProtocol" type="CM_CamProtocol"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
