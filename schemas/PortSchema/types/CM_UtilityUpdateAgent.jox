    <JadeMethod name="utlUpdateTILCType" id="da3cbca2-c8ff-46d5-af1d-1495664ca792">
        <updating/>
        <source>utlUpdateTILCType(_pxyTILCType	: CM_TILCType; _passport : CM_Passport input)updating;
// -------------------------------------------
// Created 08 December 2005 by cnwdvb1
// -------------------------------------------
vars

	expectedEdition	: Integer;
	realTILCType	: CM_TILCType;

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);
	

	_pxyTILCType.raiseExceptionIfNotProxy(method);
	_pxyTILCType.pxyGetRealObjectAndEdition(realTILCType, expectedEdition);

	exclusiveLock(realTILCType);

	if _passport.noErrors and realTILCType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Type', null, null);
		return;
	endif;
	
	realTILCType.setForUpdate(_pxyTILCType, _passport);

end;</source>
        <Parameter name="_pxyTILCType" type="CM_TILCType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIMastToDoTaskAddBulk" id="d82eefb8-e3f0-494f-a85f-ab2e2ae583f8">
        <updating/>
        <source>utlUpdateTIMastToDoTaskAddBulk(_toDoTaskDesc : CM_ToDoTaskDesc;
							_allTIs 	: CM_TIMasterSet;
							_passport 	: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwrd1	Initial creation

*/
vars
	
	ti				: CM_TIMaster;
	
begin
	app.setContinueCMExceptions(false);
	
	if _allTIs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "_allTIs set", null, null);
	endif;
	
	if _toDoTaskDesc = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "_toDoTaskDesc", null, null);
	endif;
	
	if _toDoTaskDesc.description = null then
		app.raiseCMException1(ERR_TODOTASK_ADD, 'Task has a null description (' &amp; _toDoTaskDesc.description &amp; '). This operation cannot proceed.', null, null);
	endif;
	
	app.setContinueCMExceptions(true);
	
	foreach ti in _allTIs do
		ti.addToDoTaskForBulk(_toDoTaskDesc, _passport);
	endforeach;
	

end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_allTIs" type="CM_TIMasterSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIMastToDoTaskRemBulk" id="50e9ae4b-6672-4a05-bc3c-673036307224">
        <updating/>
        <source>utlUpdateTIMastToDoTaskRemBulk(_toDoTaskDesc : CM_ToDoTaskDesc;
							_allTIs 	: CM_TIMasterSet;
							_passport 	: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwrd1	Initial creation

*/


vars
	
	ti				: CM_TIMaster;

begin
	app.setContinueCMExceptions(false);
	
	if _allTIs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "_allTIs set", null, null);
	endif;
	
	if _toDoTaskDesc = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "_toDoTaskDesc", null, null);
	endif;
	
	if _toDoTaskDesc.description = null then
		app.raiseCMException1(ERR_TODOTASK_ADD, 'Task has a null description (' &amp; _toDoTaskDesc.description &amp; '). This operation cannot proceed.', null, null);
	endif;
	
	app.setContinueCMExceptions(true);
	
	foreach ti in _allTIs do
		ti.removeToDoTaskForBulk(_toDoTaskDesc, _passport);
	endforeach;
	

end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_allTIs" type="CM_TIMasterSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIMasterTILC" id="cfaae932-bb98-4464-acec-6e2fac9c0deb">
        <source>utlUpdateTIMasterTILC(	_pxyTIMasterTILC : CM_TIMasterTILC;
						_passport : CM_Passport);
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 April 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	realTIMasterTILC	: CM_TIMasterTILC;
	expectedEdition	: Integer;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);
	

	_pxyTIMasterTILC.raiseExceptionIfNotProxy(method);
	_pxyTIMasterTILC.pxyGetRealObjectAndEdition(realTIMasterTILC, expectedEdition);

	exclusiveLock(realTIMasterTILC);

	if _passport.noErrors and realTIMasterTILC.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Type', null, null);
		return;
	endif;
	
	//realTIMasterTILC.setForUpdate(_pxyTIMasterTILC);
	
	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realTIMasterTILC, true);
	endif;

	if _passport.noErrors then
		realTIMasterTILC.setForUpdate(_pxyTIMasterTILC);
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realTIMasterTILC, false);
	endif;


epilog

end;</source>
        <Parameter name="_pxyTIMasterTILC" type="CM_TIMasterTILC"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIMatchAndQueueToTBA" id="ec600133-6cdd-499f-8f95-eb5dc3f958df">
        <source>utlUpdateTIMatchAndQueueToTBA(pProxyWLE : CM_WorkListEntry io; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 04 March 2002 By: cnwgd1
//31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
//--------------------------------------------------------------
vars
	realWle			: CM_WorkListEntry;
	arbiter			: CM_RTQueueArbiter;	
	expectedEdition	: Integer;	
begin

	self.initialiseActivity();

	pProxyWLE.raiseExceptionIfNotProxy(method);
	pProxyWLE.pxyGetRealObjectAndEdition(realWle, expectedEdition);
	
	if realWle = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WorkListEntry.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(false);	

	// do the validation here
	app.myValUA.valTBAMatch(pProxyWLE);

	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);
	
	exclusiveLock(realWle);

	if _passport.noErrors and realWle.edition &lt;&gt; expectedEdition then
		app.raiseCMException2(ObjectUpdatedByAnotherUserSave, 'work list entry', 'entry', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		realWle.myTrackedItem.matchAndQueueToTBA(realWle, _passport);
	endif;
	
	//Queue a specific WLE (and its TI's) to a Queue. The method determines the most appropriate queue.
	//We dont have to pass an arbiter in, as the method creates one if needed
	//See enqueueJob function to do ALL wle's in a job.	
	if _passport.noErrors then
		realWle.enqueueWLE(arbiter);
	endif;		
epilog
	
	
end;</source>
        <Parameter name="pProxyWLE" type="CM_WorkListEntry" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTINonTranship" id="3adbe028-38d9-4512-b4c5-e0b459f7eb2f">
        <updating/>
        <source>utlUpdateTINonTranship(_pxyTIs : CM_TIArray input; _updateMode : Integer; _passport : CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/06/2010	cnwdap1	Initial creation CCMS 1116 Tranship changes - new method to make tranships non-tranship
*/
vars
	pxyTI, realTI		: CM_TrackedItem;
	expectedEdition		: Integer;
	valUpdateCntrl,
	tiUpdateCntrlr		: CMIF_TIUpdateController;

begin
	self.initialiseActivity();
	
	valUpdateCntrl := app.createTIUpdateControl(_updateMode, null, null);
	tiUpdateCntrlr := app.createTIUpdateControl(_updateMode, _passport.userCode, null);

	foreach pxyTI in _pxyTIs do
	
		pxyTI.raiseExceptionIfNotProxy(method);
		pxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);
	
		if realTI = null then	
			app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
			return;
		endif;		
		/*
		// VALIDATION shifted to trx cnwrd1 par 24856 6.7.2010
		app.setContinueCMExceptions(true);
	
		//14/04/2009 cnwdz2 ccms1735
		if app.isSubTerminalsOn(pxyTI.myTerminal) then
			if pxyTI.mySubTerminal &lt;&gt; realTI.mySubTerminal then
				pxyTI.checkStopsToBePrevented(StopPreventSubTerminalEdit,null,true);
			endif;
		endif;
		
		// do the validation here
		
		app.myValUA.valTrackedItem(pxyTI, valUpdateCntrl, _passport);
		if not self.checkValidationWithPassport(_passport) then
			return;
		endif;
		
		app.setContinueCMExceptions(false);
		*/
	
		self.exclusiveLock(realTI);
		
		if not _passport.noErrors then
			return;
		endif;
		
		// do the updates
		realTI.setTranshipToNonTranship(pxyTI, tiUpdateCntrlr, _passport);
	endforeach;
	
epilog
	delete tiUpdateCntrlr;
	delete valUpdateCntrl;
end;</source>
        <Parameter name="_pxyTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_updateMode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIPackComplete" id="c69f1be2-128e-47ad-81b1-3cb47d19b570">
        <updating/>
        <source>utlUpdateTIPackComplete(_theProxyTI, _realTI: CM_TrackedItem input; _passport: CM_Passport input) updating;
/*
Created:		24 July 2009 by consw1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 Oct 2021 navma1 Bug 52255: SAL - Pack/Unpack Work Order issues
08 Feb 2023 navma1 ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
27 Mar 2023 navma1 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
01 Sep 2023 navhl20 ChangeRequest 59121: EUP | Handle Work orders Packing  By Type
11 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
08 Aug 2024 navbs1	Bug 65544: TPT | Pack Container via Pack Load Release - Error 75764
24 Sep 2024 navhl20	ChangeRequest 62456:[66078] EUP* | VAS Mobile App - [53813.040] VAS Tasks in other Operational Mobile Apps - Flow Integration - 2
*/

vars
	theWLE 		: CM_WorkListEntry;
	theWOD 		: CM_WodPack;
	woDtl  		: CM_WorkOrderDtl; 
	imexStatus  : CM_IMEXStatus;
	woPackWle	: CM_WorkListEntry;
	bulkRelease : CM_BulkRelease;
	wo			: CM_WorkOrderTI;
	todoJob		: CM_WOToDoTaskJob;
	wod			: CM_WorkOrderTIDtl;
	wodTodo		: CM_WodToDo;
	todoWle		: CM_WorkListEntry;
	todoDesc	: CM_ToDoTaskDesc;
	trxType     : CM_TransactionType;
begin
	
	theWLE := _realTI.getIncompleteWLE(CM_PackWLE);
	
	if theWLE &lt;&gt; null  then
			
		theWOD := theWLE.CM_PackWLE.getWorkOrderTIDtl();
		
		if theWOD = null then
			return;
		endif;
		
		//  Complete WLE
		theWLE.setStatus(WLE_COMPLETED);
		
	else 
		//woDtl := _realTI.getWorkOrderDetailOfType(WO_TASK_PACK);      //26.10.2021 navma1# 52255	//08.02.2023 navma1 #56457:[56458]
		woDtl := _realTI.getWoDetailForType(WO_TASK_PACK,woPackWle);	//08.02.2023 navma1 #56457:[56458]
		
		if woDtl &lt;&gt; null then
			theWOD :=  woDtl.CM_WodPack;
		endif;
	endif;
	
	
	if theWOD = null then											 		//26.10.2021 navma1 #52255
		return;
	endif;
	
	/*
	//22.08.2023 navma1 #59121
	*/
	bulkRelease := theWOD.myReleaseRequest;
	if bulkRelease &lt;&gt; null and bulkRelease.isPackingType then
		if woPackWle &lt;&gt; null then
			//before := _realTI.edition;									//08.8.2024 navbs1 #65544
			woPackWle.setMyTrackedItem(_realTI);
			//after  := _realTI.edition; 									//08.8.2024 navbs1 #65544
			woPackWle.setStatus(WLE_COMPLETED);
			//08.8.2024 navbs1 #65544
			/*if before &lt;&gt; after or before = after then						//08.9.2023 navhl20 #59121
				foreach pxy in app.myProxyManager.allProxies do
					if pxy.myProxyObject = _theProxyTI then
						pxy.originalRealEdition := _realTI.edition;
					endif;
				endforeach;
				foreach pxy in app.myProxyManager.allReals do
					if pxy.myRealObject = _realTI then
						pxy.originalRealEdition := _realTI.edition;
					endif;
				endforeach;
			endif;*/
			if _passport.isVASEnabled then									//24.09.2024 navhl20 #62456:[66078]
				wod := woPackWle.getWorkOrderTIDtl();
				if wod &lt;&gt; null then
					wodTodo := wod.allToDoRequests.first;
				endif;
				if wodTodo &lt;&gt; null then
					todoJob := wodTodo.allJobs.first.CM_WOToDoTaskJob;
				endif;
				if todoJob &lt;&gt; null then
					todoWle := todoJob.getWLEWithoutTi();
				endif;
				if todoWle &lt;&gt; null then
					todoWle.setMyTrackedItem(_realTI);
					todoDesc := todoWle.job.CM_WOToDoTaskJob.myToDoTaskDesc;
					trxType := todoDesc.myTransactionType; //This is the trxTypeOnCompletion.
					if trxType &lt;&gt; null and trxType.isForWorkOrder() then
						todoWle.CM_WOToDoWLE.createWOToDoTask();
					endif;
				endif;
			endif;
		endif;
	/*
	//01.9.2023 navhl20 #59121
	else
		
		theWOD.setTIComplete(_realTI,null);									//27.03.2023 navma1 #56614:[56615]*/
	endif;
	
	if _passport.isVASEnabled then											//11.07.2024 navhl20 #61368
		wo := theWOD.myParent.CM_WorkOrderTI;
		foreach theWOD in wo.allWoDtls as CM_WodPack do
			if theWOD.allSelectedTIs.includes(_realTI) then
				theWOD.setTIComplete(_realTI,null);
				continue;
			endif;
			
			theWLE := theWOD.allJobs.first.allRequests.first.hasMatchingWOWLETypeStatus(null,WO_TASK_PACK,WLE_UNACTIONED);
			if theWLE &lt;&gt; null then
				theWLE.setMyTrackedItem(_realTI);
				theWLE.setStatus(WLE_COMPLETED);
				theWOD.setTIComplete(_realTI,null);
			endif;
			
			//Start 24.09.2024 navhl20 #62456:[66078]
			if theWLE &lt;&gt; null then
				wod := theWLE.getWorkOrderTIDtl();
				if wod &lt;&gt; null then
					wodTodo := wod.allToDoRequests.first;
				endif;
				if wodTodo &lt;&gt; null then
					todoJob := wodTodo.allJobs.first.CM_WOToDoTaskJob;
				endif;
				if todoJob &lt;&gt; null then
					todoWle := todoJob.getWLEWithoutTi();
				endif;
				if todoWle &lt;&gt; null then
					todoWle.setMyTrackedItem(_realTI);
					todoDesc := todoWle.job.CM_WOToDoTaskJob.myToDoTaskDesc;
					trxType := todoDesc.myTransactionType; //This is the trxTypeOnCompletion.
					if trxType &lt;&gt; null and trxType.isForWorkOrder() then
						todoWle.CM_WOToDoWLE.createWOToDoTask();
					endif;
				endif;
			endif;
			//End 24.09.2024 navhl20 #62456:[66078]
		endforeach;
	else
		theWOD.setTIComplete(_realTI,null);									//01.9.2023 navhl20 #59121
	endif;
	
	//Work Order detail
	
	//theWOD.doCompleteTask(null,woPackWle,null);
	
	//  Set pack fields on TI (via proxy)
	if theWOD.myVoyage &lt;&gt; null then
		_theProxyTI.setMyVoyage(theWOD.myVoyage, _passport);
	endif;
	if theWOD.myOperator &lt;&gt; null then
		_theProxyTI.setMyOperator(theWOD.myOperator);
	endif;
	if theWOD.myDischargePort &lt;&gt; null then
		_theProxyTI.setDestinationPort(theWOD.myDischargePort.code);
	endif;
	if theWOD.myBookingRef &lt;&gt; null then
		_theProxyTI.setBookingReference(theWOD.myBookingRef.description);
	endif;
	
	if theWOD.imexStatus &lt;&gt; null then												//06.03.2023 navma1 #56457:[56458]
		imexStatus := app.myRoot.allImexStatuses[theWOD.imexStatus];				//06.03.2023 navma1 #56457:[56458]
		if imexStatus &lt;&gt; null then
			_theProxyTI.setImExStatus(theWOD.imexStatus);
		endif;
	endif;
	
	if theWOD.commodity &lt;&gt; null then
		_theProxyTI.setCommodity(theWOD.commodity);
	endif;
	if theWOD.mySubTerminal &lt;&gt; null then
		_theProxyTI.setMySubTerminal(theWOD.mySubTerminal.code);
	endif;
	if theWOD.myConsignee &lt;&gt; null then
		_theProxyTI.setConsignee(theWOD.myConsignee.code, null, _passport);
	endif;
	if theWOD.myConsignor &lt;&gt; null then
		_theProxyTI.setConsignor(theWOD.myConsignor.code, null, _passport);
	endif;
	if theWOD.myContentsStatus &lt;&gt; null then
		_theProxyTI.setContentsStatus(theWOD.myContentsStatus.code);  // 7/9/22 	jlier1	TFS 54700
	endif;

epilog

end;</source>
        <Parameter name="_theProxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIPriorWHousePacking" id="a9e5dbd7-9676-4346-9076-1d61a15bb8df">
        <updating/>
        <source>utlUpdateTIPriorWHousePacking(_pxyTI : CM_TrackedItem; _pxyRelease : CM_BulkRelease; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
//
vars
	realTI 			: CM_TrackedItem;
	realRelease		: CM_BulkRelease;
	expectedEdition : Integer;
	controller		: CMIF_TIUpdateController;

begin
	self.initialiseActivity();

	_pxyTI.raiseExceptionIfNotProxy(method);
	_pxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);

	if _passport.noErrors and realTI.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Tracked Item', null, null);
		return;
	endif;
	
	_pxyRelease.raiseExceptionIfNotProxy(method);
	_pxyRelease.pxyGetRealObjectAndEdition(realRelease, expectedEdition);

	if _passport.noErrors and realRelease.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Bulk Release', null, null);
		return;
	endif;
	
	controller := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);
		
	exclusiveLock(realTI);
	exclusiveLock(realRelease);

	// do the updates - change the TI's sub terminal and consignor, and attach it to the release
	realTI.setSubTerminalWithTrans(_pxyTI.mySubTerminal, _passport);
	realTI.setConsignor(_pxyTI.consignor, controller, _passport);
	realTI.setBookingRefAndItem(_pxyTI.myBookingRef, _pxyTI.myBookingRefItem, null, _passport);
	realRelease.addTIAssigned(realTI, null);
	
epilog

end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
        <Parameter name="_pxyRelease" type="CM_BulkRelease"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIReadyToShip" id="902002f5-ac3a-495f-a483-768ae3d386b1">
        <source>utlUpdateTIReadyToShip(_theTI: CM_TrackedItem input; 
					_tiUpdateCntrl : CMIF_TIUpdateController input;
					_readyToShip : Boolean;
					_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.initialiseActivity();
	_theTI.setReadyToShip(_readyToShip, _tiUpdateCntrl, _passport);

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_tiUpdateCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_readyToShip" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIReceiveType" id="ec799292-d2e7-4d73-9096-fd41f138823b">
        <source>utlUpdateTIReceiveType(_type	: Integer; _coll : CM_TISet; _passport	: CM_Passport input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2013	cnwmc5	Initial creation

*/
vars

	ti,
	proxy			: CM_TrackedItem;
	proxyColl		: CM_TISet;
	gotException	: Boolean;
	errorCount		: Integer;
	terminal		: CM_Terminal;
	tmpPinNo : CM_PinNo;
	termEmailDefaults : CM_PINObjectDefaultEmail;
	emailDefaults : CM_PINObjectDefaultEmail;
	
begin
	self.initialiseActivity();
	app.setContinueCMExceptions( true );
	
	// Do validation.
	self.raiseExceptionIfNull( _coll, 'list of Release Requests' );	// can not be nothing to change
	
	// must have supplied correct type to change to.
	if _type &lt;&gt; TI_TRANSMODE_ROAD and
	   _type &lt;&gt; TI_TRANSMODE_RAIL and
	   _type &lt;&gt; TI_TRANSMODE_NULL then				// NOTE null = 0 = BOOKING_REF_PENDING
		// we expect the GUI to take care of this
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid type');
	endif;
	
	if _passport.noErrors() then
		// OK do updating.
		create proxyColl transient;
		
		on Exception do app.handleDeletedObject (exception, ti, gotException);
		
		// 	I need to do a first pass with just doing validation so I get all errors/warnings reported
		//	for all release request
		foreach ti in _coll do
			if ti.receiptTransportMode = _type then
				// nothing to do
				continue;
			endif;
			
			proxy	:= ti.pxyCreateUpdateProxy;	// does share lock on release request
			
			if not gotException then
				proxy.setReceiptTransportMode (_type);				
				proxyColl.add (proxy);
			
				errorCount := _passport.allErrorWarnings.size;
				if errorCount &lt; _passport.allErrorWarnings.size then
					// new errors
					app.raiseCMWarning1 (Tracked_item_errors, proxy.id, null, null, null);
				endif;
			else
				gotException := false;
			endif;
			
		endforeach;
		
		if not self.checkValidationWithPassport (_passport) then
			return;
		endif;

		//////////////
		//23 Jul 2014	NDL	Par 33891
		if _type = TI_TRANSMODE_ROAD then
			termEmailDefaults	:= _passport.myTerminal.getEmailDefaultsSettings( PINEmail_Prenote );
		endif;
		//////////////
		// error free so do the updating
		
		foreach proxy in proxyColl do
			ti	:= proxy.pxyGetRealObject;

			self.exclusiveLock (ti);	// upgrading from share to exclusive
			
			if _passport.noErrors then
				self.myUpdateAuditAgent.audUpdateGeneric(ti, true);
			endif;
			
			if _passport.noErrors then
				ti.setReceiptTransportMode (proxy.receiptTransportMode);
				//////////////////
				//23 Jul 2014	NDL	Par 33891
				if _type = TI_TRANSMODE_ROAD then
					//Issue a road entry PIN number if one hasn't already been issued
					if ti.myPinNo = null and not ti.noPINforHazardousODProcess(true, false, ti.myPinNo, _passport) then
						if (not app.generatePinNo(tmpPinNo, 'Pre-Note ' &amp; ti.id, _passport.myTerminal)) then
							continue;
						endif;
						emailDefaults := termEmailDefaults.cloneSelf(true).CM_PINObjectDefaultEmail;
						emailDefaults.setAddresses( _passport.myTerminal, ti.getCarrierReceive, ti.getConsigneeObject, PINEmail_Prenote );
						tmpPinNo.addItem(ti,emailDefaults);
					endif;
				endif;
				//////////////////
			endif;
		
			if _passport.noErrors then
				self.myUpdateAuditAgent.audUpdateGeneric(ti, false);
			endif;
		
			if not _passport.noErrors then
				// we don't expect to get errors because we did all the validation up front but if we do then
				// we need to stop here - the transaction will be aborted
				break;
			endif;
		endforeach;
		
		if _passport.noErrors then
			// send out notes now that we know everything has been updated.
			terminal := _passport.myTerminal;
			
			foreach proxy in proxyColl do
				ti	:= proxy.pxyGetRealObject;
				if _passport.noErrors and terminal &lt;&gt; null and ti &lt;&gt; null then
					ti.causeEvent(terminal.getTerminalEvent(TIEvent_PreNote_Update), false, ti);
				endif;
			endforeach;	
		endif;
	endif;
epilog
	proxyColl.purge;
	delete proxyColl;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_coll" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIReeferDetails" id="90c0f512-e303-4d11-9325-385884ba4945">
        <source>utlUpdateTIReeferDetails(_proxyTI: CM_EDILoadListTI input; _tempCarr: Real; _humidity: Integer; _ventilation: Decimal; _expiryDate: Date; _remarks: String; _coolingType, _voltageType, _oxygen, _carbonDioxide: Integer;
			_curtainsIn: Boolean; _packDate: Date; _packTime: Time; _remaining: Decimal; _packTemp: Real; _extMonitor: Boolean; _passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2019	jlgmp6	Initial creation	TFS 45590

*/

vars

begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	exclusiveLock(_proxyTI);
	
	if (not _passport.noErrors) then
		return;
	endif;

	_proxyTI.setReeferDetails(_tempCarr, _humidity, _ventilation, _expiryDate, _remarks, _coolingType, _voltageType, _oxygen, _carbonDioxide, _curtainsIn, _packDate, _packTime, _remaining, _packTemp, _extMonitor);
epilog

end;</source>
        <Parameter name="_proxyTI" type="CM_EDILoadListTI" usage="input"/>
        <Parameter name="_tempCarr" type="Real"/>
        <Parameter name="_humidity" type="Integer"/>
        <Parameter name="_ventilation" type="Decimal"/>
        <Parameter name="_expiryDate" type="Date"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_coolingType" type="Integer"/>
        <Parameter name="_voltageType" type="Integer"/>
        <Parameter name="_oxygen" type="Integer"/>
        <Parameter name="_carbonDioxide" type="Integer"/>
        <Parameter name="_curtainsIn" type="Boolean"/>
        <Parameter name="_packDate" type="Date"/>
        <Parameter name="_packTime" type="Time"/>
        <Parameter name="_remaining" type="Decimal"/>
        <Parameter name="_packTemp" type="Real"/>
        <Parameter name="_extMonitor" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIRemarks" id="d0cb0752-f21e-484f-b1f9-66f1ef62024d">
        <source>utlUpdateTIRemarks(_theProxyTI: CM_TrackedItem input; _theRemarks : String;
					_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theRealTI : CM_TrackedItem;
	expectedEdition : Integer;
	tiUpdateCntrlr : CMIF_TIUpdateController;
begin
	self.initialiseActivity();

	_theProxyTI.raiseExceptionIfNotProxy(method);
	_theProxyTI.pxyGetRealObjectAndEdition(theRealTI, expectedEdition);

	exclusiveLock(theRealTI);

	if _passport.noErrors and theRealTI.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'TI Remarks', null, null);
		return;
	endif;
	
	//epr par 34113 21/5/14
	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	
	theRealTI.setRemarksTrans(_theRemarks, true,tiUpdateCntrlr, _passport);
	
	
epilog
	delete tiUpdateCntrlr;
end;</source>
        <Parameter name="_theProxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_theRemarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIRemarksDamage" id="e5dd8b20-53e5-46d6-a0b8-28e1719dcb9c">
        <source>utlUpdateTIRemarksDamage(_ti : CM_TrackedItem input; _remarks, _reeferRemarks : String;
						 _damaged : Boolean; _passport : CM_Passport input);
//-----------------------------------------
//Created: January 2003 By: cnwgd1
//-----------------------------------------
vars
	tiUpdateCntrlr : CMIF_TIUpdateController;
begin

	self.initialiseActivity();
	
	if _ti = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _ti.getName, null, null);
		return;
	endif;

	exclusiveLock(_ti);

	if (not _passport.noErrors) then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'TrackedItem', null, null);
		return;
	endif;
	
	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	_ti.setRemarksDamaged(_remarks, _reeferRemarks, _damaged, tiUpdateCntrlr, _passport);

epilog
	delete tiUpdateCntrlr;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_reeferRemarks" type="String"/>
        <Parameter name="_damaged" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIShipperSeals" id="a506cd19-7069-42f7-9494-b530e9b3a2d7">
        <source>utlUpdateTIShipperSeals(_pxyTI : CM_TrackedItem input;
						_checkSealsForDischarge : Boolean;
						_passport : CM_Passport input);
// ### AKB2007JUN POLAND
vars
	realTI 				: CM_TrackedItem;
	expectedEdition 	: Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyTI, 'Tracked Items Proxy');
	
	_pxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);
	self.raiseExceptionIfNull(realTI, 'Tracked Item proxy');
	
	if not _passport.noErrors then
		return;
	endif;
	
	exclusiveLock(realTI);
	
	realTI.setShipLanderSeals(_pxyTI,_checkSealsForDischarge);
	
epilog

end;
</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_checkSealsForDischarge" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIToDoTaskAdd" id="20bc3ee9-80ae-42cf-aff5-6c5dc64da8b9">
        <updating/>
        <source>utlUpdateTIToDoTaskAdd(_theTI : CM_TrackedItem input; _toDoCode : Integer;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	taskDesc : CM_ToDoTaskDesc;
begin

	taskDesc := app.myRoot.allToDoTaskDescriptions[_toDoCode];
	if taskDesc = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No todo task found for (' &amp; _toDoCode.String &amp; ')');
		return;
	endif;
	if (not taskDesc.canUserAdd(_passport)) then
		return;
	endif;
	
	_theTI.addToDoTask(taskDesc.description, _passport);
	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_toDoCode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIToDoTaskAddBulk" id="d7135238-fc0a-4482-a885-61a62d1e47d4">
        <updating/>
        <source>utlUpdateTIToDoTaskAddBulk(_toDoTaskDesc : CM_ToDoTaskDesc;
							_allTIs 	: CM_TISet;
							_passport 	: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
	ti				: CM_TrackedItem;
	
begin
	app.setContinueCMExceptions(false);
	
	if _allTIs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "_allTIs set", null, null);
	endif;
	
	if _toDoTaskDesc = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "_toDoTaskDesc", null, null);
	endif;
	
	if _toDoTaskDesc.description = null then
		app.raiseCMException1(ERR_TODOTASK_ADD, 'Task has a null description (' &amp; _toDoTaskDesc.description &amp; '). This operation cannot proceed.', null, null);
	endif;
	
	app.setContinueCMExceptions(true);
	
	foreach ti in _allTIs do
		ti.addToDoTaskForBulk(_toDoTaskDesc, _passport);
	endforeach;
	

end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_allTIs" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIToDoTaskBulkAdd" id="03a664f3-4324-4a9c-9878-58bbbe9d0428">
        <updating/>
        <source>utlUpdateTIToDoTaskBulkAdd(_toDoTaskDesc : CM_ToDoTaskDesc;
							_remarks 	: String;
							_allTIs 	: CM_TISet;
							_passport 	: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	22/10/2015	cnwjre1 for 36957 copy of utlUpdateTIToDoTaskAddBulk with added remarks 

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	task 		: CM_ToDoTask;
	ti			: CM_TrackedItem;
	
begin
	app.setContinueCMExceptions(false);
	
	if _allTIs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "_allTIs set", null, null);
	endif;
	
	if _toDoTaskDesc = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "_toDoTaskDesc", null, null);
	endif;
	
	if _toDoTaskDesc.description = null then
		app.raiseCMException1(ERR_TODOTASK_ADD, 'Task has a null description (' &amp; _toDoTaskDesc.description &amp; '). This operation cannot proceed.', null, null);
	endif;
	
	app.setContinueCMExceptions(true);
	
	foreach ti in _allTIs do
		task := ti.addToDoTaskForBulk(_toDoTaskDesc, _passport);
		if task &lt;&gt; null then
			task.setRemarks(_remarks);
		endif;
	endforeach;
	

end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_allTIs" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIToDoTaskCmpltBulk" id="f7ee6d96-a748-43fa-aa5f-beb8ffd17a1e">
        <updating/>
        <source>utlUpdateTIToDoTaskCmpltBulk(_toDoTaskDesc 		 : CM_ToDoTaskDesc;
							_allTIs 			 : CM_TISet;
							_resourceUsageProxys : CM_ResourceTypeUsageSet input;
							_passport 			 : CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
23 Jan 2023	 navma1		 ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
----------   ----------  --------------------------------------------------
*/
vars
	ti	: CM_TrackedItem;
begin
	self.initialiseActivity();				//23.01.2023 navma1 #54349[54262]
	
	// do validation
	self.raiseExceptionIfNull(_allTIs, 		 'Test_allTIs set');
	self.raiseExceptionIfNull(_toDoTaskDesc, '_toDoTaskDesc');
	
	if _toDoTaskDesc.description = null then
		app.raiseCMException1(ERR_TODOTASK_ADD, 'Task has a null description (' &amp; _toDoTaskDesc.description &amp; '). This operation cannot proceed.', null, null);
	endif;
	
	app.setContinueCMExceptions(true);
	
	app.myValUA.valCompleteToDoTask(_toDoTaskDesc, _resourceUsageProxys);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;	
	endif;

	foreach ti in _allTIs do
		ti.completeToDoTaskForBulk(_toDoTaskDesc, _resourceUsageProxys, _passport);
	endforeach;
	

end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_allTIs" type="CM_TISet"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIToDoTaskCmpltGTE" id="c09ef8a7-c75f-4c75-bb73-e4fe9384c935">
        <updating/>
        <source>utlUpdateTIToDoTaskCmpltGTE(_toDoTaskDesc : CM_ToDoTaskDesc;
							_allTIs : CM_TISet input;
							_pxyGTE : CMGTE_Receival;
							_resourceUsageProxys : CM_ResourceTypeUsageSet input;
							_passport : CM_Passport input) updating;
/*

Purpose:			Complete weighed todo task from Gate Receival

Parameters:			_toDoTaskDesc todo task to be done; _pxyTI tracked item being gated; 
					_pxyGTE gate receival object ti is being updated with

Return Value:		

Date				Who		Reason
19 February 2019	jlgzm1	TFS43262 Creating 'Weighed' transactions before finishing gateing

*/
vars

	ti 		: CM_TrackedItem;
	
begin

	app.setContinueCMExceptions(false);
	
	if _allTIs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "_allTIs set", null, null);
	endif;
	
	if _pxyGTE = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "_pxyGTE", null, null);
	endif;
	
	if _toDoTaskDesc.description = null then
		app.raiseCMException1(ERR_TODOTASK_ADD, 'Task has a null description (' &amp; _toDoTaskDesc.description &amp; '). This operation cannot proceed.', null, null);
	endif;
	
	app.setContinueCMExceptions(true);
	
	foreach ti in _allTIs do
		ti.completeToDoTaskForBulkGTE(_toDoTaskDesc, _pxyGTE, _resourceUsageProxys, _passport);
	endforeach;

end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_allTIs" type="CM_TISet" usage="input"/>
        <Parameter name="_pxyGTE" type="CMGTE_Receival"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIToDoTaskComplete" id="152d130f-1d6e-49ac-b166-c798f7cc208c">
