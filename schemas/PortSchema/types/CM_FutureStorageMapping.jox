    <JadeMethod name="setStorageDetail" id="3df953a0-32cb-4590-a110-a97c1296059d">
        <updating/>
        <source>setStorageDetail(_detail : CM_StorageDetail) updating;
// 37434
vars

	removedFromDetail : CM_StorageDetail;
	addedToDetail : CM_StorageDetail;
	auditText : String;
	beforeAuditText : String;
	afterAuditText : String;
	tempColl : CM_FutureStorageMappingDict;

begin

		//19 May 2016	NDL	TFS 1981
	if not self.isTransient then
		if self.myStorageDetail &lt;&gt; _detail then
			//we are changing it, and we are not a transient
			if self.myStorageDetail &lt;&gt; null and not self.myStorageDetail.isTransient then
				removedFromDetail := self.myStorageDetail;
			elseif _detail &lt;&gt; null and not _detail.isTransient then
				addedToDetail := _detail;
			endif;
		
			if removedFromDetail &lt;&gt; null then
				create tempColl transient;
				removedFromDetail.allFutureStorageMappings.copy(tempColl);
				auditText := tempColl.getStorageDetailAuditText();
				beforeAuditText := "allFutureStorageMappings" &amp; AuditStringSeparator &amp; auditText.length.String &amp; AuditStringSeparator &amp;  auditText &amp; AuditStringSeparator;
				tempColl.remove(self);
				auditText := tempColl.getStorageDetailAuditText();
				afterAuditText := "allFutureStorageMappings" &amp; AuditStringSeparator &amp; auditText.length.String &amp; AuditStringSeparator &amp;  auditText &amp; AuditStringSeparator;
				app.myAA.auditUpdateTrx(removedFromDetail, beforeAuditText, afterAuditText);
				delete tempColl;
			endif;
			
			if addedToDetail &lt;&gt; null then
				create tempColl transient;
				addedToDetail.allFutureStorageMappings.copy(tempColl);
				auditText := tempColl.getStorageDetailAuditText();
				beforeAuditText := "allFutureStorageMappings" &amp; AuditStringSeparator &amp; auditText.length.String &amp; AuditStringSeparator &amp;  auditText &amp; AuditStringSeparator;
				tempColl.add(self);
				auditText := tempColl.getStorageDetailAuditText();
				afterAuditText := "allFutureStorageMappings" &amp; AuditStringSeparator &amp; auditText.length.String &amp; AuditStringSeparator &amp;  auditText &amp; AuditStringSeparator;
				app.myAA.auditUpdateTrx(addedToDetail, beforeAuditText, afterAuditText);
				delete tempColl;
			endif;
			
		endif;
	
	endif;
	
	self.myStorageDetail := _detail;

epilog
	delete tempColl;
end;
</source>
        <Parameter name="_detail" type="CM_StorageDetail"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="3a4c10bb-92cf-4e32-8ca7-2a1408083fb4">
        <source>validateForCreate();
// 28 May 2013	cnwjre1	CCMS DPH 2278 Storage Billing by Teminal Area
begin

// NO LONGER USED		if self.myInvoiceLineType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Invoice Line Type", null, null);
// NO LONGER USED			app.raiseCMException(Input_required_field_invLneTyp, null, null); // cnwdb2	PAR 35364
// NO LONGER USED		endif;

	if self.myStorageDetail = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Storage Detail", null, null);
		app.raiseCMException(Input_required_field_storDetai, null, null); // cnwdb2	PAR 35364


	endif;

	if self.myStorageGroup = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Storage Group", null, null);
		app.raiseCMException(Input_required_field_storGroup, null, null); // cnwdb2	PAR 35364


	endif;
	
	// duplicate check
	if self.myStorageDetail.allFutureStorageMappings[self.myStorageGroup] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, 'for Storage group ' &amp; self.myStorageGroup.code, null, null);
	endif;
end;
</source>
    </JadeMethod>
