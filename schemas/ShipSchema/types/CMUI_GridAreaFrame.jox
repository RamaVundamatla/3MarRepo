    <JadeMethod name="deleteAllBayFrames" id="85630a6e-5215-4dfd-87c7-acb260af6ffe">
        <source>deleteAllBayFrames();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2009	cnwer1	Initial creation

*/

vars
	bayFrame : CMUI_GridAreaFrame;
begin
	
	bayFrame:=self.getOndeckBayFrame;
	self.deleteBayFrame(bayFrame);

	
	bayFrame := self.getUnderdeckBayFrame ;
	self.deleteBayFrame(bayFrame);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteBayFrame" id="4952f2eb-f297-44d4-971c-88f2c0b382d5">
        <source>deleteBayFrame(_bayFrame : CMUI_GridAreaFrame io );
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 May 2009	cnwer1	Initial creation

*/

vars
	cmuiGridArea : CMUI_GridArea;
begin
	if _bayFrame &lt;&gt; null then
		if _bayFrame.myGridArea &lt;&gt; null then
			cmuiGridArea:=_bayFrame.myGridArea;
			_bayFrame.myGridArea.myHLabelsFrame.clearGraphics();
		endif;
		delete cmuiGridArea;
		delete	_bayFrame;
	endif;
epilog

end;</source>
        <Parameter name="_bayFrame" type="CMUI_GridAreaFrame" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doDrawBay" id="d5b96532-2e8f-4bd9-aacb-f5300cebf442">
        <source>doDrawBay(	_bay : CM_Bay;
			_scrollDrawFrame : CMUI_ScrollableDrawingFrame input;
			_zoomFactor : Integer; 
			_frmLegend : Frame input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 May 2009	cnwer1	Initial creation

*/

vars

	bayAreaAboveDeck : SHP_BayAreaAboveDeck;
	bayAreaBelowDeck : SHP_BayAreaBelowDeck;
	theString : CM_String;
	bayFrame,bayFrameUD	: CMUI_GridAreaFrame;
	scrollDrawFrame : CMUI_ScrollableDrawingFrame;
begin


	
	
	scrollDrawFrame:=_scrollDrawFrame;
	// clear these out cos we are only looking at one area at a time and they all have column =  and row = 1
	app.mousePointer := Window.MousePointer_HourGlass;
	
	
	if _bay= null then
		scrollDrawFrame.visible := false;
		return;
	else
		scrollDrawFrame.visible := true;
	endif;

	scrollDrawFrame.clearAllSelectedPoints();
	scrollDrawFrame.myDrawingFrame.bubbleHelp := "Hatch Lids";
	scrollDrawFrame.allGridAreasByColumnRow.clear;
	scrollDrawFrame.allGridAreasByRowColumn.clear;
		
	self.deleteAllBayFrames();


	// ######################
	// ABOVE DECK
	bayFrame := self.loadControl(ONDECK).CMUI_GridAreaFrame;
	bayFrame.caption := null;
	create bayAreaAboveDeck as SHP_BayAreaAboveDeck transient;
	// there is only one at a time here so the col and row are one
	bayAreaAboveDeck.setForCreate(_bay,1,ONDECK, ShpDisplayMode_Defn);
	scrollDrawFrame.addGridAreaAndFrame(bayAreaAboveDeck, bayFrame);
	bayAreaAboveDeck.myGridAreaFrame := bayFrame;
	bayAreaAboveDeck.myForm := self.form.CM_BaseForm;
	bayAreaAboveDeck.setZoomFactorTo(_zoomFactor);
	
	// ######################
	// BELOW DECK
	bayFrameUD := self.loadControl(UNDERDECK).CMUI_GridAreaFrame;
	bayFrameUD.caption := null;

	create bayAreaBelowDeck as SHP_BayAreaBelowDeck transient;
	// there is only one at a time here so the col and row are one
	bayAreaBelowDeck.setForCreate(_bay,1,UNDERDECK, ShpDisplayMode_Defn);
	scrollDrawFrame.addGridAreaAndFrame(bayAreaBelowDeck, bayFrameUD);
	bayAreaBelowDeck.myForm := self.form.CM_BaseForm;
	bayAreaBelowDeck.setZoomFactorTo(_zoomFactor);

	scrollDrawFrame.drawSelf();

	if _frmLegend  &lt;&gt; null then
		// ########################
		// DRAW THE LEGEND
		// merge the attributes used on the 2 frames into the top frames and print the legend
		if bayFrame &lt;&gt; null then
			if bayFrameUD &lt;&gt; null then
				foreach theString in bayFrameUD.myGridArea.SHP_BayArea.allAttributesUsed do
					if not global.isValidObject(theString) then
						continue;
					endif;
					if bayFrame.myGridArea.SHP_BayArea.allAttributesUsed[theString.string] = null then
						bayFrame.myGridArea.SHP_BayArea.allAttributesUsed.add(theString);
					endif;
				endforeach;
			endif;	
			bayFrame.myGridArea.SHP_BayArea.displayAttributeLegend(_frmLegend);
		endif;
	endif;

epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_scrollDrawFrame" type="CMUI_ScrollableDrawingFrame" usage="input"/>
        <Parameter name="_zoomFactor" type="Integer"/>
        <Parameter name="_frmLegend" type="Frame" usage="input"/>
    </JadeMethod>
