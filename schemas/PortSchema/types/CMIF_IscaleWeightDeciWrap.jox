<Class name="CMIF_IscaleWeightDeciWrap" id="e2f48a26-cf8c-44e4-9f98-b6dceec744d5">
    <superclass name="CMIF_DotNetWrap"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="myWeightDeciVonversion" id="4d03e9c2-f090-4dd8-bb96-f79e61311c04">
        <embedded/>
        <type name="WeightDeciConversion"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="convertDeciFunction" id="fd4dc28d-7ddf-429d-abe4-b8fcf06e64b4">
        <source>convertDeciFunction(_weightDeci : Decimal; _weightStringData: StringUtf8 output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 October 2016	cnwrh7	Initial creation

*/

vars
	hadException : Boolean;
begin
	if self.myWeightDeciVonversion = null then
		app.writeLog(method.qualifiedName &amp; " myWeightDataConvertion is null", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return false;
	endif;
	
	on Exception do self.handleExceptions(exception, hadException);
	
	if not hadException then
		_weightStringData := self.myWeightDeciVonversion.deciConvertFunction(_weightDeci);
		
		app.writeLog(method.qualifiedName &amp; " result=" &amp;
					   "|" &amp; _weightStringData.String &amp; "|", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return true;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " no weight data", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	return false;
	
epilog
	
end;</source>
        <Parameter name="_weightDeci" type="Decimal"/>
        <Parameter name="_weightStringData" type="StringUtf8" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="d334eaab-4894-41f1-94f8-15a04c5eb9de">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2016	cnwrh7	Initial creation

*/

vars
	hadException	: Boolean;
	fileName		: String;
	iniValue		: String;
	usePresentation	: Boolean;
begin
	on Exception do self.handleExceptions(exception, hadException);
	create self.myWeightDeciVonversion transient;
	if self.myWeightDeciVonversion &lt;&gt; null then
		self.myWeightDeciVonversion.usePresentationClient := self.usePresentationClient;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="1fa33df6-71fb-404f-8c12-41210289e6a4">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 October 2016	cnwrh7	Initial creation

*/

vars

begin
	delete self.myWeightDeciVonversion;
epilog

end;</source>
    </JadeMethod>
</Class>
