    <JadeMethod name="setUseSDSSecondary" id="60a066c9-65a1-401d-84d0-9d5afc35ecfc">
        <updating/>
        <source>setUseSDSSecondary(_value: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.useSDSSecondary &lt;&gt; _value then
		self.useSDSSecondary := _value;
	endif;
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="startBackupServerApp" id="daece48f-879a-4dd8-b0df-48180de8102a">
        <executionLocation>server</executionLocation>
        <source>startBackupServerApp() serverExecution;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	app.startApplication('JACBackup', JACBackupServerAppName);
end;</source>
    </JadeMethod>
    <JadeMethod name="stopBackupServerApp" id="76f584d9-2e30-4f9c-b84d-66c47b0b25c0">
        <source>stopBackupServerApp();
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' causeEvent NotifyBackupServerDoTerminate='&amp;NotifyBackupServerDoTerminate.String, LogDebug);
	self.causeEvent(NotifyBackupServerDoTerminate, true, null);
end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="fa18fe55-dc96-451f-b5b4-38f7d5d66253">
        <updating/>
        <source>timerEvent(_eventTag : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars
	sched: JACBackupSchedule;
	command, message: String;
	result, dummy: Integer;
	args: StringArray;
	nod: Node;
	pro: Process;
	newPro: Process;
	contApp, splitApp: Boolean;
	restartTime: Integer;
	today: Date;
	objArray: ObjectArray;
	object: Object;
	tempTS: TimeStamp;
begin

	restartTime := 15000;	//15secs
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' eventTag='&amp;_eventTag.String, LogDebug);

	on Exception do backupException(exception);

	if _eventTag = Timer_CheckEvent then

		// Check for timed events
		if self.jacBackupScheduleObjects.size &gt; 0 then

			// Make sure no backup is already activated 
			sched := self.jacBackupScheduleObjects.getAtKeyGeq(JACBackupActivated, null);
			if sched = null or 
			   sched.status &lt;&gt; JACBackupActivated then

				// None activated - look for running and make sure they're still going
				sched := self.jacBackupScheduleObjects.getAtKeyGeq(JACBackupRunning, null);

				
				if sched &lt;&gt; null and 
				   sched.status = JACBackupRunning then
					if app.isSDSSecondaryBackup then
						app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifyIsBackupRunning='&amp;NotifyIsBackupRunning.String, LogDebug);
						beginTransaction;
						self.sdsCauseEvent(NotifyIsBackupRunning, false, sched);
						commitTransaction;
						app.myDBA.closeCurrentJournal();
						restartTime := 300000;	//300secs 5min //par26646 cnwrs1 29 Dec 2010
					else
						self.isBackupRunning(sched);
					endif;
					return;
				endif;

				// Look for the next scheduled one
				sched := self.jacBackupScheduleObjects.getAtKeyGeq(JACBackupScheduled, null);
				//if there are no scheduled tasks look for a failed task
				if sched = null then
					sched := self.jacBackupScheduleObjects.getAtKeyGeq(JACBackupFailed, null);
				endif;

				
				if sched &lt;&gt; null and 
				   sched.status = JACBackupScheduled and
				   sched.startTS &lt; app.actualTimeServer then// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support

					// We need to run this one - create the external process. Can't be done direct as we are a non-gui
					// server app and cannot activate any app with GUI
					beginTransaction;
					sched.setStatus(JACBackupActivated);
					sched.setActualStartTS(app.actualTimeServer);// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
					commitTransaction;
					if app.isSDSSecondaryBackup then
						app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifyBackupControlApp='&amp;NotifyBackupControlApp.String&amp;" sched= "&amp;sched.String, LogDebug);
						beginTransaction;
						self.sdsCauseEvent(NotifyBackupControlApp, false, sched);
						commitTransaction;
						app.myDBA.closeCurrentJournal();
					else
						app.writeLog(class.name&amp;'::'&amp;method.name&amp;' causeEvent NotifyBackupControlApp='&amp;NotifyBackupControlApp.String&amp;" sched= "&amp;sched.String, LogDebug);
						self.causeEvent(NotifyBackupControlApp, true, sched);
					endif;
					return;
				endif;
			endif;
			// there are scheduled entries 
			if self.purgeLogDays &gt; 0 then
				//find and remove any old completed backup entries
				create objArray transient;
				foreach sched in self.jacBackupScheduleObjects do
//					if (sched.status = JACBackupComplete or
//					    sched.status = JACBackupAborted or
//					    sched.status = JACBackupFailed) and
					// rs nov 2005 to stop deleting all schedules
					if sched.status = JACBackupComplete and
					   sched.startTS.Date + purgeLogDays &lt; today then
						objArray.add(sched);
					endif;
				endforeach;
				sched := null; //rs nov 2005 just in case 
				if objArray.size &gt; 0 then
					beginTransaction;
					foreach object in objArray do
						delete object;
					endforeach;
					commitTransaction;
				endif;
				delete objArray;
			endif;				
			sched := self.jacBackupScheduleObjects.getAtKeyGeq(JACBackupActivated, null);
			if sched &lt;&gt; null then	//rs nov 2005 may not be a current sched waiting 
				tempTS := sched.actualStartTS.jacBackupAddHours(0, 3);
			endif;
			if sched &lt;&gt; null and 
			   sched.status = JACBackupActivated and
			   app.actualTimeServer &gt; tempTS then// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				message := sched.finalMessage &amp; CrLf &amp; 
					"JACBackupControApp has failed to start actual backup." &amp; CrLf &amp;
					"Backup has not completed.";
				app.writeLog(class.name&amp;'::'&amp;method.name&amp;message, LogDebug);
				beginTransaction;
				sched.setStatus(JACBackupFailed);
				sched.setFinalMessage(message);
				commitTransaction;
				sched.backupFinished;
			endif;
		endif;
	endif;
epilog
	if args &lt;&gt; null then
		delete args;
	endif;
	if _eventTag = Timer_CheckEvent then
		self.beginTimer(restartTime, Timer_OneShot, Timer_CheckEvent);
	endif;
	delete objArray;		// PAR #27874
end;</source>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="6d8efc28-eb52-4b0f-8519-0b8be9663e23">
        <updating/>
        <source>userNotification(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
//	dba: JadeDatabaseAdmin;	
	ver: Integer;
	result, out: Integer;
	fileNode: FileNode;
	folder: FileFolder;
	file: File;
	today: Date;
	args: StringArray;
	sched: JACBackupSchedule;
	aProcess: Process;
	smtp: CnSmtpConnection;
	message: String;
	nod: Node;
	pro: Process;
	contApp, splitApp: Boolean;
	exObj: Exception;
begin
	// Arm an exception handler to trap log file backup overwrite 
	on Exception do backupException(exception);

	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' eventType ='&amp;_eventType.String&amp;' userInfo ='&amp;_userInfo.String, LogDebug);
	// Check for LogTransferEvent notifications
	if _eventType = JadeDatabaseAdmin.LogTransferEvent then
		// check that the lognumbers are sequencual
		if _userInfo.Integer = (self.logNumber + 1) or
		   self.logNumber = 0 then
		else
			// process logfile we didnt get notifications for before we process
			// the log file this notification is for
			while (_userInfo.Integer &gt; (self.logNumber + 1)) do
				self.handleLogTransfer(self.logNumber + 1);
			endwhile; 
		endif;

		self.handleLogTransfer(_userInfo.Integer);
		return;
	// Check for internal server notifications &amp; process
	elseif _eventType = NotifyBackupServerDoTerminate then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Backup Server terminating', LogAlways);
		sched := self.jacBackupScheduleObjects.getAtKeyGeq(JACBackupRunning, null);
		if sched &lt;&gt; null and 
		   sched.status = JACBackupRunning then
			app.myDBA.abortBackup;
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' DBA Backup aborted', LogDebug);
			if app.isSDSSecondaryBackup then
				if app.isSDSSecondaryDB then
					sched.setStatusNotify(JACBackupAborted);
					message := "Backup Aborted.";
					sched.setFinalMessageNotify(message);
					sched.backupFinishedNotify;
				endif;
			else
				beginTransaction;
				sched.setStatus(JACBackupAborted);
				message := "Backup Aborted.";
				sched.setFinalMessage(message);
				commitTransaction;
				sched.backupFinished;
			endif;
		endif;
		//give it time to process the notifies from the controller app before dying
		self.causeEvent(NotifyTerminate, true, null);
	elseif _eventType = NotifySecServerAppStarted then
		self.setSecondarySDSIsAlive(true);
	elseif _eventType = NotifySecServerAppStopped then
		self.setSecondarySDSIsAlive(false);
	elseif _eventType = NotifySecServerAppRunning then
		if app.isSDSSecondaryDB then
			// secondary has got query from primary so return it
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifySecServerAppRunning='&amp;NotifySecServerAppRunning.String, LogDebug);
			self.sdsCauseEvent(NotifySecServerAppRunning, true, null);
		else
			// primary has go above query back from secondary so flag as running
			self.setSecondarySDSIsAlive(true);
		endif;
	elseif _eventType = NotifyBackupAbort then
		app.myDBA.abortBackup;
	elseif _eventType = NotifyIsBackupRunning then
		// Check the appropriate app is still running by looking through the
		// systems nodes for an app of the correct name.
		sched := _userInfo.JACBackupSchedule;
		self.isBackupRunning(sched);
	elseif _eventType = NotifyBackupFinished then
		sched := _theObject.JACBackupSchedule;
		if sched &lt;&gt; null and //rs nov 2005 just in case
		   global.isValidObject(sched) then
			sched.backupFinished();
		else
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;" Received a "&amp;_eventType.String&amp;" event for a schedule entry that no longer exists. "&amp;sched.String, LogAlways);	
		endif;
		return;
	elseif _eventType = NotifyBackupControlApp then
		if app.isSDSSecondaryBackup and
		   not app.isSDSSecondaryDB then
			// if they want the backup done by the secondary and
			// we are the primary do nothing
		else
			if app.jacIsAppRunning(JACBackupControlAppName) then
				app.writeLog(class.name&amp;'::'&amp;method.name&amp;" Backup control application start and another backing already running.", LogAlways);	
				terminate;
			endif;
			sched := _userInfo.JACBackupSchedule;
			if sched &lt;&gt; null and //rs nov 2005 just in case
			   global.isValidObject(sched) then
				aProcess := app.startApplication(currentSchema.name, JACBackupControlAppName);
				if aProcess = null then
					app.writeLog("ERROR: Something is wrong with start application - Initiate Failed!!", LogAlways);
					sched.setStatusNotify(JACBackupFailed);
					sched.setFinalMessageNotify("Internal Error " &amp; CrLf &amp; "Could not start JAC Backup control app.");
				endif;
			else
				app.writeLog(class.name&amp;'::'&amp;method.name&amp;" Received a "&amp;_eventType.String&amp;" event for a schedule entry that no longer exists. "&amp;sched.String, LogAlways);	
			endif;
		endif;
		return;
	elseif _eventType = NotifySetStatus then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;'Setting status to '&amp;_userInfo.String, LogDebug);
		sched := _theObject.JACBackupSchedule;
		if sched &lt;&gt; null and //rs nov 2005 just in case
		   global.isValidObject(sched) then
			beginTransaction;
			sched.setStatus(_userInfo.String);
			commitTransaction;
		else
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;" Received a "&amp;_eventType.String&amp;" event for a schedule entry that no longer exists. "&amp;sched.String, LogAlways);	
		endif;
		return;
	elseif _eventType = NotifyRunOnSecondary then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;'Setting RunOnSecondary to '&amp;_userInfo.String, LogDebug);
		sched := _theObject.JACBackupSchedule;
		if sched &lt;&gt; null and //rs nov 2005 just in case
		   global.isValidObject(sched) then
			beginTransaction;
			sched.setRunOnSecondary(_userInfo.Boolean);
			commitTransaction;
		else
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;" Received a "&amp;_eventType.String&amp;" event for a schedule entry that no longer exists. "&amp;sched.String, LogAlways);	
		endif;
		return;
	elseif _eventType = NotifySetFinalMessage then
		sched := _theObject.JACBackupSchedule;
		if sched &lt;&gt; null and //rs nov 2005 just in case
		   global.isValidObject(sched) then
			beginTransaction;
			sched.setFinalMessage(_userInfo.String);
			commitTransaction;
		else
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;" Received a "&amp;_eventType.String&amp;" event for a schedule entry that no longer exists. "&amp;sched.String, LogAlways);	
		endif;
		return;
	elseif _eventType = NotifyTerminate then
		self.endNotificationForSubscriber(self);
		terminate;
	elseif _eventType = CnSmtpConnection.Completion_Event_Type then
		smtp := _theObject.CnSmtpConnection;
		if smtp = null then	//rs nov 2005 just in case
			app.writeLog(class.name&amp;"::"&amp;method.name&amp;" SMTP server invalid email message failed.", LogNormal);
			return;
		endif;	
		if smtp.result &lt;&gt; null then
			app.writeLog(class.name&amp;"::"&amp;method.name&amp;" Email Message failed with error="&amp;smtp.extendedErrorText&amp;" Error", LogAlways);
		else
			app.writeLog(class.name&amp;"::"&amp;method.name&amp;" Email Message sent OK", LogNormal);
		endif;
		delete smtp;
	else
		app.logUnhandledNotification(class.name, method.name, _eventType, _eventTag, _userInfo);
	endif;

epilog
	delete folder;
	if args &lt;&gt; null then
		delete args;
	endif;
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
</Class>
