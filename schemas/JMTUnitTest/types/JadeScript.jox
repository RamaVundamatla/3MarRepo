    <JadeMethod name="testOvernightRunScript" id="76bbb9a3-9cd3-492c-918c-cd56b9fd0005">
        <source>testOvernightRunScript();

/*

Purpose:		Script to run and over night run			

Parameters:			

				[class=&lt;className&gt;]				&lt;className&gt; = Class to run e.g. UT_DSL (run all tests), UT_EDI (run all EDI tests)
				[method=&lt;methodName&gt;] 			&lt;methodName&gt; = Method name within specified class.  e.g. tBOLCriteria (will run UT_AutoPlanIn::tBOLCriteria only)
				[profile=&lt;profileName&gt;] 		&lt;profileName&gt; = Profile name you want to run against.  Normally UnitTest.  If blank then defaults to UnitTest
				[schedule=&lt;scheduleName&gt;] 		&lt;scehduleName&gt; = Schedule / Category name you want to run tests for.  e.g. SCHEDULE_Weekly (Runs only those test that have been mark
																as belonging to the SCHEDULE_Weekly run)
				[sendEmail] 					Will send various emails to the user.  Admin - Summary, User Summary and User Summary Ignore.  Non Admin - Their failing tests
				[checkLeaks] 					Checks for transient leaks when tests run.  Should always be there.
				[logResult]						Stores what methods the test runs.  This can considerably increase the time it takes for the tests to run.
				[disableOvernightSave]			Disables the storing of the over night run details


Date			Who		Reason
20/11/2011		cnwmh5	Initial creation

*/

vars

begin
	app.initialize();
	//app.main("class=UT_DSL profile=UnitTest checkLeaks sendEmail disableOvernightSave");
	///app.main("class=UT_OOW checkLeaks profile=UnitTest disableOvernightSave");
	//app.main("class=UT_AutoPlanOverstow profile=UnitTest sendEmail checkLeaks disableOvernightSave");
	//app.main("schedule=SCHEDULE_Weekly profile=UnitTest sendEmail checkLeaks disableOvernightSave");
	//app.main("class=UT_EDI profile=UnitTest checkLeaks disableOvernightSave");
	//app.main("class=UT_Gate method=tReceiveWithExtraReceivals profile=UnitTest checkLeaks sendEmail disableOvernightSave");
	//app.main("class=UT_DSL sendEmail profile=UnitTest");
	
	app.main("class=UT_OOW checkLeaks sendEmail profile=UnitTest ");
	
epilog
	terminate;
end;</source>
    </JadeMethod>
