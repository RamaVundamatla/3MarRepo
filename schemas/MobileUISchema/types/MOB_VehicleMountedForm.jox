    <JadeMethod name="showGFXFrames" id="42cb8873-91fd-406c-a4b2-6b3fe736ac42">
        <updating/>
        <source>showGFXFrames() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	cnwjk3	Initial creation

*/

vars

begin
	self.frmDrawing.visible := true;
	self.frmTI.visible := true;
	
	if  self.frmTopHLabels &lt;&gt; null then
		self.frmTopHLabels.visible := true; //22/09/2010 cnwdz2 25642
	endif;
	
	if  self.frmBottomHLabels &lt;&gt; null then
		self.frmBottomHLabels.visible := true;
	endif;
	
	if  self.frmLeftVLabels &lt;&gt; null then
		self.frmLeftVLabels.visible := true;
	endif;
	
	if  self.frmRightVLabels &lt;&gt; null then
		self.frmRightVLabels.visible := true;
	endif;
	
	if  self.frmTopLeftLabel &lt;&gt; null then
		self.frmTopLeftLabel.visible := true;
	endif;
	
	if  self.frmTopRightLabel &lt;&gt; null then
		self.frmTopRightLabel.visible := true;
	endif;
	
	if  self.frmBotmLeftLabel &lt;&gt; null then
		self.frmBotmLeftLabel.visible := true;
	endif;
	
	if  self.frmBotmRightLabl &lt;&gt; null then
		self.frmBotmRightLabl.visible := true;
	endif;
	
	self.frmViewport.visible:=true;
	self.btnGraphicView.visible := app.myVMAgent.getMyRTVehicleConfig.allAvailableGraphicViews.size &gt; 1;
	self.repositionButtons();
epilog

end;</source>
