    <JadeMethod name="doSave" id="2651f4e9-6df8-4de5-b8ec-5b7bb44062d6">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	theForm 					: SOP_TableMaintForm;
	tbl						    : CM_EntryTable;
	resourceTypesCol 			: CM_ResourceTypeDict;
	proxyResourceTypeGroup		: CM_ResourceTypeGroup;
	lCode,
	lDescription 				: String;
	lIsNotAvailableForEntry,
	rtnValue 					: Boolean;
	
begin
	theForm						:= self.myForm; 
	tbl							:= theForm.tblInput1;
	lCode						:= tbl.getValueByName(ETRow_Code).String[1:15];
	lDescription				:= tbl.getValueByName(ETRow_Description).String[1:40];
	lIsNotAvailableForEntry 	:= tbl.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_ResourceTypeGroup transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	create resourceTypesCol transient;
	theForm.mulSelect1.getSelected(resourceTypesCol);
	
	proxyResourceTypeGroup := theForm.myProxyObject.CM_ResourceTypeGroup;
	proxyResourceTypeGroup.setProxy(lCode, 
									lDescription, 
									lIsNotAvailableForEntry
									);
	proxyResourceTypeGroup.allResourceTypes.clear();
	resourceTypesCol.copyNoDups(proxyResourceTypeGroup.allResourceTypes);
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateResourceTypeGroup(proxyResourceTypeGroup, theForm.myCurrentObject, app.myPassport);
		rtnValue	:=	app.myPassport.trxCompletedOK;
		
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateResourceTypeGroup(proxyResourceTypeGroup, app.myPassport);
		rtnValue	:=	app.myPassport.trxCompletedOK;
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
		
	endif;
	
	return rtnValue;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
