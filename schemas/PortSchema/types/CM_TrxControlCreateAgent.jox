    <JadeMethod name="trxCreateEDIFileTypeUser" id="d92e5942-7f7f-442f-a3ef-b22a3b162583">
        <updating/>
        <source>trxCreateEDIFileTypeUser(_realFileTypeUser	: CM_EDIFileTypeUser io;
				     _pxyFileTypeUser		: CM_EDIFileTypeUser;
					 _passport				: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreateEDIFileTypeUser(_realFileTypeUser, _pxyFileTypeUser, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_realFileTypeUser" type="CM_EDIFileTypeUser" usage="io"/>
        <Parameter name="_pxyFileTypeUser" type="CM_EDIFileTypeUser"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDIIssue" id="e9c1162b-3e29-4a10-b440-25957ab5a390">
        <updating/>
        <source>trxCreateEDIIssue(_pxyObject : CM_EDIIssue; _realObject : CM_EDIIssue output; _passport : CM_Passport input) updating;
// ##### CR 64617 TASK 65065 NAVAB1 09JUL2024
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreateEDIIssue(_pxyObject, _realObject, _passport);
	
epilog
