    <JadeMethod name="tblReceivals_dragDrop" id="103a2758-869b-4d2b-abe5-e36332e28eb8">
        <controlMethod name="Table::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReceivals_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 27 June 2007
//
//----------------------------------------------------------------------

vars

begin
	if table.row &lt;= table.fixedRows then
		app.msgBox(app.getErrorString(OPS_Select_Entry_For_Drop),'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;
	if (win = self.tblReceivals) then	// dont allow drop from same table	PAR 7234
		return;
	endif;
	self.tblWorkEntryDrop(table, win, x, y);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblReceivals_keyDown" id="0ced9d40-2ba9-4b6b-921f-e42ca0bc09a7">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblReceivals_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 02 August 2007
//
//----------------------------------------------------------------------

vars

begin
	if table.userInputEnabled
	and table.row &gt; table.fixedRows
	and shift = 0
	and keyCode = J_key_Tab then
		self.origValueInteger := table.rows;
		//if at the end of the last row then a new row will be added
		self.doQueryRowColumnChange(table, table.row+1);
		if table.rows &gt; self.origValueInteger then
			//A new row has been added, reset key code
			//To prevent jade from re-setting the column
			keyCode := 0;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
