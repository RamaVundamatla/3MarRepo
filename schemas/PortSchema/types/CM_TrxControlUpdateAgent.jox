    <JadeMethod name="trxUpdateHSCodes" id="187e1267-4c59-445e-b10b-4a91a3f1e2bd">
        <updating/>
        <source>trxUpdateHSCodes(_proxyArray : CM_HarmonizedSystemArray; _purgeFirst : Boolean; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
08 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	pxyHS 	: CM_HarmonizedSystem;
	realHS 	: CM_HarmonizedSystem;
	cmifMonitor : CMIF_Monitor;
	size	: Integer;
	count	: Integer;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	size := _proxyArray.size;
	
	// Start the transaction
	beginTransaction;

	if _purgeFirst then
		app.myRoot.allHSSections.purge();
		// purging sections should delete everything else, but in case of 
		// orphaned objects, purge everything else as well
		app.myRoot.allHSChapters.purge();
		app.myRoot.allHSHeadings.purge();
		app.myRoot.allHSCodes.purge();
		app.myRoot.allHSSubCodes.purge();
		app.myRoot.allHSTaricCodes.purge(); //26/02/2023	navkc1 CR 59577 Task 62413
	endif;
	
	
	foreach pxyHS in _proxyArray do
		realHS := pxyHS.pxyGetRealObject();
		
		if realHS = null then
			app.myUtilityCA.utlCreateHarmonizedSystem(pxyHS, realHS, _passport);
		else
			app.myUtilityUA.utlUpdateHarmonizedSystem(pxyHS, _passport);
		endif;
	endforeach;
	
epilog
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_proxyArray" type="CM_HarmonizedSystemArray"/>
        <Parameter name="_purgeFirst" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
