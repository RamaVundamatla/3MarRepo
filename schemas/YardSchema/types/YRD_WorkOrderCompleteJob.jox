	endif;
	tbl := self.tblParent;
	tbl.setMyDataClass(CM_TrackedItem);
	
	tbl.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, tiSet, true);	// MTN 35316
	
epilog
	if not self.myJob.isKindOf(CM_WOUnpackJob) then
		delete tiSet;
	endif;
	//navra1 - TFS 63751/Task 63752 - 13th May 2024 - start
	if tbl.allTblDataObjDict&lt;&gt; null then
		tbl.allTblDataObjDict.purge();				
		delete tbl.allTblDataObjDict;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTblToDoResource" id="7cdc9128-aa85-46e0-a107-e54d8b88d3f2">
        <source>loadTblToDoResource();
/*
Purpose:			

Date		Who		Reason
14 March 2024	navab1	CR 62818 TASK 62821 
30 August	2024	navcs2	Bug 64746: EUP | VAS - Without adding resources for the mandatory resource group, able to complete the job in Thin Client
01 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	tbl 			: CM_DataTable;
	vasJob 			: CM_WOToDoTaskJob;
	todoDesc 		: CM_ToDoTaskDesc;
	todoResType 	: CM_ResourceType;
	resGrp 			: CM_ResourceTypeGroup;
	prvGrpStr, 
	grpStr 			: String;
	dynaDict 		: DynaDictionary;
	row 			: Integer;
	isMandatory, 
	grpMandatory 	: Boolean;			// 30 August	2024	navcs2	Bug 64746
	termCriteria 	: CM_TaskCriteria;
begin
	tbl := self.tblResources;
	vasJob := self.myJob.CM_WOToDoTaskJob;
	todoDesc := vasJob.myToDoTaskDesc;

	self.initTblResource();
	self.loadTableItems(self.tblToDo);
	
	create dynaDict transient;	
	dynaDict.setMembership(CM_ResourceType);
	dynaDict.addMemberKey(CM_ResourceType::myResourceTypeGroup.name, false, true);
	dynaDict.addMemberKey(CM_ResourceType::description.name, false, true);
	dynaDict.endKeys(true);

	todoDesc.allResourceTypes.copy(dynaDict);
	termCriteria := todoDesc.allTaskCriteria[self.myTerminal, todoDesc.code]; // ### JIRA 33435 10JAN2025 NAVAB1
	
	foreach todoResType in dynaDict as CM_ResourceType discreteLock do
		isMandatory :=  false;												// 30 August	2024	navcs2	Bug 64746
		
		grpStr := "N/A";
		resGrp := todoResType.myResourceTypeGroup;
		if resGrp &lt;&gt; null then
			// ### JIRA 33435 10JAN2025 NAVAB1
			if termCriteria &lt;&gt; null then
				if termCriteria.allAvailableResourceGroups[resGrp.code] = null then
					continue;
				endif;
			endif;
			if termCriteria.allMandatoryResourceGroups[resGrp.code] &lt;&gt; null then
				grpMandatory :=  true;
			endif;

			grpStr := resGrp.description;

		endif;	
		
		if prvGrpStr = null 
		or prvGrpStr &lt;&gt; grpStr then
			row := tbl.addItemObject(resGrp, grpStr &amp; Tab &amp; "" &amp; Tab &amp;  grpMandatory.getYes);// ### JIRA 33435 10JAN2025 NAVAB1
			tbl.accessRow(row).backColor := LightYellow;
			grpMandatory := false;
		endif;
		
		if todoResType.mandatory then// or todoResType.isGroupMandatory(todoDesc) then			// 30 August	2024	navcs2	Bug 64746
			isMandatory :=  true;														// 30 August	2024	navcs2	Bug 64746
		endif;																			// 30 August	2024	navcs2	Bug 64746
		
		row := tbl.addItemObject(todoResType, todoResType.description &amp; Tab &amp; grpStr &amp; Tab &amp; isMandatory.getYes);		// 30 August	2024	navcs2	Bug 64746
		// ### JIRA 33435 10JAN2025 NAVAB1 if todoResType.mandatory then
		if isMandatory then
			tbl.accessCell(row,3).backColor := LightRed;
		
		endif;
		
		
		prvGrpStr := grpStr;
		
	endforeach;
epilog
	delete dynaDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTblUnpacked" id="9ab53af6-758e-4d23-b246-94abbd49e749">
