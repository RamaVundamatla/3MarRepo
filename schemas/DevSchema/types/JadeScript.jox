	endforeach;
	file.writeLine(vvrPre2014Count.String &amp; " vehicle visit records prior to 2014, with " &amp; vvrPre2014DetailCount.String &amp; " detail records");
	file.writeLine(vvrPre2015Count.String &amp; " vehicle visit records prior to 2015, with " &amp; vvrPre2015DetailCount.String &amp; " detail records");
	file.writeLine(vvrPre2016Count.String &amp; " vehicle visit records prior to 2016, with " &amp; vvrPre2016DetailCount.String &amp; " detail records");
	*/
	/*
	progress := null;
	nbr := CM_Move.instances.size;
	write nbr.String &amp; " Move transactions to process";
	file.writeLine(nbr.String &amp; " Move transactions to process");
	foreach move in CM_Move.instances do
		progress := progress + 1;
		if progress mod 200000 = 0 then
			write progress.String &amp; " moves read";
		endif;
		
		// null voyage and null tracked item?
		if move.myTrackedItem = null and move.getMyVoyage = null and move.getPropertyValue(CM_Move::voyage.name) = null then
			moveNoVoyage := moveNoVoyage + 1;
		elseif not app.isValidObject(move.getPropertyValue(CM_Move::voyage.name).CM_Voyage) then
			moveInvalidVoyage := moveInvalidVoyage + 1;
		endif;
	endforeach;
	file.writeLine(moveNoVoyage.String &amp; " move transactions with no TI or voyage, with " &amp; moveInvalidVoyage.String &amp; " move transactions with invalid voyage");
	progress := null;
	*/
	/*
	nbr := CM_StateData.instances.size;
//	write nbr.String &amp; " State Data to process";
	file.writeLine(nbr.String &amp; " State Data to process");
	year := null;
	foreach stateData in CM_StateString.instances do
	//	progress := progress + 1;
	//	if progress mod 200000 = 0 then
	//		write progress.String &amp; " state Data read";
	//	endif;
		
		// check strings are all valid
	//	badString := false;
	//	handledEx := false;
	//	badStrings := null;
		
		if app.isValidObject(stateData) and	stateData &lt;&gt; null  then
		
		
		myParentCount := (stateData.myParent &lt;&gt; null).Integer;
		
