    <JadeMethod name="doTblDataDBClick" id="c090c548-eda3-4c2c-84b0-57f2ce9b2d05">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;

vars

begin
	inheritMethod(table);
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	if table.column &lt;= table.fixedColumns then
		return;
	endif;
	
	if table.row &gt; table.fixedRows then
		//self.myCurrentRateEntry := table.accessRow(table.row).itemObject.CM_RateEntry;
		self.setMyCurrentRateEntry( table.accessRow(table.row).itemObject.CM_RateEntry );	//17 Sep 2012	NDL	Par 30375
		if self.myCurrentRateEntry &lt;&gt; null then
			self.myCurrentRate := self.myCurrentRateEntry.rate;
			self.setEnableObjects();
			if self.btnEditItem.enabled then // PAR 13250
				self.doEditItem();
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataRowColChange" id="3b2ae946-d0f0-45b2-8f53-1725ec1b0c78">
        <updating/>
        <source>doTblDataRowColChange(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin


	inheritMethod(table);
	if table.row &gt; table.fixedRows then
		//self.myCurrentRateEntry := table.accessRow(table.row).itemObject.CM_RateEntry;
		self.setMyCurrentRateEntry( table.accessRow(table.row).itemObject.CM_RateEntry );	//17 Sep 2012	NDL	Par 30375
		if self.myCurrentRateEntry &lt;&gt; null then
			self.myCurrentRate := self.myCurrentRateEntry.rate;
		endif;
		
		self.displayExtraInfo();	//19 Sep 2012	NDL	Par 30375
		self.setEnableObjects();
		
		if self.frmRateEntry.visible then
			self.showRateDetailsFrame();
		endif;

	endif;
	
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDiskFileName" id="16207414-5c81-4373-8e99-5c6c3344ecc2">
        <updating/>
        <source>getDiskFileName(_fileName: String io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwrd1	Initial creation

*/

vars
	fileNameLength		: Integer;
	fileGet		 		: CMDFileSave;
//	fileName			: String;
begin
	create fileGet;
	fileGet.filter := '*.csv';
	fileGet.fileName := _fileName;
	fileGet.overwritePrompt := false;
	fileGet.pathMustExist := true;
	fileGet.validate := true;
	fileGet.defaultExt := "csv";
	if fileGet.open = 0 then	//user clicked OK
		fileGet.fileName.length;		
		_fileName := fileGet.fileName;
	endif;

epilog
	delete fileGet;
end;</source>
        <Parameter name="_fileName" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getRateForUpdate" id="5d18b61e-f396-448c-b2cd-6f57231bbd71">
        <updating/>
        <source>getRateForUpdate()  updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Chaneged On	By			Reason
// -----------	--------	--------------------------------------------------
// 28/03/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars
	re : CM_RateEntry;
	ra : CM_DebtorRate;
	ts : TimeStamp;
	newRate : Real;

begin
	if self.myCurrentRate &lt;&gt; null then
		return;
	endif;
	
	if self.modeDisplay = self.Mode_Debtor 
	and self.myCurrentDebtor &lt;&gt; null then
		self.myCurrentRate := self.myCurrentDebtor.serviceRates[self.myCurrentService];
		if self.myCurrentRate = null then
			create self.myCurrentRate as CM_DebtorRate transient;
			self.myCurrentRate.setProxy(self.myCurrentService, self.myCurrentDebtor);
		endif;
	elseif self.myCurrentLineGroupDebtor &lt;&gt; null then
		self.myCurrentRate := self.myCurrentLineGroupDebtor.serviceRates[self.myCurrentService];
		if self.myCurrentRate = null then
			create self.myCurrentRate as CM_LineGroupDebtorRate transient;
			self.myCurrentRate.setProxy(self.myCurrentService, self.myCurrentLineGroupDebtor);
		endif;
	elseif self.myCurrentVessel &lt;&gt; null then													// TFS 37794
		self.myCurrentRate := self.myCurrentVessel.allServiceRates[self.myCurrentService];		// TFS 37794
		if self.myCurrentRate = null then														// TFS 37794
			create self.myCurrentRate as CM_VesselRate transient;								// TFS 37794
			self.myCurrentRate.setProxy(self.myCurrentService, self.myCurrentVessel);			// TFS 37794
		endif;																					// TFS 37794
	elseif self.myCurrentVesselType &lt;&gt; null then													//07.06.2018 cnwma1 ChangeRequest #38953
		self.myCurrentRate := self.myCurrentVesselType.allServiceRates[self.myCurrentService];		
		if self.myCurrentRate = null then														
			create self.myCurrentRate as CM_VesselTypeRate transient;								
			self.myCurrentRate.setProxy(self.myCurrentService, self.myCurrentVesselType);			
		endif;
	elseif self.myCurrentVisitType &lt;&gt; null then													//07.06.2018 cnwma1 ChangeRequest #38953
		self.myCurrentRate := self.myCurrentVisitType.allServiceRates[self.myCurrentService];		
		if self.myCurrentRate = null then														
			create self.myCurrentRate as CM_VisitTypeRate transient;								
			self.myCurrentRate.setProxy(self.myCurrentService, self.myCurrentVisitType);			
		endif;	
	elseif self.myCurrentBerth &lt;&gt; null then													//07.06.2018 cnwma1 ChangeRequest #38953
		self.myCurrentRate := self.myCurrentBerth.allServiceRates[self.myCurrentService];		
		if self.myCurrentRate = null then														
			create self.myCurrentRate as CM_BerthRate transient;								
			self.myCurrentRate.setProxy(self.myCurrentService, self.myCurrentBerth);			
		endif;	
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="getRatesForReport" id="22ffa674-c2fe-4f72-98d9-dcc6bc1c1fa9">
        <source>getRatesForReport(_objArray : ObjectArray input; _selectedOnly : Boolean);
//----------------------------------------------------------------------
// Created by 	cnwjre1	Sept 2010 CCMS 1155 par 23583 Invoice rate reporting
vars
	re	: CM_RateEntry;
	dn	: CM_DebtorNode;
	oa,
	oa2 : ObjectArray;
	obj	: Object;
begin
	create oa transient;
	if _selectedOnly then
		foreach obj in self.tblData.allSelectedObjects do
			re := obj.CM_RateEntry;
			oa.clear;
			self.getReportableRates(re, self.myCurrentDebtor, oa);
			oa.copy(_objArray);
		endforeach;
	else
		create oa2 transient;
		self.tblData.getAllRowObjects(oa2);
		foreach obj in oa2 do
			re := obj.CM_RateEntry;
			oa.clear;
			self.getReportableRates(re, self.myCurrentDebtor, oa);
			oa.copy(_objArray);
		endforeach;
	endif;
	
epilog
	delete oa;
	delete oa2;
end;</source>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <Parameter name="_selectedOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getReportableRates" id="903fbacc-fde1-468f-8f7c-c42ddc1c3778">
        <source>getReportableRates(_rateEntry : CM_RateEntry; _debtor : CM_DebtorNode; _coll : ObjectArray input);
// Sept 2010 CCMS 1155 par 23583 Invoice rate reporting
vars
	service 		: CM_Service;
	company			: CM_Bank;
	rateNode		: CM_DebtorNode;
	tmpInvRateIF 	: CMIF_InvRateReporter;
	rate			: Real;
	costPerUnitLabels	: StringArray;
	costPerUnitLabel	: String;
	i				: Integer;
	decPlaces		: Integer;
	iter			: Iterator;
	calculationType : CM_CalculationType;	//29 Jun 2018	NDL	TFS 39338
	calcType : Integer;	//29 Jun 2018	NDL	TFS 39338
	subTerm : CM_SubTerminal;	//29 Jun 2018	NDL	TFS 39338
	tidalClass : HMS_TidalClass;	//29 Jun 2018	NDL	TFS 39338
begin
	if _rateEntry = null then
		return;
	endif;

	decPlaces := self.myTerminal.getConfig(FinancialRateDPlaces).Integer;
	service := _rateEntry.rate.service;
	company := service.bank;
	rate := _rateEntry.getDerivedCostPerUnit(self.effectiveDate.TimeStamp);
	if _rateEntry.rate.isKindOf(CM_DebtorRate) then
		rateNode := _rateEntry.rate.CM_DebtorRate.debtorNode;
	endif;
	
	create costPerUnitLabels transient;
	_rateEntry.getCostPerUnitLabels(costPerUnitLabels);
	
	//29 Jun 2018	NDL	TFS 39338
	if service &lt;&gt; null then
		calculationType := service.myCalculationType;
		if calculationType &lt;&gt; null then
			calcType := calculationType.calculationType;
		endif;
	endif;
	
	i := 1;
	iter	:=	costPerUnitLabels.createIterator();
	while iter.next(costPerUnitLabel) do	
			
		create tmpInvRateIF transient;
						
		if costPerUnitLabel = service.name then
			tmpInvRateIF.allUnitCost	:=	null;
		else
			tmpInvRateIF.allUnitCost :=	costPerUnitLabel;	// Non-null will indicate a multi-line rate.
		endif;
		
		if calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM then	//29 Jun 2018	NDL	TFS 39338
			subTerm := self.myTerminal.allSubTerminals.getMatchingDesc( costPerUnitLabel );
			tmpInvRateIF.costPerUnit :=	_rateEntry.getCPUforObject( subTerm ).asStringJMTWithPrecision(decPlaces, false);
			
		elseif calcType = INV_CALC_TYPE_TIDAL_CLASS then	//29 Jun 2018	NDL	TFS 39338
			tidalClass := app.myRoot.allTidalClasses.getMatchingDesc( costPerUnitLabel );
			tmpInvRateIF.costPerUnit :=	_rateEntry.getCPUforObject( tidalClass ).asStringJMTWithPrecision(decPlaces, false);
			
		else
			// some instances have an older rate in the array - use costPerUnit instead
			if i = 1 and costPerUnitLabels.size =  1 then
				tmpInvRateIF.costPerUnit	:=	rate.asStringJMTWithPrecision(decPlaces, false);
			else			
				if _rateEntry.allCostPerUnits.size &lt; i then 
					tmpInvRateIF.costPerUnit	:=	"0";
				else
					tmpInvRateIF.costPerUnit	:=	_rateEntry.allCostPerUnits[i].asStringJMTWithPrecision(decPlaces, false);
				endif;
			endif;
		
		endif;
			
		if rateNode.isKindOf(CM_Debtor) then
			tmpInvRateIF.debtorCode			:=	rateNode.CM_Debtor.decfinName;
			tmpInvRateIF.debtorGroup := 'D';
		else
			tmpInvRateIF.debtorGroup := 'G';
		endif;
					
		tmpInvRateIF.debtorName := rateNode.getListName;								
		tmpInvRateIF.debtorGroup := 'D';
		tmpInvRateIF.effectiveTimestamp := _rateEntry.startTimestamp; 
		tmpInvRateIF.expiryTimestamp := _rateEntry.expiryTimestamp;
		if service.genLCode &lt;&gt; null then
			tmpInvRateIF.glCode := service.genLCode.code;
		endif;
		tmpInvRateIF.myBank := company;
		tmpInvRateIF.myDebtor := rateNode;
		tmpInvRateIF.myService := service;
		tmpInvRateIF.overrideFlag := (rateNode = _debtor) and not _debtor.isRootDebtorGroup;
		tmpInvRateIF.serviceName := service.name;
		i := i + 1;
		
		_coll.add(tmpInvRateIF);
	endwhile;
epilog
	delete costPerUnitLabels;
	delete iter;
end;
</source>
        <Parameter name="_rateEntry" type="CM_RateEntry"/>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
        <Parameter name="_coll" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="haltProgress" id="6d32db5b-09cb-4fda-b146-6f2b374a37be">
        <source>haltProgress(pe : CM_ProgressException) : Integer;

vars

begin

	if app.msgBox(self.myCurrentBank.getMsgString(WARN_CANCEL_PROGRESS ,
										"",
										"",""),
										"Cancel Progress",
										MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then

		cmbDebtor.listIndex := -1;
		self.tblData.columns := 1;
		return Ex_Abort_Action;
	else
		return Ex_Continue;
	endif;

end;</source>
        <Parameter name="pe" type="CM_ProgressException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleCalcTypeView" id="ac292c20-8ca5-4885-b092-bd586dc024f4">
        <source>handleCalcTypeView();
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 28/03/2019	jlgdap1		TFS 43694 PEL1 Charging for Vessels that use a Ramp
vars
	aCT : CM_CalculationType;
	qtyRange	: CM_QuantityRange;
	tidalClass	: HMS_TidalClass;
	oa		: ObjectArray;
	obj		: Object;
	first,int, calcType : Integer;
	idx		: Integer;
	aCaption : String;
	table	: Table;
	subTerm : CM_SubTerminal;
	rowIndex : Integer;
begin
	table := self.tblCost;

	table.rows := 2;
	table.accessCell(2,1).text := "";
	if self.myCurrentService &lt;&gt; null  then
		aCT := self.myCurrentService.myCalculationType;
		if aCT &lt;&gt; null then
			if aCT.rateType = CM_CalculationType.RateTypeHMSMovementType then	//22 Mar 2019	NDL	TFS 43687
				self.initCostsTable();
				table.rows := 1;
				table.addItem( app.getMoveTypeDescription(HMSMovementTypeArrival) );
				table.addItem( app.getMoveTypeDescription(HMSMovementTypeDeparture) );
				table.addItem( app.getMoveTypeDescription(HMSMovementTypeShift) );
				self.initCostTableWidthByText(1);
				
			elseif aCT.rateType = CM_CalculationType.RateTypeRamp then		// TFS 43694
				self.initCostsTable();										// TFS 43694
				table.rows := 1;											// TFS 43694
				table.addItem(CM_Rate.RAMP_USED_STR);						// TFS 43694
				table.addItem(CM_Rate.RAMP_NOT_USED_STR);					// TFS 43694
				table.addItem(CM_Rate.RAMP_PENALTY_STR);					// TFS 43694
				self.initCostTableWidthByText(1);							// TFS 43694
				
			elseif aCT.isWorkOrderType then // TFS 39198 Voyage WORK ORDERS
					calcType := aCT.calculationType;
					if calcType = INV_CALC_TYPE_WO_PERMIT   then // TFS 39198
						self.initCostsTable();
						table.rows := 1;
						table.addItem(app.getErrorString(STR_WO_PERMIT_METMAL));
						table.addItem(app.getErrorString(STR_WO_PERMIT_CARPEN));
						table.addItem(app.getErrorString(STR_WO_PERMIT_CARNOPEN));
						// TFS 42221 these 2 continues are the wrong way around, The permit types are used as an index 
						// INV_WO_PERMIT_CONTINUNOPENALTY = 4
						// INV_WO_PERMIT_CONTINUEPENALTY = 5		
						// However these labels were 5 then 4 so the wrong values are entered on screen
						table.addItem(app.getErrorString(STR_WO_PERMIT_CONNOPEN));
						table.addItem(app.getErrorString(STR_WO_PERMIT_CONPEN)); // TFS 42221
						self.initCostTableWidthByText(1);
					endif;
			else
				if aCT.isCargoCalcType then
					self.initCostsTable();
					calcType := aCT.calculationType;
					if calcType = INV_CALC_TYPE_BUSHRSCARGOVALUE then // PAR 30681
						table.rows := 1;
						table.addItem(app.getErrorString(Normal_hrs_rate));
						table.addItem(app.getErrorString(Overtime_hrs_rate));
						table.addItem(app.getErrorString(Excluded_hrs_rate));
						
					//27 Jun 2018	NDL	TFS 39246
					elseif calcType = INV_CALC_TYPE_WO_EXTRA then	
						self.initCostsTable();
						table.rows := 1;
						table.addItem(app.getErrorString(STR_WO_PERMIT_METMAL));
						table.addItem(app.getErrorString(STR_WO_PERMIT_CARPEN));
						table.addItem(app.getErrorString(STR_WO_PERMIT_CARNOPEN));
						// TFS 42221 these 2 continues are the wrong way around, The permit types are used as an index 
						// INV_WO_PERMIT_CONTINUNOPENALTY = 4
						// INV_WO_PERMIT_CONTINUEPENALTY = 5		
						// However these labels were 5 then 4 so the wrong values are entered on screen
						table.addItem(app.getErrorString(STR_WO_PERMIT_CONNOPEN));
						table.addItem(app.getErrorString(STR_WO_PERMIT_CONPEN)); // TFS 42221
						self.initCostTableWidthByText(1);
					
					//28 Jun 2018	NDL	TFS 39338
					elseif calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM then
						self.initCostsTable();
						table.rows := 1;
						foreach subTerm in self.myTerminal.allSubTerminals do
							rowIndex := table.addItem( subTerm.description );
							table.accessCell( rowIndex, 1 ).itemObject := subTerm;
						endforeach;
						self.initCostTableWidthByText(1);
					
					endif;
					
				endif;
	
				if aCT.isVoyageCalcType then
					self.initCostsTable();
					calcType := aCT.calculationType;
					if calcType = INV_CALC_TYPE_RESOURCE_QTY then
						// only 1 cost per unit needed
					elseif calcType = INV_CALC_TYPE_TIMEBLCK_HRS then
						// only 1 cost per unit needed 
					elseif calcType = INV_CALC_TYPE_TIMEBLCK_HRS_UNT then
						// only 1 cost per unit needed
					elseif calcType = INV_CALC_TYPE_TIMEBLCK_HRS_ONE then
						// only 1 cost per unit needed
					elseif calcType = INV_CALC_TYPE_TIME_PERIOD_HRS then
						// only 1 cost per unit needed
					elseif calcType = INV_CALC_TYPE_TIME_PERIOD_HRMN   then // ### TFS CR 65326 TASK 65327 06AUG2024 NAVAB1
						// only 1 cost per unit needed
					elseif calcType = INV_CALC_TYPE_BUSINESS_HRS_QTY then
						table.rows := 1;
						table.addItem(app.getErrorString(Included_hrs_rate));// PAR 30681
						table.addItem(app.getErrorString(Excluded_hrs_rate));// PAR 30681
					elseif calcType = INV_CALC_TYPE_BUSHRSVESELVALUE  then // PAR 30681
						table.rows := 1;
						table.addItem(app.getErrorString(Normal_hrs_rate));
						table.addItem(app.getErrorString(Overtime_hrs_rate));
						table.addItem(app.getErrorString(Excluded_hrs_rate));
					elseif calcType = INV_CALC_TYPE_VESSEL_TON then
						// only 1 cost per unit needed
					elseif (calcType = INV_CALC_TYPE_VESSEL_TON_RANGE or calcType = INV_CALC_TYPE_VESSEL_TON_QTY1) then 
						table.rows := 1;
						first := 1;
						foreach int in aCT.integerRange1 do
							aCaption := first.String &amp; " - " &amp; int.String;
							table.addItem(aCaption);
							first := int + 1;
						endforeach;
					// 34489 Tidal Class, cost per tidal class, show tidal class alphabetically
		//01 Mar 2019	NDL	TFS 43139
		/*			elseif calcType = INV_CALC_TYPE_TIDAL_CLASS then 
						table.rows := 1;
						// sort tidal classes by description - see CM_RateEntry::getCostPerUnit for code to retrieve the tidal class rate
						create oa transient;
						app.sortTidalClasses(oa);
						foreach obj in oa do
							tidalClass := obj.HMS_TidalClass;
							if tidalClass.description = null then
								aCaption := tidalClass.code;
							else
								aCaption := tidalClass.description;
							endif;
							table.addItem(aCaption);
						endforeach; */
					
					//28 Jun 2018	NDL	TFS 39338
					elseif calcType = INV_CALC_TYPE_TIDAL_CLASS then
						self.initCostsTable();
						table.rows := 1;
						foreach tidalClass in app.myRoot.allTidalClasses do
							rowIndex := table.addItem( tidalClass.description );
							table.accessCell( rowIndex, 1 ).itemObject := tidalClass;
						endforeach;
						self.initCostTableWidthByText(1);
						
					endif;
				endif;
				//	CCMS SFW 1279 May 2012 Storage Escalating Charges
				if aCT.allQuantityRanges.size &gt; 0 then
					self.initCostsTable2(true);
					foreach qtyRange in aCT.allQuantityRanges do
						aCaption := qtyRange.getDisplay();
						idx := table.addItem(aCaption);
						// day increment rate can only be entered where there is a value
						if qtyRange.daysIncrement = 0 then
							table.accessCell(idx, 3).enabled := false;
							table.accessedCell.backColor := self.colorHeadingColumn;
						endif;
					endforeach;
				endif;
			endif;
		endif;
	endif;
epilog
	delete oa;
end;</source>
    </JadeMethod>
    <JadeMethod name="initCostTableWidthByText" id="342fa08b-cf0a-478d-8c8c-5d21d3afcc77">
        <source>initCostTableWidthByText(_col : Integer);
/*

Purpose:		TFS 39198	

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2018	jlgab1	Initial creation

*/

vars
	row, colWidth, colMax : Integer;
	text : String;
begin
	self.tblCost.accessColumn(_col);
	colMax := 0;
	foreach row in 1 to self.tblCost.rows do
	
		text := self.tblCost.getCellText(row, _col);
			colWidth := self.tblCost.getTextExtent(text);
			colMax := colMax.max(colWidth);
	endforeach;
	
	self.tblCost.accessedColumn.width := colMax + 15;
epilog

end;</source>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initCostsTable" id="65261097-0749-440e-966c-467a569d08d4">
        <source>initCostsTable();
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTable : CM_EntryTable;
	dpl : Integer;
begin
	dpl := self.getRateEntryDecimalPlaces; // TFS 36954 MPD 20 Feb 2018
	theTable := self.tblCost;
	// clear table first 
	theTable.rows := 0;
	theTable.columns := 0;

	theTable.columns:= 2;
	theTable.addItem("Cost Per Unit");
	theTable.rows := 9;
	theTable.fixedRows := 1;
	theTable.fixedColumns := 1;
	theTable.userInputEnabled := true;
//	theTable.accessColumn(2).inputType := Table.InputType_TextNumeric;
	theTable.accessColumn(2).inputType := Table.InputType_SignedNumeric;	//25 Sep 2018	NDL	TFS 40810
	//theTable.accessedColumn.decimals := $CM_RateEntry.decimalPlaces;
	//theTable.accessedColumn.maxLength := 7 + $CM_RateEntry.decimalPlaces; // this allows for 999,999. and then the number of decimal places
	theTable.accessedColumn.decimals := dpl; // TFS 36954 MPD 20 Feb 2018
	//theTable.accessedColumn.maxLength := 7 + dpl; // TFS 36954 MPD 20 Feb 2018
	theTable.accessedColumn.maxLength := 11 + dpl;	//10 May 2018	NDL	TFS 38528
	theTable.accessColumn(1).width := 100; 
	theTable.backColor := self.backColor;

	theTable.accessColumn(1).backColor := self.colorHeadingColumn;
	theTable.accessColumn(2).backColor 	:= self.colorValueColumn;
	theTable.accessRow(1).backColor 	:= self.colorHeadingColumn;

end;</source>
    </JadeMethod>
    <JadeMethod name="initCostsTable2" id="cc5a1887-b861-45c8-bb45-9725cc81ca3e">
        <source>initCostsTable2(_isEscalating : Boolean);
// ---------------------------------------------------------------------------
// Created:		
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTable : CM_EntryTable;
	dpl : Integer;
begin
	dpl := self.getRateEntryDecimalPlaces;	// TFS 36954 MPD 20 Feb 2018
	theTable := self.tblCost;
	// clear table first
	theTable.rows := 0;
	theTable.columns := 0;
	
	if _isEscalating then
		theTable.columns:= 3;
		//cnwrns1 21/08/2012 Changing from Cost per unit to cost per day ccms SFW 1289
		// the options rates and amounts are only visible when it isEscalating
		theTable.addItem("Cost Per Day" &amp; Tab &amp; "Base" &amp; Tab &amp; "Increment");
		self.frmOptions.top := self.chkIgnoreEntry.top + 20;
		self.frmOptions.visible := true;
	else
		theTable.addItem("Cost Per Unit");
		theTable.rows := 9;
		theTable.columns:= 2;
	endif;
	theTable.fixedRows := 1;
	theTable.fixedColumns := 1;
	theTable.userInputEnabled := true;
//	theTable.accessColumn(2).inputType := Table.InputType_TextNumeric;
	theTable.accessColumn(2).inputType := Table.InputType_SignedNumeric;	//25 Sep 2018	NDL	TFS 40810
	//theTable.accessedColumn.decimals := $CM_RateEntry.decimalPlaces;
	//theTable.accessedColumn.maxLength := 7 + $CM_RateEntry.decimalPlaces; // this allows for 999,999. and then the number of decimal places
	theTable.accessedColumn.decimals := dpl;			// TFS 36954 MPD 20 Feb 2018
//	theTable.accessedColumn.maxLength := 7 + dpl;		// TFS 36954 MPD 20 Feb 2018
	theTable.accessedColumn.maxLength := 11 + dpl;//10 May 2018	NDL	TFS 38528
	if _isEscalating then
		theTable.accessColumn(3).inputType := Table.InputType_TextBox;	// allow +- entry and '%'
		theTable.accessedColumn.maxLength := 13;
	endif;
	theTable.accessColumn(1).width := 165;
	theTable.accessColumn(2).width := 80;
	if _isEscalating then
		theTable.accessColumn(3).width := 80;
	endif;

	theTable.backColor := self.backColor;

	theTable.accessColumn(1).backColor := self.colorHeadingColumn;
	theTable.accessColumn(2).backColor 	:= self.colorValueColumn;
	if _isEscalating then
		theTable.accessColumn(3).backColor 	:= self.colorValueColumn;
	endif;
	theTable.accessRow(1).backColor 	:= self.colorHeadingColumn;

end;</source>
        <Parameter name="_isEscalating" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="12aba14f-7439-4671-abeb-504bc64971da">
        <source>initDataTable();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTable : CM_DataTable;
begin
	theTable := self.tblData;
	// from 23582 make tblData a proper ent table, do nothing here - already done in intTable earler
	theTable.zOrder(60);


end;</source>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="33797e80-ce39-4d64-a95a-5c976ca217c9">
        <updating/>
        <source>initQueryFrame() updating, protected;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 28/03/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars
begin
	self.initQueryFrameTrade();	
	self.initQueryFrameDebtor();
	self.initQueryFrameVessel();				// TSF 37794
	self.initQueryFrameVesselType();			//07.06.2018 cnwma1 ChangeRequest #38953
	self.initQueryFrameVisitType();				//07.06.2018 cnwma1 ChangeRequest #38953
	self.initQueryFrameBerth();				    //07.06.2018 cnwma1 ChangeRequest #38953
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initQueryFrameBerth" id="f51d7222-fd9e-4450-bc41-c4e69fec69a0">
        <updating/>
        <source>initQueryFrameBerth() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

