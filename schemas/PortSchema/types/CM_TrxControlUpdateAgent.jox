    <JadeMethod name="trxUpdateWorkOrderPPK" id="ba7d9e7b-7ae1-427b-996a-addf188d3d88">
        <updating/>
        <source>trxUpdateWorkOrderPPK(	_workOrder : CM_WorkOrderDtl input; 
						_ppkNumber : String;
						_approved :Boolean;
						_passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2018	jlger1	Initial creation

*/

vars
	voyage : CM_Voyage;
	movement : HMS_VoyageMovement;
	ppkNumber : String;
	workOrderDtl : CM_WorkOrderDtl;
	initialStatus : Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(true);
	
	voyage:=_workOrder.getMyVoyageObject;
	initialStatus:=voyage.status;
	beginTransaction;
	if _approved then
		ppkNumber:=_ppkNumber;
	endif;
	
	
	if  _workOrder.isKindOf(CM_WodMarineServicesInitial) then
		movement:= voyage.getMovementArrival();
	elseif _workOrder.isKindOf(CM_WodMarineServicesDepart) or _workOrder.isKindOf(CM_WodExtension) then
		movement:= voyage.getMovementDeparture();
	elseif _workOrder.isKindOf(CM_WodShiftMovement) then
		movement:= _workOrder.CM_WodShiftMovement.myHMSVoyageMovement; //epr TFS 43849 14/3/19
	endif;
	
	if movement &lt;&gt; null then
		movement.setInaportnetPPK(ppkNumber);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;

</source>
        <Parameter name="_workOrder" type="CM_WorkOrderDtl" usage="input"/>
        <Parameter name="_ppkNumber" type="String"/>
        <Parameter name="_approved" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWorkOrderSchedule" id="58293805-04ac-4097-8483-f8076fa61b3a">
        <updating/>
        <source>trxUpdateWorkOrderSchedule(_pxySchedule : CM_WorkOrderSchedule; _passport : CM_Passport input) updating;
// -----------------------------------------------------------------------------
// Created:		17 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	realSchedule	: CM_WorkOrderSchedule;
	expectedEdition	: Integer;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	_pxySchedule.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	
	beginTransaction;

	_pxySchedule.pxyGetRealObjectAndEdition(realSchedule, expectedEdition);
	if realSchedule = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WorkOrderSchedule.name, null, null);
		return;
	endif;
	
	reserveLock(realSchedule);
	
	if _passport.noErrors() and realSchedule.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "Work Order Schedule", null, null);
		return;
	endif;
	
	app.myUtilityUA.utlUpdateWorkOrderSchedule(_pxySchedule, realSchedule, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxySchedule" type="CM_WorkOrderSchedule"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWorkOrderTISource" id="259b038d-7ffe-4d72-946d-e1d82b6855cd">
        <updating/>
        <source>trxUpdateWorkOrderTISource(_pxySource : CM_WorkOrderTISource; _passport : CM_Passport input) updating;
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
