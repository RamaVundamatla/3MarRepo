<Class name="JadeScript">
    <JadeMethod name="clearAllData" id="b6d42f2d-e125-40e1-bfbb-b54ae404c1ee">
        <source>clearAllData();

vars
	objArray:CM_ObjectArray;
	object:Object;
begin
	create objArray transient;
	Yrk_Object.allInstances(objArray, 0, true);
	beginTransaction;
	foreach object in objArray do
		if not object.isKindOf(Yrk_Configuration) then
			object.Yrk_Object.erase(NORMAL_ERASE);
		endif;
	endforeach;
	commitTransaction;
epilog
	delete objArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="createData" id="3c1ccdac-bf37-488f-bef0-915c528191a3">
        <source>createData();

vars
	config:Yrk_Configuration;
	location:Yrk_Location;
	ti:Yrk_Container;
begin
	config := Yrk_Configuration.firstInstance;
	beginTransaction;
	if config = null then
		create config;
	endif;
	create location;
	location.setForUpdate("424-77-01-2","CARR");
	create ti;
	ti.setForUpdate("N","0","MSK","Y","RF","C","A","A","ABBA1111111","This is a remark",
	                86,20,4,
	                80,-20,-20,-20,-20,-20,-20,-20,8
	                ,config,"424-77-01-2");
	create ti;
	ti.setForUpdate("N","0","MSK","Y","RF","C","A","A","ABBA1111112","This is a remark",
	                86,20,4,
	                80,-20,-20,-20,-20,-20,-20,-20,8
	                ,config,"424-77-01-2");
	commitTransaction;
end;</source>
    </JadeMethod>
</Class>
