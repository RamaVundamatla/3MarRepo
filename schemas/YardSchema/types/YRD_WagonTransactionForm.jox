    <JadeMethod name="setupForm" id="a099fe7f-5bf5-4af6-9a6c-39bd83a18e2f">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.usesQueryFrame := false;

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.useTableSorting := true;
	self.useTableInfo := true;
	inheritMethod();

	self.setCaption(app.getErrorString(Wagon) &amp; " " &amp; app.getErrorString(Transaction));
	self.setNavigatorHeading(self.caption);
	self.initTableData(ETDef_WagonTrans);	
//	self.tblData.accessColumn(1).width := 130;
	self.mnuContextColourLegend.visible := false;
	self.tblData.autoSize := 2;
	self.tblData.stretch := 1;
	self.tblInfo.rows := 0;


	// ### SWITCH the tblData control into the folder.
	self.tblData.parent := self.shtTrans;
	self.tblData.move(0,0,self.fldMain.clientWidth, self.shtTrans.clientHeight);
	self.tblData.parentAspect := 3;
	self.splMain.setLeftControl(self.fldMain);
	self.btnInvoiceLine.enabled := false;//cnwas3

	self.doQuery();
end;</source>
    </JadeMethod>
    <JadeMethod name="showCharges" id="a8929c2b-76ba-4c31-8a27-41d45e2fb8e3">
        <source>showCharges() protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars
	tran : CM_EventTransaction;
	il : CM_InvoiceLine;
	lDetails : String;
	i,idx	: Integer;
begin
	tblCharges.rows := 0;
	tblCharges.columns := 6;
	
	tblCharges.addItemAt(app.getErrorString(DateStr) &amp; Tab &amp; app.getErrorString(Seq) &amp; Tab &amp; app.getErrorString(INV_Debtor) &amp; Tab &amp; app.getErrorString(Manual) &amp; Tab &amp; app.getErrorString(Qty) &amp; Tab &amp; app.getErrorString(CM_Narration), 1);
	tblCharges.fixedRows := 1;
	tblCharges.fixedColumns := 0;
	self.setColorsForTable(self.tblCharges);			
	tblCharges.accessColumn(1);
	tblCharges.sortColumn[1] := 1;
	tblCharges.sortAsc[1] := true;

	
	foreach tran in self.myCurrentWagon.allTransactions  discreteLock do
	
		if tran.allInvoiceLines.isEmpty then
			continue;
		endif;
		
		foreach il in tran.allInvoiceLines discreteLock do
			// Get Details - returns a TAB delimited string ready for the enquiry table
			//05 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			lDetails := self.systemToLocalTime(il.getChargeTime).shortCurrentLocaleFormat &amp; Tab &amp; il.sequenceNum.String &amp; Tab &amp; il.debtor.name &amp; Tab &amp; il.manual.String &amp; Tab &amp; il.quantity.String &amp; Tab &amp; il.invoiceLineDesc.narration ;
			// Add the row to the sheet
			idx := tblCharges.addItemObject(il,lDetails);
	
			if (idx mod 2 = 0) then
				tblCharges.accessRow(idx).backColor := self.colorRow1;
			else
				tblCharges.accessRow(idx).backColor := self.colorRow2;
			endif;
		endforeach;
	endforeach;

	self.shtCharges.caption := app.getErrorString(Charges) &amp; " (" &amp; (self.tblCharges.rows - self.tblCharges.fixedRows).Integer.String &amp; ")";
end;</source>
        <access>protected</access>
    </JadeMethod>
