    <JadeMethod name="doSave" id="924e598d-f847-47ef-afd0-59bea7066802">
        <updating/>
        <source>doSave(): Boolean updating;

vars
	errObj					: CM_Error;
	idx						: Integer;
	tmpListBox				: ListBox;
	isAvailableForEntry,
	ignoreWarnings,
	rtnValue				: Boolean;
	proxyOperatorGroup		: CM_OperatorGroup;
	code,groupDescription	: String;
	theForm 				: SOP_TableMaintForm;
	codeGroupsColl			: CM_CodeGroupsByTypeDict;
	obj						: Object;
	
begin

	theForm := self.myForm; 
	code := theForm.tblInput1.getValueByName(ETRow_Code).String;
	groupDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	isAvailableForEntry := theForm.tblInput1.getValueByName(ETRow_IsAvailableForEntry).Boolean;
	
	create codeGroupsColl transient;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_OperatorGroup transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	create codeGroupsColl transient;
	foreach obj in self.allSelectedVMObjects do
		if obj.isKindOf(SOPVM_CodeGroup) then //because it'll either be that or a SOPVM_CodeGroupType which we're not interested in
			if obj.SOPVM_CodeGroup.myObject &lt;&gt; null then
				codeGroupsColl.add(obj.SOPVM_CodeGroup.myObject.CM_CodeGroup);
			endif;
		endif;
	endforeach;

	proxyOperatorGroup := theForm.myProxyObject.CM_OperatorGroup;
	proxyOperatorGroup.setProxy(code, groupDescription, codeGroupsColl, isAvailableForEntry);
	proxyOperatorGroup.allOperators.clear();
	theForm.mulSelect1.getSelected(proxyOperatorGroup.allOperators);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateOperatorGroup(proxyOperatorGroup, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateOperatorGroup(proxyOperatorGroup,app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;
epilog
	delete codeGroupsColl;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
