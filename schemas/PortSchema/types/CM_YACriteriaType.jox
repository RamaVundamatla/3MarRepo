    <JadeMethod name="getDataDisplay" id="c7593858-36f6-4a4d-8f9c-3d08979c5467">
        <source>getDataDisplay(pDataObj:CM_YAData):String;
// ---------------------------------------------------------------------------
// Created:     07 March 2005 by cnwrs2
//
// Purpose:		Return a description of the Criteria Type, and its data value(s)
//				for display within a table control.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27/05/2025	navdap1		MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
// --------------------------------------------------------------------------------
begin
	if self.isBooleanType() or self.isStringType() or self.isDateRangeType() then	// MTN-34981
		return pDataObj.getDescription();
	elseif self.isTransportModeType() then
		return pDataObj.CM_YADataInteger.allValues.asCSV(false);
	else
		return null;
	endif;
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
