    <JadeMethod name="updateToDoTemplate" id="7e2cceac-b49c-4ebc-9c82-b7612b98d0af">
        <source>updateToDoTemplate(_toDoTemplate : CM_ToDoTemplate);
/*

Purpose:	Update ToDo Template		

Date		Who		Reason
10/04/2014	cnwma1	Initial creation

*/

vars
	pxyToDoTemplate : CM_ToDoTemplate;
	operatorDict	: CM_OperatorByCodeDict;
begin
	
		// create operator
	create operatorDict transient;
	operatorDict.add(self.getOperator("MSK"));
	
	beginLoad;
	pxyToDoTemplate := _toDoTemplate.pxyCreateUpdateProxy();
	endLoad;
	
	pxyToDoTemplate.setProxy(_toDoTemplate.id,
							_toDoTemplate.empties,
							_toDoTemplate.exports,
							_toDoTemplate.imports,
							_toDoTemplate.full,
							_toDoTemplate.storage,
							_toDoTemplate.tranships,
							_toDoTemplate.availabilityGrades,
							_toDoTemplate.isoGroups,
							_toDoTemplate.isoTypes,
							operatorDict,
							_toDoTemplate.toDoTasks,
							null);
	
	app.myTrxUA.trxUpdateToDoTemplate(pxyToDoTemplate, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	
epilog
	delete operatorDict;
	delete pxyToDoTemplate;
end;</source>
        <Parameter name="_toDoTemplate" type="CM_ToDoTemplate"/>
    </JadeMethod>
    <JadeMethod name="updateTrackClearance" id="1f989fbb-8b09-4f50-9dd5-a306c865001d">
        <source>updateTrackClearance( 	_trackClearance : CM_TrackClearance io;
						_maxHeight : Decimal;
						_maxWeightWagon : Decimal;
						_maxWidth : Decimal
						);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwndl1	Initial creation

*/

vars

	loadState : Boolean;
	proxyTrackClearance : CM_TrackClearance;
	
begin
	app.cmsBeginLoad(loadState);
	proxyTrackClearance := _trackClearance.pxyCreateUpdateProxy();
	proxyTrackClearance.setProxy(	_trackClearance.allowHiCube,	//_allowHiCube : Boolean;
									_trackClearance.code,	//_code : String;
									_trackClearance.description,	//_description : String;
									_maxHeight,	//_maxHeight : Decimal;
									_maxWeightWagon,	//_maxWeightWagon : Decimal;
									_maxWidth,	//_maxWidth : Decimal;
									_trackClearance.isNotAvailableForEntry,	//_isNotAvailableForEntry : Boolean
									0, // max weight for train
									false // no empty wagons
									);
									
	app.myTrxUA.trxUpdateTrackClearance(proxyTrackClearance, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
epilog

	app.cmsEndLoad(loadState);
	delete proxyTrackClearance;

end;</source>
        <Parameter name="_trackClearance" type="CM_TrackClearance" usage="io"/>
        <Parameter name="_maxHeight" type="Decimal"/>
        <Parameter name="_maxWeightWagon" type="Decimal"/>
        <Parameter name="_maxWidth" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="updateTrackedItem" id="a0dea623-01e6-4265-baca-2c34267b6d41">
        <source>updateTrackedItem(_ti : CM_TrackedItem input);
//07 December 2009	cnwml2
// 05/08/2011 cnwmh5 Chagne to use classes version of opts
// 25 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
vars
	extraParams				: CMIF_TIUpdateExtraParams;
	txnControllerDict		: CMIF_TITxnContrlrByTypeDTDict;
	pxyCargo				: CM_TrackedItem;
	reeferProperties		: CM_TIReeferProperties;
begin
	create extraParams transient;	
	create txnControllerDict transient;
	pxyCargo := app.createUpdateProxy(_ti).CM_TrackedItem;

	 // ### JIRA 36201 07OCT2025 NAVAB1
	if self.opts.includesKey('IMEXStatus') then	
		pxyCargo.setImExStatus(self.opts.int('IMEXStatus').Integer);
	endif;
	
	 // ### JIRA 35987 12SEP2025 NAVAB1
	if self.opts.includesKey("EffectiveTS") then	
		extraParams.dateTime := self.opts.timestamp("EffectiveTS").TimeStamp;
	endif;
	
	if self.opts.includesKey("TotalWeight") then
		pxyCargo.setTotalWeight(self.opts.str("TotalWeight").Decimal, null, app.myPassport);
	endif;

	if self.opts.includesKey("Length") then
		pxyCargo.zSetPxyLength(self.opts.str("Length").Decimal);
	endif;

	if self.opts.includesKey("ReadyToShip") then
		pxyCargo.zSetPxyReadyToShip(self.opts.bool("ReadyToShip"));
	endif;
	
	if self.opts.includesKey("Operator") then
		pxyCargo.zSetPxyOperator(self.opts.obj("Operator").CM_Operator);
	endif;
	
	reeferProperties := pxyCargo.myReeferProperties;									// 05/02/2014 cnwmh5
	if self.opts.includesKey("OnPower") and reeferProperties &lt;&gt; null then
		reeferProperties.setOnPower(self.opts.bool("OnPower"));
	endif;

	if self.opts.includesKey("BookingRef") then											// 14/12/2015 cnwmh5
		pxyCargo.zSetPxyBookingReference(self.opts.obj("BookingRef").CM_BookingRef.bookingReference);
		if self.opts.includesKey("BookingRefItem") then
			pxyCargo.setMyBookingRefItem(self.opts.obj("BookingRefItem").CM_BookingRefItem);
			extraParams.useSelectedBookingItem := true;
		endif;
	endif;
	
	if self.opts.includesKey("CountryOfOrigin") then
		pxyCargo.setMyCountryOfOrigin(self.opts.obj("CountryOfOrigin").CM_Country);	// 25.08.2022 navak20 TFS 54441
	endif;
	
	if self.opts.includesKey("HSCode") then				// 23/01/2023 jlizm1 TFS 56027
		pxyCargo.setHSCode(self.opts.str("HSCode"));
	endif;
	
	app.myTrxUA.trxUpdateTIandExtraInfo(pxyCargo, TI_UPDMODE_NORMAL, extraParams, txnControllerDict, null, app.myPassport);
	
	//21/10/2025	navkc1 JIRA 36056
	if self.opts.includesKey("ExpectErrorWarning") then
	
	else
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	endif;

	reeferProperties := _ti.myReeferProperties;									// 05/02/2014 cnwmh5
	if self.opts.includesKey("DefrostTimeStamp") and reeferProperties &lt;&gt; null then		// 05/02/2014 cnwmh5
		beginTransaction;
		reeferProperties.setDefrostDate(self.opts.str("DefrostTimeStamp").TimeStamp);
		commitTransaction;
	endif;

epilog
	delete pxyCargo;
	delete extraParams;
	delete txnControllerDict;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateTrade" id="2c0c3ade-270b-497a-bc7c-5a9533d1a99b">
        <source>updateTrade(_trade : CM_Trade io);

/*

Purpose:		Update trade details

Date			Who		Reason
21/02/2014		cnwmh5	Initial creation

*/

vars

	pxyTrade						: CM_Trade;

	operators						: ObjectArray;

	updateVoyagePortsOfCall			: Boolean;
	order							: Integer;
	ls								: Boolean;

begin

	if _trade = null then
		return;
	endif;
	
	order := _trade.order;
	if self.opts.includesKey("Order") then
		order := self.opts.int("Order");
	endif;

	create operators transient;
	_trade.operators.copy(operators);
	if self.opts.includesKey("Operators") then
		self.opts.obj("Operators").ObjectArray.copyNoDups(operators);
	endif;
	
	app.cmsBeginLoad(ls);
	pxyTrade := _trade.pxyCreateUpdateProxy();
	app.cmsEndLoad(ls);
	
	pxyTrade.setProxy(_trade.code, _trade.description, order, operators, _trade.isNotAvailableForEntry, 
		_trade.allShippingLines);

	app.myTrxUA.trxUpdateTrade(pxyTrade, updateVoyagePortsOfCall, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

	app.cmsEndLoad(ls);

	delete operators;
	delete pxyTrade;
	
end;</source>
        <Parameter name="_trade" type="CM_Trade" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateTrailerType" id="2d6a3f90-54e1-424c-960e-533c49537b6d">
        <source>updateTrailerType(_trailerType : CM_TILCType);
/*

Purpose:	Update Trailer Type		

Date		Who		Reason
29/04/2014	cnwma1	Initial creation
10/03/2023	jlika1	Add width to Trailer Type
*/

vars

	pxyTrailerType : CM_TILCType;
begin


	beginLoad;
	pxyTrailerType := _trailerType.pxyCreateUpdateProxy();
	endLoad;
	
	pxyTrailerType.setProxy(_trailerType.code,
							_trailerType.description,
							_trailerType.myCargoType,
							self.opts.int("TrailerLenght"),
							_trailerType.numControllers,
							_trailerType.maxHeight,
							_trailerType.maxWeight,
							_trailerType.tareWeight,
							_trailerType.colour,
							_trailerType.isNotAvailableForEntry,
							_trailerType.height,
							_trailerType.category,
							_trailerType.width,
							_trailerType.imageID,
							self.opts.bool("allowUpdateTotalWeight") //15/10/2025	navkc1 JIRA 36057
							);
