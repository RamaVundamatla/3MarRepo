//	_allFields.add(ETRow_TemplateKey);
end;</source>
        <Parameter name="_allFields" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initApp" id="3371a9c3-f549-47fd-9338-4b9672577471">
        <updating/>
        <source>initApp() updating;

// cnwdvb1 11 December 2002 

/*

Date		Who		Reason
12 Aug 2008	cnwkpd1	PAR #17713 - Set alias based on controller class for JSM moitoring of
					critical applications
23 Sep 2008	cnwkpd1	PAR #18009 - Allow ini file control of transient check
*/
//03 Jan 2013	cnwrs1	32983 crash after user deleted.

vars

	error			: Integer;
	ls				: Boolean;
	str,
	errorText		: String;
	msg : String;
begin

//	on Exception do app.alertExceptionHandler(exception, null, 'Timer BGP Controller', error, errorText, true, false) global;
	on Exception do self.xHandlerGlobal(exception) global;
	on LockException do app.alertLockExceptionHandler(exception) global;
	str := self.getOidString();
	str.replaceChar('.' , '_');
	app.logFileNameSpecific := 'BGPController_' &amp; self.logFileName() &amp; '_' &amp; str; //cnwrs1 par 17287 June 2008
	
	app.setCnAppAlias(self.class.name);		// PAR #17713 //epr TFS 36655 29/4/19
	
	app.initialize();
	app.setIsBackGroundApp(true);

 	if app.myPassport &lt;&gt; null then
 		app.myPassport.setMyUser(self.myUser);
  	endif;
	app.cmsBeginLoad(ls);
	exclusiveLock(self);
	if self.isRunning() then
		app.isBGPAppAbort := true;
		msg := 'ERR &gt;&gt; app is already running';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		
		app.exitLogFile();
		terminate;
		return;
	endif;
	
	app.myTrxUA.trxUpdateBGPControllerProcess(self, process, process.signOnTime, true, app.myPassport);
	self.beginNotification(self, BGP_Object.BGP_TerminateAppRequest, Response_Cancel , null);
	self.beginNotification(self, BGP_Object.BGP_DebugLevelChangeEvent, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_OutputInfo, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_ApplicationStartRequest, Response_Continuous , null);

	self.beginTimer(self.timerInterval * 1000, Timer_OneShot, AutoTimer_Event_Tag);
epilog
	app.cmsEndLoad(ls);
end;</source>
    </JadeMethod>
    <JadeMethod name="isSetup" id="8dc6de91-59dc-4777-a85f-3932ac03b0c1">
        <methodInvocation>mapping</methodInvocation>
        <source>isSetup(set: Boolean; _value: Boolean io) mapping;

// cnwdvb1 28 July 2003 

vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.timerInterval &lt;&gt; 0 then
		inheritMethod(set, _value);
		return;
	endif;
	_value := false;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processTimer" id="eb26e5df-9689-4a08-b18a-e09beca4c60c">
        <updating/>
        <source>processTimer() updating, protected;

// cnwdvb1 11 December 2002 
/*

Date		Who		Reason
23 Sep 2008	cnwkpd1	PAR #18013 - Rework to remove recursive code to prevent 1201 exceptions

*/

begin
	// Keep processing until we have nothing else to do.
	app.writeLog(method.qualifiedName &amp; " Starting loop", LogTRACE);
	
	while true do
		if not self.doProcessing() then
			break;
		endif;
		if not self.createTimerRequest() then
			break;
		endif;
	endwhile;
	
/*	PAR #18013 - old code replaced
	
	if self.doProcessing() then
		if self.createTimerRequest() then
			self.processTimer();
		endif;
	endif;
*/
epilog
	app.writeLog(method.qualifiedName &amp; " Finished loop", LogTRACE);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setAttributesForCreate" id="9ac1601a-c107-45a6-8b2b-c1a8598efd74">
        <updating/>
        <source>setAttributesForCreate() updating, protected;

// cnwdvb1 11 December 2002 

vars

begin

	self.schemaName			:= 'UiCommonSchema';
	self.isEditable			:= true;			

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCMIF" id="fe06902d-fd35-4fe2-a6dd-3b319ec96795">
        <source>setCMIF(_cmif: CMIF_BGPManagerChildren input);

// cnwdvb1 11 December 2002 

vars

begin

	inheritMethod(_cmif);
	_cmif.allClasses.clear;
	self.allRequestClassesToProcess.copy(_cmif.allClasses);
	_cmif.timerInterval		:= self.timerInterval;

end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="dc9b1ec6-5c82-432c-9bee-e665a4fae39b">
        <updating/>
        <source>setForUpdate(_cmif: CMIF_BGPManagerChildren) updating;

// cnwdvb1 11 December 2002 

vars

begin
	
	inheritMethod(_cmif);
	self.allRequestClassesToProcess.clear;
	_cmif.allClasses.copy(self.allRequestClassesToProcess);
end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="8325bfd5-0b7e-459e-8785-8ccaa2ae2318">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

// cnwdvb1 11 December 2002 
//03 Jan 2013	cnwrs1	32983 crash after user deleted.

vars

begin

	if eventTag = AutoTimer_Event_Tag and self.isRunning() then
		self.doTimerEvent();
	else
		inheritMethod(eventTag);
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</Class>
