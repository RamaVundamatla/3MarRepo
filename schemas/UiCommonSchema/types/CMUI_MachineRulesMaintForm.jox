    <JadeMethod name="translateForm" id="4492ccd7-bc8a-40fe-882b-e17ec3d0201b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 03 October 2022 09:57:07.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007787, locale);
	btnDelete.translateBubbleHelp(Xlat_0004919, locale);
	btnDelete.translateCaption(Xlat_0004920, locale);
	btnDoSearch.translateBubbleHelp(Xlat_0004921, locale);
	btnDoSearch.translateCaption(Xlat_0004922, locale);
	btnEdit.translateCaption(Xlat_0004923, locale);
	btnNew.translateBubbleHelp(Xlat_0004924, locale);
	btnNew.translateCaption(Xlat_0004925, locale);
	btnPrint.translateCaption(Xlat_0004926, locale);
	chkFork.translateCaption(Xlat_0014139, locale);
	chkIMV.translateCaption(Xlat_0014140, locale);
	chkMAFI.translateCaption(Xlat_0025108, locale);
	chkRTG.translateCaption(Xlat_0014141, locale);
	chkStrad.translateCaption(Xlat_0014142, locale);
	chkTractor.translateCaption(Xlat_0025109, locale);
	grpMachTypeGrp.translateCaption(Xlat_0014143, locale);
	grpTAMasters.translateCaption(Xlat_0014144, locale);
	grpTAType.translateCaption(Xlat_0014145, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0007788, locale);
	mnuContextTbl.translateCaption(Xlat_0007789, locale);
	mnuInspectObj.translateCaption(Xlat_0007790, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateObjectInTable" id="b9cb345f-dc1b-4858-8494-51903e8a705f">
        <updating/>
        <source>updateObjectInTable(_eventType : Integer; theObject : CM_Object; _tbl : CM_DataTable input) : Boolean protected, updating;

// Created by cnwdvb1 on 05 September 2006

vars

	theRow	: Integer;

begin

	if _eventType = Object_Delete_Event or _eventType = Object_Update_Event then
		_tbl.findObjectInRow(theObject, theRow);
	
		if theRow &lt;= _tbl.fixedRows then
			return false;
		endif;
	
		_tbl.removeItem(theRow);
		
		self.setCurrentRule(null);				// 15/08/2011 cnwmh5 #27286
		
		if _eventType = Object_Update_Event then
			self.tblDataDisplayRow(theObject.CM_RTQueueMultiRule);
		endif;
	
	elseif _eventType = Object_Create_Event then
		self.tblDataDisplayRow(theObject.CM_RTQueueMultiRule);
	endif;
	
	 _tbl.colourRows(self.colorRow1, self.colorRow2);
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="theObject" type="CM_Object"/>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
