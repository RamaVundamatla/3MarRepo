    <JadeMethod name="resetMeasurementRows" id="b551454b-86ab-45d5-afaa-fbf4bf7f2c13">
        <updating/>
        <source>resetMeasurementRows(_table : CM_EntryTable io) updating;
/*
Purpose:			Reset any table rows in the input table that are measurement types and
					that have previously been made visible := false, so that loading measurements
					works for a new row in the results table
					Remove any rows that are special measurement rows

Parameters:			

Return Value:		

Date		Who		Reason
08/03/2013	cnwdap1	Initial creation PAR #31155 cCMS SFW 1321 Imperial Measurements
29/06/2016   cnwma1      PAR #37988 TFS #2233 CPL - 1090 error - System Admin
30/03/2017   cnwma1		TFS #3728:PAR38646 GUQ - Editing an Unpack transaction Date
*/
vars
	row			: Integer;
	entRow 		: EntTableRow;	
begin
	
	if _table.myEntTableDef &lt;&gt; null then //cnwma1 29/06/2016   PAR #37988 TFS #2233 
		foreach entRow in _table.myEntTableDef.allEntTableRows do
			if entRow.measurementType &lt;&gt; null then
				row := _table.getRowByName(entRow.name);
				if row &lt; 1 then   							// 30/03/2017 cnwma1 TFS #3278
					continue;
				endif;
				if  not _table.accessRow(row).visible then
					_table.accessRow(row).visible := true;
				endif;
			endif;
		endforeach;
	endif;
	//epr par 32262 17/10/13 - refactored out to table
	_table.resetMeasurementTables();
	
			
epilog

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
