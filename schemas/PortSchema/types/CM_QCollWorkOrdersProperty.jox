    <JadeMethod name="setListValues" id="cf4127ca-11c0-4f3c-ad90-ebd70445b9b8">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryCollectionOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021 navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link

*/

vars
	selectionValue, 
	idx						: Integer;
	workOrder				: CM_WorkOrder;
	workOrderDict			: CM_WorkOrderByIdDict;
	term 					: CM_Terminal;
begin
	
	term 		   := app.myPassport.myTerminal;
	workOrderDict  := term.allWorkOrders;
	
	_tbl.clear;
	_tbl.rows 	   := _tbl.fixedRows;
	
	foreach workOrder in workOrderDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(workOrder) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; workOrder.id);
		_tbl.accessRow(idx).itemObject := workOrder;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryCollectionOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="6fe63f62-87d5-4b1b-b01a-e7610b0aa7cc">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021 navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link

*/

vars
	str				: String;
	numRows,
	idx				: Integer;
	os				: CM_ObjectSet;
	workOrder		: CM_WorkOrder;
begin

	create os transient;
	
	numRows := _tbl.rows;
	
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		
		if str = TableCheckBox_Selected then
			workOrder := _tbl.accessRow(idx).itemObject.CM_WorkOrder;
			os.add(workOrder);
		endif;
	endforeach;
	
	_op.setSearchValue(os);

epilog
	delete os;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="bfcffd59-3667-4d8c-8252-bd1fd9097d74">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021 navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link

*/

vars

	wo  : CM_WorkOrder;
	str : String;

begin

	if _value &lt;&gt; null then
		if _value.isKindOf(CM_WorkOrder) then	
			return _value.CM_WorkOrder.id;
		elseif _value.isKindOf(CM_WorkOrderSet) then
			str := _value.CM_WorkOrderSet.listString(Comma,CM_WorkOrder::id.name);
			return str;
		endif;
		
	endif;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="d840dd76-89a1-42e6-8749-9fb9249f2be8">
        <source>translateToSearchValueForWeb(_value: Any; _sending: Boolean): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021 navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link

*/

vars
	objSet  : ObjectSet;
	object  : Object;
	wo	 	: CM_WorkOrder;
	result  : String;
begin
	if _value.isKindOf(ObjectSet) then
		objSet := _value.ObjectSet;
		result := objSet.listString(Comma,CM_WorkOrder::id.name);
		result := result[1:result.length-2];
		return result;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
