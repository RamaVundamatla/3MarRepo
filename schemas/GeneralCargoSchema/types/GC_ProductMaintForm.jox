    <JadeMethod name="disableProdAttrCells" id="9c675788-6182-4d5c-b940-8c9a9430a3a6">
        <source>disableProdAttrCells(_row : Integer;
					_clearCellText : Boolean);
// ---------------------------------------------------------------------------
// Created:     08 October 2002 by cnwth2
//
// Purpose:     This method disables the appropriate cells on the current row depending on the
//				product attribute type and validation type selected. This is done because
//				we do not want to allow, for example, the user to enter a 'precision' or 
//				a 'multiplier' for a string field
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 15/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
constants
	InfoCol = #FFFFFF;
	DisableCol = #EBEBEB;
	
vars

	column,
	prodAttr			: CM_ProductAttr;
	entDef				: EntTableDef;
	entRow				: EntTableRow;
	validationType		: String;
	table				: CM_DataTable;
	
begin
	table := self.tblAttributes;
	prodAttr := table.accessRow(_row).itemObject.CM_ProductAttr;
	validationType := prodAttr.validationType;
	foreach entRow in self.getTblAttributesDef.allEntTableRows do
		if entRow.name &lt;&gt; ETRow_IsViewable and
			entRow.name &lt;&gt; ETRow_DisplayName and
			entRow.name &lt;&gt; ETRow_MeasurementType and								// PAR #31155
			entRow.name &lt;&gt; ETRow_ValidationType then
			table.accessCell(_row, table.getColumnByRowName(entRow.name)).inputType := CM_DataTable.InputType_None;
			table.accessCell(_row, table.getColumnByRowName(entRow.name)).backColor := DisableCol;
			if _clearCellText then
				table.setCellText(_row, table.getColumnByRowName(entRow.name), null);
			endif;
		elseif entRow.name = ETRow_DisplayName then
			table.accessCell(_row, table.getColumnByRowName(entRow.name)).inputType := CM_DataTable.InputType_TextBox;
			
			
		endif;
	endforeach;	
	
	//re-enable depending on validation selection
	if validationType = CM_ProductAttr.ValidationType_Codes then
		table.accessCell(_row, table.getColumnByRowName(ETRow_ColumnCode)).inputType := CM_DataTable.InputType_TextBox;
		table.accessCell(_row, table.getColumnByRowName(ETRow_ColumnCode)).cellControl := self.cmbCode;
		table.accessCell(_row, table.getColumnByRowName(ETRow_ColumnCode)).backColor := InfoCol;
		
	elseif validationType = CM_ProductAttr.ValidationType_Value then
		if prodAttr.myType = String then
			table.accessCell(_row, table.getColumnByRowName(ETRow_Value)).inputType := CM_DataTable.InputType_TextBox;
			table.accessCell(_row, table.getColumnByRowName(ETRow_Value)).backColor := InfoCol;
			table.accessCell(_row, table.getColumnByRowName(ETRow_Value)).maxLength := 30; // any more than this and it will get ex. 
			table.accessCell(_row, table.getColumnByRowName(ETRow_ColumnCode)).cellControl := null;	
		elseif prodAttr.myType = Decimal then
			table.accessCell(_row, table.getColumnByRowName(ETRow_Value)).inputType := CM_DataTable.InputType_TextNumeric;
			//table.accessCell(_row, table.getColumnByRowName(ETRow_Multiplier)).inputType := CM_DataTable.InputType_TextNumeric;			// PAR #31155
			table.accessCell(_row, table.getColumnByRowName(ETRow_Value)).decimals := 3;
			table.accessCell(_row, table.getColumnByRowName(ETRow_Value)).maxLength := 12; // any more than this and it will get ex. 
			//table.accessCell(_row, table.getColumnByRowName(ETRow_Multiplier)).maxLength := 10; // any more than this and it will get ex. // PAR #31155
			//table.accessCell(_row, table.getColumnByRowName(ETRow_Multiplier)).decimals := 3;												// PAR #31155
			table.accessCell(_row, table.getColumnByRowName(ETRow_Value)).backColor := InfoCol;
			//table.accessCell(_row, table.getColumnByRowName(ETRow_Multiplier)).backColor := InfoCol;										// PAR #31155
			table.accessCell(_row, table.getColumnByRowName(ETRow_Range)).inputType := CM_DataTable.InputType_TextBox;
			table.accessCell(_row, table.getColumnByRowName(ETRow_Range)).backColor := InfoCol;
		elseif prodAttr.myType = Integer then
			table.accessCell(_row, table.getColumnByRowName(ETRow_Value)).inputType := CM_DataTable.InputType_TextNumeric;
			//table.accessCell(_row, table.getColumnByRowName(ETRow_Multiplier)).inputType := CM_DataTable.InputType_TextNumeric;			// PAR #31155
			//table.accessCell(_row, table.getColumnByRowName(ETRow_Multiplier)).decimals := 3;												// PAR #31155
			table.accessCell(_row, table.getColumnByRowName(ETRow_Value)).backColor := InfoCol;
			table.accessCell(_row, table.getColumnByRowName(ETRow_Value)).maxLength := 9; // any more than this and it will get ex. 
			//table.accessCell(_row, table.getColumnByRowName(ETRow_Multiplier)).backColor := InfoCol;										// PAR #31155
			table.accessCell(_row, table.getColumnByRowName(ETRow_Range)).inputType := CM_DataTable.InputType_TextBox;
			table.accessCell(_row, table.getColumnByRowName(ETRow_Range)).backColor := InfoCol;
		endif;
	endif;	
	
end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_clearCellText" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayAttributes" id="15f99b15-5a46-4126-8fb0-645b29f2502a">
        <source>displayAttributes(_pro : CM_Product);
// ---------------------------------------------------------------------------
// Created:     09 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	cargoType	: CM_CargoType;
	prodAttr	: CM_ProductAttr;
	entRow		: EntTableRow;
	entDef		: EntTableDef;
begin
	
	if _pro = null then
		return;
	endif;
	if _pro.myCargoType = null then //we must be adding a new product, so get off the cargoType combo
		cargoType := self.cmbEntCargoType.listObject.CM_CargoType;
	else
		cargoType := _pro.myCargoType;
	endif;
	
	//par 19915 cnwjo3
	if cargoType = null then
		//either the product doesn't have a Cargo type or
		//this is a new item and the user has not selected a CargoType in the search dialog
		return;
	endif;
	
	entDef := self.getAllAttributesDef;
	
	self.tblAttributes.rows := self.tblAttributes.fixedRows;
	
	foreach entRow in entDef.allEntTableRows do
		if cargoType.allAttributesOnProduct.includes(entRow.name) then
		// This is the new one for after 7.4.1 release	
		//if cargoType.getAttributeValue(entRow.name).Boolean then
			prodAttr := _pro.getProdAttrFromName(entRow.name);
			self.addTblAttributeRow(prodAttr);
		endif;
	endforeach;
	
	

end;</source>
        <Parameter name="_pro" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="doAddCode" id="c2af0613-bd9f-4b5a-9de5-3adcb712088d">
        <source>doAddCode();
// ---------------------------------------------------------------------------
// Created:     04 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	loopProdCode,
	prodCode		: CM_ProductAttributeCode;
	idx				: Integer;
	code,
	descr			: String;
	prodAttr		: CM_ProductAttr;
begin
	prodAttr := self.myCurrentProdAttr;

	code := self.tblEntCode.getValueByName(ETRow_EntCode).String;
	descr := self.tblEntCode.getValueByName(ETRow_EntDescription).String;
	
	if code = null then
		app.msgBox('You must enter a value for "Code" before continuing','Insufficient input', 0);
		return;
	endif;
	
	if self.isDuplicateCode(code) then
		return;
	endif;
	
	create prodCode transient;
	prodCode.setProxy(code, descr, false, null);
	prodAttr.allCodes.add(prodCode);
	idx := self.tblCodeData.addItem(prodCode.code &amp; Tab &amp; prodCode.description);
	self.tblCodeData.accessRow(idx).itemObject := prodCode;
	
	self.tblEntCode.setValueByName(ETRow_EntCode, null);
	self.tblEntCode.setValueByName(ETRow_EntDescription, null);	
	self.tblEntCode.setFocus();
	self.tblEntCode.goToRowByName(ETRow_EntCode);
	
	
end;</source>
    </JadeMethod>
