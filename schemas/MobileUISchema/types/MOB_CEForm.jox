    <JadeMethod name="handleF2Key" id="1cde7a1d-b0f4-42fc-bbf8-f366e33e2f62">
        <updating/>
        <source>handleF2Key() updating;
/*
	Created on 20 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/
begin
	app.mousePointer	:=	Busy;
	self.doCloseForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="handleF7Key" id="3d1bfbc0-5a95-4f6f-b82b-f7b6a528ac52">
        <updating/>
        <source>handleF7Key() updating;
//30 June 2008	cnwdw1	
// Display the Locations Maintenance form
vars
	tiObj	: CM_TrackedItem;
	blnNew	: Boolean;
begin
	if not app.myCurrentUserCan(self.myMobileDataAgent.myTerminal, PmMobMaintainAllocations) then
		app.msgBox(app.getErrorString1(NoPermission, 'maintain locations.'), '', MsgBox_OK_Only);
		return;
	endif;

	if app.myMobileGUIAgent.loadLocnMaintForm(self.getSelectedLocation) = MB_MODAL_UPDATE then
		tiObj := self.getTrackedItemForRow(blnNew);
		
		if tiObj &lt;&gt; null then
			self.updateTILocation(tiObj);	// This will force a replan of the current row
		endif;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="hasUnsavedChanges" id="29246a26-0d10-44f2-a46e-dbcd77ee81a0">
