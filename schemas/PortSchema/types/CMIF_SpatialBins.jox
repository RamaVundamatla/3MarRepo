    <JadeMethod name="initializeForActivity" id="0bd7ff8e-0eb8-4ddf-8d65-274bc35f4525">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*
Purpose:			

Date		Who		Reason
03 December 2021	navab1	TFS 51853
*/

vars
	gridArea : CM_GridArea;
	blockArea : CM_BlockStack;
	gridCol : CM_GridColumn;
	lc : CM_LocationsController;
	term : CM_Terminal;
begin
	inheritMethod(_any, _ewsOpsView);

	
	self.tableName		:= self.Spatial_bins;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey		:= self.generateFullGKey(_any, "");
		return;
	endif;
	
	if _any.isKindOf(CM_BlockStack) then  // ### TFS 53369 12APR2022 NAVAB1
		blockArea := _any.CM_BlockStack; // ### TFS 53369 12APR2022 NAVAB1
		blockArea.initializeForActivity(_ewsOpsView, self); // ### TFS 53369 12APR2022 NAVAB1
	elseif _any.isKindOf(CM_GridArea) then
		gridArea := _any.CM_GridArea;
		gridArea.initializeForActivity(_ewsOpsView, self);
	elseif _any.isKindOf(CM_GridColumn) then
		gridCol := _any.CM_GridColumn;
		gridCol.initializeForActivity(_ewsOpsView, self);
	elseif _any.isKindOf(CM_LocationsController) then
		lc := _any.CM_LocationsController;
		lc.initializeForActivity(_ewsOpsView, self);
	//TFS#53369 NAVSP1 27APR2022 - Uncomented as it use in the snapshot
	elseif _any.isKindOf(CM_Terminal) then
		term := _any.CM_Terminal;
		term.initializeForActivity(_ewsOpsView, self);
	endif;
	


epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivityCOL" id="5aa4949c-5a65-4944-9717-8fbfc634cc72">
        <updating/>
        <source>initializeForActivityCOL(_any: Any; _ewsOpsView: CM_EWSActivityOpsview;_gKey:String) updating;
/*
Purpose:			

Date		Who		Reason
27MAY2022	navsp1	TFS#53700
*/

vars
	gridArea : CM_GridArea;
	blockArea : CM_BlockStack;
	gridCol : CM_GridColumn;
	bc : CM_BlockController;
	term : CM_Terminal;
	opsTable:  CMIF_OpsViewTables;
begin
	
	if 	_ewsOpsView.myTerminal &lt;&gt; null then
		self.termOid := _ewsOpsView.myTerminal.getOidAsString;
	endif;
	
	self.oid := _ewsOpsView.objectOid;
	
	if self.oid = null
	and _any.isKindOf(Object) then
		self.oid := _any.Object.getOidString();			
	endif;
	
	self.tableName		:= self.Spatial_bins;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey		:= self.generateFullGKey(_any, "");
		return;
	endif;
	if _any.isKindOf(CM_BlockController) then
		bc := _any.CM_BlockController;
		bc.initializeForActivityPrefix(_ewsOpsView, self,_gKey);
	elseif _any.isKindOf(CM_BlockStack) then
		blockArea := _any.CM_BlockStack;
		blockArea.initializeForActivityCOL(_ewsOpsView, self,_gKey);
	endif;


epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_gKey" type="String"/>
    </JadeMethod>
</Class>
