<CollClass name="CM_TruckSealSet" id="c41e6864-5e7f-4733-b6e7-d05124b67c40">
    <loadFactor>66</loadFactor>
    <memberType name="CM_TruckSeal"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sealObject"/>
    <JadeMethod name="getTruckSeal" id="a0f25ea4-ea89-4c0a-89a4-35c925181b65">
        <source>getTruckSeal(_sealType : CM_SealType): CM_TruckSeal;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks
24 May 2023			jlizm1	TFS 56558 EUP Seal Numbers on Trucks

*/

vars

	seal : CM_TruckSeal;
	invalidObject : Boolean;
	
begin

	if _sealType = null then
		return null;
	endif;

	on Exception do app.handleDeletedObject(exception, seal, invalidObject);

	foreach seal in self do
		if seal.sealType = _sealType.sealType then
			return seal;
		endif;
	endforeach;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_sealType" type="CM_SealType"/>
        <ReturnType type="CM_TruckSeal"/>
    </JadeMethod>
</CollClass>
