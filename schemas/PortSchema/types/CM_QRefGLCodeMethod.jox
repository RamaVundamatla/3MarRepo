    <JadeMethod name="setComboValues" id="982525e0-6ca2-4476-b94b-14bd9273e624">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

	glCodeObjSet : ObjectSet;
	obj : Object;
	glCode : CM_GLCode;
	qrl : CM_QReferenceLookup;
	edition : Integer;
	invalidObj : Boolean;

begin
	
	_combo.clear();

	//We get services in play based on the banks in play.
	create glCodeObjSet  transient;
	self.getGLCodesInPlay( _params, glCodeObjSet );
	
	if glCodeObjSet.isEmpty then
		//nothing to do
		return;
	endif;
	
	//so populate the services based on the banks found
	foreach obj in glCodeObjSet do
		glCode := obj.CM_GLCode;
		_combo.itemObject[ _combo.addItem( self.translateToDisplayValue(glCode).String ) ] := glCode;
	endforeach;
	
	//now set the value in the combo
	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		on Exception do app.handleDeletedObject( exception, qrl.mySelectionValue, invalidObj );
		if qrl.mySelectionValue &lt;&gt; null then
			edition := qrl.mySelectionValue.edition;
			if not invalidObj then
				if _combo.findObject(qrl.mySelectionValue) &gt; 0 then
					_combo.listObject := qrl.mySelectionValue;
				endif;
			endif;
		endif;
	endif;

epilog

	delete glCodeObjSet;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="d3567b35-c1bb-4769-b815-ec01a7b9743a">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QReferenceIsOneOf; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

	glCodeObjSet : ObjectSet;
	obj : Object;
	glCode : CM_GLCode;
	selectionValue : Integer;
	idx : Integer;

begin

	_tbl.clear;
	_tbl.rows := 0;
	_tbl.sortColumn[1] := 2;
	
	//We get services in play based on the banks in play.
	create glCodeObjSet  transient;
	self.getGLCodesInPlay( _params, glCodeObjSet );
	
	if glCodeObjSet.isEmpty then
		//nothing to do
		return;
	endif;
	
	//so populate the services based on the banks found
	foreach obj in glCodeObjSet do
		glCode := obj.CM_GLCode;
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(glCode) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem( selectionValue.String &amp; Tab &amp; self.translateToDisplayValue(glCode).String );
		_tbl.accessRow(idx).itemObject := glCode;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;

epilog

	delete glCodeObjSet;

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="b30657eb-fe4d-4fa5-8f4c-ef9c828827f5">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

	glCode : CM_GLCode;

begin
	if _value.isKindOf(CM_GLCode) then
		if _value &lt;&gt; null then
			glCode := _value.CM_GLCode;
			return glCode.code &amp; "  [" &amp; glCode.bank.code &amp; "/" &amp; glCode.bank.terminal.code &amp; "]";
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="974e7006-1944-4f0a-92d0-b9f6f925350f">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_GLCode) then
			return _value.CM_GLCode;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
