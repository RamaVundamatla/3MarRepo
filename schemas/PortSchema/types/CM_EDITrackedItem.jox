    <JadeMethod name="canUserSet" id="9d90a437-bb2e-424f-8de9-bc3113308700">
        <source>canUserSet(_propName: String): Boolean;
//----------------------------------------------------------------
//	Created:	05 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 19 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
//
vars

begin
	if _propName = CM_EDITrackedItem::status.name or
	   _propName = CM_EDITrackedItem::allCustomsSeals.name or
	   _propName = CM_EDITrackedItem::cargoType.name or
	   _propName = CM_EDITrackedItem::ediFileIssueDateTime.name or
	   _propName = CM_EDITrackedItem::fileDateTime.name or
	   _propName = CM_EDITrackedItem::messageNum.name or
	   _propName = CM_EDITrackedItem::processedDateTime.name or
	   _propName = CM_EDITrackedItem::rawEDIData.name or
	   _propName = CM_EDITrackedItem::rawEDIDataArray.name or
	   _propName = CM_EDITrackedItem::temperatureAbsolute.name or
	   _propName = CM_EDITrackedItem::temperatureSign.name or
	   _propName = CM_EDITrackedItem::allAuditObjects.name or
	   _propName = CM_EDITrackedItem::allAuditObjectsForClass.name or	//21 Jan 2021	NDL	TFS 50251
	   _propName = CM_EDITrackedItem::allExtraData.name or
	   _propName = CM_EDITrackedItem::allDebtorsByType.name or
	   _propName = CM_EDITrackedItem::directDelivery.name or
	   _propName = CM_EDITrackedItem::specialStowage.name or
	   _propName = CM_EDITrackedItem::subTerminalCode.name or
	   _propName = CM_EDITrackedItem::myAttachedItems.name or
	   _propName = CM_EDITrackedItem::myEDIConfig.name or 
	   _propName = CM_EDITrackedItem::myEDIData.name or
	   _propName = CM_EDITrackedItem::myParent.name or
	   _propName = CM_EDITrackedItem::rawDataCommodity.name or					//21.11.2022 navma1 #55424
	   _propName = CM_EDITrackedItem::rawDataVoyageCode.name or					//21.11.2022 navma1 #55424
	   _propName = CM_EDITrackedItem::packDetails.name then
		return false;
	endif;
	return true;	
end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cargoTypeAllowsDuplicates" id="d8d46c62-5baf-4976-a413-b2ed9714b468">
        <source>cargoTypeAllowsDuplicates():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2016	cnwndl1	Initial creation	TFS 2919 / 2419

*/

vars

	cargoTypeObj : CM_CargoType;

begin

	if self.cargoType &lt; 1 then
		return false;
	endif;
	
	cargoTypeObj := app.myRoot.allCargoTypesById[self.cargoType];
	
	if cargoTypeObj &lt;&gt; null then
		return cargoTypeObj.allowDuplicates;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cargoTypeDescr" id="d8c56e5c-1c81-4d5a-a56c-1961afab18f2">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>cargoTypeDescr(set : Boolean; _value : String io) mapping, updating;
//
// cnwrs1 11 Feb 2010 CCMS Messina 1008 par21329
//
vars
	cType : CM_CargoType;
	int : Integer;
begin
	if set then
		int := app.myRoot.getCargoTypeIDFromDescription(_value);
		if int &lt;&gt; 0 then
			self.cargoType := int;		
		endif;
		
	else
		cType := app.myRoot.allCargoTypesById[self.cargoType];
		if cType &lt;&gt; null then
			_value := cType.description;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
