    <JadeMethod name="setupForm" id="f03b8b36-964c-4869-a6d2-cb9a70e58c24">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move

*/

vars

begin
	inheritMethod();
	self.initTable();
	self.useTableSorting := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.minimumHeight := 200;
	self.minimumWidth := 640;
	self.frmQuery.visible := false;	
	self.populateDataTable();
	self.mnuContextColourLegend.visible := false;

	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditItem.enabled:= false;
		self.btnNew.enabled := false;
		self.btnDelete.enabled := false;
	endif;

epilog

end;</source>
