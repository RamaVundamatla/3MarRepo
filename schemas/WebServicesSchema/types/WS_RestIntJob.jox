        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="workOrderId" id="2915d1f3-269c-4fd0-a50a-566fc09ecd30">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="workOrderUid" id="22f59caf-5975-4e9e-87af-a16cb404c231">
