        <source>getTransactionMap(_name : String) : CM_TranMap;
// return the transaction map with the given name
vars
	tm	: CM_TranMap;
	bank	: CM_Bank;
begin
	bank := self.getTerminal().getDefaultCompanyBank();
	foreach tm in bank.myCurrentTranMapCargo do
		if tm.name = _name then
