    <JadeMethod name="clearStats" id="4bb1b9c0-ca5d-4296-b14a-81dc8d14ea34">
        <updating/>
        <source>clearStats() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 November 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	
	self.completeMoves:=0;
	self.hasOverDimension:=false;
	self.incompleteMoves:=0;
	self.incompleteOverDimesion:=0;
	self.incompleteSLOD:=0;
	self.incompleteSLUD:=0;
	self.incompleteTLOD:=0;
	self.incompleteTLUD:=0;
	self.isRehandle:=false;
	self.num20s:=0;
	self.num40s:=0;
	//epr 31764 6/8/13
	self.totalQuantity:=0;
	self.totalVolume:=0;
	self.totalWeight:=0;
	self.completeQuantity:=0;
	self.completeVolume:=0;
	self.completeWeight:=0;
	self.completeLifts := 0;
	
	//epr tfs 830
	self.num30s:=0;
	self.num45s:=0;
	self.num53s:=0;
	self.totalMTs:=0;
	self.totalReefers:=0;
	self.complete20s:=0;
	self.complete30s:=0;
	self.complete40s:=0;
	self.complete45s:=0;
	self.complete53s:=0;
	self.completeMTs:=0;
	self.completeReefers:=0;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="04447cea-e04c-41e6-af5c-394662336523">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Date		Who		Reason
20 March 2017	cnwer1	Initial creation TFS 830

*/

vars

begin
	if _attrName = ETRow_JobId then
		return self.myJob.getDisplayStringForAttribute(ETRow_NewJobID,_short);
	elseif
		_attrName = ETRow_Location or 
		_attrName = ETRow_JobType then
		return self.myJob.getDisplayStringForAttribute(_attrName,_short);
	elseif _attrName = ETRow_LiftsDone then
		return self.completeLifts.roundedUp.asStringJMT;
	elseif _attrName = ETRow_LiftsToDo then
		return self.getLiftsToDo().asStringJMT;
	elseif _attrName = ETRow_MovesDone then
		return self.completeMoves.asStringJMT;
	elseif _attrName = ETRow_MovesToDo then
		return self.incompleteMoves.asStringJMT;
	elseif _attrName = ETRow_20sDone then
		return self.complete20s.asStringJMT;
	elseif _attrName = ETRow_20sToDo then
		return (self.num20s - self.complete20s).asStringJMT;
	elseif _attrName = ETRow_40sDone then
		return self.complete40s.asStringJMT;
	elseif _attrName = ETRow_40sToDo then
		return (self.num40s - self.complete40s).asStringJMT;	
	elseif _attrName = ETRow_30sDone then
		return self.complete30s.asStringJMT;
	elseif _attrName = ETRow_30sToDo then
		return (self.num30s - self.complete30s).asStringJMT;
	elseif _attrName = ETRow_45sDone then
		return self.complete45s.asStringJMT;
	elseif _attrName = ETRow_45sToDo then
		return (self.num45s - self.complete45s).asStringJMT;
	elseif _attrName = ETRow_53sDone then
		return self.complete53s.asStringJMT;
	elseif _attrName = ETRow_53sToDo then
		return (self.num53s - self.complete53s).asStringJMT;
	elseif _attrName = ETRow_EmtpyDone then
		return self.completeMTs.asStringJMT;
	elseif _attrName = ETRow_EmptyToDo then
		return (self.totalMTs - self.completeMTs).asStringJMT;
	elseif _attrName = ETRow_ReefersDone then
		return self.completeReefers.asStringJMT;
	elseif _attrName = ETRow_ReefersToDo then
		return (self.totalReefers - self.completeReefers).asStringJMT;
	elseif _attrName = ETRow_SobDone then
		return self.completeSOB.asStringJMT;
	elseif _attrName = ETRow_SobToDo then
		return (self.totalSOB - self.completeSOB).asStringJMT;
	elseif _attrName = ETRow_DlrDone then
		return self.completeDLR.asStringJMT;
	elseif _attrName = ETRow_DlrToDo then
		return (self.totalDLR - self.completeDLR).asStringJMT;
		
	elseif _attrName = ETRow_Remarks then
		return self.myJob.getRemarks();
	else
	
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLiftsDone" id="dfa413c3-50b2-44c0-97b6-12c227008054">
        <source>getLiftsDone() : Integer;
/*

Date		Who		Reason
20 March 2017	cnwer1	Initial creation TFS 830

*/

vars
	
	
begin

	if  self.completeLifts = 0 then
		return self.completeMoves;
	else
		return (self.completeMoves + (self.completeLifts/2)).Integer; //ok to cast as int because tl totals should always be in multiples of 2
	endif;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLiftsToDo" id="712361f5-0c32-4e5f-a25d-8c170741eb8a">
        <source>getLiftsToDo() : Integer;
/*

Date		Who		Reason
20 March 2017	cnwer1	Initial creation TFS 830

*/

vars
	incompleteTL : Real;
begin
	incompleteTL := (self.incompleteTLOD + self.incompleteTLUD);
	
	if incompleteTL = 0 then
		return self.getMovesToDo();
	else
		return (self.incompleteSLOD + self.incompleteSLUD + incompleteTL).Integer;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMovesToDo" id="38b4ce19-4017-4f49-900d-b3c7503b5d2a">
        <source>getMovesToDo() : Integer;
/*

Date		Who		Reason
20 March 2017	cnwer1	Initial creation TFS 830

*/

vars

begin
	return self.incompleteMoves;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="9a12f39a-ed32-46ee-bca2-42e6dff2cb60">
        <updating/>
        <source>setDetails(	_jobSheetStats : CMIF_JobSheetStats;
			_actualStartTime,
			_actualEndTime,
			_targetStartTime,
			_targetEndTime : TimeStamp) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.actualStartTime:=_actualStartTime;
	self.actualEndTime:=_actualEndTime;
	self.targetStartTime:=_targetStartTime;
	self.targetEndTime:=_targetEndTime;
	if self.myCMIFJobSheetStats &lt;&gt; _jobSheetStats then
		self.myCMIFJobSheetStats:=_jobSheetStats;
	endif;
	self.myCMIFJobSheetStatsForEndTime :=_jobSheetStats;
epilog

end;</source>
        <Parameter name="_jobSheetStats" type="CMIF_JobSheetStats"/>
        <Parameter name="_actualStartTime" type="TimeStamp"/>
        <Parameter name="_actualEndTime" type="TimeStamp"/>
        <Parameter name="_targetStartTime" type="TimeStamp"/>
        <Parameter name="_targetEndTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setMyCMIFJobSheetStatsForEnd" id="fad6a74e-b7e9-4417-8707-c488978698aa">
        <updating/>
        <source>setMyCMIFJobSheetStatsForEnd(_value : CMIF_JobSheetStats) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 November 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if _value &lt;&gt; self.myCMIFJobSheetStatsForEndTime then
		self.myCMIFJobSheetStatsForEndTime:=_value;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="CMIF_JobSheetStats"/>
    </JadeMethod>
