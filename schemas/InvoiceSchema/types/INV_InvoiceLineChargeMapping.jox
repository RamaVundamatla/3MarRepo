    <JadeMethod name="setCopyOptionBubblehelp" id="661c7675-b181-4afe-8656-2d845209d103">
        <source>setCopyOptionBubblehelp(_target : String);
// ---------------------------------------------------------------------------
// Created:		20 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpStr : String;
begin
	if _target = null then
		tmpStr := "the target";
	else
		tmpStr := _target;
	endif;
	
	self.optCopyAll.bubbleHelp := "Keep all existing mappings for " &amp; tmpStr &amp; Cr &amp; "and add all of the mappings for '" &amp; self.cmbParentObject.text &amp; "'";
	self.optCopySelected.bubbleHelp := "Keep all existing mappings for " &amp; tmpStr &amp; Cr &amp; "and add the selected of the mappings for '" &amp; self.cmbParentObject.text &amp; "'";
	self.optReplaceAll.bubbleHelp := "Remove all existing mappings for " &amp; tmpStr &amp; Cr &amp; "and add all of the mappings for '" &amp; self.cmbParentObject.text &amp; "'";
	self.optReplaceSelect.bubbleHelp := "Remove all existing mappings for " &amp; tmpStr &amp; Cr &amp; "and add the selected of the mappings for '" &amp; self.cmbParentObject.text &amp; "'";
end;</source>
        <Parameter name="_target" type="String"/>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="70725af9-4f5b-4c02-b4e1-d0e58561524d">
        <source>setEnableObjects();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	rateTable : Table;

begin
	rateTable := self.tblData;

	if rateTable.column &gt; 1 and rateTable.row &gt; 1 then
		self.mnuInvUpdate.enabled := true;
		self.btnEditItem.enabled := true;
	else
		self.mnuInvUpdate.enabled := false;
		self.btnEditItem.enabled := false;
	endif;

	self.btnPrint.enabled := true; 

end;</source>
    </JadeMethod>
    <JadeMethod name="setTableAlignment" id="5a052164-100a-417b-834a-ecc7af979b30">
        <source>setTableAlignment();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	saveRow:    Integer;
	saveColumn: Integer;
	row:        Integer;
	rateTable : Table;

begin
	rateTable := self.tblData;

	saveRow := rateTable.row;
	saveColumn := rateTable.column;

	rateTable.accessMode := Table.AccessMode_Sheet;
	rateTable.alignment := Table.Alignment_Right;

	rateTable.accessMode := Table.AccessMode_Column;
	rateTable.column := 1;
	rateTable.alignment := Table.Alignment_Left;

	rateTable.accessMode := Table.AccessMode_Row;
	row := 1;
	while row &lt;= rateTable.fixedRows do
		rateTable.row := row;
		rateTable.alignment := Table.Alignment_Left;
		row := row + 1;
	endwhile;

	rateTable.accessMode := Table.AccessMode_Cell;
	rateTable.alignment := Table.Alignment_Right;

	rateTable.row := saveRow;
	rateTable.column := saveColumn;


end;</source>
    </JadeMethod>
    <JadeMethod name="setToolbarButtons" id="d0910de0-e9f3-41f3-948e-032befc187c5">
        <source>setToolbarButtons(_enable : Boolean);
// ---------------------------------------------------------------------------
// Created:		21 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.btnCopy.enabled := _enable;
	self.btnDeleteMapping.enabled := _enable;
	self.btnEditItem.enabled := _enable;
	self.btnPrint.enabled := _enable;
end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a6345879-95b1-48ac-9cbb-ce3548d8c552">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aDate : Date;
begin
	self.myCurrentChargeType := -1;
	self.useCtrlScroll := true;
	
	// 35872 get business unit from user if more than one
	self.myCurrentBank := self.myTerminal.getDefaultCompanyBank();
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.usesQueryFrame := true;
	self.useTableInfo := true;
	self.splMain.hideRightControl(true);
	self.mnuContextHide.visible := false;
	self.mnuHide.visible := false;
	self.mnuContextColourLegend.visible := false;
	self.mnuColumnOrganiser.visible := false;
	self.mnuInvUpdate.visible := true;
	// Par 10880
	self.mnuInvUpdate.visible := false;
	self.doCmbBankBuild();
	
	inheritMethod();

	self.fldQuery.topSheet := self.shtQuery1;
	self.doCmbChargesBuild(self.cmbChargeType);
	self.doCmbChargesBuild(self.cmbChargeTypeMap);
	self.doCmbChargeComBuild();
	self.loadLines();
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_MAPPING_CREATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_MAPPING_DELETE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_MAPPING_UPDATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_MAPPING_PURGE), Response_Continuous, null);
	self.splMain.hideRightControl(true);
	
	// cnwrl1 PAR 19324 default the navigation entry now.
	self.setNavigatorHeading( self.caption );
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showCopyFrame" id="41ef6947-e6c6-4c06-8b2f-17c23a1290a8">
        <updating/>
        <source>showCopyFrame() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theFrame : Frame;
	tmpStr : String;
begin
	if not app.myPassport.myUser.canDo(self.myTerminal, PmAdmInvChrgMapMaint) then
		app.msgBox("You do not have permission to maintain invoice line mappings.","Copy Issue",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if self.cmbChargeType.listIndex = -1 then
		app.msgBox("Please do a query before a copy.","Copy Issue",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if self.cmbParentObject.listIndex = -1 then
		app.msgBox("Please select a " &amp; self.cmbChargeType.text &amp; " before a copy.","Copy Issue",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	
	tmpStr := "Select a " &amp; self.cmbChargeType.text &amp; " to copy to." &amp; Cr &amp; Cr &amp; 
					"Then select whether to copy all of '" &amp; self.cmbParentObject.text &amp; "' mappings or just the selected mappings.";
					
	self.setCopyOptionBubblehelp(null);
	
	self.lblCopy.caption := tmpStr;
	self.cmbParentCopy.listIndex := -1;
	
	theFrame := self.frmCopy;
	theFrame.zOrder(1);
	theFrame.centreWindow();
	theFrame.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="showDeleteFrame" id="a866912e-7ede-491b-9684-4380cec84209">
        <updating/>
        <source>showDeleteFrame() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theFrame : Frame;
	tmpStr : String;
begin
	if not app.myPassport.myUser.canDo(self.myTerminal, PmAdmInvChrgMapMaint) then
		app.msgBox("You do not have permission to maintain invoice line mappings.","Delete Issue",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if self.cmbChargeType.listIndex = -1 then
		app.msgBox("Please do a query before a delete.","Delete Issue",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if self.cmbParentObject.listIndex = -1 then
		app.msgBox("Please select a " &amp; self.cmbChargeType.text &amp; " before a delete.","Delete Issue",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	
	
	tmpStr := "Select whether to delete all of '" &amp; self.cmbParentObject.text &amp; "' mappings or just the selected mappings." &amp; Cr &amp; Cr &amp;
		"Then click the delete button to confirm.";
	self.lblDelete.caption := tmpStr;

	
	theFrame := self.frmDelete;
	theFrame.zOrder(1);
	theFrame.centreWindow();
	theFrame.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="showPropertyFrame" id="324839d9-242b-4293-9d54-185568d47c40">
        <updating/>
        <source>showPropertyFrame() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theFrame : Frame;
	theRow, theCol : Integer;
	lbl : String;
	aMap : CM_InvoiceLineChargeMapping;
	table : CM_DataTable;
begin
	if not app.myPassport.myUser.canDo(self.myTerminal, PmAdmInvChrgMapMaint) then
		app.msgBox("You do not have permission to maintain invoice line mappings.","Mapping Issue",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	table := self.tblData;
	lbl := null;
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	if table.column &lt;= table.fixedColumns then
		return;
	endif;
	
	theRow := table.row;
	theCol := table.column;
	self.myCurrentCombinationObject := null;
	self.myCurrentParentObject := null;
	self.myCurrentInvLineType := null;
	
	if theRow &gt; table.fixedRows then
		lbl := "The charge mapping for invoice line '" &amp; table.accessCell(theRow, 1).text &amp; "'," &amp; Cr &amp; 
			"when used by " &amp; self.cmbChargeType.text &amp; " '" &amp; self.cmbParentObject.text &amp; "'" &amp; Cr &amp; 
			"in combination with " &amp; self.cmbChargeTypeCom.text &amp; 
			" '" &amp; table.accessCell(1, theCol).text &amp; "' is:";
		self.lblChargeTypeMap.caption := lbl;
		
		
		self.myCurrentCombinationObject := self.tblData.accessColumn(theCol).itemObject.CM_Object;
		self.myCurrentInvLineType := self.tblData.accessRow(theRow).itemObject.CM_InvoiceLineDesc;
		self.myCurrentParentObject := self.cmbParentObject.listObject.CM_Object;

		aMap := self.myCurrentBank.allInvLineChargeMappings[self.myCurrentInvLineType, self.myCurrentParentObject, self.myCurrentCombinationObject];
		self.myCurrentMapping := aMap;
		if aMap &lt;&gt; null then
			self.doCmbChargesListIndex(self.cmbChargeTypeMap, aMap.myDebtorType); //CP CCMS 1047 PAR 16666 cnwgb1 18 April 2008
		else
			self.cmbChargeTypeMap.listIndex := -1;
		endif;
		
	endif;

	theFrame := self.frmProperties;
	theFrame.zOrder(1);
	theFrame.centreWindow();
	theFrame.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f1a17461-290f-49a4-b175-4524c1221e11">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 January 2017 09:49:31.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006170, locale);
	btnCopy.translateBubbleHelp(Xlat_0006171, locale);
	btnCopy.translateCaption(Xlat_0006172, locale);
	btnCopyCancel.translateBubbleHelp(Xlat_0006173, locale);
	btnCopyCancel.translateCaption(Xlat_0006174, locale);
	btnCopySave.translateBubbleHelp(Xlat_0006175, locale);
	btnCopySave.translateCaption(Xlat_0006176, locale);
	btnDeleteCancel.translateBubbleHelp(Xlat_0006177, locale);
	btnDeleteCancel.translateCaption(Xlat_0006178, locale);
	btnDeleteMapping.translateBubbleHelp(Xlat_0006179, locale);
	btnDeleteMapping.translateCaption(Xlat_0006180, locale);
	btnDeleteSave.translateBubbleHelp(Xlat_0006181, locale);
	btnDeleteSave.translateCaption(Xlat_0006182, locale);
	btnPropCancel.translateBubbleHelp(Xlat_0006183, locale);
	btnPropCancel.translateCaption(Xlat_0006184, locale);
	btnPropDelete.translateCaption(Xlat_0006185, locale);
	btnPropSave.translateBubbleHelp(Xlat_0006186, locale);
	btnPropSave.translateCaption(Xlat_0006187, locale);
	btnRefresh.translateBubbleHelp(Xlat_0006188, locale);
	btnRefresh.translateCaption(Xlat_0006189, locale);
	lblBank.translateCaption(Xlat_0020695, locale);
	lblChargeType.translateCaption(Xlat_0014392, locale);
	lblChargeTypeCom.translateCaption(Xlat_0006191, locale);
	lblChargeTypeMap.translateCaption(Xlat_0006192, locale);
	lblCopy.translateCaption(Xlat_0006193, locale);
	lblDelete.translateCaption(Xlat_0006194, locale);
	lblParentObject.translateCaption(Xlat_0006195, locale);
	mnuAudits.translateCaption(Xlat_0021728, locale);
	mnuViewAudits.translateCaption(Xlat_0021729, locale);
	optCopyAll.translateCaption(Xlat_0006196, locale);
	optCopySelected.translateCaption(Xlat_0006197, locale);
	optDeleteAll.translateCaption(Xlat_0006198, locale);
	optDeleteSelect.translateCaption(Xlat_0006199, locale);
	optReplaceAll.translateCaption(Xlat_0006200, locale);
	optReplaceSelect.translateCaption(Xlat_0006201, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotificationUpdateLocal" id="5b0e3df1-a2e1-487b-97b7-55e78c612ddf">
        <updating/>
        <source>userNotificationUpdateLocal(_event: Integer; _noteobj : CM_Object; _info : Any) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------

vars
	anObj : Object;
	theCom, theParent : CM_Object;
	theLineType : CM_InvoiceLineDesc;
	theMapping : CM_InvoiceLineChargeMapping;
	theDataLine : String;
	pos, pos2, idx, theRow, theColumn : Integer;
	passBack : String;
begin 
	if _event = EVENT_MAPPING_DELETE then
		// we have sent through the inv line desc and the parent object and the combination object from the delete note. This will let us find the row.
		theRow := idx;
		passBack := _info.String;
		pos := passBack.pos("~",1);
		theLineType := passBack[1: pos - 1].asOid().CM_InvoiceLineDesc;
		pos2 := passBack.pos("^",1);
		theParent := passBack[pos +1: pos2 - 1].asOid().CM_Object;
		theCom := passBack[pos2 +1: end].asOid().CM_Object;
		// different query
		if theParent &lt;&gt; self.myCurrentParentObject then
			return;
		endif;
		self.tblData.findObjectInRow(theLineType,theRow);
		self.tblData.findObjectInColumn(theCom,theColumn);

		self.tblData.accessCell(theRow,theColumn).text := theLineType.myDebtorType.description; //CP CCMS 1047 PAR 16666 cnwgb1 18 April 2008
		self.tblData.accessedCell.fontBold := false;
		self.tblData.accessedCell.itemObject := null;
				
		return;
	endif;
	
	// have deleted all of the mappings so do complete refresh
	if _event = EVENT_MAPPING_PURGE then
		theParent := _info.CM_Object;
		if theParent = null then
			return;
		endif;
		
		if theParent &lt;&gt; self.myCurrentParentObject then
			return;
		endif;
		
		self.doQuery();
		return;
	endif;
	
	if not _info.isKindOf(CM_InvoiceLineChargeMapping) then
		return;
	endif;

	if _info &lt;&gt; null 
	and (_event = EVENT_MAPPING_UPDATE or _event = EVENT_MAPPING_CREATE ) then
		theMapping := _info.CM_InvoiceLineChargeMapping;
		theLineType := theMapping.myInvoiceLineDesc;
		theParent := theMapping.myParentMappingObject;
		// different query
		if theParent &lt;&gt; self.myCurrentParentObject then
			return;
		endif;
		theCom := theMapping.myCombinationMappingObject;
		
		
		self.tblData.findObjectInRow(theLineType,theRow);
		self.tblData.findObjectInColumn(theCom,theColumn);

		// CP CCMS 1047 PAR 16666 cnwgb1 18 April 2008 ...
		self.tblData.accessCell(theRow,theColumn).text := theMapping.myDebtorType.description;
		self.tblData.accessedCell.fontBold := (theLineType.myDebtorType &lt;&gt; theMapping.myDebtorType);
		// ...CP CCMS 1047 PAR 16666 cnwgb1 18 April 2008
		self.tblData.accessedCell.itemObject := theMapping;
	endif;

end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_noteobj" type="CM_Object"/>
        <Parameter name="_info" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="2f1969b1-ab0b-40ee-8b67-df27f6e24162">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		19 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	event : Integer;
begin

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	self.userNotificationUpdateLocal(event, theObject.CM_Object, userInfo);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
