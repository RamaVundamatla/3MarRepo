    <JadeMethod name="populateTblAuditConfigs" id="31bdaba8-51b0-4bf0-b3bf-d9418f5fe5af">
        <source>populateTblAuditConfigs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2021	jlgndl1	Initial creation

*/

vars

	entDef : EntTableDef;
	iter : Iterator;
	auditConfig : CM_AuditConfig;
	str : String;
	index : Integer;
	enabledColumn : Integer;

begin

	entDef := app.myController.getEntTableDef(ETDef_AuditConfigList);
	self.tblAuditConfigs.setMyEntTableDef(entDef);	
	self.tblAuditConfigs.setTblDataEntRowsFromDef(entDef);
	
	self.tblAuditConfigs.selectMode := CM_Table.SelectMode_Row;
	self.tblAuditConfigs.selectionType := CM_BaseTable.SelectionType_Row;	
	self.tblAuditConfigs.multiSelect := CM_BaseTable.MultiSelect_None;
	
	enabledColumn := self.tblAuditConfigs.getColumnByRowName(ETRow_IsEnabled);
	
	iter := app.myRoot.allAuditConfigs.createIterator;
	
	while iter.next( auditConfig ) do
		if auditConfig.className = CM_DocketError.name
		or auditConfig.className = CM_EventRequest.name
		or auditConfig.className = CM_FileFormatEDI.name
		or auditConfig.className = "CM_TIMasterGroup"
		then
			//29 Jan 2021	TFS 50152
			//These were never set up correctly so look to be able to be deleted
			continue;
		endif;
		self.addOrUpdateRow( auditConfig, 0, enabledColumn );
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a7341b92-23b5-4ec2-a113-87ab1d7dfea9">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

	

begin

	self.handleMenusForModalDisplay();
	
	inheritMethod();
	
	self.btnOk.visible := false;
	self.btnCancel.caption := app.getErrorString( Close );
	
	self.populateTblAuditConfigs();
	
	self.doSelect();
	
	self.grpSelected.enabled := app.getMyUser.canDo( null, self.permissionMaint );
	
epilog

end;</source>
    </JadeMethod>
