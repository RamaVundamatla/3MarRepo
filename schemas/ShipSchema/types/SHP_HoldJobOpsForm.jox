    <JadeMethod name="doBuildContextMenu" id="ae8cc35e-9e71-45c9-8837-320fffe1229c">
        <updating/>
        <source>doBuildContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 19/08/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail
//
vars
	xLeft : Real;
	yTop : Real;
	obj : Object;
	currentTI : CM_TrackedItem;
	hasCurrentTI : Boolean;
	useTaskForm : Boolean;
	currentWle : CM_WorkListEntry;
	holdJob : CM_VoyageHoldJob;
	wle : CM_WorkListEntry;
	iter : Iterator;

begin
	xLeft := x;
	yTop := y;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	self.mnuVoyageContext.userObject := cntrl;	
	
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	obj := self.mnuVoyageContext.userObject;
	currentTI := self.myCurrentTrackedItem;
	
	//28 Jun 2017	NDL	TFS 4948
	if currentTI &lt;&gt; null then
		holdJob := self.cmbJob.listObject.CM_VoyageHoldJob;
		if holdJob &lt;&gt; null and not  holdJob.workListEntries.isEmpty then
			iter := holdJob.workListEntries.createIterator;
			while iter.next( wle) do
				if wle.status &lt;&gt; WLE_UNACTIONED then
					continue;
				endif;
				if wle.myTrackedItem &lt;&gt; currentTI then
					continue;
				endif;
				currentWle := wle;
				break;
			endwhile;
		endif;
	endif;
	
	self.mnuCargo.visible := true;	

	self.mnuSetStops.visible := false;
	self.mnuTasksAdd.visible := false;
	self.mnuTasksComplete.visible := false;
	self.mnuTasksRemove.visible := false;
	self.mnuCargoTaskAdd.visible := false;
	self.mnuCargoTaskComplete.visible := false;
	self.mnuCargoTaskRemove.visible := false;
	self.mnuMoveCargo.visible := true;
	self.mnuQtyChg.visible := false;	//30 Jun 2017	NDL	TFS 4948
	
	//30 Jun 2017	NDL	TFS 4948
	self.mnuQtyChg.visible := true;
	self.mnuQtyChg.enabled := false;
	self.mnuQtyChg.userObject := null;
	if currentTI &lt;&gt; null and currentWle &lt;&gt; null then
		if currentTI.myCargoType.isBreakBulkMulti or currentTI.myCargoType.isBulkMulti then
			self.mnuQtyChg.enabled := true;
			self.mnuQtyChg.userObject := currentWle;
		endif;
	elseif currentWle = null then
		self.mnuQtyChg.visible := false;
	endif;
	
	if currentTI &lt;&gt; null then 
		hasCurrentTI := true;
		
		self.mnuCargoEnquiry.visible 	:= true;	
		self.mnuCargoEdit.visible 		:= true;
		self.mnuCargoEnquiry.userObject := currentTI;	
		self.mnuCargoEdit.userObject 	:= currentTI;
		
		if currentTI.hasBeenMovedForJob(self.myCurrentJob) or not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			self.mnuMoveCargo.visible := false;
		endif;
		
		self.mnuSetStops.userObject	:= currentTI;
		self.mnuSetStops.visible 	:= true;
		self.mnuSetStops.enabled 	:= true;
		
		if useTaskForm then
			self.mnuCargoTaskAdd.visible := true;
			self.mnuCargoTaskComplete.visible := true;
			self.mnuCargoTaskRemove.visible := true;
		else
			self.myAssistant.buildMnuTasksAdd(self.mnuTasksAdd, self.mnuTasksAddSub, currentTI);
			self.myAssistant.buildMnuTasksComplete(self.mnuTasksComplete, self.mnuTasksCompleteSub, currentTI);
			self.myAssistant.buildMnuTasksRemove(self.mnuTasksRemove, self.mnuTasksRemoveSub, currentTI);
		endif;
	
		self.mnuCargo.userObject := currentTI; //&lt;-- used by sub menus click events	
	else 
		hasCurrentTI := false;
		self.mnuCargoEnquiry.visible := false;	
		self.mnuCargoEdit.visible := false;
		self.mnuCargoEnquiry.userObject := null;	
		self.mnuCargoEdit.userObject := null;
		self.mnuCargo.userObject := null;
	endif;
		
	self.mnuSummarise.visible := false;	// default this menu level to invisible, makes sub-menu invisible.
	
	if self.allowSummaryDefn then
		self.mnuSummarise.visible := true;
		// the summarise selected is only enabled if something is actually selected.
		self.mnuSummariseSel.visible :=	not self.tblJobDetails.allSelectedObjects.isEmpty;
	endif;
	
	self.mnuCargo.visible := 	self.mnuCargoEnquiry.visible or
								self.mnuCargoEdit.visible or
								self.mnuSetStops.visible or
								self.mnuTasksAdd.visible or
								self.mnuTasksComplete.visible or
								self.mnuTasksRemove.visible;								
								
	self.mnuColumnOrg.userObject := obj;
	
	self.mnuDirectRelease.visible := false;	 // TFS 42872
	self.mnuUnassignDR.visible := false;	 // TFS 42872
	// Direct Release button only visible on Load Jobs
	// Dischage wles are set for direct release by drag/drop
	if self.myCurrentWLE &lt;&gt; null and 							// TFS 42872
	   not self.myCurrentWLE.isReceipt and						// TFS 42872
	   self.myCurrentWLE.myTrackedItem &lt;&gt; null and				// TFS 42872
	   app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then // TFS 42872
		currentTI := self.myCurrentWLE.myTrackedItem;			// TFS 42872
		
	    if currentTI.myPrimaryActualLocation &lt;&gt; null then		// TFS 42872
			// Only show the button if the cargo is currently on a wagon, or tuck
			// if it's in the yard, it can't be assigned to direct release
			if currentTI.myPrimaryActualLocation.isWagon or		// TFS 42872
			   currentTI.myPrimaryActualLocation.isVehicle or	// TFS 42872
			   currentTI.isTranshipOnInboundVoyage	then		// TFS 47085 jlgzm1 31/10/2019
				self.mnuDirectRelease.visible := true;			// TFS 42872
				self.mnuDirectRelease.enabled := true;			// TFS 42872
				self.mnuUnassignDR.visible := true;			// TFS 42872
				self.mnuUnassignDR.enabled := true;			// TFS 42872
			endif;
		endif;
	endif;
	
	self.mnuInspectObject.visible := false;
	self.mnuInspectSep.visible := false;
	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
		self.mnuInspectSep.visible := true;
	endif;
	
	self.popupMenu(self.mnuVoyageContext, xLeft.Integer, yTop.Integer);
	return false;
	
epilog

	delete iter;

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBuildSubAreaCombo" id="8869b331-6c7e-4d87-b844-779dad9990ee">
        <source>doBuildSubAreaCombo();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 01/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 25/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	obj : CM_Object;
	termArea : CM_TerminalArea;
	lc : CM_LocationsController;
	col : CM_GridColumn;
	rc : CM_RoRoController;
	row : CM_GridRow;
	idx : Integer;

begin
	self.cmbSubArea.clear;
	obj := self.cmbDischLoad.listObject.CM_Object;
	if obj = null or not obj.isKindOf(CM_TerminalArea) then
		return;
	endif;
	
	termArea := obj.CM_TerminalArea;
	if not termArea.isGridArea then
		if not termArea.isIrregularBlockArea() and not termArea.type = TA_TYPE_RORO_LANE_AREA 
		and not termArea.isGeneralCargoAllocArea then									// TFS 49453
			return;
		endif;
	endif;
	
	if termArea.isIrregularBlockArea then
		foreach lc in termArea.CM_IrregularBlockArea.allLocationsControllers discreteLock do
			self.cmbSubArea.addItemObject(termArea.id &amp; " - " &amp; lc.ident, lc);
		endforeach;
	elseif termArea.type = TA_TYPE_FORK_LIFT_STACK then
		foreach col in termArea.CM_GridArea.allGridColumns discreteLock do
			self.cmbSubArea.addItemObject(termArea.id &amp; " - " &amp; col.label, col);
		endforeach;
	elseif termArea.type = TA_TYPE_RORO_LANE_AREA then
		foreach rc in termArea.CM_RoRoLaneArea.allLanesById discreteLock do	
			self.cmbSubArea.addItemObject(termArea.id &amp; " - " &amp; rc.ident, rc);
		endforeach;
	elseif termArea.isGeneralCargoAllocArea then										// TFS 49453
		foreach lc in termArea.CM_GeneralCargoAllocRowArea.allRowControllersById do		// TFS 49453
			self.cmbSubArea.addItemObject(termArea.id &amp; " - " &amp; lc.ident, lc);			// TFS 49453
		endforeach;																		// TFS 49453
	else
		foreach row in termArea.CM_GridArea.allGridRows discreteLock do
			self.cmbSubArea.addItemObject(termArea.id &amp; " - " &amp; row.label, row);
		endforeach;
	endif;
	
	if self.cmbSubArea.listCount = 1 then
		self.cmbSubArea.listIndex := 1;
	endif;
	
	if self.myDischargeSubArea &lt;&gt; null then
		idx := self.cmbSubArea.findObject(self.myDischargeSubArea);
		if idx &gt; 0 then
			self.cmbSubArea.listIndex := idx;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doColourTableRow" id="ecd695c7-a673-4c45-aeac-23a1c0c4a7ca">
        <updating/>
        <source>doColourTableRow(_wle : CM_WorkListEntry; _job : CM_VoyageHoldJob; _row : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 03/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 16/08/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail
//
vars
	splitTI : CM_TrackedItem;
	table : CM_BaseTable;
	foreColour, backColour : Integer;
	rtCol : Integer; // TFS 42872
begin
	table := self.tblJobDetails;
	rtCol := table.CM_DataTable.getColumnByRowName(ETRow_RadioTelemetry); // TFS 42872
	_wle.getRowColour(foreColour, backColour);
	table.accessRow(_row).foreColor := foreColour;
	table.accessRow(_row).backColor := backColour;
	self.displayWLEsShowRT(table.CM_DataTable, _row, rtCol); // TFS 42872
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDischargeFromShip" id="39298619-ec26-4783-a096-542e60026a1e">
        <source>doDischargeFromShip(_job : CM_VoyageHoldJob; _wle : CM_WorkListEntry; _effectiveTS : TimeStamp);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 24/02/2017	cnwdap1		TFS 3489 LNX DLR/SOB Special handling for DLRs
// 19/10/2017	jlgdap1		TFS 7492 LNX Voyage Hold Jobs - need to keep track of weight as well as quantity for LNX
// 14/08/2018	jlgdap1		TFS 40003 PEl1 Voyage to Road Moves
// 25/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	moveController : CMIF_MoveController;
	listObject : CM_Object;
	targetLocn : CM_LocationsController;
	ta : CM_TerminalArea;
	gridObject : CM_GridObject;
	requiresJob : Boolean;
	wle : CM_WorkListEntry;
	result : Integer;
	showMoveConfirmation: Boolean;

begin
	// 08 Apr 2011	NDL	Par 27045
	if self.cmbDischLoad.listIndex &lt; 1 then
		app.msgBox(app.getErrorString(PleaseSelectLocation), 'Select Discharge Area', MsgBox_Stop_Icon + MsgBox_OK_Only);		
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	if global.isValidObject(app.myMoveController) then
		delete app.myMoveController;
	else
		app.myMoveController := null;
	endif;

	create moveController transient;
	app.myMoveController := moveController;
	moveController.setMyWorkListEntry(_wle);
	moveController.setMyTrackedItem(_wle.myTrackedItem);
	moveController.setMyOriginatingLocation(_wle.myTrackedItem.myPrimaryActualLocation);
	moveController.setMoveMode(REAL_MODE);
	//moveController.setQuantity(_wle.myTrackedItem.totalQuantity);		// TFS 7492
	//moveController.setWeight(_wle.myTrackedItem.totalWeight);			// TFS 7492
	moveController.setQuantity(_wle.quantity);							// TFS 7492
	moveController.setWeight(_wle.weight);								// TFS 7492
	if _effectiveTS &lt;&gt; null then
		moveController.setEffectiveTimeStampOverride(_effectiveTS);
	endif;
	moveController.isHoldDLR := _wle.myTrackedItem.isRehandle;					// TFS 3489
	
	if self.cmbDischLoad.listObject = null and self.myCurrentVoyage.isHOLDSorSHIP() then
		// No target location, tis are released directly off site for non-worked voyages
		targetLocn := null;
	else //non-planned or mixed voyage - see if they have selected a discharge area
		listObject := self.cmbDischLoad.listObject.CM_Object;
		if CM_TerminalArea.hasInstance(listObject) then
			ta := listObject.CM_TerminalArea; 
		elseif CM_LocationsController.hasInstance(listObject) then
			targetLocn := listObject.CM_LocationsController;
		elseif CM_Wagon.hasInstance(listObject) then
			targetLocn := self.cmbSubArea.listObject.CM_LocationsController;
		endif;
		
		if targetLocn = null then
			if ta = null then
				requiresJob := false;
				if moveController.myTrackedItem.myPrimaryActualLocation.requiresJob then 
					requiresJob := true;
				endif;
				
				if requiresJob then
					// they must select a discharge area			
					app.msgBox(app.getErrorString1(Requires_job_discharge_offsite, _wle.myTrackedItem.id), app.getErrorString(Select_discharge_area), MsgBox_Stop_Icon + MsgBox_OK_Only);
					return;
				endif;
			else
				if ta.isGridArea() then
					gridObject := self.cmbSubArea.listObject.CM_GridObject;
					if gridObject = null then
						app.msgBox(app.getErrorString(PleaseSelectLocation), app.getErrorString(Select_discharge_area_row), MsgBox_Stop_Icon + MsgBox_OK_Only);		
						return;
					endif;
					targetLocn := gridObject.getNextAvailableLocation(REAL_MODE);
					if targetLocn = null then
						app.msgBox(app.getErrorString2(There_empty_locations,ta.id, gridObject.label), app.getErrorString(Select_discharge_area), MsgBox_Stop_Icon + MsgBox_OK_Only);	 //+ cnwmd1 Par 24382
						return;
					endif;
				
				elseif ta.isIrregularBlockArea()  or ta.type=TA_TYPE_RORO_LANE_AREA 
				or ta.isGeneralCargoAllocArea then										// TFS 49453
					targetLocn := self.cmbSubArea.listObject.CM_LocationsController;
					if targetLocn = null then
						app.msgBox(app.getErrorString1(Please_select_locatio_within, ta.id), app.getErrorString(Select_discharge_area), MsgBox_Stop_Icon + MsgBox_OK_Only);
						return;
					endif;
				else
					targetLocn := ta.getLocationsController();		
				endif;
			endif;
		endif;
	endif;	
	
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyToPrimaryLocation(targetLocn);
	moveController.isNonCraneVoyageMove := true;
	
	if moveController.myTrackedItem &lt;&gt; null and moveController.myTrackedItem.canMergeBreakBulk then
		if not self.getQuantityForMove(moveController) then
			return;
		endif; 
	endif;
	
	if targetLocn.isKindOf(CM_VehicleController) and  moveController.myTrackedItem &lt;&gt; null then
		wle := moveController.myTrackedItem.getIncompleteRoadWleForJob(targetLocn.CM_VehicleController.vehicle, false);
		if wle &lt;&gt; null then
			//moveController.setMyWorkListEntry(wle);			// TFS 40003
			moveController.myDDWorkListEntry := wle;			// TFS 40003
			moveController.myDDJob := wle.job;					// TFS 40003
		endif;
	endif;

	/*	28/9/17 MAP TFS6818	nonWorkedInstantPreMove should not be called from Hold Ops form
	showMoveConfirmation := app.myPassport.myTerminal.getConfig(HhShowUnplanOptions).Boolean;		// 8/9/17 MAP TFS6818
	if showMoveConfirmation then
		moveController.nonWorkedInstantPreMove();
	
		if moveController.priority = 888 then		// 28/6/17 MAP TFS4719
			return;		// user has cancelled attempt to move cargo already planned
		endif;
	endif;
	*/

	while true do	
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		if not app.myPassport.trxCompletedOK then	
			result := app.showErrorWarningDialog('Discharge Cargo', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				moveController.isNonCraneVoyageMove := true; 
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_effectiveTS" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="doDischargeLoadJob" id="8e366e9e-f40f-45db-b721-e7b85442cd69">
        <source>doDischargeLoadJob();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 30/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyge Operations Enhancements
//
vars
	job : CM_VoyageHoldJob;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	effectiveTS : TimeStamp;
	shift : CM_Shift;
	convertedEffectTS : TimeStamp;

begin
	job := self.cmbJob.listObject.CM_VoyageHoldJob;
	if job = null then
		return;
	endif;
	wle := self.tblJobDetails.allSelectedObjects.first.CM_WorkListEntry;	// can only select one row at a time
	if wle = null then
		return;
	endif;
	
	effectiveTS := null;
	if self.txtEffectiveDate.getDate &lt;&gt; null then
		effectiveTS.setDate(self.txtEffectiveDate.getDate);
		effectiveTS.setTime(self.txtEffectiveTime.getTime);
		
		// effective date/time must be within the shift start/end time
		shift := job.myShift;
		
		if shift &lt;&gt; null // TFS 3631
		and (effectiveTS &lt; shift.startDateTime or effectiveTS &gt; shift.endDateTime) then
			app.raiseCMException(Effective_date_in_shift_dates, null, null);
			return;
		endif;
		
		//29 Jun 2017	NDL	TFS 5160
		//And now we need to convert the date to a database relevant time, because it gets stamped on transactions.
		//Has to be after comparing to the shift date/time, because shift times these are not REAL timestamps
		convertedEffectTS := effectiveTS.localToSystemTimeUsingObject(self.myTerminal);
	else
		convertedEffectTS := null;
	endif;
	effectiveTS := convertedEffectTS;
	
	// is this a discharge or a load job?
	if job.isDischarge then
		self.doDischargeFromShip(job, wle, effectiveTS);
	else
		self.doLoadToShip(job, wle, effectiveTS);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHandleRemarkSaveBtns" id="4a43646b-45b2-422d-b2c2-176a1677c0df">
        <source>doHandleRemarkSaveBtns( btn : Button );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2017	cnwndl1	Initial creation	TFS 5222

*/

vars

	job : CM_VoyageHoldJob;
	shift : CM_Shift;
	pxyShift : CM_Shift;
	newJobRemarks : String;
	newShiftRemarks : String;
	jrChged : Boolean;
	srChged : Boolean;
	loadState : Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	job := self.myCurrentJob.CM_VoyageHoldJob;
	if job &lt;&gt; null then
		newJobRemarks := self.txtJobRemarks.text;
		jrChged := newJobRemarks &lt;&gt; job.remarks;
		shift := job.myShift;
		if shift &lt;&gt; null then
			newShiftRemarks := self.txtShiftRemarks.text;
			srChged := newShiftRemarks &lt;&gt; shift.remarks;
		endif;
	endif;
	
	self.btnSaveSR.visible := job &lt;&gt; null;
	self.btnSaveSR.enabled := jrChged or srChged;
		
	if btn = self.btnSaveSR then
	
			
	
		if srChged then
		
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxUpdateShiftRemarks( shift, newShiftRemarks, app.myPassport );
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('Remarks', app.myPassport, ErrWarnMode_AddUpdate);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;

		endif;
		
		if jrChged then
		
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxUpdateVoyageJobRemarks( job, newJobRemarks, app.myPassport );
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('Remarks', app.myPassport, ErrWarnMode_AddUpdate);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;
			
		endif;
		
		self.doHandleRemarkSaveBtns( null );
	
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button"/>
    </JadeMethod>
    <JadeMethod name="doLoadToShip" id="ce684489-abee-4f5a-87e4-f80021a1cab7">
        <source>doLoadToShip(_job : CM_VoyageHoldJob; _wle : CM_WorkListEntry; _effectiveTS : TimeStamp);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
/* Changes

Date		Name	TFS#		Description
============================================================================
02/02/2017	cnwdap1	TFS 3220 	Initial creation  - LNX Voyage Operations Enhancements
02/08/2018	jlgdap1	TFS 39964 	PEL1 Hold Job Ops Loading Changes
14/08/2018	jlgdap1	TFS 40003 	PEl1 Voyage to Road Moves
02/10/2019  jlgka1 	TFS 46600 	PEL1 - Loading break-bulk PreNote to ship using Job Lander
								Make Hold Operation to function similar to the Job Lander ( Handheld Apps ).
10/11/2021	navdap1	TFS 52360	SAL Direct Prenote to Voyage Incorrect Job Values
07/12/2021	navdap1	TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
============================================================================*/
vars
	targetLocn 		: CM_LocationsController;
	moveController 	: CMIF_MoveController;
	wle 			: CM_WorkListEntry;
	result 			: Integer;
	showMoveConfirmation: Boolean;
	job 			: CM_Job;
	ddWleSet 		: Boolean;						// TFS 40003
	ti				: CM_TrackedItem;		// TFS 52360

begin
	targetLocn := self.cmbDischLoad.listObject.CM_LocationsController;
	
	if targetLocn = null then
		//something is seriously wrong with the ship
		app.raiseCMException(Input_required_field_loadTo, null, null);
		self.cmbDischLoad.setFocus();
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;		

	if global.isValidObject(app.myMoveController) then
		delete app.myMoveController;
	else
		app.myMoveController := null;
	endif;
	create moveController transient;
	app.myMoveController := moveController;
	ti := _wle.myTrackedItem;											// TFS 52360
	moveController.setMyWorkListEntry(_wle);
	//moveController.setMyTrackedItem(_wle.myTrackedItem);				// TFS 52360
	moveController.setMyTrackedItem(ti);								// TFS 52360
	moveController.setMyToPrimaryLocation(targetLocn);	
	moveController.setMoveMode(REAL_MODE);
	moveController.setIsFromWeb(true); //jlgka1 TFS 46600
	moveController.isNonCraneVoyageMove := true;
	//moveController.setQuantity(_wle.myTrackedItem.totalQuantity);		// TFS 52360
	//moveController.setWeight(_wle.myTrackedItem.totalWeight);			// TFS 52360
	moveController.setQuantity(ti.totalQuantity);						// TFS 52360
	moveController.setWeight(ti.totalWeight);							// TFS 52360
	// TFS 52360 switch to 'special' stored wle value if needed
	//if self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean and _wle.CM_VoyageWLE.subSeqNum &lt;&gt; null then	// TFS 52293
	if _wle.job &lt;&gt; null and _wle.job.isDirectDeliveryJob and _wle.CM_VoyageWLE.subSeqNum &lt;&gt; null then			// TFS 52293
		if ti.isBulkByQuantity then
			moveController.setQuantity(_wle.CM_VoyageWLE.subSeqNum);
		else
			moveController.setWeight(_wle.CM_VoyageWLE.weight.Integer);
		endif;
	endif;
	// TFS 52360 end of this bit
	if _effectiveTS &lt;&gt; null then
		moveController.setEffectiveTimeStampOverride(_effectiveTS);
	endif;
	if _wle.myTrackedItem.isNotified then							// TFS 39964
		moveController.isPrenoteDirectToShip := true;				// TFS 39964
	endif;															// TFS 39964
	
	// CNWAB1 MAY2017 TFS 4435
	if moveController.myToPrimaryLocation &lt;&gt; null then
		//moveController.transferType := moveController.myToPrimaryLocation.getTransferType();
		//12 Mar 2018	NDL	TFS 37444
		if _wle &lt;&gt; null then
			job := _wle.job;
		endif;
		moveController.setTransferTypeFromJob( job, moveController.myToPrimaryLocation.getTransferType() );	//12 Mar 2018	NDL	TFS 37444
	endif;

	if moveController.myTrackedItem &lt;&gt; null and moveController.myTrackedItem.canMergeBreakBulk then
		if not self.getQuantityForMove( moveController ) then
			return;
		endif; 
	endif;
	if moveController.myTrackedItem &lt;&gt; null and  moveController.myTrackedItem.myPrimaryActualLocation.isKindOf(CM_VehicleController)  then
		wle := moveController.myTrackedItem.getIncompleteRoadWleForJob(moveController.myTrackedItem.myPrimaryActualLocation.CM_VehicleController.vehicle, true);
		if wle &lt;&gt; null then
			moveController.setMyWorkListEntry(wle);
			moveController.myDDWorkListEntry := _wle;			// TFS 40003
			moveController.myDDJob := _wle.job;					// TFS 40003
			ddWleSet := true;									// TFS 40003
		endif;
	endif;
	
	/*	28/9/17 MAP TFS6818	nonWorkedInstantPreMove should not be called from Hold Ops form
	showMoveConfirmation := app.myPassport.myTerminal.getConfig(HhShowUnplanOptions).Boolean;		// 8/9/17 MAP TFS6818
	if showMoveConfirmation then
		moveController.nonWorkedInstantPreMove();
	
		if moveController.priority = 888 then		// 28/6/17 MAP TFS4719
			return;		// user has cancelled attempt to move cargo already planned
		endif;
	endif;
	*/

	while true do
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog('Load Cargo', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				if ddWleSet then										// TFS 40003
					// reset DD wle references on move controller		// TFS 40003
					moveController.myDDWorkListEntry := _wle;			// TFS 40003
					moveController.myDDJob := _wle.job;					// TFS 40003
				endif;													// TFS 40003
				// TFS 52360 reset TI reference so we get the originating location reset on the move controller
				moveController.setMyTrackedItem(ti);
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	/*11/02/19 jlgzm1 TFS43294 LNX do not want effective time reseting to null after loading
	if app.myPassport.trxCompletedOK then
		self.txtEffectiveDate.setDate(null);
		self.txtEffectiveTime.setTime(null);
	endif;
	*/
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_effectiveTS" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="doMnuCargoEditEnquire" id="cb042dd2-3cd4-4887-b932-eb41c1bd2f46">
        <source>doMnuCargoEditEnquire(_ti : CM_TrackedItem; _editCurrentObject : Boolean);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	objArr, tiArr : ObjectArray;
	ti, firstTI : CM_TrackedItem;
	wle : CM_WorkListEntry;
	obj : Object;
begin
	create objArr transient;
	create tiArr transient;
	self.tblJobDetails.allSelectedObjects.copy(objArr);
	
	foreach obj in objArr discreteLock do
		wle := obj.CM_WorkListEntry;
		ti := wle.myTrackedItem;
		if ti &lt;&gt; null then
			tiArr.add(ti);
			if firstTI= null then
				firstTI := ti;
			endif;
		endif;
	
	endforeach;

	if objArr.size &gt; 0 then
		self.myAssistant.showCargoEnquiryForTIs(firstTI, tiArr, self.myMasterMenuAction, _editCurrentObject);
	endif;
	
epilog
	delete objArr;
	delete tiArr;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_editCurrentObject" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuColourLegend" id="349aa7f2-8317-43f6-bbe0-3b35c31970a3">
        <source>doMnuColourLegend();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 03/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	colLegend : CMUI_ColourLegend;
begin
	// Update the navigator
	create colLegend;
	self.setNavigatorHeading(colLegend.caption); 
	colLegend.centreWindow;
	colLegend.addLegendItem(app.getErrorString(Unactioned_receipt), CM_Job.Colour_ReceiptUnactioned, White, null, false);
	colLegend.addLegendItem(app.getErrorString(Unactioned_release), CM_Job.Colour_ReleaseUnactioned, White, null, false);
	colLegend.addLegendItem(app.getErrorString(Partially_worked_receipt), CM_Job.Colour_ReceiptPartComplete, White, null, false);
	colLegend.addLegendItem(app.getErrorString(Partially_worked_release), CM_Job.Colour_ReleasePartComplete, White, null, false);
	colLegend.addLegendItem(app.getErrorString(Completed_receipt), White, CM_Job.Colour_ReceiptComplete, null, false);
	colLegend.addLegendItem(app.getErrorString(Completed_release), White, CM_Job.Colour_ReleaseComplete, null, false);
	
	colLegend.showModal;

epilog
	delete colLegend;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuSetStopsClick" id="38b182b8-81d9-4df4-9f41-bc7cdd83e754">
        <updating/>
        <source>doMnuSetStopsClick(_menuItem: MenuItem input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	ti : CM_TrackedItem;
begin
	ti := _menuItem.userObject.CM_TrackedItem; 
	self.myAssistant.showStopsForm_TI(ti, null, app.getMyUser.canUpdateStops(self.myTerminal));
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuSummariseAll" id="01d603af-01b6-471d-8e65-06165117cadd">
        <source>doMnuSummariseAll();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	coll : ObjectSet;
	idx : Integer;
	ctrl : Control;
	
begin
	app.mousePointer := Busy;
	create coll transient;
	
	// Get a collection of ALL the objects to pass to the Summary Definition form.
	self.tblJobDetails.getAllRowObjects(coll);
	self.myAssistant.showXTABSummaryDefinitionForm(coll, false, false, false, true);
	
epilog
	delete coll;
	app.mousePointer := Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuSummariseSel" id="80585248-458b-4bb0-8575-10536407dae5">
        <source>doMnuSummariseSel();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
