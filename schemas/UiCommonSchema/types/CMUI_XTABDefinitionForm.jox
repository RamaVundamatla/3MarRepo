    <JadeMethod name="createProxyDefinition" id="a065033c-700a-4138-aeea-568f684cfcaf">
        <updating/>
        <source>createProxyDefinition() updating, protected;
/* ---------------------------------------------------------------------------
Created:     29 January 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	if self.myProxyXTAB &lt;&gt; null then
		delete self.myProxyXTAB;
	endif;
	
	self.currentXTABEdition := null;
	if self.myCurrentXTAB = null then
		return;
	endif;
	
	beginLoad;
	sharedLock( self.myCurrentXTAB );
	self.currentXTABEdition	:= self.myCurrentXTAB.edition;
	self.myProxyXTAB		:= self.myCurrentXTAB.cloneSelf( true );
	
epilog
	endLoad;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createProxyForNewXTAB" id="25519373-6683-4a83-915d-7573a52da8c7">
        <updating/>
        <source>createProxyForNewXTAB()updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/02/2010	cnwcs5		ccms 1925 / 22295 - release summaries
//							change way we set default mode
// ---------------------------------------------------------------------------
vars
	type, mode	:Integer;
begin
	// create proxy for new item
	create self.myProxyXTAB transient;
	
	self.myProxyXTAB.setName( ( app.getString( XTAB_New_Summary_Definition, process.userCode ) ) );
	
	self.getDefaultModeAndTypeFromColl (type, mode);	// 12/02/2010 cnwcs5 ccms 1925
	self.myProxyXTAB.setModeAndType (mode, type);		// 12/02/2010 cnwcs5 ccms 1925
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="delete" id="68c88b56-4449-4e7a-9b48-a4c17dbf67dc">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     09 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if not self.isBaseFormModal and self.myProxyXTAB &lt;&gt; null then
		// for the modal version this reference will be taken care off in the display form.
		delete self.myProxyXTAB;
	endif;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="displayOnSetupForm" id="7e9f39f7-e42e-4612-b5f2-96588c7ebd5e">
        <updating/>
        <source>displayOnSetupForm() updating, protected;

/*

Purpose:		This method will display the form and details in the appropriate state for inital start up.
				This will usually be with a "New Summary" definition and with hidden details.
Parameters:		
Return Value:	

Date				Who		Reason
29 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	// start with a new definition (which will show the form details).
	self.doBtnNewDefn(false); // TFS 7528 added param
	// and hide the details if so requested.
	if not self.showDetails then
		self.doBtnHideDetails;
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displaySelectorResults" id="b295a685-371f-4e26-9ca3-baf2756438b3">
        <updating/>
        <source>displaySelectorResults( _resultCollection : Collection; _mode : Integer ) updating;
// ---------------------------------------------------------------------------
// Created:     03 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	// if we come in with a collection of logs and are currently displaying a collection
	// of vehicles, the summary should just return null values for any invalid properties
	self.myCollection.clear;
	_resultCollection.copy( self.myCollection );
	
epilog
	
end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayXTABDefinition" id="f36e34e8-9758-4ea4-8a04-0674bb031110">
        <updating/>
        <source>displayXTABDefinition(_format :CM_OutputFormat_XTAB)updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tab			: CM_XTABGrouping;
	row			: CM_XTABGrouping;
	col			: CM_XTABGrouping;
	field		: CM_XTABField;
	
begin
	self.zClearProxyDetails;
	
	if _format &lt;&gt; null then
		self.setMyQueryDefinition( _format.getQueryDefinition );
		//cmbMode.listObject := self.myQueryDefinition;
		self.cmbMode.listIndex := self.cmbMode.findObject(self.myQueryDefinition);
		
		// build up a collection of the controls we will use.
		foreach tab in _format.allTabs do
			self.setupControlForXTABElement( tab, self.allButtons_tabs, self.frmTabs, null );
		endforeach;
		
		foreach row in _format.allRows do
			self.setupControlForXTABElement( row, self.allButtons_rows, self.frmRows, null );
		endforeach;
		
		foreach col in _format.allColumns do
			self.setupControlForXTABElement( col, self.allButtons_columns, self.frmColumns, null );
		endforeach;
		
		foreach field in _format.allFields do
			self.setupControlForXTABElement( field, self.allButtons_cells, self.frmCells, null );
		endforeach;
	endif;
	
	self.refreshTabs;
	self.refreshRows;
	self.refreshColumns;
	self.refreshFields;
	
	// populate folder
	self.loadTableSheet( _format );
	
	shtProperties.enabled	:= false;
	shtGroupings.enabled	:= false;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_format" type="CM_OutputFormat_XTAB"/>
    </JadeMethod>
    <JadeMethod name="doAddCell" id="4369e662-10e1-4046-aa18-67336dbd22a3">
        <updating/>
        <source>doAddCell( _property : CM_QueryProperty; _beforeButton : Button ) : Button updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	field	:CM_XTABField;
	btn		:Button;
	pos		:Integer;
begin
	create field transient;
	field.setPropertyName (_property.propertyName);
	field.setFunction (self.getDefaultFunctionForProperty (_property));	// cnwcs5 17/12/2009
	
	if _beforeButton &lt;&gt; null then
		pos := self.allButtons_cells.indexOf (_beforeButton);
	endif;
	
	if pos = 0 then
		self.myProxyXTAB.allFields.add (field);
	else
		self.myProxyXTAB.allFields.insert (pos,field);
	endif;
	
	btn := self.setupControlForXTABElement (field, self.allButtons_cells, self.frmCells, pos);
	
	self.refreshFields;
	self.zSetControls();			// cnwrl1 22/06/2009 PAR 19993
	
	return btn;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="CM_QueryProperty"/>
        <Parameter name="_beforeButton" type="Button"/>
        <ReturnType type="Button"/>
    </JadeMethod>
    <JadeMethod name="doAddColumn" id="66fb4d6f-3e94-4bbe-b88e-60c0abdd19d7">
        <source>doAddColumn(_property :CM_QueryProperty; _beforeButton :Button):Button protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	return self.doAddGrouping (self.frmColumns, _property, _beforeButton);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="CM_QueryProperty"/>
        <Parameter name="_beforeButton" type="Button"/>
        <ReturnType type="Button"/>
    </JadeMethod>
    <JadeMethod name="doAddGrouping" id="df11838b-2ca7-4ed6-b160-62fdb73332b7">
        <source>doAddGrouping(_parent :Frame; _property :CM_QueryProperty; _beforeButton :Button):Button protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	format			:CM_OutputFormat_XTAB;
	grouping		:CM_XTABGrouping;
	oldColl, newColl, 
	newButtonColl	:ObjectArray;
	btn				:Button;
	pos				:Integer;
begin
	format  	:= self.myProxyXTAB;
	
	// make sure we are not adding something we already have
	if _parent = self.frmTabs then
		grouping		:= format.findTab (_property.propertyName);	
		newColl			:= format.allTabs;
		newButtonColl	:= self.allButtons_tabs;
	elseif _parent = self.frmRows then
		grouping		:= format.findRow (_property.propertyName);
		newColl			:= format.allRows;
		newButtonColl	:= self.allButtons_rows;
	else
		grouping		:= format.findColumn (_property.propertyName);	
		newColl			:= format.allColumns;
		newButtonColl	:= self.allButtons_columns;
	endif;
	
	if grouping &lt;&gt; null then	
		// property already used in context
		return null;
	endif;
	
	if _parent &lt;&gt; self.frmTabs then
		grouping := format.findTab (_property.propertyName);
		oldColl		:= format.allTabs;
	endif;
	
	if grouping = null and _parent &lt;&gt; frmRows then
		grouping 	:= format.findRow (_property.propertyName);
		oldColl		:= format.allRows;
	endif;
	
	if grouping = null and _parent &lt;&gt; frmColumns then
		grouping 	:= format.findColumn (_property.propertyName);
		oldColl		:= format.allColumns;
	endif;
	
	if grouping &lt;&gt; null then
		btn 		:= self.findButtonForXTABElement (grouping);
		btn.parent 	:= _parent;
		
		if oldColl = format.allTabs then
			format.allTabs.remove (grouping);
			self.allButtons_tabs.remove (btn);	
			self.refreshTabs;	
		elseif oldColl = format.allRows then
			format.allRows.remove (grouping);
			self.allButtons_rows.remove (btn);	
			self.refreshRows;
		else
			format.allColumns.remove (grouping);
			self.allButtons_columns.remove (btn);	
			self.refreshColumns;
		endif;
	endif;
	
	if grouping = null then
		create grouping transient;
		grouping.setPropertyName (_property.propertyName);
	endif;
	
	if _beforeButton &lt;&gt;  null then
		pos := newButtonColl.indexOf (_beforeButton);
	endif;
	
	if pos = 0 then
		newColl.add (grouping);
	else
		newColl.insert (pos, grouping);
	endif;
	
	if btn = null then
		btn := self.setupControlForXTABElement (grouping, newButtonColl, _parent, pos);
	else
		if pos = 0 then
			newButtonColl.add (btn);
		else
			newButtonColl.insert (pos, btn);
		endif;
	endif;
	
	if _parent = self.frmTabs then
		self.refreshTabs;
	elseif _parent = self.frmRows then
		self.refreshRows;
	else
		self.refreshColumns;
	endif;
	
	return btn;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_parent" type="Frame"/>
        <Parameter name="_property" type="CM_QueryProperty"/>
        <Parameter name="_beforeButton" type="Button"/>
        <ReturnType type="Button"/>
    </JadeMethod>
    <JadeMethod name="doAddRow" id="f7ada8bf-b3a9-4192-8569-9cf62e5942fc">
        <source>doAddRow(_property :CM_QueryProperty; _beforeButton :Button):Button protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	return self.doAddGrouping (self.frmRows, _property, _beforeButton);
epilog

end;</source>
