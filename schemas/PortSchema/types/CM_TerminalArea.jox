    <JadeMethod name="importMyCollectionsXML" id="c2560ebe-d521-4b86-bbe1-6cc207a5df7b">
        <updating/>
        <source>importMyCollectionsXML(_collectionsBlock: String) updating;
// ---------------------------------------------------------------------------
// Created:     11 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	newRow				: CM_WarehouseRowController;
	allLCsBlock,
	lcBlock			: String;
	blockLength,
	pos				: Integer;

begin
	self.myTerminal := app.myRoot.allTerminals['POE'];
	
	allLCsBlock := _collectionsBlock.cnEcGetTagValueOfName('allLocationsControllers');
	if allLCsBlock = null then
		return;
	endif;
	
	blockLength := allLCsBlock.length;
	pos := 1;
	
	while pos &lt; blockLength do
		lcBlock := allLCsBlock.cnEcGetNextTagValueOfName('CM_WarehouseRowController', pos);
		if pos &lt; 1 then
			break;
		endif;
		
		if lcBlock = null then
			continue;
		endif;
		
		create newRow persistent;
		newRow.setPropertyValue('myTerminalArea', self);
		newRow.importMeXML(lcBlock);
	endwhile;

end;</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
