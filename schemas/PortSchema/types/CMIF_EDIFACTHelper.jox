     self.allParams.purge;
     

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getParamsForDataType" id="c2d12503-61f0-4166-9df2-2be5b9a5a039">
        <source>getParamsForDataType(_ediDataType : Integer) : CMIF_EDIFACTParams;
/*

Date		Who		Reason
17 February 2017	cnwer1	Initial creation TFS 2774

*/

vars
	obj : Object;
	ediParams : CMIF_EDIFACTParams;
begin
	
	foreach obj in self.allParams discreteLock do
		ediParams :=obj.CMIF_EDIFACTParams;
		if ediParams.ediDataType = _ediDataType then
			return ediParams;
		endif;
	endforeach;
	
	return null;
	
	
	
	
epilog

end;</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <ReturnType type="CMIF_EDIFACTParams"/>
    </JadeMethod>
