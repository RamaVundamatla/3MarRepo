					delete collObj;
				endif;
			endif;
			abortTransaction;
		endforeach;
		delete collArray;
		delete allProps;
	endforeach;
	
	self.assertEqualMsg(count, 0, "Proxy objects without collections being populated!");
	
epilog

	delete collArray;
	delete masterSubclasses;
	delete superClassSet;
	process.allTransientInstances(endingTransients, 0);
	foreach obj in endingTransients do
		if not initialTransients.includes(obj) then

			delete obj;
		endif;
	endforeach;
	delete endingTransients;
	delete initialTransients;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckQryProperties" id="fa2fb625-d935-4449-ab50-fcbb3b14fd88">
        <source>tCheckQryProperties();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2019	jlgndl1	Initial creation	TFS 45891

*/

vars

	iter : Iterator;
	queryProp : CM_QueryProperty;
	objArray : ObjectArray;
	obj : Object;
	count : Integer;

begin

	create objArray transient;
	CM_QueryProperty.allInstances( objArray, 0, true );
	
	iter := objArray.createIterator;
	while iter.next( queryProp ) do
		if queryProp.myQueryDef = null then
			if queryProp.performanceRating = 0 then
				count := count + 1;
			endif;
			continue;
		endif;
		self.assertTrueMsg( queryProp.performanceRating &lt;&gt; 0, "See " &amp; queryProp.myQueryDef.class.name &amp; "::createProperties - " &amp; queryProp.niceName &amp; " [" &amp; queryProp.propertyClassName &amp; "::" &amp; queryProp.propertyName &amp; "] (" &amp; queryProp.String &amp; ") has no performance rating" );
	endwhile;
//	write count;
	
epilog

	delete objArray;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckQryProperties2" id="a5f17310-5abd-44c5-afe7-557ee1c2f1a2">
        <source>tCheckQryProperties2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2020	jlgndl1	Initial creation	TFS 47780

*/

vars

	schema: Schema;
	obj : Object;
	objArray : ObjectArray;
	
	queryProp : CM_QueryProperty;
	queryPropClassName : String;
	queryPropClass : Class;
	propOnQuery : Property;
	
	listBoxPropName : String;
	listBoxProp : Property;
	errStr : String;

begin

	schema := currentSchema;
	while schema.name &lt;&gt; "PortSchema" do
		schema := schema.superschema;
	endwhile;

	create objArray transient;
	CM_QueryDefinition.allInstances( objArray, 0, true );
	foreach obj in objArray do
		foreach queryProp in obj.CM_QueryDefinition.allQueryProperties do
			if not queryProp.isKindOf( CM_QReferenceMethod )
			and not queryProp.isKindOf( CM_QReferenceLookupProperty )
			then
				continue;
			endif;
			listBoxProp := null;
			queryPropClassName := queryProp.propertyClassName;
			queryPropClass := schema.getClass( queryPropClassName );
			listBoxPropName := queryProp.getListBoxPropertyName;			
			propOnQuery := queryPropClass.getPropertyInHTree( queryProp.propertyName );
			if propOnQuery &lt;&gt; null and propOnQuery.isKindOf(Reference) then
				listBoxProp := propOnQuery.type.Class.getPropertyInHTree( listBoxPropName );
			else
				continue;
			endif;
			if listBoxProp = null then
				errStr := queryPropClassName &amp; "::" &amp;  queryProp.propertyName &amp; " (object) has no property called '" &amp; listBoxPropName &amp; "' used in '" &amp; queryProp.class.name &amp; "' for '" &amp; queryProp.niceName &amp; "'"
				&amp; CrLf &amp;  "Need to Re-implement method 'getListBoxPropertyName' on '" &amp; queryProp.class.name &amp; "'.";
				self.assertTrueMsg( false, errStr );
			endif;
		endforeach;
	endforeach;
	
epilog
	
	delete objArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckQryReports" id="fdf4d09c-3963-4b3f-9e39-3489e2c70af6">
        <source>tCheckQryReports();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 June 2015	cnwndl1	Initial creation

*/

vars

	iter1 : Iterator;
	iter2 : Iterator;
	rep1 : CM_QryReportSystem;
	rep2 : CM_QryReportUser;

begin

	iter1 := CM_QryReportSystem.instances.createIterator;
	while iter1.next( rep1 ) do
		self.assertTrueMsg( rep1.menuId.trimBlanks &lt;&gt; null, rep1.String &amp; " has no menuId, created (" &amp; rep1.creationTime.String &amp; "), permissions and license app MAY fail" );
		self.assertTrueMsg( rep1.myMenuReportRoot &lt;&gt; null, rep1.String &amp; " has no Menu Report Root, created (" &amp; rep1.creationTime.String &amp; "), permissions and license app MAY fail" );
		self.assertTrueMsg( rep1.myParent &lt;&gt; null, rep1.String &amp; " has no Parent, created (" &amp; rep1.creationTime.String &amp; "), permissions and license app MAY fail" );
	endwhile;
	
	
	iter2 := CM_QryReportUser.instances.createIterator;
	while iter2.next( rep2 ) do
		self.assertTrueMsg( rep2.menuId.trimBlanks &lt;&gt; null, rep2.String &amp; " has no menuId, created (" &amp; rep2.creationTime.String &amp; "), permissions and license app will fail" );
		self.assertTrueMsg( rep2.myMenuReportRoot &lt;&gt; null, rep2.String &amp; " has no Menu Report Root, created (" &amp; rep2.creationTime.String &amp; "), permissions and license app MAY fail" );
		self.assertTrueMsg( rep2.myParent &lt;&gt; null, rep2.String &amp; " has no Parent, created (" &amp; rep2.creationTime.String &amp; "), permissions and license app MAY fail" );
	endwhile;

epilog

	delete iter1;
	delete iter2;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckQueues" id="4ad0f284-5b48-4199-91ce-012f96ba5509">
        <source>tCheckQueues();
// cnwndl1
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2014	cnwdw1	Initial creation
*/
vars
	queue: CM_RadioTelemetryQueue;
	queueArray: ObjectArray;
	obj: Object;
	failed: Boolean;
	str: String;
	tis: CM_TISet;
	ti: CM_TrackedItem;
	fixMode : Boolean;
	queuesToFixArray: ObjectArray;
begin

	fixMode := false;
	
	

	
	create queuesToFixArray transient;
	create queueArray transient;
	CM_RadioTelemetryQueue.allInstances(queueArray, 0, true);
	
	foreach obj in queueArray discreteLock do
		queue := obj.CM_RadioTelemetryQueue;
		if not queue.allTrackedItems.isEmpty and queue.allEntries.isEmpty then
			queuesToFixArray.add( queue );
			failed := true;
			str := str &amp; CrLf &amp; 'Terminal ' &amp; queue.getMyTerminal().name &amp;  ' Queue ' &amp; queue.id &amp; ' has no tasks but still has ' &amp; queue.allTrackedItems.size.String &amp; ' tracked items';
		endif;
	endforeach;
	
	if not fixMode then
		assertFalseMsg(failed, str);
		
	else
		//clean up the crap.
		create tis transient;
		foreach obj in queuesToFixArray discreteLock do
			queue := obj.CM_RadioTelemetryQueue;
			
			if not queue.allTrackedItems.isEmpty and queue.allEntries.isEmpty then
				tis.clear;
				queue.allTrackedItems.copy(tis);
				beginTransaction;
					foreach ti in tis do
						ti.allQueues.clear;
					endforeach;		
				commitTransaction;
			endif;
		endforeach;
	
	endif;
	
epilog
	delete queueArray;
	delete queuesToFixArray;
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckRTQTaskInvSrcTrgLocation" id="7fccb7da-5a3b-4a85-9f11-bebe85c6a034">
        <source>tCheckRTQTaskInvSrcTrgLocation();
// cnwmh5
/*

Purpose:		Check all existing RTQ Tasks to see if either the source/target locations is invalid	

Date		Who		Reason
17 December 2010	cnwmh5	Initial creation
09/05/2012	cnwmh5	Change to handle rtqTask myEntry being null
*/


vars
	rtqTask			: CM_RTQueueTask;
	
	invalidSource	: Boolean;
	invalidTarget	: Boolean;
	failed			: Boolean;
	str				: String;
	terminalId		: String;
	targetId		: String;
	sourceId		: String;
	
begin

	foreach rtqTask in CM_RTQueueTask.instances discreteLock do
		
		invalidSource := (rtqTask.sourceLocation &lt;&gt; null and not global.isValidObject(rtqTask.sourceLocation));
		invalidTarget := (rtqTask.targetLocation &lt;&gt; null and not global.isValidObject(rtqTask.targetLocation));
	
		if invalidSource or invalidTarget then
			failed := true;
			
			str := str &amp; CrLf &amp; 'rtq (oid): ' &amp; rtqTask.String;
			if rtqTask.myEntry &lt;&gt; null then
				str := str &amp; ', entryID: ' &amp; rtqTask.myEntry.String &amp; "   " &amp; rtqTask.myEntry.id &amp; ",";
			endif;
			
			terminalId := null;
			if rtqTask.myEntry &lt;&gt; null then
				terminalId := rtqTask.getMyTerminal().code;
			endif;
			
			sourceId := null;
			if not invalidSource then
				sourceId := rtqTask.sourceLocation.ident;
			endif;
			
			targetId := null;
			if not invalidTarget then
				targetId := rtqTask.targetLocation.ident;
			endif;
			
			str := str &amp; ' created: ' &amp; rtqTask.creationTime.String &amp; 
			", terminal: " &amp; terminalId &amp; 
			", ti: " &amp; rtqTask.tiId &amp; 
			", queueId: " &amp; rtqTask.queueId &amp; 
			", machineId: "  &amp; rtqTask.machineId &amp; 
			", sourceLocation (oid): " &amp; rtqTask.sourceLocation.String &amp; 
			", source: " &amp; sourceId &amp;
			", invalid source: " &amp; invalidSource.String &amp; 
			", targetLocation (oid): " &amp; rtqTask.targetLocation.String &amp; 
			", target: " &amp; targetId &amp;
			", invalid target: " &amp; invalidTarget.String &amp; CrLf &amp; CrLf &amp; CrLf &amp;
			"Please run UT_Scripts::uDeleteInvalidSTRTQEntry using the rtqTask.myEntry oid to delete the Entry and Task";
		endif;
	
	endforeach;

	assertFalseMsg(failed, str);
	
epilog

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;fails16092014&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;fails16092014_2&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tCheckReceivalInfo" id="1750d5a0-298a-4728-a0b4-3928625b869e">
        <source>tCheckReceivalInfo();
// jlgmd1
// cnwkpd1
/*
Purpose:			Check all the CM_ReceivalInfo:allTrackedItem collection for deleted objects
					This should never happen but it does. Not sure why??

Date		Who		Reason
22 Jul 2014 cnwkpd1	Initial creation
	
*/

vars
	oa 				: ObjectArray;
	ri	 			: CM_ReceivalInfo;
	o 				: Object;
	iter 			: Iterator;
	invalidCount 	: Integer;
	badOnes			: ObjectSet;
	invalid			: Boolean;
	
begin
	create oa transient;
	CM_ReceivalInfo.allInstances(oa, 0, true);
	
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Checking "&amp;oa.size.String&amp;" CM_ReceivalInfo objects", 0);
	
	on Exception do app.handleDeletedObject(exception, ri, invalid);
	
	create badOnes transient;
	iter := oa.createIterator();
	while iter.next(ri) do
		foreach o in ri.allTrackedItems do
			if not app.isValidObject(o) then
				invalidCount := invalidCount + 1;
				badOnes.addNoDuplicates(ri, false);
				app.writeLog(method.qualifiedName &amp; Tab &amp; ri.String &amp; " allTrackedItems contains invalid object " &amp; o.String, 0);
			endif;
		endforeach;
	endwhile;
	
/*	if badOnes.size &gt; 0 then
		// KPD - Problem has been reported as JADE issue in PAR #60207.  Waiting for a fix from the plant but in the
		// meantime will suspend the reporting of the issue (and fix the corruption)
		if app.actualTimeServer.date &lt; '10/12/2014'.Date then
			delete iter;
			iter := badOnes.createIterator();
			while iter.next(ri) do
				beginTransaction;
				ri.allTrackedItems.rebuild();
				commitTransaction;
			endwhile;
			
			invalidCount := 0;
		endif;
	endif;
*/
	self.assertEqual(invalidCount, 0);	

epilog
	delete oa;
	delete badOnes;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckSchemaEntityNames" id="a3a2a0ff-5c48-4c84-bcc6-f9ffb6dbcaaa">
        <source>tCheckSchemaEntityNames();
// jlgmd1
/* cnwkpd1

Purpose:			During the migration period between JMT 8.4.2 (on JADE 7.0) and JMT 8.5.1 (on JADE 7.1)
					it will be possible for developers to inadvertantly create classes, properties and methods
					in the 7.1 development environment which will not be able to go back to 7.0, because the 
					name length limit has been increased from 30 to 100.
					This test will check all schema entity names and fail if any are greater than 30 characters.

Date		Who		Reason
28 Jan 2016	cnwkpd1	PAR #35261 - Changes JADE 7.1
04 Apr 2016	cnwkpd1	Ignore errors for CardSchema
12 Dec 2016	cnwkpd1	Ignore errors for JMTUnitTest
14 Dec 2016	cnwkpd1	Ignore errors for subclasses of JadeDotNetType
06 Feb 2018	jlgkpd1	Ignore non-released schemas
07 Jun 2018	jlgkpd1	Ignore imported Web Service classes and methods
12 Jun 2018	jlgkpd1	Ignore mapped Web Service Consumer methods
19 Jun 2019 jlgmd1	Actually Ignore imported Web Service classes (as they  aren't normally marked as usedInWebService)
07 Oct 2019	jlgmd1	Changed error logging so this method can be used by the ReleaseChecks app
22 Jul 2020 jlgmd1	Ignore errors for constants on JadeDoNetTypes
02 Sep 2022 navmd1	Ignore JadeScript method names
26 Oct 2023 navmd1	Ignore UT_IFTCSUM_PortAuthortyPOB method names
23 Jan 2024 jlizm1	Ignore CM_InvoiceByExternalFinancialID class, difficult to correct and unlikely to cause issues

*/

vars
	entities		: ObjectArray;
	schemaEntity	: SchemaEntity;
	iter			: Iterator;
	displayString	: String;
	errors			: StringArray512;	
	schemaName		: String;
	pos				: Integer;
	agent			: Object;
	releaseSchemas	: StringArray;
	
begin
	create agent as rootSchema.getSchema('DevSchema').getClass('DEV_ReleaseExtractAgent') transient;
	create releaseSchemas transient;
	agent.sendMsgWithIOParams('getReleaseSchemas', releaseSchemas);
	
	// 18/07/2019 JLGMH5 - Need to Check the JMTUnitTest as well
	releaseSchemas.add("JMTUnitTest");
	
	
	create errors transient;

	create entities transient;
	SchemaEntity.allInstances(entities, 0, true);
	
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Checking " &amp; entities.size.String &amp; " SchemaEntity objects", 0);
	
	iter := entities.createIterator();
	while iter.next(schemaEntity) do
		
		if schemaEntity.name.length() &gt; 30 then
			
			// Ignore imported .NET Classes
			if schemaEntity.isKindOf(Type) and
			   schemaEntity.Type.inheritsFrom(JadeDotNetType) then
				continue;
			endif;
			
			// Ignore imported .NET Constants
			if schemaEntity.isKindOf(Constant) and
			   schemaEntity.Feature.schemaType &lt;&gt; null and
			   schemaEntity.Feature.schemaType.inheritsFrom(JadeDotNetType) then
					continue;
			endif;
			
			if schemaEntity.isKindOf(Class) then
				if schemaEntity.getPropertyValue("usedInWebService").Boolean then
					continue;
				endif;
				if schemaEntity.Class.inheritsFrom(ImportedWebServiceProxy)	or
					schemaEntity = CM_InvoiceByExternalFinancialID then
					write "Ignoring" &amp; Tab &amp; "Class" &amp; Tab &amp; schemaEntity.__fullyQualifiedName();
					continue;
				endif;
			endif;
		
			if schemaEntity.isKindOf(Method) then
				if schemaEntity.sendMsg("_isUsedInWebService").Boolean then
					continue;
				endif;
				if schemaEntity.Method.schemaType.inheritsFrom(CM_ExtWebServiceConsumerAgent) or
					schemaEntity.Method.schemaType.inheritsFrom(JadeScript) or
					schemaEntity.Method.schemaType.inheritsFrom(UT_IFTCSUM_PortAuthortyPOB)
				then
					write "Ignoring" &amp; Tab &amp; "Method" &amp; Tab &amp; schemaEntity.__fullyQualifiedName();
					continue;
				endif;
			endif;
			
			// ignore attributes on imported Web Service classes
			if schemaEntity.isKindOf(Attribute) and schemaEntity.Attribute.schemaType.inheritsFrom(ImportedWebServiceProxy) then
				write "Ignoring" &amp; Tab &amp; "Method" &amp; Tab &amp; schemaEntity.__fullyQualifiedName();
				continue;
			endif;
			
			displayString := schemaEntity.__fullyQualifiedName();
			
			pos := 1;
			schemaName := displayString.scanUntil(":", pos);
			
			if not releaseSchemas.includes(schemaName) then
				continue;
			endif;
			
			// ignore controls
			pos := displayString.reversePos("_displayEntry");
			if pos &lt;&gt; null then
				continue;
			endif;
			pos := displayString.reversePos("_windowCreated");
			if pos &lt;&gt; null then
				continue;
			endif;
			pos := displayString.reversePos("_contextMenu");
			if pos &lt;&gt; null then
				continue;
			endif;
			
			//app.writeLog(method.qualifiedName &amp; Tab &amp; displayString &amp; " has name &gt; 30", 0);
			
			errors.add(displayString);
		endif;
	endwhile;
	
	self.assertEqualMsg(errors.size(), 0, errors.concatenate(CrLf) &amp; CrLf &amp; CrLf &amp; "Class/Method/Attribute Names greater than 30 characters");
	
epilog
	delete errors;
	delete entities;
	delete iter;
	delete releaseSchemas;
	delete agent;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckSubsLicense" id="00080553-79f1-4dd4-b52d-ff166cd56e4a">
        <source>tCheckSubsLicense();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2020	jlgndl1	Initial creation	TFS 49569

*/

constants

	SCHEMA_NAME : String = "JSSLicenseKeyMaintSchema";
	CLASS_NAME : String = "JSSLKey";
	LicenseName : String= "UNITTEST";
	
	SCHEMA_Load_NAME : String = "JSSLicenseKeySchema";

vars

	schema : Schema;
	class : Class;
	obj : Object;
	subsExpDateArray : DateArray;
	modulesArray : BooleanArray;
	expiryDate : Date;
	prodCode : String;
	licenseName : String;
	licenseKey : String;	
	binary : Binary;
	bitMask : Binary;
	includedArray : IntegerArray;
	excludedArray : IntegerArray;
	allValues : IntegerArray;
	int : Integer;
	tmpNum : Integer;
	byteValue : Integer;
	bitPointer : Integer;
	byteIndex : Integer;
	included : Boolean;	
	schemaService : Schema;
	classService : Class;
	objService : Object;
	subsExpDate : Date;
	checkDate : Date;
	datesStr : String;
	indexStr : Integer;
	segment : String;
	indexArrayInt : Integer;
	dateStr : String;
	date : Date;
	allExpiries : DateArray;
	rootExpiries : DateArray;
	resetExpiries : DateArray;
	expiredDate : Date;

begin

	//Check deciphering a known value
	schema := rootSchema.getSchema(SCHEMA_NAME);
	self.assertTrueMsg( schema &lt;&gt; null, SCHEMA_NAME &amp; " Schema not found in setup 1");
	class := schema.getClass(CLASS_NAME);
	self.assertTrueMsg( class &lt;&gt; null, CLASS_NAME &amp; " Class not found in setup 1");
	create obj as class transient;
	self.assertTrueMsg( obj &lt;&gt; null, CLASS_NAME &amp; " Object not created in setup 1");
	
	create allValues transient;
	create includedArray transient;
	create excludedArray transient;
	create modulesArray transient;
	create subsExpDateArray transient;
	create allExpiries transient;
	
	includedArray.add(Mod_BaseSystem - Mod_BaseView);
	includedArray.add(Mod_YardPlanning - Mod_BaseView);
	includedArray.add(Mod_BulkCargo - Mod_BaseView);
	includedArray.add(Mod_CargoShip - Mod_BaseView);
	includedArray.add(Mod_CargoHandling - Mod_BaseView);
	includedArray.add(Mod_DataExtract - Mod_BaseView);
	includedArray.add(Mod_EDIVGM - Mod_BaseView);
	includedArray.add(Mod_GeneralCargo - Mod_BaseView);
	includedArray.add(Mod_Weighing - Mod_BaseView);
	includedArray.add(Mod_VesselRORO - Mod_BaseView);
	includedArray.add(Mod_WebApps - Mod_BaseView);
	includedArray.add(Mod_Queuing - Mod_BaseView);
	includedArray.add(Mod_Rail - Mod_BaseView);
	includedArray.add(Mod_VehicleBooking - Mod_BaseView);
	includedArray.add(Mod_Webservice - Mod_BaseView);
		
	excludedArray.add(Mod_DutyDoc - Mod_BaseView);
	excludedArray.add(Mod_Logs - Mod_BaseView);
	excludedArray.add(Mod_CargoGroup - Mod_BaseView);
	excludedArray.add(Mod_Cash - Mod_BaseView);
	excludedArray.add(Mod_Invoicing - Mod_BaseView);
	excludedArray.add(Mod_Harbour - Mod_BaseView);
	
	includedArray.copy(allValues);
	excludedArray.copy(allValues);
	
	//Known JMT
	prodCode := ProductCode_JMT;
	licenseKey := "500000006700000054672D2A336767676767676767676767E79B4D676A66E3B5666627766D";
	licenseName := LicenseName;
	obj.sendMsgWithParams('decompose', licenseName, licenseKey );
	
	binary := obj.getPropertyValue("data1").Binary;
	self.assertTrueMsg( licenseKey = binary.String, "License Key doesn't match data1 Test 1" );
	bitMask := obj.getPropertyValue("data2").Binary;
	binary := obj.getPropertyValue("data3").Binary;
	self.assertTrueMsg( binary.Date = "31 December 3000".Date, "License Expirry doesn't match data3 Test 2" );
	binary := obj.getPropertyValue("data4").Binary;
	self.assertTrueMsg( prodCode = binary.String, "License Type doesn't match data4 Test 1" );
	
	foreach tmpNum in allValues do
		int := tmpNum + Mod_BaseView;
		byteIndex := ((tmpNum - 1) div 8) + 1;
		byteValue	:=	bitMask[byteIndex];
		bitPointer	:=	(tmpNum mod 8);
		included := false;
		if bitPointer = 1 then			
			included := byteValue.bitAnd(1) &lt;&gt; 0;
		elseif bitPointer = 2 then
			included :=  byteValue.bitAnd(2) &lt;&gt; 0;
		elseif bitPointer = 3 then
			included :=  byteValue.bitAnd(4) &lt;&gt; 0;
		elseif bitPointer = 4 then
			included :=  byteValue.bitAnd(8) &lt;&gt; 0;
		elseif bitPointer = 5 then
			included :=  byteValue.bitAnd(16) &lt;&gt; 0;
		elseif bitPointer = 6 then
			included :=  byteValue.bitAnd(32) &lt;&gt; 0;
		elseif bitPointer = 7 then
			included :=  byteValue.bitAnd(64) &lt;&gt; 0;
		elseif bitPointer = 0 then	
			included :=  byteValue.bitAnd(128) &lt;&gt; 0;
		endif;
		if includedArray.includes( tmpNum ) then
			self.assertTrueMsg( included, "Expected license value " &amp; int.String &amp; "(" &amp; tmpNum.String &amp; ") to be included in Test 1"  );
		else
			self.assertTrueMsg( not included, "Expected license value " &amp; int.String &amp; "(" &amp; tmpNum.String &amp; ") to be excluded in Test 1"  );
		endif;
	endforeach;
		
	//Known Subcription
	allValues.clear;
	includedArray.clear;
	excludedArray.clear;
	
	includedArray.add(Sub_ReeferJobs - Mod_BaseView);
	
	excludedArray.add(Mod_BaseSystem - Mod_BaseView);
	excludedArray.add(Mod_YardPlanning - Mod_BaseView);
	excludedArray.add(Mod_BulkCargo - Mod_BaseView);
	excludedArray.add(Mod_CargoShip - Mod_BaseView);
	excludedArray.add(Mod_CargoHandling - Mod_BaseView);
	excludedArray.add(Mod_DataExtract - Mod_BaseView);
	excludedArray.add(Mod_EDIVGM - Mod_BaseView);
	excludedArray.add(Mod_GeneralCargo - Mod_BaseView);
	excludedArray.add(Mod_Weighing - Mod_BaseView);
	excludedArray.add(Mod_VesselRORO - Mod_BaseView);
	excludedArray.add(Mod_WebApps - Mod_BaseView);
	excludedArray.add(Mod_Queuing - Mod_BaseView);
	excludedArray.add(Mod_Rail - Mod_BaseView);
	excludedArray.add(Mod_VehicleBooking - Mod_BaseView);
	excludedArray.add(Mod_Webservice - Mod_BaseView);		
	excludedArray.add(Mod_DutyDoc - Mod_BaseView);
	excludedArray.add(Mod_Logs - Mod_BaseView);
	excludedArray.add(Mod_CargoGroup - Mod_BaseView);
	excludedArray.add(Mod_Cash - Mod_BaseView);
	excludedArray.add(Mod_Invoicing - Mod_BaseView);
	excludedArray.add(Mod_Harbour - Mod_BaseView);
	
	prodCode := ProductCode_Subs;
	licenseKey := "460000000D000000070D0D0D390D5E584F5E0D0D0D0D0D0D0D0D0D0D8DF1270D0D0D0D0D0D0D0D0D0D093D3A383D3F3D3F3F3D3F3F";
	obj.sendMsgWithParams('decomposeSubs', licenseName, licenseKey );
	
	binary := obj.getPropertyValue("data1").Binary;
	self.assertTrueMsg( licenseKey = binary.String, "License Key doesn't match data1 Test 2" );
	bitMask := obj.getPropertyValue("data2").Binary;
	binary := obj.getPropertyValue("data3").Binary;
	self.assertTrueMsg( binary.Date = "31 December 3000".Date, "License Expirry doesn't match data3 Test 2" );
	binary := obj.getPropertyValue("data4").Binary;
	self.assertTrueMsg( prodCode = binary.String, "License Type doesn't match data4 Test 2" );
	binary := obj.getPropertyValue("data5").Binary;
	self.assertTrueMsg( "07502022022" = binary.String, "Subs Expiry date doesn't match data5 Test 2" );

	foreach tmpNum in allValues do
		int := tmpNum + Mod_BaseView;
		byteIndex := ((tmpNum - 1) div 8) + 1;
		byteValue	:=	bitMask[byteIndex];
		bitPointer	:=	(tmpNum mod 8);
		included := false;
		if bitPointer = 1 then			
			included := byteValue.bitAnd(1) &lt;&gt; 0;
		elseif bitPointer = 2 then
			included :=  byteValue.bitAnd(2) &lt;&gt; 0;
		elseif bitPointer = 3 then
			included :=  byteValue.bitAnd(4) &lt;&gt; 0;
		elseif bitPointer = 4 then
			included :=  byteValue.bitAnd(8) &lt;&gt; 0;
		elseif bitPointer = 5 then
			included :=  byteValue.bitAnd(16) &lt;&gt; 0;
		elseif bitPointer = 6 then
			included :=  byteValue.bitAnd(32) &lt;&gt; 0;
		elseif bitPointer = 7 then
			included :=  byteValue.bitAnd(64) &lt;&gt; 0;
		elseif bitPointer = 0 then	
			included :=  byteValue.bitAnd(128) &lt;&gt; 0;
		endif;
		if includedArray.includes( tmpNum ) then
			self.assertTrueMsg( included, "Expected license value " &amp; int.String &amp; "(" &amp; tmpNum.String &amp; ") to be included in Test 2"  );
		else
			self.assertTrueMsg( not included, "Expected license value " &amp; int.String &amp; "(" &amp; tmpNum.String &amp; ") to be excluded in Test 2"  );
		endif;
	endforeach;
	
	//Generate then decihper using loader
	
	//Generate JMT
	allValues.clear;
	includedArray.clear;
	excludedArray.clear;
	modulesArray.clear;
	subsExpDateArray.clear;
	
	includedArray.add(Mod_BaseSystem - Mod_BaseView);
	includedArray.add(Mod_YardPlanning - Mod_BaseView);
	includedArray.add(Mod_BulkCargo - Mod_BaseView);
	includedArray.add(Mod_CargoShip - Mod_BaseView);
	includedArray.add(Mod_CargoHandling - Mod_BaseView);
	includedArray.add(Mod_DataExtract - Mod_BaseView);
	includedArray.add(Mod_EDIVGM - Mod_BaseView);
	includedArray.add(Mod_GeneralCargo - Mod_BaseView);
	includedArray.add(Mod_Weighing - Mod_BaseView);
	includedArray.add(Mod_VesselRORO - Mod_BaseView);
	includedArray.add(Mod_WebApps - Mod_BaseView);
	includedArray.add(Mod_Queuing - Mod_BaseView);
	includedArray.add(Mod_Rail - Mod_BaseView);
	includedArray.add(Mod_VehicleBooking - Mod_BaseView);
	includedArray.add(Mod_Webservice - Mod_BaseView);
		
	excludedArray.add(Mod_DutyDoc - Mod_BaseView);
	excludedArray.add(Mod_Logs - Mod_BaseView);
	excludedArray.add(Mod_CargoGroup - Mod_BaseView);
	excludedArray.add(Mod_Cash - Mod_BaseView);
	excludedArray.add(Mod_Invoicing - Mod_BaseView);
	excludedArray.add(Mod_Harbour - Mod_BaseView);
	
	includedArray.copy(allValues);
	excludedArray.copy(allValues);
	
	foreach tmpNum in includedArray do
		modulesArray.atPut( tmpNum, true );
	endforeach;
	
	licenseName := "TFS49569";
	prodCode := ProductCode_JMT;
	expiryDate := "31 December 2030".Date;
	obj.sendMsgWithParams('generateKey', licenseName, prodCode, expiryDate, modulesArray );
	
	licenseKey := obj.getPropertyValue("data1").Binary.String;
	self.assertTrueMsg( licenseKey &lt;&gt; null, "License Key wasn't created in data1 Test 3" );
	bitMask := obj.getPropertyValue("data2").Binary;
	self.assertTrueMsg( bitMask &lt;&gt; null, "Bitmask wasn't created in data1 Test 3" );
	binary := obj.getPropertyValue("data3").Binary;
	self.assertTrueMsg( binary.Date.isValid, "Expiry Date wasn't created in data1 Test 3" );
	binary := obj.getPropertyValue("data4").Binary;
	self.assertTrueMsg( prodCode = binary.String, "License Type doesn't match data4 Test 3" );
	
	//decipher subs via loader
	schemaService := rootSchema.getSchema(SCHEMA_Load_NAME);
	self.assertTrueMsg( schemaService &lt;&gt; null, SCHEMA_Load_NAME &amp; " Schema not found in setup 4");
	classService := schemaService.getClass(CLASS_NAME);
	self.assertTrueMsg( classService &lt;&gt; null, CLASS_NAME &amp; " Class not found in setup 4");
	create objService as classService transient;
	self.assertTrueMsg( objService &lt;&gt; null, CLASS_NAME &amp; " Object not created in setup 4");
	
	objService.sendMsgWithParams('decompose', licenseName, licenseKey );
	
	binary := objService.getPropertyValue("data1").Binary;
	self.assertTrueMsg( licenseKey = binary.String, "License Key doesn't match data1 Test 4" );
	bitMask := objService.getPropertyValue("data2").Binary;
	binary := objService.getPropertyValue("data3").Binary;
	self.assertTrueMsg( binary.Date = expiryDate, "License Expirry doesn't match data3 Test 4" );
	binary := objService.getPropertyValue("data4").Binary;
	self.assertTrueMsg( prodCode = binary.String, "License Type doesn't match data4 Test 4" );

	foreach tmpNum in allValues do
		int := tmpNum + Mod_BaseView;
		byteIndex := ((tmpNum - 1) div 8) + 1;
		byteValue	:=	bitMask[byteIndex];
		bitPointer	:=	(tmpNum mod 8);
		included := false;
		if bitPointer = 1 then			
			included := byteValue.bitAnd(1) &lt;&gt; 0;
		elseif bitPointer = 2 then
			included :=  byteValue.bitAnd(2) &lt;&gt; 0;
		elseif bitPointer = 3 then
			included :=  byteValue.bitAnd(4) &lt;&gt; 0;
		elseif bitPointer = 4 then
			included :=  byteValue.bitAnd(8) &lt;&gt; 0;
		elseif bitPointer = 5 then
			included :=  byteValue.bitAnd(16) &lt;&gt; 0;
		elseif bitPointer = 6 then
			included :=  byteValue.bitAnd(32) &lt;&gt; 0;
		elseif bitPointer = 7 then
			included :=  byteValue.bitAnd(64) &lt;&gt; 0;
		elseif bitPointer = 0 then	
			included :=  byteValue.bitAnd(128) &lt;&gt; 0;
		endif;
		if includedArray.includes( tmpNum ) then
			self.assertTrueMsg( included, "Expected license value " &amp; int.String &amp; "(" &amp; tmpNum.String &amp; ") to be included in Test 4"  );
		else
			self.assertTrueMsg( not included, "Expected license value " &amp; int.String &amp; "(" &amp; tmpNum.String &amp; ") to be excluded in Test 4"  );
		endif;
	endforeach;
	
	//Generate Subs
	allValues.clear;
	includedArray.clear;
	excludedArray.clear;
	modulesArray.clear;
	subsExpDateArray.clear;
	
	includedArray.add(Sub_ReeferJobs - Mod_BaseView);
	
	excludedArray.add(Mod_BaseSystem - Mod_BaseView);
	excludedArray.add(Mod_YardPlanning - Mod_BaseView);
	excludedArray.add(Mod_BulkCargo - Mod_BaseView);
	excludedArray.add(Mod_CargoShip - Mod_BaseView);
	excludedArray.add(Mod_CargoHandling - Mod_BaseView);
	excludedArray.add(Mod_DataExtract - Mod_BaseView);
	excludedArray.add(Mod_EDIVGM - Mod_BaseView);
	excludedArray.add(Mod_GeneralCargo - Mod_BaseView);
	excludedArray.add(Mod_Weighing - Mod_BaseView);
	excludedArray.add(Mod_VesselRORO - Mod_BaseView);
	excludedArray.add(Mod_WebApps - Mod_BaseView);
	excludedArray.add(Mod_Queuing - Mod_BaseView);
	excludedArray.add(Mod_Rail - Mod_BaseView);
	excludedArray.add(Mod_VehicleBooking - Mod_BaseView);
	excludedArray.add(Mod_Webservice - Mod_BaseView);		
	excludedArray.add(Mod_DutyDoc - Mod_BaseView);
	excludedArray.add(Mod_Logs - Mod_BaseView);
	excludedArray.add(Mod_CargoGroup - Mod_BaseView);
	excludedArray.add(Mod_Cash - Mod_BaseView);
	excludedArray.add(Mod_Invoicing - Mod_BaseView);
	excludedArray.add(Mod_Harbour - Mod_BaseView);
	
	includedArray.copy(allValues);
	excludedArray.copy(allValues);
	
	subsExpDate := app.actualTimeAppServer.date + 300;
	foreach tmpNum in includedArray do
		modulesArray.atPut( tmpNum, true );
		subsExpDateArray.atPut( tmpNum, subsExpDate + tmpNum );
	endforeach;
	
	prodCode := ProductCode_Subs;
	obj.sendMsgWithParams('generateSubsKey', licenseName, prodCode, expiryDate, modulesArray, subsExpDateArray );
	
	licenseKey := obj.getPropertyValue("data1").Binary.String;
	self.assertTrueMsg( licenseKey &lt;&gt; null, "License Key wasn't created in data1 Test 5" );
	bitMask := obj.getPropertyValue("data2").Binary;
	self.assertTrueMsg( bitMask &lt;&gt; null, "Bitmask wasn't created in data1 Test 5" );
	binary := obj.getPropertyValue("data3").Binary;
	self.assertTrueMsg( binary.Date.isValid, "Expiry Date wasn't created in data1 Test 5" );
	binary := obj.getPropertyValue("data4").Binary;
	self.assertTrueMsg( prodCode = binary.String, "License Type doesn't match data4 Test 5" );
	binary := obj.getPropertyValue("data5").Binary;
	self.assertTrueMsg( binary &lt;&gt; null, "Subs Expiry date array empty data5 Test 5" );
	
	objService.sendMsgWithParams('decomposeSubs', licenseName, licenseKey );
	
	binary := objService.getPropertyValue("data1").Binary;
	self.assertTrueMsg( licenseKey = binary.String, "License Key doesn't match data1 Test 6" );
	bitMask := objService.getPropertyValue("data2").Binary;
	binary := objService.getPropertyValue("data3").Binary;
	self.assertTrueMsg( binary.Date = expiryDate, "License Expirry doesn't match data3 Test 6" );
	binary := objService.getPropertyValue("data4").Binary;
	self.assertTrueMsg( prodCode = binary.String, "License Type doesn't match data4 Test 6" );
	datesStr := obj.getPropertyValue("data5").String;
	self.assertTrueMsg( datesStr &lt;&gt; null, "Subs Expiry date array empty data5 Test 6" );
	
	indexStr := 1;
	while true do
		if indexStr &gt; datesStr.length then
			break;
		endif;
		segment := datesStr[1:11];
		indexStr := indexStr + 11;
		indexArrayInt := segment[1:3].Integer;
		dateStr := segment[4:8];
		date.setDate( dateStr[1:2].Integer, dateStr[3:2].Integer, dateStr[5:4].Integer );
		if date.isValid then
			allExpiries.atPut( indexArrayInt, date );
		endif;
	endwhile;

	foreach tmpNum in allValues do
		checkDate := subsExpDate + tmpNum;
		int := tmpNum + Mod_BaseView;
		byteIndex := ((tmpNum - 1) div 8) + 1;
		byteValue	:=	bitMask[byteIndex];
		bitPointer	:=	(tmpNum mod 8);
		included := false;
		if bitPointer = 1 then			
			included := byteValue.bitAnd(1) &lt;&gt; 0;
		elseif bitPointer = 2 then
			included :=  byteValue.bitAnd(2) &lt;&gt; 0;
		elseif bitPointer = 3 then
			included :=  byteValue.bitAnd(4) &lt;&gt; 0;
		elseif bitPointer = 4 then
			included :=  byteValue.bitAnd(8) &lt;&gt; 0;
		elseif bitPointer = 5 then
			included :=  byteValue.bitAnd(16) &lt;&gt; 0;
		elseif bitPointer = 6 then
			included :=  byteValue.bitAnd(32) &lt;&gt; 0;
		elseif bitPointer = 7 then
			included :=  byteValue.bitAnd(64) &lt;&gt; 0;
		elseif bitPointer = 0 then	
			included :=  byteValue.bitAnd(128) &lt;&gt; 0;
		endif;
		if includedArray.includes( tmpNum ) then
			self.assertTrueMsg( included, "Expected license value " &amp; int.String &amp; "(" &amp; tmpNum.String &amp; ") to be included in Test 6"  );
			self.assertTrueMsg( checkDate  = allExpiries[tmpNum], "Subscription expiry for " &amp; int.String &amp; "(" &amp; tmpNum.String &amp; ") incorrect in Test 6"  );
		else
			self.assertTrueMsg( not included, "Expected license value " &amp; int.String &amp; "(" &amp; tmpNum.String &amp; ") to be excluded in Test 6"  );
		endif;
	endforeach;
	
	
	self.assertTrueMsg( app.myRoot.canDo( Sub_ReeferJobs ), "Unable to test Root.canDo for Subscriptions, Reefer Native not licensed. Set up for Test 7"  );
	if not app.myRoot.canDo( Sub_ReeferJobs ) then
		return;
	endif;
	
	rootExpiries := app.myRoot.getConfig(ProductCode_Subs).DateArray;
	if rootExpiries &lt;&gt; null then
		create resetExpiries transient;
		rootExpiries.copy( resetExpiries ); // so we can re-instate what we overwrite
	endif;
	
	expiredDate := app.actualTimeAppServer.Date - 1;
	allExpiries.atPut( Sub_ReeferJobs - Mod_BaseView, expiredDate );
	beginTransaction;
	app.myRoot.setConfig( ProductCode_Subs, allExpiries, true );
	commitTransaction;
	
	self.assertTrueMsg( not app.myRoot.canDo( Sub_ReeferJobs ), "Reefer Native with expired date should not be allowed. Test 7"  );

epilog

	if resetExpiries &lt;&gt; null then
		//Set i back to where it was.
		beginTransaction;
		app.myRoot.setConfig( ProductCode_Subs, resetExpiries, true );
		commitTransaction;
		delete resetExpiries;
	endif;
	delete obj;
	delete objService;
	delete modulesArray;
	delete subsExpDateArray;
	delete allValues;
	delete includedArray;
	delete excludedArray;
	delete allExpiries;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTADeckingOptions" id="9b335198-430f-4ae5-bd6a-171353170fab">
        <source>tCheckTADeckingOptions();
// cnwdap1
/*
Purpose:			Check the Yard Allocation Location Cells against the Terminal Area row/column/height

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2009	cnwdap1	Initial creation
*/
vars
	terminal : CM_Terminal;
	terminalArea : CM_TerminalArea;
	area : CM_GridArea;
	areaNumber : Integer;
	str : String;
	failed : Boolean;
begin
	foreach terminal in CM_Terminal.instances where terminal.code = "DP1" do
		str := str &amp; "Terminal " &amp; terminal.code &amp; " " &amp; terminal.name &amp; CrLf;
		foreach terminalArea in terminal.allTerminalAreas do
			if terminalArea.id = "KC01" then
				// Yes this one has broken decking rules, but to difficult to fix at the moment
				continue;
			endif;
			
			if terminalArea.isKindOf(CM_GridArea) then
				area := terminalArea.CM_GridArea;
				if area.myYADeckingOptions &lt;&gt; null then
					areaNumber := area.numberOfColumns * area.numberOfRows * area.heightOfStack;
					if areaNumber &lt;&gt; area.myYADeckingOptions.allYALocationCellsIn.size then
						str := str &amp; "area " &amp; area.id &amp; " should have " &amp; areaNumber.String &amp; " cells in - has " &amp; area.myYADeckingOptions.allYALocationCellsIn.size.String &amp; CrLf;
						failed := true;
					endif;
					if areaNumber &lt;&gt; area.myYADeckingOptions.allYALocationCellsOut.size then
						str := str &amp; "area " &amp; area.id &amp; " should have " &amp; areaNumber.String &amp; " cells out - has " &amp; area.myYADeckingOptions.allYALocationCellsOut.size.String &amp; CrLf;
						failed := true;
					endif;
				endif;
			endif;
		endforeach;
	endforeach;
	
	assertFalseMsg(failed, str);
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTerminalGetNullExist" id="bc3d9748-e3be-4906-b786-d94ae7eab451">
        <source>tCheckTerminalGetNullExist();

/*

Purpose:		Checks that the getNull methods on terminal aren't in fact null

Date			Who		Reason
22/04/2015		cnwmh5	Initial creation

*/

vars

	terminal					: CM_Terminal;
	
	getNullErrors				: String;

begin

	foreach terminal in CM_Terminal.instances discreteLock do
	
		if terminal.getNullVoyage() = null then
			getNullErrors := getNullErrors &amp; "NULL voyage missing terminal (" &amp; terminal.code &amp; ")" &amp; CrLf;
		endif;
		
		if terminal.getNullTrain() = null then
			getNullErrors := getNullErrors &amp; "NULL train missing terminal (" &amp; terminal.code &amp; ")" &amp; CrLf;
		endif;
		
		if terminal.getNullOperator() = null then
			getNullErrors := getNullErrors &amp; "NULL operator missing terminal (" &amp; terminal.code &amp; ")" &amp; CrLf;
		endif;
	
	endforeach;

	if getNullErrors &lt;&gt; null then
		getNullErrors := CrLf &amp; "The following terminal NULL's are missing:" &amp; CrLf &amp; getNullErrors;
	endif;
	
	self.assertTrueMsg(getNullErrors = null, getNullErrors);	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTerminalHasVBSProcess" id="5dede3b8-0bcc-4000-8dab-8ba6d9e11d16">
        <source>tCheckTerminalHasVBSProcess();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navpw1	Initial creation TFS: 54049 (55844)

*/

vars
	terminal	: CM_Terminal;
	msg			: String;
	result		: Boolean;
	
begin
	result := true;
	foreach terminal in app.myRoot.allTerminals do
		if not terminal.isVehicleBookingEnabled then   //24.01.2024 navma1 Only if VBS Is enabled 
			continue;
		endif;
		
		if terminal.getMyVBSProcess &lt;&gt; null then
			continue;
		endif;
		msg := "Terminal: '" &amp; terminal.code &amp; "' has a null vbs process" &amp; CrLf;
		result := false;
	endforeach;
	
	self.assertTrueMsg(result, msg);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTerminalStateData" id="44dac006-c925-469a-86b0-e8af451e3edf">
        <source>tCheckTerminalStateData();
// cnwmh5
/*
Purpose:			Check all state data to see if reference that object is correct

*/

vars
	oa 				: ObjectArray;
	t				: CM_Terminal;
	o 				: Object;
	iter 			: Iterator;
	stData		 	: CM_StateData;
	stObj    		: CM_StateObject;
	fix				: Boolean;
	invalidCount 	: Integer;
	badOnes			: ObjectSet;
	
begin
	create oa transient;
	CM_Terminal.allInstances(oa, 0, true);
	
	app.writeLog("Checking "&amp;oa.size.String&amp;" CM_Terminal StateData objects", 0);
	fix := false;
	create badOnes transient;
	iter := oa.createIterator();
	while iter.next(t) do
		foreach stObj in t.getAllStateData do
			foreach stData in stObj.allStateData do
				if stData.isKindOf(CM_StateReference) and stData.CM_StateReference.myValue &lt;&gt; null then
					if not app.isValidObject(stData.CM_StateReference.myValue) then
						invalidCount := invalidCount + 1;
						badOnes.addNoDuplicates(stData, false);
						//write stData.key;
						app.writeLog('Terminal: ' &amp; t.name &amp; Tab &amp; stData.key &amp; Tab &amp; "State Data Oid:" &amp; stData.getOidString, LogINFO);
						if fix then
							beginTransaction;
							stData.setValue(null);
							commitTransaction;
						endif;
					endif;
				endif;
			endforeach;
		endforeach;
	endwhile;
	
	self.assertEqual(invalidCount, 0);	

epilog
	delete oa;
	delete badOnes;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTrxAreInWhileTrueLoop" id="06c2ea4f-9a53-4e77-ba62-bb635035fdaf">
        <source>tCheckTrxAreInWhileTrueLoop();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2020	jlgndl1	Initial creation	TFS 46815  This sucker checks the code in each of the methods
											associated with teh constants used in trxs during the process.
											The idea is to ensure they are within a 'while true do' loop,
											so that the warning acknowldegement process can work properly.

*/

vars

	constantsToCheck : ObjectArray;
	const : Constant;
	uiCommonSchema : Schema;
	obj : Object;
	methods : MethodSet;
	meth : Method;
	source : String;
	allBadMethods : DynaDictionary;
	allUsers : StringArray;
	lastModifiedUser : String;
	qualifiedName : String;
	iter : Iterator;
	emailAddress : String;
	emailBody : String;
	userName : String;
	constantString : String;

begin

	create constantsToCheck transient;
	create methods transient;
	create allBadMethods transient;
	create allUsers transient;
	
	allBadMethods.setMembership(Method);
	allBadMethods.addExternalKey(String,30,false,false);//last modified by user
	allBadMethods.addExternalKey(String,60,false,false);//method qualified name
	allBadMethods.addExternalKey(String,30,false,false);//constantString
	allBadMethods.endKeys(true);
	

	uiCommonSchema := rootSchema.getSchema("UiCommonSchema");
	
	constantsToCheck.add( uiCommonSchema.getGlobalConstant( "ErrWarnMode_CanAckWarnings") );
	constantsToCheck.add( uiCommonSchema.getGlobalConstant( "ErrWarnMode_AddUpdate") );
	constantsToCheck.add( uiCommonSchema.getGlobalConstant( "ErrWarnMode_Add") );
	constantsToCheck.add( uiCommonSchema.getGlobalConstant( "ErrWarnMode_Update") );
	constantsToCheck.add( uiCommonSchema.getGlobalConstant( "ErrWarnMode_Delete") );
	
	foreach obj in constantsToCheck do
		const := obj.Constant;
		methods.clear();
		const.getMethodRefs(methods);
		
		foreach meth in methods do
			
			if meth.getSchemaType.name.isOneOf( "LOG_VoyageOpsFormOLD", "SHP_NonPlannedNonWorkedForm", "SOP_BackgroundEditForm", "Web_PageLoaderForm" ) then
				// As per the tech spec, these forms are being deleted, so ignore these ones.
				continue;
			endif;
	
			source := meth.getSource();
			if not (source.pos("app.myTrxUA",1) &gt; 0 or source.pos("app.myTrxCA",1) &gt; 0 or source.pos("app.myTrxDA",1) &gt; 0) then
				//The method doesn't include a Trx, so nothing to check.
				continue;
			endif;
			
			if source.pos("while true do",1) = 0 then
				
				if source.pos("app.myPassport.setWarningsIgnored(true)",1) = 0 then 
					lastModifiedUser := meth.getModifiedBy;
					if not allUsers.includes( lastModifiedUser ) then
						allUsers.add( lastModifiedUser );
					endif;
					qualifiedName := meth.qualifiedName;
					if allBadMethods[lastModifiedUser, qualifiedName, constantString] = null then
						allBadMethods.putAtKey( lastModifiedUser, qualifiedName, constantString, meth );
					endif;
				endif;
				
			endif;
		endforeach;
		
	endforeach;
	
	//Sends an email to the last person to compile each of the bad methods
	foreach userName in allUsers do
		emailAddress := self.xGetEmailAddressForUser( userName );
		self.assertTrueMsg( emailAddress &lt;&gt; null, "No Email address found for '" &amp; userName &amp; "'");
		emailBody := "Hi " &amp; userName &amp; "," &amp; CrLf&amp; "The following methods (which you were the last to change) include a Trx that is NOT embedded within a 'while true' loop, please correct these:";
		iter := allBadMethods.createIterator;
		while iter.next( meth ) do
			allBadMethods.getIteratorKeys( lastModifiedUser, qualifiedName, constantString, iter );
			if userName = lastModifiedUser then
				emailBody := emailBody &amp; CrLf &amp; qualifiedName;
			endif;
		endwhile;
		self.logMessageNow(emailBody);
		self.xSendEmail( emailAddress, "Coding Issues found in DMAST!", emailBody );
		delete iter;
	endforeach;

	self.assertTrue(allBadMethods.size = 0);
	
epilog

	delete constantsToCheck;
	delete methods;
	delete iter;
	delete allUsers;
	delete allBadMethods;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckUMCompatFileNoNulls" id="0b5507c5-34ff-444a-aa51-6d093a233230">
        <source>tCheckUMCompatFileNoNulls();

/*

Purpose:		Alert if UM_MapFilesToCompact has a null record in	

Date			Who		Reason
03/08/2016		cnwmh5	Initial creation

*/

vars

	mapToCompact 					: UM_MapFilesToCompact;
	root							: UM_Root;
	
	iter							: Iterator;

begin

	root := UM_Root.firstInstance;
	self.assertNotNull(root);	

	iter := root.allMapFilesToCompact.createIterator;
	while iter.next(mapToCompact) do
		self.assertNotNullMsg(mapToCompact.mapFileName, "Please delete this record as compact record (" &amp; mapToCompact.String &amp; ") mapFile name (" &amp;
			mapToCompact.mapFileName &amp; ")");
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckUncompdMthdsNonProdScms" id="4e523938-727d-4c2b-b59c-69d2144cdf48">
        <source>tCheckUncompdMthdsNonProdScms();

/*

Purpose:		Check for Uncompiled methods in NON Production Schemas ONLY	

Date			Who		Reason
15/11/2016		cnwmh5	Initial creation

*/

vars

	uncompiledMethods				: StringArray512;
	unitTestResult 					: UM_UnitTestResult;
	
	type							: Integer;

	result							: String;
	methStartTS						: TimeStamp;
	methEndTS						: TimeStamp;
	elapsedTime						: TimeStampInterval;
	errorDetails					: String;	
	str								: String;

begin

	create uncompiledMethods transient;
	
	type := 2;
	app.xCheckForUncompiledMethods(type, uncompiledMethods);
	
	if uncompiledMethods.size = 0 then
		result := "PASS";
	else
		errorDetails := null;
		foreach str in uncompiledMethods do
			if errorDetails &lt;&gt; null then
				errorDetails := errorDetails &amp; CrLf;
			endif;
			errorDetails := errorDetails &amp; str;
		endforeach;
		errorDetails := CrLf &amp; "The following method(s) are uncompiled or in error:" &amp; CrLf &amp; CrLf &amp; errorDetails;
		errorDetails := errorDetails.replaceString("^^", " ");
	endif;
	
epilog

	delete uncompiledMethods;

	self.assertEqualMsg(errorDetails, null,  errorDetails);

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckUpgradeScripts" id="b3f3c9e9-4eb8-4f6b-b2d7-431084da8403">
        <source>tCheckUpgradeScripts();
// cnwdap1
// Purpose:			Check upgrade scripts in PortSchema_8_5_1 and above for:
//						no app.initialize
// 						uses self.hasScriptBeenRunAtAll and self.addScriptRun
//						logs something
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/07/2017	jlgdap1		Initial creation 
// 20/06/2019	jlgmd1		Added a check to make sure upgrades scripts actually get added to a pre or post method to run
// 08/08/2019	jlgdap1		Added createLogEntry to exclusions
// 03/11/2025	navmd1		Refactored PortSchemaRelease minimum version check to use numbers rather than specific names that people forget to update
//
constants
	SPECIFIC_POST_STANDARD : String = "specificPostStandard";
	SPECIFIC_PRE_STANDARD : String = "specificPreStandard";
vars
	schema, portSchema	: Schema;
	class, subClass 	: Class;
	subclasses 			: ClassColl;
	methodsDict,
	prevMthsDict		: MethodNDict;
	mthd 				: Method;
	methSource 			: String;
	errors 				: HugeStringArray;
	str, msg 			: String;
	postMth, preMth		: Method;
	postMthSrc,
	preMthSrc 			: String;
	lastRunM7D			: TimeStamp;
	match				: JadeRegexMatch;
	releaseNum			: Integer;
begin
	schema := currentSchema;
	while portSchema = null do
		if schema.superschema.name = "PortSchema" then
			portSchema := schema.superschema;
			break;
		else
			schema := schema.superschema;
		endif;
	endwhile;
	self.assertNotEqualMsg(portSchema, null, "Failed to find schema PortSchema");
	
	class := portSchema.getClass("PortSchemaRelease");
	self.assertNotEqualMsg(class, null, "Failed to find class PortSchemaRelease");
	
	create errors transient;
	create subclasses transient;
	create prevMthsDict transient;
	
	class.getSubclasses(subclasses);
	foreach subClass in subclasses do
		
		if subClass.name &lt;&gt; "PortSchemaRelease" then
			delete match;
			JadeRegex@match(subClass.name, ".*_(\d+_\d+_\d+)", true, true, match);
			releaseNum := match.at(1).value.replace__("_", "", true).Integer;	// Let this blow up to help detect incorrectly named classes
		endif;
		
		if releaseNum &lt; 20021 or subClass.name = "PortSchemaRelease" then
			continue;
		endif;
		
		methodsDict := subClass.cnGetMethods();
		postMth := methodsDict[SPECIFIC_POST_STANDARD];
		preMth := methodsDict[SPECIFIC_PRE_STANDARD];
		
		if postMth &lt;&gt; null then
			postMthSrc := postMth.getSource();
		endif;
		if preMth &lt;&gt; null then
			preMthSrc := preMth.getSource();
		endif;
		
		lastRunM7D := self.getLastRunTime();
		lastRunM7D.setDate(lastRunM7D.date.addDays(-7));
		
		// Check to see if an upgrade script has been included in both the current release and the next
		foreach mthd in prevMthsDict do
			// If the script was modified more than 7 days ago, then ignore it.
			if mthd.cnGetModifiedTimeStamp &lt; lastRunM7D then
				continue;
			endif;
			
			if methodsDict[mthd.name] = null then
				errors.add(mthd.name &amp; " has not been included in " &amp; subClass.name);
			endif;
		endforeach;
		prevMthsDict.clear();
		
		foreach mthd in methodsDict do
			/*if mthd.name = PortSchema_8_6_1::aaaScriptTemplate.name
			or mthd.name = SPECIFIC_POST_STANDARD
			or mthd.name = SPECIFIC_PRE_STANDARD
			or mthd.name = PortSchema_8_6_1::createJMTSupportUser.name
			or mthd.name = PortSchema_8_6_1::createLogEntry.name
			or mthd.name = PortSchema_8_6_1::createNullVessel.name
			or mthd.name = PortSchema_8_6_1::createOtherMaintPermissionList.name
			or mthd.name = PortSchema_8_6_1::createOtherViewPermissionList.name
			or mthd.name = PortSchema_8_5_1::fixContainerTEU.name
			or mthd.name = PortSchema_8_6_1::resetMenuForJMTSupportUser.name
			or mthd.name = PortSchema_8_6_1::setupIMEXTransition.name
			or mthd.name = PortSchema_8_6_1::tfs6962Conversion.name
			or mthd.name = PortSchema_8_6_1::tfs6962ConvertClass.name
			or mthd.name = PortSchema_8_6_1::updateLicenseModuleNames.name
			or mthd.name = PortSchema_8_6_1::updateLicenseMigrateChildren.name
			or mthd.name = PortSchema_8_6_1::updateLicenseDecommissions.name*/
			if mthd.name = PortSchema_20_0_21::updateIMVVehicleConfig.name		// doesn't include hasBeenRunAtAll check
			or mthd.name = PortSchema_22_0_24::addNoDupsHaltExHandler.name		// doesn't include hasBeenRunAtAll check  // ### JIRA 36467 03NOV2025 NAVAB1
			or mthd.name = SPECIFIC_POST_STANDARD								// ### TFS N/A 19Oct2022 NAVPW1
			or mthd.name = SPECIFIC_PRE_STANDARD								// ### TFS N/A 19Oct2022 NAVPW1
			then
				continue;
			endif;
			
			methSource := mthd.getSource();
			methSource.cnReplaceString(Tab, " ");
			
			if methSource.cnContains("app.initialize;") then
				errors.add(mthd.name &amp; " uses app.initialize");
			endif;
			if not (methSource.cnContains("self.hasScriptBeenRunAtAll") and methSource.cnContains("self.addScriptRun")) then
				errors.add(mthd.qualifiedName &amp; " does not contain hasScriptBeenRunAtAll AND addScriptRun");
			endif;
			if not methSource.cnContains("writeLog") 
			and not methSource.cnContains("logEntry") 
			and not methSource.cnContains("createLogEntry") 
			then
				errors.add(mthd.qualifiedName &amp; " does not log anything");
			endif;
			
			// Now check to make sure the method has actually been included in the upgrade classes
			// NOTE: The developer might not do this straight away to avoid the nightly builds breaking when a script isn't finished
			// But this has a tendency to be forgotten later by a certin few...
			if not (postMthSrc.cnContains(mthd.name) or preMthSrc.cnContains(mthd.name)) then
				errors.add(mthd.qualifiedName &amp; " has not been added to either pre or post upgrade method");
			endif;
			
			prevMthsDict.add(mthd);
		endforeach;
	endforeach;
	
	if not errors.isEmpty then
		foreach str in errors do
			msg := msg &amp; str &amp; CrLf;
		endforeach;
		self.assertNullMsg(msg, msg);
	endif;
epilog
	delete errors;
	delete subclasses;
	delete prevMthsDict;
	delete match;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckVbsSlotTypes" id="ce8a3a00-b58b-4e64-bf63-de4c5d34556f">
        <source>tCheckVbsSlotTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2023	navpw1	Initial creation TFS: 53697

*/

vars
	terminal							: CM_Terminal;
	vehicleBookingTerminal				: CM_VehicleBookingTerminal;
	vehicleBookingDayTemplate			: CM_VehicleBookingDayTemplate;
	vehicleBookingTimeTemplate			: CM_VehicleBookingTimeTemplate;
	errors								: String;
	invalidVehicleBookingTimeTemplates	: ObjectSet;
	invalid								: Boolean;
	
begin
	create invalidVehicleBookingTimeTemplates transient;
	
	on Exception do app.handleDeletedObject( exception, vehicleBookingTimeTemplate.myVBTimeslotType, invalid);
	
	foreach terminal in app.myRoot.allTerminals do :terminalLoop
		vehicleBookingTerminal := terminal.myVehicleBookingTerminal;
		
		if vehicleBookingTerminal = null then
			continue terminalLoop;
		endif;
		
		if vehicleBookingTerminal.allVehicleBookingDayTemplates.isEmpty then
			continue terminalLoop;
		endif;
		
		foreach vehicleBookingDayTemplate in vehicleBookingTerminal.allVehicleBookingDayTemplates do :vehicleDayTemplate
			if vehicleBookingDayTemplate.allTimeTemplates.isEmpty then
				continue vehicleDayTemplate;
			endif;
			
			foreach vehicleBookingTimeTemplate in vehicleBookingDayTemplate.allTimeTemplates do :vehicleTimeTemplate
				if vehicleBookingTimeTemplate.myVBTimeslotType = null then
					continue vehicleTimeTemplate;
				endif;
				
				vehicleBookingTimeTemplate.myVBTimeslotType.edition;
				
				if not invalid then
					continue vehicleTimeTemplate;
				endif;
				
				invalid := false;
				
				invalidVehicleBookingTimeTemplates.add(vehicleBookingTimeTemplate);
				app.writeLog("Vehicle Booking Time Template: Vbs Slot type deleted | Terminal: " &amp; terminal.code &amp; " | Day Template Name: " &amp; vehicleBookingDayTemplate.name &amp; 
								" |  Start Time: " &amp; vehicleBookingTimeTemplate.startTime.asStringJMT &amp; " | End Time: " &amp; vehicleBookingTimeTemplate.endTime.asStringJMT, LogINFO);
			endforeach;
			
		endforeach;
		
	endforeach;
	
	on Exception do null;
	
	self.assertEqualMsg(invalidVehicleBookingTimeTemplates.size, 0, "Check error log for invalid Vehicle Booking Time Templates");
	
epilog
	delete invalidVehicleBookingTimeTemplates;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckVesselAndVoyageStructure" id="297edb5c-96f2-40db-a354-096f5dededb4">
        <source>tCheckVesselAndVoyageStructure();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2012	cnwndl1	Initial creation	Par 30627

*/

vars

	slotDefnVessel : CM_SlotDefnVessel;
	iter : Iterator;
	vesselsWithIssues : CM_ObjectSet;
	vessel : CM_Vessel;
	obj : Object;
	bay : CM_Bay;
	str : String;
	
	bayVoyage : CM_BayVoyage;
	slotDefnVoy : CM_SlotDefnVoyage;
	voyage : CM_Voyage;
	voyagesWithIssues : CM_ObjectSet;
	breakVoyage : Boolean;
	
	term : CM_Terminal;
	currentVoyages : CM_VoyageSet;
	
	slotCont : CM_SlotController;
	
begin

	create vesselsWithIssues transient;
	create voyagesWithIssues transient;
	create currentVoyages transient;
	
	// find all vessel definitions with issues.
	iter := CM_SlotDefnVessel.instances.createIterator;
	while iter.next( slotDefnVessel ) do
		bay := slotDefnVessel.myBay;
		if slotDefnVessel.fortyBack and slotDefnVessel.fortyFront then
			if bay.bayType = BAY_TYPE_TRIPLE then
				if bay.isFirstInHold() then
					vessel := bay.CM_BayDefn.myVesselCellular.myVessel;
					if vessel &lt;&gt; null then
						vesselsWithIssues.addNoDuplicates(vessel,false);
					endif;
				elseif bay.isLastInHold() then
					vessel := bay.CM_BayDefn.myVesselCellular.myVessel;
					if vessel &lt;&gt; null then
						vesselsWithIssues.addNoDuplicates(vessel,false);
					endif;
				endif;
			else
				vessel := bay.CM_BayDefn.myVesselCellular.myVessel;
				if vessel &lt;&gt; null then
					vesselsWithIssues.addNoDuplicates(vessel,false);
				endif;
			endif;
		 elseif slotDefnVessel.fortyBack then
			if bay.isFirstInHold() then
				vessel := bay.CM_BayDefn.myVesselCellular.myVessel;
				if vessel &lt;&gt; null then
					vesselsWithIssues.addNoDuplicates(vessel,false);
				endif;
			endif;
		elseif slotDefnVessel.fortyFront then
			if bay.isLastInHold() then
				vessel := bay.CM_BayDefn.myVesselCellular.myVessel;
				if vessel &lt;&gt; null then
					vesselsWithIssues.addNoDuplicates(vessel,false);
				endif;
			else
				if slotDefnVessel.myAftSlot &lt;&gt; null and not slotDefnVessel.myAftSlot.unavailable and not slotDefnVessel.myAftSlot.fortyBack then
					vessel := bay.CM_BayDefn.myVesselCellular.myVessel;
					if vessel &lt;&gt; null then
						vesselsWithIssues.addNoDuplicates(vessel,false);
					endif;
				endif;  
			endif;
		endif;
	endwhile;
	delete iter;
	
	// get a collection of the the current voyages first	
	foreach term in app.myRoot.allTerminals discreteLock do
		iter := term.allVoyagesNew.createIterator();
		while iter.next(voyage) do
			if voyage.isNullVoyage then
				continue;
			endif;
			if voyage.displayOption = VoyageDisplayNever then
				continue;
			endif;
			if voyage.isCancelled then  //epr TFS 51963 5/10/21
				continue;
			endif;
			if voyage.archived or voyage.myTerminalArchived &lt;&gt; null then
				continue;
			endif;
			if not currentVoyages.includes(voyage) then
				currentVoyages.add(voyage);
			endif;
		endwhile;
		delete iter;
	endforeach;
	
	// iterate thru the current voyages finding those with bad slots
	foreach voyage in currentVoyages discreteLock do 
	
		if voyage.myCellularVoyageStructure = null then
			continue;
		endif;
		
		breakVoyage := false;
		foreach bayVoyage in voyage.myCellularVoyageStructure.allBayVoyagesByOrdinal discreteLock do 
			iter := bayVoyage.allSlotControllersByOrdinal.createIterator;
			while iter.next( slotCont ) do
				slotDefnVoy := slotCont.mySlotDefnVoyage;
				if slotDefnVoy = null then
					continue;
				endif;
				if slotDefnVoy.fortyBack and slotDefnVoy.fortyFront then
					if bayVoyage.bayType = BAY_TYPE_TRIPLE then
						if bayVoyage.isFirstInHold() then
							voyagesWithIssues.addNoDuplicates(voyage,false);
							breakVoyage := true;
							break;
						elseif bayVoyage.isLastInHold() then
							voyagesWithIssues.addNoDuplicates(voyage,false);
							breakVoyage := true;
							break;
						endif;
					else
						voyagesWithIssues.addNoDuplicates(voyage,false);
						breakVoyage := true;
						break;
					endif;
				 elseif slotDefnVoy.fortyBack then
					if bayVoyage.isFirstInHold() then
						voyagesWithIssues.addNoDuplicates(voyage,false);
						breakVoyage := true;
						break;
					endif;
				elseif slotDefnVoy.fortyFront then
					if bayVoyage.isLastInHold() then
						voyagesWithIssues.addNoDuplicates(voyage,false);
						breakVoyage := true;
						break;
					//24 Oct 2012	NDL	Par 30627
					else
						if slotDefnVoy.myAftSlot &lt;&gt; null and not slotDefnVoy.myAftSlot.unavailable and not slotDefnVoy.myAftSlot.fortyBack then
							voyagesWithIssues.addNoDuplicates(voyage,false);
							breakVoyage := true;
							break;
						endif; 
					endif;
				endif;
			endwhile;
			
			delete iter;
			if breakVoyage then
				break;
			endif;
			
		endforeach;
		
	endforeach; 
	

	foreach obj in vesselsWithIssues discreteLock do
		vessel := obj.CM_Vessel;
		str := str &amp; "'Vessel '" &amp; vessel.code &amp; "' has 40 foot slots attributes issues." &amp; CrLf;
	endforeach;
	
	foreach obj in voyagesWithIssues discreteLock do
		voyage := obj.CM_Voyage;
		str := str &amp; "'Voyage '" &amp; voyage.code &amp; "' has 40 foot slots attributes issues. (" &amp; obj.CM_Voyage.getMyTerminal.code &amp; ")" &amp; CrLf;
	endforeach; 
	
	self.assertTrueMsg( str = null, str );


epilog

	delete iter;
	delete vesselsWithIssues;
	delete voyagesWithIssues;
	delete currentVoyages;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckVoyageAllocHasVoyage" id="19be419e-7edc-46c1-a855-a8f64d46fa10">
        <source>tCheckVoyageAllocHasVoyage();

/*

Purpose:		Check that CM_VoyageAllocations actually have a valid voyage	
				Only delete for UT Terminal
				
				Note: This does it in chunks because if the collection is 
				large them it could take hours to do and we don't really 
				want that


Date			Who		Reason
11/08/2015		cnwmh5	Initial creation

*/

vars

	voyageAlloc						: CM_VoyageAllocation;
	startAtVoyAlloc					: CM_VoyageAllocation;
	nextVoyAllocToStartAt			: CM_VoyageAllocation;
	classMethod						: UM_UnitTestClassMethod;
	root							: UM_Root;
	unitTestRun						: UM_UnitTestRun;
	unitTestResult 					: UM_UnitTestResult;
	objToDelete						: UM_ObjectsToDelete;
	
	voyageAllocDict					: CM_YardAllocationsByCodeDict;
	
	iter 							: Iterator;
	
	tempStr							: String;
	noToDelete						: Integer;
	noToCheck						: Integer;
	totNoToCheck					: Integer;
	methStartTS						: TimeStamp;
	methEndTS						: TimeStamp;
	elapsedTime						: TimeStampInterval;
	result							: String;
	pos								: Integer;
	startSize						: Integer;
	
begin

	root := UM_Root.firstInstance;
	self.assertNotNull(root);
	
	startSize := CM_VoyageAllocation.instances.size;
	totNoToCheck := (startSize / 30).Integer;	
	noToCheck := totNoToCheck;
	
	create voyageAllocDict transient;
	CM_VoyageAllocation.instances.copy(voyageAllocDict);
	
	// work out where we need to start our checking from
	iter := voyageAllocDict.createIterator;
	classMethod := root.allRunnableUTClassesMethods[method.getSchemaType().name, method.name];
	if classMethod &lt;&gt; null then
		unitTestResult := classMethod.allUnitTestResults.first;
		tempStr := unitTestResult.details.uncompressToString();
		pos := 1;
		pos := tempStr.pos("NextVoyageAllocToStartAt: ", pos);
		if pos &gt; 0 then
			pos := pos + "NextVoyageAllocToStartAt: ".length;
			tempStr := tempStr.scanUntil(Cr, pos);
			pos := 1;
			pos := tempStr.pos("/", pos);
			startAtVoyAlloc := tempStr[pos+1:end].asObject().CM_VoyageAllocation;
		endif;
	endif;
	
	if startAtVoyAlloc = null then
		startAtVoyAlloc := voyageAllocDict.first.CM_VoyageAllocation;
	endif;	
	
	iter.startAtObject(startAtVoyAlloc);
	beginTransaction;
	while iter.next(voyageAlloc) do
		
		if voyageAlloc.myTerminal &lt;&gt; null  then
			continue;
		endif;
		
		if voyageAlloc.myVoyage &lt;&gt; null then
			continue;
		endif;
		
		objToDelete := root.allObjectsToDeleteByObject[voyageAlloc.getOidAsString];
		if objToDelete = null then
			create objToDelete persistent;
			objToDelete.updateDetails(voyageAlloc, UM_ObjectsToDelete.WhenToDeleteNext);
			if (noToDelete / 1000).Decimal.fractionValue = 0 then	
				commitTransaction;
				beginTransaction;
			endif;
		else	
			continue;
		endif;
		
		noToCheck := noToCheck - 1;
		if noToCheck = -1 then
			nextVoyAllocToStartAt := voyageAlloc;
			break;
		endif;
		noToDelete := noToDelete + 1;
				
	endwhile;
	commitTransaction;	
	
	///write "Starting at " &amp; startAtVoyAlloc.String &amp; " " &amp; noToDelete.String &amp; 
	///	" record(s) added to UM_ObjectsToDelete from " &amp; startSize.String &amp; CrLf &amp;
	///	"NextVoyageAllocToStartAt: " &amp; nextVoyAllocToStartAt.String;
	
	app.writeLog("Starting at " &amp; startAtVoyAlloc.String &amp; " " &amp; noToDelete.String &amp; 
		" record(s) added to UM_ObjectsToDelete from " &amp; startSize.String, LogINFO);
	app.writeLog("NextVoyageAllocToStartAt: " &amp; nextVoyAllocToStartAt.String, LogINFO);
	self.assertNull(nextVoyAllocToStartAt);
	
epilog

	delete iter;
	delete voyageAllocDict;

end;
</source>
    </JadeMethod>
    <JadeMethod name="tCheckVoyageRotations" id="9870ef97-f311-48d6-beb0-2475dd8834d2">
        <source>tCheckVoyageRotations();
// cnwndl1
// cnwdw1

// Any problems can be fixed using uFixupVoyageRotations

vars
	iter : Iterator;
	
	voyage : CM_Voyage;
	breakVoyage : Boolean;
	
	term : CM_Terminal;
	currentVoyages : CM_VoyageSet;

	portRotation: CM_PortRotation;
	
	str: String;
	termStr : String;

begin

	create currentVoyages transient;
	
	// get a collection of the the current voyages first	
	foreach term in app.myRoot.allTerminals discreteLock do
		iter := term.allVoyagesNew.createIterator();
		while iter.next(voyage) do
			if voyage.isNullVoyage then
				continue;
			endif;
			if voyage.displayOption = VoyageDisplayNever then
				continue;
			endif;
			if voyage.isCancelled then  //epr TFS 51963 5/10/21
				continue;
			endif;
			if voyage.archived or voyage.myTerminalArchived &lt;&gt; null then
				continue;
			endif;
			if not currentVoyages.includes(voyage) then
				currentVoyages.add(voyage);
			endif;
		endwhile;
		delete iter;
	endforeach;
	
	// iterate thru the current voyages finding those with bad slots
	foreach voyage in currentVoyages discreteLock do 
	
		termStr := null;
		if voyage.myTerminal &lt;&gt; null then
			termStr := voyage.myTerminal.code;
		endif;
	
		//Check for null ventries ibn Port Rotation
		foreach portRotation in voyage.allPortRotations do
			if portRotation.myPort = null then
				write voyage.String &amp; Tab &amp; voyage.code &amp; Tab &amp; portRotation.String &amp; Tab &amp; portRotation.myPort.String;
				str := str &amp; "Voyage " &amp; voyage.code &amp; " has null port in rotation in terminal " &amp; termStr &amp; CrLf;
			endif;
		endforeach;
		
	endforeach; 


	self.assertTrueMsg( str = null, str );

epilog

	delete iter;
	delete currentVoyages;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckWSTransientCollections" id="2a750df0-1e39-4ec0-8d04-45d617cc35b4">
        <source>tCheckWSTransientCollections();
/*

Purpose:			All WS_ collections should be transient not persistent

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2021	navmd1	Initial creation

*/

vars
	scm 					: Schema;
	collCls,
	cls						: Class;
	allCollectionClasses,
	classesToSkip			: ClassColl;
	
	persistenceErrors,
	instanceErrors			: StringArray;
	errorMsg,
	str						: String;
begin
	scm := rootSchema.getSchema(WebServicesSchemaName);
	self.assertNotNullMsg(scm, "Can't find WebServicesSchema");
	
	// Grab just sub classes of 'Collection' in the WebServiceSchema
	create allCollectionClasses transient;
	collCls := scm.getClass("Collection");
	collCls.allSubclassesUpToSchema(scm, allCollectionClasses);
	
	// Classes which we know are supposed to default to persistent
	// They must be classes from *this* schema, so use getClass instead of accessing the Type directly
	create classesToSkip transient;
	classesToSkip.add(scm.getClass("CM_HazardByCodeDict"));
	
	create persistenceErrors transient;
	create instanceErrors transient;
	
	foreach cls in allCollectionClasses do
		if not cls.transient then
			// Skip system, abstract or known classes
			if cls.isSystemObject or cls.abstract or classesToSkip.includes(cls) then
				continue;
			endif;
			
			persistenceErrors.add(cls.name);
			if cls.instances.size &gt; 0 then
				instanceErrors.add(cls.name);
			endif;
		endif;
	endforeach;
	
	if persistenceErrors.size &gt; 0 then
		foreach str in persistenceErrors do
			errorMsg &amp;= CrLf &amp; str;
		endforeach;
		self.assertTrueMsg(false, "The following WebServiceSchema Collections have incorrectly defaulted their Persistence to 'Persistent' rather than 'Transient'." &amp; CrLf &amp; errorMsg);
	endif;
	
	if instanceErrors.size &gt; 0 then
		errorMsg := null;
		foreach str in instanceErrors do
			errorMsg &amp;= CrLf &amp; str;
		endforeach;
		self.assertTrueMsg(false, "The following WebServiceSchema Collections have persistent objects when only transient should exist." &amp; CrLf &amp; errorMsg);
	endif;
	
epilog
	delete allCollectionClasses;
	delete classesToSkip;
	delete persistenceErrors;
	delete instanceErrors;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckXlations" id="4b727df4-78ce-4530-8716-0c7133a9e670">
        <source>tCheckXlations();
// jlgmd1
// cnwkpd1

/*

Purpose:			Check that all the CM_Xlation foreign codes are uppercase - if they are not, then 
					EDI translations will fail

Parameters:			None

Return Value:		None


Date		Who		Reason
14 Oct 2010	cnwkpd1	PAR #25810 - EDI File load performance

*/

vars
	xlation			: CM_Xlation;
	count,
	notUpper		: Integer;
	coll			: ObjectSet;
	
begin
	create coll transient;
	
	foreach xlation in CM_Xlation.instances do
		count := count + 1;
		
		if xlation.foreignCode &lt;&gt; xlation.foreignCode.toUpper() then
			notUpper := notUpper + 1;
			app.writeLog(method.qualifiedName &amp; xlation.String &amp; " has a non-uppercased foreign code", LogINFO);
			coll.add(xlation);
		endif;
	endforeach;

	self.assertEqualMsg(coll.size, 0, "Something has created a CM_Xlation with a non-uppercased foreignCode");
	

epilog
	delete coll;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCheckYACriteriaObjects" id="eb70b5e0-61b6-4643-b40b-237d224b5d89">
        <source>tCheckYACriteriaObjects();
// cnwndl1
// cnwdw1
// Check the YA Criteria Objects for invalid data
/*

Date		Who		Reason
22 Nov 2012	cnwkpd1	Performance changes - use exception handler
	
*/

vars
	oa 				: ObjectArray;
	yado 			: CM_YACriteriaPriority;
	o 				: Object;
	iter 			: Iterator;
	invalidCount 	: Integer;
	badOnes			: ObjectSet;
	str				: String;
	ed				: Integer;
	invalid			: Boolean;
	
begin
	create oa transient;
	CM_YACriteriaPriority.allInstances(oa, 0, true);
	
	create badOnes transient;
	
	on Exception do app.handleDeletedObject(exception, o, invalid);	
	
	iter := oa.createIterator();
	while iter.next(yado) do
	
		if yado.myYAData = null then
			invalid := true;
		else
			invalid := false;
			o := yado.myYAData;
			ed := o.edition();		// Dereference to force get, and trigger exception if it's invalid
		endif;
		
		if invalid then
			if yado.myYAData = null then
				str := str &amp; 'oid: ' &amp; yado.String &amp; Tab &amp; 'created: ' &amp; yado.createdTime.String &amp; Tab &amp; 
						' myYAData is null' &amp; CrLf;
			else
				str := str &amp; 'oid: ' &amp; yado.String &amp; Tab &amp; 'created: ' &amp; yado.createdTime.String &amp; Tab &amp; 
						'oid: ' &amp; o.String &amp; CrLf;
			endif;
			invalidCount := invalidCount + 1;
			badOnes.addNoDuplicates(yado, false);
		endif;
	endwhile;
	
/*	if app.cnwkpd1_IsUser() then
		badOnes.inspectModal();
	endif;
*/	
	self.assertEqual(str, null);
	self.assertEqual(invalidCount, 0);
	
epilog
	delete oa;
	delete badOnes;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckYADataObjects" id="83b0eda5-7c36-441d-a9f1-b194c588ad2f">
        <source>tCheckYADataObjects();
// jlgmd1
// cnwkpd1
/*

Purpose:			Check the YA Data Object collections for any invalid objects in their
					collections.  Invalid objects here indicates missing code in the erase/delete
					of the invalid object class

Parameters:			

Return Value:		


Date		Who		Reason
18 Sep 2009	cnwkpd1	PAR #19112 - New IsAvailable YA Criteria
22 Nov 2012	cnwkpd1	Performance changes - use exception handler
*/

vars
	oa 				: ObjectArray;
	yado 			: CM_YADataObjects;
	o 				: Object;
	iter 			: Iterator;
	invalidCount 	: Integer;
	badOnes			: ObjectSet;
	str				: String;
	ed				: Integer;
	invalid			: Boolean;
	
begin
	create oa transient;
	CM_YADataObjects.allInstances(oa, 0, true);
	
	create badOnes transient;
	
	on Exception do app.handleDeletedObject(exception, o, invalid);
	
	iter := oa.createIterator();
	while iter.next(yado) do
		foreach o in yado.allObjects do
		
			invalid := false;
			ed := o.edition();		// Dereference to force get, and trigger exception if it's invalid
			
			if invalid then
		
				str := str &amp; 'oid: ' &amp; yado.String &amp; Tab &amp; 'created: ' &amp; yado.createdTime.String &amp; Tab &amp; 
					'oid: ' &amp; o.String &amp; CrLf;
				invalidCount := invalidCount + 1;
				badOnes.addNoDuplicates(yado, false);
				
			endif;
		
		endforeach;
	endwhile;
	
/*	if app.cnwkpd1_IsUser() then
		badOnes.inspectModal();
	endif;
*/	
	//self.assertEqual(str, null);
	//self.assertEqual(invalidCount, 0);
	self.assertEqualMsg(invalidCount, 0, str);
	
epilog
	delete oa;
	delete badOnes;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckYATemplateObjects" id="42ef8c12-4a8f-4edb-aa1b-323524e83500">
        <source>tCheckYATemplateObjects();
// cnwndl1
// cnwdw1
// Check for problem YAtemplates
/*

Date		Who		Reason
22 Nov 2012	cnwkpd1	Performance changes - use exception handler
	
*/

vars
	oa 				: ObjectArray;
	yat				: CM_YATemplate;
	o 				: Object;	
	iter 			: Iterator;
	invalidCount 	: Integer;
	badOnes			: ObjectSet;
	ed				: Integer;
	invalid			: Boolean;
		
begin
	create oa transient;
	CM_YATemplate.allInstances(oa, 0, false);
	
	on Exception do app.handleDeletedObject(exception, o, invalid);	
	
	create badOnes transient;
	
	iter := oa.createIterator();
	while iter.next(yat) do
	
		if yat.myTerminal = null then
			invalid := true;
		else
			invalid := false;
			o := yat.myYardAllocation;
			ed := o.edition();		// Dereference to force get, and trigger exception if it's invalid
		endif;
		
		if invalid then
			invalidCount := invalidCount + 1;
			badOnes.addNoDuplicates(yat, false);
		endif;
	endwhile;
	
	//badOnes.inspectModal();
	//beginTransaction;
		//badOnes.purge;
	//commitTransaction;
	
	self.assertEqual(invalidCount, 0);
	
epilog
	delete oa;
	delete badOnes;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="tIncrementalCleanUp" id="867c954d-33bd-4d88-a21d-a82d5eda8df5">
        <source>tIncrementalCleanUp();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2018	jlgndl1	Initial creation

*/

vars

	classDict : ClassNDict;
	class : Class;

	firstDate : Date;
	interimDate : Date;
	oneYearAgo : Date;
	untilDate : Date;
	
	objArray : ObjectArray;
	
	obj : Object;
	
	vvr : CM_VehicleVisitRecord;
	term : CM_Terminal;
	bulkRelease : CM_BulkRelease;
	allBulkReleaseCands : CM_BulkReleaseSet;

begin

	app.isGarbageCollectionProcess := true;

	create objArray transient;

	// Clean-up any older than a year
	oneYearAgo := app.actualTimeServer.date.cnEcAddYears( -1 );

	// CM_ActivityHistUnitTest
	create classDict transient;
	classDict.add( CM_ActivityHistUnitTest );
	classDict.add( CM_ActivityHistoryGeneralSys );
	classDict.add( CM_ActivityHistoryGeneral );
	classDict.add( CM_SystemAlert );
	classDict.add( CMEVT_Login );
	classDict.add( CMEVT_Logout );
	classDict.add( CMEVT_OverriddenWarning );
	classDict.add( CM_MachineLogOnOffHistory );
	classDict.add( CM_MachineMoveHistory );
	classDict.add( CM_VehicleVisitRecord );
	classDict.add( CMEVT_BookingRefDiscrep );
	classDict.add( CMEVT_DelayEnd );
	classDict.add( CMEVT_TruckEvent );
	classDict.add( CMEVT_DelayStart );
	classDict.add( CMEVT_EDIFileReceived );
	classDict.add( CMEVT_InvoiceGeneration );
	classDict.add( CMEVT_TrainTransaction );
	classDict.add( CMEVT_UnreconciledBooking );
	classDict.add( CMEVT_VoyageEvent );
	classDict.add( CMEVT_WagonTransaction );
	classDict.add( CM_EDISenderRecipFileTypeHist );
	classDict.add( CMEVT_CargoGroupDetail );
	classDict.add( CMEVT_RollBooking );
	classDict.add( CMEVT_LocationActivity );
	classDict.add( CMEVT_SplitBooking );
	
	foreach class in classDict do
	
		obj := class.firstInstance;
		if obj = null then
			continue;
		endif;
		
		objArray.clear();
		
		firstDate := class.firstInstance.creationTime.date;
		interimDate := firstDate.cnEcAddMonths( 1 );
		
		if interimDate &lt; oneYearAgo then
			// in catch up mode.
			untilDate := interimDate;
		else
			untilDate := oneYearAgo;
		endif;
		
		
		foreach obj in class.instances do	
			if obj.creationTime.date &gt; untilDate.Date then
				break;
			endif;	
			objArray.add( obj );	
		endforeach;
		
		if obj.isKindOf( CM_VehicleVisitRecord ) then
			foreach obj in objArray do
				vvr := obj.CM_VehicleVisitRecord;
				self.deleteVVR( vvr );
			endforeach;
		else
			beginTransaction;
			objArray.purge();
			commitTransaction;
		endif;
	
	endforeach;
	
	// UT BulkReleases
	objArray.clear;
	term := CM_Root.firstInstance.allTerminals.getAtKey("UT");
	create allBulkReleaseCands transient;
	foreach bulkRelease in term.allBulkReleasesByCodeDate do
		if bulkRelease.creationTime.date &gt; oneYearAgo.Date then
			continue;
		endif;
		if bulkRelease.status = 2 and bulkRelease.type = 1 then
			allBulkReleaseCands.add( bulkRelease );
		endif;
	endforeach;
	
	if not allBulkReleaseCands.isEmpty then
		firstDate := allBulkReleaseCands.first.creationTime.date;
		interimDate := firstDate.cnEcAddMonths( 1 );
		
		if interimDate &lt; oneYearAgo then
			// in catch up mode.
			untilDate := interimDate;
		else
			untilDate := oneYearAgo;
		endif;
		write "UT CM_BulkRelease (Road) from " &amp; firstDate.String;
		foreach bulkRelease in allBulkReleaseCands do	
			if bulkRelease.creationTime.date &gt; untilDate.Date then
				break;
			endif;	
			objArray.add( bulkRelease );	
		endforeach;
		foreach obj in objArray  do
			self.ignoreTrxWarnings(true);
			app.myTrxDA.trxDeleteBulkRelease(obj.CM_BulkRelease, app.myPassport);
		endforeach;
	endif;
	

epilog

	app.isGarbageCollectionProcess := false;

	delete objArray;
	delete classDict;
	delete allBulkReleaseCands;

end;</source>
    </JadeMethod>
    <JadeMethod name="tIncrementalCleanUp2" id="a5f83eba-a41a-43a3-afaf-7a17410b057a">
        <source>tIncrementalCleanUp2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2021	navndl1	Initial creation	TFS FRIYAY

*/

vars

	classDict : ClassNDict;
	class : Class;

	firstDate : Date;
	interimDate : Date;
	threeYearsAgo : Date;
	untilDate : Date;
	
	objArray : ObjectArray;
	obj : Object;
	
	classMethod : UM_UnitTestClassMethod;
	count : Integer;

begin

	app.isGarbageCollectionProcess := true;

	create objArray transient;

	// Clean-up any older than three years
	threeYearsAgo := app.actualTimeServer.date.cnEcAddYears( -3 );

	
	create classDict transient;
	classDict.add( UM_CleanUpDetails );
	classDict.add( UM_CleanUpDetailsCompact );
	classDict.add( UM_UnitTestResult );
	classDict.add( UM_UnitTestRun );

	foreach class in classDict do
	
		obj := class.firstInstance;
		if obj = null then
			continue;
		endif;
		
		objArray.clear();
		
		firstDate := class.firstInstance.creationTime.date;
		interimDate := firstDate.cnEcAddMonths( 2 ); //resticted to a max clean-up of 2 months per run
		
		if interimDate &lt; threeYearsAgo then
			// in catch up mode.
			untilDate := interimDate;
		else
			untilDate := threeYearsAgo;
		endif;
		write class.name &amp; " - " &amp; untilDate.String;
		
		foreach obj in class.instances do	
			if obj.creationTime.date &gt; untilDate.Date then
				break;
			endif;	
			objArray.add( obj );	
		endforeach;
		
		write "Purging " &amp; objArray.size.String &amp; " " &amp; class.name &amp; " objects";
		beginTransaction;
		objArray.purge();
		commitTransaction;
	
	endforeach;
	
	//19 May 2021	NDL
	write "UM_UnitTestClassMethod 'allUnitTestResultsUsedBy' collection check/rebuild";
	foreach classMethod in UM_UnitTestClassMethod.instances do
		if not classMethod.allUnitTestResultsUsedBy.isEmpty then
			if classMethod.allUnitTestResultsUsedBy.containsBadData then
				beginTransaction;
				//write "Rebuilding 'allUnitTestResultsUsedBy' for " &amp; classMethod.className &amp; "::" &amp; classMethod.methodName;
				count := count + 1;
				classMethod.allUnitTestResultsUsedBy.rebuild(); //Not inversed
				commitTransaction;
			endif;
		endif;
	endforeach;
	write count.String &amp; " UM_UnitTestClassMethod 'allUnitTestResultsUsedBy' collections rebuild";
	
epilog

	app.isGarbageCollectionProcess := false;

	delete objArray;
	delete classDict;

end;</source>
    </JadeMethod>
