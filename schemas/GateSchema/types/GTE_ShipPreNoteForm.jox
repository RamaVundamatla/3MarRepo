    <JadeMethod name="keyDown" id="7fc7a4f9-3746-407a-b61e-811240837e44">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Changed On	By			Reason
----------	--------	-----------------------------------------------------
15/04/2013	cnwdap1		Initial creation PAR #31155 CCM SFW 1321 Impeial Measurements
*/
vars

begin
	if self.doCheckKeyDownSpecial(keyCode, GTE_ShipPreNoteForm::doTblExtraCellInputReady.name) then
		keyCode := 0;
		return;
	endif;
	
	inheritMethod(keyCode, shift);
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="savePreNoteBOL" id="bd7aa874-ad63-42e9-bf95-7e9faca1873a">
        <updating/>
        <source>savePreNoteBOL() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     04 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tmpAttach	: CMIF_InOutAttachment;
	errObj		: CM_Error;
	idx			: Integer;
	tmpListBox	: ListBox;
	result		: Integer;
	intFaceArray	: CMIF_TIObjectArray;
	origCargoType	: Integer; // XPOSE 1833 AKB2001NOV
	origTransMode	:	Integer;
	newTI		: CM_TrackedItem;
begin

	if self.mode = Mode_Update then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Mode update being attempted. Should only allow Mode New');
			return false;
	endif;
	
	create intFaceArray transient;
	
	if self.myIntFacePreNote = null then
		create self.myIntFacePreNote transient;	
	endif;
	
//	self.myIntFacePreNote.hasAttachments := true; // need to set this or attachments are purged
	self.setPreNoteForBOL();  // still do this as it sets stuff on the CMIF_Recival that can be used later.
	self.setBOL();  

	if self.myProxyObject &lt;&gt; null then
		self.myIntFacePreNote.CMIF_PreNote.setMyOriginalProxyTI(self.myProxyObject.CM_TrackedItem);
	endif;
	
	intFaceArray.add(self.myIntFaceBOL);

	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateShipBOL(intFaceArray, false, app.myPassport);
//		elseif self.mode = Mode_Update then
//			app.myTrxUA.trxUpdatePreNotes(intFaceArray, app.myPassport);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode (' &amp; self.mode.String &amp; ')');
			return false;
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Prenotes), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			errObj := app.myPassport.getFirstErrorWarning();			
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window

			if errObj &lt;&gt; null then
				self.goToErrorItem(errObj);
			endif;
		endif;
		
		return false;

	endwhile;

	// The update was successful

//	newTI := self.myIntFacePreNote.myPersistentTrackedItem;

	if self.mode = Mode_Add then
		// set self.myCurrentObject so this is selected in table
//		self.myCurrentObject := newTI;
//		if newTI &lt;&gt; null then
//			self.allAddedPreNotes.add(newTI);
			app.msgBox('Cargo added successfully', 'Cargo Added', MsgBox_OK_Only + MsgBox_Information_Icon	);
//		endif;
		
	else
		// self.mode = Mode_Update
//		if newTI &lt;&gt; null then
//		   	if newTI.cargoType &lt;&gt; origCargoType then
//		   		self.myCurrentObject := newTI;
		   		
		   		// switch the mode as the old obj has been deleted and
		   		// a new one created
//		   		self.mode := Mode_Add;
//		   	endif;
		   	
		   	//if newTI.receiptTransportMode &lt;&gt; origTransMode then
			//  self.myCurrentObject := null;
		   	//	self.tblData.removeItemObject(self.myIntFacePreNote.myPersistentTrackedItem);
			//	self.showHideWagonColumn();
			//	self.zTblDataSortAndShow(true);
			//	self.zTblDataSelectObject(null);  	   	
		   	//endif;
		endif;

	return true;

epilog

	if self.myIntFacePreNote.hasAttachments or self.myIntFaceBOL.hasAttachments then
		// remove reference to attachment to prevent them from being deleted
		foreach tmpAttach in self.allAttachments do
			tmpAttach.setMasterItem(null);
			//proxy parent and children are deleted along with self.myIntFacePreNote;
			tmpAttach.setMyProxyTrackedItem(null);
		endforeach;
	else
		self.allAttachments.purge;
	endif;
	delete self.myIntFacePreNote;
	delete self.myIntFaceBOL;
	if intFaceArray &lt;&gt; null then
		delete intFaceArray;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBOL" id="e0576c05-f535-46b4-b8f3-6df39accc05b">
        <updating/>
        <source>setBOL() updating;
// ---------------------------------------------------------------------------
// Created:     04 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	assistant		: GTE_Assistant;
	intFaceObj		: CMIF_TIObject;
	tmpAttach		: CMIF_InOutAttachment;
	tmpCombo		: ComboBox;
	intFaceCOU		: CMIF_InOutCOU;
	theRow			: Integer;
	tmpTblMain		: CM_EntryTable;
	tmpTblExtra		: CM_EntryTable;
	cargoBolType	: CM_CargoBOLType;
	pos,
	cargoDocketId	: Integer;
	consignor, 
	freightFwdr		: CM_ConsigneeConsignor;
	attach			: CMIF_TIObject;
	dischargePortCode : String;
	loadPortCode : String;
	strConsignor,
	strFreightFwdr : String;
	port			: CM_Port;
	commodity : CM_Commodity;
	commodityCode : String;
	voyageCode : String;
begin
	cargoBolType	:= self.cmbTiType.listObject.CM_CargoBOLType;
	
	
	assistant := self.myAssistant.GTE_Assistant;
	tmpTblMain		 := self.tblMain;
	tmpTblExtra		 := self.tblExtra;
	
	if self.myIntFaceBOL = null then
		create self.myIntFaceBOL transient;	
	endif;

	intFaceObj := self.myIntFaceBOL;	
	intFaceObj.setDataFromTable(tmpTblMain, tmpTblExtra, null, self.myAssistant);
	intFaceObj.GTEIF_ShipBOLIn.operatorCode := tmpTblExtra.getValueByName(ETRow_OperatorCode).String;
	intFaceObj.GTEIF_ShipBOLIn.myOperator := app.myRoot.allOperators[intFaceObj.GTEIF_ShipBOLIn.operatorCode];
	voyageCode := tmpTblExtra.getValueByName(ETRow_VoyageCode).String;
	intFaceObj.GTEIF_ShipBOLIn.myVoyage := self.myTerminal.lookupVoyage (voyageCode, null, false);
	consignor := self.cmbConsignor.myObject.CM_ConsigneeConsignor;
	freightFwdr := self.cmbFreightFwdr.myObject.CM_ConsigneeConsignor;
	
	if consignor &lt;&gt; null then 
		strConsignor := consignor.code;
	endif;
	
	if freightFwdr &lt;&gt; null then 
		strFreightFwdr := freightFwdr.code;
	endif;
	
	intFaceObj.GTEIF_ShipBOLIn.consignorCode := strConsignor;
	intFaceObj.myTerminal := self.myTerminal;
	intFaceObj.setUserDetails(self.myIntFacePreNote);
	
	if cargoBolType &lt;&gt; null then 
		cargoDocketId	:= cargoBolType.id;
	endif;
	
	port := self.cmbDischarge.myObject.CM_Port;
	if port &lt;&gt; null then 
		dischargePortCode := port.code;
	endif;

	// cnwrs1 july 2006 5 char port code 
	port := self.cmbLoadPort.myObject.CM_Port;
	if port &lt;&gt; null then 
		loadPortCode := port.code;
	endif;
//	pos := 1;
//	if self.cmbLoadPort.text &lt;&gt; null then
//		loadPortCode := self.cmbLoadPort.text.scanUntil(Tab, pos).trimBlanks;
//	endif;

	commodity := self.cmbCommodity.myObject.CM_Commodity;
	if commodity &lt;&gt; null then 
		commodityCode := commodity.code;
	endif;
	
	if cargoDocketId = BOLType_Log then
		app.raiseCMException(Relea_this_type_curre_permi_co, null, null);
		
	elseif cargoDocketId = BOLType_GeneralBillOfLading then
		assistant.receival_SaveAttachments(intFaceObj.CMIF_TIObject, self.allAttachments, null, self.myIntFacePreNote);

		if intFaceObj.allSubItems.size &gt; 0 then
			intFaceObj.CMIF_BOL.hasAttachments := true;
			foreach attach in intFaceObj.allSubItems do 
				attach.CMIF_InOutAttachment.consignor := strConsignor;
				//21/11/2006 Mohammad par#12903
				//attach.CMIF_InOutAttachment.freightForwarder := strFreightFwdr; // need to be added
				attach.CMIF_InOutAttachment.dischargePortCode := dischargePortCode;
				attach.CMIF_InOutAttachment.destinationPortCode := intFaceObj.GTEIF_ShipBOLIn.destinationPort;
				attach.CMIF_InOutAttachment.billOfLading := intFaceObj.GTEIF_ShipBOLIn.bolNumber;
				attach.CMIF_InOutAttachment.loadPortCode := loadPortCode;
				attach.CMIF_InOutAttachment.commodityCode := commodityCode;
				attach.CMIF_InOutAttachment.imExStatus := TI_IMEX_STATUS_IMPORT;
			endforeach;
		endif;
	
		intFaceObj.CMIF_BOL.bolType := BOLType_GeneralBillOfLading;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCheckForNonWorked" id="5799c906-e1d4-4df7-aef8-54489c657da9">
        <source>setCheckForNonWorked();
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 13 February 2004
//
//********************************************************************
vars
	comboNonWorked,
	comboVoyage : ComboBox;
begin

	comboVoyage := self.cmbVoyage;
	comboNonWorked := self.cmbNonWorked;
	//Need to allow for boxes that are created on nonworked voyages that can start with an imex of Export.  If nonWorked
	//is selected here then the status will be export.  If the status is set to position on ship then a location must be given
	//and the imex status is set to In Transit.
	//The check for this occurs in CMIF_Prenote::moveToShip;
	if comboVoyage.listObject &lt;&gt; null then
	// PAR 33644 and comboVoyage.listObject.CM_Voyage.isNonWorkedVoyage then
		self.tblExtra.showRowByName(ETRow_IsNonWorked, false);
		self.myAssistant.GTE_Assistant.mainExtraSetValueByControl(tblMain, tblExtra, comboNonWorked.name, comboNonWorked.text);
	else
		self.tblExtra.hideRowByName(ETRow_IsNonWorked, false);
	endif;
end;</source>
    </JadeMethod>
