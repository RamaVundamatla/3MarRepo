    <JadeMethod name="setupForm" id="bd3dd361-96b9-4bb3-84e5-e41d7a153bb2">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars

begin
	inheritMethod();
	
	if self.myInvoiceContractDtlsVolBased &lt;&gt; null and self.myInvoiceContractDtlsVolBased.accumulationType = INV_VOL_BASED_PERIOD then
		
		self.doEnableAddButton();
		
		// Always disable these if accumulation type is period based;
		self.cmbVoyage.enabled := false;
		self.cmbVessel.enabled := false;
		self.lblVessel.enabled := false;
		self.lblVoyage.enabled := false;
		
	endif;
	
	self.initTblData();
	self.initCmbVessel();
	
	self.lblAccumType.caption := self.myInvoiceContractDtlsVolBased.getAccumulatedTypeText();
	
	self.mode := self.Mode_Add;
	
	beginNotification(self.myInvoiceContractDtlsVolBased, self.myTerminal.getTerminalEvent(EVENT_InvContractAccumCreate), Response_Continuous, null);
	beginNotification(self.myInvoiceContractDtlsVolBased, self.myTerminal.getTerminalEvent(EVENT_InvContractAccumUpdate), Response_Continuous, null);
	beginNotification(self.myInvoiceContractDtlsVolBased, self.myTerminal.getTerminalEvent(EVENT_InvContractAccumDelete), Response_Continuous, null);
epilog

end;</source>
    </JadeMethod>
