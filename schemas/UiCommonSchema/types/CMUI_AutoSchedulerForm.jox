    <JadeMethod name="doLoadListRemotes" id="5998c382-fdab-4935-b3ab-96eb0348fa35">
        <updating/>
        <source>doLoadListRemotes(_csvRemotes : String) protected, updating;

vars

	user 		: CM_User;
	entRow		: EntTableRow;
	huge		: HugeStringArray;
	remote		: String;
	class		: Object;
	objArray	: ObjectArray;

begin

	self.listRemotes.clearSelected();
	self.allRemoteClasses.clear;
	self.allRemoteClasses.add(CM_RemoteRegradingHdr);
	self.allRemoteClasses.add(CM_RemoteRegradingHdrExt);
	self.allRemoteClasses.add(CM_RemoteRejectHdr);
	self.allRemoteClasses.add(CM_RemoteReticketHdr);
	self.allRemoteClasses.add(CM_RemoteReticketHdrNew);
	self.allRemoteClasses.add(CM_RemoteScaleTruckHdr);
	self.allRemoteClasses.add(CM_RemoteTransferHdr);
	self.allRemoteClasses.add(CM_RemoteDisassemblyHdr);
	self.allRemoteClasses.add(CM_RemoteCheckScalingHdr);
	
	self.listRemotes.displayCollection(self.allRemoteClasses, false, 0, null);
	create huge transient;	
	create objArray transient;
	_csvRemotes.parseCSV(huge);
	foreach remote in huge do
		foreach class in self.allRemoteClasses do
			if class.Class.name = remote.trimBlanks() then
				objArray.add(class);
				break;
			endif;
		endforeach;
	endforeach;
	self.listRemotes.setSelected(objArray);
	
epilog	
	delete huge;
	delete objArray;
end;</source>
        <access>protected</access>
        <Parameter name="_csvRemotes" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadListTemplates" id="5bb9aef5-59fe-4e54-8aa8-80f495f67a0d">
        <updating/>
        <source>doLoadListTemplates(_csvReports : String) : String protected, updating;

vars

	user 		: CM_User;
	entRow		: EntTableRow;
	row			: JadeTableRow;
	huge		: HugeStringArray;
	report,
	reports		: String;
	item		: CM_MenuUserItem;
	objArray	: ObjectArray;
	dyna		: DynaDictionary;
	iter		: Iterator;
	cmif		: CMIF_ClassSorter;
	
begin

	self.listTemplates.clearSelected();
	self.listTemplates.clear;
	row := 	self.tblTaskCreation.accessRow(self.tblTaskCreation.getRowByName(ETRow_BgpAutoUser));
	if row &lt;&gt; null and row.visible then
		user := self.cmbUser.listObject.CM_User;		
		if user &lt;&gt; null then
			create dyna transient;
			dyna.setMembership(CMIF_ClassSorter);
			dyna.addMemberKey('key', false,true);
			dyna.endKeys(true);
			iter := user.myMenuRootBGRTemplate.allMenuUserItemsWithAMenuItem.createIterator();
			while iter.next(item) do
				create cmif transient;
				cmif.myObject := item;
				cmif.key := item.CM_MenuUserReport.name[1:30];
				dyna.add(cmif);
			endwhile;

			delete iter;
			iter := dyna.createIterator();			
			self.reportTemplateSorter.clear();
			while iter.next(cmif) do
				self.reportTemplateSorter.add(cmif.myObject);
			endwhile;
			self.listTemplates.displayCollection(self.reportTemplateSorter, false, 0, null);
			create huge transient;	
			create objArray transient;
			_csvReports.parseCSV(huge);
			foreach report in huge do
				foreach item in user.myMenuRootBGRTemplate.allMenuUserItemsWithAMenuItem do
					if item.CM_MenuUserReport.name.trimBlanks() = report.trimBlanks() then
						objArray.add(item);
						reports := reports &amp; ',' &amp; report;
						break;
					endif;
				endforeach;
			endforeach;
			self.listTemplates.setSelected(objArray);
			if reports.length &gt; 1 then
				return reports[2:end];
			endif;
		endif;
	endif;
	return null;
epilog	
	delete huge;
	if dyna &lt;&gt; null then
		dyna.purge;
	endif;
	delete dyna;
	delete iter;
	delete objArray;
end;</source>
        <access>protected</access>
        <Parameter name="_csvReports" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadListTemplatesNew" id="15d90d9f-8126-4dd0-a63e-dc58363f0ffe">
        <updating/>
        <source>doLoadListTemplatesNew(_allReports : CM_ReportTemplateByNameDict) : String protected, updating;

vars

	user 		: CM_User;
	row			: JadeTableRow;

begin

	self.listTemplates.clearSelected();
	self.listTemplates.clear;
	row := 	self.tblTaskCreation.accessRow(self.tblTaskCreation.getRowByName(ETRow_BgpAutoUser));
	if row &lt;&gt; null and row.visible then
		user := self.cmbUser.listObject.CM_User;		
		if user &lt;&gt; null then
			self.allTemplates.clear();
			user.allReportsToRunForUser.copy(self.allTemplates);
			//self.listTemplates.displayCollection(user.allReportsToRunForUser, true, 0, null);
			self.listTemplates.displayCollection(self.allTemplates, false, 0, null);
			if _allReports &lt;&gt; null then
				self.listTemplates.setSelected(_allReports);
			endif;
		endif;
	endif;

//	return self.listTemplates.getSelectedString('name');
	return self.listTemplates.getSelectedString(CM_ReportTemplate::name.name);
epilog	

end;</source>
        <access>protected</access>
        <Parameter name="_allReports" type="CM_ReportTemplateByNameDict"/>
        <ReturnType type="String"/>
    </JadeMethod>
