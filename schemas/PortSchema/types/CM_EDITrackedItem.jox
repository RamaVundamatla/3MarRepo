    <JadeMethod name="setSealsAsObjects" id="38b03c27-377f-48b7-a3c4-670dee79f0c1">
        <source>setSealsAsObjects(_sealNum : String; _sealType : String);
//
// 06 Jul 2017	jlgrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
//
vars
	sealEDITI : CM_EDISealTI;
	ediTI : CM_EDITrackedItem;
	sealType : CM_SealType;
	sealNumArray : StringArray;
begin
	if _sealNum = null then
		return;
	endif;
	foreach ediTI in self.myAttachedItems do
		if ediTI.isEDISealDetails and
		   ediTI.CM_EDISealTI.sealEDIType = _sealType then
			if ediTI.CM_EDISealTI.sealEDINum = _sealNum then
				return;
			endif;
		endif;
	endforeach;
	create sealNumArray transient;
	sealType := app.myRoot.getSealType(_sealType);
	if sealType &lt;&gt; null and 
	   sealType.allowMultipleSealNums and
	   _sealNum.pos(",",1) &gt; 0 then
		_sealNum.getTokensForDelimiter(",", sealNumArray);
	endif;
	if self.isTransient then
		create sealEDITI transient;
	else
		create sealEDITI;
	endif;
	sealEDITI.setId(self.id);
	sealEDITI.sealEDINum := _sealNum;
	sealEDITI.sealEDIType := _sealType;
	sealEDITI.myParent := self;
	sealEDITI.myEDIData := self.myEDIData;
epilog
	delete sealNumArray;
end;
</source>
        <Parameter name="_sealNum" type="String"/>
        <Parameter name="_sealType" type="String"/>
    </JadeMethod>
