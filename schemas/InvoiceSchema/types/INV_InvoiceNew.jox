    <JadeMethod name="doBaseFormSave" id="3f874b49-a09f-4665-9f53-f11ba4ab2899">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Purpose:			Saves the data entered on the form for an invoice

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)
01/02/2023	navkc1	TFS CR 55305 Task 55537 UI - Invoice List UI changes
26 Apr 2023 navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 		navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
07 June 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/

vars
	pxyInvoice,
	realInvoice : CM_Invoice;
	theReturn	: Integer;
	status : Integer;		// 26.4.2023 navmk20 TFS 57663
	allWorkOrders : CM_WorkOrderSet;
	date			: Date;
	time			: Time;
	timeStamp		: TimeStamp;
	voyage			: CM_Voyage;
	bol				: CM_BOL;
	
begin
	
	status := self.cmbStatusInvProp.itemData[self.cmbStatusInvProp.listIndex];	// 26.4.2023 navmk20 TFS 57663
	create allWorkOrders transient;		//navtnr20 31-05-2023 58089
	self.mulWorkOrder.getSelected(allWorkOrders);
	self.setMyCurrentCG(); //07/06/2023 navmv20 Bug 58090
	self.setMyCurrentTI(); //20/06/2023 navmv20 Bug 58090
	
	// 10/11/2023	navkc1 Bug 61004
	if self.isUsingGeneralTab then
		voyage := self.cmbVoyageGen.listObject.CM_Voyage;
		bol := self.cmbBillOfLadingGen.listObject.CM_BOL;
	else
		voyage := self.cmbVoyageInvProp.listObject.CM_Voyage;
		bol := self.cmbBillOfLading.listObject.CM_BOL;
	endif;

	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(self.myCurrentBank,
								self.cmbDebtorInvProp.listObject.CM_Debtor,
								self.cmbDebtorAddressProp.listObject.CM_Address,		    //22.07.2019 cnwma1 TFS #45577
								voyage, // 10/11/2023	navkc1 Bug 61004
								self.cmbInvTypeInv.listObject.CM_InvoiceDesc,
								//self.cmbStatusInvProp.text = app.getErrorString(Suspense),	// for manual invoice - is it Suspense status? default is Pending. Par17895 september 2008
								status, // 26.4.2023 navmk20 TFS 57663
								true,	//isManual
								self.myCurrentTI,
								bol,		//For manual invoice creation
								self.myBookingRef,			//For manual invoice creation
								self.myCurrentCargoGroup,	//For manual invoice creation
								self.myReleaseRequest,		//For manual invoice creation
								self.cmbCategory.itemData[self.cmbCategory.listIndex], // 01/02/2023	navkc1	TFS CR 55305 TASK 55537
								self.tblInvProperties.getValueByName(ETRow_PurchaseOrderNumber).String,  // ### BUG 56925 07MAR2023 NAVAB1
								self.myCurrentBank.myInvoiceProcess, // 26.4.2023 navmk20 TFS 57663
								allWorkOrders, //navtnr20 23-05-2023 BUG 58089
								self.txtNarr.text, //14/08/2023	navkc1	Bug 59803
								self.cmbTermsTrade.listObject.CM_InvoiceTermsOfTrade, //14/08/2023	navkc1	Bug 59803
								self.tblInvProperties.getValueByName(ETRow_DebtorReference).String,	//14/08/2023	navkc1	Bug 59803
								self.cmbCurrencyType.listObject.CM_CurrencyType,	//14/08/2023	navkc1	Bug 59803
								self.cmbLocale.listObject.CM_Locale,	//14/08/2023	navkc1	Bug 59803,
								self.cmbDebtorAltAddrProp.listObject.CM_Address	//14/08/2023	navkc1	Bug 59803
								);
	
	//20/07/2023	navkc1	Bug 58995
	if self.isCreditNote then
		date := self.mskCNStartDate.getDate();
		time := self.mskCNStartTime.getTime();
		
		timeStamp.setDate(date);
		timeStamp.setTime(time);
		
		pxyInvoice.fromDT := self.localToSystemTime(timeStamp);
	endif;
	
	while true do
		//20/07/2023	navkc1	Bug 58995
		if self.isCreditNote then
			app.myTrxCA.trxCreateCreditNoteManual(self.allInvoicesToLink, pxyInvoice, realInvoice, app.myPassport);
		else
			app.myTrxCA.trxCreateInvoiceManual(pxyInvoice,realInvoice, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			if realInvoice.isCreditNote() then
				if realInvoice.externalNumber = null then
					app.msgBox( app.getErrorString1(Credit_note_create_success, realInvoice.sequenceNum.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				else
					app.msgBox( app.getErrorString2(Credit_note_ext_create_success, realInvoice.sequenceNum.String, realInvoice.externalNumber), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				endif;
			else
				if realInvoice.externalNumber = null then
					app.msgBox( app.getErrorString1(Invoice_created_successful, realInvoice.sequenceNum.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				else
					app.msgBox( app.getErrorString2(Invoice_ext_created_successful, realInvoice.sequenceNum.String, realInvoice.externalNumber), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				endif;
			endif;
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Manual_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	self.unloadForm();
	
epilog
	delete pxyInvoice;
	delete allWorkOrders;  //navtnr20 23-05-2023 BUG 58089
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBuildWorkOrder" id="252672cd-dfa0-4925-8266-cb47aa0f1b5b">
        <source>doBuildWorkOrder();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023 navtnr20	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b

*/

vars
	terminal			: CM_Terminal;
	wrkOrdr				: CM_WorkOrder;
	iter				: Iterator;
	index				: Integer;
	workOrders : CM_WorkOrderByIdDict;
    workOrder : CM_WorkOrder;
	
begin
	/*terminal := self.myTerminal;
	
	iter := terminal.allWorkOrders.createIterator;
	while iter.next(wrkOrdr) do
		if not wrkOrdr.canManuallyAttachToInvoice() then
			continue;
		endif;
		index := self.cmbWorkOrder.addItem(wrkOrdr.id);
		self.cmbWorkOrder.itemObject[index] := wrkOrdr;
	endwhile;*/
	terminal := self.myTerminal;
    create workOrders transient;
    //workOrders := terminal.allWorkOrders;
    foreach workOrder in terminal.allWorkOrders do
        if  workOrder.taskStatus = WO_STATUS_CANCELLED or workOrder.taskStatus = WO_STATUS_HELD or  
            workOrder.taskStatus = WO_STATUS_INAPORTNET or workOrder.taskStatus = WO_STATUS_USERENTRY or  workOrder.archived then
            continue;
        endif;
        workOrders.add(workOrder);
    endforeach;
    self.mulWorkOrder.setupControl(null, workOrders, INV_InvoiceNew::getFullDescription.name);

    self.mulWorkOrder.availableHeading    := app.getErrorString(Available);
    self.mulWorkOrder.selectedHeading    := app.getErrorString(Selected);
    self.mulWorkOrder.myBaseForm    := self;
    self.mulWorkOrder.setSelected(null);
epilog
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbBolBuild" id="6175576b-2d7c-4d5b-9f2a-5647ff6f2016">
        <source>doCmbBolBuild() protected;
/*

Purpose:			Builds the Bill Of Lading Combo box

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars
	terminal	: CM_Terminal;
	bol			: CM_BOL;
	iter		: Iterator;
	index		: Integer;
	
begin
	terminal := self.myTerminal;
	
	iter := terminal.allBOLsReceivedByDTType.createIterator;
	terminal.allBOLsReceivedByDTType.startKeyGeq(BOLType_GeneralBillOfLading, null, iter);
	
	while iter.next(bol) do
		if bol.status &lt;&gt; BOL_STATUS_NORMAL then
			continue;
		endif;
		
		if bol.bolType &lt;&gt; BOLType_GeneralBillOfLading then
			break;
		endif;
		
		index := self.cmbBillOfLading.addItem(bol.number);
		self.cmbBillOfLading.itemObject[index] := bol;
		
		// 10/11/2023	navkc1 Bug 61004
		index := self.cmbBillOfLadingGen.addItem(bol.number);
		self.cmbBillOfLadingGen.itemObject[index] := bol;
	endwhile;
	
epilog
	delete iter;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbBookingBuild" id="a09afab3-e652-4a21-9e47-e5e157ee53e5">
        <source>doCmbBookingBuild() protected;
/*

Purpose:			Builds the Booking Combo box

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars
	terminal	: CM_Terminal;
	booking		: CM_BookingRef;
	iter		: Iterator;
	index		: Integer;
	
begin
	terminal := self.myTerminal;
	
	iter := terminal.allBookingRefsByStatusRef.createIterator;
	
	while iter.next(booking) do
		if booking.status = BOOKING_REF_CLOSED then //Exclude any closed or Archived bookings
			break;
		endif;
		
		index := self.cmbBooking.addItem(booking.bookingReference);
		self.cmbBooking.itemObject[index] := booking;
	endwhile;
	
epilog
	delete iter;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbCargoGroupIdBuild" id="b3bddc38-1d62-48a3-b209-28d2eee7dd04">
        <source>doCmbCargoGroupIdBuild(_cargoGroup : CM_CargoGroup);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Aug 2023 navhl20 Bug 59906: FR | 54086 - Drop down menu for 'Cargo Group Specific' for Invoice/Credit note - Creation/update screens

*/

vars
	cargoGroup		: CM_TrackedItem;
	terminal		: CM_Terminal;
	cmb				: CMUI_ComboBox;
	debtor			: CM_Debtor;
	cargoType		: CM_CargoType;
begin
	terminal := self.myTerminal;
	cmb	:= self.cmbCGId;
	debtor := self.cmbDebtorInvProp.listObject.CM_Debtor;
	cargoType := self.cmbCGType.listObject.CM_CargoType;
	if cargoType = null then
		return;
	endif;
	cmb.clear();
	foreach cargoGroup in terminal.allCargoGroupsByIdCargoType discreteLock do
		if not (debtor &lt;&gt; null and 
		debtor.operators.isNotEmpty() and
		debtor.operators.includes(cargoGroup.myOperator)) then
			continue;
		endif;
		if cargoType &lt;&gt; null and cargoType.id &lt;&gt; cargoGroup.cargoType then
			continue;
		endif;
		cmb.addItemObject(cargoGroup.id, cargoGroup);
	endforeach;
	if cmb.listCount = 0 and cargoType &lt;&gt; null then
		self.tblCargoGroup.setValueByName(ETRow_CargoGroupId,"No Matched Cargo Group");
	else
		self.tblCargoGroup.setValueByName(ETRow_CargoGroupId,"");
	endif;
epilog

end;</source>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="doCmbCargoGroupTypeBuild" id="d5f3daf3-c811-4900-8b70-e889efba420b">
        <source>doCmbCargoGroupTypeBuild() protected;
/*

Purpose:			Builds theCargo Type Combo box

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
*/

vars
	iter		: Iterator;
	index		: Integer;
	cargoType	: CM_CargoType;
	terminal	: CM_Terminal;
	size        : Integer; //29/05/2023  navmv20 Bug 58090
begin
	terminal := self.myTerminal;
	
	iter := app.myRoot.allCargoTypesById.createIterator;
	while iter.next(cargoType) do
		if cargoType.isNotAvailableForEntry then
			continue;
		endif;
		
		if cargoType.productType &lt;&gt; ProductType_CargoGroup then
			continue;
		endif;
		
		if not cargoType.allTerminals.includes(terminal) then
			continue;
		endif;
		
		index := self.cmbCGType.addItem(cargoType.description);
		self.cmbCGType.itemObject[index] := cargoType;
		size := size + 1; //29/05/2023  navmv20 Bug 58090
	endwhile;
	
	//29/05/2023  navmv20 Bug 58090 - start
	if self.myCurrentCargoGroup &lt;&gt; null then
		self.cmbCGType.listIndex := self.cmbCGType.findStringExact(1,self.myCurrentCargoGroup.cargoTypeDescr);
	elseif size = 1 then
		self.cmbCGType.listIndex := 1;
	endif;
	if  self.cmbCGType.listObject&lt;&gt; null then
		self.tblCargoGroup.setValueByName(ETRow_CargoGroupType, self.cmbCGType.listObject.CM_CargoType.description);
	endif;
	//29/05/2023  navmv20 Bug 58090 - end
epilog
	delete iter;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbCategoryBuild" id="b3ca6169-5f6a-4832-9a40-33ac8f5a4966">
        <source>doCmbCategoryBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2023	navkc1	Initial creation TFS CR 55305 Task 55537 UI - Invoice List UI changes

*/

vars

begin
	self.cmbCategory.addItemWithData(app.getErrorString(Invoice), InvoiceCategory_Invoice);
	self.cmbCategory.addItemWithData(app.getErrorString(Credit_note), InvoiceCategory_CreditNote);
	
	self.cmbCategory.listIndex := 1;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbCategoryClick" id="34703db7-6c43-4e7d-b681-db4e846ee743">
        <updating/>
        <source>doCmbCategoryClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes
22 Aug 2023 navhl20 ChangeRequest 59906: EUP | FR | 54086 - Drop down menu for 'Cargo Group Specific' for Invoice/Credit note - Creation/update screens
*/

vars
	index	: Integer;
begin
	
	self.tblInvProperties.setValueByControlName(self.cmbCategory.name, self.cmbCategory.text);
	
	index := self.cmbCategory.listIndex;
	if index &gt; 0 and self.cmbCategory.itemData[index] = InvoiceCategory_CreditNote then
		// 10/11/2023	navkc1 Bug 61004
		self.tblInvProperties.showHideRowsByViewName(ETView_InvListAddCNDef, CM_EntryTable.ShowHideRows, true);
		//self.tblInvProperties.showRowByName(ETRow_CreditNoteStartDate, false);
		//self.tblInvProperties.showRowByName(ETRow_CreditNoteStartTime, false);
		self.shtLinkInvoice.visible := true;
		self.isCreditNote := true;
		self.tblInvProperties.height := self.tblInvProperties.height + 15;			//22.8.2023 navhl20 #59906
	else
		// 10/11/2023	navkc1 Bug 61004
		self.tblInvProperties.showHideRowsByViewName(ETView_InvListAddInvDef, CM_EntryTable.ShowHideRows, true);
		//self.tblInvProperties.hideRowByName(ETRow_CreditNoteStartDate, false);
		//self.tblInvProperties.hideRowByName(ETRow_CreditNoteStartTime, false);
		self.shtLinkInvoice.visible := false;
		self.isCreditNote := false;
	endif;
	self.setMyCaption();
	self.tblInvProperties.cnEcResizeContents();
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbCurrencyTypeBuild" id="31dac382-67f4-421c-a57a-ec9c90ff240f">
        <source>doCmbCurrencyTypeBuild(_debtor : CM_Debtor);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items

*/

vars
	currencyType,
	debtorCurrencyType : CM_CurrencyType;
begin
	self.cmbCurrencyType.clear();
	
	if app.myRoot.allCurrencyTypes.isEmpty() then
		self.tblInvProperties.hideRowByName(ETRow_CurrencyType, false);
		return;
	endif;
	
	foreach currencyType in app.myRoot.allCurrencyTypes discreteLock do 
		self.cmbCurrencyType.addItemObject(currencyType.code, currencyType);
	endforeach;
	
	if _debtor &lt;&gt; null then		
		debtorCurrencyType :=  _debtor.getDebtorCurrencyType();
		
		if self.cmbCurrencyType.listCount() &gt; 0 then
			if debtorCurrencyType &lt;&gt; null then
				self.cmbCurrencyType.listObject := debtorCurrencyType;
				self.cmbCurrencyType.listIndex  := self.cmbCurrencyType.findObject(debtorCurrencyType);
				self.tblInvProperties.setValueByControlName(self.cmbCurrencyType.name, self.cmbCurrencyType.text);
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="doCmbDebtorAddressBuild" id="a1cc2827-85a8-4cca-8032-cb84ed4b8f62">
        <source>doCmbDebtorAddressBuild(_debtor : CM_Debtor) protected;
/*

Purpose:			Builds the Debtor Address Combo box

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars
	address : CM_Address;
	
begin
	self.cmbDebtorAddressProp.clear();
	
	if _debtor &lt;&gt; null then
		foreach address in _debtor.allAddressesByCode discreteLock do 
			self.cmbDebtorAddressProp.addItemObject(address.description,address);
		endforeach;
		
		if self.cmbDebtorAddressProp.listCount() &gt; 0 then
			if _debtor.getDefaultDebtorAddress &lt;&gt; null then
				self.cmbDebtorAddressProp.listObject := _debtor.getDefaultDebtorAddress;
				self.cmbDebtorAddressProp.listIndex  := self.cmbDebtorAddressProp.findObject(_debtor.getDefaultDebtorAddress);
				self.tblInvProperties.setValueByControlName(self.cmbDebtorAddressProp.name, self.cmbDebtorAddressProp.text); // 07/02/2022	navkc1	CR55305 TASK 55536
			endif;
		endif;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="doCmbDebtorAltAddressBuild" id="baa269c2-7cac-4489-9372-4aab69d6be58">
        <source>doCmbDebtorAltAddressBuild(_debtor : CM_Debtor) protected;
/*

Purpose:			Builds the Debtor Address Combo box

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
09-June-2023 navtnr20 Bug 58472: EUP | Invoicing - Configuration Enhancements - Debtor Address update on Invoice
*/

vars
	altAdress, address : CM_Address;
	
begin
	self.cmbDebtorAltAddrProp.clear();
	
	if _debtor &lt;&gt; null then
		foreach address in _debtor.allAddressesByCode discreteLock do 
			self.cmbDebtorAltAddrProp.addItemObject(address.description,address);
		endforeach;
		
		if self.cmbDebtorAltAddrProp.listCount() &gt; 0 then
			altAdress := _debtor.getDebtorAlternativeAddress();
			if altAdress &lt;&gt; null then
				self.cmbDebtorAltAddrProp.listObject := altAdress;
				self.cmbDebtorAltAddrProp.listIndex  := self.cmbDebtorAltAddrProp.findObject(altAdress);
				self.tblInvProperties.setValueByControlName(self.cmbDebtorAltAddrProp.name, self.cmbDebtorAltAddrProp.text); 
			endif;
		endif;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="doCmbDebtorBuild" id="bae9a2c4-fbb6-412b-8002-17be5cd0131d">
        <source>doCmbDebtorBuild(_combo : CMUI_ComboBox input) protected;
/*

Purpose:			Builds the Debtor Combo box

Parameters:			_combo	CMUI_ComboBox	The combo box to build

Return Value:		NONE

Date		Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)
03/02/2023			navkc1	TFS CR 55305 Task 55536 UI - Invoice Credit Note UI
*/

vars
	debtor : CM_Debtor;
	
begin
	_combo.clear;
	_combo.sorted := false;
	
	// 03/02/2023	navkc1	TFS CR 55305 TASK 55536
	//_combo.addItem(app.getErrorString(CM_All_Debtors));
	//_combo.itemObject[_combo.newIndex] := null;
	//_combo.listIndex := _combo.newIndex;
	
	// Par 14209
	foreach debtor in app.myRoot.myRootCompany.debtors where not debtor.isSuspended do
		_combo.addItem(debtor.name);
		_combo.itemObject[_combo.newIndex] := debtor;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbDebtorInvPropClick" id="14b21b88-e494-481e-9fc7-033a05344a7c">
        <updating/>
        <source>doCmbDebtorInvPropClick(combobox: ComboBox input) protected, updating;
/*

Purpose:			Sets the ent table value when the debtor combo box is clicked

Parameters:			combobox	ComboBox	The combo box that was clicked

Return Value:		NONE

Date				Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)
17/01/2023	navkc1 Bug 61503: FR| 54086 - EUP - Invoice Maintenance - Debtor update.

*/
vars

	debtor : CM_Debtor;
	
begin
	self.tblInvProperties.setValueByControlName(combobox.name, combobox.text);
	debtor := combobox.listObject.CM_Debtor;
	self.doCmbDebtorAddressBuild(debtor);
 
	self.doCmbCurrencyTypeBuild(debtor);
	self.doCmbDebtorAltAddressBuild(debtor);
	self.doCmbTermsTradeBuild(debtor);
	self.doCmbLocaleBuild(debtor);
	self.doCmbCargoGroupIdBuild(null);
	
	if self.cmbInvTypeInv.listIndex &gt; 0 then
		self.invTypeClick(self.cmbInvTypeInv);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbInvoiceTypeBuild" id="0251271a-5677-4c1c-9110-f4291aa748a1">
        <updating/>
        <source>doCmbInvoiceTypeBuild(_combo : CMUI_ComboBox input;
						_showNotEnterable : Boolean) protected, updating;
/*

Purpose:			Builds the Invoice Type Combo box

Parameters:			_combo				CMUI_ComboBox	The combo box we are populating with invoice types
					_showNotEnterable	Boolean			Whether or not we should include not available for entry invoice types

Return Value:		NONE

Date		Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)
03/02/2023			navkc1	TFS CR 55305 Task 55537 UI - Invoice Credit Note UI
*/

vars
	invType:  CM_InvoiceDesc;
	
begin
	_combo.clear;
	_combo.sorted := true;

	// show 'not available for entry' invoice types for the enquiry combo
	//	but not for the new invoice combo
	foreach invType in self.myCurrentBank.invoiceTypes do
		if invType.isNotAvailableForEntry and
		   not _showNotEnterable 
		then
			continue;
		endif;
		_combo.addItem(invType.description);
		_combo.itemObject[_combo.newIndex] := invType;
	endforeach;
	
	_combo.sorted := false;
	//epr par 36958 29/6/15
	if _showNotEnterable then
		_combo.addItemAt(app.getErrorString(CM_All_Types),1);
	endif;
	
	/* // 03/02/2023	navkc1	TFS CR 55305 TASK 55537 - Don't default the invoice type;
	// from 37580 may be no types for the current BU
	if _combo.newIndex &gt; 0 then
		_combo.itemData[_combo.newIndex] := null;
		_combo.listIndex := _combo.newIndex; 
	endif;
	*/
end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_showNotEnterable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCmbLocaleBuild" id="2cef92d3-bbfd-4e15-98df-2cb56ce2bfd9">
        <source>doCmbLocaleBuild(_debtor : CM_Debtor);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items

*/

vars
	locale	: CM_Locale;
	debtorLocale : CM_Locale;
begin
	self.cmbLocale.clear();
	self.cmbLocale.sorted := false;
	
	self.cmbLocale.addItem("");
	self.cmbLocale.itemData[self.cmbLocale.newIndex()] := null;
	
	self.cmbLocale.listIndex := self.cmbLocale.newIndex();
	
	if app.myRoot.allLocales.isEmpty() then
		self.tblInvProperties.hideRowByName(ETRow_Locale, false);
		return;
	endif;
	
	foreach locale in app.myRoot.allLocales discreteLock do
		self.cmbLocale.addItemObject(locale.localeDescription, locale);
	endforeach;
	
	if _debtor &lt;&gt; null then
		debtorLocale := _debtor.getDebtorLocale();
		
		if self.cmbLocale.listCount() &gt; 0 then
			if debtorLocale &lt;&gt; null then
				self.cmbLocale.listObject := debtorLocale;
				self.cmbLocale.listIndex := self.cmbLocale.findObject(debtorLocale);
				self.tblInvProperties.setValueByControlName(self.cmbLocale.name, self.cmbLocale.text);
			endif;
		endif;
	endif;	
	
epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="doCmbReleaseRequestBuild" id="32df5465-5cd9-47da-b5da-0efde86409b3">
        <source>doCmbReleaseRequestBuild() protected;
/*

Purpose:			Builds the Release Request Combo box

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars
	terminal			: CM_Terminal;
	releaseRequest		: CM_BulkRelease;
	iter				: Iterator;
	index				: Integer;
	
begin
	terminal := self.myTerminal;
	
	iter := terminal.allBulkReleasesByCodeDate.createIterator;
	while iter.next(releaseRequest) do
		if releaseRequest.status = BR_COMPLETE or releaseRequest.status = BR_ARCHIVE then //Exclude any complete or archived release requests
			continue;
		endif;
		
		index := self.cmbReleaseRequest.addItem(releaseRequest.code);
		self.cmbReleaseRequest.itemObject[index] := releaseRequest;
	endwhile;
	
epilog
	delete iter;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbStatusInvPropBuild" id="ce87137d-4611-4497-8f4d-3aef521e0c14">
        <source>//doCmbStatusInvPropBuild() protected;																		// 26.4.2023 navmk20 TFS 57663
doCmbStatusInvPropBuild(invoiceProcess	: CM_InvoiceProcess; currentInvoiceStatus : Integer) protected;		// 26.4.2023 navmk20 TFS 57663
/*

Purpose:			Builds the Invoice Status Combo box

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)
26 April 2023		navmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice

*/

vars
	//invoiceProcess	: CM_InvoiceProcess; // TFS 39618		// 26.4.2023 navmk20 TFS 57663
	firstStatus, invoiceStatus	: CM_InvoiceStatus;
	idx : Integer;
begin
	self.cmbStatusInvProp.clear;
	cmbStatusInvProp.sorted := false;
	
	//invoiceProcess := self.myCurrentBank.getMyInvoiceProcess;			// 26.4.2023 navmk20 TFS 57663
	// start - 26.4.2023 navmk20 TFS 57663
	invoiceStatus := invoiceProcess.allStatuses[CM_Invoice.INVOICE_OPEN];  		
	firstStatus := invoiceStatus;  // ### JIRA 35468 31JUL2025 NAVAB1
	self.cmbStatusInvProp.addItem(app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_OPEN));
	self.cmbStatusInvProp.itemData[self.cmbStatusInvProp.newIndex] := CM_Invoice.INVOICE_OPEN;
	// End - 26.4.2023 navmk20 TFS 57663
	
	if invoiceProcess.isLinxProcess() then 
		invoiceStatus := invoiceProcess.allStatuses[CM_Invoice.INVOICE_PENDING_APPROVAL]; // TFS 39618 PATCH 1
		//15/04/2023 navmv20 TFS 55304 TASK 55545 - start
		if not invoiceStatus.userCanSet(self.myTerminal) then
			return;
		endif;
		//15/04/2023 navmv20 TFS 55304 TASK 55545 - end
		self.cmbStatusInvProp.addItem(invoiceStatus.description); 
		self.cmbStatusInvProp.itemData[self.cmbStatusInvProp.newIndex] := CM_Invoice.INVOICE_PENDING_APPROVAL; // TFS 39618 PATCH 1
		
		//self.cmbStatusInvProp.listIndex := 1; // 26.4.2023 navmk20 TFS 57663
		
		//self.tblInvProperties.setValueByControlName(self.cmbStatusInvProp.name, invoiceStatus.description); // TFS 39618 PATCH 1 // 26.4.2023 navmk20 TFS 57663
		
	else
		//15/04/2023 navmv20 TFS 55304 TASK 55545 - start
		invoiceStatus := invoiceProcess.allStatuses[CM_Invoice.INVOICE_PENDING];
		if not invoiceStatus.userCanSet(self.myTerminal) then 
			return;
		endif; 
		//15/04/2023 navmv20 TFS 55304 TASK 55545 - end
		//		invoiceProcess := app.getInvoiceProcess(self.myTerminal, self.myCurrentInvoice); // TFS 39618
		self.cmbStatusInvProp.addItem(app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_PENDING)); //app.getErrorString(Pending)); // TFS 39618
		self.cmbStatusInvProp.itemData[self.cmbStatusInvProp.newIndex] := CM_Invoice.INVOICE_PENDING;
		
		//self.cmbStatusInvProp.listIndex := 1; //26.4.2023 navmk20 TFS 57663
		
		//15/04/2023 navmv20 TFS 55304 TASK 55545 - start
		/*invoiceStatus := invoiceProcess.allStatuses[CM_Invoice.INVOICE_SUSPENSE];
		if not invoiceStatus.userCanSet(self.myTerminal) then 
			return;
		endif;*/
		//15/04/2023 navmv20 TFS 55304 TASK 55545 - end
		//self.cmbStatusInvProp.addItem(app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_SUSPENSE)); //app.getErrorString(Suspense)); // TFS 39618  //26.4.2023 navmk20 TFS 57663
		//self.cmbStatusInvProp.itemData[self.cmbStatusInvProp.newIndex] := CM_Invoice.INVOICE_SUSPENSE;														 //26.4.2023 navmk20 TFS 57663								

		
		//self.tblInvProperties.setValueByControlName(self.cmbStatusInvProp.name, app.getErrorString(Pending));  // 26.4.2023 navmk20 TFS 57663
	endif;
	 // ### JIRA 35468 31JUL2025 NAVAB1
	idx :=  self.cmbStatusInvProp.findStringExact(1, app.getInvoiceStatusString(invoiceProcess, currentInvoiceStatus));
	if idx &gt; 0 then
		self.cmbStatusInvProp.listIndex	:= idx;		// 26.4.2023 navmk20 TFS 57663
		self.tblInvProperties.setValueByControlName(self.cmbStatusInvProp.name,app.getInvoiceStatusString(invoiceProcess, currentInvoiceStatus)); 												 // 26.4.2023 navmk20 TFS 57663 	
	else
		self.tblInvProperties.setValueByControlName(self.cmbStatusInvProp.name, firstStatus.description); 	
		self.cmbStatusInvProp.listIndex	:= 1;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="invoiceProcess" type="CM_InvoiceProcess"/>
        <Parameter name="currentInvoiceStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doCmbTermsTradeBuild" id="a11d5282-6fe3-4aef-8b40-fe2c03d49e1f">
        <source>doCmbTermsTradeBuild(_debtor : CM_Debtor);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items

*/

vars
	
	invTerm : CM_InvoiceTermsOfTrade;
	rootCompany	: CM_Bank;
	
begin
	self.cmbTermsTrade.clear;
	cmbTermsTrade.sorted := false;

	self.cmbTermsTrade.addItem("");
	self.cmbTermsTrade.itemData[self.cmbTermsTrade.newIndex] := null;

	self.cmbTermsTrade.listIndex := self.cmbTermsTrade.newIndex;

	rootCompany := app.myRoot.myRootCompany;
	
	foreach invTerm in rootCompany.allInvoiceTermsOfTrade do
		self.cmbTermsTrade.addItem(invTerm.description);
		self.cmbTermsTrade.itemObject[self.cmbTermsTrade.newIndex] := invTerm;
	endforeach;
	
	if _debtor &lt;&gt; null then
		if _debtor.myTermsOfTrade &lt;&gt; null then
			self.cmbTermsTrade.listObject := _debtor.myTermsOfTrade;
			self.cmbTermsTrade.listIndex  := self.cmbTermsTrade.findObject(_debtor.myTermsOfTrade);
			self.tblInvProperties.setValueByControlName(self.cmbTermsTrade.name, self.cmbTermsTrade.text);
		endif;
	endif;
	
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageBuild" id="4a186f85-1f15-41b8-8a34-9f42a084dff2">
        <source>doCmbVoyageBuild(_combo : CMUI_ComboBox input; _archive : Boolean) protected;
/*

Purpose:			Builds the Voyage Combo box

Parameters:			_combo		CMUI_ComboBox	The combo box to populate with voyages
					_archive	Boolean			Whether or not we shoud include archived voyages

Return Value:		NONE

Date		Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

vars
	str				: String;
	aVoyage 		: CM_Voyage;
	idx 			: Integer;
	
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	_combo.clear;
	_combo.sorted := true;
	
	if _archive  then
		foreach aVoyage in self.myTerminal.allVoyagesArchived discreteLock do
			str := aVoyage.code.trimBlanks &amp; " - " &amp; aVoyage.description;
			if _combo.findString(-1, str) = -1 then
				idx := _combo.addItem(str);
				_combo.itemObject[idx] := aVoyage;
			endif;
		endforeach;
	endif;
	
	foreach aVoyage in self.myTerminal.allVoyagesByCode discreteLock do
		idx := _combo.addItem(aVoyage.getDisplayDetails(false));
		_combo.itemObject[idx] := aVoyage;
	endforeach;
	
epilog
	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_archive" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCreateCriteriaLine" id="829df82b-8bbb-4738-b0ba-72de9197cbb1">
        <source>doCreateCriteriaLine(_qDef : CM_QueryDefinition;
						_criteriaHolder : CM_QueryCriteriaLineHolder io;
						_propName : String;
						_qOperatorStr : String;
						_value : Any);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes

*/

vars
	criteriaLine : CM_SelectorCriteriaLine;
begin
	criteriaLine := _qDef.createCriteriaLine(_propName, _qOperatorStr, _value);
	criteriaLine.setMyCriteriaLineHolder(_criteriaHolder);
epilog

end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
        <Parameter name="_criteriaHolder" type="CM_QueryCriteriaLineHolder" usage="io"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_qOperatorStr" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doQuery" id="cd42c016-f377-4c41-a850-2f97d4baf7e2">
        <updating/>
        <source>doQuery() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes

*/

vars
	invName			: String;
	theTable 		: CM_DataTable;
	collInvoices	: CM_InvoiceBySeqNumDict;
	idx				: Integer;
	anInvoice		: CM_Invoice;
	bank			: CM_Bank;
	pd				: CMS_Progress;
	lastUpdate		: Decimal [20];
begin
	on CM_ProgressException do haltProgress(exception);
	
	self.mousePointer := Window.MousePointer_HourGlass;

	create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.setAction(app.getErrorString1(Loading_invoices,null));
	
	self.tblInvoiceResult.rows := 1;
	theTable := self.tblInvoiceResult;
	theTable.rows := theTable.fixedRows;
	theTable.clearAllSelected ();

	create collInvoices transient;

	bank := self.myCurrentBank;
	
	invName := self.doQueryInvoicesUsingSelector( collInvoices );
	
	if collInvoices &lt;&gt; null then
		if not self.doMaxTableSizeCheck(collInvoices.size, null) then
			return;
		endif;
		
		pd.progress.partsInJob := collInvoices.size;
		
		foreach anInvoice in collInvoices reversed do
			idx := idx + 1;
			if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	
				pd.setAction(app.getErrorString1(Loading_invoices,invName));
				pd.progress.partsDone := idx;
				lastUpdate := app.relativeMachineTime;													
			endif;																						
			
			if bank &lt;&gt; null and bank &lt;&gt; anInvoice.bank then
				continue;
			endif;
			
			self.doQueryAddItemToResultTbl(anInvoice);
			
			if theTable.rows = JadeTableRowLimit then
				break;
			endif;
		endforeach;
	endif;
	
epilog
	
	delete pd;
	delete collInvoices;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItemToResultTbl" id="61006809-d175-4dd7-a647-4f8c26f2b394">
        <updating/>
        <source>doQueryAddItemToResultTbl(_theInvoice : CM_Invoice) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes

*/

vars
	theDataLine : String;
	row			: Integer;
	resultTable,
 	linkTable	: CM_DataTable;
	
begin
	if not global.isValidObject(_theInvoice) then
		return;
	endif;
	
	if _theInvoice.isCreditNote() then
		return;
	endif;
	
	// Skip this invoice if it's already in the link table
	linkTable := self.tblInvoiceLink;
	row := -1;
	linkTable.findObjectInRow(_theInvoice, row);
	if row &gt; 0 then
		return;
	endif;
	
	// Add invoice to the result table
	resultTable := self.tblInvoiceResult;
	
	theDataLine := _theInvoice.getAttributeStringForDefArray(resultTable.allTblDataEntRows);

	resultTable.addItemObject(_theInvoice, theDataLine);

epilog

end;</source>
        <Parameter name="_theInvoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="doQueryInvoicesUsingSelector" id="856da619-797f-4414-b927-c9c9530f03b1">
        <source>doQueryInvoicesUsingSelector(_collInvoices	: CM_InvoiceBySeqNumDict input ) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes

*/

vars
	qDef 			: CM_QueryDefinition;
	criteriaHolder  : CM_QueryCriteriaLineHolder;
	myEnqController : CM_EnqControllerInvoice;
	bank		 	: CM_Bank;
	dr 				: CM_Debtor;
	invType 		: CM_InvoiceDesc;
	invName			: String;
	
begin
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Invoicing_Query_Type,CM_QueryDefinition.Invoice_Query_Mode];

	create myEnqController;
	create myEnqController.allObjects as  CM_InvoiceBySeqNumDict transient;
	create criteriaHolder transient;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::myTerminal.name, CM_QReferenceLookup.Operator_Equal, self.myTerminal);

	bank := self.myCurrentBank;
	if bank &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::bank.name, CM_QReferenceLookup.Operator_Equal, bank);
	endif;
	
	dr := self.cmbDebtorInvProp.listObject.CM_Debtor;
	if dr &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getDebtor.name, CM_QReferenceLookup.Operator_Equal, dr);
	endif;
		
	if cmbInvoiceType.listIndex &gt; 0 then
		invType := self.cmbInvoiceType.listObject.CM_InvoiceDesc;
		if invType &lt;&gt; null then
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getInvoiceType.name, CM_QReferenceLookup.Operator_Equal, invType);
		endif;
	endif;
	
	// Only search for Invoices, not Credit Note
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getCategoryInt.name, CM_QReferenceLookup.Operator_Equal, InvoiceCategory_Invoice);
	
	// Only seach for POSTED Invoices
	self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getInvStatus.name, CM_QIntegerLookupEqual.Operator_Equal, CM_Invoice.INVOICE_POSTED);
	
	myEnqController.doQuery( qDef );
	
	myEnqController.allObjects.CM_InvoiceBySeqNumDict.copy( _collInvoices );
	
	return invName;
epilog
	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	
	delete myEnqController;
end;</source>
        <Parameter name="_collInvoices" type="CM_InvoiceBySeqNumDict" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doRemoveSelectedFromLinkTable" id="cfb00830-6514-4f74-9f8b-78ebe0927273">
        <source>doRemoveSelectedFromLinkTable(_theTable : CM_DataTable io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes

*/

vars
	allSelectedItems	: ObjectArray;
	obj					: Object;
	row					: Integer;
begin
	
	create allSelectedItems transient;
	
	_theTable.allSelectedObjects.copy(allSelectedItems);
	
	foreach obj in allSelectedItems do
		row := -1;
		_theTable.findObjectInRow(obj, row);
		if row &gt; 0 then
			_theTable.removeItem(row);
			self.allInvoicesToLink.remove(obj.CM_Invoice);
		endif;
	endforeach;
	
epilog
	delete allSelectedItems;
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="io"/>
    </JadeMethod>
