    <JadeMethod name="addTerminalQueryLines" id="56acc242-c15c-48a1-9056-70be91afd596">
        <source>addTerminalQueryLines(	_cloneCriteriaLineHolder : CM_QueryCriteriaLineHolder io;
						_terminal : CM_Terminal;
						_terminalAreas : CM_TAMasterByIdDict
						);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2011	cnwndl1	Initial creation

*/

vars

	cloneUserQuery : CM_MenuUserQuery;
	cloneQueryLine : CM_SelectorCriteriaLine;

	cloneProperty : CM_QueryProperty;
	cloneOperator : CM_QueryOperator;
	objSet : ObjectSet;

begin

	if isInPainter then
		return;
	endif;
	
	//terminal one - unconditionally 
	create cloneQueryLine transient; 
	cloneQueryLine.setMyCriteriaLineHolder(_cloneCriteriaLineHolder);
	
	create cloneProperty as CM_QRefTerminalProperty transient;
	cloneProperty.set(	"Terminal",	//_niceName : String
						"myTerminal",	//_propName : String
						"CM_TrackedItem"	//_className : String
						);
	cloneProperty.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
	
	create cloneOperator as CM_QReferenceLookup transient;
	cloneOperator.setSearchValue( _terminal );
	
	cloneQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
										cloneProperty,	//_myQueryProperty : CM_QueryProperty;
										cloneOperator,	//_myQueryOperator : CM_QueryOperator;
										cloneProperty.propertyName,	//_propName : String;
										cloneProperty.propertyClassName	//_propClassName : String
										);
	
	//terminal areas if the form is using them
	if _terminalAreas &lt;&gt; null and not _terminalAreas.isEmpty then
	
		create objSet transient;
		_terminalAreas.copy( objSet );
		
		create cloneQueryLine transient; 
		cloneQueryLine.setMyCriteriaLineHolder(_cloneCriteriaLineHolder);
		
		create cloneProperty as CM_QRefTerminalAreaProperty transient;
		cloneProperty.set(	"Terminal Area",	//_niceName : String
							"myTerminalArea",	//_propName : String
							"CM_TrackedItem"	//_className : String
							);
		cloneProperty.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'	
		
		create cloneOperator as CM_QReferenceIsOneOf transient;
		cloneOperator.setSearchValue( objSet );
		
		cloneQueryLine.setDetailsOnClone(	false,	//_isUnavailableAtRunTime : Boolean;
											cloneProperty,	//_myQueryProperty : CM_QueryProperty;
											cloneOperator,	//_myQueryOperator : CM_QueryOperator;
											cloneProperty.propertyName,	//_propName : String;
											cloneProperty.propertyClassName	//_propClassName : String
											);
	
	endif;

epilog

	delete objSet;

end;</source>
        <Parameter name="_cloneCriteriaLineHolder" type="CM_QueryCriteriaLineHolder" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalAreas" type="CM_TAMasterByIdDict"/>
    </JadeMethod>
    <JadeMethod name="buildSelf" id="dd356569-67c8-44c3-b31c-a7862fe59c0e">
        <updating/>
        <source>buildSelf() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

begin

	self.transparent := false;
	self.borderStyle := 0;
	self.bevelInner := 0;
	self.bevelInnerWidth := 0;
	self.bevelOuter := 0;
	self.bevelOuterWidth := 0;
	self.boundaryBrush := 0;
	self.boundaryWidth := 0;
	self.stretchWidth := true;
	self.stretchHeight := true;
	
	if self.btnClearRun = null then
		create self.btnClearRun transient;
		self.btnClearRun.parent := self;
		form.addControl(self.btnClearRun);	
		
		self.btnClearRun.visible := true;
		if isInPainter then
			self.btnClearRun.caption := "Clear";
		else
			self.btnClearRun.caption := app.getErrorString(Clear);
		endif;
		self.btnClearRun.tabIndex := self.tabIndex + 1;
	endif;
	
	if self.btnOptions = null then
		create self.btnOptions transient;
		self.btnOptions.parent := self;
		form.addControl(self.btnOptions);	
		
		self.btnOptions.visible := true;
		if isInPainter then
			self.btnOptions.caption := "Options";
		else
			self.btnOptions.caption := app.getErrorString(Options);	
		endif;
		self.btnOptions.tabIndex := self.tabIndex + 2;
	endif;
	
	if self.lblSelected = null then
		create self.lblSelected transient;
		self.lblSelected.parent := self;
		form.addControl(self.lblSelected);	
		
		self.lblSelected.visible := true;
		if isInPainter then
			self.lblSelected.caption := "testing label";
		else
			self.lblSelected.caption := null;
		endif;
		self.lblSelected.tabIndex := self.tabIndex + 3;
		self.lblSelected.alignment := 7; // Centre Middle
		self.wordWrap := true;
	endif;
	
	if self.lstQueries = null then
		create self.lstQueries transient;
		self.lstQueries.parent := self;
		form.addControl(self.lstQueries);	
		
		self.lstQueries.visible := true;				
		self.lstQueries.tabIndex := self.tabIndex + 4;
		self.lstQueries.scrollBars := 3; // Both.
		self.lstQueries.sorted := true; // Both.
		
		if isInPainter then
			self.lstQueries.addItem("Test one");
			self.lstQueries.addItem("Test two");
		endif;
	
	endif;
	
	self.cnEcResizeContents();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clickBtnClear" id="0117b03a-6f63-48bb-8a51-e2f2c195cd1a">
        <source>clickBtnClear( _fromForm : Boolean );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2011	cnwndl1	Initial creation	par 27890

*/

vars

	form : CM_BaseForm;

begin

	if isInPainter then
		return;
	endif;

	form := self.form.CM_BaseForm;
	//re-colour all cargo
	if not _fromForm then
		form.setFromSelectorPanel( null, 0, true, false );
	endif;
	
	//clear the showing run results label
	self.lblSelected.caption := null;
	self.lstQueries.listIndex := -1;
		
	//reset btn label to run.
	self.btnClearRun.caption := app.getErrorString(CM_Run);
	
epilog

end;</source>
        <Parameter name="_fromForm" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clickBtnOptions" id="a5831f23-d76c-44c5-b3d3-92bffba855d8">
        <updating/>
        <source>clickBtnOptions() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	cntrl : Control;
	conwin : Window;
	mouse : Boolean;
	x : Integer;
	y : Integer;
	defMenu : MenuItem;
	mnuMaster : MenuItem;
	mnuChild1 : MenuItem;
	mnuChild2 : MenuItem;
	mnuChild3 : MenuItem;
	mnuChild4 : MenuItem;
	mnuChild5 : MenuItem;
	mnuChild6 : MenuItem;
	mnuChild7 : MenuItem;
	meth : Method;
	enqController : CM_EnquiryController;
	hasResults : Boolean;
	realUserQuery : CM_MenuUserQuery;
	form : CM_BaseForm;
	invalidObject : Boolean;

begin

	if isInPainter then
		return;
	endif;
	
	form := self.form.CM_BaseForm;
	
	meth := self.form.class.getMethodInHTree("clickSelectorMenuItem");
	if meth = null then
		app.msgBox("Developer error, method 'clickSelectorMenuItem' not implemented on " &amp; self.form.name,"Error",MsgBox_OK_Only);
	endif;
	
	form.getEnquiryController( enqController );
	
	on Exception do app.handleDeletedObject( exception, enqController, invalidObject);
	hasResults := enqController &lt;&gt; null and not enqController.allObjects.isEmpty and self.lblSelected.caption &lt;&gt; null;
	
	if invalidObject then
		hasResults := false;
	endif;
	
	if self.lstQueries.listIndex &gt; 0 then
		realUserQuery := self.lstQueries.listObject.CM_MenuUserQuery;
	endif;
	
	cntrl := self;
	conwin := self.form;
	mouse := true;

	x := (self.getFormLeft + self.btnClearRun.left).Integer;
	y := (self.getFormTop + self.btnOptions.top).Integer;
	
	mnuMaster := form.mnuBaseFormContext.getMenuItem(1);
	
	if mnuMaster = null then
		mnuMaster := form.mnuBaseFormContext.loadMenu(1); // Clone menu								
		mnuMaster.caption := "Options";
		mnuMaster.visible := true;
		mnuMaster.userObject := null;
	endif;
	
	mnuChild1 := form.mnuBaseFormContext.getMenuItem(2);
	if mnuChild1 = null then
		mnuChild1 := mnuMaster.loadSubMenu(2); // Clone menu								
		mnuChild1.caption := app.getErrorString(Close);
		mnuChild1.visible := true;
		mnuChild1.userObject := null;
		mnuChild1.setEventMapping(MenuItem::click.name, meth.name);
	endif;
	
	mnuChild2 := form.mnuBaseFormContext.getMenuItem(3);
	if mnuChild2 = null then
		mnuChild2 := mnuMaster.loadSubMenu(3); // Clone menu								
		mnuChild2.caption := app.getErrorString(Clear_query);
		mnuChild2.visible := true;
		mnuChild2.userObject := null;
		mnuChild2.setEventMapping(MenuItem::click.name, meth.name);
	endif;
	mnuChild2.enabled := self.btnClearRun.caption = app.getErrorString(Clear);
	
	mnuChild3 := form.mnuBaseFormContext.getMenuItem(4);
	if mnuChild3 = null then
		mnuChild3 := mnuMaster.loadSubMenu(4); // Clone menu								
		mnuChild3.caption := app.getErrorString(Run_Query);
		mnuChild3.visible := true;
		mnuChild3.userObject := null;
		mnuChild3.setEventMapping(MenuItem::click.name, meth.name);
	endif;
	mnuChild3.enabled := self.btnClearRun.caption = app.getErrorString(CM_Run) and  realUserQuery &lt;&gt; null;
	if mnuChild3.enabled then
		mnuChild3.caption := app.getErrorString(Run_Query) &amp; "  " &amp; realUserQuery.heading &amp; "...";
	endif;
	
	mnuChild4 := form.mnuBaseFormContext.getMenuItem(5);
	if mnuChild4 = null then
		mnuChild4 := mnuMaster.loadSubMenu(5); // Clone menu								
		mnuChild4.caption := app.getErrorString(Edit_query);
		mnuChild4.visible := true;
		mnuChild4.userObject := null;
		mnuChild4.setEventMapping(MenuItem::click.name, meth.name);
	endif;
	mnuChild4.enabled := realUserQuery &lt;&gt; null;
	if mnuChild4.enabled then
		mnuChild4.caption := app.getErrorString(Edit_query) &amp; "  " &amp; realUserQuery.heading &amp; "...";
	endif;
	
	mnuChild5 := form.mnuBaseFormContext.getMenuItem(6);
	if mnuChild5 = null then
		mnuChild5 := mnuMaster.loadSubMenu(6); // Clone menu								
		mnuChild5.caption := app.getErrorString(Send_enquiry);
		mnuChild5.visible := true;
		mnuChild5.userObject := null;
		mnuChild5.setEventMapping(MenuItem::click.name, meth.name);
	endif;
	mnuChild5.enabled := hasResults;
	
	mnuChild6 := form.mnuBaseFormContext.getMenuItem(7);
	if mnuChild6 = null then
		mnuChild6 := mnuMaster.loadSubMenu(7); // Clone menu								
		mnuChild6.caption := app.getErrorString(Send_report);
		mnuChild6.visible := true;
		mnuChild6.userObject := null;
		mnuChild6.setEventMapping(MenuItem::click.name, meth.name);
	endif;
	mnuChild6.enabled := hasResults;
	
	mnuChild7 := form.mnuBaseFormContext.getMenuItem(8);
	if mnuChild7 = null then
		mnuChild7 := mnuMaster.loadSubMenu(8); // Clone menu								
		mnuChild7.caption := app.getErrorString(Summarise_all);
		mnuChild7.visible := true;
		mnuChild7.userObject := null;
		mnuChild7.setEventMapping(MenuItem::click.name, meth.name);
	endif;
	mnuChild7.enabled := hasResults;

	form.showContextMenu(mnuMaster, cntrl, conwin, mouse, x, y);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clickBtnRun" id="836b768b-3f2a-4139-a808-e10ac0590363">
        <source>clickBtnRun() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2011	cnwndl1	Initial creation	Par 27890

*/
vars

	form : CM_BaseForm;
	msg : String;
	terminal : CM_Terminal;
	terminalAreas : CM_TAMasterByIdDict;
	gridRows : CM_GridObjectSet;
	enqController : CM_EnquiryController;
	realUserQuery : CM_MenuUserQuery;
	cloneUserQuery : CM_MenuUserQuery;
	viewMode : Integer;
	criteriaLineHolder : CM_QueryCriteriaLineHolder;
	didCreateEnqCont : Boolean;

begin

	if isInPainter then
		return;
	endif;

	form := self.form.CM_BaseForm;

	if self.lstQueries.listIndex &lt; 1 then
		msg := app.getErrorString(ERR_SelectorQuerySet);
		app.msgBox(msg,app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	realUserQuery := self.lstQueries.listObject.CM_MenuUserQuery;
	if realUserQuery = null then
		msg := app.getErrorString(NO_Query_found);
		app.msgBox(msg,app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if form = null then
		msg := app.getErrorString(No_Associated_form);
		app.msgBox(msg,app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create terminalAreas transient;
	create gridRows transient;
	form.getTermAreaDetailsForQuery( terminal, terminalAreas, gridRows, enqController, viewMode );
	if terminal = null then
		msg := app.getErrorString(Terminal_reference_set);
		app.msgBox(msg,app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	//copy query and amend
	cloneUserQuery := self.createCloneQuery( realUserQuery, terminal, terminalAreas );
	if cloneUserQuery = null then
		msg := app.getErrorString(Clone_query_not_created);
		app.msgBox(msg,app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	// run cloned query
	self.lblSelected.caption := null;
	self.doQuery( terminal, cloneUserQuery, gridRows, enqController, didCreateEnqCont );
	
	//colour all query cargo
	form.setFromSelectorPanel( enqController, viewMode, false, didCreateEnqCont );
	
	//reset btn label to run.
	self.btnClearRun.caption := app.getErrorString(Clear);
	
	//set the display line. title and number of items
	self.lblSelected.caption := self.lstQueries.text &amp; " ( " &amp; enqController.allObjects.size.String &amp; " items )";
	

epilog

	delete terminalAreas;
	delete gridRows;
	delete cloneUserQuery;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clickLstQueries" id="d25d73aa-03a8-488b-9531-2291a9cac575">
        <source>clickLstQueries( listbox : CMUI_ListBox input ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	index : Integer;

begin

	if isInPainter then
		return;
	endif;

	if listbox.listIndex &gt; 0 then
		index := listbox.listIndex;
		self.form.CM_BaseForm.setFromSelectorPanel( null, 0, true, false );
		self.lblSelected.caption := null;
		self.btnClearRun.caption := app.getErrorString(CM_Run);
		listbox.listIndex := index;
	else
		self.btnClearRun.caption := app.getErrorString(Clear);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="listbox" type="CMUI_ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnEcResizeContents" id="3256699c-5877-4351-8258-68283a1abe31">
        <updating/>
        <source>cnEcResizeContents() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	totWidth : Real;
	totHeight : Real;
	leftMargin : Real;
	defaultGap : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	remainingHeight : Real;
	specialLeft : Real;

begin

	if not self.isBuilt then
		return;
	endif;
	
	inheritMethod();
	
//	totWidth := self.width - 4;
	totWidth := self.width;	// 10 Oct 2011	NDL	Par 28332
	totHeight := self.height - 4;
	leftMargin := 2;
	defaultGap := 2;
	stdHeight := 22;
	
	if totWidth &lt; 50 or totHeight &lt; 120 then
		// too narrow or too short to be useful,
		// hide the controls.
		if totWidth &lt; 50 then
			self.caption := "Too narrow";
		else
			self.caption := "Too short";
		endif;
		self.btnClearRun.visible := false;
		self.btnOptions.visible := false;
		self.lblSelected.visible := false;
		self.lstQueries.visible := false;
		return;
	else
		self.caption := null;
		self.btnClearRun.visible := true;
		self.btnOptions.visible := true;
		self.lblSelected.visible := true;
		self.lstQueries.visible := true;
	endif;
	
	if totWidth &lt; 150 then
		//very narrow, all single file
		top := defaultGap;
		stdWidth := totWidth - ( defaultGap * 2 );
		self.btnClearRun.move(	leftMargin,
								top,
								stdWidth,
								stdHeight
								);
								
		top := self.btnClearRun.top + self.btnClearRun.height + defaultGap;
		self.btnOptions.move(	leftMargin,
								top,
								stdWidth,
								stdHeight
								);
								
		top := self.btnOptions.top + self.btnOptions.height + defaultGap;
		self.lblSelected.move(	leftMargin,
								top,
								stdWidth,
								stdHeight
								);
								
		top := self.lblSelected.top + self.lblSelected.height + defaultGap;
		remainingHeight := totHeight - top - defaultGap;
		self.lstQueries.move(	leftMargin,
								top,
								//stdWidth,
								stdWidth + defaultGap,	// 10 Oct 2011	NDL	Par 28332
								remainingHeight
								);
								
	else
		//OK Width - buttons side by side
		top := defaultGap;
		stdWidth := ((totWidth - ( defaultGap * 3 )) / 2 );
		self.btnClearRun.move(	leftMargin,
								top,
								stdWidth,
								stdHeight
								);
								
		specialLeft := btnClearRun.left + btnClearRun.width  + defaultGap;
		self.btnOptions.move(	specialLeft,
								top,
								stdWidth,
								stdHeight
								);
								
		top := self.btnOptions.top + self.btnOptions.height + defaultGap;
		self.lblSelected.move(	leftMargin,
								top,
								totWidth - ( defaultGap * 2),
								stdHeight
								);
								
		top := self.lblSelected.top + self.lblSelected.height + defaultGap;
		remainingHeight := totHeight - top - defaultGap;
		self.lstQueries.move(	leftMargin,
								top,
								//totWidth - ( defaultGap * 2),
								totWidth - defaultGap,	// 10 Oct 2011	NDL	Par 28332
								remainingHeight
								);
								
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createCloneQuery" id="70eba5dd-28bd-4790-95f4-2ab5bb77346b">
        <source>createCloneQuery(	realUserQuery : CM_MenuUserQuery;	
					terminal : CM_Terminal;
					terminalAreas : CM_TAMasterByIdDict
					) : CM_MenuUserQuery protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2011	cnwndl1	Initial creation
12 Oct 2012		cnwer1 par 30571
*/

vars

	theTerminalAreas :  CM_TAMasterByIdDict;
	cloneUserQuery : CM_MenuUserQuery;
	cloneCriteriaLineHolder : CM_QueryCriteriaLineHolder;
	cloneQueryLine : CM_SelectorCriteriaLine;
	loadStateSet : Boolean;
	realCriteriaLineHolder : CM_QueryCriteriaLineHolder;
	realQueryLine : CM_SelectorCriteriaLine;
	cloneProperty : CM_QueryProperty;
	cloneOperator : CM_QueryOperator;
	qryDef 			: CM_QueryDefinition;
begin

	if isInPainter then
		return null;
	endif;
	
	if realUserQuery = null then
		return null;
	endif;
	theTerminalAreas:=terminalAreas;
	if realUserQuery &lt;&gt; null then
	
		qryDef:=realUserQuery.getQueryDefinition;
		//epr 30571 if qryDef does not include terminal area then  running this will give and invalid property exception
		// i.e. Cargo Transaction query
		// i think all include terminal so leaving in
		if qryDef &lt;&gt; null and  qryDef.allQueryProperties[CM_TrackedItem::myTerminalArea.name] = null then
			theTerminalAreas:=null;
		endif;
	
		app.cmsBeginLoad( loadStateSet );
		cloneUserQuery := realUserQuery.pxyCreateUpdateProxy();
		foreach realCriteriaLineHolder in realUserQuery.allCriteriaLineHolders do
			cloneCriteriaLineHolder := realCriteriaLineHolder.cloneSelf(true);
			cloneUserQuery.allCriteriaLineHolders.add(cloneCriteriaLineHolder);
			cloneCriteriaLineHolder.setForUpdate(realCriteriaLineHolder);
			
			
			//unconditionally add query lines making the search for this terminal/terminal areas only.
			self.addTerminalQueryLines( cloneCriteriaLineHolder, terminal, theTerminalAreas );
			
			foreach realQueryLine in realCriteriaLineHolder.allCriteriaLines do
			
				if realQueryLine.myQueryProperty.propertyName = CM_TrackedItem::myTerminal.name
				or realQueryLine.myQueryProperty.propertyName = CM_TrackedItem::myTerminalArea.name
				then
					// skip over it, we have substituted our own already.
					continue;
				endif;
				
				create cloneQueryLine transient; 
				cloneQueryLine.setMyCriteriaLineHolder(cloneCriteriaLineHolder);
				
				cloneProperty := realQueryLine.myQueryProperty.cloneSelf(true);
				cloneOperator := realQueryLine.myQueryOperator.cloneSelf(true);
				realQueryLine.myQueryOperator.cloneReferences(cloneOperator);
				
				cloneQueryLine.setDetailsOnClone(	realQueryLine.isUnavailableAtRunTime,	//_isUnavailableAtRunTime : Boolean;
													cloneProperty,	//_myQueryProperty : CM_QueryProperty;
													cloneOperator,	//_myQueryOperator : CM_QueryOperator;
													cloneProperty.propertyName,	//_propName : String;
													cloneProperty.propertyClassName	//_propClassName : String
													);
				
			endforeach;	
		endforeach;	
	
	endif;

	return cloneUserQuery;
		
epilog

	app.cmsEndLoad( loadStateSet );

end;</source>
        <access>protected</access>
        <Parameter name="realUserQuery" type="CM_MenuUserQuery"/>
        <Parameter name="terminal" type="CM_Terminal"/>
        <Parameter name="terminalAreas" type="CM_TAMasterByIdDict"/>
        <ReturnType type="CM_MenuUserQuery"/>
    </JadeMethod>
    <JadeMethod name="doQuery" id="4d807675-2b1f-4814-beef-d754e12082f4">
        <source>doQuery(	_term : CM_Terminal;
			_userQuery : CM_MenuUserQuery;
			_gridRows : CM_GridObjectSet;
			_enqController : CM_EnquiryController io;
			_didCreate : Boolean output
			) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2011	cnwndl1	Initial creation
12 Oct 2012		cnwer1 par 30571
*/

vars

	obj 		: Object;
	queryAgent : CM_QueryAgentFilter;
	qDef : CM_QueryDefinition;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	ti : CM_TrackedItem;
	location : CM_LocationsController;
	gridRow : CM_GridRow;
	iter : Iterator;
	invalidObject : Boolean;
	
begin
	
	queryAgent := app.myQAFilter;
	
	if queryAgent = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myQAFilter was null');
		return;
	endif;
	
	qDef := app.myRoot.allQueryDefinitionObjects[_userQuery.getType, _userQuery.queryMode];
	
	if qDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Query definition for mode ' &amp;
										_userQuery.queryMode.String &amp; ' could not be found in app.myRoot.allQueryDefinitionObjects');
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, _enqController, invalidObject);
	if _enqController &lt;&gt; null then
		_enqController.allObjects.clear();
	endif;
	if invalidObject then
		_enqController := null;
	endif;
	
	
	//epr par 30571 always delete and recreate if the query selected has a different _userQuery.queryMode will get invalid property exceptions
	if _enqController &lt;&gt; null  then
		delete _enqController;
		_enqController:=null;
	endif;
	
	
	if _enqController = null then
		
		queryAgent.createEnqControllerForMode(_userQuery.queryMode, _userQuery.getType, _enqController);
		create _enqController.allObjects as  CM_ObjectSet transient; //epr par 30571 needs to be object set was CM_TISet could indclude CM_TITransactions
		_didCreate := true;
	endif;
	
	foreach criteriaHolder in _userQuery.allCriteriaLineHolders do
		_enqController.myCriteriaLineHolder := criteriaHolder;
		_enqController.doQuery(qDef);
	endforeach;	
	
	//do additional filtering based on _gridRows....
	if not _gridRows.isEmpty then
		iter := _enqController.allObjects.createIterator;
		while iter.next( obj  ) do
			//epr par 30571
			if  obj.isKindOf(CM_TrackedItem) then
				ti:=obj.CM_TrackedItem;
			elseif obj.isKindOf(CM_TITransaction) then
				ti:=obj.CM_TITransaction.myTrackedItem;
			else
				continue;
			endif;
			
			gridRow := null;
			location := ti.myPrimaryActualLocation;
			if location &lt;&gt; null and location.isKindOf( CM_GridController ) then
				gridRow := location.CM_GridController.myGridRow;
			endif;
			if gridRow = null or not _gridRows.includes( gridRow ) then
				_enqController.allObjects.remove( ti );
			endif;
		endwhile;
	endif;
	
	_enqController.myCriteriaLineHolder := null;	// to avoid the error on potential reload of Selector;
	
epilog

	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_userQuery" type="CM_MenuUserQuery"/>
        <Parameter name="_gridRows" type="CM_GridObjectSet"/>
        <Parameter name="_enqController" type="CM_EnquiryController" usage="io"/>
        <Parameter name="_didCreate" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="editQuery" id="7ea3c697-ca86-48ea-b78e-bc1bfd9c2be4">
        <source>editQuery() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2011	cnwndl1	Initial creation

*/

vars

	realUserQuery : CM_MenuUserQuery;
	theSelector : CMUI_Selector;

begin

	if self.lstQueries.listIndex &lt; 1 then
		return;
	endif;

	realUserQuery := self.lstQueries.listObject.CM_MenuUserQuery;
	if realUserQuery = null then
		return;
	endif;
	
	theSelector := app.getSelectorForm(self.form.CM_BaseForm, self.form.CM_BaseForm.myMasterMenuAction);
	
	if theSelector = null then
		return;
	endif;
	
	theSelector.show();
	theSelector.showQuery(realUserQuery);		
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleButtonClick" id="dacb3aa7-2c33-4107-ae2b-46f05cccfa20">
        <updating/>
        <source>handleButtonClick( btn : CMUI_Button input ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

begin

	if isInPainter then
		return;
	endif;
	
	if btn = self.btnClearRun then
		if self.btnClearRun.caption = app.getErrorString(Clear) then
			self.clickBtnClear( false );
		elseif self.btnClearRun.caption = app.getErrorString(CM_Run) then
			self.clickBtnRun();
		endif;
	endif;
	
	if btn = self.btnOptions then
		self.clickBtnOptions();
	endif;

epilog

end;</source>
