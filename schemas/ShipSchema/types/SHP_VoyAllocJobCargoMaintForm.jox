    <JadeMethod name="showSelectorForm" id="34ce50cf-09a6-47c5-ab49-68df4e0040a7">
        <updating/>
        <source>showSelectorForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2012	cnwrd1	Initial creation

*/

vars
	str			: String;
	theSelector	: CMUI_Selector;
	cargoType,
	containerType	: CM_CargoType;
	criteria 	: CM_YACriteria;
begin


	if self.mySelectorForm &lt;&gt; null then	
		theSelector := self.mySelectorForm;
	else
		theSelector := app.loadForm(CMUI_Selector, null, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_Selector;
		if theSelector = null then
			return;
		endif;
		theSelector.myParent := self;
	endif;
	

	
	
	criteria := self.myAllocation.getCriteriaOfTypeValue(YACriteriaType_CargoType);
	if criteria &lt;&gt; null then		
		if criteria.myYAData.CM_YADataObjects.allObjects.size &gt; 1 then
			//more than one?
			containerType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	
			if criteria.myYAData.CM_YADataObjects.allObjects.includes(containerType) then		
				if app.msgBox(app.getErrorString(Allocation_contains),'Selector Cargo Type' , MsgBox_Yes_No ) = MsgBox_Return_Yes then
					theSelector.setModeFromCargoType(containerType);
				else
					theSelector.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition. TrackedItem_Query_Type, TI_CargoType_Null];
				endif;
			else
			// no containers just set tracked item mode.
				theSelector.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition. TrackedItem_Query_Type, TI_CargoType_Null];
			endif;
		else
			//just one.
			theSelector.setModeFromCargoType(criteria.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType);
		endif;	
	else
	//no cargo type criteria.
		theSelector.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition. TrackedItem_Query_Type, TI_CargoType_Null];
	endif;
	
	
	
	theSelector.myTerminal := self.myTerminal;
	theSelector.myEnquiryCollectionClass := CM_TIArray;
	theSelector.defaultSiteStr := TI_SITE_ONSITE_str;
	
	theSelector.disableMnuEnquiry := false;
	theSelector.myEnquiryCollectionClass := CM_TIArray;
	theSelector.createQueryForAllocation(self.myAllocation);
	theSelector.show;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblResults_contextMenu" id="61d0fc60-028f-40bb-860e-0b8bf29a493d">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResults_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2012	cnwrd1	Initial creation

*/

vars

	x1, y1				: Real;

begin
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := conwin;
	
	self.mnuRemoveCargo.visible := false;

	self.mnuAddSelected.visible := true;
	if self.tblResults.getSelectedRowCount &gt; 0 then
		self.mnuAddSelected.enabled := true;
	else
		self.mnuAddSelected.enabled := false;
	endif;
	
	x1	:=	x;
	y1	:=	y;
	
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	//self.mnuEnquire.userObject := self.tblResults;
	self.popupMenu(self.mnuMainContext, x1.Integer, y1.Integer);
	return false;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblSelectedItems_contextMenu" id="9c032c1f-373b-442d-b742-0a3ec57268cf">
