    <JadeMethod name="isDBBackup" id="32fde690-ba1b-4c36-a2f0-f3754f33461f">
        <condition/>
        <source>isDBBackup(): Boolean condition;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.isKindOf(CM_BackupHistoryDB) then
		return true;
	else
		return false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
