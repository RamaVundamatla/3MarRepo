        <source>getTransportModes() : WS_TransportModeResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2008	cnwkao1	Initial creation - the id field doesn't actually get used by the JMT application, it just deals with the strings, this could be a data list


*/

vars
	response	: WS_TransportModeResponse;
