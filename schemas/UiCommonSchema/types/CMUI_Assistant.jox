    <JadeMethod name="comboBoxScanReaders" id="3696ff2e-c00d-4284-a67c-059d5e03ab77">
        <source>comboBoxScanReaders(_cmb : CMUI_ComboBox input; _term : CM_Terminal; _scanReader : CM_ScanReaderObj);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2022	navpw1	Initial creation TFS: 52773

*/

vars
	idx		: Integer;
	lstIdx	: Integer;
	scanReader	: CM_ScanReaderObj;

begin

	_cmb.clear;
	_cmb.addItem("");
	
	foreach scanReader in _term.allScanReaders do

	//	if not weighBridge.isSerialPort then
		//if scanReader.myWeighBridgeType.code &lt;&gt; CM_WeighBridgeObjType.MT226 then	//08 Jul 2019	NDl	TFS 44965
			idx := _cmb.addItemObject(scanReader.name, scanReader);
			if scanReader = _scanReader then
				lstIdx := idx;
			endif;
		//endif;
	endforeach;
	
	if lstIdx &lt;&gt; 0 then
		_cmb.listIndex := lstIdx;
	endif;

epilog

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_scanReader" type="CM_ScanReaderObj"/>
    </JadeMethod>
    <JadeMethod name="comboBoxSecRoleUsers" id="b5c45c91-1253-4607-91e7-7e6ea17eb535">
        <source>comboBoxSecRoleUsers(pCmb : ComboBox input;_secRole : CM_SecurityRole; pUser : CM_User);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2018	cnwma1	ChangeRequest 41080: PEL1 - Assigning Operators ID to Cranes/Work-Points
*/

vars
	term : CM_Terminal;
	secRole : CM_SecurityRole;
	user 	: CM_User;
	int, 
	index	: Integer;
	userSet  : CM_UserSet;
begin
	pCmb.sorted := false;
	pCmb.clear();
	create userSet transient;
	_secRole.getAllUsers(userSet);
	
	foreach user in userSet do
		if user.code &lt;&gt; 'SUPERUSER' then
			index := pCmb.addItem(user.code);		
			pCmb.itemObject[index] := user;
		endif;
	endforeach;
	
	if pUser &lt;&gt; null then 
		int := pCmb.findObject(pUser);
		pCmb.listIndex := int;
	endif;	
epilog
	delete userSet;
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_secRole" type="CM_SecurityRole"/>
        <Parameter name="pUser" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="comboBoxSecurityRoleSystem" id="7685f93e-7436-4a4b-a40a-af0c25d919b9">
        <source>comboBoxSecurityRoleSystem(_cmb : ComboBox input; _role : CM_SecurityRole);
// ---------------------------------------------------------------------------
// Created:     11 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	secRole			: CM_SecurityRole;
	idx				: Integer;
	localDict : CM_SecurityRoleSet;
	childMaintRole : CM_SecurityRole;
begin
	_cmb.clear();
	_cmb.sorted := true;
	_cmb.addItem(null);
	
	secRole := app.getMyUser.mySystemSecurityRole;
	if secRole = null then
		return;
	endif;
	
	secRole.addRoleAndChildrenToCombo(_cmb);
	
	//14 Feb 2018	NDL	TFS 36947
	create localDict transient;
	secRole.getAllChildMaintRoles( localDict );
	foreach childMaintRole in localDict do
		if _cmb.findObject( childMaintRole ) &lt; 1 then
			idx := _cmb.addItem(childMaintRole.name);
			_cmb.itemObject[idx] := childMaintRole;
		endif;
	endforeach;
	
	if _role &lt;&gt; null then
		if _cmb.findObject(_role) &gt; 0 then
			_cmb.text := self.displayEntrySecurityRole(_role);
			_cmb.listObject := _role;
		endif;
	endif;
	
epilog
	delete localDict;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_role" type="CM_SecurityRole"/>
    </JadeMethod>
    <JadeMethod name="comboBoxSecurityRoleTerminal" id="507d2dae-50e8-4811-bf9c-8ad0e2b46450">
        <source>comboBoxSecurityRoleTerminal(_cmb : CMUI_ComboBox input; _role : CM_SecurityRole);
//--------------------------------------------------------------
//Created: August 2002 By: cnwrs1
//--------------------------------------------------------------
vars
	secRoleDict		: CM_SecurityRoleDict;
	secRole			: CM_SecurityRole;
	idx				: Integer;
	localDict : CM_SecurityRoleSet;
	childMaintRole : CM_SecurityRole;
begin
	_cmb.clear();
	_cmb.sorted := true;
	
	create secRoleDict transient;
	app.getMyUser.getAllAvailableTerminalRoles(secRoleDict);
	
	foreach secRole in secRoleDict do
		_cmb.addItemObject(secRole.name, secRole);
	endforeach;
	
	//14 Feb 2018	NDL	TFS 36947
	create localDict transient;
	if not secRoleDict.isEmpty then
		secRoleDict.first.getAllChildMaintRoles( localDict );
		foreach childMaintRole in localDict do
			if _cmb.findObject( childMaintRole ) &lt; 1 then
				idx := _cmb.addItem(childMaintRole.name);
				_cmb.itemObject[idx] := childMaintRole;
			endif;
		endforeach;
	endif;
	
	if _role &lt;&gt; null and _cmb.findObject(_role) &gt; 0 then
		_cmb.text := self.displayEntrySecurityRole(_role);
		_cmb.listObject := _role;
	endif;
	
epilog
	delete secRoleDict;
	delete localDict;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_role" type="CM_SecurityRole"/>
    </JadeMethod>
    <JadeMethod name="comboBoxSelectorQueriesForRT" id="d2d7851c-5c9d-4e1e-a311-ec5db7be0f50">
        <source>comboBoxSelectorQueriesForRT( _cmb : ComboBox input; _querySet : CM_SelectorQueryAccess );
// ---------------------------------------------------------------------------
// Created:		16 April 2008  by cncwvu1
// ---------------------------------------------------------------------------

vars
	querySet: CM_SelectorQueryAccess;
	idx		: Integer;
begin

	_cmb.clear;
	
	idx := _cmb.addItem("");
	_cmb.itemObject[idx] := null;
	
	foreach querySet in app.myRoot.allSelectorQueriesAccesByDesc do
		//26 Jul 2011	NDL	Par 27890
		if not querySet.isValidForRT() then	//26 Jul 2011	NDL	Par 27890
			continue;
		endif;
		idx := _cmb.addItem( querySet.description );
		_cmb.itemObject[idx] := querySet;
	endforeach;
	if _querySet &lt;&gt; null then
		//_cmb.listObject := _querySet;
		//26 Jul 2011	NDL	Par 27890
		_cmb.listIndex := _cmb.findObject(_querySet);
	endif;
	

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_querySet" type="CM_SelectorQueryAccess"/>
    </JadeMethod>
    <JadeMethod name="comboBoxShippingAgent" id="ff1de1e3-11fc-43ff-8cc4-d06d0a2fe51b">
        <source>comboBoxShippingAgent(pCmb : ComboBox input; _shippingAgent : CM_ShippingAgent);
//--------------------------------------------------------------
//Created: March 2002 By: cnwgd1
