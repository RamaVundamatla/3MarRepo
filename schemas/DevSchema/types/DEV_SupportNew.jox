    <JadeMethod name="btnUpdate_click" id="08dbd3a6-7da0-4011-aca9-d0313d97e466">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdate_click(btn: Button input) updating;

/*
Date			Who		Reason
05 August 2016	cnwar2	Initial creation

*/
vars

begin
	if self.validateNew() then
		self.doNew();
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doNew" id="f9769850-1891-446e-b507-e4def943db1b">
        <updating/>
        <source>doNew() updating;

/*
Date			Who		Reason
05 August 2016	cnwar2	Initial creation

*/
vars
	parsys, tfs, customer, description, owner, opened, topic, release : String;
	contact	: DEV_SupportContact;
	state	: DEV_SupportState;

begin
	parsys 		:= self.txtContact.text;
	tfs			:= self.txtTFS.text;
	customer	:= self.cmbCustomer.text;
	description	:= self.txtDescription.text;
	topic		:= self.cmbTopic.text;
	release		:= self.txtRelease.text;
	owner		:= self.cmbOwned.text;
	opened		:= self.txtOpened.text;

	beginTransaction;
	create contact persistent;
	create state persistent;
	contact.number 			:= parsys.Integer;
	contact.tfsNumber 		:= tfs.Integer;
	contact.customer		:= customer;
	contact.description		:= description;
	contact.topic			:= topic;
	contact.releaseOpened	:= release;
	contact.owner			:= owner;
	contact.openedTS		:= opened.TimeStamp;
	contact.myRoot			:= DEV_SupportRoot.firstInstance;
	contact.myTimezone		:= self.getTimezoneForCust(customer);
	
	state.type				:= "Active Support";
	state.startTS			:= opened.TimeStamp;
	state.myContact			:= contact;
	commitTransaction;
	
	self.unloadForm();
end;</source>
    </JadeMethod>
    <JadeMethod name="getTimezoneForCust" id="0bb49ba6-8ddc-471f-b6f4-96f9fe0b4b96">
        <source>getTimezoneForCust(_cust : String): DEV_SupportTimezone;

/*
Date			Who		Reason
05 August 2016	cnwar2	Initial creation

*/
vars
	root 		: DEV_SupportRoot;
	timezone 	: DEV_SupportTimezone;
	
begin
	root := DEV_SupportRoot.firstInstance;
	
	foreach timezone in root.allTimezones do
		if timezone.customers.pos(_cust,1) &gt; 0 then
			return timezone;
		endif;
	endforeach;
	
	return null;
	
end;</source>
        <Parameter name="_cust" type="String"/>
        <ReturnType type="DEV_SupportTimezone"/>
    </JadeMethod>
