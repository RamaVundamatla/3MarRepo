    <JadeMethod name="btnResourcesUsed_click" id="efe52616-c614-4ed0-8b8d-330afb73e514">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnResourcesUsed_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		24 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myCurrentVoyageData &lt;&gt; null then
		self.myAssistant.showVoyageResourceUsedForm(self.myCurrentVoyageData.myVoyage,  self.myMasterMenuAction,false);
	else
		self.myAssistant.showVoyageResourceUsedForm(null, self.myMasterMenuAction, false);
	endif;


end;</source>
