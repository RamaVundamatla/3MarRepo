    <JadeMethod name="setClonedRefsAndSEDAvg" id="1cef3106-b030-45b0-b2ca-c00289264e9e">
        <updating/>
        <source>setClonedRefsAndSEDAvg(_newId : String;
					 _realTI : CM_TrackedItem;
					 _cloneTrans : Boolean;
					 _sedMax, _sedMin, _sedMean, _vol : Decimal;
					 _tiUpdateCntrl : CMIF_TIUpdateController input;
					 _moveController : CMIF_MoveController input;
					 _passport : CM_Passport input) updating;
/* ---------------------------------------------------------------------------
Created:     11 August 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	if _realTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_realTI', null, null);
		return;
	endif;

	if (not self.isTransient) then
		self.beginUpdate(_tiUpdateCntrl, _passport);
	endif;
	
	if _newId &lt;&gt; null then
		self.changeIdInternal(_newId, false,_realTI.state, false, _passport); //cwnrd1 par 25075 ccms 1973 3.11.2010
	endif;

	self.cloneReferencesInternal(_realTI, _cloneTrans, false, false, _moveController, null, _realTI.myVoyage, _passport);

	self.setSEDsFromAveragesInternal(_sedMax, _sedMin, _sedMean, _vol, _tiUpdateCntrl, _passport);	

	if (not self.isTransient) then
		self.endUpdate(_tiUpdateCntrl, _passport);
	endif;
epilog

end;</source>
        <Parameter name="_newId" type="String"/>
        <Parameter name="_realTI" type="CM_TrackedItem"/>
        <Parameter name="_cloneTrans" type="Boolean"/>
        <Parameter name="_sedMax" type="Decimal"/>
        <Parameter name="_sedMin" type="Decimal"/>
        <Parameter name="_sedMean" type="Decimal"/>
        <Parameter name="_vol" type="Decimal"/>
        <Parameter name="_tiUpdateCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDocketCorrection" id="4a97213e-585a-4e9e-9743-09f39f5b28aa">
        <updating/>
        <source>setDocketCorrection( _bol : CM_BOLIn; _validationMode : Boolean; _tiUpdateCntrl : CMIF_TIUpdateController input; _isDocketCorrectionTransaction : Boolean output) : Boolean updating;
// ---------------------------------------------------------------------------------------------------------
// Created:     07 Jan 2008 by cnwvu1
//
// Purpose:     ccms1089. Docket Correction.
//				After BOL matching we can edit the Log Docket the same day still.
//				The Docket Correction includes the following fields: 
//					Supplier, Species, Grade, Log Type, Treatment, Length, Location.
//				The method returns the boolean parameter for the myProduct correction 
//					for the LOG's extension (CM_BOLExtLogIn class):
//				a) TRUE - we have to correct the myProduct fields
//					(myProduct - Species, Grade, Log Type, Treatment, Length) on the log from _bol.
//				b) FALSE - we shouldn't correct myProduct fields on the LOG. 
//					In the case when there are extra ProductChange (or SupplierChanged) transactions, i.e. 
//				the LOG has been regraded before, we should edit the history only - the first ProductChange 
//					(or Supplier Changed) transaction.
//					 
//				The method corrects the following:
//				1. The transaction Moved. If there are no extra Moved transactions, 
//					sets the field myPrimaryActualLocation on the Log.
//				2. The attribute Supplier and the transactions Operator Change. It automatically involves the 3.
//				3. The transaction Product Change (the fields Species, Grade, Log Type, Treatment, Length
//					will be changed in the previous method giving the boolean parameter = TRUE.
//
//				The Docket Correction transaction will be created.
//
//	Parameters:	_validationMode = true - only validation, database changes won't be done
// ----------------------------------------------------------------------------------------------------------

vars
	passport	: CM_Passport;
	warn		: CM_Error;
	warningExistsAlready : Boolean;
//	isDocketCorrectionTransaction : Boolean;
	transMoveFromRoadToLocation1: CM_Move;
	transMoveFromLocn1ToLocn2	: CM_TITransaction;
	thePreviousLocation,
	theNewLocation			: String;
	theFirstSupplierChangedTrans: CM_EditOperator;
	theFirstProductChangedTrans : CM_EditProductCode;
	theOldSupplier	: CM_Operator;
	theOldProduct	: CM_Product;
	theOldJasVolume,	
	theNewJasVolume	: Decimal[12,3];	//following the CM_TrackedItem::volume atribute
	theProductToBeChangedForTheLog,
	theProductHasBeenChanged,
	theSupplierHasBeenChanged : Boolean;
	
begin

	if not _bol.isKindOf( CM_BOLIn ) then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Docket Corrections. The class is not type of CM_BOLIn' );
		return false;
	endif;
	
	if not _bol.isMatchedTodayForDocketCorrect() then
		return false;
	endif;

	if self.allTransactions.size = 0 then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Docket Corrections. The are no transactions for the log' );
		return false;
	endif;

	theProductToBeChangedForTheLog	:= false;
	theProductHasBeenChanged		:= false;
	_isDocketCorrectionTransaction	:= false;

	if self.allTransactions.first.isKindOf( CM_Reassembly )		// there is a new log after disassembly - should be untouched by docket correction
	then	// there are no transactions - nothing for docket correction.
		_isDocketCorrectionTransaction := false;
		return false;		// Note. _isDocketCorrectionTransaction should be false;
	endif;
	
// ----------------------------------------------------------------------------------------------------------
// 												Changed Location
// ----------------------------------------------------------------------------------------------------------
	self.getTransMovedForDocketCorrect( transMoveFromRoadToLocation1, transMoveFromLocn1ToLocn2 );
	if 	(transMoveFromRoadToLocation1 = null and transMoveFromLocn1ToLocn2 = null) then	//Probably, the log can be created and still on Road. 25450 13/09/2010
		_isDocketCorrectionTransaction := false;	// When the log is not moved to a location fro some reason, the log doesn't apply to Docket Correction anyway.
		return false;		// Note. _isDocketCorrectionTransaction should be false;
	endif;
	
	thePreviousLocation := transMoveFromRoadToLocation1.targetLocn;
	theNewLocation		:= _bol.origTerminalAreaId &amp;' '&amp; _bol.origLocationControllerId;
	if thePreviousLocation &lt;&gt; theNewLocation then
		_isDocketCorrectionTransaction := true;
		self.setDocketCorrection_Location( _bol, transMoveFromRoadToLocation1, transMoveFromLocn1ToLocn2, _validationMode );	// _validationMode passed, as we need to validate each log. PAR 21514 Nov 2009
		if not _validationMode then
			self.docketCorrectionTransMoved(_bol, transMoveFromRoadToLocation1, transMoveFromLocn1ToLocn2 );
		endif;
	endif;

// ----------------------------------------------------------------------------------------------------------
// 									Changed Supplier and myProduct
// ----------------------------------------------------------------------------------------------------------

	theFirstSupplierChangedTrans:= self.getTransSupplierForDocketCorre();
	theFirstProductChangedTrans	:= self.getTransProductForDocketCorrec();
	// getting the old Supplier and Product from the old transactions
	self.getOldSupplierProductFromTrans( theFirstSupplierChangedTrans, theFirstProductChangedTrans, theOldSupplier, theOldProduct );

// Firstly, we have to find out whether the Supplier and the Product have been changed.
// If they have been changed, we have to setup CM_Log with the new Supplier or the Product if:
// 		Supplier: if there are no transactions: Supplier Changed and Product Changed.
// 		Product: if there are no transactions: Supplier Changed and Product Changed.

// ------------------------------------the Supplier has been changed ----------------------------------------
	if theOldSupplier = null then
		// theOldSupplier = null - there is no the Supplier Changed transaction having the oldest Operator
		theOldSupplier := self.myOperator;
	endif;
	if theOldSupplier &lt;&gt; _bol.myOperator then
		theSupplierHasBeenChanged := true;
		_isDocketCorrectionTransaction := true;	// Supplier has been changed on the _bol
		theProductHasBeenChanged := true;		// Changed Supplier changes the Product automatically
	endif;
	if theSupplierHasBeenChanged and theFirstSupplierChangedTrans = null and theFirstProductChangedTrans = null then
		// we have to set the new Supplier (and the Product later) for the log when there are no transactions: the Supplier Changed and the Product Changed.
		// Otherwise, we will correct the old Product in either the Supplier Changed or the Product Changed transaction later.
		if not _validationMode then
			self.setMyOperator( _bol.myOperator );
			theProductHasBeenChanged := true;	// we have to change the Product for the log as well when the Supplier has been changed
		endif;
	endif;
	
// ------------------------------------- if the Product has been changed ------------------------------------
	if theOldProduct = null then
		// theOldProduct = null - there are no transactions: the Product Changed and the Supplier Changed having the oldest Product
		theOldProduct := self.myProduct;
	endif;
	if theOldProduct &lt;&gt; _bol.myProduct then
		_isDocketCorrectionTransaction := true;	// Product has been changed on the _bol
		theProductHasBeenChanged := true;
		// preparing changed jasVolume and volume for the DocketCorrection transaction
		if not _validationMode then
			theOldJasVolume	:= global.calcJASVolume( self.sedMean, theOldProduct.CM_ProductLog.logLength );
			theNewJasVolume	:= global.calcJASVolume( self.sedMean, _bol.myProduct.CM_ProductLog.logLength );
		endif;
	endif;
	if (theSupplierHasBeenChanged or theProductHasBeenChanged) 
	and theFirstSupplierChangedTrans = null and theFirstProductChangedTrans = null then
		// we have to set the new Product for the log when there are no transactions: Supplier Changed and Product Changed.
		// Otherwise, we correct the old Product in either the Supplier Changed or the Product Changed transaction later.
		if not _validationMode then
			self.setMyProductAndExtension( _bol );
		endif;
		theProductToBeChangedForTheLog := true;	// we have to change the Product for the log later (this is change for the BOL)
	endif;
	
	
// ----------------------------------------------------------------------------------------------------------
// 				Correcting old transactions : either Supplier Changed or Product Changed 
// -----------------------------------------------------------------------------------------------------------
	if not _validationMode then
		if theSupplierHasBeenChanged or theProductHasBeenChanged then
			self.docketCorrectionTransOperProd(	_bol, theOldProduct, theNewJasVolume, theSupplierHasBeenChanged, theProductHasBeenChanged, theFirstSupplierChangedTrans, theFirstProductChangedTrans);
		endif;
	endif;

// ----------------------------------------------------------------------------------------------------------
//							Creating the Docket Correction transaction for the log
// -----------------------------------------------------------------------------------------------------------
	passport := app.myPassport;
	if _isDocketCorrectionTransaction then
		
		// special warning
		passport := app.myPassport;
		warningExistsAlready := false;	// We have to scheck whether it has been added from previous logs.
		foreach warn in passport.allErrorWarnings do
			if warn.errorCode = WARNING_Docket_Correction then
				warningExistsAlready := true;
				break;
			endif;
		endforeach;
		if not warningExistsAlready then
			app.raiseCMWarning(WARNING_Docket_Correction, null, null, self);
		endif;
		
		//transaction DocketCorrection
		if not _validationMode then
			self.docketCorrectionCreateTrans( 	_tiUpdateCntrl, 
												theSupplierHasBeenChanged,	theProductHasBeenChanged,
												thePreviousLocation,		theNewLocation, 
												theOldSupplier.code,		_bol.myOperator.code,
												theOldProduct.code, 		_bol.myProduct.code,
												theOldJasVolume.String,		theNewJasVolume.String );
		endif;

	endif;
	
	return theProductToBeChangedForTheLog;

epilog
	// to prevent for creating idle docketCorrection transactions
	_tiUpdateCntrl.isDocketCorrection := true;	// this is docketCorrection case. For all other transactions a new _tiUpdateCntrl will be created.

	
end;
</source>
        <Parameter name="_bol" type="CM_BOLIn"/>
        <Parameter name="_validationMode" type="Boolean"/>
        <Parameter name="_tiUpdateCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_isDocketCorrectionTransaction" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDocketCorrection_Location" id="7fbae905-a956-4820-87aa-0bdaca710de1">
        <updating/>
        <source>setDocketCorrection_Location( _bol : CM_BOLIn; _firstMoveTransaction: CM_Move; _secondMoveTransaction : CM_TITransaction; _validationMode : Boolean ) updating, protected;
// --------------------------------------------------------------------------------------------------------
// Created:     07 Lan 2008 by cnwvu1
//
// Purpose:     ccms1089. Docket Correction.
// 				If there are no extra transactions Moved, we have to correct the field myPrimaryActualLocation 
//				on the Log. When _secondMoveTransaction &lt;&gt; null, it means that the log has been transferred 
//				to a new location. in this case we shouldn't edit the myPrimaryActualLocation for the Log.
// ----------------------------------------------------------------------------------------------------------

vars
	locationNew,
	locationOld		: CM_LocationsController;
	
begin
	
	// when there is only one transaction Move, i.e. the log hasn't been transfered to
	// any new loaction, we should set the new location for the log
	if not ( _firstMoveTransaction &lt;&gt; null and _secondMoveTransaction = null ) then
		return;
	endif;

	//if self.allTransactions.last.isKindOf( CM_Disassembly )		// there is a new log after disassembly - should be untouched by docket correction
	if self.state = TI_STATE_DELETED // this rejected or disassembled log should be untouched by docket correction - there is a new active log after reassembly or reinstate reject #24462 09/07/2010
	then	// after rejecting / disassembling the myPrimaryActualLocation should  be untouched, i.e. null for this log
		return;		// Note. _isDocketCorrectionTransaction should be false;
	endif;
	
	// _bol has the new location while the log has an old one.
	locationOld := self.getPrimaryLocation( REAL_MODE );
	
	// -------------------------------------------------------------------------------
	//							setting myPrimaryActualLocation
	// -------------------------------------------------------------------------------
	if _bol.myTerminal = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'Docket Corrections. myTerminal is null for the log docket. Contact developer.', null, self);
		return;
	endif;
	
	
	locationNew := _bol.getLocationOriginal();
	
	if _validationMode then
		locationNew.CM_LogController.validateMoveForInspectFumigate(self);	// validate and raise warnings for Inspected / Fumigated status to be changed. PAR 21514 Nov 2009
		return;	// don't do changes when validation
	endif;

	//self.setMyPrimaryLocations( locationNew, null );	// it retrieves full ID - too full for a log. PAR 21514 Nov 2009
	self.myPrimaryActualLocation := locationNew;		// PAR 21514 Nov 2009
	self.locationId := locationNew.getFullIdForTIForMode(REAL_MODE);	// Short location Id for a log. PAR 21514 Nov 2009
	
	// -------------------------------------------------------------------------------
	//							setting ti.allLocations
	// -------------------------------------------------------------------------------
	if self.allLocations.includes( locationOld ) then
		self.allLocations.remove( locationOld );
	endif;
	if not self.allLocations.includes( locationNew ) then
		self.allLocations.add( locationNew );
	endif;

	self.setInspectedFumigated(locationNew.CM_LogController, app.myPassport);	// need to manage Inspected / Fumigate status for the log anf for the log row. PAR 21514 Nov 2009
	
end;
</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOLIn"/>
        <Parameter name="_firstMoveTransaction" type="CM_Move"/>
        <Parameter name="_secondMoveTransaction" type="CM_TITransaction"/>
        <Parameter name="_validationMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateSubClasses" id="be3a6f28-f558-4146-9be7-ddd579c17fac">
        <updating/>
        <source>setForCreateSubClasses(_ti: CM_Log; _passport : CM_Passport input) updating, protected;
// -----------------------------------------------------------------------------
// Created:		09 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.gradeCode 		:= _ti.gradeCode;
	self.lengthCode		:= _ti.lengthCode;
	self.scalerCode		:= _ti.scalerCode;
	self.sedMax 		:= _ti.sedMax;
	self.sedMin 		:= _ti.sedMin;
	self.speciesCode 	:= _ti.speciesCode;
	self.treatmentCode	:= _ti.treatmentCode;
	self.typeCode 		:= _ti.typeCode;
	self.conditionCode 	:= _ti.conditionCode;
	self.fellDate		:= _ti.fellDate;

	self.setMyTerminalIfUnscaled();
	
	inheritMethod(_ti, _passport);

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_Log"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUnscaledLog" id="be3c653b-18dd-4a08-9a43-e82e7444054c">
        <updating/>
        <source>setForUnscaledLog(_seds : Real; _conditionCode, _newId : String) updating, protected;
// -----------------------------------------------------------------------------
// Created:		09 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.changeIdInternal(_newId, false,self.state, false, null); //cwnrd1 par 25075 ccms 1973 3.11.2010
	self.sedMax 		:= _seds;
	self.sedMin 		:= _seds;
	self.conditionCode 	:=_conditionCode;

	self.setMyTerminalIfUnscaled();
	
end;</source>
        <access>protected</access>
        <Parameter name="_seds" type="Real"/>
        <Parameter name="_conditionCode" type="String"/>
        <Parameter name="_newId" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateActual" id="53c80f34-79e9-4154-87b5-ae928cd805e6">
        <updating/>
        <source>setForUpdateActual(_pxyTI: CM_Log; _tiUpdateCntrlr : CMIF_TIUpdateController input; _passport : CM_Passport input) updating, protected;
//--------------------------------------------------------------
//Created: 04 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	origSedMin,
	origSedMax	: Decimal[6,2];
begin

	origSedMax := self.sedMax;
	origSedMin := self.sedMin;
	
	self.conditionCode	:= _pxyTI.conditionCode;
	self.fellDate		:= _pxyTI.fellDate;
	self.gradeCode 		:= _pxyTI.gradeCode;
	self.lengthCode		:= _pxyTI.lengthCode;
	self.scalerCode		:= _pxyTI.scalerCode;
	self.sedMax 		:= _pxyTI.sedMax;
	self.sedMin 		:= _pxyTI.sedMin;
	self.speciesCode 	:= _pxyTI.speciesCode;
	self.treatmentCode	:= _pxyTI.treatmentCode;
	self.typeCode 		:= _pxyTI.typeCode;
	
	//CCMS 1024
	//see if we need to update all averaged logs on same docket as this one.
	if self.site = TI_SITE_ONSITE and (not self.isAverageScaled) then
		if self.sedMax &lt;&gt; origSedMax or
		   self.sedMin &lt;&gt; origSedMin then
		   	//We need to update the averages as well
		   	if self.myReceivalBOL &lt;&gt; null then
			   	self.myReceivalBOL.myExtension.updateSEDAverages(_passport);
			endif;
		endif;
	endif;

	inheritMethod(_pxyTI, _tiUpdateCntrlr, _passport);
	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyTI" type="CM_Log"/>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromBOLInForSubClasses" id="7f87f736-c4db-4bed-8d0f-2a9333f25f0e">
        <updating/>
        <source>setFromBOLInForSubClasses(_bol : CM_BOLIn; _tiUpdateCntrl : CMIF_TIUpdateController input ) updating, protected;
//--------------------------------------------------------------
//Created: 04 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ext	: CM_BOLExtLog;
	isDocketCorrection : Boolean;
	logWeight : Decimal[14,4];
begin

	inheritMethod( _bol, _tiUpdateCntrl );

	if (not self.isUnscaled) and self.myReceivalBOL &lt;&gt; _bol then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_ALREADY_ATTACHED, 'Docket No.' &amp; self.myReceivalBOL.number, 'has Log ' &amp; self.id, null, null);		
		return;
	endif;

	if _bol.myExtension.isKindOf(CM_BOLExtLog) then
		ext := _bol.myExtension.CM_BOLExtLog;
	endif;

	if (not _bol.isMatched) 
	or self.setDocketCorrection( _bol, false, _tiUpdateCntrl, isDocketCorrection )	//ccms1089. Docket Correction. If it isMatchedTodayForDocketCorrect(), we can edit the product still. cnwvu1, Feb 2008
	then
		if not _bol.isMatchedTodayForDocketCorrect() then	//ccms1089. Docket Correction. When isMatchedTodayForDocketCorrect(), the product has already been changed in the setDocketCorrection(). cnwvu1, Feb 2008

			self.setMyProductAndExtension( _bol );

		endif;
	else
		if ext &lt;&gt; null then
			self.fellDate		:= ext.fellDate;
		endif;
	endif;
	
	/*if self.totalWeight = 0 and self.myReceivalBOL &lt;&gt; null then				//+cnwml2 PAR24316
		logWeight := self.myReceivalBOL.weightNet / self.myReceivalBOL.numItems;
		self.totalWeight := logWeight.roundedTo(0);
		self.weight := logWeight.roundedTo(0);					//+cnwml2 PAR24683
	endif;*/

end;</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOLIn"/>
        <Parameter name="_tiUpdateCntrl" type="CMIF_TIUpdateController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromBOLInLogScaleDtl" id="74bfb170-f71d-4d22-a1bc-f8b79bcbe46c">
        <updating/>
        <source>setFromBOLInLogScaleDtl(_bolIn : CM_BOLIn input;
						_logScalingDtl : CM_LogScalingDtl;
						_realLog : CM_Log;
						_tiUpdateCntrl : CMIF_TIUpdateController input;
						_moveController : CMIF_MoveController input;
						_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	numFound,
	saveTransType : Integer;
	
begin
	if _logScalingDtl = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, "No _logScalingDtl passed in", null, null);
		return;		
	endif;	
	
	exclusiveLock(self);
		
	//change the id first
	if self.id &lt;&gt; _logScalingDtl.logID then
		self.changeIdInternal(_logScalingDtl.logID, false,self.state, false, _passport); //cwnrd1 par 25075 ccms 1973 3.11.2010
	endif;
	
	if _realLog &lt;&gt; null then
		self.cloneReferencesInternal(_realLog, false, false, false, _moveController, null, _realLog.myVoyage, _passport);
	endif;
	
	if _bolIn &lt;&gt; null then
		self.setFromBOLInInternal(_bolIn, true, _tiUpdateCntrl, _passport);
	endif;

	if (not self.isTransient) then
		self.beginUpdate(_tiUpdateCntrl, _passport);
	endif;	

	self.sedMin 		:= _logScalingDtl.minSED;	
	self.sedMax 		:= _logScalingDtl.maxSED;
	self.conditionCode 	:= _logScalingDtl.conditionCode;
	
	if _logScalingDtl.scalerCode &lt;&gt; null then
		self.scalerCode		:= _logScalingDtl.scalerCode;
	elseif _bolIn &lt;&gt; null and _bolIn.myExtension &lt;&gt; null and
		_bolIn.myExtension.isKindOf(CM_BOLExtLogIn) then
		self.scalerCode		:= _bolIn.myExtension.CM_BOLExtLogIn.scalerCode;
	endif;
	
// cnwdad1 08/06/2009 - CCMS 1735/PAR 19815.
	if app.isSubTerminalsOn(self.myTerminal) then
		self.setSubTerminalDefaultFromTerm(self.myTerminal);
	endif;
	
	self.isAverageScaled := false;

	if (not self.isTransient) then
		self.endUpdate(_tiUpdateCntrl, _passport);
	endif;
end;</source>
        <Parameter name="_bolIn" type="CM_BOLIn" usage="input"/>
        <Parameter name="_logScalingDtl" type="CM_LogScalingDtl"/>
        <Parameter name="_realLog" type="CM_Log"/>
        <Parameter name="_tiUpdateCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromBOLInWithSEDAvg" id="163e133e-3de6-4090-9578-457ea5f170c4">
        <updating/>
        <source>setFromBOLInWithSEDAvg(_bol : CM_BOLIn input; _sedMax, _sedMin, _sedMean, _vol : Decimal;
		_tiUpdateCntrl : CMIF_TIUpdateController input; _passport : CM_Passport input) updating;
/* ---------------------------------------------------------------------------
Created:     11 August 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.beginUpdate(_tiUpdateCntrl, _passport);

	self.setFromBOLInInternal(_bol, (not _bol.isMatched), _tiUpdateCntrl, _passport);	

	self.setSEDsFromAveragesInternal(_sedMax, _sedMin, _sedMean, _vol, _tiUpdateCntrl, _passport);	

	self.endUpdate(_tiUpdateCntrl, _passport);

epilog

end;</source>
        <Parameter name="_bol" type="CM_BOLIn" usage="input"/>
        <Parameter name="_sedMax" type="Decimal"/>
        <Parameter name="_sedMin" type="Decimal"/>
        <Parameter name="_sedMean" type="Decimal"/>
        <Parameter name="_vol" type="Decimal"/>
        <Parameter name="_tiUpdateCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromBOLOut" id="fe35b682-9170-44c0-a379-1a68f95138aa">
        <updating/>
        <source>setFromBOLOut(_bolOut: CM_BOLOut; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 19 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	extension : CM_BOLExtLog;
begin

	inheritMethod(_bolOut, _passport);

	extension := _bolOut.myExtension.CM_BOLExtLog;

	self.gradeCode 		:= extension.logGradeCode;
	self.speciesCode 	:= extension.logSpeciesCode;
	self.typeCode 		:= extension.logTypeCode;
	self.treatmentCode	:= extension.logTreatmentCode;
	self.lengthCode		:= extension.lengthCode;
	
	self.setMyVoyage(_bolOut.myVoyage, _passport);
	
end;</source>
        <Parameter name="_bolOut" type="CM_BOLOut"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIFDisassembly" id="f99fe749-f585-46c8-a256-0500397bcc00">
        <updating/>
        <source>setFromCMIFDisassembly(_proxyNewLog : CMIF_LogRegrade; _oldLog : CM_Log; 
				_tiUpdateCntrl : CMIF_TIUpdateController input;
				_moveController : CMIF_MoveController input;
				_passport : CM_Passport input) updating;

vars

begin
	
	//As this is a clone set the id and references before beginUpdate
	self.changeIdInternal(_proxyNewLog.id, false,self.state, false, _passport); //cwnrd1 par 25075 ccms 1973 3.11.2010
	if _passport.hasErrors then
		return;
	endif;
	self.cloneReferencesInternal(_oldLog, false, true, false,_moveController, null, _oldLog.myVoyage,_passport);
	
	if (not self.isTransient) then
		self.beginUpdate(_tiUpdateCntrl, _passport);
	endif;

	self.gradeCode 		:= _proxyNewLog.gradeCode;
	self.lengthCode 	:= _proxyNewLog.length;
	self.typeCode		:= _proxyNewLog.type;
	self.treatmentCode	:= _proxyNewLog.treatment;
	self.sedMin 		:= _proxyNewLog.sedMin;
	self.sedMax 		:= _proxyNewLog.sedMax;
//	self.weight			:= _proxyNewLog.weight;				//-cnwml2 MSL CCMS 1017
	self.totalWeight 	:= _proxyNewLog.weight;				//+cnwml2 MSL CCMS 1017

	self.setProductCode(_passport);

	if (not self.isTransient) then
		self.endUpdate(_tiUpdateCntrl, _passport);
	endif;	

end;</source>
        <Parameter name="_proxyNewLog" type="CMIF_LogRegrade"/>
        <Parameter name="_oldLog" type="CM_Log"/>
        <Parameter name="_tiUpdateCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_Regrade" id="479f306c-a2b0-47cf-86b7-b3bc298fc459">
        <updating/>
        <source>setFromCMIF_Regrade(_logRegrade : CMIF_LogRegrade; _tiUpdateCntrlr : CMIF_TIUpdateController input;
					_passport : CM_Passport input) updating;

vars
	
begin
	
	if (not self.isTransient) then
		self.beginUpdate(_tiUpdateCntrlr, _passport);
	endif;
	
	/*if _logRegrade.consignorCode &lt;&gt; null then	commented by ccms 1116, #26786 27/01/2011
		self.consignor		:= _logRegrade.consignorCode;
	endif;*/
	
	self.myOperator		:= _logRegrade.myOperator;
	self.operatorCode 	:= _logRegrade.myOperator.code;
	self.gradeCode 		:= _logRegrade.gradeCode;
	self.speciesCode 	:= _logRegrade.species;
	self.treatmentCode 	:= _logRegrade.treatment;
	self.typeCode 		:= _logRegrade.type;
	self.lengthCode 	:= _logRegrade.length;
	
	if _logRegrade.isLogId then
		if (self.sedMin &lt;&gt; _logRegrade.sedMin) or (self.sedMax &lt;&gt; _logRegrade.sedMax) then
			self.sedMin := _logRegrade.sedMin;
			self.sedMax := _logRegrade.sedMax;
			if self.myReceivalBOL &lt;&gt; null then
				if (not self.isTransient) then	//we don't need to upgrade real averaged logs in validation step. #24110	26/05/2010
					self.myReceivalBOL.myExtension.updateSEDAverages(_passport);	//#24110	26/05/2010
				endif;
			endif;
		endif;
	endif;
	
	self.myProduct := _logRegrade.myProduct;
	//self.setProductCode(_passport);

	self.changeState(self.state, _passport);

	if (not self.isTransient) then	
		self.endUpdate(_tiUpdateCntrlr, _passport);
	endif;
	
end;</source>
        <Parameter name="_logRegrade" type="CMIF_LogRegrade"/>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromRegradeExt" id="1505c570-1bd1-4ccc-8c87-3a7f6cbf7231">
        <updating/>
        <source>setFromRegradeExt(_regradeRemoteExtra : CM_RemoteRegradingExtra; _tiUpdateCntrlr : CMIF_TIUpdateController input; _passport : CM_Passport input) : Boolean updating;

// cnwdvb1 31 March 2003 

vars

	regradeRemoteDetail : CM_RemoteRegradingDtlExt;
	operator			: CM_Operator;

begin

	regradeRemoteDetail := _regradeRemoteExtra.myRemoteDataDtl.CM_RemoteRegradingDtlExt;

	operator := app.myRoot.allOperators[regradeRemoteDetail.supplier];
	if operator = null then
		app.raiseCMWarning1(Err_InvalidSupplier, regradeRemoteDetail.supplier &amp; ' for ' &amp; _regradeRemoteExtra.itemId, null, null, self);
		return false;
	endif;
	
	if (not self.isTransient) then
		self.beginUpdate(_tiUpdateCntrlr, _passport);
	endif;

	if _regradeRemoteExtra.newItemId &lt;&gt; null then
		self.changeIdInternal(_regradeRemoteExtra.newItemId, false, self.state, false, _passport); //cwnrd1 par 25075 ccms 1973 3.11.2010
	endif;
	self.myOperator		:= operator;
	self.operatorCode 	:= regradeRemoteDetail.supplier;
	self.gradeCode 		:= regradeRemoteDetail.grade;
	self.speciesCode 	:= regradeRemoteDetail.species;
	self.treatmentCode 	:= regradeRemoteDetail.treatment;
	self.typeCode 		:= regradeRemoteDetail.type;
	self.lengthCode 	:= regradeRemoteDetail.length;
	
	self.sedMin := _regradeRemoteExtra.sedMin;
	self.sedMax := _regradeRemoteExtra.sedMax;
	
	self.setProductCode(_passport);
	self.changeState(self.state, _passport);

	if (not self.isTransient) then	
		self.endUpdate(_tiUpdateCntrlr, _passport);
	endif;
	return true;
end;</source>
        <Parameter name="_regradeRemoteExtra" type="CM_RemoteRegradingExtra"/>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setInspectedFumigated" id="0f879701-0af9-4d98-ba03-20ed87b08c29">
        <updating/>
        <source>setInspectedFumigated(_logRowTo : CM_LogController input; _passport : CM_Passport input) updating;
/* ---------------------------------------------------------------------------
Created:	02 November 2009	by cnwvu1

Purpose:	PAR 21514 - need manage Inspected / Fumigated from Docket Correction, too.
			Logic here is organized in one method for both when moving a log 
			and when Docket Correction.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpSetIsFumigated,
	tmpSetIsInspected	: Boolean;
	infoStr			: String;
	tmpEditTrans	: CM_Edit;

begin

	if (not self.getIsInspected) and _logRowTo.isInspected then
		// if log being transferred from non-inspected row, change new row to non-inspected
		tmpSetIsInspected := true;
	elseif self.getIsInspected and (not _logRowTo.isInspected) then
		self.setNotInspected(tmpEditTrans, _passport);
	endif;
	if (not self.getIsFumigated) and _logRowTo.isFumigated then
		// if log being transferred from non-fumigated row, change new row to non-fumigated
		tmpSetIsFumigated := true;
	elseif self.getIsFumigated and (not _logRowTo.isFumigated) then
		self.setNotFumigated(tmpEditTrans, _passport);
	endif;
	if tmpSetIsInspected or tmpSetIsFumigated then
		// Flags need to be changed so
		if tmpSetIsInspected then
			_logRowTo.setIsInspected(false);
			infoStr := 'NOT inspected'; 
		endif;
		if tmpSetIsFumigated then
			_logRowTo.setIsFumigated(false);
			if infoStr = null then
				infoStr := 'NOT fumigated'; 
			else
				infoStr := infoStr &amp; ', NOT fumigated'; 
			endif;
		endif;
		infoStr := 'Row updated to ' &amp; infoStr &amp; ' as a result of move in of ' &amp; self.id;
		_logRowTo.setLogsInspectedFumigated(_logRowTo.isInspected, _logRowTo.isFumigated);
		_logRowTo.createAuditObjectInformation(infoStr);
	endif;


end;</source>
        <Parameter name="_logRowTo" type="CM_LogController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setLogUnscaledNoNumber" id="73910689-8062-4e00-a2b3-2afe615dc3eb">
        <updating/>
        <source>setLogUnscaledNoNumber(_theBOL : CM_BOL input; _seds : Decimal;
					  _conditionCode, _newId : String;
					  _realLog : CM_Log;
					  _tiUpdateCntrl : CMIF_TIUpdateController input;
					  _moveController : CMIF_MoveController input;
					  _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 04 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	if _newId &lt;&gt; null then
		self.changeIdInternal(_newId, false,self.state, false, _passport); //cwnrd1 par 25075 ccms 1973 3.11.2010
	endif;
		
	if _theBOL &lt;&gt; null then
		if _theBOL.isKindOf(CM_BOLIn) then
			self.setFromBOLInInternal(_theBOL.CM_BOLIn, true, _tiUpdateCntrl, _passport);
		elseif _theBOL.isKindOf(CM_BOLOut) then
			self.state := TI_STATE_NORMAL;
			self.setFromBOLOut(_theBOL.CM_BOLOut, _passport);
		endif;
		
// cnwdad1 09/10/2009 - PAR #21118.
		if app.isSubTerminalsOn(_theBOL.myTerminal) then
			self.setSubTerminal(_theBOL.mySubTerminal,null);
		endif;
	endif;
	
	if _realLog &lt;&gt; null then
		self.cloneReferencesInternal(_realLog, false, false, false, _moveController, null, _realLog.myVoyage,_passport);
	endif;

	if (not self.isTransient) then
		self.beginUpdate(_tiUpdateCntrl, _passport);
	endif;
	
	self.sedMin 		:= _seds;
	self.sedMax 		:= _seds;
	self.sedMean		:= _seds;
	self.conditionCode 	:=_conditionCode;

	if (not self.isTransient) then
		self.endUpdate(_tiUpdateCntrl, _passport);
	endif;	
end;</source>
        <Parameter name="_theBOL" type="CM_BOL" usage="input"/>
        <Parameter name="_seds" type="Decimal"/>
        <Parameter name="_conditionCode" type="String"/>
        <Parameter name="_newId" type="String"/>
        <Parameter name="_realLog" type="CM_Log"/>
        <Parameter name="_tiUpdateCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
