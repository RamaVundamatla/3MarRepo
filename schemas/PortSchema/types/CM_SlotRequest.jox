    <JadeMethod name="getAttrOperator" id="6eed481a-2841-4aeb-981e-3fdf1203c429">
        <source>getAttrOperator():CM_Operator;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars
	criteria : CM_YACriteria;
	reserveDetail : CM_ReserveDetail;
begin
	
	if self.useVoyageAllocations  then 
		criteria := self.getAttrByType(YACriteriaType_OperatorItem);
		if criteria &lt;&gt; null then
			return criteria.myYAData.CM_YADataObjects.allObjects.first().CM_Operator;			
		endif;
	else
		reserveDetail := self.getBulkReleaseReserveDetail();
		if reserveDetail &lt;&gt; null then
			return reserveDetail.getOperator();
		endif;
	endif;
	
	return null;
	
epilog

end;</source>
