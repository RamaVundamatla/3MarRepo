vars
	obj				: Object;
	cargoBOLType	: CM_CargoBOLType;
	
begin
	obj := self.cmbAvGrade.myObject;
	self.myAssistant.GTE_Assistant.mainExtraSetValueByControl(tblMain, tblExtra, combobox.name, combobox.text);
	self.cmbAvGrade.setObjectAndOperator(obj, combobox.listObject.CM_Operator, null);
	self.myAssistant.GTE_Assistant.mainExtraSetValueByControl(tblMain, tblExtra, 	self.cmbAvGrade.name, 	self.cmbAvGrade.text);	
	self.myAssistant.GTE_Assistant.mainExtraSetValueByControl(tblMain, tblExtra, combobox.name, combobox.text);
	
	//par 17383 cnwjo3
	cargoBOLType := self.cmbTiType.listObject.CM_CargoBOLType;
	if cargoBOLType.isKindOf(CM_CargoType) then
		self.cmbProduct.setCargoType(cargoBOLType.CM_CargoType);
		self.cmbProduct.setOperator(combobox.listObject.CM_Operator);
		self.cmbProduct.setObject(self.cmbProduct.listObject.CM_Product);
	endif;
	/*self.cmbProduct.setCargoType(self.cmbTiType.listObject.CM_CargoType);		// 28/08/2009 cnwar2 #20546 - replaced with above
	self.cmbProduct.setOperator(combobox.listObject.CM_Operator);
	self.cmbProduct.setObject(self.cmbProduct.listObject.CM_Product);*/
end;</source>
