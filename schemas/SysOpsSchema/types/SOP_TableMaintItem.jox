    <JadeMethod name="setupContextMenuItems" id="02c2f936-020d-4441-9d52-5fd95b81c8eb">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
// 06/05/2010 cnwcs5	par 23801 - new menu items. Also used local variable for self.myForm
vars
	index			: Integer;
	clonedMenuItems	: Integer;
	clonedMenuItem	: MenuItem;
	masterMenuItem,
	sourceMenuItem	: MenuItem;
	invalidObject	: Boolean;
	form			: SOP_TableMaintForm;	// par 23801
begin
	form := self.myForm;	// par 23801
	
	form.mnuContext1.visible 	:= false;
	form.mnuContext2.visible 	:= false;
	form.mnuContext3.visible 	:= false;
	form.mnuContext4.visible 	:= false;
	form.mnuContext5.visible 	:= false;
	form.mnuContext6.visible	:= false;	// par 23801
	form.mnuContext7.visible	:= false;	// par 23801
	form.mnuSwipe.visible		:= false;
	form.mnuSwipeSub.visible	:= false;
	form.mnuExtractHistory.visible	:= false;	// par 23801 
	form.mnuAdd.visible 		:= false;				//+cnwml2 PAR23715 SFW CCMS1131
	form.mnuAdhocCams.visible	:=false;
	//epr par 14456 10/7/08 reset all cloned menus 
	index := 100; //not sure why but cloned menu items start at 100 
	clonedMenuItems:=form.getClonedMenuCount();
	//if the previous table item was RFID Tag
	masterMenuItem	:= form.mnuSwipe.description.asOid.MenuItem;
	on Exception do app.handleDeletedObject(exception,masterMenuItem,invalidObject);
	if masterMenuItem &lt;&gt; null and not invalidObject then
		while clonedMenuItems &gt;= index do
			clonedMenuItem	:= masterMenuItem.getMenuItem(clonedMenuItems);
			clonedMenuItems	:= clonedMenuItems - 1;
			if clonedMenuItem &lt;&gt; null then
				if clonedMenuItem.userObject.isKindOf(CM_RFIDTagReader) then
					delete clonedMenuItem;
					form.setClonedMenuCount(clonedMenuItems);
				endif;
			endif;
			
		endwhile;
		form.mnuSwipeSub.description:=null;
	endif;
	
	form.doDeleteClonedMenuFromSource(form.mnuContext1);
	form.doDeleteClonedMenuFromSource(form.mnuContext2);
	form.doDeleteClonedMenuFromSource(form.mnuContext3);
	form.doDeleteClonedMenuFromSource(form.mnuContext4);
	form.doDeleteClonedMenuFromSource(form.mnuContext5);
	form.doDeleteClonedMenuFromSource(form.mnuContext6);	// par 23801 
	form.doDeleteClonedMenuFromSource(form.mnuContext7);	// par 23801 
	form.doDeleteClonedMenuFromSource(form.mnuSwipe);
	form.doDeleteClonedMenuFromSource(form.mnuSwipeSub);
	form.doDeleteClonedMenuFromSource(form.mnuPrintHistory);
	form.doDeleteClonedMenuFromSource(form.mnuExtractHistory);	// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814
	form.doDeleteClonedMenuFromSource(form.mnuAdd);				//+cnwml2 PAR23715 SFW CCMS1131
	form.doDeleteClonedMenuFromSource(form.mnuAdhocCams);
	if invalidObject then
		form.mnuSwipe.description:=null;
	endif;
	
end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupMultiSelect1" id="22e3bac9-d7d9-4b2c-8745-65c0df5775cd">
