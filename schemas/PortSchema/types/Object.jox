    <JadeMethod name="systemToLocalTime" id="3f084686-d3c2-40e7-96a4-5c67b5d85b59">
        <source>systemToLocalTime(_timeStamp : TimeStamp) : TimeStamp;
/*

Purpose:			Convert the passed in system time to the equivalent time for 
					the receiver object's Terminal TimeZone

Parameters:			System TimeStamp to convert

Return Value:		Equivalent local TemeStamp

Date		Who		Reason
11 Mar 2016	cnwkpd1	TFS 488 - Multi Timezone Support

*/

vars

begin
	return _timeStamp.systemToLocalTimeUsingObject(self);
	
epilog

end;</source>
