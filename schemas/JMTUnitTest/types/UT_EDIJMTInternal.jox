    <JadeMethod name="tBOLAction" id="5ebff3ba-7183-475b-ac93-c09c4ac9b620">
        <source>tBOLAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalBOL";
	BOL_ID : String = "BOL_ID1";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	bol : CM_BOL;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	self.deleteBOL(BOL_ID, null);
	bol := self.getBOL(BOL_ID, 5003, "MSK");
	self.assertIsDeleted(bol);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalBOL xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalBOL.xsd"&gt;
	&lt;AllBOLHeader&gt;
		&lt;BOLHeader&gt;
			&lt;bolType&gt;5003&lt;/bolType&gt;
			&lt;numItems/&gt;
			&lt;carrierCode/&gt;
			&lt;description/&gt;
			&lt;destinationPort/&gt;
			&lt;dischargePort/&gt;
			&lt;fullOrMT/&gt;
			&lt;id&gt;'&amp;BOL_ID&amp;'&lt;/id&gt;
			&lt;loadPort/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;notifyParty/&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;remarks&gt;&lt;/remarks&gt;
			&lt;subTerminalCode/&gt;
			&lt;transportMode/&gt;
			&lt;voyageCode/&gt;
			&lt;clientRef1/&gt;
			&lt;clientRef2/&gt;
			&lt;vehicle/&gt;
			&lt;AllBOLDetails&gt;
				&lt;BOLDetails&gt;
					&lt;height/&gt;
					&lt;length/&gt;
					&lt;volume/&gt;
					&lt;weight/&gt;
					&lt;width/&gt;
					&lt;quantity/&gt;
					&lt;cargoTypeDescr/&gt;
					&lt;colour/&gt;
					&lt;commodity/&gt;
					&lt;consignee/&gt;
					&lt;consignor/&gt;
					&lt;description/&gt;
					&lt;dtlDescription/&gt;
					&lt;fullOrMT/&gt;
					&lt;id/&gt;
					&lt;mark/&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;remarks/&gt;
				&lt;/BOLDetails&gt;
			&lt;/AllBOLDetails&gt;
		&lt;/BOLHeader&gt;
	&lt;/AllBOLHeader&gt;
&lt;/JMTInternalBOL&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 2, "incorrect number of EDI trackedItems");
	bol := self.getBOL(BOL_ID, 5003, "MSK");
	self.assertNotNull(bol);
	self.assertEqualMsg(bol.remarks.trimBlanks, "Created by unit test UT_EDIJMTInternal::tBOLAction", "wrong remarks");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tBOLOutLogAction" id="49656b6f-c70b-4352-89a8-9d42d0180bb9">
        <source>tBOLOutLogAction();
//
//28 July 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalBOLOutLog";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj	:=	app.myPassport;
	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalBOLOutLog&gt;
	&lt;AllDataBOLOutLog&gt;
		&lt;DataBOLOutLog&gt;
			&lt;operatorCode&gt;C3&lt;/operatorCode&gt;
			&lt;AllItemDetails&gt;
			&lt;ItemDetails&gt;
				&lt;isAveraged&gt;true&lt;/isAveraged&gt;
				&lt;loadDate/&gt;
				&lt;logLength&gt;3.6&lt;/logLength&gt;
				&lt;hatch&gt;6&lt;/hatch&gt;
				&lt;place&gt;2&lt;/place&gt;
				&lt;jasVolume/&gt;
				&lt;cargoTypeDescr/&gt;
				&lt;description/&gt;
				&lt;fullOrMT/&gt;
				&lt;id&gt;EH4&lt;/id&gt;
				&lt;loadPortCode/&gt;
				&lt;logGradeCode&gt;G2&lt;/logGradeCode&gt;
				&lt;logLengthCode&gt;3.6&lt;/logLengthCode&gt;
				&lt;logSpeciesCode&gt;BIR&lt;/logSpeciesCode&gt;
				&lt;logTreatmentCode&gt;BO&lt;/logTreatmentCode&gt;
				&lt;logTypeCode&gt;BIN&lt;/logTypeCode&gt;
				&lt;lotNo&gt;DAX&lt;/lotNo&gt;
				&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;operatorCode&gt;FF&lt;/operatorCode&gt;
				&lt;productCode&gt;BIR:G2:BON:BO:3.6&lt;/productCode&gt;
				&lt;voyageGlobalCode&gt;06018&lt;/voyageGlobalCode&gt;
				&lt;loadTime/&gt;
				&lt;/ItemDetails&gt;
			&lt;/AllItemDetails&gt;
		&lt;/DataBOLOutLog&gt;
	&lt;/AllDataBOLOutLog&gt;
&lt;/JMTInternalBOLOutLog&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;

	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tBayPlan" id="aca16299-266e-40e9-a385-2dc077a67fe5">
        <source>tBayPlan();
//
//10 Nov 2014	cnwrs1	Par 34702 - Add support for JMT XML
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	VoyageName		= 'PAR28390';
	BoatName		= 'PAR28390Boat';
	TestOperator	= 'MSK';
	USER_DEF_NAME : String = "JMTInternalBayPlan";
vars
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	operator : CM_Operator;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	tempStr : String;
	ti : CM_TrackedItem;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	operator := self.getOperator(TestOperator);
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	// now set up cleanly
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	voyage := self.addVoyageWithContainerStructur(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	self.assertNotNullMsg(vessel, tempStr);

	passportObj	:=	app.myPassport;
	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalBayPlan xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalBayPlan.xsd"&gt;
	&lt;AllDataBayPlan&gt;
		&lt;DataBayPlan&gt;
			&lt;operatorCode&gt;FES&lt;/operatorCode&gt;
			&lt;fromPort&gt;AUMEL&lt;/fromPort&gt;
			&lt;shipperCode&gt;FES&lt;/shipperCode&gt;
			&lt;toPort&gt;MSK&lt;/toPort&gt;
			&lt;vesselName&gt;'&amp;BoatName&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
			&lt;AllBayPlan&gt;
				&lt;BayPlan&gt;
					&lt;vent&gt;-1.0000&lt;/vent&gt;
					&lt;weight&gt;21000.0000&lt;/weight&gt;
					&lt;carbonDioxide&gt;-1&lt;/carbonDioxide&gt;
					&lt;humidity&gt;-1&lt;/humidity&gt;
					&lt;oxygen&gt;-1&lt;/oxygen&gt;
					&lt;temperature&gt;-273&lt;/temperature&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;commodity&gt;WINE&lt;/commodity&gt;
					&lt;commodityDescription&gt;WINE&lt;/commodityDescription&gt;
					&lt;destinationPort&gt;CNAKL&lt;/destinationPort&gt;
					&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
			&lt;dischargePorts&gt;SGSIN AUBRI AUSYD&lt;/dischargePorts&gt;
					&lt;ediTranshipPort&gt;CNAKL&lt;/ediTranshipPort&gt;
					&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
					&lt;id&gt;PAR2839011&lt;/id&gt;
					&lt;isoType&gt;2210&lt;/isoType&gt;
					&lt;loadPort&gt;AUMEL&lt;/loadPort&gt;
					&lt;locationId&gt;0010682&lt;/locationId&gt;
					&lt;messageMode&gt;U&lt;/messageMode&gt;
					&lt;operatorCode&gt;CPS&lt;/operatorCode&gt;
				&lt;/BayPlan&gt;
				&lt;BayPlan&gt;
					&lt;vent&gt;-1.0000&lt;/vent&gt;
					&lt;weight&gt;21000.0000&lt;/weight&gt;
					&lt;carbonDioxide&gt;-1&lt;/carbonDioxide&gt;
					&lt;humidity&gt;-1&lt;/humidity&gt;
					&lt;oxygen&gt;-1&lt;/oxygen&gt;
					&lt;temperature&gt;-273&lt;/temperature&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;commodity&gt;WINE&lt;/commodity&gt;
					&lt;commodityDescription&gt;WINE&lt;/commodityDescription&gt;
					&lt;destinationPort&gt;CNAKL&lt;/destinationPort&gt;
					&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
					&lt;ediTranshipPort&gt;CNAKL&lt;/ediTranshipPort&gt;
					&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
					&lt;id&gt;XNR60001922&lt;/id&gt;
					&lt;isoType&gt;2210&lt;/isoType&gt;
					&lt;loadPort&gt;AUMEL&lt;/loadPort&gt;
					&lt;locationId&gt;0010482&lt;/locationId&gt;
					&lt;messageMode&gt;U&lt;/messageMode&gt;
					&lt;operatorCode&gt;CPS&lt;/operatorCode&gt;
				&lt;/BayPlan&gt;
				&lt;BayPlan&gt;
					&lt;vent&gt;-1.0000&lt;/vent&gt;
					&lt;weight&gt;21000.0000&lt;/weight&gt;
					&lt;carbonDioxide&gt;-1&lt;/carbonDioxide&gt;
					&lt;humidity&gt;-1&lt;/humidity&gt;
					&lt;oxygen&gt;-1&lt;/oxygen&gt;
					&lt;temperature&gt;-273&lt;/temperature&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;commodity&gt;WINE&lt;/commodity&gt;
					&lt;commodityDescription&gt;WINE&lt;/commodityDescription&gt;
					&lt;destinationPort&gt;CNAKL&lt;/destinationPort&gt;
					&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
					&lt;ediTranshipPort&gt;CNAKL&lt;/ediTranshipPort&gt;
					&lt;fullOrMT&gt;F&lt;/fullOrMT&gt;
					&lt;id&gt;XNR60001925&lt;/id&gt;
					&lt;isoType&gt;2210&lt;/isoType&gt;
					&lt;loadPort&gt;AUMEL&lt;/loadPort&gt;
					&lt;locationId&gt;0010282&lt;/locationId&gt;
					&lt;messageMode&gt;U&lt;/messageMode&gt;
					&lt;operatorCode&gt;CPS&lt;/operatorCode&gt;
				&lt;/BayPlan&gt;
				&lt;BayPlan&gt;
					&lt;vent&gt;-1.0000&lt;/vent&gt;
					&lt;weight&gt;21000.0000&lt;/weight&gt;
					&lt;carbonDioxide&gt;-1&lt;/carbonDioxide&gt;
					&lt;humidity&gt;-1&lt;/humidity&gt;
					&lt;oxygen&gt;-1&lt;/oxygen&gt;
					&lt;temperature&gt;-273&lt;/temperature&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;commodity&gt;WINE&lt;/commodity&gt;
					&lt;commodityDescription&gt;WINE&lt;/commodityDescription&gt;
					&lt;destinationPort&gt;CNAKL&lt;/destinationPort&gt;
