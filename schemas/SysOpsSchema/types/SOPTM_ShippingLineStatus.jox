    <JadeMethod name="doDelete" id="72c10363-9eff-4c94-980e-458e8c51af2a">
        <updating/>
        <source>doDelete(pObj: Object io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/08/2023	navkc1	CR 59580	Task 59588: UI - CustDocs Customs Shipping Line Status

