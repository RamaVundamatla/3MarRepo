    <JadeMethod name="action" id="3cec7c02-8ba6-4106-b9dd-065525bc308c">
        <updating/>
        <source>action(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2024	navsp1	Initial creation TFS ChangeRequest 63842: NSW | OnePort Integration Dev

*/

vars
	errCode					: Integer;
	errTxt					: String;
	agent   				: CM_APIConsumerAgent;
	extDef					: CM_ExternalWebServiceDef;		// TFS 58722
	def						: CM_APIEndpointServiceDef;
begin
	app.writeLog( method.qualifiedName,LogINFO);
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	if self.myTerminal &lt;&gt; null then
		app.myPassport.setMyTerminal(self.myTerminal);     
	endif;
	
	extDef:=app.myRoot.getFirstActiveEWSForEndpoint(ETRow_NswVesselMovements);
	if extDef &lt;&gt; null and extDef.isAPIDef then
		def := extDef.CM_APIEndpointServiceDef;
	endif; 
	
	if def = null then
		app.doRaiseAlert(app.getErrorString(NO_WEBSERVICE_DEF));
		app.raiseCMException(NO_WEBSERVICE_DEF, null, null);
		return false;
	endif;
	
	create agent transient;
	agent.setMyTerminal(self.myTerminal);
	agent.setupFromWebServiceDefinition(def);
	
	self.setUser();
	self.processOnePortRequest(agent, def);

epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	delete agent;
	inheritMethod();
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createAlert" id="0c7a1a2c-9641-4e87-8ee3-d90d4312ff71">
        <source>createAlert(_shortMsg, _longMsg : String; _severity : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Jul 2024	navsp1	Initial creation TFS ChangeRequest 63842: NSW | OnePort Integration Dev
24 Oct 2024	navdap1	MTN-14005 NSW | OnePort Integration - Requested Changes - added _longMsg parameter
*/

vars
	alert: CM_SystemAlert;
begin
	app.writeLog(_shortMsg, LogERROR);
	
	create alert transient;
	alert.details := _shortMsg;
	alert.setSeverity(_severity);
	if _longMsg &lt;&gt; null then			// MTN-14005
		alert.addLogEntry(_longMsg);	// MTN-14005
	endif;								// MTN-14005
	alert.add;
	app.commitAlert();
end;</source>
        <Parameter name="_shortMsg" type="String"/>
        <Parameter name="_longMsg" type="String"/>
        <Parameter name="_severity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="e5191a8a-8186-47d3-86ed-a2e1fe9d357d">
        <source>getDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2024	navsp1	Initial creation TFS ChangeRequest 63842: NSW | OnePort Integration Dev

*/

vars
	str, detail	: String;
begin
	str 	:= inheritMethod();
	detail 	:= 'OnPort Voyage Movement Query ' &amp; self.myTerminal.code;
	
	return str &amp; Tab &amp; detail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
