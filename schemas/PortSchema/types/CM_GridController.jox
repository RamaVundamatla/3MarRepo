    <JadeMethod name="getNumTIs" id="83508a8b-2a74-4ee0-944d-618b1611b530">
        <source>getNumTIs(_mode : Integer) : Integer;
// returns each 40' once not twice as numTIs does
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	count : Integer;
	iter : Iterator;
	ti : CM_TrackedItem;
	futureMove : CM_FutureMove;
	deepCount : Boolean;
begin

	deepCount := self.deepCountTrackedItems;
	
	if _mode = REAL_MODE then
		if self.allTrackedItems.isEmpty then
			return 0;
		endif;
		iter := self.allTrackedItems.createIterator();
		while iter.next(ti) do
			if not ti.isLCBackEnd(self, _mode) then
				if deepCount then  //cnwrd1 31736 break bulk counting
					count := count + ti.totalQuantity.max(1);
				else
					count := count + 1;
				endif;
			endif;
		endwhile;
	elseif _mode = PLANNING_MODE then
		if self.allPlannedFutureMoves.isEmpty then
			return 0;
		endif;
		foreach futureMove in self.allPlannedFutureMoves do
			ti := futureMove.getTrackedItem();
			if not ti.isLCBackEnd(self, _mode) then
				if deepCount then  //cnwrd1 31736 break bulk counting
					count := count + ti.totalQuantity.max(1);
				else
					count := count + 1;
				endif;
			endif;
		endforeach;
	elseif _mode = QUEUE_MODE then
		if self.allQueuedFutureMoves.isEmpty then
			return 0;
		endif;
		foreach futureMove in self.allQueuedFutureMoves do
			ti := futureMove.getTrackedItem();
			if not ti.isLCBackEnd(self, _mode) then
				if deepCount then  //cnwrd1 31736 break bulk counting
					count := count + ti.totalQuantity.max(1);
				else
					count := count + 1;
				endif;
			endif;
		endforeach;
	endif;
	return count;
epilog
	delete iter;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getOffsetLabel" id="ffdc5e72-0270-45c3-ac90-2afaf1291215">
        <source>getOffsetLabel(_offsetColour : Integer output) : String;
// ---------------------------------------------------------------------------
// Created:		06 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		PAR 16415 CCMS 1029
//
// ---------------------------------------------------------------------------
vars
	tmpStr : String;
begin
	if self.is45ft and self.is30ft and self.is53ft and self.is40ft  and self.is20ft then // PAR 18682
		tmpStr := '20|30|45|53|40';
		_offsetColour := LightGreen;
	elseif self.is45ft and self.is30ft and self.is53ft and self.is40ft then // PAR 18682
		tmpStr := '30|45|53|40';
		_offsetColour := LightGreen;
	elseif self.is45ft and self.is53ft and self.is40ft and self.is20ft then // PAR 18682
		tmpStr := '20|45|53|40';
		_offsetColour := LightBlue;
	elseif self.is45ft and self.is30ft and self.is40ft and self.is20ft then // PAR 18682
		tmpStr := '20|45|30|40';
		_offsetColour := LightRed;
	elseif self.is30ft and self.is53ft and self.is40ft and self.is20ft then // PAR 18682
		tmpStr := '20|30|53|40';
		_offsetColour := Black;
	elseif self.is45ft and self.is30ft and self.is53ft   and self.is20ft then // PAR 18682
		tmpStr := '20|30|45|53';
		_offsetColour := LightGreen;
	elseif self.is45ft and self.is53ft and self.is20ft then// PAR 18682
		tmpStr := '20|45|53';
		_offsetColour := LightBlue;
	elseif self.is45ft and self.is30ft and self.is20ft then// PAR 18682
		tmpStr := '20|45|30';
		_offsetColour := LightRed;
	elseif self.is30ft and self.is53ft and self.is20ft then// PAR 18682
		tmpStr := '20|30|53';
		_offsetColour := Black;
	elseif self.is45ft and self.is40ft and self.is20ft then // PAR 18682
		tmpStr := '20|45|40';
		_offsetColour := Green;
	elseif self.is30ft and self.is40ft and self.is20ft then  // PAR 18682
		tmpStr := '20|40|30';
		_offsetColour := Blue;
	elseif self.is53ft and self.is40ft and self.is20ft then  // PAR 18682
		tmpStr := '20|53|40';
		_offsetColour := Red;
	elseif self.is45ft and self.is30ft and self.is53ft then
		tmpStr := '30|45|53';
		_offsetColour := LightGreen;
	elseif self.is45ft and self.is53ft and self.is40ft then // PAR 18682
		tmpStr := '45|53|40';
		_offsetColour := LightBlue;
	elseif self.is45ft and self.is30ft and self.is40ft then // PAR 18682
		tmpStr := '45|30|40';
		_offsetColour := LightRed;
	elseif self.is30ft and self.is53ft and self.is40ft then // PAR 18682
		tmpStr := '30|53|40';
		_offsetColour := Black;
	elseif self.is45ft and self.is53ft then
		tmpStr := '45|53';
		_offsetColour := LightBlue;
	elseif self.is45ft and self.is30ft then
		tmpStr := '45|30';
		_offsetColour := LightRed;
	elseif self.is30ft and self.is53ft then
		tmpStr := '30|53';
		_offsetColour := Black;
	elseif self.is45ft and self.is40ft then // PAR 18682
		tmpStr := '45|40';
		_offsetColour := Green;
	elseif self.is30ft and self.is40ft then  // PAR 18682
		tmpStr := '40|30';
		_offsetColour := Blue;
	elseif self.is53ft and self.is40ft then  // PAR 18682
		tmpStr := '53|40';
		_offsetColour := Red;
	elseif self.is45ft and self.is20ft then // PAR 18682
		tmpStr := '45|20';
		_offsetColour := Green;
	elseif self.is30ft and self.is20ft then  // PAR 18682
		tmpStr := '20|30';
		_offsetColour := Blue;
	elseif self.is53ft and self.is20ft then  // PAR 18682
		tmpStr := '53|20';
		_offsetColour := Red;
	elseif self.is45ft then
		tmpStr := '| 45 |';
		_offsetColour := Green;
	elseif self.is30ft then 
		tmpStr := '| 30 |';
		_offsetColour := Blue;
	elseif self.is53ft then 
		tmpStr := '| 53 |';
		_offsetColour := Red;
	elseif self.is40ft then  // PAR 18682
		tmpStr := '| 40 |';
		_offsetColour := Red;
	elseif self.is20ft then  // PAR 18682
		tmpStr := '| 20 |';
		_offsetColour := Blue;
	endif;
	
	return tmpStr;
end;</source>
        <Parameter name="_offsetColour" type="Integer" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOversizedBackendsByModePrev" id="57762139-2291-48b3-8c5f-8d19d208239b">
        <source>getOversizedBackendsByModePrev(_mode : Integer; _tmpTIs : CM_TIArray input; _inc40s : Boolean);
// ---------------------------------------------------------------------------
// Created:		19 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    19MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
vars
	fms : CM_FutureMoveArray;
	tmpGC, theGC : CM_GridController;
	fmTI : CM_TrackedItem;
	aFM : CM_FutureMove;
begin
	if _mode = REAL_MODE then
		if self.is53ft and self.offset53 = self.Offset53_6 then
			theGC := self.getPreviousControllerOfType(CM_GridController);
			if theGC &lt;&gt; null then
				if not theGC.allTrackedItemOSBackEnds.isEmpty() then// PAR 17122
					if theGC.allTrackedItemOSBackEnds.first.isAttributeTrue(TI_Attrib_IsFiftyThree) then // PAR 17122
						theGC.allTrackedItemOSBackEnds.copy(_tmpTIs);
					endif;
				endif;
			endif;
			// incase of a 53 /30 mix
			if _tmpTIs.isEmpty then
				self.allTrackedItemOSBackEnds.copy(_tmpTIs);
			endif;
		else
			self.allTrackedItemOSBackEnds.copy(_tmpTIs);
		endif;
	else
		if _mode = QUEUE_MODE then
			self.allTrackedItemOSBackEndsQd.copy(_tmpTIs);
		else
			//self.allTrackedItemOSBackEndsPd.copy(_tmpTIs);
			// PAR 22614
			foreach fmTI in self.allTrackedItemOSBackEndsPd  discreteLock do
				if not _tmpTIs.includes(fmTI) then
					_tmpTIs.add(fmTI);
				endif;
			endforeach;

		endif;
			
			// incase of a 53 /30 mix
//			if self.is53ft and self.offset53 = self.Offset53_6 then
		if _tmpTIs.isEmpty() then
			if self.is53ft and self.offset53 = self.Offset53_6 then
				theGC := self.getPreviousControllerOfType(CM_GridController);
				if theGC &lt;&gt; null then
					if _mode = QUEUE_MODE then
						if not theGC.allTrackedItemOSBackEndsQd.isEmpty() then// PAR 17122
							if theGC.allTrackedItemOSBackEndsQd.first.isAttributeTrue(TI_Attrib_IsFiftyThree) then // PAR 17122
								theGC.allTrackedItemOSBackEndsQd.copy(_tmpTIs);
							endif;
						endif;
					else
						if not theGC.allTrackedItemOSBackEndsPd.isEmpty() then// PAR 17122
							if theGC.allTrackedItemOSBackEndsPd.first.isAttributeTrue(TI_Attrib_IsFiftyThree) then // PAR 17122
								theGC.allTrackedItemOSBackEndsPd.copy(_tmpTIs);
							endif;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_tmpTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_inc40s" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getOversizedFrontendsByMode" id="304ffa76-50b2-4c29-95b2-e42cbb0330b4">
        <source>getOversizedFrontendsByMode(_mode : Integer; _tmpTIs : CM_TIArray input);
// ---------------------------------------------------------------------------
// Created:		19 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    19MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
vars
	fms : CM_FutureMoveArray;
	fmTI : CM_TrackedItem;
	aFM : CM_FutureMove;
begin
	if _mode = QUEUE_MODE then
		fms := self.allQueuedFutureMoves;
	else
		fms := self.allPlannedFutureMoves;
	endif;
	foreach aFM in fms  discreteLock do
		fmTI := aFM.getTrackedItem();
		if fmTI &lt;&gt; null then
			_tmpTIs.add(fmTI);
		endif;
	endforeach;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_tmpTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getOverstowedByTIs" id="5c1f84f3-b5c6-4d00-b99b-cd1e636c7345">
        <source>getOverstowedByTIs(moveMode: Integer; tiToGetOverstowedBy : CM_TrackedItem; overstowingTIs: CMIF_RTSortByPosDict input; _includeSelf : Boolean);
// ---------------------------------------------------------------------------
// Created:     16 February 2001 by cnwdwq1
// Purpose: 
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	array		: CM_TIArray;
	ti			: CM_TrackedItem;
	allTiSorts	: CMIF_RTSortByPosDict;
	pos			: Integer;

begin
	inheritMethod(moveMode, tiToGetOverstowedBy, overstowingTIs, _includeSelf);	//Clear the set, and test for null tiToGetOverstowedBy
	create allTiSorts transient;
	create array transient;
	self.getTIs(array, moveMode, true); // PAR 27749
	if not array.includes(tiToGetOverstowedBy) then
		//app.setContinueCMExceptions(false);
		//app.raiseCMException1(ERR_TI_NOTIN_COLL, self.getID, null, null);
		return;
	endif;
	//---------------
	//Build up the set of objects
	//---------------
	foreach ti in array reversed do
		pos := array.indexOf(ti);
		if ti &lt;&gt; tiToGetOverstowedBy then
			overstowingTIs.addTi(pos, ti);
		else
			if _includeSelf then
				overstowingTIs.addTi(pos, ti);
			endif;
			break;
		endif;
	endforeach;

epilog
	delete array;
	delete allTiSorts;
end;</source>
        <Parameter name="moveMode" type="Integer"/>
        <Parameter name="tiToGetOverstowedBy" type="CM_TrackedItem"/>
        <Parameter name="overstowingTIs" type="CMIF_RTSortByPosDict" usage="input"/>
        <Parameter name="_includeSelf" type="Boolean"/>
    </JadeMethod>
