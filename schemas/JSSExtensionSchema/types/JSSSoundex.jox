    <DbClassMap file="jssxs_datavalue_primitive"/>
    <JadeMethod name="doSoundexConversion" id="3a307d65-b3ef-4f2f-bd12-e7bc6f6d7644">
        <source>doSoundexConversion(pMaxLength : Integer):String protected;

vars
	soundex		: String;
	validString	: String;
	pos			: Integer;
	size		: Integer;
	char		: Character;
	lastChar	: Character;
	
begin
	validString := inputString.toUpper();
	
	// get rid of non alpha.
	removeNonAlpha(validString);
	
	if validString.length() &lt; 2 then
		// do nothing
		
	else
		// set first character of soundex
		soundex := validString[1:1];
		validString := validString[2:end];
		
		// remove non valued letters and convert the others
		substituteSoundexValues(validString);
		
		//remove duplicates
		removeDuplicateChars(validString);
	
		//add first Character back and truncate to desired length
		validString := soundex &amp; validString;
		returnFirstChars(validString,pMaxLength);
	endif;
	
	return validString;
end;</source>
        <access>protected</access>
        <Parameter name="pMaxLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTransform" id="84d332dd-a8d1-4968-b78d-9fb8128c3739">
        <source>getTransform(pMaxLength: Integer): String;
// -----------------------------------------------------------------------------
// Created:		26 October 2001 by cnwdad1
//
// Purpose:		Transforms the receiver's string value into a soundex value,
//				and returns the result.
//
// Parameters:	pMaxLength - The maximum length of the soundex code.  If zero,
//				the default of upto four characters will be returned.
//
// Returns:		The soundex code of the receiver's string value.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	retValue	: String;
	
begin
	if pMaxLength = 0 then
		retValue := doSoundexConversion(4);
	else
		retValue := doSoundexConversion(pMaxLength);
	endif;
epilog
	return retValue;
end;</source>
        <Parameter name="pMaxLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="substituteSoundexValues" id="f9bbd354-75d7-460b-b4c3-9d26a86fb3e6">
        <source>substituteSoundexValues(pWorkString : String io) protected;

vars
	retValue	: String;
	char		: Character;
	size		: Integer;
	pos			: Integer;
begin
	// remove non valued letters and convert the others  
	size := pWorkString.length();
	
	foreach pos in 1 to size do
		char := pWorkString[pos:1].Character;
		if char = "A"
		or char = "E"
		or char = "H"
		or char = "I"
		or char = "O"
		or char = "U"
		or char = "W"
		or char = "Y"
		then
			continue;
		elseif char = "B"
		or char = "F"
		or char = "P"
		or char = "V"
		then
			retValue := retValue &amp; "1";
		elseif char = "C"
		or char = "G"
		or char = "J"
		or char = "K"
		or char = "Q"
		or char = "S"
		or char = "X"
		or char = "Z"
		then
			retValue := retValue &amp; "2";
		elseif char = "D"
		or char = "T"
		then
			retValue := retValue &amp; "3";
		elseif char = "L"
		then
			retValue := retValue &amp; "4";
		elseif char = "M"
		or char = "N"
		then
			retValue := retValue &amp; "5";
		elseif char = "R"
		then
			retValue := retValue &amp; "6";
		endif;
	endforeach;
	
	pWorkString := retValue;
end;</source>
        <access>protected</access>
        <Parameter name="pWorkString" type="String" usage="io"/>
    </JadeMethod>
</Class>
