    <JadeMethod name="fixRowAreaRows" id="d1a69d32-1e1e-42d4-b061-2a9531c235e5">
        <source>fixRowAreaRows();
// ---------------------------------------------------------------------------
// Created:     04 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ra		: CM_LogArea;
	prevRc,
	rc		: CM_RowAreaRow;
	thisNum,
	prevNum	: Integer;
	str		: String;
	delSet	: ObjectSet;
	
begin

	create delSet transient;

	foreach ra in CM_LogArea.instances do
		app.writeStatement( 'checking ' &amp; ra.id);
		prevNum := -1;
		foreach rc in ra.allRows do
			thisNum := rc.allRowControllers.size;
			if prevNum = 0 and thisNum = 0 then
				str := '  &gt;&gt; delete';
				delSet.add(rc);
			else
				str := null;
			endif;
			app.writeStatement( '    ' &amp; rc.String &amp; '  ' &amp; thisNum.String &amp; str);
			prevNum := thisNum;
		endforeach;
	endforeach;
	
	beginTransaction;
	delSet.purge;
	commitTransaction;

epilog
	delete delSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="29c6c76b-60f1-4584-88a9-9af76aa2b383">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Aug 2009	cnwer1	Initial creation
09 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

begin
	if _attrName = ETRow_MarkedUp  then
		return self.isMarkedUp.asStringJMT;
	elseif _attrName = ETRow_Length then
		return self.lengthOfArea.asStringJMT;
	elseif _attrName = 	ETRow_Labels then
		return self.getTheLabels();
	elseif _attrName = ETRow_Width then
		return self.standardWidth.asStringJMT;
	elseif _attrName = ETRow_GapManaged then
		return self.isGapManaged.asStringJMT;
	elseif _attrName = ETRow_WidthOfArea then			// TFS 49453
		return self.widthOfArea.asStringJMT;			// TFS 49453
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
