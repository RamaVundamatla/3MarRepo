    <JadeMethod name="rebuildVBSLblCaptions" id="044a2f45-8229-4a6b-8342-f25f89e88eca">
        <source>rebuildVBSLblCaptions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2015	cnwndl1	Initial creation	Par 36234

*/

vars

	vbsTerm : CM_VehicleBookingTerminal;

begin

	vbsTerm := self.myTerminal.myVehicleBookingTerminal;
	
	self.lblTemplate.caption := app.getErrorString(NoVBSTemplates);
	self.lblExclusion.caption := app.getErrorString(NoVBS_Exclusion_criteria);
	
	if vbsTerm &lt;&gt; null then
		self.lblTemplate.caption := app.getErrorString1(VBSTemplates_declared, vbsTerm.allVehicleBookingDayTemplates.size.String );
		if vbsTerm.myExclusionCriteria &lt;&gt; null then
			self.lblExclusion.caption := app.getErrorString1( VBSExclusion_criteria, vbsTerm.myExclusionCriteria.getTableDisplayString );
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAlternateBtnCaption" id="97a08acb-02c8-4220-8e8a-be87cecaba52">
        <source>setAlternateBtnCaption();
/*

Purpose:			

Parameters:			Also called from CMUI_ObjectCriteriaListform::unload  via smsg

Return Value:		

Date		Who		Reason
13 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars

	altCount : Integer;

begin

	self.btnAlternate.caption := "...";
	altCount := self.myTerminal.hasAlternateFormatsByContext( CM_ReportFormatMatchCriteria.RoadReceiptReportInt );
	if altCount &gt; 0 then
		self.btnAlternate.caption := "... (+" &amp; altCount.String &amp; ") ";
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCMIFFromForm" id="3e2d2e65-8f99-4bbf-ad05-e57683d1a0ed">
        <source>setCMIFFromForm(_cmif : CMIF_ConfigTerminal input) protected;

/*
Date			Who		Reason
02 July 2009	cnwar2	Initial creation
23 Feb 2010		consw1	PAR #21156 - Gate Config Report Names
16 Mar 2010		cnwcs5	par 22734 - transit into yard
						Also changed parameter usage from io to input
23 Nov 2011		cnwdap1	PAR #28733 CCMS SFW 1261 print options for EIR, deleted ticket fields from Printing tab
08 Feb 2012		cnwdap1	PAR #29097 Allow configuration of Reprint Driver Instructions report
01/07/2013		cnwdap1	PAR #30344 CCMS GLT 2226 Gate Out Consignee Required check box
16/12/2013		cnwdap1	PAR #32849 CCMS PEN 2321 New "Site Has Security Gate" option
12/05/2022 		navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
10 Oct 2022 	navma1	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
27/02/2023		jlika1	TFS 56731 AAT - 1Stop VBS Booking Not Required to Drop Off Export Empty Containers
21/09/2023		jlizm1	TFS 59576 Kiosk error advice report - gate config
08 Nov 2023		navlw1	Bug 60951: EUP | 53824 - Transport Manifest - VBS Slot Not Always Being Created
08 Feb 2024 	navhl20 ChangeRequest 62084:[62376] EUP | Retrospective Operations - [54177.010] - Road Entry
20 Mar 2025 	navlc30 JIRA 34268 - Create a new setting that is to be enabled for this new functionality
*/
vars
	tblConfig		: CM_EntryTable;
begin
	tblConfig							:= self.tblConfigOpts;				//05.10.2022 navma1 #52967
	_cmif.gateInCheckISOTypes			:= self.chkRecISO.value;
	_cmif.gateInForceBATNumber			:= self.chkRecBAT.value;
	_cmif.gateInOutHazardousWarning		:= self.chkRecHazard.value;
	_cmif.doNotCreateBulkRelease		:= self.chkRecBR.value;
	
	_cmif.allowDuplicateReleaseNos		:= self.chkMTDuplicates.value;
	_cmif.brPackReqDelvRelNum			:= self.chkMTUnqiue.value;
	_cmif.gateAllowMultipleMTGrades		:= self.chkMTGrades.value;
	
	_cmif.allowMultiBookingRef			:= self.chkBRMultiLine.value;
	_cmif.bookingRefBasicCheck			:= self.chkBRBasicChecks.value;
	//cnwmc5 - PAR 32690
	if app.myRoot.isDeprecated("8.1.2") then
		_cmif.useBookingSummView		:= true;
	else
		_cmif.useBookingSummView		:= self.chkBRSummaryView.value;
	endif;
	_cmif.bookingRefRequired			:= app.bookingRequiredStringToEnum(self.cmbBookingReq.text);		//+cnwml2 PAR23763 MSL PAR1078
	_cmif.bookingOversubscribe			:= self.chkBookOversubs.value;										// 08/04/2014 cnwmh5 #33829
	_cmif.bookingRefErrors				:= self.chkBRErrors.value;
	
	//26 May 2017	NDL	TFS 4452
	if self.cmbTrailDefIMEX.listObject = null then
		_cmif.defRecTrailIMEX := TI_IMEX_STATUS_STORAGE;
	else
		_cmif.defRecTrailIMEX := self.cmbTrailDefIMEX.listObject.CM_IMEXStatus.code;
	endif;
	
	_cmif.defRecTrailOper := self.cmbTrailDefOper.listObject.CM_Operator;	//21 Oct 2020	NDL	TFS 50113
	
	_cmif.noPINforHazardousPreNote		:= self.chkNoPinPrenoteH.value;
	_cmif.noPINforOverDimenPreNote		:= self.chkNoPinPrenoteO.value;
	_cmif.noPINforHazardousRelease		:= self.chkNoPinReleaseH.value;
	_cmif.noPINforOverDimenRelease		:= self.chkNoPinReleaseO.value;
	
	_cmif.fleetFileContDetails			:= self.chkFleetFileCont.value;
	_cmif.fleetFileGenDetails			:= self.chkFleetFileGen.value;
	_cmif.fleetFileTrailerDetails		:= self.chkFleetFileTrlr.value;
	_cmif.fleetFileErrors				:= self.chkFleetFileErr.value;
	
	_cmif.allowMobileRoadExit			:= self.chkOtherMAQ.value;
	_cmif.gateAllowDualGate				:= self.chkOtherMMQ.value;
	_cmif.gateAllowUngatedTrucks		:= self.chkOtherUUT.value;
	_cmif.twinLiftFromGate				:= self.chkOtherTwin.value;
	_cmif.gateElapsedTimeExceeded		:= self.txtOtherMinutes.text.Integer;
	_cmif.trailerDetailsVisible			:= self.chkTrailerDet.value;//cnwas3
		
	_cmif.showVehicleState				:= self.chkShowState.value;//cnwrd1 par 21158 18.3.2010
	
	_cmif.defaultCarrierEmail			:= self.lblEmailCarrier.value;
	_cmif.defaultConsignorEmail			:= self.lblEmailConsign.value;
	
	_cmif.gateDefaultEntry				:= self.cmbDefEntryGate.listObject.CM_Gate;
	_cmif.gateIOHideAutoComplete		:= self.chkEntryAutoComp.value;
	_cmif.gateReceiptRequired			:= self.chkEntryGateRec.value;
	_cmif.gateInOutHideBatNumber		:= self.chkEntryHideBAT.value;
	_cmif.weighBridgeEnabled			:= self.chkEntryWeigh.value;
	_cmif.gateInVehicleTareWeight		:= self.chkEntryTare.value;
	_cmif.isSubCarrierEnabled    		:= self.chkSubcarrier.value;		//12/05/2022 navhl20 TFS 53430	
	_cmif.isSubCarrierRequired			:= self.chkSubCarrierMand.value;	//12/05/2022 navhl20 TFS 53430
	_cmif.isRetrospectiveMode			:= self.chkRetroMode.value;			//08.02.2023 navhl20 #62084[62376]
	//10/01/2011 cnwdz2 26613
	_cmif.hideRGateDriverCodeName		:= self.chkEntryHideName.value;

	_cmif.gateDefaultExit				:= self.cmbDefExitGate.listObject.CM_Gate;
	_cmif.gateExitDefaultSortCol		:= self.cmbExitSort.text;
	_cmif.gateOutReleaseByISOType		:= self.chkExitISO.value;
	_cmif.gateRelNoSearchText			:= self.chkRelRecTB.value;
	
	_cmif.gateInAllowAutoComplete		:= self.chkAutoComplete.value;
	_cmif.gateInAutoBOLNumber			:= self.chkAutoBOL.value;
	_cmif.gateInAutoComplete			:= self.chkAutoCompDef.value;
	_cmif.gateInAutoVisitNo				:= self.chkAutoVisitNo.value;

	_cmif.vehicleVisitNumPrefix			:= self.txtVVPrefix.text;
	_cmif.vehicleVisitNumLength			:= self.txtVVLength.text.Integer;
	_cmif.vehicleVisitNumStartSeq		:= self.txtVVStartSeqNum.text.Integer;
	_cmif.vehicleVisitNumRollover		:= self.cmbVVRollover.listIndex;
	_cmif.vehicleVisitNumMax			:= self.txtVVMax.text.Integer;
	
	_cmif.gateCarterNoteReport			:= self.getReportNameForCMIF(self.txtPrintCarter, DefRep_GateCarterNoteReport);
	_cmif.gateDriverInstructionsReport	:= self.getReportNameForCMIF(self.txtDriverInstr, DefRep_GateDriverInstructions);
	_cmif.gateRoadJobReceipt			:= self.getReportNameForCMIF(self.txtPrintRRR, DefRep_GateRoadJobReceipt);
	_cmif.gateReprintDriverIns			:= self.getReportNameForCMIF(self.txtReprintDI, DefRep_GateReprintDriverInst);	// PAR #29097
	_cmif.gateInterchangeReport			:= self.getReportNameForCMIF(self.txtInterChg, null);	//11 Jan 2019	NDL	TFS 40479
	_cmif.gateKioskErrorAdvice			:= self.getReportNameForCMIF(self.txtKioskErrorAdv, null); // TFS 59576
	
	_cmif.gateReceiptCopies				:= self.txtPrintCopies.text.Integer;
	_cmif.printBuckslip					:= self.chkPrintBuckslip.value;
	_cmif.printInterchange				:= self.chkPrintInterchg.value;		//11 Jan 2019	NDL	TFS 40479
	
	_cmif.printPreview					:= self.chkPrintPreview.value;
	
	_cmif.gateCheckAllowsIsoChg			:= self.chkAllowIso.value;	//27 jan 2010 NDL CCMS MES 1005
	_cmif.gateCheckRequiresCargoId		:= self.chkEnterId.value;	//27 jan 2010 NDL CCMS MES 1005
	
	_cmif.gateTransitIntoYard			:= self.chkYardTransitIN.value;	// 16/03/2010 cnwcs5 par 22734
	
	_cmif.displayPrintConfirmation		:= self.chkPrintConfirm.value;	// PAR #28733
	
	_cmif.gateOutConsigneeReqd			:= self.chkConsignee.value;		// PAR #30344
	
	_cmif.siteHasSecurityGate			:= self.chkSecurityGate.value;	// PAR #32849
	
	//14 May 2015	NDL	Par 36234
	_cmif.vsOntimeGracePeriod 		:= tblConfig.getValueByName(ETRow_VsOntimeGracePeriod).Integer;
	_cmif.vsTruckDriverMand 		:= tblConfig.getValueByName(ETRow_VsTruckDriverMand).Boolean;
	_cmif.vsGenerateDaysInAdvance 	:= tblConfig.getValueByName(ETRow_VsGenerateDaysInAdvance).Integer;
	_cmif.vsPurgeSlotsOlderThan 	:= tblConfig.getValueByName(ETRow_VsPurgeSlotsOlderThan).Integer;
	_cmif.vsBookMinAdvanceHrs 		:= tblConfig.getValueByName(ETRow_VsBookMinAdvanceHrs).Integer;
	_cmif.vsBookMinAdvancePu 		:= tblConfig.getValueByName(ETRow_VsBookMinAdvancePu).Integer;
	_cmif.allowVBSInPast			:= tblConfig.getValueByName(ETRow_AllowVBSInPast).Boolean; 			// #60951
	_cmif.vsBookingRule 			:= app.vehicleBookingRuleInteger(self.cmbBookRule.text);	
	_cmif.reqVehicleBooking1Stop 	:= tblConfig.getValueByName(ETRow_ReqVehicleBooking1Stop).Boolean; // jlika1 TFS 56731
	_cmif.hhLabelReport 			:= self.txtHHLabelRep.text.trimBlanks();					// TFS 978 RoRo hand-held
	_cmif.myVBSProcess			    := self.cmbDefaultVbsProcess.listObject.CM_VBSProcess;		//05.10.2022 navma1 #52967
	_cmif.myRoadProcess				:= self.cmbRoadProcess.listObject.CM_RoadProcess;
	_cmif.vsEnhancedStdVBS			:= tblConfig.getValueByName(ETRow_VsEnhancedStdVBS).Boolean;				//20.03.2025 navlc30 #34268
end;</source>
        <access>protected</access>
        <Parameter name="_cmif" type="CMIF_ConfigTerminal" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDIAlternateBtnCaption" id="18098fe3-559f-41b2-822f-be1c2785ce8b">
        <source>setDIAlternateBtnCaption();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwrh7	Initial creation TFS2899

*/

vars

	altCount : Integer;

begin

	self.btnDIAlternate.caption := "...";
	altCount := self.myTerminal.hasAlternateFormatsByContext( CM_ReportFormatMatchCriteria.DriverCriteriaInt );
	if altCount &gt; 0 then
		self.btnDIAlternate.caption := "... (+" &amp; altCount.String &amp; ") ";
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFormFromCMIF" id="864a994f-0ce7-4a71-b542-2c3cf3f5b015">
        <source>setFormFromCMIF(_cmif : CMIF_ConfigTerminal) protected;

/*
Date			Who		Reason
02 July 2009	cnwar2	Initial creation
02/12/2009		cnwmh5	PAR21655 - Add test to check if vehicle visit length
						is &gt; 2 characters.  If so set textbox to null
23 Feb 2010		consw1	PAR #21156 - Gate Config Report Names
16/03/2010		cnwcs5	par 22734 - transit into yard
23/11/2011		cnwdap1	PAR #28733 CCMS SFW 1261 added Display Print Confirmation check box, removed Ticket fields from Printing tab
08/02/2012		cnwdap1	PAR #29097 Allow config of Reprint Driver Instructions report
01/07/2013		cnwdap1	PAR #30344 CCMS GLT 2226 Gate Out Consignee Required check box
16/12/2013		cnwdap1	PAR #32849 CCMS PEN 2321 Security Gate
12/05/2022      navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
10/10/2022  	navma1	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
27/02/2023		jlika1	TFS 56731 AAT - 1Stop VBS Booking Not Required to Drop Off Export Empty Containers
21/09/2023		jlizm1	TFS 59576 Kiosk error advice report - gate config
08 Nov 2023		navlw1	Bug 60951: EUP | 53824 - Transport Manifest - VBS Slot Not Always Being Created
08 Feb 2024 	navhl20 ChangeRequest 62084:[62376] EUP | Retrospective Operations - [54177.010] - Road Entry
26 Feb 2024 	navhl20 ChangeRequest 62084:[62632] EUP | Retrospective Operations - [54177.010] - Road Entry
20 Mar 2025 	navlc30 JIRA 34268 - Create a new setting that is to be enabled for this new functionality
*/
vars

	entTableDef			: EntTableDef;
	defImex				: Integer;
	imex				: CM_IMEXStatus;
	selectedImex		: CM_IMEXStatus;
	vbsProcessStandard,
	vbsProcess			: CM_VBSProcess;
	
begin
	self.chkRecISO.value 		:= _cmif.gateInCheckISOTypes;
	self.chkRecBAT.value 		:= _cmif.gateInForceBATNumber;
	self.chkRecHazard.value 	:= _cmif.gateInOutHazardousWarning;
	self.chkRecBR.value 		:= _cmif.doNotCreateBulkRelease;
	
	self.chkMTDuplicates.value 	:= _cmif.allowDuplicateReleaseNos;
	self.chkMTUnqiue.value 		:= _cmif.brPackReqDelvRelNum;
	self.chkMTGrades.value 		:= _cmif.gateAllowMultipleMTGrades;
	
	self.chkBRMultiLine.value 	:= _cmif.allowMultiBookingRef;
	self.chkBRBasicChecks.value := _cmif.bookingRefBasicCheck;
	self.chkBRSummaryView.value := _cmif.useBookingSummView;
	self.cmbBookingReq.text		:= 	app.bookingRequiredEnumToString(_cmif.bookingRefRequired);			//+cnwml2 PAR23763 MSL PAR1078
	self.chkBookOversubs.value  := _cmif.bookingOversubscribe;											// 08/04/2014 cnwmh5 #33829
	self.chkBRErrors.value 		:= _cmif.bookingRefErrors;
	
	//26 May 2017	NDL	TFS 4452
	defImex := _cmif.defRecTrailIMEX;
	if defImex = 0 then
		defImex := TI_IMEX_STATUS_STORAGE;
	endif;
	selectedImex := app.myRoot.allImexStatuses.getAtKey( defImex );
	self.cmbTrailDefIMEX.clear();
	foreach imex in app.myRoot.allImexStatuses where 										
		imex.code = TI_IMEX_STATUS_STORAGE or
		imex.code = TI_IMEX_STATUS_REMAINONBOARD  do
		self.cmbTrailDefIMEX.addItemObject(imex.description, imex);
	endforeach;
	if selectedImex &lt;&gt; null then
		self.cmbTrailDefIMEX.listIndex := self.cmbTrailDefIMEX.findObject(selectedImex);
	endif;
	
	self.cmbTrailDefOper.setObject( _cmif.defRecTrailOper );	//21 Oct 2020	NDL	tFS 50113
	
	self.chkNoPinPrenoteH.value := _cmif.noPINforHazardousPreNote;
	self.chkNoPinPrenoteO.value := _cmif.noPINforOverDimenPreNote;
	self.chkNoPinReleaseH.value := _cmif.noPINforHazardousRelease;
	self.chkNoPinReleaseO.value := _cmif.noPINforOverDimenRelease;
	
	self.chkFleetFileCont.value	:= _cmif.fleetFileContDetails;
	self.chkFleetFileGen.value 	:= _cmif.fleetFileGenDetails;
	self.chkFleetFileTrlr.value	:= _cmif.fleetFileTrailerDetails;
	self.chkFleetFileErr.value	:= _cmif.fleetFileErrors;
	
	self.chkOtherMAQ.value 		:= _cmif.allowMobileRoadExit;
	self.chkOtherMMQ.value 		:= _cmif.gateAllowDualGate;
	self.chkOtherUUT.value 		:= _cmif.gateAllowUngatedTrucks;
	self.chkOtherTwin.value 	:= _cmif.twinLiftFromGate;
	self.txtOtherMinutes.text 	:= _cmif.gateElapsedTimeExceeded.asStringJMT;
	
	self.lblEmailCarrier.value	:= _cmif.defaultCarrierEmail;
	self.lblEmailConsign.value	:= _cmif.defaultConsignorEmail;
	
	self.myAssistant.comboBoxGates(self.cmbDefEntryGate, _cmif.gateDefaultEntry);
	
	self.chkEntryAutoComp.value	:= _cmif.gateIOHideAutoComplete;
	self.chkEntryGateRec.value	:= _cmif.gateReceiptRequired;
	self.chkEntryHideBAT.value	:= _cmif.gateInOutHideBatNumber;
	self.chkEntryWeigh.value	:= _cmif.weighBridgeEnabled;
	self.chkEntryTare.value		:= _cmif.gateInVehicleTareWeight;
	self.chkSubcarrier.value 	:= _cmif.isSubCarrierEnabled;		//12/05/2022 navhl20 TFS 53430
	self.chkSubcarrier.change(self.chkSubcarrier);					//12/05/2022 navhl20 TFS 53430
	self.chkSubCarrierMand.value := _cmif.isSubCarrierRequired;		//12/05/2022 navhl20 TFS 53430
	self.chkRetroMode.value		:= _cmif.isRetrospectiveMode;		//08.02.2023 navhl20 #62084[62376]
	//10/01/2011 cnwdz2 26613
	self.chkEntryHideName.value	:= _cmif.hideRGateDriverCodeName;
	
	self.myAssistant.comboBoxGates(self.cmbDefExitGate, _cmif.gateDefaultExit);
	self.myAssistant.comboBoxRoadExitSortColumn(self.cmbExitSort, _cmif.gateExitDefaultSortCol);
	self.myAssistant.comboBoxBookingRequired(self.cmbBookingReq, app.bookingRequiredEnumToString(_cmif.bookingRefRequired));			//+cnwml2 PAR23763 MSL PAR1078
	self.chkExitISO.value		:= _cmif.gateOutReleaseByISOType;
	self.chkRelRecTB.value		:= _cmif.gateRelNoSearchText;
	self.chkTrailerDet.value	:= _cmif.trailerDetailsVisible;//cnwas3
	
	self.chkShowState.value	:= _cmif.showVehicleState;//cnwrd1 par 21158 18.3.2010
	
	self.chkAutoComplete.value 	:= _cmif.gateInAllowAutoComplete;
	self.chkAutoBOL.value 		:= _cmif.gateInAutoBOLNumber;
	self.chkAutoCompDef.value 	:= _cmif.gateInAutoComplete;
	self.chkAutoVisitNo.value 	:= _cmif.gateInAutoVisitNo;
	//self.chkAutoCompleteB.value := _cmif.gateInAutoCompleteBkgrnd;
	self.chkRetroMode.change(self.chkRetroMode);					//26.02.2024 navhl20 #62084[62632]
	
	self.txtVVPrefix.text		:= _cmif.vehicleVisitNumPrefix;
	// 02/12/2009 cnwmh5 #21655 - Start
	
	if _cmif.vehicleVisitNumLength.asStringJMT().length &lt;= self.txtVVLength.maxLength then	//Par 23690 cnwas3
		self.txtVVLength.text		:= _cmif.vehicleVisitNumLength.asStringJMT();
	else
		self.txtVVLength.text 		:= null;
	endif;
	//self.txtVVLength.text		:= _cmif.vehicleVisitNumLength.asStringJMT();
	// 02/12/2009 cnwmh5 #21655 - End
	self.txtVVStartSeqNum.text	:= _cmif.vehicleVisitNumStartSeq.asStringJMT();
	if _cmif.vehicleVisitNumRollover &gt; 0 then
		self.cmbVVRollover.listIndex := _cmif.vehicleVisitNumRollover;
	else
		self.cmbVVRollover.listIndex := 1;
	endif;
	self.cmbVVRollover_click(self.cmbVVRollover);
	self.txtVVMax.text			:= _cmif.vehicleVisitNumMax.asStringJMT;
	
	self.txtPrintCarter.text	:= self.getReportNameForForm(_cmif.gateCarterNoteReport, DefRep_GateCarterNoteReport);
	self.txtDriverInstr.text	:= self.getReportNameForForm(_cmif.gateDriverInstructionsReport, DefRep_GateDriverInstructions);
	self.txtPrintRRR.text		:= self.getReportNameForForm(_cmif.gateRoadJobReceipt, DefRep_GateRoadJobReceipt);
	self.txtReprintDI.text		:= self.getReportNameForForm(_cmif.gateReprintDriverIns, DefRep_GateReprintDriverInst);		// PAR #29097
	self.txtInterChg.text		:= self.getReportNameForForm(_cmif.gateInterchangeReport, null);	//11 Jan 2019	NDL	TFS 40479
	self.txtKioskErrorAdv.text 	:= self.getReportNameForForm(_cmif.gateKioskErrorAdvice, null); 	// TFS 59576
	
	self.txtPrintCopies.text	:= _cmif.gateReceiptCopies.asStringJMT;
	self.chkPrintBuckslip.value	:= _cmif.printBuckslip;
	self.chkPrintPreview.value	:= _cmif.printPreview;
	self.chkPrintInterchg.value := _cmif.printInterchange;		//11 Jan 2019	NDL	TFS 40479
	
	if not self.chkAutoComplete.value then
		self.chkAutoCompDef.enabled := false;
		self.chkAutoCompDef.value := false;		
	endif;
	if not self.chkAutoCompDef.value then
		self.chkEntryAutoComp.enabled := false;
		self.chkEntryAutoComp.value := false;		
	endif;
	
	self.chkAllowIso.value := _cmif.gateCheckAllowsIsoChg;	//27 jan 2010 NDL CCMS MES 1005
	self.chkEnterId.value := _cmif.gateCheckRequiresCargoId;	//27 jan 2010 NDL CCMS MES 1005
	
	self.chkYardTransitIN.value	:= _cmif.gateTransitIntoYard;	// 16/03/2010 cnwcs5 par 22734
	
	self.chkPrintConfirm.value := _cmif.displayPrintConfirmation;	// PAR #28733
	if self.chkPrintBuckslip.value then								// PAR #28733
		self.chkPrintConfirm.enabled := true;						// PAR #28733
	else															// PAR #28733
		self.chkPrintConfirm.enabled := false;						// PAR #28733
	endif;															// PAR #28733
	
	self.chkConsignee.value := _cmif.gateOutConsigneeReqd;			// PAR #30344
	self.chkSecurityGate.value := _cmif.siteHasSecurityGate;		// PAR #32849
	self.txtHHLabelRep.text := _cmif.hhLabelReport;			// TFS 978 RoRo handheld
	
	//15 May 2015	NDL	Par 36234
	if self.myTerminal.isVehicleBookingEnabled then
		
		self.rebuildVBSLblCaptions(); 

		self.btnTempMaint.enabled := app.myCurrentUserCan (self.myTerminal, PmGteVehSchView);
		
		self.tblConfigOpts.warningMethod := 'entTableWarning';
		self.tblConfigOpts.optimiseRowHeight := true;
		entTableDef := app.myController.getEntTableDef(	ETDef_VBSConfig );
		self.tblConfigOpts.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		self.tblConfigOpts.changeMode := CM_EntryTable.ChangeMode_FirstOnly;
		
		self.tblConfigOpts.setValueByName(ETRow_VsOntimeGracePeriod, _cmif.vsOntimeGracePeriod);
		self.tblConfigOpts.setValueByName(ETRow_VsTruckDriverMand,     _cmif.vsTruckDriverMand);
		self.tblConfigOpts.setValueByName(ETRow_VsGenerateDaysInAdvance, _cmif.vsGenerateDaysInAdvance);
		self.tblConfigOpts.setValueByName(ETRow_VsPurgeSlotsOlderThan, _cmif.vsPurgeSlotsOlderThan);
		self.tblConfigOpts.setValueByName(ETRow_VsBookMinAdvanceHrs, _cmif.vsBookMinAdvanceHrs);
		self.tblConfigOpts.setValueByName(ETRow_VsBookMinAdvancePu, _cmif.vsBookMinAdvancePu);
		self.tblConfigOpts.setValueByName(ETRow_AllowVBSInPast, _cmif.allowVBSInPast); 									// #60951
		self.comboBoxVehicleBookingRules(self.cmbBookRule, app.vehicleBookingRuleString(_cmif.vsBookingRule));
		self.tblConfigOpts.setValueByName(ETRow_VsBookingRule, self.cmbBookRule.text);
		self.tblConfigOpts.setValueByName(ETRow_ReqVehicleBooking1Stop, _cmif.reqVehicleBooking1Stop);					// jlika1 TFS 56731
		
		vbsProcessStandard	:= app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE];								// ### TFS 53697 (55829) 21Dec2022 NAVPW1
		vbsProcess			:= _cmif.myVBSProcess;																		// ### TFS 53697 (55829) 21Dec2022 NAVPW1
		
		if vbsProcess &lt;&gt; null then																						//05.10.2022 navma1 #53697
			// ### TFS 53697 (55829) 21Dec2022 NAVPW1 -Start
			if not app.myRoot.canDo(Sub_VBSSlotValidation) then
				self.tblConfigOpts.disableRowByName(ETRow_VsDefaultProcess);
				self.cmbDefaultVbsProcess.listIndex := self.cmbDefaultVbsProcess.findObject( vbsProcessStandard );
				self.tblConfigOpts.setValueByName(ETRow_VsDefaultProcess, vbsProcessStandard.description);
			else
				self.cmbDefaultVbsProcess.listIndex := self.cmbDefaultVbsProcess.findObject( vbsProcess );
				self.tblConfigOpts.setValueByName(ETRow_VsDefaultProcess, vbsProcess.description);
			endif;
			// ### TFS 53697 (55829) 21Dec2022 NAVPW1 - End
			//self.cmbDefaultVbsProcess.listIndex := self.cmbDefaultVbsProcess.findObject( _cmif.myVBSProcess );		// ### TFS 53697 (55829) 21Dec2022 NAVPW1 - Commented Out
			//self.tblConfigOpts.setValueByName(ETRow_VsDefaultProcess, _cmif.myVBSProcess.description);				// ### TFS 53697 (55829) 21Dec2022 NAVPW1 - Commented Out
		else
			//Set Standard MTN Process
			self.cmbDefaultVbsProcess.listIndex := self.cmbDefaultVbsProcess.findObject( vbsProcessStandard );			// ### TFS 53697 (55829) 21Dec2022 NAVPW1
			self.tblConfigOpts.setValueByName(ETRow_VsDefaultProcess, vbsProcessStandard.description);					// ### TFS 53697 (55829) 21Dec2022 NAVPW1
		endif;
		
		self.tblConfigOpts.setValueByName(ETRow_VsEnhancedStdVBS, _cmif.vsEnhancedStdVBS);								//20.03.2025 navlc30 #34268	
	endif;
	
	//01 Oct 2020	NDL	TFS 49189
	if _cmif.myRoadProcess &lt;&gt; null then
		self.cmbRoadProcess.listIndex := self.cmbRoadProcess.findObject( _cmif.myRoadProcess );
		self.hideVVRNumFields();
	endif;

end;
</source>
        <access>protected</access>
        <Parameter name="_cmif" type="CMIF_ConfigTerminal"/>
    </JadeMethod>
    <JadeMethod name="setRpDIAlternateBtnCaption" id="9dbbca3f-f980-4057-bd1a-79ba56eeb517">
        <source>setRpDIAlternateBtnCaption();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2017	cnwrh7	Initial creation

*/

vars
	altCount : Integer;
begin
	self.btnRpDIAlternate.caption := "...";
	altCount := self.myTerminal.hasAlternateFormatsByContext( CM_ReportFormatMatchCriteria.RpDriverCriteriaInt );
	if altCount &gt; 0 then
		self.btnRpDIAlternate.caption := "... (+" &amp; altCount.String &amp; ") ";
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setRpInterchgBtnCaption" id="bc0ba73b-1084-4941-b760-17ca1ce6d4c0">
        <source>setRpInterchgBtnCaption();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 January 2019	jlgndl1	Initial creation	TFS 40479

*/

vars
	altCount : Integer;
begin
	self.btnRpInterChg.caption := "...";
	altCount := self.myTerminal.hasAlternateFormatsByContext( CM_ReportFormatMatchCriteria.InterchangeCriteriaInt );
	if altCount &gt; 0 then
		self.btnRpInterChg.caption := "... (+" &amp; altCount.String &amp; ") ";
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setUpRetroMode" id="d42d7d05-c758-4c28-b416-051883d9a34a">
        <source>setUpRetroMode();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Feb 2024 navhl20 ChangeRequest 62084:[62376] EUP | Retrospective Operations - [54177.010] - Road Entry
26 Feb 2024 navhl20 ChangeRequest 62084:[62632] EUP | Retrospective Operations - [54177.010] - Road Entry
*/

vars
	hasRetro	: Boolean;
begin
	hasRetro := app.myPassport.isRetrospectiveWoEnabled;
	
	if hasRetro then
		self.chkRetroMode.visible 	:= true;
		self.chkRetroMode.enabled 	:= true;
	else
		self.grpRoadEntry.height 	:= 190;
		self.grpAuto.top			:= 209;
		self.grpVehicleVisit.height	:= 227;
	endif;
	
	if self.cmbRoadProcess.listObject &lt;&gt; null 
	and self.cmbRoadProcess.listObject.CM_RoadProcess.isASPA then			//26.02.2024 navhl20 #62084[62632]
		self.chkRetroMode.enabled 	:= false;
		self.chkRetroMode.value 	:= false;
		if not self.chkAutoComplete.enabled then
			self.chkAutoComplete.enabled := true;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ce387921-ab3b-433f-a582-0e55f03bed05">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//04/01/2017    cnwrh7     TFS    2899 Cargo Attribute Filter for Driver Instructions
//10/10/2022  	navma1	   ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
//20 Dec 2022	navak20    Task 55978: EUP - VBS MTN - [1] - VBS Slot Types - Review Changes
//08 Feb 2024 	navhl20	   ChangeRequest 62084:[62376] EUP | Retrospective Operations - [54177.010] - Road Entry
// ---------------------------------------------------------------------------
vars
	configCMIF 	: CMIF_ConfigTerminal;
	altCount 	: Integer;
	roadProcess : CM_Code;
	vbsProcess	: CM_VBSProcess;
	idx 		: Integer;	// 20.12.2022 navak20 TFS 55978
begin 
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	
	inheritMethod();
	
	self.myTerminal		 :=	app.getMyTerminalDO_NOT_USE();
	self.expectedEdition := self.myTerminal.edition;
	self.setNavigatorHeading(self.caption);
	
	self.cmbVVRollover.clear();
	self.cmbVVRollover.sorted := false;
	self.cmbVVRollover.addItem(app.vehicleVisitRolloverEnumToStr(VEHICLE_VISIT_ROLLOVER_DAY));
	self.cmbVVRollover.addItem(app.vehicleVisitRolloverEnumToStr(VEHICLE_VISIT_ROLLOVER_YEAR));
	self.cmbVVRollover.addItem(app.vehicleVisitRolloverEnumToStr(VEHICLE_VISIT_ROLLOVER_MAX_NUM));
	
	//01 Oct 2020	NDL	TFS 49189
	self.cmbRoadProcess.clear();
	self.cmbRoadProcess.sorted := false;
	foreach roadProcess in app.myRoot.allRoadProcesses do
		self.cmbRoadProcess.itemObject[ self.cmbRoadProcess.addItem(roadProcess.description)] := roadProcess;
	endforeach;
	
	//05.10.2022 navma1 #53697
	self.cmbDefaultVbsProcess.clear();
	self.cmbDefaultVbsProcess.sorted := false;
	foreach vbsProcess in app.myRoot.allVBSProcesses do
		//self.cmbDefaultVbsProcess.itemObject[ self.cmbDefaultVbsProcess.addItem(vbsProcess.description)] := vbsProcess;	// 20.12.2022 navak20 TFS 55978
		idx := self.cmbDefaultVbsProcess.addItem(vbsProcess.description);	// 20.12.2022 navak20 TFS 55978
		self.cmbDefaultVbsProcess.itemObject[idx] := vbsProcess;			// 20.12.2022 navak20 TFS 55978
	endforeach;
	
	create configCMIF transient;
	configCMIF.setFromPersistentData(self.myTerminal);
	self.setFormFromCMIF(configCMIF);
	
	self.setupPermissions();
	
	self.shtVBS.visible := self.myTerminal.isVehicleBookingEnabled;	//14 May 2015	NDL	Par 36234
	
	self.setAlternateBtnCaption();
	self.setDIAlternateBtnCaption();				//+TFS2899
	self.setRpDIAlternateBtnCaption();			//+TFS2899
	self.setRpInterchgBtnCaption();	//11 Jan 2019	NDL	TFS 40479
	self.setUpRetroMode();							//08.02.2023 navhl20 #62084[62376]
epilog
	delete configCMIF;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupPermissions" id="710dde7e-5020-4e11-afd7-5c02ed149aa2">
        <source>setupPermissions();

/*
Date			Who		Reason
30 July 2009	cnwar2	Initial creation

*/
vars
	allowUpdate : Boolean;
	showControls	: Boolean;
begin
	allowUpdate := (app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint));
	
	self.btnSaveBase.enabled 	:= allowUpdate;
	self.btnSave.visible 		:= allowUpdate;
	self.grpAuto.enabled 		:= allowUpdate;
	self.grpBookingRef.enabled 	:= allowUpdate;
	self.grpEmail.enabled 		:= allowUpdate;
	self.grpMT.enabled 			:= allowUpdate;
	self.grpMisc.enabled 		:= allowUpdate;
	self.grpPIN.enabled 		:= allowUpdate;
	self.grpPrintOther.enabled 	:= allowUpdate;
	self.grpPrinting.enabled 	:= allowUpdate;
	self.grpReceive.enabled 	:= allowUpdate;
	self.grpAuto.enabled 		:= allowUpdate;
	self.grpRelRec.enabled	 	:= allowUpdate;
	self.grpRoadEntry.enabled 	:= allowUpdate;
	self.grpRoadExit.enabled 	:= allowUpdate;
	self.grpGateChecker.enabled 	:= allowUpdate; // TFS 2198
	self.grpVehicleVisit.enabled 	:= allowUpdate; // TFS 2198
	self.tblConfigOpts.enabled := allowUpdate; // TFS 2198
	
	// show cash receipt report only if cash is enabled, both feature and terminal
	showControls := self.myTerminal.isCashOnlyEnabled();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="skipToAttribute" id="1763c564-a133-4464-98dd-1e00508145f9">
        <updating/>
        <source>skipToAttribute( _attributeName : String; _shtName : String ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2012	cnwndl1	Initial creation

*/

vars

	index : Integer;
	control : Control;
	tmpSheet : CMUI_Sheet;
	folder : Folder;
	entRow : EntTableRow;
	row : Integer;

begin

	foreach index in 1 to self.controlCount do
		control := self.controls(index);
		if control.isKindOf( CMUI_Sheet ) then
			tmpSheet := control.CMUI_Sheet;
		else
			continue;
		endif;
		if _shtName &lt;&gt; tmpSheet.caption then
			continue;
		endif;
		folder := tmpSheet.parent.Folder;
		folder.topSheet := tmpSheet;
		
		//15 May 2015	NDL	Par 36234
		if self.shtVBS = tmpSheet then
			if self.myTerminal.isVehicleBookingEnabled then
				entRow := self.tblConfigOpts.myEntTableDef.getEntTableRowByHeading(_attributeName);
				if entRow &lt;&gt; null then
					row := self.tblConfigOpts.myEntTableDef.allEntTableRows.indexOf(entRow);
				endif;
			endif;
		endif;
		
		if row &gt; self.tblConfigOpts.fixedRows and row &lt;= self.tblConfigOpts.rows then		
			if self.tblConfigOpts.accessRow(row).visible then
				self.tblConfigOpts.accessRow(row).selected := true;
				self.tblConfigOpts.topRow := row;
				return;
			endif;
		endif;
		
	endforeach;

epilog

end;</source>
        <Parameter name="_attributeName" type="String"/>
        <Parameter name="_shtName" type="String"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="605d91bd-7425-4b8e-b6dc-402d12abdd68">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 29 February 2024 10:23:07.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0011548, locale);
	btnAlternate.translateBubbleHelp(Xlat_0019388, locale);
	btnAlternate.translateCaption(Xlat_0019389, locale);
