    <JadeMethod name="cmbOperation_click" id="71ec2e2b-9814-405e-8dfe-44c43445889c">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOperation_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 September 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	machineId		: String;
	
begin
	machineId := self.txtMachine.text.trimBlanks;
	if machineId &lt;&gt; null then
		self.txtInput.text := machineId;
	endif;
	
	if self.cmbOperation.text = 'Logon' then
		self.txtInput.text := self.txtInput.text &amp; ',' &amp; self.txtUser.text;
	endif;
	

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doGenScriptCode" id="6a9b3c68-e343-4daa-a6ea-62a4d5f6a50d">
        <source>doGenScriptCode() protected;

/*

Purpose:			Generate JadeScript code to populate the driver scripts from the 
					current selections


Return Value:		None


Date		Who		Reason
09 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	script,
	line,
	operationName,
	tcpMessage		: String;
	len,
	pos				: Integer;
	
begin
	if not validateSelection(operationName, tcpMessage) then
		return;
	endif;

	txtOutput.text := null;
	script := null;
	script := script &amp; Tab &amp; Tab &amp; "// " &amp; operationName &amp; CrLf;
	script := script &amp; Tab &amp; Tab &amp; "create payload;" &amp; CrLf;
	script := script &amp; Tab &amp; Tab &amp; "payload.myTCPSessionScript	:= session;" &amp; CrLf;
	script := script &amp; Tab &amp; Tab &amp; "payload.operationName		:= '" &amp; operationName &amp; "';" &amp; CrLf;
	script := script &amp; Tab &amp; Tab &amp; "payload.message				:= '" &amp; tcpMessage &amp; "';";
	
	txtOutput.text := script;
	
	app.copyStringToClipboard(script);
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSendRawInput" id="c026ce4f-8445-4842-aeed-a43c634135ae">
        <source>doSendRawInput() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	self.sendTCPString(self.txtInput.text);
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSendTCPMessage" id="465d68ca-641b-4106-a042-20c03101f0fb">
        <updating/>
        <source>doSendTCPMessage() protected, updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
09 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	message			: TCPMessagePayload;
	operationName,
	tcpMessage		: String;
	
begin
	if not self.validateSelection(operationName, tcpMessage) then
		return;
	endif;
	
	create message transient;
	message.operationName := operationName;
	message.message := tcpMessage;
	
	self.sendTCPMessage(message);
	
	
epilog
	delete message;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="9f7b246f-d8dc-4a0f-bf20-7c86c49d699b">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
18 December 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars

begin
	txtHostname.text 	:= TestAppControl.DEFAULT_HOSTNAME;
	txtPort.text		:= TestAppControl.DEFAULT_PORT.String;
	
	self.loadOperations();
	
	self.setDefaults();
	
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadOperations" id="348698dc-cbf2-4a0c-85a9-d9481350eced">
        <source>loadOperations() protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
09 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	
begin
	cmbOperation.clear;
	
	cmbOperation.addItem(Operation_Initialise);
	cmbOperation.addItem(Operation_Logon);
	cmbOperation.addItem(Operation_Logoff);
	cmbOperation.addItem(Operation_SendFaultResponse);
	cmbOperation.addItem(Operation_NextJob);
	cmbOperation.addItem(Operation_Reject);
	cmbOperation.addItem(Operation_Pickup);
	cmbOperation.addItem(Operation_ValidateMove);
	cmbOperation.addItem(Operation_ValidateDischarge);	//30 Mar 2011	NDL	Par 27290
	cmbOperation.addItem(Operation_ValidateCraneQueue);	//30 Mar 2011	NDL	Par 27290
	cmbOperation.addItem(Operation_GetDestination);
	cmbOperation.addItem(Operation_SetDown);
	cmbOperation.addItem(Operation_Swap);
		
		
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="logMessage" id="dc4935ee-3ce6-458f-bd40-899f66f01ad4">
        <source>logMessage(msg: String);

/*

Purpose:			


Return Value:		


Date		Who		Reason
18 December 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	inheritMethod(msg);
	
	txtOutput.text := txtOutput.text &amp; CrLf &amp; app.actualTimeServer.time.displayWithMilliseconds &amp; " " &amp; msg;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	txtOutput.refreshNow;
	

epilog

end;</source>
        <Parameter name="msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="setDefaults" id="d2c3a1aa-10a4-4ef0-9730-48d30b491200">
        <updating/>
        <source>setDefaults() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	self.txtUser.text := app.userName.toUpper;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateSelection" id="528e4a96-ac7b-45fe-8631-735db27c5729">
        <source>validateSelection(operationName,
				  tcpMessage : String io) : Boolean protected;

/*

Purpose:			Check the input values are populated, and pass them back in the
					io parameters


Return Value:		True if the values are correct, false otherwise


Date		Who		Reason
09 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	
begin
	operationName := cmbOperation.text.trimBlanks;
	if operationName = null then
		cmbOperation.setFocus;
		app.msgBox("Operation must be selected", "Error", MsgBox_OK_Only);
		return false;
	endif;
	
	tcpMessage := txtInput.text.trimBlanks;
	
	return true;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="operationName" type="String" usage="io"/>
        <Parameter name="tcpMessage" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
