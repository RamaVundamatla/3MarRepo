<Class name="CM_LocationDiscrepancy" id="4b4105d3-dbe4-48e3-a3f3-820b97894e7f">
    <superclass name="CM_Discrepancy"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="discrep"/>
    <ExplicitInverseRef name="terminalArea" id="b2604894-fe73-43ab-b401-ebc377b5bfd1">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_TerminalArea"/>
        <access>readonly</access>
        <Inverse name="CM_TerminalArea::discrepancies"/>
    </ExplicitInverseRef>
    <JadeMethod name="updateForCreate" id="55b4663d-1d20-4497-ab83-2d6ea75137de">
        <updating/>
        <source>updateForCreate(ta : CM_TerminalArea; txt : String; term : CM_Terminal input; ts : TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:     12 February 2001 by cnwdwq1
//
// Purpose: 
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.internalText := txt;
	self.terminalArea := ta;
	self.date := ts;
	self.terminal := term;
	//We want an automatic inverse here at some point.
	//We will have to change the dict on terminal from a date/array to a date dict
	//only. A big re-org. DQ 12/2/2001
	term.addDiscrepancy(self);
	
end;</source>
        <Parameter name="ta" type="CM_TerminalArea"/>
        <Parameter name="txt" type="String"/>
        <Parameter name="term" type="CM_Terminal" usage="input"/>
        <Parameter name="ts" type="TimeStamp"/>
    </JadeMethod>
</Class>
