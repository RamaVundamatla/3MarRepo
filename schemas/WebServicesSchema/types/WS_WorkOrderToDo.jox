    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="toDoTaskOid" id="0d1617e0-0073-4864-88f0-d871ec5c19d2">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="createProxyWorkOrder" id="76cfb73c-a174-457f-9f2e-0aa726d7a354">
        <source>createProxyWorkOrder(): CM_WorkOrderTIDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2018	jlger1	Initial creation

*/

vars

	pxyWorkOrder : CM_WodToDo;
	
begin
	create pxyWorkOrder transient;

	
	return pxyWorkOrder;

epilog

end;</source>
        <ReturnType type="CM_WorkOrderTIDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="b9d8151d-afca-4190-a154-ef0ae7f4ffd3">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodToDo) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlger1	Initial creation 38520
11 Apr 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
*/

vars
	
begin
	inheritMethod(_object);
	/*
	//11.4.2023 navhl20	#56614[56615]
	if _object.myToDoTaskDesc &lt;&gt; null then
		self.toDoTaskOid := _object.myToDoTaskDesc.getOidAsString;
	endif;*/
	self.setProxyToDoTasks(_object);									//11.4.2023 navhl20	#56614[56615]
epilog

end;</source>
        <Parameter name="_object" type="CM_WodToDo"/>
    </JadeMethod>
    <JadeMethod name="setProxyToDoTasks" id="106e7f4e-85df-49dd-bf2b-a7b7273dd953">
        <source>setProxyToDoTasks(_object: CM_WodToDo);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2023	navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
*/

vars
	todoDesc 	: CM_ToDoTaskDesc;
	wsTodo 		: WS_ToDoTaskDesc;
begin
	foreach todoDesc in _object.allToDoTasksDescs do
		create wsTodo transient;
		wsTodo.setProxyFromObject(todoDesc);
		self.allToDoTasks.add(wsTodo);
	endforeach;
epilog

end;</source>
        <Parameter name="_object" type="CM_WodToDo"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="be6ed45e-8328-4cd4-a4c0-b503e3d6a994">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WorkOrderTIDtl input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2018	jlger1	Initial creation
11 Apr 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
*/

vars
	todoSet 	: CM_ToDoTaskDescSet;
	todoDesc 	: CM_ToDoTaskDesc;
	wsTodo 		: WS_ToDoTaskDesc;
	passport	: CM_Passport;
begin
	inheritMethod(_pxyWorkOrder);
	/*
	//11.4.2023 navhl20	#56614[56615]
	todo:= app.myPassport.getObjectOfTypeFromOid(self.toDoTaskOid,CM_ToDoTaskDesc).CM_ToDoTaskDesc;
	if todo &lt;&gt; null then
		_pxyWorkOrder.CM_WodToDo.setProxyWodToDo(todo);
	endif;*/
	
	passport := app.myPassport;																				//10.4.2023 navhl20	#56614:[56615]
	
	create todoSet transient;																				//10.4.2023 navhl20	#56614:[56615]

	foreach wsTodo in self.allToDoTasks do																	//10.4.2023 navhl20	#56614:[56615]
		todoDesc := passport.getObjectOfTypeFromOid(wsTodo.cmObjectId,CM_ToDoTaskDesc).CM_ToDoTaskDesc;
		if todoDesc &lt;&gt; null then
			todoSet.addNoDuplicates(todoDesc,false);
		endif;
	endforeach;
	
	_pxyWorkOrder.CM_WodToDo.allToDoTasksDescs.clear();														//10.4.2023 navhl20	#56614:[56615]
	todoSet.copyNoDuplicates(_pxyWorkOrder.CM_WodToDo.allToDoTasksDescs,false);								//10.4.2023 navhl20	#56614:[56615]
epilog
	delete todoSet;
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrderTIDtl" usage="input"/>
    </JadeMethod>
</Class>
