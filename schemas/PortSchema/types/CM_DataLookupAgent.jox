    <JadeMethod name="resolveCarrier" id="351e68c5-5cd6-41b2-aa45-1d562b26229b">
        <source>resolveCarrier(_property : String; _key: String): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2026	naviv1	Initial creation

*/

vars

begin
	 if _key = null or _key = "" then
        return null;
    endif;
	if _property = CM_Carrier::myDebtor.name then
		return app.myRoot.allDebtors[_key];
	elseif _property = CM_Carrier::allDataAccessControllersRec.name then
		return app.myRoot.allDataAccessControllers[CM_Carrier.name,_key];
	elseif _property = CM_Carrier::allDataAccessControllersRel.name then
		return app.myRoot.allDataAccessControllers[CM_Carrier.name,_key];
	endif;
    return null;
epilog

end;</source>
        <Parameter name="_property" type="String"/>
