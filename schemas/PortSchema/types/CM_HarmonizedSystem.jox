    <JadeMethod name="getDisplayString" id="579220cb-e9a7-49e6-ad87-d5b0ebbd1ca8">
        <source>getDisplayString() : String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 09 December 2022
TFS#		: 55590
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

constants
	MaxLength =  100;
vars
	display : String;
begin
	
	display:= self.id &amp; Space &amp; Hyphen &amp; Space &amp; self.description[1:MaxLength];
	
	if self.description.length &gt; MaxLength then
		display:=display &amp; "...";
	endif;
	return display;
	
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="0684ad0f-a31b-4608-a620-916f63fe01b4">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes
26/02/2023				navkc1 	CR 59577 Task 62412: UI - HS Code Sys Admin
*/

vars

begin
	if _attrName = ETRow_Type then
		return app.getErrorString(HS_Unknown);
		
	elseif _attrName = ETRow_HeadingDescription then
		return null;
		
	elseif _attrName = ETRow_HsCode then
		return self.id;
		
	elseif _attrName = ETRow_HsCodeDescription then
		if self.description.length &gt; 50 then
			return self.description[1:50] &amp; "...";
		else
			return self.description;
		endif;
	elseif _attrName = ETRow_UnitQuantity then
		return null;
	elseif _attrName = ETRow_ExternalRef1 then
		return null;
	elseif _attrName = ETRow_ExternalRef2 then
		return null;
	elseif _attrName = ETRow_ExternalRef3 then
		return null;
	elseif _attrName = ETRow_HsParentSection then
		return null;
	elseif _attrName = ETRow_HsParentChapter then
		return null;
	elseif  _attrName = ETRow_HsParentHeading then
		return null;
	elseif _attrName = ETRow_HsParentCode then
		return null;
	elseif _attrName = ETRow_HsParentSubCode then //26/02/2023	navkc1 CR 59577 Task 62412
		return null;
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
