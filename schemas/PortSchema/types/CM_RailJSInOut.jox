    <JadeMethod name="getAllWLEs" id="6f25780f-c0b2-4f2f-8155-922897612013">
        <source>getAllWLEs(_wleArray: CM_WLEArray input);
//--------------------------------------------------------------
//Created: 26 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	railJSInOutRake : CM_RailJSInOutRake;
begin
	inheritMethod(_wleArray);

	foreach railJSInOutRake in self.inoutRakes do
		railJSInOutRake.getAllWLEs(_wleArray);
	endforeach;
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
