    <JadeMethod name="getToDoTasksSys" id="a822976f-8e94-4754-9ded-de378f69f385">
        <source>getToDoTasksSys(_cargoType : CM_CargoType; _allTaskDict	: CM_ToDoTaskDescByCode input) ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2008	cnwrd1	Initial creation

*/

vars
	//taskDict, allTaskDict	: CM_ToDoTaskDescByCode;
	taskDict	: CM_ToDoTaskDescByCode;
	ut			: CM_UserTerminal;
	user		: CM_User;
	task		: CM_ToDoTaskDesc;
begin

//create allTaskDict transient;

	foreach ut in self.allUserTerminals do
		delete taskDict; //epr TFS 3581 6/3/17 leaking transients
		create taskDict transient;
		app.myPassport.myUser.getToDoTasksAddRemoveForTerm(ut.myTerminal, taskDict);
		
		foreach task in taskDict do
			if not _allTaskDict.includes(task) then
				if _cargoType.allToDoTaskDescs.includes(task) then
					_allTaskDict.add(task);
				endif;
			endif;
		endforeach;		
	endforeach;

	//return allTaskDict;
epilog
	delete taskDict;
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_allTaskDict" type="CM_ToDoTaskDescByCode" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getUseAppSkinMetro" id="b2a73440-3c74-489c-a965-b054e4a30248">
        <source>getUseAppSkinMetro() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2013	cnwmc5	Initial creation

*/

vars
	skin 				: String;
	isUsingSkinMetro 	: Boolean;
	
begin
	isUsingSkinMetro := false;
	
	skin := self.getStateData(ConfigGrp_System, UserAppSkins).String;
	
	if skin[1:8] = "JMTMetro" then
		isUsingSkinMetro := true;
	endif;
	
	return isUsingSkinMetro;
end;</source>
