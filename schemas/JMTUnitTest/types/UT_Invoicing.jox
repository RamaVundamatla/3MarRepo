    <JadeMethod name="verifyDebtorSepAttributes" id="006856a1-a1f4-4c4e-84ce-9584e557017d">
        <source>verifyDebtorSepAttributes(realInvTypeDebtorSeparation, proxyInvTypeDebtorSeparation : CM_InvTypeDebtorSeparation; title : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2023 navmv20 TFS 56995 Task 57223: Jade - Invoice Debtor Separation Unit Tests

*/

vars
	
begin

	self.assertTrueMsg(realInvTypeDebtorSeparation.myDebtor &lt;&gt; null, "myDebtor Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.mySurchargesAndExemptions &lt;&gt; null, "mySurchargesAndExemptions Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realInvTypeDebtorSeparation.myDebtor.name = proxyInvTypeDebtorSeparation.myDebtor.name, title &amp; "myDebtor Expected: '" &amp; proxyInvTypeDebtorSeparation.myDebtor.name &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.myDebtor.name &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.mySurchargesAndExemptions = proxyInvTypeDebtorSeparation.mySurchargesAndExemptions, "mySurchargesAndExemptions Objects References do not match");
	
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByBillOfLading = proxyInvTypeDebtorSeparation.separatedByBillOfLading, title &amp; "separatedByBillOfLading Expected: '" &amp;  proxyInvTypeDebtorSeparation.separatedByBillOfLading.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByBillOfLading.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByBooking = proxyInvTypeDebtorSeparation.separatedByBooking, title &amp; "separatedByBooking Expected: '" &amp; proxyInvTypeDebtorSeparation.separatedByBooking.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByBooking.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByCargoGroupId = proxyInvTypeDebtorSeparation.separatedByCargoGroupId, title &amp; "separatedByCargoGroupId Expected: '" &amp; proxyInvTypeDebtorSeparation.separatedByCargoGroupId.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByCargoGroupId.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByCargoId = proxyInvTypeDebtorSeparation.separatedByCargoId, title &amp; "separatedByCargoId: Expected '" &amp; proxyInvTypeDebtorSeparation.separatedByCargoId.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByCargoId.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByReleaseRequest = proxyInvTypeDebtorSeparation.separatedByReleaseRequest, title &amp; "separatedByReleaseRequest Expected: '" &amp; proxyInvTypeDebtorSeparation.separatedByReleaseRequest.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByReleaseRequest.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByVoyage = proxyInvTypeDebtorSeparation.separatedByVoyage, title &amp; "separatedByVoyage Expected: '" &amp; proxyInvTypeDebtorSeparation.separatedByVoyage.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByVoyage.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByVoyageGroup = proxyInvTypeDebtorSeparation.separatedByVoyageGroup, title &amp; "separatedByVoyageGroup Expected: '" &amp; proxyInvTypeDebtorSeparation.separatedByVoyageGroup.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByVoyageGroup.asStringJMT() &amp; "'");
epilog

end;</source>
