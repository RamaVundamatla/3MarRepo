    <JadeMethod name="getOperator" id="7df46318-a8f2-478b-82ca-749821df11c4">
        <source>getOperator() : CM_Operator;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2018	jlger1	Initial creation

*/

vars
operator : CM_Operator;
	translatedCode : String;
	found : Boolean;

begin

	operator := app.myRoot.allOperators[ self.npwp ]; //epr TFS 44657 9/5/19 replaced perusahaanNama 
		
	if operator = null then
		 //epr TFS 44657 9/5/19 replaced perusahaanNama 
		translatedCode := app.myRoot.getXlationSystemCode(  self.npwp, XLATION_TYPE_OPERATOR, found );
		if found then
			operator := app.myRoot.allOperators[ translatedCode ];
		endif;
	endif;
	
	return operator;

epilog

end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
