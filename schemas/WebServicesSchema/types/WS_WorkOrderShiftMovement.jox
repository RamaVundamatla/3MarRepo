    <JadeMethod name="setProxyFromObject" id="e1da1125-a66e-47f0-a520-b4a36e196341">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodShiftMovement) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jun 2018	jlger1	Initial creation
08 Dec 2018 jlger1	TFS 42253 - for shift it was getting wrong resources
10 Jan 2021	navma1  ChangeRequest 52510: SAL - Web Portal - Berth display in Cargo Request
*/

vars
	wodVoyageCargoRequest : CM_WodVoyageCargoRequest;
	marineServiceDetail   : CM_WodMarineServiceDetail;
	wsHMSResourceUsed 	  : WS_HMSResourceUsed;
	voyage 				  : CM_Voyage;
	towedVoyageData 	  : HMS_VoyageData;
	towedVoyage 		  : CM_Voyage;
	towedWoShift 		  : CM_WodShiftMovement;
	processHarbour 		  : CM_ProcessHarbour;
	cargoBerth 			  : HMS_Berth;
begin
	inheritMethod(_object);
	
	self.bowMarkTo				  := _object.bowMarkTo;
	self.draftAft				  := _object.draftAft;
	self.draftFwd				  := _object.draftFwd;
	self.occursOnDT				  := _object.occursOnDT.asStringForWebInterface;
	self.relativeOrderTimeLines   := _object.relativeOrderTimeLines;
	self.relativeOrderTimePlaunch := _object.relativeOrderTimePlaunch;
	self.relativeOrderTimeTugs	  := _object.relativeOrderTimeTugs;
	self.hasRamp 				  := _object.hasRamp; 								// TFS 40236
	self.starboardBerthed 		  := _object.starboardBerthed; 						// TFS 40236
	self.berthArrival 			  := _object.berthArrival.asStringForWebInterface;	//26 Oct 2018	NDL	TFS 41413
	
	if _object.myToBerth &lt;&gt; null then
		self.toBerthOid:=_object.myToBerth.getOidAsString;
	endif;
	
	//16 Oct 2018	NDL	TFS 41410
	voyage := _object.getMyVoyageObject();
	
	//self.allowUpdateOfShiftBerth := true;						10.01.2022 navma1 #52510
	
	if voyage &lt;&gt; null then
		//epr TFS 42248 29/11/18
	
		if not voyage.allTowedVoyages.isEmpty then
			
			//self.allowUpdateOfShiftBerth := false;			10.01.2022 navma1 #52510
			
			towedVoyageData := voyage.allTowedVoyages.first;
			if towedVoyageData &lt;&gt; null then
				towedVoyage := towedVoyageData.myVoyage;
			endif;
			if towedVoyage &lt;&gt; null then
				towedWoShift := towedVoyage.allWorkOrders.getWorkOrderDetailOfType( WO_TASK_SHIFTMOVEMENT ).CM_WodShiftMovement;
			endif;
			if towedWoShift = null then
				self.toBerthOid := null;
				self.occursOnDT := null;
			else
				if towedWoShift.myToBerth &lt;&gt; null then
					self.toBerthOid := towedWoShift.myToBerth.getOidAsString;
				endif;
				self.occursOnDT := towedWoShift.requiredByDT.asStringForWebInterface;
			endif;
		endif;
		
		
		processHarbour := voyage.myVoyageProcess.allProcessHarbours[voyage.myVoyageProcess,voyage.myTerminal.myHarbour];
		
		if processHarbour &lt;&gt; null then
			foreach marineServiceDetail in  _object.allMarineServiceDetails discreteLock do
				
				if processHarbour.allHMSResourcesForShift.includes(marineServiceDetail.myHMSResource) then
					create wsHMSResourceUsed transient;
					wsHMSResourceUsed.setProxyFromMarineService(marineServiceDetail);
					self.allHMSResourcesUsed.add(wsHMSResourceUsed);
				endif;
			endforeach;
		endif;
	endif;	
	
	if _object.myTowingVoyage &lt;&gt; null then
		self.towingVoyage := _object.myTowingVoyage.getOidAsString;
	endif;
	
	//epr TFS 41880 13/11/18
	if self.canEdit then
		self.canEdit:=false;
		
		//epr TFS 42396 13/12/18
		//if its at a logical or private berth or the cargo requests berth then ok to edit	
		wodVoyageCargoRequest := voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL).CM_WodVoyageCargoRequest;
		
		if wodVoyageCargoRequest &lt;&gt; null then
			cargoBerth:=wodVoyageCargoRequest.myBerth;
		endif;
		
		if _object.myToBerth &lt;&gt; null then
			if _object.myToBerth.isLogicalBerth or
				not _object.myToBerth.requiresLengthOfTime or
				_object.myToBerth = cargoBerth then  //private berth tfs 42396
					self.canEdit := true;				
			endif;
		endif;
		
		//still can't edit then must have a complete permit
		if not self.canEdit and  _object.myRelatedPermitRequest &lt;&gt; null then	
			self.canEdit:= _object.myRelatedPermitRequest.isComplete;		
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_WodShiftMovement"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="6efeb90e-879a-465e-8237-58a9474f239a">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WodShiftMovement input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2018	jlger1	Initial creation
01/10/2021	jlier1	TFS 51963 - changes voyage process
*/

vars
	berthTo : HMS_Berth;
	pxyResourceUsed : HMS_ResourceUsed;
	wsHMSResourceUsed : WS_HMSResourceUsed;
	allPxyHMSResourcesUsed : HMS_ResourceUsedSet;
	voyage,
	myTowingVoyage 	: CM_Voyage;
	voyageStatus  	: CM_VoyageStatus;
	hmsResource 	: HMS_Resource;
begin
	inheritMethod(_pxyWorkOrder);
	
	self.validateDateIsDuringVoyage( self.voyage, self.requiredByDT.asTimeStampFromWebInterface );	//28 Sep 2018	NDL	TFS 41148
	self.validateDateIsDuringVoyage( self.voyage, self.occursOnDT.asTimeStampFromWebInterface );	//28 Sep 2018	NDL	TFS 41148
	
	if self.toBerthOid &lt;&gt; null then
		berthTo := app.myPassport.getObjectOfTypeFromOid(self.toBerthOid,HMS_Berth).HMS_Berth;
	endif;
	
	if self.towingVoyage &lt;&gt; null then
		myTowingVoyage:=app.myPassport.getObjectOfTypeFromOid(self.towingVoyage,CM_Voyage).CM_Voyage;
	endif;
	
	_pxyWorkOrder.setProxyWodShiftMovement( self.bowMarkTo,
											self.draftAft,
											self.draftFwd,
											self.occursOnDT.asTimeStampFromWebInterface,
											self.relativeOrderTimeLines,
											self.relativeOrderTimePlaunch,
											self.relativeOrderTimeTugs,
											null,
											null,
											berthTo,
											null,
											myTowingVoyage,
											self.hasRamp,self.starboardBerthed, // TFS 40236
											self.berthArrival.asTimeStampFromWebInterface	//_berthArrivalDT : TimeStamp 26 Oct 2018	NDL	TFS 41413
											);
	
	
	voyage:= _pxyWorkOrder.myParent.getMyVoyageObject;

	if voyage.myVoyageProcess.isMTNWOProcess then //jlier1 TFS 51963 1/10/21
		voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_DepServPending];
	endif;	
	
	
	create allPxyHMSResourcesUsed transient;
	if voyageStatus &lt;&gt; null then
		foreach wsHMSResourceUsed in self.allHMSResourcesUsed discreteLock do
			create pxyResourceUsed transient;
			wsHMSResourceUsed.setProxyHMSResorceUsed(pxyResourceUsed);
			if pxyResourceUsed.myResource = null and pxyResourceUsed.myResourceType &lt;&gt; null then
				foreach hmsResource in voyageStatus.allHMSResourcesAllowed do
					if hmsResource.myHarbour &lt;&gt; voyage.myHMSVoyageData.myHarbour then
						continue;
					endif;
			
					if hmsResource.myResourceType = null or hmsResource.myResourceType.isNotAvailableForEntry or
						hmsResource.myResourceType.isMarineService then
						continue;
					endif;
					if hmsResource.myResourceType = pxyResourceUsed.myResourceType then
						pxyResourceUsed.setMyResource(hmsResource);
						break;
					endif;
				endforeach;
			endif;
			allPxyHMSResourcesUsed.add(pxyResourceUsed);		
		endforeach;
	endif;

	
	_pxyWorkOrder.setMarineDetsFromResourceUsed(allPxyHMSResourcesUsed);


epilog
	if allPxyHMSResourcesUsed &lt;&gt; null then
		allPxyHMSResourcesUsed.purge;
	endif;
	delete allPxyHMSResourcesUsed;
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WodShiftMovement" usage="input"/>
    </JadeMethod>
</Class>
