    <JadeMethod name="moveCargo" id="65aff136-80ed-4898-a658-6fd7a83c854b">
        <source>moveCargo(_ti : CM_TrackedItem; _tiSet : CM_TISet; _toLocation : CM_LocationsController; _passport : CM_Passport input);
/*

Purpose:			Moves a cargo item to its destination

Parameters:			_ti			CM_TrackedItem			The primary tracked item to move
					_tiSet		CM_TISet				The tiSet (optional) of tracked items to move
					_toLocation	CM_LocationsController	The destination locations controllers
					_passport	CM_Passport				The passport to hold all the errors and warnings

Return Value:		NONE

Date		Who		Reason
08 December 2022	navpw1	Initial creation TFS: 54571

*/

vars
	cmifMoveController : CMIF_MoveController;
	
begin
	create cmifMoveController transient;
	cmifMoveController.isForcedMove := true;
	cmifMoveController.isSystemMove := true;
	cmifMoveController.setMyTrackedItem(_ti);
	if _tiSet &lt;&gt; null and not _tiSet.isEmpty then
		cmifMoveController.setAllOtherTrackedItems(_tiSet);
	endif;
	cmifMoveController.allOtherTrackedItems.tryRemove(_ti);
	cmifMoveController.setMyToPrimaryLocation(_toLocation);
	app.myTrxUA.trxMoveTrackedItem(cmifMoveController, _passport);
	
epilog
	delete cmifMoveController;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="moveCargoForVoyageJob" id="401682a0-81ab-4107-887c-414c5854cf0b">
        <source>moveCargoForVoyageJob(_job: CM_Job; _mode: Integer);
vars
	ya : CM_YardAllocation;
	bs : CM_TerminalArea;
	jobSheet : CM_JobSheet;
	job:CM_Job;
	req : CM_Request;
	wle : CM_WorkListEntry;
	location : CM_LocationsController;
	wlesToMove, wlesWithWarnings : CM_WLEArray;
	completedDate : TimeStamp;
	sleep, idx: Integer;
	q : CM_VoyageQueue;
begin
	job := _job;
	create wlesToMove transient;
	create wlesWithWarnings transient;
	
	if job.CM_VoyageJob.isHatchLidJob() then
		return;
	endif;
	foreach wle in job.workListEntries discreteLock do
		wlesToMove.clear();
		wlesWithWarnings.clear();
		wlesToMove.add(wle);
		app.myPassport.warningsAcknowledged	:= true;	// stop 'No planned location, want to autoplan' warning and do the autoplan instead
		app.myPassport.setWarningsIgnored(true);
		app.myTrxUA.trxUpdateWLEsDoMove(wlesToMove, wlesWithWarnings, _mode, true,null, app.myPassport);
	//	self.assertNoTrxErrorsOrWarnings();	// some invoicing wles may not complete, don't really care
		self.assertTrueMsg(wlesWithWarnings.isEmpty(), "Not all jobs completed &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
		idx := idx + 1;
		
		if self.getTerminal() &lt;&gt; null and self.getTerminal().code = "BISH" then
			if idx &gt; 30 then
				break;
			endif;
		endif;
	endforeach;
	
	if idx = job.workListEntries.size then
	beginTransaction;
	job.CM_VoyageJob.updateActualAndEndTs(completedDate);
	commitTransaction;
	endif;
	
epilog
	delete wlesToMove;
	delete wlesWithWarnings;
	app.myPassport.warningsAcknowledged	:= false;	// reset after setting above
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="moveCargoForVoyageJobExtra" id="6582069c-1c5d-42d5-a72a-726671c0c328">
        <source>moveCargoForVoyageJobExtra(_job: CM_Job);
vars
begin

epilog
end;</source>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="moveDirector" id="6ab7be05-d57f-4917-ba49-253859cc783b">
        <source>moveDirector(	_id: String;
				_totalRequested: Integer;
				_operatorCode: String; 
				_isoTypeCode: String;
				_sourceTA: Any;
				_sourceBays: CM_GridObjectArray;
				_targetTA: CM_TerminalArea
				) : CM_YardDeliveryRequest;
				
/****Changes

Date		Name	TFS#			Description
============================================================================
02/02/2011	cnwdw1					Create a queued director task
03/10/2018	jlgka1	40698			Add "heavyRated" in method call 
									setProxyYardDelivery as a result of changes
									in that method.
3 Nov 2022 	navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request									
============================================================================*/
vars
	proxyJob 		: CM_YardInternalJob;
	proxyRequest 	: CM_YardDeliveryRequest;
	allAvGrades 	: IntegerArray;
	sourceTA		: CM_TerminalArea;
	job 			: CM_Job;
	request 		: CM_YardDeliveryRequest;
	release 		: CM_BulkRelease;
	reserveDetail 	: CM_ReserveDetail;
	heavyRated		: Boolean; // jlgka1 TFS# 40698
	updSubTerm 		: CM_SubTerminal;
	isAvail			: Boolean;
begin

	self.deleteYardJob(_id);
	
	if _sourceTA.isKindOf(CM_TerminalArea) then
		sourceTA := _sourceTA.CM_TerminalArea;
	endif;
	
	if self.opts.includesKey("Release") then
		release := self.opts.obj("Release").CM_BulkRelease;
		heavyRated := release.getHeavyDuty().asBooleanJMT();
	endif;
	if self.opts.includesKey("ReserveDetail") then
		reserveDetail := self.opts.obj("ReserveDetail").CM_ReserveDetail;
		heavyRated := reserveDetail.getHeavyRated();
	endif;
	
	//Start 9.11.2022	navhl20 TFS 52721
	if self.opts.includesKey("SubTerminal") then
		updSubTerm := self.opts.obj("SubTerminal").CM_SubTerminal;
	endif;
	if self.opts.includesKey("IsAvail") then
		isAvail := self.opts.bool("IsAvail");
	endif;
	//End 9.11.2022	navhl20 TFS 52721
	
	create proxyJob transient;
	proxyJob.setProxyYardDelivery(_id, self.getTerminal);
	proxyJob.setPriority(3);
	create allAvGrades transient;

	create proxyRequest transient;
	proxyRequest.setProxyYardDelivery(	_isoTypeCode,
										_operatorCode,
										"",
										_targetTA.id,
										app.getMyUserCode(),
										false,
										false,
										null,
										proxyJob,
										allAvGrades,
										_totalRequested,
										null,
										null,
										sourceTA,
										null, //source grid object ccms 2098
										null,
										self.getTerminal.getDefaultSubTerminalForRel(BR_TYPE_ROAD),
										release,
										reserveDetail,
										null,
										null,
										heavyRated,
										updSubTerm,	//3.11.2022	navsks20 TFS 52721
										isAvail);	//3.11.2022	navsks20 TFS 52721
	proxyRequest.setMTCommodity();
	if _sourceTA.isKindOf(CM_TerminalAreaArray) then
		proxyRequest.setNominatedTAs(_sourceTA.CM_TerminalAreaArray, _sourceBays);
	endif;
	
	app.myTrxCA.trxCreateYardInternalDeliveryR(proxyJob, job, proxyRequest, request, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return request;
	
epilog
	delete allAvGrades;
	delete proxyRequest;
	delete proxyJob;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_totalRequested" type="Integer"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_isoTypeCode" type="String"/>
        <Parameter name="_sourceTA" type="Any"/>
        <Parameter name="_sourceBays" type="CM_GridObjectArray"/>
        <Parameter name="_targetTA" type="CM_TerminalArea"/>
        <ReturnType type="CM_YardDeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="moveIT" id="5b2546fb-d4f1-45d2-a4c6-30874ac4d1f4">
        <source>moveIT(_ti : CM_TrackedItem; _mode : Integer);
/*
Purpose:			
Date		Who		Reason
26 March 2014	NAVAB1	Initial creation
*/

vars
	wle : CM_WorkListEntry;
	wles : CM_WLEArray;
	warnings : CM_WLEArray;
	fm : CM_FutureMove;
	idx : Integer;
begin

	if _ti = null then
		return;
	endif;

	if _mode = 0 then
		fm := _ti.getFutureMoveOfType(QUEUE_MODE, TI_FutureMoveQueued);
		if fm = null then
			fm := _ti.getFutureMoveOfType(PLANNING_MODE, TI_FutureMovePlanned);
		endif;
	elseif _mode = QUEUE_MODE then
		fm := _ti.getFutureMoveOfType(QUEUE_MODE, TI_FutureMoveQueued);
	elseif _mode = PLANNING_MODE then
			fm := _ti.getFutureMoveOfType(PLANNING_MODE, TI_FutureMovePlanned);
	endif;
	
	self.assertTrueMsg(fm &lt;&gt; null, "FM is null.");

	wle := fm.myWorkListEntry;
	self.assertTrueMsg(wle &lt;&gt; null, "WLE is null.");
	
	create wles transient;
	create warnings transient;
	wles.add(wle);
	
	
	while true do
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		app.myTrxUA.trxUpdateWLEsDoMove(wles, warnings, REAL_MODE, true,null, app.myPassport);
		
		idx := idx + 1;
		if warnings.isEmpty()
		or idx &gt; 5 then
			break;
		endif;
	endwhile;
epilog
	delete warnings;
	delete wles;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="moveOffsite" id="9e82400d-111b-4c63-9601-2dd21ee7d271">
        <source>moveOffsite(_ti: CM_TrackedItem);
//02 September 2008	cnwdw1	
// 02/08/2011	cnwmh5	Change so isForced can be passed via opts, change to use assertNoTrxErrorsOrWarnings
vars
	moveController	: CMIF_MoveController;
begin
	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyToPrimaryLocation(null);
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyOriginatingLocation(_ti.myPrimaryActualLocation);
	moveController.isNonCraneVoyageMove := true;
	
	
	if self.opts.includesKey("IsForcedMove") then					// 02/08/2011 cnwmh5
		moveController.isForcedMove := self.opts.bool("IsForcedMove");
	endif;
		
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();								// 02/08/2011 cnwmh5
	
epilog
	delete moveController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="movePlanned" id="ee1ebf8a-9c65-4d8a-b6e9-ad6ff8f8c0d1">
        <source>movePlanned(_ti: CM_TrackedItem; _destination: CM_LocationsController);
//02 September 2008	cnwdw1	
// 02/08/2011	cnwmh5	Change so isForced can be passed via opts, change to use assertNoTrxErrorsOrWarnings
vars
	moveController	: CMIF_MoveController;
	expectErrors : Boolean;
begin

	expectErrors := self.opts.bool("ExpectErrors");
	
	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyToPrimaryLocation(_destination);
	moveController.setMoveMode(PLANNING_MODE);
	
	if self.opts.includesKey("IsForcedMove") then					// 02/08/2011 cnwmh5
		moveController.isForcedMove := self.opts.bool("IsForcedMove");
	endif;
	
	if _destination.isWagon then	//17 Jul 2019	NDL	TFS 42876
		app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
	else
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	endif;
	if not expectErrors then
		self.assertNoTrxErrorsOrWarnings();								// 02/08/2011 cnwmh5 
	endif;
	
epilog
	delete moveController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_destination" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="movePlannedRequestToJob" id="aef497fc-9c80-484c-8757-5d1fc6f7723d">
        <source>movePlannedRequestToJob(	_ti : CM_TrackedItem; _targetLC : CM_LocationsController;
								_request : CM_Request);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	moveController : CMIF_MoveController;
begin
	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyToPrimaryLocation(_targetLC);
	moveController.setMoveMode(PLANNING_MODE);
	if _request.isKindOf(CM_VoyageRequest) then
		moveController.myVoyageRequest:=_request.CM_VoyageRequest;
	endif;
	if _request.isKindOf(CM_SlotRequest) then
		moveController.mySlotRequest:=_request.CM_SlotRequest;
	endif;
	
	
	app.myTrxUA.trxMoveTrackedItemAssignToJob(moveController, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete moveController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_targetLC" type="CM_LocationsController"/>
        <Parameter name="_request" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="movePlannedWLE" id="c0d49274-1fda-40bd-83e0-0b6334d10634">
        <source>movePlannedWLE(_ti: CM_TrackedItem; _destination: CM_LocationsController; _wle : CM_WorkListEntry);
//02 September 2008	cnwdw1	
// 02/08/2011	cnwmh5	Change so isForced can be passed via opts, change to use assertNoTrxErrorsOrWarnings
vars
	moveController	: CMIF_MoveController;
begin

	create moveController transient;
	moveController.isRehandleMove := _ti.isRehandle; // AKB ADDED
	moveController.isDLRLoadWithOutDischarge := _ti.isDLRLoadWithOutDischarge(); // AKB ADDED
	moveController.setMyTrackedItem(_ti);
	moveController.setMyToPrimaryLocation(_destination);
	moveController.setMoveMode(PLANNING_MODE);
	if self.opts.includesKey("IsForcedMove") then					// 02/08/2011 cnwmh5
		moveController.isForcedMove := self.opts.bool("IsForcedMove");
	endif;
	moveController.setMyWorkListEntry(_wle);
	
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();								// 02/08/2011 cnwmh5 
epilog
	delete moveController;
end;</source>
