    <JadeMethod name="doResizeControls" id="da5981da-a233-4e5a-a01d-b22a81c74910">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;
	folderHeight : Real;
	buttonWidth : Real;
	index : Integer;
	menuButton : MOB_Button;
	buttonHeight : Integer;
	buttonTop : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( 	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	folderHeight := self.clientHeight - cTop - self.getCMDButtonsHeight() - self.resizedMargin - self.resizedMargin;
	self.fldCargo.move(	self.resizedMargin,
						cTop,
						self.clientWidth - 4,
						folderHeight
						);
						
	if self.myBulkRelease.allReserveDetails.size &gt; 1 then
		if _initialSetup then
			self.cmbRelItems.visible := true;
			self.cmbRelItems.parent := self.shtSelectable;
		endif;
		self.cmbRelItems.move(	1,
								1,
								self.shtSelectable.width - self.resizedMargin,
								cHeight
								);
									
		self.frmSelectable.move(	1,
									self.cmbRelItems.top + self.cmbRelItems.height + self.resizedMargin,
									self.shtSelectable.width - self.resizedMargin,
									self.shtSelectable.height - cHeight - self.resizedMargin - self.resizedMargin
									);
	else
		if _initialSetup then
			self.cmbRelItems.visible := false;
		endif;
		self.frmSelectable.move(	1,
									1,
									self.shtSelectable.width - self.resizedMargin,
									self.shtSelectable.height - self.resizedMargin
									);
	endif;
	
	self.frmChosen.move(	1,
							1,
							self.shtChosen.width - self.resizedMargin,
							self.shtChosen.height - self.resizedMargin
							);
	
	cTop := cTop + self.fldCargo.height + self.resizedMargin;
	if _initialSetup then
		self.lblTotals.setAndIncrementTabIndex( tabIndex );
		self.lblTotals.visible := true;
	endif;
	self.lblTotals.move( 	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	if self.selectedCount &gt; 0 then
		buttonHeight := self.getScrollingButtonHeight();
		self.btnSelectTemp.height := buttonHeight;
		buttonWidth := self.getButtonWidthSetScrollBar( self.selectedCount, self.frmSelectable, self.btnSelectTemp.height, self.scrSelect );
		
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to self.selectedCount do
			menuButton := self.btnSelectTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnSelectTemp.fontSize;	//07 Apr 2015	NDL	Par 35990
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
	endif;
	
	self.btnDocActions.visible := false;
	if self.chosenCount &gt; 0 then
	
		//23 Sep 2016	NDL	TFS 2648 / 2001
		if not self.docActsToDisplay.isEmpty then
			cHeight := self.btnOne.height;
			self.frmChosen.height := self.frmChosen.height - self.resizedMargin - cHeight;
			cTop := self.frmChosen.height + self.resizedMargin;
			cLeft := self.resizedMargin;
			self.btnDocActions.parent := self.shtChosen;
			self.btnDocActions.visible := true;
			self.btnDocActions.move(	cLeft,
										cTop,
										self.btnOne.width,
										cHeight );
		endif;
		
		buttonHeight := self.getScrollingButtonHeight();
		self.btnChosenTemp.height := buttonHeight;
		buttonWidth := self.getButtonWidthSetScrollBar( self.chosenCount, self.frmChosen, self.btnChosenTemp.height, self.scrChosen );
	
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to self.chosenCount do
			menuButton := self.btnChosenTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnChosenTemp.fontSize;	//07 Apr 2015	NDL	Par 35990
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
		
	endif;
	
	self.lblNoCargoSel.move( 	self.resizedMargin,
								1,
								self.frmSelectable.width-2,
								stdHeight );
								
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findCargoInList" id="a0ed411e-4e3e-4a18-8a2f-82a9bcea1810">
        <updating/>
        <source>findCargoInList()protected, updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/10/2014	cnwndl1	Initial creation
10/03/2016	cnwdap1	PAR #37488 Allow search on alternaitive id as well as id
*/

vars

	altIdStr : String;	//08 Jul 2016	NDL	TFS 2275 / 2216
	cargoIdStr : String;	//08 Jul 2016	NDL	TFS 2275 / 2216
	buttonNumber : Integer;
	size : Integer;
	baseButton : MOB_Button;
	menuButton : MOB_Button;
	ti : CM_TrackedItem;
	scroll: ScrollBar;
	frame : MOB_Frame;
	value : Real;
	offset : Integer;
	
	buttonHeight : Integer;	//26 Apr 2016	NDL	TFS 1889

begin

	cargoIdStr := self.convertedCargoId;	//08 Jul 2016	NDL	TFS 2275 / 2216
	if cargoIdStr = null then
		return;
	endif;
	
	altIdStr := self.convertedAltId;	//08 Jul 2016	NDL	TFS 2275 / 2216
	
	if self.fldCargo.topSheet = self.shtSelectable then
		baseButton := self.btnSelectTemp;
		size := self.selectedCount;
		scroll := self.scrSelect;
		frame := self.frmSelectable;
	elseif self.fldCargo.topSheet = self.shtChosen then
		baseButton := self.btnChosenTemp;
		size := self.chosenCount;
		scroll := self.scrChosen;
		frame := self.frmChosen;
	endif;
	
	buttonHeight := self.getScrollingButtonHeight();	//26 Apr 2016	NDL	TFS 1889
	
	foreach buttonNumber in 1 to size do
		menuButton := baseButton.getControl( buttonNumber ).MOB_Button;
		if menuButton &lt;&gt; null then
		//	if buttonNumber = 1 then
		//		offset := menuButton.top.Integer; // in case its already scrolled
		//	endif;
			ti := menuButton.userObject.CM_TrackedItem;
			//if ti.id = text then												// PAR #37488
			if ti.id = cargoIdStr or ti.alternativeId = altIdStr then						// PAR #37488
			//	scroll.value := menuButton.top.Integer - offset;
				scroll.value := ( (buttonNumber - 1) * (buttonHeight + self.resizedMargin) );	//26 Apr 2016	NDL	TFS 1889
				self.setMenuScrollStart( scroll, baseButton, frame, size );
				menuButton.setFocus();
				return;
			endif;
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
