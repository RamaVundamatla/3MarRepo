    <ImplicitInverseRef name="myNibblerManager" id="f21fe9f5-fa21-439e-95ed-a772ce14a09e">
        <embedded/>
        <type name="JSSCTNibblerManager"/>
    </ImplicitInverseRef>
    <JadeMethod name="doCreate" id="6e22c736-6c85-47dd-b57b-4f6dc7b3b352">
        <updating/>
        <source>doCreate(): Boolean updating, protected;
/*
*/
begin
	create self.myNibblerManager persistent;
	self.myNibblerManager.createEntity(self);

	return (true);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="edc1f6fd-0f67-4a48-818c-67943a646e4e">
        <updating/>
        <source>doUpdate(): Boolean updating, protected;
/*
*/
begin
	self.myNibblerManager.updateEntity(self);

	return (true);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lockEntity" id="781c076f-6588-4746-8de4-6a2433a1c056">
        <source>lockEntity(): Boolean protected;
/*
*/
vars
	rtn: Boolean;
begin
	if self.myNibblerManager &lt;&gt; null then
		rtn := self.tryLockingObject(self.myNibblerManager);
	endif;
	return (rtn);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
