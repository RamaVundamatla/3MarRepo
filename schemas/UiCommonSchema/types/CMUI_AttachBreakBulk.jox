end;</source>
        <Parameter name="hazListTable" type="CMUI_HazardsListTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateWithProductDefaults" id="d0462ba6-e700-40ed-b63e-f464c10049df">
        <source>populateWithProductDefaults();
// ---------------------------------------------------------------------------
// Created:     17 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	entRow			: EntTableRow;
	prodAttr		: CM_ProductAttr;
	pro				: CM_Product;
	attrStr			: String;
	table			: CM_EntryTable;
	cargoType		: CM_CargoType;
	entRowArray		: EntTableRowArray;	
begin
	
	pro := self.cmbProduct.listObject.CM_Product;
	if pro = null then
		return;
	endif;
	cargoType := pro.myCargoType;
	table := self.tblItem;
	entRowArray := self.tblItem.myEntTableDef.allEntTableRows;
	
	foreach entRow in entRowArray do
		prodAttr := pro.getProdAttrFromName(entRow.name);
		if prodAttr = null then
			continue;
		endif;
		attrStr := entRow.name;
	//	if (cargoType.allAttributesOnProduct.includes(attrStr)) and (prodAttr.isViewable) then
		if (cargoType = null or cargoType.allAttributesOnProduct.includes(attrStr)) and (prodAttr.isViewable) then	//29 Aug 2013	NDL	Par 32055
		// This is the new one for after 7.4.1 release	
		//if (cargoType.getAttributeValue(attrStr).Boolean) and (prodAttr.isViewable) then
			table.showRowByName(attrStr, false);
			table.setValueByName(attrStr, prodAttr.getDisplayValueString());
			//self.setProductValueByName( prodAttr, attrStr );			
			table.setCellText(table.accessedRow.row, table.ColumnHeading, prodAttr.displayName);	
		else
			table.hideRowByName(attrStr, false);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="removeItem" id="cc1ce275-5a65-4246-882d-e381b546538b">
        <updating/>
        <source>removeItem() updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	attach		: CMIF_InOutAttachment;
	table		: CM_DataTable;
	row			: Integer;
	
begin
	table	:=	self.tblAll;
	row		:=	table.row;
	attach	:=	table.accessRow(row).itemObject.CMIF_InOutAttachment;
	
	if attach = null then
		app.msgBox('Please select an attachment to remove first', 'Nothing selected', 0 + MsgBox_Information_Icon);
		return;
	endif;
	
	table.removeItem(row);
	self.aAllAttachments.remove(attach);
	self.updateItemCount();
	tblItem.setFocus();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="saveAttachmentsAsTIs" id="5d6a6774-315b-478d-a0fc-11605871345b">
        <updating/>
        <source>saveAttachmentsAsTIs() : Boolean protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 February 2003		cnwth2	
//
// Purpose:     		 
// 13 Apr 2024  navnk30   Bug 63247: EUP Testing | Container Weights not updated when Making New LCL
// ----------   ----------  --------------------------------------------------
vars
	attach				: CMIF_InOutAttachment;
	pxyBreakBulkGen		: CM_BreakBulkGeneric;
	pxyBreakBulk		: CM_BreakBulk;
	pxyLCL				: CM_LCL;
	updateController	: CMIF_TIUpdateController;
	tiObj				: CM_TrackedItem;
	moveController		: CMIF_MoveController;
	lc					: CM_LocationsController;
	result				: Integer;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	newTIs				: CM_TISet;
	
begin
	if self.aAllAttachments.isEmpty then
		app.msgBox(app.getErrorString(AddNewItem), 'Add Item', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return false;
	endif;
	
	updateController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode(), null);

	foreach attach in self.aAllAttachments do
		if (tiObj.isKindOf(CM_BreakBulkGeneric)) and (not app.getMyUser().canDo(self.myTerminal, Mod_GeneralCargo))  then
			app.msgBox('Error: This system not licenced to create break-bulk of user defined cargo types','Licencing error', MsgBox_OK_Only + MsgBox_Stop_Icon);
			return false;
		endif;
		
		tiObj	:=	self.createPxyBreakBulk(attach.id, attach.myCargoType);
		tiObj.setPxyFromCMIF_InOutAttachment(attach, app.myPassport);
		
		// Par 13818. Set receive date for Tony
		if self.aMyMasterTI &lt;&gt; null then
			tiObj.setReceivedDT(self.aMyMasterTI.receivedDT);
		endif;
		
		if tiObj.myOperator = null and self.aMyOperator &lt;&gt; null then		//13.04.2024 navnk30 #63247
			tiObj.setMyOperator(self.aMyOperator);
		endif;
		
		updateController.allTransientTIs.add(tiObj);
	endforeach;

	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if self.aMyMasterTI &lt;&gt; null then			
			app.myTrxCA.trxCreateTrackedItemsAndAttach(updateController, self.aMyMasterTI, app.myPassport);
		else									
			app.myTrxCA.trxCreateTrackedItems(updateController, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Break bulk create', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		if tiObj.myOperator = null and self.aMyOperator &lt;&gt; null then			//13.04.2024 navnk30 #63247
			tiObj.setMyOperator(self.aMyOperator);
		endif;
		
		return false;
		
	endwhile;
	
	//creation was OK, so now move them into the desired location
	if self.aMyMasterTI = null then
		create moveController transient;
		moveController.setMoveMode(REAL_MODE);
		moveController.isForcedMove	:= true;
		moveController.isSystemMove := true;
		lc := attach.CMIF_InOutAttachment.myLocationsController;
		
		foreach tiObj in updateController.allPersistentTIs do
			foreach attach in self.aAllAttachments do
				if attach.CMIF_InOutAttachment.id = tiObj.id then
					moveController.setMyToPrimaryLocation(attach.CMIF_InOutAttachment.myLocationsController);
					moveController.setMyTrackedItem(tiObj);
					
					//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
					while true do
					
						app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
					
						if app.myPassport.trxCompletedOK then
							break;
						else
							theResult := app.showErrorWarningDialog('Break bulk create', app.myPassport, ErrWarnMode_Update);
							if app.myPassport.noErrors and theResult = IDOK then
								app.myPassport.warningsAcknowledged	:= true;
								continue;
							endif;
						endif;
						
						return false;
						
					endwhile;
					
					
					//most of the time all the TIs will be going into the same location - so only send
					//out a note if one is different
					if lc &lt;&gt; attach.CMIF_InOutAttachment.myLocationsController then
						lc := attach.CMIF_InOutAttachment.myLocationsController;
//						lc.myTerminalArea.causeEvent(lc.myTerminal.getTerminalEvent(EVENT_UPDATE_GRID_AREA), true, lc);
					endif;
				endif;
			endforeach;
		endforeach;
		
		create newTIs transient;												//13.04.2024 navnk30 #63247
		updateController.allPersistentTIs.copy(newTIs);							//13.04.2024 navnk30 #63247
		self.causeEvent(CMUI_AttachBreakBulk.LCLCargosCreated, true, newTIs);	//13.04.2024 navnk30 #63247

	//	lc.myTerminalArea.causeEvent(lc.myTerminal.getTerminalEvent(EVENT_UPDATE_GRID_AREA), true, lc);
	endif;
	
	return true;
epilog
	delete updateController;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAttributesFromTableItem" id="6138e117-c796-434c-b404-0e50e380f3f8">
        <source>setAttributesFromTableItem(_cmifAttach : CMIF_InOutAttachment input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     04 November 2002		cnwth2	
//
// Purpose:     Grabs the input values, validates them against any range restriction on the attribute,
//				then assigns a PROCESSED value (ie. divided by any multiplier value on the attribute)
//				String attributes have no validation or range, so they're just grabbed straight off the table				
//			 
// ----------   ----------  --------------------------------------------------
vars
	prodAttr		: CM_ProductAttr;
	pro				: CM_Product;
	table			: CM_EntryTable;
	typeStr,
	rangeStr,
	errorStr		: String;
	errorFound		: Boolean;

begin
	
	table := self.tblItem;

	if not app.getMyUser().canDo(self.myTerminal, Mod_GeneralCargo) then
		//tough - thats all you get
		return true;
	endif;
	
	typeStr := table.getValueByName(ETRow_CouType).String; // CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.			
	_cmifAttach.couType :=  app.couTypeStringToEnum(typeStr);
	
	pro := _cmifAttach.myProduct;	
	if pro = null then
		return true;
	endif;
	//here is the situation where users can't neccessarily overide product attribute values
	//if the rows not visible, always assign the default value from the product
	prodAttr := pro.myWidthString;
	if prodAttr &lt;&gt; null then
		if table.isRowVisible(ETRow_MyWidthString) then
			if prodAttr.validationType = prodAttr.ValidationType_Codes then
				if self.cmbWidthCodes.listObject &lt;&gt; null then
					_cmifAttach.widthString := self.cmbWidthCodes.listObject.CM_ProductAttributeCode.code;
				else
					app.msgBox('You must select a width code for the width text field','No width code selected...', MsgBox_Exclamation_Mark_Icon);
					return false;
				endif;
			else
				_cmifAttach.widthString := table.getValueByName(ETRow_MyWidthString).String;
			endif;
		else//value not visible to user - assign default value
			if prodAttr.validationType = prodAttr.ValidationType_Codes and prodAttr.myCode &lt;&gt; null then
				_cmifAttach.widthString := prodAttr.myCode.code;
			else
				_cmifAttach.widthString := prodAttr.CM_ProdAttrString.value;
			endif;
		endif;
	endif;
	
	prodAttr := pro.myHeightString;
	if prodAttr &lt;&gt; null then
		if table.isRowVisible(ETRow_MyHeightString) then
			if prodAttr.validationType = prodAttr.ValidationType_Codes then
				if self.cmbHeightCodes.listObject &lt;&gt; null then
					_cmifAttach.heightString := self.cmbHeightCodes.listObject.CM_ProductAttributeCode.code;
				else
					app.msgBox('You must select a height code for the height text field','No height code selected...', MsgBox_Exclamation_Mark_Icon);
					return false;
				endif;
			else
				_cmifAttach.heightString := table.getValueByName(ETRow_MyHeightString).String;
			endif;
		else//value not visible to user - assign default value
			if prodAttr.validationType = prodAttr.ValidationType_Codes and prodAttr.myCode &lt;&gt; null then
				_cmifAttach.heightString := prodAttr.myCode.code;
			else
				_cmifAttach.heightString := prodAttr.CM_ProdAttrString.value;
			endif;
		endif;
	endif;
	
	prodAttr := pro.myLengthString;
	if prodAttr &lt;&gt; null then
		if table.isRowVisible(ETRow_MyLengthString) then
			if prodAttr.validationType = prodAttr.ValidationType_Codes then
				if self.cmbLengthCodes.listObject &lt;&gt; null then
					_cmifAttach.lengthString := self.cmbLengthCodes.listObject.CM_ProductAttributeCode.code;
				else
					app.msgBox('You must select a Length code for the Length text field','No Length code selected...', MsgBox_Exclamation_Mark_Icon);
					return false;
				endif;
			else
				_cmifAttach.lengthString := table.getValueByName(ETRow_MyLengthString).String;
			endif;
		else//value not visible to user - assign default value
			if prodAttr.validationType = prodAttr.ValidationType_Codes and prodAttr.myCode &lt;&gt; null then
				_cmifAttach.lengthString := prodAttr.myCode.code;
			else
				_cmifAttach.lengthString := prodAttr.CM_ProdAttrString.value;
			endif;
		endif;
	endif;
	
	prodAttr := pro.myType;
	if prodAttr &lt;&gt; null then
		if table.isRowVisible(ETRow_MyType) then
			if prodAttr.validationType = prodAttr.ValidationType_Codes then
				if self.cmbTypeCodes.listObject &lt;&gt; null then
					_cmifAttach.type := self.cmbTypeCodes.listObject.CM_ProductAttributeCode.code;
				else
					app.msgBox('You must select a Type code for the Type text field','No Type code selected...', MsgBox_Exclamation_Mark_Icon);
					return false;
				endif;
			else
				_cmifAttach.type := table.getValueByName(ETRow_MyType).String;
			endif;
		else//value not visible to user - assign default value
			if prodAttr.validationType = prodAttr.ValidationType_Codes then
				_cmifAttach.type := prodAttr.myCode.code;
			else
				_cmifAttach.type := prodAttr.CM_ProdAttrString.value;
			endif;
		endif;
	endif;
	
	
	if table.isRowVisible(ETRow_MyWidth) then
		//_cmifAttach.width := pro.getWidthValueFromDisplay ( table.getValueByName(ETRow_MyWidth).Decimal );  //myWidth.divideValue(table.getValueByName(ETRow_MyWidth).Decimal).Integer; //30.1.09 cnwrd1 par #18821 
		_cmifAttach.width := pro.getWidthValueFromDisplay ( table.getValueByName(ETRow_MyWidth).String.asDecimalJMT );	//22 Oct 2015	NDL	Par 36655
	else
		if pro.getMyWidth() &lt;&gt; null then //30.1.09 cnwrd1 par #18821 
			_cmifAttach.width := pro.getWidthValue();  //myWidth.value; //30.1.09 cnwrd1 par #18821 
		endif;
	endif;

	if table.isRowVisible(ETRow_MyHeight) then
		//_cmifAttach.height := pro.getHeightValueFromDisplay( table.getValueByName(ETRow_MyHeight).Decimal);   //myHeight.divideValue(table.getValueByName(ETRow_MyHeight).Decimal).Integer; //30.1.09 cnwrd1 par #18821 
		_cmifAttach.height := pro.getHeightValueFromDisplay( table.getValueByName(ETRow_MyHeight).String.asDecimalJMT );	//22 Oct 2015	NDL	Par 36655
	else
		if pro.getMyHeight() &lt;&gt; null then //30.1.09 cnwrd1 par #18821 
			_cmifAttach.height := pro.getHeightValue();  //myHeight.value; //30.1.09 cnwrd1 par #18821 
		endif;
	endif;

	if table.isRowVisible(ETRow_MyLength) then
		//_cmifAttach.length := pro.getLengthValueFromDisplay(table.getValueByName(ETRow_MyLength).Decimal);   //myLength.divideValue(table.getValueByName(ETRow_MyLength).Decimal).Integer; //30.1.09 cnwrd1 par #18821 
		_cmifAttach.length := pro.getLengthValueFromDisplay(table.getValueByName(ETRow_MyLength).String.asDecimalJMT );	//22 Oct 2015	NDL	Par 36655
	else
		if pro.getMyLength() &lt;&gt; null then //30.1.09 cnwrd1 par #18821 
			_cmifAttach.length := pro.getLengthValue();  //myLength.value; //30.1.09 cnwrd1 par #18821 
		endif;
	endif;

	if table.isRowVisible(ETRow_MyQuantity) then
		//_cmifAttach.quantity := pro.myQuantity.divideValue(table.getValueByName(ETRow_MyQuantity).Decimal).Integer;
		_cmifAttach.quantity := pro.myQuantity.divideValue(table.getValueByName(ETRow_MyQuantity).String.asDecimalJMT).Integer;	//22 Oct 2015	NDL	Par 36655
	else
		if pro.myQuantity &lt;&gt; null then
			_cmifAttach.quantity := pro.myQuantity.value;
		endif;
	endif;

	if table.isRowVisible(ETRow_MyVolume) then
		//_cmifAttach.volume := pro.myVolume.divideValue(table.getValueByName(ETRow_MyVolume).Decimal).Decimal;
		_cmifAttach.volume := pro.myVolume.divideValue(table.getValueByName(ETRow_MyVolume).String.asDecimalJMT).Decimal;	//22 Oct 2015	NDL	Par 36655
	else
		if pro.myVolume &lt;&gt; null then
			_cmifAttach.volume := pro.myVolume.value;
		endif;
	endif;

	if table.isRowVisible(ETRow_MyDensity) then
		//_cmifAttach.density := pro.myDensity.divideValue(table.getValueByName(ETRow_MyDensity).Decimal).Integer;
		_cmifAttach.density := pro.myDensityDec.divideValue(table.getValueByName(ETRow_MyDensity).String.asDecimalJMT).Decimal;	//22 Oct 2015	NDL	Par 36655	// ### TFS 52193 22Nov2021 NAVPW1
	else
		if pro.myDensityDec &lt;&gt; null then																						// ### TFS 52193 22Nov2021 NAVPW1
			_cmifAttach.density := pro.myDensityDec.value;																		// ### TFS 52193 22Nov2021 NAVPW1
		endif;
	endif;

	if table.isRowVisible(ETRow_MyWeight) then
		//_cmifAttach.weight := pro.getWeightValueFromDisplay(table.getValueByName(ETRow_MyWeight).Decimal);    //myWeight.divideValue(table.getValueByName(ETRow_MyWeight).Decimal).Integer; //30.1.09 cnwrd1 par #18821 
		_cmifAttach.weight := pro.getWeightValueFromDisplay(table.getValueByName(ETRow_MyWeight).String.asDecimalJMT);	//22 Oct 2015	NDL	Par 36655
	else
		if pro.getMyWeight() &lt;&gt; null then //30.1.09 cnwrd1 par #18821 
			_cmifAttach.weight := pro.getWeightValue();  //myWeight.value; //30.1.09 cnwrd1 par #18821 
		endif;
	endif;

	if table.isRowVisible(ETRow_Colour) then
		_cmifAttach.colour := table.getValueByName(ETRow_Colour).Integer;
	else
		if pro.colour &lt;&gt; null then
			_cmifAttach.colour := pro.colour;
		endif;
	endif;

	//validate numeric attributes are within the range specified on the product attribute
	//(string attributes don't need validation)
	errorFound := false;
	
	//02.2.09 cnwrd1 par #18821
	if pro.getMyWidth() &lt;&gt; null and  
	   (not pro.validateMyWidthValue(_cmifAttach.width)) then	
		errorFound := true;
		errorStr := 'width';
		rangeStr := pro.getMyWidthRangeDescr();

	elseif pro.getMyHeight() &lt;&gt; null and
	   (not pro.validateMyHeightValue(_cmifAttach.height)) then
		errorFound := true;
		errorStr := 'height';
		rangeStr := pro.getMyHeightRangeDescr();

	elseif pro.getMyLength() &lt;&gt; null and
	   (not pro.validateMyLengthValue(_cmifAttach.length)) then
		errorFound := true;
		errorStr := 'length';	
		rangeStr := pro.getMyLengthRangeDescr();

	elseif pro.myQuantity &lt;&gt; null and
	   (not pro.myQuantity.validateValue(_cmifAttach.quantity)) then
		errorFound := true;
		errorStr := 'quantity';
		rangeStr := pro.myQuantity.getRangeDescr();

	elseif pro.myVolume &lt;&gt; null and
	   (not pro.myVolume.validateValue(_cmifAttach.volume)) then
		errorFound := true;
		errorStr := 'volume';
		rangeStr := pro.myVolume.getRangeDescr();

	elseif pro.myDensityDec &lt;&gt; null and									// ### TFS 52193 22Nov2021 NAVPW1
	   (not pro.myDensityDec.validateValue(_cmifAttach.density)) then	// ### TFS 52193 22Nov2021 NAVPW1
		errorFound := true;
		errorStr := 'density';
		rangeStr := pro.myDensityDec.getRangeDescr();					// ### TFS 52193 22Nov2021 NAVPW1

	elseif pro.getMyWeight() &lt;&gt; null and 
	   (not pro.validateMyWeightValue(_cmifAttach.weight)) then
		errorFound := true;
		errorStr := 'weight';	
		rangeStr := pro.getMyWeightRangeDescr();

	endif;	
	//02.2.09 cnwrd1 par #18821 
	if errorFound then
		app.msgBox('The value for the ' &amp; errorStr &amp; ' field is does not fall within' &amp; CrLf &amp;
					'the range specified for this attribute. Range is ' &amp; rangeStr, 'Value out of range', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="_cmifAttach" type="CMIF_InOutAttachment" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromItemFromTable" id="56103126-ac4f-4cb2-aa5c-ee420e60a905">
        <source>setFromItemFromTable(_cmifAttach : CMIF_InOutAttachment input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     18 October 2002		cnwth2	
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 13/08/2013	cnwdap1		PAR #32123 Added Colour Picker
// 10/09/2013	cnwdap1		PAR #31196 Don't set product on CMIF if it's a system default product
// 09/12/2013	cnwdap1		PAR #33128 Rejig the order of setting cargo subtype attributes and measurements
// 07/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
// 20/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
vars
	focusStr,
	errorStr			: String;
	errorFound			: Boolean;
	table				: CM_EntryTable;
	idx					: Integer;
	//mastContainer		: CM_Container;
	mastTI				: CM_TrackedItem;
	attach				: CMIF_InOutAttachment;
	imexNum				: String;
	hazDict				: CM_HazardByCodeDict;
	operator			: CM_Operator;				// TFS 53362
begin

	table := self.tblItem;
	attach := _cmifAttach;
	
	if self.aIsForCreation then
		attach.state 			:= TI_STATE_NORMAL;
	endif;
	
	attach.bolType						:= BOLType_GeneralDocket;
	attach.myTerminal 					:= self.myTerminal;
	attach.myTerminalArea 				:= self.cmbTerminalArea.listObject.CM_TerminalArea;
	attach.myLocationsController 		:= self.cmbLC.listObject.CM_LocationsController;
	attach.cargoType 					:= self.cmbCargoType.listObject.CM_CargoType.id;
	
	//+cnwml2 PAR2485
	if attach.myTerminalArea = null then
		attach.myTerminalArea := self.aMyTerminalArea;
	endif;

	//+cnwml2 PAR2485
	if attach.myLocationsController = null then
		attach.myLocationsController := self.aMyLocationsController;
	endif;
	
	
	if attach.cargoType &gt; TI_CargoBOLType_Max and
	   //attach.cargoType &lt; TI_CargoBOLType_JMTMax then										// TFS 49252
	   (attach.cargoType &lt; TI_CargoBOLType_JMTMax or app.myRoot.isClientCentrePort) then	// TFS 49252
		if not self.cmbProduct.listObject.CM_Product = self.cmbCargoType.listObject.CM_CargoType.mySystemProductType then	// PAR #31196
			attach.myProduct 	:= self.cmbProduct.listObject.CM_Product;
		endif;																												// PAR #31196
	endif;

	attach.id 							:= table.getValueByName(ETRow_Id).String[1:20];
	attach.description 					:= table.getValueByName(ETRow_Description).String;
	//attach.weight 						:= table.getValueByName(ETRow_Weight).Decimal; //ccms 1060 cnwrd1 12.1.09		//-cnwml2 MSL CCMS 1017
	if table.getRow(ETRow_TotalWeight) &lt;&gt; 0 then		//+cnwml2 PAR24137
		attach.weight					:= table.getValueByName(ETRow_TotalWeight).Decimal;	
	else
		attach.weight					:= table.getValueByName(ETRow_MyWeight).Decimal;
	endif;

	if table.getRow(ETRow_Volume) &lt;&gt; 0 then			//+cnwml2 PAR24137
		attach.volume 					:= table.getValueByName(ETRow_Volume).String.asDecimalJMT(); // ** 25592 17/11/2010 managing ITA locale.
	else
		attach.volume					:= table.getValueByName(ETRow_MyVolume).String.asDecimalJMT(); // ** 25592 17/11/2010 managing ITA locale.
	endif;
	
	if table.getRow(ETRow_Quantity) &lt;&gt; 0 then		//+cnwml2 PAR24137
		attach.quantity					:= table.getValueByName(ETRow_Quantity).Integer;
	else
		attach.quantity					:= table.getValueByName(ETRow_MyQuantity).Integer;
	endif;
	
	if table.isRowVisible(ETRow_TotalQuantity) then
		attach.totalQuantity 		:= table.getValueByName(ETRow_TotalQuantity).Integer;
	else
		attach.totalQuantity 		:= 1;
	endif;
	
	
	attach.alternativeId 				:= table.getValueByName(ETRow_AlternativeId).String[1:30];
	attach.clientRef					:= table.getValueByName(ETRow_ClientRef).String[1:30];
	attach.condition 					:= table.getValueByName(ETRow_Condition).String;
	attach.billOfLading					:= table.getValueByName(ETRow_BillOfLading).String;
//	attach.houseBillOfLading 			:= table.getValueByName(ETRow_HouseBOL).String[1:20];	// cnwrl1 16/03/2010 PAR 23186 - what it was
	attach.houseBillOfLading 			:= table.getValueByName(ETRow_HouseBOL).String;
	attach.couType 						:= table.getValueByName(ETRow_CouType).Integer;	// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	attach.hasRadio 					:= self.cmbHasRadio.itemData.String.Integer;
	attach.myCustomsAgent 				:= self.cmbCustomsAgent.listObject.CM_CustomsAgent;
	attach.isoType						:= table.getValueByName(ETRow_IsoType).String;	// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	attach.myGeneratorType				:= self.cmbGenType.listObject.CM_GeneratorType; // CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	attach.myTrailerType				:= self.cmbTrailerType.listObject.CM_TILCType;	// 17 Oct 2012	NDL	Par 30095
	
	//+cnwml2 PAR24137
	attach.lengthString				:= table.getValueByName(ETRow_MyLengthString).String;
	attach.widthString				:= table.getValueByName(ETRow_MyWidthString).String;
	attach.heightString				:= table.getValueByName(ETRow_MyHeightString).String;
	attach.length					:= table.getValueByName(ETRow_MyLength).Decimal;
	attach.width					:= table.getValueByName(ETRow_MyWidth).Decimal;
	attach.height					:= table.getValueByName(ETRow_MyHeight).Decimal;
	attach.density					:= table.getValueByName(ETRow_MyDensity).Integer;
	attach.type						:= table.getValueByName(ETRow_MyType).String;
	attach.mark						:= table.getValueByName(ETRow_Mark).String;
	
	//epr par 32062 8/8/13
	if  table.isRowVisible(ETRow_Colour) then
		if self.myTerminal.getConfig(ValidateColour).Boolean then								// PAR #32123
			attach.colourDesc := self.myAssistant.getColourString(self.lstColour, null);		// PAR #32123
		else																					// PAR #32123
			attach.colourDesc:=table.getValueByName(ETRow_Colour).String;
		endif;																					// PAR #32123
	endif;
	if  table.isRowVisible(ETRow_Remarks) then
		attach.remarks:=table.getValueByName(ETRow_Remarks).String;
	endif;
	
	create hazDict transient;
	self.lstHazardList.allSelectedObjects.copy(hazDict);
	attach.setTIHazards(hazDict);
	
	if self.cmbVoyage.listObject &lt;&gt; null then
		attach.voyageCode := self.cmbVoyage.listObject.CM_Voyage.code;
	endif;
	
	if self.aUseMasterContainer then
		if self.aMyMasterTI &lt;&gt; null then
			mastTI := self.aMyMasterTI;
			attach.operatorCode 		:= mastTI.operatorCode;
			attach.dischargePortCode 	:= mastTI.dischargePort;
			attach.destinationPortCode 	:= mastTI.destinationPort;
			attach.consignee 		:= mastTI.consignee;
			attach.consignor 		:= mastTI.consignor;
			//attach.commodityCode		:= mastTI.commodity;			//cnwmc5 - 17 June 2014 - PAR 34244
			attach.imExStatus			:= mastTI.getImExStatus;
			//epr par 32062 8/8/13
			if not table.isRowVisible(ETRow_Mark) then
				attach.mark					:= mastTI.mark;
			endif;
			if not table.isRowVisible(ETRow_Remarks) then
				attach.remarks				:= mastTI.remarks;
			endif;
			
			attach.voyageCode			:= mastTI.voyageCode;
			//PAR17500 - cnwsh3 Want to set the business unit if it exists to be that of the parent container.
			attach.companyCode			:= mastTI.companyCode;
		endif;
	else
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
			operator := self.cmbOperator.listObject.CM_Operator;	// TFS 53362
			if operator &lt;&gt; null then								// TFS 53362
				attach.operatorCode 	:= operator.code;			// TFS 53362
			endif;													// TFS 53362
		else														// TFS 53362
			attach.operatorCode			:= table.getValueByName(ETRow_Operator).String;
		endif;														// TFS 53362
		if self.cmbDestPort.myObject &lt;&gt; null then
			attach.destinationPortCode	:= self.cmbDestPort.myObject.CM_Port.code;
		endif;
		
		if self.cmbDisPort.myObject &lt;&gt; null then
			attach.dischargePortCode 	:= self.cmbDisPort.myObject.CM_Port.code;
		endif;
		
		if self.cmbConsignor.myObject &lt;&gt; null then
			attach.consignor			:= self.cmbConsignor.myObject.CM_ConsigneeConsignor.code;
		endif;
		if self.cmbConsignee.myObject &lt;&gt; null then
			attach.consignee			:= self.cmbConsignee.myObject.CM_ConsigneeConsignor.code;
		endif;
		if self.cmbISOType.myObject &lt;&gt; null then
			attach.isoType				:= self.cmbISOType.myObject.CM_ISOType.code;
		endif;
		
		//attach.commodityCode			:= table.getValueByName(ETRow_Commodity).String;		//cnwmc5 - 17 June 2014 - PAR 34244
		if self.cmbImExStatus.listObject &lt;&gt; null then
			attach.imExStatus				:= self.cmbImExStatus.listObject.CM_IMEXStatus.code;
		else
			attach.imExStatus 				:= TI_IMEX_STATUS_NULL;
		endif;
	
		attach.bookingRef				:= table.getValueByName(ETRow_BookingRef).String;
		attach.voyageCode 				:= table.getValueByName(ETRow_Voyage).String;
		
		//+cnwml2 PAR25895
		if self.cmbBookingItem.listObject &lt;&gt; null then
			attach.myBookingItem := self.cmbBookingItem.listObject.CM_BookingRefItem;
		endif;
	endif;
	
	attach.commodityCode := table.getValueByName(ETRow_Commodity).String;		//cnwmc5 - 17 June 2014 - PAR 34244
	
	attach.cargoGroupID:=table.getValueByName(ETRow_CargoGroupId).String;  //jlier1 TFS 53515 20/5/22
	// PAR #31155 cater for measurement table types														// PAR #33128
	//table.setProxyFromMeasureTables(attach);															// PAR #33128
																										// PAR #33128
	//return self.setAttributesFromTableItem(attach);													// PAR #33128
																										// PAR #33128
	// PAR #33128 have to call setProxyFromMeasureTables after setAttributesFromTableItem, otherwise	// PAR #33128
	// setAttributesFromTableItem sets cargo subtype attributes to default values, thus over-riding 	// PAR #33128
	// the values just set in setProxyFromMeasureTables													// PAR #33128
	if self.setAttributesFromTableItem(attach) then														// PAR #33128
		table.setProxyFromMeasureTables(attach);														// PAR #33128
		return true;																					// PAR #33128
	else																								// PAR #33128
		return false;																					// PAR #33128
	endif;																								// PAR #33128
epilog
	delete hazDict;
end;</source>
        <Parameter name="_cmifAttach" type="CMIF_InOutAttachment" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setItem" id="aa7e28c3-cfd9-479f-9c0f-8e63d4e32bd6">
        <updating/>
        <source>setItem(_attachArray : CMIF_InOutAttachmentArray; pSelectedAttach : CMIF_InOutAttachment) updating;
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpAttach,
	intFaceAttach	: CMIF_InOutAttachment;

begin
	self.aAllOrigAttachments.clear();
	
	foreach intFaceAttach in _attachArray do
		self.aAllOrigAttachments.add(intFaceAttach);

		tmpAttach := intFaceAttach.cloneSelf(true);
		tmpAttach.cloneReferences(intFaceAttach);
		
		self.aAllAttachments.add(tmpAttach);
		
		if intFaceAttach = pSelectedAttach then
			self.mySelectedItem := tmpAttach;
		endif;
		
	endforeach;
	
end;</source>
        <Parameter name="_attachArray" type="CMIF_InOutAttachmentArray"/>
        <Parameter name="pSelectedAttach" type="CMIF_InOutAttachment"/>
    </JadeMethod>
    <JadeMethod name="setProdAttrCodeValue" id="522ef0b1-f8b7-4b1b-b85c-2c318ee836f1">
        <source>setProdAttrCodeValue(_rowName : String; _prodAttr : CM_ProductAttr; _combo : CMUI_ComboBox input; _useDefault : Boolean; _code : String) protected;
// ---------------------------------------------------------------------------
// Created:     18 October 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTable		: CM_EntryTable;
	row				: Integer;

begin
	
	tmpTable := self.tblItem;
	row := tmpTable.getRowByName(_rowName);
	if row = null then // CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
		return;
	endif;
	
	if _prodAttr = null then
		_combo.clear();
		_combo.text := null;
		tmpTable.setValue(row, null);
		return;
	endif;
	
	if _prodAttr.validationType = CM_ProductAttr.ValidationType_Codes then
		_combo.listCollection(_prodAttr.allCodes, true, 0);
		if _useDefault then
			_combo.listObject := _prodAttr.myCode;
		else
			_combo.listObject := _prodAttr.allCodes[_code];
		endif;
		tmpTable.accessCell(row, CM_EntryTable.ColumnValue).cellControl := _combo;					
	else
		_combo.clear();
		tmpTable.accessCell(row, CM_EntryTable.ColumnValue).cellControl := null;
		tmpTable.accessedCell.inputType := CM_EntryTable.InputType_TextBox;
		if _useDefault then
			tmpTable.accessedCell.text := _prodAttr.getDisplayValueString();
		else
			tmpTable.accessedCell.text := _code;
		endif;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_prodAttr" type="CM_ProductAttr"/>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_useDefault" type="Boolean"/>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3628f33a-4931-4813-ac8b-b3f3c9d546c8">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     17 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
begin
	inheritMethod();
	
	if self.aMyMasterTI &lt;&gt; null then
		self.setCaption(app.getErrorString(CMUI_Attach_EnterAttachments) &amp; self.aMyMasterTI.id);
	else
		self.setCaption(app.getErrorString(CreateCargo));
	endif;
	
	self.aIsItemsIncreased	:=	false;
	self.modalResult		:=	MsgBox_Return_Cancel;
	self.cmbHasRadio.automaticCellControl := true;
//	self.myAssistant.listTableHazard(self.lstHazardList);
end;</source>
    </JadeMethod>
    <JadeMethod name="showAttributesForCargoType" id="45e7ffa7-960d-4b7f-9749-1c25fff4e487">
        <source>showAttributesForCargoType(_cargoType : CM_CargoType);
// ---------------------------------------------------------------------------
// Created:     01 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
//	15/10/2009	cnwmh5		PAR 20989	Add check so that if cargo types
//										isSubTypeRequired is not set then
//										don't show the details in the table
// 15/05/2013	cnwdap1		PAR #31472 Show length, width, height for LCL Cargo
// 15/08/2013	cnwdap1		PAR #32123 Colour Picker not applicable if terminal option not set
vars
	entRow			: EntTableRow;
	entDef			: EntTableDef;
	table			: CM_EntryTable;
	taTypeStr,
	taStr,
	lcStr,
	opStr,
	voyStr,
	ctStr	: String;
	row				: Integer;
	prod : CM_Product;
	prodAttr : CM_ProductAttr;
	
begin
	if _cargoType = null then
		return;
	endif;
	//hold onto exisiting combo selections
	taTypeStr := self.cmbTAType.text;
	ctStr := self.cmbCargoType.text;
	taStr := self.cmbTerminalArea.text;
	lcStr := self.cmbLC.text;
	opStr := self.cmbOperator.text;
	voyStr := self.cmbVoyage.text;
	
	table := self.tblItem;
	entDef := self.getAllAttributesDef;
	
	if (_cargoType.id = TI_CargoType_BreakBulk) or (_cargoType.id = TI_CargoType_LCL) then
		if self.aIsForCreation then
			if self.aMyMasterTI &lt;&gt; null then
				entDef := app.myController.getEntTableDef(ETDef_ItemDataLCLAttach);
			else
				entDef := app.myController.getEntTableDef(ETDef_ItemDataLCLExp);
			endif;
		else
			entDef := app.myController.getEntTableDef(ETDef_ItemData);
		endif;
			table.setEntTableDef(entDef, null, 'entTableDefSetupWarning');			//+cnwml2 PAR24137	

	// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	elseif _cargoType.id = TI_CargoType_Car then
		entDef := app.myController.getEntTableDef(ETDef_ItemDataCarGC);
			table.setEntTableDef(entDef, null, 'entTableDefSetupWarning');			//+cnwml2 PAR24137	

	elseif _cargoType.id = TI_CargoType_Generator then
		entDef := app.myController.getEntTableDef(ETDef_ItemDataGenerator);
			table.setEntTableDef(entDef, null, 'entTableDefSetupWarning');			//+cnwml2 PAR24137

	elseif _cargoType.id = TI_CargoType_COU then
		entDef := app.myController.getEntTableDef(ETDef_ItemDataCOU);	
			table.setEntTableDef(entDef, null, 'entTableDefSetupWarning');			//+cnwml2 PAR24137
	
	elseif _cargoType.id = TI_CargoType_Tower then
		entDef := app.myController.getEntTableDef(ETDef_ItemDataRefrigTower);
			table.setEntTableDef(entDef, null, 'entTableDefSetupWarning');			//+cnwml2 PAR24137

	elseif _cargoType.id = TI_CargoType_Timber then
		entDef := app.myController.getEntTableDef(ETDef_ItemDataTimber);
			table.setEntTableDef(entDef, null, 'entTableDefSetupWarning');			//+cnwml2 PAR24137

	elseif _cargoType.isSystemCargoBOLType then
		entDef := app.myController.getEntTableDef(ETDef_ItemDataCarGC);
			table.setEntTableDef(entDef, null, 'entTableDefSetupWarning');			//+cnwml2 PAR24137	

	// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes - ENDS
	else//user cargo type
		if self.aIsForCreation then
			if self.aMyMasterTI &lt;&gt; null then
				entDef := app.myController.getEntTableDef(ETDef_ItemDataAttach);
			else
				entDef := app.myController.getEntTableDef(ETDef_ItemDataExp);
			endif;
		else
			entDef := app.myController.getEntTableDef(ETDef_ItemData);
		endif;

		table.setEntTableDef(entDef, null, 'entTableDefSetupWarning');	

		foreach entRow in entDef.allEntTableRows do
			if _cargoType.allAttributesOnProduct.includes(entRow.name) then
			// This is the new one for after 7.4.1 release	
			//if _cargoType.getAttributeValue(entRow.name).Boolean then
				table.showRowByName(entRow.name, false);
				
				//29 Aug 2013	NDL	Par 32055
				prod := _cargoType.mySystemProductType;
				if prod &lt;&gt; null then
					prodAttr := prod.getProdAttrFromName(entRow.name);
					if prodAttr &lt;&gt; null and prodAttr.isViewable then
						table.setCellText(table.accessedRow.row, table.ColumnHeading, prodAttr.displayName);
						table.setValueByName(entRow.name, prodAttr.getDisplayValueString());
					endif;
				endif;
				
			else
				table.hideRowByName(entRow.name, false);
			endif;
		endforeach;
	
		table.showRowByName(ETRow_CargoType, false);				//+cnwml2 PAR24137
		table.showRowByName(ETRow_Id, false);						//+cnwml2 PAR24137
		if app.isCargoGroupEnabled then //jlier1 TFS 53515 25/5/22
			table.showRowByName(ETRow_CargoGroupId,false);
		endif;
		table.showRowByName(ETRow_Operator, false);						//+cnwrd1 par 26752 17.1.2011 - want to show operator here.
		//epr par 32062
		table.showRowByName(ETRow_Mark,false);
		table.showRowByName(ETRow_Description,false);
		table.showRowByName(ETRow_Remarks,false);	
		if _cargoType.isBreakBulkMulti() then
			table.showRowByName(ETRow_TotalQuantity,false);
		endif;
		if _cargoType.myClassToCreate = CM_BreakBulkGeneric then
			table.showRowByName(ETRow_Colour,false);
		endif;
	endif;
	
	//epr par 32062
	if self.aIsForCreation and self.aMyMasterTI &lt;&gt; null then
		if table.isRowVisible(ETRow_Mark) then
			table.setValueByName(ETRow_Mark,self.aMyMasterTI.mark);
		endif;
		if table.isRowVisible(ETRow_Remarks) then
			table.setValueByName(ETRow_Remarks,self.aMyMasterTI.remarks);
		endif;
	endif;
		
	self.cmbTAType.text := taTypeStr;
	self.cmbCargoType.text := ctStr;
	self.cmbTerminalArea.text := taStr;
	self.cmbLC.text := lcStr;
	self.cmbOperator.text := opStr;
	self.cmbVoyage.text := voyStr;
	
	table.setValueByName(ETRow_CargoType, ctStr);
	table.setValueByName(ETRow_TaType, taTypeStr);
	table.setValueByName(ETRow_TerminalArea, taStr);
	table.setValueByName(ETRow_Row, lcStr);
	table.setValueByName(ETRow_Operator, opStr);
	table.setValueByName(ETRow_Voyage, voyStr);
	if _cargoType.id = TI_CargoType_Car then
		if self.aMyMasterTI &lt;&gt; null then //ccms 1093 cnwrs1 mar 2008
			table.hideRowByName(ETRow_TaType, false);
			table.hideRowByName(ETRow_TerminalArea,false);
			table.hideRowByName(ETRow_Row, false);
		endif;
	endif;
	
	// 15/10/2009 cnwmh5 20989 - Start
	if not _cargoType.isSubCargoTypeRequired then
		table.hideRowByName(ETRow_Product, false);
	else
		table.showRowByName(ETRow_Product, false);				//+cnwml2 PAR24137
	endif;
	// 15/10/2009 cnwmh5 20989 - End	
	
	//17 Oct 2012	NDL	Par 30095
	if _cargoType.isTrailer then
		table.showRowByName(ETRow_MyTrailerType, false);
	else
		table.hideRowByName(ETRow_MyTrailerType, false);
	endif;
	
	if _cargoType.id = TI_CargoType_LCL then							// PAR #31472
		table.showRowByName(ETRow_MyHeight, false);						// PAR #31472
		table.showRowByName(ETRow_MyLength, false);						// PAR #31472
		table.showRowByName(ETRow_MyWidth, false);						// PAR #31472
	endif;																// PAR #31472
	
	table.setValueByName(ETRow_DestPort, null);
	if self.myDestinationPort &lt;&gt; null then 
		self.cmbDestPort.setObject(self.myDestinationPort);
		table.setValueByName(ETRow_DestPort, self.cmbDestPort.text);
	endif;
	table.setValueByControlName(cmbDisPort.name, null);
	if self.myDischargePort &lt;&gt; null then
		self.cmbDisPort.setObject(self.myDischargePort);
		table.setValueByControlName(cmbDisPort.name, self.cmbDisPort.text);
	endif;
	table.setValueByControlName(self.cmbOperator.name, null);
	if self.aMyOperator &lt;&gt; null then
		self.cmbOperator.setObject(self.aMyOperator);
		table.setValueByControlName(self.cmbOperator.name, self.cmbOperator.text);
	endif;
	
	//cnwmc5 - 17 June 2014 - PAR 34244
	if self.myCommodity &lt;&gt; null then
		self.cmbCommodity.setObject(self.myCommodity);
		table.setValueByControlName(self.cmbCommodity.name, self.cmbCommodity.text);
	elseif self.aMyMasterTI &lt;&gt; null then
		self.cmbCommodity.setObject(self.aMyMasterTI.getCommodityObject());
		table.setValueByControlName(self.cmbCommodity.name, self.aMyMasterTI.commodity);
	else
		table.setValueByControlName(self.cmbCommodity.name, null);
	endif;
	
	table.setValueByControlName(self.cmbImExStatus.name, self.cmbImExStatus.text);
	table.setValueByControlName(self.cmbConsignee.name, null);
	if self.myConsignee &lt;&gt; null then
		self.cmbConsignee.setObject(self.myConsignee);
		table.setValueByControlName(self.cmbConsignee.name, self.cmbConsignee.text);
	endif;
	table.setValueByControlName(self.cmbConsignor.name, null);
	if self.myConsignor &lt;&gt; null then
		self.cmbConsignor.setObject(self.myConsignor);
		table.setValueByControlName(self.cmbConsignor.name, self.cmbConsignor.text);
	endif;
	table.setValueByName(ETRow_BillOfLading, self.bolNumber);
	
	self.myAssistant.comboBoxCOUType(self.tblItem, ETRow_CouType);	
	
	if not self.myTerminal.getConfig(ValidateColour).Boolean then				// PAR #32123
		row := table.getRowByName(ETRow_Colour);								// PAR #32123
		if row &lt;&gt; null then														// PAR #32123
			table.accessCell(row, table.columns).cellControl := null;			// PAR #32123
		endif;																	// PAR #32123
	endif;																		// PAR #32123
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="showNumberOfItems" id="64ddefc1-1252-4a36-bda2-4881738b6e84">
        <source>showNumberOfItems():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		18 November 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblItem_HeightLostFocus" id="f086c439-98d4-41a8-8ae7-07eaf2a867b9">
        <updating/>
        <source>tblItem_HeightLostFocus(_table : CM_EntryTable input; row : Integer; rowName : String; pValue : Any) updating;
/*
----------   ----------  --------------------------------------------------
Created:	15 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	self.autoCalcVolume(_table);

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="row" type="Integer"/>
        <Parameter name="rowName" type="String"/>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="tblItem_LengthLostFocus" id="39ce4172-bd49-4d5b-8e85-5620315acf9c">
        <updating/>
        <source>tblItem_LengthLostFocus(_table : CM_EntryTable input; row : Integer; rowName : String; pValue : Any) updating;
/*
----------   ----------  --------------------------------------------------
Created:	15 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	self.autoCalcVolume(_table);

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="row" type="Integer"/>
        <Parameter name="rowName" type="String"/>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="tblItem_WidthLostFocus" id="e8d2e169-cae7-43fa-8e6d-f3908d274d94">
        <updating/>
        <source>tblItem_WidthLostFocus(_table : CM_EntryTable input; row : Integer; rowName : String; pValue : Any) updating;
/*
----------   ----------  --------------------------------------------------
Created:	15 June 2006 By cnwth2

Purpose:	

