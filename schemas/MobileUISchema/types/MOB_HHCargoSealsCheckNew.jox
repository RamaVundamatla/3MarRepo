    <JadeMethod name="matchesValueFromUser" id="c6e61834-825a-4b60-bdf4-ddfa22d18b53">
        <source>matchesValueFromUser( _beforeValue : String; _afterValue : String; _sealTi : CM_SealTI; _sealObject : CM_SealObject ): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 September 2010	cnwndl1	Initial creation

*/

vars

begin

	if _sealObject &lt;&gt; null then
		// let the seal do the checking. ( covers multi seal options)
		if not _sealObject.matchesValueFromUser( _afterValue ) then
			return false;
		endif;
		
	elseif _sealTi &lt;&gt; null then
		// let the seal do the checking. ( covers multi seal options)
		if not _sealTi.matchesValueFromUser( _afterValue ) then
			return false;
		endif;
		
	else
		// no existing seal, can do a direct check.
		if _beforeValue.trimBlanks &lt;&gt; _afterValue.trimBlanks then
			return false;
		endif;
	
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_beforeValue" type="String"/>
        <Parameter name="_afterValue" type="String"/>
        <Parameter name="_sealTi" type="CM_SealTI"/>
        <Parameter name="_sealObject" type="CM_SealObject"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateTblSeals" id="e13e01f0-93ca-41d9-b9e0-b87920844a10">
        <updating/>
        <source>populateTblSeals() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2010	cnwndl1	Initial creation	Par 25608	part of SFW CCMS 1131

*/

vars

	ti : CM_TrackedItem;
	context : Integer;
	cargoType : CM_CargoType;
	mess : String;
	sealType : CM_SealType;
	allSealTypes : CM_SealTypeSet;
	sealTi : CM_SealTI;
	idx : Integer;
	oneHalf : Integer;
	baseColour : Integer;
	wagon : CM_Wagon;

begin

	tblSeals.clear();
	
	ti := self.myMobileGenericAgent.myNextTiToAction;
	wagon := self.myMobileGenericAgent.myCurrentWagon;
	context := self.myMobileGenericAgent.checksState;

	if context = 0 then
		mess := "No context set. " &amp; app.getErrorString(Contact_developer);
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return;
	endif;
	
	if context.isOneOf( WAGON_CHECK_CONTEXT_PLACE_IN, WAGON_CHECK_CONTEXT_PLACE_OUT ) then
	
		if wagon = null then
			mess := "wagon = null. " &amp; app.getErrorString(Contact_developer);
			self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
			return;
		endif;
		
		create allSealTypes transient;
		wagon.getSelectableSealTypes( allSealTypes );
		
		if allSealTypes.isEmpty then
			mess := app.getErrorString1(Seal_types_decla_wagon_class_t, wagon.myWagonClass.code);//"No Seal types declared for cargo type that are available for entry.";
			self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
			return;
		endif;
	
		self.sealCheckType := wagon.getSealCheckTypeForContext( self.myMobileGenericAgent.getEquipChkContextFromChkState );
	
	else
	
		if ti = null then
			mess := "ti = null. " &amp; app.getErrorString(Contact_developer);
			self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
			return;
		endif;
			
		cargoType := ti.myCargoType;
		if cargoType = null then
			mess := app.getErrorString(CouldNotFindCargoType);
			self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
			return;
		endif;
		
		create allSealTypes transient;
		foreach sealType in cargoType.allSealTypes do
			if sealType.notAvailableForEntry then
				continue;
			endif;
			allSealTypes.add(sealType);
		endforeach;
		
		if allSealTypes.isEmpty then
			mess := app.getErrorString(No_Seal_types_for_cargo_type);//"No Seal types declared for cargo type that are available for entry.";
			self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
			return;
		endif;
	
		self.sealCheckType := ti.getSealCheckTypeForContext( self.myMobileGenericAgent.getEquipChkContextFromChkState );
	
	endif;
	
	if sealCheckType = SEAL_CHECK_NONE then // 1
		self.setTableForNoneMode();

	elseif self.sealCheckType = SEAL_CHECK_VIEW then	// 2
		self.setTableForViewMode( allSealTypes, ti, wagon );	// sealName column and Yes / No  columns only
	
	elseif self.sealCheckType = SEAL_CHECK_FULL then	// 3
		self.setTableForFullMode( allSealTypes, ti, wagon );	// type and value columns only
	
	elseif self.sealCheckType = SEAL_CHECK_STRICT then	//4
		self.setTableForStrictMode( allSealTypes, ti, wagon );	// type and value columns only
	
	else
		mess := app.getErrorString(Invalid_seal_check_type) &amp; " [" &amp; self.sealCheckType.String &amp; "]" &amp; CrLf &amp; app.getErrorString(Contact_developer);
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		
	endif;
	

epilog

	delete allSealTypes;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="processFullChecks" id="1ace227f-1e99-4cde-b196-40696e2c4614">
        <source>processFullChecks( startPos : Integer; endPos : Integer ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2010	cnwndl1	Initial creation	Par 25608	part of SFW CCMS 1131

*/

vars

	mess : String;
	pos : Integer;
	obj : Object;
	sealType : CM_SealType;
	sealTi : CM_SealTI;
	sealBefore : String;
	sealAfter : String;
	pxySealCheckTrx : CM_SealCheck;
	realSealCheckTrx : CM_SealCheck;
	sealObj : CM_SealObject;
	
	updateArray : CM_ObjectArray;
	
	context : Integer;
	
	wagon : CM_Wagon;	//29 Jul 2015	NDL	Par 36658
	wagonTrx : CMEVT_WagonTransaction;		//29 Jul 2015	NDL	Par 36658
	pxyWagonCheckDetailArray : ObjectArray;	//29 Jul 2015	NDL	Par 36658
	
begin

	
	if self.sealCheckType &lt;&gt; SEAL_CHECK_FULL then
		return false;
	endif;
	
	//29 Jul 2015	NDL	Par 36658
	context := self.myMobileGenericAgent.checksState;
	if context.isOneOf( WAGON_CHECK_CONTEXT_PLACE_IN, WAGON_CHECK_CONTEXT_PLACE_OUT ) then
		wagon := self.myMobileGenericAgent.myCurrentWagon;
	endif;
	if wagon &lt;&gt; null then
		create pxyWagonCheckDetailArray transient;
	else
		create pxySealCheckTrx transient;
	endif;
	create updateArray transient;
	
	foreach pos in startPos to endPos do
		obj := self.tblSeals.accessRow(pos).itemObject;
		if obj &lt;&gt; null then
			if obj.isKindOf( CM_SealType ) then
				sealTi := null;
				sealObj := null;
				sealType := obj.CM_SealType;
				sealBefore := null;
			elseif obj.isKindOf( CM_SealTI ) then
				sealTi := obj.CM_SealTI;
				sealBefore := sealTi.getSealValueAsString;
				sealType := app.myRoot.getSealType(sealTi.sealType);
			elseif obj.isKindOf( CM_SealObject ) then
				sealObj := obj.CM_SealObject;
				sealBefore := sealObj.getSealValueAsString;
				sealType := app.myRoot.getSealType(sealObj.sealType);
			endif;
		else
			continue;
		endif;
		sealAfter := self.tblSeals.accessCell(pos,2).text;
		
		if not self.matchesValueFromUser( sealBefore, sealAfter, sealTi, sealObj ) then

			mess := app.getErrorString2(Value_entered_does_not_match, sealAfter, sealType.description);
			mess := mess &amp; CrLf &amp; app.getErrorString1(Continue_update_values, sealType.description);
			if self.msgBox( mess, app.getErrorString(Warning) , MsgBox_Yes_No, false) = MsgBox_Return_Yes then
				updateArray.add(sealType);
			else
				//user wants the opportunity to re-enter the value(s) for this seal
				self.tblSeals.row := pos;
				self.tblSeals.column := 2;
				self.tblSeals.accessCell(pos,2).cellControl.TextBox.selStart := 0;
				self.tblSeals.accessCell(pos,2).cellControl.TextBox.selLength := sealAfter.length;
				self.tblSeals.setFocus;
				return false;
			endif;
			
		endif;	
		
		if wagon &lt;&gt; null then
			self.createPxyWagonSealCheckDetail( 	pxyWagonCheckDetailArray,	//_objArray : ObjectArray input;
													sealAfter,	//_sealAfter : String;
													sealBefore,	//_sealBefore : String;
													self.sealCheckType,	//_sealCheckType : Integer;
													sealType.sealType,	//_sealType : String;
													0	//_viewed : Integer
													);
			
		else
			self.createPxyTiSealCheckDetail( 	pxySealCheckTrx,	//_sealCheck : CM_SealCheck;
												sealAfter,	//_sealAfter : String;
												sealBefore,	//_sealBefore : String;
												self.sealCheckType,	//_sealCheckType : Integer;
												sealType.sealType,	//_sealType : String;
												0	//_viewed : Integer
												);
		endif;
		
	endforeach;
	
	if wagon &lt;&gt; null then
		wagonTrx := createWagonSealCheckTrans( wagon, pxyWagonCheckDetailArray, updateArray, context );
		return wagonTrx &lt;&gt; null;
	else
		realSealCheckTrx := self.createTiSealCheckTransaction(pxySealCheckTrx, updateArray, app.myPassport);
		
	endif;
	
	return realSealCheckTrx &lt;&gt; null;
	
	

epilog

	delete pxySealCheckTrx;
	delete updateArray;
	if pxyWagonCheckDetailArray &lt;&gt; null and not pxyWagonCheckDetailArray.isEmpty then
		pxyWagonCheckDetailArray.purge();
	endif;
	delete pxyWagonCheckDetailArray;

end;</source>
        <Parameter name="startPos" type="Integer"/>
        <Parameter name="endPos" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processStrictChecks" id="550f966d-9370-41d3-8d48-8a4830bb3e3a">
        <source>processStrictChecks( startPos : Integer; endPos : Integer ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2010	cnwndl1	Initial creation	Par 25608	part of SFW CCMS 1131

*/

vars

	mess : String;
	pos : Integer;
	obj : Object;
	sealType : CM_SealType;
	sealTi : CM_SealTI;
	sealBefore : String;
	sealAfter : String;
	pxySealCheckTrx : CM_SealCheck;
	realSealCheckTrx : CM_SealCheck;
	sealObj : CM_SealObject;
	context : Integer;
	
	wagon : CM_Wagon;	//29 Jul 2015	NDL	Par 36658
	wagonTrx : CMEVT_WagonTransaction;		//29 Jul 2015	NDL	Par 36658
	pxyWagonCheckDetailArray : ObjectArray;	//29 Jul 2015	NDL	Par 36658
	
begin

	
	if self.sealCheckType &lt;&gt; SEAL_CHECK_STRICT then
		return false;
	endif;
	
	//29 Jul 2015	NDL	Par 36658
	context := self.myMobileGenericAgent.checksState;
	if context.isOneOf( WAGON_CHECK_CONTEXT_PLACE_IN, WAGON_CHECK_CONTEXT_PLACE_OUT ) then
		wagon := self.myMobileGenericAgent.myCurrentWagon;
	endif;
	if wagon &lt;&gt; null then
		create pxyWagonCheckDetailArray transient;
	else
		create pxySealCheckTrx transient;
	endif;
	
	foreach pos in startPos to endPos do
		obj := self.tblSeals.accessRow(pos).itemObject;
		if obj &lt;&gt; null then
			if obj.isKindOf( CM_SealType ) then
				sealTi := null;
				sealObj := null;
				sealType := obj.CM_SealType;
				sealBefore := null;
			elseif obj.isKindOf( CM_SealTI ) then
				sealTi := obj.CM_SealTI;
				sealBefore := sealTi.getSealValueAsString;
				sealType := app.myRoot.getSealType(sealTi.sealType);
			elseif obj.isKindOf( CM_SealObject ) then
				sealObj := obj.CM_SealObject;
				sealBefore := sealObj.getSealValueAsString;
				sealType := app.myRoot.getSealType(sealObj.sealType);
			endif;
		else
			continue;
		endif;
		sealAfter := self.tblSeals.accessCell(pos,2).text;
		
		if not self.matchesValueFromUser( sealBefore, sealAfter, sealTi, sealObj ) then
			mess := app.getErrorString2(Value_entered_does_not_match, sealAfter, sealType.description);
			self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
			//set user back to this field.
			self.tblSeals.row := pos;
			self.tblSeals.column := 2;
			self.tblSeals.accessCell(pos,2).cellControl.TextBox.selStart := 0;
			self.tblSeals.accessCell(pos,2).cellControl.TextBox.selLength := sealAfter.length;
			self.tblSeals.setFocus;	
			return false;
		endif;	
		
		if wagon &lt;&gt; null then
			self.createPxyWagonSealCheckDetail(	pxyWagonCheckDetailArray,	//_objArray : ObjectArray input;
												sealAfter,	//_sealAfter : String;
												sealBefore,	//_sealBefore : String;
												self.sealCheckType,	//_sealCheckType : Integer;
												sealType.sealType,	//_sealType : String;
												0	//_viewed : Integer
												);
			
		else
			self.createPxyTiSealCheckDetail(	pxySealCheckTrx,	//_sealCheck : CM_SealCheck;
												sealAfter,	//_sealAfter : String;
												sealBefore,	//_sealBefore : String;
												self.sealCheckType,	//_sealCheckType : Integer;
												sealType.sealType,	//_sealType : String;
												0	//_viewed : Integer
												);
		endif;
		
	endforeach;

	if wagon &lt;&gt; null then
		wagonTrx := createWagonSealCheckTrans( wagon, pxyWagonCheckDetailArray, null, context );
		return wagonTrx &lt;&gt; null;
	else
		realSealCheckTrx := self.createTiSealCheckTransaction(pxySealCheckTrx, null, app.myPassport);
	endif;
	
	return realSealCheckTrx &lt;&gt; null;

epilog

	delete pxySealCheckTrx;
	if pxyWagonCheckDetailArray &lt;&gt; null and not pxyWagonCheckDetailArray.isEmpty then
		pxyWagonCheckDetailArray.purge();
	endif;
	delete pxyWagonCheckDetailArray;

end;</source>
        <Parameter name="startPos" type="Integer"/>
        <Parameter name="endPos" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processViewChecks" id="6993285c-2da9-4fa8-8d77-5dc84f300f22">
        <source>processViewChecks( startPos : Integer; endPos : Integer ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2010	cnwndl1	Initial creation	Par 25608	part of SFW CCMS 1131

*/

vars

	mess : String;
	pos : Integer;
	obj : Object;
	sealType : CM_SealType;
	sealTi : CM_SealTI;
	sealBefore : String;
	sealAfter : String;
	pxySealCheckTrx : CM_SealCheck;
	realSealCheckTrx : CM_SealCheck;
	viewed : Integer;
	sealObj : CM_SealObject;
	context : Integer;
	
	wagon : CM_Wagon;	//29 Jul 2015	NDL	Par 36658
	wagonTrx : CMEVT_WagonTransaction;		//29 Jul 2015	NDL	Par 36658
	pxyWagonCheckDetailArray : ObjectArray;	//29 Jul 2015	NDL	Par 36658
	
begin

	
	if self.sealCheckType &lt;&gt; SEAL_CHECK_VIEW then
		return false;
	endif;
	
	//29 Jul 2015	NDL	Par 36658
	context := self.myMobileGenericAgent.checksState;
	if context.isOneOf( WAGON_CHECK_CONTEXT_PLACE_IN, WAGON_CHECK_CONTEXT_PLACE_OUT ) then
		wagon := self.myMobileGenericAgent.myCurrentWagon;
	endif;
	if wagon &lt;&gt; null then
		create pxyWagonCheckDetailArray transient;
	else
		create pxySealCheckTrx transient;
	endif;
	
	foreach pos in startPos to endPos do
		obj := self.tblSeals.accessRow(pos).itemObject;
		if obj &lt;&gt; null then
			if obj.isKindOf( CM_SealType ) then
				sealTi := null;
				sealType := obj.CM_SealType;
				sealBefore := null;
			elseif obj.isKindOf( CM_SealTI ) then
				sealTi := obj.CM_SealTI;
				sealBefore := sealTi.getSealValueAsString;
				sealType := app.myRoot.getSealType(sealTi.sealType);
			elseif obj.isKindOf( CM_SealObject ) then
				sealObj := obj.CM_SealObject;
				sealBefore := sealObj.getSealValueAsString;
				sealType := app.myRoot.getSealType(sealObj.sealType);
			endif;
		else
			continue;
		endif;
		sealAfter := sealBefore;	// No provision to change it in this mode.
		if self.tblSeals.accessCell(pos,3).selected then
			// Not viewed
			viewed := CM_SealCheckDetail.Seal_Not_Viewed;
		elseif self.tblSeals.accessCell(pos,2).selected then
			//viewed
			viewed := CM_SealCheckDetail.Seal_Viewed;
		else
			mess := app.getErrorString3(Must_select, app.getErrorString(Viewed), app.getErrorString(Not_viewed), sealType.description );
			self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
			return false;
		endif;
		
		if wagon &lt;&gt; null then
			self.createPxyWagonSealCheckDetail( 	pxyWagonCheckDetailArray,	//_objArray : ObjectArray input;
													sealAfter,	//_sealAfter : String;
													sealBefore,	//_sealBefore : String;
													self.sealCheckType,	//_sealCheckType : Integer;
													sealType.sealType,	//_sealType : String;
													viewed	//_viewed : Integer
													);
		else
			self.createPxyTiSealCheckDetail( 	pxySealCheckTrx,	//_sealCheck : CM_SealCheck;
												sealAfter,	//_sealAfter : String;
												sealBefore,	//_sealBefore : String;
												self.sealCheckType,	//_sealCheckType : Integer;
												sealType.sealType,	//_sealType : String;
												viewed	//_viewed : Integer
												);
		endif;
		
	endforeach;
	

	if wagon &lt;&gt; null then
		wagonTrx := self.createWagonSealCheckTrans( wagon, pxyWagonCheckDetailArray, null, context );
		return wagonTrx &lt;&gt; null;
	else
		realSealCheckTrx := self.createTiSealCheckTransaction(pxySealCheckTrx, null, app.myPassport);
	endif;
	
	return realSealCheckTrx &lt;&gt; null;

epilog

	delete pxySealCheckTrx;
	if pxyWagonCheckDetailArray &lt;&gt; null and not pxyWagonCheckDetailArray.isEmpty then
		pxyWagonCheckDetailArray.purge();
	endif;
	delete pxyWagonCheckDetailArray;

end;</source>
        <Parameter name="startPos" type="Integer"/>
        <Parameter name="endPos" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableForFullMode" id="e27b7703-49ab-4cea-8ea8-8b1f1a745e25">
        <source>setTableForFullMode( allSealTypes : CM_SealTypeSet; ti : CM_TrackedItem; _wagon : CM_Wagon );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2010	cnwndl1	Initial creation	Par 25608	part of SFW CCMS 1131

*/

vars

	sealType : CM_SealType;
	index : Integer;
	sealTi : CM_SealTI;
	sealObj : CM_SealObject;

begin

	tblSeals.selectMode := Table.SelectMode_None;
	tblSeals.columns := 2;
	tblSeals.rows := 2;
	
	tblSeals.fixedRows := 2;
	tblSeals.fixedColumns := 1;
	
	tblSeals.accessCell(1,1).mergeCells := Table.MergeCells_Merge;

	tblSeals.setCellText(1,1,app.getErrorString1(Seal_check_mode, app.sealCheckTypeEnumToString(SEAL_CHECK_FULL) ) );
	tblSeals.accessCell(1,1).alignment := Table.Alignment_Center_Middle;
	
	tblSeals.accessRow(2).alignment := Table.Alignment_Left_Middle;
	tblSeals.accessRow(2).fontBold := true;
	tblSeals.setCellText(2,1,app.getErrorString(CM_Type) );
	tblSeals.setCellText(2,2,app.getErrorString(Value) );
	
	if _wagon &lt;&gt; null then
		foreach sealType in allSealTypes do
		
			index := tblSeals.addItem(sealType.description);
			sealObj := _wagon.getWagonSeal(sealType);
			
			if sealObj = null then
				tblSeals.accessRow(index).itemObject := sealType;
			else
				if sealType.showSealOnCheck then
					tblSeals.setCellText(index,2,sealObj.getSealValueAsString);
				else
					tblSeals.setCellText(index,2,null);
				endif;
				tblSeals.accessRow(index).itemObject := sealObj;
			endif;
			tblSeals.accessCell(index,2).inputType := Table.InputType_TextBox;
			tblSeals.accessRow(index).height := 24;
			
		endforeach;
	
	else
		foreach sealType in allSealTypes do
		
			index := tblSeals.addItem(sealType.description);
			sealTi := ti.getSealTI(sealType);
			
			if sealTi = null then
				tblSeals.accessRow(index).itemObject := sealType;
			else
				if sealType.showSealOnCheck then
					tblSeals.setCellText(index,2,sealTi.getSealValueAsString);
				else
					tblSeals.setCellText(index,2,null);
				endif;
				tblSeals.accessRow(index).itemObject := sealTi;
			endif;
			tblSeals.accessCell(index,2).inputType := Table.InputType_TextBox;
			tblSeals.accessRow(index).height := 24;
			
		endforeach;
	
	endif;
	
epilog

end;</source>
        <Parameter name="allSealTypes" type="CM_SealTypeSet"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="setTableForNoneMode" id="3cfc3454-f296-4b3e-b961-0455435b3f53">
        <source>setTableForNoneMode();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2010	cnwndl1	Initial creation

*/

vars

	mess : String;
	
begin

	self.tblSeals.visible := false;
	self.chkToDoTask.visible := false;
	self.btnOne.enabled := false;
	
	mess := app.getErrorString(Seal_types_but_check_NONE);
	
	self.lblNoChecks.visible := true;
	self.lblNoChecks.caption := mess;
	
epilog

end;</source>
    </JadeMethod>
