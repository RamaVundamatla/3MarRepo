    <JadeMethod name="buildMoveCollToValidate" id="002c6a8a-ece5-46f7-b920-46732dfe47fe">
        <updating/>
        <source>buildMoveCollToValidate() updating;

vars
	currentDT:	TimeStamp;
	prevMove,
	permMove:	HMS_VoyageMovement;
	iter : Iterator;
	
begin
	// This method builds a collection of permanent movements that could potentially require validation
	self.allMovesToValidate.clear();

	if self.myHarbour = null then
		return;
	endif;
	
	iter := self.myHarbour.allVoyageMovements.createIterator();
	self.myHarbour.allVoyageMovements.startKeyGeq(currentDT, iter);

	while iter.next(permMove) do
		if permMove.moveType &lt;&gt; HMSMovementTypeArrival then
			prevMove := permMove.getVoyageMovementPrevious();
			
			if prevMove &lt;&gt; null and (not self.allMovesToValidate.includes(prevMove)) then
				self.allMovesToValidate.add(prevMove);
			endif;
		else
			if permMove.occursOnDTNEW &gt; self.endDT then
				// arrives after end date
				continue;
			endif;
			
			if (not self.allMovesToValidate.includes(permMove)) then
				self.allMovesToValidate.add(permMove);
			endif;
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="5c9124d4-edef-4790-846a-d1001cd9929b">
        <updating/>
        <source>create() updating;
//--------------------------------------------------
// Created:	27 April 2004 By: cnwgd1
//--------------------------------------------------
begin
	self.myHarbour	:=	app.getMyHarbour();
	self.fromDT		:=	app.actualTimeServer();
	self.endDT		:=	self.fromDT.cnEcAddYears(1); //&lt;&lt;-- need to add terminal config, default to 1 year for now
end;</source>
    </JadeMethod>
    <JadeMethod name="createConflict" id="9b4231a0-bc47-4d32-bb93-cddb4bef164e">
        <source>createConflict(move: HMS_VoyageMovement; validationType: Integer; _errorInfo:String):CMIF_HMS_Conflict protected;

vars
	permConflict	: CMIF_HMS_Conflict;
	
begin
 	// This method creates a conflict object for the move specified and adds it to the 
 	// conflict managers collection of allConflicts
 	create permConflict transient;
 	permConflict.myVoyageMovement	:=	move;
 	permConflict.myConflictManager	:=	self;
 	permConflict.conflictType		:=	validationType;
	permConflict.extraDetail		:=	_errorInfo;
	
	return permConflict;
end;</source>
        <access>protected</access>
        <Parameter name="move" type="HMS_VoyageMovement"/>
        <Parameter name="validationType" type="Integer"/>
        <Parameter name="_errorInfo" type="String"/>
        <ReturnType type="CMIF_HMS_Conflict"/>
    </JadeMethod>
    <JadeMethod name="extractAsCSV" id="45b18c4b-1953-4e8b-9b4f-e09683a048db">
        <source>extractAsCSV(_fileName : String );
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
constants
	Delimiter = ",";
vars
	line : StringArray;
	csv: String;
	file : File;
	extractLine : CnStringArray;
	conflict : CMIF_HMS_Conflict;
	iter  : Iterator;
begin	

	create file transient;
	file.fileName := _fileName;
	file.mode := File.Mode_Output;

	if not file.tryOpen then
		return;
	endif;

	iter := self.allCMIFConflicts.createIterator;
	
	while iter.next(conflict) do
		
		create extractLine transient;
		extractLine[8]:=null;			
		extractLine[1]:=conflict.getDisplayStringForAttribute(ETRow_VesselName,false).String;
		extractLine[2]:=conflict.getDisplayStringForAttribute(ETRow_HmsMovementVoyage,false).String;
		if conflict.myVoyageMovement &lt;&gt; null then
			extractLine[3]:=conflict.myVoyageMovement.getMoveTypeName;
		else
			extractLine[3]:=null;
		endif;
		extractLine[4]:=conflict.getDisplayStringForAttribute(ETRow_OccursOnDT,false);
		if conflict.myVoyageMovement &lt;&gt; null then
			extractLine[5]:=conflict.myVoyageMovement .getMyBerth().code;	
		else
			extractLine[5]:=null;
		endif;
		extractLine[6]:=conflict.conflictTypeDescription;
		extractLine[7]:=conflict.conflictTypeDescription;
		extractLine[8]:=conflict.extraDetail;
		
		file.writeLine(extractLine.asCSV(true));	
		delete extractLine;
	endwhile;
	
epilog
	if file &lt;&gt; null then
		if file.isOpen then
			file.close;
		endif;
		delete file;
	endif;
	
	delete iter;
end;</source>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="0b796982-3eb4-45ec-96d2-9ff43375278c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	09 February 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _attrName = ETRow_MyVessel
	or _attrName = ETRow_Movement
	or _attrName = ETRow_OccursOnDT  then
		return self.myChangedVessel.getDisplayStringForAttribute(_attrName, _short);
	elseif _attrName = ETRow_ConflictType then
		return 'Still to do';
	elseif _attrName = ETRow_ConflictDescription then
		return 'Still to do';
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="runConflictReport" id="2848aca1-b812-4db6-b245-bb47e5e1ac6e">
        <updating/>
        <source>runConflictReport() updating;
//-----------------------------------------
// Created: October 2005 By: cnwgd1
//-----------------------------------------
vars
	stopDT			: TimeStamp;
	startDT			: TimeStamp;
	prevMoveObj		: HMS_VoyageMovement;
	nextMoveObj		: HMS_VoyageMovement;
 	tmpMovementObj	: HMS_VoyageMovement;
 	iteratorObj		: Iterator;
	allHarboursObj	: ObjectSet;
	setMemberObj	: Object;
	harbourObj		: HMS_Harbour;
	vesselCode		: String;
	
begin
	if self.myHarbour = null then
		return;
	endif;
	
	if self.allValidationTypes.isEmpty() then
		return;
	endif;
	
	startDT	:=	self.fromDT;
	stopDT	:=	self.endDT;
	
	if (not startDT.isValid) then
		startDT	:=	app.actualTimeServer();
	endif;

	if (not stopDT.isValid) then
		stopDT	:=	startDT.cnEcAddYears(1);
	endif;
	
	create allHarboursObj transient;
	
	if self.isAllHarbours then
		app.myRoot.allHarbours.copy(allHarboursObj);
	else
		allHarboursObj.add(self.myHarbour);
	endif;
	
	if self.myChangedVessel = null then
		vesselCode	:=	null;
	else
		vesselCode	:=	self.myChangedVessel.code;
	endif;
	
	foreach setMemberObj in allHarboursObj do
		harbourObj	:=	setMemberObj.HMS_Harbour;
		iteratorObj	:=	harbourObj.allVoyageMovements.createIterator();
		harbourObj.allVoyageMovements.startKeyGeq(startDT, iteratorObj);
	
		while iteratorObj.next(tmpMovementObj) do
			if tmpMovementObj.occursOnDTNEW &gt; stopDT then
				break;
			endif;
			
			// cnwdad1 04/03/2008 - PAR #16116.
			if vesselCode &lt;&gt; null and tmpMovementObj.myHMSVoyageData.vesselCode &lt;&gt; vesselCode then
				continue;
			endif;
			
			if tmpMovementObj.occursOnDTNEW &gt;= startDT then
				// validate movement
				if tmpMovementObj.moveType = HMSMovementTypeDeparture then
					prevMoveObj	:=	tmpMovementObj.getVoyageMovementPrevious();
					
					if prevMoveObj &lt;&gt; null then
						if prevMoveObj.occursOnDTNEW &lt; startDT then
							self.validateMovement(prevMoveObj);	
						else
							self.validateMovement(tmpMovementObj);			
						endif;
					endif;
				else
					self.validateMovement(tmpMovementObj);
				endif;
			else
				nextMoveObj	:=	tmpMovementObj.myHMSVoyageData.allVoyageMovements.getAtKeyGtr(tmpMovementObj.occursOnDTNEW).HMS_VoyageMovement;
				
				if nextMoveObj &lt;&gt; null then
					if nextMoveObj.occursOnDTNEW &gt;= startDT then
						// validate movement
						self.validateMovement(tmpMovementObj);
					endif;
				endif;
			endif;
		endwhile;
		
		delete iteratorObj;
	endforeach;
	
	if self.allValidationTypes.includes(ValidateStockpile) then
		self.validateStockpiles();
	endif;
epilog
	delete iteratorObj;
	delete allHarboursObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMovement" id="4407dc6f-ec6f-4920-80de-8011d83ed560">
        <source>validateMovement(_movement : HMS_VoyageMovement) protected;
//-----------------------------------------
// Created: October 2005 By: cnwgd1
//-----------------------------------------
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	vesselCode				: String;
	invalidType				: Integer;
	validationType			: Integer;
	isLockoutChecked		: Boolean;
	isOverhangChecked		: Boolean;
	isTidalChecked			: Boolean;
	isClearanceChecked		: Boolean;
	isBerthChecked			: Boolean;
	isMasterPilotChecked	: Boolean;
	isSteamTimeChecked		: Boolean;
	isVesselUnavailChecked	: Boolean;
	errorInfo				: String;
	
begin
	// Run the appropriate validation method on each _movementment
	if self.myChangedVessel &lt;&gt; null then
		vesselCode	:=	self.myChangedVessel.code;
	endif;
	
	foreach validationType in self.allValidationTypes do
		if validationType = ValidateClearances
		and (not isClearanceChecked)
		then
			if (not _movement.validate_WharfPosnClearances(self, invalidType, errorInfo)) then
				// Create a conflict object for this _movement
				self.createConflict(_movement, invalidType, errorInfo);
			endif;
			

			//epr 25/9/08  par 16784 - always done not just for voyage commodity planning
				if (not _movement.validate_BerthOccupancy(false, app.myPassport, errorInfo)) then
					// Create a conflict object for this _movement
					self.createConflict(_movement, ValidateClearances, errorInfo);
				endif;

			
			isClearanceChecked	:=	true;
			
		elseif validationType = ValidateShipPosn then
			if (not isClearanceChecked) then
				if (not _movement.validate_WharfPosnClearances(self, invalidType, errorInfo)) then
					// Create a conflict object for this _movement
					self.createConflict(_movement, invalidType, errorInfo);
				endif;
			endif;
			
			// wharf overhang
			if (not isOverhangChecked) then
				if (not _movement.validate_WharfOverhang(false, errorInfo)) then
					// Create a conflict object for this _movement
					self.createConflict(_movement, ValidateWharfOverhang, errorInfo);
				endif;
			endif;
			
			isClearanceChecked	:=	true;
			isOverhangChecked	:=	true;
			
		elseif validationType = ValidateShipDraft then
			if vesselCode &lt;&gt; null
			and _movement.myHMSVoyageData.vesselCode = vesselCode
			then
			 	// Vessel has been updated but it is not for this movement
				continue;
			endif;
			
			if (not isTidalChecked) then
				if (not _movement.validate_TidalWindow(false, errorInfo)) then
					// Create a conflict object for this _movement
					self.createConflict(_movement, ValidateTidalWindow, errorInfo);
				endif;
			endif;
			
			if (not isBerthChecked) then
				if (not _movement.validate_BerthDepths(false, errorInfo)) then
					// Create a conflict object for this _movement
					self.createConflict(_movement, ValidateBerthDepths, errorInfo);
				endif;
			endif;
			
			isBerthChecked	:=	true; // so they are not double checked
			isTidalChecked	:=	true; // so they are not double checked
		
		elseif validationType = ValidateTidalClass
		and (not isTidalChecked)
		then
			if self.myChangedTidalClass &lt;&gt; null
			and (not _movement.myTidalClass = self.myChangedTidalClass) then
				// Tidal Class has been updated but it is not for this movement
				continue;
			endif;
			
			if (not _movement.validate_TidalWindow(false, errorInfo)) then
				// Create a conflict object for this _movement
				self.createConflict(_movement, ValidateTidalWindow, errorInfo);
			endif;
			
			isTidalChecked	:=	true; // so they are not double checked
		
		elseif validationType = ValidateBerthDepths
		and (not isBerthChecked)
		then
			if (not _movement.validate_BerthDepths(false, errorInfo)) then
				// Create a conflict object for this _movement
				self.createConflict(_movement, ValidateBerthDepths, errorInfo);
			endif;
			
			isBerthChecked	:=	true; // so they are not double checked below
			
		elseif validationType = ValidateWharfLockout
		and (not isLockoutChecked)
		then
			if (not _movement.validate_WharfLockouts(false, errorInfo)) then
				// Create a conflict object for this _movement
				self.createConflict(_movement, validationType, errorInfo);
			endif;
			
			isLockoutChecked	:=	true;
			
		elseif validationType = ValidateWharfOverhang
		and (not isOverhangChecked)
		then
			if (not _movement.validate_WharfOverhang(false, errorInfo)) then
				// Create a conflict object for this _movement
				self.createConflict(_movement, ValidateWharfOverhang, errorInfo);
			endif;
			
			isOverhangChecked	:=	true;
			
		elseif validationType = ValidatePilotMaster
		and (not isMasterPilotChecked)
		then
			if (not _movement.validate_ExemptMaster(false, errorInfo)) then
				// Create a conflict object for this _movement
				self.createConflict(_movement, ValidatePilotMaster, errorInfo);
			endif;
			
			isMasterPilotChecked	:=	true;
			
		elseif validationType = ValidateSteamTime
		and (not isSteamTimeChecked)
		then
			if (not _movement.validate_SteamingTime(false, errorInfo)) then
				// Create a conflict object for this _movement
				self.createConflict(_movement, ValidateSteamTime, errorInfo);
			endif;
			
			isSteamTimeChecked	:=	true;
		
		elseif validationType = ValidateVesselUnavail
		and (not isVesselUnavailChecked)
		then
			if (not _movement.validate_VesselUnavailability(false, errorInfo)) then
				// Create a conflict object for this _movement
				self.createConflict(_movement, ValidateVesselUnavail, errorInfo);
			endif;
			
			isVesselUnavailChecked	:=	true;
			
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_movement" type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="validateStockpiles" id="d14426a3-be15-4fa5-9ebb-2c90e690775f">
        <source>validateStockpiles() protected;
// --------------------------------------------------------------------------------
// Created:		22 February 2007 by cnwdad1
//
// Purpose:		Validates the Stockpiles for the Harbour's Terminal Areas.  If an
//				area's Stockpiles are outside the minimum/maximum limits for a given
//				date, then a Conflict object will be created.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startDate		: Date;
	stopDate		: Date;
	requiredDate	: Date;
	currentDate		: Date;
	quantity		: Integer;
	progressiveQ	: Integer;
	volume			: Decimal[12,2];
	progressiveV	: Decimal[12,2];
	weight			: Decimal[14,4];
	progressiveW	: Decimal[14,4];
	isBelowLimit	: Boolean;
	actualLimit		: Integer;
	aboveBelow		: String;
	harbourObj		: HMS_Harbour;
	terminalObj		: CM_Terminal;
	termAreaObj		: CM_TerminalArea;
	productObj		: CM_Product;
	conflictObj		: CMIF_HMS_Conflict;
 	terminalIterObj	: Iterator;
	areaIterObj		: Iterator;
	errorInfo		: String;
	allHarboursObj	: ObjectSet;
	setMemberObj	: Object;
	
begin
	startDate		:=	self.fromDT.date();
	stopDate		:=	self.endDT.date();
	currentDate		:=	app.actualTimeServer().date();
	
	create allHarboursObj transient;
	
	if self.isAllHarbours then
		app.myRoot.allHarbours.copy(allHarboursObj);
	else
		allHarboursObj.add(self.myHarbour);
	endif;
	
	foreach setMemberObj in allHarboursObj do
		harbourObj		:=	setMemberObj.HMS_Harbour;
		terminalIterObj	:=	harbourObj.allTerminalsByCode.createIterator();

		while terminalIterObj.next(terminalObj) do
			areaIterObj	:=	terminalObj.allTerminalAreas.createIterator();
			
			while areaIterObj.next(termAreaObj) do
				if termAreaObj.id.toLower() = "alu" then
					app.writeStatement( null);
				endif;
					
				if not termAreaObj.isBulkArea()
				or not termAreaObj.isStockControlled
				then
					continue;
				endif;
				
				foreach productObj in self.allProducts do
					if productObj.code.toLower() = "mgbb" then
						app.writeStatement( null);
					endif;
					
					progressiveQ	:=	0;
					progressiveV	:=	0;
					progressiveW	:=	0;
					
					foreach requiredDate in startDate to stopDate do
						
						termAreaObj.getQVWforDate(	requiredDate,
													requiredDate,
													true,
													productObj,	// Get stock for all Products.
													quantity,
													volume,
													weight);
						
						if requiredDate &lt;= currentDate then
							progressiveQ	:=	quantity;
							progressiveV	:=	volume;
							progressiveW	:=	weight;
						else
							progressiveQ	:=	progressiveQ + quantity;
							progressiveV	:=	progressiveV + volume;
							//epr par 16277 27/3/08 we can't keep adding if it is going to be bigger than the max integer
							if Max_Integer - progressiveW &gt;= weight then
								progressiveW	:=	progressiveW + weight;
							endif;
						endif;
						
						if not termAreaObj.isProductWeightInRange(productObj, progressiveW, isBelowLimit, actualLimit) then
							if isBelowLimit then
								aboveBelow	:=	app.getString(Lit_Below).toLower();
							else
								aboveBelow	:=	app.getString(Lit_Above).toLower();
							endif;
		
							
							conflictObj	:=	self.createConflict(null, ValidateStockpile, errorInfo);
							conflictObj.setConflictDetails(	terminalObj.name,
															termAreaObj.id,
															requiredDate.shortFormatJMT(),
															app.getErrorString4(Conflict_Stockpile,
																				productObj.code,
																				aboveBelow,
																				actualLimit.cnEcNumberFormat(),
																				progressiveW.cnEcNumberFormat())
																);
						endif;
					endforeach;
				endforeach;
			endwhile;
			
			delete areaIterObj;
		endwhile;
		
		delete terminalIterObj;
	endforeach;
epilog
	delete areaIterObj;
	delete terminalIterObj;
	delete allHarboursObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
