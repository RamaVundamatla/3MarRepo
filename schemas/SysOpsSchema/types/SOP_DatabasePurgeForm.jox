    <JadeMethod name="displayHistory" id="792428bd-f56b-4342-b02b-b1a1f4b50e58">
        <source>displayHistory(_activity : CM_ActivityHistory) protected;
//  06/05/2013	cnwcs5	par 29777 - imporve performance
vars
	table	:CM_DataTable;
begin
	if _activity.activityType &lt;&gt; ActivityHistoryDBPurge then
		return;
	endif;
		
	table := self.tblActivity;
	
	table.addItemObject(_activity, _activity.getAttributeStringForDefArray(table.allTblDataEntRows));
end;</source>
        <access>protected</access>
        <Parameter name="_activity" type="CM_ActivityHistory"/>
    </JadeMethod>
    <JadeMethod name="doAbortProcessing" id="80be69fd-7292-436f-bbf6-5b5a29a62eb9">
        <source>doAbortProcessing() protected;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
// 06/05/2013	cnwcs5		par 29777 - imporve performance.  
vars
	request			:BGP_DatabasePurgeRequest;
	controller		:BGP_Controller;
	gotException	:Boolean;	
	dummy			:Integer;
begin

	if not app.msgBox(app.getErrorString(Do_You_Wish_To_Abort), app.getErrorString(Database_Purge), MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then
		return;
	endif;
	
	on Exception do app.handleDeletedObject (exception, request, gotException);
	
	request 	:= self.myCurrentRequest;
	controller	:= request.myProcessingController;
	
	if gotException then
		// invalid request
		return;
	endif;
	
	on Exception do app.handleDeletedObject (exception, controller, gotException);
	
	dummy := controller.edition;
	
	if gotException then
		return;
	endif;
	
	app.myTrxUA.trxUpdateAbortBGPProcessing(controller, app.myPassport);
end;</source>
        <access>protected</access>
    </JadeMethod>
